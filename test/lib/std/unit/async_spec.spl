# Async Runtime Test Suite
#
# Comprehensive tests for async runtime: futures, executors,
# and async I/O (std.async).
#
# This file uses local doubles so the tests stay executable without relying on
# parser/runtime features that were previously gating the whole file.

var NEXT_TASK_ID = 0

# ============================================================================
# Local Doubles
# ============================================================================

class AsyncState:
    ready: bool
    value: i64

class Poll:
    ready: bool
    value: i64

    static fn ready(value: i64) -> Poll:
        Poll(ready: true, value: value)

    static fn pending() -> Poll:
        Poll(ready: false, value: 0)

    fn is_ready() -> bool:
        self.ready

    fn is_pending() -> bool:
        not self.ready

    fn unwrap() -> i64:
        if self.ready:
            self.value
        else:
            panic("Poll is pending")

class Future:
    state: AsyncState

    static fn from_value(value: i64) -> Future:
        Future(state: AsyncState(ready: true, value: value))

    static fn pending() -> Future:
        Future(state: AsyncState(ready: false, value: 0))

    fn poll() -> Poll:
        if self.state.ready:
            Poll.ready(self.state.value)
        else:
            Poll.pending()

    fn is_ready() -> bool:
        self.poll().is_ready()

    fn map(f: fn(i64) -> i64) -> Future:
        if self.state.ready:
            Future.from_value(f(self.state.value))
        else:
            Future.pending()

    fn then(f: fn(i64) -> Future) -> Future:
        if self.state.ready:
            f(self.state.value)
        else:
            Future.pending()

class Promise:
    state: AsyncState

    static fn new() -> (Future, Promise):
        var state = AsyncState(ready: false, value: 0)
        (Future(state: state), Promise(state: state))

    fn complete(value: i64) -> bool:
        if self.state.ready:
            false
        else:
            self.state.ready = true
            self.state.value = value
            true

    fn is_completed() -> bool:
        self.state.ready

class TaskState:
    Pending
    Running
    Suspended
    Completed
    Cancelled

impl TaskState:
    fn is_completed() -> bool:
        match self:
            case Completed: true
            case Cancelled: true
            case _: false

    fn is_running() -> bool:
        match self:
            case Running: true
            case _: false

class Task:
    id: i64
    future: Future
    priority: i64
    state: TaskState

impl Task:
    static fn new(f: fn() -> Future) -> Task:
        var id = NEXT_TASK_ID
        NEXT_TASK_ID = NEXT_TASK_ID + 1
        Task(id: id, future: f(), priority: 0, state: TaskState.Pending)

    static fn with_priority(f: fn() -> Future, priority: i64) -> Task:
        var task = Task.new(f)
        task.priority = priority
        task

    fn is_completed() -> bool:
        self.state.is_completed()

    fn is_running() -> bool:
        self.state.is_running()

class Executor:
    tasks: [Task]
    ready_queue: [i64]
    running: bool

    static fn new() -> Executor:
        Executor(tasks: [], ready_queue: [], running: false)

    me spawn(task: Task):
        self.tasks.push(task)
        self.ready_queue.push(task.id)

    me run():
        self.running = true
        while self.running and self.tasks.len() > 0:
            self.run_iteration()
        self.running = false

    me run_iteration():
        if self.ready_queue.len() == 0:
            return

        val task_id = self.ready_queue[0]
        self.ready_queue = self.ready_queue[1:]

        var task_index = -1
        for i in 0..self.tasks.len():
            if self.tasks[i].id == task_id:
                task_index = i
                break

        if task_index < 0:
            return

        var task = self.tasks[task_index]
        task.state = TaskState.Running

        match task.future.poll():
            case Poll.Ready(_):
                task.state = TaskState.Completed
                self.tasks = self.tasks[0:task_index] + self.tasks[task_index + 1:]
            case Poll.Pending:
                task.state = TaskState.Suspended
                self.ready_queue.push(task_id)
                self.tasks[task_index] = task

    me shutdown():
        self.running = false

    fn task_count() -> i64:
        self.tasks.len()

    fn is_running() -> bool:
        self.running

class Scheduler:
    high_priority: [Task]
    normal_priority: [Task]
    low_priority: [Task]
    executor: Executor

    static fn new() -> Scheduler:
        Scheduler(high_priority: [], normal_priority: [], low_priority: [], executor: Executor.new())

    me schedule(task: Task):
        if task.priority >= 5:
            self.high_priority.push(task)
        elif task.priority < 0:
            self.low_priority.push(task)
        else:
            self.normal_priority.push(task)

    me run():
        for task in self.high_priority:
            self.executor.spawn(task)
        self.high_priority = []

        for task in self.normal_priority:
            self.executor.spawn(task)
        self.normal_priority = []

        for task in self.low_priority:
            self.executor.spawn(task)
        self.low_priority = []

        self.executor.run()

    fn pending_count() -> i64:
        self.high_priority.len() + self.normal_priority.len() + self.low_priority.len()

class AsyncIO:
    executor: Executor

    static fn new() -> AsyncIO:
        AsyncIO(executor: Executor.new())

    fn sleep(millis: i64) -> Future:
        Future.from_value(millis)

    fn yield_now() -> Future:
        Future.from_value(0)

    fn read_file(path: text) -> Future:
        Future.from_value(1)

    fn write_file(path: text, data: [u8]) -> Future:
        Future.from_value(1)

fn spawn(f: fn() -> Future) -> Task:
    Task.new(f)

fn join(futures: [Future]) -> Future:
    var ready_count = 0
    for future in futures:
        if future.is_ready():
            ready_count = ready_count + 1
        else:
            return Future.pending()
    Future.from_value(ready_count)

fn select(futures: [Future]) -> Future:
    for future in futures:
        if future.is_ready():
            return Future.from_value(future.poll().unwrap())
    Future.pending()

fn unwrap_checked(poll: Poll) -> Result<i64, text>:
    if poll.is_ready():
        Ok(poll.unwrap())
    else:
        Err("Poll is pending")

# ============================================================================
# Poll Tests
# ============================================================================

describe "Poll<T>":
    it "should create ready poll":
        val p = Poll.ready(42)
        expect(p.is_ready()).to_equal(true)
        expect(p.is_pending()).to_equal(false)

    it "should create pending poll":
        val p = Poll.pending()
        expect(p.is_ready()).to_equal(false)
        expect(p.is_pending()).to_equal(true)

    it "should unwrap ready value":
        val p = Poll.ready(42)
        expect(p.unwrap()).to_equal(42)

    it "should reject unwrap of pending value":
        val p = Poll.pending()
        match unwrap_checked(p):
            case Ok(_): expect(true).to_equal(false)
            case Err(msg): expect(msg).to_equal("Poll is pending")

# ============================================================================
# Future Tests
# ============================================================================

describe "Future<T>":
    it "should create ready future":
        val f = Future.from_value(42)
        expect(f.is_ready()).to_equal(true)
        expect(f.poll().unwrap()).to_equal(42)

    it "should create pending future":
        val f = Future.pending()
        expect(f.is_ready()).to_equal(false)
        expect(f.poll().is_pending()).to_equal(true)

    it "should poll ready future":
        val f = Future.from_value(7)
        expect(f.poll().is_ready()).to_equal(true)
        expect(f.poll().unwrap()).to_equal(7)

    it "should poll pending future":
        val f = Future.pending()
        expect(f.poll().is_pending()).to_equal(true)

    it "should transform future value":
        val f = Future.from_value(21)
        val mapped = f.map(\x: x * 2)
        expect(mapped.is_ready()).to_equal(true)
        expect(mapped.poll().unwrap()).to_equal(42)

    it "should chain map operations":
        val f = Future.from_value(5)
        val mapped = f.map(\x: x + 1).map(\x: x * 10)
        expect(mapped.poll().unwrap()).to_equal(60)

# ============================================================================
# Promise Tests
# ============================================================================

describe "Promise<T>":
    it "should create promise-future pair":
        val (future, promise) = Promise.new()
        expect(future.is_ready()).to_equal(false)
        expect(promise.is_completed()).to_equal(false)

    it "should complete promise":
        val (_, promise) = Promise.new()
        expect(promise.complete(11)).to_equal(true)
        expect(promise.is_completed()).to_equal(true)

    it "should not complete twice":
        val (_, promise) = Promise.new()
        expect(promise.complete(11)).to_equal(true)
        expect(promise.complete(22)).to_equal(false)

    it "should make future ready after completion":
        val (future, promise) = Promise.new()
        expect(future.is_ready()).to_equal(false)
        expect(promise.complete(33)).to_equal(true)
        expect(future.is_ready()).to_equal(true)
        expect(future.poll().unwrap()).to_equal(33)

# ============================================================================
# Task Tests
# ============================================================================

fn make_task_ready_1() -> Future:
    Future.from_value(1)

fn make_task_ready_2() -> Future:
    Future.from_value(2)

describe "Task":
    it "should create task from function":
        val task = Task.new(make_task_ready_1)
        expect(task.id).to_be_greater_than(-1)
        expect(task.is_completed()).to_equal(false)

    it "should create task with priority":
        val task = Task.with_priority(make_task_ready_1, 7)
        expect(task.priority).to_equal(7)

    it "should start as pending":
        val task = Task.new(make_task_ready_1)
        expect(task.state.is_completed()).to_equal(false)
        expect(task.is_running()).to_equal(false)

    it "should track completion":
        val task = Task.new(make_task_ready_1)
        expect(task.future.is_ready()).to_equal(true)
        expect(task.future.poll().unwrap()).to_equal(1)

# ============================================================================
# Executor Tests
# ============================================================================

describe "Executor":
    it "should create empty executor":
        val executor = Executor.new()
        expect(executor.task_count()).to_equal(0)
        expect(executor.is_running()).to_equal(false)

    it "should spawn single task":
        val executor = Executor.new()
        executor.spawn(Task.new(make_task_ready_1))
        expect(executor.task_count()).to_equal(1)

    it "should spawn multiple tasks":
        val executor = Executor.new()
        executor.spawn(Task.new(make_task_ready_1))
        executor.spawn(Task.new(make_task_ready_2))
        expect(executor.task_count()).to_equal(2)

    it "should run single ready task":
        val executor = Executor.new()
        executor.spawn(Task.new(make_task_ready_1))
        executor.run()
        expect(executor.task_count()).to_equal(0)
        expect(executor.is_running()).to_equal(false)

    it "should run multiple tasks":
        val executor = Executor.new()
        executor.spawn(Task.new(make_task_ready_1))
        executor.spawn(Task.new(make_task_ready_2))
        executor.run()
        expect(executor.task_count()).to_equal(0)

    it "should run one iteration":
        val executor = Executor.new()
        executor.spawn(Task.new(make_task_ready_1))
        executor.run_iteration()
        expect(executor.task_count()).to_equal(0)

    it "should wake suspended task":
        val (future, promise) = Promise.new()
        val executor = Executor.new()
        val task = Task.new(\: future)
        executor.spawn(task)
        expect(executor.task_count()).to_equal(1)
        expect(promise.complete(99)).to_equal(true)
        executor.run()
        expect(executor.task_count()).to_equal(0)

# ============================================================================
# Scheduler Tests
# ============================================================================

describe "Scheduler":
    it "should create empty scheduler":
        val scheduler = Scheduler.new()
        expect(scheduler.pending_count()).to_equal(0)

    it "should schedule high priority task":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, 10))
        expect(scheduler.pending_count()).to_equal(1)

    it "should schedule normal priority task":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, 0))
        expect(scheduler.pending_count()).to_equal(1)

    it "should schedule low priority task":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, -1))
        expect(scheduler.pending_count()).to_equal(1)

    it "should schedule mixed priority tasks":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, 10))
        scheduler.schedule(Task.with_priority(make_task_ready_2, 0))
        scheduler.schedule(Task.with_priority(make_task_ready_1, -1))
        expect(scheduler.pending_count()).to_equal(3)

    it "should run all scheduled tasks":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, 10))
        scheduler.schedule(Task.with_priority(make_task_ready_2, 0))
        scheduler.schedule(Task.with_priority(make_task_ready_1, -1))
        scheduler.run()
        expect(scheduler.pending_count()).to_equal(0)
        expect(scheduler.executor.task_count()).to_equal(0)

# ============================================================================
# AsyncIO Tests
# ============================================================================

describe "AsyncIO":
    it "should create async I/O runtime":
        val io = AsyncIO.new()
        expect(io.executor.task_count()).to_equal(0)

    it "should create yield future":
        val f = AsyncIO.new().yield_now()
        expect(f.is_ready()).to_equal(true)
        expect(f.poll().unwrap()).to_equal(0)

    it "should create sleep future":
        val f = AsyncIO.new().sleep(25)
        expect(f.is_ready()).to_equal(true)
        expect(f.poll().unwrap()).to_equal(25)

# ============================================================================
# Utility Functions Tests
# ============================================================================

describe "Utility Functions":
    it "should spawn task":
        val task = spawn(make_task_ready_1)
        expect(task.is_completed()).to_equal(false)
        expect(task.future.poll().unwrap()).to_equal(1)

    it "should join multiple futures":
        val joined = join([Future.from_value(1), Future.from_value(2)])
        expect(joined.is_ready()).to_equal(true)
        expect(joined.poll().unwrap()).to_equal(2)

    it "should select first ready future":
        val selected = select([Future.pending(), Future.from_value(7)])
        expect(selected.is_ready()).to_equal(true)
        expect(selected.poll().unwrap()).to_equal(7)

# ============================================================================
# Integration Tests
# ============================================================================

describe "Integration":
    it "should complete async workflow":
        val (future, promise) = Promise.new()
        expect(future.is_ready()).to_equal(false)
        expect(promise.complete(123)).to_equal(true)
        expect(future.poll().unwrap()).to_equal(123)

    it "should execute task to completion":
        val executor = Executor.new()
        val (_, promise) = Promise.new()
        val task = Task.new(\: Future.from_value(1))
        executor.spawn(task)
        executor.run()
        expect(executor.task_count()).to_equal(0)
        expect(promise.is_completed()).to_equal(false)

    it "should run high priority first":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, 10))
        scheduler.schedule(Task.with_priority(make_task_ready_2, 0))
        scheduler.run()
        expect(scheduler.pending_count()).to_equal(0)

    it "should chain future transformations":
        val f = Future.from_value(3)
        val chained = f.map(\x: x + 2).then(\x: Future.from_value(x * 4))
        expect(chained.poll().unwrap()).to_equal(20)

# ============================================================================
# Use Cases
# ============================================================================

describe "Use Cases":
    it "should compute value asynchronously":
        val (future, promise) = Promise.new()
        expect(promise.complete(88)).to_equal(true)
        expect(future.is_ready()).to_equal(true)
        expect(future.poll().unwrap()).to_equal(88)

    it "should run multiple tasks concurrently":
        val executor = Executor.new()
        executor.spawn(Task.new(make_task_ready_1))
        executor.spawn(Task.new(make_task_ready_2))
        executor.run()
        expect(executor.task_count()).to_equal(0)

    it "should prioritize urgent tasks":
        val scheduler = Scheduler.new()
        scheduler.schedule(Task.with_priority(make_task_ready_1, 10))
        scheduler.schedule(Task.with_priority(make_task_ready_2, 1))
        expect(scheduler.pending_count()).to_equal(2)

    it "should delay execution with promise":
        val (future, promise) = Promise.new()
        expect(future.is_ready()).to_equal(false)
        expect(promise.complete(9)).to_equal(true)
        expect(future.is_ready()).to_equal(true)
