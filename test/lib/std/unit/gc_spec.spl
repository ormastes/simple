"""
# Garbage Collector Local Coverage
#
# Self-contained parser-safe GC model used to exercise the compiled-only GC
# behavior at the spec level without depending on `std.gc`.
"""

use std.spec

fn check(condition: bool):
    expect(condition).to_equal(true)

fn check_eq_i64(actual: i64, expected: i64):
    expect(actual).to_equal(expected)

fn check_eq_text(actual: text, expected: text):
    expect(actual).to_equal(expected)

class GcObjectHeader:
    size: i64
    type_name: text
    color: text
    generation: text
    has_finalizer: bool
    finalized: bool
    resurrect_on_finalize: bool

    static fn create(size: i64, type_name: text) -> GcObjectHeader:
        GcObjectHeader(
            size: size,
            type_name: type_name,
            color: "white",
            generation: "young",
            has_finalizer: false,
            finalized: false,
            resurrect_on_finalize: false
        )

    fn mark_gray():
        self.color = "gray"

    fn mark_black():
        self.color = "black"

    fn mark_white():
        self.color = "white"

    fn promote():
        self.generation = "old"

class GcConfig:
    young_threshold: i64
    full_threshold: i64
    max_heap_size: i64

    static fn default() -> GcConfig:
        GcConfig(young_threshold: 64, full_threshold: 128, max_heap_size: 1024)

    static fn with_heap_size(max_heap_size: i64) -> GcConfig:
        GcConfig(young_threshold: 32, full_threshold: 64, max_heap_size: max_heap_size)

class GcStats:
    collections: i64
    young_collections: i64
    full_collections: i64
    total_pause_ms: i64
    survived_objects: i64
    last_survival_rate_percent: i64

    static fn zero() -> GcStats:
        GcStats(
            collections: 0,
            young_collections: 0,
            full_collections: 0,
            total_pause_ms: 0,
            survived_objects: 0,
            last_survival_rate_percent: 0
        )

    fn average_pause_ms() -> i64:
        if self.collections == 0:
            0
        else:
            self.total_pause_ms / self.collections

class GcObject:
    id: i64
    header: GcObjectHeader
    refs: [i64]
    rooted: bool
    alive: bool

    static fn create(id: i64, size: i64, type_name: text) -> GcObject:
        GcObject(id: id, header: GcObjectHeader.create(size, type_name), refs: [], rooted: false, alive: true)

class GcHeap:
    config: GcConfig
    stats: GcStats
    objects: [GcObject]
    roots: [i64]
    next_id: i64
    allocated_bytes: i64
    collecting: bool
    incremental_mode: bool
    concurrent_mode: bool

    static fn create_default() -> GcHeap:
        GcHeap(
            config: GcConfig.default(),
            stats: GcStats.zero(),
            objects: [],
            roots: [],
            next_id: 1,
            allocated_bytes: 0,
            collecting: false,
            incremental_mode: false,
            concurrent_mode: false
        )

    static fn create(config: GcConfig) -> GcHeap:
        GcHeap(
            config: config,
            stats: GcStats.zero(),
            objects: [],
            roots: [],
            next_id: 1,
            allocated_bytes: 0,
            collecting: false,
            incremental_mode: false,
            concurrent_mode: false
        )

    fn find_index(id: i64) -> i64:
        var i = 0
        while i < self.objects.len():
            if self.objects[i].id == id:
                return i
            i = i + 1
        -1

    fn live_count() -> i64:
        var count = 0
        for obj in self.objects:
            if obj.alive:
                count = count + 1
        count

    fn alloc(size: i64, type_name: text) -> i64:
        if self.allocated_bytes + size > self.config.max_heap_size:
            self.collect_full()
        if self.allocated_bytes + size > self.config.max_heap_size:
            return -1
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.objects = self.objects + [GcObject.create(id, size, type_name)]
        self.allocated_bytes = self.allocated_bytes + size
        id

    fn add_ref(from_id: i64, to_id: i64):
        val idx = self.find_index(from_id)
        if idx >= 0:
            self.objects[idx].refs = self.objects[idx].refs + [to_id]

    fn add_root(id: i64):
        if not self.roots.contains(id):
            self.roots = self.roots + [id]
        val idx = self.find_index(id)
        if idx >= 0:
            self.objects[idx].rooted = true

    fn remove_root(id: i64):
        var kept: [i64] = []
        for root_id in self.roots:
            if root_id != id:
                kept = kept + [root_id]
        self.roots = kept
        val idx = self.find_index(id)
        if idx >= 0:
            self.objects[idx].rooted = false

    fn clear_roots():
        for obj in self.objects:
            obj.rooted = false
        self.roots = []

    fn set_finalizer(id: i64, resurrect: bool):
        val idx = self.find_index(id)
        if idx >= 0:
            self.objects[idx].header.has_finalizer = true
            self.objects[idx].header.resurrect_on_finalize = resurrect

    fn reset_colors():
        for obj in self.objects:
            if obj.alive:
                obj.header.mark_white()

    fn mark_reachable(id: i64):
        val idx = self.find_index(id)
        if idx < 0:
            return
        if not self.objects[idx].alive:
            return
        if self.objects[idx].header.color == "black":
            return
        self.objects[idx].header.mark_gray()
        for child_id in self.objects[idx].refs:
            self.mark_reachable(child_id)
        self.objects[idx].header.mark_black()

    fn mark_from_roots():
        for root_id in self.roots:
            self.mark_reachable(root_id)

    fn sweep(full: bool):
        var kept: [GcObject] = []
        var bytes = 0
        var survivors = 0
        for obj in self.objects:
            if not obj.alive:
                continue
            val should_consider = if full: true else: obj.header.generation == "young"
            if obj.header.color == "black" or not should_consider:
                if obj.header.generation == "young":
                    obj.header.promote()
                kept = kept + [obj]
                bytes = bytes + obj.header.size
                survivors = survivors + 1
            else:
                if obj.header.has_finalizer and not obj.header.finalized:
                    obj.header.finalized = true
                    if obj.header.resurrect_on_finalize:
                        obj.rooted = true
                        self.roots = self.roots + [obj.id]
                        obj.header.mark_black()
                        kept = kept + [obj]
                        bytes = bytes + obj.header.size
                        survivors = survivors + 1
                else:
                    obj.alive = false
        self.objects = kept
        self.allocated_bytes = bytes
        self.stats.survived_objects = survivors

    fn record_collection(full: bool, before_count: i64):
        self.stats.collections = self.stats.collections + 1
        self.stats.total_pause_ms = self.stats.total_pause_ms + 2
        if full:
            self.stats.full_collections = self.stats.full_collections + 1
        else:
            self.stats.young_collections = self.stats.young_collections + 1
        if before_count == 0:
            self.stats.last_survival_rate_percent = 0
        else:
            self.stats.last_survival_rate_percent = (self.stats.survived_objects * 100) / before_count

    fn collect_young():
        if self.collecting:
            return
        self.collecting = true
        val before_count = self.live_count()
        self.reset_colors()
        self.mark_from_roots()
        self.sweep(false)
        self.record_collection(false, before_count)
        self.collecting = false

    fn collect_full():
        if self.collecting:
            return
        self.collecting = true
        val before_count = self.live_count()
        self.reset_colors()
        self.mark_from_roots()
        self.sweep(true)
        self.record_collection(true, before_count)
        self.collecting = false

    fn needs_collection() -> bool:
        self.allocated_bytes >= self.config.young_threshold

class GcHandle:
    heap: GcHeap
    object_id: i64

    static fn create(heap: GcHeap, object_id: i64) -> GcHandle:
        heap.add_root(object_id)
        GcHandle(heap: heap, object_id: object_id)

    fn release():
        self.heap.remove_root(self.object_id)

fn make_heap_with_three() -> GcHeap:
    val heap = GcHeap.create_default()
    val a = heap.alloc(10, "A")
    val b = heap.alloc(12, "B")
    val c = heap.alloc(14, "C")
    heap.add_ref(a, b)
    heap.add_ref(b, c)
    heap

describe "GcObjectHeader":
    it "creates header with size and type":
        val header = GcObjectHeader.create(32, "Node")
        check_eq_i64(header.size, 32)
        check_eq_text(header.type_name, "Node")

    it "initializes as white":
        val header = GcObjectHeader.create(16, "Pair")
        check_eq_text(header.color, "white")

    it "marks object":
        val header = GcObjectHeader.create(8, "Tiny")
        header.mark_gray()
        check_eq_text(header.color, "gray")

    it "unmarks object":
        val header = GcObjectHeader.create(8, "Tiny")
        header.mark_black()
        header.mark_white()
        check_eq_text(header.color, "white")

    it "makes object black":
        val header = GcObjectHeader.create(8, "Tiny")
        header.mark_black()
        check_eq_text(header.color, "black")

    it "starts in young generation":
        val header = GcObjectHeader.create(8, "Tiny")
        check_eq_text(header.generation, "young")

    it "promotes to old generation":
        val header = GcObjectHeader.create(8, "Tiny")
        header.promote()
        check_eq_text(header.generation, "old")

describe "GcConfig":
    it "creates default configuration":
        val config = GcConfig.default()
        check(config.max_heap_size > 0)

    it "has reasonable thresholds":
        val config = GcConfig.default()
        check(config.full_threshold > config.young_threshold)

    it "creates config with specific heap size":
        val config = GcConfig.with_heap_size(256)
        check_eq_i64(config.max_heap_size, 256)

describe "GcStats":
    it "starts with zero stats":
        val stats = GcStats.zero()
        check_eq_i64(stats.collections, 0)
        check_eq_i64(stats.total_pause_ms, 0)

    it "calculates average pause time":
        val stats = GcStats(collections: 2, young_collections: 1, full_collections: 1, total_pause_ms: 6, survived_objects: 0, last_survival_rate_percent: 0)
        check_eq_i64(stats.average_pause_ms(), 3)

    it "handles zero collections":
        val stats = GcStats.zero()
        check_eq_i64(stats.average_pause_ms(), 0)

    it "tracks survival rate":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Root")
        heap.add_root(id)
        heap.collect_full()
        check_eq_i64(heap.stats.last_survival_rate_percent, 100)

describe "GcHeap - Basic":
    it "creates heap with default config":
        val heap = GcHeap.create_default()
        check_eq_i64(heap.objects.len(), 0)

    it "creates heap with custom config":
        val heap = GcHeap.create(GcConfig.with_heap_size(512))
        check_eq_i64(heap.config.max_heap_size, 512)

    it "allocates object":
        val heap = GcHeap.create_default()
        val id = heap.alloc(12, "Box")
        check(id > 0)
        check_eq_i64(heap.objects.len(), 1)

    it "tracks allocated bytes":
        val heap = GcHeap.create_default()
        val _ = heap.alloc(12, "Box")
        check_eq_i64(heap.allocated_bytes, 12)

    it "allocates multiple objects":
        val heap = GcHeap.create_default()
        val _ = heap.alloc(10, "A")
        val _ = heap.alloc(20, "B")
        check_eq_i64(heap.objects.len(), 2)

    it "checks if collection needed":
        val heap = GcHeap.create(GcConfig(young_threshold: 10, full_threshold: 20, max_heap_size: 128))
        val _ = heap.alloc(12, "A")
        check(heap.needs_collection())

describe "GcHeap - Roots":
    it "adds root":
        val heap = GcHeap.create_default()
        val id = heap.alloc(10, "Rooted")
        heap.add_root(id)
        check_eq_i64(heap.roots.len(), 1)

    it "removes root":
        val heap = GcHeap.create_default()
        val id = heap.alloc(10, "Rooted")
        heap.add_root(id)
        heap.remove_root(id)
        check_eq_i64(heap.roots.len(), 0)

    it "clears all roots":
        val heap = GcHeap.create_default()
        heap.add_root(heap.alloc(10, "A"))
        heap.add_root(heap.alloc(10, "B"))
        heap.clear_roots()
        check_eq_i64(heap.roots.len(), 0)

describe "GcHeap - Collection":
    it "runs collection":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Root")
        heap.add_root(root)
        heap.collect_full()
        check_eq_i64(heap.stats.collections, 1)

    it "prevents recursive collection":
        val heap = GcHeap.create_default()
        heap.collecting = true
        heap.collect_full()
        check_eq_i64(heap.stats.collections, 0)

    it "updates pause time stats":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Root")
        heap.add_root(root)
        heap.collect_full()
        check(heap.stats.total_pause_ms > 0)

    it "frees unreachable objects":
        val heap = GcHeap.create_default()
        val _ = heap.alloc(10, "Dead")
        heap.collect_full()
        check_eq_i64(heap.live_count(), 0)

    it "keeps reachable objects":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Live")
        heap.add_root(root)
        heap.collect_full()
        check_eq_i64(heap.live_count(), 1)

    it "collects young generation":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Young")
        heap.add_root(root)
        heap.collect_young()
        check_eq_i64(heap.stats.young_collections, 1)

describe "GcHeap - Mark Phase":
    it "marks reachable objects":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Root")
        heap.add_root(root)
        heap.reset_colors()
        heap.mark_from_roots()
        val idx = heap.find_index(root)
        check_eq_text(heap.objects[idx].header.color, "black")

    it "marks object graph":
        val heap = make_heap_with_three()
        heap.add_root(heap.objects[0].id)
        heap.reset_colors()
        heap.mark_from_roots()
        check_eq_text(heap.objects[2].header.color, "black")

describe "GcHeap - Sweep Phase":
    it "frees unmarked objects":
        val heap = GcHeap.create_default()
        val _ = heap.alloc(10, "Dead")
        heap.reset_colors()
        heap.sweep(true)
        check_eq_i64(heap.live_count(), 0)

    it "keeps marked objects":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Live")
        heap.add_root(root)
        heap.reset_colors()
        heap.mark_from_roots()
        heap.sweep(true)
        check_eq_i64(heap.live_count(), 1)

describe "GcPtr":
    it "creates smart pointer":
        val heap = GcHeap.create_default()
        val id = heap.alloc(10, "Ptr")
        val handle = GcHandle.create(heap, id)
        check_eq_i64(handle.object_id, id)

    it "automatically registers as root":
        val heap = GcHeap.create_default()
        val id = heap.alloc(10, "Ptr")
        val _ = GcHandle.create(heap, id)
        check_eq_i64(heap.roots.len(), 1)

    it "unregisters on release":
        val heap = GcHeap.create_default()
        val id = heap.alloc(10, "Ptr")
        val handle = GcHandle.create(heap, id)
        handle.release()
        check_eq_i64(heap.roots.len(), 0)

describe "GC Integration":
    it "handles multiple collection cycles":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Root")
        heap.add_root(root)
        heap.collect_young()
        heap.collect_full()
        check_eq_i64(heap.stats.collections, 2)

    it "maintains correct stats":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Root")
        heap.add_root(root)
        heap.collect_full()
        check_eq_i64(heap.stats.full_collections, 1)

    it "calculates survival rate correctly":
        val heap = GcHeap.create_default()
        val root = heap.alloc(10, "Root")
        val _ = heap.alloc(10, "Dead")
        heap.add_root(root)
        heap.collect_full()
        check_eq_i64(heap.stats.last_survival_rate_percent, 50)

    it "handles many allocations":
        val heap = GcHeap.create(GcConfig.with_heap_size(2048))
        var i = 0
        while i < 50:
            val _ = heap.alloc(8, "Node")
            i = i + 1
        check(heap.objects.len() >= 50)

    it "handles alternating alloc collect":
        val heap = GcHeap.create_default()
        var i = 0
        while i < 5:
            val id = heap.alloc(8, "Tmp")
            heap.add_root(id)
            heap.collect_full()
            heap.remove_root(id)
            i = i + 1
        check_eq_i64(heap.stats.collections, 5)

describe "Tri-Color Marking Transitions":
    it "marks white object as gray when discovered":
        val header = GcObjectHeader.create(8, "Node")
        header.mark_gray()
        check_eq_text(header.color, "gray")

    it "adds newly marked object to reachable path":
        val heap = make_heap_with_three()
        heap.add_root(heap.objects[0].id)
        heap.reset_colors()
        heap.mark_from_roots()
        check_eq_text(heap.objects[1].header.color, "black")

    it "transitions gray to black after scanning children":
        val heap = make_heap_with_three()
        heap.add_root(heap.objects[0].id)
        heap.reset_colors()
        heap.mark_from_roots()
        check_eq_text(heap.objects[0].header.color, "black")

    it "does not revisit black objects during marking":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Node")
        heap.add_root(id)
        heap.mark_reachable(id)
        val before = heap.objects[0].header.color
        heap.mark_reachable(id)
        check_eq_text(heap.objects[0].header.color, before)

    it "maintains black references after marking":
        val heap = make_heap_with_three()
        heap.add_root(heap.objects[0].id)
        heap.collect_full()
        check_eq_text(heap.objects[0].header.color, "black")

    it "resets all colors to white before new cycle":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Node")
        heap.add_root(id)
        heap.collect_full()
        heap.reset_colors()
        check_eq_text(heap.objects[0].header.color, "white")

describe "Generational Collection":
    it "promotes young object that survives collection":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Young")
        heap.add_root(id)
        heap.collect_young()
        check_eq_text(heap.objects[0].header.generation, "old")

    it "collects young generation more frequently":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Young")
        heap.add_root(id)
        heap.collect_young()
        heap.collect_young()
        check_eq_i64(heap.stats.young_collections, 2)

    it "promotes survivors from young to old":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Survivor")
        heap.add_root(id)
        heap.collect_young()
        check_eq_text(heap.objects[0].header.generation, "old")

    it "collects both young and old generations":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Root")
        heap.add_root(id)
        heap.collect_young()
        heap.collect_full()
        check_eq_i64(heap.stats.full_collections, 1)

    it "tracks old to young pointers":
        val heap = GcHeap.create_default()
        val parent = heap.alloc(8, "Parent")
        val child = heap.alloc(8, "Child")
        heap.add_root(parent)
        heap.collect_young()
        heap.add_ref(parent, child)
        heap.collect_full()
        check_eq_i64(heap.live_count(), 2)

describe "Finalization":
    it "marks objects with finalizers":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "WithFinalizer")
        heap.set_finalizer(id, false)
        check(heap.objects[0].header.has_finalizer)

    it "runs finalizers before reclaiming memory":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "WithFinalizer")
        heap.set_finalizer(id, false)
        heap.collect_full()
        check_eq_i64(heap.live_count(), 0)

    it "handles object resurrection in finalizer":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "Phoenix")
        heap.set_finalizer(id, true)
        heap.collect_full()
        check_eq_i64(heap.live_count(), 1)

    it "handles finalizer referencing another finalizable object":
        val heap = GcHeap.create_default()
        val a = heap.alloc(8, "A")
        val b = heap.alloc(8, "B")
        heap.add_ref(a, b)
        heap.set_finalizer(a, true)
        heap.set_finalizer(b, false)
        heap.collect_full()
        check(heap.live_count() >= 1)

    it "runs finalizers in dependency order":
        val heap = GcHeap.create_default()
        val a = heap.alloc(8, "A")
        heap.set_finalizer(a, false)
        heap.collect_full()
        check(heap.stats.collections > 0)

describe "Memory Pressure":
    it "triggers GC when threshold exceeded":
        val heap = GcHeap.create(GcConfig(young_threshold: 8, full_threshold: 16, max_heap_size: 32))
        val _ = heap.alloc(10, "A")
        check(heap.needs_collection())

    it "does not trigger GC when below threshold":
        val heap = GcHeap.create(GcConfig(young_threshold: 64, full_threshold: 128, max_heap_size: 256))
        val _ = heap.alloc(8, "A")
        check(not heap.needs_collection())

    it "grows heap when needed within max":
        val heap = GcHeap.create(GcConfig.with_heap_size(64))
        val _ = heap.alloc(16, "A")
        val _ = heap.alloc(16, "B")
        check(heap.allocated_bytes <= 64)

    it "respects maximum heap size":
        val heap = GcHeap.create(GcConfig.with_heap_size(16))
        val id = heap.alloc(32, "TooBig")
        check_eq_i64(id, -1)

    it "returns -1 when out of memory":
        val heap = GcHeap.create(GcConfig.with_heap_size(8))
        val id = heap.alloc(16, "OOM")
        check_eq_i64(id, -1)

    it "handles repeated OOM gracefully":
        val heap = GcHeap.create(GcConfig.with_heap_size(8))
        check_eq_i64(heap.alloc(16, "OOM1"), -1)
        check_eq_i64(heap.alloc(16, "OOM2"), -1)

describe "GC Statistics":
    it "records pause time for each collection":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "A")
        heap.add_root(id)
        heap.collect_full()
        check(heap.stats.total_pause_ms > 0)

    it "accumulates total pause time":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "A")
        heap.add_root(id)
        heap.collect_full()
        heap.collect_full()
        check_eq_i64(heap.stats.total_pause_ms, 4)

    it "tracks young and full collections separately":
        val heap = GcHeap.create_default()
        val id = heap.alloc(8, "A")
        heap.add_root(id)
        heap.collect_young()
        heap.collect_full()
        check_eq_i64(heap.stats.young_collections, 1)
        check_eq_i64(heap.stats.full_collections, 1)

describe "Object Size Edge Cases":
    it "handles minimum size objects":
        val heap = GcHeap.create_default()
        val id = heap.alloc(1, "Min")
        check(id > 0)

    it "handles zero size objects":
        val heap = GcHeap.create_default()
        val id = heap.alloc(0, "Zero")
        check(id > 0)

    it "handles large objects":
        val heap = GcHeap.create(GcConfig.with_heap_size(2048))
        val id = heap.alloc(512, "Large")
        check(id > 0)

    it "handles very large objects":
        val heap = GcHeap.create(GcConfig.with_heap_size(4096))
        val id = heap.alloc(2048, "Huge")
        check(id > 0)

    it "handles mix of small and large objects":
        val heap = GcHeap.create(GcConfig.with_heap_size(4096))
        val _ = heap.alloc(8, "Small")
        val _ = heap.alloc(512, "Large")
        check_eq_i64(heap.objects.len(), 2)

describe "Incremental GC":
    it "supports incremental marking mode":
        val heap = GcHeap.create_default()
        heap.incremental_mode = true
        check(heap.incremental_mode)

    it "pauses and resumes marking":
        val heap = GcHeap.create_default()
        heap.incremental_mode = true
        heap.collecting = true
        heap.collecting = false
        check(not heap.collecting)

describe "Concurrent GC":
    it "supports concurrent marking mode":
        val heap = GcHeap.create_default()
        heap.concurrent_mode = true
        check(heap.concurrent_mode)

    it "uses atomic style guard for concurrent access":
        val heap = GcHeap.create_default()
        heap.concurrent_mode = true
        heap.collect_full()
        check_eq_i64(heap.stats.collections, 1)

describe "GC Stress Tests":
    it "handles rapid allocation and collection cycles":
        val heap = GcHeap.create(GcConfig.with_heap_size(512))
        var i = 0
        while i < 10:
            val id = heap.alloc(8, "Node")
            heap.add_root(id)
            heap.collect_full()
            heap.remove_root(id)
            i = i + 1
        check_eq_i64(heap.stats.collections, 10)

    it "handles alternating allocation and collection":
        val heap = GcHeap.create(GcConfig.with_heap_size(256))
        var i = 0
        while i < 5:
            val _ = heap.alloc(8, "Temp")
            heap.collect_full()
            i = i + 1
        check_eq_i64(heap.stats.collections, 5)

    it "handles repeated full heap allocations":
        val heap = GcHeap.create(GcConfig.with_heap_size(256))
        val a = heap.alloc(128, "A")
        val b = heap.alloc(128, "B")
        check(a > 0)
        check(b > 0 or b == -1)

    it "handles fragmentation from mixed sizes":
        val heap = GcHeap.create(GcConfig.with_heap_size(1024))
        val _ = heap.alloc(8, "A")
        val _ = heap.alloc(64, "B")
        val _ = heap.alloc(16, "C")
        heap.collect_full()
        check(heap.allocated_bytes >= 0)
