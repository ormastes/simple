#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.text_advanced.*


fn main():
    # @cover src/lib/common/text_advanced.spl 80%
    """
    # Text Helpers Specification
    
    **Feature IDs:** #TEXT-P1, #TEXT-P2
    **Category:** Stdlib
    **Difficulty:** 2/5
    **Status:** Implemented
    **Requirements:** doc/02_requirements/feature/stdlib_helpers.md
    
    ## Overview
    
    Tests for text helper functions: P1 case conversions (to_kebab_case,
    to_pascal_case, to_screaming_snake), character transforms (chars_map,
    tr, gsub), tokenization (split_n, cut, contains_any), and P2 string
    predicates, character ops, search, replacement, radix parsing, quote.
    """


    # ============================================================================
    # P1: Case Conversion
    # ============================================================================

    describe "to_kebab_case":
        it "converts PascalCase":
            expect to_kebab_case("HelloWorld") == "hello-world"

        it "converts snake_case":
            expect to_kebab_case("hello_world") == "hello-world"

        it "converts camelCase":
            expect to_kebab_case("helloWorld") == "hello-world"

        it "handles SCREAMING_SNAKE":
            expect to_kebab_case("HELLO_WORLD") == "hello-world"

        it "preserves existing kebab":
            expect to_kebab_case("already-kebab") == "already-kebab"

        it "handles empty":
            expect to_kebab_case("") == ""

    describe "to_pascal_case":
        it "converts snake_case":
            expect to_pascal_case("hello_world") == "HelloWorld"

        it "converts kebab-case":
            expect to_pascal_case("hello-world") == "HelloWorld"

        it "handles empty":
            expect to_pascal_case("") == ""

    describe "to_screaming_snake":
        it "converts camelCase":
            expect to_screaming_snake("helloWorld") == "HELLO_WORLD"

        it "converts PascalCase":
            expect to_screaming_snake("HelloWorld") == "HELLO_WORLD"

        it "handles empty":
            expect to_screaming_snake("") == ""

    # ============================================================================
    # P1: Character Transforms
    # ============================================================================

    describe "chars_map":
        it "maps each character":
            expect chars_map("hello", \c: c.upper()) == "HELLO"

        it "handles empty":
            expect chars_map("", \c: c) == ""

    describe "tr":
        it "transliterates characters":
            expect tr("hello", "elo", "ELO") == "hELLO"

        it "maps character by character":
            expect tr("aabbcc", "abc", "xyz") == "xxyyzz"

        it "handles empty source":
            expect tr("", "a", "b") == ""

        it "handles empty from":
            expect tr("hello", "", "") == "hello"

    describe "gsub":
        it "replaces with callback":
            expect gsub("hello world", "o", \m: m.upper()) == "hellO wOrld"

        it "handles no matches":
            expect gsub("hello", "x", \m: "Y") == "hello"

        it "handles empty string":
            expect gsub("", "a", \m: "b") == ""

    # ============================================================================
    # P1: Tokenization
    # ============================================================================

    describe "split_n":
        it "splits into at most n parts":
            val result = split_n("a,b,c,d", ",", 2)
            expect result.len() == 2
            expect result[0] == "a"
            expect result[1] == "b,c,d"

        it "returns full split if fewer than n parts":
            val result = split_n("hello", ",", 5)
            expect result.len() == 1
            expect result[0] == "hello"

    describe "cut":
        it "cuts at separator":
            val (before, after, found) = cut("hello=world", "=")
            expect before == "hello"
            expect after == "world"
            expect found == true

        it "returns false when not found":
            val (before, after, found) = cut("hello", "=")
            expect before == "hello"
            expect after == ""
            expect found == false

    describe "contains_any":
        it "finds vowels":
            expect contains_any("hello", "aeiou") == true

        it "finds no match":
            expect contains_any("xyz", "aeiou") == false

        it "handles empty string":
            expect contains_any("", "abc") == false

        it "handles empty chars":
            expect contains_any("hello", "") == false

    # ============================================================================
    # P2: String Predicates
    # ============================================================================

    describe "is_ascii":
        it "returns true for ASCII":
            expect is_ascii("hello") == true

        it "returns true for empty":
            expect is_ascii("") == true

    describe "is_upper":
        it "returns true for uppercase":
            expect is_upper("HELLO") == true

        it "returns false for mixed":
            expect is_upper("Hello") == false

        it "ignores non-alpha":
            expect is_upper("HELLO 123") == true

        it "returns false for empty":
            expect is_upper("") == false

    describe "is_lower":
        it "returns true for lowercase":
            expect is_lower("hello") == true

        it "returns false for mixed":
            expect is_lower("Hello") == false

        it "ignores non-alpha":
            expect is_lower("hello 123") == true

        it "returns false for empty":
            expect is_lower("") == false

    describe "is_printable":
        it "returns true for printable":
            expect is_printable("hello world") == true

        it "returns true for empty":
            expect is_printable("") == true

    describe "is_title":
        it "returns true for title case":
            expect is_title("Hello World") == true

        it "returns false for lowercase start":
            expect is_title("hello World") == false

        it "returns true for single word":
            expect is_title("Hello") == true

        it "returns false for empty":
            expect is_title("") == false

    # ============================================================================
    # P2: Character Operations
    # ============================================================================

    describe "delete_chars":
        it "deletes specified characters":
            expect delete_chars("hello world", "lo") == "he wrd"

        it "handles empty chars":
            expect delete_chars("abc", "") == "abc"

        it "handles empty string":
            expect delete_chars("", "abc") == ""

    # ============================================================================
    # P2: Advanced Search
    # ============================================================================

    describe "index_of_any":
        it "finds first vowel":
            expect index_of_any("hello", "aeiou") == 1

        it "returns nil when not found":
            expect index_of_any("xyz", "aeiou") == nil

        it "handles empty":
            expect index_of_any("", "abc") == nil

    describe "index_of_func":
        it "finds by predicate":
            expect index_of_func("hello", \c: c == "l") == 2

        it "returns nil when not found":
            expect index_of_func("hello", \c: c == "z") == nil

    describe "last_index_of_func":
        it "finds last by predicate":
            expect last_index_of_func("hello", \c: c == "l") == 3

        it "returns nil when not found":
            expect last_index_of_func("hello", \c: c == "z") == nil

    describe "fields_func":
        it "splits by custom predicate":
            val result = fields_func("hello world\tfoo", \c: c == " " or c == "\t")
            expect result.len() == 3
            expect result[0] == "hello"
            expect result[1] == "world"
            expect result[2] == "foo"

        it "handles consecutive separators":
            val result = fields_func("a  b", \c: c == " ")
            expect result.len() == 2

    # ============================================================================
    # P2: Replacement
    # ============================================================================

    describe "replace_n":
        it "replaces first n occurrences":
            expect replace_n("aaa", "a", "b", 2) == "bba"

        it "replaces first only":
            expect replace_n("hello", "l", "r", 1) == "herlo"

        it "handles no match":
            expect replace_n("hello", "x", "y", 5) == "hello"

    describe "multi_replace":
        it "replaces multiple pairs":
            val result = multi_replace("hello world", [("hello", "hi"), ("world", "earth")])
            expect result == "hi earth"

        it "handles no pairs":
            expect multi_replace("hello", []) == "hello"

    # ============================================================================
    # P2: String Insertion
    # ============================================================================

    describe "text_insert":
        it "inserts at middle":
            expect text_insert("hello", 2, "XY") == "heXYllo"

        it "inserts at beginning":
            expect text_insert("hello", 0, "AB") == "ABhello"

        it "inserts at end":
            expect text_insert("hello", 5, "!") == "hello!"

    # ============================================================================
    # P2: Radix Parsing
    # ============================================================================

    describe "hex_to_int":
        it "parses hex":
            expect hex_to_int("ff") == 255

        it "parses with 0x prefix":
            expect hex_to_int("0xFF") == 255

        it "parses simple hex":
            expect hex_to_int("10") == 16

        it "returns nil for invalid":
            expect hex_to_int("xyz") == nil

    describe "oct_to_int":
        it "parses octal":
            expect oct_to_int("77") == 63

        it "parses with prefix":
            expect oct_to_int("0o77") == 63

    describe "to_int_radix":
        it "parses binary":
            expect to_int_radix("1010", 2) == 10

        it "parses hex":
            expect to_int_radix("ff", 16) == 255

        it "parses octal":
            expect to_int_radix("77", 8) == 63

        it "parses base 36":
            expect to_int_radix("z", 36) == 35

        it "returns nil for invalid base":
            expect to_int_radix("10", 1) == nil

        it "returns nil for empty":
            expect to_int_radix("", 10) == nil

    # ============================================================================
    # P2: Quote
    # ============================================================================

    describe "text_quote":
        it "quotes simple string":
            expect text_quote("hello") == "\"hello\""

    # ============================================================================
    # P2: Split After
    # ============================================================================

    describe "split_after":
        it "keeps separator at end of each part":
            val result = split_after("a,b,c", ",")
            expect result.len() == 3
            expect result[0] == "a,"
            expect result[1] == "b,"
            expect result[2] == "c"

        it "handles no separator found":
            val result = split_after("hello", ",")
            expect result.len() == 1
            expect result[0] == "hello"

    # ============================================================================
    # P2: Expand Tabs
    # ============================================================================

    describe "expandtabs":
        it "expands tabs to spaces":
            expect expandtabs("a\tb", 4) == "a   b"

        it "handles no tabs":
            expect expandtabs("hello", 4) == "hello"