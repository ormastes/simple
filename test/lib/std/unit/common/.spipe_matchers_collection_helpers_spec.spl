# @cover src/lib/common/collection_helpers.spl 80%
"""
# Collection Helpers Specification

**Feature IDs:** #COLL-P1
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** doc/02_requirements/feature/stdlib_helpers.md

## Overview

Tests for Phase 1 collection helper functions: sort_by_key, min_by_key,
max_by_key, flat_map, compact_map, insert_at, remove_at, arr_pop,
arr_shift, reject, none, one, find_last, find_last_index, at, arr_clone,
each_slice, chunk, pairwise, sum_by, product, tally, compress,
reduce_right, values_at, fill, replace_range, zip_longest, slice_when,
chunk_while, top_n, bottom_n, each_cons, arr_compare, dedup_by.
"""

use std.spipe.*
use std.collection_helpers.*

# ============================================================================
# Sort / Min / Max by Key
# ============================================================================

describe "sort_by_key":
    it "sorts strings by length":
        val result = sort_by_key(["banana", "apple", "fig"], &:len)
        expect result[0] == "fig"
        expect result[1] == "apple"
        expect result[2] == "banana"

    it "returns empty for empty array":
        val result = sort_by_key([], &:len)
        expect result.len() == 0

    it "returns single-element array unchanged":
        val result = sort_by_key(["only"], &:len)
        expect result[0] == "only"

describe "min_by_key":
    it "finds shortest string":
        val result = min_by_key(["banana", "apple", "fig"], &:len)
        expect result == "fig"

    it "returns nil for empty array":
        val result = min_by_key([], &:len)
        expect result == nil

describe "max_by_key":
    it "finds longest string":
        val result = max_by_key(["banana", "apple", "fig"], &:len)
        expect result == "banana"

    it "returns nil for empty array":
        val result = max_by_key([], &:len)
        expect result == nil

# ============================================================================
# Flat Map / Compact Map
# ============================================================================

describe "flat_map":
    it "maps and flattens one level":
        val result = flat_map([1, 2, 3], \x: [x, x * 10])
        expect result.len() == 6
        expect result[0] == 1
        expect result[1] == 10
        expect result[2] == 2
        expect result[3] == 20

    it "handles empty arrays":
        val result = flat_map([], \x: [x])
        expect result.len() == 0

describe "compact_map":
    it "maps and removes nils":
        val result = compact_map([1, 2, 3, 4], \x: if x % 2 == 0: x * 10 else: nil)
        expect result.len() == 2
        expect result[0] == 20
        expect result[1] == 40

    it "returns empty when all nil":
        val result = compact_map([1, 3, 5], \x: if x % 2 == 0: x else: nil)
        expect result.len() == 0

# ============================================================================
# Insert / Remove / Pop / Shift
# ============================================================================

describe "insert_at":
    it "inserts at middle":
        val result = insert_at([1, 2, 3], 1, 99)
        expect result.len() == 4
        expect result[0] == 1
        expect result[1] == 99
        expect result[2] == 2

    it "inserts at beginning":
        val result = insert_at([1, 2], 0, 99)
        expect result[0] == 99
        expect result.len() == 3

    it "inserts at end":
        val result = insert_at([1, 2], 2, 99)
        expect result[2] == 99
        expect result.len() == 3

describe "remove_at":
    it "removes at middle":
        val result = remove_at([10, 20, 30], 1)
        expect result.len() == 2
        expect result[0] == 10
        expect result[1] == 30

    it "returns original for out of bounds":
        val result = remove_at([1, 2, 3], 5)
        expect result.len() == 3

describe "arr_pop":
    it "removes and returns last element":
        val (rest, last) = arr_pop([1, 2, 3])
        expect last == 3
        expect rest.len() == 2
        expect rest[0] == 1
        expect rest[1] == 2

    it "returns nil for empty array":
        val (rest, last) = arr_pop([])
        expect last == nil
        expect rest.len() == 0

describe "arr_shift":
    it "removes and returns first element":
        val (rest, first) = arr_shift([1, 2, 3])
        expect first == 1
        expect rest.len() == 2
        expect rest[0] == 2

    it "returns nil for empty array":
        val (rest, first) = arr_shift([])
        expect first == nil

# ============================================================================
# Reject / None / One
# ============================================================================

describe "reject":
    it "keeps elements not matching predicate":
        val result = reject([1, 2, 3, 4, 5], \x: x % 2 == 0)
        expect result.len() == 3
        expect result[0] == 1
        expect result[1] == 3
        expect result[2] == 5

    it "keeps all when nothing matches":
        val result = reject([1, 3, 5], \x: x % 2 == 0)
        expect result.len() == 3

describe "none":
    it "returns true when no match":
        expect none([1, 3, 5], \x: x % 2 == 0) == true

    it "returns false when any match":
        expect none([1, 2, 3], \x: x % 2 == 0) == false

    it "returns true for empty array":
        expect none([], \x: true) == true

describe "one":
    it "returns true for exactly one match":
        expect one([1, 2, 3], \x: x == 2) == true

    it "returns false for multiple matches":
        expect one([1, 2, 2], \x: x == 2) == false

    it "returns false for no matches":
        expect one([1, 3, 5], \x: x == 2) == false

# ============================================================================
# Find Last / Find Last Index
# ============================================================================

describe "find_last":
    it "finds last matching element":
        expect find_last([1, 2, 3, 4], \x: x % 2 == 0) == 4

    it "returns nil when none match":
        expect find_last([1, 3, 5], \x: x % 2 == 0) == nil

describe "find_last_index":
    it "finds index of last match":
        expect find_last_index([1, 2, 3, 2], \x: x == 2) == 3

    it "returns nil when none match":
        expect find_last_index([1, 3, 5], \x: x == 2) == nil

# ============================================================================
# At with Negative Index
# ============================================================================

describe "at":
    it "gets element by positive index":
        expect at([10, 20, 30], 0) == 10
        expect at([10, 20, 30], 2) == 30

    it "supports negative index":
        expect at([10, 20, 30], -1) == 30
        expect at([10, 20, 30], -2) == 20
        expect at([10, 20, 30], -3) == 10

    it "returns nil for out of bounds":
        expect at([10, 20, 30], 5) == nil
        expect at([10, 20, 30], -4) == nil

# ============================================================================
# Clone
# ============================================================================

describe "arr_clone":
    it "creates shallow copy":
        val original = [1, 2, 3]
        val copy = arr_clone(original)
        expect copy.len() == 3
        expect copy[0] == 1
        expect copy[1] == 2
        expect copy[2] == 3

    it "returns empty for empty":
        val copy = arr_clone([])
        expect copy.len() == 0

# ============================================================================
# Chunk / Each Slice / Each Cons
# ============================================================================

describe "chunk":
    it "splits into chunks":
        val result = chunk([1, 2, 3, 4, 5], 2)
        expect result.len() == 3
        expect result[0].len() == 2
        expect result[0][0] == 1
        expect result[0][1] == 2
        expect result[2].len() == 1
        expect result[2][0] == 5

    it "returns empty for empty array":
        val result = chunk([], 2)
        expect result.len() == 0

    it "returns empty for zero chunk size":
        val result = chunk([1, 2, 3], 0)
        expect result.len() == 0

describe "pairwise":
    it "returns consecutive pairs":
        val result = pairwise([1, 2, 3, 4])
        expect result.len() == 3

    it "returns empty for single element":
        val result = pairwise([1])
        expect result.len() == 0

    it "returns empty for empty array":
        val result = pairwise([])
        expect result.len() == 0

# ============================================================================
# Sum By / Product
# ============================================================================

describe "sum_by":
    it "sums extracted values":
        expect sum_by(["hi", "hello", "hey"], &:len) == 10

    it "returns 0 for empty":
        expect sum_by([], &:len) == 0

describe "product":
    it "multiplies all elements":
        expect product([1, 2, 3, 4]) == 24

    it "returns 1 for empty":
        expect product([]) == 1

    it "handles single element":
        expect product([5]) == 5

# ============================================================================
# Tally
# ============================================================================

describe "tally":
    it "counts element frequencies":
        val result = tally(["a", "b", "a", "c", "b", "a"])
        expect result.len() == 3

    it "returns empty for empty array":
        val result = tally([])
        expect result.len() == 0

# ============================================================================
# Compress / Values At / Fill
# ============================================================================

describe "compress":
    it "filters by boolean selectors":
        val result = compress(["a", "b", "c", "d"], [true, false, true, false])
        expect result.len() == 2
        expect result[0] == "a"
        expect result[1] == "c"

    it "handles shorter selector array":
        val result = compress(["a", "b", "c"], [true])
        expect result.len() == 1

describe "values_at":
    it "gets elements at specified indices":
        val result = values_at(["a", "b", "c", "d"], [0, 2, 3])
        expect result.len() == 3
        expect result[0] == "a"
        expect result[1] == "c"
        expect result[2] == "d"

describe "fill":
    it "fills array with value":
        val result = fill([1, 2, 3], 0)
        expect result.len() == 3
        expect result[0] == 0
        expect result[1] == 0
        expect result[2] == 0

# ============================================================================
# Reduce Right
# ============================================================================

describe "reduce_right":
    it "folds from right to left":
        val result = reduce_right(["a", "b", "c"], "", \acc, x: acc + x)
        expect result == "cba"

    it "returns init for empty":
        val result = reduce_right([], 0, \acc, x: acc + x)
        expect result == 0

# ============================================================================
# Replace Range / Zip Longest
# ============================================================================

describe "replace_range":
    it "replaces range of elements":
        val result = replace_range([1, 2, 3, 4, 5], 1, 3, [20, 30, 40])
        expect result.len() == 6
        expect result[0] == 1
        expect result[1] == 20
        expect result[2] == 30
        expect result[3] == 40
        expect result[4] == 4

describe "zip_longest":
    it "zips with fill for unequal lengths":
        val result = zip_longest([1, 2, 3], ["a", "b"], 0, "z")
        expect result.len() == 3

# ============================================================================
# Slice When / Chunk While
# ============================================================================

describe "slice_when":
    it "splits when predicate true between elements":
        val result = slice_when([1, 2, 4, 5, 7], \a, b: b - a > 1)
        expect result.len() == 3
        expect result[0].len() == 2
        expect result[1].len() == 2
        expect result[2].len() == 1

    it "returns empty for empty":
        val result = slice_when([], \a, b: true)
        expect result.len() == 0

describe "chunk_while":
    it "chunks while predicate true":
        val result = chunk_while([1, 2, 4, 5, 7], \a, b: b - a <= 1)
        expect result.len() == 3

# ============================================================================
# Top N / Bottom N
# ============================================================================

describe "top_n":
    it "returns n largest":
        val result = top_n([3, 1, 4, 1, 5, 9], 3)
        expect result.len() == 3
        expect result[0] == 9
        expect result[1] == 5
        expect result[2] == 4

    it "returns empty for n=0":
        val result = top_n([1, 2], 0)
        expect result.len() == 0

describe "bottom_n":
    it "returns n smallest":
        val result = bottom_n([3, 1, 4, 1, 5, 9], 3)
        expect result.len() == 3
        expect result[0] == 1
        expect result[1] == 1
        expect result[2] == 3

# ============================================================================
# Compare / Dedup By
# ============================================================================

describe "arr_compare":
    it "compares less":
        expect arr_compare([1, 2, 3], [1, 2, 4]) == -1

    it "compares equal":
        expect arr_compare([1, 2, 3], [1, 2, 3]) == 0

    it "compares greater":
        expect arr_compare([1, 2, 4], [1, 2, 3]) == 1

    it "shorter is less":
        expect arr_compare([1, 2], [1, 2, 3]) == -1

describe "dedup_by":
    it "removes consecutive duplicates":
        val result = dedup_by([1, 1, 2, 2, 3, 1], \a, b: a == b)
        expect result.len() == 4
        expect result[0] == 1
        expect result[1] == 2
        expect result[2] == 3
        expect result[3] == 1

    it "returns empty for empty":
        val result = dedup_by([], \a, b: a == b)
        expect result.len() == 0