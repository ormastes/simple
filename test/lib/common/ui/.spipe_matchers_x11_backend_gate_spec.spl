use common.ui.x11_backend_gate.{
    x11_backend_required_features,
    x11_backend_missing_features,
    x11_backend_gate,
    x11_backend_event_gate,
    x11_backend_pixel_gate,
    x11_backend_property_gate
}

describe "X11-class backend readiness gate":
    describe "feature coverage":
        it "lists native WM features needed by a future Wine backend":
            val required = x11_backend_required_features()
            expect required.len() > 10
            expect required[0] == "display"

        it "reports the first missing X11-class renderer feature":
            val state = x11_backend_gate("display screen window map-unmap configure surface damage clip expose present input focus atom property wm-name wm-class wm-protocols")
            expect state == "missing-wm-state"

        it "returns ready when all required features are declared":
            val state = x11_backend_gate("display screen window map-unmap configure surface damage clip expose present input focus atom property wm-name wm-class wm-protocols wm-state cursor clipboard text glyph blit fill")
            expect state == "ready"

    describe "event coverage":
        it "requires a full window lifecycle and interaction stream":
            val state = x11_backend_event_gate("create map configure expose focus input")
            expect state == "missing-unmap"

    describe "pixel coverage":
        it "requires golden, damage, text, cursor, and present evidence":
            val state = x11_backend_pixel_gate("golden damage text")
            expect state == "missing-cursor"

    describe "WM property coverage":
        it "requires X11 WM atoms and properties that Wine checks during window setup":
            val state = x11_backend_property_gate("WM_NAME WM_CLASS WM_PROTOCOLS")
            expect state == "missing-_NET_WM_STATE"