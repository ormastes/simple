use common.ui.x11_backend_gate.{
    x11_backend_required_features,
    x11_backend_missing_features,
    x11_backend_gate,
    x11_backend_event_gate,
    x11_backend_pixel_gate
}

describe "X11-class backend readiness gate":
    describe "feature coverage":
        it "lists native WM features needed by a future Wine backend":
            val required = x11_backend_required_features()
            expect(required.len()).to_be_greater_than(10)
            expect(required[0]).to_equal("display")

        it "reports the first missing X11-class renderer feature":
            val state = x11_backend_gate("display screen window map-unmap configure surface damage clip expose present input focus cursor")
            expect(state).to_equal("missing-clipboard")

        it "returns ready when all required features are declared":
            val state = x11_backend_gate("display screen window map-unmap configure surface damage clip expose present input focus cursor clipboard text glyph blit fill")
            expect(state).to_equal("ready")

    describe "event coverage":
        it "requires a full window lifecycle and interaction stream":
            val state = x11_backend_event_gate("create map configure expose focus input")
            expect(state).to_equal("missing-clipboard")

    describe "pixel coverage":
        it "requires golden, damage, text, cursor, and present evidence":
            val state = x11_backend_pixel_gate("golden damage text")
            expect(state).to_equal("missing-cursor")

