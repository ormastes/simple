use common.wine_kernel32_global_memory.{
    wine_kernel32_execute_global_memory,
    wine_kernel32_global_alloc,
    wine_kernel32_global_free,
    wine_kernel32_global_realloc,
    wine_kernel32_global_size
}
use common.wine_nt_heap.{wine_nt_process_heap_new}
use common.wine_vm_adapter.{wine_vm_space_new}

describe "Wine KERNEL32 global-memory bridge":
    it "executes a bounded GlobalAlloc, GlobalSize, GlobalReAlloc, and GlobalFree sequence":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val result = wine_kernel32_execute_global_memory(
            ["GlobalAlloc", "GlobalSize", "GlobalReAlloc", "GlobalFree"],
            heap,
            24,
            40
        )

        expect result.ok == true
        expect result.previous_ptr == 0x71000000
        expect result.ptr == 0x71000018
        expect result.size == 40
        expect result.heap.blocks.len() == 2
        expect result.heap.blocks[0].freed == true
        expect result.heap.blocks[1].freed == true
        expect result.operations == "GlobalAlloc GlobalSize GlobalReAlloc GlobalFree"

    it "exposes direct global-memory helpers":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val allocated = wine_kernel32_global_alloc(heap, 16)
        val sized = wine_kernel32_global_size(allocated.heap, allocated.ptr)
        val reallocated = wine_kernel32_global_realloc(sized.heap, sized.ptr, 32)
        val freed = wine_kernel32_global_free(reallocated.heap, reallocated.ptr)

        expect allocated.ok == true
        expect sized.size == 16
        expect reallocated.previous_ptr == 0x71000000
        expect reallocated.ptr == 0x71000010
        expect freed.ok == true
        expect freed.heap.blocks[1].freed == true

    it "keeps global-memory dispatch ordered and bounded":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val out_of_order = wine_kernel32_execute_global_memory(["GlobalSize", "GlobalAlloc", "GlobalReAlloc", "GlobalFree"], heap, 16, 32)
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-global-memory-sequence-expected:GlobalAlloc"

        val wrong_family = wine_kernel32_execute_global_memory(["GlobalAlloc", "GlobalSize", "GlobalReAlloc", "HeapAlloc"], heap, 16, 32)
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:HeapAlloc"

    it "rejects invalid global-memory sizes and pointers":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val allocated = wine_kernel32_global_alloc(heap, 16)
        val freed = wine_kernel32_global_free(allocated.heap, allocated.ptr)

        expect wine_kernel32_global_alloc(heap, 0).error == "GlobalAlloc:invalid-size"
        expect wine_kernel32_global_size(heap, 0x72000000).error == "GlobalSize:invalid-pointer"
        expect wine_kernel32_global_size(freed.heap, allocated.ptr).error == "GlobalSize:freed-pointer"
        expect wine_kernel32_global_realloc(heap, 0x72000000, 8).error == "GlobalReAlloc:GlobalSize:invalid-pointer"