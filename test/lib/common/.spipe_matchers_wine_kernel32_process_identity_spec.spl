use common.wine_kernel32_process_identity.{
    WineKernel32ProcessIdentity,
    wine_kernel32_execute_process_identity,
    wine_kernel32_process_identity_default
}

describe "Wine KERNEL32 process identity bridge":
    it "executes bounded process and thread identity calls":
        val result = wine_kernel32_execute_process_identity(
            ["GetCurrentProcessId", "GetCurrentThreadId", "GetCurrentProcess", "GetCurrentThread"],
            wine_kernel32_process_identity_default()
        )

        expect result.ok == true
        expect result.process_id == 0x40
        expect result.thread_id == 0x80
        expect result.process_handle == -1
        expect result.thread_handle == -2
        expect result.operations == "GetCurrentProcessId GetCurrentThreadId GetCurrentProcess GetCurrentThread"

    it "keeps identity dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_process_identity(
            ["GetCurrentThreadId", "GetCurrentProcessId", "GetCurrentProcess", "GetCurrentThread"],
            wine_kernel32_process_identity_default()
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-process-identity-sequence-expected:GetCurrentProcessId"

        val wrong_family = wine_kernel32_execute_process_identity(
            ["GetCurrentProcessId", "GetCurrentThreadId", "GetCurrentProcess", "HeapAlloc"],
            wine_kernel32_process_identity_default()
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:HeapAlloc"

    it "rejects invalid identity values":
        val identity = WineKernel32ProcessIdentity(process_id: 0, thread_id: 0x80, process_handle: -1, thread_handle: -2)
        val result = wine_kernel32_execute_process_identity(
            ["GetCurrentProcessId", "GetCurrentThreadId", "GetCurrentProcess", "GetCurrentThread"],
            identity
        )

        expect result.ok == false
        expect result.error == "GetCurrentProcessId:invalid-process-id"