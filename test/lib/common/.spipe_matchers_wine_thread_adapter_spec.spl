use common.wine_thread_adapter.{
    wine_thread_adapter_feature_string,
    wine_thread_adapter_gate,
    wine_thread_adapter_gate_with_wait_result,
    wine_thread_adapter_missing_apis,
    wine_thread_adapter_required_apis,
    wine_thread_adapter_sffi_binding
}
use common.wine_nt_thread_wait.{
    wine_nt_create_pending_thread,
    wine_nt_create_thread,
    wine_nt_thread_table_new,
    wine_nt_wait_for_single_object
}

fn _existing_thread_sffi_apis() -> text:
    "thread-create thread-join thread-detach thread-current-id thread-yield " +
        "mutex-create mutex-lock mutex-try-lock mutex-unlock " +
        "condvar-create condvar-wait condvar-wait-timeout condvar-signal condvar-broadcast"

fn _all_thread_apis() -> text:
    _existing_thread_sffi_apis() + " tls-key-create tls-get tls-set tls-delete " +
        "semaphore-create semaphore-wait semaphore-post " +
        "event-create event-wait event-signal event-reset thread-fault-record"

describe "Wine thread adapter contract":
    it "lists pthread, TLS, synchronization, wait-object, and fault APIs":
        val apis = wine_thread_adapter_required_apis()
        expect apis.len() > 20
        expect apis[0] == "thread-create"

    it "reports the first missing thread adapter API":
        val missing = wine_thread_adapter_missing_apis("thread-create thread-join")
        expect missing[0] == "thread-detach"

    it "maps currently available thread SFFI calls to their runtime symbols":
        expect wine_thread_adapter_sffi_binding("thread-create") == "spl_thread_create"
        expect wine_thread_adapter_sffi_binding("mutex-try-lock") == "spl_mutex_try_lock"
        expect wine_thread_adapter_sffi_binding("condvar-wait-timeout") == "spl_condvar_wait_timeout"

    it "shows existing thread SFFI still lacks Wine TLS and wait objects":
        val result = wine_thread_adapter_gate(_existing_thread_sffi_apis())
        expect result.ready == false
        expect result.state == "missing-api-tls-key-create"
        expect (result.thread_features).contains("pthread")
        expect (result.thread_features).contains("mutex")

    it "derives a ready Wine thread gate from the full adapter surface":
        val features = wine_thread_adapter_feature_string(_all_thread_apis())
        expect (features).contains("pthread")
        expect (features).contains("tls")
        expect (features).contains("thread-fault")

    it "accepts the full thread/TLS/wait-object adapter API set":
        val result = wine_thread_adapter_gate(_all_thread_apis())
        expect result.ready == true
        expect result.state == "ready"

    it "requires modeled NT thread wait completion before full adapter readiness":
        val created = wine_nt_create_thread(wine_nt_thread_table_new(_all_thread_apis()), "main", 7)
        val waited = wine_nt_wait_for_single_object(created.table, created.handle, 1000)
        val result = wine_thread_adapter_gate_with_wait_result(_all_thread_apis(), waited)
        expect result.ready == true
        expect result.state == "ready"
        expect (result.thread_features).contains("nt-thread-wait")

    it "keeps thread adapter readiness blocked on timeout or invalid wait evidence":
        val pending = wine_nt_create_pending_thread(wine_nt_thread_table_new(_all_thread_apis()), "worker")
        val timeout = wine_nt_wait_for_single_object(pending.table, pending.handle, 0)
        val timed = wine_thread_adapter_gate_with_wait_result(_all_thread_apis(), timeout)
        expect timed.ready == false
        expect timed.state == "thread-wait-not-signaled:WAIT_TIMEOUT"

        val invalid = wine_nt_wait_for_single_object(wine_nt_thread_table_new(_all_thread_apis()), 0x999, 0)
        val errored = wine_thread_adapter_gate_with_wait_result(_all_thread_apis(), invalid)
        expect errored.ready == false
        expect errored.state == "thread-wait-invalid-handle"