use common.wine_nt_api_catalog.{
    wine_nt_api_catalogued_gui_symbols,
    wine_nt_api_catalogued_future_symbols,
    wine_nt_api_dispatch_gate,
    wine_nt_api_dll_gate,
    wine_nt_api_gui_dispatch_gate,
    wine_nt_api_gui_import_gate,
    wine_nt_api_implemented_symbols_for_gui_hello,
    wine_nt_api_implemented_symbols_for_hello,
    wine_nt_api_import_gate,
    wine_nt_api_modeled_precondition_symbols,
    wine_nt_api_symbol_state
}

describe "Wine NT API catalog":
    it "keeps the executable hello surface to the implemented console/process calls":
        val symbols = wine_nt_api_implemented_symbols_for_hello()
        expect(symbols.len()).to_equal(3)
        expect(symbols[0]).to_equal("GetStdHandle")
        expect(wine_nt_api_import_gate("KERNEL32.dll", symbols)).to_equal("ready")

    it "catalogs broader NT and Win32 prerequisites without marking them implemented":
        val future = wine_nt_api_catalogued_future_symbols()
        expect(future.len()).to_be_greater_than(30)
        val entry = wine_nt_api_symbol_state("kernel32.dll", "VirtualAlloc")
        expect(entry.category).to_equal("virtual-memory")
        expect(entry.state).to_equal("catalogued")

    it "records modeled precondition calls that are still not import-dispatchable":
        val modeled = wine_nt_api_modeled_precondition_symbols()
        expect(modeled.len()).to_equal(21)
        expect(modeled[0]).to_equal("VirtualAlloc")
        expect(modeled[3]).to_equal("CreateFileW")
        expect(modeled[6]).to_equal("CreateThread")
        expect(modeled[9]).to_equal("GetCommandLineW")
        expect(modeled[11]).to_equal("HeapAlloc")
        expect(modeled[13]).to_equal("NtAllocateVirtualMemory")
        expect(modeled[19]).to_equal("RtlAllocateHeap")
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"])).to_equal("catalogued-symbol:VirtualAlloc")
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "CreateFileW"])).to_equal("catalogued-symbol:CreateFileW")
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "CreateThread"])).to_equal("catalogued-symbol:CreateThread")
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "GetCommandLineW"])).to_equal("catalogued-symbol:GetCommandLineW")
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "HeapAlloc"])).to_equal("catalogued-symbol:HeapAlloc")

    it "keeps GUI and GDI catalog symbols out of the console precondition bridge":
        val gui = wine_nt_api_catalogued_gui_symbols()
        expect(gui.len()).to_equal(12)
        expect(gui[0]).to_equal("CreateWindowExW")
        expect(gui[8]).to_equal("TextOutW")

    it "keeps ntdll as catalogued but not import-ready for the hello milestone":
        expect(wine_nt_api_dll_gate("ntdll.dll")).to_equal("catalogued-dll:ntdll.dll")
        expect(wine_nt_api_import_gate("ntdll.dll", ["NtAllocateVirtualMemory"])).to_equal("catalogued-dll:ntdll.dll")

    it "blocks unknown imports before dispatch can pretend they exist":
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "UnknownApi"])).to_equal("unsupported-symbol:UnknownApi")

    it "reports catalogued symbols distinctly from implemented bridge calls":
        expect(wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"])).to_equal("catalogued-symbol:VirtualAlloc")
        expect(wine_nt_api_dispatch_gate(["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"])).to_equal("bridge-unsupported:VirtualAlloc")

    it "preserves the bridge missing-symbol order for the known hello call table":
        expect(wine_nt_api_dispatch_gate(["GetStdHandle"])).to_equal("bridge-missing:WriteFile")

    it "implements only MessageBoxW for the controlled GUI milestone":
        val symbols = wine_nt_api_implemented_symbols_for_gui_hello()
        expect(symbols.len()).to_equal(1)
        expect(symbols[0]).to_equal("MessageBoxW")
        expect(wine_nt_api_gui_import_gate("user32.dll", ["MessageBoxW"])).to_equal("ready")
        expect(wine_nt_api_gui_import_gate("user32.dll", ["MessageBoxW", "CreateWindowExW"])).to_equal("catalogued-symbol:CreateWindowExW")
        expect(wine_nt_api_gui_import_gate("gdi32.dll", ["TextOutW"])).to_equal("catalogued-dll:gdi32.dll")
        expect(wine_nt_api_gui_dispatch_gate(["MessageBoxW"])).to_equal("ready")
        expect(wine_nt_api_gui_dispatch_gate(["CreateWindowExW"])).to_equal("bridge-missing:MessageBoxW")
