        expect(wine_nt_api_kernel32_heap_dispatch_gate(symbols)).to_equal("ready")
        expect(wine_nt_api_kernel32_heap_dispatch_gate(["VirtualAlloc"])).to_equal("bridge-wrong-category:VirtualAlloc")

