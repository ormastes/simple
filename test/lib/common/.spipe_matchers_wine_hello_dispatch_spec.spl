use common.wine_hello_dispatch.{
    wine_known_hello_execute_plan,
    wine_known_hello_fixture_gate,
    wine_known_hello_fixture_gate_at_rva,
    wine_known_hello_stdout,
    wine_known_hello_execute_at_rva,
    wine_known_hello_stdout_at_rva,
    wine_known_hello_stdout_payload,
    wine_known_hello_stdout_payload_at_rva
}
use common.wine_cpu_exec.{wine_cpu_hello_execution_plan}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _put_marker(data: [u8], offset: i64) -> [u8]:
    data[offset] = 0x53
    data[offset + 1] = 0x49
    data[offset + 2] = 0x4d
    data[offset + 3] = 0x50
    data[offset + 4] = 0x4c
    data[offset + 5] = 0x45
    data[offset + 6] = 0x5f
    data[offset + 7] = 0x57
    data[offset + 8] = 0x49
    data[offset + 9] = 0x4e
    data[offset + 10] = 0x45
    data[offset + 11] = 0x5f
    data[offset + 12] = 0x48
    data[offset + 13] = 0x45
    data[offset + 14] = 0x4c
    data[offset + 15] = 0x4c
    data[offset + 16] = 0x4f
    data

fn _put_stdout_payload(data: [u8], offset: i64, payload: text) -> [u8]:
    val marker = "SIMPLE_WINE_STDOUT:"
    var i = 0
    while i < marker.len():
        data[offset + i] = marker[i] as u8
        i = i + 1
    var j = 0
    while j < payload.len():
        data[offset + marker.len() + j] = payload[j] as u8
        j = j + 1
    data[offset + marker.len() + payload.len()] = 0
    data

fn _put_pe_mapping(data: [u8]) -> [u8]:
    var out = data
    out[0] = 0x4d
    out[1] = 0x5a
    out = _put_u32_le(out, 0x3c, 0x80)
    out[0x80] = 0x50
    out[0x81] = 0x45
    out = _put_u16_le(out, 0x84, 0x8664)
    out = _put_u16_le(out, 0x86, 1)
    out = _put_u16_le(out, 0x94, 0xf0)
    out = _put_u16_le(out, 0x98, 0x20b)
    out = _put_u32_le(out, 0x98 + 0x10, 0x2000)
    out = _put_u32_le(out, 0x98 + 0x38, 0x5000)
    out = _put_u32_le(out, 0x98 + 0x3c, 0x200)
    out = _put_u16_le(out, 0x98 + 0x5c, 3)
    out = _put_u32_le(out, 0x98 + 0x6c, 16)
    val section_offset = 0x98 + 0xf0
    out = _put_u32_le(out, section_offset + 8, 0x300)
    out = _put_u32_le(out, section_offset + 12, 0x2000)
    out = _put_u32_le(out, section_offset + 16, 0x200)
    out = _put_u32_le(out, section_offset + 20, 0x200)
    out

fn _put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

describe "Wine known hello fixture bridge":
    it "rejects PE bytes without the explicit hello marker":
        expect wine_known_hello_fixture_gate(_zero_bytes(64)) == "hello-fixture-marker-missing"

    it "accepts only the known hello milestone marker":
        val data = _put_stdout_payload(_put_marker(_zero_bytes(128), 8), 40, "Hello from SimpleOS Wine\n")
        expect wine_known_hello_fixture_gate(data) == "ready"

    it "requires stdout payload bytes after the fixture marker":
        expect wine_known_hello_fixture_gate(_put_marker(_zero_bytes(64), 8)) == "hello-stdout-payload-missing"

    it "extracts the milestone stdout from fixture bytes":
        val data = _put_stdout_payload(_put_marker(_zero_bytes(128), 8), 40, "Hello from SimpleOS Wine\n")
        expect wine_known_hello_stdout_payload(data) == "Hello from SimpleOS Wine\n"

    it "extracts stdout only from the decoded payload RVA":
        val data = _put_stdout_payload(_put_marker(_put_pe_mapping(_zero_bytes(1024)), 0x300), 0x320, "Hello from SimpleOS Wine\n")
        expect wine_known_hello_stdout_payload_at_rva(data, 0x2120) == "Hello from SimpleOS Wine\n"
        expect wine_known_hello_stdout_payload_at_rva(data, 0x2130) == ""
        expect wine_known_hello_fixture_gate_at_rva(data, 0x2130) == "hello-stdout-payload-rva-mismatch"

    it "returns the milestone stdout for the known fixture":
        val data = _put_stdout_payload(_put_marker(_zero_bytes(128), 8), 40, "Hello from SimpleOS Wine\n")
        expect wine_known_hello_stdout(data) == "Hello from SimpleOS Wine\n"

    it "returns stdout only through the decoded payload RVA":
        val data = _put_stdout_payload(_put_marker(_put_pe_mapping(_zero_bytes(1024)), 0x300), 0x320, "Hello from SimpleOS Wine\n")
        expect wine_known_hello_stdout_at_rva(data, 0x2120) == "Hello from SimpleOS Wine\n"
        expect wine_known_hello_stdout_at_rva(data, 0x2130) == ""

    it "returns structured execution evidence through the decoded payload RVA":
        val data = _put_stdout_payload(_put_marker(_put_pe_mapping(_zero_bytes(1024)), 0x300), 0x320, "Hello from SimpleOS Wine\n")
        val result = wine_known_hello_execute_at_rva(data, 0x2120)
        expect result.ok == true
        expect result.bytes_written == 25
        expect result.exit_code == 0
        expect result.stdout == "Hello from SimpleOS Wine\n"

    it "executes only through a valid CPU hello execution plan":
        var data = _put_stdout_payload(_put_marker(_put_pe_mapping(_zero_bytes(1024)), 0x300), 0x320, "Hello from SimpleOS Wine\n")
        data[0x200] = 0x48
        data[0x201] = 0x31
        data[0x202] = 0xc9
        data[0x203] = 0xe8
        data = _put_u32_le(data, 0x204, 0x78)
        data[0x208] = 0x48
        data[0x209] = 0x8d
        data[0x20a] = 0x15
        data = _put_u32_le(data, 0x20b, 0x111)
        data[0x20f] = 0xe8
        data = _put_u32_le(data, 0x210, 0x8c)
        data[0x214] = 0x31
        data[0x215] = 0xc9
        data[0x216] = 0xe8
        data = _put_u32_le(data, 0x217, 0xa5)
        val plan = wine_cpu_hello_execution_plan(data, "thread-context user-stack entrypoint-mapped import-thunks-bound stdout-handle exit-trap no-native-jump x86_64-decoder x86_64-dispatch")
        val result = wine_known_hello_execute_plan(data, plan)
        expect result.ok == true
        expect result.stdout == "Hello from SimpleOS Wine\n"