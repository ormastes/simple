use common.wine_advapi32_service.{wine_advapi32_execute_service_start}

describe "Wine ADVAPI32 service-control bridge":
    it "executes a bounded service manager open-create-open-start-close sequence":
        val result = wine_advapi32_execute_service_start(["OpenSCManagerW", "CreateServiceW", "OpenServiceW", "StartServiceW", "CloseServiceHandle"], "SimpleOSSCM", "WineEventLog")
        expect result.ok == true
        expect result.manager == "SimpleOSSCM"
        expect result.service == "WineEventLog"
        expect result.handle > 0
        expect result.started == true
        expect (result.operations).contains("OpenSCManagerW")
        expect (result.operations).contains("StartServiceW")
        expect (result.operations).contains("CloseServiceHandle")

    it "keeps service-control dispatch ordered and bounded":
        val out_of_order = wine_advapi32_execute_service_start(["CreateServiceW", "OpenSCManagerW", "OpenServiceW", "StartServiceW", "CloseServiceHandle"], "SCM", "Svc")
        expect out_of_order.ok == false
        expect out_of_order.error == "advapi32-service-sequence-expected:OpenSCManagerW"

        val unsupported = wine_advapi32_execute_service_start(["OpenSCManagerW", "CreateServiceW", "OpenServiceW", "GetMessageW", "CloseServiceHandle"], "SCM", "Svc")
        expect unsupported.ok == false
        expect unsupported.error == "bridge-unsupported:GetMessageW"

        val invalid = wine_advapi32_execute_service_start(["OpenSCManagerW", "CreateServiceW", "OpenServiceW", "StartServiceW", "CloseServiceHandle"], "SCM", "")
        expect invalid.ok == false
        expect invalid.error == "empty-service"