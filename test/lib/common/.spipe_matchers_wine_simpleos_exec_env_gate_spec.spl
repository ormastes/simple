use common.wine_simpleos_exec_env_gate.{
    wine_simpleos_exec_env_evidence_from_serial_log,
    wine_simpleos_exec_env_fixture_evidence,
    wine_simpleos_exec_env_fixture_serial_log,
    wine_simpleos_exec_env_gate,
    wine_simpleos_exec_env_gate_from_serial_log,
    wine_simpleos_exec_env_required_evidence
}

describe "Wine SimpleOS executable environment gate":
    it "lists VM, full-OS, and container evidence required before Wine readiness claims":
        val required = wine_simpleos_exec_env_required_evidence()
        expect required.len() == 9
        expect required[0] == "simpleos-qemu-vm"
        expect required[1] == "simpleos-full-os-boot"
        expect required[7] == "simpleos-container-namespace"
        expect required[8] == "simpleos-container-rootfs"

    it "reports the first missing executable-environment prerequisite":
        val state = wine_simpleos_exec_env_gate("simpleos-qemu-vm simpleos-full-os-boot simpleos-user-process")
        expect state == "missing-simpleos-vmspace"

    it "accepts the fixture evidence used by the composed Wine precondition manifest":
        expect wine_simpleos_exec_env_gate(wine_simpleos_exec_env_fixture_evidence()) == "ready"

    it "derives executable-environment evidence from QEMU desktop serial markers":
        val evidence = wine_simpleos_exec_env_evidence_from_serial_log(wine_simpleos_exec_env_fixture_serial_log())
        expect (evidence).contains("simpleos-qemu-vm")
        expect (evidence).contains("simpleos-full-os-boot")
        expect (evidence).contains("simpleos-user-process")
        expect (evidence).contains("simpleos-vmspace")
        expect (evidence).contains("simpleos-container-namespace")
        expect (evidence).contains("simpleos-container-rootfs")
        expect wine_simpleos_exec_env_gate_from_serial_log(wine_simpleos_exec_env_fixture_serial_log()) == "ready"

    it "keeps QEMU desktop evidence blocked until container rootfs proof appears":
        val serial_log = "QEMU x86_64 desktop lane\n" +
            "[phase-3-mount] fat32 ok\n" +
            "[vfs] mounted fat32 device=nvme0 volume=simpleos\n" +
            "[fs-exec] spawn:image path=/sys/apps/wine_hello entry=0 segments=1 stub_bytes=128\n" +
            "[desktop-e2e] process-backed:ok app=wine_hello pid=42\n" +
            "[desktop-e2e] wm:ok pid=42 wid=1001\n" +
            "[desktop-e2e] network-smoke:bounded ok packets=1\n" +
            "[desktop-e2e] container-namespace:ok pid fs ipc net capability\n" +
            "TEST PASSED"
        expect wine_simpleos_exec_env_gate_from_serial_log(serial_log) == "missing-simpleos-container-rootfs"