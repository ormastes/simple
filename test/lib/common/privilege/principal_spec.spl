# @cover src/lib/common/privilege/principal.spl 80%
"""
# Principal Specification

**Feature:** spm-winfs-llm-suite / AC-1
**Status:** Red (no impl yet)

Principal kind validation — local principal default; non-local rejected.
"""

use std.sspec.*
use lib.common.privilege.principal.{Principal, PrincipalKind, principal_is_local, principal_validate}

describe "Principal":
    describe "kinds":
        it "AC-1: default principal is Local":
            val p = Principal.default_local("alice")
            expect principal_is_local(p) to_equal true

        it "AC-1: local principal passes validation":
            val p = Principal(kind: PrincipalKind.Local, id: "alice")
            val result = principal_validate(p)
            expect result.ok to_equal true

        it "AC-1: non-local principal is rejected in this release":
            val p = Principal(kind: PrincipalKind.Remote, id: "host:alice")
            val result = principal_validate(p)
            expect result.ok to_equal false

        it "AC-1: non-local principal_is_local returns false":
            val p = Principal(kind: PrincipalKind.Remote, id: "host:alice")
            expect principal_is_local(p) to_equal false
