use common.wine_kernel32_interlocked.{
    wine_kernel32_execute_interlocked,
    wine_kernel32_interlocked_cell_new,
    wine_kernel32_interlocked_compare_exchange,
    wine_kernel32_interlocked_decrement,
    wine_kernel32_interlocked_exchange,
    wine_kernel32_interlocked_exchange_add,
    wine_kernel32_interlocked_increment
}

describe "Wine KERNEL32 interlocked bridge":
    it "executes a bounded interlocked operation sequence":
        val result = wine_kernel32_execute_interlocked(
            ["InterlockedIncrement", "InterlockedDecrement", "InterlockedExchange", "InterlockedCompareExchange", "InterlockedExchangeAdd"],
            wine_kernel32_interlocked_cell_new(10),
            40,
            2
        )

        expect result.ok == true
        expect result.previous == 41
        expect result.current == 43
        expect result.cell.value == 43
        expect result.operations == "InterlockedIncrement InterlockedDecrement InterlockedExchange InterlockedCompareExchange InterlockedExchangeAdd"

    it "exposes direct interlocked helpers":
        val incremented = wine_kernel32_interlocked_increment(wine_kernel32_interlocked_cell_new(1))
        val decremented = wine_kernel32_interlocked_decrement(incremented.cell)
        val exchanged = wine_kernel32_interlocked_exchange(decremented.cell, 9)
        val compared = wine_kernel32_interlocked_compare_exchange(exchanged.cell, 11, 9)
        val added = wine_kernel32_interlocked_exchange_add(compared.cell, 4)

        expect incremented.current == 2
        expect decremented.current == 1
        expect exchanged.previous == 1
        expect compared.current == 11
        expect added.previous == 11
        expect added.current == 15

    it "preserves compare-exchange value when the comparand does not match":
        val result = wine_kernel32_interlocked_compare_exchange(wine_kernel32_interlocked_cell_new(7), 12, 6)

        expect result.previous == 7
        expect result.current == 7
        expect result.cell.value == 7

    it "keeps interlocked dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_interlocked(
            ["InterlockedExchange", "InterlockedIncrement", "InterlockedDecrement", "InterlockedCompareExchange", "InterlockedExchangeAdd"],
            wine_kernel32_interlocked_cell_new(10),
            40,
            2
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-interlocked-sequence-expected:InterlockedIncrement"

        val wrong_family = wine_kernel32_execute_interlocked(
            ["InterlockedIncrement", "InterlockedDecrement", "InterlockedExchange", "InterlockedCompareExchange", "HeapAlloc"],
            wine_kernel32_interlocked_cell_new(10),
            40,
            2
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:HeapAlloc"