use common.wine_dynload_adapter.{
    wine_dynload_adapter_feature_string,
    wine_dynload_adapter_gate,
    wine_dynload_adapter_gate_with_loader_result,
    wine_dynload_adapter_missing_apis,
    wine_dynload_adapter_native_binding,
    wine_dynload_adapter_required_apis
}
use common.wine_ntdll_loader.{wine_ntdll_execute_loader_resolution, wine_ntdll_loader_table_new}

fn _current_native_loader_apis() -> text:
    "native-module-open native-module-close native-self-handle native-symbol-lookup"

fn _all_dynload_apis() -> text:
    _current_native_loader_apis() + " search-path dependency-list link-namespace relocation-apply " +
        "import-bind tls-callback pe-loader-boundary structured-loader-error"

describe "Wine dynamic loader adapter contract":
    it "lists native loader, dependency, namespace, relocation, import, TLS, and error APIs":
        val apis = wine_dynload_adapter_required_apis()
        expect apis.len() > 10
        expect apis[0] == "native-module-open"

    it "reports the first missing dynamic loader API":
        val missing = wine_dynload_adapter_missing_apis(_current_native_loader_apis())
        expect missing[0] == "search-path"

    it "maps existing native dynamic loader bindings":
        expect wine_dynload_adapter_native_binding("native-module-open") == "spl_dlopen"
        expect wine_dynload_adapter_native_binding("native-symbol-lookup") == "spl_dlsym"
        expect wine_dynload_adapter_native_binding("native-self-handle") == "dlopen(NULL)"

    it "does not treat native dlopen alone as Wine dynamic-loader readiness":
        val result = wine_dynload_adapter_gate(_current_native_loader_apis())
        expect result.ready == false
        expect result.state == "missing-api-search-path"
        expect (result.dynload_features).contains("dynload")

    it "derives Wine dynamic gate features from the full coexistence surface":
        val features = wine_dynload_adapter_feature_string(_all_dynload_apis())
        expect (features).contains("dynload")
        expect (features).contains("symbol-lookup")
        expect (features).contains("loader-errors")

    it "accepts the full dynamic loading coexistence API set":
        val result = wine_dynload_adapter_gate(_all_dynload_apis())
        expect result.ready == true
        expect result.state == "ready"

    it "requires bounded NTDLL loader resolution evidence before full adapter readiness":
        val loader = wine_ntdll_execute_loader_resolution(
            ["LdrLoadDll", "LdrGetProcedureAddress", "LdrUnloadDll"],
            wine_ntdll_loader_table_new(),
            "KERNEL32.dll",
            "GetProcAddress"
        )
        val result = wine_dynload_adapter_gate_with_loader_result(_all_dynload_apis(), loader)
        expect result.ready == true
        expect result.state == "ready"
        expect (result.dynload_features).contains("ntdll-loader-resolution")

    it "keeps dynamic-loader readiness blocked on failed loader resolution":
        val loader = wine_ntdll_execute_loader_resolution(
            ["LdrLoadDll", "LdrGetProcedureAddress", "LdrUnloadDll"],
            wine_ntdll_loader_table_new(),
            "advapi32.dll",
            "RegOpenKeyExW"
        )
        val result = wine_dynload_adapter_gate_with_loader_result(_all_dynload_apis(), loader)
        expect result.ready == false
        expect result.state == "loader-resolution-LdrLoadDll:module-not-found"