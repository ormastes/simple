use common.wine_precondition_manifest.{
    wine_precondition_manifest,
    wine_precondition_required_process_log
}

describe "Wine precondition manifest":
    it "blocks on incomplete process-backed app evidence before proxy gates":
        val partial_log = "[desktop-e2e] process-backed:ok app=browser_demo pid=1\n" +
            "[desktop-e2e] process-backed:ok app=hello_world pid=2\n" +
            "[desktop-e2e] process-backed:ok app=editor pid=3"
        val manifest = wine_precondition_manifest(partial_log, "ready", "ready", "ready", "ready", "ready", "ready", "ready", "ready", "ready")
        expect manifest.ready == false
        expect manifest.state == "blocked-process:insufficient-evidence"

    it "reports the first ordered precondition blocker":
        val manifest = wine_precondition_manifest(wine_precondition_required_process_log(), "missing-mprotect", "ready", "ready", "ready", "ready", "ready", "ready", "ready", "ready")
        expect manifest.ready == false
        expect manifest.state == "blocked-vm:missing-mprotect"
        expect manifest.gates == "process=verified"

    it "keeps renderer readiness separate from hello.exe substrate gates":
        val manifest = wine_precondition_manifest(wine_precondition_required_process_log(), "ready", "missing-clipboard", "ready", "ready", "ready", "ready", "ready", "ready", "ready")
        expect manifest.ready == false
        expect manifest.state == "blocked-renderer:missing-clipboard"
        expect (manifest.gates).contains("vm=verified")

    it "requires host, POSIX, pthread, dynload, async, and PE gates before hello.exe":
        val manifest = wine_precondition_manifest(wine_precondition_required_process_log(), "ready", "ready", "ready", "ready", "ready", "ready", "missing-submit-write", "ready", "ready")
        expect manifest.ready == false
        expect manifest.state == "blocked-async:missing-submit-write"
        expect (manifest.gates).contains("dynload=verified")

    it "requires the modeled NT bridge before hello.exe":
        val manifest = wine_precondition_manifest(wine_precondition_required_process_log(), "ready", "ready", "ready", "ready", "ready", "ready", "ready", "ready", "missing-heap")
        expect manifest.ready == false
        expect manifest.state == "blocked-nt-bridge:missing-heap"
        expect (manifest.gates).contains("pe_loader=verified")

    it "emits the verified gate string accepted by the hello.exe gate":
        val manifest = wine_precondition_manifest(wine_precondition_required_process_log(), "ready", "ready", "ready", "ready", "ready", "ready", "ready", "ready", "ready")
        expect manifest.ready == true
        expect manifest.state == "ready"
        expect (manifest.gates).contains("process=verified")
        expect (manifest.gates).contains("pe_loader=verified")
        expect (manifest.gates).contains("nt_bridge=verified")