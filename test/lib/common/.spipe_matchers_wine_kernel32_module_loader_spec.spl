use common.wine_kernel32_module_loader.{
    WineKernel32ModuleTable,
    wine_kernel32_execute_module_resolution,
    wine_kernel32_execute_module_resolution_ex,
    wine_kernel32_get_module_handle_w,
    wine_kernel32_get_proc_address,
    wine_kernel32_load_library_ex_w,
    wine_kernel32_module_table_add_module,
    wine_kernel32_module_table_new,
    wine_kernel32_plan_dll_search_order
}

fn _table() -> WineKernel32ModuleTable:
    wine_kernel32_module_table_add_module(wine_kernel32_module_table_new(), "kernel32.dll", ["LoadLibraryW", "LoadLibraryExW", "GetProcAddress", "FreeLibrary"])

describe "Wine KERNEL32 module loader bridge":
    it "models DLL search order without host filesystem access or DLL execution":
        val result = wine_kernel32_plan_dll_search_order(
            "kernel32.dll",
            "C:\\Games",
            "C:\\Users\\Player",
            ["D:\\GameBin", "E:\\Shared"],
            ["kernel32.dll", "ntdll.dll"]
        )

        expect result.ok == true
        expect result.search_roots.len() == 8
        expect result.search_roots[0] == "\\KnownDlls"
        expect result.search_roots[1] == "C:\\Games"
        expect result.search_roots[6] == "D:\\GameBin"
        expect result.candidate_paths[0] == "\\KnownDlls\\kernel32.dll"
        expect result.candidate_paths[1] == "C:\\Games\\kernel32.dll"
        expect result.selected_path == "\\KnownDlls\\kernel32.dll"
        expect (result.evidence).contains("dll-search-order-modeled")
        expect (result.evidence).contains("no-host-filesystem-access")
        expect (result.evidence).contains("no-dll-entrypoint-executed")
        expect result.status == "dll-search-order-modeled"

    it "uses application directory first for non-KnownDll basenames":
        val result = wine_kernel32_plan_dll_search_order("gameaudio.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"])

        expect result.ok == true
        expect result.selected_path == "C:\\Games\\gameaudio.dll"
        expect result.candidate_paths[0] == "\\KnownDlls\\gameaudio.dll"
        expect result.candidate_paths[1] == "C:\\Games\\gameaudio.dll"

    it "rejects DLL search inputs that would escape the modeled basename lane":
        val absolute = wine_kernel32_plan_dll_search_order("C:\\Windows\\System32\\kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"])
        expect absolute.ok == false
        expect absolute.error == "dll-name-must-be-basename"

        val missing_suffix = wine_kernel32_plan_dll_search_order("kernel32", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"])
        expect missing_suffix.ok == false
        expect missing_suffix.error == "dll-name-must-end-with-dll"

    it "executes a bounded module and procedure resolution sequence":
        val result = wine_kernel32_execute_module_resolution(
            ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"],
            _table(),
            "KERNEL32.dll",
            "GetProcAddress"
        )

        expect result.ok == true
        expect result.handle == 0x120
        expect result.proc_address == 0x120000 + 3
        expect result.operations == "GetModuleHandleW LoadLibraryW GetProcAddress FreeLibrary"
        expect wine_kernel32_get_module_handle_w(result.table, "kernel32.dll").ok == true

    it "executes a bounded LoadLibraryExW module resolution sequence":
        val result = wine_kernel32_execute_module_resolution_ex(
            ["GetModuleHandleW", "LoadLibraryExW", "GetProcAddress", "FreeLibrary"],
            _table(),
            "kernel32.dll",
            "GetProcAddress",
            0
        )

        expect result.ok == true
        expect result.handle == 0x120
        expect result.proc_address == 0x120000 + 3
        expect result.operations == "GetModuleHandleW LoadLibraryExW GetProcAddress FreeLibrary"

    it "keeps module loader dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_module_resolution(
            ["LoadLibraryW", "GetModuleHandleW", "GetProcAddress", "FreeLibrary"],
            _table(),
            "kernel32.dll",
            "GetProcAddress"
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-module-loader-sequence-expected:GetModuleHandleW"

        val wrong_family = wine_kernel32_execute_module_resolution(
            ["GetModuleHandleW", "LoadLibraryW", "VirtualAlloc", "FreeLibrary"],
            _table(),
            "kernel32.dll",
            "GetProcAddress"
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:VirtualAlloc"

        val wrong_ex_order = wine_kernel32_execute_module_resolution_ex(
            ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"],
            _table(),
            "kernel32.dll",
            "GetProcAddress",
            0
        )
        expect wrong_ex_order.ok == false
        expect wrong_ex_order.error == "kernel32-module-loader-sequence-expected:LoadLibraryExW"

    it "reports missing modules, missing procedures, and invalid handles":
        val missing_module = wine_kernel32_execute_module_resolution(
            ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"],
            _table(),
            "user32.dll",
            "MessageBoxW"
        )
        expect missing_module.ok == false
        expect missing_module.error == "GetModuleHandleW:module-not-loaded"

        val missing_proc = wine_kernel32_execute_module_resolution(
            ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"],
            _table(),
            "kernel32.dll",
            "UnknownProc"
        )
        expect missing_proc.ok == false
        expect missing_proc.error == "GetProcAddress:proc-not-found"

        val invalid_handle = wine_kernel32_get_proc_address(_table(), 0x999, "GetProcAddress")
        expect invalid_handle.ok == false
        expect invalid_handle.error == "invalid-module-handle"

        val unsupported_flags = wine_kernel32_load_library_ex_w(_table(), "kernel32.dll", 8)
        expect unsupported_flags.ok == false
        expect unsupported_flags.error == "unsupported-load-flags"