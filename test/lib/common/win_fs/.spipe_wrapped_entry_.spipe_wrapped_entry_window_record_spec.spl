#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use lib.common.privilege.id_path.{IdPath, id_path_intern}
use lib.common.win_fs.window_record.{WindowRecord, WindowState, Rect, BufferRef, window_update_title, window_mark_destroyed}

fn main():
    # @cover src/lib/common/win_fs/window_record.spl 80%
    """
    # WindowRecord Specification
    
    **Feature:** spm-winfs-llm-suite / AC-2
    **Status:** Red (no impl yet)
    
    Record lifecycle: create / update / destroy semantics and generation counter.
    """


    describe "WindowRecord":
        describe "lifecycle":
            it "AC-2: creation yields Normal state and generation 1":
                val rec = WindowRecord(
                    wid: 100, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.banking.view"))
                expect rec.generation == 1

            it "AC-2: update_title bumps generation":
                val rec = WindowRecord(
                    wid: 100, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.banking.view"))
                val next = window_update_title(rec, "Transfer")
                expect next.title == "Transfer"
                expect next.generation > 1

            it "AC-2: mark_destroyed sets state to Destroyed":
                val rec = WindowRecord(
                    wid: 100, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.banking.view"))
                val gone = window_mark_destroyed(rec)
                expect gone.state == WindowState.Destroyed
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)

