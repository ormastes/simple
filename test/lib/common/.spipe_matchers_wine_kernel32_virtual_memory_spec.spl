use common.wine_kernel32_virtual_memory.{wine_kernel32_execute_virtual_memory}
use common.wine_vm_adapter.{wine_vm_access_gate, wine_vm_space_new}

describe "Wine KERNEL32 virtual memory bridge":
    it "executes a bounded allocate-protect-free sequence through the VM adapter":
        val result = wine_kernel32_execute_virtual_memory(
            ["VirtualAlloc", "VirtualProtect", "VirtualFree"],
            wine_vm_space_new(),
            0x700000,
            0x2000,
            "rw",
            "rx"
        )

        expect result.ok == true
        expect result.base == 0x700000
        expect result.size == 0x2000
        expect result.old_perms == "rw"
        expect result.operations == "VirtualAlloc VirtualProtect VirtualFree"
        expect wine_vm_access_gate(result.space, 0x700000, "read") == "page-fault-unmapped"

    it "keeps virtual memory dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_virtual_memory(
            ["VirtualProtect", "VirtualAlloc", "VirtualFree"],
            wine_vm_space_new(),
            0x710000,
            0x1000,
            "rw",
            "rx"
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-virtual-memory-sequence-expected:VirtualAlloc"

        val wrong_family = wine_kernel32_execute_virtual_memory(
            ["VirtualAlloc", "GetCommandLineW", "VirtualFree"],
            wine_vm_space_new(),
            0x720000,
            0x1000,
            "rw",
            "rx"
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:GetCommandLineW"

        val invalid = wine_kernel32_execute_virtual_memory(
            ["VirtualAlloc", "VirtualProtect", "VirtualFree"],
            wine_vm_space_new(),
            0x730000,
            0,
            "rw",
            "rx"
        )
        expect invalid.ok == false
        expect invalid.error == "VirtualAlloc:invalid-size"