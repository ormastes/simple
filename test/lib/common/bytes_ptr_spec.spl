# Spec: [u8].ptr() + .len() — used by SPM syscall wrappers to pass
# buffer pointers through the 5-arg syscall ABI.
#
# Interpreter representation of [u8] is Arc<Vec<Value>> — .ptr() returns
# the backing Vec data address (non-zero, stable per-slice), NOT a tight
# byte buffer. This is sufficient for mock-transport tests today. Real
# kernel calls from compiled mode (LLVM/Cranelift) use fat-pointer ABI
# which yields the true byte-array address at codegen time.

use std.test.{describe, it, expect}

describe("byte slice .ptr() and .len()"):

    it("empty slice has len 0"):
        val b: [u8] = []
        expect(b.len()).to_equal(0)

    it("non-empty slice has non-zero ptr"):
        val b: [u8] = [1 as u8, 2 as u8, 3 as u8]
        val p = b.ptr()
        expect(p != 0).to_equal(true)

    it("same slice returns same ptr twice"):
        val b: [u8] = [42 as u8, 99 as u8]
        val p1 = b.ptr()
        val p2 = b.ptr()
        expect(p1).to_equal(p2)

    it("len matches slice length"):
        val b: [u8] = [10 as u8, 20 as u8, 30 as u8, 40 as u8, 50 as u8]
        expect(b.len()).to_equal(5)

    it("val binding keeps ptr stable"):
        val raw: [u8] = [7 as u8, 8 as u8]
        val p_before = raw.ptr()
        val also = raw
        val p_after = also.ptr()
        expect(p_before).to_equal(p_after)

    it("two independent slices have independent ptrs"):
        # NOTE: coincidence collision is allowed but extremely unlikely.
        val a: [u8] = [1 as u8, 2 as u8, 3 as u8, 4 as u8]
        val b: [u8] = [5 as u8, 6 as u8, 7 as u8, 8 as u8]
        val pa = a.ptr()
        val pb = b.ptr()
        expect(pa != 0).to_equal(true)
        expect(pb != 0).to_equal(true)
