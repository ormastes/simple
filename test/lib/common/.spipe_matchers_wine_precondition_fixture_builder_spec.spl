use common.wine_precondition_fixture_builder.{
    wine_precondition_fixture_async_state,
    wine_precondition_fixture_dynload_state,
    wine_precondition_fixture_host_state,
    wine_precondition_fixture_manifest,
    wine_precondition_fixture_nt_bridge_state,
    wine_precondition_fixture_pe_loader_state,
    wine_precondition_fixture_posix_state,
    wine_precondition_fixture_pthread_state,
    wine_precondition_fixture_renderer_state,
    wine_precondition_fixture_vm_state
}

describe "Wine precondition fixture builder":
    it "derives VM and renderer readiness from adapter models":
        expect wine_precondition_fixture_vm_state() == "ready"
        expect wine_precondition_fixture_renderer_state() == "ready"

    it "derives host, POSIX, pthread, dynamic loading, async, and PE readiness":
        expect wine_precondition_fixture_host_state() == "ready"
        expect wine_precondition_fixture_posix_state() == "ready"
        expect wine_precondition_fixture_pthread_state() == "ready"
        expect wine_precondition_fixture_dynload_state() == "ready"
        expect wine_precondition_fixture_async_state() == "ready"
        expect wine_precondition_fixture_pe_loader_state() == "ready"
        expect wine_precondition_fixture_nt_bridge_state() == "ready"

    it "builds the manifest accepted by the hello fixture path":
        val manifest = wine_precondition_fixture_manifest()
        expect manifest.ready == true
        expect manifest.state == "ready"
        expect (manifest.gates).contains("process=verified")
        expect (manifest.gates).contains("pe_loader=verified")
        expect (manifest.gates).contains("nt_bridge=verified")