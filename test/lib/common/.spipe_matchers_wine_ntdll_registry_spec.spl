use common.wine_ntdll_registry.{wine_ntdll_execute_registry_query, wine_ntdll_registry_hive_default}

describe "Wine NTDLL registry bridge":
    it "executes bounded key open, value query, and close":
        val result = wine_ntdll_execute_registry_query(
            ["NtOpenKey", "NtQueryValueKey", "NtClose"],
            wine_ntdll_registry_hive_default(),
            "\\Registry\\Machine\\Software\\Wine",
            "InstallRoot"
        )

        expect result.ok == true
        expect result.handle == 0x600
        expect result.value == "C:\\windows"
        expect result.operations == "NtOpenKey NtQueryValueKey NtClose"

    it "keeps NTDLL registry dispatch ordered and bounded":
        val out_of_order = wine_ntdll_execute_registry_query(
            ["NtQueryValueKey", "NtOpenKey", "NtClose"],
            wine_ntdll_registry_hive_default(),
            "\\Registry\\Machine\\Software\\Wine",
            "InstallRoot"
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "ntdll-registry-sequence-expected:NtOpenKey"

        val wrong_family = wine_ntdll_execute_registry_query(
            ["NtOpenKey", "NtQueryValueKey", "NtCreateFile"],
            wine_ntdll_registry_hive_default(),
            "\\Registry\\Machine\\Software\\Wine",
            "InstallRoot"
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:NtCreateFile"

    it "rejects missing registry values":
        val result = wine_ntdll_execute_registry_query(
            ["NtOpenKey", "NtQueryValueKey", "NtClose"],
            wine_ntdll_registry_hive_default(),
            "\\Registry\\Machine\\Software\\Wine",
            "Missing"
        )
        expect result.ok == false
        expect result.error == "NtQueryValueKey:value-not-found"