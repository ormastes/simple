use common.wine_ntdll_system_info.{
    WineNtdllSystemInfo,
    wine_ntdll_execute_system_info,
    wine_ntdll_system_info_default
}

fn _classes() -> [text]:
    ["SystemBasicInformation", "SystemProcessorInformation", "SystemTimeOfDayInformation"]

describe "Wine NTDLL system information bridge":
    it "executes a bounded NtQuerySystemInformation sequence":
        val result = wine_ntdll_execute_system_info(["NtQuerySystemInformation"], _classes(), wine_ntdll_system_info_default())

        expect result.ok == true
        expect result.page_size == 4096
        expect result.allocation_granularity == 65536
        expect result.processor_count == 4
        expect result.timer_resolution_100ns == 156250
        expect result.system_root == "C:\\windows"
        expect result.classes == "SystemBasicInformation SystemProcessorInformation SystemTimeOfDayInformation"
        expect result.operations == "NtQuerySystemInformation"

    it "keeps system information dispatch and classes bounded":
        val wrong_family = wine_ntdll_execute_system_info(["NtCreateFile"], _classes(), wine_ntdll_system_info_default())
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:NtCreateFile"

        val wrong_class = wine_ntdll_execute_system_info(["NtQuerySystemInformation"], ["SystemProcessorInformation", "SystemBasicInformation", "SystemTimeOfDayInformation"], wine_ntdll_system_info_default())
        expect wrong_class.ok == false
        expect wrong_class.error == "ntdll-system-info-class-expected:SystemBasicInformation"

    it "rejects invalid system information facts":
        val invalid = WineNtdllSystemInfo(
            page_size: 4096,
            allocation_granularity: 65536,
            processor_count: 0,
            timer_resolution_100ns: 156250,
            system_root: "C:\\windows"
        )
        val result = wine_ntdll_execute_system_info(["NtQuerySystemInformation"], _classes(), invalid)
        expect result.ok == false
        expect result.error == "NtQuerySystemInformation:invalid-processor-count"