use common.wine_image_map.{wine_image_entry_window_gate, wine_image_map_gate}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn _minimal_image(entry_rva: i64, image_size: i64) -> [u8]:
    var data = _zero_bytes(1024)
    data[0] = 0x4d
    data[1] = 0x5a
    data = _put_u32_le(data, 0x3c, 0x80)
    data[0x80] = 0x50
    data[0x81] = 0x45
    data = _put_u16_le(data, 0x84, 0x8664)
    data = _put_u16_le(data, 0x86, 1)
    data = _put_u16_le(data, 0x94, 0xf0)
    data = _put_u16_le(data, 0x98, 0x20b)
    data = _put_u32_le(data, 0x98 + 0x10, entry_rva)
    data = _put_u32_le(data, 0x98 + 0x38, image_size)
    data = _put_u32_le(data, 0x98 + 0x3c, 0x200)
    data = _put_u16_le(data, 0x98 + 0x5c, 3)
    data = _put_u32_le(data, 0x98 + 0x6c, 16)
    val section_offset = 0x98 + 0xf0
    data = _put_u32_le(data, section_offset + 8, 0x300)
    data = _put_u32_le(data, section_offset + 12, 0x2000)
    data = _put_u32_le(data, section_offset + 16, 0x200)
    data = _put_u32_le(data, section_offset + 20, 0x200)
    data = _put_u32_le(data, section_offset + 36, 0x60000020)
    data

fn _minimal_image_without_executable_section(entry_rva: i64, image_size: i64) -> [u8]:
    var data = _minimal_image(entry_rva, image_size)
    val section_offset = 0x98 + 0xf0
    data = _put_u32_le(data, section_offset + 36, 0x40000040)
    data

fn _minimal_image_with_raw_overflow(entry_rva: i64, image_size: i64) -> [u8]:
    var data = _minimal_image(entry_rva, image_size)
    val section_offset = 0x98 + 0xf0
    data = _put_u32_le(data, section_offset + 16, 0x1000)
    data

describe "Wine image map gate":
    it "requires an entry point":
        expect(wine_image_map_gate(_minimal_image(0, 0x5000))).to_equal("missing-entrypoint")

    it "requires the entry point to map through a section":
        expect(wine_image_map_gate(_minimal_image(0x9000, 0x5000))).to_equal("entrypoint-unmapped")

    it "requires an image larger than headers":
        expect(wine_image_map_gate(_minimal_image(0x2010, 0x100))).to_equal("bad-image-size")

    it "rejects section raw data outside the PE bytes":
        expect(wine_image_map_gate(_minimal_image_with_raw_overflow(0x2010, 0x5000))).to_equal("section-raw-out-of-bounds")

    it "requires the entry point section to be executable":
        expect(wine_image_map_gate(_minimal_image_without_executable_section(0x2010, 0x5000))).to_equal("entry-section-not-executable")

    it "accepts a bounded mapped image layout":
        expect(wine_image_map_gate(_minimal_image(0x2010, 0x5000))).to_equal("ready")

    it "requires the entry execution window to stay mapped and contiguous":
        expect(wine_image_entry_window_gate(_minimal_image(0x2010, 0x5000), 27)).to_equal("ready")
        expect(wine_image_entry_window_gate(_minimal_image(0x2010, 0x5000), 0)).to_equal("invalid-entry-window")
        expect(wine_image_entry_window_gate(_minimal_image(0x21f0, 0x5000), 32)).to_equal("entry-window-unmapped")
