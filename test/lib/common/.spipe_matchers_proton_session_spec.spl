use common.proton_runtime_subsystems.{
    proton_fixture_non_wine_runtime_evidence,
    proton_non_wine_runtime_evidence_new
}
use common.proton_session.{
    proton_session_launch_handoff,
    proton_session_launch_handoff_with_exec_env,
    proton_session_plan,
    proton_session_request_gate,
    proton_session_request_new
}
use common.wine_simpleos_exec_env_gate.{wine_simpleos_exec_env_fixture_evidence}

describe "Non-Wine Proton session planning":
    it "rejects incomplete session requests before runtime evidence":
        val missing_app = proton_session_request_new("", "steamapps/compatdata/480/pfx", "hl2.exe", [])
        expect proton_session_request_gate(missing_app) == "missing-app-id"

        val missing_prefix = proton_session_request_new("480", "", "hl2.exe", [])
        expect proton_session_request_gate(missing_prefix) == "missing-compat-prefix"

        val invalid_prefix = proton_session_request_new("480", "tmp/pfx", "hl2.exe", [])
        expect proton_session_request_gate(invalid_prefix) == "invalid-compat-prefix"

        val unsupported = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "README.txt", [])
        expect proton_session_request_gate(unsupported) == "unsupported-executable"

    it "blocks session planning on incomplete non-Wine runtime evidence":
        val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid"])
        val evidence = proton_non_wine_runtime_evidence_new(
            "steam-runtime abi-x86_64 soldier",
            "pressure-vessel-container container-rootfs container-rootfs-nvfs namespace-pid namespace-fs namespace-ipc namespace-net namespace-capability",
            "vulkan-loader vulkan-device dxvk",
            "proton-launcher steamworks-bridge controller-input",
            "esync-or-fsync"
        )
        val plan = proton_session_plan(request, evidence)
        expect plan.ok == false
        expect plan.error == "missing-vkd3d-proton"
        expect plan.status == "blocked"

    it "plans a launch session when every non-Wine Proton subsystem is ready":
        val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid", "-fullscreen"])
        val plan = proton_session_plan(request, proton_fixture_non_wine_runtime_evidence())
        expect plan.ok == true
        expect plan.error == ""
        expect plan.app_id == "480"
        expect plan.compat_prefix == "steamapps/compatdata/480/pfx"
        expect plan.launch_command == "hl2.exe -novid -fullscreen"
        expect (plan.runtime_features).contains("steam-runtime")
        expect (plan.runtime_features).contains("pressure-vessel-container")
        expect (plan.runtime_features).contains("dxvk")
        expect (plan.runtime_features).contains("vkd3d-proton")
        expect (plan.runtime_features).contains("esync-or-fsync")
        expect plan.status == "planned"

    it "creates a dry-run handoff record without executing Proton":
        val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid"])
        val plan = proton_session_plan(request, proton_fixture_non_wine_runtime_evidence())
        val blocked = proton_session_launch_handoff(plan, false)
        expect blocked.ok == false
        expect blocked.error == "execution-not-implemented"
        expect blocked.status == "blocked"

        val handoff = proton_session_launch_handoff(plan, true)
        expect handoff.ok == true
        expect handoff.app_id == "480"
        expect handoff.compat_prefix == "steamapps/compatdata/480/pfx"
        expect handoff.launch_command == "hl2.exe -novid"
        expect (handoff.container_profile).contains("pressure-vessel")
        expect (handoff.container_profile).contains("container-rootfs-nvfs")
        expect (handoff.container_profile).contains("namespace-capability")
        expect (handoff.runtime_features).contains("steam-runtime")
        expect (handoff.runtime_features).contains("vkd3d-proton")
        expect handoff.status == "dry-run-ready"

    it "requires SimpleOS MDSOC executable-environment evidence before dry-run handoff":
        val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid"])
        val plan = proton_session_plan(request, proton_fixture_non_wine_runtime_evidence())
        val missing_exec_env = proton_session_launch_handoff_with_exec_env(plan, true, "simpleos-qemu-vm")
        expect missing_exec_env.ok == false
        expect missing_exec_env.error == "exec-env:missing-simpleos-full-os-boot"

        val handoff = proton_session_launch_handoff_with_exec_env(plan, true, wine_simpleos_exec_env_fixture_evidence())
        expect handoff.ok == true
        expect handoff.status == "dry-run-ready"
        expect (handoff.container_profile).contains("pressure-vessel")