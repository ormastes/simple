use common.proton_runtime_subsystems.{
    proton_fixture_non_wine_runtime_evidence,
    proton_graphics_translation_gate,
    proton_non_wine_feature_evidence,
    proton_non_wine_runtime_evidence_new,
    proton_non_wine_runtime_gate,
    proton_pressure_vessel_gate,
    proton_steam_integration_gate,
    proton_steam_runtime_gate,
    proton_sync_gate
}

describe "Non-Wine Proton runtime subsystems":
    it "gates Steam runtime ABI without depending on Wine":
        expect proton_steam_runtime_gate("") == "missing-steam-runtime"
        expect proton_steam_runtime_gate("steam-runtime soldier") == "missing-abi-x86_64"
        expect proton_steam_runtime_gate("steam-runtime abi-x86_64") == "missing-steam-linux-runtime-generation"
        expect proton_steam_runtime_gate("steam-runtime abi-x86_64 soldier") == "ready"

    it "gates pressure-vessel container evidence without depending on Wine":
        expect proton_pressure_vessel_gate("pressure-vessel-container pid fs ipc net capability") == "missing-container-rootfs"
        expect proton_pressure_vessel_gate("pressure-vessel-container container-rootfs pid fs ipc net") == "missing-capability"
        expect proton_pressure_vessel_gate("pressure-vessel-container container-rootfs pid fs ipc net capability") == "ready"

    it "gates Vulkan graphics translation evidence without depending on Wine":
        expect proton_graphics_translation_gate("vulkan-loader vulkan-device") == "missing-dxvk"
        expect proton_graphics_translation_gate("vulkan-loader vulkan-device dxvk") == "missing-vkd3d-proton"
        expect proton_graphics_translation_gate("vulkan-loader vulkan-device dxvk vkd3d-proton") == "missing-shader-cache"
        expect proton_graphics_translation_gate("vulkan-loader vulkan-device dxvk vkd3d-proton shader-cache") == "ready"

    it "gates Steam integration and sync evidence without depending on Wine":
        expect proton_steam_integration_gate("proton-launcher controller-input") == "missing-steamworks-bridge"
        expect proton_steam_integration_gate("proton-launcher steamworks-bridge controller-input") == "ready"
        expect proton_sync_gate("") == "missing-esync-or-fsync"
        expect proton_sync_gate("esync-or-fsync") == "ready"

    it "composes every non-Wine Proton subsystem":
        val missing = proton_non_wine_runtime_evidence_new(
            "steam-runtime abi-x86_64 soldier",
            "pressure-vessel-container container-rootfs pid fs ipc net capability",
            "vulkan-loader vulkan-device dxvk",
            "proton-launcher steamworks-bridge controller-input",
            "esync-or-fsync"
        )
        expect proton_non_wine_runtime_gate(missing) == "missing-vkd3d-proton"
        expect proton_non_wine_runtime_gate(proton_fixture_non_wine_runtime_evidence()) == "ready"

    it "derives Proton feature evidence for the higher readiness gate":
        val features = proton_non_wine_feature_evidence(proton_fixture_non_wine_runtime_evidence())
        expect (features).contains("steam-runtime")
        expect (features).contains("pressure-vessel-container")
        expect (features).contains("vulkan-loader")
        expect (features).contains("dxvk")
        expect (features).contains("vkd3d-proton")
        expect (features).contains("steamworks-bridge")
        expect (features).contains("controller-input")
        expect (features).contains("shader-cache")
        expect (features).contains("esync-or-fsync")