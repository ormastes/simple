use common.wine_dll_entrypoint_lifecycle.{wine_dll_entrypoint_lifecycle_gate}
use common.wine_dll_load_session.{wine_dll_load_session_new, wine_dll_session_load_modeled}

describe "wine dll entrypoint lifecycle":
    it "models TLS-before-DllMain ordering without executing DLL code":
        val session = wine_dll_load_session_new(0x76000000)
        val loaded = wine_dll_session_load_modeled(session, "kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x6000)
        val result = wine_dll_entrypoint_lifecycle_gate(loaded.dll_name, loaded.status, loaded.evidence, 0x1100, 2, false)
        expect result.ok == true
        expect result.dll_name == "kernel32.dll"
        expect result.entrypoint_rva == 0x1100
        expect result.tls_callback_count == 2
        expect result.status == "dll-entrypoint-lifecycle-modeled"
        expect (result.evidence).contains("loader-lock-acquired")
        expect (result.evidence).contains("tls-callbacks-planned")
        expect (result.evidence).contains("DllMain-process-attach-planned")
        expect (result.evidence).contains("dll-entrypoint-execution-blocked")
        expect (result.evidence).contains("tls-callback-execution-blocked")
        expect (result.evidence).contains("no-arbitrary-execution")

    it "blocks requests to actually execute DllMain or TLS callbacks":
        val session = wine_dll_load_session_new(0x77000000)
        val loaded = wine_dll_session_load_modeled(session, "kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x6000)
        val result = wine_dll_entrypoint_lifecycle_gate(loaded.dll_name, loaded.status, loaded.evidence, 0x1100, 1, true)
        expect result.ok == false
        expect result.error == "dll-entrypoint-execution-not-implemented"
        expect result.status == "blocked"
        expect (result.evidence).contains("dll-entrypoint-execution-requested")

    it "requires a modeled load session and valid lifecycle inputs":
        val missing_load = wine_dll_entrypoint_lifecycle_gate("kernel32.dll", "rolled-back", "dll-load-session-created", 0x1100, 0, false)
        expect missing_load.ok == false
        expect missing_load.error == "dll-load-session-required:rolled-back"
        val missing_evidence = wine_dll_entrypoint_lifecycle_gate("kernel32.dll", "dll-load-session-recorded", "dll-load-session-created", 0x1100, 0, false)
        expect missing_evidence.error == "missing-modeled-loaded-image-evidence"
        val invalid_entry = wine_dll_entrypoint_lifecycle_gate("kernel32.dll", "dll-load-session-recorded", "modeled-loaded-image", 0, 0, false)
        expect invalid_entry.error == "invalid-dll-entrypoint-rva"
        val invalid_tls = wine_dll_entrypoint_lifecycle_gate("kernel32.dll", "dll-load-session-recorded", "modeled-loaded-image", 0x1100, -1, false)
        expect invalid_tls.error == "invalid-tls-callback-count"