use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_process_session.{
    wine_process_plan_full_image_loader_runtime,
    wine_process_session_plan,
    wine_process_session_request_new
}

fn _full_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified user32=verified " +
        "gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified " +
        "pthread=verified dynload=verified audio=verified fonts=verified input=verified " +
        "pe_loader=verified async=verified nt_bridge=verified"

describe "Wine process session loader runtime preflight":
    it "composes full-image handoff with relocation and TLS runtime evidence":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val result = wine_process_plan_full_image_loader_runtime(plan, wine_known_hello_exe_fixture_bytes(), 0x400000, 0x400000, "native-module-open tls-callback")
        expect result.ok == true
        expect result.command == "game.exe"
        expect result.relocation_count == 0
        expect result.tls_callback_count == 0
        expect (result.evidence).contains("full-image-loader-runtime-planned")
        expect (result.evidence).contains("relocation-runtime-planned")
        expect (result.evidence).contains("tls-runtime-planned")
        expect (result.evidence).contains("relocation-no-entries")
        expect (result.evidence).contains("tls-callback-table-empty")
        expect (result.evidence).contains("no-arbitrary-execution")
        expect result.status == "full-image-loader-runtime-planned"

    it "rejects loader runtime preflight when TLS callback support is missing":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val result = wine_process_plan_full_image_loader_runtime(plan, wine_known_hello_exe_fixture_bytes(), 0x400000, 0x400000, "native-module-open")
        expect result.ok == false
        expect result.error == "tls:missing-api-tls-callback"
        expect result.relocation_count == 0
        expect result.tls_callback_count == 0
        expect (result.evidence).contains("relocation-no-entries")
        expect (result.evidence).contains("tls-directory")
        expect result.status == "rejected"