use common.wine_x86_64_decode.{wine_x86_64_hello_decode_gate, wine_x86_64_hello_decode_plan, wine_x86_64_instruction_at, wine_x86_64_instruction_len_at, wine_x86_64_scan_window}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn _minimal_image() -> [u8]:
    var data = _zero_bytes(1024)
    data[0] = 0x4d
    data[1] = 0x5a
    data = _put_u32_le(data, 0x3c, 0x80)
    data[0x80] = 0x50
    data[0x81] = 0x45
    data = _put_u16_le(data, 0x84, 0x8664)
    data = _put_u16_le(data, 0x86, 1)
    data = _put_u16_le(data, 0x94, 0xf0)
    data = _put_u16_le(data, 0x98, 0x20b)
    data = _put_u32_le(data, 0x98 + 0x10, 0x2010)
    data = _put_u32_le(data, 0x98 + 0x38, 0x5000)
    data = _put_u32_le(data, 0x98 + 0x3c, 0x200)
    data = _put_u16_le(data, 0x98 + 0x5c, 3)
    data = _put_u32_le(data, 0x98 + 0x6c, 16)
    val section_offset = 0x98 + 0xf0
    data = _put_u32_le(data, section_offset + 8, 0x300)
    data = _put_u32_le(data, section_offset + 12, 0x2000)
    data = _put_u32_le(data, section_offset + 16, 0x200)
    data = _put_u32_le(data, section_offset + 20, 0x200)
    data

fn _put_hello_code(data: [u8], offset: i64) -> [u8]:
    _put_hello_code_at_rva(data, offset, 0x2010)

fn _put_hello_code_at_rva(data: [u8], offset: i64, code_rva: i64) -> [u8]:
    data[offset] = 0x48
    data[offset + 1] = 0x31
    data[offset + 2] = 0xc9
    data[offset + 3] = 0xff
    data[offset + 4] = 0x15
    data = _put_u32_le(data, offset + 5, 0x2060 - (code_rva + 9))
    data[offset + 9] = 0x48
    data[offset + 10] = 0x8d
    data[offset + 11] = 0x15
    data = _put_u32_le(data, offset + 12, 0x2120 - (code_rva + 16))
    data[offset + 16] = 0xff
    data[offset + 17] = 0x15
    data = _put_u32_le(data, offset + 18, 0x2068 - (code_rva + 22))
    data[offset + 22] = 0x31
    data[offset + 23] = 0xc9
    data[offset + 24] = 0xff
    data[offset + 25] = 0x15
    data = _put_u32_le(data, offset + 26, 0x2070 - (code_rva + 30))
    data

fn _put_hello_code_with_safe_prologue(data: [u8], offset: i64) -> [u8]:
    data[offset] = 0x48
    data[offset + 1] = 0x83
    data[offset + 2] = 0xec
    data[offset + 3] = 0x28
    data[offset + 4] = 0x90
    _put_hello_code_at_rva(data, offset + 5, 0x2015)

fn _put_hello_code_with_frame_prologue(data: [u8], offset: i64) -> [u8]:
    data[offset] = 0x55
    data[offset + 1] = 0x48
    data[offset + 2] = 0x89
    data[offset + 3] = 0xe5
    data[offset + 4] = 0x48
    data[offset + 5] = 0x83
    data[offset + 6] = 0xec
    data[offset + 7] = 0x28
    _put_hello_code_at_rva(data, offset + 8, 0x2018)

fn _put_hello_code_with_bad_write_target(data: [u8], offset: i64) -> [u8]:
    var out = _put_hello_code(data, offset)
    out = _put_u32_le(out, offset + 18, 0)
    out

describe "Wine x86_64 hello decoder gate":
    it "rejects missing entrypoint instruction sequence":
        expect wine_x86_64_hello_decode_gate(_minimal_image()) == "unsupported-entry-instruction:unsupported-opcode"

    it "classifies supported and unsupported tiny instruction forms":
        val data = _put_hello_code(_minimal_image(), 0x210)
        expect wine_x86_64_instruction_at(data, 0x210) == "xor-rcx-rcx"
        expect wine_x86_64_instruction_len_at(data, 0x210) == 3
        expect wine_x86_64_instruction_at(data, 0x213) == "call-rip-indirect"
        expect wine_x86_64_instruction_len_at(data, 0x213) == 6
        expect wine_x86_64_instruction_at(data, 0x219) == "lea-rdx-rip-rel32"
        expect wine_x86_64_instruction_len_at(data, 0x219) == 7
        expect wine_x86_64_instruction_at(data, 0x226) == "xor-ecx-ecx"
        expect wine_x86_64_instruction_len_at(data, 0x226) == 2
        expect wine_x86_64_instruction_at(data, 0x22e) == "unsupported-opcode"
        expect wine_x86_64_instruction_len_at(data, 0x22e) == 0

    it "classifies common safe prologue and epilogue forms":
        var data = _zero_bytes(16)
        data[0] = 0x55
        data[1] = 0x48
        data[2] = 0x89
        data[3] = 0xe5
        data[4] = 0x48
        data[5] = 0x83
        data[6] = 0xec
        data[7] = 0x28
        data[8] = 0x90
        data[9] = 0x48
        data[10] = 0x83
        data[11] = 0xc4
        data[12] = 0x28
        data[13] = 0x5d
        data[14] = 0xc3
        expect wine_x86_64_instruction_at(data, 0) == "push-rbp"
        expect wine_x86_64_instruction_len_at(data, 0) == 1
        expect wine_x86_64_instruction_at(data, 1) == "mov-rbp-rsp"
        expect wine_x86_64_instruction_len_at(data, 1) == 3
        expect wine_x86_64_instruction_at(data, 4) == "sub-rsp-imm8"
        expect wine_x86_64_instruction_len_at(data, 4) == 4
        expect wine_x86_64_instruction_at(data, 8) == "nop"
        expect wine_x86_64_instruction_len_at(data, 8) == 1
        expect wine_x86_64_instruction_at(data, 9) == "add-rsp-imm8"
        expect wine_x86_64_instruction_len_at(data, 9) == 4
        expect wine_x86_64_instruction_at(data, 13) == "pop-rbp"
        expect wine_x86_64_instruction_len_at(data, 13) == 1
        expect wine_x86_64_instruction_at(data, 14) == "ret"
        expect wine_x86_64_instruction_len_at(data, 14) == 1

    it "classifies truncated near-call bytes":
        var data = _zero_bytes(4)
        data[0] = 0xe8
        expect wine_x86_64_instruction_at(data, 0) == "truncated-call-rel32"
        expect wine_x86_64_instruction_len_at(data, 0) == 0

    it "classifies truncated and unsupported rex imm8 arithmetic forms":
        var truncated = _zero_bytes(3)
        truncated[0] = 0x48
        truncated[1] = 0x83
        truncated[2] = 0xec
        expect wine_x86_64_instruction_at(truncated, 0) == "truncated-rex-alu-imm8"
        var unsupported = _zero_bytes(4)
        unsupported[0] = 0x48
        unsupported[1] = 0x83
        unsupported[2] = 0xc0
        unsupported[3] = 0x01
        expect wine_x86_64_instruction_at(unsupported, 0) == "unsupported-rex-alu-imm8"

    it "classifies unsupported rex mov forms":
        var data = _zero_bytes(3)
        data[0] = 0x48
        data[1] = 0x89
        data[2] = 0xc8
        expect wine_x86_64_instruction_at(data, 0) == "unsupported-rex-mov"
        expect wine_x86_64_instruction_len_at(data, 0) == 3

    it "scans a bounded safe prologue and epilogue window":
        var data = _zero_bytes(16)
        data[0] = 0x48
        data[1] = 0x83
        data[2] = 0xec
        data[3] = 0x28
        data[4] = 0x90
        data[5] = 0x48
        data[6] = 0x83
        data[7] = 0xc4
        data[8] = 0x28
        data[9] = 0xc3
        val scan = wine_x86_64_scan_window(data, 0, 10, 8)
        expect scan.ok == true
        expect scan.state == "ready"
        expect scan.end_offset == 10
        expect scan.instruction_count == 4
        expect scan.last_offset == 9
        expect scan.last_instruction == "ret"

    it "rejects unsupported opcodes while scanning":
        var data = _zero_bytes(4)
        data[0] = 0xff
        val scan = wine_x86_64_scan_window(data, 0, 4, 8)
        expect scan.ok == false
        expect scan.state == "unsupported-ff-instruction"
        expect scan.last_offset == 0
        expect scan.last_instruction == "unsupported-ff-instruction"

    it "rejects truncated near calls while scanning":
        var data = _zero_bytes(4)
        data[0] = 0xe8
        val scan = wine_x86_64_scan_window(data, 0, 4, 8)
        expect scan.ok == false
        expect scan.state == "truncated-call-rel32"
        expect scan.last_offset == 0
        expect scan.last_instruction == "truncated-call-rel32"

    it "rejects instructions that cross the scan byte window":
        var data = _zero_bytes(8)
        data[0] = 0x48
        data[1] = 0x83
        data[2] = 0xec
        data[3] = 0x28
        val scan = wine_x86_64_scan_window(data, 0, 3, 8)
        expect scan.ok == false
        expect scan.state == "instruction-window-overrun:sub-rsp-imm8"
        expect scan.last_offset == 0
        expect scan.last_instruction == "sub-rsp-imm8"

    it "rejects scan windows that exceed the instruction limit":
        var data = _zero_bytes(8)
        data[0] = 0x90
        data[1] = 0x90
        data[2] = 0xc3
        val scan = wine_x86_64_scan_window(data, 0, 3, 2)
        expect scan.ok == false
        expect scan.state == "instruction-limit"
        expect scan.instruction_count == 2
        expect scan.last_offset == 1
        expect scan.last_instruction == "nop"

    it "reports relative call targets for the import layer to validate":
        val plan = wine_x86_64_hello_decode_plan(_put_hello_code_with_bad_write_target(_minimal_image(), 0x210))
        expect plan.ok == true
        expect plan.get_std_handle_rva == 0x2060
        expect plan.stdout_payload_rva == 0x2120
        expect plan.write_file_rva == 0x2026
        expect plan.exit_process_rva == 0x2070

    it "recognizes the hello call skeleton after a bounded frame-pointer prologue":
        val plan = wine_x86_64_hello_decode_plan(_put_hello_code_with_frame_prologue(_minimal_image(), 0x210))
        expect plan.ok == true
        expect plan.entry_rva == 0x2010
        expect plan.sequence_rva == 0x2018
        expect plan.sequence_end_rva == 0x2036

    it "recognizes the known hello call skeleton at the PE entrypoint":
        expect wine_x86_64_hello_decode_gate(_put_hello_code(_minimal_image(), 0x210)) == "ready"

    it "recognizes the hello call skeleton after a bounded safe entry prologue":
        val plan = wine_x86_64_hello_decode_plan(_put_hello_code_with_safe_prologue(_minimal_image(), 0x210))
        expect plan.ok == true
        expect plan.entry_rva == 0x2010
        expect plan.sequence_rva == 0x2015
        expect plan.sequence_end_rva == 0x2033
        expect plan.get_std_handle_rva == 0x2060
        expect plan.stdout_payload_rva == 0x2120
        expect plan.write_file_rva == 0x2068
        expect plan.exit_process_rva == 0x2070

    it "returns a structured hello execution plan from the decoded entrypoint":
        val plan = wine_x86_64_hello_decode_plan(_put_hello_code(_minimal_image(), 0x210))
        expect plan.ok == true
        expect plan.entry_rva == 0x2010
        expect plan.sequence_rva == 0x2010
        expect plan.sequence_end_rva == 0x202e
        expect plan.instruction_sequence == "xor-rcx-rcx call-rip-indirect lea-rdx-rip-rel32 call-rip-indirect xor-ecx-ecx call-rip-indirect"
        expect plan.instruction_count == 6
        expect plan.call_sequence == "GetStdHandle WriteFile ExitProcess"
        expect plan.call_count == 3
        expect plan.get_std_handle_rva == 0x2060
        expect plan.stdout_payload_rva == 0x2120
        expect plan.write_file_rva == 0x2068
        expect plan.exit_process_rva == 0x2070