use common.wine_cpu_exec.{wine_cpu_execution_evidence_all_ready, wine_cpu_execution_evidence_text}
use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_peb_teb.{wine_peb_teb_apply_layout_byte_writes, wine_peb_teb_init_default, wine_peb_teb_layout_byte_writes, wine_peb_teb_layout_write_plan, wine_peb_teb_memory_write_gate}
use common.wine_process_session.{
    wine_process_map_known_console_image,
    wine_process_map_known_console_image_with_peb_teb_vm_writes,
    wine_process_session_plan,
    wine_process_session_request_new
}
use common.wine_vm_adapter.{WineVmSpace, wine_vm_commit, wine_vm_process_space_new, wine_vm_reserve_fixed}

fn _commit_fixed(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineVmSpace:
    val reserved = wine_vm_reserve_fixed(space, base, size)
    if not reserved.ok:
        return reserved.space
    val committed = wine_vm_commit(reserved.space, reserved.region.base, perms)
    committed.space

fn _startup_write_space() -> WineVmSpace:
    var space = wine_vm_process_space_new(10, 30, "pid fs ipc net capability")
    space = _commit_fixed(space, 0x7ffdc000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffdd000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffde000, 0x1000, "rw")
    _commit_fixed(space, 0x7ffdf000, 0x1000, "rw")

fn _full_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified user32=verified " +
        "gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified " +
        "pthread=verified dynload=verified audio=verified fonts=verified input=verified " +
        "pe_loader=verified async=verified nt_bridge=verified"

describe "Wine process session mapped image preflight":
    it "maps the patched known-console image into a bounded process address space":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val result = wine_process_map_known_console_image(plan, wine_known_hello_exe_fixture_bytes(), 8, wine_cpu_execution_evidence_text(wine_cpu_execution_evidence_all_ready()))
        expect result.ok == true
        expect result.command == "game.exe"
        expect result.mapped_base == 0x400000
        expect result.mapped_size == 0x5000
        expect (result.evidence).contains("process-image-mapped")
        expect (result.evidence).contains("os-process")
        expect (result.evidence).contains("os-address-space")
        expect (result.evidence).contains("os-vma")
        expect (result.evidence).contains("image-map")
        expect (result.evidence).contains("process-vma-write-window")
        expect (result.evidence).contains("process-vma-rx-restored")
        expect (result.evidence).contains("no-host-code-jump")
        expect result.status == "mapped-image-preflight-ready"

    it "blocks mapped-image preflight before non-import CPU evidence is complete":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val result = wine_process_map_known_console_image(plan, wine_known_hello_exe_fixture_bytes(), 8, "")
        expect result.ok == false
        expect result.error == "missing-thread-context"
        expect result.status == "blocked"

    it "maps the known-console image only after PEB/TEB VM byte-write readback":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
        val layout = wine_peb_teb_layout_write_plan(init, writes)
        val bytes = wine_peb_teb_layout_byte_writes(layout)
        val vm_writes = wine_peb_teb_apply_layout_byte_writes(_startup_write_space(), bytes)
        val result = wine_process_map_known_console_image_with_peb_teb_vm_writes(plan, wine_known_hello_exe_fixture_bytes(), 0x400000, 0x400000, "native-module-open tls-callback", 8, wine_cpu_execution_evidence_text(wine_cpu_execution_evidence_all_ready()), vm_writes)

        expect result.ok == true
        expect result.mapped_base == 0x400000
        expect (result.evidence).contains("peb-teb-vm-writes-ready")
        expect (result.evidence).contains("tls-callback-dispatch-empty")
        expect (result.evidence).contains("process-image-mapped")
        expect (result.evidence).contains("no-host-code-jump")
        expect result.status == "mapped-image-preflight-ready"

    it "blocks mapped-image preflight when PEB/TEB VM byte writes are not ready":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
        val layout = wine_peb_teb_layout_write_plan(init, writes)
        val bytes = wine_peb_teb_layout_byte_writes(layout)
        val vm_writes = wine_peb_teb_apply_layout_byte_writes(wine_vm_process_space_new(10, 30, "pid fs ipc net capability"), bytes)
        val result = wine_process_map_known_console_image_with_peb_teb_vm_writes(plan, wine_known_hello_exe_fixture_bytes(), 0x400000, 0x400000, "native-module-open tls-callback", 8, wine_cpu_execution_evidence_text(wine_cpu_execution_evidence_all_ready()), vm_writes)

        expect result.ok == false
        expect result.error == "peb-teb-vm-write:vm-write:NtTib.StackBase:page-fault-unmapped"
        expect result.status == "rejected"
        expect (result.evidence).contains("full-image-handoff-blocked")