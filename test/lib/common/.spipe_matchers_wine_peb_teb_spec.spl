use common.wine_kernel32_critical_section.{wine_kernel32_critical_section_table_new}
use common.wine_peb_teb.{WinePebTebInitEvidence, wine_peb_teb_init_default, wine_peb_teb_init_gate, wine_peb_teb_init_with_loader_lock, wine_peb_teb_layout_byte_writes, wine_peb_teb_layout_write_plan, wine_peb_teb_memory_write_gate, wine_peb_teb_required_evidence}
use common.wine_vm_adapter.{WineVmSpace, wine_vm_commit, wine_vm_process_space_new, wine_vm_reserve_fixed}

fn _loader_lock_symbols() -> [text]:
    ["InitializeCriticalSection", "EnterCriticalSection", "LeaveCriticalSection", "DeleteCriticalSection"]

fn _commit_fixed(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineVmSpace:
    val reserved = wine_vm_reserve_fixed(space, base, size)
    if not reserved.ok:
        return reserved.space
    val committed = wine_vm_commit(reserved.space, reserved.region.base, perms)
    committed.space

fn _peb_teb_write_space() -> WineVmSpace:
    var space = wine_vm_process_space_new(10, 30, "pid fs ipc net capability")
    space = _commit_fixed(space, 0x7ffdc000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffdd000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffde000, 0x1000, "rw")
    _commit_fixed(space, 0x7ffdf000, 0x1000, "rw")

describe "Wine PEB/TEB initialization gate":
    it "lists the SimpleOS and MDSOC evidence required before PEB/TEB handoff":
        val required = wine_peb_teb_required_evidence()
        expect required.len() == 8
        expect required[0] == "simpleos-process-identity"
        expect required[1] == "simpleos-thread-identity"
        expect required[2] == "simpleos-address-space"
        expect required[3] == "simpleos-stack-bounds"
        expect required[4] == "simpleos-process-parameters"
        expect required[5] == "simpleos-tls-vector"
        expect required[6] == "simpleos-mdsoc-process-port"
        expect required[7] == "simpleos-mdsoc-thread-port"

    it "accepts bounded aligned PEB, TEB, TLS, process-parameter, and stack evidence":
        val result = wine_peb_teb_init_gate(wine_peb_teb_init_default())
        expect result.ok == true
        expect result.state == "ready"
        expect result.peb_address == 0x7ffdf000
        expect result.teb_address == 0x7ffde000
        expect result.stack_base == 0x7ffef000
        expect result.stack_limit == 0x7ffee000
        expect result.tls_vector_address == 0x7ffdd000
        expect result.process_parameters_address == 0x7ffdc000
        expect result.operations == "PEB TEB TLS ProcessParameters"

    it "rejects missing MDSOC ownership evidence":
        val init = WinePebTebInitEvidence(
            process_id: 10,
            thread_id: 20,
            peb_address: 0x7ffdf000,
            teb_address: 0x7ffde000,
            image_base: 0x400000,
            stack_base: 0x7ffef000,
            stack_limit: 0x7ffee000,
            tls_vector_address: 0x7ffdd000,
            process_parameters_address: 0x7ffdc000,
            evidence: "simpleos-process-identity simpleos-thread-identity simpleos-address-space simpleos-stack-bounds simpleos-process-parameters simpleos-tls-vector"
        )
        val result = wine_peb_teb_init_gate(init)
        expect result.ok == false
        expect result.state == "missing-simpleos-mdsoc-process-port"

    it "rejects invalid stack ordering and unaligned PEB addresses":
        val bad_stack = WinePebTebInitEvidence(
            process_id: 10,
            thread_id: 20,
            peb_address: 0x7ffdf000,
            teb_address: 0x7ffde000,
            image_base: 0x400000,
            stack_base: 0x7ffee000,
            stack_limit: 0x7ffef000,
            tls_vector_address: 0x7ffdd000,
            process_parameters_address: 0x7ffdc000,
            evidence: "simpleos-process-identity simpleos-thread-identity simpleos-address-space simpleos-stack-bounds simpleos-process-parameters simpleos-tls-vector simpleos-mdsoc-process-port simpleos-mdsoc-thread-port"
        )
        expect wine_peb_teb_init_gate(bad_stack).state == "invalid-stack-bounds"

        val unaligned = WinePebTebInitEvidence(
            process_id: 10,
            thread_id: 20,
            peb_address: 0x7ffdf008,
            teb_address: 0x7ffde000,
            image_base: 0x400000,
            stack_base: 0x7ffef000,
            stack_limit: 0x7ffee000,
            tls_vector_address: 0x7ffdd000,
            process_parameters_address: 0x7ffdc000,
            evidence: "simpleos-process-identity simpleos-thread-identity simpleos-address-space simpleos-stack-bounds simpleos-process-parameters simpleos-tls-vector simpleos-mdsoc-process-port simpleos-mdsoc-thread-port"
        )
        expect wine_peb_teb_init_gate(unaligned).state == "invalid-peb-address"

    it "requires the bounded loader-lock sequence around PEB/TEB startup":
        val result = wine_peb_teb_init_with_loader_lock(wine_peb_teb_init_default(), _loader_lock_symbols(), wine_kernel32_critical_section_table_new())
        expect result.ok == true
        expect result.operations == "PEB TEB TLS ProcessParameters LoaderLock"

        val blocked = wine_peb_teb_init_with_loader_lock(
            wine_peb_teb_init_default(),
            ["EnterCriticalSection", "InitializeCriticalSection", "LeaveCriticalSection", "DeleteCriticalSection"],
            wine_kernel32_critical_section_table_new()
        )
        expect blocked.ok == false
        expect blocked.state == "loader-lock:kernel32-critical-section-sequence-expected:InitializeCriticalSection"

    it "requires writable VM mappings before PEB/TEB startup fields are mutated":
        val result = wine_peb_teb_memory_write_gate(wine_peb_teb_init_default(), _peb_teb_write_space())
        expect result.ok == true
        expect result.state == "ready"
        expect result.write_count == 4
        expect result.operations == "PEB TEB TLS ProcessParameters PEBWrite TEBWrite TLSVectorWrite ProcessParametersWrite"

    it "blocks PEB/TEB memory writes without mapped writable startup pages":
        val result = wine_peb_teb_memory_write_gate(wine_peb_teb_init_default(), wine_vm_process_space_new(10, 30, "pid fs ipc net capability"))
        expect result.ok == false
        expect result.state == "peb-write:page-fault-unmapped"
        expect result.write_count == 0

        var read_only = _peb_teb_write_space()
        read_only = _commit_fixed(wine_vm_process_space_new(10, 30, "pid fs ipc net capability"), 0x7ffdf000, 0x1000, "r")
        val blocked = wine_peb_teb_memory_write_gate(wine_peb_teb_init_default(), read_only)
        expect blocked.ok == false
        expect blocked.state == "peb-write:page-fault-write"

    it "plans x64 PEB/TEB layout writes after VM write readiness":
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, _peb_teb_write_space())
        val plan = wine_peb_teb_layout_write_plan(init, writes)

        expect plan.ok == true
        expect plan.state == "ready"
        expect plan.record_count == 6
        expect plan.records[0].field_name == "NtTib.StackBase"
        expect plan.records[0].address == 0x7ffde008
        expect plan.records[0].value == 0x7ffef000
        expect plan.records[3].field_name == "ProcessEnvironmentBlock"
        expect plan.records[3].address == 0x7ffde060
        expect plan.records[3].value == 0x7ffdf000
        expect plan.records[4].field_name == "ImageBaseAddress"
        expect plan.records[4].address == 0x7ffdf010
        expect plan.records[5].field_name == "ProcessParameters"
        expect plan.records[5].value == 0x7ffdc000
        expect (plan.operations).contains("PEBTEBLayoutWritePlan")

    it "blocks PEB/TEB layout planning when VM write readiness failed":
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, wine_vm_process_space_new(10, 30, "pid fs ipc net capability"))
        val plan = wine_peb_teb_layout_write_plan(init, writes)

        expect plan.ok == false
        expect plan.state == "write:peb-write:page-fault-unmapped"
        expect plan.record_count == 0

    it "materializes PEB/TEB layout records as little-endian byte writes":
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, _peb_teb_write_space())
        val plan = wine_peb_teb_layout_write_plan(init, writes)
        val bytes = wine_peb_teb_layout_byte_writes(plan)

        expect bytes.ok == true
        expect bytes.state == "ready"
        expect bytes.write_count == 6
        expect bytes.byte_count == 48
        expect bytes.writes[0].field_name == "NtTib.StackBase"
        expect bytes.writes[0].address == 0x7ffde008
        expect bytes.writes[0].bytes[0] == 0x00
        expect bytes.writes[0].bytes[1] == 0xf0
        expect bytes.writes[0].bytes[2] == 0xfe
        expect bytes.writes[0].bytes[3] == 0x7f
        expect bytes.writes[4].field_name == "ImageBaseAddress"
        expect bytes.writes[4].bytes[0] == 0x00
        expect bytes.writes[4].bytes[1] == 0x00
        expect bytes.writes[4].bytes[2] == 0x40
        expect (bytes.operations).contains("PEBTEBLayoutBytesWritten")

    it "blocks byte writes when PEB/TEB layout planning failed":
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, wine_vm_process_space_new(10, 30, "pid fs ipc net capability"))
        val plan = wine_peb_teb_layout_write_plan(init, writes)
        val bytes = wine_peb_teb_layout_byte_writes(plan)

        expect bytes.ok == false
        expect bytes.state == "layout:write:peb-write:page-fault-unmapped"
        expect bytes.write_count == 0