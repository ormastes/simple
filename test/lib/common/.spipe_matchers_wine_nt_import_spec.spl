use common.pe_coff_header.{PeImportSymbolBinding}
use common.wine_kernel32_module_loader.{
    WineKernel32ModuleTable,
    wine_kernel32_module_table_add_module,
    wine_kernel32_module_table_new
}
use common.wine_nt_import.{
    wine_nt_import_kernel32_module_loader_binding_gate,
    wine_nt_import_kernel32_module_loader_binding_plan,
    wine_nt_import_hello_binding_gate,
    wine_nt_import_hello_binding_plan,
    wine_nt_import_dll_gate,
    wine_nt_import_hello_gate,
    wine_nt_import_required_symbols_for_hello
}

fn _module_table() -> WineKernel32ModuleTable:
    wine_kernel32_module_table_add_module(
        wine_kernel32_module_table_new(),
        "kernel32.dll",
        ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress", "FreeLibrary"]
    )

fn _module_loader_bindings() -> [PeImportSymbolBinding]:
    [
        PeImportSymbolBinding(symbol: "GetModuleHandleW", name_rva: 0x2140),
        PeImportSymbolBinding(symbol: "LoadLibraryW", name_rva: 0x2160),
        PeImportSymbolBinding(symbol: "GetProcAddress", name_rva: 0x2180),
        PeImportSymbolBinding(symbol: "FreeLibrary", name_rva: 0x21a0)
    ]

describe "Wine NT import resolver gate":
    it "recognizes the minimal hello.exe KERNEL32 import set":
        expect wine_nt_import_required_symbols_for_hello().len() == 3
        expect wine_nt_import_dll_gate("KERNEL32.dll") == "ready"

    it "rejects unsupported DLLs before symbol checks":
        expect wine_nt_import_hello_gate("USER32.dll", ["GetStdHandle", "WriteFile", "ExitProcess"]) == "unsupported-dll:USER32.dll"

    it "reports the first missing minimal console symbol":
        expect wine_nt_import_hello_gate("KERNEL32.dll", ["GetStdHandle"]) == "missing-symbol:WriteFile"

    it "accepts the minimal console symbol set":
        expect wine_nt_import_hello_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess"]) == "ready"

    it "requires the known hello import bindings to target expected name RVAs":
        val bindings = [
            PeImportSymbolBinding(symbol: "GetStdHandle", name_rva: 0x2080),
            PeImportSymbolBinding(symbol: "WriteFile", name_rva: 0x20a0),
            PeImportSymbolBinding(symbol: "ExitProcess", name_rva: 0x20c0)
        ]
        expect wine_nt_import_hello_binding_gate("KERNEL32.dll", bindings) == "ready"

    it "returns a structured hello binding plan":
        val bindings = [
            PeImportSymbolBinding(symbol: "GetStdHandle", name_rva: 0x2080),
            PeImportSymbolBinding(symbol: "WriteFile", name_rva: 0x20a0),
            PeImportSymbolBinding(symbol: "ExitProcess", name_rva: 0x20c0)
        ]
        val plan = wine_nt_import_hello_binding_plan("KERNEL32.dll", bindings)
        expect plan.ok == true
        expect plan.dll == "kernel32.dll"
        expect plan.call_sequence == "GetStdHandle WriteFile ExitProcess"
        expect plan.binding_count == 3
        expect plan.get_std_handle_rva == 0x2080
        expect plan.write_file_rva == 0x20a0
        expect plan.exit_process_rva == 0x20c0

    it "rejects mismatched hello import binding targets":
        val bindings = [
            PeImportSymbolBinding(symbol: "GetStdHandle", name_rva: 0x2080),
            PeImportSymbolBinding(symbol: "WriteFile", name_rva: 0x2080),
            PeImportSymbolBinding(symbol: "ExitProcess", name_rva: 0x20c0)
        ]
        expect wine_nt_import_hello_binding_gate("KERNEL32.dll", bindings) == "binding-target-mismatch:WriteFile"

    it "binds KERNEL32 module-loader imports to module exports":
        expect wine_nt_import_kernel32_module_loader_binding_gate("KERNEL32.dll", _module_loader_bindings(), _module_table()) == "ready"

        val plan = wine_nt_import_kernel32_module_loader_binding_plan("KERNEL32.dll", _module_loader_bindings(), _module_table())
        expect plan.ok == true
        expect plan.dll == "kernel32.dll"
        expect plan.binding_count == 4
        expect plan.call_sequence == "GetModuleHandleW LoadLibraryW GetProcAddress FreeLibrary"
        expect plan.module_handle == 0x120
        expect plan.get_module_handle_name_rva == 0x2140
        expect plan.get_module_handle_proc_address == 0x120000 + 1
        expect plan.get_proc_address_proc_address == 0x120000 + 3

    it "rejects incomplete or unexported module-loader import bindings":
        val missing = [
            PeImportSymbolBinding(symbol: "GetModuleHandleW", name_rva: 0x2140),
            PeImportSymbolBinding(symbol: "LoadLibraryW", name_rva: 0x2160),
            PeImportSymbolBinding(symbol: "GetProcAddress", name_rva: 0x2180)
        ]
        expect wine_nt_import_kernel32_module_loader_binding_gate("KERNEL32.dll", missing, _module_table()) == "missing-binding:FreeLibrary"

        val missing_module = wine_nt_import_kernel32_module_loader_binding_gate("USER32.dll", _module_loader_bindings(), _module_table())
        expect missing_module == "unsupported-dll:USER32.dll"

        val incomplete_exports = wine_kernel32_module_table_add_module(wine_kernel32_module_table_new(), "kernel32.dll", ["GetModuleHandleW", "LoadLibraryW", "GetProcAddress"])
        expect wine_nt_import_kernel32_module_loader_binding_gate("KERNEL32.dll", _module_loader_bindings(), incomplete_exports) == "module-loader-export:FreeLibrary"