use common.wine_kernel32_startup_info.{
    WineKernel32StartupInfo,
    wine_kernel32_execute_startup_info,
    wine_kernel32_startup_info_default
}

describe "Wine KERNEL32 startup info bridge":
    it "executes bounded startup info and standard handle discovery":
        val result = wine_kernel32_execute_startup_info(
            ["GetStartupInfoW", "GetStdHandle", "GetStdHandle", "GetStdHandle"],
            wine_kernel32_startup_info_default()
        )

        expect result.ok == true
        expect result.show_window == 1
        expect result.std_input == -10
        expect result.std_output == -11
        expect result.std_error == -12
        expect result.desktop == "winsta0\\default"
        expect result.operations == "GetStartupInfoW GetStdHandle GetStdHandle GetStdHandle"

    it "keeps startup info dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_startup_info(
            ["GetStdHandle", "GetStartupInfoW", "GetStdHandle", "GetStdHandle"],
            wine_kernel32_startup_info_default()
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-startup-info-sequence-expected:GetStartupInfoW"

        val wrong_family = wine_kernel32_execute_startup_info(
            ["GetStartupInfoW", "GetStdHandle", "GetStdHandle", "HeapAlloc"],
            wine_kernel32_startup_info_default()
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:HeapAlloc"

    it "rejects invalid standard handle models":
        val info = WineKernel32StartupInfo(show_window: 1, std_input: -10, std_output: 99, std_error: -12, desktop: "winsta0\\default", title: "SimpleOS Wine")
        val result = wine_kernel32_execute_startup_info(
            ["GetStartupInfoW", "GetStdHandle", "GetStdHandle", "GetStdHandle"],
            info
        )

        expect result.ok == false
        expect result.error == "GetStdHandle:invalid-stdout"