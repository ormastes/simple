    it "implements bounded ADVAPI32 registry symbols":
        val symbols = wine_nt_api_implemented_advapi32_registry_symbols()
        expect symbols.len() == 5
        expect symbols[0] == "RegCreateKeyExW"
        expect wine_nt_api_advapi32_import_gate("advapi32.dll", symbols) == "ready"
        expect wine_nt_api_advapi32_dispatch_gate(symbols) == "ready"

    it "implements bounded ADVAPI32 service-control symbols":
        val symbols = wine_nt_api_implemented_advapi32_service_symbols()
        expect symbols.len() == 5
        expect symbols[0] == "OpenSCManagerW"
        expect wine_nt_api_advapi32_import_gate("advapi32.dll", symbols) == "ready"
        expect wine_nt_api_advapi32_dispatch_gate(symbols) == "ready"