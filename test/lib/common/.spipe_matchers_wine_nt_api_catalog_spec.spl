use common.wine_nt_api_catalog.{
    wine_nt_api_catalogued_future_symbols,
    wine_nt_api_dispatch_gate,
    wine_nt_api_dll_gate,
    wine_nt_api_gui_dispatch_gate,
    wine_nt_api_gui_import_gate,
    wine_nt_api_implemented_symbols_for_gui_hello,
    wine_nt_api_implemented_symbols_for_hello,
    wine_nt_api_import_gate,
    wine_nt_api_modeled_precondition_symbols,
    wine_nt_api_symbol_state
}

describe "Wine NT API catalog":
    it "keeps the executable hello surface to the implemented console/process calls":
        val symbols = wine_nt_api_implemented_symbols_for_hello()
        expect symbols.len() == 3
        expect symbols[0] == "GetStdHandle"
        expect wine_nt_api_import_gate("KERNEL32.dll", symbols) == "ready"

    it "catalogs broader NT and Win32 prerequisites without marking them implemented":
        val future = wine_nt_api_catalogued_future_symbols()
        expect future.len() > 30
        val entry = wine_nt_api_symbol_state("kernel32.dll", "VirtualAlloc")
        expect entry.category == "virtual-memory"
        expect entry.state == "catalogued"

    it "records modeled precondition calls that are still not import-dispatchable":
        val modeled = wine_nt_api_modeled_precondition_symbols()
        expect modeled.len() == 34
        expect modeled[0] == "VirtualAlloc"
        expect modeled[3] == "CreateFileW"
        expect modeled[6] == "CreateThread"
        expect modeled[9] == "GetCommandLineW"
        expect modeled[11] == "HeapAlloc"
        expect modeled[13] == "NtAllocateVirtualMemory"
        expect modeled[19] == "RtlAllocateHeap"
        expect modeled[21] == "CreateWindowExW"
        expect modeled[29] == "TextOutW"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"]) == "catalogued-symbol:VirtualAlloc"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "CreateFileW"]) == "catalogued-symbol:CreateFileW"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "CreateThread"]) == "catalogued-symbol:CreateThread"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "GetCommandLineW"]) == "catalogued-symbol:GetCommandLineW"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "HeapAlloc"]) == "catalogued-symbol:HeapAlloc"

    it "keeps ntdll as catalogued but not import-ready for the hello milestone":
        expect wine_nt_api_dll_gate("ntdll.dll") == "catalogued-dll:ntdll.dll"
        expect wine_nt_api_import_gate("ntdll.dll", ["NtAllocateVirtualMemory"]) == "catalogued-dll:ntdll.dll"

    it "blocks unknown imports before dispatch can pretend they exist":
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "UnknownApi"]) == "unsupported-symbol:UnknownApi"

    it "reports catalogued symbols distinctly from implemented bridge calls":
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"]) == "catalogued-symbol:VirtualAlloc"
        expect wine_nt_api_dispatch_gate(["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"]) == "bridge-unsupported:VirtualAlloc"

    it "preserves the bridge missing-symbol order for the known hello call table":
        expect wine_nt_api_dispatch_gate(["GetStdHandle"]) == "bridge-missing:WriteFile"

    it "implements only MessageBoxW for the controlled GUI milestone":
        val symbols = wine_nt_api_implemented_symbols_for_gui_hello()
        expect symbols.len() == 1
        expect symbols[0] == "MessageBoxW"
        expect wine_nt_api_gui_import_gate("user32.dll", ["MessageBoxW"]) == "ready"
        expect wine_nt_api_gui_import_gate("user32.dll", ["MessageBoxW", "CreateWindowExW"]) == "catalogued-symbol:CreateWindowExW"
        expect wine_nt_api_gui_import_gate("gdi32.dll", ["TextOutW"]) == "catalogued-dll:gdi32.dll"
        expect wine_nt_api_gui_dispatch_gate(["MessageBoxW"]) == "ready"
        expect wine_nt_api_gui_dispatch_gate(["CreateWindowExW"]) == "bridge-missing:MessageBoxW"