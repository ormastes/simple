describe "Wine NT API catalog":
    it "keeps the executable hello surface to the implemented console/process calls":
        val symbols = wine_nt_api_implemented_symbols_for_hello()
        expect symbols.len() == 3
        expect symbols[0] == "GetStdHandle"
        expect wine_nt_api_import_gate("KERNEL32.dll", symbols) == "ready"

    it "catalogs broader NT and Win32 prerequisites without marking them implemented":
        val future = wine_nt_api_catalogued_future_symbols()
        expect future.len() > 30
        val entry = wine_nt_api_symbol_state("kernel32.dll", "VirtualAlloc")
        expect entry.category == "virtual-memory"
        expect entry.state == "implemented"

    it "records modeled precondition calls and keeps non-hello symbols on dedicated gates":
        val modeled = wine_nt_api_modeled_precondition_symbols()
        expect modeled.len() == 87
        expect modeled[0] == "VirtualAlloc"
        expect modeled[3] == "CreateFileW"
        expect modeled[6] == "GetFileAttributesW"
        expect modeled[8] == "SetFilePointer"
        expect modeled[9] == "CreateThread"
        expect modeled[12] == "SetLastError"
        expect modeled[13] == "FormatMessageW"
        expect modeled[14] == "GetCommandLineW"
        expect modeled[16] == "GetCurrentDirectoryW"
        expect modeled[19] == "GetEnvironmentVariableW"
        expect modeled[21] == "ExpandEnvironmentStringsW"
        expect modeled[22] == "GetProcessHeap"
        expect modeled[25] == "LocalAlloc"
        expect modeled[28] == "LocalFree"
        expect modeled[29] == "GlobalAlloc"
        expect modeled[30] == "GlobalSize"
        expect modeled[31] == "GlobalLock"
        expect modeled[32] == "GlobalUnlock"
        expect modeled[33] == "GlobalReAlloc"
        expect modeled[34] == "GlobalFree"
        expect modeled[35] == "NtAllocateVirtualMemory"
        expect modeled[41] == "RtlAllocateHeap"
        expect modeled[43] == "RtlInitUnicodeString"
        expect modeled[45] == "RtlFreeAnsiString"
        expect modeled[46] == "GetModuleHandleW"
        expect modeled[49] == "FreeLibrary"
        expect modeled[50] == "GetTickCount"
        expect modeled[54] == "GetVersionExW"
        expect modeled[55] == "GetWindowsDirectoryW"
        expect modeled[58] == "SearchPathW"
        expect modeled[59] == "GetCurrentProcessId"
        expect modeled[62] == "GetCurrentThread"
        expect modeled[63] == "CreateEventW"
        expect modeled[65] == "ResetEvent"
        expect modeled[66] == "GetStartupInfoW"
        expect modeled[67] == "InitializeCriticalSection"
        expect modeled[70] == "DeleteCriticalSection"
        expect modeled[71] == "GlobalAddAtomW"
        expect modeled[73] == "GlobalDeleteAtom"
        expect modeled[74] == "TlsAlloc"
        expect modeled[77] == "TlsFree"
        expect modeled[78] == "FlsAlloc"
        expect modeled[81] == "FlsFree"
        expect modeled[82] == "InterlockedIncrement"
        expect modeled[86] == "InterlockedExchangeAdd"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"]) == "wrong-category:VirtualAlloc"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "CreateFileW"]) == "wrong-category:CreateFileW"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "CreateThread"]) == "wrong-category:CreateThread"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "GetCommandLineW"]) == "wrong-category:GetCommandLineW"
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "HeapAlloc"]) == "wrong-category:HeapAlloc"

    it "keeps GUI and GDI catalog symbols out of the console precondition bridge":
        val gui = wine_nt_api_catalogued_gui_symbols()
        expect gui.len() == 12
        expect gui[0] == "CreateWindowExW"
        expect gui[8] == "TextOutW"

    it "keeps ntdll as catalogued but not import-ready for the hello milestone":
        expect wine_nt_api_dll_gate("ntdll.dll") == "catalogued-dll:ntdll.dll"
        expect wine_nt_api_import_gate("ntdll.dll", ["NtAllocateVirtualMemory"]) == "catalogued-dll:ntdll.dll"
        expect wine_nt_api_ntdll_file_io_import_gate("ntdll.dll", ["RtlAllocateHeap"]) == "wrong-category:RtlAllocateHeap"

    it "blocks unknown imports before dispatch can pretend they exist":
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "UnknownApi"]) == "unsupported-symbol:UnknownApi"

    it "keeps the generic hello bridge separate from implemented dedicated KERNEL32 families":
        expect wine_nt_api_import_gate("kernel32.dll", ["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"]) == "wrong-category:VirtualAlloc"
        expect wine_nt_api_dispatch_gate(["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"]) == "bridge-wrong-category:VirtualAlloc"

    it "preserves the bridge missing-symbol order for the known hello call table":
        expect wine_nt_api_dispatch_gate(["GetStdHandle"]) == "bridge-missing:WriteFile"

    it "implements bounded KERNEL32 process environment symbols":
        val symbols = wine_nt_api_implemented_kernel32_process_env_symbols()
        expect symbols.len() == 8
        expect symbols[0] == "GetCommandLineW"
        expect symbols[2] == "GetCurrentDirectoryW"
        expect symbols[4] == "GetModuleFileNameW"
        expect symbols[7] == "ExpandEnvironmentStringsW"
        expect wine_nt_api_kernel32_process_env_import_gate("kernel32.dll", symbols) == "ready"
        expect wine_nt_api_kernel32_process_env_dispatch_gate(symbols) == "ready"
        expect wine_nt_api_kernel32_process_env_dispatch_gate(["GetStdHandle"]) == "bridge-wrong-category:GetStdHandle"

    it "implements bounded KERNEL32 virtual memory symbols":
        val symbols = wine_nt_api_implemented_kernel32_virtual_memory_symbols()
        expect symbols.len() == 3
        expect symbols[0] == "VirtualAlloc"
        expect wine_nt_api_kernel32_virtual_memory_import_gate("kernel32.dll", symbols) == "ready"
        expect wine_nt_api_kernel32_virtual_memory_dispatch_gate(symbols) == "ready"
        expect wine_nt_api_kernel32_virtual_memory_dispatch_gate(["GetStdHandle"]) == "bridge-wrong-category:GetStdHandle"

