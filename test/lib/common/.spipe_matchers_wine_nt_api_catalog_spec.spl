    it "implements MessageBoxW for the controlled GUI milestone":
        val symbols = wine_nt_api_implemented_symbols_for_gui_hello()
        expect symbols.len() == 1
        expect symbols[0] == "MessageBoxW"
        expect wine_nt_api_gui_import_gate("user32.dll", ["MessageBoxW"]) == "ready"
        expect wine_nt_api_gui_import_gate("user32.dll", ["MessageBoxW", "TextOutW"]) == "unsupported-symbol:TextOutW"
        expect wine_nt_api_gdi_import_gate("gdi32.dll", ["TextOutW"]) == "ready"
        expect wine_nt_api_gui_dispatch_gate(["MessageBoxW"]) == "ready"
        expect wine_nt_api_gui_dispatch_gate(["TextOutW"]) == "bridge-unsupported:TextOutW"

    it "implements the bounded USER32 window lifecycle symbols":
        val symbols = wine_nt_api_implemented_user32_window_symbols()
        expect symbols.len() == 4
        expect symbols[0] == "CreateWindowExW"
        expect wine_nt_api_gui_import_gate("user32.dll", symbols) == "ready"
        expect wine_nt_api_gui_dispatch_gate(symbols) == "ready"

