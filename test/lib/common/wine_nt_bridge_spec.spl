use common.wine_nt_bridge.{
    wine_nt_bridge_call_exit_process,
    wine_nt_bridge_call_get_std_handle,
    wine_nt_bridge_call_write_file,
    wine_nt_bridge_dispatch_call,
    wine_nt_bridge_exit_code_zero,
    wine_nt_bridge_execute_hello_stdout,
    wine_nt_bridge_execute_message_box_sequence,
    wine_nt_bridge_execute_stdout_sequence,
    wine_nt_bridge_gate,
    wine_nt_bridge_modeled_precondition_gate,
    wine_nt_bridge_stdout_handle,
    wine_nt_bridge_write_file,
    wine_nt_bridge_write_stdout
}

describe "Wine NT bridge":
    it "requires the known console bridge calls":
        expect(wine_nt_bridge_gate(["GetStdHandle", "WriteFile"])).to_equal("bridge-missing:ExitProcess")

    it "accepts the known hello bridge table":
        expect(wine_nt_bridge_gate(["GetStdHandle", "WriteFile", "ExitProcess"])).to_equal("ready")

    it "separates modeled precondition routing from arbitrary import dispatch":
        val vm = wine_nt_bridge_modeled_precondition_gate("kernel32.dll", "VirtualAlloc")
        val heap = wine_nt_bridge_modeled_precondition_gate("kernel32.dll", "HeapAlloc")
        val ntdll = wine_nt_bridge_modeled_precondition_gate("ntdll.dll", "NtAllocateVirtualMemory")
        expect(vm.ok).to_equal(true)
        expect(vm.state).to_equal("implemented")
        expect(heap.category).to_equal("heap")
        expect(ntdll.ok).to_equal(true)
        expect(ntdll.category).to_equal("nt-virtual-memory")
        expect(wine_nt_bridge_gate(["GetStdHandle", "WriteFile", "ExitProcess", "VirtualAlloc"])).to_equal("bridge-wrong-category:VirtualAlloc")

    it "rejects unknown precondition routing symbols":
        val result = wine_nt_bridge_modeled_precondition_gate("kernel32.dll", "UnknownApi")
        expect(result.ok).to_equal(false)
        expect(result.state).to_equal("unsupported-symbol:UnknownApi")

    it "models the stdout handle and exit code for the milestone":
        expect(wine_nt_bridge_stdout_handle()).to_equal(-11)
        expect(wine_nt_bridge_exit_code_zero()).to_equal(0)

    it "writes only through the bridge helper":
        expect(wine_nt_bridge_write_stdout("Hello from SimpleOS Wine\n")).to_equal("Hello from SimpleOS Wine\n")

    it "requires stdout handle and byte count for WriteFile":
        expect(wine_nt_bridge_write_file(-11, "Hello from SimpleOS Wine\n", 25)).to_equal("Hello from SimpleOS Wine\n")
        expect(wine_nt_bridge_write_file(-12, "Hello from SimpleOS Wine\n", 25)).to_equal("")
        expect(wine_nt_bridge_write_file(-11, "Hello from SimpleOS Wine\n", 5)).to_equal("")

    it "dispatches the modeled hello NT calls with structured results":
        val handle = wine_nt_bridge_call_get_std_handle(-11)
        expect(handle.ok).to_equal(true)
        expect(handle.symbol).to_equal("GetStdHandle")
        expect(handle.i64_value).to_equal(-11)

        val write = wine_nt_bridge_call_write_file(handle.i64_value, "Hello from SimpleOS Wine\n", 25)
        expect(write.ok).to_equal(true)
        expect(write.symbol).to_equal("WriteFile")
        expect(write.i64_value).to_equal(25)
        expect(write.text_value).to_equal("Hello from SimpleOS Wine\n")

        val exit = wine_nt_bridge_call_exit_process(0)
        expect(exit.ok).to_equal(true)
        expect(exit.symbol).to_equal("ExitProcess")
        expect(exit.i64_value).to_equal(0)

    it "rejects unsupported dispatch calls and invalid modeled arguments":
        expect(wine_nt_bridge_dispatch_call("VirtualAlloc", -11, "", 0).error).to_equal("bridge-unsupported:VirtualAlloc")
        expect(wine_nt_bridge_call_get_std_handle(-12).error).to_equal("unsupported-std-handle")
        expect(wine_nt_bridge_call_exit_process(5).error).to_equal("unsupported-exit-code")

    it "returns structured execution evidence for the hello stdout bridge":
        val result = wine_nt_bridge_execute_hello_stdout("Hello from SimpleOS Wine\n")
        expect(result.ok).to_equal(true)
        expect(result.stdout_handle).to_equal(-11)
        expect(result.bytes_written).to_equal(25)
        expect(result.exit_code).to_equal(0)
        expect(result.stdout).to_equal("Hello from SimpleOS Wine\n")

    it "executes stdout only through the ordered NT call sequence":
        val result = wine_nt_bridge_execute_stdout_sequence(["GetStdHandle", "WriteFile", "ExitProcess"], "Hello from SimpleOS Wine\n")
        expect(result.ok).to_equal(true)
        expect(result.bytes_written).to_equal(25)
        expect(wine_nt_bridge_execute_stdout_sequence(["WriteFile", "GetStdHandle", "ExitProcess"], "Hello from SimpleOS Wine\n").error).to_equal("bridge-sequence-expected:GetStdHandle")
        expect(wine_nt_bridge_execute_stdout_sequence(["GetStdHandle", "WriteFile"], "Hello from SimpleOS Wine\n").error).to_equal("bridge-sequence-count-mismatch")

    it "rejects empty bridge payload execution":
        val result = wine_nt_bridge_execute_hello_stdout("")
        expect(result.ok).to_equal(false)
        expect(result.error).to_equal("empty-payload")

    it "executes only the controlled USER32 MessageBoxW GUI bridge":
        val result = wine_nt_bridge_execute_message_box_sequence(["MessageBoxW"], "SimpleOS Wine GUI Hello", "Hello from SimpleOS Wine\n")
        expect(result.ok).to_equal(true)
        expect(result.symbol).to_equal("MessageBoxW")
        expect(result.title).to_equal("SimpleOS Wine GUI Hello")
        expect(result.message).to_equal("Hello from SimpleOS Wine\n")
        expect(result.result_code).to_equal(1)
        expect(wine_nt_bridge_execute_message_box_sequence(["CreateWindowExW"], "title", "message").error).to_equal("user32-message-box-expected:MessageBoxW")
        expect(wine_nt_bridge_execute_message_box_sequence(["MessageBoxW"], "", "message").error).to_equal("empty-title")
