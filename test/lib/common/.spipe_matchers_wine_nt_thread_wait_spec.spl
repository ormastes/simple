use common.wine_nt_thread_wait.{
    wine_nt_create_pending_thread,
    wine_nt_create_thread,
    wine_nt_get_last_error,
    wine_nt_thread_table_new,
    wine_nt_thread_wait_required_calls,
    wine_nt_wait_for_single_object
}

fn _all_thread_apis() -> text:
    "thread-create thread-join thread-detach thread-current-id thread-yield " +
        "mutex-create mutex-lock mutex-try-lock mutex-unlock " +
        "condvar-create condvar-wait condvar-wait-timeout condvar-signal condvar-broadcast " +
        "tls-key-create tls-get tls-set tls-delete " +
        "semaphore-create semaphore-wait semaphore-post " +
        "event-create event-wait event-signal event-reset thread-fault-record"

describe "Wine NT thread/wait bridge":
    it "lists the modeled CreateThread, WaitForSingleObject, and GetLastError calls":
        val calls = wine_nt_thread_wait_required_calls()
        expect calls.len() == 3
        expect calls[0] == "CreateThread"

    it "blocks thread table readiness until thread prerequisites pass":
        val table = wine_nt_thread_table_new("thread-create thread-join")
        expect table.ready == false
        expect table.state == "missing-api-thread-detach"
        expect wine_nt_get_last_error(table) == "missing-api-thread-detach"

    it "creates a modeled thread handle and waits for completion":
        val created = wine_nt_create_thread(wine_nt_thread_table_new(_all_thread_apis()), "main", 7)
        expect created.ok == true
        expect created.handle == 0x80
        val waited = wine_nt_wait_for_single_object(created.table, created.handle, 1000)
        expect waited.ok == true
        expect waited.wait_status == "WAIT_OBJECT_0"
        expect waited.exit_code == 7
        expect wine_nt_get_last_error(waited.table) == "OK"

    it "rejects invalid entrypoints and exposes last error":
        val created = wine_nt_create_thread(wine_nt_thread_table_new(_all_thread_apis()), "", 0)
        expect created.ok == false
        expect created.state == "invalid-entrypoint"
        expect wine_nt_get_last_error(created.table) == "ERROR_INVALID_PARAMETER"

    it "rejects invalid wait handles and exposes last error":
        val waited = wine_nt_wait_for_single_object(wine_nt_thread_table_new(_all_thread_apis()), 0x99, 0)
        expect waited.ok == false
        expect waited.state == "invalid-handle"
        expect wine_nt_get_last_error(waited.table) == "ERROR_INVALID_HANDLE"

    it "reports timeout for unsignaled modeled handles":
        val created = wine_nt_create_pending_thread(wine_nt_thread_table_new(_all_thread_apis()), "worker")
        expect created.state == "created-pending"
        val waited = wine_nt_wait_for_single_object(created.table, created.handle, 0)
        expect waited.ok == true
        expect waited.state == "wait-timeout"
        expect waited.wait_status == "WAIT_TIMEOUT"