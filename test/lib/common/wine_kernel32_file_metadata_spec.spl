use common.wine_kernel32_file_metadata.{wine_kernel32_execute_file_metadata}
use common.wine_nt_file_io.{WineNtFileTable, wine_nt_file_read, wine_nt_file_table_add_file, wine_nt_file_table_new}

fn _all_adapter_apis() -> text:
    "fd-open fd-read fd-write fd-close fd-dup fd-inherit stdio pipe socket timer poll-wait " +
        "cwd env argv spawn path-normalize path-attrs path-locks errno-map"

fn _all_async_features() -> text:
    "io-driver submit-open submit-read submit-write submit-close submit-timeout poll-completion " +
        "event-loop register-fd deregister-fd waker wake"

fn _table_with_file() -> WineNtFileTable:
    wine_nt_file_table_add_file(wine_nt_file_table_new(_all_adapter_apis(), _all_async_features()), "C:\\hello.txt", "hello wine")

describe "Wine KERNEL32 file metadata bridge":
    it "executes a bounded attributes, open, size, seek, and close sequence":
        val result = wine_kernel32_execute_file_metadata(
            ["GetFileAttributesW", "CreateFileW", "GetFileSize", "SetFilePointer", "CloseHandle"],
            _table_with_file(),
            "C:\\hello.txt",
            6
        )

        expect(result.ok).to_equal(true)
        expect(result.handle).to_equal(0x40)
        expect(result.attributes).to_equal(0x80)
        expect(result.size).to_equal(10)
        expect(result.pointer).to_equal(6)
        expect(result.operations).to_equal("GetFileAttributesW CreateFileW GetFileSize SetFilePointer CloseHandle")
        expect(wine_nt_file_read(result.table, result.handle, 1).state).to_equal("invalid-handle")

    it "keeps file metadata dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_file_metadata(
            ["CreateFileW", "GetFileAttributesW", "GetFileSize", "SetFilePointer", "CloseHandle"],
            _table_with_file(),
            "C:\\hello.txt",
            6
        )
        expect(out_of_order.ok).to_equal(false)
        expect(out_of_order.error).to_equal("kernel32-file-metadata-sequence-expected:GetFileAttributesW")

        val wrong_family = wine_kernel32_execute_file_metadata(
            ["GetFileAttributesW", "CreateFileW", "GetFileSize", "HeapAlloc", "CloseHandle"],
            _table_with_file(),
            "C:\\hello.txt",
            6
        )
        expect(wrong_family.ok).to_equal(false)
        expect(wrong_family.error).to_equal("bridge-wrong-category:HeapAlloc")

    it "propagates metadata and pointer failures":
        val missing = wine_kernel32_execute_file_metadata(
            ["GetFileAttributesW", "CreateFileW", "GetFileSize", "SetFilePointer", "CloseHandle"],
            _table_with_file(),
            "C:\\missing.txt",
            0
        )
        expect(missing.ok).to_equal(false)
        expect(missing.error).to_equal("GetFileAttributesW:file-not-found")

        val past_eof = wine_kernel32_execute_file_metadata(
            ["GetFileAttributesW", "CreateFileW", "GetFileSize", "SetFilePointer", "CloseHandle"],
            _table_with_file(),
            "C:\\hello.txt",
            99
        )
        expect(past_eof.ok).to_equal(false)
        expect(past_eof.error).to_equal("SetFilePointer:file-pointer-past-eof")
