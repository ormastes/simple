use common.wine_kernel32_heap.{wine_kernel32_execute_heap}
use common.wine_nt_heap.{wine_nt_heap_alloc, wine_nt_process_heap_new}
use common.wine_vm_adapter.{wine_vm_space_new}

describe "Wine KERNEL32 heap bridge":
    it "executes a bounded HeapAlloc and HeapFree sequence":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val result = wine_kernel32_execute_heap(["GetProcessHeap", "HeapAlloc", "HeapFree"], heap, 48)

        expect result.ok == true
        expect result.ptr == 0x71000000
        expect result.size == 48
        expect result.operations == "GetProcessHeap HeapAlloc HeapFree"
        expect result.heap.blocks[0].freed == true

    it "keeps heap dispatch ordered and bounded":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val out_of_order = wine_kernel32_execute_heap(["HeapAlloc", "GetProcessHeap", "HeapFree"], heap, 16)
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-heap-sequence-expected:GetProcessHeap"

        val wrong_family = wine_kernel32_execute_heap(["GetProcessHeap", "HeapAlloc", "VirtualFree"], heap, 16)
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:VirtualFree"

        val invalid = wine_kernel32_execute_heap(["GetProcessHeap", "HeapAlloc", "HeapFree"], wine_nt_process_heap_new(wine_vm_space_new(), false), 16)
        expect invalid.ok == false
        expect invalid.error == "GetProcessHeap:missing-process-heap"

    it "preserves heap state when freeing through KERNEL32":
        val heap = wine_nt_process_heap_new(wine_vm_space_new(), true)
        val seeded = wine_nt_heap_alloc(heap, heap.handle, 12)
        val result = wine_kernel32_execute_heap(["GetProcessHeap", "HeapAlloc", "HeapFree"], seeded.heap, 8)

        expect result.ok == true
        expect result.heap.blocks.len() == 2
        expect result.heap.blocks[0].freed == false
        expect result.heap.blocks[1].freed == true