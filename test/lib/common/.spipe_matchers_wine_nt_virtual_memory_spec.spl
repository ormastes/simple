use common.wine_nt_virtual_memory.{
    wine_nt_virtual_memory_alloc,
    wine_nt_virtual_memory_free,
    wine_nt_virtual_memory_protect,
    wine_nt_virtual_memory_required_calls
}
use common.wine_vm_adapter.{wine_vm_access_gate, wine_vm_space_new}

describe "Wine NT virtual memory bridge":
    it "lists the modeled VirtualAlloc, VirtualProtect, and VirtualFree calls":
        val calls = wine_nt_virtual_memory_required_calls()
        expect calls.len() == 3
        expect calls[0] == "VirtualAlloc"

    it "allocates automatic committed memory through the VM adapter":
        val allocated = wine_nt_virtual_memory_alloc(wine_vm_space_new(), 0, 0x2000, "rw")
        expect allocated.ok == true
        expect allocated.state == "allocated"
        expect allocated.base == 0x10000000
        expect wine_vm_access_gate(allocated.space, allocated.base, "write") == "ready"

    it "allocates fixed memory and rejects fixed overlap":
        val first = wine_nt_virtual_memory_alloc(wine_vm_space_new(), 0x400000, 0x2000, "rw")
        val second = wine_nt_virtual_memory_alloc(first.space, 0x401000, 0x1000, "rw")
        expect first.ok == true
        expect second.ok == false
        expect second.state == "fixed-map-conflict"

    it "protects committed memory and returns old permissions":
        val allocated = wine_nt_virtual_memory_alloc(wine_vm_space_new(), 0x500000, 0x1000, "rw")
        val protected = wine_nt_virtual_memory_protect(allocated.space, 0x500000, "rx")
        expect protected.ok == true
        expect protected.state == "protected"
        expect protected.old_perms == "rw"
        expect wine_vm_access_gate(protected.space, 0x500000, "execute") == "ready"
        expect wine_vm_access_gate(protected.space, 0x500000, "write") == "page-fault-write"

    it "frees mapped memory through the VM adapter":
        val allocated = wine_nt_virtual_memory_alloc(wine_vm_space_new(), 0x600000, 0x1000, "rw")
        val freed = wine_nt_virtual_memory_free(allocated.space, 0x600000)
        expect freed.ok == true
        expect freed.state == "freed"
        expect wine_vm_access_gate(freed.space, 0x600000, "read") == "page-fault-unmapped"

    it "rejects invalid allocation and missing protect/free targets":
        expect wine_nt_virtual_memory_alloc(wine_vm_space_new(), 0, 0, "rw").state == "invalid-size"
        expect wine_nt_virtual_memory_protect(wine_vm_space_new(), 0x700000, "rx").state == "missing-region"
        expect wine_nt_virtual_memory_free(wine_vm_space_new(), 0x700000).state == "missing-region"