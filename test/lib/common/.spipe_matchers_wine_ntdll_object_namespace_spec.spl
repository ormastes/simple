use common.wine_ntdll_object_namespace.{
    wine_ntdll_execute_object_namespace,
    wine_ntdll_object_namespace_default
}

describe "Wine NTDLL object namespace bridge":
    it "executes bounded directory object open, query, and close":
        val result = wine_ntdll_execute_object_namespace(
            ["NtOpenDirectoryObject", "NtQueryDirectoryObject", "NtClose"],
            wine_ntdll_object_namespace_default(),
            "\\KnownDlls"
        )

        expect result.ok == true
        expect result.handle == 0x500
        expect result.entries == "kernel32.dll ntdll.dll user32.dll"
        expect result.operations == "NtOpenDirectoryObject NtQueryDirectoryObject NtClose"

    it "keeps object namespace dispatch ordered and bounded":
        val out_of_order = wine_ntdll_execute_object_namespace(
            ["NtQueryDirectoryObject", "NtOpenDirectoryObject", "NtClose"],
            wine_ntdll_object_namespace_default(),
            "\\KnownDlls"
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "ntdll-object-namespace-sequence-expected:NtOpenDirectoryObject"

        val wrong_family = wine_ntdll_execute_object_namespace(
            ["NtOpenDirectoryObject", "NtQueryDirectoryObject", "NtCreateFile"],
            wine_ntdll_object_namespace_default(),
            "\\KnownDlls"
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:NtCreateFile"

    it "rejects unknown object directories":
        val result = wine_ntdll_execute_object_namespace(
            ["NtOpenDirectoryObject", "NtQueryDirectoryObject", "NtClose"],
            wine_ntdll_object_namespace_default(),
            "\\Missing"
        )
        expect result.ok == false
        expect result.error == "NtOpenDirectoryObject:directory-not-found"