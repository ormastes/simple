use common.wine_dll_load_session.{
    wine_dll_load_session_loaded_count,
    wine_dll_load_session_new,
    wine_dll_session_load_modeled,
    wine_dll_session_load_with_rollback,
    wine_dll_session_unload_modeled
}

describe "wine dll load session":
    it "records modeled loaded image state after image-map handoff":
        val session = wine_dll_load_session_new(0x71000000)
        val result = wine_dll_session_load_modeled(session, "kernel32.dll", "C:\\Games", "C:\\Users\\Player", ["D:\\GameBin"], ["kernel32.dll"], 0x6000)
        expect result.ok == true
        expect result.dll_name == "kernel32.dll"
        expect result.selected_path == "\\KnownDlls\\kernel32.dll"
        expect result.mapped_base == 0x71000000
        expect result.mapped_size == 0x6000
        expect result.ref_count == 1
        expect result.status == "dll-load-session-recorded"
        expect wine_dll_load_session_loaded_count(result.session) == 1
        expect (result.evidence).contains("dll-image-map-handoff-ready")
        expect (result.evidence).contains("dll-load-session-recorded")
        expect (result.evidence).contains("modeled-loaded-image")
        expect (result.evidence).contains("no-real-dll-loaded")
        expect (result.evidence).contains("no-dll-entrypoint-executed")
        expect (result.evidence).contains("no-tls-callback-executed")

    it "increments modeled refcount for repeated loads and unloads by refcount":
        val session = wine_dll_load_session_new(0x72000000)
        val first = wine_dll_session_load_modeled(session, "kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x5000)
        val second = wine_dll_session_load_modeled(first.session, "kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x5000)
        expect second.ok == true
        expect second.ref_count == 2
        expect second.status == "dll-load-existing-refcounted"
        expect wine_dll_load_session_loaded_count(second.session) == 1
        val released = wine_dll_session_unload_modeled(second.session, "kernel32.dll")
        expect released.ok == true
        expect released.ref_count == 1
        expect wine_dll_load_session_loaded_count(released.session) == 1

    it "rolls back modeled loads without leaving loaded state":
        val session = wine_dll_load_session_new(0x73000000)
        val result = wine_dll_session_load_with_rollback(session, "user32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x7000, false)
        expect result.ok == false
        expect result.error == "dll-load-session-rolled-back"
        expect result.status == "rolled-back"
        expect result.ref_count == 0
        expect wine_dll_load_session_loaded_count(result.session) == 0
        expect (result.evidence).contains("dll-load-session-unloaded")
        expect (result.evidence).contains("dll-load-session-rolled-back")
        expect (result.evidence).contains("no-real-dll-loaded")

    it "rejects invalid image handoff inputs":
        val session = wine_dll_load_session_new(0x74000000)
        val result = wine_dll_session_load_modeled(session, "C:\\Windows\\kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x4000)
        expect result.ok == false
        expect result.error == "image-map:dll-search:dll-name-must-be-basename"
        expect result.status == "rejected"
        expect wine_dll_load_session_loaded_count(result.session) == 0