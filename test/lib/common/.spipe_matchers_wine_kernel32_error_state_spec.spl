use common.wine_kernel32_error_state.{
    wine_kernel32_error_state_new,
    wine_kernel32_execute_error_state,
    wine_kernel32_format_message_w,
    wine_kernel32_get_last_error,
    wine_kernel32_set_last_error
}

describe "Wine KERNEL32 error-state bridge":
    it "sets, gets, and formats a bounded last-error code":
        val result = wine_kernel32_execute_error_state(
            ["SetLastError", "GetLastError", "FormatMessageW"],
            wine_kernel32_error_state_new(),
            87
        )

        expect result.ok == true
        expect result.code == 87
        expect result.state.symbol == "ERROR_INVALID_PARAMETER"
        expect result.message == "The parameter is incorrect."
        expect result.operations == "SetLastError GetLastError FormatMessageW"

    it "exposes direct error-state helpers":
        val updated = wine_kernel32_set_last_error(wine_kernel32_error_state_new(), 2)
        val fetched = wine_kernel32_get_last_error(updated)
        val formatted = wine_kernel32_format_message_w(updated, fetched.code)

        expect fetched.ok == true
        expect fetched.code == 2
        expect fetched.message == "ERROR_FILE_NOT_FOUND"
        expect formatted.message == "The system cannot find the file specified."

    it "keeps error-state dispatch ordered and bounded":
        val out_of_order = wine_kernel32_execute_error_state(
            ["GetLastError", "SetLastError", "FormatMessageW"],
            wine_kernel32_error_state_new(),
            87
        )
        expect out_of_order.ok == false
        expect out_of_order.error == "kernel32-error-state-sequence-expected:SetLastError"

        val wrong_family = wine_kernel32_execute_error_state(
            ["SetLastError", "GetLastError", "HeapAlloc"],
            wine_kernel32_error_state_new(),
            87
        )
        expect wrong_family.ok == false
        expect wrong_family.error == "bridge-wrong-category:HeapAlloc"

    it "rejects invalid modeled error codes":
        val result = wine_kernel32_execute_error_state(
            ["SetLastError", "GetLastError", "FormatMessageW"],
            wine_kernel32_error_state_new(),
            -1
        )

        expect result.ok == false
        expect result.error == "SetLastError:invalid-error-code"