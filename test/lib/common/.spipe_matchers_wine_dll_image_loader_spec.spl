use common.wine_dll_image_loader.{wine_dll_prepare_image_map_handoff}

describe "Wine DLL image loader handoff":
    it "maps and unmaps a modeled KnownDll image without executing DLL code":
        val result = wine_dll_prepare_image_map_handoff(
            "kernel32.dll",
            "C:\\Games",
            "C:\\Users\\Player",
            ["D:\\GameBin"],
            ["kernel32.dll", "ntdll.dll"],
            0x5000,
            0x70000000
        )

        expect result.ok == true
        expect result.dll_name == "kernel32.dll"
        expect result.selected_path == "\\KnownDlls\\kernel32.dll"
        expect result.mapped_base == 0x70000000
        expect result.mapped_size == 0x5000
        expect result.section_handle == 0x400
        expect (result.evidence).contains("dll-search-order-modeled")
        expect (result.evidence).contains("NtCreateSection NtMapViewOfSection NtUnmapViewOfSection")
        expect (result.evidence).contains("dll-image-map-handoff-ready")
        expect (result.evidence).contains("dll-view-unmapped")
        expect (result.evidence).contains("no-dll-entrypoint-executed")
        expect (result.evidence).contains("no-tls-callback-executed")
        expect result.status == "dll-image-map-handoff-ready"

    it "rejects invalid image map parameters before section mapping":
        val bad_size = wine_dll_prepare_image_map_handoff("kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0, 0x70000000)
        expect bad_size.ok == false
        expect bad_size.error == "invalid-image-size"
        expect bad_size.status == "rejected"

        val bad_base = wine_dll_prepare_image_map_handoff("kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x5000, 0)
        expect bad_base.ok == false
        expect bad_base.error == "invalid-image-base"
        expect bad_base.status == "rejected"

    it "rejects DLL names outside the modeled basename search lane":
        val result = wine_dll_prepare_image_map_handoff("C:\\Windows\\System32\\kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], 0x5000, 0x70000000)

        expect result.ok == false
        expect result.error == "dll-search:dll-name-must-be-basename"
        expect result.status == "rejected"