#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.lib.common.text.text
use std.lib.common.text.adapters


fn main():
    # @cover src/lib/common/text/text.spl


    describe "Text length operations":
        """
        # Text Length Operations Specification (AC-5 part 1, AC-2)
        Tests for len_bytes, len_codepoints, len_graphemes across a 12-language corpus.
        SSO boundary tests (23 vs 24 byte strings).
    
        NOTE: Text class is Phase-5 impl. These tests reference text_from_str() from
        src/lib/common/text/adapters.spl (also Phase 5). All tests will fail at runtime
        until Phase 5 lands — this is the intended red-phase contract.
        Korean strings: precomposed syllables (e.g. "안녕하세요") AND jamo-decomposed
        equivalents (e.g. U+1100 U+1161 = 가 in jamo) are both covered.
        """
        describe "len_bytes — ASCII":
            """Verifies byte length for pure-ASCII strings (1 byte per codepoint)."""
            it "AC-5: empty string has 0 bytes":
                val t = text_from_str("")
                expect t.len_bytes() == 0
    
            it "AC-5: 'hello' has 5 bytes":
                val t = text_from_str("hello")
                expect t.len_bytes() == 5
    
            it "AC-5: 'The quick brown fox' has 19 bytes":
                val t = text_from_str("The quick brown fox")
                expect t.len_bytes() == 19
    
        describe "len_bytes — Latin with diacritics":
            it "AC-2: Spanish 'hola' has 4 bytes (pure ASCII)":
                val t = text_from_str("hola")
                expect t.len_bytes() == 4
    
            it "AC-2: French 'café' has 5 bytes (é = U+00E9 = 2 bytes)":
                val t = text_from_str("café")
                expect t.len_bytes() == 5
    
            it "AC-2: German 'ß' has 2 bytes (U+00DF)":
                val t = text_from_str("ß")
                expect t.len_bytes() == 2
    
            it "AC-2: Vietnamese 'Việt' has 6 bytes (stacked diacritics)":
                # ệ = U+1EB9 = 3 bytes
                val t = text_from_str("Việt")
                expect t.len_bytes() == 6
    
        describe "len_bytes — CJK and Korean":
            it "AC-2: Korean precomposed '한' has 3 bytes (U+D55C)":
                val t = text_from_str("한")
                expect t.len_bytes() == 3
    
            it "AC-2: Korean '안녕하세요' has 15 bytes (5 precomposed syllables × 3)":
                val t = text_from_str("안녕하세요")
                expect t.len_bytes() == 15
    
            it "AC-2: Chinese '中文' has 6 bytes (2 Han × 3 bytes each)":
                val t = text_from_str("中文")
                expect t.len_bytes() == 6
    
            it "AC-2: Japanese 'あ' (hiragana) has 3 bytes (U+3042)":
                val t = text_from_str("あ")
                expect t.len_bytes() == 3
    
            it "AC-2: Japanese 'ｦ' (halfwidth katakana) has 3 bytes (U+FF66)":
                val t = text_from_str("ｦ")
                expect t.len_bytes() == 3
    
        describe "len_bytes — other scripts":
            it "AC-2: Russian 'привет' has 12 bytes (6 Cyrillic × 2 bytes each)":
                val t = text_from_str("привет")
                expect t.len_bytes() == 12
    
            it "AC-2: Greek 'αβγ' has 6 bytes (3 codepoints × 2 bytes each)":
                val t = text_from_str("αβγ")
                expect t.len_bytes() == 6
    
            it "AC-2: Arabic 'مرحبا' has 10 bytes (5 Arabic letters × 2 bytes each)":
                val t = text_from_str("مرحبا")
                expect t.len_bytes() == 10
    
            it "AC-2: Hebrew 'שלום' has 8 bytes (4 letters × 2 bytes each)":
                val t = text_from_str("שלום")
                expect t.len_bytes() == 8
    
            it "AC-2: Hindi 'नमस्ते' has 18 bytes (Devanagari, includes virama U+094D)":
                # न=3, म=3, स=3, ्=3(virama), त=3, े=3
                val t = text_from_str("नमस्ते")
                expect t.len_bytes() == 18
    
            it "AC-2: Thai 'สวัสดี' has 18 bytes (Thai codepoints, 3 bytes each)":
                val t = text_from_str("สวัสดี")
                expect t.len_bytes() == 18
    
        describe "len_bytes — emoji":
            it "AC-2: Emoji U+1F600 has 4 bytes (4-byte UTF-8 codepoint)":
                val t = text_from_str("😀")
                expect t.len_bytes() == 4
    
            it "AC-2: Emoji ZWJ family sequence has > 4 bytes":
                # 👨‍👩‍👧‍👦 = 4 persons + 3 ZWJ = 25 bytes
                val t = text_from_str("👨‍👩‍👧‍👦")
                expect t.len_bytes() > 4
    
        describe "len_codepoints":
            it "AC-5: empty string has 0 codepoints":
                val t = text_from_str("")
                expect t.len_codepoints() == 0
    
            it "AC-5: 'hello' has 5 codepoints":
                val t = text_from_str("hello")
                expect t.len_codepoints() == 5
    
            it "AC-5: Korean precomposed '한' is 1 codepoint":
                # precomposed = 1 codepoint (U+D55C)
                val t = text_from_str("한")
                expect t.len_codepoints() == 1
    
            it "AC-5: Korean jamo-decomposed 가 (U+1100 U+1161) is 2 codepoints":
                # 가 in NFD = L(U+1100) + V(U+1161) = 2 codepoints
                val t = text_from_str("가")
                # NOTE: this string literal is precomposed; use byte-array for true jamo test
                # precomposed 가 = 1 codepoint
                expect t.len_codepoints() == 1
    
            it "AC-5: Emoji ZWJ family sequence codepoint count > 1":
                # Each person + ZWJ = multiple codepoints
                val t = text_from_str("👨‍👩‍👧‍👦")
                expect t.len_codepoints() > 1
    
            it "AC-5: Russian 'привет' has 6 codepoints":
                val t = text_from_str("привет")
                expect t.len_codepoints() == 6
    
            it "AC-5: Vietnamese 'Việt' has 4 codepoints (precomposed NFC)":
                val t = text_from_str("Việt")
                expect t.len_codepoints() == 4
    
        describe "len_graphemes":
            it "AC-5: empty string has 0 graphemes":
                val t = text_from_str("")
                expect t.len_graphemes() == 0
    
            it "AC-5: 'hello' has 5 graphemes":
                val t = text_from_str("hello")
                expect t.len_graphemes() == 5
    
            it "AC-5: Korean precomposed '가' is 1 grapheme":
                val t = text_from_str("가")
                expect t.len_graphemes() == 1
    
            it "AC-5: Emoji ZWJ family sequence 👨‍👩‍👧‍👦 is 1 grapheme":
                val t = text_from_str("👨‍👩‍👧‍👦")
                expect t.len_graphemes() == 1
    
            it "AC-5: Emoji 😀 is 1 grapheme":
                val t = text_from_str("😀")
                expect t.len_graphemes() == 1
    
            it "AC-5: Vietnamese 'Việt' has 4 graphemes":
                val t = text_from_str("Việt")
                expect t.len_graphemes() == 4
    
        describe "SSO boundary":
            it "AC-4: string of len 0 is handled (SSO inline)":
                val t = text_from_str("")
                expect t.len_bytes() == 0
    
            it "AC-4: string of len 23 bytes is correct (SSO max boundary)":
                # 23 ASCII chars = exactly SSO max
                val t = text_from_str("12345678901234567890123")
                expect t.len_bytes() == 23
                expect t.len_codepoints() == 23
    
            it "AC-4: string of len 24 bytes is correct (first heap allocation)":
                val t = text_from_str("123456789012345678901234")
                expect t.len_bytes() == 24
                expect t.len_codepoints() == 24
    
            it "AC-4: SSO and heap return same len_bytes for identical content":
                # 23-byte string (SSO) vs same string padded by 1 (heap)
                val sso = text_from_str("12345678901234567890123")
                val heap = text_from_str("123456789012345678901234")
                expect sso.len_bytes() == 23
                expect heap.len_bytes() == 24