# @cover src/lib/common/text/text.spl

use std.spec.*
use std.lib.common.text.text
use std.lib.common.text.adapters

describe "Text search operations":
    """
    # Text Search Specification (AC-5 part 3)
    Tests for contains(needle) and find(needle) across ASCII, Korean, emoji.
    find() returns a byte offset (per arch doc §3 / api_and_design.md).

    NOTE: Text class is Phase-5 impl. All tests are red-phase.
    Multi-byte boundary safety: needle must not match mid-codepoint sequences.
    """
    describe "contains — ASCII":
        """Verifies contains() detects substrings in ASCII haystacks."""
        it "AC-5: 'hello world' contains 'world'":
            val t = text_from_str("hello world")
            val needle = text_from_str("world")
            expect t.contains(needle) == true

        it "AC-5: 'hello world' does not contain 'xyz'":
            val t = text_from_str("hello world")
            val needle = text_from_str("xyz")
            expect t.contains(needle) == false

        it "AC-5: string contains itself":
            val t = text_from_str("abc")
            expect t.contains(t) == true

        it "AC-5: empty needle is always contained":
            val t = text_from_str("hello")
            val needle = text_from_str("")
            expect t.contains(needle) == true

        it "AC-5: empty haystack does not contain non-empty needle":
            val t = text_from_str("")
            val needle = text_from_str("a")
            expect t.contains(needle) == false

        it "AC-5: needle larger than haystack is not contained":
            val t = text_from_str("hi")
            val needle = text_from_str("hello world")
            expect t.contains(needle) == false

    describe "contains — Korean":
        it "AC-5: Korean string contains Korean needle":
            val t = text_from_str("안녕하세요")
            val needle = text_from_str("하세")
            expect t.contains(needle) == true

        it "AC-5: Korean string does not contain ASCII needle":
            val t = text_from_str("안녕하세요")
            val needle = text_from_str("hello")
            expect t.contains(needle) == false

    describe "contains — emoji":
        it "AC-5: string with emoji contains that emoji":
            val t = text_from_str("hello 😀 world")
            val needle = text_from_str("😀")
            expect t.contains(needle) == true

        it "AC-5: string without emoji does not match emoji needle":
            val t = text_from_str("hello world")
            val needle = text_from_str("😀")
            expect t.contains(needle) == false

    describe "find — ASCII":
        it "AC-5: find 'world' in 'hello world' returns byte offset 6":
            val t = text_from_str("hello world")
            val needle = text_from_str("world")
            val result = t.find(needle)
            expect result == 6

        it "AC-5: find 'hello' at start returns byte offset 0":
            val t = text_from_str("hello world")
            val needle = text_from_str("hello")
            val result = t.find(needle)
            expect result == 0

        it "AC-5: find absent needle returns -1 or nil (no match)":
            val t = text_from_str("hello")
            val needle = text_from_str("xyz")
            val result = t.find(needle)
            # find returns -1 as sentinel for not-found (i64)
            expect result == -1

    describe "find — Korean (byte offset)":
        it "AC-5: find '하세' in '안녕하세요' returns byte offset 6":
            val t = text_from_str("안녕하세요")
            # 안(3) + 녕(3) = 6 bytes before 하
            val needle = text_from_str("하세")
            val result = t.find(needle)
            expect result == 6

    describe "find — emoji":
        it "AC-5: find emoji '😀' in 'hi😀' returns byte offset 2":
            val t = text_from_str("hi😀")
            val needle = text_from_str("😀")
            val result = t.find(needle)
            expect result == 2

    describe "multi-byte boundary safety":
        it "AC-5: ASCII needle does not match inside a 3-byte Korean codepoint":
            # "한" = 0xED 0x95 0x9C; needle 0x95 alone is a continuation byte, not ASCII
            val t = text_from_str("한")
            # continuation byte 0x95 as single-byte string is NOT valid UTF-8
            # and must not match inside '한'
            val needle = text_from_str("a")
            expect t.contains(needle) == false