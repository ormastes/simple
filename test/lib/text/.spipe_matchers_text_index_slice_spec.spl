# @cover src/lib/common/text/text.spl,src/lib/common/text/text_view.spl

use std.spec.*
use std.lib.common.text.text
use std.lib.common.text.text_view
use std.lib.common.text.adapters

describe "Text index and slice operations":
    """
    # Text Index and Slice Specification (AC-5 part 2)
    Tests for cp_at(i) and slice_codepoints(s, e) across mixed-width corpus.

    NOTE: Text class and TextView are Phase-5 impl. All tests reference
    src/lib/common/text/text.spl and text_view.spl (not yet created).
    Tests will fail at runtime until Phase 5 lands — red-phase contract.
    """
    describe "cp_at — ASCII":
        """Verifies cp_at returns correct codepoints for ASCII characters."""
        it "AC-5: cp_at(0) on 'hello' returns codepoint for 'h' (104)":
            val t = text_from_str("hello")
            expect t.cp_at(0) == 104

        it "AC-5: cp_at(4) on 'hello' returns codepoint for 'o' (111)":
            val t = text_from_str("hello")
            expect t.cp_at(4) == 111

    describe "cp_at — mixed-width Korean + ASCII":
        it "AC-5: cp_at(0) on '한a' returns codepoint U+D55C (54620)":
            val t = text_from_str("한a")
            expect t.cp_at(0) == 0xD55C

        it "AC-5: cp_at(1) on '한a' returns codepoint for 'a' (97)":
            val t = text_from_str("한a")
            expect t.cp_at(1) == 97

        it "AC-5: cp_at(0) on '가' (AC00, Hangul syllable base) returns 0xAC00":
            val t = text_from_str("가")
            expect t.cp_at(0) == 0xAC00

    describe "cp_at — 4-byte codepoints":
        it "AC-5: cp_at(0) on emoji '😀' returns U+1F600 (128512)":
            val t = text_from_str("😀")
            expect t.cp_at(0) == 0x1F600

        it "AC-5: cp_at(1) on 'a😀b' returns U+1F600":
            val t = text_from_str("a😀b")
            expect t.cp_at(1) == 0x1F600

        it "AC-5: cp_at(2) on 'a😀b' returns codepoint for 'b' (98)":
            val t = text_from_str("a😀b")
            expect t.cp_at(2) == 98

    describe "slice_codepoints — boundary cases":
        it "AC-5: empty slice (s==e) returns empty TextView":
            val t = text_from_str("hello")
            val view = t.slice_codepoints(2, 2)
            expect view.len_bytes() == 0

        it "AC-5: full slice returns all bytes":
            val t = text_from_str("hello")
            val view = t.slice_codepoints(0, 5)
            expect view.len_bytes() == 5

        it "AC-5: middle slice 'ell' from 'hello' has 3 bytes":
            val t = text_from_str("hello")
            val view = t.slice_codepoints(1, 4)
            expect view.len_bytes() == 3

    describe "slice_codepoints — mixed-width Korean":
        it "AC-5: slice 1 Korean codepoint from '안녕' returns 3 bytes":
            val t = text_from_str("안녕")
            val view = t.slice_codepoints(0, 1)
            # 안 = U+C548 = 3 bytes
            expect view.len_bytes() == 3

        it "AC-5: slice both Korean codepoints from '안녕' returns 6 bytes":
            val t = text_from_str("안녕")
            val view = t.slice_codepoints(0, 2)
            expect view.len_bytes() == 6

        it "AC-5: slice Hangul syllable 가 (AC00) from mixed string returns 3 bytes":
            val t = text_from_str("a가b")
            val view = t.slice_codepoints(1, 2)
            expect view.len_bytes() == 3

    describe "slice_codepoints — 4-byte emoji":
        it "AC-5: slice emoji U+1F600 from 'a😀b' returns 4 bytes":
            val t = text_from_str("a😀b")
            val view = t.slice_codepoints(1, 2)
            expect view.len_bytes() == 4

    describe "slice_codepoints — out-of-bounds saturation":
        it "AC-5: slice with e > len saturates to len (no panic)":
            val t = text_from_str("hi")
            val view = t.slice_codepoints(0, 100)
            # Should return entire string, not panic
            expect view.len_bytes() == 2

        it "AC-5: slice with s > len returns empty (no panic)":
            val t = text_from_str("hi")
            val view = t.slice_codepoints(100, 200)
            expect view.len_bytes() == 0