# @cover src/lib/nogc_async_mut/gpu/dxvk_d3d9.spl
# @cover src/lib/nogc_async_mut/gpu/dxvk_d3d10.spl
# @cover src/lib/nogc_async_mut/gpu/dxvk_d3d11.spl

use std.spec
use std.nogc_async_mut.gpu.dxvk_d3d9.{
    dxvk_d3d9_create_device,
    dxvk_d3d9_create_texture,
    dxvk_d3d9_draw_primitive
}
use std.nogc_async_mut.gpu.dxvk_d3d10.{
    dxvk_d3d10_create_device,
    dxvk_d3d10_draw,
    dxvk_d3d10_create_render_target
}
use std.nogc_async_mut.gpu.dxvk_d3d11.{
    dxvk_d3d11_create_device,
    dxvk_d3d11_create_swapchain,
    dxvk_d3d11_present,
    dxvk_d3d11_create_render_target
}

describe "DXVK D3D9 translation":
    it "create_device returns is_ok=true":
        val result = dxvk_d3d9_create_device()
        expect result.is_ok == true
        expect result.device_handle > 0

    it "create_texture returns positive handle on valid device":
        val dev = dxvk_d3d9_create_device()
        val tex = dxvk_d3d9_create_texture(dev.device_handle, 256, 256)
        expect tex > 0

    it "create_texture returns 0 on invalid device":
        val tex = dxvk_d3d9_create_texture(0, 256, 256)
        expect tex == 0

    it "draw_primitive returns is_ok=true with vertex count":
        val dev = dxvk_d3d9_create_device()
        val result = dxvk_d3d9_draw_primitive(dev.device_handle, 3)
        expect result.is_ok == true
        expect result.vertex_count == 3

    it "draw_primitive returns error on invalid device":
        val result = dxvk_d3d9_draw_primitive(0, 3)
        expect result.is_ok == false

describe "DXVK D3D10 translation":
    it "create_device returns is_ok=true":
        val result = dxvk_d3d10_create_device()
        expect result.is_ok == true
        expect result.device_handle > 0

    it "draw returns true on valid device with vertices":
        val dev = dxvk_d3d10_create_device()
        expect dxvk_d3d10_draw(dev.device_handle, 6) == true

    it "draw returns false on invalid device":
        expect dxvk_d3d10_draw(0, 6) == false

    it "create_render_target returns positive handle":
        val dev = dxvk_d3d10_create_device()
        val rt = dxvk_d3d10_create_render_target(dev.device_handle, 1920, 1080)
        expect rt > 0

    it "create_render_target returns 0 on invalid device":
        val rt = dxvk_d3d10_create_render_target(0, 1920, 1080)
        expect rt == 0

describe "DXVK D3D11 translation":
    it "create_device returns is_ok=true":
        val result = dxvk_d3d11_create_device()
        expect result.is_ok == true
        expect result.device_handle > 0

    it "create_swapchain returns is_ok=true on valid device":
        val dev = dxvk_d3d11_create_device()
        val sc = dxvk_d3d11_create_swapchain(dev.device_handle, 1920, 1080)
        expect sc.is_ok == true
        expect sc.swapchain_handle > 0

    it "create_swapchain returns error on invalid device":
        val sc = dxvk_d3d11_create_swapchain(0, 800, 600)
        expect sc.is_ok == false

    it "present returns true on valid swapchain":
        val dev = dxvk_d3d11_create_device()
        val sc = dxvk_d3d11_create_swapchain(dev.device_handle, 800, 600)
        expect dxvk_d3d11_present(sc.swapchain_handle) == true

    it "create_render_target returns positive handle":
        val dev = dxvk_d3d11_create_device()
        val rt = dxvk_d3d11_create_render_target(dev.device_handle, 800, 600)
        expect rt > 0