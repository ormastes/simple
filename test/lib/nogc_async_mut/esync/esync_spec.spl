# @cover src/lib/nogc_async_mut/esync/esync.spl

use std.spec
use std.nogc_async_mut.esync.esync.{
    esync_create,
    esync_signal,
    esync_wait,
    esync_reset,
    esync_close
}

describe "esync NT event/semaphore":
    it "create returns a positive handle":
        val h = esync_create()
        expect(h).to_be_greater_than(0)

    it "two creates return distinct handles":
        val h1 = esync_create()
        val h2 = esync_create()
        expect(h1).to_not_equal(h2)

    it "wait on unsignaled handle with timeout=0 returns timeout":
        val h = esync_create()
        val result = esync_wait(h, 0)
        expect(result).to_equal("timeout")

    it "signal then wait returns signaled":
        val h = esync_create()
        esync_signal(h)
        val result = esync_wait(h, 0)
        expect(result).to_equal("signaled")

    it "wait consumes signal (auto-reset)":
        val h = esync_create()
        esync_signal(h)
        esync_wait(h, 0)
        val result2 = esync_wait(h, 0)
        expect(result2).to_equal("timeout")

    it "reset clears a signaled handle":
        val h = esync_create()
        esync_signal(h)
        esync_reset(h)
        val result = esync_wait(h, 0)
        expect(result).to_equal("timeout")

    it "wait on invalid handle returns invalid":
        val result = esync_wait(-1, 0)
        expect(result).to_equal("invalid")

    it "signal on invalid handle does not panic":
        esync_signal(-99)
        expect(1).to_equal(1)

    it "close removes handle from active set":
        val h = esync_create()
        esync_close(h)
        val result = esync_wait(h, 0)
        expect(result).to_equal("invalid")
