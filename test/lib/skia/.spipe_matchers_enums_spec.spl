# @cover src/lib/skia/entity/enums.spl 80%
"""
# Skia Enums Specification

**Feature IDs:** #SKI-001
**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Implemented

## Overview

Tests that all Skia enum variants construct correctly and compare by identity.
"""

use std.skia.entity.enums.{
    SkPaintStyle, SkPaintCap, SkPaintJoin,
    SkBlendMode,
    SkPathFillType, SkPathDirection,
    SkClipOp,
    SkTileMode,
    SkAlphaType, SkColorType,
    SkFilterMode, SkMipmapMode,
    SkTextEncoding
}

describe "SkPaintStyle":
    it "Fill variant exists":
        val s = SkPaintStyle.Fill
        expect s == SkPaintStyle.Fill

    it "Stroke variant exists":
        val s = SkPaintStyle.Stroke
        expect s == SkPaintStyle.Stroke

    it "StrokeAndFill variant exists":
        val s = SkPaintStyle.StrokeAndFill
        expect s == SkPaintStyle.StrokeAndFill

    it "Fill != Stroke":
        expect SkPaintStyle.Fill == SkPaintStyle.Stroke == false

describe "SkPaintCap":
    it "Butt variant":
        expect SkPaintCap.Butt == SkPaintCap.Butt

    it "Round variant":
        expect SkPaintCap.Round == SkPaintCap.Round

    it "Square variant":
        expect SkPaintCap.Square == SkPaintCap.Square

describe "SkPaintJoin":
    it "Miter variant":
        expect SkPaintJoin.Miter == SkPaintJoin.Miter

    it "Round variant":
        expect SkPaintJoin.Round == SkPaintJoin.Round

    it "Bevel variant":
        expect SkPaintJoin.Bevel == SkPaintJoin.Bevel

describe "SkBlendMode":
    it "SrcOver is default blend mode":
        val bm = SkBlendMode.SrcOver
        expect bm == SkBlendMode.SrcOver

    it "Clear variant exists":
        expect SkBlendMode.Clear == SkBlendMode.Clear

    it "Multiply variant exists":
        expect SkBlendMode.Multiply == SkBlendMode.Multiply

    it "SrcOver != Dst":
        expect SkBlendMode.SrcOver == SkBlendMode.Dst == false

describe "SkPathFillType":
    it "Winding variant":
        expect SkPathFillType.Winding == SkPathFillType.Winding

    it "EvenOdd variant":
        expect SkPathFillType.EvenOdd == SkPathFillType.EvenOdd

    it "InverseWinding variant":
        expect SkPathFillType.InverseWinding == SkPathFillType.InverseWinding

    it "InverseEvenOdd variant":
        expect SkPathFillType.InverseEvenOdd == SkPathFillType.InverseEvenOdd

describe "SkPathDirection":
    it "Cw variant":
        expect SkPathDirection.Cw == SkPathDirection.Cw

    it "Ccw variant":
        expect SkPathDirection.Ccw == SkPathDirection.Ccw

describe "SkClipOp":
    it "Difference variant":
        expect SkClipOp.Difference == SkClipOp.Difference

    it "Intersect variant":
        expect SkClipOp.Intersect == SkClipOp.Intersect

describe "SkTileMode":
    it "Clamp variant":
        expect SkTileMode.Clamp == SkTileMode.Clamp

    it "Repeat variant":
        expect SkTileMode.Repeat == SkTileMode.Repeat

    it "Mirror variant":
        expect SkTileMode.Mirror == SkTileMode.Mirror

    it "Decal variant":
        expect SkTileMode.Decal == SkTileMode.Decal

describe "SkAlphaType":
    it "Premul variant":
        expect SkAlphaType.Premul == SkAlphaType.Premul

    it "Opaque variant":
        expect SkAlphaType.Opaque == SkAlphaType.Opaque

describe "SkColorType":
    it "Rgba8888 variant":
        expect SkColorType.Rgba8888 == SkColorType.Rgba8888

    it "Alpha8 variant":
        expect SkColorType.Alpha8 == SkColorType.Alpha8

describe "SkTextEncoding":
    it "Utf8 variant":
        expect SkTextEncoding.Utf8 == SkTextEncoding.Utf8

    it "GlyphId variant":
        expect SkTextEncoding.GlyphId == SkTextEncoding.GlyphId