# Shaper and script detection specification tests

use std.sspec.*
use std.skia.feature.shaper.script_detect.{Script, script_of, script_is_rtl}
use std.skia.feature.shaper.feature_tags.{OpenTypeFeature, feature_tag}
use std.skia.feature.shaper.font_fallback.{FallbackChain, fallback_chain_new, system_default_chain}
use std.skia.feature.shaper.shaper.{Shaper, shaper_new, ascii_to_codepoints}
use std.skia.entity.font.{sk_font_default}

describe "script_of: Latin range":
    it "ASCII 'A' (0x0041) is Latin":
        val cp = 65 as u32
        val s = script_of(cp)
        expect s to_equal Script.Latin

    it "ASCII boundary 0x007F is Latin":
        val cp = 127 as u32
        val s = script_of(cp)
        expect s to_equal Script.Latin

describe "script_of: Hebrew range":
    it "Hebrew alef 0x05D0 (1488) is Hebrew":
        val cp = 1488 as u32
        val s = script_of(cp)
        expect s to_equal Script.Hebrew

describe "script_of: Arabic range":
    it "Arabic letter 0x0628 (1576) is Arabic":
        val cp = 1576 as u32
        val s = script_of(cp)
        expect s to_equal Script.Arabic

describe "script_of: CJK range":
    it "CJK 0x4E2D (19997) is CJK":
        val cp = 19997 as u32
        val s = script_of(cp)
        expect s to_equal Script.CJK

describe "script_is_rtl":
    it "Arabic is RTL":
        val r = script_is_rtl(Script.Arabic)
        expect r to_equal true

    it "Hebrew is RTL":
        val r = script_is_rtl(Script.Hebrew)
        expect r to_equal true

    it "Latin is not RTL":
        val r = script_is_rtl(Script.Latin)
        expect r to_equal false

describe "feature_tag":
    it "Kerning tag is kern":
        val t = feature_tag(OpenTypeFeature.Kerning)
        expect t to_equal "kern"

    it "Ligatures tag is liga":
        val t = feature_tag(OpenTypeFeature.Ligatures)
        expect t to_equal "liga"

    it "SmallCaps tag is smcp":
        val t = feature_tag(OpenTypeFeature.SmallCaps)
        expect t to_equal "smcp"

describe "FallbackChain":
    it "new stores primary font":
        val font = sk_font_default()
        val chain = fallback_chain_new(font)
        expect chain.primary.size to_equal 12.0

    it "system_default_chain returns a chain with 12pt primary":
        val chain = system_default_chain()
        expect chain.primary.size to_equal 12.0

describe "Shaper":
    it "shaper_new stores fallback chain":
        val chain = system_default_chain()
        val shaper = shaper_new(chain)
        expect shaper.fallback.primary.size to_equal 12.0

describe "ascii_to_codepoints":
    it "hello produces 5 codepoints":
        val cps = ascii_to_codepoints("hello")
        expect cps.len() to_equal 5

    it "first codepoint of hello is 104 (h)":
        val cps = ascii_to_codepoints("hello")
        val first = cps[0]
        expect first to_equal 104 as u32
