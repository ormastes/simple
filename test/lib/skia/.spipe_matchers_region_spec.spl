# @cover src/lib/skia/entity/region.spl 80%
"""
# Skia Region Specification

**Feature IDs:** #SKI-REGION
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests for SkRegion — YX-banded multi-rectangle integer region used for complex
clips (mirrors Skia's SkRegion).
"""

use std.skia.entity.geometry.{SkIRect, sk_irect}
use std.skia.entity.region.{
    SkRegion,
    sk_region_empty,
    sk_region_from_rect
}

describe "SkRegion":
    it "sk_region_empty: is_empty returns true":
        val reg = sk_region_empty()
        expect reg.is_empty() == true

    it "sk_region_from_rect: is_rect returns true, bounds matches":
        val r = sk_irect(10, 20, 110, 220)
        val reg = sk_region_from_rect(r)
        expect reg.is_rect() == true
        val b = reg.bounds()
        expect b.left == 10
        expect b.top == 20
        expect b.right == 110
        expect b.bottom == 220

    it "SkRegion.contains: point inside rect returns true":
        val reg = sk_region_from_rect(sk_irect(0, 0, 100, 100))
        expect reg.contains(50, 50) == true

    it "SkRegion.contains: point outside rect returns false":
        val reg = sk_region_from_rect(sk_irect(0, 0, 100, 100))
        expect reg.contains(200, 50) == false

    it "op_union: two disjoint rects produces region with both bounds":
        val a = sk_region_from_rect(sk_irect(0, 0, 10, 10))
        val b = sk_region_from_rect(sk_irect(100, 100, 120, 120))
        val u = a.op_union(b)
        expect u.rects.len() > 1
        val bb = u.bounds()
        expect bb.left == 0
        expect bb.top == 0
        expect bb.right == 120
        expect bb.bottom == 120

    it "op_intersect: two overlapping rects produces the overlap":
        val a = sk_region_from_rect(sk_irect(0, 0, 100, 100))
        val b = sk_region_from_rect(sk_irect(50, 50, 150, 150))
        val x = a.op_intersect(b)
        expect x.is_rect() == true
        val bb = x.bounds()
        expect bb.left == 50
        expect bb.top == 50
        expect bb.right == 100
        expect bb.bottom == 100

    it "op_intersect: disjoint rects produces empty":
        val a = sk_region_from_rect(sk_irect(0, 0, 10, 10))
        val b = sk_region_from_rect(sk_irect(100, 100, 120, 120))
        val x = a.op_intersect(b)
        expect x.is_empty() == true

    it "op_difference: rect minus contained rect produces residual frame":
        val outer = sk_region_from_rect(sk_irect(0, 0, 100, 100))
        val inner = sk_region_from_rect(sk_irect(25, 25, 75, 75))
        val d = outer.op_difference(inner)
        expect d.is_empty() == false
        expect d.rects.len() == 4
        expect d.contains(50, 50) == false
        expect d.contains(10, 10) == true
        val bb = d.bounds()
        expect bb.left == 0
        expect bb.top == 0
        expect bb.right == 100
        expect bb.bottom == 100