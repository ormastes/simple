#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.skia.entity.enums.{SkPathFillType, SkPathDirection}
use std.skia.entity.path.{SkPath, SkPathVerb, sk_path_new}


fn main():
    # @cover src/lib/skia/entity/path.spl 80%
    """
    # Skia Path Specification
    
    **Feature IDs:** #SKI-005
    **Category:** Stdlib
    **Difficulty:** 2/5
    **Status:** Implemented
    
    ## Overview
    
    Tests for SkPath construction and path-building operations.
    """


    describe "SkPath construction":
        it "sk_path_new creates empty path":
            val p = sk_path_new()
            expect p.is_empty() == true

        it "sk_path_new has Winding fill type":
            val p = sk_path_new()
            expect p.fill_type == SkPathFillType.Winding

        it "empty path has 0 verbs":
            val p = sk_path_new()
            expect p.count_verbs() == 0

    describe "SkPath move_to and line_to":
        it "move_to adds one verb":
            val p = sk_path_new().move_to(0.0, 0.0)
            expect p.count_verbs() == 1

        it "move_to is not empty":
            val p = sk_path_new().move_to(10.0, 20.0)
            expect p.is_empty() == false

        it "line_to adds a verb":
            val p = sk_path_new()
            val p2 = p.move_to(0.0, 0.0).line_to(100.0, 0.0)
            expect p2.count_verbs() == 2

        it "verb kind for move is Move":
            val p = sk_path_new().move_to(0.0, 0.0)
            val seg = p.segments[0]
            expect seg.verb == SkPathVerb.Move

        it "verb kind for line is Line":
            val p = sk_path_new().move_to(0.0, 0.0).line_to(100.0, 0.0)
            val seg = p.segments[1]
            expect seg.verb == SkPathVerb.Line

    describe "SkPath quad_to and cubic_to":
        it "quad_to adds a Quad verb":
            val p = sk_path_new().move_to(0.0, 0.0).quad_to(50.0, 50.0, 100.0, 0.0)
            expect p.count_verbs() == 2
            val seg = p.segments[1]
            expect seg.verb == SkPathVerb.Quad

        it "quad_to stores two control points":
            val p = sk_path_new().move_to(0.0, 0.0).quad_to(50.0, 50.0, 100.0, 0.0)
            val seg = p.segments[1]
            expect seg.pts.len() == 2

        it "cubic_to adds a Cubic verb":
            val p = sk_path_new().move_to(0.0, 0.0).cubic_to(25.0, 75.0, 75.0, 75.0, 100.0, 0.0)
            val seg = p.segments[1]
            expect seg.verb == SkPathVerb.Cubic

        it "cubic_to stores three points":
            val p = sk_path_new().move_to(0.0, 0.0).cubic_to(25.0, 75.0, 75.0, 75.0, 100.0, 0.0)
            val seg = p.segments[1]
            expect seg.pts.len() == 3

    describe "SkPath close":
        it "close adds a Close verb":
            val p = sk_path_new().move_to(0.0, 0.0).line_to(100.0, 0.0).close()
            val seg = p.segments[2]
            expect seg.verb == SkPathVerb.Close

    describe "SkPath fill_type":
        it "with_fill_type changes fill type":
            val p = sk_path_new().with_fill_type(SkPathFillType.EvenOdd)
            expect p.fill_type == SkPathFillType.EvenOdd

        it "with_fill_type is immutable — original unchanged":
            val p = sk_path_new()
            val _ = p.with_fill_type(SkPathFillType.EvenOdd)
            expect p.fill_type == SkPathFillType.Winding

    describe "SkPath immutability":
        it "move_to does not modify original":
            val p = sk_path_new()
            val _ = p.move_to(0.0, 0.0)
            expect p.is_empty() == true

        it "line_to chaining returns new path each time":
            val p0 = sk_path_new()
            val p1 = p0.move_to(0.0, 0.0)
            val p2 = p1.line_to(100.0, 0.0)
            expect p0.count_verbs() == 0
            expect p1.count_verbs() == 1
            expect p2.count_verbs() == 2

    describe "SkPath bounds":
        it "empty path has degenerate bounds":
            val p = sk_path_new()
            val b = p.bounds()
            expect b.left == 0.0
            expect b.right == 0.0

        it "rectangle path reports corner bounds":
            val p = sk_path_new()
                .move_to(10.0, 20.0)
                .line_to(110.0, 20.0)
                .line_to(110.0, 70.0)
                .line_to(10.0, 70.0)
                .close()
            val b = p.bounds()
            expect b.left == 10.0
            expect b.top == 20.0
            expect b.right == 110.0
            expect b.bottom == 70.0

    describe "SkPath contains":
        # Winding is the default fill rule (sk_path_new sets Winding).
        # Edges: points that lie exactly on an edge can land either inside
        # or outside depending on floating-point rounding. The half-open
        # y-span rule (y_top <= y < y_bot) chosen here makes horizontal
        # top edges "inside" and bottom edges "outside". Tests exercise
        # the top edge to lock this behavior in.

        it "point inside a rectangular path returns true":
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(100.0, 50.0)
                .line_to(0.0, 50.0)
                .close()
            expect p.contains(50.0, 25.0) == true

        it "point outside the bounding box returns false":
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(100.0, 50.0)
                .line_to(0.0, 50.0)
                .close()
            expect p.contains(200.0, 25.0) == false

        it "point far above the bounding box returns false":
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(100.0, 50.0)
                .line_to(0.0, 50.0)
                .close()
            expect p.contains(50.0, -10.0) == false

        it "point on the top edge of a rectangle returns true (half-open span)":
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(100.0, 50.0)
                .line_to(0.0, 50.0)
                .close()
            expect p.contains(50.0, 0.0) == true

        it "point inside a triangle returns true":
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(50.0, 80.0)
                .close()
            expect p.contains(50.0, 20.0) == true

        it "point outside a triangle (but inside bbox) returns false":
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(50.0, 80.0)
                .close()
            # Near the bottom-left corner of bbox, outside the triangle's slant.
            expect p.contains(5.0, 70.0) == false

        it "point in the concave notch of a C-shape returns false":
            # C-shape: a 100x100 square with a rectangular bite taken out of its
            # right side from (40, 25) to (100, 75).
            val p = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(100.0, 25.0)
                .line_to(40.0, 25.0)
                .line_to(40.0, 75.0)
                .line_to(100.0, 75.0)
                .line_to(100.0, 100.0)
                .line_to(0.0, 100.0)
                .close()
            # Point in the notch: x > 40, 25 < y < 75.
            expect p.contains(70.0, 50.0) == false
            # Sanity check — a point in the solid spine of the C is inside.
            expect p.contains(20.0, 50.0) == true

        it "closed path with hole — point inside hole returns false (even-odd rule)":
            # Outer 100x100 square + inner 40x40 hole, both wound CW.
            # Under EvenOdd fill, the inner region is "outside".
            val outer = sk_path_new()
                .move_to(0.0, 0.0)
                .line_to(100.0, 0.0)
                .line_to(100.0, 100.0)
                .line_to(0.0, 100.0)
                .close()
                .move_to(30.0, 30.0)
                .line_to(70.0, 30.0)
                .line_to(70.0, 70.0)
                .line_to(30.0, 70.0)
                .close()
            val p = outer.with_fill_type(SkPathFillType.EvenOdd)
            # Inside the hole: outside per even-odd.
            expect p.contains(50.0, 50.0) == false
            # Between outer and hole: inside per even-odd.
            expect p.contains(10.0, 50.0) == true