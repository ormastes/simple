# @cover src/lib/skia/entity/geometry.spl 80%
"""
# Skia Geometry Specification

**Feature IDs:** #SKI-002
**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Implemented

## Overview

Tests for SkPoint, SkRect, SkSize, SkIRect, SkRRect geometry types.
"""

use std.skia.entity.geometry.{
    SkPoint, SkIPoint, SkSize, SkISize, SkRect, SkIRect, SkRRect,
    sk_point, sk_point_zero,
    sk_size, sk_isize,
    sk_rect, sk_rect_make_wh, sk_rect_make_xywh,
    sk_irect, sk_irect_make_wh,
    sk_rrect_make, sk_rrect_make_oval
}

describe "SkPoint":
    it "constructs with x and y":
        val p = sk_point(3.0, 4.0)
        expect p.x == 3.0
        expect p.y == 4.0

    it "zero point has x=0 y=0":
        val p = sk_point_zero()
        expect p.x == 0.0
        expect p.y == 0.0

    it "offset moves point":
        val p = sk_point(1.0, 2.0)
        val q = p.offset(10.0, 20.0)
        expect q.x == 11.0
        expect q.y == 22.0

    it "to_string contains coordinates":
        val p = sk_point(1.0, 2.0)
        val s = p.to_string()
        expect (s).contains("SkPoint")

describe "SkSize":
    it "constructs with width and height":
        val s = sk_size(100.0, 200.0)
        expect s.width == 100.0
        expect s.height == 200.0

    it "is_empty true for zero size":
        val s = sk_size(0.0, 100.0)
        expect s.is_empty() == true

    it "is_empty false for positive size":
        val s = sk_size(10.0, 10.0)
        expect s.is_empty() == false

    it "is_empty true for negative width":
        val s = sk_size(-1.0, 100.0)
        expect s.is_empty() == true

describe "SkISize":
    it "constructs with integer width and height":
        val s = sk_isize(800, 600)
        expect s.width == 800
        expect s.height == 600

describe "SkRect":
    it "constructs from ltrb":
        val r = sk_rect(10.0, 20.0, 110.0, 70.0)
        expect r.left == 10.0
        expect r.top == 20.0
        expect r.right == 110.0
        expect r.bottom == 70.0

    it "make_wh starts at origin":
        val r = sk_rect_make_wh(200.0, 100.0)
        expect r.left == 0.0
        expect r.top == 0.0
        expect r.right == 200.0
        expect r.bottom == 100.0

    it "make_xywh sets position and size":
        val r = sk_rect_make_xywh(5.0, 10.0, 100.0, 50.0)
        expect r.left == 5.0
        expect r.top == 10.0
        expect r.right == 105.0
        expect r.bottom == 60.0

    it "width() returns right - left":
        val r = sk_rect(10.0, 0.0, 90.0, 0.0)
        expect r.width() == 80.0

    it "height() returns bottom - top":
        val r = sk_rect(0.0, 5.0, 0.0, 55.0)
        expect r.height() == 50.0

    it "is_empty when left >= right":
        val r = sk_rect(50.0, 0.0, 50.0, 100.0)
        expect r.is_empty() == true

    it "is_empty false for valid rect":
        val r = sk_rect_make_wh(100.0, 100.0)
        expect r.is_empty() == false

    it "contains_point inside":
        val r = sk_rect(0.0, 0.0, 100.0, 100.0)
        val p = SkPoint(x: 50.0, y: 50.0)
        expect r.contains_point(p) == true

    it "contains_point outside":
        val r = sk_rect(0.0, 0.0, 100.0, 100.0)
        val p = SkPoint(x: 150.0, y: 50.0)
        expect r.contains_point(p) == false

    it "inset reduces rect":
        val r = sk_rect(0.0, 0.0, 100.0, 100.0)
        val inset = r.inset(10.0, 10.0)
        expect inset.left == 10.0
        expect inset.top == 10.0
        expect inset.right == 90.0
        expect inset.bottom == 90.0

    it "offset shifts rect":
        val r = sk_rect(10.0, 20.0, 110.0, 120.0)
        val shifted = r.offset(5.0, -5.0)
        expect shifted.left == 15.0
        expect shifted.top == 15.0

    it "intersects overlapping rects":
        val r1 = sk_rect(0.0, 0.0, 100.0, 100.0)
        val r2 = sk_rect(50.0, 50.0, 150.0, 150.0)
        expect r1.intersects(r2) == true

    it "does not intersect disjoint rects":
        val r1 = sk_rect(0.0, 0.0, 100.0, 100.0)
        val r2 = sk_rect(200.0, 200.0, 300.0, 300.0)
        expect r1.intersects(r2) == false

describe "SkIRect":
    it "constructs from ltrb integers":
        val r = sk_irect(0, 0, 800, 600)
        expect r.width() == 800
        expect r.height() == 600

    it "make_wh starts at origin":
        val r = sk_irect_make_wh(1920, 1080)
        expect r.left == 0
        expect r.right == 1920

    it "is_empty when width is zero":
        val r = sk_irect(10, 0, 10, 100)
        expect r.is_empty() == true

describe "SkRRect":
    it "constructs with rect and radii":
        val rect = sk_rect_make_wh(200.0, 100.0)
        val rr = sk_rrect_make(rect, 10.0, 10.0)
        expect rr.radius_x == 10.0
        expect rr.radius_y == 10.0

    it "is_rect when radii are zero":
        val rect = sk_rect_make_wh(100.0, 100.0)
        val rr = sk_rrect_make(rect, 0.0, 0.0)
        expect rr.is_rect() == true

    it "is_not_rect when radii are nonzero":
        val rect = sk_rect_make_wh(100.0, 100.0)
        val rr = sk_rrect_make(rect, 5.0, 5.0)
        expect rr.is_rect() == false

    it "oval has radii equal to half size":
        val rect = sk_rect_make_wh(100.0, 60.0)
        val rr = sk_rrect_make_oval(rect)
        expect rr.radius_x == 50.0
        expect rr.radius_y == 30.0

    it "oval is_oval":
        val rect = sk_rect_make_wh(100.0, 60.0)
        val rr = sk_rrect_make_oval(rect)
        expect rr.is_oval() == true