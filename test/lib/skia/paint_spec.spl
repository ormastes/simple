# @cover src/lib/skia/entity/paint.spl 80%
"""
# Skia Paint Specification

**Feature IDs:** #SKI-004
**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Implemented

## Overview

Tests for SkPaint construction and builder-style mutation.
"""

use std.skia.entity.enums.{SkPaintStyle, SkPaintCap, SkPaintJoin, SkBlendMode}
use std.skia.entity.color.{sk_color_black, sk_color_white, sk_color_rgb}
use std.skia.entity.paint.{SkPaint, sk_paint_new, sk_paint_fill, sk_paint_stroke}

describe "SkPaint construction":
    it "sk_paint_new default is fill":
        val p = sk_paint_new()
        expect(p.style).to_equal(SkPaintStyle.Fill)

    it "sk_paint_new default anti_alias is false":
        val p = sk_paint_new()
        expect(p.anti_alias).to_equal(false)

    it "sk_paint_new default stroke_width is 0":
        val p = sk_paint_new()
        expect(p.stroke_width).to_equal(0.0)

    it "sk_paint_new default color is black":
        val p = sk_paint_new()
        expect(p.color).to_equal(sk_color_black())

    it "sk_paint_fill creates fill paint":
        val p = sk_paint_fill(sk_color_white())
        expect(p.style).to_equal(SkPaintStyle.Fill)
        expect(p.anti_alias).to_equal(true)

    it "sk_paint_stroke creates stroke paint":
        val p = sk_paint_stroke(sk_color_black(), 2.0)
        expect(p.style).to_equal(SkPaintStyle.Stroke)
        expect(p.stroke_width).to_equal(2.0)

describe "SkPaint with_ builders":
    it "with_color changes color":
        val p = sk_paint_new()
        val white = sk_color_white()
        val p2 = p.with_color(white)
        expect(p2.color).to_equal(white)

    it "with_style changes style to stroke":
        val p = sk_paint_new()
        val p2 = p.with_style(SkPaintStyle.Stroke)
        expect(p2.style).to_equal(SkPaintStyle.Stroke)

    it "with_stroke_width sets width":
        val p = sk_paint_new()
        val p2 = p.with_stroke_width(5.0)
        expect(p2.stroke_width).to_equal(5.0)

    it "with_anti_alias enables aa":
        val p = sk_paint_new()
        val p2 = p.with_anti_alias(true)
        expect(p2.anti_alias).to_equal(true)

    it "with_blend_mode sets mode":
        val p = sk_paint_new()
        val p2 = p.with_blend_mode(SkBlendMode.Multiply)
        expect(p2.blend_mode).to_equal(SkBlendMode.Multiply)

    it "builders are immutable — original unchanged":
        val p = sk_paint_new()
        val _ = p.with_stroke_width(99.0)
        expect(p.stroke_width).to_equal(0.0)

describe "SkPaint predicates":
    it "is_fill true for fill paint":
        val p = sk_paint_fill(sk_color_black())
        expect(p.is_fill()).to_equal(true)
        expect(p.is_stroke()).to_equal(false)

    it "is_stroke true for stroke paint":
        val p = sk_paint_stroke(sk_color_black(), 1.0)
        expect(p.is_stroke()).to_equal(true)
        expect(p.is_fill()).to_equal(false)

describe "SkPaint to_string":
    it "to_string contains SkPaint":
        val p = sk_paint_new()
        expect(p.to_string()).to_contain("SkPaint")
