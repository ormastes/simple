#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.skia.feature.shaper.script_detect.{Script, script_of, script_is_rtl}
use std.skia.feature.shaper.feature_tags.{OpenTypeFeature, feature_tag}
use std.skia.feature.shaper.font_fallback.{FallbackChain, fallback_chain_new, fallback_chain_add, fallback_chain_font_for_script, fallback_chain_font_for_run, system_default_chain}
use std.skia.feature.shaper.shaper.{Shaper, ShapedRun, ShapedGlyph, ArabicJoinForm, IndicClass, ThaiClass, MyanmarClass, KhmerClass, TibetanClass, HangulClass, HebrewClass, MongolianClass, shaper_new, shaper_with_ot_font, ascii_to_codepoints, shaper_shape, arabic_join_form, devanagari_classify, classify_thai_char, classify_myanmar_char, classify_khmer_char, classify_tibetan_char, classify_hangul_char, classify_hebrew_char, classify_mongolian_char}
use std.skia.entity.font.{sk_font_default, sk_typeface_from_name, sk_typeface_from_attached_font, sk_font_new, sk_font_style_normal}
use std.nogc_sync_mut.io.font_ffi.{load_font, free_font}


fn main():
    # Shaper and script detection specification tests


    describe "script_of: Latin range":
        it "ASCII 'A' (0x0041) is Latin":
            val cp = 65 as u32
            val s = script_of(cp)
            expect s == Script.Latin

        it "ASCII boundary 0x007F is Latin":
            val cp = 127 as u32
            val s = script_of(cp)
            expect s == Script.Latin

    describe "script_of: Hebrew range":
        it "Hebrew alef 0x05D0 (1488) is Hebrew":
            val cp = 1488 as u32
            val s = script_of(cp)
            expect s == Script.Hebrew

    describe "script_of: Arabic range":
        it "Arabic letter 0x0628 (1576) is Arabic":
            val cp = 1576 as u32
            val s = script_of(cp)
            expect s == Script.Arabic

    describe "script_of: CJK range":
        it "CJK 0x4E2D (19997) is CJK":
            val cp = 19997 as u32
            val s = script_of(cp)
            expect s == Script.CJK

    describe "script_is_rtl":
        it "Arabic is RTL":
            val r = script_is_rtl(Script.Arabic)
            expect r == true

        it "Hebrew is RTL":
            val r = script_is_rtl(Script.Hebrew)
            expect r == true

        it "Latin is not RTL":
            val r = script_is_rtl(Script.Latin)
            expect r == false

    describe "feature_tag":
        it "Kerning tag is kern":
            val t = feature_tag(OpenTypeFeature.Kerning)
            expect t == "kern"

        it "Ligatures tag is liga":
            val t = feature_tag(OpenTypeFeature.Ligatures)
            expect t == "liga"

        it "SmallCaps tag is smcp":
            val t = feature_tag(OpenTypeFeature.SmallCaps)
            expect t == "smcp"

    describe "FallbackChain":
        it "new stores primary font":
            val font = sk_font_default()
            val chain = fallback_chain_new(font)
            expect chain.primary.size == 12.0

        it "system_default_chain returns a chain with 12pt primary":
            val chain = system_default_chain()
            expect chain.primary.size == 12.0

        it "returns primary font for Latin script":
            val primary = sk_font_new(sk_typeface_from_name("Primary Sans", sk_font_style_normal()), 12.0)
            val arabic = sk_font_new(sk_typeface_from_name("Noto Sans Arabic", sk_font_style_normal()), 12.0)
            val chain = fallback_chain_add(fallback_chain_new(primary), arabic)
            val selected = fallback_chain_font_for_script(chain, Script.Latin)
            expect selected.typeface.family_name == "Primary Sans"

        it "prefers script-named fallback font for Arabic":
            val primary = sk_font_new(sk_typeface_from_name("Primary Sans", sk_font_style_normal()), 12.0)
            val arabic = sk_font_new(sk_typeface_from_name("Noto Sans Arabic", sk_font_style_normal()), 12.0)
            val hebrew = sk_font_new(sk_typeface_from_name("Noto Sans Hebrew", sk_font_style_normal()), 12.0)
            val chain = fallback_chain_add(fallback_chain_add(fallback_chain_new(primary), hebrew), arabic)
            val selected = fallback_chain_font_for_script(chain, Script.Arabic)
            expect selected.typeface.family_name == "Noto Sans Arabic"

        it "falls back to first fallback when no script-specific match exists":
            val primary = sk_font_new(sk_typeface_from_name("Primary Sans", sk_font_style_normal()), 12.0)
            val fallback = sk_font_new(sk_typeface_from_name("Fallback Sans", sk_font_style_normal()), 12.0)
            val chain = fallback_chain_add(fallback_chain_new(primary), fallback)
            val selected = fallback_chain_font_for_script(chain, Script.CJK)
            expect selected.typeface.family_name == "Fallback Sans"

        it "prefers attached fallback font when it alone covers the run":
            val demo = load_font("src/compiler_rust/vendor/ttf-parser/tests/fonts/demo.ttf")
            expect (demo != nil) == true
            val handle = demo as std.nogc_sync_mut.io.font_ffi.FontHandle
            val primary = sk_font_new(sk_typeface_from_name("Primary Sans", sk_font_style_normal()), 12.0)
            val attached = sk_font_new(
                sk_typeface_from_attached_font("Demo Latin", sk_font_style_normal(), handle.path, handle.handle),
                12.0
            )
            val chain = fallback_chain_add(fallback_chain_new(primary), attached)
            val cps: [u32] = [65 as u32]
            val selected = fallback_chain_font_for_run(chain, Script.Latin, cps, 0, cps.len())
            expect selected.typeface.family_name == "Demo Latin"
            free_font(handle)

        it "falls back to heuristic script match when no attached font covers the run":
            val demo = load_font("src/compiler_rust/vendor/ttf-parser/tests/fonts/demo.ttf")
            expect (demo != nil) == true
            val handle = demo as std.nogc_sync_mut.io.font_ffi.FontHandle
            val primary = sk_font_new(
                sk_typeface_from_attached_font("Demo Latin", sk_font_style_normal(), handle.path, handle.handle),
                12.0
            )
            val cjk = sk_font_new(sk_typeface_from_name("Noto Sans CJK", sk_font_style_normal()), 12.0)
            val chain = fallback_chain_add(fallback_chain_new(primary), cjk)
            val cps: [u32] = [19997 as u32]
            val selected = fallback_chain_font_for_run(chain, Script.CJK, cps, 0, cps.len())
            expect selected.typeface.family_name == "Noto Sans CJK"
            free_font(handle)

    describe "Shaper":
        it "shaper_new stores fallback chain":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            expect shaper.fallback.primary.size == 12.0

    describe "ascii_to_codepoints":
        it "hello produces 5 codepoints":
            val cps = ascii_to_codepoints("hello")
            expect cps.len() == 5

        it "first codepoint of hello is 104 (h)":
            val cps = ascii_to_codepoints("hello")
            val first = cps[0]
            expect first == 104 as u32

    # ===== New shaping tests =====

    describe "shaper_shape: empty text":
        it "empty codepoint list produces empty run list":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val runs = shaper_shape(shaper, [], sk_font_default(), 0.0, 0.0)
            expect runs.len() == 0

    describe "shaper_shape: ASCII Latin text":
        it "ASCII 'hi' produces a single Latin run":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps = ascii_to_codepoints("hi")
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            expect runs.len() == 1

        it "Latin run has correct script":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps = ascii_to_codepoints("hi")
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            expect run.script == Script.Latin

        it "Latin glyph ids match codepoints (identity mapping without OtFont)":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            # 'A' = 65, 'B' = 66
            val cps: [u32] = [65 as u32, 66 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            val gid0 = run.glyph_ids[0]
            val gid1 = run.glyph_ids[1]
            expect gid0 == 65 as u32
            expect gid1 == 66 as u32

    describe "shaper_shape: mixed Latin + Arabic":
        it "mixed Latin then Arabic codepoints produces 2 runs":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            # 'A'=65 (Latin), Arabic ba=1576
            val cps: [u32] = [65 as u32, 1576 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            expect runs.len() == 2

        it "first run of mixed text is Latin":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [65 as u32, 1576 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val first_run = runs[0]
            expect first_run.script == Script.Latin

        it "second run of mixed text is Arabic":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [65 as u32, 1576 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val second_run = runs[1]
            expect second_run.script == Script.Arabic

    describe "shaper_shape: Arabic-only joining forms":
        it "Arabic run is RTL":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            # Arabic: alef=1575, ba=1576, jim=1580
            val cps: [u32] = [1575 as u32, 1576 as u32, 1580 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            expect run.is_rtl == true

        it "Arabic sequence produces exactly 1 run":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [1575 as u32, 1576 as u32, 1580 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            expect runs.len() == 1

        it "Arabic middle letter classified as Medial or Final (joining form set)":
            # ba (1576) between two joiners: alef (1575, right-joining only) on left, jim (1580) on right
            # alef can join left (to ba on its right), ba can join right (to jim on its right)
            # ba: has_left = alef joins to ba's left neighbor? alef is right-joining only so arabic_can_join_left(1575)=false
            # ba: has_right = jim (1580) arabic_can_join_right(1580)=true (in 1576-1594 range)
            # So ba gets Initial form
            val cps: [u32] = [1575 as u32, 1576 as u32, 1580 as u32]
            val form = arabic_join_form(cps, 1)
            expect form == ArabicJoinForm.Initial

        it "isolated Arabic letter gets Isolated join form":
            val cps: [u32] = [1575 as u32]
            val form = arabic_join_form(cps, 0)
            expect form == ArabicJoinForm.Isolated

    describe "shaper_shape: Devanagari reph classification":
        it "Devanagari ra (2352) is classified as Reph":
            val cls = devanagari_classify(2352 as u32)
            expect cls == IndicClass.Reph

        it "Devanagari virama (2381) is classified as Halant":
            val cls = devanagari_classify(2381 as u32)
            expect cls == IndicClass.Halant

        it "Devanagari matra (2366) is classified as Matra":
            val cls = devanagari_classify(2366 as u32)
            expect cls == IndicClass.Matra

        it "Devanagari run produces 1 run for Devanagari-only codepoints":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            # Devanagari: ka=2325, virama=2381, ra=2352
            val cps: [u32] = [2325 as u32, 2381 as u32, 2352 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            expect runs.len() == 1

        it "Devanagari run has Devanagari script":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [2325 as u32, 2381 as u32, 2352 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            expect run.script == Script.Devanagari

        it "leading ra + halant is reordered after the first base consonant":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            # ra + halant + ka
            val cps: [u32] = [2352 as u32, 2381 as u32, 2325 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            expect run.glyphs.len() == 3
            expect run.glyphs[0].indic_class == IndicClass.Normal
            expect run.glyphs[1].indic_class == IndicClass.Reph
            expect run.glyphs[2].indic_class == IndicClass.Halant
            expect run.glyphs[1].x_advance == 0.0
            expect run.glyphs[2].x_advance == 0.0
            expect run.positions[1].x == run.positions[0].x + run.glyphs[0].x_advance
            expect run.positions[2].x == run.positions[1].x

    describe "shaper_shape: glyph count matches codepoint count (no ligatures)":
        it "3 ASCII codepoints produce 3 glyph ids":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [72 as u32, 105 as u32, 33 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            expect run.glyph_ids.len() == 3

        it "positions count matches glyph count":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [72 as u32, 105 as u32, 33 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            expect run.positions.len() == run.glyph_ids.len()

    describe "shaper_shape: advances from font size when no OtFont":
        it "positions are monotonically increasing for LTR Latin":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [65 as u32, 66 as u32, 67 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 0.0, 0.0)
            val run = runs[0]
            val x0 = run.positions[0].x
            val x1 = run.positions[1].x
            val x2 = run.positions[2].x
            expect x1 to_be_greater_than x0
            expect x2 to_be_greater_than x1

        it "first position x is start_x":
            val chain = system_default_chain()
            val shaper = shaper_new(chain)
            val cps: [u32] = [65 as u32, 66 as u32]
            val runs = shaper_shape(shaper, cps, sk_font_default(), 10.0, 5.0)
            val run = runs[0]
            expect run.positions[0].x == 10.0

    # ===== Complex-script classification tests =====

    describe "classify_thai_char":
        it "Thai ko kai U+0E01 is Consonant":
            val c = classify_thai_char(0x0E01)
            expect c == ThaiClass.Consonant

        it "Thai sara a U+0E30 is Vowel":
            val c = classify_thai_char(0x0E30)
            expect c == ThaiClass.Vowel

        it "Thai mai ek U+0E48 is ToneMark":
            val c = classify_thai_char(0x0E48)
            expect c == ThaiClass.ToneMark

    describe "classify_myanmar_char":
        it "Myanmar ka U+1000 is Consonant":
            val c = classify_myanmar_char(0x1000)
            expect c == MyanmarClass.Consonant

        it "Myanmar asat/virama U+1039 is Virama":
            val c = classify_myanmar_char(0x1039)
            expect c == MyanmarClass.Virama

    describe "classify_khmer_char":
        it "Khmer ka U+1780 is Consonant":
            val c = classify_khmer_char(0x1780)
            expect c == KhmerClass.Consonant

        it "Khmer coeng U+17D2 is Coeng":
            val c = classify_khmer_char(0x17D2)
            expect c == KhmerClass.Coeng

    describe "classify_tibetan_char":
        it "Tibetan ka U+0F40 is Consonant":
            val c = classify_tibetan_char(0x0F40)
            expect c == TibetanClass.Consonant

        it "Tibetan subjoined ka U+0F90 is Subjoined":
            val c = classify_tibetan_char(0x0F90)
            expect c == TibetanClass.Subjoined

    describe "classify_hangul_char":
        it "Hangul leading jamo U+1100 is LeadingJamo":
            val c = classify_hangul_char(0x1100)
            expect c == HangulClass.LeadingJamo

        it "Hangul precomposed syllable U+AC00 is PrecomposedSyllable":
            val c = classify_hangul_char(0xAC00)
            expect c == HangulClass.PrecomposedSyllable

    describe "classify_hebrew_char":
        it "Hebrew alef U+05D0 is Consonant":
            val c = classify_hebrew_char(0x05D0)
            expect c == HebrewClass.Consonant

        it "Hebrew final kaf U+05DA is FinalConsonant":
            val c = classify_hebrew_char(0x05DA)
            expect c == HebrewClass.FinalConsonant

        it "Hebrew patah U+05B7 is Point":
            val c = classify_hebrew_char(0x05B7)
            expect c == HebrewClass.Point

    describe "classify_mongolian_char":
        it "Mongolian consonant U+1820 is Consonant":
            val c = classify_mongolian_char(0x1820)
            expect c == MongolianClass.Consonant

        it "Mongolian FVS1 U+180B is FormatControl":
            val c = classify_mongolian_char(0x180B)
            expect c == MongolianClass.FormatControl