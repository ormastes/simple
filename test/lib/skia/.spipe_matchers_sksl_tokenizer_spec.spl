# @cover src/lib/skia/feature/sksl/tokenizer.spl 80%
"""
# SkSL Tokenizer Specification

**Feature IDs:** #SKI-SKSL-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests for `tokenize_sksl` — the lexical analyzer that turns SkSL source
text into a token stream for the future SkRuntimeEffect frontend. Covers
identifiers, keywords, int/float literals, operators, line comments, and
a small end-to-end shader fragment.
"""

use std.spipe.*
use std.skia.feature.sksl.{
    TokenKind, Token,
    SKSL_KEYWORDS,
    tokenize_sksl
}

describe "sksl_tokenizer":
    it "tokenize_sksl: empty string returns [Eof]":
        val toks = tokenize_sksl("")
        expect toks.len() == 1
        expect toks[0].kind == TokenKind.Eof == true
        expect toks[0].text == ""

    it "tokenize_sksl: single identifier \"foo\" produces [Identifier(\"foo\"), Eof]":
        val toks = tokenize_sksl("foo")
        expect toks.len() == 2
        expect toks[0].kind == TokenKind.Identifier == true
        expect toks[0].text == "foo"
        expect toks[1].kind == TokenKind.Eof == true

    it "tokenize_sksl: keyword \"uniform\" produces [Keyword(\"uniform\"), Eof]":
        val toks = tokenize_sksl("uniform")
        expect toks.len() == 2
        expect toks[0].kind == TokenKind.Keyword == true
        expect toks[0].text == "uniform"
        expect toks[1].kind == TokenKind.Eof == true

    it "tokenize_sksl: integer literal \"42\" produces [IntLiteral(\"42\"), Eof]":
        val toks = tokenize_sksl("42")
        expect toks.len() == 2
        expect toks[0].kind == TokenKind.IntLiteral == true
        expect toks[0].text == "42"
        expect toks[1].kind == TokenKind.Eof == true

    it "tokenize_sksl: float literal \"3.14\" produces [FloatLiteral(\"3.14\"), Eof]":
        val toks = tokenize_sksl("3.14")
        expect toks.len() == 2
        expect toks[0].kind == TokenKind.FloatLiteral == true
        expect toks[0].text == "3.14"
        expect toks[1].kind == TokenKind.Eof == true

    it "tokenize_sksl: operator \"==\" produces [Operator(\"==\"), Eof]":
        val toks = tokenize_sksl("==")
        expect toks.len() == 2
        expect toks[0].kind == TokenKind.Operator == true
        expect toks[0].text == "=="
        expect toks[1].kind == TokenKind.Eof == true

    it "tokenize_sksl: line comment \"// hi\\nfoo\" skips comment, emits Identifier(\"foo\")":
        val toks = tokenize_sksl("// hi\nfoo")
        expect toks.len() == 2
        expect toks[0].kind == TokenKind.Identifier == true
        expect toks[0].text == "foo"
        expect toks[1].kind == TokenKind.Eof == true

    it "tokenize_sksl: simple shader \"void main() { return; }\" produces expected 6+ tokens":
        val toks = tokenize_sksl("void main() { return; }")
        # void Keyword, main Identifier, ( Punct, ) Punct, { Punct,
        # return Keyword, ; Punct, } Punct, Eof  => 9 total (>= 7 non-Eof)
        expect toks.len() > 6
        expect toks[0].kind == TokenKind.Keyword == true
        expect toks[0].text == "void"
        expect toks[1].kind == TokenKind.Identifier == true
        expect toks[1].text == "main"
        val last = toks[toks.len() - 1]
        expect last.kind == TokenKind.Eof == true