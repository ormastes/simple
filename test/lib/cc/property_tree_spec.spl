# Tests for cc::PropertyTrees — TransformTree, ClipTree, EffectTree, ScrollTree.

use std.lib.cc.entity.property_tree.{
    TransformTree, TransformNode,
    ClipTree, ClipNode,
    EffectTree, EffectNode,
    ScrollTree, ScrollNode,
    PropertyTrees
}

describe "TransformTree":
    it "initializes with a root node at id 0":
        val tree = TransformTree.new()
        val root = tree.get(0)
        expect(root.id).to_equal(0)

    it "root has parent_id -1":
        val tree = TransformTree.new()
        val root = tree.get(0)
        expect(root.parent_id).to_equal(-1)

    it "add_node returns id 1 for first child":
        val tree = TransformTree.new()
        val child = TransformNode(
            id: 0,
            parent_id: 0,
            local: [f32](),
            origin_x: 0.0,
            origin_y: 0.0,
            scrolls: false,
            flattens_inherited_transform: false
        )
        val new_id = tree.add_node(child)
        expect(new_id).to_equal(1)

    it "root_id returns 0":
        val tree = TransformTree.new()
        expect(tree.root_id()).to_equal(0)

describe "ClipTree":
    it "initializes with a root node at id 0":
        val tree = ClipTree.new()
        val root = tree.get(0)
        expect(root.id).to_equal(0)

    it "root has parent_id -1":
        val tree = ClipTree.new()
        val root = tree.get(0)
        expect(root.parent_id).to_equal(-1)

    it "add_node returns id 1 for first child":
        val tree = ClipTree.new()
        val child = ClipNode(
            id: 0,
            parent_id: 0,
            clip_x: 10.0,
            clip_y: 20.0,
            clip_w: 100.0,
            clip_h: 50.0,
            transform_id: 0,
            applies_local_clip: true
        )
        val new_id = tree.add_node(child)
        expect(new_id).to_equal(1)

describe "EffectTree":
    it "initializes with a root node at id 0":
        val tree = EffectTree.new()
        val root = tree.get(0)
        expect(root.id).to_equal(0)

    it "root opacity is 1.0":
        val tree = EffectTree.new()
        val root = tree.get(0)
        expect(root.opacity).to_equal(1.0)

    it "add_node returns id 1 for first child":
        val tree = EffectTree.new()
        val child = EffectNode(
            id: 0,
            parent_id: 0,
            opacity: 0.5,
            blend_mode: 0,
            has_render_surface: true,
            clip_id: 0,
            transform_id: 0
        )
        val new_id = tree.add_node(child)
        expect(new_id).to_equal(1)

describe "ScrollTree":
    it "initializes with a root node at id 0":
        val tree = ScrollTree.new()
        val root = tree.get(0)
        expect(root.id).to_equal(0)

    it "root is not scrollable":
        val tree = ScrollTree.new()
        val root = tree.get(0)
        expect(root.scrollable).to_equal(false)

    it "add_node returns id 1 for first child":
        val tree = ScrollTree.new()
        val child = ScrollNode(
            id: 0,
            parent_id: 0,
            scrollable: true,
            scroll_offset_x: 0.0,
            scroll_offset_y: 100.0,
            container_width: 800.0,
            container_height: 600.0,
            content_width: 800.0,
            content_height: 1200.0
        )
        val new_id = tree.add_node(child)
        expect(new_id).to_equal(1)

describe "PropertyTrees":
    it "new creates all four trees":
        val trees = PropertyTrees.new()
        expect(trees.transform_tree.root_id()).to_equal(0)
        expect(trees.clip_tree.root_id()).to_equal(0)
        expect(trees.effect_tree.root_id()).to_equal(0)
        expect(trees.scroll_tree.root_id()).to_equal(0)
