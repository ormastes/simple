#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.cc.entity.layer.{Layer, LayerKind}
use std.cc.entity.layer_tree_host.{LayerTreeImpl, LayerTreeHost}
use std.skia.entity.geometry.{SkRect}


fn main():
    # @cover src/lib/cc/entity/layer_tree_host.spl 80%


    describe "LayerTreeImpl":
        context "empty":
            it "has 0 layers when created empty":
                val tree = LayerTreeImpl.empty()
                expect tree.layer_count() == 0

        context "add_layer":
            it "add_layer returns monotonically increasing ids":
                var tree = LayerTreeImpl.empty()
                val bounds = SkRect.make_xywh(0.0, 0.0, 100.0, 100.0)
                val l1 = Layer.root(bounds)
                val l2 = Layer.root(bounds)
                val id1 = tree.add_layer(l1)
                val id2 = tree.add_layer(l2)
                expect id2 > id1 == true

            it "layer_count grows after add_layer":
                var tree = LayerTreeImpl.empty()
                val bounds = SkRect.make_xywh(0.0, 0.0, 50.0, 50.0)
                val l = Layer.root(bounds)
                tree.add_layer(l)
                expect tree.layer_count() == 1

    describe "LayerTreeHost":
        context "new":
            it "starts with needs_commit=false and source_frame_number=0":
                val host = LayerTreeHost.new()
                expect host.needs_commit == false
                expect host.source_frame_number == 0

        context "set_needs_commit and commit":
            it "set_needs_commit sets flag then commit clears it":
                var host = LayerTreeHost.new()
                host.set_needs_commit()
                expect host.needs_commit == true
                host.commit()
                expect host.needs_commit == false

        context "commit copies pending to active":
            it "layer added to pending appears in active after commit":
                var host = LayerTreeHost.new()
                val bounds = SkRect.make_xywh(0.0, 0.0, 200.0, 200.0)
                val l = Layer.root(bounds)
                host.pending_tree.add_layer(l)
                expect host.active_tree.layer_count() == 0
                host.commit()
                expect host.active_tree.layer_count() == 1

        context "begin_main_frame":
            it "increments source_frame_number each call":
                var host = LayerTreeHost.new()
                host.begin_main_frame()
                expect host.source_frame_number == 1
                host.begin_main_frame()
                expect host.source_frame_number == 2

        context "tree independence":
            it "changing pending after commit does not mutate active":
                var host = LayerTreeHost.new()
                val bounds = SkRect.make_xywh(0.0, 0.0, 64.0, 64.0)
                val l = Layer.root(bounds)
                host.pending_tree.add_layer(l)
                host.commit()
                val active_count_before = host.active_tree.layer_count()
                val l2 = Layer.root(bounds)
                host.pending_tree.add_layer(l2)
                expect host.active_tree.layer_count() == active_count_before