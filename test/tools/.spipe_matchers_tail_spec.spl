# Test: tail tool
# Feature: TOOL-TAIL - Output last part of files

# Local reimplementation to avoid interpreter-mode import issues
# (importing app.tools.tail.main fails with "cannot index string with type `symbol`")

fn tail_lines(content: text, n: i64) -> text:
    """Get last n lines of content."""
    val lines = content.split("\n")
    if n >= lines.len():
        return content
    val start = lines.len() - n
    var result: [text] = []
    var i = start
    while i < lines.len():
        result.push(lines[i])
        i = i + 1
    result.join("\n")

fn tail_bytes(content: text, n: i64) -> text:
    """Get last n bytes of content."""
    if n >= content.len():
        return content
    content[content.len() - n:]

describe "tail tool":
    context "line selection":
        it "gets last N lines":
            val content = "line1\nline2\nline3\nline4\nline5"
            val result = tail_lines(content, 3)
            expect result == "line3\nline4\nline5"

        it "returns all lines when N exceeds count":
            val content = "line1\nline2"
            val result = tail_lines(content, 10)
            expect result == "line1\nline2"

        it "returns last line":
            val content = "first\nlast"
            val result = tail_lines(content, 1)
            expect result == "last"

    context "byte selection":
        it "gets last N bytes":
            val content = "hello world"
            val result = tail_bytes(content, 5)
            expect result == "world"

        it "returns all when N exceeds length":
            val content = "hi"
            val result = tail_bytes(content, 100)
            expect result == "hi"