# Test: head tool
# Feature: TOOL-HEAD - Output first part of files
#
# Local reimplementation of head functions to avoid interpreter-mode issues
# (importing app.tools.head.main fails with "cannot index string with type `symbol`")

fn head_lines(content: text, n: i64) -> text:
    """Get first n lines of content."""
    val lines = content.split("\n")
    var result: [text] = []
    var count = 0
    for line in lines:
        if count >= n:
            return result.join("\n")
        result.push(line)
        count = count + 1
    result.join("\n")

fn head_bytes(content: text, n: i64) -> text:
    """Get first n bytes of content."""
    if n >= content.len():
        return content
    content.substring(0, n)

describe "head tool":
    context "line selection":
        it "gets first N lines":
            val content = "line1\nline2\nline3\nline4\nline5"
            val result = head_lines(content, 3)
            expect(result).to_equal("line1\nline2\nline3")

        it "returns all lines when N exceeds count":
            val content = "line1\nline2"
            val result = head_lines(content, 10)
            expect(result).to_equal("line1\nline2")

        it "returns first line":
            val content = "only\nsecond"
            val result = head_lines(content, 1)
            expect(result).to_equal("only")

    context "byte selection":
        it "gets first N bytes":
            val content = "hello world"
            val result = head_bytes(content, 5)
            expect(result).to_equal("hello")

        it "returns all when N exceeds length":
            val content = "hi"
            val result = head_bytes(content, 100)
            expect(result).to_equal("hi")
