# Test: echo tool
# Feature: TOOL-ECHO - Print arguments to stdout

# Local reimplementation to avoid interpreter-mode import issues
# (importing app.tools.echo.main fails with "cannot index string with type `symbol`")

fn process_escapes(s: text) -> text:
    """Process backslash escape sequences."""
    var result = ""
    var i = 0
    while i < s.len():
        if s[i:i + 1] == "\\" and i + 1 < s.len():
            val next = s[i + 1:i + 2]
            if next == "n":
                result = result + "\n"
                i = i + 2
            elif next == "t":
                result = result + "\t"
                i = i + 2
            elif next == "\\":
                result = result + "\\"
                i = i + 2
            else:
                result = result + s[i:i + 1]
                i = i + 1
        else:
            result = result + s[i:i + 1]
            i = i + 1
    result

describe "echo tool":
    context "escape processing":
        it "processes newline escape":
            val result = process_escapes("hello\\nworld")
            expect(result).to_equal("hello\nworld")

        it "processes tab escape":
            val result = process_escapes("col1\\tcol2")
            expect(result).to_equal("col1\tcol2")

        it "processes backslash escape":
            val result = process_escapes("back\\\\slash")
            expect(result).to_equal("back\\slash")

        it "leaves non-escape text unchanged":
            val result = process_escapes("hello world")
            expect(result).to_equal("hello world")

        it "handles empty string":
            val result = process_escapes("")
            expect(result).to_equal("")
