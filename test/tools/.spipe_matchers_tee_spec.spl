# Test: tee tool
# Feature: TOOL-TEE - Read stdin and write to stdout and files

describe "tee tool":
    context "basic functionality":
        it "passes text through":
            val input = "hello world"
            expect input == "hello world"

        it "splits text into lines for file output":
            val content = "line1\nline2\nline3"
            val lines = content.split("\n")
            expect lines.len() == 3