# Test: uniq tool
# Feature: TOOL-UNIQ - Report or omit repeated lines

# Local reimplementation to avoid interpreter-mode import issues
# (importing app.tools.uniq.main fails with "cannot index string with type `symbol`")

fn lines_equal(a: text, b: text, ignore_case: bool) -> bool:
    """Compare two lines, optionally ignoring case."""
    if ignore_case:
        a.lower() == b.lower()
    else:
        a == b

describe "uniq tool":
    context "line comparison":
        it "detects equal lines":
            val result = lines_equal("hello", "hello", false)
            expect result == true

        it "detects different lines":
            val result = lines_equal("hello", "world", false)
            expect result == false

        it "compares case-insensitively":
            val result = lines_equal("Hello", "hello", true)
            expect result == true

        it "rejects different lines case-insensitively":
            val result = lines_equal("Hello", "World", true)
            expect result == false