# Test: grep tool
# Feature: TOOL-GREP - Search files for pattern matches
#
# Local reimplementation of grep helper functions to avoid interpreter-mode issues
# (importing app.tools.grep.main fails with "cannot convert enum to int")

fn is_word_char(ch: text) -> bool:
    """Check if character is a word character (letter, digit, underscore)."""
    if ch == "_":
        return true
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    false

fn line_matches(line: text, pattern: text, ignore_case: bool, whole_word: bool, whole_line: bool) -> bool:
    """Check if a line matches the given pattern with options."""
    var search_line = line
    var search_pattern = pattern

    if ignore_case:
        search_line = search_line.to_lower()
        search_pattern = search_pattern.to_lower()

    if whole_line:
        return search_line == search_pattern

    if not search_line.contains(search_pattern):
        return false

    if whole_word:
        val idx = search_line.index_of(search_pattern) ?? -1
        if idx < 0:
            return false
        # Check character before match
        if idx > 0:
            val before = search_line.substring(idx - 1, idx)
            if is_word_char(before):
                return false
        # Check character after match
        val after_idx = idx + search_pattern.len()
        if after_idx < search_line.len():
            val after = search_line.substring(after_idx, after_idx + 1)
            if is_word_char(after):
                return false

    true

describe "grep tool":
    context "basic matching":
        it "matches simple substring":
            val result = line_matches("hello world", "world", false, false, false)
            expect(result).to_equal(true)

        it "rejects non-matching line":
            val result = line_matches("hello world", "foo", false, false, false)
            expect(result).to_equal(false)

    context "case insensitive":
        it "matches ignoring case":
            val result = line_matches("Hello World", "hello", true, false, false)
            expect(result).to_equal(true)

        it "matches uppercase pattern against lowercase text":
            val result = line_matches("hello world", "HELLO", true, false, false)
            expect(result).to_equal(true)

    context "whole word matching":
        it "matches whole word":
            val result = line_matches("hello world", "hello", false, true, false)
            expect(result).to_equal(true)

        it "rejects partial word match":
            val result = line_matches("helloworld", "hello", false, true, false)
            expect(result).to_equal(false)

    context "whole line matching":
        it "matches entire line":
            val result = line_matches("hello", "hello", false, false, true)
            expect(result).to_equal(true)

        it "rejects partial line match":
            val result = line_matches("hello world", "hello", false, false, true)
            expect(result).to_equal(false)

    context "word character detection":
        it "detects letter as word char":
            expect(is_word_char("a")).to_equal(true)

        it "detects digit as word char":
            expect(is_word_char("5")).to_equal(true)

        it "detects underscore as word char":
            expect(is_word_char("_")).to_equal(true)

        it "rejects space as non-word char":
            expect(is_word_char(" ")).to_equal(false)
