# Test: sort tool
# Feature: TOOL-SORT - Sort lines of text

use app.tools.sort.main (insertion_sort, extract_field, remove_duplicates, compare_lines)

describe "sort tool":
    context "basic sorting":
        it "sorts lines alphabetically":
            val lines = ["cherry", "apple", "banana"]
            val result = insertion_sort(lines, false, false, false, 0, " ")
            expect(result[0]).to_equal("apple")
            expect(result[1]).to_equal("banana")
            expect(result[2]).to_equal("cherry")

        it "sorts in reverse":
            val lines = ["apple", "cherry", "banana"]
            val result = insertion_sort(lines, false, true, false, 0, " ")
            expect(result[0]).to_equal("cherry")
            expect(result[1]).to_equal("banana")
            expect(result[2]).to_equal("apple")

    context "numeric sorting":
        it "sorts numbers numerically":
            val lines = ["10", "2", "100", "1"]
            val result = insertion_sort(lines, true, false, false, 0, " ")
            expect(result[0]).to_equal("1")
            expect(result[1]).to_equal("2")
            expect(result[2]).to_equal("10")
            expect(result[3]).to_equal("100")

    context "field extraction":
        it "extracts first field":
            val field = extract_field("hello world", 1, " ")
            expect(field).to_equal("hello")

        it "extracts second field":
            val field = extract_field("hello world", 2, " ")
            expect(field).to_equal("world")

        it "returns full line for invalid field":
            val field = extract_field("hello", 5, " ")
            expect(field).to_equal("hello")

    context "duplicate removal":
        it "removes consecutive duplicates":
            val lines = ["a", "a", "b", "b", "c"]
            val result = remove_duplicates(lines)
            expect(result.len()).to_equal(3)
            expect(result[0]).to_equal("a")
            expect(result[1]).to_equal("b")
            expect(result[2]).to_equal("c")
