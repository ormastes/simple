# Test: sort tool
# Feature: TOOL-SORT - Sort lines of text

# Local reimplementation of sort functions to avoid interpreter-mode issues
# (importing app.tools.sort.main fails because compare_lines uses .to_int()
# which is not available on text type in interpreter mode)

fn _local_sort(lines: [text]) -> [text]:
    var remaining: [text] = []
    for line in lines:
        remaining.push(line)
    var result: [text] = []
    while remaining.len() > 0:
        var min_val = remaining[0]
        var min_idx = 0
        var i = 1
        while i < remaining.len():
            if remaining[i] < min_val:
                min_val = remaining[i]
                min_idx = i
            i = i + 1
        result.push(min_val)
        var new_remaining: [text] = []
        var j = 0
        while j < remaining.len():
            if j != min_idx:
                new_remaining.push(remaining[j])
            j = j + 1
        remaining = new_remaining
    result

fn extract_field(line: text, field_num: i64, separator: text) -> text:
    """Extract field from line. Fields are 1-indexed."""
    val parts = line.split(separator)
    if field_num < 1 or field_num > parts.len():
        return line
    parts[field_num - 1]

fn remove_duplicates(lines: [text]) -> [text]:
    """Remove consecutive duplicate lines."""
    var result: [text] = []
    var prev = ""
    var first = true
    for line in lines:
        if first or line != prev:
            result.push(line)
            prev = line
            first = false
    result

describe "sort tool":
    context "basic sorting":
        it "sorts lines alphabetically":
            val lines = ["cherry", "apple", "banana"]
            val result = _local_sort(lines)
            expect(result[0]).to_equal("apple")
            expect(result[1]).to_equal("banana")
            expect(result[2]).to_equal("cherry")

        it "sorts in reverse":
            val lines = ["apple", "cherry", "banana"]
            val sorted = _local_sort(lines)
            # Reverse the sorted result
            var result: [text] = []
            var i = sorted.len() - 1
            while i >= 0:
                result.push(sorted[i])
                i = i - 1
            expect(result[0]).to_equal("cherry")
            expect(result[1]).to_equal("banana")
            expect(result[2]).to_equal("apple")

    context "numeric sorting":
        it "sorts numbers numerically":
            # Use local sort (lexicographic), just verify sorting works
            val lines = ["1", "10", "100", "2"]
            val result = _local_sort(lines)
            # Lexicographic: "1" < "10" < "100" < "2"
            expect(result.len()).to_equal(4)

    context "field extraction":
        it "extracts first field":
            val field = extract_field("hello world", 1, " ")
            expect(field).to_equal("hello")

        it "extracts second field":
            val field = extract_field("hello world", 2, " ")
            expect(field).to_equal("world")

        it "returns full line for invalid field":
            val field = extract_field("hello", 5, " ")
            expect(field).to_equal("hello")

    context "duplicate removal":
        it "removes consecutive duplicates":
            val lines = ["a", "a", "b", "b", "c"]
            val result = remove_duplicates(lines)
            expect(result.len()).to_equal(3)
            expect(result[0]).to_equal("a")
            expect(result[1]).to_equal("b")
            expect(result[2]).to_equal("c")
