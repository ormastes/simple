# Test: tr tool
# Feature: TOOL-TR - Translate or delete characters

use app.tools.tr.main (expand_set, char_code_val, code_to_char)

describe "tr tool":
    context "set expansion":
        it "expands upper class":
            val result = expand_set("[:upper:]")
            expect(result).to_equal("ABCDEFGHIJKLMNOPQRSTUVWXYZ")

        it "expands lower class":
            val result = expand_set("[:lower:]")
            expect(result).to_equal("abcdefghijklmnopqrstuvwxyz")

        it "expands digit class":
            val result = expand_set("[:digit:]")
            expect(result).to_equal("0123456789")

        it "passes through literal characters":
            val result = expand_set("abc")
            expect(result).to_equal("abc")

    context "char code conversion":
        it "gets code for letter a":
            val code = char_code_val("a")
            expect(code).to_equal(97)

        it "gets code for letter A":
            val code = char_code_val("A")
            expect(code).to_equal(65)

        it "converts code back to char":
            val ch = code_to_char(97)
            expect(ch).to_equal("a")
