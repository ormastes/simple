# Test: tr tool
# Feature: TOOL-TR - Translate or delete characters
# @cover tools/shell/tr/tr_tool.spl

describe "tr tool":
    context "character translation":
        it "translates characters":
            val input = "hello"
            var output = ""
            for ch in input:
                if ch == "l":
                    output = "{output}r"
                else:
                    output = "{output}{ch}"
            expect(output).to_equal("herro")

    context "character deletion":
        it "deletes specified characters":
            val input = "hello world"
            var output = ""
            for ch in input:
                if ch != "l":
                    output = "{output}{ch}"
            expect(output).to_equal("heo word")

    context "squeeze":
        it "squeezes repeated characters":
            val input = "aabbcc"
            var output = ""
            var prev = ""
            for ch in input:
                if ch != prev:
                    output = "{output}{ch}"
                prev = ch
            expect(output).to_equal("abc")
