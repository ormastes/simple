# Test: strings tool
# Feature: TOOL-STRINGS - Extract printable strings
# @cover tools/shell/strings/strings_tool.spl

describe "strings tool":
    context "printable detection":
        it "identifies printable ASCII range":
            val code = 65  # 'A'
            val is_printable = code >= 32 and code < 127
            expect(is_printable).to_equal(true)

        it "rejects control characters":
            val code = 0
            val is_printable = code >= 32 and code < 127
            expect(is_printable).to_equal(false)

    context "minimum length":
        it "filters short strings":
            val s = "ab"
            val min_len = 4
            expect(s.len() < min_len).to_equal(true)

        it "keeps long enough strings":
            val s = "hello"
            val min_len = 4
            expect(s.len() >= min_len).to_equal(true)
