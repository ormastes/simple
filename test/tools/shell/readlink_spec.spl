# Test: readlink tool
# Feature: TOOL-READLINK - Resolve symlinks
# @cover tools/shell/readlink/readlink_tool.spl

describe "readlink tool":
    context "path resolution":
        it "resolves absolute path":
            val path = "/usr/bin/simple"
            expect(path).to_start_with("/")

        it "needs at least one argument":
            val args: [text] = []
            expect(args.len()).to_equal(0)
