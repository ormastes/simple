use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}
use std.gc_async_mut.gpu.browser_engine.html_string_parser.{browser_renderer_normalize_style_rules}

val WIDTH: i32 = 32
val HEIGHT: i32 = 24

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn _renders_color(style: text, body: text, color: u32) -> bool:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color) > 0

describe "WPT CSS @supports":

    context "@supports conditional rules":

        it "@supports (display: flex) applies rules":
            expect(_renders_color(
                "@supports (display: flex) { div { width: 12px; height: 8px; background-color: #0891b2; } }",
                "<div></div>",
                0xFF0891B2u32
            )).to_equal(true)

        it "@supports (nonexistent: value) does not apply":
            val rendered = _renders_color(
                "@supports (nonexistent: value) { div { width: 12px; height: 8px; background-color: #dc2626; } }",
                "<div></div>",
                0xFFDC2626u32
            )
            expect(not rendered).to_equal(true)

        it "@supports not (nonexistent: value) applies rules":
            expect(_renders_color(
                "@supports not (nonexistent: value) { div { width: 12px; height: 8px; background-color: #16a34a; } }",
                "<div></div>",
                0xFF16A34Au32
            )).to_equal(true)

        it "@supports (text-overflow: ellipsis) applies text rules":
            expect(_renders_color(
                "@supports (text-overflow: ellipsis) { div { width: 12px; height: 8px; background-color: #7c3aed; text-overflow: ellipsis; } }",
                "<div></div>",
                0xFF7C3AEDu32
            )).to_equal(true)

        it "@supports (text-transform: uppercase) applies text rules":
            expect(_renders_color(
                "@supports (text-transform: uppercase) { div { width: 12px; height: 8px; background-color: #be123c; text-transform: uppercase; } }",
                "<div></div>",
                0xFFBE123Cu32
            )).to_equal(true)

        it "@supports selector(:has()) applies supported selector rules":
            expect(_renders_color(
                "@supports selector(div:has(.badge)) { div:has(.badge) { width: 12px; height: 8px; background-color: #0e7490; } }",
                "<div><span class='badge'></span></div>",
                0xFF0E7490u32
            )).to_equal(true)

        it "@supports selector() rejects unsupported pseudo selectors":
            val rendered = _renders_color(
                "@supports selector(div:popover-open) { div { width: 12px; height: 8px; background-color: #dc2626; } }",
                "<div></div>",
                0xFFDC2626u32
            )
            expect(not rendered).to_equal(true)
