use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport,
    browser_renderer_normalize_style_rules}

val WIDTH: i32 = 80
val HEIGHT: i32 = 60

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn _renders_color(style: text, body: text, color: u32) -> bool:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color) > 0

fn _pixel_count(style: text, body: text, color: u32) -> i32:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color)

fn _has_color_at_row(style: text, body: text, color: u32, row: i32) -> bool:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    var x: i32 = 0
    while x < WIDTH:
        val idx = row * WIDTH + x
        if idx < pixels.len():
            if pixels[idx] == color:
                return true
        x = x + 1
    false

describe "WPT-derived pseudo-element and text shaping":

    context "before pseudo-element content":

        it "renders before pseudo-element content text on empty div":
            val style = "div { color: #2563eb; } div::before { content: 'Hello'; }"
            val body = "<div></div>"
            expect(_renders_color(style, body, 0xFF2563EBu32)).to_equal(true)

        it "renders before pseudo-element on empty element":
            val style = "div { color: #16a34a; } div::before { content: 'Generated'; }"
            val body = "<div></div>"
            expect(_renders_color(style, body, 0xFF16A34Au32)).to_equal(true)

    context "after pseudo-element content":

        it "renders after pseudo-element content text on empty div":
            val style = "div { color: #dc2626; } div::after { content: 'Suffix'; }"
            val body = "<div></div>"
            expect(_renders_color(style, body, 0xFFDC2626u32)).to_equal(true)

        it "renders after pseudo-element on empty element":
            val style = "div { color: #7c3aed; } div::after { content: 'Only'; }"
            val body = "<div></div>"
            expect(_renders_color(style, body, 0xFF7C3AEDu32)).to_equal(true)

        it "renders both before and after pseudo-elements on empty div":
            val style = "div { color: #0891b2; } div::before { content: 'A'; } div::after { content: 'Z'; }"
            val body = "<div></div>"
            expect(_renders_color(style, body, 0xFF0891B2u32)).to_equal(true)

    context "text-overflow ellipsis":

        it "truncates overflowing text with ellipsis":
            val trunc_style = "div { width: 40px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; color: #0f766e; font-size: 8px; }"
            val no_trunc_style = "div { width: 40px; color: #0f766e; font-size: 8px; }"
            val body = "<div>ThisIsAVeryLongWordThatOverflows</div>"
            val trunc_px = _pixel_count(trunc_style, body, 0xFF0F766Eu32)
            val no_trunc_px = _pixel_count(no_trunc_style, body, 0xFF0F766Eu32)
            expect(trunc_px).to_be_less_than(no_trunc_px)

    context "word-break and overflow-wrap":

        it "break-all wraps long word onto second line":
            val style = "div { width: 40px; word-break: break-all; color: #4338ca; font-size: 8px; }"
            val body = "<div>ABCDEFGHIJKLMNOPQRST</div>"
            val second_row = 8 + 4 + 2
            expect(_has_color_at_row(style, body, 0xFF4338CAu32, second_row)).to_equal(true)

        it "overflow-wrap break-word wraps long word onto second line":
            val style = "div { width: 40px; overflow-wrap: break-word; color: #9333ea; font-size: 8px; }"
            val body = "<div>ABCDEFGHIJKLMNOPQRST</div>"
            val second_row = 8 + 4 + 2
            expect(_has_color_at_row(style, body, 0xFF9333EAu32, second_row)).to_equal(true)
