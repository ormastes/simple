use std.spec.*

use std.gc_async_mut.gpu.browser_engine.style.animation.{
    interpolate, ease_value, interpolate_keyframes, interpolate_length,
    TimingFunction, CSSValue, CSSDeclaration, Keyframe
}
use std.gc_async_mut.gpu.browser_engine.style_block.{extract_keyframes}

fn approx(a: f64, b: f64) -> bool:
    val diff = a - b
    val abs_diff = if diff < 0.0: diff * (-1.0) else: diff
    abs_diff < 0.01

fn _interp_number_half() -> bool:
    match interpolate(CSSValue.Number(v: 0.0), CSSValue.Number(v: 1.0), 0.5):
        CSSValue.Number(v): approx(v, 0.5)
        _: false

describe "WPT-derived CSS animations subset":

    context "CSS animation pure function coverage":

        it "interpolate_length at t=0.5 returns midpoint":
            val result = interpolate_length(0.0, 100.0, 0.5)
            expect(approx(result, 50.0)).to_equal(true)

        it "ease_value linear returns identity":
            val result = ease_value(0.5, TimingFunction.Linear)
            expect(approx(result, 0.5)).to_equal(true)

        it "ease_value ease-in starts slow":
            val result = ease_value(0.5, TimingFunction.EaseIn)
            expect(result < 0.5).to_equal(true)

        it "interpolate Number values at midpoint":
            expect(_interp_number_half()).to_equal(true)

        it "extract_keyframes parses @keyframes block":
            val css = "@keyframes fade { from { opacity: 0; } to { opacity: 1; } }"
            val registry = extract_keyframes(css)
            expect(registry.entries.len() >= 1).to_equal(true)
