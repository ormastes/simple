    WEBGL_STENCIL_FAIL, WEBGL_STENCIL_PASS_DEPTH_FAIL, WEBGL_STENCIL_PASS_DEPTH_PASS,
    WEBGL_DEPTH_RANGE,
    WEBGL_DEPTH_WRITEMASK, WEBGL_STENCIL_WRITEMASK, WEBGL_STENCIL_BACK_WRITEMASK, WEBGL_COLOR_WRITEMASK,
    WEBGL_BLEND_EQUATION, WEBGL_BLEND_EQUATION_RGB, WEBGL_BLEND_EQUATION_ALPHA,
