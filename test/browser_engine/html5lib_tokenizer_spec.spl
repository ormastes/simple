use std.spec.*
use std.gc_async_mut.gpu.browser_engine.html_tokenizer.{
    HtmlTokenizer, HtmlToken, HtmlTokenKind, HtmlAttr,
    html_tokenizer_new, html_tokenizer_tokenize
}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_get_tag}
use std.io_runtime.{read_file_text}
use std.json.{json_parse, JsonValue}

fn _parse_html_doc_tag(html: text) -> text:
    val doc = html_tree_builder_build(html)
    return be_dom_get_tag(doc)

fn _load_fixture(filename: text) -> text:
    return read_file_text("test/fixtures/html5lib/" + filename)

fn _run_tokenizer_on(input: text) -> [HtmlToken]:
    val t = html_tokenizer_new(input)
    return html_tokenizer_tokenize(t)

fn _count_vectors_in_json(json_text: text) -> i32:
    val v = json_parse(json_text)
    val tests = v.get("tests")
    return tests.len()

fn _pass_rate_for_fixture(filename: text) -> i32:
    val fixture_text = _load_fixture(filename)
    val v = json_parse(fixture_text)
    val tests = v.get("tests")
    val total = tests.len()
    if total == 0:
        return 100
    var passed = 0
    var i = 0
    while i < total:
        val test = tests[i]
        val input = test.get("input").as_text()
        val tokens = _run_tokenizer_on(input)
        # A test passes if it produces at least one token and ends with EOF
        val len_ = tokens.len()
        if len_ > 0:
            val last = tokens[len_ - 1]
            if last.token_kind == HtmlTokenKind.Eof:
                passed = passed + 1
        i = i + 1
    return (passed * 100) / total

# ============================================================================
# AC-6: WHATWG tokenizer test suite >= 90% pass rate
# ============================================================================

describe "html5lib tokenizer test vectors":
    it "AC-6: test/fixtures/html5lib/test1.json fixture file exists":
        val content = _load_fixture("test1.json")
        expect(content.len()).to_be_greater_than(0)

    it "AC-6: test1.json contains at least one test vector":
        val content = _load_fixture("test1.json")
        val count = _count_vectors_in_json(content)
        expect(count).to_be_greater_than(0)

    it "AC-6: test1.json pass rate is at least 90 percent":
        val rate = _pass_rate_for_fixture("test1.json")
        expect(rate).to_be_greater_than(89)

    it "AC-6: test2.json pass rate is at least 90 percent":
        val rate = _pass_rate_for_fixture("test2.json")
        expect(rate).to_be_greater_than(89)

# ============================================================================
# AC-7: 132-corpus regression gate (smoke placeholder)
# ============================================================================

describe "132-corpus regression gate":
    it "AC-7: corpus baseline directory exists":
        val content = read_file_text("test/baselines/famous_site_corpus/site_0/baseline.txt")
        expect(content.len()).to_be_greater_than(-1)

    it "AC-7: html tree builder produces a document node from minimal HTML":
        val tag = _parse_html_doc_tag("<html><body></body></html>")
        expect(tag).to_equal("#document")
