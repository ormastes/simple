use std.spec.*
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{
    html_tree_builder_build
}
use std.gc_async_mut.gpu.browser_engine.dom.{
    BeDomNode, be_dom_get_tag_name, be_dom_get_children,
    be_dom_get_display
}
use std.gc_async_mut.gpu.browser_engine.layout.{
    LayoutContext, LayoutBox, layout_block, layout_context_new
}

fn _build_and_layout(html: text) -> LayoutBox:
    val doc = html_tree_builder_build(html)
    val ctx = layout_context_new(800, 600)
    return layout_block(doc, ctx)

fn _count_anon_blocks(box_: LayoutBox) -> i32:
    val ch = box_.children
    var count = 0
    var i = 0
    while i < ch.len():
        val child = ch[i]
        if child.is_anonymous:
            count = count + 1
        i = i + 1
    return count

fn _child_box_count(box_: LayoutBox) -> i32:
    return box_.children.len()

# ============================================================================
# AC-3: Anonymous block generation — mixed inline/block content
# ============================================================================

describe "Anonymous block generation":
    it "AC-3: wraps leading inline text before block sibling in anon block":
        val box_ = _build_and_layout("<div>text<p>block</p></div>")
        val anon_count = _count_anon_blocks(box_)
        expect(anon_count).to_be_greater_than(0)

    it "AC-3: wraps trailing inline text after block sibling in anon block":
        val box_ = _build_and_layout("<div><p>block</p>text after</div>")
        val anon_count = _count_anon_blocks(box_)
        expect(anon_count).to_be_greater_than(0)

    it "AC-3: mixed inline and block children produce at least two layout children":
        val box_ = _build_and_layout("<div>before<p>block</p>after</div>")
        val count = _child_box_count(box_)
        expect(count).to_be_greater_than(1)

    it "AC-3: block-only children produce zero anonymous blocks":
        val box_ = _build_and_layout("<div><p>a</p><p>b</p></div>")
        val anon_count = _count_anon_blocks(box_)
        expect(anon_count).to_equal(0)
