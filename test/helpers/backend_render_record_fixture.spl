use common.renderdoc.backend_render_record.{
    BackendRenderField,
    BackendRenderRecord,
    backend_render_field,
    backend_render_record_finalize
}

val BACKEND_RENDER_FIXTURE_HASH: text = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
val BACKEND_RENDER_FIXTURE_HASH_ALT: text = "abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789"

fn backend_render_fixture(
    producer_id: text,
    requested: text,
    actual: text,
    native_api: text,
    execution: text,
    translation: text,
    handle: i64,
    readback_source: text,
    pixel_hash: text,
    nonblank: i64
) -> BackendRenderRecord:
    val fields = [
        backend_render_field("commands.000.kind", "draw_rect_filled", "text", true),
        backend_render_field("commands.000.pipeline_hash", BACKEND_RENDER_FIXTURE_HASH, "sha256", true),
        backend_render_field("commands.count", "1", "i64", true),
        backend_render_field("frame.backend_handle", handle.to_text(), "i64", false),
        backend_render_field("frame.complete", "true", "bool", true),
        backend_render_field("pipelines.000.fragment_shader_hash", BACKEND_RENDER_FIXTURE_HASH, "sha256", true),
        backend_render_field("pipelines.000.pipeline_hash", BACKEND_RENDER_FIXTURE_HASH, "sha256", true),
        backend_render_field("producer.actual_backend", actual, "text", false),
        backend_render_field("producer.adapter", actual + "-adapter", "text", false),
        backend_render_field("producer.capture_log_path", "/tmp/" + producer_id + "/capture.log", "text", false),
        backend_render_field("producer.capture_path", "/tmp/" + producer_id + "/capture.rdc", "text", false),
        backend_render_field("producer.execution_kind", execution, "text", false),
        backend_render_field("producer.native_api", native_api, "text", false),
        backend_render_field("producer.requested_backend", requested, "text", false),
        backend_render_field("producer.translation_layer", translation, "text", false),
        backend_render_field("readback.content_hash", pixel_hash, "sha256", true),
        backend_render_field("readback.format", "argb-u32", "text", true),
        backend_render_field("readback.height", "4", "i64", true),
        backend_render_field("readback.nonblank_pixel_count", nonblank.to_text(), "i64", true),
        backend_render_field("readback.pixel_count", "16", "i64", true),
        backend_render_field("readback.source", readback_source, "text", true),
        backend_render_field("readback.stride", "16", "i64", true),
        backend_render_field("readback.width", "4", "i64", true),
        backend_render_field("resources.000.content_hash", BACKEND_RENDER_FIXTURE_HASH, "sha256", true),
        backend_render_field("resources.000.kind", "framebuffer", "text", true),
        backend_render_field("target.content_hash", pixel_hash, "sha256", true),
        backend_render_field("target.format", "argb-u32", "text", true),
        backend_render_field("target.height", "4", "i64", true),
        backend_render_field("target.stride", "16", "i64", true),
        backend_render_field("target.width", "4", "i64", true),
        backend_render_field("transitions.000.after", "present", "text", true),
        backend_render_field("transitions.000.before", "color-attachment", "text", true)
    ]
    backend_render_record_finalize(producer_id, fields)

fn backend_render_fixture_replace(record: BackendRenderRecord, path: text, value: text) -> BackendRenderRecord:
    var fields: [BackendRenderField] = []
    for field in record.fields:
        if field.path == path:
            fields = fields.push(backend_render_field(field.path, value, field.value_kind, field.semantic))
        else:
            fields = fields.push(field)
    backend_render_record_finalize(record.producer_id, fields)

