class FontPerfRssEvidence:
    legacy_2d_kb: i64
    multiface_2d_kb: i64
    legacy_3d_kb: i64
    multiface_3d_kb: i64
    available: bool
    reason: text

class FontPerfBudgetEvidence:
    status: text
    reason: text
    warm_1080_p95_ns: i64
    warm_4k_p95_ns: i64
    cpu_4096_p95_ns: i64
    gpu_4096_p95_ns: i64
    warm_hits: i64
    warm_requests: i64
    unchanged_upload: bool
    rss_growth_percent: i64
    gpu_resource_high_water_bytes: i64
    rss_available: bool
    legacy_2d_kb: i64
    multiface_2d_kb: i64
    legacy_3d_kb: i64
    multiface_3d_kb: i64
    gpu_device_name: text
    gpu_driver_identity: text
    warm_1080_samples_ns: [i64]
    warm_4k_samples_ns: [i64]
    cpu_4096_samples_ns: [i64]
    gpu_4096_samples_ns: [i64]
    device_loss_status: text
    device_loss_batch_identity_before: text
    device_loss_batch_identity_after: text
    cpu_after_device_loss_p95_ns: i64
    cpu_after_device_loss_samples_ns: [i64]
    stage_shaping_p95_ns: i64 = 0
    stage_material_p95_ns: i64 = 0
    stage_emission_compile_ns: i64 = 0
    stage_dirty_upload_p95_ns: i64 = 0
    stage_queue_device_p95_ns: i64 = 0
    stage_sync_p95_ns: i64 = 0
    stage_present_readback_p95_ns: i64 = 0
    stage_cpu_oracle_p95_ns: i64 = 0
    stage_shaping_samples_ns: [i64] = []
    stage_material_samples_ns: [i64] = []
    stage_dirty_upload_samples_ns: [i64] = []
    stage_queue_device_samples_ns: [i64] = []
    stage_sync_samples_ns: [i64] = []
    stage_present_readback_samples_ns: [i64] = []
    stage_cpu_oracle_samples_ns: [i64] = []
    promotion_artifact_identity: text = ""
    promotion_entry_name: text = ""
    promotion_program_version: i64 = 0
    promotion_batch_identity: text = ""
    promotion_atlas_payload_sha256: text = ""
    promotion_shader_handle: i64 = 0
    promotion_pipeline_handle: i64 = 0
    promotion_atlas_buffer_handle: i64 = 0
    promotion_params_buffer_handle: i64 = 0
    promotion_command_handle: i64 = 0
    promotion_fence_handle: i64 = 0
    promotion_readback_buffer_handle: i64 = 0
    promotion_quad_count: i64 = 0
    promotion_dispatch_count: i64 = 0
    promotion_submitted: bool = false
    promotion_completion_waited: bool = false
    promotion_fence_evidence_available: bool = false
    promotion_fence_destroyed: bool = false
    promotion_readback_source: text = ""
    promotion_readback_byte_count: i64 = 0
    promotion_readback_nonblank_pixels: i64 = 0
    promotion_device_checksum: i64 = 0
    promotion_oracle_checksum: i64 = 0
    promotion_parity: bool = false
    promotion_device_executed: bool = false
    promotion_ready: bool = false
    promotion_present_mode: text = ""

fn unavailable_font_perf_evidence(reason: text) -> FontPerfBudgetEvidence:
    FontPerfBudgetEvidence(
        status: "unavailable", reason: reason,
        warm_1080_p95_ns: 0, warm_4k_p95_ns: 0,
        cpu_4096_p95_ns: 0, gpu_4096_p95_ns: 0,
        warm_hits: 0, warm_requests: 0, unchanged_upload: false,
        rss_growth_percent: 0, gpu_resource_high_water_bytes: 0,
        rss_available: false,
        legacy_2d_kb: 0, multiface_2d_kb: 0,
        legacy_3d_kb: 0, multiface_3d_kb: 0,
        gpu_device_name: "", gpu_driver_identity: "",
        warm_1080_samples_ns: [], warm_4k_samples_ns: [],
        cpu_4096_samples_ns: [], gpu_4096_samples_ns: [],
        device_loss_status: "unavailable",
        device_loss_batch_identity_before: "",
        device_loss_batch_identity_after: "",
        cpu_after_device_loss_p95_ns: 0,
        cpu_after_device_loss_samples_ns: [])

fn _samples_text(values: [i64]) -> text:
    var out = ""
    var i: i64 = 0
    while i < values.len():
        if i > 0: out = out + ","
        out = out + values[i].to_text()
        i = i + 1
    out

fn font_perf_samples_text(values: [i64]) -> text:
    _samples_text(values)

fn _parse_samples(value: text) -> [i64]:
    if value == "": return []
    val parts = value.split(",")
    var samples: [i64] = []
    for part in parts:
        val parsed = part.to_i64() ?? -1
        if parsed <= 0: return []
        samples.push(parsed)
    samples

fn _parse_stage_samples(value: text) -> [i64]:
    if value == "": return []
    val parts = value.split(",")
    var samples: [i64] = []
    for part in parts:
        val parsed = part.to_i64() ?? -1
        if parsed < 0: return []
        samples.push(parsed)
    samples

fn _valid_samples_text(value: text) -> bool:
    if value == "": return true
    val parts = value.split(",")
    if parts.len() > FONT_PERF_SAMPLE_COUNT: return false
    for part in parts:
        if (part.to_i64() ?? -1) <= 0: return false
    true

fn _valid_stage_samples_text(value: text) -> bool:
    if value == "": return true
    val parts = value.split(",")
    if parts.len() > FONT_PERF_SAMPLE_COUNT: return false
    for part in parts:
        if (part.to_i64() ?? -1) < 0: return false
    true

fn _valid_nonnegative_samples(samples: [i64]) -> bool:
    for sample in samples:
        if sample < 0: return false
    true

fn _valid_sha256(value: text) -> bool:
    value.len() == 64

fn _valid_precompiled_spirv_identity(value: text) -> bool:
    val prefix = "precompiled-spirv:"
    value.starts_with(prefix) and _valid_sha256(value.substring(prefix.len(), value.len()))

fn _safe_record_text(value: text) -> bool:
    not value.contains("\n") and not value.contains("\r")

fn _valid_status(status: text) -> bool:
    status == "pass" or status == "failed" or status == "unavailable"

fn font_perf_p95(values: [i64]) -> i64:
    if values.len() == 0: return 0
    var sorted = values.clone()
    sorted.sort()
    var index = sorted.len() * 95 / 100
    if index >= sorted.len(): index = sorted.len() - 1
    sorted[index]

fn font_perf_rss_growth_percent(baseline_kb: i64, multiface_kb: i64) -> i64:
    if baseline_kb <= 0 or multiface_kb <= baseline_kb: return 0
    val growth_kb = multiface_kb - baseline_kb
    (growth_kb * 100 + baseline_kb - 1) / baseline_kb

fn _paired_rss_growth_percent(evidence: FontPerfBudgetEvidence) -> i64:
    val growth_2d = font_perf_rss_growth_percent(evidence.legacy_2d_kb, evidence.multiface_2d_kb)
    val growth_3d = font_perf_rss_growth_percent(evidence.legacy_3d_kb, evidence.multiface_3d_kb)
    if growth_2d > growth_3d: growth_2d else: growth_3d

fn _valid_paired_rss(evidence: FontPerfBudgetEvidence) -> bool:
    if evidence.legacy_2d_kb < 0 or evidence.legacy_2d_kb > 1000000000 or
        evidence.multiface_2d_kb < 0 or evidence.multiface_2d_kb > 1000000000 or
        evidence.legacy_3d_kb < 0 or evidence.legacy_3d_kb > 1000000000 or
        evidence.multiface_3d_kb < 0 or evidence.multiface_3d_kb > 1000000000:
        return false
    if not evidence.rss_available:
        return evidence.legacy_2d_kb == 0 and evidence.multiface_2d_kb == 0 and
            evidence.legacy_3d_kb == 0 and evidence.multiface_3d_kb == 0 and
            evidence.rss_growth_percent == 0
    evidence.legacy_2d_kb > 0 and evidence.multiface_2d_kb > 0 and
        evidence.legacy_3d_kb > 0 and evidence.multiface_3d_kb > 0 and
        evidence.rss_growth_percent == _paired_rss_growth_percent(evidence)

fn _valid_shape(evidence: FontPerfBudgetEvidence) -> bool:
    if not _valid_status(evidence.status) or evidence.reason == "": return false
    if (not _safe_record_text(evidence.reason) or not _safe_record_text(evidence.gpu_device_name) or
        not _safe_record_text(evidence.gpu_driver_identity) or not _safe_record_text(evidence.device_loss_status) or
        not _safe_record_text(evidence.device_loss_batch_identity_before) or
        not _safe_record_text(evidence.device_loss_batch_identity_after) or
        not _safe_record_text(evidence.promotion_artifact_identity) or
        not _safe_record_text(evidence.promotion_entry_name) or
        not _safe_record_text(evidence.promotion_batch_identity) or
        not _safe_record_text(evidence.promotion_atlas_payload_sha256) or
        not _safe_record_text(evidence.promotion_readback_source) or
        not _safe_record_text(evidence.promotion_present_mode)):
        return false
    if evidence.warm_1080_p95_ns < 0 or evidence.warm_1080_p95_ns > 1000000000000 or evidence.warm_4k_p95_ns < 0 or evidence.warm_4k_p95_ns > 1000000000000: return false
    if evidence.cpu_4096_p95_ns < 0 or evidence.cpu_4096_p95_ns > 1000000000000 or evidence.gpu_4096_p95_ns < 0 or evidence.gpu_4096_p95_ns > 1000000000000: return false
    if evidence.cpu_after_device_loss_p95_ns < 0 or evidence.cpu_after_device_loss_p95_ns > 1000000000000: return false
    if (evidence.stage_shaping_p95_ns < 0 or evidence.stage_shaping_p95_ns > 1000000000000 or
        evidence.stage_material_p95_ns < 0 or evidence.stage_material_p95_ns > 1000000000000 or
        evidence.stage_emission_compile_ns < 0 or evidence.stage_emission_compile_ns > 1000000000000 or
        evidence.stage_dirty_upload_p95_ns < 0 or evidence.stage_dirty_upload_p95_ns > 1000000000000 or
        evidence.stage_queue_device_p95_ns < 0 or evidence.stage_queue_device_p95_ns > 1000000000000 or
        evidence.stage_sync_p95_ns < 0 or evidence.stage_sync_p95_ns > 1000000000000 or
        evidence.stage_present_readback_p95_ns < 0 or evidence.stage_present_readback_p95_ns > 1000000000000 or
        evidence.stage_cpu_oracle_p95_ns < 0 or evidence.stage_cpu_oracle_p95_ns > 1000000000000):
        return false
    if evidence.warm_hits < 0 or evidence.warm_requests < 0 or evidence.rss_growth_percent < 0 or evidence.gpu_resource_high_water_bytes < 0: return false
    if not _valid_paired_rss(evidence): return false
    if evidence.warm_hits > evidence.warm_requests: return false
    if evidence.warm_1080_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or evidence.warm_4k_samples_ns.len() > FONT_PERF_SAMPLE_COUNT: return false
    if evidence.cpu_4096_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or evidence.gpu_4096_samples_ns.len() > FONT_PERF_SAMPLE_COUNT: return false
    if evidence.cpu_after_device_loss_samples_ns.len() > FONT_PERF_SAMPLE_COUNT: return false
    if (evidence.stage_shaping_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or
        evidence.stage_material_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or
        evidence.stage_dirty_upload_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or
        evidence.stage_queue_device_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or
        evidence.stage_sync_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or
        evidence.stage_present_readback_samples_ns.len() > FONT_PERF_SAMPLE_COUNT or
        evidence.stage_cpu_oracle_samples_ns.len() > FONT_PERF_SAMPLE_COUNT):
        return false
    if (not _valid_nonnegative_samples(evidence.stage_shaping_samples_ns) or
        not _valid_nonnegative_samples(evidence.stage_material_samples_ns) or
        not _valid_nonnegative_samples(evidence.stage_dirty_upload_samples_ns) or
        not _valid_nonnegative_samples(evidence.stage_queue_device_samples_ns) or
        not _valid_nonnegative_samples(evidence.stage_sync_samples_ns) or
        not _valid_nonnegative_samples(evidence.stage_present_readback_samples_ns) or
        not _valid_nonnegative_samples(evidence.stage_cpu_oracle_samples_ns)):
        return false
    if evidence.status == "pass":
        return (evidence.warm_1080_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.warm_4k_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.cpu_4096_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.gpu_4096_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.cpu_after_device_loss_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_shaping_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_material_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_dirty_upload_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_queue_device_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_sync_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_present_readback_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.stage_cpu_oracle_samples_ns.len() == FONT_PERF_SAMPLE_COUNT and
            evidence.warm_1080_p95_ns == font_perf_p95(evidence.warm_1080_samples_ns) and
            evidence.warm_4k_p95_ns == font_perf_p95(evidence.warm_4k_samples_ns) and
            evidence.cpu_4096_p95_ns == font_perf_p95(evidence.cpu_4096_samples_ns) and
            evidence.gpu_4096_p95_ns == font_perf_p95(evidence.gpu_4096_samples_ns) and
            evidence.cpu_after_device_loss_p95_ns == font_perf_p95(evidence.cpu_after_device_loss_samples_ns) and
            evidence.stage_shaping_p95_ns == font_perf_p95(evidence.stage_shaping_samples_ns) and
            evidence.stage_material_p95_ns == font_perf_p95(evidence.stage_material_samples_ns) and
            evidence.stage_dirty_upload_p95_ns == font_perf_p95(evidence.stage_dirty_upload_samples_ns) and
            evidence.stage_queue_device_p95_ns == font_perf_p95(evidence.stage_queue_device_samples_ns) and
            evidence.stage_sync_p95_ns == font_perf_p95(evidence.stage_sync_samples_ns) and
            evidence.stage_present_readback_p95_ns == font_perf_p95(evidence.stage_present_readback_samples_ns) and
            evidence.stage_cpu_oracle_p95_ns == font_perf_p95(evidence.stage_cpu_oracle_samples_ns))
    true

fn expect_font_perf_budget(evidence: FontPerfBudgetEvidence) -> bool:
    _valid_shape(evidence) and evidence.status == "pass" and
        evidence.warm_requests == 22528 and evidence.warm_hits * 100 >= evidence.warm_requests * 95 and
        evidence.warm_1080_p95_ns <= 4000000 and evidence.warm_4k_p95_ns <= 8000000 and
        evidence.gpu_4096_p95_ns > 0 and evidence.cpu_4096_p95_ns * 100 >= evidence.gpu_4096_p95_ns * 125 and
        evidence.unchanged_upload and evidence.rss_available and
        evidence.rss_growth_percent == _paired_rss_growth_percent(evidence) and evidence.rss_growth_percent <= 10 and
        evidence.gpu_device_name != "" and evidence.gpu_driver_identity != "" and
        evidence.device_loss_status == "controlled-poison-cpu-fallback" and
        evidence.device_loss_batch_identity_before != "" and
        evidence.device_loss_batch_identity_after == evidence.device_loss_batch_identity_before and
        evidence.cpu_after_device_loss_p95_ns > 0 and
        evidence.cpu_after_device_loss_p95_ns <= evidence.cpu_4096_p95_ns and
        evidence.stage_shaping_p95_ns > 0 and evidence.stage_material_p95_ns > 0 and
        evidence.stage_emission_compile_ns > 0 and evidence.stage_dirty_upload_p95_ns == 0 and
        evidence.stage_queue_device_p95_ns > 0 and evidence.stage_sync_p95_ns > 0 and
        evidence.stage_present_readback_p95_ns > 0 and evidence.stage_cpu_oracle_p95_ns > 0 and
        _valid_precompiled_spirv_identity(evidence.promotion_artifact_identity) and
        evidence.promotion_entry_name == "main" and evidence.promotion_program_version == 1 and
        evidence.promotion_batch_identity != "" and _valid_sha256(evidence.promotion_atlas_payload_sha256) and
        evidence.promotion_shader_handle > 0 and evidence.promotion_pipeline_handle > 0 and
        evidence.promotion_atlas_buffer_handle > 0 and evidence.promotion_params_buffer_handle > 0 and
        evidence.promotion_command_handle > 0 and evidence.promotion_fence_handle > 0 and
        evidence.promotion_readback_buffer_handle > 0 and evidence.promotion_quad_count > 0 and
        evidence.promotion_dispatch_count == evidence.promotion_quad_count and
        evidence.promotion_submitted and evidence.promotion_completion_waited and
        evidence.promotion_fence_evidence_available and evidence.promotion_fence_destroyed and
        evidence.promotion_readback_source == "device_readback" and
        evidence.promotion_readback_byte_count == 1920 * 1080 * 4 and
        evidence.promotion_readback_nonblank_pixels > 0 and
        evidence.promotion_readback_nonblank_pixels <= 1920 * 1080 and
        evidence.promotion_device_checksum != 0 and
        evidence.promotion_device_checksum == evidence.promotion_oracle_checksum and
        evidence.promotion_parity and evidence.promotion_device_executed and evidence.promotion_ready and
        evidence.promotion_present_mode == "not-applicable-offscreen" and
        evidence.gpu_resource_high_water_bytes > 0 and evidence.gpu_resource_high_water_bytes <= 134217728

fn _font_perf_implementation_sha256() -> text:
    val paths = [
        "src/lib/gc_async_mut/gpu/engine2d/engine.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_font.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_font_types.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_session.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_session_runtime_ops.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_helpers.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_glsl.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_spirv.spl",
        "src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_spirv_raster_blobs.spl",
        "src/lib/gc_async_mut/gpu/engine3d/engine.spl",
        "src/lib/gc_async_mut/gpu/engine3d/vulkan_font_adapter.spl",
        "src/lib/nogc_sync_mut/text_layout/font_renderer.spl",
        "src/lib/nogc_sync_mut/text_layout/font_rasterizer.spl",
        "src/lib/nogc_sync_mut/io/font_sffi.spl",
        "src/lib/skia/feature/shaper/shaper.spl",
        "src/lib/skia/feature/shaper/font_fallback.spl",
        "src/lib/skia/feature/shaper/selected_devanagari.spl",
        "src/lib/skia/feature/shaper/selected_arabic.spl",
        FONT_PERF_RSS_PROBE_PATH,
    ]
    var material = ""
    for path in paths:
        val digest = file_hash_sha256(path)
        if digest.len() != 64: return ""
        material = material + path.len().to_text() + ":" + path + ":" + digest
    sha256_text(material)

fn _font_perf_face_manifest_sha256() -> text:
    val material = FONT_PERF_FACE_SC_PATH + ":" + file_hash_sha256(FONT_PERF_FACE_SC_PATH) +
        "|" + FONT_PERF_FACE_DEVANAGARI_PATH + ":" + file_hash_sha256(FONT_PERF_FACE_DEVANAGARI_PATH) +
        "|" + FONT_PERF_FACE_ARABIC_PATH + ":" + file_hash_sha256(FONT_PERF_FACE_ARABIC_PATH)
    sha256_text(material)

fn font_perf_evidence_record(evidence: FontPerfBudgetEvidence) -> text:
    if not _valid_shape(evidence): return ""
    val sc_sha = file_hash_sha256(FONT_PERF_FACE_SC_PATH)
    val devanagari_sha = file_hash_sha256(FONT_PERF_FACE_DEVANAGARI_PATH)
    val arabic_sha = file_hash_sha256(FONT_PERF_FACE_ARABIC_PATH)
    val font_sha = _font_perf_face_manifest_sha256()
    val collector_sha = file_hash_sha256(FONT_PERF_COLLECTOR_PATH)
    val helper_sha = file_hash_sha256(FONT_PERF_HELPER_PATH)
    val implementation_sha = _font_perf_implementation_sha256()
    val evidence_host_os = host_os()
    val evidence_host_arch = host_arch()
    if sc_sha != FONT_PERF_FACE_SC_SHA256 or devanagari_sha != FONT_PERF_FACE_DEVANAGARI_SHA256 or arabic_sha != FONT_PERF_FACE_ARABIC_SHA256 or font_sha.len() != 64 or collector_sha.len() != 64 or helper_sha.len() != 64 or implementation_sha.len() != 64 or evidence_host_os == "" or evidence_host_arch == "": return ""
    val rss_comparison = if evidence.rss_available: "paired-2d-3d-legacy" else: "unavailable"
    val base = "schema=shared-multilingual-gpu-font-perf/v5\nfixture=top-10-language-witnesses\nwitness_mapping={FONT_PERF_WITNESS_MAPPING}\nface_mapping={FONT_PERF_FACE_MAPPING}\nrepresentative_codepoints={FONT_PERF_CODEPOINTS}\nglyphs_1080=1024\nglyphs_4k=1024\nglyphs_compare=4096\nsample_count=11\nwarm_backend=vulkan\nviewport_1080=1920x1080\nviewport_4k=3840x2160\ncompare_viewport=1920x1080\ncolor_space=srgb-byte-domain-no-linearization\npixel_format=argb8888-packed-u32\nalpha_mode=straight-argb-src-over-opaque-destination\nrounding=mask-alpha-nearest-blend-floor\nwarmup_frames_per_route=1\npercentile_method=sorted-index-floor-n-times-95-over-100\ncomparator=exact-packed-argb-u32-cpu-oracle\nhost_os={evidence_host_os}\nhost_arch={evidence_host_arch}\nfont_path_0={FONT_PERF_FACE_SC_PATH}\nfont_sha256_0={sc_sha}\nfont_path_1={FONT_PERF_FACE_DEVANAGARI_PATH}\nfont_sha256_1={devanagari_sha}\nfont_path_2={FONT_PERF_FACE_ARABIC_PATH}\nfont_sha256_2={arabic_sha}\nfont_sha256={font_sha}\ncollector_path={FONT_PERF_COLLECTOR_PATH}\ncollector_sha256={collector_sha}\nhelper_path={FONT_PERF_HELPER_PATH}\nhelper_sha256={helper_sha}\nimplementation_sha256={implementation_sha}\nstatus={evidence.status}\nreason={evidence.reason}\nwarm_1080_p95_ns={evidence.warm_1080_p95_ns}\nwarm_4k_p95_ns={evidence.warm_4k_p95_ns}\ncpu_4096_p95_ns={evidence.cpu_4096_p95_ns}\ngpu_4096_p95_ns={evidence.gpu_4096_p95_ns}\nwarm_hits={evidence.warm_hits}\nwarm_requests={evidence.warm_requests}\nunchanged_upload={evidence.unchanged_upload}\nrss_growth_percent={evidence.rss_growth_percent}\ngpu_resource_high_water_bytes={evidence.gpu_resource_high_water_bytes}\nrss_available={evidence.rss_available}\nlegacy_2d_kb={evidence.legacy_2d_kb}\nmultiface_2d_kb={evidence.multiface_2d_kb}\nlegacy_3d_kb={evidence.legacy_3d_kb}\nmultiface_3d_kb={evidence.multiface_3d_kb}\nrss_comparison={rss_comparison}\ngpu_device_name={evidence.gpu_device_name}\ngpu_driver_identity={evidence.gpu_driver_identity}\nwarm_1080_samples_ns={_samples_text(evidence.warm_1080_samples_ns)}\nwarm_4k_samples_ns={_samples_text(evidence.warm_4k_samples_ns)}\ncpu_4096_samples_ns={_samples_text(evidence.cpu_4096_samples_ns)}\ngpu_4096_samples_ns={_samples_text(evidence.gpu_4096_samples_ns)}"
    val recovery = "\ndevice_loss_status={evidence.device_loss_status}\ndevice_loss_batch_identity_before={evidence.device_loss_batch_identity_before}\ndevice_loss_batch_identity_after={evidence.device_loss_batch_identity_after}\ncpu_after_device_loss_p95_ns={evidence.cpu_after_device_loss_p95_ns}\ncpu_after_device_loss_samples_ns={_samples_text(evidence.cpu_after_device_loss_samples_ns)}"
    val stages = "\nstage_shaping_p95_ns={evidence.stage_shaping_p95_ns}\nstage_material_p95_ns={evidence.stage_material_p95_ns}\nstage_emission_compile_ns={evidence.stage_emission_compile_ns}\nstage_dirty_upload_p95_ns={evidence.stage_dirty_upload_p95_ns}\nstage_queue_device_p95_ns={evidence.stage_queue_device_p95_ns}\nstage_sync_p95_ns={evidence.stage_sync_p95_ns}\nstage_present_readback_p95_ns={evidence.stage_present_readback_p95_ns}\nstage_cpu_oracle_p95_ns={evidence.stage_cpu_oracle_p95_ns}\nstage_shaping_samples_ns={_samples_text(evidence.stage_shaping_samples_ns)}\nstage_material_samples_ns={_samples_text(evidence.stage_material_samples_ns)}\nstage_dirty_upload_samples_ns={_samples_text(evidence.stage_dirty_upload_samples_ns)}\nstage_queue_device_samples_ns={_samples_text(evidence.stage_queue_device_samples_ns)}\nstage_sync_samples_ns={_samples_text(evidence.stage_sync_samples_ns)}\nstage_present_readback_samples_ns={_samples_text(evidence.stage_present_readback_samples_ns)}\nstage_cpu_oracle_samples_ns={_samples_text(evidence.stage_cpu_oracle_samples_ns)}"
    val promotion = "\npromotion_artifact_identity={evidence.promotion_artifact_identity}\npromotion_entry_name={evidence.promotion_entry_name}\npromotion_program_version={evidence.promotion_program_version}\npromotion_batch_identity={evidence.promotion_batch_identity}\npromotion_atlas_payload_sha256={evidence.promotion_atlas_payload_sha256}\npromotion_shader_handle={evidence.promotion_shader_handle}\npromotion_pipeline_handle={evidence.promotion_pipeline_handle}\npromotion_atlas_buffer_handle={evidence.promotion_atlas_buffer_handle}\npromotion_params_buffer_handle={evidence.promotion_params_buffer_handle}\npromotion_command_handle={evidence.promotion_command_handle}\npromotion_fence_handle={evidence.promotion_fence_handle}\npromotion_readback_buffer_handle={evidence.promotion_readback_buffer_handle}\npromotion_quad_count={evidence.promotion_quad_count}\npromotion_dispatch_count={evidence.promotion_dispatch_count}\npromotion_submitted={evidence.promotion_submitted}\npromotion_completion_waited={evidence.promotion_completion_waited}\npromotion_fence_evidence_available={evidence.promotion_fence_evidence_available}\npromotion_fence_destroyed={evidence.promotion_fence_destroyed}\npromotion_readback_source={evidence.promotion_readback_source}\npromotion_readback_byte_count={evidence.promotion_readback_byte_count}\npromotion_readback_nonblank_pixels={evidence.promotion_readback_nonblank_pixels}\npromotion_device_checksum={evidence.promotion_device_checksum}\npromotion_oracle_checksum={evidence.promotion_oracle_checksum}\npromotion_parity={evidence.promotion_parity}\npromotion_device_executed={evidence.promotion_device_executed}\npromotion_ready={evidence.promotion_ready}\npromotion_present_mode={evidence.promotion_present_mode}"
    base + recovery + stages + promotion

fn _line_value(lines: [text], index: i64, key: text) -> text:
    val prefix = key + "="
    if index < 0 or index >= lines.len() or not lines[index].starts_with(prefix): return ""
    lines[index].substring(prefix.len(), lines[index].len())

fn parse_font_perf_evidence(record: text) -> FontPerfBudgetEvidence:
    val lines = record.split("\n")
    if lines.len() != 104: return unavailable_font_perf_evidence("durable performance record is malformed")
    if _line_value(lines, 0, "schema") != "shared-multilingual-gpu-font-perf/v5" or _line_value(lines, 1, "fixture") != "top-10-language-witnesses": return unavailable_font_perf_evidence("durable performance schema or fixture mismatch")
    if _line_value(lines, 2, "witness_mapping") != FONT_PERF_WITNESS_MAPPING or _line_value(lines, 3, "face_mapping") != FONT_PERF_FACE_MAPPING or _line_value(lines, 4, "representative_codepoints") != FONT_PERF_CODEPOINTS: return unavailable_font_perf_evidence("durable performance witness mapping mismatch")
    if _line_value(lines, 5, "glyphs_1080") != "1024" or _line_value(lines, 6, "glyphs_4k") != "1024" or _line_value(lines, 7, "glyphs_compare") != "4096" or _line_value(lines, 8, "sample_count") != "11" or _line_value(lines, 9, "warm_backend") != "vulkan": return unavailable_font_perf_evidence("durable performance dimensions or backend mismatch")
    if (_line_value(lines, 10, "viewport_1080") != "1920x1080" or
        _line_value(lines, 11, "viewport_4k") != "3840x2160" or
        _line_value(lines, 12, "compare_viewport") != "1920x1080" or
        _line_value(lines, 13, "color_space") != "srgb-byte-domain-no-linearization" or
        _line_value(lines, 14, "pixel_format") != "argb8888-packed-u32" or
        _line_value(lines, 15, "alpha_mode") != "straight-argb-src-over-opaque-destination" or
        _line_value(lines, 16, "rounding") != "mask-alpha-nearest-blend-floor" or
        _line_value(lines, 17, "warmup_frames_per_route") != "1" or
        _line_value(lines, 18, "percentile_method") != "sorted-index-floor-n-times-95-over-100" or
        _line_value(lines, 19, "comparator") != "exact-packed-argb-u32-cpu-oracle" or
        _line_value(lines, 20, "host_os") != host_os() or
        _line_value(lines, 21, "host_arch") != host_arch()):
        return unavailable_font_perf_evidence("durable performance run metadata mismatch")
    if _line_value(lines, 22, "font_path_0") != FONT_PERF_FACE_SC_PATH or _line_value(lines, 23, "font_sha256_0") != FONT_PERF_FACE_SC_SHA256 or file_hash_sha256(FONT_PERF_FACE_SC_PATH) != FONT_PERF_FACE_SC_SHA256: return unavailable_font_perf_evidence("durable performance SC face mismatch")
    if _line_value(lines, 24, "font_path_1") != FONT_PERF_FACE_DEVANAGARI_PATH or _line_value(lines, 25, "font_sha256_1") != FONT_PERF_FACE_DEVANAGARI_SHA256 or file_hash_sha256(FONT_PERF_FACE_DEVANAGARI_PATH) != FONT_PERF_FACE_DEVANAGARI_SHA256: return unavailable_font_perf_evidence("durable performance Devanagari face mismatch")
    if _line_value(lines, 26, "font_path_2") != FONT_PERF_FACE_ARABIC_PATH or _line_value(lines, 27, "font_sha256_2") != FONT_PERF_FACE_ARABIC_SHA256 or file_hash_sha256(FONT_PERF_FACE_ARABIC_PATH) != FONT_PERF_FACE_ARABIC_SHA256: return unavailable_font_perf_evidence("durable performance Arabic face mismatch")
    if _line_value(lines, 28, "font_sha256") != _font_perf_face_manifest_sha256(): return unavailable_font_perf_evidence("durable performance face manifest mismatch")
    if _line_value(lines, 29, "collector_path") != FONT_PERF_COLLECTOR_PATH or _line_value(lines, 30, "collector_sha256") != file_hash_sha256(FONT_PERF_COLLECTOR_PATH): return unavailable_font_perf_evidence("durable performance collector is stale")
    if _line_value(lines, 31, "helper_path") != FONT_PERF_HELPER_PATH or _line_value(lines, 32, "helper_sha256") != file_hash_sha256(FONT_PERF_HELPER_PATH): return unavailable_font_perf_evidence("durable performance schema implementation is stale")
    if _line_value(lines, 33, "implementation_sha256") != _font_perf_implementation_sha256(): return unavailable_font_perf_evidence("durable performance implementation is stale")
    val unchanged_text = _line_value(lines, 42, "unchanged_upload")
    val rss_available_text = _line_value(lines, 45, "rss_available")
    val rss_comparison = _line_value(lines, 50, "rss_comparison")
    if (unchanged_text != "true" and unchanged_text != "false") or (rss_available_text != "true" and rss_available_text != "false"): return unavailable_font_perf_evidence("durable performance boolean is malformed")
    if (rss_available_text == "true" and rss_comparison != "paired-2d-3d-legacy") or (rss_available_text == "false" and rss_comparison != "unavailable"): return unavailable_font_perf_evidence("durable performance RSS comparison mismatch")
    if (not _valid_samples_text(_line_value(lines, 53, "warm_1080_samples_ns")) or
        not _valid_samples_text(_line_value(lines, 54, "warm_4k_samples_ns")) or
        not _valid_samples_text(_line_value(lines, 55, "cpu_4096_samples_ns")) or
        not _valid_samples_text(_line_value(lines, 56, "gpu_4096_samples_ns")) or
        not _valid_samples_text(_line_value(lines, 61, "cpu_after_device_loss_samples_ns"))):
        return unavailable_font_perf_evidence("durable performance samples are malformed")
    if (not _valid_stage_samples_text(_line_value(lines, 70, "stage_shaping_samples_ns")) or
        not _valid_stage_samples_text(_line_value(lines, 71, "stage_material_samples_ns")) or
        not _valid_stage_samples_text(_line_value(lines, 72, "stage_dirty_upload_samples_ns")) or
        not _valid_stage_samples_text(_line_value(lines, 73, "stage_queue_device_samples_ns")) or
        not _valid_stage_samples_text(_line_value(lines, 74, "stage_sync_samples_ns")) or
        not _valid_stage_samples_text(_line_value(lines, 75, "stage_present_readback_samples_ns")) or
        not _valid_stage_samples_text(_line_value(lines, 76, "stage_cpu_oracle_samples_ns"))):
        return unavailable_font_perf_evidence("durable performance stage samples are malformed")
    val promotion_submitted_text = _line_value(lines, 91, "promotion_submitted")
    val promotion_completion_waited_text = _line_value(lines, 92, "promotion_completion_waited")
    val promotion_fence_available_text = _line_value(lines, 93, "promotion_fence_evidence_available")
    val promotion_fence_destroyed_text = _line_value(lines, 94, "promotion_fence_destroyed")
    val promotion_parity_text = _line_value(lines, 100, "promotion_parity")
    val promotion_device_executed_text = _line_value(lines, 101, "promotion_device_executed")
    val promotion_ready_text = _line_value(lines, 102, "promotion_ready")
    if ((promotion_submitted_text != "true" and promotion_submitted_text != "false") or
        (promotion_completion_waited_text != "true" and promotion_completion_waited_text != "false") or
        (promotion_fence_available_text != "true" and promotion_fence_available_text != "false") or
        (promotion_fence_destroyed_text != "true" and promotion_fence_destroyed_text != "false") or
        (promotion_parity_text != "true" and promotion_parity_text != "false") or
        (promotion_device_executed_text != "true" and promotion_device_executed_text != "false") or
        (promotion_ready_text != "true" and promotion_ready_text != "false")):
        return unavailable_font_perf_evidence("durable performance promotion boolean is malformed")
    if _line_value(lines, 98, "promotion_device_checksum").to_i64() == nil or
        _line_value(lines, 99, "promotion_oracle_checksum").to_i64() == nil:
        return unavailable_font_perf_evidence("durable performance promotion checksum is malformed")
    val evidence = FontPerfBudgetEvidence(
        status: _line_value(lines, 34, "status"), reason: _line_value(lines, 35, "reason"),
        warm_1080_p95_ns: _line_value(lines, 36, "warm_1080_p95_ns").to_i64() ?? -1,
        warm_4k_p95_ns: _line_value(lines, 37, "warm_4k_p95_ns").to_i64() ?? -1,
        cpu_4096_p95_ns: _line_value(lines, 38, "cpu_4096_p95_ns").to_i64() ?? -1,
        gpu_4096_p95_ns: _line_value(lines, 39, "gpu_4096_p95_ns").to_i64() ?? -1,
        warm_hits: _line_value(lines, 40, "warm_hits").to_i64() ?? -1,
        warm_requests: _line_value(lines, 41, "warm_requests").to_i64() ?? -1,
        unchanged_upload: unchanged_text == "true",
        rss_growth_percent: _line_value(lines, 43, "rss_growth_percent").to_i64() ?? -1,
        gpu_resource_high_water_bytes: _line_value(lines, 44, "gpu_resource_high_water_bytes").to_i64() ?? -1,
        rss_available: rss_available_text == "true",
        legacy_2d_kb: _line_value(lines, 46, "legacy_2d_kb").to_i64() ?? -1,
        multiface_2d_kb: _line_value(lines, 47, "multiface_2d_kb").to_i64() ?? -1,
        legacy_3d_kb: _line_value(lines, 48, "legacy_3d_kb").to_i64() ?? -1,
        multiface_3d_kb: _line_value(lines, 49, "multiface_3d_kb").to_i64() ?? -1,
        gpu_device_name: _line_value(lines, 51, "gpu_device_name"),
        gpu_driver_identity: _line_value(lines, 52, "gpu_driver_identity"),
        warm_1080_samples_ns: _parse_samples(_line_value(lines, 53, "warm_1080_samples_ns")),
        warm_4k_samples_ns: _parse_samples(_line_value(lines, 54, "warm_4k_samples_ns")),
        cpu_4096_samples_ns: _parse_samples(_line_value(lines, 55, "cpu_4096_samples_ns")),
        gpu_4096_samples_ns: _parse_samples(_line_value(lines, 56, "gpu_4096_samples_ns")),
        device_loss_status: _line_value(lines, 57, "device_loss_status"),
        device_loss_batch_identity_before: _line_value(lines, 58, "device_loss_batch_identity_before"),
        device_loss_batch_identity_after: _line_value(lines, 59, "device_loss_batch_identity_after"),
        cpu_after_device_loss_p95_ns: _line_value(lines, 60, "cpu_after_device_loss_p95_ns").to_i64() ?? -1,
        cpu_after_device_loss_samples_ns: _parse_samples(_line_value(lines, 61, "cpu_after_device_loss_samples_ns")),
        stage_shaping_p95_ns: _line_value(lines, 62, "stage_shaping_p95_ns").to_i64() ?? -1,
        stage_material_p95_ns: _line_value(lines, 63, "stage_material_p95_ns").to_i64() ?? -1,
        stage_emission_compile_ns: _line_value(lines, 64, "stage_emission_compile_ns").to_i64() ?? -1,
        stage_dirty_upload_p95_ns: _line_value(lines, 65, "stage_dirty_upload_p95_ns").to_i64() ?? -1,
        stage_queue_device_p95_ns: _line_value(lines, 66, "stage_queue_device_p95_ns").to_i64() ?? -1,
        stage_sync_p95_ns: _line_value(lines, 67, "stage_sync_p95_ns").to_i64() ?? -1,
        stage_present_readback_p95_ns: _line_value(lines, 68, "stage_present_readback_p95_ns").to_i64() ?? -1,
        stage_cpu_oracle_p95_ns: _line_value(lines, 69, "stage_cpu_oracle_p95_ns").to_i64() ?? -1,
        stage_shaping_samples_ns: _parse_stage_samples(_line_value(lines, 70, "stage_shaping_samples_ns")),
        stage_material_samples_ns: _parse_stage_samples(_line_value(lines, 71, "stage_material_samples_ns")),
        stage_dirty_upload_samples_ns: _parse_stage_samples(_line_value(lines, 72, "stage_dirty_upload_samples_ns")),
        stage_queue_device_samples_ns: _parse_stage_samples(_line_value(lines, 73, "stage_queue_device_samples_ns")),
        stage_sync_samples_ns: _parse_stage_samples(_line_value(lines, 74, "stage_sync_samples_ns")),
        stage_present_readback_samples_ns: _parse_stage_samples(_line_value(lines, 75, "stage_present_readback_samples_ns")),
        stage_cpu_oracle_samples_ns: _parse_stage_samples(_line_value(lines, 76, "stage_cpu_oracle_samples_ns")),
        promotion_artifact_identity: _line_value(lines, 77, "promotion_artifact_identity"),
        promotion_entry_name: _line_value(lines, 78, "promotion_entry_name"),
        promotion_program_version: _line_value(lines, 79, "promotion_program_version").to_i64() ?? -1,
        promotion_batch_identity: _line_value(lines, 80, "promotion_batch_identity"),
        promotion_atlas_payload_sha256: _line_value(lines, 81, "promotion_atlas_payload_sha256"),
        promotion_shader_handle: _line_value(lines, 82, "promotion_shader_handle").to_i64() ?? -1,
        promotion_pipeline_handle: _line_value(lines, 83, "promotion_pipeline_handle").to_i64() ?? -1,
        promotion_atlas_buffer_handle: _line_value(lines, 84, "promotion_atlas_buffer_handle").to_i64() ?? -1,
        promotion_params_buffer_handle: _line_value(lines, 85, "promotion_params_buffer_handle").to_i64() ?? -1,
        promotion_command_handle: _line_value(lines, 86, "promotion_command_handle").to_i64() ?? -1,
        promotion_fence_handle: _line_value(lines, 87, "promotion_fence_handle").to_i64() ?? -1,
        promotion_readback_buffer_handle: _line_value(lines, 88, "promotion_readback_buffer_handle").to_i64() ?? -1,
        promotion_quad_count: _line_value(lines, 89, "promotion_quad_count").to_i64() ?? -1,
        promotion_dispatch_count: _line_value(lines, 90, "promotion_dispatch_count").to_i64() ?? -1,
        promotion_submitted: promotion_submitted_text == "true",
        promotion_completion_waited: promotion_completion_waited_text == "true",
        promotion_fence_evidence_available: promotion_fence_available_text == "true",
        promotion_fence_destroyed: promotion_fence_destroyed_text == "true",
        promotion_readback_source: _line_value(lines, 95, "promotion_readback_source"),
        promotion_readback_byte_count: _line_value(lines, 96, "promotion_readback_byte_count").to_i64() ?? -1,
        promotion_readback_nonblank_pixels: _line_value(lines, 97, "promotion_readback_nonblank_pixels").to_i64() ?? -1,
        promotion_device_checksum: _line_value(lines, 98, "promotion_device_checksum").to_i64() ?? 0,
        promotion_oracle_checksum: _line_value(lines, 99, "promotion_oracle_checksum").to_i64() ?? 0,
        promotion_parity: promotion_parity_text == "true",
        promotion_device_executed: promotion_device_executed_text == "true",
        promotion_ready: promotion_ready_text == "true",
        promotion_present_mode: _line_value(lines, 103, "promotion_present_mode"))
    if not _valid_shape(evidence): return unavailable_font_perf_evidence("durable performance fields are incomplete")
    evidence

fn write_font_perf_evidence(evidence: FontPerfBudgetEvidence) -> bool:
    if file_exists(FONT_PERF_EVIDENCE_PATH): file_delete(FONT_PERF_EVIDENCE_PATH)
    val record = font_perf_evidence_record(evidence)
    record != "" and file_write(FONT_PERF_EVIDENCE_PATH, record)

fn read_font_perf_evidence() -> FontPerfBudgetEvidence:
    if not file_exists(FONT_PERF_EVIDENCE_PATH):
        return unavailable_font_perf_evidence("durable performance evidence is missing")
    parse_font_perf_evidence(file_read(FONT_PERF_EVIDENCE_PATH))
