# Shared, portable SSpec bodies for GPU processing + 2D drawing coverage.
#
# The intensive GPU/draw/event test plan
# (doc/03_plan/ui/testing/gpu_draw_event_intensive_tests.md, section 3) asks for
# ONE set of parameterized bodies that every backend spec calls, so backend
# coverage is data-driven instead of copy-pasted. This module owns:
#   - a device-availability probe (honest host-unavailable(reason) on CI),
#   - a read_pixels()->PPM (P6) oracle wrapper, and
#   - parameterized scenario bodies for kernel emission, compute payload-gating,
#     ExecTarget enforcement, and CPU/SW readback.
#
# All I/O routes through the std.io_runtime env facade (no raw rt_* in test
# code). Every scenario body carries an absolute oracle (a known fixed pixel /
# value, or proof the producer ran) so a no-op fallback can never pass green.

use std.spec.*
use compiler.backend.gpu_portable_compute.{
    PortableComputeTarget,
    emit_portable_u32_fill_kernel, emit_portable_u32_add_kernel,
    portable_compute_backend_target_diagnostic
}
use std.common.image.ppm_decode.{encode_ppm_p6}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gc_async_mut.gpu.engine2d.color.{rgba, color_r, color_g, color_b, color_a}
use std.nogc_async_mut.compute.exec_target.{
    DeviceClass, ComputeBackend, EnforceMode, BackendCaps, ExecTarget,
    resolve_exec_target
}
use std.nogc_async_mut.compute.backend_dispatch.{
    dispatch_reduce_i64_forced, dispatch_is_device, dispatch_backend_name
}

# Opaque black is the SoftwareBackend init() background (backend_software.spl:112).
val BG_BLACK: u32 = 0xff000000u32

fn add_i64(a: i64, b: i64) -> i64:
    return a + b

# ---------------------------------------------------------------------------
# Device-availability probe (fail-closed, honest).
# ---------------------------------------------------------------------------
# Portable CI wires NO real device detection here: raw rt_cuda_*/rt_metal_*
# device queries are runtime-tier only and are not allowed in test modules.
# Availability is therefore established from the BackendCaps the host provides
# (the same injectable-caps pattern the compute specs use). When a backend is
# not in caps, the probe reports host-unavailable(reason) rather than a silent
# skip, so a system-specific spec can fail-closed on it.
class BackendProbe:
    backend: text
    available: bool
    reason: text

fn _caps_has(backend: text, caps: BackendCaps) -> bool:
    if backend == "cuda":
        return caps.has_cuda
    if backend == "hip":
        return caps.has_hip
    if backend == "opencl":
        return caps.has_opencl
    if backend == "vulkan":
        return caps.has_vulkan
    if backend == "metal":
        return caps.has_metal
    if backend == "webgpu":
        return caps.has_webgpu
    return false

fn probe_backend(backend: text, caps: BackendCaps) -> BackendProbe:
    if _caps_has(backend, caps):
        return BackendProbe(backend: backend, available: true, reason: "")
    return BackendProbe(
        backend: backend,
        available: false,
        reason: "host-unavailable(no {backend} device in provided caps)")

# ---------------------------------------------------------------------------
# read_pixels() -> PPM (P6) oracle wrapper.
# ---------------------------------------------------------------------------
# The absolute drawing oracle is a real framebuffer download encoded as a P6
# PPM (doc research: encode_ppm_p6 at common/image/ppm_decode.spl:111). Callers
# feed a [u32] ARGB readback and get a header-prefixed byte stream.
fn read_pixels_ppm(width: i32, height: i32, pixels: [u32]) -> [u8]:
    return encode_ppm_p6(width as u32, height as u32, pixels)

# ---------------------------------------------------------------------------
# Kernel-emission shared body (host-portable, NO device).
# ---------------------------------------------------------------------------
# Markers assert against the ACTUAL emitter (gpu_portable_compute.spl:455-461):
# HIP shares the CUDA `__global__` marker (it diverges only by enum/binary
# format/toolchain), so HIP is NOT `__kernel` here — that would be a false
# assertion. OpenCL alone is `__kernel void`.
fn expected_kernel_marker(target: PortableComputeTarget) -> text:
    match target:
        case Cuda: "__global__ void"
        case Hip: "__global__ void"
        case OpenCl: "__kernel void"
        case Metal: "[[thread_position_in_grid]]"
        case WebGpu: "@compute @workgroup_size"

fn assert_fill_kernel_markers(target: PortableComputeTarget, name: text):
    val a = emit_portable_u32_fill_kernel(target, name)
    expect(a.source).to_contain(expected_kernel_marker(target))
    expect(a.source).to_contain(name)
    # Metal must carry BOTH the `kernel void` prefix and the thread-index attr.
    if target == PortableComputeTarget.Metal:
        expect(a.source).to_contain("kernel void {name}")

fn assert_add_kernel_markers(target: PortableComputeTarget, name: text):
    val a = emit_portable_u32_add_kernel(target, name)
    expect(a.source).to_contain(expected_kernel_marker(target))
    expect(a.source).to_contain(name)

# Reject / unknown-backend branch: the portable emitter accepts
# cuda/hip/opencl/metal/webgpu; Vulkan and any unknown name are closed.
fn assert_kernel_backend_rejected(backend_name: text, expected_status: text):
    val d = portable_compute_backend_target_diagnostic(backend_name)
    assert_false(d.accepted)
    expect(d.status).to_equal(expected_status)

fn assert_kernel_backend_accepted(backend_name: text, expected_target: text):
    val d = portable_compute_backend_target_diagnostic(backend_name)
    assert_true(d.accepted)
    expect(d.target_name).to_equal(expected_target)

# ---------------------------------------------------------------------------
# Compute payload-gating shared body (host-portable, deterministic).
# ---------------------------------------------------------------------------
# std.compute is a payload-gated SIMULATION: it always computes the CPU
# reference and only reports GPU provenance. The discriminator: with the gate
# false the CPU ran (ran_on_cpu=true) even though the target IS a named device;
# with the gate true ran_on_cpu flips to false. The value MUST equal the CPU
# oracle in BOTH branches (a device that returned a different value is a bug).
fn caps_for(backend: ComputeBackend) -> BackendCaps:
    var c = BackendCaps.none()
    if backend == ComputeBackend.Cuda:
        c.has_cuda = true
    if backend == ComputeBackend.Hip:
        c.has_hip = true
    if backend == ComputeBackend.OpenCl:
        c.has_opencl = true
    if backend == ComputeBackend.Vulkan:
        c.has_vulkan = true
    if backend == ComputeBackend.Metal:
        c.has_metal = true
    if backend == ComputeBackend.WebGpu:
        c.has_webgpu = true
    return c

fn gpu_target(backend: ComputeBackend) -> ExecTarget:
    return resolve_exec_target(DeviceClass.Gpu, backend, EnforceMode.Suggest, caps_for(backend))

fn bool_to_i(b: bool) -> i64:
    if b:
        return 1
    return 0

fn assert_payload_gating(backend: ComputeBackend):
    val target = gpu_target(backend)
    # The requested device really resolved to itself and is a device lane.
    expect(target.backend).to_equal(backend)
    assert_true(dispatch_is_device(target))
    val data = [10, 20, 30]
    val without_payload = dispatch_reduce_i64_forced(data, 0, add_i64, target, false)
    val with_payload = dispatch_reduce_i64_forced(data, 0, add_i64, target, true)
    # Absolute oracle: 10+20+30 == 60 in BOTH branches.
    expect(without_payload.value).to_equal(60)
    expect(with_payload.value).to_equal(60)
    # Discriminator: only the payload gate changes ran_on_cpu.
    expect(bool_to_i(without_payload.stats.ran_on_cpu)).to_equal(1)
    expect(bool_to_i(with_payload.stats.ran_on_cpu)).to_equal(0)
    # Provenance is the named backend, not a masquerade.
    expect(without_payload.stats.backend).to_equal(dispatch_backend_name(target.backend))
    expect(with_payload.stats.backend).to_equal(dispatch_backend_name(target.backend))

# ---------------------------------------------------------------------------
# ExecTarget suggest vs require-absent (fail-closed) shared body.
# ---------------------------------------------------------------------------
fn assert_suggest_falls_back():
    # GPU class, SUGGEST, bare machine: never fails — falls back to CPU.
    val t = resolve_exec_target(DeviceClass.Gpu, ComputeBackend.NoneBackend, EnforceMode.Suggest, BackendCaps.none())
    assert_true(t.resolved)
    assert_true(t.is_cpu())

fn assert_require_absent_fails_closed():
    # GPU class, REQUIRE, bare machine: resolved=false so the caller rt_exit 70.
    val t = resolve_exec_target(DeviceClass.Gpu, ComputeBackend.NoneBackend, EnforceMode.Require, BackendCaps.none())
    assert_false(t.resolved)
    expect(t.backend).to_equal(ComputeBackend.NoneBackend)

# ---------------------------------------------------------------------------
# CPU / software per-primitive readback shared body (absolute pixel oracle).
# ---------------------------------------------------------------------------
# The software backend is the only fully-honest rasterizer, so it is the
# absolute oracle: a known drawn point == the draw color, a known background
# point == opaque black. Each assertion compares all four ARGB channels so a
# same-value coincidence cannot pass.
fn new_surface(width: i32, height: i32) -> SoftwareBackend:
    var sw = SoftwareBackend.create()
    sw.init(width, height)
    return sw

fn _px(pixels: [u32], width: i32, x: i32, y: i32) -> u32:
    return pixels[(y * width + x) as i64]

fn assert_color_eq(actual: u32, expected: u32):
    expect(color_r(actual)).to_equal(color_r(expected))
    expect(color_g(actual)).to_equal(color_g(expected))
    expect(color_b(actual)).to_equal(color_b(expected))
    expect(color_a(actual)).to_equal(color_a(expected))

# Draw one primitive on a fresh surface, read the framebuffer back, and assert
# the drawn fixed point equals the draw color and the background point stays bg.
fn assert_primitive_readback(kind: text):
    val col = rgba(255, 0, 0, 255)
    val w = 20
    val h = 20
    var sw = new_surface(w, h)
    var drawn_x = 0
    var drawn_y = 0
    var bg_x = 0
    var bg_y = 0
    if kind == "fill_rect":
        sw.draw_rect_filled(4, 4, 8, 8, col)
        drawn_x = 8
        drawn_y = 8
        bg_x = 0
        bg_y = 0
    elif kind == "stroke_rect":
        sw.draw_rect(4, 4, 8, 8, col)
        drawn_x = 4          # top-left corner of the outline
        drawn_y = 4
        bg_x = 8             # interior stays background
        bg_y = 8
    elif kind == "line":
        sw.draw_line(2, 5, 15, 5, col, 1)
        drawn_x = 8          # on the horizontal line
        drawn_y = 5
        bg_x = 8             # far from the line
        bg_y = 12
    elif kind == "circle_filled":
        sw.draw_circle_filled(10, 10, 5, col)
        drawn_x = 10         # disk center
        drawn_y = 10
        bg_x = 0
        bg_y = 0
    elif kind == "circle_outline":
        sw.draw_circle(10, 10, 5, col)
        drawn_x = 15         # cx + r on the ring
        drawn_y = 10
        bg_x = 10            # ring center stays background
        bg_y = 10
    elif kind == "rounded_rect":
        sw.draw_rounded_rect(4, 4, 12, 12, 3, col)
        drawn_x = 10         # filled interior
        drawn_y = 10
        bg_x = 0
        bg_y = 0
    else:
        fail("assert_primitive_readback: unknown primitive kind {kind}")
        return
    val px = sw.read_pixels()
    assert_color_eq(_px(px, w, drawn_x, drawn_y), col)
    assert_color_eq(_px(px, w, bg_x, bg_y), BG_BLACK)

# Explicit-failure placeholder used by the readback body above: an unknown
# primitive kind must fail loudly, never silently pass.
fn fail(message: text):
    expect("primitive-kind").to_equal(message)
