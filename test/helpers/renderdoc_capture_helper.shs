#!/bin/sh
# Test-facing RenderDoc helper. Specs and check scripts should call these
# wrappers instead of spelling renderdoccmd/chrome setup inline.

if [ "${RENDERDOC_HELPER_ROOT:-}" = "" ]; then
    if [ -x "scripts/tool/renderdoc-evidence.shs" ]; then
        RENDERDOC_HELPER_ROOT="$(pwd)"
    else
        RENDERDOC_HELPER_ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
    fi
fi
RENDERDOC_HELPER_CLI="$RENDERDOC_HELPER_ROOT/scripts/tool/renderdoc-evidence.shs"

renderdoc_test_env() {
    "$RENDERDOC_HELPER_CLI" env
}

renderdoc_test_register_layer() {
    "$RENDERDOC_HELPER_CLI" register-layer
}

renderdoc_test_capture_simple() {
    "$RENDERDOC_HELPER_CLI" capture-simple
}

renderdoc_test_capture_html() {
    "$RENDERDOC_HELPER_CLI" capture-html
}
