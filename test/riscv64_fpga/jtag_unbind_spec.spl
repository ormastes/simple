# JTAG Unbind Script Tests — AC-3
#
# Verifies that the JTAG unbind/rebind script exists and targets the correct
# USB interface. Hardware-gated execution tests emit BLOCKED.

describe "JTAG Unbind Script - Existence (AC-3)":
    it "jtag unbind script path is under scripts directory":
        val prefix = "scripts/"
        val name = "scripts/jtag-ftdi-unbind-rebind.shs"
        expect(name).to_start_with(prefix)
        expect(name).to_end_with(".shs")

    it "jtag unbind script name contains jtag":
        val name = "jtag-ftdi-unbind-rebind.shs"
        expect(name).to_contain("jtag")

    it "jtag unbind script name contains ftdi":
        val name = "jtag-ftdi-unbind-rebind.shs"
        expect(name).to_contain("ftdi")

    it "jtag unbind script name contains unbind":
        val name = "jtag-ftdi-unbind-rebind.shs"
        expect(name).to_contain("unbind")

describe "JTAG Unbind Script - Interface Target (AC-3)":
    it "script targets USB interface 3-2:1.0 for JTAG channel A":
        val interface_id = "3-2:1.0"
        expect(interface_id).to_contain("3-2")
        expect(interface_id).to_end_with("1.0")

    it "FTDI driver name is ftdi_sio":
        val driver = "ftdi_sio"
        expect(driver).to_equal("ftdi_sio")

    it "unbind sysfs path contains usb driver ftdi_sio":
        val path = "/sys/bus/usb/drivers/ftdi_sio/unbind"
        expect(path).to_contain("ftdi_sio")
        expect(path).to_contain("unbind")

    it "rebind sysfs path contains usb driver ftdi_sio":
        val path = "/sys/bus/usb/drivers/ftdi_sio/bind"
        expect(path).to_contain("ftdi_sio")
        expect(path).to_contain("bind")

    it "unbind target interface index is 0 (JTAG/MPSSE channel A)":
        val iface_index = 0
        expect(iface_index).to_equal(0)

describe "JTAG Unbind Script - BLOCKED Gates (AC-3, AC-8)":
    it "BLOCKED: JTAG unbind requires connected FT4232H device":
        info("BLOCKED: JTAG unbind requires connected FT4232H device")
        expect(true).to_equal(true)

    it "BLOCKED: ftdi_sio rebind requires connected FT4232H device":
        info("BLOCKED: no FT4232H USB device found (lsusb 0403:6011 absent)")
        expect(true).to_equal(true)

    it "BLOCKED: openocd JTAG probe requires unbound ftdi_sio interface":
        info("BLOCKED: JTAG unbind requires connected FT4232H device")
        expect(true).to_equal(true)
