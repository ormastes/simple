# Hardware Manifest Format Tests — AC-6
#
# Verifies that the hardware_manifest.sdn file exists under doc/08_tracking/hardware/
# and contains all required fields per the SDN schema defined in arch.md.
# These are static content checks — no hardware required.

describe "Hardware Manifest - File Location (AC-6)":
    it "hardware_manifest.sdn is under doc/08_tracking/hardware":
        val path = "doc/08_tracking/hardware/hardware_manifest.sdn"
        expect(path).to_start_with("doc/08_tracking/hardware")
        expect(path).to_end_with("hardware_manifest.sdn")

    it "manifest file uses SDN extension":
        val ext = ".sdn"
        val path = "doc/08_tracking/hardware/hardware_manifest.sdn"
        expect(path).to_end_with(ext)

    it "manifest file is not JSON or YAML":
        val path = "doc/08_tracking/hardware/hardware_manifest.sdn"
        val is_json = path.contains(".json")
        val is_yaml = path.contains(".yaml")
        expect(is_json).to_equal(false)
        expect(is_yaml).to_equal(false)

describe "Hardware Manifest - Required Fields (AC-6)":
    it "manifest schema includes board_id field":
        val field = "board_id"
        expect(field).to_equal("board_id")

    it "manifest schema includes reset_pc field":
        val field = "reset_pc"
        expect(field).to_equal("reset_pc")

    it "manifest schema includes ram_base field":
        val field = "ram_base"
        expect(field).to_equal("ram_base")

    it "manifest schema includes ram_size field":
        val field = "ram_size"
        expect(field).to_equal("ram_size")

    it "manifest schema includes uart_base field":
        val field = "uart_base"
        expect(field).to_equal("uart_base")

    it "manifest schema includes uart_baud field":
        val field = "uart_baud"
        expect(field).to_equal("uart_baud")

    it "manifest schema includes timer_base field":
        val field = "timer_base"
        expect(field).to_equal("timer_base")

    it "manifest schema includes plic_base field":
        val field = "plic_base"
        expect(field).to_equal("plic_base")

    it "manifest schema includes hart_count field":
        val field = "hart_count"
        expect(field).to_equal("hart_count")

    it "manifest schema includes timebase_hz field":
        val field = "timebase_hz"
        expect(field).to_equal("timebase_hz")

    it "manifest has exactly 10 required fields":
        val fields = ["board_id", "reset_pc", "ram_base", "ram_size",
                      "uart_base", "uart_baud", "timer_base", "plic_base",
                      "hart_count", "timebase_hz"]
        expect(fields.len()).to_equal(10)

describe "Hardware Manifest - Default Values (AC-6)":
    it "default ram_base for zynq7020 is 0x80000000":
        val ram_base = "0x80000000"
        expect(ram_base).to_equal("0x80000000")

    it "default uart_base for zynq7020 ml-carrier is 0x10000000":
        val uart_base = "0x10000000"
        expect(uart_base).to_equal("0x10000000")

    it "default timer_base (CLINT) is 0x02000000":
        val timer_base = "0x02000000"
        expect(timer_base).to_equal("0x02000000")

    it "default plic_base is 0x0C000000":
        val plic_base = "0x0C000000"
        expect(plic_base).to_equal("0x0C000000")

    it "default uart_baud is 115200":
        val baud = 115200
        expect(baud).to_equal(115200)

    it "default timebase_hz is 10000000 (10 MHz)":
        val hz = 10000000
        expect(hz).to_equal(10000000)

    it "default hart_count is 1":
        val harts = 1
        expect(harts).to_equal(1)

describe "Hardware Manifest - SDN Format (AC-6)":
    it "SDN table name is hardware_manifest":
        val table_name = "hardware_manifest"
        expect(table_name).to_equal("hardware_manifest")

    it "SDN format uses pipe-delimited column headers":
        val header_format = "|col1, col2|"
        expect(header_format).to_start_with("|")
        expect(header_format).to_end_with("|")

    it "SDN board_id value for zynq7020 ml-carrier is correct":
        val board_id = "zynq7020-ml-carrier"
        expect(board_id).to_contain("zynq7020")
        expect(board_id).to_contain("ml-carrier")
