# mix_blend_mode scene — CSS mix-blend-mode Multiply via SkBlendMode, cull 301x300

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 301.0, bottom: 300.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record saveLayer(kMultiply) + drawRect pairs + restore.
    # Chromium ref: CSS mix-blend-mode:multiply between two overlapping colour rects.
    started.finish_recording()
