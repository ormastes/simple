# scroll_damage scene — cc scroll damage invalidation rectangle, cull 400x400

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 400.0, bottom: 400.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record two drawRect calls — pre-scroll content + post-scroll
    # damage rect — matching cc::DamageTracker output after 50px scroll delta.
    # Chromium ref: DamageTracker::ComputeSurfaceDamageList on scrolling PictureLayer.
    started.finish_recording()
