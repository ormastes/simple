# backdrop_filter scene — CSS backdrop-filter blur via SkImageFilter, cull 300x301

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 300.0, bottom: 301.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record saveLayer with backdrop SkImageFilter blur sigma=10 + restore.
    # Chromium ref: frosted-glass panel over photo; Blink maps backdrop-filter to
    # SkCanvas::saveLayer(bounds, paint_with_backdrop_filter).
    started.finish_recording()
