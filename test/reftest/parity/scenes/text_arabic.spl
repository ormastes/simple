# text_arabic scene — Arabic RTL text shaping via HarfBuzz/Skia, cull 200x202

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 202.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record shaped Arabic glyph run via SkTextBlob + drawTextBlob here.
    # Chromium ref: "مرحبا" in Noto Naskh Arabic, RTL bidi, drawTextBlob at (190, 50).
    started.finish_recording()
