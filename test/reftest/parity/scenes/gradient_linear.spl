# gradient_linear scene — SkLinearGradient shader, cull 202x200

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 202.0, bottom: 200.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record SkShader::MakeLinearGradient + drawRect ops here.
    # Chromium ref: two-stop black-to-white horizontal gradient filling bounds.
    started.finish_recording()
