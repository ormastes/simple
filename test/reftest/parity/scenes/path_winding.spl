# path_winding scene — winding fill rule (nonzero), cull 200x200

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 200.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record real winding-fill path ops here.
    # Chromium ref: SkPath::setFillType(kWinding) + star polygon.
    started.finish_recording()
