# transform_tree scene — SetMatrix op followed by DrawPath, cull 401x400

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_path}
use std.skia.entity.paint.{SkPaint, sk_paint_new, sk_paint_fill}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkPathFillType}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 401.0, bottom: 400.0)
    val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
    # SetMatrix op (no payload fields — kind only)
    val set_matrix_paint = sk_paint_new()
    val set_matrix_op = SkPictureOp(
        kind: SkPictureOpKind.SetMatrix,
        rect: zero_rect,
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: set_matrix_paint,
        x: 0.0,
        y: 0.0
    )
    # DrawPath: a rectangle path representing a transformed tile
    val p0 = sk_path_new()
    val p1 = p0.move_to(80.0, 80.0)
    val p2 = p1.line_to(200.0, 80.0)
    val p3 = p2.line_to(200.0, 200.0)
    val p4 = p3.line_to(80.0, 200.0)
    val tile_path = p4.close()
    val paint = sk_paint_fill(sk_color_argb(255, 80, 160, 240))
    val ops = [SkPictureOp]()
    ops.push(set_matrix_op)
    ops.push(sk_picture_op_draw_path(tile_path, paint))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
