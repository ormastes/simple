# transform_tree scene — cc/blink property-tree transform node, cull 401x400

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 401.0, bottom: 400.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record setMatrix(rotate45) + drawRect + setMatrix(identity).
    # Chromium ref: TransformNode with local_transform=rotate(45deg) in cc property tree;
    # PictureLayerImpl applies node matrix before rasterising tile.
    started.finish_recording()
