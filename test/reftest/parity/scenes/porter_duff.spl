# porter_duff scene — 4 DrawRects with different blend modes, cull 300x300

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkBlendMode}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 300.0, bottom: 300.0)
    # Background rect
    val bg = SkRect(left: 20.0, top: 20.0, right: 280.0, bottom: 280.0)
    val paint_bg = sk_paint_fill(sk_color_argb(255, 100, 149, 237))
    # SrcOver rect
    val r1 = SkRect(left: 30.0, top: 30.0, right: 150.0, bottom: 150.0)
    val base1 = sk_paint_fill(sk_color_argb(180, 220, 50, 50))
    val paint1 = base1.with_blend_mode(SkBlendMode.SrcOver)
    # Multiply rect
    val r2 = SkRect(left: 100.0, top: 30.0, right: 220.0, bottom: 150.0)
    val base2 = sk_paint_fill(sk_color_argb(180, 50, 200, 50))
    val paint2 = base2.with_blend_mode(SkBlendMode.Multiply)
    # Screen rect
    val r3 = SkRect(left: 30.0, top: 100.0, right: 150.0, bottom: 220.0)
    val base3 = sk_paint_fill(sk_color_argb(180, 50, 50, 220))
    val paint3 = base3.with_blend_mode(SkBlendMode.Screen)
    # DstIn rect
    val r4 = SkRect(left: 100.0, top: 100.0, right: 220.0, bottom: 220.0)
    val base4 = sk_paint_fill(sk_color_argb(180, 220, 180, 50))
    val paint4 = base4.with_blend_mode(SkBlendMode.DstIn)
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_rect(bg, paint_bg))
    ops.push(sk_picture_op_draw_rect(r1, paint1))
    ops.push(sk_picture_op_draw_rect(r2, paint2))
    ops.push(sk_picture_op_draw_rect(r3, paint3))
    ops.push(sk_picture_op_draw_rect(r4, paint4))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
