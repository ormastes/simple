# porter_duff scene — Porter-Duff SrcOver composite, cull 300x300

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 300.0, bottom: 300.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record saveLayer + drawRect with kSrcOver blend + restore.
    # Chromium ref: red rect over blue rect with kSrcOver; alpha=0.5 on top layer.
    started.finish_recording()
