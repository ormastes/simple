# opacity_layer scene — CSS opacity via cc EffectNode / SkCanvas::saveLayerAlpha, cull 400x401

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 400.0, bottom: 401.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record saveLayerAlpha(128) + drawRect(red) + restore.
    # Chromium ref: EffectNode{opacity:0.5} in cc property tree; raster applies
    # SkCanvas::saveLayerAlpha with alpha=128 around the layer's picture.
    started.finish_recording()
