# dashed_strokes scene — SkDashPathEffect stroked path, cull 200x201

use std.skia.entity.picture.{SkPicture, SkPictureRecorder}
use std.skia.entity.geometry.{SkRect}

fn make_scene() -> SkPicture:
    val bounds = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 201.0)
    val rec = SkPictureRecorder(recording: false, cull_rect: bounds, ops: 0)
    val started = rec.begin_recording(bounds)
    # Phase 8 final: record SkDashPathEffect + drawPath ops here.
    # Chromium ref: SkDashPathEffect::Make({10,5}, 2, 0) applied to horizontal line.
    started.finish_recording()
