# Golden fixture: transform_tree — SetMatrix op + DrawPath (triangle)
# SetMatrix is a no-op in the CPU backend; the DrawPath renders normally.

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_path}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_green}
use std.skia.entity.enums.{SkPathFillType}

fn _set_matrix_op(paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.SetMatrix,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn _triangle_path() -> SkPath:
    val base = sk_path_new()
    val p1 = base.move_to(128.0, 40.0)
    val p2 = p1.line_to(216.0, 216.0)
    val p3 = p2.line_to(40.0, 216.0)
    p3.close()

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    val fill_paint = sk_paint_fill(sk_color_green())
    val op_matrix = _set_matrix_op(fill_paint)
    val path = _triangle_path()
    val op_path = sk_picture_op_draw_path(path, fill_paint)
    val ops = [op_matrix, op_path]
    val picture = SkPicture(cull_rect: cull, op_count: 2, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
