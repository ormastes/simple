# pixel_diff — stub pixel comparator for Phase 8 parity reftests

# ============================================================================
# PixelDiffResult — outcome of comparing two rasterised pictures
# ============================================================================

class PixelDiffResult:
    ratio: f64
    max_channel_delta: i32
    mismatched_pixels: i64

# ============================================================================
# compare_pictures — compare two scenes by op-stream signature
#
# Phase 8 stub: if signatures are equal the diff ratio is 0.0 (identical);
# otherwise 1.0 (all-different). Phase 8 final wires real CPU + Vulkan raster.
# TODO(reftest): wire real CPU + Vulkan raster pixel compare in Phase 8 final.
# ============================================================================

fn compare_pictures(a_sig: i64, b_sig: i64) -> PixelDiffResult:
    if a_sig == b_sig:
        PixelDiffResult(ratio: 0.0, max_channel_delta: 0, mismatched_pixels: 0)
    else:
        PixelDiffResult(ratio: 1.0, max_channel_delta: 255, mismatched_pixels: -1)
