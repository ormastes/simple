# pixel_diff — real pixel comparator driving CpuBackend -> Bitmap -> pixel_diff_core

use std.skia.entity.geometry.{SkRect, SkIRect}
use std.skia.entity.picture.{SkPicture}
use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use test.reftest.parity.pixel_diff_core.{BitmapRef, PixelDiffSummary, summarize}

# ============================================================================
# PixelDiffResult — outcome of comparing two rasterised pictures
# ============================================================================

class PixelDiffResult:
    ratio: f64
    rect: SkIRect
    max_delta: i32
    passed: bool

# ============================================================================
# compare_pictures — render both pictures via CpuBackend and diff the pixels
# ============================================================================

fn compare_pictures(a: SkPicture, b: SkPicture, cull: SkRect, tolerance: i32) -> PixelDiffResult:
    val backend = cpu_backend_new()
    val bitmap_a = backend.render_picture(a, cull)
    val bitmap_b = backend.render_picture(b, cull)
    val ref_a = BitmapRef(width: bitmap_a.width, height: bitmap_a.height, pixels: bitmap_a.pixels)
    val ref_b = BitmapRef(width: bitmap_b.width, height: bitmap_b.height, pixels: bitmap_b.pixels)
    val summary = summarize(ref_a, ref_b, tolerance)
    PixelDiffResult(
        ratio: summary.ratio,
        rect: summary.diff_rect,
        max_delta: summary.max_channel_delta,
        passed: false
    )

# ============================================================================
# compare_with_threshold — like compare_pictures, also sets passed flag
# ============================================================================

fn compare_with_threshold(a: SkPicture, b: SkPicture, cull: SkRect, ratio_threshold: f64, tolerance: i32) -> PixelDiffResult:
    val base = compare_pictures(a, b, cull, tolerance)
    val did_pass = base.ratio <= ratio_threshold
    PixelDiffResult(
        ratio: base.ratio,
        rect: base.rect,
        max_delta: base.max_delta,
        passed: did_pass
    )
