#!/usr/bin/env simple
# RISC-V ISA gate runner — compile tests, run through GHDL, report pass/fail

use std.io_runtime
use std.fs
use std.text
use std.process

# Configuration
const GATE_DIR = "/home/ormastes/dev/pub/simple/test/riscv_isa_gate"
const RISCV_TESTS_DIR = GATE_DIR ++ "/riscv-tests"
const PAYLOADS_DIR = GATE_DIR ++ "/payloads"
const GHDL_WORK_DIR = "/home/ormastes/dev/pub/simple/build/vhdl/rv32"

# Curated test set: ~10 tests covering proven-bug areas
const TESTS = [
  # Base integer ISA
  ("rv32ui", "simple"),   # basic setup
  ("rv32ui", "add"),      # arithmetic
  ("rv32ui", "addi"),     # immediate arithmetic
  ("rv32ui", "jal"),      # jump
  ("rv32ui", "jalr"),     # jump register
  ("rv32ui", "beq"),      # branch equal
  ("rv32ui", "lb"),       # load byte
  ("rv32ui", "sw"),       # store word
  # M extension (mul/div)
  ("rv32um", "mul"),      # multiply
  ("rv32um", "div"),      # divide
  ("rv32um", "rem"),      # remainder
]

fun compile_test(src_dir: string, name: string): string =
  # Cross-compile test for rv32imac
  let src = RISCV_TESTS_DIR ++ "/isa/" ++ src_dir ++ "/" ++ name ++ ".S"
  let elf = PAYLOADS_DIR ++ "/" ++ name ++ ".elf"
  let mem = PAYLOADS_DIR ++ "/" ++ name ++ ".mem"

  # Compile with rv32imac_zicsr target
  let cc_cmd = "riscv64-unknown-elf-gcc -march=rv32imac_zicsr -mabi=ilp32 "
               ++ "-static -nostdlib -Ttext=0x80000000 "
               ++ "-o " ++ elf ++ " " ++ src
  let result = process.run(cc_cmd)

  if result.rc != 0 then
    eprintln("ERROR: Failed to compile " ++ name)
    eprintln("  stderr: " ++ result.stderr)
    return ""  # failure marker
  end

  # Convert ELF to .mem hex format
  let objcopy_cmd = "riscv64-unknown-elf-objcopy -O verilog " ++ elf ++ " /tmp/temp.mem"
  let objcopy_result = process.run(objcopy_cmd)

  if objcopy_result.rc != 0 then
    eprintln("ERROR: Failed objcopy for " ++ name)
    return ""
  end

  # Extract hex words, filter to 32-bit words only (skip @ addresses)
  let hexdump_cmd = "hexdump -v -e '1/4 \"%08x\\n\"' /tmp/temp.mem | "
                    ++ "grep -v '^$' > " ++ mem
  let hexdump_result = process.run(hexdump_cmd)

  if hexdump_result.rc != 0 then
    eprintln("ERROR: Failed hexdump for " ++ name)
    return ""
  end

  mem

fun run_test(mem_file: string): i64 =
  # Run GHDL simulation with timeout, capture gp value
  let tb_cmd = "cd " ++ GHDL_WORK_DIR ++ " && "
               ++ "ghdl -r tb_gate --ieee-asserts=disable "
               ++ "--stop-time=1ms > /tmp/gate_out.txt 2>&1"

  # Load test via memory init (needs tb_gate to support mem load parameter)
  # For now, manually copy to rv32_payload.mem location
  let cp_cmd = "cp " ++ mem_file ++ " " ++ GHDL_WORK_DIR ++ "/rv32_payload.mem"
  let cp_result = process.run(cp_cmd)

  if cp_result.rc != 0 then
    eprintln("ERROR: Failed to copy " ++ mem_file)
    return -1
  end

  let tb_result = process.run(tb_cmd)
  let output = tb_result.stdout ++ tb_result.stderr

  # Parse GATE_GP=X line
  for line in output.split('\n') do
    if line.starts_with("GATE_GP=") then
      let gp_str = line.substring(8)  # skip "GATE_GP="
      return gp_str.to_i64()
    end
  end

  -2  # timeout/error marker

fun main(): i64 =
  println("RISC-V ISA Gate — rv32 GHDL Core")
  println("=" * 40)

  var pass_count = 0
  var fail_count = 0
  var error_count = 0

  for (src_dir, test_name) in TESTS do
    print("Compiling " ++ test_name ++ "... ")
    let mem_file = compile_test(src_dir, test_name)

    if mem_file == "" then
      println("COMPILE FAIL")
      error_count += 1
      continue
    end

    print("Running... ")
    let gp = run_test(mem_file)

    if gp == -1 then
      println("RUNTIME ERROR")
      error_count += 1
    else if gp == -2 then
      println("TIMEOUT")
      error_count += 1
    else if gp == 0 then
      println("PASS")
      pass_count += 1
    else
      println("FAIL (gp=" ++ gp.to_string() ++ ")")
      fail_count += 1
    end
  end

  println()
  println("Summary:")
  println("  PASS:   " ++ pass_count.to_string())
  println("  FAIL:   " ++ fail_count.to_string())
  println("  ERROR:  " ++ error_count.to_string())

  0
