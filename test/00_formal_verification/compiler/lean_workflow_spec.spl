use std.spipe.*
use std.nogc_sync_mut.io.{file_exists, file_read_text}
use verification.lean.runner.{LeanCheckResult, VerificationSummary}
use verification.models.contracts.{FunctionContract, ContractClause, ContractExpr}
use verification.proofs.obligations.{ProofObligation, ProofStatus, extract_from_contract}
use verification.proofs.checker.{ProofChecker, LeanResult}
use verification.regenerate.{regenerate_all, write_regenerated_files, validate_regeneration}
use std.nogc_sync_mut.io.{shell}

describe "Lean Verification Workflow Core":
    context "LeanCheckResult":
        it "flags unproven goals and formats them":
            val result = LeanCheckResult(
                file: "src/verification/demo.lean",
                success: true,
                stdout: "goals accomplished",
                stderr: "",
                goals_solved: 1,
                goals_remaining: 2,
                exit_code: Some(0)
            )

            expect(result.has_unproven()).to_equal(true)
            expect(result.is_fully_proven()).to_equal(false)
            expect(result.passed()).to_equal(true)
            expect(result.format()).to_contain("Goals remaining (sorry): 2")

    context "VerificationSummary":
        it "aggregates pass/fail and unproven counts":
            val ok = LeanCheckResult(
                file: "src/verification/ok.lean",
                success: true,
                stdout: "goals accomplished",
                stderr: "",
                goals_solved: 1,
                goals_remaining: 0,
                exit_code: Some(0)
            )
            val bad = LeanCheckResult(
                file: "src/verification/bad.lean",
                success: false,
                stdout: "",
                stderr: "error: sorry",
                goals_solved: 0,
                goals_remaining: 1,
                exit_code: Some(1)
            )

            val summary = VerificationSummary.from_results([ok, bad])
            expect(summary.files_checked).to_equal(2)
            expect(summary.files_passed).to_equal(1)
            expect(summary.files_failed).to_equal(1)
            expect(summary.total_theorems).to_equal(2)
            expect(summary.proven_theorems).to_equal(1)
            expect(summary.unproven_theorems).to_equal(1)
            expect(summary.is_success()).to_equal(false)
            expect(summary.is_fully_proven()).to_equal(false)
            expect(summary.format()).to_contain("Files: 1/2 passed")
            expect(summary.format()).to_contain("Theorems: 1/2 proven")
            expect(summary.format()).to_contain("Unproven (sorry): 1")

    context "Proof obligations":
        it "extracts obligations with stable identifiers":
            var contract = FunctionContract.new()
            contract = contract.add_precondition(
                ContractClause.new(
                    ContractExpr.ge(
                        ContractExpr.variable("n"),
                        ContractExpr.int_val(0)
                    )
                )
            )
            contract = contract.add_postcondition(
                ContractClause.new(
                    ContractExpr.gt(
                        ContractExpr.result(),
                        ContractExpr.int_val(0)
                    )
                )
            )
            contract = contract.add_invariant(
                ContractClause.new(
                    ContractExpr.ge(
                        ContractExpr.variable("n"),
                        ContractExpr.int_val(0)
                    )
                )
            )

            val obls = extract_from_contract("factorial", "math.spl", 42, contract)
            expect(obls.len()).to_equal(3)
            expect(obls[0].id).to_equal("factorial_pre_0")
            expect(obls[1].id).to_equal("factorial_post_0")
            expect(obls[2].id).to_equal("factorial_inv_0")
            expect(obls[0].source_file).to_equal("math.spl")
            expect(obls[0].source_line).to_equal(42)

        it "preserves proof text when marked proven":
            val ob = ProofObligation.create(
                "demo_post_0",
                "demo_postcondition_0",
                "demo.spl",
                7,
                "True"
            )
            var proven_status = ob.with_status(ProofStatus.Proven)
            val proven = proven_status.with_proof("rfl")
            val theorem = proven.to_lean_theorem()

            expect(proven.status.to_string()).to_equal("proven")
            expect(theorem.name).to_equal("demo_postcondition_0")
            expect(theorem.proof_text()).to_equal("rfl")
            expect(theorem.to_lean()).to_contain("rfl")

    context "Regeneration inventory":
        it "returns the supported file set":
            val files = regenerate_all()
            expect(files.len()).to_equal(15)
            expect(files.has("src/verification/memory_capabilities/src/MemoryCapabilities.lean")).to_equal(true)
            expect(files.has("src/verification/memory_model_drf/src/MemoryModelDRF.lean")).to_equal(true)
            expect(files.has("src/verification/type_inference_compile/src/Contracts.lean")).to_equal(true)

        it "writes regenerated files to a temp directory":
            val temp_root = "/tmp/simple-lean-workflow-unit"
            # Clean up any marker-less file left by a prior run of this test —
            # write_regenerated_files refuses to overwrite files that lack the
            # generated marker, which makes a bare fixed temp path non-idempotent.
            shell("rm -f '" + temp_root + "/src/verification/demo/src/Demo.lean'")
            val sample = {"src/verification/demo/src/Demo.lean": "theorem demo : True := by rfl"}
            val written = write_regenerated_files(sample, temp_root)

            expect(written.len()).to_equal(1)
            expect(written[0]).to_start_with(temp_root)
            expect(file_exists(written[0])).to_equal(true)
            expect(file_read_text(written[0])).to_equal("theorem demo : True := by rfl")

    context "Proof status":
        it "renders admitted and pending states distinctly":
            expect(ProofStatus.Pending.to_string()).to_equal("pending")
            expect(ProofStatus.Proven.to_string()).to_equal("proven")
            expect(ProofStatus.Admitted.to_string()).to_equal("admitted")

    context "Strict checker":
        it "hard-fails on files that still contain sorry":
            val temp_root = "/tmp/simple-lean-workflow-strict"
            # Same idempotency cleanup as above — see comment there.
            shell("rm -f '" + temp_root + "/src/verification/demo/src/Demo.lean'")
            val written = write_regenerated_files(
                {"src/verification/demo/src/Demo.lean": "theorem demo : True := by sorry"},
                temp_root
            )

            expect(written.len()).to_equal(1)

            val proof_checker = ProofChecker.create()
            val result = proof_checker.check_file(written[0])

            val status_str = result.result.to_string()
            expect(status_str).to_contain("proof error")
            expect(result.sorry_count()).to_equal(1)
            expect(result.error_message()).to_contain("sorry")

        it "flags missing validation targets as mismatches":
            val validation = validate_regeneration(
                {"src/verification/demo/src/Demo.lean": "theorem demo : True := by rfl"},
                "/tmp/simple-lean-workflow-missing"
            )

            expect(validation.has("src/verification/demo/src/Demo.lean")).to_equal(true)
            expect(validation["src/verification/demo/src/Demo.lean"]).to_equal("mismatch")
