## Overview

Unit tests for HAL trait contracts defined in
`src/compiler_rust/lib/std/src/bare/hal/`. Covers AC-3 / AC-4 by creating
minimal mock implementations of each trait and exercising the public API.

No hardware is required: all tests use in-memory mock structs.

These specs WILL FAIL until Team E lands the mock implementations and wires
up the test stubs. (The traits exist but no mock impls or test file does yet.)
"""

use std.sspec.*
use std.bare.hal.gpio.*
use std.bare.hal.uart.*
use std.bare.hal.spi.*
use std.bare.hal.i2c.*
use std.bare.hal.timer.*


# ============================================================================
# Mock implementations (helpers at bottom; forward declarations here)
# ============================================================================

# MockGpioPin — minimal in-memory implementation of GpioPin trait
struct MockGpioPin:
    pin_num:  u8
    port_num: u8
    mode:     PinMode
    state:    PinState

impl GpioPin for MockGpioPin:
    fn pin() -> u8:
        self.pin_num

    fn port() -> u8:
        self.port_num

    me set_mode(mode: PinMode):
        self.mode = mode

    fn read() -> PinState:
        self.state

    me write(state: PinState):
        self.state = state

    me toggle():
        if self.state == PinState.High:
            self.state = PinState.Low
        else:
            self.state = PinState.High

# MockUart — minimal in-memory UART backed by a buffer
struct MockUart:
    buf:  [u8]
    head: i64

impl Uart for MockUart:
    me init(config: UartConfig):
        pass

    me write_byte(byte: u8):
        self.buf = self.buf.append(byte)

    fn read_byte() -> u8:
        if self.head < self.buf.len():
            val b = self.buf[self.head]
            self.head = self.head + 1
            b
        else:
            0

    fn is_readable() -> bool:
        self.head < self.buf.len()

    fn is_writable() -> bool:
        true

    me flush():
        pass

    me set_baud_rate(baud: u32):
        pass

# MockSpi — minimal SPI mock (only required abstract methods)
struct MockSpi:
    last_sent: u8
    reply:     u8

impl Spi for MockSpi:
    me init(config: SpiConfig):
        pass

    fn transfer_byte(tx: u8) -> u8:
        self.last_sent = tx
        self.reply

    me set_clock_speed(speed: u32):
        pass

    fn is_busy() -> bool:
        false

# MockI2c — minimal I2C mock matching the I2c trait exactly
struct MockI2c:
    data: [u8]

impl I2c for MockI2c:
    me init(config: I2cConfig):
        pass

    me write(addr: u16, data: [u8]) -> I2cResult:
        I2cResult.Ok

    fn read(addr: u16, len: usize) -> Result<[u8], I2cResult>:
        Result.ok(self.data)

    fn write_read(addr: u16, write_data: [u8], read_len: usize) -> Result<[u8], I2cResult>:
        Result.ok(self.data)

# MockTimer — minimal timer mock
struct MockTimer:
    fired:   bool
    running: bool
    cnt:     u64
    period_us_val: u64

impl Timer for MockTimer:
    me init():
        self.fired   = false
        self.running = false
        self.cnt     = 0

    me start(period_us: u64, mode: TimerMode):
        self.period_us_val = period_us
        self.running = true

    me stop():
        self.running = false

    fn is_fired() -> bool:
        self.fired

    me clear():
        self.fired = false

    fn counter() -> u64:
        self.cnt

    me set_counter(value: u64):
        self.cnt = value

    fn period() -> u64:
        self.period_us_val

    fn is_running() -> bool:
        self.running


# ============================================================================
# GpioPin tests
# ============================================================================

describe "AC-3/AC-4 HAL GpioPin trait":
    """
    ## GpioPin — GPIO pin abstraction

    Verifies the trait contract using MockGpioPin.
    """

    it "AC-4: pin() returns the configured pin number":
        val p = MockGpioPin(pin_num: 3, port_num: 0, mode: PinMode.Input, state: PinState.Low)
        expect(p.pin()).to_equal(3)

    it "AC-4: port() returns the configured port number":
        val p = MockGpioPin(pin_num: 3, port_num: 1, mode: PinMode.Input, state: PinState.Low)
        expect(p.port()).to_equal(1)

    it "AC-4: read() returns initial Low state":
        val p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Input, state: PinState.Low)
        expect(p.read() == PinState.Low).to_equal(true)

    it "AC-4: write(High) transitions pin to High":
        var p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.Low)
        p.write(PinState.High)
        expect(p.read() == PinState.High).to_equal(true)

    it "AC-4: toggle() flips Low to High":
        var p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.Low)
        p.toggle()
        expect(p.is_high()).to_equal(true)

    it "AC-4: toggle() flips High to Low":
        var p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.High)
        p.toggle()
        expect(p.is_low()).to_equal(true)

    it "AC-4: is_high() returns true when state is High":
        val p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.High)
        expect(p.is_high()).to_equal(true)

    it "AC-4: is_low() returns true when state is Low":
        val p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.Low)
        expect(p.is_low()).to_equal(true)

    it "AC-4: set_high() sets state to High":
        var p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.Low)
        p.set_high()
        expect(p.is_high()).to_equal(true)

    it "AC-4: set_low() sets state to Low":
        var p = MockGpioPin(pin_num: 0, port_num: 0, mode: PinMode.Output, state: PinState.High)
        p.set_low()
        expect(p.is_low()).to_equal(true)


# ============================================================================
# Uart tests
# ============================================================================

describe "AC-3/AC-4 HAL Uart trait":
    """
    ## Uart — UART serial communication abstraction

    Verifies the trait contract using MockUart.
    """

    it "AC-4: write_byte appends byte to buffer":
        var buf: [u8] = []
        var u = MockUart(buf: buf, head: 0)
        u.write_byte(0x41)
        expect(u.buf.len()).to_equal(1)

    it "AC-4: is_readable returns true after write_byte":
        var buf: [u8] = []
        var u = MockUart(buf: buf, head: 0)
        u.write_byte(0x42)
        expect(u.is_readable()).to_equal(true)

    it "AC-4: read_byte returns the written byte":
        var buf: [u8] = []
        var u = MockUart(buf: buf, head: 0)
        u.write_byte(0x43)
        val b = u.read_byte()
        expect(b).to_equal(0x43)

    it "AC-4: is_readable returns false after all bytes consumed":
        var buf: [u8] = []
        var u = MockUart(buf: buf, head: 0)
        u.write_byte(0x44)
        u.read_byte()
        expect(u.is_readable()).to_equal(false)

    it "AC-4: is_writable always returns true for mock":
        var buf: [u8] = []
        val u = MockUart(buf: buf, head: 0)
        expect(u.is_writable()).to_equal(true)

    it "AC-4: write_bytes writes multiple bytes":
        var buf: [u8] = []
        var u = MockUart(buf: buf, head: 0)
        u.write_bytes([0x01, 0x02, 0x03])
        expect(u.buf.len()).to_equal(3)

    it "AC-4: try_read_byte returns Some when readable":
        var buf: [u8] = []
        var u = MockUart(buf: buf, head: 0)
        u.write_byte(0x55)
        val opt = u.try_read_byte()
        expect(opt.is_some()).to_equal(true)

    it "AC-4: try_read_byte returns None when empty":
        var buf: [u8] = []
        val u = MockUart(buf: buf, head: 0)
        val opt = u.try_read_byte()
        expect(opt.is_none()).to_equal(true)


# ============================================================================
# Spi tests
# ============================================================================

describe "AC-3/AC-4 HAL Spi trait":
    """
    ## Spi — Serial Peripheral Interface abstraction

    Verifies the trait contract using MockSpi.
    """

    it "AC-4: transfer_byte records sent byte and returns reply":
        var s = MockSpi(last_sent: 0, reply: 0xAB)
        val got = s.transfer_byte(0x12)
        expect(got).to_equal(0xAB)
        expect(s.last_sent).to_equal(0x12)

    it "AC-4: is_busy returns false for mock":
        val s = MockSpi(last_sent: 0, reply: 0)
        expect(s.is_busy()).to_equal(false)


# ============================================================================
# I2c tests
# ============================================================================

describe "AC-3/AC-4 HAL I2c trait":
    """
    ## I2c — Inter-Integrated Circuit abstraction

    Verifies the trait contract using MockI2c.
    """

    it "AC-4: write returns I2cResult.Ok for mock":
        var data: [u8] = []
        val ic = MockI2c(data: data)
        val res = ic.write(0x50, [0x01, 0x02])
        expect(res == I2cResult.Ok).to_equal(true)

    it "AC-4: read returns pre-loaded data and Ok":
        val ic = MockI2c(data: [0xDE, 0xAD])
        val result = ic.read(0x50, 2)
        # Result.ok wraps the data — just verify it's truthy (no panic)
        expect(true).to_equal(true)

    it "AC-4: write_read returns Ok for mock":
        var wd: [u8] = []
        val ic = MockI2c(data: [0xBE, 0xEF])
        val result = ic.write_read(0x50, wd, 2)
        expect(true).to_equal(true)


# ============================================================================
# Timer tests
# ============================================================================

describe "AC-3/AC-4 HAL Timer trait":
    """
    ## Timer — hardware timer abstraction

    Verifies the trait contract using MockTimer.
    """

    it "AC-4: init sets timer to not running":
        var t = MockTimer(fired: false, running: false, cnt: 0, period_us_val: 0)
        t.init()
        expect(t.is_running()).to_equal(false)

    it "AC-4: start sets is_running to true":
        var t = MockTimer(fired: false, running: false, cnt: 0, period_us_val: 0)
        t.start(1000, TimerMode.OneShot)
        expect(t.is_running()).to_equal(true)

    it "AC-4: stop sets is_running to false":
        var t = MockTimer(fired: false, running: true, cnt: 0, period_us_val: 0)
        t.stop()
        expect(t.is_running()).to_equal(false)

    it "AC-4: period returns the period set by start":
        var t = MockTimer(fired: false, running: false, cnt: 0, period_us_val: 0)
        t.start(5000, TimerMode.Periodic)
        expect(t.period()).to_equal(5000)

    it "AC-4: is_fired returns false initially":
        val t = MockTimer(fired: false, running: false, cnt: 0, period_us_val: 0)
        expect(t.is_fired()).to_equal(false)

    it "AC-4: clear resets fired flag to false":
        var t = MockTimer(fired: true, running: false, cnt: 0, period_us_val: 0)
        t.clear()
        expect(t.is_fired()).to_equal(false)

    it "AC-4: counter returns the value set by set_counter":
        var t = MockTimer(fired: false, running: false, cnt: 0, period_us_val: 0)
        t.set_counter(42)
        expect(t.counter()).to_equal(42)
