# Pin Golden Hash — FNV-1a over the demo's deterministic init framebuffer.
#
# Boots a 4×4 representative pattern (Phase 3 §G shared fixture is 4×4).
# Hash is byte-stable across runs for identical inputs (AC-5 contract).
#
# Run via: bin/simple test/util/game2d_pin_golden_hash.spl
# (3-run determinism check — outputs must match exactly).
use std.nogc_sync_mut.game2d.backend.frame_hash.{frame_hash, frame_hash_hex}

fn main():
    # 4×4 representative framebuffer matching test/system/fixtures/game2d_minimal/
    # Pattern: black (0x00000000) with 4 white pixels at corners.
    val fb: [i64] = [
        0xffffffff, 0x00000000, 0x00000000, 0xffffffff,
        0x00000000, 0x00000000, 0x00000000, 0x00000000,
        0x00000000, 0x00000000, 0x00000000, 0x00000000,
        0xffffffff, 0x00000000, 0x00000000, 0xffffffff
    ]
    val h = frame_hash(fb)
    print("frame_hash=0x{h}")
