use os.port.simpleos_multiplatform_build.{simpleos_platform_arch_name, simpleos_platform_target_names, simpleos_platform_qemu_system}

fn main():
    val names = simpleos_platform_target_names()
    print "names: {names.len()}"
    for n in names:
        val aname = simpleos_platform_arch_name(n)
        val qsys = simpleos_platform_qemu_system(n)
        print "  {n}: arch_name={aname} qemu_sys={qsys}"
main()
