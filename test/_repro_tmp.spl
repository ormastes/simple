use os.qemu_runner.{get_all_targets, arch_display_name}

fn main():
    print "calling get_all_targets"
    val targets = get_all_targets()
    print "got targets: {targets.len()}"
    for t in targets:
        val name = arch_display_name(t.arch)
        print "  {name}  ->  {t.target_triple}  ({t.qemu_system})"
main()
