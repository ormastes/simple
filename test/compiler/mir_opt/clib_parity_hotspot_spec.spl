    describe "DB optimization rules in clib_parity_rule_table (AC-5)":
        it "AC-5: database domain has at least 12 rules after DB hardening":
            expect(clib_parity_domain_rule_count("database")).to_be_greater_than(11)

        it "AC-5: match_db_fts_match rule exists with correct fields":
            val maybe_rule = clib_parity_rule_by_name("match_db_fts_match")
            expect(maybe_rule.?).to_equal(true)
            if maybe_rule:
