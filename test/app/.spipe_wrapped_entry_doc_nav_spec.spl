#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.io_runtime.{read_file, file_exists}
use std.ffi.system.{process_run}


fn main():
    # @cover src/app/spipe_docgen/ 80%
    """
    # Documentation Navigation Generation Specification
    
    **Feature IDs:** #1210-1215 (doc navigation generation)
    **Category:** Tooling / Documentation
    **Difficulty:** 3/5
    **Status:** Implemented
    
    ## Overview
    
    Tests that the REAL `bin/simple spipe-docgen` generator produces correct
    documentation with navigation structure from SPipe test files.
    
    Exercises the actual spipe-docgen binary and reads the real generated
    markdown to verify heading hierarchy, metadata tables, scenario counts,
    source references, and cross-navigation links.
    """


    # ============================================================================
    # Real spipe-docgen Execution
    # ============================================================================

    describe "Real spipe-docgen output":

        context "generates markdown for math_render_spec":
            it "runs spipe-docgen successfully":
                val (stdout, stderr, code) = process_run("bin/simple", ["spipe-docgen", "test/feature/usage/math_render_spec.spl"])
                expect code == 0
                expect (stdout).contains("Generated")

            it "creates output file":
                # spipe-docgen generates to doc/spec/ by default
                val exists = file_exists("doc/spec/math_render_spec.md")
                expect exists == true

        context "markdown heading structure":
            it "has H1 title from docstring":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("# Math Block Rendering Specification")

            it "has metadata table with Feature IDs":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Feature IDs")
                expect (md).contains("#1090")

            it "has metadata table with Category":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Category")
                expect (md).contains("Math DSL")

            it "has metadata table with Difficulty":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Difficulty")
                expect (md).contains("3/5")

            it "has metadata table with Status":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Status")
                expect (md).contains("Implemented")

            it "has source file reference":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Source")
                expect (md).contains("math_render_spec.spl")

            it "has date stamp":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Updated")
                expect (md).contains("2026")

            it "has generator attribution":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("spipe-docgen")

        context "scenario summary table":
            it "reports total scenario count":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Total scenarios")
                expect (md).contains("129")

            it "reports active scenarios":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Active scenarios")
                expect (md).contains("129")

            it "reports zero skipped scenarios":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("Skipped scenarios")
                expect (md).contains("0")

        context "overview section from docstring":
            it "includes overview content":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("## Overview")

            it "includes renderer list":
                val md = read_file("doc/spec/math_render_spec.md")
                expect (md).contains("to_text()")
                expect (md).contains("to_debug()")
                expect (md).contains("to_pretty()")
                expect (md).contains("render_latex_raw()")


    # ============================================================================
    # Real spipe-docgen on loss_nograd spec
    # ============================================================================

    describe "Real spipe-docgen for loss_nograd_blocks_spec":

        it "runs spipe-docgen successfully":
            val (stdout, stderr, code) = process_run("bin/simple", ["spipe-docgen", "test/feature/usage/loss_nograd_blocks_spec.spl"])
            expect code == 0

        it "creates output file":
            val exists = file_exists("doc/spec/loss_nograd_blocks_spec.md")
            expect exists == true

        it "has title from docstring":
            val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
            expect (md).contains("loss{}")
            expect (md).contains("nograd{}")

        it "reports 38 scenarios":
            val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
            expect (md).contains("38")

        it "has feature IDs":
            val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
            expect (md).contains("#1099")


    # ============================================================================
    # Real spipe-docgen on math_blocks_spec
    # ============================================================================

    describe "Real spipe-docgen for math_blocks_spec":

        it "runs spipe-docgen successfully":
            val (stdout, stderr, code) = process_run("bin/simple", ["spipe-docgen", "test/feature/usage/math_blocks_spec.spl"])
            expect code == 0

        it "creates output file":
            val exists = file_exists("doc/spec/math_blocks_spec.md")
            expect exists == true

        it "reports 28 scenarios":
            val md = read_file("doc/spec/math_blocks_spec.md")
            expect (md).contains("28")

        it "has tensor operations context":
            val md = read_file("doc/spec/math_blocks_spec.md")
            expect (md).contains("Math Block")


    # ============================================================================
    # Navigation Index Generation
    # ============================================================================

    describe "Doc navigation INDEX.md":

        it "INDEX.md exists in doc/spec":
            val exists = file_exists("doc/spec/INDEX.md")
            expect exists == true

        it "INDEX.md links to math_render_spec":
            val idx = read_file("doc/spec/INDEX.md")
            expect (idx).contains("math_render_spec")

        it "INDEX.md links to loss_nograd_blocks_spec":
            val idx = read_file("doc/spec/INDEX.md")
            expect (idx).contains("loss_nograd_blocks_spec")

        it "INDEX.md links to math_blocks_spec":
            val idx = read_file("doc/spec/INDEX.md")
            expect (idx).contains("math_blocks_spec")


    # ============================================================================
    # Cross-Navigation Consistency
    # ============================================================================

    describe "Cross-navigation between math specs":

        context "consistent metadata across related specs":
            it "all math specs reference the same feature range":
                val render_md = read_file("doc/spec/math_render_spec.md")
                val blocks_md = read_file("doc/spec/math_blocks_spec.md")
                val loss_md = read_file("doc/spec/loss_nograd_blocks_spec.md")
                # All should reference feature IDs in the #1090-1102 range
                expect (render_md).contains("1090")
                expect (loss_md).contains("1099")

            it "all math specs have source file references":
                val render_md = read_file("doc/spec/math_render_spec.md")
                val blocks_md = read_file("doc/spec/math_blocks_spec.md")
                val loss_md = read_file("doc/spec/loss_nograd_blocks_spec.md")
                expect (render_md).contains("Source")
                expect (blocks_md).contains("Source")
                expect (loss_md).contains("Source")

            it "all math specs have date stamps":
                val render_md = read_file("doc/spec/math_render_spec.md")
                val blocks_md = read_file("doc/spec/math_blocks_spec.md")
                val loss_md = read_file("doc/spec/loss_nograd_blocks_spec.md")
                expect (render_md).contains("2026")
                expect (blocks_md).contains("2026")
                expect (loss_md).contains("2026")

        context "scenario counts match test runner":
            it "render spec doc matches test runner count":
                val (stdout, _err, _code) = process_run("bin/simple", ["test", "--list", "test/feature/usage/math_render_spec.spl"])
                val lines = stdout.split("\n")
                var test_count = 0
                for line in lines:
                    if line.contains("math_render_spec.spl") and line.contains(" - "):
                        test_count = test_count + 1
                val md = read_file("doc/spec/math_render_spec.md")
                # Doc should report same count as test runner
                expect (md).contains("{test_count}")

            it "loss_nograd spec doc matches test runner count":
                val (stdout, _err, _code) = process_run("bin/simple", ["test", "--list", "test/feature/usage/loss_nograd_blocks_spec.spl"])
                val lines = stdout.split("\n")
                var test_count = 0
                for line in lines:
                    if line.contains("loss_nograd") and line.contains(" - "):
                        test_count = test_count + 1
                val md = read_file("doc/spec/loss_nograd_blocks_spec.md")
                expect (md).contains("{test_count}")