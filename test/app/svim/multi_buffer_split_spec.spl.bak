# @cover src/lib/editor/core/session.spl 80%
# @cover src/app/svim/buffer_manager.spl 90%
# @cover src/app/svim/split_pane_render.spl 80%
# @cover src/app/svim/session_adapter.spl 70%
"""
svim multi-buffer editing and split pane layout specification

Self-contained tests for buffer manager, split pane layout,
EditSession split/focus implementation, and adapter wiring.
"""

use std.spec.{describe, it, expect}

# ============================================================================
# Inline EditSession for testing (avoids file I/O)
# ============================================================================

use std.editor.core.session.{EditSession, Pane}
use std.editor.view.split_tree.{SplitTree, SplitNode, SplitDirection}
use app.svim.buffer_manager.{buffer_switch_by_name, buffer_switch_by_index, buffer_next, buffer_prev, buffer_list_info}
use app.svim.split_pane_render.{compute_pane_regions, render_pane_status, render_split_layout, PaneRegion}

fn _make_session_with_buffers() -> EditSession:
    """Create an EditSession and add two empty buffers for testing."""
    var s = EditSession.new()
    s.open_empty()
    s.open_empty()
    s

# ============================================================================
# Tests: EditSession split operations (5 tests)
# ============================================================================

describe "EditSession split operations":

    it "starts with one pane":
        val s = EditSession.new()
        expect(s.pane_count()).to_equal(1)

    it "split_editor adds a vertical pane":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor()
        expect(s.pane_count()).to_equal(2)

    it "split_editor_horizontal adds a horizontal pane":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor_horizontal()
        expect(s.pane_count()).to_equal(2)

    it "close_other_groups reduces to one pane":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor()
        s.split_editor_horizontal()
        expect(s.pane_count()).to_equal(3)
        s.close_other_groups()
        expect(s.pane_count()).to_equal(1)

    it "focus_next_group cycles through panes":
        var s = EditSession.new()
        s.open_empty()
        s.open_empty()
        val initial_pane = s.active_pane_id()
        s.split_editor()
        val second_pane = s.active_pane_id()
        # Focus should have moved to the new pane
        expect(second_pane != initial_pane).to_equal(true)
        # Focus next should wrap back
        s.focus_next_group()
        val after_next = s.active_pane_id()
        expect(after_next).to_equal(initial_pane)

# ============================================================================
# Tests: buffer manager (5 tests)
# ============================================================================

describe "buffer manager":

    it "buffer_next switches to next buffer":
        var s = _make_session_with_buffers()
        expect(s.active_index).to_equal(1)
        buffer_next(s)
        expect(s.active_index).to_equal(0)

    it "buffer_prev switches to previous buffer":
        var s = _make_session_with_buffers()
        expect(s.active_index).to_equal(1)
        buffer_prev(s)
        expect(s.active_index).to_equal(0)

    it "buffer_switch_by_index switches to valid index":
        var s = _make_session_with_buffers()
        val ok = buffer_switch_by_index(s, 0)
        expect(ok).to_equal(true)
        expect(s.active_index).to_equal(0)

    it "buffer_switch_by_index rejects invalid index":
        var s = _make_session_with_buffers()
        val ok = buffer_switch_by_index(s, 99)
        expect(ok).to_equal(false)

    it "buffer_list_info contains active marker":
        var s = _make_session_with_buffers()
        val info = buffer_list_info(s)
        expect(info.contains("*")).to_equal(true)
        expect(info.contains("[No Name]")).to_equal(true)

# ============================================================================
# Tests: split pane rendering (4 tests)
# ============================================================================

describe "split pane rendering":

    it "single pane computes one region":
        var s = EditSession.new()
        s.open_empty()
        val regions = compute_pane_regions(s.split_tree(), 80, 24)
        expect(regions.len()).to_equal(1)
        expect(regions[0].width).to_equal(80)
        expect(regions[0].height).to_equal(24)

    it "vertical split computes two regions side by side":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor()
        val regions = compute_pane_regions(s.split_tree(), 80, 24)
        expect(regions.len()).to_equal(2)
        # Left and right regions should not overlap
        val left_end = regions[0].col + regions[0].width
        expect(left_end < regions[1].col or regions[1].col < left_end).to_equal(true)

    it "horizontal split computes two regions stacked":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor_horizontal()
        val regions = compute_pane_regions(s.split_tree(), 80, 24)
        expect(regions.len()).to_equal(2)

    it "render_pane_status shows buffer and pane info":
        var s = EditSession.new()
        s.open_empty()
        val status = render_pane_status(s)
        expect(status.contains("buf 1/1")).to_equal(true)
        expect(status.contains("pane 1/1")).to_equal(true)

# ============================================================================
# Tests: focus direction (4 tests)
# ============================================================================

describe "split focus direction":

    it "focus_direction left moves to prev pane":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor()
        val right_pane = s.active_pane_id()
        s.focus_direction("left", [])
        expect(s.active_pane_id() != right_pane).to_equal(true)

    it "focus_direction right moves to next pane":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor()
        val right_pane = s.active_pane_id()
        s.focus_direction("left", [])
        val left_pane = s.active_pane_id()
        s.focus_direction("right", [])
        expect(s.active_pane_id()).to_equal(right_pane)

    it "focus_prev_group wraps around":
        var s = EditSession.new()
        s.open_empty()
        s.split_editor()
        val pane_after_split = s.active_pane_id()
        s.focus_prev_group()
        s.focus_prev_group()
        expect(s.active_pane_id()).to_equal(pane_after_split)

    it "document_count returns correct count":
        var s = _make_session_with_buffers()
        expect(s.document_count()).to_equal(2)
