#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use app.svim.core.*

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool


fn main():
    # @cover src/app/svim/core.spl 80%
    """
    # svim shared editor core specification
    
    Validates the foundational shared editor core used by host TUI first and
    future shells later. Covers piece-table storage, anchor updates, modal
    commands, registers, splits/tabpages, quickfix flow, and RPC control.
    """


    describe "svim piece table":
        it "applies insert and delete edits without flattening the model":
            var table = PieceTable.from_text("abc")
            table.insert(1, "XY")
            expect table.to_text() == "aXYbc"
            table.delete(2, 4)
            expect table.to_text() == "aXc"


    describe "svim anchors":
        it "moves extmark-like anchors across multiline inserts":
            var tracker = AnchorTracker.new()
            val id = tracker.create(0, 1, true)
            tracker.apply_insert(0, 1, "ZZ\nQ")
            val pos = tracker.get(id)
            expect pos.row == 1
            expect pos.col == 1

        it "clamps anchors into deleted ranges":
            var tracker = AnchorTracker.new()
            val id = tracker.create(2, 5, true)
            tracker.apply_delete(1, 3, 3, 2)
            val pos = tracker.get(id)
            expect pos.row == 1
            expect pos.col == 3


    describe "svim modal editing":
        it "inserts text in insert mode and tracks cursor":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "hello", 1, "")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "hello"
            expect session.current_cursor().col == 5

        it "supports line yank delete and put through registers":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "alpha\nbeta", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            session.execute_named("move-up", "", 1, "")
            session.execute_named("yank-line", "", 1, "\"")
            session.execute_named("move-down", "", 1, "")
            session.execute_named("delete-line", "", 1, "")
            session.execute_named("put-after", "", 1, "\"")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "alpha\nalpha\n"

        it "supports undo and redo for text edits":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "abc", 1, "")
            session.execute_named("undo", "", 1, "")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == ""
            session.execute_named("redo", "", 1, "")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "abc"

        it "supports operator-pending word deletion with counts":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "alpha beta gamma", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            session.execute(svim_parse_normal_command("2dw"))
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "gamma"
            expect session.current_cursor().col == 0

        it "supports operator-pending word yank and text objects":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "alpha beta gamma", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            session.execute(svim_parse_normal_command("2yw"))
            expect session.registers.entries[0].content == "alpha beta "
            session.execute_named("search-forward", "beta", 1, "")
            session.execute(svim_parse_normal_command("diw"))
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "alpha  gamma"


    describe "svim workspace state":
        it "supports split windows over the same buffer":
            var session = SvimSession.new()
            val result = session.execute_named("split-window", "", 1, "")
            expect result.ok == true
            expect session.tabs[session.current_tab_index].window_ids.len() == 2

        it "supports opening a new tabpage from the current buffer":
            var session = SvimSession.new()
            val result = session.execute_named("new-tab", "", 1, "")
            expect result.ok == true
            expect session.tabs.len() == 2

        it "builds quickfix items from diagnostics and jumps to them":
            var session = SvimSession.new()
            val buffer_id = session.active_buffer()?.id ?? BufferId(value: 0)
            session.replace_simple_diagnostics(buffer_id, [0], [0], ["error"], ["boom"])
            expect session.quickfix.items.len() == 1
            val jump = session.jump_to_quickfix(0)
            expect jump.ok == true
            expect jump.message == "boom"

        it "cycles quickfix entries through shared commands and commandline aliases":
            var session = SvimSession.new()
            val buffer_id = session.active_buffer()?.id ?? BufferId(value: 0)
            session.replace_simple_diagnostics(buffer_id, [0, 1], [0, 2], ["error", "warn"], ["boom", "bam"])
            val next = session.execute_named("quickfix-next", "", 1, "")
            expect next.ok == true
            expect session.quickfix.selected_index == 1
            expect session.current_cursor().row == 1
            expect session.current_cursor().col == 2
            val prev = session.execute_commandline("cprev")
            expect prev.ok == true
            expect session.quickfix.selected_index == 0
            expect session.current_cursor().row == 0
            expect session.current_cursor().col == 0

        it "handles rpc snapshot and command requests through the shared session api":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            val cmd = session.handle_rpc_text("1", "svim.command", "insert-text:rpc")
            expect cmd.ok == true
            val snap = session.handle_rpc_text("2", "svim.snapshot", "")
            expect snap.ok == true
            expect (snap.result_json).contains("rpc")

        it "moves the cursor for search-forward commands":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "alpha beta", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            val result = session.execute_named("search-forward", "beta", 1, "")
            expect result.ok == true
            expect session.current_cursor().col == 6

        it "repeats search forward and backward through shared commands and commandline aliases":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "alpha beta alpha", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            session.execute_commandline("search alpha")
            expect session.current_cursor().col == 11
            session.execute(svim_parse_normal_command("N"))
            expect session.current_cursor().col == 0
            session.execute_commandline("next")
            expect session.current_cursor().col == 11

        it "tracks visual selection endpoints in the shared session":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "hello", 1, "")
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-left", "", 2, "")
            expect (session.selection?.end.col ?? -1) == 3
            expect (svim_snapshot_text(session)).contains("selection")

        it "yanks a visual selection into the active register":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "hello", 1, "")
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-left", "", 2, "")
            session.execute_named("yank-line", "", 1, "\"")
            expect session.registers.entries[0].content == "lo"
            expect session.mode_state.mode == SvimMode.Normal

        it "deletes a visual selection through the shared edit path":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "hello", 1, "")
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-left", "", 2, "")
            session.execute_named("delete-line", "", 1, "\"")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "hel"
            expect session.current_cursor().col == 3
            expect session.mode_state.mode == SvimMode.Normal

        it "handles forward visual selections with the same yank and delete semantics":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "hello", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            session.execute_named("move-left", "", 5, "")
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-right", "", 2, "")
            session.execute_named("yank-line", "", 1, "\"")
            expect session.registers.entries[0].content == "he"
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-right", "", 2, "")
            session.execute_named("delete-line", "", 1, "\"")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "llo"
            expect session.current_cursor().col == 0

        it "replaces a visual selection with register content on put":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "hello", 1, "")
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-left", "", 2, "")
            session.execute_named("yank-line", "", 1, "\"")
            session.execute_named("move-left", "", 3, "")
            session.execute_named("set-mode", "visual", 1, "")
            session.execute_named("move-right", "", 2, "")
            session.execute_named("put-after", "", 1, "\"")
            expect (session.active_buffer()?.piece_table.to_text() ?? "") == "lollo"
            expect session.current_cursor().col == 2
            expect session.mode_state.mode == SvimMode.Normal

        it "supports jump-back after a search move":
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "alpha beta", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            session.execute_named("search-forward", "beta", 1, "")
            session.execute_named("jump-back", "", 1, "")
            expect session.current_cursor().col == 0

        it "cycles between buffers through shared commands":
            var session = SvimSession.new()
            val second = session.open_text("/tmp/second.txt", "two")
            session.focus_buffer(second)
            expect (session.active_buffer()?.path ?? "") == "/tmp/second.txt"
            session.execute_named("next-buffer", "", 1, "")
            expect (session.active_buffer()?.path ?? "") == ""

        it "saves a buffer to disk and reopens it through the shared session":
            val path = "/tmp/svim_core_spec_save.txt"
            val _ = rt_file_delete(path)
            var session = SvimSession.new()
            session.execute_named("set-mode", "insert", 1, "")
            session.execute_named("insert-text", "saved from spec", 1, "")
            session.execute_named("set-mode", "normal", 1, "")
            val saved = session.execute_named("save-as", path, 1, "")
            expect saved.ok == true
            expect rt_file_read_text(path) == "saved from spec"
            var reopened = SvimSession.new()
            val opened = reopened.open_path(path)
            expect opened.ok == true
            expect (reopened.active_buffer()?.piece_table.to_text() ?? "") == "saved from spec"
            val _cleanup = rt_file_delete(path)

    describe "svim normal command parser":
        it "parses count-aware motions":
            val cmd = svim_parse_normal_command("3j")
            expect cmd.name == "move-down"
            expect cmd.count == 3

        it "parses shorthand editor commands":
            expect svim_parse_normal_command("dd").name == "delete-line"
            expect svim_parse_normal_command(":w").name == "commandline"
            expect svim_parse_normal_command("/term").payload == "term"
            expect svim_parse_normal_command("v").payload == "visual"
            expect svim_parse_normal_command("bn").name == "next-buffer"
            expect svim_parse_normal_command("ctrl-o").name == "jump-back"
            expect svim_parse_normal_command("y").name == "yank-line"
            expect svim_parse_normal_command("p").name == "put-after"
            expect svim_parse_normal_command("]q").name == "quickfix-next"
            expect svim_parse_normal_command("[q").name == "quickfix-prev"
            expect svim_parse_normal_command("n").name == "search-next"
            expect svim_parse_normal_command("N").name == "search-prev"
            expect svim_parse_normal_command("2dw").name == "delete-motion"
            expect svim_parse_normal_command("2dw").count == 2
            expect svim_parse_normal_command("2dw").payload == "word"
            expect svim_parse_normal_command("d2w").count == 2
            expect svim_parse_normal_command("diw").name == "delete-text-object"
            expect svim_parse_normal_command("yaw").payload == "aw"