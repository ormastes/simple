## Source-contract spec for ui.web route command dispatch.
##
## The previous runtime-heavy version drifted from the current taskbar launch
## contract and also hit the trailing teardown semantic failure on this route
## surface. Keep this file focused on the route wiring itself.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val UI_ROUTES_PATH = "src/app/ui.web/ui_routes.spl"
val HOST_ADAPTER_CONTRACT_PATH = "src/app/ui.web/host_adapter_contract.spl"

fn _read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "ui_routes window_cmd dispatch contracts":
    it "routes websocket window_cmd payloads through WmBridge":
        val source = _read_source(UI_ROUTES_PATH)
        expect(source).to_contain("fn _handle_window_cmd(frame: text, session: UISession, session_id: text, out: BoundedChannel<text>):")
        expect(source).to_contain("val payload = _extract_object(frame, \"payload\")")
        expect(source).to_contain("val bridge = WmBridge.new(session)")
        expect(source).to_contain("val result = bridge.handle_window_cmd(cmd_kind, payload)")

    it "drains host taskbar client frames after successful commands":
        val source = _read_source(UI_ROUTES_PATH)
        expect(source).to_contain("if host_taskbar_runtime_is_enabled():")
        expect(source).to_contain("for client_frame in host_taskbar_runtime_take_client_frames(session_id):")
        expect(source).to_contain("out.send(client_frame)")

    it "keeps resume parsing and nested payload extraction on local helper paths":
        val source = _read_source(UI_ROUTES_PATH)
        expect(source).to_contain("val rev: u64 = if rev_str == \"\": 0 else: _parse_u64(rev_str)")
        expect(source).to_contain("fn _extract_object(json: text, field: text) -> text:")
        expect(source).to_contain("fn _find_from(haystack: text, needle: text, start: i64) -> i64:")

    it "preserves the native_event feedback frame contract":
        val source = _read_source(HOST_ADAPTER_CONTRACT_PATH)
        expect(source).to_contain("val HOST_NATIVE_EVENT_SOURCE: text = \"native_event\"")
        expect(source).to_contain("fn native_feedback_window_cmd_frame_to_json(")
        expect(source).to_contain("val base = ")
        expect(source).to_contain("HOST_NATIVE_EVENT_SOURCE")
