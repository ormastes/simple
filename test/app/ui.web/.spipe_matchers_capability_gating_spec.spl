use std.spec
use app.ui.web.origin_guard.{OriginGuard}
use app.ui.web.session_token.{SessionToken}
use common.ui.capability.{Capability}
use common.ui.capability_policy.{CapabilityPolicy, check_capability, grant}

describe "OriginGuard.check":
    it "allows a matching origin":
        val guard = OriginGuard(allowed: ["https://app.example.com"])
        val headers = "Origin: https://app.example.com\r\nHost: app.example.com\r\n"
        val result = guard.check(headers)
        expect result.is_ok() == true

describe "SessionToken":
    it "serializes a token with the grant id":
        val tok = SessionToken.issue("dev", "https://app.example.com", 60000u64, "test-secret-key")
        expect tok.serialize().contains(".dev.") == true

    it "percent-encodes dots in the serialized origin segment":
        val tok = SessionToken.issue("dev", "https://app.example.com", 60000u64, "test-secret-key")
        expect tok.serialize().contains("%2E") == true

describe "CapabilityPolicy":
    it "default-deny policy denies InputInject":
        val policy = CapabilityPolicy.new("win-1")
        val result = check_capability(policy, Capability.InputInject)
        expect result.is_err() == true

    it "granting InputInject allows it":
        val policy = CapabilityPolicy.new("win-1")
        val granted_policy = grant(policy, Capability.InputInject)
        val result = check_capability(granted_policy, Capability.InputInject)
        expect result.is_ok() == true