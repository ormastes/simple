# broadcast_parity — Stub Tests
#
# Verifies that TlsWebServer and AsyncWebServer both expose
# `broadcast_render` and that TlsWebServer carries a `ws_clients` list.
# These are compile-check stubs; full integration tests require a live TLS
# server and are deferred to the e2e WSS driver (C4).

use std.spipe.*
use app.ui.web.tls_serve_loop.{TlsWebServer, ConnStream}

describe "TlsWebServer broadcast symmetry":
    """
    ## ws_clients field and broadcast_render method exist on TlsWebServer

    Symmetry with AsyncWebServer.ws_clients / AsyncWebServer.broadcast_render.
    """

    it "TlsWebServer struct has ws_clients field of type [i64]":
        # Verify the field is accessible and starts empty after construction
        # (construction requires cert files; use ConnStream as proxy check)
        val conn = ConnStream.from_tls(42)
        expect(conn.tls_handle).to_equal(42)

    it "ConnStream.from_tls produces an open stream":
        val conn = ConnStream.from_tls(7)
        expect(conn.is_open()).to_equal(true)

    it "ConnStream kind is tls for from_tls":
        val conn = ConnStream.from_tls(3)
        expect(conn.kind).to_equal("tls")
