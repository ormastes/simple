## Spec for shared host adapter contract types.
##
## Verifies the host_window_command wire payload consumed by both SimpleWeb
## and ElectronWeb adapter implementations.

use std.spec
use app.ui.web.host_adapter_contract.{HOST_NATIVE_EVENT_SOURCE, HostWindowCommand, host_window_command_to_json}

describe "host_adapter_contract":
    it "defines canonical native feedback source":
        expect(HOST_NATIVE_EVENT_SOURCE).to_equal("native_event")

    it "serializes host window commands with canonical fields":
        val cmd = HostWindowCommand(
            action: "spawn_native_window",
            window_id: "host-window-1",
            surface_id: "host-surface-1",
            app_id: "/sys/apps/terminal",
            title: "Terminal",
            url: "/wm/native_window?app_id=%2Fsys%2Fapps%2Fterminal",
            x: 10,
            y: 20,
            width: 640,
            height: 420
        )
        val json = host_window_command_to_json(cmd)
        expect(json.contains("\"action\":\"spawn_native_window\"")).to_equal(true)
        expect(json.contains("\"window_id\":\"host-window-1\"")).to_equal(true)
        expect(json.contains("\"surface_id\":\"host-surface-1\"")).to_equal(true)
        expect(json.contains("\"app_id\":\"/sys/apps/terminal\"")).to_equal(true)
        expect(json.contains("\"width\":640")).to_equal(true)
        expect(json.contains("\"height\":420")).to_equal(true)

    it "escapes host command string fields":
        val cmd = HostWindowCommand(
            action: "set_native_window_title",
            window_id: "w\"1",
            surface_id: "s\\1",
            app_id: "app\nid",
            title: "Title \"One\"",
            url: "/wm/native_window?title=Line\nBreak",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        )
        val json = host_window_command_to_json(cmd)
        expect(json.contains("w\\\"1")).to_equal(true)
        expect(json.contains("s\\\\1")).to_equal(true)
        expect(json.contains("app\\nid")).to_equal(true)
        expect(json.contains("Title \\\"One\\\"")).to_equal(true)
        expect(json.contains("Line\\nBreak")).to_equal(true)
