## Spec for shared host adapter contract types.
##
## Verifies the host_window_command wire payload consumed by both SimpleWeb
## and ElectronWeb adapter implementations.

use std.spec
use app.ui.web.host_adapter_contract.{
    HOST_NATIVE_EVENT_SOURCE,
    HostWindowCommand,
    host_window_command_to_json,
    host_window_command_contract_fixture,
    host_window_command_contract_golden_json,
    native_feedback_window_cmd_payload_to_json,
    native_feedback_window_cmd_frame_to_json
}

describe "host_adapter_contract":
    it "defines canonical native feedback source":
        expect(HOST_NATIVE_EVENT_SOURCE).to_equal("native_event")

    it "serializes host window commands with canonical fields":
        val cmd = host_window_command_contract_fixture()
        val json = host_window_command_to_json(cmd)
        expect(json).to_equal(host_window_command_contract_golden_json())

    it "escapes host command string fields":
        val cmd = HostWindowCommand(
            action: "set_native_window_title",
            window_id: "w\"1",
            surface_id: "s\\1",
            app_id: "app\nid",
            title: "Title \"One\"",
            url: "/wm/native_window?title=Line\nBreak",
            x: 0,
            y: 0,
            width: 0,
            height: 0
        )
        val json = host_window_command_to_json(cmd)
        expect(json).to_equal("{\"action\":\"set_native_window_title\",\"window_id\":\"w\\\"1\",\"surface_id\":\"s\\\\1\",\"app_id\":\"app\\nid\",\"title\":\"Title \\\"One\\\"\",\"url\":\"/wm/native_window?title=Line\\nBreak\",\"x\":0,\"y\":0,\"width\":0,\"height\":0}")

    it "serializes native feedback window_cmd frames with canonical source":
        expect(native_feedback_window_cmd_frame_to_json("sess-native", "focus", "host-window-7", "", 0, 0, 0, 0)).to_equal("{\"t\":\"window_cmd\",\"v\":1,\"s\":\"sess-native\",\"seq\":null,\"payload\":{\"cmd_type\":\"focus\",\"kind\":\"focus\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\"}}")
        expect(native_feedback_window_cmd_payload_to_json("minimize", "host-window-7", "", 0, 0, 0, 0)).to_equal("{\"cmd_type\":\"minimize\",\"kind\":\"minimize\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\"}")
        expect(native_feedback_window_cmd_payload_to_json("restore", "host-window-7", "", 0, 0, 0, 0)).to_equal("{\"cmd_type\":\"restore\",\"kind\":\"restore\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\"}")
        expect(native_feedback_window_cmd_payload_to_json("maximize", "host-window-7", "", 0, 0, 0, 0)).to_equal("{\"cmd_type\":\"maximize\",\"kind\":\"maximize\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\"}")
        expect(native_feedback_window_cmd_payload_to_json("unmaximize", "host-window-7", "", 0, 0, 0, 0)).to_equal("{\"cmd_type\":\"unmaximize\",\"kind\":\"unmaximize\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\"}")
        expect(native_feedback_window_cmd_payload_to_json("move", "host-window-7", "", 11, 22, 0, 0)).to_equal("{\"cmd_type\":\"move\",\"kind\":\"move\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\",\"x\":11,\"y\":22}")
        expect(native_feedback_window_cmd_payload_to_json("resize", "host-window-7", "", 0, 0, 333, 444)).to_equal("{\"cmd_type\":\"resize\",\"kind\":\"resize\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\",\"w\":333,\"h\":444}")
        expect(native_feedback_window_cmd_payload_to_json("set_title", "host-window-7", "Native \"Title\"", 0, 0, 0, 0)).to_equal("{\"cmd_type\":\"set_title\",\"kind\":\"set_title\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\",\"title\":\"Native \\\"Title\\\"\"}")
        expect(native_feedback_window_cmd_payload_to_json("close", "host-window-7", "", 0, 0, 0, 0)).to_equal("{\"cmd_type\":\"close\",\"kind\":\"close\",\"window_id_hint\":\"host-window-7\",\"source\":\"native_event\"}")
