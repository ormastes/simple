## Spec for the host taskbar runtime.
##
## Verifies:
##   * embedded launch opens a SimpleWeb surface and emits taskbar state
##   * minimize/restore update the authoritative taskbar frame
##   * native launch queues a native-window command instead of opening a surface
##   * hidden_taskbar shares native-window behavior while hiding Simple taskbar chrome

use std.spec
use common.ui.session.{UISession}
use common.ui.window_surface_registry.{UI_SURFACE_KIND_SIMPLE_WEB, UI_SURFACE_KIND_ELECTRON, UI_SURFACE_KIND_HEADLESS}
use common.ui.builder.{column, label, build_tree_with_title}
use common.ui.taskbar_model.{AppRef, TrayItem}
use app.ui.web.taskbar_runtime.{
    host_taskbar_runtime_reset,
    host_taskbar_runtime_enable,
    host_taskbar_runtime_mode_name,
    host_taskbar_runtime_hides_desktop,
    host_taskbar_runtime_hides_taskbar,
    host_taskbar_runtime_adapter_capabilities,
    host_taskbar_runtime_save_layout,
    host_taskbar_runtime_clear_persisted_layout,
    host_taskbar_runtime_mark_persisted_layout_corrupt_for_test,
    host_taskbar_runtime_catalog,
    host_taskbar_runtime_launch,
    host_taskbar_runtime_native_window_html,
    host_taskbar_runtime_focus,
    host_taskbar_runtime_move,
    host_taskbar_runtime_minimize,
    host_taskbar_runtime_maximize,
    host_taskbar_runtime_unmaximize,
    host_taskbar_runtime_resize,
    host_taskbar_runtime_restore,
    host_taskbar_runtime_close,
    host_taskbar_runtime_set_title,
    host_taskbar_runtime_taskbar_frame,
    host_taskbar_runtime_take_client_frames
}
use examples.hello_taskbar.app_manifest.{APP_ID}

fn _session() -> UISession:
    val tree = build_tree_with_title(
        column("main_root", [label("main_label", "root")]),
        "Main",
        "glass_dark"
    )
    UISession.new(tree)

describe "taskbar_runtime desktop_embedded":
    it "reports embedded adapter capabilities":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("embedded", true)
        val caps = host_taskbar_runtime_adapter_capabilities()
        expect(host_taskbar_runtime_mode_name()).to_equal("embedded")
        expect(host_taskbar_runtime_hides_desktop()).to_equal(false)
        expect(host_taskbar_runtime_hides_taskbar()).to_equal(false)
        expect(caps.supports_native_windows).to_equal(false)
        expect(caps.supports_embedded_surfaces).to_equal(true)
        expect(caps.supports_headless_session).to_equal(false)
        expect(caps.requires_js_host_bridge).to_equal(true)

    it "keeps desktop_embedded as a legacy alias":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", true)
        expect(host_taskbar_runtime_mode_name()).to_equal("desktop_embedded")
        expect(host_taskbar_runtime_hides_desktop()).to_equal(false)

    it "launches the demo app into a SimpleWeb surface":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, APP_ID)
        expect(result.is_ok()).to_equal(true)
        expect(session.has_surface("host-surface-1")).to_equal(true)
        expect(session.window_surfaces.len()).to_equal(1)
        val frames = host_taskbar_runtime_take_client_frames("sess-simpleweb")
        expect(frames.len()).to_equal(0)

    it "reports minimized state in the taskbar frame":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val _ = host_taskbar_runtime_launch(session, APP_ID)
        val _ = host_taskbar_runtime_minimize(session, "host-surface-1")
        val minimized = host_taskbar_runtime_taskbar_frame("sess-1", session)
        expect(minimized.contains("\"minimized\":true")).to_equal(true)
        val _ = host_taskbar_runtime_restore(session, "host-surface-1")
        val restored = host_taskbar_runtime_taskbar_frame("sess-1", session)
        expect(restored.contains("\"minimized\":false")).to_equal(true)

    it "exposes manifest-backed apps as pinned taskbar items":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val frame = host_taskbar_runtime_taskbar_frame("sess-pinned", session)
        expect(frame.contains("\"app_id\":\"examples/hello_taskbar\"")).to_equal(true)
        expect(frame.contains("\"app_id\":\"/sys/apps/terminal\"")).to_equal(true)
        expect(frame.contains("\"display_name\":\"Terminal\"")).to_equal(true)

    it "rejects unknown app ids":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, "missing.app")
        expect(result.is_err()).to_equal(true)

describe "taskbar_runtime app catalog":
    it "includes built-in desktop manifests":
        val apps = host_taskbar_runtime_catalog()
        var found_terminal = false
        for app in apps:
            if app.app_id == "/sys/apps/terminal":
                found_terminal = true
                expect(app.display_name).to_equal("Terminal")
                expect(app.icon).to_equal("term")
        expect(found_terminal).to_equal(true)

    it "resolves native window html for supported apps":
        val html = host_taskbar_runtime_native_window_html(APP_ID)
        expect(html == nil).to_equal(false)
        expect(html.unwrap().contains("Hello from the taskbar shell")).to_equal(true)

    it "resolves generic native window html for built-in desktop manifests":
        val html = host_taskbar_runtime_native_window_html("/sys/apps/terminal")
        expect(html == nil).to_equal(false)
        expect(html.unwrap().contains("<h1>Terminal</h1>")).to_equal(true)
        expect(html.unwrap().contains("Host terminal surface ready")).to_equal(true)
        expect(html.unwrap().contains("/sys/apps/terminal")).to_equal(true)

    it "returns an unsupported host content page for manifests without hooks":
        val html = host_taskbar_runtime_native_window_html("/sys/apps/editor")
        expect(html == nil).to_equal(false)
        expect(html.unwrap().contains("This app has no host content hook yet.")).to_equal(true)
        expect(html.unwrap().contains("Unsupported host content")).to_equal(true)

    it "returns nil for unsupported native window apps":
        val html = host_taskbar_runtime_native_window_html("missing.app")
        expect(html == nil).to_equal(true)

describe "taskbar_runtime persisted layout":
    it "loads defaults when no persisted layout store exists":
        host_taskbar_runtime_clear_persisted_layout()
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val frame = host_taskbar_runtime_taskbar_frame("sess-default-layout", session)
        expect(frame.contains("\"app_id\":\"/sys/apps/terminal\"")).to_equal(true)
        expect(frame.contains("\"item_id\":\"host-runtime\"")).to_equal(true)

    it "saves pinned order and tray state across runtime reset":
        host_taskbar_runtime_clear_persisted_layout()
        val saved = host_taskbar_runtime_save_layout(
            [
                AppRef(app_id: "/sys/apps/settings", display_name: "Settings", icon: "settings"),
                AppRef(app_id: "/sys/apps/terminal", display_name: "Terminal", icon: "term")
            ],
            [TrayItem(item_id: "net", label: "online", icon: "net")]
        )
        expect(saved.is_ok()).to_equal(true)
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val frame = host_taskbar_runtime_taskbar_frame("sess-saved-layout", session)
        val settings_idx = frame.index_of("\"app_id\":\"/sys/apps/settings\"") ?? -1
        val terminal_idx = frame.index_of("\"app_id\":\"/sys/apps/terminal\"") ?? -1
        expect(settings_idx).to_be_less_than(terminal_idx)
        expect(frame.contains("\"item_id\":\"net\"")).to_equal(true)
        expect(frame.contains("\"item_id\":\"host-runtime\"")).to_equal(false)
        host_taskbar_runtime_clear_persisted_layout()

    it "rejects corrupt saved layouts before they become runtime state":
        host_taskbar_runtime_clear_persisted_layout()
        val saved = host_taskbar_runtime_save_layout(
            [
                AppRef(app_id: "/sys/apps/terminal", display_name: "Terminal", icon: "term"),
                AppRef(app_id: "/sys/apps/terminal", display_name: "Terminal Again", icon: "term")
            ],
            []
        )
        expect(saved.is_err()).to_equal(true)
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val frame = host_taskbar_runtime_taskbar_frame("sess-rejected-layout", session)
        expect(frame.contains("\"app_id\":\"/sys/apps/settings\"")).to_equal(true)
        host_taskbar_runtime_clear_persisted_layout()

    it "falls back to defaults when the persisted layout store is corrupt":
        host_taskbar_runtime_clear_persisted_layout()
        val saved = host_taskbar_runtime_save_layout(
            [AppRef(app_id: "/sys/apps/settings", display_name: "Settings", icon: "settings")],
            [TrayItem(item_id: "net", label: "online", icon: "net")]
        )
        expect(saved.is_ok()).to_equal(true)
        host_taskbar_runtime_mark_persisted_layout_corrupt_for_test()
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val frame = host_taskbar_runtime_taskbar_frame("sess-corrupt-layout", session)
        expect(frame.contains("\"app_id\":\"/sys/apps/terminal\"")).to_equal(true)
        expect(frame.contains("\"item_id\":\"host-runtime\"")).to_equal(true)
        expect(frame.contains("\"item_id\":\"net\"")).to_equal(false)
        host_taskbar_runtime_clear_persisted_layout()

    it "launches built-in desktop manifests into embedded surfaces":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, "/sys/apps/terminal")
        expect(result.is_ok()).to_equal(true)
        expect(session.has_surface("host-surface-1")).to_equal(true)
        val binding = session.window_surfaces.for_surface("host-surface-1")
        expect(binding == nil).to_equal(false)
        expect(binding.app_id).to_equal("/sys/apps/terminal")
        expect(binding.title).to_equal("Terminal")
        val frames = host_taskbar_runtime_take_client_frames("sess-terminal-simpleweb")
        expect(frames.len()).to_equal(0)

    it "smokes SimpleWeb no-native launches for demo and terminal apps":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("desktop_embedded", false)
        val session = _session()
        val demo = host_taskbar_runtime_launch(session, APP_ID)
        val terminal = host_taskbar_runtime_launch(session, "/sys/apps/terminal")
        expect(demo.is_ok()).to_equal(true)
        expect(terminal.is_ok()).to_equal(true)
        expect(session.has_surface("host-surface-1")).to_equal(true)
        expect(session.has_surface("host-surface-2")).to_equal(true)
        expect(session.window_surfaces.len()).to_equal(2)
        val frames = host_taskbar_runtime_take_client_frames("sess-no-native")
        expect(frames.len()).to_equal(0)

describe "taskbar_runtime headless":
    it "reports headless adapter capabilities":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("headless", true)
        val caps = host_taskbar_runtime_adapter_capabilities()
        expect(host_taskbar_runtime_hides_desktop()).to_equal(true)
        expect(host_taskbar_runtime_hides_taskbar()).to_equal(false)
        expect(caps.supports_native_windows).to_equal(false)
        expect(caps.supports_embedded_surfaces).to_equal(false)
        expect(caps.supports_headless_session).to_equal(true)
        expect(caps.requires_js_host_bridge).to_equal(false)

    it "records launch state without opening a local surface or native window":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("headless", false)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, APP_ID)
        expect(result.is_ok()).to_equal(true)
        expect(session.has_surface("host-surface-1")).to_equal(false)
        expect(session.window_surfaces.len()).to_equal(1)
        val binding = session.window_surfaces.for_surface("host-surface-1")
        expect(binding == nil).to_equal(false)
        expect(binding.surface_kind).to_equal(UI_SURFACE_KIND_HEADLESS)
        val frames = host_taskbar_runtime_take_client_frames("sess-headless")
        expect(frames.len()).to_equal(0)
        val taskbar = host_taskbar_runtime_taskbar_frame("sess-headless", session)
        expect(taskbar.contains("\"window_id\":\"host-window-1\"")).to_equal(true)
        expect(taskbar.contains("\"app_id\":\"examples/hello_taskbar\"")).to_equal(true)

describe "taskbar_runtime taskbar_only":
    it "launches GUI apps across embedded native and hidden_taskbar host modes":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("embedded", true)
        val embedded_session = _session()
        val embedded = host_taskbar_runtime_launch(embedded_session, APP_ID)
        expect(embedded.is_ok()).to_equal(true)
        val embedded_binding = embedded_session.window_surfaces.for_surface("host-surface-1")
        expect(embedded_binding == nil).to_equal(false)
        expect(embedded_binding.surface_kind).to_equal(UI_SURFACE_KIND_SIMPLE_WEB)
        expect(host_taskbar_runtime_take_client_frames("host-smoke-embedded").len()).to_equal(0)

        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("native", true)
        val native_session = _session()
        val native = host_taskbar_runtime_launch(native_session, APP_ID)
        expect(native.is_ok()).to_equal(true)
        val native_binding = native_session.window_surfaces.for_surface("host-surface-1")
        expect(native_binding == nil).to_equal(false)
        expect(native_binding.surface_kind).to_equal(UI_SURFACE_KIND_ELECTRON)
        val native_frames = host_taskbar_runtime_take_client_frames("host-smoke-native")
        expect(native_frames.len()).to_equal(1)
        expect(native_frames[0].contains("\"spawn_native_window\"")).to_equal(true)

        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("hidden_taskbar", true)
        val hidden_session = _session()
        val hidden = host_taskbar_runtime_launch(hidden_session, APP_ID)
        expect(hidden.is_ok()).to_equal(true)
        expect(host_taskbar_runtime_hides_taskbar()).to_equal(true)
        val hidden_binding = hidden_session.window_surfaces.for_surface("host-surface-1")
        expect(hidden_binding == nil).to_equal(false)
        expect(hidden_binding.surface_kind).to_equal(UI_SURFACE_KIND_ELECTRON)
        val hidden_frames = host_taskbar_runtime_take_client_frames("host-smoke-hidden")
        expect(hidden_frames.len()).to_equal(1)
        expect(hidden_frames[0].contains("\"spawn_native_window\"")).to_equal(true)

    it "reports native adapter capabilities":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("native", true)
        val caps = host_taskbar_runtime_adapter_capabilities()
        expect(host_taskbar_runtime_mode_name()).to_equal("native")
        expect(host_taskbar_runtime_hides_desktop()).to_equal(true)
        expect(host_taskbar_runtime_hides_taskbar()).to_equal(false)
        expect(caps.supports_native_windows).to_equal(true)
        expect(caps.supports_embedded_surfaces).to_equal(false)
        expect(caps.supports_headless_session).to_equal(false)
        expect(caps.requires_js_host_bridge).to_equal(true)

    it "keeps taskbar_only as a legacy alias":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("taskbar_only", true)
        expect(host_taskbar_runtime_mode_name()).to_equal("taskbar_only")
        expect(host_taskbar_runtime_hides_desktop()).to_equal(true)
        expect(host_taskbar_runtime_hides_taskbar()).to_equal(false)

    it "supports hidden_taskbar as native windows without Simple taskbar chrome":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("hidden_taskbar", true)
        val caps = host_taskbar_runtime_adapter_capabilities()
        expect(host_taskbar_runtime_mode_name()).to_equal("hidden_taskbar")
        expect(host_taskbar_runtime_hides_desktop()).to_equal(true)
        expect(host_taskbar_runtime_hides_taskbar()).to_equal(true)
        expect(caps.supports_native_windows).to_equal(true)
        expect(caps.supports_embedded_surfaces).to_equal(false)

    it "surfaces launch errors in the taskbar frame":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("taskbar_only", false)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, APP_ID)
        expect(result.is_err()).to_equal(true)
        val taskbar = host_taskbar_runtime_taskbar_frame("sess-launch-error", session)
        expect(taskbar.contains("\"launch_errors\"")).to_equal(true)
        expect(taskbar.contains("\"app_id\":\"examples/hello_taskbar\"")).to_equal(true)
        expect(taskbar.contains("native-window capable host adapter")).to_equal(true)

    it "queues a native-window spawn command":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("taskbar_only", true)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, APP_ID)
        expect(result.is_ok()).to_equal(true)
        expect(session.has_surface("host-surface-1")).to_equal(false)
        expect(session.window_surfaces.len()).to_equal(1)
        expect(session.active_surface()).to_equal("host-surface-1")
        val frames = host_taskbar_runtime_take_client_frames("sess-2")
        expect(frames.len()).to_equal(1)
        expect(frames[0].contains("\"spawn_native_window\"")).to_equal(true)
        expect(frames[0].contains("/wm/native_window")).to_equal(true)

    it "queues native windows for built-in desktop manifests":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("taskbar_only", true)
        val session = _session()
        val result = host_taskbar_runtime_launch(session, "/sys/apps/terminal")
        expect(result.is_ok()).to_equal(true)
        expect(session.has_surface("host-surface-1")).to_equal(false)
        val binding = session.window_surfaces.for_surface("host-surface-1")
        expect(binding == nil).to_equal(false)
        expect(binding.surface_kind).to_equal(UI_SURFACE_KIND_ELECTRON)
        expect(binding.app_id).to_equal("/sys/apps/terminal")
        val frames = host_taskbar_runtime_take_client_frames("sess-manifest")
        expect(frames.len()).to_equal(1)
        expect(frames[0].contains("\"spawn_native_window\"")).to_equal(true)
        expect(frames[0].contains("app_id=%2Fsys%2Fapps%2Fterminal")).to_equal(true)
        expect(frames[0].contains("\"title\":\"Terminal\"")).to_equal(true)

    it "queues native lifecycle commands":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("taskbar_only", true)
        val session = _session()
        val _ = host_taskbar_runtime_launch(session, APP_ID)
        val _ = host_taskbar_runtime_take_client_frames("sess-3")

        val _ = host_taskbar_runtime_minimize(session, "host-surface-1")
        val minimize_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(minimize_frames.len()).to_equal(1)
        expect(minimize_frames[0].contains("\"minimize_native_window\"")).to_equal(true)

        val _ = host_taskbar_runtime_restore(session, "host-surface-1")
        val restore_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(restore_frames.len()).to_equal(1)
        expect(restore_frames[0].contains("\"restore_native_window\"")).to_equal(true)

        val _ = host_taskbar_runtime_focus(session, "host-surface-1")
        val focus_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(focus_frames.len()).to_equal(1)
        expect(focus_frames[0].contains("\"focus_native_window\"")).to_equal(true)

        val _ = host_taskbar_runtime_move(session, "host-surface-1", 12, 34)
        val move_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(move_frames.len()).to_equal(1)
        expect(move_frames[0].contains("\"move_native_window\"")).to_equal(true)
        expect(move_frames[0].contains("\"x\":12")).to_equal(true)
        expect(move_frames[0].contains("\"y\":34")).to_equal(true)

        val _ = host_taskbar_runtime_resize(session, "host-surface-1", 900, 700)
        val resize_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(resize_frames.len()).to_equal(1)
        expect(resize_frames[0].contains("\"resize_native_window\"")).to_equal(true)
        expect(resize_frames[0].contains("\"width\":900")).to_equal(true)
        expect(resize_frames[0].contains("\"height\":700")).to_equal(true)

        val _ = host_taskbar_runtime_maximize(session, "host-surface-1")
        val maximize_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(maximize_frames.len()).to_equal(1)
        expect(maximize_frames[0].contains("\"maximize_native_window\"")).to_equal(true)

        val _ = host_taskbar_runtime_unmaximize(session, "host-surface-1")
        val unmaximize_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(unmaximize_frames.len()).to_equal(1)
        expect(unmaximize_frames[0].contains("\"unmaximize_native_window\"")).to_equal(true)

        val _ = host_taskbar_runtime_set_title(session, "host-surface-1", "Renamed")
        val title_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(title_frames.len()).to_equal(1)
        expect(title_frames[0].contains("\"set_native_window_title\"")).to_equal(true)
        expect(title_frames[0].contains("\"title\":\"Renamed\"")).to_equal(true)

        val _ = host_taskbar_runtime_close(session, "host-surface-1")
        val close_frames = host_taskbar_runtime_take_client_frames("sess-3")
        expect(close_frames.len()).to_equal(1)
        expect(close_frames[0].contains("\"close_native_window\"")).to_equal(true)
