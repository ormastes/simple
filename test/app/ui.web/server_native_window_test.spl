## Spec for ui.web native-window route helpers.
##
## Verifies manifest-backed app ids survive URL encoding in /wm/native_window.

use std.spec
use app.ui.web.server.{_native_window_html, _query_value}

describe "ui.web server native window route":
    it "decodes encoded app_id query values":
        val path = "/wm/native_window?app_id=%2Fsys%2Fapps%2Fterminal&surface_id=host-surface-1"
        expect(_query_value(path, "app_id")).to_equal("/sys/apps/terminal")

    it "decodes lowercase escapes and plus spaces":
        val path = "/wm/native_window?app_id=%2fsys%2fapps%2fterminal+demo&title=Hello%3dWorld"
        expect(_query_value(path, "app_id")).to_equal("/sys/apps/terminal demo")
        expect(_query_value(path, "title")).to_equal("Hello=World")

    it "serves manifest-backed native window html from encoded app ids":
        val path = "/wm/native_window?app_id=%2Fsys%2Fapps%2Fterminal&surface_id=host-surface-1"
        val html = _native_window_html(path)
        expect(html.contains("<h1>Terminal</h1>")).to_equal(true)
        expect(html.contains("/sys/apps/terminal")).to_equal(true)

    it "returns unsupported html for unknown app ids":
        val path = "/wm/native_window?app_id=missing.app"
        val html = _native_window_html(path)
        expect(html.contains("Unsupported app")).to_equal(true)
        expect(html.contains("missing.app")).to_equal(true)
