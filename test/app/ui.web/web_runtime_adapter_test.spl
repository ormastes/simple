## Source-contract spec for WebRuntimeAdapter taskbar-model emission.
##
## The prior runtime-oriented assertions were written against the old channel
## receive shape and now fail on generic cast paths. This file stays focused on
## the adapter emission contract.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val WEB_RUNTIME_ADAPTER_PATH = "src/app/ui.web/web_runtime_adapter.spl"

fn _read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "WebRuntimeAdapter taskbar frame contracts":
    it "always emits a snapshot frame from send_snapshot":
        val source = _read_source(WEB_RUNTIME_ADAPTER_PATH)
        expect(source).to_contain("me send_snapshot(self):")
        expect(source).to_contain("val payload = encode_snapshot(snap, rev)")
        expect(source).to_contain("val frame = _make_frame(\"snapshot\", self.session_id, \"null\", payload)")

    it "emits taskbar_model frames only through the dedicated helper":
        val source = _read_source(WEB_RUNTIME_ADAPTER_PATH)
        expect(source).to_contain("_emit_taskbar_model()")
        expect(source).to_contain("host_taskbar_runtime_is_enabled()")
        expect(source).to_contain("host_taskbar_runtime_taskbar_frame(self.session_id, self.session)")

    it "deduplicates unchanged taskbar payloads":
        val source = _read_source(WEB_RUNTIME_ADAPTER_PATH)
        expect(source).to_contain("last_taskbar_frame")
        expect(source).to_contain("if frame == self.last_taskbar_frame:")
