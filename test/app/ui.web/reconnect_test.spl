# Reconnect / PatchStream Tests
#
# Exercises PatchStream.bump_revision and patches_since reconnect logic.
# patches_since is a free function in common.ui.patch_stream, not a method
# on UISession — tests call it directly.
#
# v1 behaviour (from patch_stream.spl):
#   from_sequence <= 0 OR events empty  => PatchSinceResult(snapshot: snap, patches: [])
#   from_sequence > 0 AND events exist AND from_sequence >= events[0].sequence
#                                       => PatchSinceResult(snapshot: nil, patches: [])
#   from_sequence > 0 AND events exist AND from_sequence < events[0].sequence
#                                       => PatchSinceResult(snapshot: snap, patches: [])

use std.spipe.*
use common.ui.patch_stream.{PatchStream, PatchSinceResult, patches_since}
use common.ui.access.{
    UiAccessSnapshot,
    UiAccessEvent,
    UI_ACCESS_PROTOCOL_VERSION,
    ui_access_empty_snapshot
}
use common.ui.session.{UISession}
use common.ui.widget.{UITree, WidgetNode}

# ============================================================================
# Helper
# ============================================================================

fn _make_empty_snapshot() -> UiAccessSnapshot:
    return ui_access_empty_snapshot("cli", "main", [])

fn _make_event(seq: i64) -> UiAccessEvent:
    return UiAccessEvent(
        surface_id: "main",
        widget_id: "w1",
        canonical_id: "main#w1",
        event_kind: "focus",
        payload: "",
        sequence: seq
    )

# ============================================================================
# Test Group 1: PatchStream initial state
# ============================================================================

describe "PatchStream initial state":
    """
    ## PatchStream construction

    A fresh PatchStream starts with snapshot_revision == 0.
    UISession.new wraps a PatchStream automatically.
    """

    it "PatchStream.new has snapshot_revision 0":
        val ps = PatchStream.new()
        expect(ps.snapshot_revision).to_equal(0u64)

    it "UISession.new exposes patch_stream with snapshot_revision 0":
        val node = WidgetNode(id: "root")
        val tree = UITree.new(node)
        val session = UISession.new(tree)
        expect(session.patch_stream.snapshot_revision).to_equal(0u64)

# ============================================================================
# Test Group 2: bump_revision
# ============================================================================

describe "PatchStream bump_revision":
    """
    ## Revision counter

    bump_revision increments snapshot_revision by 1 each call.
    """

    it "bump_revision increments from 0 to 1":
        var ps = PatchStream.new()
        ps.bump_revision()
        expect(ps.snapshot_revision).to_equal(1u64)

    it "bump_revision increments from 1 to 2":
        var ps = PatchStream.new()
        ps.bump_revision()
        ps.bump_revision()
        expect(ps.snapshot_revision).to_equal(2u64)

# ============================================================================
# Test Group 3: patches_since cold-start (empty events)
# ============================================================================

describe "patches_since cold start":
    """
    ## Cold-start path

    When events is empty or from_sequence <= 0, patches_since returns
    PatchSinceResult with snapshot set (not nil) and patches empty.
    """

    it "returns snapshot on cold start (from_sequence 0, no events)":
        val snap = _make_empty_snapshot()
        val result = patches_since(snap, [], 0i64)
        expect(result.snapshot).to_equal(snap)
        expect(result.patches.len()).to_equal(0)

    it "returns snapshot when from_sequence is negative":
        val snap = _make_empty_snapshot()
        val result = patches_since(snap, [], -1i64)
        expect(result.snapshot).to_equal(snap)
        expect(result.patches.len()).to_equal(0)

    it "returns snapshot when events exist but from_sequence is 0":
        val snap = _make_empty_snapshot()
        val events = [_make_event(1i64), _make_event(2i64)]
        val result = patches_since(snap, events, 0i64)
        expect(result.snapshot).to_equal(snap)
        expect(result.patches.len()).to_equal(0)

# ============================================================================
# Test Group 4: patches_since with events present
# ============================================================================

describe "patches_since with existing events":
    """
    ## Resume path

    When from_sequence > 0 and events exist:
    - from_sequence >= earliest sequence -> (nil, []) — client is in retention window
    - from_sequence < earliest sequence  -> (snapshot, []) — structural reset
    """

    it "returns nil snapshot when client is in retention window":
        val snap = _make_empty_snapshot()
        val events = [_make_event(1i64), _make_event(2i64)]
        # from_sequence 1 >= earliest 1 => client is within window
        val result = patches_since(snap, events, 1i64)
        expect(result.snapshot).to_be_nil()
        expect(result.patches.len()).to_equal(0)

    it "returns snapshot on revision mismatch (from_sequence behind retention window)":
        val snap = _make_empty_snapshot()
        # Events retained starting at sequence 10; client has sequence 3 => too far behind
        val events = [_make_event(10i64), _make_event(11i64)]
        val result = patches_since(snap, events, 3i64)
        expect(result.snapshot).to_equal(snap)
        expect(result.patches.len()).to_equal(0)

    it "after bump_revision, cold-start still returns snapshot":
        var ps = PatchStream.new()
        ps.bump_revision()
        val snap = UiAccessSnapshot(
            protocol_version: UI_ACCESS_PROTOCOL_VERSION,
            snapshot_revision: ps.snapshot_revision,
            mode: "cli",
            active_surface: "main",
            surfaces: [],
            nodes: [],
            recent_events: []
        )
        # from_sequence 5 with no events => cold start => returns snapshot
        val result = patches_since(snap, [], 5i64)
        expect(result.snapshot).to_equal(snap)

# ============================================================================
# Test Group 5: Resume boundary checks
# ============================================================================

describe "patches_since resume — event injection":
    """
    ## Resume boundary checks

    These examples cover the current retention-window boundary behavior
    without pretending to drive a full injected-event replay path.
    """

    it "from_sequence at earliest event boundary returns nil snapshot (in-window)":
        # Simulate: events held from sequence 100 onwards; client at 100
        val snap = _make_empty_snapshot()
        val events = [_make_event(100i64)]
        val result = patches_since(snap, events, 100i64)
        # from_sequence 100 >= earliest 100 => in window
        expect(result.snapshot).to_be_nil()

    it "from_sequence one before earliest triggers structural reset":
        val snap = _make_empty_snapshot()
        val events = [_make_event(100i64)]
        val result = patches_since(snap, events, 99i64)
        # 99 < 100 => behind retention => returns snapshot
        expect(result.snapshot).to_equal(snap)
