# random_hex — Unit Tests
#
# Covers the Simple-level random_hex helper added in session_token.spl after
# the Rust-runtime rt_random_hex extern turned out to be unimplemented.
# See commit c56553c68d for context.

use std.sspec.*
use app.ui.web.session_token.{random_hex}

fn _is_hex_char(ch: text) -> bool:
    val hex_chars = "0123456789abcdef"
    var i = 0
    while i < hex_chars.len():
        if ch == hex_chars[i:i+1]:
            return true
        i = i + 1
    return false

fn _all_hex(s: text) -> bool:
    var i = 0
    while i < s.len():
        if not _is_hex_char(s[i:i+1]):
            return false
        i = i + 1
    return true

describe "random_hex":
    """
    ## Length and alphabet invariants

    random_hex(N) must return exactly 2*N characters drawn from [0-9a-f].
    """

    it "random_hex(1) has length 2":
        expect(random_hex(1).len()).to_equal(2)

    it "random_hex(8) has length 16":
        expect(random_hex(8).len()).to_equal(16)

    it "random_hex(32) has length 64":
        expect(random_hex(32).len()).to_equal(64)

    it "random_hex(0) is empty":
        expect(random_hex(0)).to_equal("")

    it "random_hex(16) contains only hex characters":
        expect(_all_hex(random_hex(16))).to_equal(true)

    it "random_hex(32) contains only hex characters":
        expect(_all_hex(random_hex(32))).to_equal(true)

describe "random_hex — sequence advance":
    """
    ## Subsequent calls advance the RNG state

    Because the xorshift generator is seeded once at first use, successive
    calls must return different values (collision probability is negligible
    at 32 hex chars).
    """

    it "two 16-byte calls differ":
        val a = random_hex(16)
        val b = random_hex(16)
        expect(a == b).to_equal(false)

    it "three 4-byte calls are not all equal":
        val a = random_hex(4)
        val b = random_hex(4)
        val c = random_hex(4)
        expect(a == b and b == c).to_equal(false)
