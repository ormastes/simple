## Spec for Wave 5: Electron stdin JSON IPC unification.
##
## Verifies:
##   * register_electron_window binds a window with surface_kind "Electron".
##   * The registry round-trip preserves surface_kind so wm_bridge + host
##     taskbar_shell see the Electron kind.
##
## Real BrowserWindow spawn is gated behind the Electron Node shell
## (tools/electron-shell/main.js) and is NOT exercised here — SIMPLE_ELECTRON=1
## local runs are how that path is covered; CI skips it by construction.
##
## Run:
##   bin/simple test test/app/ui.electron/spawn_via_manifest_test.spl

use std.spec
use common.ui.window_surface_registry.{new_ui_window_surface_registry}
use app.ui.electron.main.{register_electron_window}

describe "ui.electron.main.register_electron_window":
    """Electron windows register with surface_kind = "Electron"."""

    it "binds a new entry into the registry":
        val reg = new_ui_window_surface_registry()
        register_electron_window(reg, "sfc-1", "win-1", 42 as u64, "browser", "Example")
        expect(reg.len()).to_equal(1)

    it "preserves surface_kind 'Electron' on the binding":
        val reg = new_ui_window_surface_registry()
        register_electron_window(reg, "sfc-e", "win-e", 7 as u64, "browser", "E")
        val b = reg.for_surface("sfc-e")
        expect(b == nil).to_equal(false)
        expect(b.surface_kind).to_equal("Electron")

    it "keeps app_id and title readable":
        val reg = new_ui_window_surface_registry()
        register_electron_window(reg, "sfc-z", "win-z", 9 as u64, "app-x", "Title Z")
        val b = reg.for_surface("sfc-z")
        expect(b.app_id).to_equal("app-x")
        expect(b.title).to_equal("Title Z")
