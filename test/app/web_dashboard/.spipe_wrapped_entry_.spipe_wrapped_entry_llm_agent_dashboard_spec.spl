#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use app.web_dashboard.server.{DashboardServer}
use app.llm_dashboard.gui.html_views.{generate_agents_html}
use app.llm_dashboard.data.store.{AgentDashboardStore}

fn main():
    # LLM Agent Dashboard Web Specification
    #
    # Focused coverage for the agent dashboard browser UI and router wiring.


    describe "LLM agent dashboard web UI":
        it "redirects unauthenticated /agents requests to /login":
            val server = DashboardServer.new(4242)
            val resp = server.route_request("GET", "/agents", "", "")
            expect (resp).starts_with("HTTP/1.1 302 Found")
            expect (resp).contains("Location: /login")

        it "includes responsive layout rules for narrow screens":
            val html = generate_agents_html(AgentDashboardStore.new())
            expect (html).contains("@media (max-width: 1100px)")
            expect (html).contains("@media (max-width: 720px)")
            expect (html).contains("grid-template-columns: 1fr 1fr 1fr")
            expect (html).contains("grid-template-columns: 1fr 1fr")
            expect (html).contains("grid-template-columns: 1fr;")
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)

