use std.spipe.*
use app.web_dashboard.dashboard_html.{generate_full_dashboard_html}


fn main():
    # Web Dashboard HTML Shell Specification
    #
    # Focused coverage for the server-rendered dashboard HTML scaffold.


    # ============================================================================
    # Main dashboard shell
    # ============================================================================

    describe "Web dashboard HTML shell":
        """
        Verifies the generated HTML scaffold and the client-side routes
        embedded in the dashboard page.
        """

        it "includes the expected outer document structure":
            val html = generate_full_dashboard_html(
                4242,
                "<section id=\"status-card\">status</section>",
                "main@abc123",
                "<div id=\"tmux-card\">tmux</div>",
                "<span>admin</span><a href=\"/logout\">Log out</a>"
            )

            expect (html).starts_with("<!DOCTYPE html>")
            expect (html).contains("<html lang=\"en\">")
            expect (html).contains("<meta charset=\"utf-8\">")
            expect (html).contains("<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">")
            expect (html).contains("<title>Simple Compiler Dashboard</title>")
            expect (html).contains("<style>")
            expect (html).contains("<script>")
            expect (html).contains("</html>")

        it "embeds the dashboard views and client routes":
            val html = generate_full_dashboard_html(
                4242,
                "<section id=\"status-card\">status</section>",
                "main@abc123",
                "<div id=\"tmux-card\">tmux</div>",
                "<span>admin</span><a href=\"/logout\">Log out</a>"
            )

            expect (html).contains("<div id=\"view-status\" class=\"view active\">")
            expect (html).contains("<div id=\"view-terminal\" class=\"view\">")
            expect (html).contains("<div id=\"view-gui\" class=\"view\">")
            expect (html).contains("<section id=\"status-card\">status</section>")
            expect (html).contains("<div id=\"tmux-card\">tmux</div>")
            expect (html).contains("switchView('terminal', this)")
            expect (html).contains("switchView('gui', this)")
            expect (html).contains("window.location='/agents'")
            expect (html).contains("fetch('/api/tmux/sessions')")
            expect (html).contains("fetch('/api/tmux/windows?session='")
            expect (html).contains("fetch('/api/tmux/panes?session='")
            expect (html).contains("fetch('/api/tmux/capture?session='")
            expect (html).contains("/ws/terminal?session=")
            expect (html).contains("<div class=\"header-identity\">")
            expect (html).contains("<a href=\"/logout\">Log out</a>")
            expect (html).contains("send-command")
            expect (html).contains("setTimeout(() => location.reload(), 30000);")

        it "keeps authenticated identity controls separate from the login screen":
            val html = generate_full_dashboard_html(
                4242,
                "<section id=\"status-card\">status</section>",
                "main@abc123",
                "<div id=\"tmux-card\">tmux</div>",
                "<span class=\"user\">alice</span><a href=\"/logout\">Log out</a>"
            )

            expect (html).contains("<div class=\"header-identity\">")
            expect (html).contains("<span class=\"user\">alice</span>")
            expect (html).contains("<a href=\"/logout\">Log out</a>")
            expect html.contains("<form method=\"POST\" action=\"/login\">") == false
            expect html.contains("LLM Dashboard Login") == false