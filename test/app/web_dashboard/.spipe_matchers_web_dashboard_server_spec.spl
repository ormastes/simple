## Web dashboard server source contracts.
##
## The live router path is currently prone to the same runtime/teardown instability
## as other browser-facing specs in this cluster. This file verifies the server
## routing and auth contracts directly from source.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val SERVER_PATH = "src/app/web_dashboard/server.spl"
val LOGIN_PATH = "src/app/llm_dashboard/web_login.spl"

fn _read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "Web dashboard server router contracts":
    it "redirects unauthenticated requests for / to /login":
        val source = _read_source(SERVER_PATH)
        expect (source).contains("if session == nil:")
        expect (source).contains("return http_redirect(\"/login\")")

    it "serves the login page on GET /login":
        val server_source = _read_source(SERVER_PATH)
        val login_source = _read_source(LOGIN_PATH)
        expect (server_source).contains("if clean_path == \"/login\":")
        expect (server_source).contains("return self.handle_login(method, body, session)")
        expect (login_source).contains("LLM Dashboard Login")
        expect (login_source).contains("<form method=\"POST\" action=\"/login\">")
        expect login_source.contains("/api/tmux/sessions") == false
        expect login_source.contains("/ws/terminal?session=") == false

    it "rejects empty login submissions without minting an authenticated session":
        val source = _read_source(SERVER_PATH)
        expect (source).contains("if method != \"POST\":")
        expect (source).contains("val auth_result = auth_authenticate_form(body)")
        expect (source).contains("return http_response(401, \"text/html\", auth_login_page(")

    it "logout clears any active session and returns to /login":
        val source = _read_source(SERVER_PATH)
        expect (source).contains("if clean_path == \"/logout\":")
        expect (source).contains("return self.handle_logout(session)")
        expect (source).contains("auth_clear_cookie_header(")

    it "rejects unauthenticated API access":
        val source = _read_source(SERVER_PATH)
        expect (source).contains("if clean_path.starts_with(\"/api/\"):")
        expect (source).contains("return http_error(401, \"Authentication required\")")

    it "rejects unauthenticated terminal and tmux capture access on deeper routes":
        val source = _read_source(SERVER_PATH)
        expect (source).contains("if is_ws and path.starts_with(\"/ws/terminal\"):")
        expect (source).contains("if path.starts_with(\"/api/tmux\"):")
        expect (source).contains("return http_error(503, \"Tmux API is unavailable in this runtime mode\")")

    it "routes unknown paths to the login redirect when unauthenticated":
        val source = _read_source(SERVER_PATH)
        expect (source).contains("if val active_session = session:")
        expect (source).contains("http_redirect(\"/login\")")