# @cover src/app/llm_process_gen/main.spl 80%

use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

struct ProcResult:
    stdout: text
    stderr: text
    exit_code: i64

fn shell(command: text) -> ProcResult:
    val (stdout, stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    ProcResult(stdout: stdout, stderr: stderr, exit_code: code)

fn run_gen(args: [text]) -> ProcResult:
    val (stdout, stderr, code) = rt_process_run("bin/simple", ["llm-process-gen"] + args)
    ProcResult(stdout: stdout, stderr: stderr, exit_code: code)

fn root(name: text) -> text:
    "/tmp/simple_llm_process_gen_" + name

fn seed(root_path: text, mode: text):
    val source_file = if mode == "gemini_toml_skill": "src/source.toml" else: "src/source.md"
    val source_body = if mode == "gemini_toml_skill": "description = \"Demo command\"\nprompt = \"\"\"\nRun demo.\n\"\"\"\n" else: "hello source\n"
    val script = "rm -rf '" + root_path + "' && mkdir -p '" + root_path + "/doc/00_llm_process' '" + root_path + "/src' '" + root_path + "/out' && " +
        "cat > '" + root_path + "/" + source_file + "' <<'SRC'\n" + source_body + "SRC\n" +
        "cat > '" + root_path + "/doc/00_llm_process/llm_process_manifest.sdn' <<'EOF'\n" +
        "skills:\n  - id: sample\ncommands:\n  - id: sample\nsubagents:\n  - id: sample\ntools:\n  - id: sample\nexpert_routes:\n  - id: sample\n" +
        "generated_files:\n" +
        "  - id: sample_doc\n" +
        "    kind: skill\n" +
        "    owner: test\n" +
        "    stage: test\n" +
        "    source_path: " + source_file + "\n" +
        "    target_path: out/generated.md\n" +
        "    mode: " + mode + "\n" +
        "EOF"
    expect(shell(script).exit_code).to_equal(0)

fn seed_tools(root_path: text):
    val script = "rm -rf '" + root_path + "' && mkdir -p '" + root_path + "/doc/00_llm_process/skill_command/skills/codex/demo' && " +
        "cat > '" + root_path + "/doc/00_llm_process/llm_process_manifest.sdn' <<'EOF'\n" +
        "skills:\n  - id: sample\ncommands:\n  - id: sample\nsubagents:\n  - id: sample\ntools:\n  - id: sample\nexpert_routes:\n  - id: sample\n" +
        "generated_files:\n" +
        "  - id: demo_tools\n" +
        "    kind: tools\n" +
        "    owner: codex\n" +
        "    stage: demo\n" +
        "    source_path: doc/00_llm_process/llm_process_manifest.sdn\n" +
        "    target_path: doc/00_llm_process/skill_command/skills/codex/demo/tools.sdn\n" +
        "    mode: tools_sdn\n" +
        "EOF"
    expect(shell(script).exit_code).to_equal(0)

