# UI Test API Handler — Regression Tests
#
# Exercises the routes in src/app/ui.test_api/handler.spl at the
# function-call level (no real sockets).  Calls handle_test_request()
# directly and inspects the (status, content_type, body) tuple.

use std.spipe.*
use app.ui.test_api.handler.{handle_test_request, PROTOCOL_VERSION}
use common.ui.widget.{UIState, UIEvent, UITree, WidgetNode}
use common.ui.session.{UISession}

# ============================================================================
# Module-level inject_event test double
#
# Closure-modify limitation: nested closures cannot mutate an outer var.
# Use a module-level var + a named function instead.
# ============================================================================

var _captured_events: [UIEvent] = []

fn _stub_inject(e: UIEvent):
    _captured_events = _captured_events.push(e)

fn _noop_inject(e: UIEvent):
    _captured_events = _captured_events

# ============================================================================
# Fixture helpers
# ============================================================================

fn _make_state() -> UIState:
    val root = WidgetNode(id: "root")
    val tree = UITree.new(root)
    return UIState.new(tree)

fn _make_session() -> UISession:
    val root = WidgetNode(id: "root")
    val tree = UITree.new(root)
    return UISession.new(tree)

# ============================================================================
# Group 1: /api/test/ready  (GET)
# ============================================================================

describe "GET /api/test/ready":
    """
    ## Protocol version sentinel

    The ready route must return 200 with ready:true and the integer
    protocol_version matching the PROTOCOL_VERSION constant (expected: 1).
    """

    it "returns 200 with ready:true":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ready", "GET", "", state, _noop_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ready\":true")

    it "PROTOCOL_VERSION constant equals 1":
        expect(PROTOCOL_VERSION).to_equal(1)

    it "body contains protocol_version 1":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ready", "GET", "", state, _noop_inject, nil)
        expect(body).to_contain("\"protocol_version\":1")

    it "returns application/json content type":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ready", "GET", "", state, _noop_inject, nil)
        expect(ctype).to_equal("application/json")

