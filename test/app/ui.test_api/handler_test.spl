# ============================================================================
# Group 12: POST /api/test/click
# ============================================================================

describe "POST /api/test/click":
    """
    ## Inject a click action for a widget

    Happy path: id present → 200 ok:true, event captured.
    Error path: missing id → 400.
    """

    it "returns 200 with ok:true when id is provided":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/click", "POST", "{\"id\":\"btn1\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(ctype).to_equal("application/json")
        expect(body).to_contain("\"ok\":true")

    it "injects a click action event":
        _captured_events = []
        val state = _make_state()
        handle_test_request("/api/test/click", "POST", "{\"id\":\"btn1\"}", state, _stub_inject, nil)
        expect(_captured_events.len()).to_equal(1)

    it "returns 400 when id is missing":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/click", "POST", "{}", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

