# Group 13: POST /api/test/type
# ============================================================================

describe "POST /api/test/type":
    """
    ## Focus widget and inject key presses

    Happy path: id + text present → 200 ok:true, events captured.
    Error path: missing id → 400.
    """

    it "returns 200 with ok:true":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/type", "POST", "{\"id\":\"input1\",\"text\":\"hi\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(ctype).to_equal("application/json")
        expect(body).to_contain("\"ok\":true")

    it "injects focus plus one KeyPress per character":
        _captured_events = []
        val state = _make_state()
        handle_test_request("/api/test/type", "POST", "{\"id\":\"input1\",\"text\":\"ab\"}", state, _stub_inject, nil)
        # 1 focus action + 2 key presses = 3 events
        expect(_captured_events.len()).to_equal(3)

    it "returns 400 when id is missing":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/type", "POST", "{\"text\":\"hi\"}", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

