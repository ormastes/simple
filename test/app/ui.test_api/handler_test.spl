# ============================================================================
# Group 4: /api/test/element  (GET)
# ============================================================================

describe "GET /api/test/element":
    """
    ## Single element lookup by id query param

    Happy path: ?id=root → 200 with the root widget payload.
    Error path: missing ?id= → 400.
    Error path: unknown id → 404.
    """

    it "returns 200 for the root widget id":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/element?id=root", "GET", "", state, _noop_inject, nil)
        expect(status).to_equal(200)
        expect(ctype).to_equal("application/json")
        expect(body).to_contain("\"id\":\"root\"")

    it "returns 400 when id param is missing":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/element", "GET", "", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 404 for unknown widget id":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/element?id=no_such_widget", "GET", "", state, _noop_inject, nil)
        expect(status).to_equal(404)
        expect(body).to_contain("element_not_found")

