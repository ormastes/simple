# Group 16: POST /api/test/event
# ============================================================================

describe "POST /api/test/event":
    """
    ## Inject a raw UIEvent

    Covers event_type: key, action, quit, focus_next, focus_prev, resize.
    Error path: unknown event_type → 400.
    """

    it "event_type=key returns 200":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"key\",\"key\":\"Enter\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")

    it "event_type=action returns 200":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"action\",\"name\":\"save\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")

    it "event_type=quit returns 200":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"quit\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")

    it "event_type=focus_next returns 200":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"focus_next\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")

    it "event_type=focus_prev returns 200":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"focus_prev\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")

    it "event_type=resize returns 200":
        _captured_events = []
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"resize\",\"width\":\"800\",\"height\":\"600\"}", state, _stub_inject, nil)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")

    it "unknown event_type returns 400":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"bogus\"}", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("unknown_event_type")

    it "event_type=key with missing key field returns 400":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/event", "POST", "{\"event_type\":\"key\"}", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

# ============================================================================
# Group 17: POST /api/test/ui/act
# ============================================================================

describe "POST /api/test/ui/act":
    """
    ## Additive UI access action route

    Happy path with session: surface_id + action present → 200 ok:true.
    Error path: missing action → 400.
    Error path: surface not found → 404.
    """

    it "returns 400 when action field is missing":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/act", "POST", "{\"surface_id\":\"main\"}", state, _noop_inject, session)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 404 for unknown surface_id when session provided":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/act", "POST", "{\"surface_id\":\"ghost\",\"action\":\"click\"}", state, _noop_inject, session)
        expect(status).to_equal(404)
        expect(body).to_contain("element_not_found")

    it "returns 200 with known surface_id and action":
        _captured_events = []
        val state = _make_state()
        val session = _make_session()
        # UISession.new opens a "main" surface automatically
        val (status, ctype, body) = handle_test_request("/api/test/ui/act", "POST", "{\"surface_id\":\"main\",\"action\":\"click\"}", state, _stub_inject, session)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")
        expect(body).to_contain("\"surface_id\":\"main\"")

    it "returns 400 when surface_id missing and no canonical_id":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ui/act", "POST", "{\"action\":\"click\"}", state, _noop_inject, nil)
        expect(status).to_equal(400)

# ============================================================================
# Group 18: POST /api/test/ui/state
# ============================================================================

describe "POST /api/test/ui/state":
    """
    ## Declarative UI state route

    Error path: missing state_key → 400.
    Error path: session nil → 400.
    Happy path: state_key=active + known surface → 200.
    """

    it "returns 400 when state_key is missing":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/state", "POST", "{\"surface_id\":\"main\"}", state, _noop_inject, session)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 400 when session is nil":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ui/state", "POST", "{\"surface_id\":\"main\",\"state_key\":\"active\",\"state_value\":\"true\"}", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 200 when activating a known surface":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/state", "POST", "{\"surface_id\":\"main\",\"state_key\":\"active\",\"state_value\":\"true\"}", state, _noop_inject, session)
        expect(status).to_equal(200)
        expect(body).to_contain("\"ok\":true")
        expect(body).to_contain("\"surface_id\":\"main\"")
        expect(body).to_contain("\"state_key\":\"active\"")

# ============================================================================
# Group 19: Method dispatch error paths
# ============================================================================

describe "Method dispatch":
    """
    ## Routing and method validation

    POST to a GET-only route → 404 (no POST handler matches).
    Unknown method → 405.
    """

    it "POST to GET-only /api/test/ready returns 404":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ready", "POST", "", state, _noop_inject, nil)
        expect(status).to_equal(404)
        expect(body).to_contain("not_found")

    it "DELETE method returns 405":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ready", "DELETE", "", state, _noop_inject, nil)
        expect(status).to_equal(405)
        expect(body).to_contain("method_not_allowed")

    it "unknown GET route returns 404":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/no_such_route", "GET", "", state, _noop_inject, nil)
        expect(status).to_equal(404)

# ============================================================================
# Group 20: GET /api/test/ui/ensure
# ============================================================================

describe "GET /api/test/ui/ensure":
    """
    ## Goal-state polling route

    timeout_ms=0 forces a single snapshot read with no rt_sleep_ms call.
    Always returns 200 with an ensure-shaped JSON body.
    """

    it "returns 200 with no session and timeout_ms=0":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ui/ensure?timeout_ms=0", "GET", "", state, _noop_inject, nil)
        expect(status).to_equal(200)
        expect(ctype).to_equal("application/json")
        expect(body).to_contain("\"satisfied\":")

    it "returns 200 with a session and timeout_ms=0":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/ensure?surface_id=main&timeout_ms=0", "GET", "", state, _noop_inject, session)
        expect(status).to_equal(200)
        expect(body).to_contain("\"surface_id\":\"main\"")

    it "honors expectation+expected_value query params":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/ensure?surface_id=main&expectation=value&expected_value=x&timeout_ms=0", "GET", "", state, _noop_inject, session)
        expect(status).to_equal(200)

# ============================================================================
# Group 21: POST /api/test/ui/value
# ============================================================================

describe "POST /api/test/ui/value":
    """
    ## Typed value write route

    Validates required fields and surface presence before delegating
    the write to the session.
    """

    it "returns 400 when canonical_id is missing":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/value", "POST", "{\"value\":\"hi\"}", state, _noop_inject, session)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 400 when value is missing":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/value", "POST", "{\"canonical_id\":\"main#root\"}", state, _noop_inject, session)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 400 when session is nil":
        val state = _make_state()
        val (status, ctype, body) = handle_test_request("/api/test/ui/value", "POST", "{\"canonical_id\":\"main#root\",\"value\":\"hi\"}", state, _noop_inject, nil)
        expect(status).to_equal(400)
        expect(body).to_contain("missing_field")

    it "returns 404 when surface is not present":
        val state = _make_state()
        val session = _make_session()
        val (status, ctype, body) = handle_test_request("/api/test/ui/value", "POST", "{\"surface_id\":\"ghost\",\"canonical_id\":\"ghost#root\",\"value\":\"hi\"}", state, _noop_inject, session)
        expect(status).to_equal(404)
        expect(body).to_contain("element_not_found")

