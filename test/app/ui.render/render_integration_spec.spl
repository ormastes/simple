# @cover src/app/dashboard.render/adapter.spl 60%
# @cover src/app/office/render_adapter.spl 40%
"""
# UI Render Integration Specification

**Feature IDs:** #UI-RENDER-002
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** doc/05_design/ui_render_feature_caret.md
**Research:** N/A

## Overview

Integration tests for the render adapters. Validates that the dashboard
adapter and office adapter produce meaningful output through the shared
RenderResult contract, and that unknown adapter names are handled gracefully.

## Key Concepts

| Concept | Description |
|---------|-------------|
| DashboardRenderRequest | Dashboard-specific render request with summary dict |
| render_dashboard | Dashboard adapter entry point producing RenderResult |
| office_render | Office adapter entry point routing to sub-apps |
| Adapter routing | Config.adapter_name selects which sub-app handles the request |

## Behavior

- Dashboard adapter produces text output containing status information
- Dashboard adapter produces HTML output containing styled cards
- Office adapter routes to word, sheets, slides, mail, planner, launcher
- Unknown adapter_name in office adapter returns warning message
"""

use std.spipe.*
use app.ui.render.types.{RenderConfig, RenderResult}
use app.dashboard.render.adapter.{render_dashboard, DashboardRenderRequest,
    default_dashboard_config}


# ============================================================================
# Test Group 1: Dashboard Adapter
# ============================================================================

describe "Dashboard Render Adapter":
    """
    ## Dashboard rendering through shared contract

    The dashboard adapter takes a DashboardRenderRequest (config + summary dict)
    and produces a RenderResult with text and/or HTML output depending on format.
    """

    context "text output for status mode":
        """
        ### Scenario: Default status mode with text format

        The dashboard should produce a non-empty text output containing
        project status information when given a summary dict.
        """

        it "produces non-empty text output":
            val cfg = default_dashboard_config()
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            val len = result.text_output.len()
            expect(len > 0).to_equal(true)

        it "text output contains status header":
            val cfg = default_dashboard_config()
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            expect(result.text_output).to_contain("Status")

        it "text output contains feature count":
            val cfg = default_dashboard_config()
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            expect(result.text_output).to_contain("10")

        it "sets metadata adapter to dashboard":
            val cfg = default_dashboard_config()
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            expect(result.metadata["adapter"]).to_equal("dashboard")

    context "html output":
        """
        ### Scenario: HTML format rendering

        When format is "html", the dashboard should produce HTML output
        containing styled elements.
        """

        it "produces non-empty html output when format is html":
            var cfg = default_dashboard_config()
            cfg.format = "html"
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            val len = result.html_output.len()
            expect(len > 0).to_equal(true)

        it "html output contains DOCTYPE":
            var cfg = default_dashboard_config()
            cfg.format = "html"
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            expect(result.html_output).to_contain("DOCTYPE")

        it "html output contains dashboard heading":
            var cfg = default_dashboard_config()
            cfg.format = "html"
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            expect(result.html_output).to_contain("Dashboard")

    context "both format":
        """
        ### Scenario: Dual output with both format

        When format is "both", the dashboard should produce both text and HTML.
        """

        it "produces both text and html output":
            var cfg = default_dashboard_config()
            cfg.format = "both"
            val summary = build_test_summary()
            val req = DashboardRenderRequest(config: cfg, summary: summary)
            val result = render_dashboard(req)
            val text_len = result.text_output.len()
            val html_len = result.html_output.len()
            expect(text_len > 0).to_equal(true)
            expect(html_len > 0).to_equal(true)


# ============================================================================
# Test Group 2: Office Adapter Routing
# ============================================================================

describe "Office Render Adapter Routing":
    """
    ## Office adapter_name routing

    The office adapter uses config.adapter_name to route to the
    correct sub-app renderer (word, sheets, slides, mail, planner, launcher).
    Unknown names should return a result with a warning.
    """

    context "unknown adapter_name":
        """
        ### Scenario: Unrecognized adapter name

        When adapter_name is not a known office sub-app, the adapter
        should return a result with a warning message.
        """

        it "returns text mentioning unknown adapter":
            var cfg = RenderConfig.default()
            cfg.adapter_name = "nonexistent_app"

            # Use the office_render function directly
            use app.office.render_adapter.{office_render}
            val result = office_render(cfg)
            expect(result.text_output).to_contain("Unknown")

        it "includes warning for unknown adapter":
            var cfg = RenderConfig.default()
            cfg.adapter_name = "nonexistent_app"

            use app.office.render_adapter.{office_render}
            val result = office_render(cfg)
            val has_warnings = result.warnings.len() > 0
            expect(has_warnings).to_equal(true)

    context "known adapter names route correctly":
        """
        ### Scenario: Valid adapter names

        Each recognized adapter_name should be accepted without errors.
        We test with "word" as a representative sub-app.
        """

        it "word adapter produces non-empty text output":
            var cfg = RenderConfig.default()
            cfg.adapter_name = "word"

            use app.office.render_adapter.{office_render}
            val result = office_render(cfg)
            val len = result.text_output.len()
            expect(len > 0).to_equal(true)

        it "word adapter text output contains app name":
            var cfg = RenderConfig.default()
            cfg.adapter_name = "word"

            use app.office.render_adapter.{office_render}
            val result = office_render(cfg)
            expect(result.text_output).to_contain("Word")


# ============================================================================
# Helper Code
# ============================================================================

fn build_test_summary() -> Dict<text, text>:
    """Build a minimal test summary dict for dashboard rendering."""
    var d: Dict<text, text> = {}
    d["features_total"] = "10"
    d["features_complete"] = "5"
    d["features_in_progress"] = "3"
    d["features_planned"] = "2"
    d["todos_total"] = "20"
    d["todos_open"] = "15"
    d["todos_blocked"] = "2"
    d["tests_total"] = "100"
    d["tests_passed"] = "90"
    d["tests_failed"] = "5"
    d["tests_skipped"] = "5"
    d["lines_total"] = "10000"
    d["lines_covered"] = "7500"
    d["coverage_pct"] = "75"
    return d
