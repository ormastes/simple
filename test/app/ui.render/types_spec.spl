# @cover src/app/ui.render/types.spl 80%
"""
# UI Render Contract Types Specification

**Feature IDs:** #UI-RENDER-001
**Category:** Tooling
**Difficulty:** 1/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** doc/05_design/ui_render_feature_caret.md
**Research:** N/A

## Overview

Tests the shared render contract types used by all app adapters
(dashboard, llm_dashboard, office). Validates factory methods,
default values, and result construction for RenderConfig,
RenderRequest, and RenderResult.

## Key Concepts

| Concept | Description |
|---------|-------------|
| RenderConfig | Configuration for a render request (mode, backend, format, dimensions) |
| RenderResult | Result of a render operation (text_output, html_output, metadata) |
| RenderRequest | Combines config with export targets |
| Factory methods | Static constructors: default(), text_export(), html_export(), empty(), text(), html(), both() |

## Behavior

- RenderConfig.default() returns sensible defaults (80x24, "text" format, "dark" theme)
- RenderConfig.text_export() and html_export() set the format field
- RenderResult.empty() returns empty strings for all output fields
- RenderResult.text(content) sets text_output only
- RenderResult.html(content) sets html_output only
- RenderResult.both(t, h) sets both output fields and format to "both"
"""

use std.sspec.*
use app.ui.render.types.{RenderConfig, RenderRequest, RenderResult}


# ============================================================================
# Test Group 1: RenderConfig Factory Methods
# ============================================================================

describe "RenderConfig Factory Methods":
    """
    ## RenderConfig Construction

    Validates that factory methods produce correct default values
    and format-specific configurations.
    """

    context "default()":
        """
        ### Scenario: Default configuration

        The default configuration should provide sensible values
        for all fields, suitable for a typical terminal render.
        """

        it "returns mode as render":
            val cfg = RenderConfig.default()
            expect(cfg.mode).to_equal("render")

        it "returns backend as auto":
            val cfg = RenderConfig.default()
            expect(cfg.backend).to_equal("auto")

        it "returns format as text":
            val cfg = RenderConfig.default()
            expect(cfg.format).to_equal("text")

        it "returns width of 80":
            val cfg = RenderConfig.default()
            expect(cfg.width).to_equal(80)

        it "returns height of 24":
            val cfg = RenderConfig.default()
            expect(cfg.height).to_equal(24)

        it "returns theme as dark":
            val cfg = RenderConfig.default()
            expect(cfg.theme).to_equal("dark")

        it "returns empty asset_path":
            val cfg = RenderConfig.default()
            expect(cfg.asset_path).to_equal("")

        it "returns empty output_path":
            val cfg = RenderConfig.default()
            expect(cfg.output_path).to_equal("")

        it "returns empty adapter_name":
            val cfg = RenderConfig.default()
            expect(cfg.adapter_name).to_equal("")

        it "returns use_default_demo as false":
            val cfg = RenderConfig.default()
            expect(cfg.use_default_demo).to_equal(false)

    context "text_export()":
        """
        ### Scenario: Text export preset

        text_export() should set format to "text" while inheriting
        all other defaults.
        """

        it "sets format to text":
            val cfg = RenderConfig.text_export()
            expect(cfg.format).to_equal("text")

        it "inherits default width":
            val cfg = RenderConfig.text_export()
            expect(cfg.width).to_equal(80)

        it "inherits default height":
            val cfg = RenderConfig.text_export()
            expect(cfg.height).to_equal(24)

    context "html_export()":
        """
        ### Scenario: HTML export preset

        html_export() should set format to "html" while inheriting
        all other defaults.
        """

        it "sets format to html":
            val cfg = RenderConfig.html_export()
            expect(cfg.format).to_equal("html")

        it "inherits default theme":
            val cfg = RenderConfig.html_export()
            expect(cfg.theme).to_equal("dark")

        it "inherits default backend":
            val cfg = RenderConfig.html_export()
            expect(cfg.backend).to_equal("auto")


# ============================================================================
# Test Group 2: RenderResult Factory Methods
# ============================================================================

describe "RenderResult Factory Methods":
    """
    ## RenderResult Construction

    Validates the static factory methods that create result objects
    with the correct format, output fields, and empty collections.
    """

    context "empty()":
        """
        ### Scenario: Empty result

        empty() should return a result with all fields set to empty/default values.
        """

        it "returns format as text":
            val result = RenderResult.empty()
            expect(result.format).to_equal("text")

        it "returns empty text_output":
            val result = RenderResult.empty()
            expect(result.text_output).to_equal("")

        it "returns empty html_output":
            val result = RenderResult.empty()
            expect(result.html_output).to_equal("")

    context "text(content)":
        """
        ### Scenario: Text-only result

        text(content) should set text_output and leave html_output empty.
        """

        it "sets text_output to provided content":
            val result = RenderResult.text("hello world")
            expect(result.text_output).to_equal("hello world")

        it "sets format to text":
            val result = RenderResult.text("hello")
            expect(result.format).to_equal("text")

        it "leaves html_output empty":
            val result = RenderResult.text("hello")
            expect(result.html_output).to_equal("")

    context "html(content)":
        """
        ### Scenario: HTML-only result

        html(content) should set html_output and leave text_output empty.
        """

        it "sets html_output to provided content":
            val result = RenderResult.html("<h1>hello</h1>")
            expect(result.html_output).to_equal("<h1>hello</h1>")

        it "sets format to html":
            val result = RenderResult.html("<p>test</p>")
            expect(result.format).to_equal("html")

        it "leaves text_output empty":
            val result = RenderResult.html("<p>test</p>")
            expect(result.text_output).to_equal("")

    context "both(text_content, html_content)":
        """
        ### Scenario: Dual-format result

        both(t, h) should set both output fields and format to "both".
        """

        it "sets text_output":
            val result = RenderResult.both("plain", "<b>rich</b>")
            expect(result.text_output).to_equal("plain")

        it "sets html_output":
            val result = RenderResult.both("plain", "<b>rich</b>")
            expect(result.html_output).to_equal("<b>rich</b>")

        it "sets format to both":
            val result = RenderResult.both("plain", "<b>rich</b>")
            expect(result.format).to_equal("both")


# ============================================================================
# Test Group 3: RenderRequest Construction
# ============================================================================

describe "RenderRequest Construction":
    """
    ## RenderRequest from Config

    Validates that from_config wraps a RenderConfig correctly.
    """

    context "from_config":
        """
        ### Scenario: Wrapping a config into a request

        from_config should carry the config and initialize empty export targets.
        """

        it "preserves config format":
            val cfg = RenderConfig.html_export()
            val req = RenderRequest.from_config(cfg)
            expect(req.config.format).to_equal("html")

        it "preserves config mode":
            val cfg = RenderConfig.default()
            val req = RenderRequest.from_config(cfg)
            expect(req.config.mode).to_equal("render")
