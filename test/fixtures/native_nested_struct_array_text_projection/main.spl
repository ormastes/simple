use test.fixtures.native_nested_struct_array_text_projection.model.{
    NativeProjectionBatch,
    NativeProjectionCommand
}

fn count_rects(commands: [NativeProjectionCommand]) -> i64:
    var count: i64 = 0
    for command in commands:
        if command.kind == "rect":
            count = count + command.value
    count

fn count_batch(batch: NativeProjectionBatch) -> i64:
    count_rects(batch.commands)

fn main() -> i64:
    val batch = NativeProjectionBatch(
        commands: [
            NativeProjectionCommand(kind: "rect", value: 2),
            NativeProjectionCommand(kind: "other", value: 100),
            NativeProjectionCommand(kind: "rect", value: 3)
        ]
    )
    val result = count_batch(batch)
    println("result={result}")
    if result == 5:
        return 0
    91
