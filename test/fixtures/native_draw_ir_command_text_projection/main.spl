use common.ui.draw_ir.{
    DRAW_IR_BACKEND_GPU,
    DrawIrBatch,
    DrawIrCommand,
    DrawIrComposition,
    draw_ir_batch,
    draw_ir_composition,
    draw_ir_embedding_config,
    draw_ir_rect
}

fn count_rects(commands: [DrawIrCommand]) -> i64:
    var count: i64 = 0
    for command in commands:
        if command.kind == "rect":
            count = count + 1
    count

fn count_batch(batch: DrawIrBatch) -> i64:
    count_rects(batch.commands)

fn count_composition(composition: DrawIrComposition) -> i64:
    var count: i64 = 0
    for batch in composition.batches:
        count = count + count_batch(batch)
    count

fn main() -> i64:
    val embedding = draw_ir_embedding_config("surface", "probe", 0, 0, 4, 4, 0, 1000, true)
    val batch = draw_ir_batch("batch", DRAW_IR_BACKEND_GPU, embedding, [
        draw_ir_rect("probe", 0, 0, 4, 4, 0xFFFFFFFFu32)
    ])
    val composition = draw_ir_composition("composition", "scene", DRAW_IR_BACKEND_GPU, [batch])
    val result = count_composition(composition)
    println("result={result}")
    if result == 1:
        return 0
    92
