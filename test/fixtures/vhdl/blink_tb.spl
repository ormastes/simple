# Blink Testbench Fixture
#
# Provides testbench generation for the hello_blink example.
# Used by VHDL emulation system tests.

use examples.vhdl.hello_blink.{generate_blink_vhdl, blink_ports}
use compiler.backend.vhdl.vhdl_testbench.VhdlTestbenchGenerator

fn generate_blink_testbench() -> text:
    """Generate complete testbench for blink example."""
    val gen = VhdlTestbenchGenerator.create()
    gen.generate_basic("blink", blink_ports())

fn generate_blink_design() -> text:
    """Generate the blink design VHDL (100 MHz, 1 Hz blink)."""
    generate_blink_vhdl(100, 1)
