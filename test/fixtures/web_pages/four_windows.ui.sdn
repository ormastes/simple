(scene
  name: four_windows
  width: 320
  height: 240
  elements: [
    (element kind: desktop_chrome x: 0 y: 0 w: 320 h: 240
      color_top: 0xFF1A1A2E color_bottom: 0xFF16213E)
    # Terminal — scaled from (50,60,600,400) / 1280x720
    (element kind: decoration x: 12 y: 20 w: 150 h: 18 title: "Terminal")
    (element kind: glass_panel x: 14 y: 40 w: 146 h: 111
      surface_color: 0xFF303050 alpha: 180 blur_radius: 4)
    (element kind: text_label x: 16 y: 22 w: 142 h: 14
      text: "Terminal" fg: 0xFFFFFFFF bg: 0x00000000)
    # Editor — (300,120,700,500)
    (element kind: decoration x: 75 y: 40 w: 175 h: 18 title: "Editor")
    (element kind: glass_panel x: 77 y: 60 w: 171 h: 145
      surface_color: 0xFF303050 alpha: 180 blur_radius: 4)
    (element kind: text_label x: 79 y: 42 w: 167 h: 14
      text: "Editor" fg: 0xFFFFFFFF bg: 0x00000000)
    # Browser — (500,80,650,450)
    (element kind: decoration x: 125 y: 26 w: 162 h: 18 title: "Browser")
    (element kind: glass_panel x: 127 y: 46 w: 158 h: 128
      surface_color: 0xFF303050 alpha: 180 blur_radius: 4)
    (element kind: text_label x: 129 y: 28 w: 154 h: 14
      text: "Browser" fg: 0xFFFFFFFF bg: 0x00000000)
    # File Manager — (150,200,550,350)
    (element kind: decoration x: 37 y: 66 w: 137 h: 18 title: "Files")
    (element kind: glass_panel x: 39 y: 86 w: 133 h: 98
      surface_color: 0xFF303050 alpha: 180 blur_radius: 4)
    (element kind: text_label x: 41 y: 68 w: 129 h: 14
      text: "Files" fg: 0xFFFFFFFF bg: 0x00000000)
  ])
