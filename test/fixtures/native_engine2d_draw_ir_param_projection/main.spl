use common.ui.draw_ir.{
    DRAW_IR_BACKEND_CPU,
    DrawIrCommand,
    draw_ir_batch,
    draw_ir_composition,
    draw_ir_embedding_config,
    draw_ir_rect
}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{
    engine2d_draw_ir_adv_batch,
    engine2d_draw_ir_adv_composition
}

struct EngineProjectionOutcome:
    engine: Engine2D
    count: i64

fn count_rects_with_engine(engine: Engine2D, commands: [DrawIrCommand]) -> EngineProjectionOutcome:
    var eng = engine
    var count: i64 = 0
    for command in commands:
        if command.kind == "rect":
            count = count + 1
    EngineProjectionOutcome(engine: eng, count: count)

fn main() -> i64:
    val engine = Engine2D.create_offscreen(4, 4)
    val outcome = count_rects_with_engine(engine, [
        draw_ir_rect("probe", 0, 0, 4, 4, 0xFFFFFFFFu32)
    ])
    var returned_engine = outcome.engine
    val batch = draw_ir_batch(
        "probe-batch",
        DRAW_IR_BACKEND_CPU,
        draw_ir_embedding_config("", "probe", 0, 0, 4, 4, 0, 1000, true),
        [draw_ir_rect("probe", 0, 0, 4, 4, 0xFFFFFFFFu32)]
    )
    val rendered = engine2d_draw_ir_adv_batch(returned_engine, batch, false)
    returned_engine.shutdown()
    var composition_engine = Engine2D.create_offscreen(4, 4)
    val composition = draw_ir_composition("probe-composition", "probe-scene", DRAW_IR_BACKEND_CPU, [batch])
    val composed = engine2d_draw_ir_adv_composition(composition_engine, composition, false)
    composition_engine.shutdown()
    println("direct={outcome.count} batch_rendered={rendered.rendered_command_count} batch_skipped={rendered.skipped_command_count} composition_rendered={composed.rendered_command_count} composition_skipped={composed.skipped_command_count}")
    if (outcome.count == 1 and rendered.rendered_command_count == 1 and rendered.skipped_command_count == 0 and
        composed.rendered_command_count == 1 and composed.skipped_command_count == 0):
        return 0
    93
