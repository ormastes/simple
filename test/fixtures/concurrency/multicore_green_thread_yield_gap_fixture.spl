use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism}
use std.concurrent.thread.{thread_yield}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_thread_sleep(ms: i64)
extern fn rt_exit(code: i32)

fn spin_for_us_with_thread_yield(target_us: i64, value: i64) -> i64:
    val start = rt_time_now_unix_micros()
    var last_yield = start
    while rt_time_now_unix_micros() - start < target_us:
        _ = 1 + 1
        val now = rt_time_now_unix_micros()
        if now - last_yield >= 1000:
            thread_yield()
            last_yield = now
    value

fn main() -> i64:
    multicore_green_set_parallelism(1)
    println("parallelism_before={multicore_green_parallelism()}")
    val h0 = multicore_green_spawn(\: spin_for_us_with_thread_yield(120000, 2))
    rt_thread_sleep(10)
    val h1 = multicore_green_spawn(\: 7)
    rt_thread_sleep(20)
    val quick_done_during_spin = h1.is_done()
    println("quick_done_during_spin={quick_done_during_spin}")
    val total = h0.join() + h1.join()
    println("parallelism_after_join={multicore_green_parallelism()}")
    println("total={total}")
    if total != 9:
        rt_exit(71)
    if quick_done_during_spin:
        rt_exit(72)
    0
