use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_thread_sleep(ms: i64)
extern fn rt_exit(code: i32)

fn spin_for_us(target_us: i64, value: i64) -> i64:
    val start = rt_time_now_unix_micros()
    while rt_time_now_unix_micros() - start < target_us:
        _ = 1 + 1
    value

fn main() -> i64:
    val zero_clamped = multicore_green_set_parallelism(0)
    println("parallelism_zero_clamped={zero_clamped}")
    if zero_clamped != 1:
        rt_exit(68)
    val negative_clamped = multicore_green_set_parallelism(-3)
    println("parallelism_negative_clamped={negative_clamped}")
    if negative_clamped != 1:
        rt_exit(69)
    multicore_green_set_parallelism(2)
    println("parallelism_before={multicore_green_parallelism()}")
    val h0 = multicore_green_spawn(\: spin_for_us(120000, 1))
    val h1 = multicore_green_spawn(\: spin_for_us(120000, 2))
    rt_thread_sleep(10)
    val h2 = multicore_green_spawn(\: 7)
    println("parallelism_after_submit={multicore_green_parallelism()}")
    println("quick_done_early={h2.is_done()}")
    val total = h0.join() + h1.join() + h2.join()
    println("parallelism_after_join={multicore_green_parallelism()}")
    println("total={total}")
    if total != 10:
        rt_exit(71)
    if multicore_green_parallelism() != 2:
        rt_exit(72)
    0
