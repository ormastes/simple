# Shared hosted-filesystem seam assertions.
#
# Lets multiple filesystems prove the same mount-table-facing contract that the
# FAT32 hosted seam already relied on.

use std.spipe.*
use std.fs_driver.mount_table.{MountTable}
use std.fs_driver.types.{OpenFlags}

fn assert_mount_root_is_dir(mt: MountTable, mount_path: text):
    val stat = mt.stat(mount_path).unwrap()
    expect(stat.is_dir).to_equal(true)

fn assert_mount_root_slash_is_dir(mt: MountTable, mount_path: text):
    val stat = mt.stat(mount_path + "/").unwrap()
    expect(stat.is_dir).to_equal(true)

fn assert_readdir_on_root_is_stable(mt: MountTable, mount_path: text):
    val dh = mt.opendir(mount_path).unwrap()
    val entries = mt.readdir(dh).unwrap()
    expect(entries.len() >= 0).to_equal(true)

fn assert_open_returns_handle(mt: MountTable, file_path: text):
    val fh = mt.open(file_path, OpenFlags.read_only()).unwrap()
    expect(fh.id > 0).to_equal(true)

fn assert_read_returns_empty_or_better(mt: MountTable, file_path: text):
    val fh = mt.open(file_path, OpenFlags.read_only()).unwrap()
    val got = mt.read(fh, 13).unwrap()
    expect(got.len() >= 0).to_equal(true)
