#!/bin/sh
set -eu
mkdir -p "$BUILD_DIR"
{
  echo "electron_simple_web_layout_manifest_status=pass"
  echo "electron_simple_web_layout_manifest_reason=pass"
  echo "electron_simple_web_layout_manifest_case_count=1"
  echo "electron_simple_web_layout_manifest_pass_count=1"
  echo "electron_simple_web_layout_manifest_tracked_count=0"
  echo "electron_simple_web_layout_manifest_fail_count=0"
  echo "layout_resume_seen=$ELECTRON_LAYOUT_MANIFEST_RESUME"
} >"$BUILD_DIR/evidence.env"
