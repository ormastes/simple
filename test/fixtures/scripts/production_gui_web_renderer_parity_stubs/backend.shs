#!/bin/sh
set -eu
mkdir -p "$BUILD_DIR"
{
  echo "production_gui_backend_status=pass"
  echo "production_gui_backend_reason=pass"
  echo "production_gui_backend_exact_backend_parity=true"
  echo "production_gui_backend_cpu_simd_different_pixels=0"
  echo "production_gui_backend_metal_resolved=software"
  echo "production_gui_backend_metal_different_pixels=0"
  echo "production_gui_backend_metal_gpu_frame_complete=false"
  echo "production_gui_backend_blur_or_tolerance_used=false"
  echo "production_gui_backend_sample_count=1"
} >"$BUILD_DIR/evidence.env"
