use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_draw_ir
}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{
    engine2d_draw_ir_adv_composition
}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}

fn fixture_html() -> text:
    [
        "<!doctype html>\n",
        "<meta charset=\"utf-8\">\n",
        "<style>\n",
        "html, body { margin: 0; padding: 0; width: 320px; height: 240px; overflow: hidden; background: #ffffff; }\n",
        ".box { width: 80px; height: 40px; margin: 8px; background: #2563eb; }\n",
        ".box-red { width: 60px; height: 30px; margin: 8px; padding: 4px; background: #ef4444; }\n",
        ".box-green { width: 100px; height: 20px; margin: 4px 8px; background: #22c55e; }\n",
        "</style>\n",
        "<body>\n",
        "<div class=\"box\"></div>\n",
        "<div class=\"box-red\"></div>\n",
        "<div class=\"box-green\"></div>\n",
        "</body>\n",
        "</html>\n"
    ].join("")

fn main() -> i64:
    val composition = simple_web_layout_render_html_draw_ir(fixture_html(), 320, 240)
    var producer_count: i64 = 0
    var producer_rects: i64 = 0
    for batch in composition.batches:
        for command in batch.commands:
            producer_count = producer_count + 1
            if command.kind == "rect":
                producer_rects = producer_rects + 1

    val original_batch = composition.batches[0]
    var engine = Engine2D.create_with_backend_fast(320, 240, "metal")
    engine.clear(0u32)
    val rendered = engine2d_draw_ir_adv_composition(engine, composition, true)
    engine.shutdown()

    println("producer={producer_count} rects={producer_rects} embedding={original_batch.embedding.x},{original_batch.embedding.y},{original_batch.embedding.width},{original_batch.embedding.height},{original_batch.embedding.opacity_milli} rendered={rendered.rendered_command_count} skipped={rendered.skipped_command_count} source={rendered.readback_source}")
    if (producer_count == 4 and producer_rects == 4 and
        rendered.rendered_command_count == 4 and rendered.skipped_command_count == 0 and
        rendered.readback_source == "device_readback"):
        return 0
    94
