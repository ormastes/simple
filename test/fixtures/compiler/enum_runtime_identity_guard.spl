use compiler.hir.hir_types.{SymbolTable}
use compiler.mir.mir_lowering.{MirLowering}

fn main() -> i64:
    var lowering = MirLowering.new(SymbolTable.new())
    lowering.register_enum_runtime_name("collision.Type175882", "Type175882", nil)
    lowering.register_enum_runtime_name("collision.Type255081", "Type255081", nil)
    if lowering.errors.len() != 1:
        return 1
    var same = MirLowering.new(SymbolTable.new())
    same.register_enum_runtime_name("pkg.Shared", "Shared", nil)
    same.register_enum_runtime_name("pkg.Shared", "Shared", nil)
    if same.errors.len() != 0:
        return 2
    0
