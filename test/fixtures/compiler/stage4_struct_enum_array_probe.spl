"""Native transport probe for arrays of structs containing enum payloads."""

enum ProbeKind:
    Let(value: i64)
    Expr(value: i64)

struct ProbeStmt:
    kind: ProbeKind
    span: i64

fn probe_value(stmt: ProbeStmt) -> i64:
    val kind: ProbeKind = stmt.kind
    val span: i64 = stmt.span
    match kind:
        case Let(value): value + span
        case Expr(value): value - span
        case _: -1

fn joined_array_value(use_second: bool) -> i64:
    var values = [11]
    if use_second:
        values = [23]
    val copied = values
    copied[0]

fn joined_struct_value(use_second: bool) -> i64:
    var stmt = ProbeStmt(kind: ProbeKind.Let(value: 10), span: 2)
    if use_second:
        stmt = ProbeStmt(kind: ProbeKind.Expr(value: 50), span: 8)
    val copied = stmt
    val stmts = [copied]
    probe_value(stmts[0])

fn narrow_array_value() -> i64:
    val byte: u8 = 255
    if byte != 255: return -5
    val signed: i8 = -2
    val flag: bool = true
    val float32: f32 = 1.5
    val float64: f64 = 2.5
    val bytes: [u8] = [byte]
    val signed_values: [i8] = [signed]
    val flags: [bool] = [flag]
    val floats32: [f32] = [float32]
    val floats64: [f64] = [float64]
    if bytes[0] != 255: return -1
    if signed_values[0] != -2: return -6
    if not flags[0]: return -2
    if floats32[0] != 1.5: return -3
    if floats64[0] != 2.5: return -4
    1

fn nested_collection_value() -> i64:
    val nested = [[7]]
    if nested[0][0] != 7: return -1
    val values: Dict<text, i64> = {"x": 9}
    if values["x"] != 9: return -2
    val nested_dict: Dict<text, Dict<text, i64>> = {"outer": {"inner": 5}}
    if nested_dict["outer"]["inner"] != 5: return -3
    1

fn nil_collection_value() -> i64:
    val values: [i64?] = [nil]
    if values[0] != nil: return -1
    if (values[0] ?? 6) != 6: return -2
    1

fn add_pair(a: i64, b: i64) -> i64:
    a + b

fn zero_value() -> i64:
    31

fn call_zero(f: fn() -> i64) -> i64:
    f()

fn call_pair(f: fn(i64, i64) -> i64) -> i64:
    f(20, 22)

fn identity(value: i64) -> i64:
    value

fn main() -> i64:
    if joined_array_value(false) != 11: return 1
    if joined_array_value(true) != 23: return 2
    if joined_struct_value(false) != 12: return 3
    if joined_struct_value(true) != 42: return 4
    if narrow_array_value() != 1: return 5
    if nested_collection_value() != 1: return 6
    if nil_collection_value() != 1: return 7
    if add_pair(20, 22) != 42: return 8
    if call_zero(zero_value) != 31: return 9
    if call_pair(add_pair) != 42: return 10
    val local_value = 17
    if identity(local_value) != 17: return 11
    0
