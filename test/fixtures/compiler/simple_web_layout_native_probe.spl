use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_software_pixels}

fn main() -> i64:
    val html = "<style></style><style></style><h1>x</h1>"
    val pixels = simple_web_layout_render_html_software_pixels(html, 320, 180)
    if pixels.len() == 57600: 0 else: 1
