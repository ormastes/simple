use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_debug_attr_by_id, simple_web_layout_render_html_software_pixels}

fn main() -> i64:
    val html = "<style></style><style></style><div id='probe' style='width:48px;height:24px;background-color:#224466'></div>"
    if simple_web_layout_debug_attr_by_id(html, "probe", "style") != "width:48px;height:24px;background-color:#224466":
        return 1
    val pixels = simple_web_layout_render_html_software_pixels(html, 64, 48)
    if pixels.len() != 3072:
        return 2
    var color_count = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] == 0xFF224466u32:
            color_count = color_count + 1
        i = i + 1
    if color_count == 1152: 0 else: 3
