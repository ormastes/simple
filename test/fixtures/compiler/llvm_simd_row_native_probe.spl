"""Hosted LLVM probe for exact Engine2D row output and native SIMD execution."""

use std.nogc_sync_mut.gpu.engine2d.simd_native_rows.{
    engine2d_simd_fill_rows_u32,
    engine2d_simd_copy_row_u32
}

extern fn rt_simd_engine2d_neon_reset() -> i64
extern fn rt_simd_engine2d_neon_hits() -> i64
extern fn rt_array_len(array: [u32]) -> i64
extern fn rt_array_get(array: [u32], index: i64) -> i64

fn main() -> i64:
    val color = 4278256131 as u32
    rt_simd_engine2d_neon_reset()
    val fill = engine2d_simd_fill_rows_u32(4, 2, color, 2)
    if rt_array_len(fill) != 8 or (rt_array_get(fill, 7) & 4294967295) != 4278256131:
        return 1
    val copy = engine2d_simd_copy_row_u32(fill)
    if rt_array_len(copy) != 8 or (rt_array_get(copy, 3) & 4294967295) != 4278256131:
        return 2
    if rt_simd_engine2d_neon_hits() < 2:
        return 3
    0
