class Box:
    padding: i64
    value: i64

class Label:
    code: i64
    padding: i64

enum Marker:
    Code(value: i64)
    Empty

fn boxed_box() -> Option<Box>:
    Some(Box(padding: 91, value: 7))

fn boxed_label() -> Option<Label>:
    Some(Label(code: 13, padding: 92))

fn boxed_none() -> Option<Box>:
    None

fn flat_enum() -> Marker?:
    Marker.Code(value: 17)

fn try_marker_value(marker: Marker?) -> i64?:
    val owned = marker?
    marker_value(owned)

fn marker_value(marker: Marker) -> i64:
    match marker:
        case Code(value): value
        case Empty: 0

fn main() -> i64:
    # Construct both class payloads before either unwrap. A global
    # Option::Some payload-name slot makes one identity overwrite the other.
    val maybe_box: Option<Box> = boxed_box()
    val maybe_label: Option<Label> = boxed_label()
    val missing: Option<Box> = boxed_none()
    val maybe_marker: Marker? = flat_enum()

    if maybe_box.is_none(): return 1
    if maybe_label.is_none(): return 2
    if missing.is_some(): return 3

    val box = maybe_box.?
    val label = maybe_label.?
    val fallback = missing.unwrap_or(Box(padding: 93, value: 19))
    val marker = maybe_marker.?
    val direct = maybe_box.unwrap()
    val coalesced = missing ?? Box(padding: 94, value: 23)
    val mapped = maybe_box.map(\item: item.value)
    val tried = try_marker_value(maybe_marker)

    if box.value != 7: return 4
    if label.code != 13: return 5
    if fallback.value != 19: return 6
    if marker_value(marker) != 17: return 7
    if direct.value != 7: return 8
    if coalesced.value != 23: return 9
    if mapped.unwrap_or(0) != 7: return 10
    if tried.unwrap_or(0) != 17: return 11
    0
