class Counter:
    value: i64

    static fn new(v: i64) -> Counter:
        Counter(value: v)

fn mutate_first(counters: [Counter]):
    counters[0].value = counters[0].value + 1

fn main() -> i64:
    val counters = [Counter.new(0), Counter.new(0)]
    mutate_first(counters)
    print(counters[0].value)
    if counters[0].value == 1:
        return 0
    1
