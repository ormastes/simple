fn raw_three() -> i64?:
    3

fn raw_zero() -> i64?:
    0

fn raw_none() -> i64?:
    nil

fn explicit_three() -> Option<i64>:
    Some(3)

fn explicit_zero() -> Option<i64>:
    Some(0)

fn explicit_none() -> Option<i64>:
    None

fn through_argument(value: i64?) -> i64:
    value.unwrap_or(777)

fn through_if(present: bool) -> i64?:
    if present:
        Some(3)
    else:
        None

fn through_function_value(f: fn(i64?) -> i64, value: i64?) -> i64:
    f(value)

fn through_match(selector: i64) -> i64?:
    match selector:
        case 0: 3
        case _: nil

struct OptionHolder:
    value: i64?

fn main() -> i64:
    print(raw_three().unwrap_or(777))
    print(explicit_three().unwrap_or(777))
    print(explicit_none().unwrap_or(777))
    print(raw_none().unwrap_or(777))
    print(raw_zero().unwrap_or(777))
    print(explicit_zero().unwrap_or(777))
    val local_three: i64? = 3
    val alias = local_three
    print(local_three.unwrap_or(777))
    print(alias.unwrap_or(777))
    print(through_argument(3))
    print(through_argument(nil))
    print(through_argument(0))
    print(through_argument(Some(3)))
    val holder = OptionHolder(value: 3)
    val empty_holder = OptionHolder()
    print(holder.value.unwrap_or(777))
    print(empty_holder.value.unwrap_or(777))
    print(through_if(true).unwrap_or(777))
    print(through_if(false).unwrap_or(777))
    print(through_function_value(through_argument, 3))
    print(through_function_value(through_argument, nil))
    print(through_match(0).unwrap_or(777))
    print(through_match(1).unwrap_or(777))
    0
