fn init_value() -> i64: 4
fn init_next(value: i64) -> i64: value + 1
fn label_value() -> i64: 7
val module_value = init_value()
val next_value = init_next(module_value)
val word_bytes: i64 = init_value() * 2
val label: text = "value={label_value()}"

fn main() -> i64:
    if word_bytes != 8: return 1
    if label != "value=7": return 2
    module_value * 10 + next_value
