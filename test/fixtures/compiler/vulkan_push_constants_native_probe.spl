use std.gc_async_mut.gpu.engine2d.backend_vulkan_helpers.{VK_PUSH_CONSTANT_SIZE, _pack_clear_pc, _pack_rect_pc}

fn _read_u32_le(bytes: [u8], offset: i32) -> u32:
    (bytes[offset] as u32) |
        ((bytes[offset + 1] as u32) << 8) |
        ((bytes[offset + 2] as u32) << 16) |
        ((bytes[offset + 3] as u32) << 24)

fn _tail_is_zero(bytes: [u8], used_bytes: i64) -> bool:
    var i = used_bytes
    while i < bytes.len():
        if bytes[i] != 0u8:
            return false
        i = i + 1
    true

fn main() -> i64:
    val word_bytes: i32 = 4
    val color: u32 = 0xA1B2C3D4u32
    val width: i32 = -2
    val height: i32 = 3
    val clear = _pack_clear_pc(color, width, height)
    if clear.len() != VK_PUSH_CONSTANT_SIZE:
        return 1
    if _read_u32_le(clear, 0) != color or (_read_u32_le(clear, word_bytes) as i32) != width or (_read_u32_le(clear, word_bytes * 2) as i32) != height:
        return 2
    if not _tail_is_zero(clear, (word_bytes * 3) as i64):
        return 3

    val x: i32 = -7
    val y: i32 = 9
    val rect_width: i32 = 40
    val rect_height: i32 = 24
    val fb_width: i32 = 64
    val fb_height: i32 = 48
    val clip_x: i32 = 2
    val clip_y: i32 = 3
    val clip_width: i32 = 50
    val clip_height: i32 = 32
    val rect = _pack_rect_pc(x, y, rect_width, rect_height, color, fb_width, fb_height, clip_x, clip_y, clip_width, clip_height, true)
    val expected: [i32] = [x, y, rect_width, rect_height, color as i32, fb_width, fb_height, clip_x, clip_y, clip_width, clip_height, 1]
    var field: i32 = 0
    while field < expected.len():
        if (_read_u32_le(rect, field * word_bytes) as i32) != expected[field]:
            return 4
        field = field + 1
    if not _tail_is_zero(rect, (field * word_bytes) as i64):
        return 5
    0
