# Builtin-looking method names belong to their receiver type. Shared MIR must
# lower Option/Result operations only after proving the receiver is Option or
# Result; backend adapters must not dispatch from the leaf name alone.
struct Names:
    value: i64

var make_calls = 0

impl Names:
    fn is_some(self) -> bool:
        false

    fn is_none(self) -> bool:
        true

    fn unwrap(self) -> i64:
        self.value

    fn unwrap_or(self, fallback: i64) -> i64:
        self.value + fallback

    fn unwrap_err(self) -> text:
        "custom"

    fn map(self, transform: fn(i64) -> i64) -> i64:
        transform(self.value)

fn text_error() -> Result<i64, text>:
    Err("boom")

fn make_names() -> Names:
    make_calls = make_calls + 1
    Names(value: 7)

fn main() -> i64:
    val names = Names(value: 7)
    print(names.is_some())
    print(names.is_none())
    print(names.unwrap())
    print(names.unwrap_or(5))
    print(names.unwrap_err())
    print(names.map(\value: value + 1))
    print(text_error().unwrap_err())
    print(make_names().unwrap())
    print(make_calls)
    return 0
