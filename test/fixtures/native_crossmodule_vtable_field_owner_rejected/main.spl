use test.fixtures.native_crossmodule_vtable_field_owner_rejected.provider.{VtableFieldOwner}

fn main():
    # Direct imported construction must relocate the provider's qualified
    # vtable data object and preserve the +8 object-header layout.
    var owned = VtableFieldOwner(id: 7, payload: "direct", width: 1024, height: 720)
    val initial_width = owned.width
    val initial_height = owned.height
    owned.width = 1280
    owned.height = 800
    if initial_width == 1024 and initial_height == 720 and owned.width == 1280 and owned.height == 800:
        print "DIRECT_IMPORTED_VTABLE_INIT_PASS"
    else:
        print "DIRECT_IMPORTED_VTABLE_INIT_FAIL"
