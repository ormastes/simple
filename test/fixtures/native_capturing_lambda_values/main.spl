struct Box:
    value: i64

extern fn rt_closure_func_ptr(value: i64) -> i64

fn apply(f: fn(i64) -> i64, x: i64) -> i64:
    return f(x)

fn increment(x: i64) -> i64:
    return x + 1

fn main() -> i64:
    var n = 5
    val add_n = \x: x + n
    n = 100
    print(apply(add_n, 3))

    val box = Box(value: 40)
    val add_box = \x: box.value + x
    print(apply(add_box, 2))
    print(apply(increment, 6))
    # A tagged-looking non-member must be rejected without dereferencing 0x1000.
    print(rt_closure_func_ptr(4097))
    return 0
