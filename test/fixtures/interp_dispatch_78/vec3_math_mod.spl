## vec3_math_mod.spl — defines a struct named `Vec3` (deliberately same simple
## name pattern as many modules use) plus a free fn ctor-style function, to
## test module-qualified dispatch when the CALLING file ALSO defines a
## same-named struct/global (collision scenario for task #78).

struct Vec3:
    x: i64
    y: i64
    z: i64

fn make_vec3(x: i64, y: i64, z: i64) -> Vec3:
    Vec3(x: x, y: y, z: z)

export Vec3, make_vec3
