## math_mod78.spl — defines Vec3Math78 struct + a module-level free fn
## Fixture for task #78: module-qualified constructor/function dispatch
## (`math.Vec3Math78(...)` and `math.add_vec3_78(...)` called qualified from
## another file that imports this module under the alias `math`).
## Struct named uniquely (Vec3Math78) to avoid the interp global-registry
## name collision documented for same-named structs across modules.

struct Vec3Math78:
    x: i64
    y: i64
    z: i64

fn add_vec3_78(a: Vec3Math78, b: Vec3Math78) -> Vec3Math78:
    Vec3Math78(x: a.x + b.x, y: a.y + b.y, z: a.z + b.z)

export Vec3Math78, add_vec3_78
