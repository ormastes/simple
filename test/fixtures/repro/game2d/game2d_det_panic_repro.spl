# Game2D AC-4 determinism guard repro — Phase 7 verify.
# Calls time.now() outside any callback while deterministic mode is on.
# Expected: panic GAME-DET-001.
use std.nogc_sync_mut.game2d.time.det_guard as t

fn main():
    t.set_deterministic_mode(true)
    val ts = t.now()
    print("UNEXPECTED: ts = " + ts.to_text())
