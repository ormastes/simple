struct FramebufferDriver:
    front_addr: i64
    back_buffer: i64
    width: i64
    height: i64

struct DisplayState:
    frame_id: i64
    driver: FramebufferDriver

fn make_display_state() -> DisplayState:
    DisplayState(
        frame_id: 7,
        driver: FramebufferDriver(front_addr: 11, back_buffer: 22, width: 640, height: 480),
    )

export FramebufferDriver, DisplayState, make_display_state
