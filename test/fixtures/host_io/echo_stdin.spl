# Fixture: echo_stdin.spl
# Reads one line from stdin and writes it back to stdout.
# rt_read_stdin_line strips the trailing newline, so we add it back.
# Used by stdio_async_spec.spl to verify round-trip behaviour.
#
# Works in interpreter mode (bin/simple run with piped stdin).
#
# Run via shell pipe:
#   printf 'hello\n' | bin/simple run test/fixtures/host_io/echo_stdin.spl

extern fn rt_read_stdin_line() -> text

fn main():
    val line = rt_read_stdin_line()
    if line == "":
        pass_dn
    else:
        print_raw(line + "\n")
