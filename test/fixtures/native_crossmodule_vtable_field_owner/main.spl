use test.fixtures.native_crossmodule_vtable_field_owner.provider.{
    VtableFieldOwner,
    make_vtable_field_owner
}

# First local custom type intentionally occupies the same per-module numeric
# TypeId ordinal as the provider's trait-bearing class.
class PlainFieldOwner:
    width: i64
    height: i64

fn main():
    var plain = PlainFieldOwner(width: 11, height: 22)
    plain.width = 33
    plain.height = 44

    print "CROSSMODULE_STAGE before-factory"
    var owned: VtableFieldOwner = make_vtable_field_owner()
    print "CROSSMODULE_STAGE after-factory"
    val direct_width = owned.width
    val direct_height = owned.height
    print "CROSSMODULE_STAGE after-direct-read"
    owned.width = 1280
    owned.height = 800
    print "CROSSMODULE_STAGE after-direct-write"

    val valid = plain.width == 33 and plain.height == 44 and direct_width == 1024 and direct_height == 720 and owned.width == 1280 and owned.height == 800
    if valid:
        print "CROSSMODULE_VTABLE_FIELD_OWNER_PASS"
    else:
        print "CROSSMODULE_VTABLE_FIELD_OWNER_FAIL"
        print plain.width
        print plain.height
        print direct_width
        print direct_height
        print owned.width
        print owned.height
