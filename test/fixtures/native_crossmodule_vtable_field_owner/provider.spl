trait FieldOwnerMarker:
    fn marker() -> i64

class VtableFieldOwner:
    id: i64
    payload: text
    width: i64
    height: i64

    fn width_via_owner() -> i64:
        self.width

    fn height_via_owner() -> i64:
        self.height

impl FieldOwnerMarker for VtableFieldOwner:
    fn marker() -> i64:
        self.id

fn make_vtable_field_owner() -> VtableFieldOwner:
    VtableFieldOwner(id: 7, payload: "provider", width: 1024, height: 720)

export FieldOwnerMarker, VtableFieldOwner, make_vtable_field_owner
