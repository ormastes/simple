# Scripted replay frames for AC-5 (game2d_replay_spec.spl).
# Each frame holds an InputSnapshot (keys_down, keys_pressed, mouse_pos,
# mouse_buttons). 6 frames = 100ms @ 60Hz.
replay:
  frames:
    - frame: 0
      keys_down: ["Right"]
      keys_pressed: ["Right"]
      mouse_pos: [0.0, 0.0]
      mouse_buttons: []
    - frame: 1
      keys_down: ["Right"]
      keys_pressed: []
      mouse_pos: [0.0, 0.0]
      mouse_buttons: []
    - frame: 2
      keys_down: ["Right"]
      keys_pressed: []
      mouse_pos: [0.0, 0.0]
      mouse_buttons: []
    - frame: 3
      keys_down: ["Right"]
      keys_pressed: []
      mouse_pos: [0.0, 0.0]
      mouse_buttons: []
    - frame: 4
      keys_down: ["Right"]
      keys_pressed: []
      mouse_pos: [0.0, 0.0]
      mouse_buttons: []
    - frame: 5
      keys_down: []
      keys_pressed: []
      mouse_pos: [0.0, 0.0]
      mouse_buttons: []
expected:
  player_x: 0.6
  epsilon: 0.01
