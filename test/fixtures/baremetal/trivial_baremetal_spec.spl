# Trivial baremetal test — verifies the compile-and-run pipeline.
#
# This file is compiled to a RISC-V ELF and run on QEMU with semihosting.
# It does NOT use SSpec (describe/it/expect) because the SSpec framework
# requires runtime features that may not be available in baremetal mode.
#
# Instead, it prints results directly and exits with 0 on success.

fn main() -> i64:
    # Basic arithmetic check
    val a = 2 + 3
    if a == 5:
        print "PASS: arithmetic 2+3=5"
    else:
        print "FAIL: arithmetic 2+3 expected 5"
        return 1

    # String literal check
    val greeting = "hello"
    if greeting == "hello":
        print "PASS: string literal"
    else:
        print "FAIL: string literal mismatch"
        return 1

    print "All baremetal tests passed"
    return 0
