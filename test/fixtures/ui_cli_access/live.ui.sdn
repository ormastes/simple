app:
    title: "UI CLI access fixture"
    theme: glass_dark

layout:
    type: vbox
    id: root
    children:
        main:
            type: panel
            id: main_panel
            title: "UI CLI access fixture"
            flex: 1
            children:
                greeting:
                    type: text
                    id: greeting
                    content: "Hello UI CLI access"
                noop:
                    type: button
                    id: noop
                    label: "Invoke noop"
                    action: focus_noop
