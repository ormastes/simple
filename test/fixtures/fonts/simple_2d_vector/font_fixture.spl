"""Deterministic TTF fixtures derived from ttf-parser's 400-byte demo font.

Source and derivatives are dual licensed MIT OR Apache-2.0. The Latin-1 lane
changes only the format-4 cmap from U+0041 to U+00E9 and its delta.
"""

val SIMPLE_2D_ASCII_FONT_HEX = ""

fn _font_hex_nibble(code: i32) -> i32:
    if code >= 48 and code <= 57:
        return code - 48
    if code >= 97 and code <= 102:
        return code - 87
    0

fn _font_hex_bytes(value: text) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i + 1 < value.len():
        val hi = _font_hex_nibble(value.char_code_at(i))
        val lo = _font_hex_nibble(value.char_code_at(i + 1))
        out.push((hi * 16 + lo).to_u8())
        i = i + 2
    out

fn simple_2d_ascii_font_bytes() -> [u8]:
    _font_hex_bytes(SIMPLE_2D_ASCII_FONT_HEX)

fn simple_2d_latin1_font_bytes() -> [u8]:
    var bytes = simple_2d_ascii_font_bytes()
    bytes[283] = 0xE9u8
    bytes[289] = 0xE9u8
    bytes[292] = 0xFFu8
    bytes[293] = 0x18u8
    bytes
