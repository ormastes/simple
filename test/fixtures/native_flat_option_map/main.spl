use native_flat_option_map.provider.{next_external_text}

class Counter:
    value: i64

    static fn new(value: i64) -> Counter:
        Counter(value: value)

fn increment(counters: [Counter]):
    counters[0].value = counters[0].value + 1

fn next_value(present: bool, calls: [Counter]) -> i64?:
    increment(calls)
    if present:
        return 5
    return nil

fn map_value(value: i64, delta: i64, calls: [Counter]) -> text:
    increment(calls)
    return (value + delta).to_string()

fn default_text(calls: [Counter]) -> text:
    increment(calls)
    return "missing"

fn next_float(present: bool) -> f64?:
    if present:
        return 1.5
    return nil

fn next_text(present: bool) -> text?:
    if present:
        return "simple"
    return nil

fn main() -> i64:
    val delta = 2
    val receiver_calls = [Counter.new(0)]
    val mapper_calls = [Counter.new(0)]
    val default_calls = [Counter.new(0)]
    val present = next_value(true, receiver_calls).map(\x: map_value(x, delta, mapper_calls)).unwrap_or(default_text(default_calls))
    if present != "7":
        return 11
    if receiver_calls[0].value != 1:
        return 12
    if mapper_calls[0].value != 1:
        return 13
    if default_calls[0].value != 1:
        return 14

    val absent = next_value(false, receiver_calls).map(\x: map_value(x, delta, mapper_calls)).unwrap_or(default_text(default_calls))
    if absent != "missing":
        return 21
    if receiver_calls[0].value != 2:
        return 22
    if mapper_calls[0].value != 1:
        return 23
    if default_calls[0].value != 2:
        return 24

    val float_present = next_float(true).map(\x: x + 0.5).unwrap_or(9.0)
    if float_present != 2.0:
        return 31

    val float_absent = next_float(false).map(\x: x + 0.5).unwrap_or(9.0)
    if float_absent != 9.0:
        return 41

    val text_present = next_text(true).map(\x: x + "-os").unwrap_or("missing")
    if text_present != "simple-os":
        return 51

    val text_absent = next_text(false).map(\x: x + "-os").unwrap_or("missing")
    if text_absent != "missing":
        return 61

    val external_text = next_external_text(true).map(\x: x + "-module").unwrap_or("missing")
    if external_text != "cross-module":
        return 71

    val external_absent = next_external_text(false).map(\x: x + "-module").unwrap_or("missing")
    if external_absent != "missing":
        return 72

    print("flat-option-map-ok")
    return 0
