# Fixture: dup_pair/a.spl - deliberately duplicated ~15-line function body.
# The checker MUST report this pair (see duplicate_check_unit_spec.spl /
# duplicate_check_contract_spec.spl). Body is identical to b.spl's
# score_order_total_b; only the function name differs.

fn score_order_total_a(base: i64, extra: i64, discount: i64) -> i64:
    var total = base
    total = total + extra
    if discount > 0:
        total = total - discount
    var bonus = 0
    if total > 100:
        bonus = 10
    elif total > 50:
        bonus = 5
    else:
        bonus = 0
    total = total + bonus
    var tax = total / 10
    total = total + tax
    if total < 0:
        total = 0
    return total
