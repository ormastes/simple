fn main() -> i64:
    var values: [text] = []
    var i = 0
    while i < 10000:
        values = values + ["item-{i}-{i * 17}"]
        i = i + 1
    var checksum = 0
    for value in values:
        checksum = checksum + value.len()
    print("{values.len()} {checksum}")
    if values.len() == 10000 and checksum > 100000: 0 else: 1
