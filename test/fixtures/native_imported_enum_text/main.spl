use test.fixtures.native_imported_enum_text.event.{ImportedTextEvent, deliver}

fn action_name(event: ImportedTextEvent) -> text:
    match event:
        ImportedTextEvent.Action(name): name
        _: ""

fn main() -> i64:
    val name = deliver(ImportedTextEvent.Action(name: "run"), action_name)
    if name != "run":
        eprint("expected=run actual={name}")
        return 1
    print(name)
    return 0
