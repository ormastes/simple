use compiler.frontend.core.parser.{parse_module, parser_has_errors}

extern fn rt_time_now_monotonic_ms() -> i64

fn generated_module(count: i64) -> text:
    var source = ""
    var i = 0
    while i < count:
        source = source + "fn f{i}() -> i64:\n    {i}\n"
        i = i + 1
    source

fn parse_ms(source: text) -> i64:
    val started = rt_time_now_monotonic_ms()
    parse_module(source, "generated.spl")
    rt_time_now_monotonic_ms() - started

fn main() -> i64:
    val small_ms = parse_ms(generated_module(440))
    if parser_has_errors():
        return 1
    val large_ms = parse_ms(generated_module(880))
    if parser_has_errors():
        return 2
    print("{small_ms} {large_ms}")
    if large_ms >= 15000 or (small_ms >= 100 and large_ms > small_ms * 3):
        return 3
    0
