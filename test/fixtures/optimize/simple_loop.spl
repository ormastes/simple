"""
Minimal fixture for optimize CLI tests.
Contains a simple loop with a redundant bounds check and a loop-invariant load
so the optimizer has something real to analyze.
"""

fn sum_array(arr: List<i64>) -> i64
    val n = arr.len()
    var total = 0
    var i = 0
    while i < n:
        total = total + arr[i]
        i = i + 1
    total
