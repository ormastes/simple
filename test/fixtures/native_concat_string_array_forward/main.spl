extern fn rt_execute_native(binary_path: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn forwarded() -> text:
    return "forwarded"

fn main() -> i64:
    val (stdout, _, code) = rt_execute_native("/bin/echo", ["concat-" + forwarded()], 5000)
    print(stdout)
    print(code)
    return 0
