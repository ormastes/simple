use native_crossmodule_result_u8.provider.{BytesError, CrossZeroArgReceiver, fail_bytes, load_bytes}
use std.path.{normalize, path_join, relative_to}

var option_receiver_calls = 0

fn next_cross_target_option() -> i64?:
    option_receiver_calls = option_receiver_calls + 1
    return 5

fn cross_target_option_map_once_ok() -> bool:
    val mapped = next_cross_target_option().map(\x: x + 1).unwrap_or(99)
    mapped == 6 and option_receiver_calls == 1

fn cross_target_option_exists_ok() -> bool:
    val value: i64? = 7
    if val payload = value.?:
        return payload == 7
    false

struct CrossInnerCopy:
    n: i64

class CrossSharedRef:
    n: i64

struct CrossOuterCopy:
    inner: CrossInnerCopy
    shared: CrossSharedRef

fn mutate_cross_copy(value: CrossOuterCopy):
    value.inner.n = 9
    value.shared.n = 5

fn cross_target_nested_copy_ok() -> bool:
    var original = CrossOuterCopy(inner: CrossInnerCopy(n: 1), shared: CrossSharedRef(n: 3))
    var local_copy = original
    local_copy.inner.n = 2
    local_copy.shared.n = 4
    if original.inner.n != 1 or original.shared.n != 4:
        return false
    mutate_cross_copy(original)
    original.inner.n == 1 and original.shared.n == 5

class CrossArrayContainer:
    var marker: i64
    var items: [i64]

impl CrossArrayContainer:
    fn zero_arg_local_receiver_ok(self, receiver: CrossZeroArgReceiver) -> bool:
        val actual = receiver.read()
        actual == 37 and self.marker == 99

fn mutate_cross_array(c: CrossArrayContainer):
    c.items.push(42)
    c.items[0] = 7

fn cross_target_class_array_ok() -> bool:
    var container = CrossArrayContainer(marker: 99, items: [11])
    val alias = container.items
    mutate_cross_array(container)
    if container.items.len() != 2 or alias.len() != 2:
        return false
    if container.items[0] != 7 or container.items[1] != 42:
        return false
    val receiver = CrossZeroArgReceiver(value: 37)
    alias[0] == 7 and alias[1] == 42 and container.zero_arg_local_receiver_ok(receiver)

struct CrossFlagBox:
    bits: [bool]

class CrossNameBox:
    var marker: i64
    var values: [text]

fn cross_target_bool_array_interp_ok() -> bool:
    val flags: [bool] = [true, false]
    val val_true = flags[0]
    var var_false = flags[1]
    val box = CrossFlagBox(bits: [false, true])
    val field_bool = box.bits[1]
    val names = CrossNameBox(marker: 99, values: ["left", "right"])
    val field_text = names.values[1]
    val actual = "{flags[0]}/{flags[1]};{val_true}/{var_false};{box.bits[0]}/{field_bool};{names.values[0]}/{field_text}/{names.marker}"
    actual == "true/false;true/false;false/true;left/right/99"

fn cross_target_text_option_unwrap_ok() -> bool:
    val value: text? = "opt"
    val rendered = "{value.unwrap()}"
    rendered == "opt"

fn cross_target_path_ok() -> bool:
    path_join(["left", "right", "file.spl"]) == "left/right/file.spl" and
        normalize("left/./right/../file.spl") == "left/file.spl" and
        relative_to("/repo/src/file.spl", "/repo") == "src/file.spl"

fn cross_target_char_code_at_ok() -> bool:
    val raw = "A—B"
    val tagged = "A" + "—B"
    raw.char_code_at(0) == 65 and raw.char_code_at(1) == 8212 and raw.char_code_at(2) == 66 and
        tagged.char_code_at(0) == 65 and tagged.char_code_at(1) == 8212 and tagged.char_code_at(2) == 66

fn forward_load_bytes() -> Result<[u8], BytesError>:
    val data = load_bytes()?
    Ok(data)

fn forward_fail_bytes() -> Result<[u8], BytesError>:
    val data = fail_bytes()?
    Ok(data)

fn cross_target_arithmetic_ok() -> bool:
    val signed_int: i64 = 41
    if not (signed_int < 41.5) or 41.5 < signed_int:
        return false
    val small: i64 = 1
    val high: u64 = 0x8000000000000000u64
    if not (small < high) or high < small:
        return false
    if not (small <= high) or high <= small:
        return false
    if small > high or not (high > small):
        return false
    if small >= high or not (high >= small):
        return false
    if not (high > 0.0) or not (0.0 < high):
        return false
    if high < 9223372036854775808.0 or not (high <= 9223372036854775808.0):
        return false
    if high / 2u64 != 0x4000000000000000u64 or high % 3u64 != 2u64:
        return false
    if high >> 63u64 != 1u64:
        return false
    val negative: i64 = -2
    val unsigned_count: u64 = 1u64
    if negative >> unsigned_count != -1:
        return false
    val signed_dividend: i64 = -9
    if signed_dividend / 2 != -4 or signed_dividend % 2 != -1:
        return false
    true

fn main() -> i64:
    match forward_load_bytes():
        Ok(data):
            if data.len() != 3 or data[0] != 17u8 or data[2] != 43u8:
                return 1
        Err(_):
            return 2

    if not cross_target_arithmetic_ok():
        return 5
    if not cross_target_option_map_once_ok():
        return 6
    if not cross_target_nested_copy_ok():
        return 7
    if not cross_target_class_array_ok():
        return 8
    if not cross_target_bool_array_interp_ok():
        return 9
    if not cross_target_text_option_unwrap_ok():
        return 10
    if not cross_target_option_exists_ok():
        return 11
    if not cross_target_path_ok():
        return 12
    if not cross_target_char_code_at_ok():
        return 13

    match forward_fail_bytes():
        Ok(_):
            return 4
        Err(_):
            print("result-u8-ok")
            return 0
    return 3
