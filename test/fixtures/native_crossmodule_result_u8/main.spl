use native_crossmodule_result_u8.provider.{BytesError, fail_bytes, load_bytes}

fn main() -> i64:
    match load_bytes():
        Ok(data):
            if data.len() != 3 or data[0] != 17u8 or data[2] != 43u8:
                return 1
        Err(_):
            return 2

    match fail_bytes():
        Ok(_):
            return 4
        Err(_):
            print("result-u8-ok")
            return 0
    return 3
