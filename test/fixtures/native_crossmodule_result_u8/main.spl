use native_crossmodule_result_u8.provider.{BytesError, CrossProviderIdentity, CrossZeroArgReceiver, fail_bytes, load_bytes, provider_identity}
use std.path.{normalize, path_join, relative_to}

extern fn rt_array_new_with_cap_u64(cap: i64) -> [u64]
extern fn rt_typed_words_u64_push(array: [u64], value: i64) -> bool
extern fn rt_byte_array_new(cap: i64) -> [u8]
extern fn rt_typed_bytes_u8_push(array: [u8], value: i64) -> bool
extern fn rt_enum_id(value: Any) -> i64

# Same-named UFCS functions must not steal primitive integer builtins.
fn chr(code: i64) -> text:
    "wrong-chr"

fn to_char(code: i64) -> text:
    "wrong-to-char"

struct CrossCharOwner:
    marker: i64

impl CrossCharOwner:
    fn chr(self) -> text:
        "owned-chr"

    fn to_char(self) -> text:
        "owned-to-char"

fn cross_target_init_value() -> i64: 4
fn cross_target_init_next(value: i64) -> i64: value + 1
fn cross_target_init_f32() -> f32: 3.5f32
fn cross_target_init_f64() -> f64: 3.5
val cross_target_module_value = cross_target_init_value()
val cross_target_next_value = cross_target_init_next(cross_target_module_value)
val cross_target_module_f32: f32 = cross_target_init_f32()
val cross_target_module_f64: f64 = cross_target_init_f64()

var option_receiver_calls = 0

fn cross_target_module_init_order_ok() -> bool:
    cross_target_module_value * 10 + cross_target_next_value == 45 and
        cross_target_module_f32 == 3.5f32 and cross_target_module_f32 * 2.0f32 == 7.0f32 and
        cross_target_module_f64 == 3.5 and cross_target_module_f64 * 2.0 == 7.0

fn next_cross_target_option() -> i64?:
    option_receiver_calls = option_receiver_calls + 1
    return 5

fn cross_target_option_map_once_ok() -> bool:
    val mapped = next_cross_target_option().map(\x: x + 1).unwrap_or(99)
    mapped == 6 and option_receiver_calls == 1

fn cross_target_option_exists_ok() -> bool:
    val value: i64? = 7
    if val payload = value.?:
        return payload == 7
    false

struct CrossInnerCopy:
    n: i64

class CrossSharedRef:
    n: i64

struct CrossOuterCopy:
    inner: CrossInnerCopy
    shared: CrossSharedRef

fn mutate_cross_copy(value: CrossOuterCopy):
    value.inner.n = 9
    value.shared.n = 5

fn cross_target_nested_copy_ok() -> bool:
    var original = CrossOuterCopy(inner: CrossInnerCopy(n: 1), shared: CrossSharedRef(n: 3))
    var local_copy = original
    local_copy.inner.n = 2
    local_copy.shared.n = 4
    if original.inner.n != 1 or original.shared.n != 4:
        return false
    mutate_cross_copy(original)
    original.inner.n == 1 and original.shared.n == 5

class CrossArrayContainer:
    var marker: i64
    var items: [i64]

impl CrossArrayContainer:
    fn zero_arg_local_receiver_ok(self, receiver: CrossZeroArgReceiver) -> bool:
        val actual = receiver.read()
        actual == 37 and self.marker == 99

fn mutate_cross_array(c: CrossArrayContainer):
    c.items.push(42)
    c.items[0] = 7

fn cross_target_class_array_ok() -> bool:
    var container = CrossArrayContainer(marker: 99, items: [11])
    val alias = container.items
    mutate_cross_array(container)
    if container.items.len() != 2 or alias.len() != 2:
        return false
    if container.items[0] != 7 or container.items[1] != 42:
        return false
    val receiver = CrossZeroArgReceiver(value: 37)
    alias[0] == 7 and alias[1] == 42 and container.zero_arg_local_receiver_ok(receiver)

struct CrossFlagBox:
    bits: [bool]

class CrossNameBox:
    var marker: i64
    var values: [text]

fn cross_target_bool_array_interp_ok() -> bool:
    val flags: [bool] = [true, false]
    val val_true = flags[0]
    var var_false = flags[1]
    val box = CrossFlagBox(bits: [false, true])
    val field_bool = box.bits[1]
    val names = CrossNameBox(marker: 99, values: ["left", "right"])
    val field_text = names.values[1]
    val actual = "{flags[0]}/{flags[1]};{val_true}/{var_false};{box.bits[0]}/{field_bool};{names.values[0]}/{field_text}/{names.marker}"
    actual == "true/false;true/false;false/true;left/right/99"

fn cross_target_conditional_interp_ok() -> bool:
    val probe_bits: u8 = 3u8
    val set_mask: u8 = 1u8
    val clear_mask: u8 = 4u8
    val actual = "{if (probe_bits & set_mask) != 0u8: 1 else: 0}/{if (probe_bits & clear_mask) != 0u8: 1 else: 0}"
    actual == "1/0"

fn cross_target_text_option_unwrap_ok() -> bool:
    val value: text? = "opt"
    val rendered = "{value.unwrap()}"
    rendered == "opt"

fn cross_target_path_ok() -> bool:
    path_join(["left", "right", "file.spl"]) == "left/right/file.spl" and
        normalize("left/./right/../file.spl") == "left/file.spl" and
        relative_to("/repo/src/file.spl", "/repo") == "src/file.spl"

fn cross_target_char_code_at_ok() -> bool:
    val raw = "A—B"
    val tagged = "A" + "—B"
    raw.char_code_at(0) == 65 and raw.char_code_at(1) == 8212 and raw.char_code_at(2) == 66 and
        tagged.char_code_at(0) == 65 and tagged.char_code_at(1) == 8212 and tagged.char_code_at(2) == 66 and
        (raw.char_code_at(0) as u8) == 65u8 and (tagged.char_code_at(1) as u32) == 8212u32 and
        raw.char_code_at(-1) == 0 and raw.char_code_at(99) == 0 and
        tagged.char_code_at(-1) == 0 and tagged.char_code_at(99) == 0

fn cross_target_chr_builtin_owner_ok() -> bool:
    val a: i64 = 65
    val z: i64 = 90
    val acute: i64 = 233
    val smile: i64 = 128578
    val nul = 0.chr()
    val owner: CrossCharOwner = CrossCharOwner(marker: 1)
    (a.chr() == "A" and z.to_char() == "Z" and acute.chr() == "é" and smile.to_char() == "🙂" and
        nul.len() == 1 and nul.char_code_at(0) == 0 and
        owner.chr() == "owned-chr" and owner.to_char() == "owned-to-char")

fn cross_target_text_predicate_conversion_ok() -> bool:
    val sample = "prefix-" + "middle-suffix"
    if not sample.starts_with("prefix") or not sample.ends_with("suffix") or not sample.contains("middle"):
        return false
    if sample.starts_with("middle") or sample.ends_with("middle") or sample.contains("absent"):
        return false
    val truth = true
    val falsehood = false
    val decimal: f64 = 3.5
    val signed: i64 = -7
    val unsigned: u64 = 0x8000000000000000u64
    val plain = "plain"
    val string_rendered = truth.to_string() + "|" + falsehood.to_string() + "|" + decimal.to_string() + "|" + signed.to_string() + "|" + unsigned.to_string() + "|" + plain.to_string()
    val text_rendered = truth.to_text() + "|" + falsehood.to_text() + "|" + decimal.to_text() + "|" + signed.to_text() + "|" + unsigned.to_text() + "|" + plain.to_text()
    val expected = "true|false|3.5|-7|9223372036854775808|plain"
    string_rendered == expected and text_rendered == expected

fn cross_target_tuple_parts(alternate: bool) -> (i64, i64, bool):
    if alternate:
        return (1, 2, false)
    (17, 37, true)

fn cross_target_tuple_clobber(alternate: bool) -> (i64, i64, bool):
    if alternate:
        return (3, 4, true)
    (91, 99, false)

fn cross_target_tuple_return_survives_call() -> bool:
    val parts = cross_target_tuple_parts(false)
    if not parts.2:
        return false
    val clobber = cross_target_tuple_clobber(false)
    if clobber.0 != 91 or clobber.1 != 99 or clobber.2:
        return false
    parts.0 == 17 and parts.1 == 37 and parts.2

enum CrossExecutionPolicy:
    Suggested
    Preferred
    Required

enum CrossNamedPolicy:
    Named(text)

enum CrossScalarPolicy:
    Scalar(i64)

enum CrossArrayPolicy:
    Values([u64])

enum CrossAnyArrayPolicy:
    Values(Any)

enum CrossIdentityLeft:
    Same

enum CrossIdentityRight:
    Same

enum CrossIdentityBox:
    Wrapped(Any)

class CrossExecutionConfig:
    var execution_policy: CrossExecutionPolicy

class CrossNamedConfig:
    var policy: CrossNamedPolicy

fn cross_target_policy_is_suggested(policy: CrossExecutionPolicy) -> bool:
    policy == CrossExecutionPolicy.Suggested

fn cross_target_policy_value() -> CrossExecutionPolicy:
    CrossExecutionPolicy.Required

fn cross_target_enum_merge_ok(choose_suggested: bool) -> bool:
    val policy: CrossExecutionPolicy = if choose_suggested: CrossExecutionPolicy.Suggested else: CrossExecutionPolicy.Preferred
    policy == CrossExecutionPolicy.Suggested

fn cross_target_enum_match_ok(choose_suggested: bool) -> bool:
    val selector = if choose_suggested: 1 else: 2
    val policy: CrossExecutionPolicy = match selector:
        1 => CrossExecutionPolicy.Suggested
        _ => CrossExecutionPolicy.Preferred
    policy == CrossExecutionPolicy.Suggested

fn cross_target_enum_field_equality_ok() -> bool:
    val config = CrossExecutionConfig(execution_policy: CrossExecutionPolicy.Suggested)
    if config.execution_policy != CrossExecutionPolicy.Suggested:
        return false
    if config.execution_policy == CrossExecutionPolicy.Preferred or config.execution_policy == CrossExecutionPolicy.Required:
        return false
    if CrossExecutionPolicy.Preferred != CrossExecutionPolicy.Preferred:
        return false
    if CrossExecutionPolicy.Required != CrossExecutionPolicy.Required:
        return false
    if not cross_target_policy_is_suggested(CrossExecutionPolicy.Suggested):
        return false
    if cross_target_policy_value() != CrossExecutionPolicy.Required:
        return false
    if not cross_target_enum_merge_ok(true) or cross_target_enum_merge_ok(false):
        return false
    if not cross_target_enum_match_ok(true) or cross_target_enum_match_ok(false):
        return false
    val named_config = CrossNamedConfig(policy: CrossNamedPolicy.Named("enum" + "-payload"))
    val equal_policy = CrossNamedPolicy.Named("enum-" + "payload")
    val other = CrossNamedPolicy.Named("other")
    if named_config.policy != equal_policy or named_config.policy == other:
        return false
    val raw_left = CrossScalarPolicy.Scalar(4097)
    val raw_right = CrossScalarPolicy.Scalar(4105)
    if raw_left == raw_right:
        return false
    val packed: [u64] = rt_array_new_with_cap_u64(2)
    if not rt_typed_words_u64_push(packed, 17) or not rt_typed_words_u64_push(packed, 37):
        return false
    val packed_same: [u64] = rt_array_new_with_cap_u64(2)
    if not rt_typed_words_u64_push(packed_same, 17) or not rt_typed_words_u64_push(packed_same, 37):
        return false
    val array_left = CrossArrayPolicy.Values([17u64, 37u64])
    val array_right = CrossArrayPolicy.Values(packed)
    val array_other = CrossArrayPolicy.Values([17u64, 38u64])
    if array_left != array_right or array_left == array_other:
        return false
    if array_right != CrossArrayPolicy.Values(packed_same):
        return false
    val packed_bytes_left: [u8] = rt_byte_array_new(2)
    val packed_bytes_right: [u8] = rt_byte_array_new(2)
    if not rt_typed_bytes_u8_push(packed_bytes_left, 17) or not rt_typed_bytes_u8_push(packed_bytes_left, 37):
        return false
    if not rt_typed_bytes_u8_push(packed_bytes_right, 17) or not rt_typed_bytes_u8_push(packed_bytes_right, 37):
        return false
    val bytes_left = CrossAnyArrayPolicy.Values(packed_bytes_left)
    val bytes_right = CrossAnyArrayPolicy.Values(packed_bytes_right)
    bytes_left == bytes_right

fn cross_target_enum_type_identity_ok() -> bool:
    val left_value = CrossIdentityLeft.Same
    val right_value = CrossIdentityRight.Same
    val left = CrossIdentityBox.Wrapped(left_value)
    val right = CrossIdentityBox.Wrapped(right_value)
    val imported = provider_identity()
    val left_id = rt_enum_id(left_value)
    val right_id = rt_enum_id(right_value)
    left_id >= 2 and right_id >= 2 and left_id != right_id and
        left != right and imported == CrossProviderIdentity.Same

fn forward_load_bytes() -> Result<[u8], BytesError>:
    val data = load_bytes()?
    Ok(data)

fn forward_fail_bytes() -> Result<[u8], BytesError>:
    val data = fail_bytes()?
    Ok(data)

fn cross_target_arithmetic_ok() -> bool:
    val signed_int: i64 = 41
    if not (signed_int < 41.5) or 41.5 < signed_int:
        return false
    val small: i64 = 1
    val high: u64 = 0x8000000000000000u64
    if not (small < high) or high < small:
        return false
    if not (small <= high) or high <= small:
        return false
    if small > high or not (high > small):
        return false
    if small >= high or not (high >= small):
        return false
    if not (high > 0.0) or not (0.0 < high):
        return false
    if high < 9223372036854775808.0 or not (high <= 9223372036854775808.0):
        return false
    if high / 2u64 != 0x4000000000000000u64 or high % 3u64 != 2u64:
        return false
    if high >> 63u64 != 1u64:
        return false
    val negative: i64 = -2
    val unsigned_count: u64 = 1u64
    if negative >> unsigned_count != -1:
        return false
    val signed_dividend: i64 = -9
    if signed_dividend / 2 != -4 or signed_dividend % 2 != -1:
        return false
    true

fn main() -> i64:
    match forward_load_bytes():
        Ok(data):
            if data.len() != 3 or data[0] != 17u8 or data[2] != 43u8:
                return 1
        Err(_):
            return 2

    if not cross_target_arithmetic_ok():
        return 5
    if not cross_target_option_map_once_ok():
        return 6
    if not cross_target_nested_copy_ok():
        return 7
    if not cross_target_class_array_ok():
        return 8
    if not cross_target_bool_array_interp_ok():
        return 9
    if not cross_target_conditional_interp_ok():
        return 20
    if not cross_target_text_option_unwrap_ok():
        return 10
    if not cross_target_option_exists_ok():
        return 11
    if not cross_target_path_ok():
        return 12
    if not cross_target_char_code_at_ok():
        return 13
    if not cross_target_text_predicate_conversion_ok():
        return 17
    if not cross_target_module_init_order_ok():
        return 18
    if not cross_target_chr_builtin_owner_ok():
        return 19
    if not cross_target_tuple_return_survives_call():
        return 14
    if not cross_target_enum_field_equality_ok():
        return 15
    if not cross_target_enum_type_identity_ok():
        return 16

    match forward_fail_bytes():
        Ok(_):
            return 4
        Err(_):
            print("result-u8-ok")
            return 0
    return 3
