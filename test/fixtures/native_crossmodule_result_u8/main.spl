use native_crossmodule_result_u8.provider.{BytesError, load_bytes}

fn main() -> i64:
    match load_bytes():
        Ok(data):
            if data.len() != 3 or data[0] != 17u8 or data[2] != 43u8:
                return 1
            print("result-u8-ok")
            return 0
        Err(_):
            return 2
    return 3
