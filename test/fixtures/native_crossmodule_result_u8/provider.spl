enum BytesError:
    Missing

class CrossZeroArgReceiver:
    var value: i64

impl CrossZeroArgReceiver:
    fn read(self) -> i64:
        self.value

fn load_bytes() -> Result<[u8], BytesError>:
    val bytes: [u8] = [17u8, 29u8, 43u8]
    Ok(bytes)

fn fail_bytes() -> Result<[u8], BytesError>:
    Err(BytesError.Missing)

export BytesError, CrossZeroArgReceiver, load_bytes, fail_bytes
