# param_tag_test_fixture.spl
#
# Test fixture for the PTAG001/PTAG002 lint rule.
#
# Expected lint output when scanned (verified against check_param_tag):
#   copy_file  (line ~17): PTAG002  (pub fn, @tag present, different roles on text params)
#   hash_bad   (line ~24): PTAG001  (pub fn, 2x i64, no @tag)
#   write_file (line ~29): PTAG001  (pub fn, 2x text, no @tag)
#   linspace   (line ~37): PTAG002  (pub fn, @tag present, different roles on f64 params)
#   add_values:   no warning (same tag = commutative)
#   internal_helper: no warning (non-pub fn)
#   hash_combine:   no warning (commutative allowlist)
#
# ============================================================================

# Case 1: pub fn WITH @tag — different roles on same-type params → PTAG002 fires
#         (callers must use named args; call-site enforcement is future AST work)
# @tag(src=source_path, dst=destination_path)
pub fn copy_file(src: text, dst: text) -> bool:
    """Copy src to dst. @tag disambiguates swap hazard."""
    false

# Case 2: pub fn WITH same @tag (commutative roles) → neither PTAG001 nor PTAG002
# @tag(a=value, b=value)
pub fn add_values(a: i64, b: i64) -> i64:
    """Addition is commutative; same tag = no swap hazard."""
    a + b

# Case 3: pub fn WITHOUT @tag, ≥2 same-type primitive params → PTAG001
pub fn hash_bad(h1: i64, h2: i64) -> i64:
    """Missing @tag — PTAG001 expected here."""
    h1 + h2

# Case 4: non-pub fn WITHOUT @tag → no PTAG001 (rule is pub-only)
fn internal_helper(x: i64, y: i64) -> i64:
    """Private function — PTAG001 does not apply."""
    x + y

# Case 5: pub fn with same-type text params and no @tag → PTAG001
pub fn write_file(path: text, content: text) -> bool:
    """Missing @tag on text params — PTAG001 expected here."""
    false

# Case 6: commutative fn name in allowlist — no PTAG001 even without @tag
pub fn hash_combine(h1: i64, h2: i64) -> i64:
    """Commutative name — suppressed by COMMUTATIVE_FN_NAMES list."""
    h1 + h2

# Case 7: pub fn with mixed types (one same-type group) — params of different types
#         only the i64 pair would be flagged, but @tag is present → PTAG002 check
# @tag(start=range_start, end_val=range_end, steps=step_count)
pub fn linspace(start: f64, end_val: f64, steps: i64) -> [f64]:
    """Two f64 params with different tags → PTAG002 fires; i64 is alone."""
    []
