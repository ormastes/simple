"""
# Deprecated Items Removed Spec

**Feature IDs:** fix-allow-suppressions
**Category:** Testing
**Difficulty:** 1/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Canary spec for AC-5: verifies that the replacement APIs for all 13 real
`@deprecated` items work correctly after Team G removes the deprecated methods.

NOTE: These specs verify the *replacement method works*. They cannot directly
assert that the deprecated method is gone — that is a grep gate at phase 7-verify:
  `rg -F '@deprecated' src/lib/nogc_sync_mut/ src/compiler_rust/lib/std/src/`
should return zero results after Team G completes.

These specs exercise Set.has / intersect / diff / sym_diff, Map.has,
String.upper / lower / each, List.each, and Path.ext.
They WILL PASS right now (replacement methods already exist). Their purpose
is to lock the replacement contract so it cannot regress.
"""

use std.sspec.*


# ============================================================================
# Set replacement methods (AC-5)
# ============================================================================

describe "AC-5 Set deprecated replacements":
    """
    ## Set.has, intersect, diff, sym_diff

    Verifies the replacement methods for the 4 deprecated Set methods:
    - contains -> has
    - intersection -> intersect
    - difference -> diff
    - symmetric_difference -> sym_diff
    """

    it "AC-5: Set.has returns true for a member element":
        val s = Set.new()
        s.insert("Alice")
        expect(s.has("Alice")).to_equal(true)

    it "AC-5: Set.has returns false for a missing element":
        val s = Set.new()
        s.insert("Alice")
        expect(s.has("Bob")).to_equal(false)

    it "AC-5: Set.intersect returns common elements only":
        val a = Set.new()
        a.insert("x")
        a.insert("y")
        val b = Set.new()
        b.insert("y")
        b.insert("z")
        val result = a.intersect(b)
        expect(result.has("y")).to_equal(true)
        expect(result.has("x")).to_equal(false)
        expect(result.has("z")).to_equal(false)

    it "AC-5: Set.diff returns elements only in self":
        val a = Set.new()
        a.insert("x")
        a.insert("y")
        val b = Set.new()
        b.insert("y")
        b.insert("z")
        val result = a.diff(b)
        expect(result.has("x")).to_equal(true)
        expect(result.has("y")).to_equal(false)

    it "AC-5: Set.sym_diff returns elements in exactly one set":
        val a = Set.new()
        a.insert("x")
        a.insert("y")
        val b = Set.new()
        b.insert("y")
        b.insert("z")
        val result = a.sym_diff(b)
        expect(result.has("x")).to_equal(true)
        expect(result.has("z")).to_equal(true)
        expect(result.has("y")).to_equal(false)


# ============================================================================
# Map replacement methods (AC-5)
# ============================================================================

describe "AC-5 Map deprecated replacements":
    """
    ## Map.has

    Verifies the replacement for the deprecated Map.contains_key method.
    - contains_key -> has
    """

    it "AC-5: Map.has returns true when key present":
        val m = Map.new()
        m.put("name", "Alice")
        expect(m.has("name")).to_equal(true)

    it "AC-5: Map.has returns false when key absent":
        val m = Map.new()
        m.put("name", "Alice")
        expect(m.has("age")).to_equal(false)


# ============================================================================
# String replacement methods (AC-5)
# ============================================================================

describe "AC-5 String deprecated replacements":
    """
    ## String.upper, lower, each

    Verifies the replacements for deprecated toUpperCase, toLowerCase, forEach.
    - toUpperCase -> upper
    - toLowerCase -> lower
    - forEach -> each
    """

    it "AC-5: String.upper converts to uppercase":
        val s = "hello"
        expect(s.upper()).to_equal("HELLO")

    it "AC-5: String.lower converts to lowercase":
        val s = "WORLD"
        expect(s.lower()).to_equal("world")

    it "AC-5: String.each iterates over characters":
        var count = 0
        val s = "abc"
        s.each(\c:
            count = count + 1
        )
        expect(count).to_equal(3)


# ============================================================================
# List replacement methods (AC-5)
# ============================================================================

describe "AC-5 List deprecated replacements":
    """
    ## List.each

    Verifies the replacement for deprecated List.forEach.
    - forEach -> each
    """

    it "AC-5: List.each iterates over all elements":
        val items = [1, 2, 3]
        var sum = 0
        items.each(\n:
            sum = sum + n
        )
        expect(sum).to_equal(6)


# ============================================================================
# Path replacement methods (AC-5)
# ============================================================================

describe "AC-5 Path deprecated replacements":
    """
    ## Path.ext

    Verifies the replacement for deprecated Path.extension.
    - extension -> ext
    """

    it "AC-5: Path.ext returns the file extension":
        val path = Path.new("report.md")
        expect(path.ext()).to_equal("md")

    it "AC-5: Path.ext returns empty string for no extension":
        val path = Path.new("Makefile")
        expect(path.ext()).to_equal("")
