"""
# Primitive API Types Spec — Canonical Wrapper Types

**Feature IDs:** fix-primitive-api-suppressions
**Category:** Tooling
**Difficulty:** 1/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests that the canonical wrapper types in `src/lib/common/types.spl` (existing
and new ones added by Team W in Phase 0) can be constructed and have their
inner value accessed.  Existing wrappers should pass today; new wrappers
(ExitCode, Handle, ErrorCode, MemAddr, DurationMs) will FAIL until Team W
extends types.spl.
"""

use std.spipe.*
use types.{
    ActorId, MessageId, ProcessId, BinaryId, RefId,
    ByteSize, Capacity, Count,
    Millis, Nanos, Timestamp,
    Reductions, RefCount, Offset, Length,
    LineNumber, ColumnNumber, IndentLevel,
    PortNumber, HitRate, StringId, SenderId
}


# ============================================================================
# Test Group 1: Existing wrapper types (should pass today)
# ============================================================================

describe "canonical wrapper types — existing (types.spl)":
    """
    ## Existing Wrappers

    Verifies construction and `.value` field access for all wrappers already
    present in `src/lib/common/types.spl`.  These specs should PASS today;
    they lock the existing contract so it cannot regress.
    """

    it "AC-1: ActorId wraps i64 and exposes .value":
        val id = ActorId(value: 42)
        expect(id.value).to_equal(42)

    it "AC-1: MessageId wraps i64 and exposes .value":
        val id = MessageId(value: 7)
        expect(id.value).to_equal(7)

    it "AC-1: ProcessId wraps i64 and exposes .value":
        val id = ProcessId(value: 1)
        expect(id.value).to_equal(1)

    it "AC-1: ByteSize wraps i64 and exposes .value":
        val sz = ByteSize(value: 4096)
        expect(sz.value).to_equal(4096)

    it "AC-1: Capacity wraps i64 and exposes .value":
        val cap = Capacity(value: 128)
        expect(cap.value).to_equal(128)

    it "AC-1: Count wraps i64 and exposes .value":
        val c = Count(value: 10)
        expect(c.value).to_equal(10)

    it "AC-1: Millis wraps i64 and exposes .value":
        val ms = Millis(value: 500)
        expect(ms.value).to_equal(500)

    it "AC-1: Nanos wraps i64 and exposes .value":
        val ns = Nanos(value: 1000000)
        expect(ns.value).to_equal(1000000)

    it "AC-1: Offset wraps i64 and exposes .value":
        val off = Offset(value: 64)
        expect(off.value).to_equal(64)

    it "AC-1: Length wraps i64 and exposes .value":
        val len = Length(value: 32)
        expect(len.value).to_equal(32)

    it "AC-1: LineNumber wraps i64 and exposes .value":
        val ln = LineNumber(value: 1)
        expect(ln.value).to_equal(1)

    it "AC-1: ColumnNumber wraps i64 and exposes .value":
        val col = ColumnNumber(value: 0)
        expect(col.value).to_equal(0)

    it "AC-1: PortNumber wraps i32 and exposes .value":
        val p = PortNumber(value: 8080)
        expect(p.value).to_equal(8080)


# ============================================================================
# Test Group 2: New wrappers added by Team W (WILL FAIL until Phase 0 lands)
# ============================================================================

describe "canonical wrapper types — Team W new additions (types.spl)":
    """
    ## New Wrappers (Phase 0, Team W)

    These wrapper types will be added to `src/lib/common/types.spl` by
    Team W before parallel Teams A–E start.  These specs WILL FAIL until
    Team W extends types.spl with ExitCode, Handle, ErrorCode, MemAddr, DurationMs.
    """

    it "AC-1: ExitCode wraps i64 and exposes .value":
        val ec = ExitCode(value: 0)
        expect(ec.value).to_equal(0)

    it "AC-1: Handle wraps i64 and exposes .value":
        val h = Handle(value: 3)
        expect(h.value).to_equal(3)

    it "AC-1: ErrorCode wraps i64 and exposes .value":
        val err = ErrorCode(value: 22)
        expect(err.value).to_equal(22)

    it "AC-1: MemAddr wraps i64 and exposes .value":
        val addr = MemAddr(value: 0xdeadbeef)
        expect(addr.value).to_equal(0xdeadbeef)

    it "AC-1: DurationMs wraps i32 and exposes .value":
        val dur = DurationMs(value: 250)
        expect(dur.value).to_equal(250)
