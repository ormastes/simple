"""
# text.chars() Deprecation Replacement Spec

**Feature IDs:** fix-foreach-deprecated, fix-char-at
**Category:** Testing
**Difficulty:** 1/5
**Status:** Complete
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Canary spec locking the replacement APIs for the deprecated `text.chars()` method.
All migration waves are complete:
- Pattern B/C (indexed access `chars()[i]`, stored `val cs = s.chars(); cs[i]`) — migrated to `s.get(i)`.
- Pattern D (`.chars().first()/.last()/.filter()/.reverse()/.enumerate()`) — migrated to direct API.
- Pattern A (`for ch in s.chars()`) — handled by `collection_desugar.spl` Pattern F: the compiler
  automatically rewrites `for x in s.chars()` → `for x in s` at AST level, eliminating the
  `List<char>` allocation without requiring source changes.

Replacements for `text.chars()` usage:
- Iteration: `for ch in s` (preferred — text implements Iterable<char>; auto-desugared from `s.chars()`)
- Callback iteration: `s.each(fn)` (use when callback is a named function)
- Indexed iteration: `s.each_with_index(fn)` (replaces enumerate patterns)
- Random access: `s.get(i)` returns `Option<char>` (replaces `s.chars()[i]`)

`text.chars()` remains `@deprecated` because non-for patterns (`.chars().len()`,
`.chars().map(...)`) still allocate. These specs lock the replacement contract
so regressions are caught.
"""

use std.sspec.*


# ============================================================================
# text.each(fn) — replacement for chars() callback/iteration usage
# ============================================================================

describe "text.each(fn) visits every character (replaces chars() iteration)":
    """
    ## text.each(fn) replacement

    `s.each(\ch: ...)` is the replacement for callback-style uses of
    `s.chars()` followed by iteration. Verifies correctness of each() as
    the drop-in for Pattern A chars() callers.
    """

    it "text.each(fn) visits every character in order":
        val s = "abc"
        var result = ""
        s.each(\c:
            result = result + c.to_string()
        )
        expect(result).to_equal("abc")

    it "text.each(fn) on empty string calls fn zero times":
        val s = ""
        var count = 0
        s.each(\c:
            count = count + 1
        )
        expect(count).to_equal(0)

    it "text.each(fn) counts characters correctly":
        val s = "hello"
        var count = 0
        s.each(\c:
            count = count + 1
        )
        expect(count).to_equal(5)


# ============================================================================
# for ch in string — preferred replacement for for ch in s.chars()
# ============================================================================

describe "for ch in string iterates characters without chars()":
    """
    ## Direct for-in on text

    `for ch in s` is the preferred replacement for `for ch in s.chars()`.
    text implements Iterable<char> so no intermediate List<char> is needed.
    Confirmed working in existing codebase (parser_types_utils.spl, config.spl).
    """

    it "for ch in string visits every character":
        val s = "xyz"
        var count = 0
        for ch in s:
            count = count + 1
        expect(count).to_equal(3)

    it "for ch in string accumulates characters in order":
        val s = "hi"
        var result = ""
        for ch in s:
            result = result + ch.to_string()
        expect(result).to_equal("hi")

    it "for ch in empty string executes zero iterations":
        val s = ""
        var count = 0
        for ch in s:
            count = count + 1
        expect(count).to_equal(0)


# ============================================================================
# text.each_with_index() — indexed iteration replacement
# ============================================================================

describe "text.each_with_index provides index alongside character":
    """
    ## text.each_with_index(fn)

    Replacement for patterns that combined chars() with enumerate() or manual
    index tracking. Verifies index is correct alongside character value.
    """

    it "text.each_with_index passes correct index and character":
        val s = "abc"
        var index_sum = 0
        s.each_with_index(\i, c:
            index_sum = index_sum + i
        )
        # indices 0+1+2 = 3
        expect(index_sum).to_equal(3)

    it "text.each_with_index index starts at zero":
        val s = "z"
        var first_index = -1
        s.each_with_index(\i, c:
            first_index = i
        )
        expect(first_index).to_equal(0)


# ============================================================================
# Pattern F regression guard — for x in s.chars() semantic contract
# ============================================================================

describe "for ch in s.chars() produces same result as for ch in s (Pattern F)":
    """
    ## Pattern F desugar regression guard

    `collection_desugar.spl` Pattern F rewrites `for x in s.chars()` → `for x in s`
    at AST level, eliminating the List<char> allocation. These tests lock the
    semantic contract so any regression in the desugar or in text's Iterable<char>
    impl is caught immediately.
    """

    it "for ch in s.chars() accumulates same string as for ch in s":
        val s = "hello"
        var from_chars = ""
        for ch in s.chars():
            from_chars = from_chars + ch.to_string()
        var from_s = ""
        for ch in s:
            from_s = from_s + ch.to_string()
        expect(from_chars).to_equal(from_s)

    it "for ch in s.chars() on empty string iterates zero times":
        var count = 0
        for ch in "".chars():
            count = count + 1
        expect(count).to_equal(0)

    it "for ch in s.chars() visits characters in forward order":
        val s = "abc"
        var result = ""
        for ch in s.chars():
            result = result + ch.to_string()
        expect(result).to_equal("abc")
