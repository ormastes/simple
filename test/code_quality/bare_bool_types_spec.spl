"""
# Bare Bool Types Spec — Semantic Alias Pattern and Lint Level

**Feature IDs:** fix-bare-bool-suppressions
**Category:** Tooling
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests the semantic alias pattern (D-4), predicate naming convention (D-1 spirit),
and lint level for `bare_bool`:

- Group 1: `build_default_levels` returns `"warn"` for `bare_bool` (not deny).
- Group 2: `type Enabled = bool` transparent alias round-trips correctly (D-4 pattern).
- Group 3: Predicate-prefix functions with non-bool params returning bool are
  semantically correct and match the D-1 spirit.
"""

use std.sspec.*
use compiler.tools.lint.main.{build_default_levels}


# ============================================================================
# Test Group 1: Lint level for bare_bool
# ============================================================================

describe "bare_bool lint — default level":
    """
    ## Group 1: bare_bool is warn-level by default

    `build_default_levels()` must return `"warn"` for `bare_bool`.
    It is NOT promoted to `deny` (that is reserved for `primitive_api`).
    """

    it "AC-1a: build_default_levels returns warn for bare_bool":
        val levels = build_default_levels()
        expect(levels["bare_bool"]).to_equal("warn")


# ============================================================================
# Test Group 2: Transparent type alias pattern (D-4)
# ============================================================================

describe "bare_bool types — transparent alias pattern":
    """
    ## Group 2: type Alias = bool is the correct D-4 pattern

    When a public field must stay public but carries a bool, use a transparent
    alias like `type Enabled = bool` with a justification comment.
    The alias round-trips correctly in expressions.
    """

    it "AC-2a: transparent bool alias equals underlying bool true":
        type Enabled = bool
        val flag: Enabled = true
        expect(flag).to_equal(true)

    it "AC-2b: transparent bool alias equals underlying bool false":
        type Deleted = bool
        val flag: Deleted = false
        expect(flag).to_equal(false)

    it "AC-2c: transparent bool alias can be negated like a bool":
        type Active = bool
        val a: Active = true
        val b = not a
        expect(b).to_equal(false)


# ============================================================================
# Test Group 3: Predicate prefix convention (D-1 spirit)
# ============================================================================

describe "bare_bool types — predicate prefix convention":
    """
    ## Group 3: Predicate-named functions with non-bool params returning bool

    Functions named with is_*, has_*, can_*, should_* prefixes, non-bool params,
    returning bool are the canonical pattern that D-1 exempts in the Rust AST lint.
    These tests confirm the semantics are correct.
    """

    it "AC-3a: is_* fn with non-bool param can return bool":
        fn is_above_threshold(value: i64) -> bool:
            value > 100
        expect(is_above_threshold(150)).to_equal(true)
        expect(is_above_threshold(50)).to_equal(false)

    it "AC-3b: has_* fn with non-bool param can return bool":
        fn has_content(s: text) -> bool:
            s.len() > 0
        expect(has_content("hello")).to_equal(true)
        expect(has_content("")).to_equal(false)

    it "AC-3c: can_* fn with no params can return bool":
        fn can_proceed() -> bool:
            true
        expect(can_proceed()).to_equal(true)

    it "AC-3d: should_* fn with non-bool param can return bool":
        fn should_retry(attempts: i64) -> bool:
            attempts < 3
        expect(should_retry(1)).to_equal(true)
        expect(should_retry(5)).to_equal(false)
