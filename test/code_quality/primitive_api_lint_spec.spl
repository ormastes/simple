"""
# Primitive API Lint Spec — Text Scanner Exemptions

**Feature IDs:** fix-primitive-api-suppressions
**Category:** Tooling
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests the text-scanner lint (`check_primitive_api`) after Team W adds:
- D-1: pure-math exemption — `pub fn` where every param and return type is the
  SAME bare primitive is not flagged.
- D-2: extern fn exemption — lines starting with `extern fn` are never flagged.
- AC-7: `primitive_api` level is `deny` in `build_default_levels()` after Phase 2.

These specs WILL FAIL until Team W lands the exemptions and Phase 2 promotes the
level to `deny`. The existing integration spec at
`test/integration/app/primitive_api_lint_spec.spl` covers the base case;
this file covers the NEW exemption cases only.
"""

use std.sspec.*
use compiler.tools.fix.main.{collect_fixes_from_source}
use compiler.tools.lint.main.{LintConfig, LintLevel, build_default_levels}


# Helper: count primitive_api fix hits in a source snippet (respects @allow).
fn count_primitive_api_fixes(source: text) -> i64:
    val fixes = collect_fixes_from_source("sample.spl", source)
    var config = LintConfig.new()
    config.apply_file_attributes(source)
    var count = 0
    for fix in fixes:
        val parts = fix.id.split(":")
        if parts.len() >= 2 and parts[1] == "primitive_api" and config.get_level("primitive_api") != LintLevel.Allow:
            count = count + 1
    count


# ============================================================================
# Test Group 1: D-1 Pure-math exemption
# ============================================================================

describe "primitive_api lint — D-1 pure-math exemption":
    """
    ## D-1: All-same-primitive exemption

    A `pub fn` where every parameter and the return type are the same bare
    primitive (e.g. `fn add(a: i64, b: i64) -> i64`) is NOT flagged after
    Team W adds the exemption.  These specs will FAIL before Team W lands.
    """

    it "AC-D1: should NOT flag pub fn with all-same-primitive args and return (i64)":
        # Arrange: pure-math function — same type everywhere
        val source =
            "pub fn add(a: i64, b: i64) -> i64:\n" +
            "    return a + b\n"
        # Act + Assert: after Team W exemption, count must be 0
        expect(count_primitive_api_fixes(source)).to_equal(0)

    it "AC-D1: should NOT flag pub fn with all-same-primitive args and return (f64)":
        val source =
            "pub fn lerp(a: f64, b: f64, t: f64) -> f64:\n" +
            "    return a + (b - a) * t\n"
        expect(count_primitive_api_fixes(source)).to_equal(0)

    it "AC-D1: should NOT flag single-arg single-return same-primitive fn":
        val source =
            "pub fn negate(x: i64) -> i64:\n" +
            "    return 0 - x\n"
        expect(count_primitive_api_fixes(source)).to_equal(0)

    it "AC-D1: should STILL flag pub fn with mixed primitive types (i64 param, i32 return)":
        # Mixed types are NOT exempt — this must still fire
        val source =
            "pub fn truncate(value: i64) -> i32:\n" +
            "    return value as i32\n"
        expect(count_primitive_api_fixes(source)).to_be_greater_than(0)

    it "AC-D1: should STILL flag pub fn with only a primitive return type (no params)":
        val source =
            "pub fn get_count() -> i64:\n" +
            "    return 0\n"
        expect(count_primitive_api_fixes(source)).to_be_greater_than(0)


# ============================================================================
# Test Group 2: D-2 extern fn exemption
# ============================================================================

describe "primitive_api lint — D-2 extern fn exemption":
    """
    ## D-2: extern fn is never flagged

    `extern fn` declarations cannot have their signatures changed (C ABI
    boundary).  After Team W adds the exemption, no `extern fn` line fires
    the lint regardless of its primitive types.
    These specs will FAIL before Team W lands.
    """

    it "AC-D2: should NOT flag extern fn with primitive args":
        val source =
            "extern fn rt_alloc(size: i64) -> i64\n"
        expect(count_primitive_api_fixes(source)).to_equal(0)

    it "AC-D2: should NOT flag extern fn with mixed primitive types":
        val source =
            "extern fn rt_read(fd: i32, buf: i64, len: i64) -> i32\n"
        expect(count_primitive_api_fixes(source)).to_equal(0)

    it "AC-D2: should STILL flag a regular pub fn that mirrors an extern signature":
        # Same shape as extern, but declared pub fn — must still fire
        val source =
            "pub fn wrap_alloc(size: i64) -> i64:\n" +
            "    return rt_alloc(size)\n"
        expect(count_primitive_api_fixes(source)).to_be_greater_than(0)


# ============================================================================
# Test Group 3: AC-7 deny promotion
# ============================================================================

describe "primitive_api lint — AC-7 deny level":
    """
    ## AC-7: primitive_api promoted to deny in build_default_levels()

    After Phase 2 serial step, `build_default_levels()` must return `deny`
    for `primitive_api`.  This spec will FAIL until that promotion lands.
    """

    it "AC-7: build_default_levels returns deny for primitive_api":
        val levels = build_default_levels()
        expect(levels["primitive_api"]).to_equal("deny")
