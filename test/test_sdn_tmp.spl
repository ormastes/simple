class Foo:
    pos: i64

impl Foo:
    me step() -> i64:
        self.pos = 100
        val result = if true:
            self.pos + 1
        else:
            0
        print("  [step] result={result}, self.pos = {self.pos}")
        result

var f = Foo(pos: 0)
val r = f.step()
print("f.pos = {f.pos}, r = {r}")

