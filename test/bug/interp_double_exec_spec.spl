# Bug: Double execution in interpreter mode
# Severity: P2
# Workaround: Guard flag (MAIN_EXECUTED) to prevent re-entry

var EXEC_COUNT = 0
var MAIN_GUARD_EXECUTED = false

fn guarded_main():
    if MAIN_GUARD_EXECUTED:
        return
    MAIN_GUARD_EXECUTED = true
    EXEC_COUNT = EXEC_COUNT + 1

# Module-level unguarded counter for third test
var UNGUARDED_COUNT = 0

fn unguarded_increment():
    UNGUARDED_COUNT = UNGUARDED_COUNT + 1

describe "Double execution bug":
    it "guard prevents multiple executions":
        # Reset and call within the it block (module-level calls
        # don't reliably persist into test context)
        EXEC_COUNT = 0
        MAIN_GUARD_EXECUTED = false
        guarded_main()
        expect(EXEC_COUNT).to_equal(1)
        expect(MAIN_GUARD_EXECUTED).to_equal(true)

    it "calling guarded_main again is a no-op":
        EXEC_COUNT = 0
        MAIN_GUARD_EXECUTED = false
        guarded_main()
        guarded_main()
        guarded_main()
        # Should still be 1 due to guard
        expect(EXEC_COUNT).to_equal(1)

    it "without guard, count increments each call":
        # Nested fn capture of local vars is broken,
        # so use module-level fn + module-level var
        UNGUARDED_COUNT = 0
        unguarded_increment()
        unguarded_increment()
        expect(UNGUARDED_COUNT).to_equal(2)
