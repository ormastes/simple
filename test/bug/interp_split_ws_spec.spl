# Bug: split("\n") strips leading whitespace
# Severity: P2
# Workaround: Manual line parsing with index scanning

fn _parse_lines_preserving_indent(content: text) -> [text]:
    # Manual line splitter that preserves leading whitespace
    var lines: [text] = []
    var start = 0
    var pos = 0
    val clen = content.len()
    while pos < clen:
        val ch = content[pos:pos + 1]
        if ch == "\n":
            val line = content[start:pos]
            lines.push(line)
            start = pos + 1
        pos = pos + 1
    if start < clen:
        val line = content[start:clen]
        lines.push(line)
    lines

describe "split(newline) whitespace stripping bug":
    it "demonstrates the bug with split":
        val text_with_indent = "line1\n  indented\n    deeply"
        val lines = text_with_indent.split("\n")
        # BUG: split("\n") strips leading whitespace
        # lines[1] becomes "indented" instead of "  indented"
        # We can only verify the content is present, not the indent
        expect(lines.len()).to_equal(3)
        expect(lines[0]).to_equal("line1")
        # lines[1] should be "  indented" but bug strips it
        expect(lines[1]).to_contain("indented")

    it "workaround preserves indentation":
        val text_with_indent = "line1\n  indented\n    deeply"
        val lines = _parse_lines_preserving_indent(text_with_indent)
        expect(lines.len()).to_equal(3)
        expect(lines[0]).to_equal("line1")
        expect(lines[1]).to_equal("  indented")
        expect(lines[2]).to_equal("    deeply")

    it "workaround handles trailing newline":
        val content = "a\nb\n"
        val lines = _parse_lines_preserving_indent(content)
        expect(lines.len()).to_equal(2)
        expect(lines[0]).to_equal("a")
        expect(lines[1]).to_equal("b")
