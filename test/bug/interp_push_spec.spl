# Bug: Module-level .push() → "unsupported path call"
# Severity: P2
# Workaround: Use arr = arr + [item] for module-level arrays

# Module-level array - .push() fails here
var MODULE_ITEMS: [text] = []
var MODULE_COUNT = 0

# Workaround: concatenation instead of .push()
fn module_add_item(item: text):
    MODULE_ITEMS = MODULE_ITEMS + [item]
    MODULE_COUNT = MODULE_COUNT + 1

fn module_get_items() -> [text]:
    MODULE_ITEMS

describe "Module-level .push() bug":
    it "demonstrates workaround with concatenation":
        # Explicit reset (module-level init may not persist into it blocks)
        MODULE_ITEMS = []
        MODULE_COUNT = 0
        module_add_item("alpha")
        module_add_item("beta")
        module_add_item("gamma")
        expect(MODULE_COUNT).to_equal(3)
        val items = module_get_items()
        expect(items.len()).to_equal(3)
        expect(items[0]).to_equal("alpha")
        expect(items[1]).to_equal("beta")
        expect(items[2]).to_equal("gamma")

    it "push works inside local scope":
        # .push() works fine on local variables
        var local_items: [text] = []
        local_items.push("one")
        local_items.push("two")
        expect(local_items.len()).to_equal(2)
        expect(local_items[0]).to_equal("one")

    it "workaround preserves existing items":
        MODULE_ITEMS = []
        MODULE_COUNT = 0
        module_add_item("first")
        module_add_item("second")
        val items = module_get_items()
        expect(items[0]).to_equal("first")
        expect(items[1]).to_equal("second")
