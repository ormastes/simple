  text_ink_delta: (text_ink_delta div_box: (region name: "div_box" different_pixels: 1612 chrome_exact_black_pixels: 45 simple_background_mismatch_pixels: 1612) overflow_text: (region name: "overflow_text" different_pixels: 1104 chrome_exact_black_pixels: 22 simple_background_mismatch_pixels: 1104))
  text_line_ink_delta: (text_line_ink_delta count: 4
    (line index: 0 text: "Google search" x: 8 y: 8 width: 105 region: (region name: "line_0" different_pixels: 808 chrome_exact_black_pixels: 25 simple_background_mismatch_pixels: 808))
