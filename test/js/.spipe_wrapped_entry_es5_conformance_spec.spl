#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.engine.parser.{JsParser}
use std.js.engine.interpreter.{JsInterpreter}
use std.js.types.js_types.{JsValue}

fn _run_js(source: text) -> text:
    """Helper: parse and execute JS, return string result."""
    val logger = Logger.new("test", LogLevel.Error)
    val parser = JsParser.new(source, logger)
    val program = parser.parse_program()
    match program:
        Ok(stmts):
            val interp = JsInterpreter.new(logger)
            val result = interp.execute(stmts)
            match result:
                Ok(value):
                    return _display(value)
                Err(e):
                    return "Error: {e.message}"
        Err(e):
            return "SyntaxError: {e.message}"

fn _display(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

describe "ES5 Conformance":
    describe "Types and typeof":
        it "typeof undefined":
            expect _run_js("typeof undefined") == "undefined"
        it "typeof null returns object":
            expect _run_js("typeof null") == "object"
        it "typeof number":
            expect _run_js("typeof 42") == "number"
        it "typeof string":
            expect _run_js("typeof 'hello'") == "string"
        it "typeof boolean":
            expect _run_js("typeof true") == "boolean"
        it "typeof function":
            expect _run_js("typeof function(){}") == "function"

    describe "Arithmetic":
        it "addition":
            expect _run_js("1 + 2") == "3"
        it "subtraction":
            expect _run_js("10 - 3") == "7"
        it "multiplication":
            expect _run_js("6 * 7") == "42"
        it "division":
            expect _run_js("15 / 3") == "5"
        it "modulo":
            expect _run_js("10 % 3") == "1"
        it "exponentiation":
            expect _run_js("2 ** 10") == "1024"
        it "unary minus":
            expect _run_js("-5") == "-5"
        it "unary plus":
            expect _run_js("+'3'") == "3"
        it "increment":
            expect _run_js("var x=5; ++x") == "6"

    describe "String operations":
        it "concatenation":
            expect _run_js("'hello' + ' ' + 'world'") == "hello world"
        it "string + number":
            expect _run_js("'count: ' + 5") == "count: 5"
        it "string length":
            expect _run_js("'test'.length") == "4"

    describe "Type coercion":
        it "null == undefined":
            expect _run_js("null == undefined") == "true"
        it "null !== undefined":
            expect _run_js("null === undefined") == "false"
        it "boolean to number":
            expect _run_js("true + 1") == "2"
        it "empty string is falsy":
            expect _run_js("!''") == "true"
        it "0 is falsy":
            expect _run_js("!0") == "true"

    describe "Comparison":
        it "strict equality":
            expect _run_js("1 === 1") == "true"
        it "strict inequality":
            expect _run_js("1 === '1'") == "false"
        it "abstract equality coercion":
            expect _run_js("1 == '1'") == "true"
        it "less than":
            expect _run_js("3 < 5") == "true"
        it "greater than":
            expect _run_js("5 > 3") == "true"

    describe "Logical operators":
        it "and short circuit":
            expect _run_js("true && 42") == "42"
        it "or short circuit":
            expect _run_js("false || 'hello'") == "hello"
        it "not":
            expect _run_js("!false") == "true"

    describe "Variables":
        it "var declaration":
            expect _run_js("var x = 10; x") == "10"
        it "assignment":
            expect _run_js("var x = 1; x = 5; x") == "5"
        it "multiple vars":
            expect _run_js("var a = 1; var b = 2; a + b") == "3"

    describe "Control flow":
        it "if true":
            expect _run_js("var r; if (true) { r = 'yes'; } else { r = 'no'; } r") == "yes"
        it "if false":
            expect _run_js("var r; if (false) { r = 'yes'; } else { r = 'no'; } r") == "no"
        it "while loop":
            expect _run_js("var i=0; while(i<3){i=i+1;} i") == "3"
        it "for loop":
            expect _run_js("var s=0; for(var i=0;i<5;i=i+1){s=s+i;} s") == "10"
        it "ternary":
            expect _run_js("true ? 'a' : 'b'") == "a"
        it "switch":
            expect _run_js("var r; switch(2){case 1:r='a';break;case 2:r='b';break;default:r='c';} r") == "b"

    describe "Functions":
        it "declaration and call":
            expect _run_js("function f(x){return x*2;} f(5)") == "10"
        it "multiple params":
            expect _run_js("function add(a,b){return a+b;} add(3,4)") == "7"
        it "closure":
            expect _run_js("function f(){var x=10;return function(){return x;};} f()()") == "10"
        it "arguments.length":
            expect _run_js("function f(){return arguments.length;} f(1,2,3)") == "3"
        it "recursion":
            expect _run_js("function fib(n){if(n<=1)return n;return fib(n-1)+fib(n-2);} fib(6)") == "8"

    describe "Objects":
        it "object literal":
            expect _run_js("var o={a:1,b:2}; o.a+o.b") == "3"
        it "property assignment":
            expect _run_js("var o={}; o.x=42; o.x") == "42"
        it "in operator":
            expect _run_js("'a' in {a:1}") == "true"
        it "delete":
            expect _run_js("var o={a:1}; delete o.a; typeof o.a") == "undefined"

    describe "Arrays":
        it "array literal":
            expect _run_js("[1,2,3].length") == "3"
        it "index access":
            expect _run_js("var a=[10,20,30]; a[1]") == "20"

    describe "Error handling":
        it "try-catch":
            expect _run_js("try{throw 'err';}catch(e){e}") == "err"
        it "try-finally":
            expect _run_js("var x=0; try{x=1;}finally{x=2;} x") == "2"

    describe "Void and typeof":
        it "void operator":
            expect _run_js("typeof void 0") == "undefined"
fn main():
    # ES5 ECMAScript Conformance Tests
    # @cover src/lib/common/js/engine/interpreter.spl

