# Task #112 / #99(d) — regression guard: STRUCTS keep VALUE semantics.
#
# Copying a struct into a second binding and mutating the copy must NOT affect
# the original — the opposite of the class reference model. This proves the
# class-reference change did not accidentally make structs alias.
#
# Expected stdout: 42
#
# Verify: default bin/simple run <this file>  -> 42
#
# NOTE (honest scope): verify this guard under DEFAULT `bin/simple run` (JIT /
# compiled), where struct field assignment works and value-copies. Struct field
# assignment is a SEPARATE, still-unimplemented path in the interpret-mode
# 70.backend engine (its field-assign target handling currently routes only
# class Objects through the store; a struct target returns not_implemented). That
# is a known adjacent gap, tracked, and NOT part of the class-reference change
# under test here — do not treat an interpret-mode error on this file as a
# regression of the class-reference patch.
struct Point:
    var x: i64

fn main():
    var p = Point(x: 42)
    var q = p
    q.x = 777
    print(p.x)

main()
