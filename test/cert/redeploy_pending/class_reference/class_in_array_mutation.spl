# Task #112 / #99(d) — class-in-array reference semantics (the core repro).
#
# A class instance stored in an array, read out into an alias var, and mutated
# through that alias, MUST be observed through the array slot — REFERENCE
# semantics. This is the exact 42-vs-777 repro from
# doc/08_tracking/bug/jit_class_mutation_drop_characterization_2026-07-04.md.
#
# Expected stdout: 777
#   Before the fix, interpret mode (CompileMode.Interpret -> InterpreterBackendImpl)
#   could not even read `arr[0]` (no HirExprKind.Index arm) and, on the frozen
#   deployed binary, dropped the mutation and printed 42. The Index-read arm now
#   returns the element's Value.Object(handle) verbatim, so all holders share the
#   one ObjectStore record.
#
# Verify: SIMPLE_EXECUTION_MODE=interpret bin/simple run <this file>  -> 777
#         default bin/simple run <this file>                          -> 777
class Counter:
    var n: i64

fn main():
    var arr = [Counter(n: 42)]
    var c = arr[0]
    c.n = 777
    print(arr[0].n)

main()
