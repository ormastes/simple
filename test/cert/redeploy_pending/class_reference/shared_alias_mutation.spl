# Task #112 / #99(d) — shared-alias reference semantics.
#
# Two variables bound to ONE class instance share underlying state: a mutation
# through one alias is visible through the other. This is the alias case the
# committed ObjectStore model (commit 19cd165d238) already handles; kept here as
# a staged guard that the Index-read change did not regress plain aliasing.
#
# Expected stdout: 777
#
# Verify: SIMPLE_EXECUTION_MODE=interpret bin/simple run <this file>  -> 777
#         default bin/simple run <this file>                          -> 777
class Box:
    var n: i64

fn main():
    var a = Box(n: 42)
    var b = a
    b.n = 777
    print(a.n)

main()
