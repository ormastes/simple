# Differential-fuzzer PROGRAM GENERATOR (cert task C3).
#
# Emits ONE random, VALID Simple program over the SOUND language subset,
# deterministically derived from a single integer seed (the last CLI arg).
# The generated program prints a fixed sequence of deterministic values, so any
# stdout divergence between the interpreter (oracle) and the compiled backend is
# a codegen defect. See scripts/check/cert/fuzz-diff.shs for the driver/oracle.
#
# SOUND subset covered (see honest-scope note at bottom):
#   * integer arithmetic +,-,*,/,% with precedence and parentheses
#   * custom enum + match with payload binding (NOT built-in Result/Ok/Err)
#   * struct construction + field access
#   * a recursive function
#   * booleans / short-circuit (and/or/not) + comparison operators
#   * local vars (val)
# Division/modulo RHS is ALWAYS a nonzero literal (1..9) => no divide-by-zero.
#
# IMPORTANT: run this generator itself under SIMPLE_EXECUTION_MODE=interpret.
# The deployed compiled backend has frozen bugs in int()/str() that would
# corrupt the emitted text; the interpreter renders it correctly.

use std.io_runtime (get_args)

# ---- deterministic LCG PRNG (state threaded through a module global) --------
var g_state: i64 = 1

fn seed_rng(s: i64):
    # Avoid a zero state (LCG with c!=0 still advances, but keep it lively).
    g_state = (s * 2654435761 + 1013904223) % 2147483647
    if g_state < 0:
        g_state = g_state + 2147483647
    if g_state == 0:
        g_state = 1

fn next_rand() -> i64:
    g_state = (g_state * 1103515245 + 12345) % 2147483648
    if g_state < 0:
        g_state = g_state + 2147483648
    return g_state

# ri(lo, hi) -> uniform-ish integer in [lo, hi] inclusive.
fn ri(lo: i64, hi: i64) -> i64:
    val span = hi - lo + 1
    return lo + (next_rand() % span)

# ---- expression grammar ------------------------------------------------------
# Leaf: a small literal, or a reference to one of v0..v(nvars-1).
fn gen_leaf(nvars: i64) -> text:
    if nvars > 0 and ri(0, 1) == 0:
        return "v" + str(ri(0, nvars - 1))
    return str(ri(0, 9))

# gen_expr(depth, nvars) -> a syntactically valid integer expression.
# depth 0 => leaf. Otherwise combine two subexpressions with a random operator,
# sometimes wrapped in parens (exercises precedence with AND without parens).
fn gen_expr(depth: i64, nvars: i64) -> text:
    if depth <= 0:
        return gen_leaf(nvars)
    val choice = ri(0, 4)
    val left = gen_expr(depth - 1, nvars)
    if choice == 0 or choice == 1:
        # +/-/* with another subexpression
        val opc = ri(0, 2)
        var op = " + "
        if opc == 1:
            op = " - "
        if opc == 2:
            op = " * "
        val right = gen_expr(depth - 1, nvars)
        if ri(0, 1) == 0:
            return "(" + left + op + right + ")"
        return left + op + right
    if choice == 2:
        # division by a nonzero literal (no divide-by-zero)
        return "(" + left + ") / " + str(ri(1, 9))
    if choice == 3:
        # modulo by a nonzero literal
        return "(" + left + ") % " + str(ri(1, 9))
    # parenthesized single subexpression
    return "(" + left + ")"

# gen_bool(nvars) -> a boolean expression using comparisons + short-circuit.
fn gen_cmp(nvars: i64) -> text:
    val a = gen_expr(1, nvars)
    val b = gen_expr(1, nvars)
    val c = ri(0, 5)
    var op = " < "
    if c == 1:
        op = " > "
    if c == 2:
        op = " <= "
    if c == 3:
        op = " >= "
    if c == 4:
        op = " == "
    if c == 5:
        op = " != "
    return a + op + b

fn gen_bool(nvars: int) -> text:
    val l = gen_cmp(nvars)
    val k = ri(0, 3)
    if k == 0:
        return "not (" + l + ")"
    if k == 1:
        return l + " and " + gen_cmp(nvars)
    if k == 2:
        return l + " or " + gen_cmp(nvars)
    return l

# ---- program emission --------------------------------------------------------
fn emit_program():
    # Enum + struct with fixed shapes; bodies/uses are randomized.
    print("enum En:")
    print("    Ea(i64)")
    print("    Eb(i64, i64)")
    print("")
    print("struct St:")
    print("    x: i64")
    print("    y: i64")
    print("")
    # A recursive function (sum 0..n), guarded so it always terminates.
    print("fn rec(n: i64) -> i64:")
    print("    if n <= 0:")
    print("        0")
    print("    else:")
    print("        n + rec(n - 1)")
    print("")
    # Enum evaluator: match with payload binding. Arms reference their payloads.
    print("fn ev(e: En) -> i64:")
    print("    match e:")
    print("        En.Ea(a): " + gen_expr_over("a", 0))
    print("        En.Eb(a, b): " + gen_expr_over2("a", "b"))
    print("")
    # main: local vars, struct field access, enum value, recursion, boolean.
    print("fn main():")
    val nv = ri(2, 4)
    print("    val v0 = " + str(ri(0, 9)))
    var i = 1
    while i < nv:
        print("    val v" + str(i) + " = " + gen_expr(2, i))
        i = i + 1
    print("    val s = St(x: " + str(ri(0, 9)) + ", y: " + str(ri(0, 9)) + ")")
    # Random enum construction.
    if ri(0, 1) == 0:
        print("    val e0 = En.Ea(" + str(ri(0, 9)) + ")")
    else:
        print("    val e0 = En.Eb(" + str(ri(0, 9)) + ", " + str(ri(0, 9)) + ")")
    # Final deterministic prints combining every construct.
    print("    print(" + gen_main_expr(nv) + ")")
    print("    print(ev(e0))")
    print("    print(rec(" + str(ri(0, 8)) + "))")
    print("    print(" + gen_bool(nv) + ")")

# Expression over a single named payload variable (plus literals).
fn gen_expr_over(name: text, extra: int) -> text:
    val op = ri(0, 2)
    if op == 0:
        return name + " * " + str(ri(1, 9))
    if op == 1:
        return name + " + " + str(ri(0, 9))
    return "(" + name + " - " + str(ri(0, 9)) + ")"

fn gen_expr_over2(a: text, b: text) -> text:
    val op = ri(0, 3)
    if op == 0:
        return a + " * " + b
    if op == 1:
        return a + " + " + b
    if op == 2:
        return a + " - " + b
    return "(" + a + " + " + b + ") * 2"

# Final expression in main: mixes local vars, struct fields, ev(), rec().
fn gen_main_expr(nv: int) -> text:
    var e = gen_expr(2, nv)
    val k = ri(0, 3)
    if k == 0:
        return e + " + s.x - s.y"
    if k == 1:
        return "(" + e + ") * 1 + s.x"
    if k == 2:
        return e + " + rec(" + str(ri(0, 5)) + ")"
    return e + " + s.y"

fn main():
    val a = get_args()
    var seed = 1
    if a.len() > 0:
        seed = int(a[a.len() - 1])
    seed_rng(seed)
    emit_program()
