# OPEN DEFECT repro (NOT gated by the runner). See README.md.
# `match e` handles only E.A; calling f(E.B) hits no arm. This SHOULD be a
# compile-time non-exhaustiveness error (or at least a runtime trap). On the
# deployed binary it is silently ACCEPTED: f(E.B) returns 0, exit 0.
enum E:
    A
    B

fn f(e: E) -> i64:
    match e:
        E.A: 1

fn main():
    print(f(E.B))
