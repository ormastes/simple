# Should happen: a closure created inside a function, capturing that
# function's parameter, and returned to the caller, remains callable and
# returns the correct captured-parameter-based value.
# Actually happens (deployed binary): SILENT ACCEPT (exit=0) that prints an
# invalid-heap-pointer tag instead of the computed value once the closure
# escapes its defining function's stack frame.
#
# Repro:
#   bin/release/x86_64-unknown-linux-gnu/simple run <this file> ; echo "exit=$?"
# Observed output (exit=0): <invalid-heap:0x69>
# Expected (hand-computed): adder = make_adder(100) captures base=100;
#   adder(5) = 5 + 100 = 105.
fn make_adder(base: i64):
    val add_base = \x: x + base
    return add_base

fn main():
    val adder = make_adder(100)
    print(adder(5))   # expected 105, ACTUAL: <invalid-heap:0x69>
