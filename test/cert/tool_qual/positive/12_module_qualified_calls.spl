# Tool-qual positive case: module/type-qualified static calls (`Type.method()`).
# Hand-computed: MathUtil.add(3,4)=7; MathUtil.mul(3,4)=12.
struct MathUtil:
    dummy: i64

impl MathUtil:
    static fn add(a: i64, b: i64) -> i64:
        a + b

    static fn mul(a: i64, b: i64) -> i64:
        a * b

fn main():
    print(MathUtil.add(3, 4))   # 7
    print(MathUtil.mul(3, 4))   # 12
