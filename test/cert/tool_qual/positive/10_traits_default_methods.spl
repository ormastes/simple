# Tool-qual positive case: trait with a required method + a default method,
# both explicitly implemented by `impl Trait for Struct`.
# Hand-computed: Ann.hello() (explicit impl) returns "Hi, Ann"; Ann.bye()
# (a trait default, explicitly overridden here) returns "Bye, Ann".
#
# SCOPE NOTE: this case only exercises the explicit-override path. Calling a
# trait default method that is NOT overridden in the impl (true inheritance of
# the default body) segfaults on the deployed binary -- see
# known_defects/trait_default_method_inherited_segfault.spl. That construct is
# skipped here per the oracle-independence policy (never pin a golden for a
# crash).
trait Greeter:
    fn hello() -> text          # required, no body

    fn bye() -> text:            # default body
        "Bye, stranger"

struct Ann:
    name: text

impl Greeter for Ann:
    fn hello() -> text:
        "Hi, " + self.name

    fn bye() -> text:
        "Bye, " + self.name

fn main():
    val a = Ann(name: "Ann")
    print(a.hello())   # Hi, Ann
    print(a.bye())     # Bye, Ann
