# Tool-qual positive case: array/list ops -- push, len, for-loop iteration,
# and indexing.
# Hand-computed: [1,2,3,4,5].push(6) -> [1,2,3,4,5,6], len=6;
# sum(1..6)=1+2+3+4+5+6=21; first=1; last=xs[5]=6.
fn main():
    var xs = [1, 2, 3, 4, 5]
    xs.push(6)
    print(xs.len())              # 6
    var total = 0
    for x in xs:
        total = total + x
    print(total)                 # 21
    print(xs[0])                 # 1
    print(xs[xs.len() - 1])      # 6
