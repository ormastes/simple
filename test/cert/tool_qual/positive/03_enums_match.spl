# Tool-qual positive case: CUSTOM enum + match with payload binding.
# Deliberately NOT the built-in Result/Ok/Err/? path (frozen-buggy on the
# deployed binary); a user-defined enum exercises the same codegen cleanly.
# Hand-computed: Circle(2) -> 2*2*3 = 12; Rect(3,5) -> 3*5 = 15.
enum Shape:
    Circle(i64)
    Rect(i64, i64)

fn area(s: Shape) -> i64:
    match s:
        Shape.Circle(r): r * r * 3
        Shape.Rect(w, h): w * h

fn main():
    print(area(Shape.Circle(2)))    # 12
    print(area(Shape.Rect(3, 5)))   # 15
