# Tool-qual positive case: generic function with a trait bound (`<T: Trait>`),
# distinct from 05_generics.spl's unbounded identity-function case.
# Hand-computed: Boxed(n:21).value()=21; double_val bound to Numeric doubles
# it: 21*2=42.
trait Numeric:
    fn value() -> i64

struct Boxed:
    n: i64

impl Numeric for Boxed:
    fn value() -> i64:
        self.n

fn double_val<T: Numeric>(x: T) -> i64:
    x.value() * 2

fn main():
    print(double_val(Boxed(n: 21)))   # 42
