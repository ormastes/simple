# Bug: interp_to_int_split_result_nil_coalesce_garbage_2026-07-17.md
# Root cause: `lower_builtin_method_call`'s string-methods result-type table
# (src/compiler_rust/compiler/src/hir/lower/expr/mod.rs) never listed
# "to_int"/"to_i64" alongside "len"/"length"/"bytes". A `.to_int()` call on a
# String-typed receiver therefore fell through to the generic dynamic-dispatch
# fallback, which does not actually invoke `rt_string_to_int` -- it resolves
# to an identity pass-through of the receiver's own (still-boxed) pointer,
# typed `I64`. Printing/using that raw pointer as an i64 misdecodes it: a
# small, near-zero float for literal strings, or an ASLR-varying huge integer
# ("garbage") for heap-allocated strings such as `.split()` elements.
# Severity: P1 (silent wrong answer, not a crash)

describe "to_int() on string receivers (literal and split()-derived)":
    it "parses a literal numeric string exactly":
        val n = "42".to_int()
        expect(n).to_equal(42)

    it "combines with ?? default and still yields the parsed value":
        val n = "42".to_int() ?? 0
        expect(n).to_equal(42)

    it "parses a split()-derived (heap-allocated) numeric string exactly":
        # Index directly (not via a helper fn) -- an untyped wrapper
        # parameter forces JIT-compilation to bail out and silently fall
        # back to the tree-walking interpreter, which never exhibited this
        # bug and would make this assertion pass even without the fix.
        val parts = "hello:42:world".split(":")
        val n = parts[1].to_int()
        expect(n).to_equal(42)

    it "combines a split()-derived to_int() with ?? default":
        val parts = "hello:42:world".split(":")
        val n = parts[1].to_int() ?? 0
        expect(n).to_equal(42)

    it "still returns 0 (not garbage) for a non-numeric string":
        val n = "abc".to_int()
        expect(n).to_equal(0)
