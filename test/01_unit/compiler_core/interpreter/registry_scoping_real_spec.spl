# Registry Scoping / Cross-Module Collision — REAL-IMPORT Specification
# marker: pure_interp_registry_2026-07-17
#
# Companion to registry_scoping_spec.spl (which uses mocks). This spec
# imports and drives the ACTUAL functions in eval_tables.spl and
# interp_resource_tracker.spl directly (following the real-import pattern
# proven viable by module_loader_lazy_spec.spl in the sibling
# test/01_unit/compiler/interpreter/ directory: stateful work in ordinary
# fn's returning "" (pass) or an error string, asserted from `it` blocks —
# interpreter-mode `it` closures can observe stale state for inline work).
#
# If this file fails to even load/parse (import-graph choke), that failure
# — not a guess — is the evidence for falling back to mocks; see
# registry_scoping_spec.spl and the audit section in
# doc/08_tracking/bug/mcp_stdio_smoke_seed_flat_registry_len_i64_2026-07-17.md.

use compiler.core.interpreter.eval_tables.{
    func_table_reset,
    func_table_register,
    func_table_lookup,
    func_table_remove_owned
}
use compiler.core.interpreter.interp_resource_tracker.{
    irt_init,
    irt_begin_module,
    irt_track_func,
    irt_unload_module
}

fn check_collision_survives_unload() -> text:
    func_table_reset()
    irt_init()
    irt_begin_module("real_mod_a")
    irt_begin_module("real_mod_b")

    func_table_register("real_helper", 100)
    irt_track_func("real_mod_a", "real_helper", 100, 0, 1)

    # mod_b collides on the same bare name — table now holds mod_b's decl_id.
    func_table_register("real_helper", 200)
    irt_track_func("real_mod_b", "real_helper", 200, 0, 1)

    val before = func_table_lookup("real_helper")
    if before != 200:
        return "before-unload lookup=" + before.to_text() + " (want 200)"

    # Unloading mod_a must NOT delete mod_b's live registration.
    irt_unload_module("real_mod_a")

    val after = func_table_lookup("real_helper")
    if after != 200:
        return "after-unload(mod_a) lookup=" + after.to_text() + " (want 200 — mod_b survives)"
    ""

fn check_sole_owner_unload_removes_it() -> text:
    func_table_reset()
    irt_init()
    irt_begin_module("real_mod_solo")
    func_table_register("real_solo_fn", 300)
    irt_track_func("real_mod_solo", "real_solo_fn", 300, 0, 1)

    val before = func_table_lookup("real_solo_fn")
    if before != 300:
        return "before-unload lookup=" + before.to_text() + " (want 300)"

    irt_unload_module("real_mod_solo")

    val after = func_table_lookup("real_solo_fn")
    if after != -1:
        return "after-unload lookup=" + after.to_text() + " (want -1 — removed)"
    ""

fn check_owned_remove_noops_on_mismatch() -> text:
    func_table_reset()
    func_table_register("guard_fn", 400)
    # A different (stale/wrong) expected decl_id must not remove the entry.
    val removed_wrong = func_table_remove_owned("guard_fn", 999)
    if removed_wrong:
        return "func_table_remove_owned removed on mismatched decl_id"
    val still_there = func_table_lookup("guard_fn")
    if still_there != 400:
        return "guard_fn lookup=" + still_there.to_text() + " (want 400 — untouched)"
    # Correct expected decl_id does remove it.
    val removed_right = func_table_remove_owned("guard_fn", 400)
    if not removed_right:
        return "func_table_remove_owned did not remove on matching decl_id"
    ""

describe "real registry scoping (imports eval_tables.spl / interp_resource_tracker.spl directly)":
    it "unloading the overwritten module does not delete the surviving module's live entry":
        val err = check_collision_survives_unload()
        expect(err).to_equal("")

    it "unloading the sole owner of a name removes it":
        val err = check_sole_owner_unload_removes_it()
        expect(err).to_equal("")

    it "func_table_remove_owned no-ops on a mismatched decl_id and removes on a match":
        val err = check_owned_remove_noops_on_mismatch()
        expect(err).to_equal("")
