use std.io_runtime.{file_read}

describe "Tokens":
    it "defines token names, keyword lookup, and precedence helpers":
        val src = file_read("src/compiler/10.frontend/core/tokens.spl")

        expect(src).to_contain("fn tok_kind_name(kind: i64) -> text:")
        expect(src).to_contain("if kind == TOK_INT_LIT: return \"IntLit\"")
        expect(src).to_contain("if kind == TOK_PIPE_FORWARD: return \"|>\"")
        expect(src).to_contain("return \"Unknown(\" + kind.to_text() + \")\"")

        expect(src).to_contain("fn keyword_lookup(name: text) -> i64:")
        expect(src).to_contain("if name == \"fn\": return TOK_KW_FN")
        expect(src).to_contain("if name == \"nil\": return TOK_NIL_LIT")
        expect(src).to_contain("    TOK_IDENT")

        expect(src).to_contain("fn tok_precedence(kind: i64) -> i64:")
        expect(src).to_contain("if kind == TOK_ASSIGN: return 1")
        expect(src).to_contain("if kind == TOK_STAR_STAR: return 12")
        expect(src).to_contain("return 0")

    it "keeps the complete keyword map and identifier fallback":
        val src = file_read("src/compiler/10.frontend/core/tokens.spl")
        val mappings = [
            "as", "TOK_KW_AS", "ce", "TOK_KW_CE", "do", "TOK_KW_DO",
            "fn", "TOK_KW_FN", "if", "TOK_KW_IF", "in", "TOK_KW_IN",
            "is", "TOK_KW_IS", "me", "TOK_KW_ME", "on", "TOK_KW_ON",
            "or", "TOK_KW_OR", "and", "TOK_KW_AND", "asm", "TOK_KW_ASM",
            "cli", "TOK_KW_CLI", "dyn", "TOK_KW_DYN", "for", "TOK_KW_FOR",
            "new", "TOK_KW_NEW", "nil", "TOK_NIL_LIT", "not", "TOK_KW_NOT",
            "pub", "TOK_KW_PUB", "use", "TOK_KW_USE", "val", "TOK_KW_VAL",
            "var", "TOK_KW_VAR", "xor", "TOK_CARET", "bind", "TOK_KW_BIND",
            "case", "TOK_KW_CASE", "elif", "TOK_KW_ELIF", "else", "TOK_KW_ELSE",
            "enum", "TOK_KW_ENUM", "impl", "TOK_KW_IMPL", "lazy", "TOK_KW_LAZY",
            "loop", "TOK_KW_LOOP", "pass", "TOK_KW_PASS", "self", "TOK_KW_SELF",
            "true", "TOK_KW_TRUE", "type", "TOK_KW_TYPE", "after", "TOK_KW_AFTER",
            "allow", "TOK_KW_ALLOW", "async", "TOK_KW_ASYNC", "await", "TOK_KW_AWAIT",
            "break", "TOK_KW_BREAK", "class", "TOK_KW_CLASS", "const", "TOK_KW_CONST",
            "defer", "TOK_KW_DEFER", "false", "TOK_KW_FALSE", "keyof", "TOK_KW_KEYOF",
            "match", "TOK_KW_MATCH", "mixin", "TOK_KW_MIXIN", "spawn", "TOK_KW_SPAWN",
            "trait", "TOK_KW_TRAIT", "where", "TOK_KW_WHERE", "while", "TOK_KW_WHILE",
            "yield", "TOK_KW_YIELD", "export", "TOK_KW_EXPORT", "extend", "TOK_KW_EXTEND",
            "extern", "TOK_KW_EXTERN", "forbid", "TOK_KW_FORBID", "import", "TOK_KW_IMPORT",
            "return", "TOK_KW_RETURN", "static", "TOK_KW_STATIC", "struct", "TOK_KW_STRUCT",
            "newtype", "TOK_KW_NEWTYPE", "newunit", "TOK_KW_NEWUNIT",
            "pass_dn", "TOK_KW_PASS_DN", "receive", "TOK_KW_RECEIVE",
            "bitfield", "TOK_KW_BITFIELD", "comptime", "TOK_KW_COMPTIME",
            "continue", "TOK_KW_CONTINUE", "errdefer", "TOK_KW_ERRDEFER",
            "interface", "TOK_KW_INTERFACE", "pass_todo", "TOK_KW_PASS_TODO",
            "implements", "TOK_KW_IMPLEMENTS", "static_for", "TOK_KW_STATIC_FOR",
            "pass_do_nothing", "TOK_KW_PASS_DO_NOTHING"
        ]

        expect(mappings.len()).to_equal(146)
        expect(src).to_contain("val length = name.len()")
        var i: i64 = 0
        while i < mappings.len():
            val name = mappings[i]
            val kind = mappings[i + 1]
            expect(src).to_contain("if name == \"" + name + "\": return " + kind)
            i = i + 2

        val nonkeywords = ["", "f", "function", "static_fo", "pass_do_nothin", "pass_do_nothingx", "hello", "xyz123"]
        for name in nonkeywords:
            expect(src.contains("if name == \"" + name + "\": return")).to_equal(false)
        expect(src).to_contain("    TOK_IDENT")

    it "defines token classification helpers":
        val src = file_read("src/compiler/10.frontend/core/tokens.spl")

        expect(src).to_contain("fn tok_is_right_assoc(kind: i64) -> bool:")
        expect(src).to_contain("if kind == TOK_STAR_STAR: return true")
        expect(src).to_contain("if tok_is_assignment(kind): return true")

        expect(src).to_contain("fn tok_is_literal(kind: i64) -> bool:")
        expect(src).to_contain("if kind == TOK_INT_LIT: return true")
        expect(src).to_contain("if kind == TOK_NIL_LIT: return true")

        expect(src).to_contain("fn tok_is_comparison(kind: i64) -> bool:")
        expect(src).to_contain("if kind == TOK_GT_EQ: return true")
        expect(src).to_contain("fn tok_is_assignment(kind: i64) -> bool:")
        expect(src).to_contain("if kind == TOK_PERCENT_EQ: return true")
        expect(src).to_contain("fn tok_is_additive(kind: i64) -> bool:")
        expect(src).to_contain("fn tok_is_multiplicative(kind: i64) -> bool:")

