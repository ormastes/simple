fn double(x: i64) -> i64: x * 2
fn triple(x: i64) -> i64: x * 3
fn add1(x: i64) -> i64: x + 1

describe "Compose operator >>":
    it "basic compose":
        val f = double >> triple
        expect(f(2)).to_equal(12)

    it "chained compose":
        val f = add1 >> double >> triple
        expect(f(1)).to_equal(12)

    it "compose with pipe":
        val f = double >> add1
        val result = 5 |> f
        expect(result).to_equal(11)
