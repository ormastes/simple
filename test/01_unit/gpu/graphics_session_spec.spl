# Graphics Session API spec tests
use std.io
use std.spec.{describe, it, expect}

class GraphicsSession:
    session_id: i64
    mode: text
    active: bool
    frame_count: i64

    static fn make(sid: i64, m: text) -> GraphicsSession:
        GraphicsSession(session_id: sid, mode: m, active: false, frame_count: 0)

    me retain() -> text:
        if self.active:
            if self.mode == "perf_exclusive":
                return "error:mode_conflict"
        self.active = true
        return ""

    me release() -> text:
        self.active = false
        return ""

    me begin_frame() -> i64:
        if self.active == false:
            return -1
        self.frame_count = self.frame_count + 1
        return self.frame_count

    me end_frame(fid: i64) -> text:
        if self.active == false:
            return "error:not_active"
        return ""

class Caps:
    backend: text
    arch: text
    bits: i64
    has_compute: bool
    has_graphics: bool

    static fn cpu() -> Caps:
        Caps(backend: "cpu", arch: "x86_64", bits: 64, has_compute: true, has_graphics: false)

    static fn vulkan(arch: text, bits: i64) -> Caps:
        Caps(backend: "vulkan", arch: arch, bits: bits, has_compute: true, has_graphics: true)

class LegacyEngine2D:
    session_id: i64
    backend: text

    static fn create(w: i64, h: i64) -> LegacyEngine2D:
        LegacyEngine2D(session_id: 100, backend: "legacy_no_session")

    me fill_rect(x: i64, y: i64, w: i64, h: i64, c: i64) -> text:
        return "fill_rect"

    me cleanup() -> text:
        return "cleaned"

class LegacyEngine3D:
    session_id: i64
    backend: text

    static fn create(w: i64, h: i64) -> LegacyEngine3D:
        LegacyEngine3D(session_id: 200, backend: "legacy_no_session")

    me draw_mesh(mesh_id: i64, mat_id: i64) -> text:
        return "draw_mesh"

    me cleanup() -> text:
        return "cleaned"

class Game2DSession:
    session_id: i64
    mode: text
    sprite_count: i64

    static fn create_managed(w: i64, h: i64) -> Game2DSession:
        Game2DSession(session_id: 2000, mode: "managed_shared", sprite_count: 0)

    me add_sprite(x: i64, y: i64, w: i64, h: i64, tid: i64) -> i64:
        self.sprite_count = self.sprite_count + 1
        return self.sprite_count

class Game3DSession:
    session_id: i64
    mode: text
    asset_count: i64

    static fn create_perf(w: i64, h: i64) -> Game3DSession:
        Game3DSession(session_id: 3000, mode: "perf_exclusive", asset_count: 0)

    me load_asset(name: text, kind: text) -> i64:
        self.asset_count = self.asset_count + 1
        return self.asset_count

class WebRendererSession:
    session_id: i64
    mode: text
    surface_id: i64
    paint_count: i64
    webgpu_enabled: bool
    active: bool

    static fn create_managed(sid: i64) -> WebRendererSession:
        WebRendererSession(
            session_id: 4000 + sid,
            mode: "managed_shared",
            surface_id: sid,
            paint_count: 0,
            webgpu_enabled: true,
            active: true
        )

    me paint_fragment(ftype: text, x: i64, y: i64, w: i64, h: i64) -> text:
        self.paint_count = self.paint_count + 1
        return "painted"

    me needs_gpu() -> bool:
        return self.webgpu_enabled

    me cleanup() -> text:
        self.active = false
        return "cleaned"

class GuiAppSession:
    session_id: i64
    mode: text
    window_count: i64
    paint_dirty: bool
    active: bool

    static fn create_managed() -> GuiAppSession:
        GuiAppSession(
            session_id: 5000,
            mode: "managed_shared",
            window_count: 0,
            paint_dirty: false,
            active: true
        )

    me add_window(title: text, w: i64, h: i64) -> i64:
        self.window_count = self.window_count + 1
        return self.window_count

    me mark_dirty():
        self.paint_dirty = true

    me cleanup() -> text:
        self.active = false
        return "cleaned"

class WmCompositorSession:
    session_id: i64
    mode: text
    surface_count: i64
    damage_region_count: i64
    frame_count: i64
    active: bool

    static fn create_managed() -> WmCompositorSession:
        WmCompositorSession(
            session_id: 6000,
            mode: "managed_shared",
            surface_count: 0,
            damage_region_count: 0,
            frame_count: 0,
            active: true
        )

    me add_surface(owner_id: i64, w: i64, h: i64) -> i64:
        self.surface_count = self.surface_count + 1
        return self.surface_count

    me mark_damage(sid: i64, x: i64, y: i64, w: i64, h: i64) -> text:
        self.damage_region_count = self.damage_region_count + 1
        return "damage"

    me compose_frame() -> text:
        self.frame_count = self.frame_count + 1
        return "composed"

    me cleanup() -> text:
        self.active = false
        return "cleaned"

class GraphicsOptProvider:
    provider_id: text
    fact_count: i64
    active: bool

    static fn create(pid: text, kind: text, backend: text) -> GraphicsOptProvider:
        GraphicsOptProvider(provider_id: pid, fact_count: 0, active: true)

    me add_fact(key: text, v: text) -> i64:
        self.fact_count = self.fact_count + 1
        return self.fact_count

fn test_session_create_managed():
    print("--- Test: session_create_managed ---")
    val s = GraphicsSession.make(1, "managed_shared")
    if s.mode == "managed_shared":
        print("PASS: mode is managed_shared")
    else:
        print("FAIL: mode is " + s.mode)
    if s.active == false:
        print("PASS: inactive after create")
    else:
        print("FAIL: should be inactive")

fn test_session_create_legacy():
    print("--- Test: session_create_legacy ---")
    val s = GraphicsSession.make(0, "legacy_no_session")
    if s.mode == "legacy_no_session":
        print("PASS: legacy mode")
    else:
        print("FAIL: " + s.mode)

fn test_session_create_perf():
    print("--- Test: session_create_perf ---")
    val s = GraphicsSession.make(2, "perf_exclusive")
    if s.mode == "perf_exclusive":
        print("PASS: perf mode")
    else:
        print("FAIL: " + s.mode)

fn test_mode_conflict():
    print("--- Test: mode_conflict ---")
    val s = GraphicsSession.make(2, "perf_exclusive")
    val r1 = s.retain()
    val r2 = s.retain()
    if r2 == "error:mode_conflict":
        print("PASS: mode_conflict detected")
    else:
        print("FAIL: got " + r2)

fn test_session_lifecycle():
    print("--- Test: session_lifecycle ---")
    val s = GraphicsSession.make(1, "managed_shared")
    val ret = s.retain()
    if ret == "":
        print("PASS: retain ok")
    else:
        print("FAIL: retain " + ret)
    val fid = s.begin_frame()
    if fid == 1:
        print("PASS: begin_frame=1")
    else:
        print("FAIL: fid=" + fid.to_text())
    val ef = s.end_frame(fid)
    if ef == "":
        print("PASS: end_frame ok")
    else:
        print("FAIL: end_frame " + ef)
    val rel = s.release()
    if rel == "":
        print("PASS: release ok")
    else:
        print("FAIL: release " + rel)

fn test_backend_capabilities():
    print("--- Test: backend_capabilities ---")
    val c = Caps.cpu()
    if c.backend == "cpu":
        print("PASS: cpu backend")
    else:
        print("FAIL: " + c.backend)
    if c.has_compute:
        print("PASS: has_compute")
    else:
        print("FAIL: no compute")

fn test_arch_capabilities():
    print("--- Test: arch_capabilities ---")
    val x = Caps.vulkan("x86_64", 64)
    val a = Caps.vulkan("aarch64", 64)
    val r = Caps.vulkan("riscv64", 64)
    if x.arch == "x86_64":
        print("PASS: x86_64")
    else:
        print("FAIL: x86_64")
    if a.arch == "aarch64":
        print("PASS: aarch64")
    else:
        print("FAIL: aarch64")
    if r.arch == "riscv64":
        print("PASS: riscv64")
    else:
        print("FAIL: riscv64")

fn test_legacy_engine2d():
    print("--- Test: legacy_engine2d ---")
    val e = LegacyEngine2D.create(1920, 1080)
    if e.backend == "legacy_no_session":
        print("PASS: legacy mode")
    else:
        print("FAIL: " + e.backend)
    val r = e.fill_rect(0, 0, 100, 100, 0)
    if r == "fill_rect":
        print("PASS: fill_rect")
    else:
        print("FAIL: fill_rect")

fn test_legacy_engine3d():
    print("--- Test: legacy_engine3d ---")
    val e = LegacyEngine3D.create(1280, 720)
    if e.backend == "legacy_no_session":
        print("PASS: legacy mode")
    else:
        print("FAIL: " + e.backend)
    val r = e.draw_mesh(1, 2)
    if r == "draw_mesh":
        print("PASS: draw_mesh")
    else:
        print("FAIL: draw_mesh")

fn test_game2d_session():
    print("--- Test: game2d_session ---")
    val g = Game2DSession.create_managed(1280, 720)
    if g.mode == "managed_shared":
        print("PASS: mode")
    else:
        print("FAIL: " + g.mode)
    val sid = g.add_sprite(10, 20, 64, 64, 1)
    if sid == 1:
        print("PASS: sprite_id=1")
    else:
        print("FAIL: sid=" + sid.to_text())

fn test_game3d_session():
    print("--- Test: game3d_session ---")
    val g = Game3DSession.create_perf(1920, 1080)
    if g.mode == "perf_exclusive":
        print("PASS: mode")
    else:
        print("FAIL: " + g.mode)
    val aid = g.load_asset("mesh.obj", "mesh")
    if aid == 1:
        print("PASS: asset_id=1")
    else:
        print("FAIL: aid=" + aid.to_text())

fn test_web_renderer():
    print("--- Test: web_renderer ---")
    val w = WebRendererSession.create_managed(7)
    if w.mode == "managed_shared":
        print("PASS: mode")
    else:
        print("FAIL: " + w.mode)
    if w.surface_id == 7:
        print("PASS: surface_id=7")
    else:
        print("FAIL: sid=" + w.surface_id.to_text())
    val r = w.paint_fragment("div", 0, 0, 200, 100)
    if w.paint_count == 1:
        print("PASS: paint_count=1")
    else:
        print("FAIL: pc=" + w.paint_count.to_text())
    if w.needs_gpu():
        print("PASS: needs_gpu")
    else:
        print("FAIL: needs_gpu")

fn test_gui_app():
    print("--- Test: gui_app ---")
    val g = GuiAppSession.create_managed()
    if g.mode == "managed_shared":
        print("PASS: mode")
    else:
        print("FAIL: " + g.mode)
    val wid = g.add_window("Main", 800, 600)
    if wid == 1:
        print("PASS: window_id=1")
    else:
        print("FAIL: wid=" + wid.to_text())
    g.mark_dirty()
    if g.paint_dirty:
        print("PASS: paint_dirty")
    else:
        print("FAIL: paint_dirty")

fn test_wm_compositor():
    print("--- Test: wm_compositor ---")
    val wm = WmCompositorSession.create_managed()
    if wm.mode == "managed_shared":
        print("PASS: mode")
    else:
        print("FAIL: " + wm.mode)
    val sid = wm.add_surface(42, 1920, 1080)
    if sid == 1:
        print("PASS: surface_id=1")
    else:
        print("FAIL: sid=" + sid.to_text())
    val dr = wm.mark_damage(sid, 0, 0, 100, 100)
    if wm.damage_region_count == 1:
        print("PASS: damage=1")
    else:
        print("FAIL: damage=" + wm.damage_region_count.to_text())
    val fr = wm.compose_frame()
    if wm.frame_count == 1:
        print("PASS: frame=1")
    else:
        print("FAIL: frame=" + wm.frame_count.to_text())

fn test_optimization_provider():
    print("--- Test: optimization_provider ---")
    val p = GraphicsOptProvider.create("test", "shader", "vulkan")
    if p.provider_id == "test":
        print("PASS: provider_id")
    else:
        print("FAIL: " + p.provider_id)
    if p.active:
        print("PASS: active")
    else:
        print("FAIL: not active")
    val fc = p.add_fact("simd_width", "256")
    if fc == 1:
        print("PASS: fact=1")
    else:
        print("FAIL: fc=" + fc.to_text())
    val fc2 = p.add_fact("arch", "x86_64")
    if fc2 == 2:
        print("PASS: fact=2")
    else:
        print("FAIL: fc2=" + fc2.to_text())

fn test_cross_surface_policy():
    print("--- Test: cross_surface_policy ---")
    val web = WebRendererSession.create_managed(1)
    val gui = GuiAppSession.create_managed()
    val wm = WmCompositorSession.create_managed()
    if web.mode == "managed_shared":
        if gui.mode == "managed_shared":
            if wm.mode == "managed_shared":
                print("PASS: all surfaces accept managed_shared")
            else:
                print("FAIL: wm mode")
        else:
            print("FAIL: gui mode")
    else:
        print("FAIL: web mode")

describe "GraphicsSession API":
    it "creates managed sessions inactive":
        val s = GraphicsSession.make(1, "managed_shared")
        expect(s.mode).to_equal("managed_shared")
        expect(s.active).to_equal(false)

    it "rejects sharing perf exclusive sessions twice":
        val s = GraphicsSession.make(2, "perf_exclusive")
        val first = s.retain()
        val second = s.retain()
        expect(first).to_equal("")
        expect(second).to_equal("error:mode_conflict")

    it "begins a frame after retain":
        val s = GraphicsSession.make(1, "managed_shared")
        val ret = s.retain()
        val frame = s.begin_frame()
        expect(ret).to_equal("")
        expect(frame).to_equal(1)

describe "GraphicsSession surfaces":
    it "keeps legacy 2D constructors in legacy no-session mode":
        val e = LegacyEngine2D.create(1920, 1080)
        expect(e.backend).to_equal("legacy_no_session")
        expect(e.fill_rect(0, 0, 100, 100, 0)).to_equal("fill_rect")

    it "keeps legacy 3D constructors in legacy no-session mode":
        val e = LegacyEngine3D.create(1280, 720)
        expect(e.backend).to_equal("legacy_no_session")
        expect(e.draw_mesh(1, 2)).to_equal("draw_mesh")

    it "supports managed 2D game sprite sessions":
        val g = Game2DSession.create_managed(1280, 720)
        expect(g.mode).to_equal("managed_shared")
        expect(g.add_sprite(10, 20, 64, 64, 1)).to_equal(1)

    it "supports perf-exclusive 3D game asset sessions":
        val g = Game3DSession.create_perf(1920, 1080)
        expect(g.mode).to_equal("perf_exclusive")
        expect(g.load_asset("mesh.obj", "mesh")).to_equal(1)

    it "shares managed policy across web, GUI, and WM surfaces":
        val web = WebRendererSession.create_managed(1)
        val gui = GuiAppSession.create_managed()
        val wm = WmCompositorSession.create_managed()
        expect(web.mode).to_equal("managed_shared")
        expect(gui.mode).to_equal("managed_shared")
        expect(wm.mode).to_equal("managed_shared")

describe "GraphicsSession optimization providers":
    it "persists provider facts by incrementing fact count":
        val p = GraphicsOptProvider.create("test", "shader", "vulkan")
        expect(p.add_fact("simd_width", "256")).to_equal(1)
        expect(p.add_fact("arch", "x86_64")).to_equal(2)

fn main():
    test_session_create_managed()
    test_session_create_legacy()
    test_session_create_perf()
    test_mode_conflict()
    test_session_lifecycle()
    test_backend_capabilities()
    test_arch_capabilities()
    test_legacy_engine2d()
    test_legacy_engine3d()
    test_game2d_session()
    test_game3d_session()
    test_web_renderer()
    test_gui_app()
    test_wm_compositor()
    test_optimization_provider()
    test_cross_surface_policy()
    print("DONE")
