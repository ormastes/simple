enum HirParamNativePayload:
    Item(i64, i64, i64)

fn hir_param_native_third(value: HirParamNativePayload) -> i64:
    match value:
        case HirParamNativePayload.Item(first, second, result):
            return result
        case _:
            return 0

describe "HIR parameter native lowering":
    it "preserves a required parameter symbol through enum payload lowering":
        expect(hir_param_native_third(HirParamNativePayload.Item(1, 2, 3))).to_equal(3)
