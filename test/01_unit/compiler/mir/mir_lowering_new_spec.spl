extern fn rt_file_read_text(path: text) -> text

fn read_mir_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "Mir Lowering New":
    it "keeps MirLowering state shape available":
        val source = read_mir_source("src/compiler/50.mir/mir_lowering_types.spl")

        expect(source).to_contain("struct MirLowering")
        expect(source).to_contain("builder: MirBuilder")
        expect(source).to_contain("symbols: SymbolTable")

    it "keeps MirLowering constructor wired to HIR symbols":
        val source = read_mir_source("src/compiler/50.mir/_MirLowering/module_lowering.spl")

        expect(source).to_contain("static fn new(symbols: SymbolTable) -> MirLowering")
        expect(source).to_contain("symbols: symbols")

    it "lowers real bootstrap MIR functions instead of fixed symbol slots":
        val source = read_mir_source("src/compiler/50.mir/_MirLowering/module_lowering.spl")

        expect(source).to_contain("val bootstrap_functions = module.functions.values()")
        expect(source).to_contain("val bootstrap_main_only = bootstrap_mode and not native_entry_closure_mir")
        expect(source).to_contain("if bootstrap_main_only:")
        expect(source).to_not_contain("val bootstrap_function_count = 6")
        expect(source).to_not_contain("var fn_sym = SymbolId(id: 1)")

    it "keeps bootstrap HIR and MIR from depending on corrupt symbol destructuring":
        val hir_source = read_mir_source("src/compiler/20.hir/hir_lowering/_Items/module_lowering.spl")
        val mir_source = read_mir_source("src/compiler/50.mir/_MirLowering/module_lowering.spl")

        expect(hir_source).to_contain("val fn_key: SymbolId = SymbolId(id: lower_idx)")
        expect(hir_source).to_not_contain("functions[hir_fn.symbol] = hir_fn")
        expect(mir_source).to_contain("fn_.is_extern")

    it "resets entry-closure MIR state before each source module":
        val source = read_mir_source("src/compiler/80.driver/driver_pipeline.spl")

        expect(source).to_contain("module: MirModule(")
        expect(source).to_contain("name: name_direct")
        expect(source).to_contain("direct_lowering.local_map = {}")
        expect(source).to_contain("direct_lowering.bitfield_value_syms = {}")

    it "keeps named bootstrap calls from becoming unknown symbol calls":
        val source = read_mir_source("src/compiler/50.mir/_MirLoweringExpr/switch_operators_calls.spl")

        expect(source).to_contain("case NamedVar(symbol, callee_name):")
        expect(source).to_contain("MirConstValue.Str(callee_name)")
        expect(source).to_contain("case Var(symbol):")
        expect(source).to_contain("val func_operand = self.symbol_to_operand(symbol)")

    it "keeps ordinary binary ops from taking the nil special-op branch":
        val source = read_mir_source("src/compiler/50.mir/_MirLoweringExpr/expr_dispatch.spl")

        expect(source).to_contain("val special_result = self.lower_binop_special(op, left, right)")
        expect(source).to_contain("if special_result != nil:")
        expect(source).to_not_contain("if val special_local = special_result:")

    it "lowers if expression results through an SSA phi at the merge block":
        val source = read_mir_source("src/compiler/50.mir/mir_lowering_stmts.spl")
        val backend_source = read_mir_source("src/compiler/70.backend/backend/_MirToLlvm/aggregate_intrinsics.spl")
        val active_instruction_source = read_mir_source("src/compiler/70.backend/backend/mir_to_llvm_instructions.spl")

        expect(source).to_contain("MirInstKind.Intrinsic(Some(result), \"__simple_ssa_phi\"")
        expect(source).to_contain("fn local_raw_id(local: LocalId) -> i64:")
        expect(source).to_contain("var emitted_phi = false")
        expect(source).to_contain("MirInstKind.Const(result, MirConstValue.Int(0), MirType.i64())")
        expect(source).to_contain("if then_result.? and else_result.?:")
        expect(source).to_contain("if not then_is_unit and not else_is_unit:")
        expect(backend_source).to_contain("if then_ty == \"void\" and else_ty == \"void\":")
        expect(backend_source).to_contain("if then_ty != else_ty:")
        expect(backend_source).to_contain("phi fallback")
        expect(backend_source).to_contain("if fallback_ty == \"ptr\":")
        expect(backend_source).to_contain("if then_ty == \"ptr\":")
        expect(backend_source).to_not_contain("ERROR: __simple_ssa_phi type mismatch")
        expect(backend_source).to_contain("val idx_cast = self.cast_value_if_needed(idx_val, idx_ty, self.native_int())")
        expect(active_instruction_source).to_contain("val idx_cast = self.cast_value_if_needed(idx_val, idx_ty, self.native_int())")
        expect(backend_source).to_contain("val base_input_ty = self.valid_llvm_type(self.llvm_value_type(base_val, self.get_operand_type(base)))")
        expect(active_instruction_source).to_contain("val base_input_ty = self.valid_llvm_type(self.llvm_value_type(base_val, self.get_operand_type(base)))")
        expect(backend_source).to_contain("var base_ptr = if base_input_ty == \"ptr\" and base_val == \"0\": \"null\" else: base_val")
        expect(active_instruction_source).to_contain("var base_ptr = if base_input_ty == \"ptr\" and base_val == \"0\": \"null\" else: base_val")
        expect(backend_source).to_contain("val base_ptr = self.cast_value_if_needed(base_val, base_ty, \"ptr\")")
        expect(active_instruction_source).to_contain("val base_ptr = self.cast_value_if_needed(base_val, base_ty, \"ptr\")")
        expect(backend_source).to_contain("index_vals = index_vals.push(")
        expect(active_instruction_source).to_contain("index_vals = index_vals.push(")
        expect(source).to_contain("MirConstValue.Int(then_block.id)")
        expect(source).to_contain("MirConstValue.Int(else_block.id)")
        expect(source).to_not_contain("b3.emit_copy(result, then_local)")
        expect(source).to_not_contain("b5.emit_copy(result, else_local)")

    it "only skips the unsafe collection optimizer for native entry closures":
        val source = read_mir_source("src/compiler/60.mir_opt/mir_opt/mod.spl")

        expect(source).to_contain("SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE")
        expect(source).to_contain("pass_name == \"collection_opt\"")
        expect(source).to_contain("native_entry.ends_with(\"bootstrap_main.spl\")")
        expect(source).to_contain("pass_name == \"predicate_promote\"")

    it "keeps LLVM binops from emitting nil type names":
        val source = read_mir_source("src/compiler/70.backend/backend/_MirToLlvm/core_codegen.spl")
        val class_source = read_mir_source("src/compiler/70.backend/backend/_MirToLlvm/class_def.spl")
        val active_instruction_source = read_mir_source("src/compiler/70.backend/backend/mir_to_llvm_instructions.spl")
        val aggregate_source = read_mir_source("src/compiler/70.backend/backend/_MirToLlvm/aggregate_intrinsics.spl")
        val cast_source = read_mir_source("src/compiler/70.backend/backend/_MirToLlvm/asm_constraints_helpers.spl")
        val builder_source = read_mir_source("src/compiler/70.backend/backend/llvm_ir_builder.spl")

        expect(source).to_contain("val ty = self.valid_llvm_type(self.get_local_type(dest.id))")
        expect(active_instruction_source).to_contain("val ty = self.valid_llvm_type(self.get_local_type(dest.id))")
        expect(source).to_contain("val lt_cmp_ty = self.common_llvm_value_type(left_ty, right_ty)")
        expect(active_instruction_source).to_contain("val lt_cmp_ty = self.common_llvm_value_type(left_ty, right_ty)")
        expect(source).to_contain("val eq_left = self.cast_value_if_needed(left_val, left_ty, eq_cmp_ty)")
        expect(active_instruction_source).to_contain("val eq_left = self.cast_value_if_needed(left_val, left_ty, eq_cmp_ty)")
        expect(source).to_not_contain("self.emit_comparison(dest_name, ty, eq_pred, eq_cmp_ty, self.cast_value_if_needed")
        expect(active_instruction_source).to_not_contain("self.emit_comparison(dest_name, ty, eq_pred, eq_cmp_ty, self.cast_value_if_needed")
        expect(source).to_contain("fn local_id_value(local: LocalId) -> i64:")
        expect(source).to_contain("local.id")
        expect(source).to_contain("block.id")
        expect(source).to_contain("case nil: \"i64\"")
        expect(source).to_contain("me cast_value_if_needed(value: text, src_ty: text, target_ty: text) -> text:")
        expect(source).to_contain("val tmp = self.builder.fresh_local()")
        expect(source).to_contain("ptrtoint ptr null to")
        expect(source).to_contain("if target_ty == \"ptr\" and value == \"0\":")
        expect(source).to_not_contain("val tmp = if value.starts_with(\"%\")")
        expect(builder_source).to_contain("\"%tmp")
        expect(source).to_contain("fn common_llvm_value_type(left_ty: text, right_ty: text) -> text:")
        expect(source).to_contain("if left_ty == \"ptr\" or right_ty == \"ptr\":")
        expect(source).to_contain("val local_id = self.local_id_value(local.id)")
        expect(source).to_contain("val final_ret_val = self.cast_value_if_needed(val_str, ret_ty, self.current_return_type)")
        expect(source).to_contain("val final_arg_val = if target_arg_ty == \"ptr\" and cast_arg_val == \"0\": \"null\" else: cast_arg_val")
        expect(active_instruction_source).to_contain("val final_arg_val = if target_arg_ty == \"ptr\" and cast_arg_val == \"0\": \"null\" else: cast_arg_val")
        expect(source).to_contain("self.local_types[self.local_id_value(dest)] = ty")
        expect(source).to_contain("self.local_types[dest.id] = ty")
        expect(aggregate_source).to_contain("val casted = self.cast_value_if_needed(operand_val, src_ty, target_ty)")
        expect(active_instruction_source).to_contain("val casted = self.cast_value_if_needed(operand_val, src_ty, target_ty)")
        expect(aggregate_source).to_contain("self.ptr_locals.remove(self.local_id_value(dest))")
        expect(source).to_contain("case Not: \"i1\"")
        expect(class_source).to_contain("emitted_local_types: Dict<i64, text>")
        expect(class_source).to_contain("local_aliases: Dict<i64, text>")
        expect(source).to_contain("self.emitted_local_types = {}")
        expect(source).to_contain("self.local_aliases = {}")
        expect(source).to_contain("me translate_block(block: MirBlock):")
        expect(source).to_contain("self.emitted_local_types[self.local_id_value(dest)] = ty")
        expect(source).to_contain("self.local_aliases[dest_id] = dest_name")
        expect(source).to_contain("if self.ptr_locals.has(local_id):")
        expect(source).to_contain("if self.ptr_locals.has(src_id): \"ptr\" else:")
        expect(source).to_contain("self.ptr_locals[dest_id] = true")
        expect(source).to_contain("self.ptr_locals.remove(dest_id)")
        expect(active_instruction_source).to_contain("self.ptr_locals[dest_id] = true")
        expect(source).to_contain("if self.local_aliases.has(local_id): self.local_aliases[local_id] else: if self.emitted_local_types.has(local_id): self.get_local(local_id) else: \"0\"")
        expect(source).to_contain("if self.emitted_local_types.has(local_id): self.emitted_local_types[local_id] else: self.get_local_type(local_id)")
        expect(source).to_contain("fn llvm_value_type(value: text, fallback: text) -> text:")
        expect(source).to_contain("if id >= 0 and self.ptr_locals.has(id):")
        expect(source).to_contain("val actual_src_ty = self.llvm_value_type(value, src_ty)")
        expect(class_source).to_contain("func_return_types: Dict<text, text>")
        expect(class_source).to_contain("func_param_types: Dict<text, [text]>")
        expect(source).to_contain("self.func_param_types[fn_.name] = param_types")
        expect(source).to_contain("self.func_return_types[fn_.name] = self.valid_llvm_type(self.llvm_type_text(fn_.signature.return_type))\n            for fn_ in module.functions.values():")
        expect(source).to_contain("val known_fn_param_types = if self.func_param_types.has(name): self.func_param_types[name] else: []")
        expect(source).to_contain("val param_ty = if arg_i < known_fn_param_types.len(): known_fn_param_types[arg_i] else: local_param_ty")
        expect(source).to_contain("self.local_types[local_id] = param_ty")
        expect(source).to_contain("val known_param_types = if self.func_param_types.has(known_func_name): self.func_param_types[known_func_name] else: []")
        expect(source).to_contain("val target_arg_ty = if arg_i < known_param_types.len(): known_param_types[arg_i] else: arg_ty")
        expect(source).to_contain("val ret_ty = if self.func_return_types.has(known_func_name): self.func_return_types[known_func_name] else: local_ret_ty")
        expect(source).to_contain("if ret_ty == \"void\":")
        expect(source).to_contain("call void")
        expect(active_instruction_source).to_contain("if ret_ty == \"void\":")
        expect(active_instruction_source).to_contain("call void")
        expect(source).to_contain("fn known_call_name(func: MirOperand) -> text:")
        expect(aggregate_source).to_contain("if src_ty == target_ty:")
        expect(active_instruction_source).to_contain("if src_ty == target_ty:")
        expect(cast_source).to_contain("target_ty == \"i1\"")
        expect(source).to_contain("val ty = self.valid_llvm_type(self.get_local_type(dest.id))")

    it "keeps native entry parse tracing and missing-entry diagnostics":
        val source = read_mir_source("src/compiler/80.driver/driver.spl")

        expect(source).to_contain("phase2:parse:entry")
        expect(source).to_contain("phase2:parse:entry:done")
        expect(source).to_contain("native entry source not found")

    it "keeps frontend parser bridge trace markers":
        val source = read_mir_source("src/compiler/10.frontend/frontend.spl")
        val bridge = read_mir_source("src/compiler/10.frontend/_FlatAstBridge/module_assembly.spl")
        val parser_module = read_mir_source("src/compiler/10.frontend/core/_ParserDecls/enum_module_body.spl")
        val parser_stmts = read_mir_source("src/compiler/10.frontend/core/parser_stmts.spl")
        val parser_expr = read_mir_source("src/compiler/10.frontend/core/parser_expr.spl")
        val parser_primary = read_mir_source("src/compiler/10.frontend/core/_ParserPrimary/primary_expr.spl")
        val ast_expr = read_mir_source("src/compiler/10.frontend/core/_AstExpr/nodes.spl")

        expect(source).to_contain("[frontend] parse_and_build:start")
        expect(source).to_contain("[frontend] parse_and_build:done")
        expect(bridge).to_contain("[flat-bridge] path=")
        expect(bridge).to_contain("[flat-bridge] building frontend module path=")
        expect(bridge).to_contain("[flat-bridge] built frontend module path=")
        expect(parser_module).to_contain("[parser-module] decl:start")
        expect(parser_stmts).to_contain("[parser-block] stmt:start")
        expect(parser_stmts).to_contain("[parser-block] expr-branch:start")
        expect(parser_expr).to_contain("[parser-expr] expr:start")
        expect(parser_expr).to_contain("parser_expr_trace_step(\"postfix\")")
        expect(parser_primary).to_contain("[parser-primary] ident:start")
        expect(parser_expr).to_contain("[parser-expr] call:start")
        expect(ast_expr).to_contain("[ast-expr] call-alloc:start")

