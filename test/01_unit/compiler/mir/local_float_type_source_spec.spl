use std.io_runtime.{file_read}
use std.spec.*

describe "MIR local float typing":
    it "defines the float-local helper used by statement lowering":
        val source = file_read("src/compiler/50.mir/_MirLoweringExpr/expr_dispatch.spl")
        expect(source).to_contain("fn local_is_float(local: LocalId) -> bool:")
        expect(source).to_contain("case MirTypeKind.F32 | MirTypeKind.F64: return true")
