use std.spec
use compiler.common.config.{Logger}
use compiler.frontend.frontend.{parse_full_frontend}
use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.mir.mir.*

fn lower_read_width_mir() -> text:
    val source = "struct FramebufferDriver:\n    front_addr: i64\n    back_buffer: i64\n    width: i64\n    height: i64\n\nstruct LargerDecoy:\n    width: i64\n    height: i64\n    pad0: i64\n    pad1: i64\n    pad2: i64\n    pad3: i64\n\nstruct DisplayState:\n    frame_id: i64\n    driver: FramebufferDriver\n\nfn read_width(state: DisplayState) -> i64:\n    return state.driver.width\n"
    val module = parse_full_frontend(source, "field_index_collision.spl", "field_index_collision.spl", Logger(level: 0))
    var hir_lowering = HirLowering.with_filename("field_index_collision.spl")
    val hir = hir_lowering.lower_module(module)
    var mir_lowering = MirLowering.new(hir.symbols)
    val mir = mir_lowering.lower_module(hir)
    for function in mir.functions.values():
        if function.name == "read_width" or function.name.ends_with(".read_width"):
            return serialize_mir_function(function)
    ""

describe "MIR typed receiver field-index collision", tag: ["only-compiled"]:
    it "keeps the nested receiver's width declaration index":
        val mir = lower_read_width_mir()
        val driver_pos = mir.index_of("\"field\":1") ?? -1
        val width_pos = mir.index_of("\"field\":2") ?? -1

        expect(mir.split("\"GetField\"").len()).to_equal(3)
        expect(driver_pos).to_be_greater_than(-1)
        expect(width_pos).to_be_greater_than(driver_pos)
