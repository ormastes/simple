extern fn rt_file_read_text(path: text) -> text

fn bootstrap_globals_source() -> text:
    rt_file_read_text("src/compiler/50.mir/_MirLowering/bootstrap_globals.spl") ?? ""

describe "bootstrap real body guard source":
    it "counts terminators as real bootstrap MIR body operations":
        val source = bootstrap_globals_source()

        expect(source).to_contain("var real_term_total = 0")
        expect(source).to_contain("case MirTerminator.Unreachable:")
        expect(source).to_contain("real_term_total = real_term_total + 1")
        expect(source).to_contain("real_instr_total == 0 and real_term_total == 0")
