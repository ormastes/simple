use std.spec
use compiler.common.config.{Logger}
use compiler.frontend.frontend.{parse_full_frontend}
use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.mir.mir.*

fn lower_text_find_mir(src: text, fname: text) -> text:
    val module = parse_full_frontend(src, fname + ".spl", fname + ".spl", Logger(level: 0))
    var hir_lowering = HirLowering.with_filename(fname + ".spl")
    val hir = hir_lowering.lower_module(module)
    var mir_lowering = MirLowering.new(hir.symbols)
    serialize_mir_module(mir_lowering.lower_module(hir))

describe "Text builtin find MIR lowering", tag: ["only-compiled"]:
    it "lowers .find on an unresolved-receiver string to rt_string_find (native_env_closure_unsupported_methods_2026-07-16)":
        # Same zero-arg-string-arg / i64-result shape as
        # std.env.variables.expand_var_expr's `expr.find(":-")` /
        # `expr.find(":=")`, the exact call that previously loud-failed
        # native-build with "unresolved method call: find".
        val source = "fn find_default_sep(expr: text) -> i64:\n    return expr.find(\":-\")\n"
        val mir = lower_text_find_mir(source, "find_default_sep")

        expect(mir).to_contain("rt_string_find")
        expect(mir.contains("rt_string_rfind")).to_equal(false)
        expect(mir.contains("unresolved method call")).to_equal(false)
