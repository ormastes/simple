extern fn rt_file_read_text(path: text) -> text

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "MIR null coalesce lowering":
    it "unwraps a present Option payload before merging":
        val source = read_source("src/compiler/50.mir/_MirLoweringExpr/expr_dispatch.spl")
        val runtime = read_source("src/runtime/runtime_native.c")

        expect(source).to_contain("case NullCoalesce(left, right):")
        expect(source).to_contain("MirConstValue.Str(\"rt_unwrap_or_self\")")
        expect(source).to_contain("return_type: MirType.i64()")
        expect(source).to_contain("self.decode_runtime_value(unwrapped, result_type)")
        expect(source).to_contain("left_value = unwrapped")
        expect(source).to_contain("val right_terminated = self.builder.current_block_has_explicit_terminator()")
        expect(source).to_contain("if not right_terminated:")
        expect(runtime).to_contain("if (rt_enum_discriminant(value) >= 0) return rt_enum_payload(value);")
