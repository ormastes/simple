# # Text-Method Behavior Parity (Erased-Receiver MIR Fallbacks)
#
# **Feature ID:** #COMPILER-MIR-TEXT-METHOD-FALLBACK-PARITY
# **Category:** Compiler | MIR | Text Methods
# **Status:** Implemented
#
# These specs use interpreter execution as the behavioral oracle for
# `trim`, `to_lower`, `split`, `replace`, and `rfind` on `text`. They exist to
# pin exact edge-case semantics (empty string, no-match, multi-match, unicode
# content, delimiter-at-ends) that the new MIR erased-receiver fallback path
# for these methods must reproduce bit-for-bit against the interpreter
# oracle. A regression in the fallback lowering (e.g. wrong byte offsets on
# multibyte UTF-8, off-by-one on delimiter-at-ends, or a fallback that only
# handles the ASCII fast path) would silently diverge from these pinned
# values without failing a naive "it compiles" check.

use lib.common.bytes.span.{ByteSpan}

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "text predicate owner precedence":
    it "keeps text starts_with ahead of a same-named custom struct method":
        val opener: text = "@media (min-width: 1px)"
        check(opener.starts_with("@"))

    it "retains custom starts_with dispatch for a ByteSpan receiver":
        val bytes: [u8] = [64u8, 109u8, 101u8, 100u8, 105u8, 97u8]
        val prefix: [u8] = [64u8]
        check(ByteSpan.new(bytes).starts_with(ByteSpan.new(prefix)))

describe "text.trim":
    it "removes leading and trailing whitespace":
        check("  hi  ".trim() == "hi")

    it "returns the original text unchanged when there is no whitespace to trim":
        check("hi".trim() == "hi")

    it "returns an empty string when trimming an empty string":
        check("".trim() == "")

    it "collapses an all-whitespace string to empty":
        check("   ".trim() == "")

describe "text.to_lower":
    it "lowercases an all-uppercase ASCII string":
        check("HELLO WORLD".to_lower() == "hello world")

    it "leaves an already-lowercase string unchanged":
        check("hello world".to_lower() == "hello world")

    it "leaves an empty string unchanged":
        check("".to_lower() == "")

    it "case-folds accented unicode letters":
        check("HÉLLO WÖRLD".to_lower() == "héllo wörld")

    it "leaves already-lowercase unicode content unchanged":
        check("héllo wörld".to_lower() == "héllo wörld")

describe "text.split":
    it "splits on every occurrence of a single-character delimiter":
        val parts = "a,b,c".split(",")
        check(parts.len() == 3)
        check(parts[0] == "a")
        check(parts[1] == "b")
        check(parts[2] == "c")

    it "preserves empty fields for consecutive delimiters":
        val parts = "a,b,,c".split(",")
        check(parts.len() == 4)
        check(parts[2] == "")

    it "produces a leading and trailing empty field when the delimiter sits at both ends":
        val parts = ",a,b,".split(",")
        check(parts.len() == 4)
        check(parts[0] == "")
        check(parts[3] == "")

    it "returns a single-element list for a string with no delimiter occurrence":
        val parts = "abc".split(",")
        check(parts.len() == 1)
        check(parts[0] == "abc")

    it "returns a single empty-string element when splitting an empty string":
        val parts = "".split(",")
        check(parts.len() == 1)
        check(parts[0] == "")

    it "splits on a multibyte unicode delimiter without corrupting surrounding bytes":
        val parts = "héllo".split("é")
        check(parts.len() == 2)
        check(parts[0] == "h")
        check(parts[1] == "llo")

describe "text.replace":
    it "replaces every occurrence of a multi-match needle":
        check("aXbXc".replace("X", "-") == "a-b-c")

    it "returns the original text unchanged when the needle never matches":
        check("abc".replace("z", "-") == "abc")

    it "handles a replacement that expands the string":
        check("aaa".replace("a", "bb") == "bbbbbb")

    it "leaves an empty string unchanged":
        check("".replace("a", "b") == "")

    it "replaces a multibyte unicode needle correctly":
        val out = "héllo wörld".replace("ö", "o")
        check(out == "héllo world")

describe "text.rfind":
    it "returns the index of the last occurrence for a multi-match needle":
        check("abcabc".rfind("bc") == 4)

    it "returns -1 when the needle never occurs":
        check("abcabc".rfind("zz") == -1)

    it "returns 0 when the only match is at the very start":
        check("abc".rfind("a") == 0)

    it "returns -1 when searching an empty haystack for a non-empty needle":
        check("".rfind("x") == -1)

    it "locates a multibyte unicode needle by byte offset in a repeated pattern":
        check("héllo héllo".rfind("héllo") == 7)
