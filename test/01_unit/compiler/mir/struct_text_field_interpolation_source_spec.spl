use app.io.mod.{file_read}

describe "native struct text field interpolation":
    it "preserves declared text type on field projections":
        val lowering = file_read("src/compiler/50.mir/_MirLoweringExpr/expr_dispatch.spl")
        expect(lowering).to_contain("field_reprs[field_idx] == \"str\"")
        expect(lowering).to_contain("field_type = MirType(kind: MirTypeKind.Opaque(\"str\"))")
        expect(lowering).to_contain("self.local_hir_types[field_result.id] = declared_field_type")

    it "keeps the exact W83 oracle in every cross-target gate":
        val fixture = file_read("test/fixtures/native_crossmodule_result_u8/main.spl")
        expect(fixture).to_contain("fn cross_target_struct_text_field_interp_ok() -> bool:")
        expect(fixture).to_contain("before == \"mode0=human\" and after == \"mode1=llm quiet=true\"")
        expect(fixture).to_contain("if not cross_target_struct_text_field_interp_ok():")
