# @cover src/compiler/50.mir/mir_instructions.spl 10%
# @cover src/compiler/50.mir/mir_lowering_part2_part2.spl 10%
# @tag: unit, compiler, mir, gpu, opencl

use std.spipe.*
use compiler.common.attributes.{FunctionAttr, parse_function_attrs}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.frontend.parser_types.{Attribute}
use compiler.frontend.parser_types_expr.{Expr, ExprKind}
use compiler.hir.hir_types.{SymbolId, SymbolTable}
use compiler.mir.mir_data.{MirFunction, MirModule, MirSignature, MirBuilder, BlockId}
use compiler.mir.mir_instructions.{MirBlock, MirTerminator}
use compiler.mir.mir_types.{MirType}
use compiler.mir.mir_lowering.{MirLowering}

fn empty_span() -> Span:
    Span.empty()

fn empty_block(label: text) -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some(label),
        instructions: [],
        terminator: MirTerminator.Unreachable
    )

fn make_mir_function(name: text) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: 1),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [],
        blocks: [empty_block("entry")],
        entry_block: BlockId.entry(),
        span: empty_span(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_gpu_attr(target: text, backends: text) -> FunctionAttr:
    var attr = FunctionAttr.default()
    attr.is_gpu_kernel = true
    attr.gpu_target = target
    attr.gpu_backends = backends
    attr

fn make_gpu_source_attr(target: text) -> Attribute:
    val span = empty_span()
    Attribute(
        name: "gpu",
        args: [Expr(kind: ExprKind.StringLit(target, nil), span: span)],
        span: span
    )

describe "MIR GPU target metadata":
    it "lowers frontend-shaped gpu attribute metadata into MIR":
        val parsed_attr = parse_function_attrs([make_gpu_source_attr("opencl")])
        val lowerer = MirLowering.new(SymbolTable.new())
        val fn_ = make_mir_function("gpu_kernel")

        val result = lowerer.apply_function_attr_to_mir(fn_, parsed_attr)

        expect(result.is_kernel).to_equal(true)
        expect(result.gpu_target).to_equal("opencl")
        expect(result.gpu_backend_order).to_equal("opencl")

    it "propagates normalized OpenCL target metadata from function attrs":
        val lowerer = MirLowering.new(SymbolTable.new())
        val fn_ = make_mir_function("gpu_kernel")
        val attr = make_gpu_attr("opencl-spirv", "")

        val result = lowerer.apply_function_attr_to_mir(fn_, attr)

        expect(result.is_kernel).to_equal(true)
        expect(result.gpu_target).to_equal("opencl")
        expect(result.gpu_backend_order).to_equal("opencl")

    it "propagates normalized ROCm target metadata as HIP from function attrs":
        val lowerer = MirLowering.new(SymbolTable.new())
        val fn_ = make_mir_function("gpu_kernel")
        val attr = make_gpu_attr("rocm", "")

        val result = lowerer.apply_function_attr_to_mir(fn_, attr)

        expect(result.is_kernel).to_equal(true)
        expect(result.gpu_target).to_equal("hip")
        expect(result.gpu_backend_order).to_equal("hip")

    it "preserves explicit backend order through MirFunction copies":
        val fn_ = make_mir_function("gpu_kernel")
        val attr = make_gpu_attr("auto", "hip,opencl,cuda")
        val lowerer = MirLowering.new(SymbolTable.new())
        val tagged = lowerer.apply_function_attr_to_mir(fn_, attr)

        val copied = MirFunction.with_blocks(tagged, [empty_block("replacement")])

        expect(copied.is_kernel).to_equal(true)
        expect(copied.gpu_target).to_equal("auto")
        expect(copied.gpu_backend_order).to_equal("hip,opencl,cuda")
