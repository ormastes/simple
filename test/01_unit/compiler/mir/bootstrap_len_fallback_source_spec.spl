extern fn rt_file_read_text(path: text) -> text

fn method_call_lowering_source() -> text:
    rt_file_read_text("src/compiler/50.mir/_MirLoweringExpr/method_calls_literals.spl") ?? ""

describe "bootstrap MIR method-call lowering source":
    it "defines untyped bootstrap len calls through the array runtime helper":
        val source = method_call_lowering_source()

        expect(source).to_contain("if len_symbol == \"\" and (rt_env_get(\"SIMPLE_BOOTSTRAP\") ?? \"\") == \"1\":")
        expect(source).to_contain("len_symbol = \"rt_array_len\"")
