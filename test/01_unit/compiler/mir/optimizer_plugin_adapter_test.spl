# Adapter test harness for optimizer_plugin_run_on_function / run_on_module
# Uses bin/simple run (not test runner) to exercise MIR type construction
# run_typed_pass execution requires compiled mode; this tests routing logic

use compiler.hir.hir_types.{SymbolId}
use compiler.common.diagnostics.span.{Span}
use compiler.mir.{
    MirFunction, MirBlock, MirTerminator,
    BlockId, MirType, MirTypeKind,
    mir_signature_simple
}
use compiler.mir_opt.mir_opt.mod.{PassKind, PassScope, OptLevel}
use compiler.mir_opt.optimizer_plugin.{
    ApplyMode, PluginScope,
    optimizer_plugin_source, optimizer_plugin_mir, optimizer_plugin_both,
    optimizer_plugin_run_on_function,
    plugin_scope_name, plugin_scope_includes_mir,
    optimizer_plugin_from_mir_descriptor, optimizer_plugin_from_dynamic_descriptor
}
use compiler.mir_opt.optimizer_manifest.{DynamicPassDescriptor}
use compiler.mir_opt.mir_opt.mod.{MirPassDescriptor}

fn make_test_function() -> MirFunction:
    val void_type = MirType(kind: MirTypeKind.Unit)
    val sig = mir_signature_simple(void_type)
    val entry_block = MirBlock(
        id: BlockId(id: 0),
        label: nil,
        instructions: [],
        terminator: MirTerminator.Ret(value: nil)
    )
    val span = Span(start: 0, end: 0, line: 1, col: 1, file: "test.spl")
    MirFunction(
        symbol: SymbolId(id: 0),
        name: "test_fn",
        signature: sig,
        locals: [],
        blocks: [entry_block],
        entry_block: BlockId(id: 0),
        span: span
    )

fn main():
    var passed = 0
    var failed = 0

    val func = make_test_function()

    # 1: nil-guard — source-only plugin returns function unchanged
    val src_plugin = optimizer_plugin_source(
        "string_concat", [], ApplyMode.Static, OptLevel.Speed, ["concat"]
    )
    val result = optimizer_plugin_run_on_function(src_plugin, func)
    if result.name == "test_fn":
        passed = passed + 1
        print("PASS: nil-guard returns function unchanged")
    else:
        failed = failed + 1
        print("FAIL: nil-guard altered function name")

    # 2: nil-guard preserves block structure
    if result.blocks.len() == 1:
        passed = passed + 1
        print("PASS: nil-guard preserves block count")
    else:
        failed = failed + 1
        print("FAIL: nil-guard changed block count")

    # 3: MIR plugin descriptor has correct pass_kind set
    val mir_plugin = optimizer_plugin_mir(
        "dce", ["dead_code_elimination"],
        PassKind.DeadCodeElimination, PassScope.Function,
        ApplyMode.Static, OptLevel.Speed, "cheap"
    )
    if mir_plugin.mir_pass_kind.?:
        passed = passed + 1
        print("PASS: MIR plugin has pass_kind set")
    else:
        failed = failed + 1
        print("FAIL: MIR plugin missing pass_kind")

    # 4: source plugin has nil pass_kind (confirms nil-guard path)
    if not src_plugin.mir_pass_kind.?:
        passed = passed + 1
        print("PASS: source plugin has nil pass_kind")
    else:
        failed = failed + 1
        print("FAIL: source plugin should have nil pass_kind")

    # 5: both-scope plugin can route through MIR
    val both_plugin = optimizer_plugin_both(
        "strength_reduction", ["sr"],
        PassKind.StrengthReduction, PassScope.Function,
        ApplyMode.Both, OptLevel.Speed, "medium",
        ["modulo power"]
    )
    if both_plugin.mir_pass_kind.? and plugin_scope_includes_mir(both_plugin.plugin_scope):
        passed = passed + 1
        print("PASS: both-scope plugin routes MIR")
    else:
        failed = failed + 1
        print("FAIL: both-scope plugin MIR routing broken")

    # 6: from_mir_descriptor factory
    val mir_desc = MirPassDescriptor(
        stable_name: "const_fold",
        aliases: ["cf"],
        kind: PassKind.ConstantFolding,
        scope: PassScope.Function,
        cost_class: "cheap"
    )
    val from_mir = optimizer_plugin_from_mir_descriptor(mir_desc, ApplyMode.Static, OptLevel.Speed)
    if from_mir.name == "const_fold" and from_mir.cost_class == "cheap":
        passed = passed + 1
        print("PASS: from_mir_descriptor preserves name + cost")
    else:
        failed = failed + 1
        print("FAIL: from_mir_descriptor fields wrong")

    # 7: from_mir_descriptor sets MIR scope
    if plugin_scope_name(from_mir.plugin_scope) == "mir":
        passed = passed + 1
        print("PASS: from_mir_descriptor sets MIR scope")
    else:
        failed = failed + 1
        print("FAIL: from_mir_descriptor wrong scope")

    # 8: from_dynamic_descriptor factory
    val dyn_desc = DynamicPassDescriptor(
        name: "custom_pass",
        aliases: ["cp"],
        scope: PassScope.Function,
        cost_class: "medium"
    )
    val from_dyn = optimizer_plugin_from_dynamic_descriptor(dyn_desc, OptLevel.Speed)
    if from_dyn.name == "custom_pass" and from_dyn.cost_class == "medium":
        passed = passed + 1
        print("PASS: from_dynamic_descriptor preserves name + cost")
    else:
        failed = failed + 1
        print("FAIL: from_dynamic_descriptor fields wrong")

    # 9: from_dynamic_descriptor forces Dynamic apply mode
    if not from_dyn.mir_pass_kind.?:
        passed = passed + 1
        print("PASS: from_dynamic_descriptor has nil pass_kind (dynamic)")
    else:
        failed = failed + 1
        print("FAIL: from_dynamic_descriptor should have nil pass_kind")

    print("")
    print("Adapter tests: {passed} passed, {failed} failed")
    if failed > 0:
        print("SOME TESTS FAILED")
    else:
        print("ALL TESTS PASSED")
