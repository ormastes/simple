use std.spec.{check_msg}
use compiler.common.mir_target_context.{MirTargetContext, mir_target_context_from}

struct MirTargetContextCase:
    name: text
    target: text
    host_arch: text
    host_os: text
    backend: text
    version: i64
    expected: MirTargetContext

fn target_context(arch: text, os: text, abi: text, backend: text, version: i64) -> MirTargetContext:
    MirTargetContext(arch: arch, os: os, abi: abi, backend: backend, version: version)

fn check_target_context_case(row: MirTargetContextCase):
    val actual = mir_target_context_from(row.target, row.host_arch, row.host_os, row.backend, row.version)
    check_msg(actual.arch == row.expected.arch, "{row.name}: arch")
    check_msg(actual.os == row.expected.os, "{row.name}: os")
    check_msg(actual.abi == row.expected.abi, "{row.name}: abi")
    check_msg(actual.backend == row.expected.backend, "{row.name}: backend")
    check_msg(actual.version == row.expected.version, "{row.name}: version")

describe "MIR target context":
    it "normalizes host, target, ABI, and backend variants":
        val rows = [
            MirTargetContextCase(name: "empty host", target: "", host_arch: "amd64", host_os: "linux", backend: "auto", version: 19, expected: target_context("x86_64", "linux", "gnu", "llvm", 19)),
            MirTargetContextCase(name: "host macOS", target: "host", host_arch: "x64", host_os: "darwin", backend: "llvm-lib", version: 18, expected: target_context("x86_64", "macos", "macho", "llvm", 18)),
            MirTargetContextCase(name: "native Windows", target: "native", host_arch: "arm64", host_os: "windows", backend: "llvmlib", version: 17, expected: target_context("aarch64", "windows", "msvc", "llvm", 17)),
            MirTargetContextCase(name: "Linux GNU", target: "x86_64-unknown-linux-gnu", host_arch: "aarch64", host_os: "macos", backend: "llvm", version: 20, expected: target_context("x86_64", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "i386", target: "i386-unknown-linux-gnu", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "i486", target: "i486-unknown-linux-gnu", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "i586", target: "i586-unknown-linux-gnu", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "i686", target: "i686-unknown-linux-gnu", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "ARM GNU hard float", target: "armv7-unknown-linux-gnueabihf", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("arm", "linux", "eabihf", "llvm", 20)),
            MirTargetContextCase(name: "Thumb bare metal", target: "thumbv7em-none-eabihf", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("arm", "baremetal", "eabihf", "llvm", 20)),
            MirTargetContextCase(name: "RV32 bare metal", target: "rv32imac-unknown-none-elf", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("riscv32", "baremetal", "none", "llvm", 20)),
            MirTargetContextCase(name: "RV32 hosted Linux", target: "riscv32-unknown-linux-gnu", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("riscv32", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "RISC-V 64 Linux", target: "riscv64gc-unknown-linux-gnu", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("riscv64", "linux", "gnu", "llvm", 20)),
            MirTargetContextCase(name: "macOS", target: "aarch64-apple-darwin", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("aarch64", "macos", "macho", "llvm", 20)),
            MirTargetContextCase(name: "Windows MSVC", target: "x86_64-pc-windows-msvc", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86_64", "windows", "msvc", "llvm", 20)),
            MirTargetContextCase(name: "Windows ARM64 object target", target: "aarch64-pc-windows-msvc", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("aarch64", "windows", "msvc", "llvm", 20)),
            MirTargetContextCase(name: "Windows GNU Cranelift", target: "x86_64-pc-windows-gnu", host_arch: "x86_64", host_os: "linux", backend: "cranelift", version: -1, expected: target_context("x86_64", "windows", "gnu", "cranelift", -1)),
            MirTargetContextCase(name: "Windows MinGW", target: "x86_64-w64-mingw32", host_arch: "aarch64", host_os: "linux", backend: "auto", version: 18, expected: target_context("x86_64", "windows", "gnu", "llvm", 18)),
            MirTargetContextCase(name: "FreeBSD", target: "x86_64-unknown-freebsd", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86_64", "freebsd", "sysv", "llvm", 20)),
            MirTargetContextCase(name: "FreeBSD ARM64 object target", target: "aarch64-unknown-freebsd", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("aarch64", "freebsd", "sysv", "llvm", 20)),
            MirTargetContextCase(name: "Linux musl", target: "x86_64-unknown-linux-musl", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86_64", "linux", "musl", "llvm", 20)),
            MirTargetContextCase(name: "SimpleOS", target: "x86_64-unknown-simpleos", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 20, expected: target_context("x86_64", "simpleos", "none", "llvm", 20)),
            MirTargetContextCase(name: "SimpleOS shorthand", target: "simpleos", host_arch: "aarch64", host_os: "linux", backend: "native", version: 0, expected: target_context("x86_64", "simpleos", "none", "native", 0)),
            MirTargetContextCase(name: "RISC-V ABI", target: "riscv64-unknown-linux-lp64d", host_arch: "x86_64", host_os: "linux", backend: "llvm", version: 18, expected: target_context("riscv64", "linux", "lp64d", "llvm", 18))
        ]
        for row in rows:
            check_target_context_case(row)
