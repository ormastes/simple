"""
# MIR Module Lowering Isolation Specification

**Feature IDs:** #TBD
**Category:** Compiler / MIR
**Status:** Regression

## Overview

Regression for the entry-MIR duplication bug hit during native-build
`--entry-closure` (stage2 redeploy of `app.cli.bootstrap_main` through a pure
re-export shim, `compiler.driver`'s `__init__.spl`).

`driver_pipeline.spl`'s `lower_to_mir()` reuses ONE `MirLowering` instance
(`direct_lowering`) across every source module reachable from `--entry`,
reassigning only `.symbols` before each `lower_module()` call (mirrored here).
`lower_module()` used to mutate the shared `builder.module.functions/statics/
constants/types` dicts in place without clearing them first, so a module with
no functions/types of its own -- a pure `export use` re-export shim -- would
silently inherit whatever a PREVIOUSLY-lowered module in the same loop had
accumulated. Observed as `object.compiler.driver.mod.o` containing
`app.cli.bootstrap_main`'s entire function set, i.e. duplicate symbol
definitions at link time.
"""

use compiler.mir.mir_lowering.{MirLowering}
use compiler.hir.hir_definitions.{HirFunction, HirParam, HirBlock, HirExpr, HirExprKind}
use compiler.hir.hir_types.{HirModule, HirType, HirTypeKind, SymbolId, SymbolTable}
use compiler.core.lexer_types.{Span}
use compiler.common.dependency.visibility.{Visibility}

fn empty_span() -> Span:
    Span(start: 0, end_pos: 0, line: 1, col: 1)

fn unit_type() -> HirType:
    HirType(kind: HirTypeKind.Unit, span: empty_span())

fn dummy_expr() -> HirExpr:
    HirExpr(
        kind: HirExprKind.UnitLit,
        has_type_: false,
        type_: unit_type(),
        span: empty_span()
    )

fn dummy_block() -> HirBlock:
    HirBlock(
        stmts: [],
        has: true,
        value: dummy_expr(),
        span: empty_span()
    )

fn make_fn(id: i64, name: text) -> HirFunction:
    HirFunction(
        symbol: SymbolId(id: id),
        name: name,
        type_params: [],
        params: [],
        return_type: unit_type(),
        body: dummy_block(),
        effects: [],
        visibility: Visibility.Public,
        is_async: false,
        is_static: false,
        is_public: true,
        is_method: false,
        is_mutable: false,
        is_const: false,
        is_extern: false,
        func_attr: nil,
        has_export_attr: false,
        export_attr: nil,
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_suspension: false,
        has_vhdl_metadata: false,
        vhdl_metadata: nil,
        has_doc_comment: false,
        doc_comment: "",
        span: empty_span()
    )

fn make_module(name: text, path: text, functions: Dict<SymbolId, HirFunction>) -> HirModule:
    HirModule(
        name: name,
        path: path,
        imports: [],
        exports: [],
        domain_blocks: [],
        symbols: SymbolTable.new(),
        functions: functions,
        classes: {},
        structs: {},
        enums: {},
        bitfields: {},
        traits: {},
        impls: [],
        constants: {},
        static_asserts: [],
        aop_advices: [],
        di_bindings: [],
        arch_rules: [],
        mock_decls: [],
        types: []
    )

fn make_entry_module() -> HirModule:
    """A module with its own function -- stands in for app.cli.bootstrap_main."""
    var functions: Dict<SymbolId, HirFunction> = {}
    val entry_fn = make_fn(30, "bootstrap_output_from_args")
    functions[entry_fn.symbol] = entry_fn
    make_module("app.cli.bootstrap_main", "src/app/cli/bootstrap_main.spl", functions)

fn make_reexport_shim_module() -> HirModule:
    """A pure `export use` shim -- stands in for compiler.driver's __init__.spl:
    zero own functions/classes/structs/etc."""
    make_module("compiler.driver", "src/compiler/80.driver/__init__.spl", {})

describe "MIR module lowering isolation across a shared MirLowering instance":
    it "does not leak a previously-lowered module's functions into a module with none of its own":
        # Mirrors driver_pipeline.spl's --entry-closure `direct_lowering` loop:
        # ONE MirLowering instance is shared across every source module, with
        # only `.symbols` reassigned before each lower_module() call.
        val entry_module = make_entry_module()
        val shim_module = make_reexport_shim_module()

        var lowering = MirLowering.new(entry_module.symbols)
        val entry_mir = lowering.lower_module(entry_module)
        expect(entry_mir.functions.keys().len()).to_equal(1)
        expect(entry_mir.functions.has(SymbolId(id: 30))).to_equal(true)

        lowering.symbols = shim_module.symbols
        val shim_mir = lowering.lower_module(shim_module)

        # Root-cause regression check: the shim must get an EMPTY function
        # set, not the entry module's leftover functions.
        expect(shim_mir.functions.keys().len()).to_equal(0)
        expect(shim_mir.functions.has(SymbolId(id: 30))).to_equal(false)
        expect(shim_mir.name).to_equal("compiler.driver")

    it "keeps a second real module's own functions intact (not just the shim case)":
        # Same shared-instance loop, but the SECOND module also has its own
        # function -- must see only its own function, not the first's too.
        var first_fns: Dict<SymbolId, HirFunction> = {}
        val first_fn = make_fn(1, "first_only")
        first_fns[first_fn.symbol] = first_fn
        val first_module = make_module("mod.first", "mod/first.spl", first_fns)

        var second_fns: Dict<SymbolId, HirFunction> = {}
        val second_fn = make_fn(2, "second_only")
        second_fns[second_fn.symbol] = second_fn
        val second_module = make_module("mod.second", "mod/second.spl", second_fns)

        var lowering = MirLowering.new(first_module.symbols)
        val first_mir = lowering.lower_module(first_module)
        expect(first_mir.functions.keys().len()).to_equal(1)

        lowering.symbols = second_module.symbols
        val second_mir = lowering.lower_module(second_module)

        expect(second_mir.functions.keys().len()).to_equal(1)
        expect(second_mir.functions.has(SymbolId(id: 2))).to_equal(true)
        expect(second_mir.functions.has(SymbolId(id: 1))).to_equal(false)

    it "clears module-local global SymbolIds before lowering the next module":
        val first_module = make_entry_module()
        val second_module = make_reexport_shim_module()
        var lowering = MirLowering.new(first_module.symbols)

        lowering.global_symbol_ids[30] = true
        expect(lowering.global_symbol_ids.has(30)).to_equal(true)

        lowering.symbols = second_module.symbols
        lowering.lower_module(second_module)

        expect(lowering.global_symbol_ids.has(30)).to_equal(false)
