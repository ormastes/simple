use std.spec
use compiler.common.config.{Logger}
use compiler.frontend.frontend.{parse_full_frontend}
use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.mir.mir.*

fn lower_result_unwrap_function(source: text, target: text) -> (text, text):
    val parsed = parse_full_frontend(source, "result_unwrap.spl", "result_unwrap", Logger(level: 0))
    var hir_lowering = HirLowering.with_filename("result_unwrap.spl")
    val hir = hir_lowering.lower_module(parsed)
    var mir_lowering = MirLowering.new(hir.symbols)
    val mir = mir_lowering.lower_module(hir)
    var errors = ""
    for err in mir_lowering.errors:
        errors = errors + err.message + "\n"
    for function in mir.functions.values():
        if function.name == target or function.name.ends_with(".{target}"):
            return (serialize_mir_function(function), errors)
    ("", errors)

describe "Result unwrap struct provenance", tag: ["only-compiled"]:
    it "keeps an unannotated struct payload on its method owner":
        val source = "struct A:\n    value: i64\n\nimpl A:\n    fn emit_object(self) -> i64: self.value\n\nstruct B:\n    value: i64\n\nimpl B:\n    fn emit_object(self) -> i64: self.value + 100\n\nfn make() -> Result<A, text>:\n    Ok(A(value: 7))\n\nfn choose() -> i64:\n    val pending = make()\n    val module = pending.unwrap()\n    module.emit_object()\n"
        val (mir, errors) = lower_result_unwrap_function(source, "choose")

        expect(errors).to_equal("")
        expect(mir).to_contain("result_unwrap.A.emit_object")
        expect(mir.contains("result_unwrap.B.emit_object")).to_equal(false)

    it "still rejects a receiver with no matching method owner":
        val source = "struct A:\n    value: i64\n\nimpl A:\n    fn emit_object(self) -> i64: 1\n\nstruct B:\n    value: i64\n\nimpl B:\n    fn emit_object(self) -> i64: 2\n\nfn bad(value) -> i64:\n    value.emit_object()\n"
        val (_, errors) = lower_result_unwrap_function(source, "bad")

        expect(errors).to_contain("unresolved method call: emit_object")

    it "clears a stale payload owner after reassignment":
        val source = "struct A:\n    value: i64\n\nimpl A:\n    fn emit_object(self) -> i64: self.value\n\nfn make() -> Result<A, text>:\n    Ok(A(value: 7))\n\nfn bad_reassign() -> i64:\n    var pending = make()\n    pending = 7\n    val module = pending.unwrap()\n    module.emit_object()\n"
        val (mir, errors) = lower_result_unwrap_function(source, "bad_reassign")

        expect(errors).to_contain("unresolved method call: emit_object")
        expect(mir.contains("result_unwrap.A.emit_object")).to_equal(false)
