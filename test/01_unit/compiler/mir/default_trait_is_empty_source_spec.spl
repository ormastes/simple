extern fn rt_file_read_text(path: text) -> text

describe "pure-Simple default-trait is_empty compatibility source":
    it "keeps affected built-in collection checks on direct length lowering":
        val lean_backend = rt_file_read_text("src/compiler/70.backend/backend/lean_backend.spl") ?? ""
        val lean_translate = rt_file_read_text("src/compiler/70.backend/backend/lean_mir_translate.spl") ?? ""
        val lint_rules = rt_file_read_text("src/compiler/90.tools/fix/rules/impl_/lint_code.spl") ?? ""

        expect(lean_backend.contains(".is_empty()")).to_equal(false)
        expect(lean_translate.contains(".is_empty()")).to_equal(false)
        expect(lint_rules.contains(".is_empty()")).to_equal(false)
        expect(lean_backend).to_contain("if param_types.len() == 0:")
        expect(lean_translate).to_contain("if keys.len() == 0:")
        expect(lint_rules).to_contain("if parts.len() == 0:")
