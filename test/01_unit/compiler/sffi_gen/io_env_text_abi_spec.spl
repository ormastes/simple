use std.spec

use compiler.tools.sffi_gen.module_gen (generate_module_source)
use compiler.tools.sffi_gen.specs.io_full (io_module)

describe "SFFI environment text ABI":
    it "generates length-delimited get and set signatures":
        val source = generate_module_source(io_module())
        val mirror = file_read("src/app/ffi_gen.specs/io_full.spl")

        expect(source).to_contain("fn rt_env_get(key: *const u8, key_len: u64)")
        expect(source).to_contain("fn rt_env_set(key: *const u8, key_len: u64, value: *const u8, value_len: u64)")
        expect(source).to_contain("key.is_null() || key_len == 0")
        expect(source).to_contain("value_len == 0")
        expect(source).to_contain("value.is_null()")
        expect(source).to_contain("from_utf8(key_bytes)")
        expect(source).to_contain("from_utf8(value_bytes)")
        expect(source).to_contain("key_str.as_bytes().contains(&0) || key_str.contains('=')")
        expect(source).to_contain("value_str.as_bytes().contains(&0)")
        expect(source).to_contain("key_len > 4095")
        expect(source).to_contain("value_len > 65535")
        expect(mirror).to_contain("FFIParamSpec__raw_ptr(\"key\", \"*const u8\"), FFIParamSpec__simple(\"key_len\", \"u64\")")
        expect(mirror).to_contain("FFIParamSpec__raw_ptr(\"value\", \"*const u8\"), FFIParamSpec__simple(\"value_len\", \"u64\")")
        expect(mirror).to_contain("value_len == 0")
        expect(mirror).to_contain("value.is_null()")
        expect(mirror).to_contain("key_str.contains('=')")
