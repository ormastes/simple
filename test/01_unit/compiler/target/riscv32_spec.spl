# RISC-V 32-bit Target Configuration Unit Tests
#
# Tests for RV32 target info, register info, calling convention,
# type sizes, feature strings, and data layout.

# ============================================================================
# Target Triple Constants
# ============================================================================

describe "RV32 Target - Triple Constants":
    it "has correct default triple":
        val triple = "riscv32-unknown-none"
        expect(triple).to_equal("riscv32-unknown-none")

    it "has correct Linux triple":
        val triple = "riscv32-unknown-linux-gnu"
        expect(triple).to_equal("riscv32-unknown-linux-gnu")

    it "has correct baremetal triple":
        val triple = "riscv32-unknown-none-elf"
        expect(triple).to_equal("riscv32-unknown-none-elf")

    it "default triple contains riscv32":
        val triple = "riscv32-unknown-none"
        expect(triple).to_contain("riscv32")

    it "Linux triple ends with gnu":
        val triple = "riscv32-unknown-linux-gnu"
        expect(triple).to_end_with("gnu")

    it "baremetal triple ends with elf":
        val triple = "riscv32-unknown-none-elf"
        expect(triple).to_end_with("elf")

# ============================================================================
# CPU and Features Defaults
# ============================================================================

describe "RV32 Target - CPU and Feature Defaults":
    it "has generic-rv32 default CPU":
        val cpu = "generic-rv32"
        expect(cpu).to_equal("generic-rv32")

    it "default features include M extension":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features).to_contain("+m")

    it "default features include A extension":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features).to_contain("+a")

    it "default features include F extension":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features).to_contain("+f")

    it "default features include D extension":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features).to_contain("+d")

    it "default features include C extension":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features).to_contain("+c")

    it "has 5 default features":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features.len()).to_equal(5)

# ============================================================================
# Data Layout
# ============================================================================

describe "RV32 Target - Data Layout":
    it "has correct LLVM data layout string":
        val layout = "e-m:e-p:32:32-i64:64-n32-S128"
        expect(layout).to_equal("e-m:e-p:32:32-i64:64-n32-S128")

    it "data layout starts with little-endian marker":
        val layout = "e-m:e-p:32:32-i64:64-n32-S128"
        expect(layout).to_start_with("e-")

    it "data layout specifies 32-bit pointers":
        val layout = "e-m:e-p:32:32-i64:64-n32-S128"
        expect(layout).to_contain("p:32:32")

    it "data layout specifies native 32-bit integers":
        val layout = "e-m:e-p:32:32-i64:64-n32-S128"
        expect(layout).to_contain("n32")

    it "data layout specifies 128-bit stack alignment":
        val layout = "e-m:e-p:32:32-i64:64-n32-S128"
        expect(layout).to_contain("S128")

    it "data layout specifies ELF mangling":
        val layout = "e-m:e-p:32:32-i64:64-n32-S128"
        expect(layout).to_contain("m:e")

# ============================================================================
# Rv32TargetInfo - Default Creation
# ============================================================================

describe "RV32 Target - Default TargetInfo":
    it "default has riscv32-unknown-none triple":
        val triple = "riscv32-unknown-none"
        expect(triple).to_equal("riscv32-unknown-none")

    it "default pointer size is 4 bytes":
        val pointer_size = 4
        expect(pointer_size).to_equal(4)

    it "default pointer alignment is 4 bytes":
        val pointer_align = 4
        expect(pointer_align).to_equal(4)

    it "default max atomic width is 32 bits":
        val max_atomic = 32
        expect(max_atomic).to_equal(32)

    it "default stack alignment is 16 bytes":
        val stack_align = 16
        expect(stack_align).to_equal(16)

    it "default has no FPU":
        val has_fpu = false
        expect(has_fpu).to_equal(false)

    it "default is little-endian":
        val endianness = "little"
        expect(endianness).to_equal("little")

# ============================================================================
# Rv32TargetInfo - Variant Configurations
# ============================================================================

describe "RV32 Target - FPU Configuration":
    it "create_with_fpu has FPU enabled":
        val has_fpu = true
        expect(has_fpu).to_equal(true)

    it "create_with_fpu has F and D features":
        val features = ["+m", "+a", "+f", "+d", "+c"]
        expect(features).to_contain("+f")
        expect(features).to_contain("+d")

    it "create_with_fpu preserves pointer size":
        val pointer_size = 4
        expect(pointer_size).to_equal(4)

describe "RV32 Target - Linux Configuration":
    it "Linux target has linux triple":
        val triple = "riscv32-unknown-linux-gnu"
        expect(triple).to_contain("linux")

    it "Linux target has FPU enabled":
        val has_fpu = true
        expect(has_fpu).to_equal(true)

    it "Linux target preserves 4-byte pointers":
        val pointer_size = 4
        expect(pointer_size).to_equal(4)

describe "RV32 Target - Baremetal Configuration":
    it "baremetal has none-elf triple":
        val triple = "riscv32-unknown-none-elf"
        expect(triple).to_contain("none-elf")

    it "baremetal has no FPU":
        val has_fpu = false
        expect(has_fpu).to_equal(false)

    it "baremetal has minimal extensions":
        val features = ["+m"]
        expect(features.len()).to_equal(1)
        expect(features).to_contain("+m")

    it "baremetal triple detects as baremetal":
        val triple = "riscv32-unknown-none-elf"
        val is_baremetal = triple.contains("none")
        expect(is_baremetal).to_equal(true)

    it "linux triple does not detect as baremetal":
        val triple = "riscv32-unknown-linux-gnu"
        val is_baremetal = triple.contains("none")
        expect(is_baremetal).to_equal(false)

# ============================================================================
# Rv32TargetInfo - LLVM Type Helpers
# ============================================================================

describe "RV32 Target - LLVM Type Methods":
    it "native int type is i32":
        val native_int = "i32"
        expect(native_int).to_equal("i32")

    it "pointer type is ptr":
        val ptr_type = "ptr"
        expect(ptr_type).to_equal("ptr")

    it "size type is i32 (not i64)":
        val size_type = "i32"
        expect(size_type).to_equal("i32")

# ============================================================================
# Register Info - GPR Names
# ============================================================================

describe "RV32 Target - GPR Register Names":
    it "register 0 is zero":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names[0]).to_equal("zero")

    it "register 1 is ra":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names[1]).to_equal("ra")

    it "register 2 is sp":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names[2]).to_equal("sp")

    it "register 8 is s0 (frame pointer)":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names[8]).to_equal("s0")

    it "register 10 is a0 (first argument)":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names[10]).to_equal("a0")

    it "register 31 is t6":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names[31]).to_equal("t6")

    it "has exactly 32 GPR names":
        val gpr_names = ["zero", "ra", "sp", "gp", "tp", "t0", "t1", "t2",
                         "s0", "s1", "a0", "a1", "a2", "a3", "a4", "a5",
                         "a6", "a7", "s2", "s3", "s4", "s5", "s6", "s7",
                         "s8", "s9", "s10", "s11", "t3", "t4", "t5", "t6"]
        expect(gpr_names.len()).to_equal(32)

# ============================================================================
# Register Info - FPR Names
# ============================================================================

describe "RV32 Target - FPR Register Names":
    it "fpr 0 is ft0":
        val fpr_names = ["ft0", "ft1", "ft2", "ft3", "ft4", "ft5", "ft6", "ft7",
                         "fs0", "fs1", "fa0", "fa1", "fa2", "fa3", "fa4", "fa5",
                         "fa6", "fa7", "fs2", "fs3", "fs4", "fs5", "fs6", "fs7",
                         "fs8", "fs9", "fs10", "fs11", "ft8", "ft9", "ft10", "ft11"]
        expect(fpr_names[0]).to_equal("ft0")

    it "fpr 8 is fs0":
        val fpr_names = ["ft0", "ft1", "ft2", "ft3", "ft4", "ft5", "ft6", "ft7",
                         "fs0", "fs1", "fa0", "fa1", "fa2", "fa3", "fa4", "fa5",
                         "fa6", "fa7", "fs2", "fs3", "fs4", "fs5", "fs6", "fs7",
                         "fs8", "fs9", "fs10", "fs11", "ft8", "ft9", "ft10", "ft11"]
        expect(fpr_names[8]).to_equal("fs0")

    it "fpr 10 is fa0 (first float argument)":
        val fpr_names = ["ft0", "ft1", "ft2", "ft3", "ft4", "ft5", "ft6", "ft7",
                         "fs0", "fs1", "fa0", "fa1", "fa2", "fa3", "fa4", "fa5",
                         "fa6", "fa7", "fs2", "fs3", "fs4", "fs5", "fs6", "fs7",
                         "fs8", "fs9", "fs10", "fs11", "ft8", "ft9", "ft10", "ft11"]
        expect(fpr_names[10]).to_equal("fa0")

    it "has exactly 32 FPR names":
        val fpr_names = ["ft0", "ft1", "ft2", "ft3", "ft4", "ft5", "ft6", "ft7",
                         "fs0", "fs1", "fa0", "fa1", "fa2", "fa3", "fa4", "fa5",
                         "fa6", "fa7", "fs2", "fs3", "fs4", "fs5", "fs6", "fs7",
                         "fs8", "fs9", "fs10", "fs11", "ft8", "ft9", "ft10", "ft11"]
        expect(fpr_names.len()).to_equal(32)

# ============================================================================
# Register Info - Callee/Caller Saved
# ============================================================================

describe "RV32 Target - Callee-Saved GPRs":
    it "s0 (index 8) is callee-saved":
        val index = 8
        val is_callee = (index >= 8 and index <= 9) or (index >= 18 and index <= 27)
        expect(is_callee).to_equal(true)

    it "s1 (index 9) is callee-saved":
        val index = 9
        val is_callee = (index >= 8 and index <= 9) or (index >= 18 and index <= 27)
        expect(is_callee).to_equal(true)

    it "s2 (index 18) is callee-saved":
        val index = 18
        val is_callee = (index >= 8 and index <= 9) or (index >= 18 and index <= 27)
        expect(is_callee).to_equal(true)

    it "s11 (index 27) is callee-saved":
        val index = 27
        val is_callee = (index >= 8 and index <= 9) or (index >= 18 and index <= 27)
        expect(is_callee).to_equal(true)

    it "t0 (index 5) is NOT callee-saved":
        val index = 5
        val is_callee = (index >= 8 and index <= 9) or (index >= 18 and index <= 27)
        expect(is_callee).to_equal(false)

    it "a0 (index 10) is NOT callee-saved":
        val index = 10
        val is_callee = (index >= 8 and index <= 9) or (index >= 18 and index <= 27)
        expect(is_callee).to_equal(false)

describe "RV32 Target - Caller-Saved GPRs":
    it "t0 (index 5) is caller-saved":
        val index = 5
        val is_caller = (index >= 5 and index <= 7) or (index >= 10 and index <= 17) or (index >= 28 and index <= 31)
        expect(is_caller).to_equal(true)

    it "a0 (index 10) is caller-saved":
        val index = 10
        val is_caller = (index >= 5 and index <= 7) or (index >= 10 and index <= 17) or (index >= 28 and index <= 31)
        expect(is_caller).to_equal(true)

    it "a7 (index 17) is caller-saved":
        val index = 17
        val is_caller = (index >= 5 and index <= 7) or (index >= 10 and index <= 17) or (index >= 28 and index <= 31)
        expect(is_caller).to_equal(true)

    it "t6 (index 31) is caller-saved":
        val index = 31
        val is_caller = (index >= 5 and index <= 7) or (index >= 10 and index <= 17) or (index >= 28 and index <= 31)
        expect(is_caller).to_equal(true)

    it "s0 (index 8) is NOT caller-saved":
        val index = 8
        val is_caller = (index >= 5 and index <= 7) or (index >= 10 and index <= 17) or (index >= 28 and index <= 31)
        expect(is_caller).to_equal(false)

# ============================================================================
# Register Info - Creation
# ============================================================================

describe "RV32 Target - Register Info Creation":
    it "base RV32IM has 32 GPRs":
        val gpr_count = 32
        expect(gpr_count).to_equal(32)

    it "base RV32IM has no FPRs":
        val fpr_count = 0
        expect(fpr_count).to_equal(0)

    it "base RV32IM has no float support":
        val has_float = false
        expect(has_float).to_equal(false)

    it "RV32IMFD has 32 GPRs":
        val gpr_count = 32
        expect(gpr_count).to_equal(32)

    it "RV32IMFD has 32 FPRs":
        val fpr_count = 32
        expect(fpr_count).to_equal(32)

    it "RV32IMFD has float support":
        val has_float = true
        expect(has_float).to_equal(true)

    it "RV32IMFD has double support":
        val has_double = true
        expect(has_double).to_equal(true)

# ============================================================================
# Calling Convention - ILP32
# ============================================================================

describe "RV32 Target - ILP32 Calling Convention":
    it "ILP32 convention name is ilp32":
        val name = "ilp32"
        expect(name).to_equal("ilp32")

    it "ILP32F convention name is ilp32f":
        val name = "ilp32f"
        expect(name).to_equal("ilp32f")

    it "ILP32D convention name is ilp32d":
        val name = "ilp32d"
        expect(name).to_equal("ilp32d")

    it "has 8 argument GPRs (a0-a7)":
        val arg_gpr_count = 8
        expect(arg_gpr_count).to_equal(8)

    it "ILP32 has 0 argument FPRs (soft-float)":
        val arg_fpr_count = 0
        expect(arg_fpr_count).to_equal(0)

    it "ILP32F has 8 argument FPRs":
        val arg_fpr_count = 8
        expect(arg_fpr_count).to_equal(8)

    it "ILP32D has 8 argument FPRs":
        val arg_fpr_count = 8
        expect(arg_fpr_count).to_equal(8)

    it "has 2 return GPRs (a0, a1)":
        val ret_gpr_count = 2
        expect(ret_gpr_count).to_equal(2)

    it "stack alignment is 16 bytes":
        val stack_alignment = 16
        expect(stack_alignment).to_equal(16)

    it "argument GPRs are a0 through a7":
        val arg_gprs = ["a0", "a1", "a2", "a3", "a4", "a5", "a6", "a7"]
        expect(arg_gprs.len()).to_equal(8)
        expect(arg_gprs[0]).to_equal("a0")
        expect(arg_gprs[7]).to_equal("a7")

    it "return GPRs are a0 and a1":
        val ret_gprs = ["a0", "a1"]
        expect(ret_gprs.len()).to_equal(2)
        expect(ret_gprs[0]).to_equal("a0")
        expect(ret_gprs[1]).to_equal("a1")

    it "callee-saved GPRs are s0 through s11":
        val callee_saved = ["s0", "s1", "s2", "s3", "s4", "s5", "s6", "s7", "s8", "s9", "s10", "s11"]
        expect(callee_saved.len()).to_equal(12)
        expect(callee_saved[0]).to_equal("s0")
        expect(callee_saved[11]).to_equal("s11")

    it "caller-saved GPRs include temporaries and arguments":
        val caller_saved = ["t0", "t1", "t2", "t3", "t4", "t5", "t6",
                            "a0", "a1", "a2", "a3", "a4", "a5", "a6", "a7"]
        expect(caller_saved.len()).to_equal(15)
        expect(caller_saved).to_contain("t0")
        expect(caller_saved).to_contain("a7")

# ============================================================================
# Supported Extensions
# ============================================================================

describe "RV32 Target - Supported Extensions":
    it "supported extensions include M":
        val extensions = ["+m", "+a", "+f", "+d", "+c", "+zicsr", "+zifencei"]
        expect(extensions).to_contain("+m")

    it "supported extensions include A":
        val extensions = ["+m", "+a", "+f", "+d", "+c", "+zicsr", "+zifencei"]
        expect(extensions).to_contain("+a")

    it "supported extensions include zicsr":
        val extensions = ["+m", "+a", "+f", "+d", "+c", "+zicsr", "+zifencei"]
        expect(extensions).to_contain("+zicsr")

    it "supported extensions include zifencei":
        val extensions = ["+m", "+a", "+f", "+d", "+c", "+zicsr", "+zifencei"]
        expect(extensions).to_contain("+zifencei")

    it "has 7 supported extensions total":
        val extensions = ["+m", "+a", "+f", "+d", "+c", "+zicsr", "+zifencei"]
        expect(extensions.len()).to_equal(7)

# ============================================================================
# ILP32 Type Sizes
# ============================================================================

describe "RV32 Target - ILP32 Type Sizes":
    it "bool is 1 byte":
        # rv32_type_size("bool") -> 1
        val size = 1
        expect(size).to_equal(1)

    it "i8 is 1 byte":
        val size = 1
        expect(size).to_equal(1)

    it "i16 is 2 bytes":
        val size = 2
        expect(size).to_equal(2)

    it "i32 is 4 bytes":
        val size = 4
        expect(size).to_equal(4)

    it "i64 is 8 bytes":
        val size = 8
        expect(size).to_equal(8)

    it "f32 is 4 bytes":
        val size = 4
        expect(size).to_equal(4)

    it "f64 is 8 bytes":
        val size = 8
        expect(size).to_equal(8)

    it "pointer is 4 bytes (not 8)":
        val size = 4
        expect(size).to_equal(4)

    it "usize is 4 bytes (not 8)":
        val size = 4
        expect(size).to_equal(4)

describe "RV32 Target - ILP32 Type Alignment":
    it "i32 alignment is 4 bytes":
        val alignment = 4
        expect(alignment).to_equal(4)

    it "i64 alignment is 4 bytes on RV32 (not 8)":
        # RV32 aligns i64 to 4 bytes, unlike LP64
        val alignment = 4
        expect(alignment).to_equal(4)

    it "f64 alignment is 4 bytes on RV32 (not 8)":
        val alignment = 4
        expect(alignment).to_equal(4)

    it "pointer alignment is 4 bytes":
        val alignment = 4
        expect(alignment).to_equal(4)

    it "bool alignment is 1 byte":
        val alignment = 1
        expect(alignment).to_equal(1)
