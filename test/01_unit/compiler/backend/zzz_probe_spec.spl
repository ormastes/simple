# VHDL Backend Integration Specification
#
# Tests VhdlBackend compilation pipeline via VhdlBuilder integration.
# Verifies that generated VHDL is structurally valid for common patterns.
#
# **Feature IDs:** #vhdl-backend
# **Category:** Backend
# **Difficulty:** 3/5

use compiler.backend.backend.vhdl.vhdl_builder.VhdlBuilder
use compiler.backend.backend.vhdl_backend.VhdlBackend
use compiler.backend.backend.backend_helpers.{available_backends, backend_for_name}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, compileoptions_default_options}
use compiler.backend.backend.vhdl_type_mapper.VhdlTypeMapper
use compiler.backend.backend.common.type_mapper.PrimitiveType
use compiler.common.attributes.{VhdlClockedMetadata, VhdlResetPolarity, VhdlResetSynchrony, vhdl_hardware_metadata_default}
use compiler.common.config.{Logger}
use compiler.frontend.frontend.{parse_full_frontend}
use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.mir.mir_data.*
use compiler.mir.mir_lowering.{MirLowering}
use lib.hardware.fpga_linux.riscv_fpga_linux.{RiscvFpgaLane}
use compiler.hir.hir_types.{SymbolId}
use compiler.common.diagnostics.span.{Span}

extern fn rt_file_read_text(path: text) -> text

fn check(condition: bool):
    expect(condition).to_equal(true)

fn make_logger() -> Logger:
    Logger(level: 0)

fn empty_span() -> Span:
    Span(start: 0, end: 0, line: 1, col: 1, file: "", length: 0)

fn diagnostic_span() -> Span:
    Span(start: 20, end: 25, line: 7, col: 3, file: "", length: 0)

fn make_i32() -> MirType:
    MirType(kind: MirTypeKind.I32)

fn make_i64() -> MirType:
    MirType(kind: MirTypeKind.I64)

fn make_u8() -> MirType:
    MirType(kind: MirTypeKind.U8)

fn make_u32() -> MirType:
    MirType(kind: MirTypeKind.U32)

fn make_f32() -> MirType:
    MirType(kind: MirTypeKind.F32)

fn make_u8_array(size: i64) -> MirType:
    MirType(kind: MirTypeKind.Array(make_u8(), size))

fn make_bool() -> MirType:
    MirType(kind: MirTypeKind.Bool)

fn make_unit() -> MirType:
    MirType(kind: MirTypeKind.Unit)

fn make_ptr_i32() -> MirType:
    MirType(kind: MirTypeKind.Ptr(make_i32(), false))

fn make_bits(width: i64) -> MirType:
    MirType.bits(width)

fn make_sbits(width: i64) -> MirType:
    MirType.sbits(width)

fn make_tuple_i32_bool() -> MirType:
    MirType(kind: MirTypeKind.Tuple([make_i32(), make_bool()]))

fn make_arg_local(id: i64, index: i64, name: text, ty: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: Some(name), type_: ty, kind: LocalKind.Arg(index))

fn make_return_local(id: i64, ty: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: ty, kind: LocalKind.Return)

fn make_temp_local(id: i64, name: text, ty: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: Some(name), type_: ty, kind: LocalKind.Temp)

fn make_simple_backend() -> VhdlBackend:
    val options = compileoptions_default_options()
    VhdlBackend.create(CodegenTarget.Riscv32, options)

fn make_hardware_meta():
    var meta = vhdl_hardware_metadata_default()
    meta.is_hardware = true
    meta

fn make_func_operand(name: text) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(
        MirConstValue.Str(name),
        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: make_i32(), is_variadic: false)))
    ))

fn make_payloadless_enum_type_def(symbol: SymbolId, name: text, variant_names: [text]) -> MirTypeDef:
    var variants: [MirVariantDef] = []
    var idx = 0
    for variant_name in variant_names:
        variants = variants.push(MirVariantDef(name: variant_name, discriminant: idx, payload: nil))
        idx = idx + 1
    MirTypeDef(
        symbol: symbol,
        name: name,
        kind: MirTypeDefKind.Enum(variants),
        is_export_c: false,
        export_name: ""
    )

fn single_block_module(name: text, func: MirFunction) -> MirModule:
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[func.symbol] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn compile_single_vhdl_instruction(name: text, inst: MirInstKind):
    val ret_local = make_return_local(1, make_i32())
    val temp_local = make_temp_local(2, "tmp_sig", make_i32())
    val block = MirBlock(
        id: BlockId(id: 0),
        label: Some("entry"),
        instructions: [MirInst(kind: inst, span: nil)],
        terminator: MirTerminator.Ret(nil)
    )
    val func = MirFunction(
        symbol: SymbolId(id: 9040),
        name: name,
        signature: MirSignature(params: [], return_type: make_i32(), is_variadic: false),
        locals: [ret_local, temp_local],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: empty_span(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: false,
        export_name: "",
        driver_manifest_attr: nil
    )
    val backend = make_simple_backend()
    backend.compile(single_block_module("{name}_mod", func))

fn normalize_vhdl(vhdl: text) -> text:
    var lines = vhdl.split("\n")
    var result: [text] = []
    for line in lines:
        result = result.push(line.trim_end())
    result.join("\n").trim()

fn make_adder_function() -> MirFunction:
    val a_local = make_arg_local(1, 0, "a", make_i32())
    val b_local = make_arg_local(2, 1, "b", make_i32())
    val ret_local = make_return_local(3, make_i32())
    val sum_local = make_temp_local(4, "sum_sig", make_i32())

    val block = MirBlock(
        id: BlockId(id: 0),
        label: Some("entry"),
        instructions: [
            MirInst(
                kind: MirInstKind.BinOp(
                    LocalId(id: 4),
                    MirBinOp.Add,
                    MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))),
                    MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))
                ),
                span: nil
            ),
            MirInst(
                kind: MirInstKind.Copy(LocalId(id: 3), LocalId(id: 4)),
                span: nil
            )
        ],
        terminator: MirTerminator.Ret(nil)
    )

    MirFunction(
        symbol: SymbolId(id: 10),
        name: "adder",
        signature: MirSignature(params: [make_i32(), make_i32()], return_type: make_i32(), is_variadic: false),
        locals: [a_local, b_local, ret_local, sum_local],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: empty_span(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: false,
        export_name: "",
        driver_manifest_attr: nil
    )

fn make_named_adder_function(symbol: SymbolId, name: text) -> MirFunction:
    """Same shape as make_adder_function() but with a caller-chosen symbol/name.

    NOTE: intentionally avoids the `MirFunction(..base, field: override, ...)`
    struct-spread-with-override syntax. That syntax was found to be broken in
    the current interpreter (crashes with "type mismatch: cannot convert
    object to int" regardless of which field is overridden) -- see
    doc/08_tracking/bug/vhdl_backend_spec_remaining_failures_2026-07-02.md.
    """
    val a_local = make_arg_local(1, 0, "a", make_i32())
    val b_local = make_arg_local(2, 1, "b", make_i32())
    val ret_local = make_return_local(3, make_i32())
    val sum_local = make_temp_local(4, "sum_sig", make_i32())

    val block = MirBlock(
        id: BlockId(id: 0),
        label: Some("entry"),
        instructions: [
            MirInst(
                kind: MirInstKind.BinOp(
                    LocalId(id: 4),
                    MirBinOp.Add,
                    MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))),
                    MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))
                ),
                span: nil
            ),
            MirInst(
                kind: MirInstKind.Copy(LocalId(id: 3), LocalId(id: 4)),
                span: nil
            )
        ],
        terminator: MirTerminator.Ret(nil)
    )

    MirFunction(
        symbol: symbol,
        name: name,
        signature: MirSignature(params: [make_i32(), make_i32()], return_type: make_i32(), is_variadic: false),
        locals: [a_local, b_local, ret_local, sum_local],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: empty_span(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: false,
        export_name: "",
        driver_manifest_attr: nil
    )

fn make_named_hardware_adder_function(symbol: SymbolId, name: text) -> MirFunction:
    """Hardware-flagged variant of make_named_adder_function()."""
    var f = make_named_adder_function(symbol, name)
    f.has_vhdl_metadata = true
    f.vhdl_metadata = make_hardware_meta()
    f

# ============================================================================
# Backend Registration
# ============================================================================

describe "probe dump":
    it "dump read vhdl":
        val src = """
bitfield Rv32Instruction(u32):
    opcode: u7
    rd: u5
    funct3: u3
    rs1: u5
    rs2: u5
    funct7: u7

@hardware
@clocked(clk, reset_n)
fn bitfield_opcode(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction(imem_rdata)
    inst.opcode as u32
"""
        val path = "testdata/bitfield_opcode_hw.spl"
        val log = make_logger()
        val module = parse_full_frontend(src, path, "bitfield_opcode_hw", log)
        var hir_lowering = HirLowering.with_filename(path)
        val hir_module = hir_lowering.lower_module(module)
        var mir_lowering = MirLowering.new(hir_module.symbols)
        val mir_module = mir_lowering.lower_module(hir_module)
        val result = make_simple_backend().compile(mir_module)
        print "ZREACHED ok={result.is_ok()}"
        if result.is_ok():
            val compiled = result.unwrap()
            val vhdl = compiled.vhdl
            val parts = vhdl.split("\n")
            for line in parts:
                print "ZVHDL| {line}"
        print "ZRET {mir_module.functions.values()[0].signature.return_type.kind}"
        for loc in mir_module.functions.values()[0].locals:
            val nm = if loc.name.?: loc.name.unwrap() else: "NIL"
            print "ZLOC id={loc.id.id} name={nm} kind={loc.kind} ty={loc.type_.kind}"
        print "ZHASVHDL {mir_module.functions.values()[0].has_vhdl_metadata}"
