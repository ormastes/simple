extern fn rt_file_read_text(path: text) -> text

describe "LLVM comparison operand type lowering":
    it "compares operands in operand type before producing bool result":
        val source = rt_file_read_text("src/compiler/70.backend/backend/_MirToLlvm/core_codegen.spl") ?? ""

        expect(source).to_contain("val eq_cmp_ty = self.valid_llvm_type(self.get_operand_type(left))")
        expect(source).to_contain("val eq_left = self.value_as_type(left_raw, self.get_operand_type(left), eq_cmp_ty)")
        expect(source).to_contain("val eq_right = self.value_as_type(right_raw, self.get_operand_type(right), eq_cmp_ty)")
        expect(source).to_not_contain("self.emit_comparison(dest_name, ty, eq_pred, eq_cmp_ty, left_val, right_val)")
        expect(source).to_not_contain("self.emit_comparison(dest_name, ty, lt_pred, lt_cmp_ty, left_val, right_val)")

    it "uses unsigned integer to float conversion when MIR provenance requires it":
        val llvm_source = rt_file_read_text("src/compiler/70.backend/backend/_MirToLlvm/core_codegen.spl") ?? ""
        val cranelift_source = rt_file_read_text("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl") ?? ""

        expect(llvm_source).to_contain("if src_unsigned and cast_inst == \"sitofp\":")
        expect(llvm_source).to_contain("cast_inst = \"uitofp\"")
        expect(cranelift_source).to_contain("case U8 | U16 | U32 | U64: cranelift_fcvt_from_uint(ctx, to_cl, src_val)")
