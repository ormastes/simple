# Backend Benchmark Matrix — x86-64 Same-or-Faster Gate
#
# Feature ID: #COMPILER-BACKEND-BENCH-MATRIX
# Category:   Compiler | Backend | Benchmarks
# Status:     Active (fixture skeleton — not a live benchmark runner)
#
# Tests Task 6: benchmark fixture contracts and gate predicates.
# This spec encodes the *expected* instruction-cost relationships between:
#   - x86-64 wide (REX.W) forms vs narrow (32-bit) forms
#   - Simple-generated code vs C/Rust reference sizes (byte-count proxies)
#
# What this is NOT:
#   - It does not invoke an assembler or hardware performance counter.
#   - It does not run QEMU.
#   - Live benchmark runs require a separate benchmark harness.
#
# The "gate" checks here validate the structural properties that the benchmark
# harness will enforce at CI time:
#   1. narrow forms are always same-or-shorter than wide forms.
#   2. The gate predicate rejects prohibited ops.
#   3. Cost tables are self-consistent (cost >= 0 for supported idioms).
#
# Interpreter-mode note: assertions not executed in interpreter mode.

use compiler.backend.feature_caps.{
    X86Caps, Aarch64Caps, Rv64Caps, ArmCaps, Rv32Caps, X86_32Caps,
    x86_caps_from_target, aarch64_caps_from_target, rv64_caps_from_target,
    arm_caps_from_target, rv32_caps_from_target, x86_32_caps_from_target,
    TargetIdiom,
    x86_instruction_cost, aarch64_instruction_cost, rv64_instruction_cost,
    arm_instruction_cost, rv32_instruction_cost,
    instruction_cost_unsupported
}
use compiler.backend.lowering.x86_narrow_form.{
    bench_add_r64_bytes,
    bench_add_r32_bytes,
    narrow_form_is_same_or_shorter,
    bench_narrow_gate_passes,
    x86_narrow_form_legal
}

# ============================================================================
# Encoding size gate — narrow < wide for x86
# ============================================================================

describe "BenchMatrix — x86-64 narrow-form encoding size gate":
    it "r32 ADD is strictly smaller than r64 ADD":
        expect(bench_add_r32_bytes()).to_be_less_than(bench_add_r64_bytes())

    it "narrow gate passes for add+42 (legal + shorter)":
        expect(bench_narrow_gate_passes("add", 42)).to_equal(true)

    it "narrow gate passes for xor+0 (legal + shorter)":
        expect(bench_narrow_gate_passes("xor", 0)).to_equal(true)

    it "narrow gate rejects mul regardless of value (prohibited)":
        expect(bench_narrow_gate_passes("mul", 1)).to_equal(false)

    it "narrow gate rejects add with huge value (value overflow)":
        expect(bench_narrow_gate_passes("add", 5000000000)).to_equal(false)

    it "narrow_form_is_same_or_shorter is reflexive (equal is ok)":
        expect(narrow_form_is_same_or_shorter(3, 3)).to_equal(true)

    it "narrow_form_is_same_or_shorter rejects strictly larger narrow":
        expect(narrow_form_is_same_or_shorter(3, 5)).to_equal(false)

# ============================================================================
# Cost-table self-consistency — x86_64-v3
# ============================================================================

describe "BenchMatrix — x86-64-v3 cost table self-consistency":
    it "AesEnc cost is non-negative":
        val caps = x86_caps_from_target("x86_64-v3")
        val cost = x86_instruction_cost(caps, TargetIdiom.AesEnc)
        expect(cost.latency).to_be_greater_than(0)

    it "RotateLeft cost is non-negative":
        val caps = x86_caps_from_target("x86_64-v3")
        val cost = x86_instruction_cost(caps, TargetIdiom.RotateLeft)
        expect(cost.latency).to_be_greater_than(0)

    it "Sha512Rounds2 is unsupported on x86_64-v3 (cost sentinel)":
        val caps = x86_caps_from_target("x86_64-v3")
        val cost = x86_instruction_cost(caps, TargetIdiom.Sha512Rounds2)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

# ============================================================================
# Cost-table self-consistency — AArch64
# ============================================================================

describe "BenchMatrix — aarch64+crypto cost table self-consistency":
    it "AesEnc cost is non-negative on aarch64+crypto":
        val caps = aarch64_caps_from_target("aarch64+crypto")
        val cost = aarch64_instruction_cost(caps, TargetIdiom.AesEnc)
        expect(cost.latency).to_be_greater_than(0)

    it "Sha512Rounds2 cost is non-negative on armv8.4-A+crypto+sha3":
        val caps = aarch64_caps_from_target("armv8.4-A+crypto+sha3")
        val cost = aarch64_instruction_cost(caps, TargetIdiom.Sha512Rounds2)
        expect(cost.latency).to_be_greater_than(0)

    it "AesEnc unsupported on bare aarch64 baseline":
        val caps = aarch64_caps_from_target("aarch64")
        val cost = aarch64_instruction_cost(caps, TargetIdiom.AesEnc)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

# ============================================================================
# Cost-table self-consistency — RV64
# ============================================================================

describe "BenchMatrix — rv64gcv_zvkn cost table self-consistency":
    it "AesEnc cost is non-negative on rv64gcv_zvkn":
        val caps = rv64_caps_from_target("rv64gcv_zvkn")
        val cost = rv64_instruction_cost(caps, TargetIdiom.AesEnc)
        expect(cost.latency).to_be_greater_than(0)

    it "RotateLeft cost is non-negative with Zbb":
        val caps = rv64_caps_from_target("rv64gc_zbb")
        val cost = rv64_instruction_cost(caps, TargetIdiom.RotateLeft)
        expect(cost.latency).to_be_greater_than(0)

    it "CRC32 is unsupported on RV64 (always)":
        val caps = rv64_caps_from_target("rv64gcv_zvkn")
        val cost = rv64_instruction_cost(caps, TargetIdiom.Crc32U32)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

# ============================================================================
# Cost-table self-consistency — ARM32
# ============================================================================

describe "BenchMatrix — arm32 neon+crypto cost table self-consistency":
    it "AesEnc cost is non-negative with AES extension":
        val caps = arm_caps_from_target("armv8-neon-crypto")
        val cost = arm_instruction_cost(caps, TargetIdiom.AesEnc)
        expect(cost.latency).to_be_greater_than(0)

    it "RotateLeft cost is non-negative on ARM32":
        val caps = arm_caps_from_target("thumbv6m-none-eabi")
        val cost = arm_instruction_cost(caps, TargetIdiom.RotateLeft)
        expect(cost.latency).to_be_greater_than(0)

    it "Sha512Rounds2 is unsupported on any ARM32 target":
        val caps = arm_caps_from_target("armv8-neon-crypto")
        val cost = arm_instruction_cost(caps, TargetIdiom.Sha512Rounds2)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

    it "SimdI32x8 is unsupported on ARM32":
        val caps = arm_caps_from_target("armv8-neon-crypto")
        val cost = arm_instruction_cost(caps, TargetIdiom.SimdI32x8)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

# ============================================================================
# Cost-table self-consistency — RV32
# ============================================================================

describe "BenchMatrix — rv32 scalar crypto cost table self-consistency":
    it "AesEnc cost is non-negative with Zkne":
        val caps = rv32_caps_from_target("riscv32imac_zkne")
        val cost = rv32_instruction_cost(caps, TargetIdiom.AesEnc)
        expect(cost.latency).to_be_greater_than(0)

    it "RotateLeft cost is non-negative with Zbb":
        val caps = rv32_caps_from_target("riscv32imac_zbb")
        val cost = rv32_instruction_cost(caps, TargetIdiom.RotateLeft)
        expect(cost.latency).to_be_greater_than(0)

    it "Sha512 is unsupported on RV32 (64-bit ops unavailable)":
        val caps = rv32_caps_from_target("riscv32imac_zknd_zkne_zknh")
        val cost = rv32_instruction_cost(caps, TargetIdiom.Sha512Rounds2)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

    it "CRC32 is always unsupported on RV32":
        val caps = rv32_caps_from_target("riscv32imac")
        val cost = rv32_instruction_cost(caps, TargetIdiom.Crc32U32)
        val unsupported = instruction_cost_unsupported()
        expect(cost.latency).to_equal(unsupported.latency)

# ============================================================================
# Cross-arch comparison gate (Simple vs C vs Rust proxy: byte-count)
# ============================================================================

describe "BenchMatrix — cross-arch narrow-vs-wide gate summary":
    it "x86-64 narrow ADD is strictly shorter (2 bytes vs 4 bytes proxy)":
        val narrow = bench_add_r32_bytes()
        val wide = bench_add_r64_bytes()
        expect(narrow_form_is_same_or_shorter(wide, narrow)).to_equal(true)

    it "benchmark gate passes for all approved ops with values fitting in 32 bits":
        expect(bench_narrow_gate_passes("sub",  1000)).to_equal(true)
        expect(bench_narrow_gate_passes("and",  0xFF)).to_equal(true)
        expect(bench_narrow_gate_passes("or",   0x0F)).to_equal(true)
        expect(bench_narrow_gate_passes("xor",  0xAB)).to_equal(true)

    it "benchmark gate rejects all prohibited ops":
        expect(bench_narrow_gate_passes("div",     1)).to_equal(false)
        expect(bench_narrow_gate_passes("idiv",    1)).to_equal(false)
        expect(bench_narrow_gate_passes("syscall", 0)).to_equal(false)
        expect(bench_narrow_gate_passes("rdtsc",   0)).to_equal(false)
