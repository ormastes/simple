use compiler.backend.{MirToLlvm}
use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.*

fn build_alloc_copy_module() -> MirModule:
    val i64_type = MirType.i64()
    val fn_ = MirFunction(
        symbol: SymbolId(id: 1),
        name: "alloc_copy_move",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [
            MirLocal(id: LocalId(id: 1), name: Some("slot"), type_: i64_type, kind: LocalKind.Temp, is_ghost: false),
            MirLocal(id: LocalId(id: 2), name: Some("copy_slot"), type_: i64_type, kind: LocalKind.Temp, is_ghost: false),
            MirLocal(id: LocalId(id: 3), name: Some("move_slot"), type_: i64_type, kind: LocalKind.Temp, is_ghost: false)
        ],
        blocks: [
            MirBlock(
                id: BlockId.entry(),
                label: Some("entry"),
                instructions: [
                    MirInst(kind: MirInstKind.Alloc(LocalId(id: 1), i64_type), span: nil),
                    MirInst(kind: MirInstKind.Copy(LocalId(id: 2), LocalId(id: 1)), span: nil),
                    MirInst(kind: MirInstKind.Move(LocalId(id: 3), LocalId(id: 2)), span: nil)
                ],
                terminator: MirTerminator.Ret(nil)
            )
        ],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

    var functions: Dict<SymbolId, MirFunction> = {}
    functions[fn_.symbol] = fn_
    MirModule(name: "test.llvm.alloc_copy_move", functions: functions, statics: {}, constants: {}, types: {})

describe "LLVM alloc copy move":
    it "keeps alloc results pointer-typed across copy and move chains":
        val translator = MirToLlvm.create("test.llvm.alloc_copy_move", CodegenTarget.X86_64, nil)
        val output = translator.translate_module(build_alloc_copy_module())

        expect(output).to_contain("%l1 = alloca i64")
        expect(output).to_contain("%l2 = getelementptr i8, ptr %l1, i64 0  ; copy")
        expect(output).to_contain("%l3 = getelementptr i8, ptr %l2, i64 0  ; move")
        expect(output.contains("add i64 %l2, 0")).to_equal(false)
