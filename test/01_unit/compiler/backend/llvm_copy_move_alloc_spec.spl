use compiler.backend.{MirToLlvm}
use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.*

fn build_alloc_copy_module() -> MirModule:
    val i64_type = MirType.i64()
    val fn_ = MirFunction(
        symbol: SymbolId(id: 1),
        name: "alloc_copy_move",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [
            MirLocal(id: LocalId(id: 1), name: Some("slot"), type_: i64_type, kind: LocalKind.Temp, is_ghost: false),
            MirLocal(id: LocalId(id: 2), name: Some("copy_slot"), type_: i64_type, kind: LocalKind.Temp, is_ghost: false),
            MirLocal(id: LocalId(id: 3), name: Some("move_slot"), type_: i64_type, kind: LocalKind.Temp, is_ghost: false)
        ],
        blocks: [
            MirBlock(
                id: BlockId.entry(),
                label: Some("entry"),
                instructions: [
                    MirInst(kind: MirInstKind.Alloc(LocalId(id: 1), i64_type), span: nil),
                    MirInst(kind: MirInstKind.Copy(LocalId(id: 2), LocalId(id: 1)), span: nil),
                    MirInst(kind: MirInstKind.Move(LocalId(id: 3), LocalId(id: 2)), span: nil)
                ],
                terminator: MirTerminator.Ret(nil)
            )
        ],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

    var functions: Dict<SymbolId, MirFunction> = {}
    functions[fn_.symbol] = fn_
    MirModule(name: "test.llvm.alloc_copy_move", functions: functions, statics: {}, constants: {}, types: {})

fn build_local_zero_pointer_copy_module() -> MirModule:
    val ptr_type = MirType.ptr(MirType.i64(), false)
    val fn_ = MirFunction(
        symbol: SymbolId(id: 2),
        name: "local_zero_pointer_copy",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [
            MirLocal(id: LocalId(id: 0), name: Some("source"), type_: ptr_type, kind: LocalKind.Temp, is_ghost: false),
            MirLocal(id: LocalId(id: 1), name: Some("copy_slot"), type_: ptr_type, kind: LocalKind.Temp, is_ghost: false)
        ],
        blocks: [
            MirBlock(
                id: BlockId.entry(),
                label: Some("entry"),
                instructions: [
                    MirInst(kind: MirInstKind.Const(LocalId(id: 0), MirConstValue.Zero, ptr_type), span: nil),
                    MirInst(kind: MirInstKind.Copy(LocalId(id: 1), LocalId(id: 0)), span: nil)
                ],
                terminator: MirTerminator.Ret(nil)
            )
        ],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

    var functions: Dict<SymbolId, MirFunction> = {}
    functions[fn_.symbol] = fn_
    MirModule(name: "test.llvm.local_zero_pointer_copy", functions: functions, statics: {}, constants: {}, types: {})

fn build_pointer_condition_module() -> MirModule:
    val ptr_type = MirType.ptr(MirType.i64(), false)
    val fn_ = MirFunction(
        symbol: SymbolId(id: 3),
        name: "pointer_condition",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [
            MirLocal(id: LocalId(id: 0), name: Some("cond"), type_: ptr_type, kind: LocalKind.Temp, is_ghost: false)
        ],
        blocks: [
            MirBlock(
                id: BlockId.entry(),
                label: Some("entry"),
                instructions: [
                    MirInst(kind: MirInstKind.Const(LocalId(id: 0), MirConstValue.Zero, ptr_type), span: nil)
                ],
                terminator: MirTerminator.If(
                    MirOperand(kind: MirOperandKind.Copy(LocalId(id: 0))),
                    BlockId(id: 1),
                    BlockId(id: 2)
                )
            ),
            MirBlock(id: BlockId(id: 1), label: Some("then"), instructions: [], terminator: MirTerminator.Ret(nil)),
            MirBlock(id: BlockId(id: 2), label: Some("else"), instructions: [], terminator: MirTerminator.Ret(nil))
        ],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

    var functions: Dict<SymbolId, MirFunction> = {}
    functions[fn_.symbol] = fn_
    MirModule(name: "test.llvm.pointer_condition", functions: functions, statics: {}, constants: {}, types: {})

fn build_pointer_not_module() -> MirModule:
    val ptr_type = MirType.ptr(MirType.i64(), false)
    val bool_type = MirType.bool()
    val fn_ = MirFunction(
        symbol: SymbolId(id: 5),
        name: "pointer_not",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [
            MirLocal(id: LocalId(id: 0), name: Some("source"), type_: ptr_type, kind: LocalKind.Temp, is_ghost: false),
            MirLocal(id: LocalId(id: 1), name: Some("result"), type_: bool_type, kind: LocalKind.Temp, is_ghost: false)
        ],
        blocks: [
            MirBlock(
                id: BlockId.entry(),
                label: Some("entry"),
                instructions: [
                    MirInst(kind: MirInstKind.Const(LocalId(id: 0), MirConstValue.Zero, ptr_type), span: nil),
                    MirInst(
                        kind: MirInstKind.UnaryOp(
                            LocalId(id: 1),
                            MirUnaryOp.Not,
                            MirOperand(kind: MirOperandKind.Copy(LocalId(id: 0)))
                        ),
                        span: nil
                    )
                ],
                terminator: MirTerminator.Ret(nil)
            )
        ],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        gpu_target: "",
        gpu_backend_order: "",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

    var functions: Dict<SymbolId, MirFunction> = {}
    functions[fn_.symbol] = fn_
    MirModule(name: "test.llvm.pointer_not", functions: functions, statics: {}, constants: {}, types: {})

