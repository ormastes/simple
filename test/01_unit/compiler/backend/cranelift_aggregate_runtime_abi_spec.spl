"""Regression contract for Cranelift aggregate runtime representation."""

use std.io_runtime.{file_read}
use std.spec.*

describe "Cranelift aggregate runtime ABI":
    it "owns a behavioral aggregate and bounds check":
        val check = file_read("scripts/check/check-cranelift-aot-aggregates.shs")
        val cross_check = file_read("scripts/check/check-cranelift-aot-aggregate-cross.shs")
        val fixture = file_read("test/fixtures/compiler/stage4_struct_enum_array_probe.spl")
        expect(check).to_contain("stage4_struct_enum_array_probe.spl")
        expect(check).to_contain("cranelift_array_oob.spl")
        expect(check).to_contain("test ! -s \"$BUILD_DIR/actual.txt\"")
        expect(check).to_contain("oob.expected.stderr")
        expect(cross_check).to_contain("aarch64-unknown-linux-gnu AArch64")
        expect(cross_check).to_contain("riscv64-unknown-linux-gnu RISC-V")
        expect(cross_check).to_contain("Type:[[:space:]]+REL")
        expect(cross_check).to_contain("function address missing")
        expect(cross_check).to_contain("check_unsupported_arm32")
        expect(cross_check).to_contain("Backend cranelift does not support target arm")
        expect(cross_check).to_contain("EXEC_FIXTURE=\"test/fixtures/native_crossmodule_result_u8/main.spl\"")
        expect(cross_check).to_contain("CRANELIFT_CROSS_EXECUTE")
        expect(cross_check).to_contain("printf 'result-u8-ok\\n' | cmp - \"$actual\"")
        expect(fixture).to_contain("if signed_values[0] != -2: return -6")
        expect(fixture).to_contain("if add_pair(20, 22) != 42: return 8")
        expect(fixture).to_contain("if call_zero(zero_value) != 31: return 9")
        expect(fixture).to_contain("if call_pair(add_pair) != 42: return 10")
        expect(fixture).to_contain("if identity(local_value) != 17: return 11")
        expect(fixture).to_contain("fn main() -> i64:")

    it "reloads tuple heap pointers as runtime handles":
        val adapter = file_read("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl")
        expect(adapter).to_contain("case Struct(_) | Array(_, _) | Dict(_, _) | Slice(_) | Tuple(_): true")

    it "keeps dictionaries on the heap runtime ABI":
        val core = file_read("src/runtime/simple_core/core_array.spl")
        val lowering = file_read("src/compiler/50.mir/_MirLoweringExpr/method_calls_literals.spl")
        expect(core.contains("pub fn rt_dict_new")).to_equal(false)
        expect(lowering).to_contain("method == \"values\" or method == \"keys\"")
        expect(lowering).to_contain("\"rt_dict_values\"")
        expect(lowering).to_contain("\"rt_dict_keys\"")

    it "materializes function pointer constants as code addresses":
        val adapter = file_read("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl")
        val wrapper = file_read("src/lib/nogc_sync_mut/sffi/codegen.spl")
        val resolver = file_read("src/compiler_rust/compiler/src/elf_utils.rs")
        val interpreter = file_read("src/compiler_rust/compiler/src/interpreter_extern/mod.rs")
        expect(adapter).to_contain("case FuncPtr(_): return cranelift_function_addr_in_func(ctx, v)")
        expect(adapter).to_contain("if target_code < 0:")
        expect(adapter).to_contain("compileerror_target_unsupported(BackendKind.Cranelift")
        expect(adapter).to_contain("case _: -1")
        expect(adapter).to_not_contain("case _: CL_TARGET_X86_64")
        expect(wrapper).to_contain("rt_cranelift_function_addr_in_func")
        expect(resolver).to_contain("\"rt_cranelift_function_addr_in_func\"")
        expect(interpreter).to_contain("\"rt_cranelift_function_addr_in_func\"")

    it "separates ordinary local collisions from lowering-owned runtime calls":
        val adapter = file_read("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl")
        val calls = file_read("src/compiler_rust/compiler/src/codegen/instr/calls.rs")
        val backend = file_read("src/compiler_rust/compiler/src/codegen/common_backend.rs")
        val call_start = adapter.index_of("fn cl_translate_call(") ?? -1
        val call_body = adapter.substring(call_start, adapter.len())
        val compile_start = adapter.index_of("fn compile_function(") ?? -1
        val compile_body = adapter.substring(compile_start, call_start)
        val reserved_guard = call_body.index_of("if cl_is_lowering_owned_runtime(name):") ?? -1
        val local_lookup = call_body.index_of("if func_handles.has(name)") ?? -1
        val extern_fallback = call_body.index_of("# External function - declare as import") ?? -1
        expect(call_start).to_be_greater_than(-1)
        expect(compile_start).to_be_greater_than(-1)
        expect(compile_body).to_contain("val emit_name = cl_function_emit_name(func.name)")
        expect(reserved_guard).to_be_greater_than(-1)
        expect(local_lookup).to_be_greater_than(-1)
        expect(local_lookup).to_be_greater_than(reserved_guard)
        expect(extern_fallback).to_be_greater_than(local_lookup)
        val rust_call_start = calls.index_of("pub fn compile_call<M: Module>(") ?? -1
        val rust_call_body = calls.substring(rust_call_start, calls.len())
        val local_guard = rust_call_body.index_of("if has_defined_local_function(ctx, func_name)") ?? -1
        val first_runtime_shortcut = rust_call_body.index_of("if compile_simple_runtime_memory_intrinsic") ?? -1
        val generic_runtime = rust_call_body.index_of("ctx.runtime_funcs.get(sffi_name)") ?? -1
        expect(local_guard).to_be_greater_than(-1)
        expect(first_runtime_shortcut).to_be_greater_than(-1)
        expect(generic_runtime).to_be_greater_than(-1)
        expect(local_guard).to_be_greater_than(first_runtime_shortcut)
        expect(generic_runtime).to_be_greater_than(local_guard)
        expect(backend).to_contain("self.func_ids.insert(func.name.clone(), func_id)")
        expect(adapter).to_contain("if cl_is_lowering_owned_runtime(name):")
        expect(adapter).to_contain("name == \"rt_array_len\" or name == \"rt_array_get\" or name == \"rt_array_get_text\" or name == \"rt_array_set\" or name == \"rt_array_set_text\"")
        expect(adapter).to_contain("return \"__simple_local_{name}\"")
        expect(adapter).to_contain("translate_runtime_import_call_i64(ctx, cl_module, \"rt_string_new\"")
        expect(adapter).to_contain("translate_runtime_import_call_i64(ctx, cl_module, \"rt_string_to_int_lenient\"")
        expect(adapter.contains("fn cl_call_runtime_i64")).to_equal(false)
        val fixture = file_read("test/fixtures/compiler/native_runtime_local_name_collision.spl")
        val non_generic_fixture = file_read("test/fixtures/compiler/native_runtime_local_name_collision_non_generic.spl")
        val open_repro = file_read("test/fixtures/compiler/native_runtime_generic_call_origin_collision_repro.spl")
        val portability = file_read("scripts/check/check-bootstrap-portability.shs")
        val gate = file_read("scripts/check/check-cranelift-aot-aggregates.shs")
        expect(fixture).to_contain("fn rt_array_len_safe<T>(array: [T]) -> i64:")
        expect(fixture).to_contain("fn rt_array_len(value: i64) -> i64:")
        expect(fixture).to_contain("fn rt_array_get(array: i64, index: i64) -> i64:")
        expect(fixture).to_contain("fn rt_array_set(array: i64, index: i64, value: i64) -> i64:")
        expect(non_generic_fixture).to_contain("fn rt_array_len_safe(array: [i64]) -> i64:")
        expect(gate).to_contain("native_runtime_local_name_collision.spl")
        expect(gate).to_contain("native_runtime_local_name_collision_non_generic.spl")
        expect(gate).to_contain("printf '4\\n20\\n25\\n'")
        expect(gate).to_contain("printf '3\\n'")
        expect(open_repro).to_contain("fn rt_array_new(capacity: i64) -> i64:")
        expect(open_repro).to_contain("fn rt_array_push(array: i64, value: i64) -> i64:")
        expect(open_repro).to_contain("fn first() -> i64:")
        expect(open_repro).to_contain("fn second() -> i64:")
        expect(open_repro).to_contain("val items = [first, second]")
        expect(open_repro).to_contain("print(rt_array_new(0))")
        expect(portability).to_contain("owned code defines a guarded compiler-generated runtime helper before MIR call origin exists")
    it "expands Cranelift text arguments exactly once":
        val wrapper = file_read("src/lib/nogc_sync_mut/sffi/codegen.spl")
        val adapter = file_read("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl")
        val generator = file_read("src/compiler/90.tools/sffi_gen/specs/cranelift_advanced.spl")
        val module_init_fixture = file_read("test/fixtures/compiler/native_module_global_initializer.spl")
        val sffi = file_read("src/compiler_rust/compiler/src/codegen/cranelift_sffi.rs")
        val native_calls = file_read("src/compiler_rust/compiler/src/codegen/instr/calls.rs")
        val llvm_calls = file_read("src/compiler_rust/compiler/src/codegen/llvm/functions/calls.rs")
        expect(wrapper).to_contain("rt_cranelift_new_module(rt_string_data(name), rt_string_len(name), target)")
        expect(wrapper).to_contain("rt_cranelift_new_aot_module(rt_string_data(name), rt_string_len(name), target)")
        expect(wrapper).to_contain("rt_cranelift_begin_function(module, rt_string_data(name), rt_string_len(name), sig)")
        expect(wrapper).to_contain("rt_cranelift_get_function_ptr(module, rt_string_data(name), rt_string_len(name))")
        expect(wrapper).to_contain("rt_cranelift_declare_function(module, rt_string_data(name), rt_string_len(name), sig, linkage)")
        expect(wrapper).to_contain("rt_cranelift_emit_object_raw(module, rt_string_data(path), rt_string_len(path))")
        expect(native_calls.contains("\"rt_cranelift_new_module\" | \"rt_cranelift_new_aot_module\" => Some(&[0])")).to_equal(false)
        expect(native_calls.contains("\"rt_cranelift_begin_function\" => Some(&[1])")).to_equal(false)
        expect(native_calls.contains("\"rt_cranelift_get_function_ptr\" => Some(&[1])")).to_equal(false)
        expect(llvm_calls.contains("\"rt_cranelift_new_module\" | \"rt_cranelift_new_aot_module\" => Some(&[0])")).to_equal(false)
        expect(wrapper).to_contain("rt_cranelift_aot_define_function(module, 0, 0, ctx)")
        expect(adapter).to_contain("cranelift_aot_define_function(cl_module, finished)")
        expect(generator).to_contain("FFIParamSpec.simple(\"name_len\", \"i64\")")
        expect(module_init_fixture).to_contain("val module_value = init_value()")
        expect(wrapper).to_contain("rt_cranelift_begin_function(module, func_handle, 0, sig)")
        expect(adapter).to_contain("cranelift_begin_declared_function(cl_module, func_handle, sig)")
        expect(sffi).to_contain("let func_id = {")
        expect(sffi).to_contain("ctx.func_ids.iter().find_map")
        expect(sffi).to_contain("let name = finished.name;")
        expect(sffi.contains("let name = string_from_ptr(name_ptr, name_len);")).to_equal(false)

    it "types backend compilation results for driver unwrapping":
        val helpers = file_read("src/compiler/70.backend/backend/backend_helpers.spl")
        expect(helpers).to_contain("opt_level_i64: i64\n) -> Result<CompiledModule, CompileError>:")

    it "keeps the f64 text renderer on its native runtime ABI":
        val imports = file_read("src/compiler/70.backend/backend/cranelift_runtime_imports.spl")
        val adapter = file_read("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl")
        val call_start = adapter.index_of("fn cl_translate_call(") ?? -1
        val call_body = adapter.substring(call_start, adapter.len())
        val typed_guard = call_body.index_of("if name == \"rt_raw_f64_to_string\" and arg_vals.len() == 1:") ?? -1
        val local_lookup = call_body.index_of("if func_handles.has(name)") ?? -1
        expect(imports).to_contain("fn translate_runtime_import_call_f64_i64(")
        expect(imports).to_contain("cranelift_sig_add_param(sig, CL_TYPE_F64_FOR_RUNTIME_IMPORT)")
        expect(adapter).to_contain("translate_runtime_import_call_f64_i64(ctx, cl_module, name, arg_vals[0])")
        expect(typed_guard).to_be_greater_than(-1)
        expect(local_lookup).to_be_greater_than(typed_guard)

    it "predispatches colliding MIR Const instructions":
        val adapter = file_read("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl")
        expect(adapter).to_contain("val const_disc = rt_enum_discriminant(MirInstKind.Const(")
        expect(adapter).to_contain("val payload: [Any] = rt_enum_payload(inst_kind)")
        expect(adapter).to_contain("val dest_id = rt_value_as_int(payload[0])")
        expect(adapter).to_contain("val value: MirConstValue = payload[1]")
        expect(adapter).to_contain("val type_: MirType = payload[2]")
        expect(adapter.contains("case Const(dest, value, type_):")).to_equal(false)

    it "decodes GEMM operand locals without struct pattern binding":
        val fusion = file_read("src/compiler/70.backend/backend/cranelift_gemm_fusion.spl")
        expect(fusion).to_contain("val copy_disc = rt_enum_discriminant(MirOperandKind.Copy(LocalId(0)))")
        expect(fusion).to_contain("val move_disc = rt_enum_discriminant(MirOperandKind.Move(LocalId(0)))")
        expect(fusion).to_contain("Some(rt_value_as_int(rt_enum_payload(kind)))")
        expect(fusion.contains("val payload: [Any] = rt_enum_payload(kind)")).to_equal(false)
        expect(fusion.contains("case Copy(local) | Move(local): Some(local.id)")).to_equal(false)
        expect(fusion).to_contain("rt_enum_discriminant(matmul_op) != rt_enum_discriminant(MirBinOp.MatMul)")
        expect(fusion).to_contain("val value: Any = rt_enum_payload(term)")
        expect(fusion.contains("case Ret(value):")).to_equal(false)
