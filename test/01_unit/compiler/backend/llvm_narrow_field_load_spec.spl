use compiler.backend.backend.mir_to_llvm.{MirToLlvm}
use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.mir.mir_data.*

fn narrow_field_ir() -> text:
    val llvm = MirToLlvm.create("test.llvm.narrow_field", CodegenTarget.X86_64, nil)
    llvm.local_types[0] = "ptr"
    llvm.ptr_locals[0] = true
    llvm.defined_locals[0] = true
    llvm.local_types[1] = "i32"
    llvm.local_types[2] = "i1"
    llvm.bool_locals[2] = true
    val base = mir_operand_copy(LocalId(id: 0))
    llvm.translate_get_field(LocalId(id: 1), base, 0)
    llvm.translate_get_field(LocalId(id: 2), base, 1)
    llvm.builder.build()

describe "LLVM narrow aggregate field loads":
    it "loads native words then truncates to the declared i32 and bool widths":
        val ir = narrow_field_ir()
        expect(ir).to_contain("%l1 = trunc i64")
        expect(ir).to_contain("to i32")
        expect(ir).to_contain("%l2 = trunc i64")
        expect(ir).to_contain("to i1")
        expect(ir.contains("%l1 = load i64")).to_equal(false)
        expect(ir.contains("%l2 = load i64")).to_equal(false)
