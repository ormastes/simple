use compiler.backend.backend.c_backend_translate.{MirToC}
use compiler.backend.backend.c_backend_translate_ops.*
use compiler.backend.backend.c_backend_stubs.*
use compiler.mir.mir_types.*
use compiler.mir.mir_instructions.*
use compiler.hir.hir_types.{SymbolId}

extern fn rt_file_write_text(path: text, content: text) -> bool

fn _probe_function() -> MirFunction:
    val ret_type = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: ret_type, is_variadic: false)
    MirFunction(
        symbol: SymbolId.new(0), name: "probe_empty", signature: sig,
        locals: [], blocks: [], entry_block: BlockId.new(0),
        span: nil, generic_params: [], is_generic_template: false,
        specialization_of: nil, type_bindings: {}
    )

fn _probe_module() -> MirModule:
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = _probe_function()
    MirModule(name: "probe", functions: functions, statics: {}, constants: {}, types: {})

fn main():
    print "PROBE_MAIN_START"
    val m = _probe_module()
    val t = MirToC.create("probe")
    val impl = t.translate_module(m)
    val hdr = t.build_header()
    val ok1 = rt_file_write_text("/tmp/probe.cpp", impl)
    val ok2 = rt_file_write_text("/tmp/probe.h", hdr)
    print "WROTE_CPP={ok1} WROTE_H={ok2} IMPL_LEN={impl.len()} HDR_LEN={hdr.len()}"
