use std.spec.*

use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.backend.backend.riscv_target.{riscv_linux_target_contract}
use compiler.backend.native.{R_RISCV_CALL_PLT}
use compiler.backend.native.encode_riscv64.{encode_li_riscv64}
use compiler.backend.native.riscv_encoding.{
    riscv_emit_u32_le, riscv_encode_u_type,
    emit_rol_riscv64, emit_ror_riscv64,
    emit_clz_riscv64, emit_ctz_riscv64, emit_cpop_riscv64,
    emit_rev8_riscv64, emit_brev8_riscv64
}

describe "Encode Riscv64":
    it "shares the Linux call relocation and ABI contract":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
        expect(R_RISCV_CALL_PLT).to_equal(19)
        expect(contract.call_plt_reloc).to_equal(19)
        expect(contract.abi_text()).to_equal("lp64d")
        expect(contract.march).to_equal("rv64gc")

    it "encodes RV64 U-type LUI and AUIPC words":
        expect(riscv_emit_u32_le([], riscv_encode_u_type(0x12345, 1, 0x37))).to_equal([0xB7, 0x50, 0x34, 0x12])
        expect(riscv_emit_u32_le([], riscv_encode_u_type(0x12345, 1, 0x17))).to_equal([0x97, 0x50, 0x34, 0x12])

    it "expands RV64 LI as ADDI or LUI plus ADDI":
        expect(encode_li_riscv64([], 1, 42)).to_equal([0x93, 0x00, 0xA0, 0x02])
        expect(encode_li_riscv64([], 1, 4097)).to_equal([0xB7, 0x10, 0x00, 0x00, 0x93, 0x80, 0x10, 0x00])

describe "Encode Riscv64 scalar bitmanip":
    it "encodes rol":
        expect(emit_rol_riscv64(1, 2, 3)).to_equal([0xB3, 0x10, 0x31, 0x60])

    it "encodes ror":
        expect(emit_ror_riscv64(1, 2, 3)).to_equal([0xB3, 0x50, 0x31, 0x60])

    it "encodes clz/ctz/cpop":
        expect(emit_clz_riscv64(1, 2)).to_equal([0x93, 0x10, 0x01, 0x60])
        expect(emit_ctz_riscv64(1, 2)).to_equal([0x93, 0x10, 0x11, 0x60])
        expect(emit_cpop_riscv64(1, 2)).to_equal([0x93, 0x10, 0x21, 0x60])

    it "encodes rev8 and brev8":
        expect(emit_rev8_riscv64(1, 2)).to_equal([0x93, 0x50, 0x81, 0x6B])
        expect(emit_brev8_riscv64(1, 2)).to_equal([0x93, 0x50, 0x71, 0x68])
