use std.spec.*

use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.backend.backend.riscv_target.{riscv_linux_target_contract}
use compiler.backend.native.{encode_module_rv32}
use compiler.backend.native.encode_riscv32.{ELF32_EI_CLASS, ELF32_HEADER_SIZE, RV32_R_RISCV_CALL_PLT, encode_li_rv32}
use compiler.backend.native.mach_inst.{MachBlock, MachFunction, MachModule, RV_OP_ADD, RV_OP_BEQ, RV_OP_BGE, RV_OP_BLT, RV_OP_BNE, RV_OP_CALL, RV_OP_JAL, RV_OP_JALR, RV_OP_LW, RV_OP_MUL, RV_OP_NEG, RV_OP_NOP, RV_OP_NOT, RV_OP_SEQZ, RV_OP_SNEZ, RV_OP_SRA, RV_OP_SUB, RV_OP_SW, RV_X1, RV_X2, RV_X3, new_mach_inst, op_imm, op_label, op_mem, op_phys, op_sym, physical_reg}
use compiler.backend.native.riscv_encoding.{riscv_emit_u32_le, riscv_encode_b_type, riscv_encode_i_type, riscv_encode_j_type, riscv_encode_r_type, riscv_encode_s_type, riscv_encode_u_type}

fn rv32_backward_patch_module() -> MachModule:
    val start = MachBlock(label: "start", insts: [new_mach_inst(RV_OP_NOP, [])], block_id: 0, offset: 0)
    val back = MachBlock(
        label: "back",
        insts: [
            new_mach_inst(RV_OP_BEQ, [op_phys(RV_X1), op_phys(RV_X2), op_label(0)]),
            new_mach_inst(RV_OP_JAL, [op_phys(RV_X1), op_label(0)])
        ],
        block_id: 1,
        offset: 0
    )
    val func = MachFunction(name: "rv32_backward_patch", blocks: [start, back], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_backward_patch", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_forward_patch_module() -> MachModule:
    val start = MachBlock(
        label: "start",
        insts: [
            new_mach_inst(RV_OP_BEQ, [op_phys(RV_X1), op_phys(RV_X2), op_label(1)]),
            new_mach_inst(RV_OP_JAL, [op_phys(RV_X1), op_label(1)])
        ],
        block_id: 0,
        offset: 0
    )
    val target = MachBlock(label: "target", insts: [new_mach_inst(RV_OP_NOP, [])], block_id: 1, offset: 0)
    val func = MachFunction(name: "rv32_forward_patch", blocks: [start, target], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_forward_patch", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_malformed_jump_module() -> MachModule:
    val block = MachBlock(
        label: "entry",
        insts: [
            new_mach_inst(RV_OP_BEQ, [op_phys(RV_X1), op_phys(RV_X2), op_imm(99)]),
            new_mach_inst(RV_OP_JAL, [op_phys(RV_X1), op_sym("bad_target")])
        ],
        block_id: 0,
        offset: 0
    )
    val func = MachFunction(name: "rv32_malformed_jump", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_malformed_jump", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_branch_funct_module() -> MachModule:
    val start = MachBlock(
        label: "start",
        insts: [
            new_mach_inst(RV_OP_BNE, [op_phys(RV_X1), op_phys(RV_X2), op_label(1)]),
            new_mach_inst(RV_OP_BLT, [op_phys(RV_X1), op_phys(RV_X2), op_label(1)]),
            new_mach_inst(RV_OP_BGE, [op_phys(RV_X1), op_phys(RV_X2), op_label(1)])
        ],
        block_id: 0,
        offset: 0
    )
    val target = MachBlock(label: "target", insts: [new_mach_inst(RV_OP_NOP, [])], block_id: 1, offset: 0)
    val func = MachFunction(name: "rv32_branch_funct", blocks: [start, target], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_branch_funct", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_alu_module() -> MachModule:
    val block = MachBlock(
        label: "entry",
        insts: [
            new_mach_inst(RV_OP_ADD, [op_phys(RV_X1), op_phys(RV_X2), op_phys(RV_X3)]),
            new_mach_inst(RV_OP_SUB, [op_phys(RV_X1), op_phys(RV_X2), op_phys(RV_X3)]),
            new_mach_inst(RV_OP_MUL, [op_phys(RV_X1), op_phys(RV_X2), op_phys(RV_X3)]),
            new_mach_inst(RV_OP_SRA, [op_phys(RV_X1), op_phys(RV_X2), op_phys(RV_X3)])
        ],
        block_id: 0,
        offset: 0
    )
    val func = MachFunction(name: "rv32_alu", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_alu", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_pseudo_alu_module() -> MachModule:
    val block = MachBlock(
        label: "entry",
        insts: [
            new_mach_inst(RV_OP_NEG, [op_phys(RV_X1), op_phys(RV_X2)]),
            new_mach_inst(RV_OP_NOT, [op_phys(RV_X1), op_phys(RV_X2)]),
            new_mach_inst(RV_OP_SEQZ, [op_phys(RV_X1), op_phys(RV_X2)]),
            new_mach_inst(RV_OP_SNEZ, [op_phys(RV_X1), op_phys(RV_X2)])
        ],
        block_id: 0,
        offset: 0
    )
    val func = MachFunction(name: "rv32_pseudo_alu", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_pseudo_alu", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_memory_offset_module() -> MachModule:
    val block = MachBlock(
        label: "entry",
        insts: [
            new_mach_inst(RV_OP_LW, [op_phys(RV_X1), op_mem(physical_reg(RV_X2), -4)]),
            new_mach_inst(RV_OP_SW, [op_phys(RV_X3), op_mem(physical_reg(RV_X2), -8)])
        ],
        block_id: 0,
        offset: 0
    )
    val func = MachFunction(name: "rv32_memory_offset", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_memory_offset", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_symbol_call_module() -> MachModule:
    val block = MachBlock(label: "entry", insts: [new_mach_inst(RV_OP_CALL, [op_sym("callee")])], block_id: 0, offset: 0)
    val func = MachFunction(name: "rv32_symbol_call", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_symbol_call", functions: [func], data_sections: [], extern_symbols: ["callee"])

fn rv32_label_call_module() -> MachModule:
    val start = MachBlock(label: "start", insts: [new_mach_inst(RV_OP_CALL, [op_label(1)])], block_id: 0, offset: 0)
    val target = MachBlock(label: "target", insts: [new_mach_inst(RV_OP_NOP, [])], block_id: 1, offset: 0)
    val func = MachFunction(name: "rv32_label_call", blocks: [start, target], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_label_call", functions: [func], data_sections: [], extern_symbols: [])

fn rv32_jalr_module() -> MachModule:
    val block = MachBlock(label: "entry", insts: [new_mach_inst(RV_OP_JALR, [op_phys(RV_X1), op_phys(RV_X2), op_imm(-4)])], block_id: 0, offset: 0)
    val func = MachFunction(name: "rv32_jalr", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv32_jalr", functions: [func], data_sections: [], extern_symbols: [])

describe "Encode Riscv32":
    it "retains ELF32 constants for the RV32 Linux lane":
        expect(ELF32_EI_CLASS).to_equal(1)
        expect(ELF32_HEADER_SIZE).to_equal(52)

    it "shares the Linux call relocation and ABI contract":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv32)
        expect(contract.call_plt_reloc).to_equal(19)
        expect(contract.abi_text()).to_equal("ilp32d")
        expect(contract.march).to_equal("rv32gc")

    it "encodes RV32 U-type LUI and AUIPC words":
        expect(riscv_emit_u32_le([], riscv_encode_u_type(0x12345, 1, 0x37))).to_equal([0xB7, 0x50, 0x34, 0x12])
        expect(riscv_emit_u32_le([], riscv_encode_u_type(0x12345, 1, 0x17))).to_equal([0x97, 0x50, 0x34, 0x12])

    it "encodes RV32 R-type ADD and SUB words":
        expect(riscv_emit_u32_le([], riscv_encode_r_type(0, 3, 2, 0, 1, 0x33))).to_equal([0xB3, 0x00, 0x31, 0x00])
        expect(riscv_emit_u32_le([], riscv_encode_r_type(0x20, 3, 2, 0, 1, 0x33))).to_equal([0xB3, 0x00, 0x31, 0x40])

    it "encodes RV32 ALU MachInst funct fields":
        val encoded = encode_module_rv32(rv32_alu_module())
        expect(encoded[0].code).to_equal([0xB3, 0x00, 0x31, 0x00, 0xB3, 0x00, 0x31, 0x40, 0xB3, 0x00, 0x31, 0x02, 0xB3, 0x50, 0x31, 0x40])

    it "encodes RV32 pseudo ALU MachInst words":
        val encoded = encode_module_rv32(rv32_pseudo_alu_module())
        expect(encoded[0].code).to_equal([0xB3, 0x00, 0x20, 0x40, 0x93, 0x40, 0xF1, 0xFF, 0x93, 0x30, 0x11, 0x00, 0xB3, 0x30, 0x20, 0x00])

    it "encodes RV32 negative load and store offsets":
        val encoded = encode_module_rv32(rv32_memory_offset_module())
        expect(encoded[0].code).to_equal([0x83, 0x20, 0xC1, 0xFF, 0x23, 0x2C, 0x31, 0xFE])

    it "encodes RV32 symbol calls with CALL_PLT relocation":
        val encoded = encode_module_rv32(rv32_symbol_call_module())
        expect(encoded[0].code).to_equal([0x97, 0x00, 0x00, 0x00, 0xE7, 0x80, 0x00, 0x00])
        expect(encoded[0].relocations.len()).to_equal(1)
        expect(encoded[0].relocations[0].offset).to_equal(0)
        expect(encoded[0].relocations[0].symbol_name).to_equal("callee")
        expect(encoded[0].relocations[0].reloc_type).to_equal(RV32_R_RISCV_CALL_PLT)
        expect(encoded[0].relocations[0].addend).to_equal(0)

    it "encodes RV32 label calls as patched JAL":
        val encoded = encode_module_rv32(rv32_label_call_module())
        expect(encoded[0].code).to_equal([0xEF, 0x00, 0x40, 0x00, 0x13, 0x00, 0x00, 0x00])
        expect(encoded[0].relocations.len()).to_equal(0)

    it "encodes RV32 JALR signed immediates":
        val encoded = encode_module_rv32(rv32_jalr_module())
        expect(encoded[0].code).to_equal([0xE7, 0x00, 0xC1, 0xFF])

    it "expands RV32 LI as ADDI or LUI plus ADDI":
        expect(encode_li_rv32([], 1, 42)).to_equal([0x93, 0x00, 0xA0, 0x02])
        expect(encode_li_rv32([], 1, -1)).to_equal([0x93, 0x00, 0xF0, 0xFF])
        expect(encode_li_rv32([], 1, 4097)).to_equal([0xB7, 0x10, 0x00, 0x00, 0x93, 0x80, 0x10, 0x00])

    it "encodes RV32 store branch and jump immediates":
        expect(riscv_emit_u32_le([], riscv_encode_s_type(20, 2, 1, 2, 0x23))).to_equal([0x23, 0xAA, 0x20, 0x00])
        expect(riscv_emit_u32_le([], riscv_encode_i_type(-1, 2, 0, 1, 0x13))).to_equal([0x93, 0x00, 0xF1, 0xFF])
        expect(riscv_emit_u32_le([], riscv_encode_s_type(-4, 2, 1, 2, 0x23))).to_equal([0x23, 0xAE, 0x20, 0xFE])
        expect(riscv_emit_u32_le([], riscv_encode_b_type(16, 2, 1, 0, 0x63))).to_equal([0x63, 0x88, 0x20, 0x00])
        expect(riscv_emit_u32_le([], riscv_encode_b_type(-4, 2, 1, 0, 0x63))).to_equal([0xE3, 0x8E, 0x20, 0xFE])
        expect(riscv_emit_u32_le([], riscv_encode_j_type(2048, 1, 0x6F))).to_equal([0xEF, 0x00, 0x10, 0x00])
        expect(riscv_emit_u32_le([], riscv_encode_j_type(-2048, 1, 0x6F))).to_equal([0xEF, 0xF0, 0x1F, 0x80])

    it "patches RV32 backward branch and jump labels":
        val encoded = encode_module_rv32(rv32_backward_patch_module())
        expect(encoded[0].code).to_equal([0x13, 0x00, 0x00, 0x00, 0xE3, 0x8E, 0x20, 0xFE, 0xEF, 0xF0, 0x9F, 0xFF])

    it "patches RV32 forward branch and jump labels":
        val encoded = encode_module_rv32(rv32_forward_patch_module())
        expect(encoded[0].code).to_equal([0x63, 0x84, 0x20, 0x00, 0xEF, 0x00, 0x40, 0x00, 0x13, 0x00, 0x00, 0x00])

    it "keeps RV32 malformed branch and jump targets inert":
        val encoded = encode_module_rv32(rv32_malformed_jump_module())
        expect(encoded[0].code).to_equal([0x63, 0x80, 0x20, 0x00, 0xEF, 0x00, 0x00, 0x00])
        expect(encoded[0].relocations.len()).to_equal(0)

    it "encodes RV32 branch funct3 labels":
        val encoded = encode_module_rv32(rv32_branch_funct_module())
        expect(encoded[0].code).to_equal([0x63, 0x96, 0x20, 0x00, 0x63, 0xC4, 0x20, 0x00, 0x63, 0xD2, 0x20, 0x00, 0x13, 0x00, 0x00, 0x00])
