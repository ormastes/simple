fn build_rv32_unsupported_ops_module() -> MirModule:
    val i32_type = MirType(kind: MirTypeKind.I32)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i32_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("left"), type_: i32_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("right"), type_: i32_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("pow"), type_: i32_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 4), name: Some("transpose"), type_: i32_type, kind: LocalKind.Temp)
    ]
    val value = MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1)))
    val entry = MirBlock(
        id: BlockId.new(0),
