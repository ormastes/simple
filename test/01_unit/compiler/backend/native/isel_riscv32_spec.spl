fn build_rv32_alloc_cast_module_with_type(name: text, alloc_type: MirType) -> MirModule:
    val i32_type = MirType(kind: MirTypeKind.I32)
    val unit_type = MirType(kind: MirTypeKind.Unit)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: unit_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("ptr"), type_: alloc_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("value"), type_: i32_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("casted"), type_: i32_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Alloc(LocalId(id: 1), alloc_type), span: nil),
            MirInst(kind: MirInstKind.Const(LocalId(id: 2), MirConstValue.Int(7), i32_type), span: nil),
            MirInst(kind: MirInstKind.Cast(LocalId(id: 3), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2))), i32_type), span: nil)
        ],
        terminator: MirTerminator.Unreachable
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: MirSignature(params: [], return_type: unit_type, is_variadic: false),
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_rv32_alloc_cast_module() -> MirModule:
    val i32_type = MirType(kind: MirTypeKind.I32)
