# Lean Backend Translation Core Specification
#
# Mission-critical bar for a verification-carrying codegen:
# 1. SOUND: constructs the translator cannot faithfully model HARD-FAIL with a
#    named error — never `sorry`, never empty output, never a wrong operator.
# 2. DETERMINISTIC: same input produces byte-identical Lean.
# 3. TOTAL error paths: diagnostics name the offending construct.

use std.spec
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_instructions.{BlockId, MirBlock, MirBody, MirFunction, MirInst, MirInstKind, MirOperand, MirOperandKind, MirTerminator}
use compiler.mir.mir_types.{LocalId, LocalKind, MirBinOp, MirLocal, MirSignature, MirType, MirTypeKind}
use compiler.backend.backend.lean_mir_translate.{translate_mir_body, translate_binop, mir_type_to_lean, sort_mir_functions_by_name}
use compiler.backend.backend.lean_backend.{LeanBuilder}
use compiler.backend.backend.backend_types.{CompileError}

# ============================================================================
# Fixtures
# ============================================================================

fn local(id: i64, kind: LocalKind) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: MirType.i64(), kind: kind, is_ghost: false)

fn copy_operand(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(LocalId(id: id)))

fn add_body() -> MirBody:
    """fn add(arg0, arg1) -> i64 { _l2 = _l0 + _l1; return _l2 }"""
    MirBody(
        name: "add",
        blocks: [
            MirBlock(
                id: BlockId(id: 0),
                label: Some("entry"),
                instructions: [
                    MirInst(
                        kind: MirInstKind.BinOp(LocalId(id: 2), MirBinOp.Add, copy_operand(0), copy_operand(1)),
                        span: nil
                    )
                ],
                terminator: MirTerminator.Ret(Some(copy_operand(2)))
            )
        ],
        locals: [
            local(0, LocalKind.Arg(0)),
            local(1, LocalKind.Arg(1)),
            local(2, LocalKind.Temp)
        ],
        arg_count: 2,
        return_ty: MirType.i64()
    )

fn body_with_terminator(term: MirTerminator) -> MirBody:
    MirBody(
        name: "fixture",
        blocks: [
            MirBlock(id: BlockId(id: 0), label: nil, instructions: [], terminator: term)
        ],
        locals: [local(0, LocalKind.Temp)],
        arg_count: 0,
        return_ty: MirType.unit()
    )

fn named_fn(name: text) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: 9001),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.i64(), is_variadic: false),
        locals: [local(0, LocalKind.Temp)],
        blocks: [
            MirBlock(
                id: BlockId(id: 0),
                label: nil,
                instructions: [],
                terminator: MirTerminator.Ret(Some(copy_operand(0)))
            )
        ],
        entry_block: BlockId(id: 0),
        span: Span.default(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn ok_text(r: Result<text, CompileError>) -> text:
    match r:
        case Ok(code): code
        case Err(_): ""

fn err_text(r: Result<text, CompileError>) -> text:
    match r:
        case Ok(_): ""
        case Err(e): e.message

# ============================================================================
# Specs
# ============================================================================

describe "Lean backend translation core":
    it "builds emitted lines with newline separators":
        var builder = LeanBuilder.create()
        builder.emit("first")
        builder.emit("second")
        expect(builder.build()).to_equal("first\nsecond")

    context "end-to-end translation":
        it "translates a tiny add function into a Lean let-chain returning the result":
            val code = ok_text(translate_mir_body(add_body()))
            expect(code).to_contain("let _l2 := _l0 + _l1")
            expect(code).to_contain("_l2")
            expect(code.contains("sorry")).to_equal(false)

        it "preserves signedness and width in Lean type mapping":
            expect(ok_text(mir_type_to_lean(MirType(kind: MirTypeKind.I64)))).to_equal("Int")
            expect(ok_text(mir_type_to_lean(MirType(kind: MirTypeKind.I32)))).to_equal("Int32")
            expect(ok_text(mir_type_to_lean(MirType(kind: MirTypeKind.U32)))).to_equal("UInt32")
            expect(ok_text(mir_type_to_lean(MirType(kind: MirTypeKind.U8)))).to_equal("UInt8")
            expect(ok_text(mir_type_to_lean(MirType(kind: MirTypeKind.F32)))).to_equal("Float32")
            expect(ok_text(mir_type_to_lean(MirType(kind: MirTypeKind.F64)))).to_equal("Float")

    context "deterministic output":
        it "produces byte-identical Lean for repeated translation of the same MIR":
            val first = ok_text(translate_mir_body(add_body()))
            val second = ok_text(translate_mir_body(add_body()))
            expect(first != "").to_equal(true)
            expect(first).to_equal(second)

        it "orders functions by name regardless of input order":
            val forward = sort_mir_functions_by_name([named_fn("alpha"), named_fn("beta"), named_fn("gamma")])
            val reversed = sort_mir_functions_by_name([named_fn("gamma"), named_fn("beta"), named_fn("alpha")])
            expect(forward.len()).to_equal(3)
            expect(forward[0].name).to_equal("alpha")
            expect(forward[1].name).to_equal("beta")
            expect(forward[2].name).to_equal("gamma")
            expect(reversed[0].name).to_equal("alpha")
            expect(reversed[1].name).to_equal("beta")
            expect(reversed[2].name).to_equal("gamma")

    context "unsupported constructs hard-fail with named errors":
        it "rejects a body with no basic blocks instead of emitting sorry":
            val empty = MirBody(name: "ghost", blocks: [], locals: [], arg_count: 0, return_ty: MirType.unit())
            val msg = err_text(translate_mir_body(empty))
            expect(msg).to_contain("ghost")
            expect(msg).to_contain("no MIR basic blocks")

        it "rejects unstructured goto control flow, naming the target block":
            val msg = err_text(translate_mir_body(body_with_terminator(MirTerminator.Goto(BlockId(id: 7)))))
            expect(msg).to_contain("block7")
            expect(msg).to_contain("structured-CFG")

        it "rejects conditional branches that the flat translator cannot model":
            val term = MirTerminator.If(copy_operand(0), BlockId(id: 1), BlockId(id: 2))
            val msg = err_text(translate_mir_body(body_with_terminator(term)))
            expect(msg).to_contain("structured-CFG")

        it "rejects binary operators with no faithful scalar Lean operator":
            expect(err_text(translate_binop(MirBinOp.MatMul))).to_contain("binary operator")
            expect(err_text(translate_binop(MirBinOp.BroadcastAdd))).to_contain("binary operator")
            expect(ok_text(translate_binop(MirBinOp.Shr))).to_equal(">>>")

        it "rejects MIR types with no faithful Lean representation":
            val msg = err_text(mir_type_to_lean(MirType(kind: MirTypeKind.Vec4f)))
            expect(msg).to_contain("no faithful Lean")
