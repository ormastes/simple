use compiler.backend.backend.stage4_symbol_closure.{stage4_requested_from_nm_output, stage4_select_requested_archive_indices, stage4_resolve_requested_archive_owners, stage4_link_profile_fingerprint_input}
use std.spec.{describe, it, expect}

extern fn rt_file_read_text(path: text) -> text

describe "Stage4 aggregate final symbol closure":
    it "subtracts sibling definitions and returns sorted unique runtime requests":
        val rows = """
first.o:
                 U rt_cross
                 U rt_need
                 U rt_need
                 U user_helper
                 U rt_unique
                 U rt_weak_lower_fn
                 w rt_weak_lower_fn
                 U rt_weak_lower_data
                 v rt_weak_lower_data
                 U rt_weak_upper_fn
                 W rt_weak_upper_fn
                 U rt_weak_upper_data
                 V rt_weak_upper_data
                 U rt_weak_defined
                 U rt_malformed
second.o:
0000000000000000 T rt_cross
0000000000000000 u rt_unique
0000000000000000 W rt_weak_defined
                 U spl_init_args
                 u rt_malformed
not-an-address W rt_malformed
"""
        val requested = stage4_requested_from_nm_output(rows, false)
        expect(requested.len()).to_equal(7)
        expect(requested[0]).to_equal("rt_malformed")
        expect(requested[1]).to_equal("rt_need")
        expect(requested[2]).to_equal("rt_weak_lower_data")
        expect(requested[3]).to_equal("rt_weak_lower_fn")
        expect(requested[4]).to_equal("rt_weak_upper_data")
        expect(requested[5]).to_equal("rt_weak_upper_fn")
        expect(requested[6]).to_equal("spl_init_args")

    it "normalizes the leading object underscore only for Mach-O":
        val rows = "                 U _spl_init_args\n"
        val macho = stage4_requested_from_nm_output(rows, true)
        val elf = stage4_requested_from_nm_output(rows, false)
        expect(macho.len()).to_equal(1)
        expect(macho[0]).to_equal("spl_init_args")
        expect(elf.len()).to_equal(0)

    it "derives after the entry object and before the shared final link":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val entry_pos = source.find("val entry_obj_path = match c_result")
        val closure_pos = source.find("match llvm_stage4_final_requested_symbols(final_simple_objects)")
        val link_pos = source.find("val link_result = link_to_native(all_objects, output, link_config)")
        expect(entry_pos).to_be_greater_than(-1)
        expect(closure_pos).to_be_greater_than(entry_pos)
        expect(link_pos).to_be_greater_than(closure_pos)
        expect(source).to_contain("Stage4 strict profile rejects libsimple_native_all.a")

    it "selects uniquely owning archives in declared order":
        val result = stage4_select_requested_archive_indices(
            ["rt_a", "rt_b", "rt_a"],
            ["provider-b", "provider-a", "unused"],
            ["0000000000000000 T rt_b", "0000000000000000 T rt_a", "0000000000000000 T rt_unused"],
            false
        ).unwrap()
        expect(result.len()).to_equal(2)
        expect(result[0]).to_equal(0)
        expect(result[1]).to_equal(1)

    it "normalizes Mach-O provider definitions":
        val result = stage4_select_requested_archive_indices(
            ["rt_need"], ["provider"], ["0000000000000000 T _rt_need"], true
        ).unwrap()
        expect(result.len()).to_equal(1)
        expect(result[0]).to_equal(0)

    it "rejects missing and repeated owners":
        val missing = stage4_select_requested_archive_indices(
            ["rt_missing"], ["core-c"], ["0000000000000000 T rt_other"], false
        )
        val repeated = stage4_select_requested_archive_indices(
            ["rt_need"], ["provider"], ["0000000000000000 T rt_need\n0000000000000001 T rt_need"], false
        )
        expect(missing.unwrap_err()).to_contain("has no archive owner")
        expect(repeated.unwrap_err()).to_contain("repeats global definition")

    it "rejects core-C and component-provider overlap":
        val overlap = stage4_select_requested_archive_indices(
            ["spl_memtrack_init"],
            ["core-c", "memtrack"],
            ["0000000000000000 T spl_memtrack_init", "0000000000000000 T spl_memtrack_init"],
            false
        )
        expect(overlap.unwrap_err()).to_contain("overlaps archives")

    it "rejects empty and mismatched candidate inputs":
        val empty_requested = stage4_select_requested_archive_indices([], ["core-c"], ["0000000000000000 T rt_a"], false)
        val mismatched = stage4_select_requested_archive_indices(["rt_a"], ["core-c"], [], false)
        val empty_archive = stage4_select_requested_archive_indices(["rt_a"], ["core-c"], [""], false)
        val duplicate_label = stage4_select_requested_archive_indices(
            ["rt_a"], ["core-c", "core-c"], ["0000000000000000 T rt_a", "0000000000000000 T rt_b"], false
        )
        expect(empty_requested.is_err()).to_equal(true)
        expect(mismatched.is_err()).to_equal(true)
        expect(empty_archive.is_err()).to_equal(true)
        expect(duplicate_label.is_err()).to_equal(true)

    it "resolves sorted unique owner rows without changing selected indices":
        val requested = ["rt_b", "rt_a", "rt_b"]
        val labels = ["provider-b", "provider-a", "unused"]
        val scans = [
            "0000000000000000 T rt_b",
            "0000000000000000 T rt_a",
            "0000000000000000 T rt_unused"
        ]
        val selected_before = stage4_select_requested_archive_indices(requested, labels, scans, false).unwrap()
        val (selected, owner_rows) = stage4_resolve_requested_archive_owners(requested, labels, scans, false).unwrap()
        expect(selected.len()).to_equal(selected_before.len())
        expect(selected[0]).to_equal(selected_before[0])
        expect(selected[1]).to_equal(selected_before[1])
        expect(owner_rows.len()).to_equal(2)
        expect(owner_rows[0]).to_equal("rt_a=provider-a")
        expect(owner_rows[1]).to_equal("rt_b=provider-b")

    it "canonicalizes link-profile row permutations":
        val first = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-hash",
            ["src/b.spl=source-b", "src/a.spl=source-a"],
            ["provider-z=archive-z", "provider-a=archive-a"],
            ["rt_z=provider-z", "rt_a=provider-a"]
        ).unwrap()
        val permuted = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-hash",
            ["src/a.spl=source-a", "src/b.spl=source-b"],
            ["provider-a=archive-a", "provider-z=archive-z"],
            ["rt_a=provider-a", "rt_z=provider-z"]
        ).unwrap()
        expect(permuted).to_equal(first)

    it "includes every scalar and named-row group in the link-profile input":
        val base = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val target = stage4_link_profile_fingerprint_input(
            "aarch64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val backend = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "cranelift", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val options = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=2,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val compiler = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-b",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val sources = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-b"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val archives = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-b"], ["rt_need=core-c"]
        ).unwrap()
        val owners = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=compiler"]
        ).unwrap()
        expect(target == base).to_be(false)
        expect(backend == base).to_be(false)
        expect(options == base).to_be(false)
        expect(compiler == base).to_be(false)
        expect(sources == base).to_be(false)
        expect(archives == base).to_be(false)
        expect(owners == base).to_be(false)

    it "fails closed on missing malformed and duplicate named rows":
        val missing = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3", "compiler-a",
            [], ["core-c=archive-a"], ["rt_need=core-c"]
        )
        val malformed = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3", "compiler-a",
            ["src/main.spl=source-a"], ["core-c"], ["rt_need=core-c"]
        )
        val duplicate = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"],
            ["rt_need=core-c", "rt_need=compiler"]
        )
        expect(missing.is_err()).to_be(true)
        expect(malformed.is_err()).to_be(true)
        expect(duplicate.is_err()).to_be(true)
