            ["C:\\stage4\\simple_compiler_backfill.LIB", "C:\\stage4\\simple_stage4_font.lib"],
            true
        )
        expect(unix.is_ok()).to_be(true)
        expect(windows.is_ok()).to_be(true)

    it "rejects incomplete ambiguous and forbidden archive inventories":
        val empty = stage4_validate_candidate_archive_inputs([], [])
        val mismatched = stage4_validate_candidate_archive_inputs(
            ["compiler", "timestamp"], ["/stage4/libsimple_compiler_backfill.a"]
        )
        val duplicate_label = stage4_validate_candidate_archive_inputs(
            ["compiler", "compiler"],
            ["/stage4/libsimple_compiler_backfill.a", "/stage4/libsimple_stage4_time.a"]
        )
        val duplicate_path = stage4_validate_candidate_archive_inputs(
            ["compiler", "compiler-copy"],
            ["/stage4/libsimple_compiler_backfill.a", "/stage4/libsimple_compiler_backfill.a"]
        )
        val windows_duplicate_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["C:\\Stage4\\Provider.LIB", "c:/stage4/provider.lib"],
            true
        )
        val windows_duplicate_a_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["C:\\Stage4\\Provider.A", "c:/stage4/provider.a"],
            true
        )
