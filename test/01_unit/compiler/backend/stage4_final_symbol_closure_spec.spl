use compiler.backend.backend.stage4_symbol_closure.{stage4_dynload_provider_archive_file, stage4_dynload_provider_object_format, stage4_validate_dynload_provider_symbol_contract, stage4_forbidden_archive_sections, stage4_requested_from_nm_output, stage4_select_requested_archive_indices, stage4_resolve_requested_archive_owners, stage4_link_profile_fingerprint_input, stage4_validate_candidate_archive_inputs, stage4_validate_candidate_archive_inputs_for_platform}
use std.spec.{describe, it, expect}

extern fn rt_file_read_text(path: text) -> text

describe "Stage4 aggregate final symbol closure":
    it "uses seed-safe canonical ordering instead of the seed no-op sort":
        val source = rt_file_read_text("src/compiler/70.backend/backend/stage4_symbol_closure.spl") ?? ""
        expect(source).to_contain("fn stage4_sorted_text")
        expect(source.contains(".sort()")).to_be(false)

    it "defines target-explicit dynamic-loader archive identities without building them":
        expect(stage4_dynload_provider_archive_file("linux", false).unwrap()).to_equal("libsimple_stage4_dynload.a")
        expect(stage4_dynload_provider_archive_file("macos", false).unwrap()).to_equal("libsimple_stage4_dynload.a")
        expect(stage4_dynload_provider_archive_file("freebsd", false).unwrap()).to_equal("libsimple_stage4_dynload.a")
        expect(stage4_dynload_provider_archive_file("windows", false).unwrap()).to_equal("libsimple_stage4_dynload.a")
        expect(stage4_dynload_provider_archive_file("windows", true).unwrap()).to_equal("simple_stage4_dynload.lib")
        expect(stage4_dynload_provider_archive_file("linux", true).is_err()).to_be(true)
        expect(stage4_dynload_provider_archive_file("plan9", false).is_err()).to_be(true)

    it "maps hosted dynamic-loader objects to exact portable nm contracts":
        expect(stage4_dynload_provider_object_format("linux", false).unwrap()).to_equal("elf")
        expect(stage4_dynload_provider_object_format("freebsd", false).unwrap()).to_equal("elf")
        expect(stage4_dynload_provider_object_format("macos", false).unwrap()).to_equal("macho")
        expect(stage4_dynload_provider_object_format("windows", false).unwrap()).to_equal("coff-mingw")
        expect(stage4_dynload_provider_object_format("windows", true).unwrap()).to_equal("coff-msvc")
        expect(stage4_dynload_provider_object_format("linux", true).is_err()).to_be(true)
        expect(stage4_dynload_provider_object_format("plan9", false).is_err()).to_be(true)

    it "accepts exact ELF Mach-O and COFF dynamic-loader provider contracts":
        val elf = "0000000000000000 T spl_dlopen\n0000000000000010 T spl_dlsym\n0000000000000020 T spl_dlclose\n                 U rt_interp_cstr\n                 U dlopen\n                 U dlsym\n                 U dlclose"
        val macho = "0000000000000000 T _spl_dlopen\n0000000000000010 T _spl_dlsym\n0000000000000020 T _spl_dlclose\n                 U _rt_interp_cstr\n                 U _dlopen\n                 U _dlsym\n                 U _dlclose"
        val msvc = "00000000 T spl_dlopen\n00000010 T spl_dlsym\n00000020 T spl_dlclose\n00000000 A @feat.00\n         U rt_interp_cstr\n         U __imp_LoadLibraryA\n         U __imp_GetProcAddress\n         U __imp_FreeLibrary"
        val mingw = "00000000 T _spl_dlopen\n00000010 T _spl_dlsym\n00000020 T _spl_dlclose\n         U _rt_interp_cstr\n         U __imp__LoadLibraryA@4\n         U __imp__GetProcAddress@8\n         U __imp__FreeLibrary@4"
        expect(stage4_validate_dynload_provider_symbol_contract(elf, "elf").is_ok()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(macho, "macho").is_ok()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(msvc, "coff-msvc").is_ok()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(mingw, "coff-mingw").is_ok()).to_be(true)

    it "rejects incomplete extra repeated and unknown dynamic-loader provider contracts":
        val exact = "0000000000000000 T spl_dlopen\n0000000000000010 T spl_dlsym\n0000000000000020 T spl_dlclose\n                 U rt_interp_cstr\n                 U dlopen\n                 U dlsym\n                 U dlclose"
        val missing = exact.replace("0000000000000020 T spl_dlclose\n", "")
        val extra_definition = exact + "\n0000000000000030 T spl_hidden"
        val extra_undefined = exact + "\n                 U __stack_chk_fail"
        val repeated = exact + "\n0000000000000040 T spl_dlopen"
        val repeated_undefined = exact + "\n                 U dlopen"
        val coff = "00000000 T spl_dlopen\n00000010 T spl_dlsym\n00000020 T spl_dlclose\n00000000 A @feat.00\n         U rt_interp_cstr\n         U __imp_LoadLibraryA\n         U __imp_GetProcAddress\n         U __imp_FreeLibrary"
        val false_decoration = coff.replace("__imp_LoadLibraryA", "__imp_LoadLibraryA@evil")
        val wrong_arity = coff.replace("__imp_LoadLibraryA", "__imp_LoadLibraryA@8")
        val repeated_import_alias = coff + "\n         U LoadLibraryA"
        expect(stage4_validate_dynload_provider_symbol_contract(missing, "elf").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(extra_definition, "elf").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(extra_undefined, "elf").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(repeated, "elf").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(repeated_undefined, "elf").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(false_decoration, "coff-msvc").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(wrong_arity, "coff-msvc").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(repeated_import_alias, "coff-msvc").is_err()).to_be(true)
        expect(stage4_validate_dynload_provider_symbol_contract(exact, "wasm").is_err()).to_be(true)

    it "rejects hosted constructor and destructor section families":
        val headers = ".preinit_array .init_array.42 .ctors .fini_array .dtors __mod_init_func __mod_term_func .CRT$XIA .CRT$XCU .CRT$XPU .CRT$XTU .CRT$XLB"
        val found = stage4_forbidden_archive_sections(headers)
        val joined = found.join(" ")
        expect(joined).to_contain(".preinit_array")
        expect(joined).to_contain(".init_array")
        expect(joined).to_contain(".ctors")
        expect(joined).to_contain(".fini_array")
        expect(joined).to_contain(".dtors")
        expect(joined).to_contain("__mod_init_func")
        expect(joined).to_contain("__mod_term_func")
        expect(joined).to_contain(".CRT$XI")
        expect(joined).to_contain(".CRT$XC")
        expect(joined).to_contain(".CRT$XP")
        expect(joined).to_contain(".CRT$XT")
        expect(joined).to_contain(".CRT$XL")
        expect(stage4_forbidden_archive_sections(".text .data .bss").len()).to_equal(0)

    it "subtracts sibling definitions and returns sorted unique runtime requests":
        val rows = """
first.o:
                 U rt_cross
                 U rt_need
                 U rt_need
                 U user_helper
                 U rt_unique
                 U rt_weak_lower_fn
                 w rt_weak_lower_fn
                 U rt_weak_lower_data
                 v rt_weak_lower_data
                 U rt_weak_upper_fn
                 W rt_weak_upper_fn
                 U rt_weak_upper_data
                 V rt_weak_upper_data
                 U rt_weak_defined
                 U rt_malformed
second.o:
0000000000000000 T rt_cross
0000000000000000 u rt_unique
0000000000000000 W rt_weak_defined
                 U spl_init_args
                 u rt_malformed
not-an-address W rt_malformed
"""
        val requested = stage4_requested_from_nm_output(rows, false)
        expect(requested.len()).to_equal(7)
        expect(requested[0]).to_equal("rt_malformed")
        expect(requested[1]).to_equal("rt_need")
        expect(requested[2]).to_equal("rt_weak_lower_data")
        expect(requested[3]).to_equal("rt_weak_lower_fn")
        expect(requested[4]).to_equal("rt_weak_upper_data")
        expect(requested[5]).to_equal("rt_weak_upper_fn")
        expect(requested[6]).to_equal("spl_init_args")

    it "normalizes the leading object underscore only for Mach-O":
        val rows = "                 U _spl_init_args\n"
        val macho = stage4_requested_from_nm_output(rows, true)
        val elf = stage4_requested_from_nm_output(rows, false)
        expect(macho.len()).to_equal(1)
        expect(macho[0]).to_equal("spl_init_args")
        expect(elf.len()).to_equal(0)

    it "derives after the entry object and before the shared final link":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val entry_pos = source.find("val entry_obj_path = match c_result")
        val closure_pos = source.find("match llvm_stage4_final_requested_symbols(final_simple_objects)")
        val link_pos = source.find("val link_result = link_to_native(all_objects, output, link_config)")
        expect(entry_pos).to_be_greater_than(-1)
        expect(closure_pos).to_be_greater_than(entry_pos)
        expect(link_pos).to_be_greater_than(closure_pos)
        expect(source).to_contain("Stage4 strict profile rejects libsimple_native_all.a")

    it "fails closed before shared linking while archive composition is unwired":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val closure_pos = source.find("match llvm_stage4_final_requested_symbols(final_simple_objects)")
        val barrier_pos = source.find("Stage4 strict archive composition is unavailable")
        val combine_pos = source.find("# Step 3: Combine all objects and link")
        expect(barrier_pos).to_be_greater_than(closure_pos)
        expect(combine_pos).to_be_greater_than(barrier_pos)
        expect(source).to_contain("cleanup_runtime_objects(runtime_objects)\n        rt_file_delete(entry_obj_path)\n        if bootstrap_support_obj != \"\":\n            rt_file_delete(bootstrap_support_obj)\n        return Err(\"Stage4 strict archive composition is unavailable")

    it "selects uniquely owning archives in declared order":
        val result = stage4_select_requested_archive_indices(
            ["rt_a", "rt_b", "rt_a"],
            ["provider-b", "provider-a", "unused"],
            ["0000000000000000 T rt_b", "0000000000000000 T rt_a", "0000000000000000 T rt_unused"],
            false
        ).unwrap()
        expect(result.len()).to_equal(2)
        expect(result[0]).to_equal(0)
        expect(result[1]).to_equal(1)

    it "normalizes Mach-O provider definitions":
        val result = stage4_select_requested_archive_indices(
            ["rt_need"], ["provider"], ["0000000000000000 T _rt_need"], true
        ).unwrap()
        expect(result.len()).to_equal(1)
        expect(result[0]).to_equal(0)

    it "rejects missing and repeated owners":
        val missing = stage4_select_requested_archive_indices(
            ["rt_missing"], ["core-c"], ["0000000000000000 T rt_other"], false
        )
        val repeated = stage4_select_requested_archive_indices(
            ["rt_need"], ["provider"], ["0000000000000000 T rt_need\n0000000000000001 T rt_need"], false
        )
        expect(missing.unwrap_err()).to_contain("has no archive owner")
        expect(repeated.unwrap_err()).to_contain("repeats global definition")

    it "rejects core-C and component-provider overlap":
        val overlap = stage4_select_requested_archive_indices(
            ["spl_memtrack_init"],
            ["core-c", "memtrack"],
            ["0000000000000000 T spl_memtrack_init", "0000000000000000 T spl_memtrack_init"],
            false
        )
        expect(overlap.unwrap_err()).to_contain("overlaps archives")

    it "rejects empty and mismatched candidate inputs":
        val empty_requested = stage4_select_requested_archive_indices([], ["core-c"], ["0000000000000000 T rt_a"], false)
        val mismatched = stage4_select_requested_archive_indices(["rt_a"], ["core-c"], [], false)
        val empty_archive = stage4_select_requested_archive_indices(["rt_a"], ["core-c"], [""], false)
        val duplicate_label = stage4_select_requested_archive_indices(
            ["rt_a"], ["core-c", "core-c"], ["0000000000000000 T rt_a", "0000000000000000 T rt_b"], false
        )
        expect(empty_requested.is_err()).to_equal(true)
        expect(mismatched.is_err()).to_equal(true)
        expect(empty_archive.is_err()).to_equal(true)
        expect(duplicate_label.is_err()).to_equal(true)

    it "resolves sorted unique owner rows without changing selected indices":
        val requested = ["rt_b", "rt_a", "rt_b"]
        val labels = ["provider-b", "provider-a", "unused"]
        val scans = [
            "0000000000000000 T rt_b",
            "0000000000000000 T rt_a",
            "0000000000000000 T rt_unused"
        ]
        val selected_before = stage4_select_requested_archive_indices(requested, labels, scans, false).unwrap()
        val (selected, owner_rows) = stage4_resolve_requested_archive_owners(requested, labels, scans, false).unwrap()
        expect(selected.len()).to_equal(selected_before.len())
        expect(selected[0]).to_equal(selected_before[0])
        expect(selected[1]).to_equal(selected_before[1])
        expect(owner_rows.len()).to_equal(2)
        expect(owner_rows[0]).to_equal("rt_a=provider-a")
        expect(owner_rows[1]).to_equal("rt_b=provider-b")

    it "selects transitive runtime owners and ignores system dependencies":
        val labels = ["core-c", "provider", "unused"]
        val scans = [
            "0000000000000000 T rt_core",
            "0000000000000000 T rt_root\n                 U rt_core\n                 U malloc\n                 U sqlite3_open",
            "0000000000000000 T rt_unused"
        ]
        val (selected, owner_rows) = stage4_resolve_requested_archive_owners(["rt_root"], labels, scans, false).unwrap()
        expect(selected.len()).to_equal(2)
        expect(selected[0]).to_equal(0)
        expect(selected[1]).to_equal(1)
        expect(owner_rows.len()).to_equal(2)
        expect(owner_rows[0]).to_equal("rt_core=core-c")
        expect(owner_rows[1]).to_equal("rt_root=provider")

    it "converges through a cyclic three-archive runtime closure":
        val labels = ["leaf", "middle", "root"]
        val scans = [
            "0000000000000000 T rt_leaf\n                 U rt_root",
            "0000000000000000 T rt_middle\n                 U rt_leaf",
            "0000000000000000 T rt_root\n                 U rt_middle"
        ]
        val (selected, owner_rows) = stage4_resolve_requested_archive_owners(["rt_root"], labels, scans, false).unwrap()
        expect(selected.len()).to_equal(3)
        expect(selected[0]).to_equal(0)
        expect(selected[1]).to_equal(1)
        expect(selected[2]).to_equal(2)
        expect(owner_rows.len()).to_equal(3)

    it "fails selected missing runtime dependencies but ignores unselected ones":
        val labels = ["provider", "unused"]
        val bad_scans = [
            "0000000000000000 T rt_root\n                 U rt_missing",
            "0000000000000000 T rt_unused"
        ]
        val error = stage4_resolve_requested_archive_owners(["rt_root"], labels, bad_scans, false).unwrap_err()
        expect(error).to_contain("archive 'provider' runtime dependency 'rt_missing'")

        val safe_scans = [
            "0000000000000000 T rt_root",
            "0000000000000000 T rt_unused\n                 U rt_missing"
        ]
        val (selected, _) = stage4_resolve_requested_archive_owners(["rt_root"], labels, safe_scans, false).unwrap()
        expect(selected.len()).to_equal(1)
        expect(selected[0]).to_equal(0)

    it "normalizes Mach-O transitive runtime dependencies":
        val labels = ["core-c", "provider"]
        val scans = [
            "0000000000000000 T _rt_dep",
            "0000000000000000 T _rt_root\n                 U _rt_dep"
        ]
        val (selected, owner_rows) = stage4_resolve_requested_archive_owners(["rt_root"], labels, scans, true).unwrap()
        expect(selected.len()).to_equal(2)
        expect(owner_rows[0]).to_equal("rt_dep=core-c")
        expect(owner_rows[1]).to_equal("rt_root=provider")

    it "canonicalizes link-profile row permutations":
        val first = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-hash",
            ["src/b.spl=source-b", "src/a.spl=source-a"],
            ["provider-z=archive-z", "provider-a=archive-a"],
            ["rt_z=provider-z", "rt_a=provider-a"]
        ).unwrap()
        val permuted = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-hash",
            ["src/a.spl=source-a", "src/b.spl=source-b"],
            ["provider-a=archive-a", "provider-z=archive-z"],
            ["rt_a=provider-a", "rt_z=provider-z"]
        ).unwrap()
        expect(permuted).to_equal(first)

    it "includes every scalar and named-row group in the link-profile input":
        val base = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val target = stage4_link_profile_fingerprint_input(
            "aarch64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val backend = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "cranelift", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val options = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=2,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val compiler = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-b",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val sources = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-b"], ["core-c=archive-a"], ["rt_need=core-c"]
        ).unwrap()
        val archives = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-b"], ["rt_need=core-c"]
        ).unwrap()
        val owners = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3,pie=true", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"], ["rt_need=compiler"]
        ).unwrap()
        expect(target == base).to_be(false)
        expect(backend == base).to_be(false)
        expect(options == base).to_be(false)
        expect(compiler == base).to_be(false)
        expect(sources == base).to_be(false)
        expect(archives == base).to_be(false)
        expect(owners == base).to_be(false)

    it "fails closed on missing malformed and duplicate named rows":
        val missing = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3", "compiler-a",
            [], ["core-c=archive-a"], ["rt_need=core-c"]
        )
        val malformed = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3", "compiler-a",
            ["src/main.spl=source-a"], ["core-c"], ["rt_need=core-c"]
        )
        val duplicate = stage4_link_profile_fingerprint_input(
            "x86_64-unknown-linux-gnu", "llvm", "opt=3", "compiler-a",
            ["src/main.spl=source-a"], ["core-c=archive-a"],
            ["rt_need=core-c", "rt_need=compiler"]
        )
        expect(missing.is_err()).to_be(true)
        expect(malformed.is_err()).to_be(true)
        expect(duplicate.is_err()).to_be(true)

    it "accepts explicit Unix and Windows static archive inventories":
        val unix = stage4_validate_candidate_archive_inputs(
            ["compiler", "timestamp", "sqlite", "memtrack"],
            [
                "/stage4/libsimple_compiler_backfill.a",
                "/stage4/LIBSIMPLE_STAGE4_TIME.A",
                "/stage4/libsimple_stage4_sqlite.a",
                "/stage4/libsimple_stage4_memtrack.a"
            ]
        )
        val windows = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "font"],
            ["C:\\stage4\\simple_compiler_backfill.LIB", "C:\\stage4\\simple_stage4_font.lib"],
            true
        )
        expect(unix.is_ok()).to_be(true)
        expect(windows.is_ok()).to_be(true)

    it "rejects incomplete ambiguous and forbidden archive inventories":
        val empty = stage4_validate_candidate_archive_inputs([], [])
        val mismatched = stage4_validate_candidate_archive_inputs(
            ["compiler", "timestamp"], ["/stage4/libsimple_compiler_backfill.a"]
        )
        val duplicate_label = stage4_validate_candidate_archive_inputs(
            ["compiler", "compiler"],
            ["/stage4/libsimple_compiler_backfill.a", "/stage4/libsimple_stage4_time.a"]
        )
        val duplicate_path = stage4_validate_candidate_archive_inputs(
            ["compiler", "compiler-copy"],
            ["/stage4/libsimple_compiler_backfill.a", "/stage4/libsimple_compiler_backfill.a"]
        )
        val windows_duplicate_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["C:\\Stage4\\Provider.LIB", "c:/stage4/provider.lib"],
            true
        )
        val windows_duplicate_a_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["C:\\Stage4\\Provider.A", "c:/stage4/provider.a"],
            true
        )
        val windows_relative_duplicate_a_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["build/Provider.a", "build/provider.a"],
            true
        )
        val unix_relative_case_distinct_a_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["build/Provider.a", "build/provider.a"],
            false
        )
        val windows_relative_duplicate_lib_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["build/Provider.lib", "build/provider.lib"],
            true
        )
        val unix_relative_case_distinct_lib_path = stage4_validate_candidate_archive_inputs_for_platform(
            ["compiler", "compiler-copy"],
            ["build/Provider.lib", "build/provider.lib"],
            false
        )
        val native_all = stage4_validate_candidate_archive_inputs(
            ["runtime"], ["/stage4/LIBSIMPLE_NATIVE_ALL.A"]
        )
        val broad_core = stage4_validate_candidate_archive_inputs(
            ["core-c"], ["/stage4/libsimple_runtime.a"]
        )
        val windows_native_all = stage4_validate_candidate_archive_inputs(
            ["runtime"], ["C:\\stage4\\SIMPLE_NATIVE_ALL.LIB"]
        )
        val windows_broad_core = stage4_validate_candidate_archive_inputs(
            ["core-c"], ["C:\\stage4\\simple_runtime.lib"]
        )
        val shared_object = stage4_validate_candidate_archive_inputs(
            ["provider"], ["/stage4/libprovider.so"]
        )
        val import_archive = stage4_validate_candidate_archive_inputs(
            ["provider"], ["C:\\stage4\\provider.dll.a"]
        )
        expect(empty.is_err()).to_be(true)
        expect(mismatched.is_err()).to_be(true)
        expect(duplicate_label.is_err()).to_be(true)
        expect(duplicate_path.is_err()).to_be(true)
        expect(windows_duplicate_path.is_err()).to_be(true)
        expect(windows_duplicate_a_path.is_err()).to_be(true)
        expect(windows_relative_duplicate_a_path.is_err()).to_be(true)
        expect(unix_relative_case_distinct_a_path.is_ok()).to_be(true)
        expect(windows_relative_duplicate_lib_path.is_err()).to_be(true)
        expect(unix_relative_case_distinct_lib_path.is_ok()).to_be(true)
        expect(native_all.is_err()).to_be(true)
        expect(broad_core.is_err()).to_be(true)
        expect(windows_native_all.is_err()).to_be(true)
        expect(windows_broad_core.is_err()).to_be(true)
        expect(shared_object.is_err()).to_be(true)
        expect(import_archive.is_err()).to_be(true)

    it "discovers the canonical native-all archive name for each hosted OS":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        expect(source).to_contain("if hosted_os == \"windows\": \"simple_native_all.lib\" else: \"libsimple_native_all.a\"")

    it "builds and validates the dedicated dynload archive before the strict fail-closed boundary":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val inventory_pos = source.find("fn llvm_stage4_candidate_archive_inventory")
        val config_pos = source.find("# Configuration")
        expect(inventory_pos).to_be_greater_than(-1)
        expect(config_pos).to_be_greater_than(inventory_pos)
        val inventory_source = source.substring(inventory_pos, config_pos)
        val validate_pos = inventory_source.find("stage4_validate_candidate_archive_inputs_for_platform(")
        val exists_pos = inventory_source.find("rt_file_exists(")
        val resolver_pos = inventory_source.find("find_nm_portable()")
        val section_resolver_pos = inventory_source.find("find_objdump_portable()")
        val section_scan_pos = inventory_source.find("rt_process_run(section_reader")
        val forbidden_pos = inventory_source.find("stage4_forbidden_archive_sections(section_out)")
        val scan_pos = inventory_source.find("rt_process_run(nm")
        expect(validate_pos).to_be_greater_than(-1)
        expect(resolver_pos).to_be_greater_than(validate_pos)
        expect(section_resolver_pos).to_be_greater_than(resolver_pos)
        expect(exists_pos).to_be_greater_than(validate_pos)
        expect(section_scan_pos).to_be_greater_than(exists_pos)
        expect(forbidden_pos).to_be_greater_than(section_scan_pos)
        expect(scan_pos).to_be_greater_than(resolver_pos)
        expect(scan_pos).to_be_greater_than(forbidden_pos)
        expect(inventory_source).to_contain("section scan failed")
        expect(inventory_source).to_contain("section scan was empty")
        expect(inventory_source).to_contain("retained constructor/destructor sections")
        expect(inventory_source).to_contain("stage4_validate_candidate_archive_inputs_for_platform(labels, paths, host_os() == \"windows\")")
        val build_pos = source.find("fn llvm_stage4_build_dynload_provider_archive")
        val production_pos = source.last_index_of("llvm_stage4_build_dynload_provider_archive(runtime_objects, hosted_os, pid)") ?? -1
        val fail_closed_pos = source.find("remaining provider inventory and unique-owner selection are wired")
        val step3_pos = source.find("# Step 3: Combine all objects and link")
        val build_source = source.substring(build_pos, source.find("# Configuration"))
        val copy_pos = build_source.find("file_copy(dynload_objects[0], staged_object)")
        val archive_pos = build_source.find("process_run(archiver, [\"rcsD\", archive_path, staged_object])")
        val list_pos = build_source.find("process_run(archiver, [\"t\", archive_path])")
        val inventory_call_pos = build_source.find("llvm_stage4_candidate_archive_inventory([\"runtime_dynload\"], [archive_path])")
        val contract_pos = build_source.find("stage4_validate_dynload_provider_symbol_contract(scans[0], object_format)")
        expect(build_pos).to_be_greater_than(inventory_pos)
        expect(production_pos).to_be_greater_than(build_pos)
        expect(fail_closed_pos).to_be_greater_than(production_pos)
        expect(step3_pos).to_be_greater_than(fail_closed_pos)
        expect(copy_pos).to_be_greater_than(-1)
        expect(archive_pos).to_be_greater_than(copy_pos)
        expect(list_pos).to_be_greater_than(archive_pos)
        expect(inventory_call_pos).to_be_greater_than(list_pos)
        expect(contract_pos).to_be_greater_than(inventory_call_pos)
        expect(source).to_contain("find_archive_portable()")
        expect(source).to_contain("dynload_objects.len() != 1")
        expect(source).to_contain("file_copy(dynload_objects[0], staged_object)")
        expect(source).to_contain("val expected_member = \"runtime_dynload\" + object_ext")
        expect(source).to_contain("process_run(archiver, [\"rcsD\", archive_path, staged_object])")
        expect(source).to_contain("process_run(archiver, [\"t\", archive_path])")
        expect(source).to_contain("members_out.replace(\"\\r\", \"\").trim()")
        expect(source).to_contain("llvm_stage4_candidate_archive_inventory([\"runtime_dynload\"], [archive_path])")
        expect(source).to_contain("stage4_validate_dynload_provider_symbol_contract(scans[0], object_format)")
        expect(source).to_contain("dir_remove_all(stage_dir)")
        expect(source.contains("runtime_dynload.c")).to_be(false)

    it "routes both Stage4 symbol scans through the portable nm resolver":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val final_pos = source.find("fn llvm_stage4_final_requested_symbols")
        val inventory_pos = source.find("fn llvm_stage4_candidate_archive_inventory")
        val config_pos = source.find("# Configuration")
        val final_source = source.substring(final_pos, inventory_pos)
        val inventory_source = source.substring(inventory_pos, config_pos)
        val section_exit_pos = inventory_source.find("if section_code != 0")
        val section_diagnostic_pos = inventory_source.find("if section_err.trim() != \"\"")
        val forbidden_pos = inventory_source.find("stage4_forbidden_archive_sections(section_out)")
        expect(final_source).to_contain("find_nm_portable()")
        expect(final_source).to_contain("rt_process_run(nm, args)")
        expect(inventory_source).to_contain("find_nm_portable()")
        expect(inventory_source).to_contain("rt_process_run(nm, [\"-g\", path])")
        expect(section_diagnostic_pos).to_be_greater_than(section_exit_pos)
        expect(forbidden_pos).to_be_greater_than(section_diagnostic_pos)
        expect(source.split("section_err.trim() != \"\"").len() - 1).to_equal(1)
        expect(source).to_contain("diagnostics despite exit 0")
        expect(source.split("rt_process_run(\"nm\"").len() - 1).to_equal(0)

    it "keeps the portable nm override and LLVM-first fallback order":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_capability.spl") ?? ""
        val resolver_pos = source.find("pub fn find_nm_portable")
        val detect_pos = source.find("# Detect libLLVM availability")
        val resolver_source = source.substring(resolver_pos, detect_pos)
        val override_pos = resolver_source.find("env_get(\"SIMPLE_NM\")")
        val newest_pos = resolver_source.find("\"llvm-nm-22\"")
        val fallback_pos = resolver_source.find("\"nm\"")
        expect(override_pos).to_be_greater_than(-1)
        expect(newest_pos).to_be_greater_than(override_pos)
        expect(fallback_pos).to_be_greater_than(newest_pos)
        expect(source).to_contain("for path in out.split(\"\\n\")")

    it "keeps the deterministic archiver override and ar-compatible fallbacks":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_capability.spl") ?? ""
        val resolver_pos = source.find("pub fn find_archive_portable")
        val next_pos = source.find("pub fn find_objdump_portable")
        val resolver_source = source.substring(resolver_pos, next_pos)
        val override_pos = resolver_source.find("env_get(\"SIMPLE_AR\")")
        val newest_pos = resolver_source.find("\"llvm-ar-22\"")
        val fallback_pos = resolver_source.last_index_of("\"ar\"") ?? -1
        expect(override_pos).to_be_greater_than(-1)
        expect(newest_pos).to_be_greater_than(override_pos)
        expect(fallback_pos).to_be_greater_than(newest_pos)
        expect(resolver_source.contains("\"lib\"")).to_be(false)

    it "keeps the portable section-reader override and platform-safe fallbacks":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_capability.spl") ?? ""
        val resolver_pos = source.find("pub fn find_objdump_portable")
        val detect_pos = source.find("# Detect libLLVM availability")
        val resolver_source = source.substring(resolver_pos, detect_pos)
        val override_pos = resolver_source.find("env_get(\"SIMPLE_OBJDUMP\")")
        val newest_pos = resolver_source.last_index_of("\"llvm-objdump-22\"") ?? -1
        val readelf_pos = resolver_source.last_index_of("\"readelf\"") ?? -1
        val fallback_pos = resolver_source.last_index_of("\"objdump\"") ?? -1
        expect(override_pos).to_be_greater_than(-1)
        expect(newest_pos).to_be_greater_than(override_pos)
        expect(readelf_pos).to_be_greater_than(newest_pos)
        expect(fallback_pos).to_be_greater_than(readelf_pos)
        expect(resolver_source).to_contain("/opt/homebrew/opt/llvm/bin/llvm-objdump")
