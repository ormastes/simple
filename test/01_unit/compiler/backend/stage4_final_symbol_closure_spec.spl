    it "accepts the exact hosted fork ABI and POSIX memtrack dependencies":
        val exact = "00000000 T rt_fork_child_setup\n00000010 T rt_fork_parent_wait\n00000020 T rt_fork_parent_timed_out\n00000030 T rt_fork_parent_signaled\n00000040 T rt_fork_parent_stdout\n00000050 T rt_fork_parent_stderr\n00000060 T rt_fork_child_exit\n"
