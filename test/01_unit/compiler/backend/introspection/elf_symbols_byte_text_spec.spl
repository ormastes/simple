use std.spec
use compiler.backend.introspection.elf_symbols.{elf_symbol_cstring_to_text}

describe "ELF symbol C-string byte conversion":
    it "decodes symbol bytes without text.from_utf8":
        val decoded = elf_symbol_cstring_to_text([0u8, 95u8, 115u8, 121u8, 109u8, 10u8, 13u8, 9u8, 255u8, 0u8], 1)
        expect(decoded).to_equal("_sym\n\r\t?")
