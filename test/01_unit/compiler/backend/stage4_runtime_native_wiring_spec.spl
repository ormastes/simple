use std.spec.{describe, it, expect}

extern fn rt_file_read_text(path: text) -> text

describe "Stage4 runtime-native wiring":
    it "localizes legacy dynload owners before archive inventory":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val build_start: i64 = source.find("fn llvm_stage4_build_runtime_native_archive(") ?? -1
        val next_start: i64 = source.find("fn llvm_stage4_build_dynload_provider_archive(") ?? -1
        val build_source = if build_start >= 0 and next_start > build_start: source.substring(build_start, next_start) else: ""
        expect(build_start).to_be_greater_than(-1)
        expect(next_start).to_be_greater_than(build_start)

        val match_pos: i64 = build_source.find("stage4_runtime_provider_object_matches(object, \"runtime_native\"") ?? -1
        val raw_scan_pos: i64 = build_source.find("stage4_runtime_native_localization_symbols(raw_nm_out, object_format)") ?? -1
        val objcopy_pos: i64 = build_source.find("\"--localize-symbols=\" + localize_path") ?? -1
        val contract_pos: i64 = build_source.find("stage4_validate_runtime_native_core_symbol_contract(localized_nm_out, object_format)") ?? -1
        val archive_pos: i64 = build_source.find("process_run(archiver, [\"rcsD\", archive_path, localized_object])") ?? -1
        val member_pos: i64 = build_source.find("members != \"runtime_native\" + object_ext") ?? -1
        val inventory_pos: i64 = build_source.find("llvm_stage4_candidate_archive_inventory([\"runtime_native\"], [archive_path])") ?? -1
        expect(match_pos).to_be_greater_than(-1)
        expect(raw_scan_pos).to_be_greater_than(match_pos)
        expect(objcopy_pos).to_be_greater_than(raw_scan_pos)
        expect(contract_pos).to_be_greater_than(objcopy_pos)
        expect(archive_pos).to_be_greater_than(contract_pos)
        expect(member_pos).to_be_greater_than(archive_pos)
        expect(inventory_pos).to_be_greater_than(member_pos)

    it "resolves current owners but retains the projection barrier":
        val source = rt_file_read_text("src/compiler/70.backend/backend/llvm_native_link.spl") ?? ""
        val strict_start: i64 = source.find("var stage4_requested_symbols: [text] = []") ?? -1
        val strict_source = if strict_start >= 0: source.substring(strict_start) else: ""
        val native_pos: i64 = strict_source.find("llvm_stage4_build_runtime_native_archive(") ?? -1
        val labels_pos: i64 = strict_source.find("\"compiler_backfill\", \"runtime_native\", \"runtime_dynload\"") ?? -1
        val owner_pos: i64 = strict_source.find("stage4_resolve_requested_archive_owners(") ?? -1
        val cleanup_pos: i64 = strict_source.find("file_delete(runtime_native_archive)") ?? -1
        val barrier_pos: i64 = strict_source.find("Stage4 strict archive projection is unavailable") ?? -1
        expect(native_pos).to_be_greater_than(-1)
        expect(labels_pos).to_be_greater_than(native_pos)
        expect(owner_pos).to_be_greater_than(labels_pos)
        expect(cleanup_pos).to_be_greater_than(owner_pos)
        expect(barrier_pos).to_be_greater_than(cleanup_pos)
        expect(strict_source).to_contain("if hosted_os != \"windows\":")
