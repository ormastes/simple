use compiler.backend.backend.runtime_compiler.{find_c_compiler, find_runtime_source_dir}
use app.io.mod.{cwd}
use std.io_runtime.{rt_file_read_text}

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text)

fn with_env(key: text, value: text, block: fn()):
    val previous = rt_env_get(key) ?? ""
    rt_env_set(key, value)
    block()
    rt_env_set(key, previous)

describe "Runtime Compiler":
    it "honors SIMPLE_CC override":
        with_env("SIMPLE_NATIVE_BUILD_TARGET", "aarch64-unknown-linux-gnu", fn():
            with_env("SIMPLE_CC", "/custom/toolchain/cc", fn():
                expect(find_c_compiler()).to_equal("/custom/toolchain/cc")
            )
        )

    it "fails closed before host compiler discovery when a cross driver is missing":
        val source = rt_file_read_text("src/compiler/70.backend/backend/runtime_compiler.spl") ?? ""
        val finder_pos = source.find("fn find_c_compiler()")
        val discovery_pos = source.find("# Runtime Source Discovery")
        val finder_source = source.substring(finder_pos, discovery_pos)
        val cross_pos = finder_source.find("val plan = hosted_c_compiler_plan")
        val lookup_pos = finder_source.find("command -v {plan.command}")
        val windows_pos = finder_source.find("if _is_windows()")
        val guarded = finder_source.substring(cross_pos, windows_pos)
        expect(cross_pos).to_be_greater_than(-1)
        expect(lookup_pos).to_be_greater_than(cross_pos)
        expect(windows_pos).to_be_greater_than(lookup_pos)
        expect(guarded).to_contain("return \"\"")

    it "honors SIMPLE_PROJECT_ROOT override before cwd fallback":
        val project_root = cwd()
        with_env("SIMPLE_PROJECT_ROOT", project_root, fn():
            expect(find_runtime_source_dir()).to_equal("{project_root}/src/runtime")
        )

    it "finds runtime sources from cwd when no override is set":
        with_env("SIMPLE_PROJECT_ROOT", "", fn():
            expect(find_runtime_source_dir()).to_equal("src/runtime")
        )

