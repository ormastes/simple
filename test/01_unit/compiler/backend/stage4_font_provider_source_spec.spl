use std.spec.{describe, it, expect}

extern fn rt_file_read_text(path: text) -> text

describe "Stage4 font provider source contract":
    it "keeps stb private behind the complete Simple font ABI":
        val source = rt_file_read_text("src/runtime/runtime_font.c")
        val header = rt_file_read_text("src/runtime/runtime.h")
        val static_pos = source.find("#define STBTT_STATIC")
        val implementation_pos = source.find("#define STB_TRUETYPE_IMPLEMENTATION")
        expect(static_pos).to_be_greater_than(-1)
        expect(implementation_pos).to_be_greater_than(static_pos)

        val exports = [
            "rt_font_load", "rt_font_load_bytes", "rt_font_free",
            "rt_font_glyph_bitmap", "rt_font_glyph_index", "rt_font_glyph_bitmap_index",
            "rt_font_bitmap_width", "rt_font_bitmap_height", "rt_font_bitmap_xoff",
            "rt_font_bitmap_yoff", "rt_font_bitmap_get_pixel", "rt_font_bitmap_free",
            "rt_font_glyph_advance", "rt_font_glyph_advance_index", "rt_font_line_height",
            "rt_font_ascent", "rt_font_descent", "rt_font_line_gap"
        ]
        for name in exports:
            expect(source).to_contain(name + "(")
            expect(header).to_contain(name + "(")
