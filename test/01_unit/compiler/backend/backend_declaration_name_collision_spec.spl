use std.spec
use std.io_runtime.{file_read}

describe "backend declaration name collision guards":
    it "keeps backend facade construction off the globally ambiguous Backend name":
        val src = file_read("src/compiler/70.backend/backend/backend_api.spl")
        expect(src).to_contain("class CompilerBackend:")
        expect(src).to_contain("type Backend = CompilerBackend")
        expect(src.contains("\nclass Backend:")).to_equal(false)
        expect(src.contains("\n        Backend(")).to_equal(false)
        expect(src.contains("Ok(Backend(")).to_equal(false)

    it "keeps legacy cranelift state construction off the globally ambiguous Codegen name":
        val src = file_read("src/compiler/70.backend/codegen.spl")
        expect(src).to_contain("struct CraneliftCodegenState:")
        expect(src).to_contain("type Codegen = CraneliftCodegenState")
        expect(src.contains("\nstruct Codegen:")).to_equal(false)
        expect(src.contains("Codegen.new(")).to_equal(false)
        expect(src.contains("\n        Codegen(")).to_equal(false)

    it "keeps HIR symbol table construction off the globally ambiguous Symbol name":
        val src = file_read("src/compiler/20.hir/hir_types.spl")
        expect(src).to_contain("struct HirSymbol:")
        expect(src).to_contain("type Symbol = HirSymbol")
        expect(src.contains("\nstruct Symbol:")).to_equal(false)
        expect(src.contains("\n        val symbol = Symbol(")).to_equal(false)
        expect(src.contains("var type_symbol: Symbol = Symbol(")).to_equal(false)
