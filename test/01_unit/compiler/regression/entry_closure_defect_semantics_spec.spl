# Preventing specs for the native-build entry-closure freestanding cranelift
# codegen defect catalog: doc/08_tracking/bug/simpleos_native_build_entry_closure_codegen_defects_2026-07-17.md
#
# Each `describe` below pins the CORRECT language-level semantics for one
# catalog entry. These are interpreter-verifiable today (the interpreter path
# was not the broken one — the defects were found on
# `native-build --entry-closure --target x86_64-unknown-none --backend
# cranelift --opt-level=aggressive`), so this file is a regression fixture:
# it must stay green on the interpreter forever, and becomes a native-parity
# gate once the same assertions can run through that backend.
#
# C3 (short-circuit `and` drops its RHS call) is covered separately in
# short_circuit_semantics_spec.spl. C8 (trait-object dispatch extra deref) is
# a native-only vtable/codegen defect with no interpreter-level surface and is
# intentionally not reproduced here.
#
# tag: unit

# ---------------------------------------------------------------------------
# C1: module-global `val X = call()` initializers must run before first use.
# ---------------------------------------------------------------------------
# Bug: the initializer call for a module-global was never emitted on the
# native-build path, so the global stayed nil/empty and the first read
# dereferenced garbage. Also hit `[]`-initialized array globals.

fn ecd_compute_global() -> i64:
    return 21 + 21

val ecd_c1_module_global = ecd_compute_global()

fn ecd_build_list() -> [i64]:
    return [1, 2, 3]

val ecd_c1_array_global = ecd_build_list()

describe "C1: module-global val initialized via a function call":
    it "is the computed value at first read, not nil/0":
        expect(ecd_c1_module_global).to_equal(42)

    it "an array global built via a function call keeps its elements, not length 0":
        expect(ecd_c1_array_global.len()).to_equal(3)
        expect(ecd_c1_array_global[0]).to_equal(1)
        expect(ecd_c1_array_global[2]).to_equal(3)

# ---------------------------------------------------------------------------
# C2: `if val x = opt:` must bind the real value on the hit path.
# ---------------------------------------------------------------------------
# Bug: disassembly of the hit-path accessor showed `xor rax,rax; ret` — the
# binding returned nil even though a value existed, while the miss path was
# correct. A later `.field`/method call on the nil binding faulted.

fn ecd_maybe_value(flag: bool) -> Option<i64>:
    if flag:
        return Some(99)
    return nil

fn ecd_extract_or_default(flag: bool) -> i64:
    if val x = ecd_maybe_value(flag):
        return x
    return -1

describe "C2: `if val x = opt:` binds the real value on the hit path":
    it "binds the wrapped value when the Option is Some (not nil)":
        expect(ecd_extract_or_default(true)).to_equal(99)

    it "falls through to the else path when the Option is None":
        expect(ecd_extract_or_default(false)).to_equal(-1)

# ---------------------------------------------------------------------------
# C4: anonymous tuple positional members must read the matching slot.
# ---------------------------------------------------------------------------
# Bug: a `(Engine2D, i32, i32, text)` anon-tuple return had its `.1` read the
# real `.2` and vice versa — a fully rendered frame reported `rendered=0`,
# rejecting a good frame. `.N` numeric tuple-field access is valid Simple
# syntax (see src/compiler/10.frontend/core/parser_expr.spl "Numeric
# tuple-field access: pair.0, pair.1"); this pins the syntax's own contract.

fn ecd_make_triple() -> (i64, i64, text):
    return (10, 20, "third")

describe "C4: anonymous tuple positional members read the matching slot":
    it "`.0` `.1` `.2` each read the value at their own construction position":
        val t = ecd_make_triple()
        expect(t.0).to_equal(10)
        expect(t.1).to_equal(20)
        expect(t.2).to_equal("third")

# ---------------------------------------------------------------------------
# C5: enum `==` comparison must agree with match-based equality.
# ---------------------------------------------------------------------------
# Bug: `lease.mode == NvmeNamespaceMode.System` was false for a genuine
# System value while a match-based helper in the SAME frame correctly printed
# "system" — misrouted a boot lease. Workaround was a match-based predicate;
# this spec pins that `==` and `match` must never disagree.

enum EcdC5Mode:
    System
    User

fn ecd_mode_is_system_via_eq(m: EcdC5Mode) -> bool:
    return m == EcdC5Mode.System

fn ecd_mode_is_system_via_match(m: EcdC5Mode) -> bool:
    match m:
        case EcdC5Mode.System:
            return true
        case EcdC5Mode.User:
            return false

describe "C5: enum `==` comparison agrees with match-based equality":
    it "`==` and `match` agree that System is System":
        expect(ecd_mode_is_system_via_eq(EcdC5Mode.System)).to_equal(ecd_mode_is_system_via_match(EcdC5Mode.System))
        expect(ecd_mode_is_system_via_eq(EcdC5Mode.System)).to_equal(true)

    it "`==` and `match` agree that User is not System":
        expect(ecd_mode_is_system_via_eq(EcdC5Mode.User)).to_equal(ecd_mode_is_system_via_match(EcdC5Mode.User))
        expect(ecd_mode_is_system_via_eq(EcdC5Mode.User)).to_equal(false)

# ---------------------------------------------------------------------------
# C6: `b0 | (b1 << 8)` byte-combine must keep the high-byte term.
# ---------------------------------------------------------------------------
# Bug: inlining this exact shape into a FAT dirent scan lost the high-byte
# term: first-cluster `0x0f70` read as `0x70`, sending the exec probe to the
# wrong disk cluster. Reproduces the literal failing constants from
# vfs_boot_init.spl.

fn ecd_combine_bytes(b0: i64, b1: i64) -> i64:
    return b0 | (b1 << 8)

describe "C6: `b0 | (b1 << 8)` keeps the high-byte term":
    it "combines the exact failing FAT dirent bytes into 0x0f70, not 0x70":
        expect(ecd_combine_bytes(0x70, 0x0f)).to_equal(0x0f70)

    it "a high byte alone shifts into the correct bit position":
        expect(ecd_combine_bytes(0x00, 0x01)).to_equal(0x0100)

    it "both bytes set combine without dropping either term":
        expect(ecd_combine_bytes(0xff, 0xff)).to_equal(0xffff)

# ---------------------------------------------------------------------------
# C7: widening a u16 to u32 must use `as u32`, not a bare conversion method.
# ---------------------------------------------------------------------------
# Bug: a bare `.to_u32()` on a scalar u16 dispatched through the
# freestanding bare->qualified alias bridge into an unrelated struct's
# `to_u32` method (Color.to_u32 in fb_driver) and faulted. `.to_u32()` is not
# a builtin method on scalar integer types (grep confirms it is only defined
# on structs like Color/IpAddr) — `as u32` is the correct, dispatch-free
# widening and is what this spec pins.

fn ecd_widen_u16_to_u32(v: u16) -> u32:
    return v as u32

describe "C7: u16 -> u32 widening via `as u32` preserves the value":
    it "widens a representative value without truncation":
        expect(ecd_widen_u16_to_u32(0xbeef as u16)).to_equal(0xbeef as u32)

    it "widens the maximum u16 value correctly":
        expect(ecd_widen_u16_to_u32(0xffff as u16)).to_equal(0xffff as u32)

    it "widens zero correctly":
        expect(ecd_widen_u16_to_u32(0 as u16)).to_equal(0 as u32)
