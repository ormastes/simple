describe "interpreter mixed numeric arithmetic":
    it "promotes either operand for addition":
        expect(2 + 0.5).to_equal(2.5)
        expect(0.5 + 2).to_equal(2.5)
        expect(-3 + 0.5).to_equal(-2.5)
        expect(0 + 0.5).to_equal(0.5)

    it "promotes either operand for subtraction":
        expect(2 - 0.5).to_equal(1.5)
        expect(2.5 - 2).to_equal(0.5)

    it "promotes either operand for multiplication":
        expect(2 * 0.5).to_equal(1.0)
        expect(0.5 * 2).to_equal(1.0)

    it "promotes either operand for division":
        expect(5 / 2.0).to_equal(2.5)
        expect(5.0 / 2).to_equal(2.5)

    it "promotes either operand for ordering but keeps equality type-strict":
        expect(41 < 41.5).to_equal(true)
        expect(41.5 < 41).to_equal(false)
        expect(41 <= 41.5).to_equal(true)
        expect(41.5 <= 41).to_equal(false)
        expect(41 > 41.5).to_equal(false)
        expect(41.5 > 41).to_equal(true)
        expect(41 >= 41.5).to_equal(false)
        expect(41.5 >= 41).to_equal(true)
        expect(42 < 42.0).to_equal(false)
        expect(42.0 < 42).to_equal(false)
        expect(42 <= 42.0).to_equal(true)
        expect(42.0 <= 42).to_equal(true)
        expect(42 > 42.0).to_equal(false)
        expect(42.0 > 42).to_equal(false)
        expect(42 >= 42.0).to_equal(true)
        expect(42.0 >= 42).to_equal(true)
        expect(42 == 42.0).to_equal(false)
        expect(42 != 42.0).to_equal(true)
