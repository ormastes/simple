use std.spec

class MutableCounter:
    value: i32

    me set_value(next: i32):
        self.value = next

class MutableListHolder:
    values: [i32]

    me set_first(next: i32):
        self.values[0] = next

    me set_first_via_free_function(next: i32):
        write_first(self.values, next)

    me set_first_via_self_free_function(next: i32):
        write_holder_first(self, next)

class MutableDictHolder:
    values: Dict<text, i32>

struct MutableStructDictHolder:
    values: Dict<text, i32>

enum DictWriteResult:
    Success

fn write_first(values: [i32], next: i32):
    values[0] = next

fn write_holder_first(holder: MutableListHolder, next: i32):
    holder.values[0] = next

fn write_holder_named_self(self: MutableListHolder, next: i32):
    self.values[0] = next

fn write_dict_holder(self: MutableDictHolder, key: text, next: i32):
    self.values[key] = next

fn write_struct_dict_holder(self: MutableStructDictHolder, key: text, next: i32) -> DictWriteResult:
    self.values[key] = next
    DictWriteResult.Success

describe "interpreter self field assignment":
    it "allows self.field assignment inside me methods":
        var counter = MutableCounter(value: 1)
        counter.set_value(7)
        expect(counter.value).to_equal(7)

    it "allows self.field[index] assignment inside me methods":
        var holder = MutableListHolder(values: [1, 2])
        holder.set_first(9)
        expect(holder.values[0]).to_equal(9)

    it "preserves self.field mutations passed through free functions":
        var holder = MutableListHolder(values: [1, 2])
        holder.set_first_via_free_function(11)
        expect(holder.values[0]).to_equal(11)

    it "preserves self receiver mutations passed through free functions":
        var holder = MutableListHolder(values: [1, 2])
        holder.set_first_via_self_free_function(13)
        expect(holder.values[0]).to_equal(13)

    it "preserves mutations through free functions whose parameter is named self":
        var holder = MutableListHolder(values: [1, 2])
        write_holder_named_self(holder, 17)
        expect(holder.values[0]).to_equal(17)

    it "preserves dictionary-field mutations through free functions":
        var holder = MutableDictHolder(values: {})
        write_dict_holder(holder, "answer", 42)
        expect(holder.values.has("answer")).to_equal(true)
        expect(holder.values["answer"]).to_equal(42)

    it "preserves struct dictionary-field mutations through returning free functions":
        var holder = MutableStructDictHolder(values: {})
        val result = write_struct_dict_holder(holder, "answer", 43)
        match result:
            case DictWriteResult.Success:
                expect(holder.values.has("answer")).to_equal(true)
            case _:
                expect("unexpected").to_equal("success")
