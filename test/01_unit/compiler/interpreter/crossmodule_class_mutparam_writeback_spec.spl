use std.spec
use test.fixtures.interpreter_crossmodule_class_mutparam_writeback.builder.{BddMutCounter, bdd_crossmodule_bump_counter}

# Regression spec for
# doc/08_tracking/bug/sspec_it_block_loses_cross_module_class_mutation_2026-07-17.md
#
# Root cause: a cross-module function imported via `use module.{name}` could
# be registered twice in the interpreter's process-wide FUNCTION_OVERLOADS
# map (once when the exporting module's own source was evaluated, once again
# when the importer unpacked the same export). Once a plain (single
# definition) function crossed the "more than one candidate" overload
# threshold this way, the interpreter routed calls to it through the
# overload-resolution path, which — unlike the normal single-function call
# path — never wrote a mutated `mut` parameter back to the caller's binding.
# That silently dropped the mutation for ANY interpreted call to a
# cross-module function with a `mut` class-typed parameter — most visibly
# inside a `std.spec` `it` block, since BDD support only exists in the
# tree-walking interpreter (never native/JIT-compiled code), so `it` blocks
# are the one place ordinary spec code reliably exercises this path.
describe "interpreter cross-module class mut-param writeback":
    it "preserves a cross-module function's mutation of a mut class-typed parameter inside the BDD closure":
        val counter = BddMutCounter()
        bdd_crossmodule_bump_counter(counter)
        expect(counter.n).to_equal(1)

        bdd_crossmodule_bump_counter(counter)
        expect(counter.n).to_equal(2)
