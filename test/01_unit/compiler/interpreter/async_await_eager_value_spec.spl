# Async/await eager-value regression spec (B2)
#
# Bug: doc/08_tracking/bug/async_await_interpreter_crashes_2026-06-11.md
# `await f()` on an async fn previously SIGSEGV'd, then silently yielded the
# NIL bit pattern (printed as 3) in JIT mode and a semantic error in
# interpreter mode. Root causes fixed:
#   - rt_future_await: non-Future input is the identity (already-resolved
#     value), not NIL (src/compiler_rust/runtime/src/value/async_gen.rs)
#   - interpreter Expr::Await: non-Future/non-Actor values route through
#     await_value passthrough instead of erroring
#     (src/compiler_rust/compiler/src/interpreter/expr.rs)

use std.spec.*

async fn just_42() -> i64:
    42

async fn add_async(a: i64, b: i64) -> i64:
    a + b

fn run_await_42() -> i64:
    val x = await just_42()
    x

fn run_await_add() -> i64:
    val x = await add_async(20, 22)
    x

describe "await on async fn (B2 eager-async)":

    context "zero-arg async fn":
        it "returns the body value, not NIL/3":
            val got = run_await_42()
            expect(got).to_equal(42)

    context "async fn with args":
        it "returns the computed value":
            val got = run_await_add()
            expect(got).to_equal(42)

    context "await inside expression position":
        it "awaited value usable in arithmetic":
            val got = run_await_42() + 8
            expect(got).to_equal(50)
