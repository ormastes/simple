extern fn rt_file_read_text(path: text) -> text

describe "interpreter text.index_of start offset":
    it "searches from the requested position":
        val value = "a\nb\nc"
        expect(value.index_of("\n") ?? -1).to_equal(1)
        expect(value.index_of("x") ?? -1).to_equal(-1)
        expect(value.index_of("\n", 0) ?? -1).to_equal(1)
        expect(value.index_of("\n", 2) ?? -1).to_equal(3)
        expect(value.index_of("\n", 4) ?? -1).to_equal(-1)

    it "evaluates and forwards the second argument in the active owner":
        val source = rt_file_read_text("src/compiler/10.frontend/core/interpreter/_EvalOps/access_literal_assign_eval.spl") ?? ""
        val branch_start = source.index_of("if method_name == \"index_of\":") ?? -1
        expect(branch_start).to_be_greater_than(-1)
        val branch = source.substring(branch_start, source.len())
        val needle_pos = branch.index_of("val needle_val = eval_expr(arg_eids[0])") ?? -1
        val needle_error_pos = branch.index_of("if eval_had_error: return -1", needle_pos) ?? -1
        val start_pos = branch.index_of("val start_val = eval_expr(arg_eids[1])") ?? -1
        val start_error_pos = branch.index_of("if eval_had_error: return -1", start_pos) ?? -1
        val two_arg_pos = branch.index_of("s.index_of(needle, val_get_int(start_val)) ?? -1") ?? -1
        val one_arg_pos = branch.index_of("s.index_of(needle) ?? -1") ?? -1

        expect(needle_error_pos).to_be_greater_than(needle_pos)
        expect(start_pos).to_be_greater_than(needle_error_pos)
        expect(start_error_pos).to_be_greater_than(start_pos)
        expect(two_arg_pos).to_be_greater_than(start_error_pos)
        expect(one_arg_pos).to_be_greater_than(two_arg_pos)
