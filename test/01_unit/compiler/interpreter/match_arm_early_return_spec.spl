## match arm early-return propagation spec
##
## Regression for bug: interp_match_or_pattern_early_return_swallowed_2026-06-13
## Root cause: exec_block_fn used exec_if_expr/exec_match_expr for last-statement
## if/match handling, which collapsed Control::Return into a plain value instead
## of propagating the early return up to the enclosing function.
##
## Affected: ALL pattern kinds (not just or-patterns) when the match arm's
## last statement is an if/match containing an explicit return.

spec "match arm early-return propagation":

    enum Dir:
        North
        South
        East
        West

    fn or_pattern_if_return(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                if true:
                    return 1
        return 0

    fn single_pattern_if_return(d: Dir) -> i64:
        match d:
            Dir.North:
                if true:
                    return 1
        return 0

    fn arm_value_no_return(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                42
            _:
                0

    fn guard_false_fallthrough(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                if false:
                    return 1
        return 0

    fn nested_match_return(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                match d:
                    Dir.North:
                        return 10
                    _:
                        return 20
        return 0

    it "or-pattern: explicit return inside if propagates":
        val result = or_pattern_if_return(Dir.North)
        expect(result).to_equal(1)

    it "or-pattern: second variant in or also returns":
        val result = or_pattern_if_return(Dir.South)
        expect(result).to_equal(1)

    it "or-pattern: non-matching arm falls through to post-match return":
        val result = or_pattern_if_return(Dir.East)
        expect(result).to_equal(0)

    it "single-pattern: explicit return inside if propagates":
        val result = single_pattern_if_return(Dir.North)
        expect(result).to_equal(1)

    it "single-pattern: non-matching falls through":
        val result = single_pattern_if_return(Dir.South)
        expect(result).to_equal(0)

    it "arm value with no early return still works correctly":
        val r1 = arm_value_no_return(Dir.North)
        val r2 = arm_value_no_return(Dir.East)
        expect(r1).to_equal(42)
        expect(r2).to_equal(0)

    it "false if-condition: falls through to post-match return":
        val result = guard_false_fallthrough(Dir.North)
        expect(result).to_equal(0)

    it "nested match as last statement: return propagates":
        val r1 = nested_match_return(Dir.North)
        val r2 = nested_match_return(Dir.South)
        expect(r1).to_equal(10)
        expect(r2).to_equal(20)
