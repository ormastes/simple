# Regression: typed `val x: T = ...` bindings inside nested blocks (if/while/else)
# within closure bodies (describe/it lambdas) must bind like unannotated vals.
# Bug: exec_block_closure_mut hand-rolled only identifier patterns, silently
# dropping Pattern::Typed bindings — reads then failed with
# "variable `x` not found".
# See doc/08_tracking/bug/test_runner_annotated_u32_val_arg_corruption_2026-06-12.md
# @tag: unit, compiler, interpreter, closure, binding

use std.spec.{describe, it, expect}

fn take_u(v: u32) -> u32:
    v

describe "typed val bindings in nested closure blocks":
    it "binds annotated i32 inside if and reads it":
        val cond = true
        if cond:
            val x: i32 = 5
            expect(x).to_equal(5)
        else:
            expect(2).to_equal(2)

    it "binds annotated u32 inside if and passes it as call arg":
        val cond = true
        if cond:
            val v: u32 = 0xFF0000FFu32
            expect(take_u(v)).to_equal(0xFF0000FFu32)
        else:
            expect(2).to_equal(2)

    it "binds annotated val inside while body":
        var i = 0
        var total = 0
        while i < 1:
            val x: i32 = 7
            total = total + x
            i = i + 1
        expect(total).to_equal(7)

    it "binds annotated val inside else branch":
        val cond = false
        if cond:
            expect(1).to_equal(1)
        else:
            val x: i32 = 9
            expect(x).to_equal(9)

    it "binds tuple destructuring inside if":
        val cond = true
        if cond:
            val (a, b) = (3, 4)
            expect(a + b).to_equal(7)
        else:
            expect(2).to_equal(2)
