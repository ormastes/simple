use std.spec.{describe, it, expect}

extern fn rt_file_read_text(path: text) -> text

describe "pure-Simple core interpreter dict literal dispatch":
    it "routes the rare expression tag to the active evaluator":
        val dispatch = rt_file_read_text("src/compiler/10.frontend/core/interpreter/eval.spl") ?? ""
        val exports = rt_file_read_text("src/compiler/10.frontend/core/interpreter/eval_ops.spl") ?? ""
        val owner = rt_file_read_text("src/compiler/10.frontend/core/interpreter/_EvalOps/access_literal_assign_eval.spl") ?? ""
        val integration = rt_file_read_text("src/compiler/10.frontend/core/interpreter/test_interp.spl") ?? ""
        val route_pos = dispatch.find("if tag == EXPR_DICT_LIT: return eval_dict_lit(eid)")
        val fallback_pos = dispatch.find("unsupported expression kind")

        expect(route_pos).to_be_greater_than(-1)
        expect(fallback_pos).to_be_greater_than(route_pos)
        expect(exports).to_contain("export use compiler.frontend.core.interpreter._EvalOps.access_literal_assign_eval.*")
        expect(owner).to_contain("fn eval_dict_lit(eid: i64) -> i64")
        expect(owner).to_contain("val_make_struct(\"__dict\", field_names, field_values)")
        expect(integration).to_contain("empty dict literals allocate independently")
