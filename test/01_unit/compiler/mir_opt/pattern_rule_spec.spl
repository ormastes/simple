# @cover src/compiler/60.mir_opt/mir_opt/pattern/pattern_rule_pass.spl 80%
"""
# PatternRulePass Specification

**Feature IDs:** #web-server-optimizer-complete
**Category:** Compiler / MIR Optimization — Rule Engine
**Difficulty:** 3/5
**Status:** Draft

## Overview

Validates the data-driven PatternRulePass which loads `.opt.json` rule
files, matches MIR instruction sequences against named patterns, and
applies rewrites. The AC-7 schema extends `simple.opt.mir.v1` with an
optional `rules: [PatternRule]` array.

## Behavior

- Rule file with valid schema is loaded without error
- Pattern matching finds the expected instruction sequence
- Rewrite replaces matched sequence with the rewritten form
- Rule with invalid pattern syntax is rejected at load time
- Applied rule reports its cost_delta
"""

use std.spec


# ============================================================================
# Stub types mirroring PatternRule / PatternRulePass
# ============================================================================

class PatternRule:
    name: text
    pattern: text
    rewrite: text
    cost_delta: i64

class RuleLoadResult:
    ok: bool
    error_msg: text
    rules: List<PatternRule>

fn validate_pattern_syntax(pattern: text) -> bool:
    # A valid pattern must be non-empty and contain at least one ":".
    pattern.len() > 0 and pattern.contains(":")

fn load_opt_json(schema_version: text, rules_raw: List<PatternRule>) -> RuleLoadResult:
    # Validate schema version and each rule's pattern syntax.
    if schema_version != "simple.opt.mir.v1":
        RuleLoadResult(ok: false, error_msg: "unknown schema: " + schema_version, rules: [])
    else:
        var errors: List<text> = []
        var i = 0
        while i < rules_raw.len():
            if not validate_pattern_syntax(rules_raw[i].pattern):
                errors = errors + ["invalid pattern in rule: " + rules_raw[i].name]
            i = i + 1
        if errors.len() > 0:
            RuleLoadResult(ok: false, error_msg: errors[0], rules: [])
        else:
            RuleLoadResult(ok: true, error_msg: "", rules: rules_raw)

fn find_pattern(instructions: List<text>, pattern_opcode: text) -> i64:
    # Returns index of first matching instruction or -1.
    var i = 0
    while i < instructions.len():
        val inst = instructions[i]
        if inst.contains(pattern_opcode):
            return i
        i = i + 1
    -1

fn apply_rewrite(instructions: List<text>, match_idx: i64, rewrite: text) -> List<text>:
    # Replace instruction at match_idx with rewrite string.
    var result: List<text> = []
    var i = 0
    while i < instructions.len():
        if i == match_idx:
            result = result + [rewrite]
        else:
            result = result + [instructions[i]]
        i = i + 1
    result


# ============================================================================
# PatternRulePass tests
# ============================================================================

describe "PatternRulePass":

    describe "rule file loading":

        it "loads .opt.json rule file and validates schema":
            val rules = [
                PatternRule(
                    name: "add_zero_elim",
                    pattern: "BinOp:Add(%x, 0)",
                    rewrite: "Copy(%x)",
                    cost_delta: -1
                )
            ]
            val result = load_opt_json("simple.opt.mir.v1", rules)
            expect(result.ok).to_equal(true)
            expect(result.rules.len()).to_equal(1)

        it "rejects rule with invalid pattern syntax":
            # Pattern without ":" is structurally invalid.
            val bad_rules = [
                PatternRule(
                    name: "bad_rule",
                    pattern: "",
                    rewrite: "Nop",
                    cost_delta: 0
                )
            ]
            val result = load_opt_json("simple.opt.mir.v1", bad_rules)
            expect(result.ok).to_equal(false)
            expect(result.error_msg).to_contain("invalid pattern")

        it "rejects file with unknown schema version":
            val rules: List<PatternRule> = []
            val result = load_opt_json("simple.opt.mir.v99", rules)
            expect(result.ok).to_equal(false)
            expect(result.error_msg).to_contain("unknown schema")

    describe "pattern matching":

        it "matches MIR pattern against instruction sequence":
            val instructions = [
                "Load %ptr",
                "BinOp:Add %a 0",
                "Store %dst"
            ]
            val match_idx = find_pattern(instructions, "BinOp:Add")
            expect(match_idx).to_equal(1)

        it "returns -1 when pattern is not present in sequence":
            val instructions = ["Load %ptr", "Store %dst"]
            val match_idx = find_pattern(instructions, "BinOp:Mul")
            expect(match_idx).to_equal(-1)

    describe "rewrite application":

        it "applies rewrite to matched instructions":
            val instructions = ["Load %ptr", "BinOp:Add %a 0", "Store %dst"]
            val match_idx = 1
            val rewritten = apply_rewrite(instructions, match_idx, "Copy %a")
            expect(rewritten.len()).to_equal(3)
            expect(rewritten[1]).to_equal("Copy %a")
            # Other instructions unchanged
            expect(rewritten[0]).to_equal("Load %ptr")
            expect(rewritten[2]).to_equal("Store %dst")

    describe "cost reporting":

        it "reports cost delta for applied rule":
            val rule = PatternRule(
                name: "strength_reduce_mul2",
                pattern: "BinOp:Mul(%x, 2)",
                rewrite: "BinOp:Shl(%x, 1)",
                cost_delta: -2
            )
            expect(rule.cost_delta).to_equal(-2)
            expect(rule.cost_delta).to_be_less_than(0)
