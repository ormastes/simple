use std.spec
use compiler.mir.mir_instructions.{
    BlockId, MirBlock, MirInst, MirInstKind, MirOperand, MirOperandKind,
    MirTerminator, MirBinOp
}
use compiler.mir.mir_types.{LocalId, LocalKind, MirConstValue, MirLocal, MirType}
use compiler.mir_opt.mir_opt.var_reassign_ssa.{ssa_alloca_transform_blocks}

# Regression guard for bug:
#   doc/08_tracking/bug/llvm_runtime_array_assignment_ssa_2026-07-10.md
#
# Assigning a returned runtime array back into an existing variable emitted a
# SECOND definition of the same LLVM local (`%l5 = getelementptr ...` then
# `%l5 = add ...`), which llc rejects. The alloca-per-reassigned-local transform
# (ssa_alloca_transform_blocks) is the SIMPLE_BOOTSTRAP LLVM path's fix, but it
# previously bailed out on ANY single-block function (`blocks.len() < 2`), so a
# straight-line reassignment was never slotted and the duplicate def survived.
# It also must keep working for the conditional / loop / zero-iteration shapes.

fn local(id: i64) -> LocalId:
    LocalId(id: id)

fn int_operand(value: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(value), MirType.i64()))

fn copy_operand(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(local(id)))

fn inst(kind: MirInstKind) -> MirInst:
    MirInst(kind: kind, span: nil)

fn i64_local(id: i64) -> MirLocal:
    MirLocal(id: local(id), name: nil, type_: MirType.i64(), kind: LocalKind.Var, is_ghost: false)

# Count how many emitted instructions still WRITE `target_id` as their dest.
# After the transform each reassigned def must become a Store into the stack
# slot (dest rewritten to a fresh temp), so the original local must be written
# zero times -- proving no duplicate `%lN` def can be emitted.
fn writes_of(blocks: [MirBlock], target_id: i64) -> i64:
    var count = 0
    for block in blocks:
        for i in block.instructions:
            match i.kind:
                case GetElementPtr(dest, _, _):
                    if dest.id == target_id: count = count + 1
                case BinOp(dest, _, _, _):
                    if dest.id == target_id: count = count + 1
                case Const(dest, _, _):
                    if dest.id == target_id: count = count + 1
                case Call(dest, _, _):
                    if dest.?:
                        if dest.unwrap().id == target_id: count = count + 1
                case _: pass_do_nothing
    count

describe "runtime array assignment SSA (bug: duplicate %lN def)":

    it "slots a straight-line single-block reassignment of a returned array":
        # Mirrors the bug's span probe:
        #   %l5 = getelementptr i8, ptr %l4, i64 0
        #   %l5 = add i64 %l11, 0     <- second def of the SAME local
        # local 5 is written twice, then returned (it ESCAPES), so the SSA-rename
        # fallback cannot rescue it -- only the alloca slot can.
        val blocks = [
            MirBlock(
                id: BlockId.new(0),
                label: "entry",
                instructions: [
                    inst(MirInstKind.GetElementPtr(local(5), copy_operand(4), [int_operand(0)])),
                    inst(MirInstKind.BinOp(local(5), MirBinOp.Add, copy_operand(11), int_operand(0)))
                ],
                terminator: MirTerminator.Ret(Some(copy_operand(5)))
            )
        ]
        val locals = [i64_local(4), i64_local(5), i64_local(11)]
        val result = ssa_alloca_transform_blocks(blocks, locals, BlockId.new(0))
        expect(result.applied).to_equal(true)
        expect(result.reason).to_equal("ready")
        # The two duplicate defs of local 5 must be gone (rewritten to stores).
        expect(writes_of(result.blocks, 5)).to_equal(0)

    it "slots a reassignment inside an if/else (multi-block)":
        val blocks = [
            MirBlock(id: BlockId.new(0), label: "entry", instructions: [],
                terminator: MirTerminator.If(copy_operand(9), BlockId.new(1), BlockId.new(2))),
            MirBlock(id: BlockId.new(1), label: "then",
                instructions: [inst(MirInstKind.BinOp(local(5), MirBinOp.Add, copy_operand(11), int_operand(0)))],
                terminator: MirTerminator.Goto(BlockId.new(3))),
            MirBlock(id: BlockId.new(2), label: "else",
                instructions: [inst(MirInstKind.GetElementPtr(local(5), copy_operand(4), [int_operand(0)]))],
                terminator: MirTerminator.Goto(BlockId.new(3))),
            MirBlock(id: BlockId.new(3), label: "join", instructions: [],
                terminator: MirTerminator.Ret(Some(copy_operand(5))))
        ]
        val locals = [i64_local(4), i64_local(5), i64_local(9), i64_local(11)]
        val result = ssa_alloca_transform_blocks(blocks, locals, BlockId.new(0))
        expect(result.applied).to_equal(true)
        expect(result.reason).to_equal("ready")
        expect(writes_of(result.blocks, 5)).to_equal(0)

    it "slots a loop-carried reassignment (back-edge, multi-block)":
        val blocks = [
            MirBlock(id: BlockId.new(0), label: "entry",
                instructions: [inst(MirInstKind.GetElementPtr(local(5), copy_operand(4), [int_operand(0)]))],
                terminator: MirTerminator.Goto(BlockId.new(1))),
            MirBlock(id: BlockId.new(1), label: "header", instructions: [],
                terminator: MirTerminator.If(copy_operand(9), BlockId.new(2), BlockId.new(3))),
            MirBlock(id: BlockId.new(2), label: "body",
                instructions: [inst(MirInstKind.BinOp(local(5), MirBinOp.Add, copy_operand(5), int_operand(1)))],
                terminator: MirTerminator.Goto(BlockId.new(1))),
            MirBlock(id: BlockId.new(3), label: "exit", instructions: [],
                terminator: MirTerminator.Ret(Some(copy_operand(5))))
        ]
        val locals = [i64_local(4), i64_local(5), i64_local(9)]
        val result = ssa_alloca_transform_blocks(blocks, locals, BlockId.new(0))
        expect(result.applied).to_equal(true)
        expect(result.reason).to_equal("ready")
        expect(writes_of(result.blocks, 5)).to_equal(0)

    it "slots a possibly-zero-iteration loop (entry def dominates exit use)":
        # Same CFG as a loop, but the body may run zero times; the exit still
        # reads local 5. The entry-block alloca dominates the exit load, so the
        # use is defined on the zero-trip path too (no `undef`).
        val blocks = [
            MirBlock(id: BlockId.new(0), label: "entry",
                instructions: [inst(MirInstKind.GetElementPtr(local(5), copy_operand(4), [int_operand(0)]))],
                terminator: MirTerminator.Goto(BlockId.new(1))),
            MirBlock(id: BlockId.new(1), label: "header", instructions: [],
                terminator: MirTerminator.If(copy_operand(9), BlockId.new(2), BlockId.new(3))),
            MirBlock(id: BlockId.new(2), label: "body",
                instructions: [inst(MirInstKind.BinOp(local(5), MirBinOp.Add, copy_operand(5), int_operand(1)))],
                terminator: MirTerminator.Goto(BlockId.new(1))),
            MirBlock(id: BlockId.new(3), label: "exit", instructions: [],
                terminator: MirTerminator.Ret(Some(copy_operand(5))))
        ]
        val locals = [i64_local(4), i64_local(5), i64_local(9)]
        val result = ssa_alloca_transform_blocks(blocks, locals, BlockId.new(0))
        expect(result.applied).to_equal(true)
        expect(result.reason).to_equal("ready")
        expect(writes_of(result.blocks, 5)).to_equal(0)

    it "stays a no-op for a single-block function with no reassignment":
        val blocks = [
            MirBlock(
                id: BlockId.new(0),
                label: "entry",
                instructions: [
                    inst(MirInstKind.Const(local(4), MirConstValue.Int(1), MirType.i64())),
                    inst(MirInstKind.BinOp(local(5), MirBinOp.Add, copy_operand(4), int_operand(1)))
                ],
                terminator: MirTerminator.Ret(Some(copy_operand(5)))
            )
        ]
        val locals = [i64_local(4), i64_local(5)]
        val result = ssa_alloca_transform_blocks(blocks, locals, BlockId.new(0))
        expect(result.applied).to_equal(false)
        expect(result.reason).to_equal("no slotted locals")
