use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirBlock}
use compiler.mir_opt.mir_opt.loop_strength.{create_strength_reduction_pass, strength_reduction_provider}
use compiler.mir_opt.pattern.rule_engine.{
    OptimizerProviderKind, OptimizerRuleLookupKind,
    optimization_rule_provider_has_required_fact,
    optimization_rule_provider_is_pipeline_pass
}

fn _sr_lid(id: i64) -> LocalId:
    LocalId(id: id)

fn _sr_copy(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(_sr_lid(id)))

fn _sr_int(value: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(value), MirType.i64()))

fn _sr_reduce_one(inst: MirInst) -> MirInstKind:
    val block = MirBlock(
        id: BlockId(id: 0),
        label: Some("entry"),
        instructions: [inst],
        terminator: MirTerminator.Ret(nil)
    )
    var sr_pass = create_strength_reduction_pass()
    val optimized = sr_pass.reduce_block(block)
    optimized.instructions[0].kind

fn _sr_reduce_all(inst: MirInst) -> [MirInstKind]:
    val block = MirBlock(
        id: BlockId(id: 0),
        label: Some("entry"),
        instructions: [inst],
        terminator: MirTerminator.Ret(nil)
    )
    var sr_pass = create_strength_reduction_pass()
    val optimized = sr_pass.reduce_block(block)
    var kinds: [MirInstKind] = []
    for opt_inst in optimized.instructions:
        kinds.push(opt_inst.kind)
    kinds

fn _sr_expect_bitand_mask(kind: MirInstKind, mask: i64):
    match kind:
        case BinOp(_, BitAnd, _, right):
            match right.kind:
                case Const(Int(actual), _):
                    expect actual == mask
                case _:
                    expect false == true
        case _:
            expect false == true

fn _sr_expect_copy_from(kind: MirInstKind, source_id: i64):
    match kind:
        case Copy(_, source):
            expect source.id == source_id
        case _:
            expect false == true

fn _sr_expect_int_const(kind: MirInstKind, value: i64):
    match kind:
        case Const(_, Int(actual), _):
            expect actual == value
        case _:
            expect false == true

fn _sr_expect_shift_amount(kind: MirInstKind, amount: i64):
    match kind:
        case BinOp(_, Shl, _, right):
            match right.kind:
                case Const(Int(actual), _):
                    expect actual == amount
                case _:
                    expect false == true
        case _:
            expect false == true

fn _sr_expect_binop_kind(kind: MirInstKind, op: MirBinOp):
    match kind:
        case BinOp(_, actual, _, _):
            expect actual == op
        case _:
            expect false == true

describe "MIR strength reduction":
    it "declares a reusable built-in MIR pipeline optimization provider":
        val provider = strength_reduction_provider()
        expect(provider.name).to_equal("simple.opt.math.strength_reduce")
        expect(provider.kind).to_equal(OptimizerProviderKind.Mir)
        expect(provider.lookup_kind).to_equal(OptimizerRuleLookupKind.PipelinePass)
        expect(optimization_rule_provider_is_pipeline_pass(provider)).to_equal(true)
        expect(optimization_rule_provider_has_required_fact(provider, "integer_widths")).to_equal(true)
        expect(optimization_rule_provider_has_required_fact(provider, "non_negative_or_unsigned_operands")).to_equal(true)
        expect(provider.produced_facts[0]).to_equal("canonical_integer_arithmetic")

    it "lowers net-driver style modulo by 128 to bitmask":
        _sr_expect_bitand_mask(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Rem, _sr_copy(1), _sr_int(128)), span: nil)),
            127
        )

    it "lowers 64-bit power-of-two modulo constants to bitmask":
        _sr_expect_bitand_mask(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Rem, _sr_copy(1), _sr_int(1099511627776)), span: nil)),
            1099511627775
        )

    it "removes bit-or zero identity":
        _sr_expect_copy_from(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.BitOr, _sr_copy(1), _sr_int(0)), span: nil)),
            1
        )

    it "removes bit-xor zero identity":
        _sr_expect_copy_from(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.BitXor, _sr_int(0), _sr_copy(1)), span: nil)),
            1
        )

    it "folds bit-and zero annihilator":
        _sr_expect_int_const(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.BitAnd, _sr_copy(1), _sr_int(0)), span: nil)),
            0
        )

    it "removes zero left shift":
        _sr_expect_copy_from(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Shl, _sr_copy(1), _sr_int(0)), span: nil)),
            1
        )

    it "removes zero right shift":
        _sr_expect_copy_from(
            _sr_reduce_one(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Shr, _sr_copy(1), _sr_int(0)), span: nil)),
            1
        )

    it "decomposes multiply by 6 into two shifts and add":
        val kinds = _sr_reduce_all(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Mul, _sr_copy(1), _sr_int(6)), span: nil))
        expect kinds.len() == 3
        _sr_expect_shift_amount(kinds[0], 2)
        _sr_expect_shift_amount(kinds[1], 1)
        _sr_expect_binop_kind(kinds[2], MirBinOp.Add)

    it "decomposes multiply by 14 into two shifts and subtract":
        val kinds = _sr_reduce_all(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Mul, _sr_int(14), _sr_copy(1)), span: nil))
        expect kinds.len() == 3
        _sr_expect_shift_amount(kinds[0], 4)
        _sr_expect_shift_amount(kinds[1], 1)
        _sr_expect_binop_kind(kinds[2], MirBinOp.Sub)

    it "decomposes multiply by 11 into two shifts plus source add":
        val kinds = _sr_reduce_all(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Mul, _sr_copy(1), _sr_int(11)), span: nil))
        expect kinds.len() == 4
        _sr_expect_shift_amount(kinds[0], 3)
        _sr_expect_shift_amount(kinds[1], 1)
        _sr_expect_binop_kind(kinds[2], MirBinOp.Add)
        _sr_expect_binop_kind(kinds[3], MirBinOp.Add)

    it "decomposes multiply by 13 into two shifts plus source add":
        val kinds = _sr_reduce_all(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Mul, _sr_int(13), _sr_copy(1)), span: nil))
        expect kinds.len() == 4
        _sr_expect_shift_amount(kinds[0], 3)
        _sr_expect_shift_amount(kinds[1], 2)
        _sr_expect_binop_kind(kinds[2], MirBinOp.Add)
        _sr_expect_binop_kind(kinds[3], MirBinOp.Add)

    it "decomposes multiply by 17 into shift and add":
        val kinds = _sr_reduce_all(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Mul, _sr_copy(1), _sr_int(17)), span: nil))
        expect kinds.len() == 2
        _sr_expect_shift_amount(kinds[0], 4)
        _sr_expect_binop_kind(kinds[1], MirBinOp.Add)

    it "decomposes multiply by 31 into shift and subtract":
        val kinds = _sr_reduce_all(MirInst(kind: MirInstKind.BinOp(_sr_lid(2), MirBinOp.Mul, _sr_int(31), _sr_copy(1)), span: nil))
        expect kinds.len() == 2
        _sr_expect_shift_amount(kinds[0], 5)
        _sr_expect_binop_kind(kinds[1], MirBinOp.Sub)
