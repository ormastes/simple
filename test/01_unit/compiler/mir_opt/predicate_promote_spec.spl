# test/unit/compiler/mir_opt/predicate_promote_spec.spl
#
# Feature ID: #COMPILER-MIROPT-PP-I2
# Category:   Compiler | MIR Optimization | Predicate Promotion
# Status:     Active — fusion pass implementation (Wave I2)
#
# Test plan:
#   Positive cases (5): MaskFromCmp + Masked{Add,Mul,Fma} -> Predicated* fusion
#   Negative cases (3): mask mismatch / non-adjacent -> no fusion; insts preserved
#   No-op case   (1):   empty module passes through unchanged
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and describe/it
#   block reachability.  The assertions inside it-blocks are not executed.
#   All assertions use built-in matchers only: to_equal, to_be_nil, to_be.

use compiler.mir.mir_data.{MirInst, MirInstKind, MirOperand, MirOperandKind,
    MirBinOp, MirTerminator, LocalId, BlockId}
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}
use compiler.mir_opt.mir_opt.predicate_promote.{
    run_predicate_promote,
    promote_block_predicate,
    operand_is_local,
    try_fuse_binary,
    try_fuse_ternary
}

# ============================================================================
# Helpers — minimal MIR construction for tests
# ============================================================================

fn make_local(id: i64) -> LocalId:
    LocalId(id: id)

fn make_block_id(id: i64) -> BlockId:
    BlockId.new(id)

fn make_copy_op(local_id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(make_local(local_id)))

fn make_jump_terminator() -> MirTerminator:
    MirTerminator.Goto(make_block_id(0))

fn make_mask_from_cmp_inst(dest_id: i64, a_id: i64, b_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.MaskFromCmp(
        make_local(dest_id), "CmpLt",
        make_copy_op(a_id), make_copy_op(b_id)
    ))

fn make_masked_add_inst(dest_id: i64, mask_id: i64, a_id: i64, b_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.MaskedAdd(
        make_local(dest_id),
        make_copy_op(mask_id),
        make_copy_op(a_id),
        make_copy_op(b_id)
    ))

fn make_masked_mul_inst(dest_id: i64, mask_id: i64, a_id: i64, b_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.MaskedMul(
        make_local(dest_id),
        make_copy_op(mask_id),
        make_copy_op(a_id),
        make_copy_op(b_id)
    ))

fn make_masked_fma_inst(dest_id: i64, mask_id: i64, a_id: i64, b_id: i64, c_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.MaskedFma(
        make_local(dest_id),
        make_copy_op(mask_id),
        make_copy_op(a_id),
        make_copy_op(b_id),
        make_copy_op(c_id)
    ))

fn make_binop_inst(dest_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.BinOp(
        make_local(dest_id), MirBinOp.Add,
        make_copy_op(0), make_copy_op(0)
    ))

fn make_test_block(id: i64, insts: [MirInst]) -> MirBlock:
    MirBlock(
        id: make_block_id(id),
        label: nil,
        instructions: insts,
        terminator: make_jump_terminator()
    )

fn inst_is_predicated_add(inst: MirInst) -> bool:
    match inst.kind:
        case PredicatedAdd(_, _, _, _, _, _): true
        case _: false

fn inst_is_predicated_mul(inst: MirInst) -> bool:
    match inst.kind:
        case PredicatedMul(_, _, _, _, _, _): true
        case _: false

fn inst_is_predicated_fma(inst: MirInst) -> bool:
    match inst.kind:
        case PredicatedFma(_, _, _, _, _, _, _): true
        case _: false

fn inst_is_mask_from_cmp(inst: MirInst) -> bool:
    match inst.kind:
        case MaskFromCmp(_, _, _, _): true
        case _: false

fn inst_is_masked_add(inst: MirInst) -> bool:
    match inst.kind:
        case MaskedAdd(_, _, _, _): true
        case _: false

# ============================================================================
# Positive cases — fusion should produce Predicated* ops
# ============================================================================

describe "predicate_promote — MaskFromCmp+MaskedAdd fuses to PredicatedAdd":
    it "two-instruction block yields one instruction after fusion":
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2),
            make_masked_add_inst(20, 10, 3, 4)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(1)
        expect(inst_is_predicated_add(result.instructions[0])).to_equal(true)

describe "predicate_promote — MaskFromCmp+MaskedMul fuses to PredicatedMul":
    it "two-instruction block yields one PredicatedMul":
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2),
            make_masked_mul_inst(20, 10, 3, 4)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(1)
        expect(inst_is_predicated_mul(result.instructions[0])).to_equal(true)

describe "predicate_promote — MaskFromCmp+MaskedFma fuses to PredicatedFma":
    it "two-instruction block yields one PredicatedFma":
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2),
            make_masked_fma_inst(20, 10, 3, 4, 5)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(1)
        expect(inst_is_predicated_fma(result.instructions[0])).to_equal(true)

describe "predicate_promote — fuses second pair in block independently":
    it "block with two MaskFromCmp+MaskedAdd pairs yields two PredicatedAdd instructions":
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2),
            make_masked_add_inst(20, 10, 3, 4),
            make_mask_from_cmp_inst(11, 5, 6),
            make_masked_add_inst(21, 11, 7, 8)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(2)
        expect(inst_is_predicated_add(result.instructions[0])).to_equal(true)
        expect(inst_is_predicated_add(result.instructions[1])).to_equal(true)

describe "predicate_promote — operand_is_local utility":
    it "Copy operand matching local id returns true":
        val op = make_copy_op(42)
        val id = make_local(42)
        expect(operand_is_local(op, id)).to_equal(true)
    it "Copy operand with different id returns false":
        val op = make_copy_op(42)
        val id = make_local(99)
        expect(operand_is_local(op, id)).to_equal(false)

# ============================================================================
# Negative cases — no fusion when conditions are not met
# ============================================================================

describe "predicate_promote — wrong mask local: both instructions preserved":
    it "MaskedAdd referencing a different local yields 2 instructions":
        # MaskFromCmp produces %10, MaskedAdd consumes %11 (mismatch)
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2),
            make_masked_add_inst(20, 11, 3, 4)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(2)
        expect(inst_is_mask_from_cmp(result.instructions[0])).to_equal(true)
        expect(inst_is_masked_add(result.instructions[1])).to_equal(true)

describe "predicate_promote — non-adjacent: intervening instruction blocks fusion":
    it "MaskFromCmp, BinOp, MaskedAdd yields 3 instructions unchanged":
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2),
            make_binop_inst(99),
            make_masked_add_inst(20, 10, 3, 4)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(3)
        expect(inst_is_mask_from_cmp(result.instructions[0])).to_equal(true)

describe "predicate_promote — standalone MaskedAdd without prior MaskFromCmp":
    it "single MaskedAdd in block is passed through unchanged":
        val insts = [
            make_masked_add_inst(20, 10, 3, 4)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(1)
        expect(inst_is_masked_add(result.instructions[0])).to_equal(true)

# ============================================================================
# No-op / structural invariant
# ============================================================================

describe "predicate_promote — empty module passes through unchanged":
    it "run_predicate_promote on empty module returns 0 functions":
        val result = run_predicate_promote(MirModule(functions: {}))
        expect(result.functions.len()).to_equal(0)

describe "predicate_promote — trailing MaskFromCmp with no following Masked* is preserved":
    it "lone MaskFromCmp at end of block is kept":
        val insts = [
            make_mask_from_cmp_inst(10, 1, 2)
        ]
        val blk = make_test_block(1, insts)
        val result = promote_block_predicate(blk)
        expect(result.instructions.len()).to_equal(1)
        expect(inst_is_mask_from_cmp(result.instructions[0])).to_equal(true)
