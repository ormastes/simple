describe "Unified registry bootstrap source":
    it "uses compiled-safe dictionary iteration for custom literals":
        val source = file_read("src/compiler/15.blocks/blocks/unified_registry.spl")

        expect(source).to_contain("for name in literals_config.custom.keys():")
        expect(source).to_contain("val lit_def = literals_config.custom[name]")
        expect(source.index_of("for name, lit_def in literals_config.custom:")).to_be_nil()
