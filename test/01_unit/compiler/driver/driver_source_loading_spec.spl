use std.spec.*
use compiler.driver.driver_source_loading.{_driver_module_aliases}

describe "driver source module aliases":
    it "keeps physical lib identity and adds the public std alias":
        val aliases = _driver_module_aliases(
            "src/lib/gc_async_mut/gpu/engine2d/simd_native_rows.spl",
            "fn marker(): pass",
            "lib.gc_async_mut.gpu.engine2d.simd_native_rows"
        )

        expect(aliases.len()).to_equal(2)
        expect(aliases[0].module_name).to_equal("lib.gc_async_mut.gpu.engine2d.simd_native_rows")
        expect(aliases[1].module_name).to_equal("std.gc_async_mut.gpu.engine2d.simd_native_rows")
