# # CompileResult Free Accessors
#
# **Feature ID:** #COMPILER-DRIVER-COMPILE-RESULT-ACCESSORS
# **Category:** Compiler | Driver | Core Types
# **Status:** Implemented
#
# `compile_result_is_success` / `compile_result_errors`
# (src/compiler/00.common/driver_core_types.spl) are the free-function mirrors
# of `CompileResult.is_success()` / `CompileResult.get_errors()`, added so
# bootstrap-reachable callers (MIR-lowered without HIR type inference) can
# resolve the accessor by plain symbol name instead of a method call on an
# erased receiver (Task #145 erased-receiver class). These specs pin their
# behavior across every CompileResult variant, and confirm
# `driver_core_compile_options_default()` — the body `CompileOptions.default()`
# forwards to for the same bootstrap-resolution reason — returns the same
# defaults as the static method.

use std.spec
use compiler.common.driver_core_types.{CompileOptions, CompileResult, compile_result_is_success, compile_result_errors, driver_core_compile_options_default}

describe "compile_result_is_success":
    it "is true only for Success":
        expect(compile_result_is_success(CompileResult.Success(nil))).to_equal(true)

    it "is false for TypeError":
        expect(compile_result_is_success(CompileResult.TypeError(["bad type"]))).to_equal(false)

    it "is false for ParseError":
        expect(compile_result_is_success(CompileResult.ParseError(["bad parse"]))).to_equal(false)

    it "is false for BlockError":
        expect(compile_result_is_success(CompileResult.BlockError(["bad block"]))).to_equal(false)

    it "is false for ResolveError":
        expect(compile_result_is_success(CompileResult.ResolveError(["bad resolve"]))).to_equal(false)

    it "is false for BorrowError":
        expect(compile_result_is_success(CompileResult.BorrowError(["bad borrow"]))).to_equal(false)

    it "is false for CodegenError":
        expect(compile_result_is_success(CompileResult.CodegenError("bad codegen"))).to_equal(false)

    it "is false for RuntimeError":
        expect(compile_result_is_success(CompileResult.RuntimeError("bad runtime"))).to_equal(false)

describe "compile_result_errors":
    it "returns an empty list for Success":
        expect(compile_result_errors(CompileResult.Success(nil)).len()).to_equal(0)

    it "passes through the TypeError list verbatim":
        val errs = compile_result_errors(CompileResult.TypeError(["e1", "e2"]))
        expect(errs.len()).to_equal(2)
        expect(errs[0]).to_equal("e1")
        expect(errs[1]).to_equal("e2")

    it "passes through the ParseError list verbatim":
        val errs = compile_result_errors(CompileResult.ParseError(["parse fail"]))
        expect(errs.len()).to_equal(1)
        expect(errs[0]).to_equal("parse fail")

    it "passes through the BlockError list verbatim":
        val errs = compile_result_errors(CompileResult.BlockError(["block fail"]))
        expect(errs.len()).to_equal(1)
        expect(errs[0]).to_equal("block fail")

    it "passes through the ResolveError list verbatim":
        val errs = compile_result_errors(CompileResult.ResolveError(["resolve fail"]))
        expect(errs.len()).to_equal(1)
        expect(errs[0]).to_equal("resolve fail")

    it "passes through the BorrowError list verbatim":
        val errs = compile_result_errors(CompileResult.BorrowError(["borrow fail"]))
        expect(errs.len()).to_equal(1)
        expect(errs[0]).to_equal("borrow fail")

    it "wraps the single CodegenError message in a one-element list":
        val errs = compile_result_errors(CompileResult.CodegenError("codegen fail"))
        expect(errs.len()).to_equal(1)
        expect(errs[0]).to_equal("codegen fail")

    it "wraps the single RuntimeError message in a one-element list":
        val errs = compile_result_errors(CompileResult.RuntimeError("runtime fail"))
        expect(errs.len()).to_equal(1)
        expect(errs[0]).to_equal("runtime fail")

describe "compile_result_is_success and compile_result_errors are consistent":
    it "never reports both success and a non-empty error list":
        val r = CompileResult.TypeError(["x"])
        expect(compile_result_is_success(r)).to_equal(false)
        expect(compile_result_errors(r).len() > 0).to_equal(true)

    it "never reports a non-empty error list for a Success result":
        val r = CompileResult.Success(nil)
        expect(compile_result_is_success(r)).to_equal(true)
        expect(compile_result_errors(r).len()).to_equal(0)

describe "driver_core_compile_options_default matches CompileOptions.default":
    it "produces field-for-field identical defaults to the static method":
        val free_fn = driver_core_compile_options_default()
        val static_method = CompileOptions.default()
        expect(free_fn.mode).to_equal(static_method.mode)
        expect(free_fn.input_files.len()).to_equal(static_method.input_files.len())
        expect(free_fn.output_file).to_equal(static_method.output_file)
        expect(free_fn.output_format).to_equal(static_method.output_format)
        expect(free_fn.optimize).to_equal(static_method.optimize)
        expect(free_fn.opt_level).to_equal(static_method.opt_level)
        expect(free_fn.release).to_equal(static_method.release)
        expect(free_fn.debug_info).to_equal(static_method.debug_info)
        expect(free_fn.verbose).to_equal(static_method.verbose)
        expect(free_fn.log_level).to_equal(static_method.log_level)
        expect(free_fn.profile).to_equal(static_method.profile)
        expect(free_fn.no_borrow_check).to_equal(static_method.no_borrow_check)
        expect(free_fn.backend).to_equal(static_method.backend)
        expect(free_fn.interpreter_mode).to_equal(static_method.interpreter_mode)
        expect(free_fn.gc_off).to_equal(static_method.gc_off)
        expect(free_fn.smf_output_mode).to_equal(static_method.smf_output_mode)
        expect(free_fn.low_memory).to_equal(static_method.low_memory)
        expect(free_fn.debug_trace_level).to_equal(static_method.debug_trace_level)
        expect(free_fn.allowed_families.len()).to_equal(static_method.allowed_families.len())
        expect(free_fn.build_mode).to_equal(static_method.build_mode)
        expect(free_fn.bootstrap_input_count).to_equal(static_method.bootstrap_input_count)

    it "defaults to an unrestricted, JIT, dev-profile configuration":
        val opts = driver_core_compile_options_default()
        expect(opts.profile).to_equal("dev")
        expect(opts.backend).to_equal("auto")
        expect(opts.build_mode).to_equal("debug")
        expect(opts.allowed_families.len()).to_equal(0)
        expect(opts.gc_off).to_equal(false)
        expect(opts.release).to_equal(false)
