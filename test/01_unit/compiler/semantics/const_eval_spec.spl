use compiler.semantics.const_eval.{ConstValue}

describe "ConstValue text formatting":
    it "formats nested values through the typed formatter":
        val value = ConstValue.Tuple([
            ConstValue.Int(7),
            ConstValue.Array([ConstValue.Bool(true), ConstValue.String("ok")])
        ])

        expect(value.to_text()).to_equal("(7, [true, \"ok\"])")
