#!/usr/bin/env simple
# Preprocessor @when/@cfg Conditional Compilation Tests
#
# Tests the @when/@elif/@else/@end block directives and @cfg per-declaration
# conditional compilation that replaced the old #if/#elif/#else/#endif syntax.

use std.spec.*
use compiler.frontend.frontend.{preprocess_conditionals}
use compiler.frontend.core.cfg_platform.{cfg_detect_arch}

describe "Preprocessor @when/@cfg":
    describe "@when block directives":
        it "@when(true) includes block":
            # @when(true):
            #     val x = 1
            # @end
            # The block should be included when condition is true
            expect("@when(true):\n    val x = 1\n@end").to_contain("@when(true)")

        it "@when(false) excludes block":
            # @when(false):
            #     val x = 1
            # @end
            # The block should be excluded when condition is false
            expect("@when(false):\n    val x = 1\n@end").to_contain("@when(false)")

        it "@when/@elif/@else/@end full chain":
            # @when(false):
            #     val branch = "first"
            # @elif(true):
            #     val branch = "second"
            # @else:
            #     val branch = "third"
            # @end
            # Only the @elif branch should be included
            expect("@when(false):\n@elif(true):\n@else:\n@end").to_contain("@elif(true)")

        it "@else branch activates when all prior false":
            # @when(false):
            #     val x = 1
            # @elif(false):
            #     val x = 2
            # @else:
            #     val x = 3
            # @end
            # The @else branch should be the active one
            expect("@when(false):\n@elif(false):\n@else:\n@end").to_contain("@else:")

    describe "nested @when blocks":
        it "nested @when blocks work correctly":
            # @when(true):
            #     @when(true):
            #         val inner = 1
            #     @end
            # @end
            # Nested blocks should both be evaluated
            expect("@when(true):\n    @when(true):\n    @end\n@end").to_contain("    @when(true)")

        it "nested @when false in true parent excludes inner":
            # @when(true):
            #     @when(false):
            #         val inner = 1
            #     @end
            # @end
            expect("@when(true):\n    @when(false):\n    @end\n@end").to_contain("@when(false)")

    describe "boolean conditions":
        it "@when(linux and x86_64) uses boolean AND":
            # Tests combined OS + arch condition
            expect("@when(linux and x86_64):").to_contain(" and ")

        it "@when(not windows) uses boolean NOT":
            # Tests negated condition
            expect("@when(not windows):").to_contain("not windows")

        it "@when(linux or macos) uses boolean OR":
            # Tests OR condition
            expect("@when(linux or macos):").to_contain(" or ")

    describe "@cfg per-declaration":
        it "@cfg(true) includes following declaration":
            # @cfg(true)
            # fn included(): ...
            # The function should be available
            expect("@cfg(true)\nfn included():").to_start_with("@cfg(true)")

        it "@cfg(false) excludes following declaration":
            # @cfg(false)
            # fn excluded(): ...
            # The function should NOT be available
            expect("@cfg(false)\nfn excluded():").to_contain("@cfg(false)")

        it "@cfg with key-value form":
            # @cfg("os", "linux")
            # fn linux_only(): ...
            # Key-value form is converted to os=linux for evaluation
            expect("@cfg(\"os\", \"linux\")\nfn linux_only():").to_contain("\"linux\"")

    describe "line count preservation":
        it "blanked directives preserve line count":
            # All @when/@elif/@else/@end lines are replaced with empty lines
            # so that diagnostics line numbers remain correct
            val before = "@when(true):\nval x = 1\n@end"
            val after = "\nval x = 1\n"
            expect(before.split("\n").len()).to_equal(after.split("\n").len())

    describe "platform conditions":
        it "@when(linux) detects Linux":
            # Should be true on Linux hosts
            expect("@when(linux):").to_contain("linux")

        it "@when(unix) detects Unix-like systems":
            # Should be true on Linux, macOS, FreeBSD, etc.
            expect("@when(unix):").to_contain("unix")

# ================================================================
# Task #45 residual — source-driven same-name @cfg/@when arch dispatch
# ================================================================
# #45: two same-named functions gated by different @cfg(arch) conditions
# resolved to whichever was DECLARED FIRST, instead of the host-matching
# one (last/first-write-wins bug). Repro: bin/simple run on a same-name
# arch_name() pair still shows the pre-fix symptom on the deployed binary
# ("arm64" wins when the arm64 variant is declared first, on an x86_64
# host) — that is expected: the deployed binary's self-compiled frontend
# is redeploy-gated. This block verifies the FIX ITSELF straight from
# current .spl source, independent of the deployed binary.
#
# Investigation trail (see git log):
#   - d4ae10aeb3c "fix(interpreter): evaluate @cfg conditions at
#     registration time (#45)" touches src/app/interpreter/module/
#     evaluator.spl's evaluate_module/cfg_decorators_active. That function
#     has zero callers anywhere in src/ or test/ (grep "evaluate_module(")
#     and its item types (Node/FunctionDef with a `.decorators` field) do
#     not match any struct/enum defined in the .spl tree — this is
#     orphaned code on a path `bin/simple run` never executes.
#   - cb8d9df703558 "fix(frontend): activate @cfg stripping (was inert) +
#     native host arch/os detection" (one day earlier) is the REAL fix:
#     src/compiler/10.frontend/frontend.spl's `preprocess_conditionals`
#     used to be a local passthrough (`fn preprocess_conditionals(source):
#     source`) that bare-name-shadowed its own
#     `use compiler.core.parser_preprocessor.{preprocess_conditionals}`
#     import, so @cfg/@when stripping never ran and the FIRST-declared
#     same-name variant always won regardless of host arch. The fix
#     delegates to the uniquely-named `_pp_preprocess_conditionals` so the
#     real text-level stripping (which blanks the losing declaration
#     entirely before parsing) always executes.
#   - `preprocess_conditionals` here is imported from
#     `compiler.frontend.frontend` (the exact function that had the #45
#     regression), driven directly from source — not a hand-rolled
#     reimplementation of its logic.
describe "Task #45 residual — same-name arch dispatch (source-driven)":
    it "reassembles spaced key value cfg conditions":
        val arch = cfg_detect_arch()
        val src = "@cfg(arch = \"{arch}\")\nfn single_equals() -> text:\n    \"kept-single\"\n\n@cfg(arch == \"{arch}\")\nfn double_equals() -> text:\n    \"kept-double\"\n"
        val out = preprocess_conditionals(src)
        expect(out.contains("kept-single")).to_equal(true)
        expect(out.contains("kept-double")).to_equal(true)

    it "keeps the host-matching @cfg variant, x86_64 declared first (order A)":
        val src = "@cfg(x86_64)\nfn arch_name() -> text:\n    \"x86_64\"\n\n@cfg(arm64)\nfn arch_name() -> text:\n    \"arm64\"\n"
        val out = preprocess_conditionals(src)
        expect(out.contains("\"x86_64\"")).to_equal(true)
        expect(out.contains("\"arm64\"")).to_equal(false)

    it "keeps the host-matching @cfg variant, arm64 declared first (order B — the #45 regression order)":
        val src = "@cfg(arm64)\nfn arch_name() -> text:\n    \"arm64\"\n\n@cfg(x86_64)\nfn arch_name() -> text:\n    \"x86_64\"\n"
        val out = preprocess_conditionals(src)
        expect(out.contains("\"x86_64\"")).to_equal(true)
        expect(out.contains("\"arm64\"")).to_equal(false)

    it "@when sibling path: keeps the host-matching block-form variant regardless of order":
        # cfg_eval_key_value/cfg_detect_arch (compiler.core.cfg_platform) is
        # shared between the per-declaration @cfg path and the block-scoped
        # @when path (both route through preprocess_conditionals's two
        # preprocessing passes in _pp_preprocess_conditionals). This proves
        # the @when sibling has no analogous same-name gap in the current
        # source: the false-condition block is blanked in its entirety
        # before parsing, same as @cfg, so no duplicate name ever reaches
        # the parser/interpreter to race on declaration order.
        val src = "@when(arm64)\nfn arch_name() -> text:\n    \"arm64\"\n@end\n\n@when(x86_64)\nfn arch_name() -> text:\n    \"x86_64\"\n@end\n"
        val out = preprocess_conditionals(src)
        expect(out.contains("\"x86_64\"")).to_equal(true)
        expect(out.contains("\"arm64\"")).to_equal(false)
