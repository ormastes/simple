# Interpolation Fragment Sticky par_had_error Regression
#
# Bug: commit 102035b227f added a phase-2 gate in driver.spl's parse_all_impl
# (`if par_had_error_get(): fail phase 2`) so real parse errors are no longer
# silently ignored. But `par_had_error` (compiler.core.parser) is a single
# sticky module global, and `flat_bridge_parse_interp_inner`
# (_FlatAstBridge/convert_nodes.spl) sub-lexes+parses each `{...}` region of a
# string literal as a SPECULATIVE fragment: if the region isn't a clean single
# expression it deliberately falls back to a plain literal (see the `idx < 0`
# path) — a recovered, by-design failure, not a real module-level parse
# error. Before the fix, that recovered failure still set `par_had_error`,
# and nothing ever cleared it again, so a file containing e.g. a JSON/CSS-ish
# brace run inside a string (not real interpolation) would fail phase 2 even
# though its AST is fine.
#
# @cover src/compiler/10.frontend/_FlatAstBridge/convert_nodes.spl 5%

use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.core.ast.{ast_reset}
use compiler.core.parser.{parser_has_errors, parser_diagnostics_suppressed_get, parser_warnings_get}
use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.hir.hir_lowering.items.*

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool

describe "Flat AST bridge interpolation fragment recovery does not stick par_had_error":
    it "recovers from a non-expression brace region in a string literal without leaving par_had_error set":
        # `{,}` is not a clean single expression (a bare comma), so
        # flat_bridge_parse_interp_inner's primary-expr parse fails silently
        # for the FRAGMENT (not the real module source) and returns -1
        # so the whole string is kept as a plain literal.
        val src = "val s = \"prefix {,} suffix\"\n"
        val module = parse_and_build_module(src, "test_interp_fragment_recovery.spl")

        expect(module.constants.contains("s")).to_equal(true)
        expect(parser_has_errors()).to_equal(false)
        expect(parser_diagnostics_suppressed_get()).to_equal(false)
        expect(parser_warnings_get().len()).to_equal(0)

    it "keeps brace-literal function scopes isolated during bootstrap HIR lowering":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)

        # Build the June 2026 repro source without placing its unmatched open
        # and close braces in one host-test string literal.
        val open = "{"
        val close = "}"
        val src = "fn open_brace(x: text) -> text:\n    \" " + open + " \"\n\n" +
            "fn main():\n" +
            "    val ob = open_brace(\"unused\")\n" +
            "    val rule = \".a\" + ob + \"color: red\" + \" " + close + " \"\n" +
            "    print(\"RULE: [\" + rule + \"]\")\n\n" +
            "main()\n"

        ast_reset()
        val module = parse_and_build_module(src, "brace_literal_scope.spl")
        var lowering = HirLowering.with_filename("brace_literal_scope.spl")
        val hir = lowering.lower_module(module)
        val open_id = hir.symbols.lookup("open_brace")
        val main_id = hir.symbols.lookup("main")
        var kept_open = false
        var kept_main = false
        for function in hir.functions.values():
            if function.name == "open_brace":
                kept_open = true
            if function.name == "main":
                kept_main = true

        expect(parser_has_errors()).to_equal(false)
        expect(lowering.errors.len()).to_equal(0)
        expect(open_id.?).to_equal(true)
        expect(main_id.?).to_equal(true)
        expect(kept_open).to_equal(true)
        expect(kept_main).to_equal(true)

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)

    it "still reports a real top-level parse error via the same flag":
        # Sanity check: the fix must not blind the gate to genuine module-level
        # parse errors (e.g. a truncated function with no body).
        val bad_src = "fn broken(\n"
        val bad_module = parse_and_build_module(bad_src, "test_real_parse_error.spl")

        expect(parser_has_errors()).to_equal(true)
