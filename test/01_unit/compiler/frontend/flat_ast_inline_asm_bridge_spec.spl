# Flat AST bridge inline asm fidelity.
#
# Regression guard: EXPR_ASM used to fall through convert_flat_expr and become
# NilLit/identifier-shaped output, making HIR/JIT report "Unknown variable: asm"
# and fall back to the slow interpreter path before native-build created any .o.

use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.frontend.parser_types.*

fn first_asm_template(src: text) -> text:
    val m = parse_and_build_module(src, "flat_ast_inline_asm_bridge_spec.spl")
    val fn_ = m.functions["test"] ?? panic("missing test function")
    for stmt in fn_.body.stmts:
        match stmt.kind:
            case StmtKind.Expr(expr):
                match expr.kind:
                    case ExprKind.AsmBlock(asm_node):
                        return asm_node.asm_template
                    case _:
                        pass
            case _:
                pass
    "missing"

describe "Flat AST bridge inline asm fidelity":
    it "preserves inline asm as typed AsmBlock nodes":
        val src = "fn test():\n    asm(\"cli\")\n"
        expect(first_asm_template(src)).to_equal("cli")

    it "preserves volatile asm text":
        val src = "fn test():\n    asm volatile(\"bkpt #0\")\n"
        expect(first_asm_template(src)).to_equal("bkpt #0")
