# Flat AST bridge inline fat-arrow match-arm fidelity.
#
# Regression guard: the parser used to store expression ids directly in an
# arm body even though every arm consumer reads statement ids.  When expression
# and statement arena indices diverged, inline arms became unrelated statements
# or NilLit nodes during conversion.

use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.frontend.parser_types.*

fn inline_match_arms(src: text) -> [MatchArm]:
    val module = parse_and_build_module(src, "flat_ast_fat_arrow_match_bridge_spec.spl")
    val fn_ = module.functions["classify"] ?? panic("missing classify function")
    for stmt in fn_.body.stmts:
        match stmt.kind:
            case StmtKind.Expr(expr):
                match expr.kind:
                    case ExprKind.MatchCase(scrutinee, arms):
                        return arms
                    case _:
                        pass
            case _:
                pass
    panic("missing bridged match expression")

describe "Flat AST bridge inline fat-arrow match arms":
    it "preserves literal and return expression arm bodies":
        val src = "fn classify(n: i64):\n    match n:\n        1 => 11\n        2 => 22\n        _ => return 33\n"
        val arms = inline_match_arms(src)

        expect(inline_match_arms_are_intact(arms)).to_equal(true)

fn inline_match_arms_are_intact(arms: [MatchArm]) -> bool:
    if arms.len() != 3:
        panic("inline match arm count changed")
    if arms[0].body.stmts.len() != 1 or arms[1].body.stmts.len() != 1 or arms[2].body.stmts.len() != 1:
        panic("inline match arm body count changed")

    match arms[0].body.stmts[0].kind:
        case StmtKind.Expr(expr):
            match expr.kind:
                case ExprKind.IntLit(value):
                    if value != 11:
                        panic("first inline arm changed its literal")
                case _:
                    panic("first inline arm lost its literal")
        case _:
            panic("first inline arm is not an expression statement")

    match arms[1].body.stmts[0].kind:
        case StmtKind.Expr(expr):
            match expr.kind:
                case ExprKind.IntLit(value):
                    if value != 22:
                        panic("second inline arm changed its literal")
                case _:
                    panic("second inline arm lost its literal")
        case _:
            panic("second inline arm is not an expression statement")

    match arms[2].body.stmts[0].kind:
        case StmtKind.Expr(expr):
            match expr.kind:
                case ExprKind.Return(value):
                    val returned = value ?? panic("return arm lost its value")
                    match returned.kind:
                        case ExprKind.IntLit(number):
                            if number != 33:
                                panic("return arm changed its value")
                        case _:
                            panic("return arm value is not a literal")
                case _:
                    panic("third inline arm lost its return")
        case _:
            panic("third inline arm is not an expression statement")
    true

fn main():
    val src = "fn classify(n: i64):\n    match n:\n        1 => 11\n        2 => 22\n        _ => return 33\n"
    inline_match_arms_are_intact(inline_match_arms(src))
    print("flat_ast_fat_arrow_match_bridge=true")
