# # Pretty Printer Unit Tests
#
# **Feature ID:** #COMPILER-FRONTEND-004
# **Category:** Compiler | Frontend | Pretty Printer
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Format Expressions":
    it "format integer literal":
        val s = "{42}"
        check(s == "42")

    it "format negative integer":
        val s = "{-5}"
        check(s == "-5")

    it "format float literal":
        val x = 3.14
        val s = "{x}"
        check(s.contains("3.14"))

    it "format string literal":
        val s = "hello"
        check(s == "hello")

    it "format boolean true":
        val s = "{true}"
        check(s == "true")

    it "format boolean false":
        val s = "{false}"
        check(s == "false")

    it "format array":
        val arr = [1, 2, 3]
        val s = "{arr}"
        check(s.contains("1"))
        check(s.contains("3"))

describe "Format Statements":
    it "format val declaration":
        val decl = "val x = 42"
        check(decl.starts_with("val"))

    it "format var declaration":
        val decl = "var x = 42"
        check(decl.starts_with("var"))

    it "format assignment":
        val stmt = "x = 42"
        check(stmt.contains("="))

    it "format return":
        val stmt = "return 42"
        check(stmt.starts_with("return"))

describe "Format Control Flow":
    it "format if statement":
        val stmt = "if x > 0:"
        check(stmt.starts_with("if"))

    it "format while loop":
        val stmt = "while i < 10:"
        check(stmt.starts_with("while"))

    it "format for loop":
        val stmt = "for i in 0..10:"
        check(stmt.starts_with("for"))

    it "format match":
        val stmt = "match x:"
        check(stmt.starts_with("match"))

describe "Indentation":
    it "top level no indent":
        val indent = 0
        check(indent == 0)

    it "block body indented":
        val indent = 4
        check(indent == 4)

    it "nested block double indented":
        val indent = 8
        check(indent == 8)

    it "consistent indent width":
        val width = 4
        val level1 = width
        val level2 = width * 2
        val level3 = width * 3
        check(level1 == 4)
        check(level2 == 8)
        check(level3 == 12)
