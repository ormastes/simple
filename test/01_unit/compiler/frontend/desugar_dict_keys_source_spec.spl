extern fn rt_file_read_text(path: text) -> text

describe "async desugar Dict key traversal source":
    it "uses the typed Dict runtime owner instead of ambiguous Map dispatch":
        val source = rt_file_read_text("src/compiler/10.frontend/desugar/desugar_async.spl") ?? ""

        expect(source).to_contain("use std.alloc.sffi.{rt_dict_keys}")
        expect(source).to_contain("val function_names: [text] = rt_dict_keys(module.functions)")
        expect(source).to_contain("val helper_names: [text] = rt_dict_keys(generated_helper_functions)")
        expect(source).to_contain("val actor_names: [text] = rt_dict_keys(module.actors)")
