# Bootstrap AST declaration count slot regression.
#
# @cover src/compiler/10.frontend/core/_Ast/decl_nodes.spl
# @cover src/compiler/10.frontend/core/_Ast/module_state.spl
# @cover src/compiler/10.frontend/core/_AstExpr/nodes.spl
# @cover src/compiler/10.frontend/core/ast_stmt.spl

use compiler.core.ast.{
    ast_reset, decl_count, decl_fn, decl_set_impl_trait, decl_get_impl_trait,
    decl_set_trait, decl_get_is_trait, decl_set_param_muts, decl_get_param_muts, module_add_decl,
    module_decl_at, module_decl_count_get
}
use compiler.core.ast_stmt.{stmt_gpu_launch, stmt_get_gpu_grid, stmt_get_gpu_block}
use compiler.core.ast_expr.{asm_arm_new, asm_arm_archs}
use compiler.frontend.flat_ast_bridge.{flat_ast_to_module, parse_and_build_module}

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_file_read_text(path: text) -> text

describe "bootstrap AST declaration count slots":
    it "reuses AST arenas across file resets":
        val decl_reset = rt_file_read_text("src/compiler/10.frontend/core/_Ast/module_state.spl") ?? ""
        val expr_reset = rt_file_read_text("src/compiler/10.frontend/core/_AstExpr/nodes.spl") ?? ""
        val stmt_reset = rt_file_read_text("src/compiler/10.frontend/core/ast_stmt.spl") ?? ""

        expect(decl_reset).to_contain("decl_tag.clear()")
        expect(decl_reset).to_contain("decl_impl_trait.clear()")
        expect(decl_reset).to_contain("decl_param_mut_text.clear()")
        expect(decl_reset).to_contain("module_decl_slots.clear()")
        expect(decl_reset).to_not_contain("    decl_tag = []\n    decl_span = []")
        expect(expr_reset).to_contain("expr_tag.clear()")
        expect(expr_reset).to_contain("asm_arm_archs.clear()")
        expect(expr_reset).to_not_contain("    expr_tag = []\n    expr_span = []")
        expect(stmt_reset).to_contain("stmt_gpu_grid_exprs.clear()")
        expect(stmt_reset).to_not_contain("    stmt_tag = []\n    stmt_span = []")

    it "clears GPU and asm metadata between parses":
        ast_reset()
        val first_gpu = stmt_gpu_launch([1], [2], [], 0)
        val first_asm = asm_arm_new(["x86_64"], "linux", "gnu", "llvm", [], [], "nop", false, "", false)
        expect(first_gpu).to_equal(0)
        expect(first_asm).to_equal(0)

        ast_reset()
        val fresh_gpu = stmt_gpu_launch([3], [4], [], 0)
        val fresh_asm = asm_arm_new(["aarch64"], "macos", "", "llvm", [], [], "ret", false, "", false)
        expect(fresh_gpu).to_equal(0)
        expect(fresh_asm).to_equal(0)
        expect(stmt_get_gpu_grid(fresh_gpu)).to_equal([3])
        expect(stmt_get_gpu_block(fresh_gpu)).to_equal([4])
        expect(asm_arm_archs[fresh_asm]).to_equal(["aarch64"])

        ast_reset()

    it "keeps declaration counts in arena when the env mirror is cleared":
        ast_reset()
        val d = decl_fn("arena_count_guard", [], [], 0, [], 0, [], 0)
        module_add_decl(d)

        expect(decl_count()).to_equal(1)
        expect(module_decl_count_get()).to_equal(1)
        expect(module_decl_at(0)).to_equal(d)

        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_COUNT", "")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_MODULE_DECL_COUNT", "")).to_equal(true)

        expect(decl_count()).to_equal(1)
        expect(module_decl_count_get()).to_equal(1)
        expect(module_decl_at(0)).to_equal(d)

        ast_reset()
        expect(decl_count()).to_equal(0)
        expect(module_decl_count_get()).to_equal(0)

    it "uses arena declaration tags when bootstrap tag env mirrors are absent":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)

        ast_reset()
        val d = decl_fn("arena_tag_guard", [], [], 0, [], 0, [], 0)
        module_add_decl(d)
        val module = flat_ast_to_module("src/app/cli/bootstrap_main.spl")

        expect(module.functions.contains("arena_tag_guard")).to_equal(true)

        decl_set_impl_trait(d, "StaleTrait")
        decl_set_trait(d, [])
        decl_set_param_muts(d, [1])
        expect(decl_get_impl_trait(d)).to_equal("StaleTrait")
        expect(decl_get_is_trait(d)).to_equal(1)
        expect(decl_get_param_muts(d)).to_equal([1])

        ast_reset()
        val fresh = decl_fn("fresh_metadata_guard", [], [], 0, [], 0, [], 0)
        expect(fresh).to_equal(0)
        expect(decl_get_impl_trait(fresh)).to_equal("")
        expect(decl_get_is_trait(fresh)).to_equal(0)
        expect(decl_get_param_muts(fresh)).to_equal([])

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)).to_equal(true)

    it "builds bootstrap-path functions with arena metadata only":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)

        val path = "src/app/cli/bootstrap_main.spl"
        val source = "fn main() -> i64:\n    0\n\nfn run_native_build_bootstrap(args: [text]) -> i64:\n    1\n"
        val module = parse_and_build_module(source, path)

        expect(module.functions.contains("main")).to_equal(true)
        expect(module.functions.contains("run_native_build_bootstrap")).to_equal(true)
        expect(module.functions.len()).to_be_greater_than(0)

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)).to_equal(true)

    it "builds requested native-build entry functions in bootstrap mode":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        val old_native_entry = rt_env_get("SIMPLE_NATIVE_BUILD_ENTRY") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_BUILD_ENTRY", "src/app/mcp/main.spl")).to_equal(true)

        val source = "fn main() -> i64:\n    0\n"
        val module = parse_and_build_module(source, "src/app/mcp/main.spl")

        expect(module.functions.contains("main")).to_equal(true)
        expect(module.functions.len()).to_be_greater_than(0)

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)).to_equal(true)
