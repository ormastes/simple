# Bootstrap AST declaration count slot regression.
#
# @cover src/compiler/10.frontend/core/_Ast/decl_nodes.spl
# @cover src/compiler/10.frontend/core/_Ast/module_state.spl
# @cover src/compiler/10.frontend/core/_AstExpr/nodes.spl
# @cover src/compiler/10.frontend/core/ast_stmt.spl

use compiler.core.ast.{
    ast_reset, decl_count, decl_fn, decl_struct_def,
    decl_get_tag, decl_get_name, decl_get_fields, decl_get_field_types,
    decl_get_type_params, decl_get_visibility_text,
    decl_set_impl_trait, decl_get_impl_trait,
    decl_set_trait, decl_get_is_trait, decl_get_is_comptime, decl_get_is_lazy,
    decl_set_param_muts, decl_get_param_muts, module_add_decl,
    module_decl_at, module_decl_count_get
}
use compiler.core.ast_stmt.{
    stmt_count, stmt_get_tag, stmt_gpu_launch, stmt_get_gpu_grid, stmt_get_gpu_block, stmt_tag
}
use compiler.core.ast_expr.{
    expr_count, expr_get_tag, expr_tag,
    asm_arm_new, asm_arm_archs, asm_arm_os, asm_arm_abi, asm_arm_backend,
    asm_arm_ver_ops, asm_arm_ver_vals, asm_arm_asm_text, asm_arm_is_compile_error,
    asm_arm_error_msg, asm_arm_is_wildcard
}
use compiler.frontend.flat_ast_bridge.{flat_ast_to_module, parse_and_build_module}

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_file_read_text(path: text) -> text

describe "bootstrap AST declaration count slots":
    it "reuses AST arenas across file resets":
        val decl_reset = rt_file_read_text("src/compiler/10.frontend/core/_Ast/module_state.spl") ?? ""
        val expr_reset = rt_file_read_text("src/compiler/10.frontend/core/_AstExpr/nodes.spl") ?? ""
        val stmt_reset = rt_file_read_text("src/compiler/10.frontend/core/ast_stmt.spl") ?? ""

        expect(decl_reset).to_contain("decl_tag.clear()")
        expect(decl_reset).to_contain("decl_impl_trait.clear()")
        expect(decl_reset).to_contain("decl_param_mut_text.clear()")
        expect(decl_reset).to_contain("module_decl_slots.clear()")
        expect(decl_reset).to_not_contain("    decl_tag = []\n    decl_span = []")
        expect(expr_reset).to_contain("expr_tag.clear()")
        expect(expr_reset).to_contain("asm_arm_archs.clear()")
        expect(expr_reset).to_not_contain("    expr_tag = []\n    expr_span = []")
        expect(stmt_reset).to_contain("stmt_gpu_grid_exprs.clear()")
        expect(stmt_reset).to_not_contain("    stmt_tag = []\n    stmt_span = []")

    it "reuses parser and lexer state containers across file parses":
        val parser_source = rt_file_read_text("src/compiler/10.frontend/core/parser.spl") ?? ""
        val lexer_source = rt_file_read_text("src/compiler/10.frontend/core/lexer.spl") ?? ""
        val parser_init_start = parser_source.index_of("fn parser_init_with_path(source: text, path: text):") ?? -1
        val parser_advance_start = parser_source.index_of("fn parser_advance():") ?? -1
        val lexer_init_start = lexer_source.index_of("fn lex_init_with_path(source: text, source_path: text):") ?? -1
        val lexer_state_start = lexer_source.index_of("fn lex_state_get(key: text, fallback: text)") ?? -1
        expect(parser_init_start).to_be_greater_than(-1)
        expect(parser_advance_start).to_be_greater_than(parser_init_start)
        expect(lexer_init_start).to_be_greater_than(-1)
        expect(lexer_state_start).to_be_greater_than(lexer_init_start)
        val parser_init_body = parser_source.substring(parser_init_start, parser_advance_start)
        val lexer_init_body = lexer_source.substring(lexer_init_start, lexer_state_start)

        expect(parser_init_body).to_contain("par_errors.clear()")
        expect(parser_init_body).to_contain("par_warnings.clear()")
        expect(parser_init_body).to_contain("par_struct_names.clear()")
        expect(parser_init_body).to_contain("par_kind_slot[0] = 0")
        expect(parser_init_body).to_contain("par_text_slot[0] = \"\"")
        expect(parser_init_body).to_contain("par_line_slot[0] = 0")
        expect(parser_init_body).to_contain("par_col_slot[0] = 0")
        expect(parser_init_body).to_contain("par_src_cache_slot[0] = \"\"")
        expect(parser_init_body).to_contain("par_src_cache_gen_slot[0] = -1")
        for name in ["par_errors", "par_warnings", "par_struct_names", "par_kind_slot", "par_text_slot", "par_line_slot", "par_col_slot", "par_src_cache_slot", "par_src_cache_gen_slot"]:
            expect(parser_init_body).to_not_contain("\n    {name} =")
        expect(lexer_init_body).to_contain("current_core_lexer_slot[0] = fresh_core_lexer")
        val fresh_pos = lexer_init_body.index_of("val fresh_core_lexer = make_core_lexer(core_source)") ?? -1
        val retire_pos = lexer_init_body.index_of("val retired_core_lexer = current_core_lexer_slot[0]") ?? -1
        val replace_pos = lexer_init_body.index_of("current_core_lexer_slot[0] = fresh_core_lexer") ?? -1
        val release_pos = lexer_init_body.index_of("rt_array_free(retired_core_lexer.source_chars)") ?? -1
        expect(fresh_pos).to_be_greater_than(-1)
        expect(retire_pos).to_be_greater_than(fresh_pos)
        expect(replace_pos).to_be_greater_than(retire_pos)
        expect(release_pos).to_be_greater_than(replace_pos)
        expect(lexer_init_body).to_contain("if lexer_array_len(current_core_lexer_slot) == 0:\n        current_core_lexer_slot = [fresh_core_lexer]")
        expect(lexer_init_body).to_not_contain("\n    current_core_lexer_slot =")

        val large_module = parse_and_build_module("fn stale_large() -> i64:\n" + "    0\n".repeat(256), "large_state_probe.spl")
        val large_expr_count = expr_tag.len()
        val large_stmt_count = stmt_tag.len()
        expect(large_module.functions.contains("stale_large")).to_equal(true)
        expect(large_expr_count).to_be_greater_than(100)
        expect(large_stmt_count).to_be_greater_than(100)

        val small_module = parse_and_build_module("fn only_small() -> i64:\n    1\n", "small_state_probe.spl")
        expect(small_module.functions.contains("only_small")).to_equal(true)
        expect(small_module.functions.contains("stale_large")).to_equal(false)
        expect(small_module.functions.len()).to_equal(1)
        expect(decl_count()).to_equal(1)
        expect(expr_tag.len()).to_be_less_than(large_expr_count)
        expect(stmt_tag.len()).to_be_less_than(large_stmt_count)

    it "clears GPU and asm metadata between parses":
        ast_reset()
        val first_gpu = stmt_gpu_launch([1], [2], [], 0)
        val first_asm = asm_arm_new(["x86_64"], "linux", "gnu", "llvm", [], [], "nop", false, "", false)
        expect(first_gpu).to_equal(0)
        expect(first_asm).to_equal(0)

        ast_reset()
        expect(stmt_get_gpu_grid(0)).to_equal([])
        expect(stmt_get_gpu_block(0)).to_equal([])
        val cleared_asm_fields = asm_arm_archs.len() + asm_arm_os.len() + asm_arm_abi.len() + asm_arm_backend.len() + asm_arm_ver_ops.len() + asm_arm_ver_vals.len() + asm_arm_asm_text.len() + asm_arm_is_compile_error.len() + asm_arm_error_msg.len() + asm_arm_is_wildcard.len()
        expect(cleared_asm_fields).to_equal(0)
        val fresh_gpu = stmt_gpu_launch([3], [4], [], 0)
        val fresh_asm = asm_arm_new(["aarch64"], "macos", "", "llvm", [], [], "ret", false, "", false)
        expect(fresh_gpu).to_equal(0)
        expect(fresh_asm).to_equal(0)
        expect(stmt_get_gpu_grid(fresh_gpu)).to_equal([3])
        expect(stmt_get_gpu_block(fresh_gpu)).to_equal([4])
        expect(asm_arm_archs[fresh_asm]).to_equal(["aarch64"])

        ast_reset()

    it "keeps declaration counts in arena when the env mirror is cleared":
        ast_reset()
        val d = decl_fn("arena_count_guard", [], [], 0, [], 0, [], 0)
        module_add_decl(d)

        expect(decl_count()).to_equal(1)
        expect(module_decl_count_get()).to_equal(1)
        expect(module_decl_at(0)).to_equal(d)

        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_COUNT", "")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_MODULE_DECL_COUNT", "")).to_equal(true)

        expect(decl_count()).to_equal(1)
        expect(module_decl_count_get()).to_equal(1)
        expect(module_decl_at(0)).to_equal(d)

        ast_reset()
        expect(decl_count()).to_equal(0)
        expect(module_decl_count_get()).to_equal(0)

    it "uses arena declaration tags when bootstrap tag env mirrors are absent":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)

        ast_reset()
        val d = decl_fn("arena_tag_guard", [], [], 0, [], 0, [], 0)
        module_add_decl(d)
        val module = flat_ast_to_module("src/app/cli/bootstrap_main.spl")

        expect(module.functions.contains("arena_tag_guard")).to_equal(true)

        decl_set_impl_trait(d, "StaleTrait")
        decl_set_trait(d, [])
        decl_set_param_muts(d, [1])
        expect(decl_get_impl_trait(d)).to_equal("StaleTrait")
        expect(decl_get_is_trait(d)).to_equal(1)
        expect(decl_get_param_muts(d)).to_equal([1])

        ast_reset()
        val fresh = decl_fn("fresh_metadata_guard", [], [], 0, [], 0, [], 0)
        expect(fresh).to_equal(0)
        expect(decl_get_impl_trait(fresh)).to_equal("")
        expect(decl_get_is_trait(fresh)).to_equal(0)
        expect(decl_get_param_muts(fresh)).to_equal([])

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)).to_equal(true)

    it "keeps the interpreter expression and statement mirrors":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        val old_expr_count = rt_env_get("SIMPLE_BOOTSTRAP_EXPR_COUNT") ?? ""
        val old_expr_tag = rt_env_get("SIMPLE_BOOTSTRAP_EXPR_0_TAG") ?? ""
        val old_stmt_count = rt_env_get("SIMPLE_BOOTSTRAP_STMT_COUNT") ?? ""
        val old_stmt_tag = rt_env_get("SIMPLE_BOOTSTRAP_STMT_0_TAG") ?? ""
        defer:
            ast_reset()
            rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)
            rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)
            rt_env_set("SIMPLE_BOOTSTRAP_EXPR_COUNT", old_expr_count)
            rt_env_set("SIMPLE_BOOTSTRAP_EXPR_0_TAG", old_expr_tag)
            rt_env_set("SIMPLE_BOOTSTRAP_STMT_COUNT", old_stmt_count)
            rt_env_set("SIMPLE_BOOTSTRAP_STMT_0_TAG", old_stmt_tag)

        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "")).to_equal(true)
        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP_EXPR_COUNT", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_EXPR_0_TAG", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_STMT_COUNT", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_STMT_0_TAG", "1")).to_equal(true)
        expect(expr_count()).to_equal(1)
        expect(stmt_count()).to_equal(1)
        expect(expr_get_tag(0)).to_equal(1)
        expect(stmt_get_tag(0)).to_equal(1)

    it "ignores stale declaration mirrors in native arena mode":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        val old_tag = rt_env_get("SIMPLE_BOOTSTRAP_DECL_TAG_0") ?? ""
        val old_name = rt_env_get("SIMPLE_BOOTSTRAP_DECL_NAME_0") ?? ""
        val old_fields = rt_env_get("SIMPLE_BOOTSTRAP_DECL_FIELD_NAMES_0") ?? ""
        val old_field_types = rt_env_get("SIMPLE_BOOTSTRAP_DECL_FIELD_TYPES_0") ?? ""
        val old_type_params = rt_env_get("SIMPLE_BOOTSTRAP_DECL_0_TYPE_PARAMS") ?? ""
        val old_visibility = rt_env_get("SIMPLE_BOOTSTRAP_DECL_0_VIS") ?? ""
        val old_comptime = rt_env_get("SIMPLE_BOOTSTRAP_DECL_0_COMPTIME") ?? ""
        val old_lazy = rt_env_get("SIMPLE_BOOTSTRAP_DECL_0_LAZY") ?? ""
        defer:
            ast_reset()
            rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)
            rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_TAG_0", old_tag)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_NAME_0", old_name)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_FIELD_NAMES_0", old_fields)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_FIELD_TYPES_0", old_field_types)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_TYPE_PARAMS", old_type_params)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_VIS", old_visibility)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_COMPTIME", old_comptime)
            rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_LAZY", old_lazy)

        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_TAG_0", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_NAME_0", "StaleFunction")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_FIELD_NAMES_0", "stale_field")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_FIELD_TYPES_0", "999")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_TYPE_PARAMS", "StaleType")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_VIS", "public")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_COMPTIME", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_BOOTSTRAP_DECL_0_LAZY", "1")).to_equal(true)

        ast_reset()
        val current = decl_struct_def(
            "CurrentStruct", ["current_field"], [7], [-1], [-1], 0
        )
        expect(current).to_equal(0)
        expect(decl_get_tag(current)).to_equal(3)
        expect(decl_get_name(current)).to_equal("CurrentStruct")
        expect(decl_get_fields(current)).to_equal(["current_field"])
        expect(decl_get_field_types(current)).to_equal([7])
        expect(decl_get_type_params(current)).to_equal([])
        expect(decl_get_visibility_text(current)).to_equal("private")
        expect(decl_get_is_comptime(current)).to_equal(false)
        expect(decl_get_is_lazy(current)).to_equal(0)

    it "builds bootstrap-path functions with arena metadata only":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)

        val path = "src/app/cli/bootstrap_main.spl"
        val source = "fn main() -> i64:\n    0\n\nfn run_native_build_bootstrap(args: [text]) -> i64:\n    1\n"
        val module = parse_and_build_module(source, path)

        expect(module.functions.contains("main")).to_equal(true)
        expect(module.functions.contains("run_native_build_bootstrap")).to_equal(true)
        expect(module.functions.len()).to_be_greater_than(0)

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)).to_equal(true)

    it "builds requested native-build entry functions in bootstrap mode":
        val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
        val old_native_arena = rt_env_get("SIMPLE_NATIVE_ARENA_DECLS") ?? ""
        val old_native_entry = rt_env_get("SIMPLE_NATIVE_BUILD_ENTRY") ?? ""
        expect(rt_env_set("SIMPLE_BOOTSTRAP", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", "1")).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_BUILD_ENTRY", "src/app/mcp/main.spl")).to_equal(true)

        val source = "fn main() -> i64:\n    0\n"
        val module = parse_and_build_module(source, "src/app/mcp/main.spl")

        expect(module.functions.contains("main")).to_equal(true)
        expect(module.functions.len()).to_be_greater_than(0)

        ast_reset()
        expect(rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_ARENA_DECLS", old_native_arena)).to_equal(true)
        expect(rt_env_set("SIMPLE_NATIVE_BUILD_ENTRY", old_native_entry)).to_equal(true)
