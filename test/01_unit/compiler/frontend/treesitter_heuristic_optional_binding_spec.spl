use compiler.frontend.treesitter.outline_lexer.{treesitter_with_heuristic_mode}
use compiler.frontend.treesitter.heuristic.*

describe "TreeSitter heuristic colon extraction":
    it "handles signatures with a trailing colon":
        val parser = treesitter_with_heuristic_mode(true)
        expect(parser.heuristic_extract_until_colon("fn main() -> i64:")).to_equal("fn main() -> i64")

    it "keeps lines without a colon unchanged":
        val parser = treesitter_with_heuristic_mode(true)
        expect(parser.heuristic_extract_until_colon("class Worker")).to_equal("class Worker")

    it "extracts names without omitted-start slicing":
        val parser = treesitter_with_heuristic_mode(true)
        expect(parser.heuristic_extract_name("main()")).to_equal("main")
