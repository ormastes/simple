use compiler.tools.lint.main.{Linter, LintLevel, lint_cli_source}
use compiler.core.parser.{parser_has_errors, parser_set_had_error}

extern fn rt_exit(code: i32)

val linter = Linter.new()
var parse_errors = 0
var parse_error_is_deny = false
var parse_error_line = 0

parser_set_had_error(false)
for result in lint_cli_source(linter, "/tmp/lint_invalid_source.spl", "fn broken("):
    if result.lint.code == "PARSE001":
        parse_errors = parse_errors + 1
        parse_error_is_deny = result.lint.level == LintLevel.Deny
        parse_error_line = result.line
val clean_parser_state_preserved = not parser_has_errors()

parser_set_had_error(true)
val _ = lint_cli_source(linter, "/tmp/lint_invalid_prior_state.spl", "fn broken(")
val prior_parser_state_preserved = parser_has_errors()
parser_set_had_error(false)

if parse_errors != 1 or not parse_error_is_deny or parse_error_line != 1 or not clean_parser_state_preserved or not prior_parser_state_preserved:
    print "FAIL: parser failure did not produce one deny diagnostic or preserve parser state"
    rt_exit(1)

print "PASS: parser failure produces one PARSE001 deny diagnostic and preserves parser state"
rt_exit(0)
