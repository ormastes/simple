# Oracle harness for reliable-mode P1 / R1 step 3: the LSP/build lint diagnostic
# path honors the strictness tier (sdn profile= + @lint_profile), matching `simple lint`.
#
# Run via:  bin/simple run test/01_unit/compiler/lint/lint_profile_lsp_severity_check.spl
# Exits non-zero on failure. NOT a BDD `_spec`: it drives `_collect_lint_diagnostics_json`
# from top-level statements because the diagnostic collect-mode uses module-level vars that
# the interpreter test runner does not share into `it`-block execution.
use app.cli.query_lint.{_collect_lint_diagnostics_json}

extern fn rt_exit(code: i32)

val body = "fn f(x: i64) -> text:\n    match x:\n        case 0:\n            \"z\"\n        case 1:\n            \"o\"\n"

# Reliable tier must elevate a tier-governed lint (non_exhaustive_match) to LSP error (1).
val rel = _collect_lint_diagnostics_json("p.spl", "@lint_profile(reliable)\n\n" + body)
if rel.1.len() == 0 or not rel.1[0].contains("\"code\":\"MEXH002\"") or not rel.1[0].contains("\"severity\":1"):
    print "FAIL: reliable tier did not elevate MEXH002 to severity 1"
    rt_exit(1)
print "PASS: @lint_profile(reliable) elevates MEXH002 to severity 1"

# No tier = legacy behavior: the same lint stays a warning (2).
val plain = _collect_lint_diagnostics_json("p.spl", body)
if plain.1.len() == 0 or not plain.1[0].contains("\"code\":\"MEXH002\"") or not plain.1[0].contains("\"severity\":2"):
    print "FAIL: default (no tier) changed MEXH002 from severity 2"
    rt_exit(1)
print "PASS: default (no tier) keeps MEXH002 at severity 2"

val wide_body = "export symbol00\nexport symbol01\nexport symbol02\nexport symbol03\nexport symbol04\nexport symbol05\nexport symbol06\nexport symbol07\nexport symbol08\nexport symbol09\nexport symbol10\nexport symbol11\nexport symbol12\nexport symbol13\nexport symbol14\nexport symbol15\nexport symbol16\nexport symbol17\nexport symbol18\nexport symbol19\nexport symbol20\nexport symbol21\nexport symbol22\nexport symbol23\nexport symbol24\nexport symbol25\nexport symbol26\nexport symbol27\nexport symbol28\nexport symbol29\nexport symbol30\n"
val wide_allowed = _collect_lint_diagnostics_json("p.spl", "@allow(visibility_boundary)\n" + wide_body)
if wide_allowed.0 != 0 or wide_allowed.1.len() != 0:
    print "FAIL: visibility_boundary allow did not suppress W0404"
    rt_exit(1)
val wide_denied = _collect_lint_diagnostics_json("p.spl", "@deny(visibility_boundary)\n" + wide_body)
if wide_denied.1.len() != 1 or not wide_denied.1[0].contains("\"code\":\"W0404\"") or not wide_denied.1[0].contains("\"severity\":1"):
    print "FAIL: visibility_boundary deny did not elevate W0404 to severity 1"
    rt_exit(1)
print "PASS: visibility_boundary governs W0404 on query/LSP"

print "ALL_LSP_SEVERITY_PASS"
rt_exit(0)
