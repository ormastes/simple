# Raw Runtime Intrinsic Access Lint Specification
#
# Verifies RAW-RT-001 flags `extern fn rt_*` declarations outside the
# privileged (facade-owner) tiers. `src/compiler/` was previously exempt as a
# whole tier; a refactor (see llvm_native_link.spl) routed the compiler
# backend through the std facade because a new `extern fn rt_*` in a
# CLI-closure module can brick the deployed binary. This spec covers the
# extended coverage (src/compiler/** now flagged) while confirming
# src/lib/** and src/runtime/** (the facade owners) stay exempt.

use std.spec.*
use compiler.semantics.lint.raw_rt_access.{
    RawRtAccessFinding,
    check_raw_rt_access
}


# ============================================================================
# Test Group 1: RAW-RT-001 — extern fn rt_* outside privileged tiers
# ============================================================================

describe "RAW-RT-001: raw extern fn rt_* outside privileged tiers":
    """
    ## Raw Runtime Intrinsic Detection

    Flags `extern fn rt_<name>` declared anywhere except src/lib/ or
    src/runtime/ (the facade owners).
    """

    context "when declared in src/compiler/ (CLI-closure, now covered)":
        """
        ### Scenario: compiler backend declares a raw rt_* extern

        src/compiler/ is CLI-closure code; a new raw rt_* extern there can
        brick the deployed binary (unknown-extern rejection at module load),
        so it is no longer a privileged tier.
        """

        it "detects extern fn rt_* in src/compiler/70.backend/backend/":
            val source = "extern fn rt_new_intrinsic(x: i64) -> i64\n"
            val findings = check_raw_rt_access(source, "src/compiler/70.backend/backend/llvm_native_link.spl")
            expect(findings.len()).to_equal(1)
            expect(findings[0].code).to_equal("RAW-RT-001")
            expect(findings[0].name).to_equal("rt_new_intrinsic")

        it "detects extern fn rt_* in any src/compiler/ subdirectory":
            val source = "extern fn rt_cli_arg_count() -> i64\n"
            val findings = check_raw_rt_access(source, "src/compiler/00.common/config.spl")
            expect(findings.len()).to_equal(1)

        it "reports the accurate line number for a non-first-line declaration":
            val source = "use std.io\n\nfn helper():\n    pass\n\nextern fn rt_new_intrinsic(x: i64) -> i64\n"
            val findings = check_raw_rt_access(source, "src/compiler/00.common/config.spl")
            expect(findings.len()).to_equal(1)
            expect(findings[0].line_num).to_equal(6)

    context "when declared in application/CLI code (already covered)":
        """
        ### Scenario: generic non-privileged path

        Behavior unchanged from before this lint's extension.
        """

        it "detects extern fn rt_* in src/app/":
            val source = "extern fn rt_file_read_text(path: text) -> text\n"
            val findings = check_raw_rt_access(source, "src/app/cli/main.spl")
            expect(findings.len()).to_equal(1)
            expect(findings[0].code).to_equal("RAW-RT-001")

    context "when declared in a privileged (facade-owner) tier":
        """
        ### Scenario: src/lib/ and src/runtime/ still exempt

        These are the facade owners — they must be able to declare raw
        intrinsics directly (routing through themselves would be circular).
        """

        it "does not flag extern fn rt_* in src/lib/":
            val source = "extern fn rt_file_read_text(path: text) -> text\n"
            val findings = check_raw_rt_access(source, "src/lib/nogc_sync_mut/io_runtime.spl")
            expect(findings.len()).to_equal(0)

        it "does not flag extern fn rt_* in src/runtime/":
            val source = "extern fn rt_gc_alloc(size: i64) -> i64\n"
            val findings = check_raw_rt_access(source, "src/runtime/gc/alloc.spl")
            expect(findings.len()).to_equal(0)

    context "when the file opts out with @runtime_intrinsics":
        """
        ### Scenario: file-level opt-out marker

        Emulators, baremetal MMIO, and crypto/protocol implementations may
        legitimately keep raw rt_* externs by declaring this marker near the
        top of the file — regardless of tier.
        """

        it "does not flag a src/compiler/ file marked @runtime_intrinsics":
            val source = "@runtime_intrinsics\n\nextern fn rt_new_intrinsic(x: i64) -> i64\n"
            val findings = check_raw_rt_access(source, "src/compiler/70.backend/backend/llvm_native_link.spl")
            expect(findings.len()).to_equal(0)

    context "when the extern is not an rt_* intrinsic":
        """
        ### Scenario: non-runtime externs are out of scope

        Only the `rt_` prefix is a raw runtime intrinsic; other externs
        (e.g. FFI bindings to third-party libraries) are unaffected.
        """

        it "ignores a non-rt_ extern fn":
            val source = "extern fn curl_easy_init() -> i64\n"
            val findings = check_raw_rt_access(source, "src/app/cli/main.spl")
            expect(findings.len()).to_equal(0)


# ============================================================================
# Test Group 2: Warning Formatting
# ============================================================================

describe "RawRtAccessFinding formatting":
    """
    ## Warning Output Format

    The fmt() method should produce a readable diagnostic string.
    """

    it "produces formatted output":
        val f = RawRtAccessFinding(
            code: "RAW-RT-001",
            severity: "WARNING",
            message: "test message",
            name: "rt_thing",
            note: "test note",
            line_num: 3
        )
        val output = f.fmt()
        expect(output).to_contain("RAW-RT-001")
        expect(output).to_contain("WARNING")
        expect(output).to_contain("test message")
        expect(output).to_contain("test note")
