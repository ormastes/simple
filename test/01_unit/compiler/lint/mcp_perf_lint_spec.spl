# MCP Performance Lint Specification

use std.spec.*
use compiler.semantics.lint.mcp_perf_lint.{
    lint_mcp_perf_source,
    mcp_perf_path_in_scope
}


describe "MCP performance lint aggregate":
    it "accepts clean MCP source":
        val source = "fn handle_request():\n    val result = cached_result\n"
        val warnings = lint_mcp_perf_source(source, "src/app/mcp/handler.spl")
        expect(warnings.len()).to_equal(0)

    it "detects a source entrypoint in a production wrapper":
        val source = "ENTRY=src/app/mcp/main.spl\n"
        val warnings = lint_mcp_perf_source(source, "bin/simple_mcp_server")
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("MCP001")

    it "detects a full-tree scan in a request handler":
        val source = "fn handle_request():\n    val files = rt_dir_walk(root)\n"
        val warnings = lint_mcp_perf_source(source, "src/app/mcp/handler.spl")
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("MCP002")

    it "detects a subprocess in a request handler":
        val source = "fn dispatch_request():\n    val result = rt_process_run(command)\n"
        val warnings = lint_mcp_perf_source(source, "src/app/mcp/handler.spl")
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("MCP003")

    it "detects a cache without invalidation":
        val source = "var RESULT_CACHE: text = \"\"\n"
        val warnings = lint_mcp_perf_source(source, "src/app/mcp/cache.spl")
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("MCP004")

    it "returns warnings in MCP001 through MCP004 order":
        val source = "ENTRY=src/app/mcp/main.spl\nvar RESULT_CACHE: text = \"initial\"\nfn handle_request():\n    val files = rt_dir_walk(root)\n    val result = rt_process_run(command)\n"
        val warnings = lint_mcp_perf_source(source, "bin/mcp/test_mcp_server")
        expect(warnings.len()).to_equal(4)
        expect(warnings[0].code).to_equal("MCP001")
        expect(warnings[1].code).to_equal("MCP002")
        expect(warnings[2].code).to_equal("MCP003")
        expect(warnings[3].code).to_equal("MCP004")

    it "recognizes LSP MCP source paths":
        expect(mcp_perf_path_in_scope("examples/editor/src/lsp_mcp/handler.spl")).to_be(true)
        expect(mcp_perf_path_in_scope("src/app/simple_lsp_mcp/handler.spl")).to_be(true)
        val source = "fn handle_request():\n    val files = rt_dir_walk(root)\n"
        val warnings = lint_mcp_perf_source(source, "examples/editor/src/lsp_mcp/handler.spl")
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("MCP002")
