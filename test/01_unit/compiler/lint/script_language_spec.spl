use compiler.tools.fix.rules.impl_.lint_script_language.{check_simple_script_required}
extern fn rt_file_read_text(path: text) -> text

fn count_rule(source: text, file: text, rule: text) -> i64:
    val fixes = check_simple_script_required(source, file)
    var count = 0
    for fix in fixes:
        val parts = fix.id.split(":")
        if parts.len() >= 2 and parts[1] == rule:
            count = count + 1
    count

describe "script language lint":
    it "flags Python automation scripts":
        val source = "#!/usr/bin/env python3\nprint('smoke')\n"
        expect(count_rule(source, "scripts/smoke/tool_smoke.py", "simple_script_required")).to_equal(1)

    it "flags Python calls embedded in repository shell scripts":
        val source =
            "#!/bin/sh\n" +
            "python3 - \"$input\" <<'PY'\n" +
            "print('helper')\n" +
            "PY\n"
        expect(count_rule(source, "scripts/check/example.shs", "simple_script_required")).to_equal(1)

    it "does not flag vendored Python scripts":
        val source = "print('generated')\n"
        expect(count_rule(source, "src/app/vscode_extension/node_modules/tool.py", "simple_script_required")).to_equal(0)

    it "allows Python tkinter comparison benchmark baseline":
        val source = rt_file_read_text("tools/gui_perf_bench/bench_python.py")
