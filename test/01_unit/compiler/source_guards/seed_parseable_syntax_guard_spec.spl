# Guard: seed-unparseable labeled-tuple-return syntax must not spread.
#
# `-> (name: type, name: type, ...)` labeled-tuple return types are
# DOCUMENTED language syntax (doc/07_guide/quick_reference/syntax_quick_reference.md,
# "Multi-Return Tuples" section, the `div_rem` example) but are confirmed
# unparseable by BOTH the frozen Rust seed and the deployed self-hosted
# binary — see
# doc/08_tracking/bug/seed_parser_labeled_tuple_return_type_gap_2026-07-17.md
# and doc/08_tracking/bug/bootstrap_named_tuple_return_parse_2026-07-17.md.
# Commit aee3289936b worked around the one bootstrap-critical instance by
# reverting `process_run` (src/lib/nogc_sync_mut/io_runtime.spl) from a
# labeled tuple return back to an unlabeled one, specifically because this
# file sits on bootstrap_main.spl's entry-closure import graph, where the
# pipeline hard-aborts the whole native-build on the first parse error.
#
# NOTE: the pure-Simple frontend parser SOURCE
# (src/compiler/10.frontend/core/parser.spl, `parser_parse_tuple_element_type`)
# has since been extended to accept this grammar in-tree (see
# test/01_unit/compiler/bootstrap/labeled_tuple_return_parser_spec.spl), but
# that fix only protects code once it reaches a REDEPLOYED bin/simple —
# until then, any `.spl` file under src/lib, src/app, or src/compiler using
# this syntax risks the exact Stage-1 bootstrap failure the bug doc
# describes. This guard exists to stop the syntax from spreading further
# while that redeploy is pending.
#
# CURRENT STATE (lane S74, checkout 188941ed081c): this scan logic finds
# exactly TWO pre-existing real (non-comment) occurrences that predate this
# guard and are not this lane's to fix — a sibling, not-yet-merged lane's
# "31e6de2c6b7-era" normalization pass covers ten files elsewhere but has not
# landed on this lane's lineage:
#   - src/app/office/file_formats.spl:49
#   - src/compiler/70.backend/backend/stage4_symbol_closure.spl:59
# This guard therefore asserts NO NEW occurrence appears anywhere else, and
# separately pins the known-violation count so a silent THIRD occurrence (in
# either of those two files, or elsewhere) is caught. Once those two files
# are normalized upstream, shrink _known_open_violations() to `[]` below and the
# first `it` becomes a true "assert zero matches" guard, as originally
# scoped for this spec.
#
# LOGIC VALIDATION: the scan helpers (`_scan_all_source_roots` and its
# callees) were copied into a scratch probe with a `main()` and run via
# `env -u SIMPLE_BOOTSTRAP bin/simple run <probe>` (the interpreter path,
# NOT native-build — see VERIFICATION CAVEAT). That probe run produced
# EXACTLY the two lines above, matching `_known_open_violations()` verbatim,
# after fixing two bugs the probe caught: (1) `{`/`}` (dict-type-sugar
# tuple elements, e.g. `-> ({text: text}, i64)?:`) were not tracked as
# depth-changing characters, causing a false positive on
# src/compiler/40.mono/monomorphize/deferred_deserialize.spl's internal
# dict-type colons; (2) src/compiler has 17 un-numbered symlink aliases for
# its numbered layer dirs (src/compiler/backend -> 70.backend, etc.) that
# dir_walk() follows, double-reporting every hit under src/compiler unless
# filtered (see `_is_compiler_alias_path`) — src/app has a smaller,
# similar set (see `_is_app_alias_path`). Both are fixed below.
#
# VERIFICATION CAVEAT: the deployed binary currently hangs on all
# single-file `bin/simple test` runs
# (doc/08_tracking/bug/deployed_seed_test_runner_init_hang_2026-07-17.md).
# This spec ITSELF (via the `describe`/`it` harness) was attempted with
# `timeout 60` and hung (see lane report) — it has NOT been confirmed green
# or red by running the actual SSpec file. Only its extracted scan logic was
# validated (see LOGIC VALIDATION above), via plain script execution, which
# does not exercise the test-runner init path that hangs. Resume full-spec
# verification with:
#   bin/simple test test/01_unit/compiler/source_guards/seed_parseable_syntax_guard_spec.spl
# once the deployed binary is redeployed past that regression. The lane's
# executable evidence for this session is the native-smoke-matrix cases
# instead (scripts/check/native-smoke-matrix.shs).
#
# Also noted, not chased (out of scope for this guard): `dir_walk()`
# returns EMPTY when called from a native-build-compiled binary (confirmed
# via the same probe compiled with native-build instead of `run` — likely
# an SFFI argument-marshaling gap specific to the native path). Irrelevant
# here since specs execute under the interpreter, but worth a bug filing by
# whoever next touches native-build + directory listing. Separately,
# `bin/simple run` on this worktree currently prints
# "WARNING: this Rust-built Simple binary is a bootstrap seed only" —
# i.e. the shared release binary this worktree's `bin/simple` symlinks to
# was, at least transiently, the frozen seed rather than the self-hosted
# binary (plausibly a concurrent redeploy from another parallel lane on
# this machine); unrelated to this guard's logic, which was validated
# against whichever interpreter that invocation actually ran.

use std.spec.*
use std.io_runtime.{file_read, dir_walk}

# Heuristic mirrors the existing depth-tracked scan
# (`_fsk_check_anon_tuple_return` in
# src/compiler/90.tools/lint/_LintMain/os_freestanding_lints.spl), which
# looks for a top-level `,` inside a `fn ... -> (...)` return type. This
# guard instead looks for a `:` at paren-depth 1 — a labeled tuple element —
# while still tracking depth so a nested lambda/generic/dict type's own
# `:`/`,` (e.g. a `fn(x: i64) -> bool` parameter, `Dict<text, i64>`, or a
# `{text: text}` dict-type-sugar tuple element) is never mistaken for a
# top-level label. `{`/`}` must be tracked alongside `(`/`)`/`[`/`]`/`<`/`>`
# — a probe against a real unlabeled-tuple case
# (`-> ({text: text}, i64)?:` in
# src/compiler/40.mono/monomorphize/deferred_deserialize.spl) confirmed
# omitting `{`/`}` produces a false positive on the dict-type's internal
# colon. Depth-1 alone is then a complete discriminator: unlabeled tuples
# (`(i64, text)`) have zero depth-1 colons; nested generics/lambdas/dict
# types sit at depth >= 2; the body-opening `:` is only reached after depth
# returns to 0 (where the loop already stopped). Deliberately does NOT also
# require the colon to follow an identifier char — a probe confirmed
# `text as i64` does not reliably yield a codepoint on every interpreter
# this spec might run under, so this guard avoids that cast entirely rather
# than depend on it.
fn _line_looks_like_labeled_tuple_return(trimmed: text) -> bool:
    val is_fn_line = trimmed.starts_with("fn ") or trimmed.starts_with("me ") or trimmed.starts_with("static fn ") or trimmed.starts_with("extern fn ")
    if not is_fn_line:
        return false
    val arrow_idx = trimmed.find("->")
    if arrow_idx < 0:
        return false
    val after = trimmed.substring(arrow_idx + 2, trimmed.len()).trim()
    if not after.starts_with("("):
        return false
    var depth = 0
    var i = 0
    var found_label = false
    while i < after.len():
        val ch = after.substring(i, i + 1)
        if ch == "(" or ch == "[" or ch == "<" or ch == "{":
            depth = depth + 1
        elif ch == ")" or ch == "]" or ch == ">" or ch == "}":
            depth = depth - 1
            if depth == 0:
                break
        elif ch == ":" and depth == 1:
            found_label = true
        i = i + 1
    found_label

fn _is_spl_source_file(path: text) -> bool:
    path.len() > 4 and path.substring(path.len() - 4, path.len()) == ".spl"

fn _is_vendor_path(path: text) -> bool:
    path.contains("/vendor/")

fn _starts_with_digit(s: text) -> bool:
    if s.len() == 0:
        return false
    "0123456789".contains(s.substring(0, 1))

# src/compiler's numbered layer directories (00.common, 10.frontend, ...,
# 99.loader) each have a matching un-numbered symlink alias for readability
# (src/compiler/common -> 00.common, src/compiler/backend -> 70.backend,
# etc. — 17 total, see `find src/compiler -maxdepth 1 -type l`). dir_walk()
# follows symlinks, so without this filter every file under src/compiler
# would be scanned TWICE (once via its canonical numbered path, once via the
# alias), double-reporting any hit. Keep only the canonical form: the first
# path segment under src/compiler/ must start with a digit.
fn _is_compiler_alias_path(path: text) -> bool:
    val prefix = "src/compiler/"
    if not path.starts_with(prefix):
        return false
    val rest = path.substring(prefix.len(), path.len())
    not _starts_with_digit(rest)

# src/app has a handful of symlink aliases that either duplicate src/lib
# content under a different path (lsp/, lsp.handlers/, debug/coordinator.spl,
# debug/remote/target/riscv32.spl -> src/lib/nogc_sync_mut/...) or escape
# all three scan roots entirely into examples/10_tooling or an example repo
# (mcp_t32, spostgre, t32_cli, t32_lsp_mcp). Both would otherwise re-scan
# already-covered content or pull unrelated files into scope (see
# `find src/app -type l`).
fn _is_app_alias_path(path: text) -> bool:
    path.starts_with("src/app/lsp") or
        path.starts_with("src/app/mcp_t32") or
        path.starts_with("src/app/spostgre") or
        path.starts_with("src/app/t32_cli") or
        path.starts_with("src/app/t32_lsp_mcp") or
        path.starts_with("src/app/debug/coordinator.spl") or
        path.starts_with("src/app/debug/remote/target/riscv32.spl")

fn _scan_root_for_labeled_tuple_returns(root: text) -> [text]:
    var hits: [text] = []
    for path in dir_walk(root):
        val in_scope = _is_spl_source_file(path) and not _is_vendor_path(path) and
            not _is_compiler_alias_path(path) and not _is_app_alias_path(path)
        if in_scope:
            val content = file_read(path)
            val lines = content.split("\n")
            var line_no = 0
            for line in lines:
                line_no = line_no + 1
                val trimmed = line.trim()
                if not trimmed.starts_with("#") and _line_looks_like_labeled_tuple_return(trimmed):
                    hits.push("{path}:{line_no}")
    hits

fn _scan_all_source_roots() -> [text]:
    _scan_root_for_labeled_tuple_returns("src/lib") +
        _scan_root_for_labeled_tuple_returns("src/app") +
        _scan_root_for_labeled_tuple_returns("src/compiler")

fn _array_contains(items: [text], target: text) -> bool:
    for item in items:
        if item == target:
            return true
    false

fn _all_hits_are_known(hits: [text]) -> bool:
    for hit in hits:
        if not _array_contains(_known_open_violations(), hit):
            return false
    true

# The two documented pre-existing occurrences (see header comment). Shrink
# to `[]` once file_formats.spl and stage4_symbol_closure.spl are
# normalized to unlabeled tuple returns by whatever lane owns that cleanup.
# A function (not a module-level array literal) so native-build --entry
# initializes it on every call rather than risking a silent zero/nil default
# module initializer.
fn _known_open_violations() -> [text]:
    [
        "src/app/office/file_formats.spl:49",
        "src/compiler/70.backend/backend/stage4_symbol_closure.spl:59",
    ]

describe "seed-parseable syntax guard (labeled-tuple returns)":
    """
    ## Seed-parseable syntax guard (labeled-tuple returns)

    `-> (name: type, ...)` labeled-tuple return types are documented
    language syntax but are confirmed unparseable by the deployed
    self-hosted binary (a Stage-1 bootstrap blocker, worked around at
    aee3289936b). This scans src/lib, src/app, and src/compiler for the
    pattern so no new occurrence spreads while the parser fix behind it
    is pending a redeploy.
    """
    it "does not introduce labeled-tuple-return syntax beyond the two known-open exceptions":
        step("Scan src/lib, src/app, src/compiler *.spl for '-> (name: type' signatures")
        val hits = _scan_all_source_roots()
        expect(_all_hits_are_known(hits)).to_equal(true)

    it "keeps the known-open violation count from silently growing":
        step("Confirm no third occurrence has crept into the two cited files (or elsewhere)")
        val hits = _scan_all_source_roots()
        expect(hits.len()).to_equal(_known_open_violations().len())
