use std.spec
use std.string_core.{char_from_code}
use compiler.loader.loader.smf_mmap_native.{str_from_utf8_lossy}

describe "SMF mmap byte text conversion":
    it "decodes valid bytes and replaces invalid bytes":
        val decoded = str_from_utf8_lossy([65u8, 0xC2u8, 0xA2u8, 0xFFu8, 66u8])
        expect(decoded).to_equal("A" + char_from_code(162) + "?B")
