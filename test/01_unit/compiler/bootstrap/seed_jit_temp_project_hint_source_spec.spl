extern fn rt_file_read_text(path: text) -> text

describe "seed JIT temporary-source project hint wiring":
    it "passes the existing bounded project hint into HIR lowering":
        val execution = rt_file_read_text("src/compiler_rust/compiler/src/pipeline/execution.rs") ?? ""
        val pipeline = rt_file_read_text("src/compiler_rust/compiler/src/pipeline/mod.rs") ?? ""
        val jit = rt_file_read_text("src/compiler_rust/driver/src/exec_core.rs") ?? ""

        expect(execution).to_contain("pub fn native_single_file_project_hint")
        expect(pipeline).to_contain("native_single_file_project_hint")
        expect(jit).to_contain("native_single_file_project_hint(path)")
        expect(jit).to_contain("lower_with_context_and_project_hint(&ast, path, project_hint.as_deref())")
        expect(jit.contains("hir::lower_with_context(&ast, path)")).to_equal(false)
