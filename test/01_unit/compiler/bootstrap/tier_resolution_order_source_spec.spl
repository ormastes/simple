use std.io_runtime.{file_read}

fn follows_canonical_order(source: text, anchor: text, from: i64) -> bool:
    val remainder = source.substring(from)
    val relative_start = remainder.index_of(anchor)
    if relative_start < 0:
        return false
    val start = from + relative_start
    val tail = source.substring(start)
    val relative_end = tail.index_of("]")
    if relative_end < 0:
        return false
    val block = tail.substring(0, relative_end)
    var previous = -1
    for tier in ["nogc_async_mut", "nogc_sync_mut", "nogc_async_immut", "common", "gc_async_mut", "nogc_async_mut_noalloc"]:
        val position = block.index_of("\"" + tier + "\"")
        if position <= previous:
            return false
        previous = position
    true

describe "canonical tier module resolution":
    it "uses one default order in every fallback resolver":
        val compile_targets = file_read("src/app/io/_CliCompile/compile_targets.spl")
        val hir_modules = file_read("src/compiler/20.hir/hir_lowering/_Items/module_lowering.spl")
        val seed_modules = file_read("src/compiler_rust/compiler/src/module_resolver/resolution.rs")
        val seed_interpreter = file_read("src/compiler_rust/compiler/src/interpreter_module/path_resolution.rs")

        val first_seed_fallback = seed_interpreter.index_of("for subdir in &[")
        expect(follows_canonical_order(compile_targets, "for tier in [", 0)).to_equal(true)
        expect(follows_canonical_order(hir_modules, "for tier in [", 0)).to_equal(true)
        expect(follows_canonical_order(seed_modules, "= &[", 0)).to_equal(true)
        expect(follows_canonical_order(seed_interpreter, "for subdir in &[", 0)).to_equal(true)
        expect(follows_canonical_order(seed_interpreter, "for subdir in &[", first_seed_fallback + 1)).to_equal(true)
