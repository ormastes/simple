# Exact regression for the Stage4 parser.spl self-parse failure.
# @cover src/compiler/10.frontend/core/parser.spl

use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.core.parser.{parser_has_errors}
use std.nogc_sync_mut.io.file_ops.{rt_file_read_text}

describe "bootstrap parser self-parse":
    it "parses the compiler parser including guarded integer text":
        val path = "src/compiler/10.frontend/core/parser.spl"
        val source = rt_file_read_text(path) ?? ""
        val module = parse_and_build_module(source, path)

        expect(source.len()).to_be_greater_than(0)
        expect(parser_has_errors()).to_equal(false)
        expect(module.functions.contains("parser_guarded_int_text")).to_equal(true)
