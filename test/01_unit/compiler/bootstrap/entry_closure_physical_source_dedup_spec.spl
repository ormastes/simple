extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool

use compiler.common.driver_core_types.{SourceFile}
use compiler.driver.driver_source_loading.{
    _driver_canonical_source_path, _driver_module_name_from_path, _driver_unique_physical_sources,
    _driver_text_bucket_set_new, _driver_text_bucket_set_has, _driver_text_bucket_set_add,
    _driver_collect_sources_via_find, _driver_entry_import_module_paths
}

describe "entry-closure physical source deduplication":
    it "normalizes aliases to one physical parse source":
        val content = "fn shared() -> i64: 1\n"
        val sources = [
            SourceFile(path: "./src/lib/common/../common/shared.spl", content: content, module_name: "std.shared"),
            SourceFile(path: "src/lib/common/shared.spl", content: content, module_name: "lib.common.shared")
        ]

        expect(_driver_canonical_source_path(sources[0].path)).to_equal("src/lib/common/shared.spl")
        expect(_driver_unique_physical_sources(sources).len()).to_equal(1)

    it "keeps absolute workspace punctuation out of native module symbols":
        expect(_driver_module_name_from_path("/private/tmp/simple-main-bootstrap/src/compiler/80.driver/driver.spl")).to_equal("compiler.80.driver.driver")
        expect(_driver_module_name_from_path("/private/tmp/simple-main-bootstrap/examples/10_tooling/trace32_tools/t32_cli/cli_shell.spl")).to_equal("examples.10_tooling.trace32_tools.t32_cli.cli_shell")
        expect(_driver_module_name_from_path("plugins/my-tool/main.spl")).to_equal("plugins.my_tool.main")

    it "keeps colliding bucket keys exact and persistent":
        var buckets = _driver_text_bucket_set_new(1)
        buckets = _driver_text_bucket_set_add(buckets, "std.alpha")
        buckets = _driver_text_bucket_set_add(buckets, "std.alphabet")
        buckets = _driver_text_bucket_set_add(buckets, "std.alpha")

        expect(_driver_text_bucket_set_has(buckets, "std.alpha")).to_be(true)
        expect(_driver_text_bucket_set_has(buckets, "std.alphabet")).to_be(true)
        expect(_driver_text_bucket_set_has(buckets, "std.alph")).to_be(false)

    it "spreads distinct keys across phase-one buckets":
        var buckets = _driver_text_bucket_set_new(16)
        for key in [
            "std.alpha", "std.beta", "std.gamma", "std.delta",
            "std.epsilon", "std.zeta", "std.eta", "std.theta",
            "app.main", "app.cli", "compiler.driver", "compiler.parser"
        ]:
            buckets = _driver_text_bucket_set_add(buckets, key)

        var populated = 0
        for bucket in buckets:
            if bucket != "":
                populated = populated + 1
        expect(populated).to_be_greater_than(1)

    it "registers every logical alias from one cached module result":
        val driver = rt_file_read_text("src/compiler/80.driver/driver.spl") ?? ""

        expect(driver).to_contain("val unique_entry_sources = _driver_unique_physical_sources(entry_sources)")
        expect(driver).to_contain("parsed_entry_paths = parsed_entry_paths.push(physical_key)")
        expect(driver).to_contain("parsed_entry_modules = parsed_entry_modules.push(entry_module)")
        expect(driver).to_contain("self.ctx.modules[source.module_name] = parsed_entry_modules[parsed_idx]")
        expect(driver).to_contain(r"phase2:parse:closure:sources collected={entry_sources.len()} unique={unique_entry_sources.len()}")

    it "uses bucket sets for every phase-one closure membership role":
        val driver = rt_file_read_text("src/compiler/80.driver/driver.spl") ?? ""

        expect(driver).to_contain("var seen_sources = _driver_text_bucket_set_new(8192)")
        expect(driver).to_contain("var closure_loaded_mods = _driver_text_bucket_set_new(8192)")
        expect(driver).to_contain("var closure_seen_mods = _driver_text_bucket_set_new(8192)")
        expect(driver).to_contain("var closure_scanned_paths = _driver_text_bucket_set_new(8192)")
        expect(driver).to_not_contain("var closure_seen_mods: [text]")

    it "skips docstring imports without slicing every source character":
        val imports = _driver_entry_import_module_paths("use std.real\n\"\"\"\nuse fake.block\n\"\"\"\n\"\"\"use fake.inline\"\"\"\nexport use app.live.*\n")
        val long_imports = _driver_entry_import_module_paths("x".repeat(65536) + "\nuse std.real\n")
        val loading = rt_file_read_text("src/compiler/80.driver/driver_source_loading.spl") ?? ""

        expect(imports).to_equal(["std.real", "app.live"])
        expect(long_imports).to_equal(["std.real"])
        expect(loading).to_contain("var quote_pos = quote_tail.index_of")
        expect(loading).to_not_contain("line.substring(scan_pos, scan_pos + 3)")

    it "keeps a zero-import explicit entry out of whole-workspace loading":
        val driver = rt_file_read_text("src/compiler/80.driver/driver.spl") ?? ""

        expect(driver).to_contain("if self.ctx.errors.len() == 0:\n                # A successful explicit-entry walk is a closure")
        expect(driver).to_contain("rt_env_set(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\", \"1\")")
        expect(driver).to_contain("if has_project_source and self.ctx.options.mode != CompileMode.Check and not nb_entry_closure:")
        expect(driver).to_not_contain("closure_added")

    it "collects only the source roots supplied by its caller":
        val loading = rt_file_read_text("src/compiler/80.driver/driver_source_loading.spl") ?? ""
        val helpers = rt_file_read_text("src/compiler/80.driver/driver_helpers.spl") ?? ""

        expect(loading).to_contain("for path in paths:\n        val loaded = _driver_collect_sources(path)")
        expect(helpers).to_contain("for path in paths:\n        val loaded = _driver_collect_sources(path)")
        expect(loading).to_not_contain("find src/app src/lib src/compiler src/runtime")
        expect(helpers).to_not_contain("find src/app src/lib src/compiler src/runtime")

    it "does not scan a sibling root omitted by its caller":
        val fixture = "/tmp/simple-entry-closure-source-roots"
        val included = fixture + "/included"
        val omitted = fixture + "/omitted"
        expect(rt_dir_create(included, true)).to_be(true)
        expect(rt_dir_create(omitted, true)).to_be(true)
        expect(rt_file_write_text(included + "/main.spl", "fn main() -> i64: 0\n")).to_be(true)
        expect(rt_file_write_text(omitted + "/database.spl", "fn unrelated() -> i64: 1\n")).to_be(true)

        val sources = _driver_collect_sources_via_find([included])
        expect(sources.len()).to_be_greater_than(0)
        for source in sources:
            expect(source.path).to_start_with(included)
