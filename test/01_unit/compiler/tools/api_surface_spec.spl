# # API Surface Tools Unit Tests
#
# **Feature ID:** #COMPILER-TOOLS-001
# **Category:** Compiler | Tools
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

extern fn rt_file_read_text(path: text) -> text?

fn source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "Public API Detection":
    it "public function is in API":
        val visibility = "public"
        check(visibility == "public")

    it "private function is not in API":
        val visibility = "private"
        check(visibility == "private")

    it "module-level function":
        val scope = "module"
        check(scope == "module")

    it "class method":
        val scope = "method"
        check(scope == "method")

    it "static method":
        val scope = "static"
        check(scope == "static")

describe "Symbol Categories":
    it "function symbol":
        val kind = "function"
        check(kind == "function")

    it "class symbol":
        val kind = "class"
        check(kind == "class")

    it "trait symbol":
        val kind = "trait"
        check(kind == "trait")

    it "enum symbol":
        val kind = "enum"
        check(kind == "enum")

    it "type alias symbol":
        val kind = "type_alias"
        check(kind == "type_alias")

    it "constant symbol":
        val kind = "constant"
        check(kind == "constant")

describe "API Documentation Coverage":
    it "documented function":
        val has_doc = true
        check(has_doc)

    it "undocumented function":
        val has_doc = false
        check(not has_doc)

    it "doc coverage percentage":
        val documented = 80
        val total = 100
        val coverage = documented * 100 / total
        check(coverage == 80)

    it "coverage threshold check":
        val coverage = 85
        val threshold = 80
        check(coverage >= threshold)

describe "Symbol Analysis":
    it "count public functions":
        val count = 42
        check(count > 0)

    it "count public classes":
        val count = 15
        check(count > 0)

    it "count public traits":
        val count = 8
        check(count > 0)

    it "module dependency graph":
        val edges = 100
        check(edges > 0)

    it "cyclic dependency detection":
        val has_cycle = false
        check(not has_cycle)

describe "API Surface Bootstrap Syntax":
    it "formats function parameters without parser-fragile lambda match":
        val layered = source("src/compiler/90.tools/api_surface.spl")
        val flat = source("src/compiler/tools/api_surface.spl")

        expect(layered).to_contain("var param_parts: [text] = []")
        expect(layered).to_contain("for param in sig.params:")
        expect(layered).to_not_contain("sig.params.map(\\param:")
        expect(flat).to_contain("var param_parts: [text] = []")
        expect(flat).to_contain("for param in sig.params:")
        expect(flat).to_not_contain("sig.params.map(\\param:")

    it "keeps context pack parameter formatting bootstrap-safe":
        val layered = source("src/compiler/90.tools/context_pack.spl")
        val flat = source("src/compiler/tools/context_pack.spl")

        expect(layered).to_contain("var param_parts: [text] = []")
        expect(layered).to_contain("for param in sig.params:")
        expect(layered).to_not_contain("sig.params.map(\\param:")
        expect(flat).to_contain("var param_parts: [text] = []")
        expect(flat).to_contain("for param in sig.params:")
        expect(flat).to_not_contain("sig.params.map(\\param:")
