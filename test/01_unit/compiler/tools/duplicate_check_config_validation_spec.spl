use compiler.tools.duplicate_check.config.{parse_config_file, config_validation_error}

describe "duplicate-check config enum validation":
    it "rejects invalid config enums and accepts valid config":
        val invalid_mode = parse_config_file("duplicate-check:\n  mode: nope")
        expect(config_validation_error(invalid_mode)).to_equal("invalid simple.duplicate-check.sdn mode: nope")

        val invalid_format = parse_config_file("duplicate-check:\n  output-format: yaml")
        expect(config_validation_error(invalid_format)).to_equal("invalid simple.duplicate-check.sdn output-format: yaml")

        val valid = parse_config_file("duplicate-check:\n  mode: token\n  output-format: json")
        expect(config_validation_error(valid)).to_equal("")
