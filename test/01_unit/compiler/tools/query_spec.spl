# # Query Tools Unit Tests
#
# **Feature ID:** #COMPILER-TOOLS-002
# **Category:** Compiler | Tools
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Symbol Query":
    it "find function by name":
        val name = "main"
        check(name == "main")

    it "find class by name":
        val name = "Point"
        check(name == "Point")

    it "find method by class and name":
        val class_name = "Point"
        val method = "get_x"
        check(class_name == "Point" and method == "get_x")

    it "find symbols by pattern":
        val pattern = "parse_*"
        check(pattern.starts_with("parse"))

    it "find symbols in module":
        val module = "compiler.frontend"
        check(module.contains("frontend"))

describe "Type Query":
    it "query type of expression":
        val expr_type = "i64"
        check(expr_type == "i64")

    it "query return type of function":
        val ret_type = "text"
        check(ret_type == "text")

    it "query field types of class":
        val fields = ["x: i64", "y: i64"]
        check(fields.len() == 2)

    it "query trait implementations":
        val impls = ["Display", "Debug"]
        check(impls.len() == 2)

describe "Code Navigation":
    it "go to definition":
        val file = "src/main.spl"
        val line = 10
        check(file.ends_with(".spl"))
        check(line > 0)

    it "find all references":
        val refs = 5
        check(refs > 0)

    it "find callers":
        val callers = 3
        check(callers > 0)

    it "find callees":
        val callees = 2
        check(callees > 0)

describe "AST Query":
    it "query all if expressions":
        val count = 10
        check(count > 0)

    it "query all match expressions":
        val count = 5
        check(count > 0)

    it "query all function definitions":
        val count = 50
        check(count > 0)

    it "query all class definitions":
        val count = 20
        check(count > 0)

    it "query all use statements":
        val count = 15
        check(count > 0)
