use compiler.core.ast.{ast_reset, module_get_decls, decl_get_name, decl_get_tag, DECL_IMPL}
use compiler.core.parser.{parser_init_with_path, parser_has_errors}
use compiler.core.parser_decls.{parse_module_body}

fn parse_impl_decls(source: text, path: text) -> [i64]:
    ast_reset()
    parser_init_with_path(source, path)
    parse_module_body()
    if parser_has_errors():
        panic("generic impl parser produced errors")
    module_get_decls()

describe "generic impl declarations":
    it "parses generic parameters on an inherent impl target":
        val source = (
            "enum Option<T>:\n" +
            "    Some(value: T)\n" +
            "    None_\n" +
            "\n" +
            "impl Option<T>:\n" +
            "    fn is_some() -> bool:\n" +
            "        match self:\n" +
            "            case Some(_): true\n" +
            "            case nil: false\n"
        )

        val decls = parse_impl_decls(source, "generic_impl_decl_spec.spl")
        expect(decl_get_tag(decls[1])).to_equal(DECL_IMPL)
        expect(decl_get_name(decls[1])).to_equal("Option")

    it "parses prefix generics trait targets and where constraints":
        val source = (
            "impl<T, E> Hash for Result<T, E> where T: Hash, E: Hash:\n" +
            "    fn hash() -> i64:\n" +
            "        0\n"
        )

        val decls = parse_impl_decls(source, "generic_impl_trait_target_spec.spl")
        expect(decl_get_tag(decls[0])).to_equal(DECL_IMPL)
        expect(decl_get_name(decls[0])).to_equal("Result")

    it "parses array and tuple impl targets":
        val source = (
            "impl<T> Hash for [T] where T: Hash:\n" +
            "    fn hash() -> i64:\n" +
            "        0\n" +
            "\n" +
            "impl<T1, T2> Hash for (T1, T2) where T1: Hash, T2: Hash:\n" +
            "    fn hash() -> i64:\n" +
            "        0\n"
        )

        val decls = parse_impl_decls(source, "generic_impl_builtin_target_spec.spl")
        expect(decl_get_tag(decls[0])).to_equal(DECL_IMPL)
        expect(decl_get_name(decls[0])).to_equal("Array")
        expect(decl_get_tag(decls[1])).to_equal(DECL_IMPL)
        expect(decl_get_name(decls[1])).to_equal("Tuple")
