# Regression spec for the trailing-binary-operator line-continuation lexer
# rule (aka "G27" in src/compiler/10.frontend/core/lexer_struct.spl).
#
# doc/08_tracking/bug/self_hosted_parser_dedent_continuation_2026-07-11.md
# reported that a line ending in a binary operator (e.g. trailing `+`) could
# not be closed by a token dedented BELOW the continuation indent — the
# self-hosted lexer was said to emit a spurious Dedent token and the
# expression parser would fail with "expected expression, found Dedent".
#
# Direct empirical testing (both against the Rust seed's `simple_parser`
# crate and against the current pure-Simple lexer/parser) found:
#   - The Rust seed's parser (src/compiler_rust/parser) does NOT special-case
#     this pattern either — `simple_parser::Parser::new(source).parse()`
#     fails on the exact dedented-close snippet with the same
#     "expected expression, found Dedent" error. The bug doc's premise that
#     "the seed parses it fine" does not hold for the current seed.
#   - The current self-hosted lexer already contains a "G27" rule
#     (lexer_struct.spl handle_indentation(), ~line 777) that suppresses
#     Indent/Dedent/Newline emission whenever the previously scanned
#     significant token is a binary operator, so a continuation line closing
#     below its continuation indent never surfaces a Dedent token to the
#     parser at all.
#
# This spec locks in that current, already-correct behavior so it does not
# silently regress, and documents the trailing-op continuation contract for
# future readers (JSON-string-builder call sites like
# src/lib/common/ui/access_cli_grammar.spl rely on this).
use std.spec
use compiler.core.ast.{module_get_decls, decl_get_name}
use compiler.core.parser.{parse_module, parser_has_errors, parser_set_had_error}

fn parses_ok(name: text, src: text) -> bool:
    parser_set_had_error(false)
    parse_module(src, "dedent_continuation_spec_" + name)
    not parser_has_errors()

describe "trailing-operator continuation across indentation changes":
    it "parses a closing token dedented BELOW the continuation indent (the reported bug repro)":
        val src = "fn make_page(a: text, b: text) -> text:\n" +
            "    val page = \"{\" +\n" +
            "        a + \",\" +\n" +
            "        b +\n" +
            "    \"}\"\n" +
            "    page\n"
        expect(parses_ok("dedented_close", src)).to_equal(true)

    it "parses a closing token indented DEEPER than the continuation indent":
        val src = "fn make_page(a: text, b: text) -> text:\n" +
            "    val page = \"{\" +\n" +
            "        a +\n" +
            "            b +\n" +
            "    \"}\"\n" +
            "    page\n"
        expect(parses_ok("extra_indented_close", src)).to_equal(true)

    it "still parses the closing token left at the continuation indent (previously-normalized style)":
        val src = "fn make_page(a: text, b: text) -> text:\n" +
            "    val page = \"{\" +\n" +
            "        a + \",\" +\n" +
            "        b +\n" +
            "        \"}\"\n" +
            "    page\n"
        expect(parses_ok("continuation_indent_close", src)).to_equal(true)

    it "parses nested trailing-op continuations (mirrors access_cli_grammar.spl access_render_json)":
        val src = "fn render(a: text, b: text) -> text:\n" +
            "    val page = \"{\" +\n" +
            "        a + \",\" +\n" +
            "        b +\n" +
            "    \"}\"\n" +
            "    \"{\" +\n" +
            "        \"page:\" + page +\n" +
            "    \"}\"\n"
        expect(parses_ok("nested_dedented_close", src)).to_equal(true)

    it "parses same-indent RHS after trailing bitwise OR":
        val src = "fn read_word(bytes: [u8]) -> i64:\n" +
            "    (bytes[0] as i64) |\n" +
            "    ((bytes[1] as i64) << 8)\n"
        expect(parses_ok("same_indent_bitwise_or", src)).to_equal(true)

    it "keeps greater-than as a trailing expression operator":
        val src = "fn greater(a: i64, b: i64) -> bool:\n" +
            "    a >\n" +
            "    b\n"
        expect(parses_ok("greater_than_continuation", src)).to_equal(true)

describe "generic close indentation":
    it "dedents after a generic class field type":
        val src = "class Holder:\n" +
            "    values: Dict<text, i32>\n\n" +
            "fn read() -> i64:\n" +
            "    val x = 1\n" +
            "    x\n"
        expect(parses_ok("generic_class_field", src)).to_equal(true)
        val decls = module_get_decls()
        expect(decls.len()).to_equal(2)
        expect(decl_get_name(decls[1])).to_equal("read")

    it "dedents after compact nested generic closes":
        val src = "class Holder:\n" +
            "    values: Dict<text, Option<i32>>\n\n" +
            "fn read() -> i64:\n" +
            "    1\n"
        expect(parses_ok("nested_generic_class_field", src)).to_equal(true)
        val decls = module_get_decls()
        expect(decls.len()).to_equal(2)
        expect(decl_get_name(decls[1])).to_equal("read")

describe "non-continuation indentation is unaffected":
    it "still requires a real INDENT/DEDENT pair for an ordinary nested block":
        val src = "fn f() -> i64:\n" +
            "    if true:\n" +
            "        return 1\n" +
            "    return 0\n"
        expect(parses_ok("ordinary_block", src)).to_equal(true)

    it "still rejects a body statement that is under-indented relative to its block":
        # No trailing binary operator precedes this line, so the dedent
        # suppression rule must NOT apply — a real indentation error here
        # should still be caught by the parser.
        val src = "fn f() -> i64:\n" +
            "    if true:\n" +
            "  return 1\n"
        expect(parses_ok("bad_indent", src)).to_equal(false)
