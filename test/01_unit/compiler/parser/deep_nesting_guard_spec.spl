# Parser deep-nesting recursion guard
#
# Regression for the noise/robustness sweep finding: deeply nested expressions
# (e.g. ~175+ nested parens) overflowed the native stack and aborted `check`
# with a core dump instead of a graceful diagnostic. parse_expr now bounds
# recursion depth (MAX_EXPR_NEST_DEPTH=128) and emits a parser error instead
# of recursing without limit.
#
# The regression itself is "the process survives": before the fix, parsing the
# deep input here would stack-overflow and kill the test runner. Reaching the
# assertions at all proves the guard prevents the crash.

use std.spec
use compiler.frontend.core.parser.{parse_module}

fn nested_parens(n: i64) -> text:
    var s = "fn main():\n  print("
    for i in 0..n:
        s = s + "("
    s = s + "1"
    for i in 0..n:
        s = s + ")"
    s = s + ")\n"
    s

describe "parser deep-nesting recursion guard":
    it "parses pathologically deep nesting without a stack-overflow crash":
        val deep = nested_parens(300)
        val _m = parse_module(deep, "deep_noise.spl")
        # Reaching this line means parse_module returned instead of aborting
        # the process with a stack overflow.
        expect(deep.len()).to_be_greater_than(600)
