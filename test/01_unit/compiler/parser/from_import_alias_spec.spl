use compiler.core.ast.{ast_reset, module_get_decls, decl_get_name, decl_get_imports, decl_get_tag, DECL_USE}
use compiler.core.parser.{parser_init_with_path, parser_has_errors}
use compiler.core.parser_decls.{parse_module_body}

describe "from import aliases":
    it "consumes aliases and records their local names":
        ast_reset()
        parser_init_with_path(
            "from compiler.types.expr_infer import {infer_expr as synthesize_expr}\n" +
            "val after = 1\n",
            "from_import_alias_spec.spl",
        )
        parse_module_body()

        expect(parser_has_errors()).to_equal(false)
        val decls = module_get_decls()
        expect(decls.len()).to_equal(2)
        expect(decl_get_tag(decls[0])).to_equal(DECL_USE)
        expect(decl_get_name(decls[0])).to_equal("compiler.types.expr_infer")
        val imports = decl_get_imports(decls[0])
        expect(imports.len()).to_equal(1)
        expect(imports[0]).to_equal("infer_expr:synthesize_expr")
        expect(decl_get_name(decls[1])).to_equal("after")
