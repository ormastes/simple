use compiler.core.ast.{ast_reset, stmt_get_expr, stmt_get_tag, expr_get_tag, STMT_DEFER, STMT_ERRDEFER, EXPR_CALL}
use compiler.core.parser.{parser_init}
use compiler.core.parser_stmts.{parse_statement}

fn parse_one_statement(source: text) -> i64:
    ast_reset()
    parser_init(source)
    parse_statement()

describe "Errdefer":
    describe "parsing":
        it "parses errdefer statement":
            val stmt = parse_one_statement("errdefer cleanup()")
            expect(stmt_get_tag(stmt)).to_equal(STMT_ERRDEFER)
            expect(expr_get_tag(stmt_get_expr(stmt))).to_equal(EXPR_CALL)

        it "parses defer statement":
            val stmt = parse_one_statement("defer cleanup()")
            expect(stmt_get_tag(stmt)).to_equal(STMT_DEFER)
            expect(expr_get_tag(stmt_get_expr(stmt))).to_equal(EXPR_CALL)
