use compiler.core.parser.{parse_module, parser_get_errors, parser_has_errors}

describe "for tuple bindings":
    it "parses unparenthesized statement and expression targets":
        val source = (
            "fn consume(entries):\n" +
            "    for name, value in entries:\n" +
            "        pass\n" +
            "\n" +
            "for name, value in [(\"answer\", 42)]:\n" +
            "    value\n"
        )

        parse_module(source, "for_tuple_binding_spec.spl")
        expect(parser_has_errors()).to_equal(false)
        expect(parser_get_errors().len()).to_equal(0)
