use compiler.core.parser.{parse_module, parser_has_errors, parser_get_errors}
use std.io_runtime.{file_read}

describe "generic dictionary field declaration boundaries":
    it "parses raw generic maps without swallowing following declarations":
        val source = (
            "struct RawStructOwner:\n" +
            "    fields: Dict<text, i64>\n" +
            "\n" +
            "class RawClassOwner:\n" +
            "    cache: Dict<i64, [i64]>\n" +
            "\n" +
            "fn after_raw_owners() -> i64:\n" +
            "    7\n" +
            "\n" +
            "enum RawMapValue:\n" +
            "    Empty\n" +
            "    Map(Dict<text, i64>)\n" +
            "\n" +
            "    fn as_map(self) -> Dict<text, i64>?:\n" +
            "        None\n" +
            "\n" +
            "fn after_raw_enum() -> i64:\n" +
            "    9\n"
        )

        parse_module(source, "raw_generic_dict_boundaries.spl")
        expect(parser_has_errors()).to_equal(false)
        expect(parser_get_errors().len()).to_equal(0)

    it "dedents after an inline Dict type before a following impl":
        val source = (
            "struct TypeRegistry:\n" +
            "    types: Dict<text, Any>\n" +
            "\n" +
            "impl TypeRegistry:\n" +
            "    fn has_type(name: text) -> bool:\n" +
            "        self.types.has(name)\n"
        )

        parse_module(source, "generic_dict_impl_adjacency_spec.spl")
        expect(parser_has_errors()).to_equal(false)
        expect(parser_get_errors().len()).to_equal(0)

    it "parses a following top-level struct outside the prior owner":
        val source = (
            "type CaptureMap = {text: i64}\n" +
            "struct ClosureValue:\n" +
            "    captures: CaptureMap\n" +
            "\n" +
            "struct ObjectValue:\n" +
            "    class_name: text\n" +
            "    handle: i64\n"
        )

        parse_module(source, "generic_dict_struct_adjacency_spec.spl")
        expect(parser_has_errors()).to_equal(false)
        expect(parser_get_errors().len()).to_equal(0)

    it "keeps HIR template maps behind the bootstrap-safe named boundary":
        val source = file_read("src/compiler/20.hir/hir_definitions.spl")

        expect(source).to_contain("type HirTypeBindings = {text: HirType}")
        expect(source).to_contain("type_bindings: HirTypeBindings")
        expect(source.contains("type_bindings: Dict<text, HirType>")).to_equal(false)

    it "keeps backend symbol-name maps behind the bootstrap-safe named boundary":
        val source = file_read("src/compiler/70.backend/backend/env.spl")

        expect(source).to_contain("type SymbolNameMap = {i64: text}")
        expect(source).to_contain("names: SymbolNameMap")
        expect(source.contains("names: Dict<i64, text>")).to_equal(false)

    it "keeps optional SDN dictionary returns behind a bootstrap-safe named boundary":
        val source = file_read("src/lib/common/sdn/value.spl")

        expect(source).to_contain("type SdnDict = {text: SdnValue}")
        expect(source).to_contain("Dict(SdnDict)")
        expect(source).to_contain("fn as_dict(self) -> SdnDict?:")
        expect(source.contains("fn as_dict(self) -> Dict<text, SdnValue>?:")).to_equal(false)

    it "keeps async state snapshots behind the bootstrap-safe named boundary":
        val source = file_read("src/compiler/90.tools/async_integration.spl")

        expect(source).to_contain("type AsyncLocalsSnapshot = {i64: MirOperand}")
        expect(source).to_contain("locals_snapshot: AsyncLocalsSnapshot")
        expect(source.contains("locals_snapshot: Dict<i64, MirOperand>")).to_equal(false)

    it "keeps NLL liveness maps behind the bootstrap-safe named boundary":
        val source = file_read("src/compiler/55.borrow/borrow_check/nll.spl")

        expect(source).to_contain("type LivenessMap = {i64: [i64]}")
        expect(source).to_contain("live_out: LivenessMap")
        expect(source).to_contain("defs: LivenessMap")
        expect(source.contains("\n    live_out: Dict<i64, [i64]>")).to_equal(false)
