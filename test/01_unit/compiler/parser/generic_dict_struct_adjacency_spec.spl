use compiler.core.parser.{parse_module, parser_has_errors, parser_get_errors}

describe "generic dictionary field declaration boundaries":
    it "parses a following top-level struct outside the prior owner":
        val source = (
            "type CaptureMap = {text: i64}\n" +
            "struct ClosureValue:\n" +
            "    captures: CaptureMap\n" +
            "\n" +
            "struct ObjectValue:\n" +
            "    class_name: text\n" +
            "    handle: i64\n"
        )

        parse_module(source, "generic_dict_struct_adjacency_spec.spl")
        expect(parser_has_errors()).to_equal(false)
        expect(parser_get_errors().len()).to_equal(0)
