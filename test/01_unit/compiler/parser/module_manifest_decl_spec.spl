use std.spec
use compiler.core.parser.{parser_init_with_path, parse_module_body, parser_has_errors, parser_get_errors}
use compiler.core.ast.{ast_reset, decl_count, decl_get_name}

describe "module manifest declarations":
    it "consumes dotted public and private child modules before declarations":
        val source =
            "pub mod public.child;\n" +
            "pri mod restricted.child\n" +
            "mod private_child;\n" +
            "fn kept() -> i64:\n" +
            "    1\n"

        ast_reset()
        parser_init_with_path(source, "module_manifest_decl_spec.spl")
        parse_module_body()

        expect(parser_has_errors()).to_equal(false)
        expect(parser_get_errors().len()).to_equal(0)
        expect(decl_count()).to_equal(1)
        expect(decl_get_name(0)).to_equal("kept")

    it "reports a missing module name and resumes on the next line":
        val source =
            "pub mod\n" +
            "fn recovered() -> i64:\n" +
            "    1\n"

        ast_reset()
        parser_init_with_path(source, "module_manifest_decl_recovery_spec.spl")
        parse_module_body()

        expect(parser_has_errors()).to_equal(true)
        expect(parser_get_errors().len()).to_be_greater_than(0)
        expect(decl_count()).to_equal(1)
        expect(decl_get_name(0)).to_equal("recovered")
