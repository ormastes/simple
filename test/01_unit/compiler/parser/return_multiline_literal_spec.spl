# Regression spec for #145: bare multi-line array/dict literals in RETURN
# position must parse, including sources with CRLF line endings (the "\r"
# used to surface as an Error token, breaking multi-line bracketed literals
# with errors like "expected ], got ..." while a re-typed LF val-assignment
# form worked).
use std.spec
use compiler.core.parser.{parse_module, parser_has_errors, parser_set_had_error}

fn parses_ok(name: text, src: text) -> bool:
    parser_set_had_error(false)
    parse_module(src, "return_multiline_literal_spec_" + name)
    not parser_has_errors()

describe "return-position multi-line literals (#145)":
    it "parses multi-line array with trailing comma in return position":
        expect(parses_ok("trailing", "fn f() -> [i64]:\n    return [\n        1,\n        2,\n    ]\n")).to_be_true()

    it "parses multi-line array without trailing comma in return position":
        expect(parses_ok("no_trailing", "fn f() -> [i64]:\n    return [\n        1,\n        2\n    ]\n")).to_be_true()

    it "parses nested array literal in return position":
        expect(parses_ok("nested", "fn f() -> [[i64]]:\n    return [[1,2],[3,4]]\n")).to_be_true()

    it "parses multi-line nested array literal in return position":
        expect(parses_ok("nested_ml", "fn f() -> [[i64]]:\n    return [\n        [1, 2],\n        [3, 4],\n    ]\n")).to_be_true()

    it "parses multi-line dict literal in return position":
        expect(parses_ok("dict", "fn f() -> {text: i64}:\n    return {\n        \"a\": 1,\n        \"b\": 2,\n    }\n")).to_be_true()

    it "still parses multi-line array in val-assignment position":
        expect(parses_ok("val_form", "fn f() -> [i64]:\n    val r = [\n        1,\n        2,\n    ]\n    return r\n")).to_be_true()

    it "parses CRLF source with multi-line array in return position":
        expect(parses_ok("crlf", "fn f() -> [i64]:\r\n    return [\r\n        1,\r\n        2,\r\n    ]\r\n")).to_be_true()

    it "parses mixed LF/CRLF source (pasted block) in return position":
        expect(parses_ok("mixed", "fn f() -> [i64]:\n    return [\r\n        1,\r\n        2,\r\n    ]\n")).to_be_true()

describe "multi-line array runtime behavior (#145)":
    it "returns the array value from return-position multi-line literal":
        val a = p145_ret_arr()
        expect(a.len()).to_equal(2)
        expect(a[0]).to_equal(1)
        expect(a[1]).to_equal(2)

fn p145_ret_arr() -> [i64]:
    return [
        1,
        2,
    ]
