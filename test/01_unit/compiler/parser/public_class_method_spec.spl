use compiler.core.ast.{
    ast_reset, module_get_decls, decl_get_body, decl_get_is_async,
    decl_get_name, decl_get_tag, decl_get_visibility_text, DECL_IMPL
}
use compiler.core.parser.{parser_init_with_path, parser_has_errors}
use compiler.core.parser_decls.{parse_module_body}

describe "public class methods":
    it "preserves visibility and method modes before the next declaration":
        val source = (
            "class PublicMethods:\n" +
            "    pub static fn static_api() -> i64:\n" +
            "        1\n" +
            "    pub fn instance_api() -> i64:\n" +
            "        2\n" +
            "    pub me mutable_api():\n" +
            "        pass_dn\n" +
            "\n" +
            "val sentinel = 7\n"
        )

        ast_reset()
        parser_init_with_path(source, "public_class_method_spec.spl")
        parse_module_body()

        expect(parser_has_errors()).to_equal(false)
        val decls = module_get_decls()
        expect(decls.len()).to_equal(3)
        expect(decl_get_tag(decls[0])).to_equal(DECL_IMPL)
        val methods = decl_get_body(decls[0])
        expect(methods.len()).to_equal(3)

        expect(decl_get_name(methods[0])).to_equal("PublicMethods__static_api")
        expect(decl_get_is_async(methods[0])).to_equal(1)
        expect(decl_get_visibility_text(methods[0])).to_equal("public")

        expect(decl_get_name(methods[1])).to_equal("PublicMethods__instance_api")
        expect(decl_get_is_async(methods[1])).to_equal(0)
        expect(decl_get_visibility_text(methods[1])).to_equal("public")

        expect(decl_get_name(methods[2])).to_equal("PublicMethods__mutable_api")
        expect(decl_get_is_async(methods[2])).to_equal(2)
        expect(decl_get_visibility_text(methods[2])).to_equal("public")
        expect(decl_get_name(decls[2])).to_equal("sentinel")

    it "rejects unsupported public fields without losing parser recovery":
        ast_reset()
        parser_init_with_path(
            "class InvalidPublicField:\n" +
            "    pub value: i64\n" +
            "\n" +
            "val sentinel = 9\n",
            "public_class_method_spec.spl",
        )
        parse_module_body()

        expect(parser_has_errors()).to_equal(true)
        val decls = module_get_decls()
        expect(decls.len()).to_equal(2)
        expect(decl_get_name(decls[1])).to_equal("sentinel")
