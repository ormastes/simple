use compiler.frontend.parser.recovery.{CommonMistake, detect_common_mistake}

describe "function common-mistake detection":
    it "detects a TypeScript function declaration shape":
        val mistake = detect_common_mistake(
            "function", "Identifier", "Newline", "add", "Identifier")
        if mistake.?:
            expect(mistake).to_equal(CommonMistake.TsFunction)
        else:
            fail("expected TypeScript function declaration detection")

    it "accepts function as a Simple for binder":
        val mistake = detect_common_mistake(
            "function", "Identifier", "For", "in", "In")
        expect(mistake.?).to_equal(false)
