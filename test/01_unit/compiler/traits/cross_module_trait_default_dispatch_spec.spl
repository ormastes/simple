"""
# Cross-module trait default-method dispatch (task #55, interpreter half).
#
# Companion to default_trait_dispatch_spec.spl, which covers the SAME-MODULE
# case (trait + impl in one file). This spec puts the trait (with default
# bodies) in test/fixtures/cross_module_trait_default/xmod_trait_def.spl and
# the impl (overriding only one of the two defaults) in a separate module,
# xmod_trait_impl.spl. The un-overridden default (greet) must still dispatch
# through the trait's own body when called on the implementing type.
"""

use std.spec.{describe, it, expect}
use test.fixtures.cross_module_trait_default.xmod_trait_impl.{XModDftTarget}

describe "cross-module trait default method dispatch":
    """Real t.method() dispatch where the trait default lives in a different
    module than the impl."""

    it "inherited default greet runs the trait's own body across modules":
        val t = XModDftTarget(n: 1)
        expect(t.greet()).to_equal("default-greet")

    it "overridden farewell runs the impl body, not the trait default":
        val t = XModDftTarget(n: 2)
        expect(t.farewell()).to_equal("override-farewell")
