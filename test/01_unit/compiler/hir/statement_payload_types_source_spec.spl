extern fn rt_file_read_text(path: text) -> text

describe "HIR statement payload extraction source":
    it "keeps pre-dispatched payloads on their concrete parser types":
        val source = rt_file_read_text("src/compiler/20.hir/hir_lowering/statements.spl") ?? ""

        expect(source).to_contain("val v_name: text = match stmt_kind_value:")
        expect(source).to_contain("val v_type: Type? = match stmt_kind_value:")
        expect(source).to_contain("val v_init: Expr = match stmt_kind_value:")
        expect(source).to_contain("val vr_init: Expr? = match stmt_kind_value:")
        expect(source).to_contain("val as_target: Expr = match stmt_kind_value:")
        expect(source).to_contain("val as_op: AssignOp? = match stmt_kind_value:")
        expect(source).to_contain("val as_value: Expr = match stmt_kind_value:")
