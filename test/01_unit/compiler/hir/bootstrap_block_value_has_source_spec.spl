extern fn rt_file_read_text(path: text) -> text

fn hir_expressions_source() -> text:
    rt_file_read_text("src/compiler/20.hir/hir_lowering/expressions.spl") ?? ""

describe "bootstrap HIR block value source":
    it "marks extracted bootstrap tail values as present":
        val source = hir_expressions_source()

        expect(source).to_contain("if boot_value.?:")
        expect(source).to_contain("return HirBlock(stmts: boot_stmts, has: true")
        expect(source).to_contain("return HirBlock(stmts: boot_stmts, has: false")
