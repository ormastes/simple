extern fn rt_file_read_text(path: text) -> text

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "HIR statement dispatch source":
    it "keeps bootstrap statement discriminants aligned with parser statement variants":
        val source = read_source("src/compiler/20.hir/hir_lowering/statements.spl")

        expect(source).to_contain("fn hir_stmt_kind_disc(k: StmtKind) -> i64:")
        expect(source).to_contain("case StmtKind.Val(_, _, _):")
        expect(source).to_contain("case StmtKind.Var(_, _, _):")
        expect(source).to_contain("case StmtKind.Return(_):")
        expect(source).to_contain("case StmtKind.For(_, _, _):")
        expect(source).to_contain("case StmtKind.While(_, _):")
        expect(source).to_contain("case StmtKind.GpuLaunch(_, _):")
