struct Inner:
    v: i64

struct Outer:
    inner: Inner
    arr: [i64]

fn main():
    # struct field holding a bit-63 i64
    var o = Outer(inner: Inner(v: 0), arr: [0, 0, 0])
    o.inner.v = 0x8010000000000000
    print("struct field bit63 ? {o.inner.v == -9218868437227405312}  (dropped? {o.inner.v == 4503599627370496})")

    # nested struct + array-in-struct (like core.rf.regs)
    o.arr[2] = 0x8010000000000000
    print("array-in-struct bit63 ? {o.arr[2] == -9218868437227405312}  (dropped? {o.arr[2] == 4503599627370496})")

    # pass bit-63 i64 into a function param and back
    print("fn-return bit63 ? {ident(0x8010000000000000) == -9218868437227405312}")

fn ident(x: i64) -> i64:
    x
