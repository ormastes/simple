use std.spec.{describe, it, expect}

fn classify(x: i64) -> i64:
    if x == 1: return 10
    if x == 2: return 20
    if x == 3: return 30
    return -1

fn classify_u8(b: u8) -> i64:
    if b == 0x41u8: return 0
    if b == 0x42u8: return 1
    if b == 0x43u8: return 2
    return -1

describe "sequential if return":
    it "first branch works":
        expect(classify(1)).to_equal(10)

    it "second branch works":
        expect(classify(2)).to_equal(20)

    it "third branch works":
        expect(classify(3)).to_equal(30)

    it "default fallthrough":
        expect(classify(99)).to_equal(-1)

    it "u8 first branch":
        expect(classify_u8(0x41u8)).to_equal(0)

    it "u8 second branch":
        expect(classify_u8(0x42u8)).to_equal(1)

    it "u8 third branch":
        expect(classify_u8(0x43u8)).to_equal(2)

    it "u8 default":
        expect(classify_u8(0x44u8)).to_equal(-1)
