# Regression spec: qualified `Result.Ok(x)` / `Option.Some(x)` receivers must
# resolve even in a module that never explicitly imports the stdlib
# Result/Option declaration (this file intentionally has no `use` statement).
#
# Mirrors Rust-seed fix 86e56ca7867 ("route qualified Result.Ok/Option.Some
# through static-member lowering when types.lookup misses"). Self-hosted
# mirror site: src/compiler/20.hir/hir_lowering/expressions.spl
# `lower_unresolved_ident`.
#
# Surface bug (pre-fix): `Result<T,E>`/`Option<T>` TYPE annotations are
# special-cased in hir_lowering/types.spl without ever registering a
# "Result"/"Option" SYMBOL. A module that only ever uses them as type
# annotations (never imports the real struct/enum declaration -- mirrors the
# seed bug's "freestanding/entry-closure kernel module without the std
# prelude") had no such symbol, so the qualified receiver `Result`/`Option`
# hard-errored "unresolved name: Result" during HIR lowering, even though
# MIR's enum_variant_index always registers Result/Option's variants
# module-wide and would route `.Ok(...)`/`.Some(...)` correctly if only the
# receiver identifier had resolved.
#
# tag: unit

fn make_ok(x: i64) -> Result<i64, text>:
    return Result.Ok(x)

fn make_err(msg: text) -> Result<i64, text>:
    return Result.Err(msg)

fn make_some(x: i64) -> Option<i64>:
    return Option.Some(x)

describe "qualified Result.Ok/Err and Option.Some without an explicit std import":
    it "constructs and unwraps a qualified Result.Ok(...) receiver":
        expect make_ok(7).unwrap() == 7

    it "constructs a qualified Result.Err(...) receiver and falls back on unwrap_or":
        expect make_err("boom").unwrap_or(9) == 9

    it "constructs and unwraps a qualified Option.Some(...) receiver":
        expect make_some(11).unwrap() == 11
