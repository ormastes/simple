fn empty_kernel_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [],
        terminator: MirTerminator.Unreachable
    )

fn opencl_id_kernel_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.GpuGlobalId(LocalId(id: 0), 0), span: nil),
            MirInst(kind: MirInstKind.GpuLocalId(LocalId(id: 1), 0), span: nil),
            MirInst(kind: MirInstKind.GpuBarrier(GpuBarrierScope.Workgroup), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn u32_type() -> MirType:
    MirType(kind: MirTypeKind.U32)

fn u64_type() -> MirType:
    MirType(kind: MirTypeKind.U64)

fn f32_type() -> MirType:
    MirType(kind: MirTypeKind.F32)

fn vec4f_type() -> MirType:
    MirType(kind: MirTypeKind.Vec4f)

fn vec8f_type() -> MirType:
    MirType(kind: MirTypeKind.Vec8f)

fn vec4d_type() -> MirType:
    MirType(kind: MirTypeKind.Vec4d)

fn vec4i_type() -> MirType:
    MirType(kind: MirTypeKind.Vec4i)

fn vec8i_type() -> MirType:
    MirType(kind: MirTypeKind.Vec8i)

fn bool_type() -> MirType:
    MirType(kind: MirTypeKind.Bool)

fn global_u32_ptr_type() -> MirType:
    MirType.ptr(u32_type(), true)

fn global_f32_ptr_type() -> MirType:
    MirType.ptr(f32_type(), true)

fn global_vec4f_ptr_type() -> MirType:
    MirType.ptr(vec4f_type(), true)

fn private_u32_ptr_type() -> MirType:
    MirType.ptr(u32_type(), false)

fn u32_array3_type() -> MirType:
    MirType(kind: MirTypeKind.Array(u32_type(), 3))

fn arg_local(id: i64, index: i64, name: text, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: Some(name), type_: type_, kind: LocalKind.Arg(index), is_ghost: false)

fn temp_local(id: i64, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: type_, kind: LocalKind.Temp, is_ghost: false)

fn opencl_vector_add_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.GpuGlobalId(LocalId(id: 3), 0), span: nil),
            MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 4), MirOperand.copy(LocalId(id: 0)), [MirOperand.copy(LocalId(id: 3))]), span: nil),
            MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 5), MirOperand.copy(LocalId(id: 1)), [MirOperand.copy(LocalId(id: 3))]), span: nil),
            MirInst(kind: MirInstKind.Load(LocalId(id: 7), MirOperand.copy(LocalId(id: 4))), span: nil),
            MirInst(kind: MirInstKind.Load(LocalId(id: 8), MirOperand.copy(LocalId(id: 5))), span: nil),
            MirInst(kind: MirInstKind.BinOp(LocalId(id: 9), MirBinOp.Add, MirOperand.copy(LocalId(id: 7)), MirOperand.copy(LocalId(id: 8))), span: nil),
            MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 6), MirOperand.copy(LocalId(id: 2)), [MirOperand.copy(LocalId(id: 3))]), span: nil),
            MirInst(kind: MirInstKind.Store(MirOperand.copy(LocalId(id: 6)), MirOperand.copy(LocalId(id: 9))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_checked_binop_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.CheckedBinOp(LocalId(id: 2), MirBinOp.Add, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_cast_bitcast_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Cast(LocalId(id: 1), MirOperand.copy(LocalId(id: 0)), f32_type()), span: nil),
            MirInst(kind: MirInstKind.Bitcast(LocalId(id: 2), MirOperand.copy(LocalId(id: 0)), f32_type()), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_scale_device_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.BinOp(LocalId(id: 2), MirBinOp.Mul, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil)
        ],
        terminator: MirTerminator.Ret(Some(MirOperand.copy(LocalId(id: 2))))
    )

fn opencl_call_block() -> MirBlock:
    val callee = MirOperand(kind: MirOperandKind.Const(
        MirConstValue.Str("opencl_scale_u32"),
        MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [u32_type(), u32_type()], return_type: u32_type(), is_variadic: false)))
    ))
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Call(Some(LocalId(id: 2)), callee, [MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))]), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_indirect_call_block() -> MirBlock:
    val sig = MirSignature(params: [u32_type()], return_type: u32_type(), is_variadic: false)
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.CallIndirect(Some(LocalId(id: 2)), MirOperand.copy(LocalId(id: 0)), [MirOperand.copy(LocalId(id: 1))], sig), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_array_aggregate_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Aggregate(LocalId(id: 3), AggregateKind.Array(u32_type()), [MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 2))]), span: nil),
            MirInst(kind: MirInstKind.GetField(LocalId(id: 4), MirOperand.copy(LocalId(id: 3)), 1), span: nil),
            MirInst(kind: MirInstKind.SetField(MirOperand.copy(LocalId(id: 3)), 2, MirOperand.copy(LocalId(id: 4))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_alloc_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Alloc(LocalId(id: 1), u32_type()), span: nil),
            MirInst(kind: MirInstKind.Store(MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 0))), span: nil),
            MirInst(kind: MirInstKind.Load(LocalId(id: 2), MirOperand.copy(LocalId(id: 1))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_simd_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.SimdAddF32x4(LocalId(id: 5), MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil),
            MirInst(kind: MirInstKind.SimdFmaF32x4(LocalId(id: 6), MirOperand.copy(LocalId(id: 5)), MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 2))), span: nil),
            MirInst(kind: MirInstKind.SimdXorI32x4(LocalId(id: 7), MirOperand.copy(LocalId(id: 3)), MirOperand.copy(LocalId(id: 4))), span: nil),
            MirInst(kind: MirInstKind.SimdAndI32x4(LocalId(id: 8), MirOperand.copy(LocalId(id: 7)), MirOperand.copy(LocalId(id: 4))), span: nil),
            MirInst(kind: MirInstKind.SimdHaddF32x4(LocalId(id: 9), MirOperand.copy(LocalId(id: 6))), span: nil),
            MirInst(kind: MirInstKind.SimdHmaxF32x4(LocalId(id: 10), MirOperand.copy(LocalId(id: 6))), span: nil),
            MirInst(kind: MirInstKind.SimdHminF32x4(LocalId(id: 11), MirOperand.copy(LocalId(id: 6))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_generic_simd_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.MirSimdSplat(LocalId(id: 8), MirOperand.copy(LocalId(id: 0)), vec4f_type()), span: nil),
            MirInst(kind: MirInstKind.MirSimdLoad(LocalId(id: 9), MirOperand.copy(LocalId(id: 5)), true, vec4f_type()), span: nil),
            MirInst(kind: MirInstKind.MirSimdGather(LocalId(id: 10), MirOperand.copy(LocalId(id: 6)), MirOperand.copy(LocalId(id: 4)), vec4f_type()), span: nil),
            MirInst(kind: MirInstKind.MirSimdBinop(LocalId(id: 11), MirOperand.copy(LocalId(id: 8)), MirOperand.copy(LocalId(id: 9)), "Add"), span: nil),
            MirInst(kind: MirInstKind.MirSimdTernop(LocalId(id: 12), MirOperand.copy(LocalId(id: 11)), MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 2)), "Fma"), span: nil),
            MirInst(kind: MirInstKind.MirSimdUnop(LocalId(id: 13), MirOperand.copy(LocalId(id: 12)), "Sqrt"), span: nil),
            MirInst(kind: MirInstKind.MirSimdReduce(LocalId(id: 14), MirOperand.copy(LocalId(id: 13)), "Sum"), span: nil),
            MirInst(kind: MirInstKind.MirSimdCmp(LocalId(id: 15), MirOperand.copy(LocalId(id: 3)), MirOperand.copy(LocalId(id: 4)), "Lt"), span: nil),
            MirInst(kind: MirInstKind.MirSimdSelect(LocalId(id: 16), MirOperand.copy(LocalId(id: 15)), MirOperand.copy(LocalId(id: 13)), MirOperand.copy(LocalId(id: 10))), span: nil),
            MirInst(kind: MirInstKind.MirSimdMaskOp(LocalId(id: 17), MirOperand.copy(LocalId(id: 15)), MirOperand.copy(LocalId(id: 3)), "And"), span: nil),
            MirInst(kind: MirInstKind.MirSimdStore(MirOperand.copy(LocalId(id: 16)), MirOperand.copy(LocalId(id: 5)), true), span: nil),
            MirInst(kind: MirInstKind.MirSimdScatter(MirOperand.copy(LocalId(id: 16)), MirOperand.copy(LocalId(id: 6)), MirOperand.copy(LocalId(id: 4))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_branch_blocks() -> [MirBlock]:
    [
        MirBlock(
            id: BlockId.entry(),
            label: Some("entry"),
            instructions: [],
            terminator: MirTerminator.If(MirOperand.copy(LocalId(id: 0)), BlockId(id: 1), BlockId(id: 2))
        ),
        MirBlock(
            id: BlockId(id: 1),
            label: Some("then"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 3))
        ),
        MirBlock(
            id: BlockId(id: 2),
            label: Some("else"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 3))
        ),
        MirBlock(
            id: BlockId(id: 3),
            label: Some("merge"),
            instructions: [],
            terminator: MirTerminator.Ret(nil)
        )
    ]

fn opencl_switch_blocks() -> [MirBlock]:
    [
        MirBlock(
            id: BlockId.entry(),
            label: Some("entry"),
            instructions: [],
            terminator: MirTerminator.Switch(
                MirOperand.copy(LocalId(id: 0)),
                [
                    SwitchCase(value: 1, target: BlockId(id: 1)),
                    SwitchCase(value: 2, target: BlockId(id: 2))
                ],
                BlockId(id: 3)
            )
        ),
        MirBlock(
            id: BlockId(id: 1),
            label: Some("case_one"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 4))
        ),
        MirBlock(
            id: BlockId(id: 2),
            label: Some("case_two"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 4))
        ),
        MirBlock(
            id: BlockId(id: 3),
            label: Some("default"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 4))
        ),
        MirBlock(
            id: BlockId(id: 4),
            label: Some("merge"),
            instructions: [],
            terminator: MirTerminator.Ret(nil)
        )
    ]

fn opencl_atomic_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.GpuAtomicOp(LocalId(id: 2), GpuAtomicOpKind.Add, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil),
            MirInst(kind: MirInstKind.GpuAtomicCas(LocalId(id: 3), MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 2))), span: nil),
            MirInst(kind: MirInstKind.GpuMemFence(GpuMemoryScope.All), span: nil),
            MirInst(kind: MirInstKind.GpuSharedAlloc(LocalId(id: 4), u32_type(), 32), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn make_kernel_function(id: i64, name: text, target: text) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: id),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [],
        blocks: [empty_kernel_block()],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: target,
        gpu_backend_order: target,
