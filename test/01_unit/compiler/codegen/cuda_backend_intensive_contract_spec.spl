# @cover src/compiler/70.backend/backend/cuda_backend.spl 80%
# @tag: unit, compiler, gpu, codegen, cuda

use compiler.backend.backend.backend_types.{BackendKind}
use compiler.backend.cuda_backend.{CudaBackend}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_data.{MirFunction, MirModule, MirSignature, BlockId, LocalId}
use compiler.mir.mir_instructions.{MirBlock, MirInst, MirInstKind, MirTerminator, MirOperand, MirOperandKind, MirBinOp, GpuAtomicOpKind}
use compiler.mir.mir_types.{MirLocal, MirType, MirTypeKind, MirConstValue, LocalKind}

fn cuda_u32() -> MirType: MirType(kind: MirTypeKind.U32)
fn cuda_u64() -> MirType: MirType(kind: MirTypeKind.U64)
fn cuda_bool() -> MirType: MirType(kind: MirTypeKind.Bool)
fn cuda_ptr() -> MirType: MirType.ptr(cuda_u32(), true)

fn cuda_arg(id: i64, index: i64, name: text, ty: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: Some(name), type_: ty, kind: LocalKind.Arg(index), is_ghost: false)

fn cuda_temp(id: i64, ty: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: ty, kind: LocalKind.Temp, is_ghost: false)

fn cuda_function(id: i64, name: text, params: [MirType], ret: MirType, locals: [MirLocal], blocks: [MirBlock], kernel: bool) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: id), name: name,
        signature: MirSignature(params: params, return_type: ret, is_variadic: false),
        locals: locals, blocks: blocks, entry_block: BlockId.entry(), span: Span.empty(),
        generic_params: [], is_generic_template: false, specialization_of: nil,
        type_bindings: {}, layout_phase: nil, is_kernel: kernel,
        gpu_target: "cuda", gpu_backend_order: "cuda", is_export_c: false,
        export_name: "", has_driver_manifest_attr: false, driver_manifest_attr: nil,
        has_vhdl_metadata: false, vhdl_metadata: vhdl_hardware_metadata_default(), has_fast_math: false
    )

fn cuda_module(functions: [MirFunction]) -> MirModule:
    var map: Dict<SymbolId, MirFunction> = {}
    for fn_ in functions: map[fn_.symbol] = fn_
    MirModule(name: "cuda_intensive", functions: map, statics: {}, constants: {}, types: {})

fn compile_supported_cuda(functions: [MirFunction]) -> text:
    val result = CudaBackend.create((8, 6)).compile(cuda_module(functions))
    expect(result.is_ok()).to_equal(true)
    result.unwrap().ptx

fn reject_unsupported_cuda(fn_: MirFunction):
    val result = CudaBackend.create((8, 6)).compile(cuda_module([fn_]))
    expect(result.is_err()).to_equal(true)

fn assert_backend_error_contains(fn_: MirFunction, fragment: text):
    val result = CudaBackend.create((8, 6)).compile(cuda_module([fn_]))
    expect(result.is_err()).to_equal(true)
    val error = result.unwrap_err()
    expect(error.phase).to_contain(BackendKind.Cuda.to_text())
    expect(error.message).to_contain(fragment)

fn assert_no_placeholder_output(ptx: text):
    expect(ptx.contains("Unsupported")).to_equal(false)
    expect(ptx.contains("placeholder")).to_equal(false)
    expect(ptx.contains("not implemented")).to_equal(false)

describe "CUDA backend intensive MIR contract":
    it "emits if branches and loop backedges as executable PTX control flow":
        val blocks = [
            MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [], terminator: MirTerminator.If(MirOperand.copy(LocalId(id: 0)), BlockId(id: 1), BlockId(id: 3))),
            MirBlock(id: BlockId(id: 1), label: Some("loop"), instructions: [], terminator: MirTerminator.Goto(BlockId(id: 2))),
            MirBlock(id: BlockId(id: 2), label: Some("backedge"), instructions: [], terminator: MirTerminator.Goto(BlockId(id: 1))),
            MirBlock(id: BlockId(id: 3), label: Some("exit"), instructions: [], terminator: MirTerminator.Ret(nil))
        ]
        val fn_ = cuda_function(1, "cuda_control", [cuda_bool()], MirType.unit(), [cuda_arg(0, 0, "cond", cuda_bool())], blocks, true)
        val ptx = compile_supported_cuda([fn_])
        expect(ptx).to_contain("ld.param.u8")
        expect(ptx).to_contain("setp.ne.u8 %r0")
        expect(ptx).to_contain("@%r0 bra BB1;")
        expect(ptx).to_contain("bra BB3;")
        expect(ptx).to_contain("bra BB1;")
        assert_no_placeholder_output(ptx)

    it "emits direct device calls by symbol name":
        val callee_signature = MirSignature(params: [cuda_u32(), cuda_u32()], return_type: cuda_u32(), is_variadic: false)
        val callee_block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.BinOp(LocalId(id: 2), MirBinOp.Add, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil)], terminator: MirTerminator.Ret(Some(MirOperand.copy(LocalId(id: 2)))))
        val callee = cuda_function(2, "cuda_add", [cuda_u32(), cuda_u32()], cuda_u32(), [cuda_arg(0, 0, "a", cuda_u32()), cuda_arg(1, 1, "b", cuda_u32()), cuda_temp(2, cuda_u32())], [callee_block], false)
        val callee_operand = MirOperand(kind: MirOperandKind.Const(MirConstValue.Str("cuda_add"), MirType(kind: MirTypeKind.FuncPtr(callee_signature))))
        val caller_block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.Call(Some(LocalId(id: 2)), callee_operand, [MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))]), span: nil)], terminator: MirTerminator.Ret(nil))
        val caller = cuda_function(3, "cuda_call", [cuda_u32(), cuda_u32()], MirType.unit(), [cuda_arg(0, 0, "a", cuda_u32()), cuda_arg(1, 1, "b", cuda_u32()), cuda_temp(2, cuda_u32())], [caller_block], true)
        val ptx = compile_supported_cuda([callee, caller])
        expect(ptx).to_contain(".param .u32 __call_0_arg_0;")
        expect(ptx).to_contain("st.param.u32 [__call_0_arg_0], %r0;")
        expect(ptx).to_contain(".param .u32 __call_0_arg_1;")
        expect(ptx).to_contain("st.param.u32 [__call_0_arg_1], %r1;")
        expect(ptx).to_contain(".param .u32 __call_0_retval;")
        expect(ptx).to_contain("call (__call_0_retval), cuda_add, (__call_0_arg_0, __call_0_arg_1);")
        expect(ptx).to_contain("ld.param.u32 %r2, [__call_0_retval];")
        expect(ptx).to_contain("st.param.u32 [retval], %r2;")
        expect(ptx).to_contain("add.u32 %r2, %r0, %r1;")
        expect(ptx.contains("call (%r2)")).to_equal(false)
        assert_no_placeholder_output(ptx)

    it "emits global load store and shared allocation":
        val block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [
            MirInst(kind: MirInstKind.Load(LocalId(id: 1), MirOperand.copy(LocalId(id: 0))), span: nil),
            MirInst(kind: MirInstKind.Store(MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil),
            MirInst(kind: MirInstKind.GpuSharedAlloc(LocalId(id: 2), cuda_u32(), 64), span: nil)
        ], terminator: MirTerminator.Ret(nil))
        val fn_ = cuda_function(4, "cuda_memory", [cuda_ptr()], MirType.unit(), [cuda_arg(0, 0, "data", cuda_ptr()), cuda_temp(1, cuda_u32()), cuda_temp(2, cuda_ptr())], [block], true)
        val ptx = compile_supported_cuda([fn_])
        expect(ptx).to_contain("ld.global")
        expect(ptx).to_contain("st.global")
        expect(ptx).to_contain("ld.global.u32 %r1, [%r0];")
        expect(ptx).to_contain("st.global.u32 [%r0], %r1;")
        expect(ptx).to_contain(".shared")
        expect(ptx).to_contain("shared_2")
        expect(ptx).to_contain("cvta.shared.u64 %r2, shared_2;")
        expect(ptx).to_contain("ld.param.u64 %r0, [param_0];")
        assert_no_placeholder_output(ptx)

    it "rejects compare-exchange through the deprecated generic atomic instruction":
        val block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [
            MirInst(kind: MirInstKind.GpuAtomicOp(LocalId(id: 2), GpuAtomicOpKind.CompareExchange, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil)
        ], terminator: MirTerminator.Ret(nil))
        val fn_ = cuda_function(13, "cuda_deprecated_compare_exchange", [cuda_ptr(), cuda_u32()], MirType.unit(), [cuda_arg(0, 0, "ptr", cuda_ptr()), cuda_arg(1, 1, "value", cuda_u32()), cuda_temp(2, cuda_u32())], [block], true)

        assert_backend_error_contains(fn_, "compare-exchange requires GpuAtomicCas")

    it "rejects indirect calls with CUDA backend identity preserved":
        val sig = MirSignature(params: [cuda_u32()], return_type: cuda_u32(), is_variadic: false)
        val block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.CallIndirect(Some(LocalId(id: 2)), MirOperand.copy(LocalId(id: 0)), [MirOperand.copy(LocalId(id: 1))], sig), span: nil)], terminator: MirTerminator.Ret(nil))
        val fn_ = cuda_function(5, "cuda_indirect", [MirType(kind: MirTypeKind.FuncPtr(sig)), cuda_u32()], MirType.unit(), [cuda_arg(0, 0, "fnptr", MirType(kind: MirTypeKind.FuncPtr(sig))), cuda_arg(1, 1, "x", cuda_u32()), cuda_temp(2, cuda_u32())], [block], true)
        reject_unsupported_cuda(fn_)
        assert_backend_error_contains(fn_, "indirect GPU calls")

    it "rejects unsupported switch terminators instead of comment-only success":
        val block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [], terminator: MirTerminator.Switch(MirOperand.copy(LocalId(id: 0)), [], BlockId(id: 1)))
        val fn_ = cuda_function(6, "cuda_switch", [cuda_u32()], MirType.unit(), [cuda_arg(0, 0, "selector", cuda_u32())], [block], true)
        reject_unsupported_cuda(fn_)
        assert_backend_error_contains(fn_, "terminator")

    it "rejects unsupported arithmetic and constants with typed CUDA errors":
        val rem_block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.BinOp(LocalId(id: 2), MirBinOp.Rem, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil)], terminator: MirTerminator.Ret(nil))
        val rem_fn = cuda_function(7, "cuda_rem", [cuda_u32(), cuda_u32()], MirType.unit(), [cuda_arg(0, 0, "a", cuda_u32()), cuda_arg(1, 1, "b", cuda_u32()), cuda_temp(2, cuda_u32())], [rem_block], true)
        assert_backend_error_contains(rem_fn, "binary operation")

        val str_block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.Const(LocalId(id: 0), MirConstValue.Str("bad"), MirType(kind: MirTypeKind.Opaque("text"))), span: nil)], terminator: MirTerminator.Ret(nil))
        val str_fn = cuda_function(8, "cuda_string", [], MirType.unit(), [cuda_temp(0, MirType(kind: MirTypeKind.Opaque("text")))], [str_block], true)
        assert_backend_error_contains(str_fn, "local type")

        val bool_sig = MirSignature(params: [cuda_bool()], return_type: MirType.unit(), is_variadic: false)
        val bool_callee = MirOperand(kind: MirOperandKind.Const(MirConstValue.Str("cuda_bool_device"), MirType(kind: MirTypeKind.FuncPtr(bool_sig))))
        val bool_device_block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [], terminator: MirTerminator.Ret(nil))
        val bool_device_fn = cuda_function(11, "cuda_bool_device", [cuda_bool()], MirType.unit(), [cuda_arg(0, 0, "flag", cuda_bool())], [bool_device_block], false)
        val bool_call_block = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.Call(nil, bool_callee, [MirOperand.copy(LocalId(id: 0))]), span: nil)], terminator: MirTerminator.Ret(nil))
        val bool_call_fn = cuda_function(12, "cuda_bool_call", [cuda_bool()], MirType.unit(), [cuda_arg(0, 0, "flag", cuda_bool())], [bool_call_block], true)
        val bool_result = CudaBackend.create((8, 6)).compile(cuda_module([bool_device_fn, bool_call_fn]))
        expect(bool_result.is_err()).to_equal(true)
        expect(bool_result.unwrap_err().message).to_contain("boolean parameters")

    it "rejects unknown and malformed intrinsics instead of emitting comments":
        val unknown = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_unknown", []), span: nil)], terminator: MirTerminator.Ret(nil))
        val unknown_fn = cuda_function(9, "cuda_unknown_intrinsic", [], MirType.unit(), [cuda_temp(0, cuda_u32())], [unknown], true)
        assert_backend_error_contains(unknown_fn, "does not support intrinsic")

        val malformed = MirBlock(id: BlockId.entry(), label: Some("entry"), instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_vec4_load_f32", []), span: nil)], terminator: MirTerminator.Ret(nil))
        val malformed_fn = cuda_function(10, "cuda_bad_intrinsic", [], MirType.unit(), [cuda_temp(0, cuda_u32())], [malformed], true)
        assert_backend_error_contains(malformed_fn, "requires 2 arguments")
