# Host/GPU lane codegen marker consumption regression.
#
# @cover src/compiler/70.backend/codegen.spl 5%

use std.spec
use compiler.backend.codegen.{Codegen, CodegenMode, CodegenTarget}
use compiler.mir.mir.*

fn marker_codegen_score() -> i64:
    var codegen = Codegen.new(CodegenTarget.Native, CodegenMode.Jit)
    codegen.compile_inst(MirInst(
        kind: MirInstKind.HostGpuLaneBegin("gpu", Some(MirOperand.const_int(512))),
        span: nil
    ))
    codegen.compile_inst(MirInst(kind: MirInstKind.Nop, span: nil))
    codegen.compile_inst(MirInst(kind: MirInstKind.HostGpuLaneEnd("gpu"), span: nil))

    var score = 0
    if codegen.errors.len() == 0:
        score = score + 1
    if codegen.host_gpu_lane_depth == 0:
        score = score + 10
    if codegen.host_gpu_lane_packet_count == 1:
        score = score + 100
    if codegen.host_gpu_lane_body_inst_count == 1:
        score = score + 1000
    if codegen.host_gpu_lane_payload_bytes == 64:
        score = score + 10000
    if codegen.host_gpu_lane_max_packet_bytes == 512:
        score = score + 100000
    if codegen.host_gpu_lane_last_lane == "gpu":
        score = score + 1000000
    score

fn unmatched_end_error_count() -> i64:
    var codegen = Codegen.new(CodegenTarget.Native, CodegenMode.Jit)
    codegen.compile_inst(MirInst(kind: MirInstKind.HostGpuLaneEnd("gpu"), span: nil))
    codegen.errors.len()

describe "Host/GPU lane native codegen markers", tag: ["only-compiled"]:
    it "consumes lane markers as queue-boundary accounting instead of unsupported instructions":
        expect(marker_codegen_score()).to_equal(1111111)

    it "diagnoses an unmatched host GPU lane end marker":
        expect(unmatched_end_error_count()).to_equal(1)
