# Native regression for the canonical pure-Simple CUDA source emitter.

use compiler.backend.gpu_portable_compute.{PortableComputeTarget, emit_portable_2d_optimization_module, emit_portable_font_atlas_composite_kernel, portable_compute_artifact_source_hash, portable_compute_artifact_version_hash}

fn main() -> i64:
    print_raw("phase=module\n")
    val artifact = emit_portable_2d_optimization_module(PortableComputeTarget.Cuda)
    print_raw("module_bytes={artifact.source.len()}\n")
    val font = emit_portable_font_atlas_composite_kernel(PortableComputeTarget.Cuda)
    print_raw("font_bytes={font.source.len()}\n")
    val source_hash = portable_compute_artifact_source_hash(artifact)
    print_raw("source_hash_bytes={source_hash.len()}\n")
    val version_hash = portable_compute_artifact_version_hash(artifact)
    print_raw("version_hash_bytes={version_hash.len()}\n")
    val font_source_hash = portable_compute_artifact_source_hash(font)
    print_raw("font_source_hash_bytes={font_source_hash.len()}\n")
    val font_version_hash = portable_compute_artifact_version_hash(font)
    print_raw("font_version_hash_bytes={font_version_hash.len()}\n")
    if artifact.source.len() == 0 or font.source.len() == 0:
        return 1
    if source_hash.len() != 64 or version_hash.len() != 64 or font_source_hash.len() != 64 or font_version_hash.len() != 64:
        return 2
    0
