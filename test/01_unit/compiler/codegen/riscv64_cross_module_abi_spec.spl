# RISC-V 64-bit Cross-Module ABI Codegen Spec
#
# Documents and pins arch-sensitive codegen behaviors for the riscv64gc target
# (LP64D ABI, 8 argument registers, 16-byte stack alignment).
#
# Arch-sensitive behaviors covered:
#   1. Pointer width: riscv64 is LP64 (pointer_bits=64), unlike riscv32 (ILP32).
#      A cross-module global load for a pointer-typed val must widen to 64 bits.
#   2. ABI: LP64D (lp64d abi, rv64gc march, +d extension for double-precision).
#      Argument registers a0-a7 (8 total); return in a0/a1.
#      This differs from rv32 (ILP32D, 4-byte pointer, same arg register count).
#   3. Cross-module function calls: import resolution must produce the correct
#      64-bit mangled symbol so the linker resolves to the right .o section.
#      (Same class of bug as native_cross_module_abi_spec, but on rv64 target.)
#   4. Module-level val constants: On riscv64-linux (non-baremetal), BSS is
#      initialised by the OS ELF loader, so module-level val constants are NOT
#      subject to the baremetal_module_val_zero bug. This spec pins that
#      the riscv64-linux preset is NOT a baremetal preset.
#
# Reference bugs:
#   - native_cross_module_abi_spec.spl — x86_64 cross-module ABI regression
#   - baremetal_cross_module_val_spec.spl — x86_64 baremetal data-export bug
#   - doc/08_tracking/bug/baremetal_module_val_zero_bss_2026-05-20.md (FIXED)
#
# This spec is documentation-level (hosted tests cannot easily spawn an rv64
# cross-compile). The contract facts are pinned here so regressions in
# target_presets.spl or riscv_target.spl are immediately visible.
# When the cross-compile test harness is unified with test/unit, this spec
# can be expanded to compile and nm-verify actual rv64 object files.

use compiler.backend.target_presets.{
    preset_riscv64_linux,
    preset_riscv32_baremetal,
    preset_is_baremetal
}
use compiler.backend.backend.riscv_target.{
    riscv_linux_target_contract
}
use compiler.backend.backend.backend_types.{CodegenTarget}

# ============================================================================
# RV64 LP64D ABI contracts
# ============================================================================

describe "riscv64 cross-module ABI contracts":

    context "pointer width — LP64 vs ILP32":
        it "riscv64-linux preset has 64-bit pointers":
            val preset = preset_riscv64_linux()
            expect(preset.pointer_width).to_equal(64)

        it "riscv32-baremetal preset has 32-bit pointers":
            # Contrast: cross-module pointer loads on rv32 must NOT be widened
            # to 64 bits or the value is corrupted.
            val preset = preset_riscv32_baremetal()
            expect(preset.pointer_width).to_equal(32)

        it "riscv64 and riscv32 pointer widths differ":
            val rv64 = preset_riscv64_linux()
            val rv32 = preset_riscv32_baremetal()
            expect(rv64.pointer_width).to_not_equal(rv32.pointer_width)

    context "ABI — LP64D":
        it "riscv64-linux preset ABI is lp64d":
            val preset = preset_riscv64_linux()
            expect(preset.abi).to_equal("lp64d")

        it "riscv64 contract pointer_bits is 64":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            expect(contract.pointer_bits).to_equal(64)

        it "riscv64 contract has 8 argument registers (a0-a7)":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            expect(contract.arg_register_count).to_equal(8)

        it "riscv64 contract stack alignment is 16 bytes":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            expect(contract.stack_align_bytes).to_equal(16)

        it "riscv64 ABI text is lp64d or lp64":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            val abi = contract.abi_text()
            val is_lp64d = abi == "lp64d"
            val is_lp64 = abi == "lp64"
            expect(is_lp64d or is_lp64).to_equal(true)

    context "architecture triple":
        it "riscv64-linux triple starts with riscv64":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            val triple = contract.triple()
            expect(triple.starts_with("riscv64")).to_equal(true)

        it "riscv64-linux triple contains linux":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            val triple = contract.triple()
            expect(triple.contains("linux")).to_equal(true)

    context "module-level val safety (non-baremetal)":
        it "riscv64-linux is NOT a baremetal preset":
            # baremetal_module_val_zero bug only affects --target *-unknown-none.
            # riscv64-linux is an OS-hosted target: ELF loader initialises BSS,
            # so module-level val constants are NOT zero at startup.
            val preset = preset_riscv64_linux()
            expect(preset_is_baremetal(preset)).to_equal(false)

        it "riscv64-linux has no_std=false":
            val preset = preset_riscv64_linux()
            expect(preset.no_std).to_equal(false)

        it "riscv64-linux has float support":
            val preset = preset_riscv64_linux()
            expect(preset.float_support).to_equal(true)

    context "cross-module symbol mangling":
        it "riscv64 contract arch field is riscv64":
            # The arch field drives the triple component used in mangled symbol
            # names for rv64 cross-module imports. Must be "riscv64" (not "rv64"
            # or "riscv64gc") so linker symbol resolution is deterministic.
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            expect(contract.arch).to_equal("riscv64")

        it "riscv64 contract os field is linux":
            val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
            expect(contract.os).to_equal("linux")
