use compiler.backend.linker.smf_header.{SmfHeader}
use compiler.backend.linker.smf_enums.{Platform, Arch}
use compiler.driver.cache.cache_validator.{read_smf_source_hash}
use std.io_runtime.{file_write_bytes, file_delete, getpid}

describe "SMF cache validator header layout":
    it "reads source_hash from the canonical SMF header offset":
        var header = SmfHeader.new_v1_1(Platform.Linux, Arch.X86_64)
        header.module_hash = 456
        header.source_hash = 123456789
        header.window_width = 321
        header.window_height = 654
        val path = "/tmp/simple_cache_validator_smf_header_{getpid()}.smf"
        expect(file_write_bytes(path, header.to_bytes())).to_equal(true)
        expect(read_smf_source_hash(path)).to_equal(123456789)
        expect(file_delete(path)).to_equal(true)
