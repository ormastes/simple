use std.io_runtime.{file_write_bytes, file_read_bytes, file_delete}
use compiler.backend.linker.lib_smf.{ModuleIndexEntry, fnv1a_hash}

describe "file byte alias":
    it "round-trips high-bit u8 bytes through std.io_runtime":
        val path = "/tmp/simple_file_byte_alias_spec.bin"
        file_write_bytes(path, [0x86, 0xF2, 0xF9, 0xAF])
        val bytes = file_read_bytes(path)
        expect(bytes.len()).to_equal(4)
        expect(bytes[0]).to_equal(0x86)
        expect(bytes[1]).to_equal(0xF2)
        expect(bytes[2]).to_equal(0xF9)
        expect(bytes[3]).to_equal(0xAF)
        file_delete(path)

    it "round-trips serialized SMF index entries through std.io_runtime":
        val path = "/tmp/simple_file_byte_alias_index_spec.bin"
        val hash = fnv1a_hash([0xC3])
        val entry = ModuleIndexEntry.new("drivers/ahci", 256, 1, hash)
        val entry_bytes = entry.to_bytes()
        file_write_bytes(path, entry_bytes)
        val bytes = file_read_bytes(path)
        expect(bytes).to_equal(entry_bytes)
        val restored = ModuleIndexEntry.from_bytes(bytes, 0).unwrap()
        expect(restored.hash).to_equal(hash)
        file_delete(path)
