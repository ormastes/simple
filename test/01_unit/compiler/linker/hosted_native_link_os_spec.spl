extern fn rt_file_read_text(path: text) -> text

use compiler.backend.linker.linker_wrapper.{hosted_native_link_os_supported, hosted_native_link_unsupported_error}

describe "hosted native-link OS gate":
    it "accepts only implemented hosted link families":
        expect(hosted_native_link_os_supported("linux")).to_equal(true)
        expect(hosted_native_link_os_supported("macos")).to_equal(true)
        expect(hosted_native_link_os_supported("darwin")).to_equal(true)
        expect(hosted_native_link_os_supported("windows")).to_equal(true)
        expect(hosted_native_link_os_supported("freebsd")).to_equal(true)
        expect(hosted_native_link_os_supported("openbsd")).to_equal(false)
        expect(hosted_native_link_os_supported("netbsd")).to_equal(false)

    it "keeps unsupported-host diagnostics actionable":
        expect(hosted_native_link_unsupported_error("openbsd")).to_equal("Native linking is unsupported on host OS 'openbsd'")

    it "rejects unsupported hosts before SMF bundle dispatch":
        val source = rt_file_read_text("src/compiler/70.backend/linker/_LinkerWrapper/native_linking.spl") ?? ""
        val gate_pos = source.index_of("if not hosted_native_link_os_supported(os):") ?? -1
        val smf_pos = source.index_of("val smf_inputs = filter_smf_inputs(object_files)") ?? -1

        expect(gate_pos).to_be_greater_than(-1)
        expect(smf_pos).to_be_greater_than(-1)
        expect(gate_pos).to_be_less_than(smf_pos)
