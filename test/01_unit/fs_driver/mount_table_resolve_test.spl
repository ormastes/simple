# @cover src/lib/nogc_sync_mut/fs_driver/mount_table.spl 80%
"""
# MountTable.resolve() Tests — FR-STORAGE-0004

**Feature IDs:** #FS-DRIVER-MOUNT-RESOLVE
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** In Progress
**Design:** doc/05_design/fs_driver_interface.md §3, §8

## Overview

Tests for MountTable.resolve() after FR-STORAGE-0004 fix.

The fix replaces `path.raw.slice(mp_len, …)` with an indexed char-copy loop
(using str_char_at) so baremetal Cranelift codegen is not hit by the broken
slice() path.

## Design notes: relpath semantics

  resolve("/") with "/" mounted → relpath ""  (empty: nothing after the mount point)
  resolve("/foo") with "/" mounted → relpath "foo"  (slash is the separator, stripped)
  resolve("/mnt/data/file.txt") with "/mnt/data" mounted → relpath "file.txt"
  resolve("/nonexistent") with no matching mount → Err(FsError.NotFound)
"""

use std.spipe.*
use std.fs_driver.mount_table.{MountTable, MountId}
use std.fs_driver.types.{Path, MountOptions}
use std.fs_driver.instance.{DriverInstance, RamFsStub}
use std.fs_driver.error.{FsError}


fn make_driver() -> DriverInstance:
    DriverInstance.RamFs(driver: RamFsStub(name: "test_ramfs"))

fn make_opts() -> MountOptions:
    MountOptions.default()


# ============================================================================
# resolve() — basic cases after FR-STORAGE-0004 fix
# ============================================================================

describe "MountTable.resolve() — FR-STORAGE-0004 fix":
    """
    ## resolve() correctness

    These tests verify that MountTable.resolve() works correctly after replacing
    slice() with indexed char-copy (FR-STORAGE-0004). All four cases must pass
    on both host and baremetal targets.
    """

    it "resolve('/') with root mounted returns relpath ''":
        # mount point == path → strip entire prefix → empty relpath
        var mt = MountTable.new()
        mt.mount("/", make_driver(), make_opts())
        val r = mt.resolve(Path(raw: "/"))
        expect(r.is_ok()).to_equal(true)
        val pair = r.unwrap()
        val rel = pair.relpath
        # relpath is "" because the mount point consumes the entire path
        expect(rel.raw).to_equal("")

    it "resolve('/foo') with '/' mounted returns relpath 'foo'":
        # '/' mount point length is 1; path is '/foo' (4 chars) → drop 1 → 'foo'
        var mt = MountTable.new()
        mt.mount("/", make_driver(), make_opts())
        val r = mt.resolve(Path(raw: "/foo"))
        expect(r.is_ok()).to_equal(true)
        val pair = r.unwrap()
        val rel = pair.relpath
        expect(rel.raw).to_equal("foo")

    it "resolve('/mnt/data/file.txt') with '/mnt/data' mounted returns relpath 'file.txt'":
        var mt = MountTable.new()
        mt.mount("/mnt/data", make_driver(), make_opts())
        val r = mt.resolve(Path(raw: "/mnt/data/file.txt"))
        expect(r.is_ok()).to_equal(true)
        val pair = r.unwrap()
        val rel = pair.relpath
        expect(rel.raw).to_equal("file.txt")

    it "resolve('/nonexistent') with no matching mount returns Err(NotFound)":
        # empty table → no prefix match → NotFound
        val mt = MountTable.new()
        val r = mt.resolve(Path(raw: "/nonexistent"))
        expect(r.is_err()).to_equal(true)
        match r.unwrap_err():
            case NotFound: expect(true).to_equal(true)
            case _:        expect(false).to_equal(true)

    it "resolve('/mnt/data/file.txt') with both '/' and '/mnt/data' mounted picks longest prefix":
        # longest-prefix match: '/mnt/data' (9) beats '/' (1)
        # relpath after '/mnt/data' → 'file.txt'
        var mt = MountTable.new()
        val d1 = DriverInstance.RamFs(driver: RamFsStub(name: "rootfs"))
        val d2 = DriverInstance.RamFs(driver: RamFsStub(name: "datavol"))
        mt.mount("/", d1, make_opts())
        mt.mount("/mnt/data", d2, make_opts())
        val r = mt.resolve(Path(raw: "/mnt/data/file.txt"))
        expect(r.is_ok()).to_equal(true)
        val pair = r.unwrap()
        val mid = pair.mount_id
        val rel = pair.relpath
        # id=2 is the /mnt/data mount (mounted second)
        expect(mid.id).to_equal(2)
        expect(rel.raw).to_equal("file.txt")

    it "resolve('/mnt/database/file.txt') does not match sibling /mnt/data mount":
        var mt = MountTable.new()
        val d1 = DriverInstance.RamFs(driver: RamFsStub(name: "rootfs"))
        val d2 = DriverInstance.RamFs(driver: RamFsStub(name: "datavol"))
        mt.mount("/", d1, make_opts())
        mt.mount("/mnt/data", d2, make_opts())
        val r = mt.resolve(Path(raw: "/mnt/database/file.txt"))
        expect(r.is_ok()).to_equal(true)
        val pair = r.unwrap()
        expect(pair.mount_id.id).to_equal(1)
        expect(pair.relpath.raw).to_equal("mnt/database/file.txt")
