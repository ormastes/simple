use std.nogc_async_mut.ndarray.{array, Axis, Index, Shape}

describe "NDArray view bounds hardening":
    it "keeps the original array for invalid public reshape":
        val values = array([1.0, 2.0, 3.0])
        val reshaped = values.reshape(Shape.new([Index.new(2), Index.new(2)]))
        expect(reshaped.shape).to_equal(values.shape)
        expect(reshaped.len().value).to_equal(3)

    it "keeps the original array for invalid public transpose axes":
        val values = array([1.0, 2.0])
        val transposed = values.transpose_axes(Axis.new(0), Axis.new(1))
        expect(transposed.shape).to_equal(values.shape)
        expect(transposed.len().value).to_equal(2)

    it "returns empty row for out-of-range row index":
        val matrix = array([1.0, 2.0, 3.0, 4.0]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val row = matrix.row(Index.new(9))
        expect(row.len().value).to_equal(0)
        expect(row.to_f64_values().len()).to_equal(0)

    it "returns empty column for out-of-range column index":
        val matrix = array([1.0, 2.0, 3.0, 4.0]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val col = matrix.column(Index.new(9))
        expect(col.len().value).to_equal(0)
        expect(col.to_f64_values().len()).to_equal(0)
