use std.nogc_async_mut.thread_pool.{task_spawn}

extern fn rt_exit(code: i32)

fn lcg_work(seed: i64) -> i64:
    var x = seed + 1
    for i in 0..10000:
        x = (x * 1103515245 + 12345) % 2147483648
    x

describe "Runtime pool task_spawn":
    it "joins multiple pool-backed tasks":
        val h0 = task_spawn(\: lcg_work(0))
        val h1 = task_spawn(\: lcg_work(1))
        val h2 = task_spawn(\: lcg_work(2))
        val h3 = task_spawn(\: lcg_work(3))

        val got = h0.join() + h1.join() + h2.join() + h3.join()
        val expected = lcg_work(0) + lcg_work(1) + lcg_work(2) + lcg_work(3)

        if got != expected:
            rt_exit(31)
