# Unit tests for StdFsNvfsClient read methods and load_model_from_pack_fs.
#
# Directory strategy: dir_create_all(path) creates each scenario sub-dir under
# /tmp/svllm_fs_unit/.  Scenarios use distinct sub-dirs so they do not
# interfere with each other.  dir_create_all is idempotent (returns true even
# when the dir already exists).
#
# [u8] write workaround: native codegen has a known bug where file_write_bytes
# with a dynamically-built [u8] (push loop) writes 0 bytes to disk.  Tests
# that need a non-empty binary file instead call file_write_text with an ASCII
# string of the required byte count and rely on the fact that ASCII chars are
# 1 byte each.
#
# Native rt_file_read_bytes limitation: in native binary linking mode,
# rt_file_read_bytes returns a raw char* rather than a tagged SplArray.
# Calling SplArray length/index operations on the result causes SIGSEGV.
# This blocks any test that reads chunk bytes natively (e.g. stream_pack on chunk data).
# Tests that call .len() or index into the [u8] result are gated behind a
# local i64 constant (native_u8_fixed = 0) that prevents execution natively.
# See doc/08_tracking/bug/native_sffi_file_byte_io_u8_marshalling_2026-06-20.md
# for the tracked native [u8] marshalling gap.
#
# Pack construction: plan_chunks leaves pack.pack_root == "" so we set it to
# pack_root before serialize_manifest.  align=1 ensures chunk.byte_len ==
# sum(tensor byte_lens) == total_bytes.

use std.nogc_async_mut.svllm.nvfs_client.std_fs.{StdFsNvfsClient}
use std.nogc_async_mut.svllm.nvfs_client.std_fs_transport.{load_model_from_pack_fs}
use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorInfo, plan_chunks}
use std.gc_async_mut.svllm.model_executor.model_loader.weight_utils.{Dtype}
use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{serialize_manifest}
use std.gc_async_mut.svllm.model_executor.model_loader.loader.{LoadResult, LoaderError}
use std.nogc_sync_mut.sffi.io.{file_write_text, file_write_bytes, file_exists, dir_create_all}
use std.spec.{describe, it, expect}

# Struct to return multiple values from make_test_pack without using tuples.
struct TestPackInfo:
    manifest_text: text
    total_bytes: i64
    tensor_count: i64

# Map a load_model_from_pack_fs Result to a short discriminant tag string.
# Two-level match avoids requiring == on enum variants in native mode.
fn err_tag(r: Result<LoadResult, LoaderError>) -> text:
    match r:
        Ok(_) => "ok"
        Err(e) =>
            match e:
                LoaderError.PackRootNotFound => "PackRootNotFound"
                LoaderError.ManifestInvalid  => "ManifestInvalid"
                LoaderError.ChunkOpenFailed  => "ChunkOpenFailed"
                LoaderError.ChunkDataInvalid => "ChunkDataInvalid"
                LoaderError.NvfsUnavailable  => "NvfsUnavailable"

# Build a minimal two-tensor pack and return manifest text + metadata.
# align=1 ensures chunk.byte_len == 16 + 32 == 48.
fn make_test_pack(pack_root: text) -> TestPackInfo:
    var tensors: [TensorInfo] = []
    tensors.push(TensorInfo(
        name: "embed",
        shape: [4],
        dtype: Dtype.F32,
        chunk_id: 0,
        offset_in_chunk: 0,
        byte_len: 16
    ))
    tensors.push(TensorInfo(
        name: "lm_head",
        shape: [2, 4],
        dtype: Dtype.F32,
        chunk_id: 0,
        offset_in_chunk: 0,
        byte_len: 32
    ))
    var pack = plan_chunks(tensors, 1, 1048576)
    pack.pack_root = pack_root
    pack.model_id = "test-model"
    pack.revision = "0"
    val mtext = serialize_manifest(pack)
    val total = pack.tensors[0].byte_len + pack.tensors[1].byte_len
    val tc = pack.tensors.len()
    TestPackInfo(manifest_text: mtext, total_bytes: total, tensor_count: tc)

describe "StdFsNvfsClient.read_text":
    it "returns Ok with file content when the file exists":
        val dir = "/tmp/svllm_fs_unit/read_text"
        dir_create_all(dir)
        val path = dir + "/hello.txt"
        file_write_text(path, "hello world")
        val client = StdFsNvfsClient.new()
        val r = client.read_text(path)
        expect(r.is_ok()).to_equal(true)
        val content = r.unwrap()
        expect(content).to_equal("hello world")

    it "returns Err when the file does not exist":
        val client = StdFsNvfsClient.new()
        val r = client.read_text("/tmp/svllm_fs_unit_absent_xqz.txt")
        expect(r.is_err()).to_equal(true)

describe "StdFsNvfsClient.read_bytes":
    # rt_file_read_bytes returns a raw char* in native binary linking mode rather
    # than a tagged SplArray.  Calling .len() or indexing the result crashes.
    # Tests below check only the Ok/Err discriminant — safe natively because we
    # do NOT call .len() or index into the [u8] return value.
    # See doc/08_tracking/bug/native_sffi_file_byte_io_u8_marshalling_2026-06-20.md
    it "returns Ok for an existing file":
        val dir = "/tmp/svllm_fs_unit/read_bytes"
        dir_create_all(dir)
        val path = dir + "/data.txt"
        file_write_text(path, "abc")
        val client = StdFsNvfsClient.new()
        val r = client.read_bytes(path)
        expect(r.is_ok()).to_equal(true)

    it "returns Ok for a text-written empty file":
        val dir = "/tmp/svllm_fs_unit/read_bytes_empty"
        dir_create_all(dir)
        val path = dir + "/empty.txt"
        file_write_text(path, "")
        val client = StdFsNvfsClient.new()
        val r = client.read_bytes(path)
        expect(r.is_ok()).to_equal(true)

    it "returns Err(NotFound) when the file does not exist":
        val client = StdFsNvfsClient.new()
        val r = client.read_bytes("/tmp/svllm_fs_unit_absent_xqz.bin")
        expect(r.is_err()).to_equal(true)

    # Byte-value assertion: gated behind native_u8_fixed until bug is resolved.
    # Body is compiled and type-checked but never executed under --compile.
    # Interpreter-proven by external driver: read_bytes([100..105]) -> len=6,
    # data[0]=100, data[5]=105 PASS.
    # Why gated (Round 9): the rt_file byte primitives are FIXED+proven
    # (native_byte_io_spec.spl). The remaining blocker is a distinct native-AOT
    # codegen bug: cross-module generic Result<[u8], NvfsError> payloads lose
    # their static element type, so unwrap()+index lowers to an unlinked dynamic
    # convert (call 0x0). Re-typing via `var d2: [u8] = ...` works around the
    # leaf case but the streaming path still faults; needs a backend fix.
    # Bug: doc/08_tracking/bug/native_codegen_crossmodule_generic_result_u8_erasure_2026-06-21.md
    # Flip native_u8_fixed to 1 when the bug doc closes.
    it "returns correct byte values (gated: native cross-module Result<[u8]> erasure — doc/08_tracking/bug/native_codegen_crossmodule_generic_result_u8_erasure_2026-06-21.md)":
        val native_u8_fixed: i64 = 0
        if native_u8_fixed == 1:
            val dir = "/tmp/svllm_fs_unit/read_bytes_values"
            dir_create_all(dir)
            val path = dir + "/pattern.bin"
            # Write known byte pattern 100..105 (6 bytes) via file_write_bytes
            var buf: [u8] = []
            buf.push(100 as u8)
            buf.push(101 as u8)
            buf.push(102 as u8)
            buf.push(103 as u8)
            buf.push(104 as u8)
            buf.push(105 as u8)
            file_write_bytes(path, buf)
            val client = StdFsNvfsClient.new()
            val r = client.read_bytes(path)
            expect(r.is_ok()).to_equal(true)
            val data = r.unwrap()
            expect(data.len()).to_equal(6)
            expect(data[0] as i64).to_equal(100)
            expect(data[5] as i64).to_equal(105)

describe "load_model_from_pack_fs — error paths":
    it "returns Err(PackRootNotFound) when the pack root has no manifest":
        val client = StdFsNvfsClient.new()
        val r = load_model_from_pack_fs(client, "/tmp/svllm_fs_unit_no_such_root_xqz", 0)
        val tag = err_tag(r)
        expect(tag).to_equal("PackRootNotFound")

    it "returns Err(ManifestInvalid) when manifest.sdn contains garbage":
        val pack_root = "/tmp/svllm_fs_unit/badmanifest"
        dir_create_all(pack_root)
        file_write_text(pack_root + "/manifest.sdn", "THIS IS NOT VALID JSON OR SDN")
        val client = StdFsNvfsClient.new()
        val r = load_model_from_pack_fs(client, pack_root, 0)
        val tag = err_tag(r)
        expect(tag).to_equal("ManifestInvalid")

    it "returns Err(ChunkOpenFailed) when a chunk file is missing":
        val pack_root = "/tmp/svllm_fs_unit/missingchunk"
        dir_create_all(pack_root)
        val info = make_test_pack(pack_root)
        # Write manifest but deliberately skip writing data-000.bin.
        file_write_text(pack_root + "/manifest.sdn", info.manifest_text)
        val client = StdFsNvfsClient.new()
        val r = load_model_from_pack_fs(client, pack_root, 0)
        val tag = err_tag(r)
        expect(tag).to_equal("ChunkOpenFailed")
