use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_uses_global_fifo_queue, multicore_green_uses_work_stealing}

extern fn rt_exit(code: i32)

fn multicore_green_lcg_native(seed: i64) -> i64:
    var x = seed + 1
    for i in 0..10000:
        x = (x * 1103515245 + 12345) % 2147483648
    x

fn main() -> i64:
    if multicore_green_uses_global_fifo_queue():
        rt_exit(35)
    if !multicore_green_uses_work_stealing():
        rt_exit(36)

    val h0 = multicore_green_spawn(\: multicore_green_lcg_native(0))
    val h1 = multicore_green_spawn(\: multicore_green_lcg_native(1))
    val h2 = multicore_green_spawn(\: multicore_green_lcg_native(2))
    val h3 = multicore_green_spawn(\: multicore_green_lcg_native(3))

    if !h0.used_runtime_pool() or !h1.used_runtime_pool() or !h2.used_runtime_pool() or !h3.used_runtime_pool():
        rt_exit(34)

    val got = h0.join() + h1.join() + h2.join() + h3.join()
    val expected = multicore_green_lcg_native(0) + multicore_green_lcg_native(1) + multicore_green_lcg_native(2) + multicore_green_lcg_native(3)
    if got != expected:
        rt_exit(33)
    0
