use std.spec
use std.nogc_async_mut.sanitizer.lsan.mod.{lsan_is_enabled, lsan_check_since, lsan_bytes_since, lsan_suppress_tag, lsan_is_suppressed, lsan_error_count, lsan_reset}
use std.nogc_async_mut.sanitizer.lsan.types.{leak_checkpoint}

describe "nogc_async_mut sanitizer lsan facade":

    it "re-exports leak sanitizer disabled-state checks and records":
        lsan_reset()
        expect(lsan_is_enabled()).to_equal(false)
        expect(lsan_check_since("missing")).to_equal(0)
        expect(lsan_bytes_since("missing")).to_equal(0)
        expect(lsan_error_count()).to_equal(0)

        val checkpoint = leak_checkpoint("before", 7)
        expect(checkpoint.name).to_equal("before")

    it "re-exports suppression tags":
        lsan_reset()
        expect(lsan_is_suppressed("fixture")).to_equal(false)
        lsan_suppress_tag("fixture")
        expect(lsan_is_suppressed("fixture")).to_equal(true)
