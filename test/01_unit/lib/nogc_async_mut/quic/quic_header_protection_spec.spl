"""QUIC AES header-protection mask spec (RFC 9001 §5.4.3 + Appendix A.2).

quic_header_protect_mask is wired to the pure-Simple AES-128 block cipher
(AES-ECB of one block). Asserts the canonical RFC 9001 §A.2 Client Initial
header-protection vector: AES-ECB(hp, sample)[0..4] == 437b9aec36.
"""

use std.io.quic.quic_crypto.{quic_header_protect_mask}

fn _hp_key() -> [i64]:
    [0x9f, 0x50, 0x44, 0x9e, 0x04, 0xa0, 0xe8, 0x10,
     0x28, 0x3a, 0x1e, 0x99, 0x33, 0xad, 0xed, 0xd2]

fn _sample() -> [u8]:
    [0xd1u8, 0xb1u8, 0xc9u8, 0x8du8, 0xd7u8, 0x68u8, 0x9fu8, 0xb8u8,
     0xecu8, 0x11u8, 0xd2u8, 0x42u8, 0xb1u8, 0x23u8, 0xdcu8, 0x9bu8]

fn _mask_byte(i: i64) -> i64:
    val mask = quic_header_protect_mask(_hp_key(), _sample())
    mask[i].to_i64()

fn _mask_len() -> i64:
    quic_header_protect_mask(_hp_key(), _sample()).len()

describe "QUIC AES header protection (RFC 9001 §A.2)":

    it "produces a 5-byte mask":
        expect(_mask_len()).to_equal(5)

    it "mask[0] = 0x43":
        expect(_mask_byte(0)).to_equal(0x43)

    it "mask[1] = 0x7b":
        expect(_mask_byte(1)).to_equal(0x7b)

    it "mask[2] = 0x9a":
        expect(_mask_byte(2)).to_equal(0x9a)

    it "mask[3] = 0xec":
        expect(_mask_byte(3)).to_equal(0xec)

    it "mask[4] = 0x36":
        expect(_mask_byte(4)).to_equal(0x36)
