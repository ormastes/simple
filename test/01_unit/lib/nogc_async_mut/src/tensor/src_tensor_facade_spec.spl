use std.spec
use std.nogc_async_mut.src.tensor.factory.{zeros, ones, full, randn, rand, eye, arange, linspace, logspace, empty, zeros_tr, ones_tr, randn_tr, rand_tr, zeros_gpu, ones_gpu, randn_gpu, zeros_cpu, ones_cpu, randn_cpu, tensor, tensor_like, zeros_like, ones_like, randn_like, empty_like}

describe "nogc_async_mut src tensor facade":

    it "re-exports tensor factory API names":
        val factories = [
            "zeros", "ones", "full", "randn", "rand", "eye", "arange", "linspace", "logspace", "empty",
            "zeros_tr", "ones_tr", "randn_tr", "rand_tr",
            "zeros_gpu", "ones_gpu", "randn_gpu", "zeros_cpu", "ones_cpu", "randn_cpu",
            "tensor", "tensor_like", "zeros_like", "ones_like", "randn_like", "empty_like"
        ]
        expect(factories.length()).to_equal(26)
        expect(factories[0]).to_equal("zeros")
        expect(factories[25]).to_equal("empty_like")
