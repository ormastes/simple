# @cover src/lib/nogc_async_mut/compute/compute_algo_ext.spl
use std.spec.*
use std.nogc_async_mut.compute.compute_algo_ext.{compute_min_element, compute_max_element, compute_transform_reduce, compute_unique, compute_lower_bound, compute_binary_search, compute_exclusive_scan}
use std.nogc_async_mut.compute.exec_target.{DeviceClass, ComputeBackend, EnforceMode, BackendCaps, ExecTarget, resolve_exec_target}

fn less_i64(a: i64, b: i64) -> bool:
    a < b

fn add_i64(a: i64, b: i64) -> i64:
    a + b

fn dbl_i64(a: i64) -> i64:
    a * 2

fn cpu_target() -> ExecTarget:
    resolve_exec_target(DeviceClass.Cpu, ComputeBackend.NoneBackend, EnforceMode.Suggest, BackendCaps.none())

describe "compute_algo_ext":

    it "min_element returns index of minimum":
        val t = cpu_target()
        val data = [5, 2, 8, 1, 9]
        expect(compute_min_element(data, less_i64, t)).to_equal(3)

    it "min_element returns -1 on empty":
        val t = cpu_target()
        val data: [i64] = []
        expect(compute_min_element(data, less_i64, t)).to_equal(-1)

    it "max_element returns index of maximum":
        val t = cpu_target()
        val data = [5, 2, 8, 1, 9]
        expect(compute_max_element(data, less_i64, t)).to_equal(4)

    it "max_element returns -1 on empty":
        val t = cpu_target()
        val data: [i64] = []
        expect(compute_max_element(data, less_i64, t)).to_equal(-1)

    it "transform_reduce doubles then sums":
        val t = cpu_target()
        val data = [1, 2, 3, 4]
        # (2+4+6+8) + init 0 = 20
        expect(compute_transform_reduce(data, dbl_i64, 0, add_i64, t)).to_equal(20)

    it "transform_reduce on empty returns init":
        val t = cpu_target()
        val data: [i64] = []
        expect(compute_transform_reduce(data, dbl_i64, 7, add_i64, t)).to_equal(7)

    it "unique removes consecutive duplicates":
        val t = cpu_target()
        val data = [1, 1, 2, 3, 3, 3, 1]
        val out = compute_unique(data, less_i64, t)
        expect(out.len()).to_equal(4)
        expect(out[0]).to_equal(1)
        expect(out[1]).to_equal(2)
        expect(out[2]).to_equal(3)
        expect(out[3]).to_equal(1)

    it "unique on empty returns empty":
        val t = cpu_target()
        val data: [i64] = []
        val out = compute_unique(data, less_i64, t)
        expect(out.len()).to_equal(0)

    it "lower_bound finds first not-less index":
        val t = cpu_target()
        val data = [1, 3, 5, 7]
        expect(compute_lower_bound(data, 5, less_i64, t)).to_equal(2)

    it "lower_bound of missing low key is 0":
        val t = cpu_target()
        val data = [1, 3, 5, 7]
        expect(compute_lower_bound(data, 0, less_i64, t)).to_equal(0)

    it "lower_bound of key above all is len":
        val t = cpu_target()
        val data = [1, 3, 5, 7]
        expect(compute_lower_bound(data, 9, less_i64, t)).to_equal(4)

    it "binary_search hit":
        val t = cpu_target()
        val data = [1, 3, 5, 7]
        expect(compute_binary_search(data, 5, less_i64, t)).to_equal(true)

    it "binary_search miss":
        val t = cpu_target()
        val data = [1, 3, 5, 7]
        expect(compute_binary_search(data, 4, less_i64, t)).to_equal(false)

    it "binary_search on empty is false":
        val t = cpu_target()
        val data: [i64] = []
        expect(compute_binary_search(data, 1, less_i64, t)).to_equal(false)

    it "exclusive_scan prefixes from init":
        val t = cpu_target()
        val data = [1, 2, 3, 4]
        val out = compute_exclusive_scan(data, 0, add_i64, t)
        expect(out.len()).to_equal(4)
        expect(out[0]).to_equal(0)
        expect(out[1]).to_equal(1)
        expect(out[2]).to_equal(3)
        expect(out[3]).to_equal(6)

    it "exclusive_scan on empty returns empty":
        val t = cpu_target()
        val data: [i64] = []
        val out = compute_exclusive_scan(data, 5, add_i64, t)
        expect(out.len()).to_equal(0)
