# @cover src/lib/nogc_async_mut/compute/containers.spl
use std.spec.*
use std.nogc_async_mut.compute.containers.{Span, FixedArray, InplaceVector}

describe "compute containers":

    it "Span.of views a whole array":
        val s = Span.of([10, 20, 30, 40])
        expect(s.len()).to_equal(4)
        expect(s.get(0)).to_equal(10)
        expect(s.get(2)).to_equal(30)
        expect(s.first()).to_equal(10)
        expect(s.last()).to_equal(40)
        expect(s.is_empty()).to_be(false)

    it "Span.slice respects start offset":
        val s = Span.slice([10, 20, 30, 40, 50], 1, 3)
        expect(s.len()).to_equal(3)
        expect(s.get(0)).to_equal(20)
        expect(s.last()).to_equal(40)

    it "empty Span reports is_empty":
        val empty: [i64] = []
        val s = Span.of(empty)
        expect(s.len()).to_equal(0)
        expect(s.is_empty()).to_be(true)

    it "FixedArray.filled creates n copies":
        var a = FixedArray.filled(7, 4)
        expect(a.len()).to_equal(4)
        expect(a.get(0)).to_equal(7)
        expect(a.get(3)).to_equal(7)

    it "FixedArray.set mutates a slot":
        var a = FixedArray.filled(0, 3)
        a.set(1, 99)
        expect(a.get(1)).to_equal(99)
        expect(a.get(0)).to_equal(0)

    it "InplaceVector pushes up to capacity":
        var v = InplaceVector.with_cap(0, 3)
        expect(v.len()).to_equal(0)
        val a = v.push(10)
        val b = v.push(20)
        expect(a).to_be(true)
        expect(b).to_be(true)
        expect(v.len()).to_equal(2)
        expect(v.get(0)).to_equal(10)
        expect(v.get(1)).to_equal(20)

    it "InplaceVector push fails when full":
        var v = InplaceVector.with_cap(0, 2)
        val a = v.push(1)
        val b = v.push(2)
        val c = v.push(3)
        expect(a).to_be(true)
        expect(b).to_be(true)
        expect(c).to_be(false)
        expect(v.is_full()).to_be(true)
        expect(v.len()).to_equal(2)

    it "InplaceVector clear resets count":
        var v = InplaceVector.with_cap(0, 3)
        val _a = v.push(5)
        v.clear()
        expect(v.len()).to_equal(0)
        expect(v.is_full()).to_be(false)
