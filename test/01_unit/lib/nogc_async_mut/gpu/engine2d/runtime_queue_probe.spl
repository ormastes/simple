# Host/GPU runtime queue evidence probe.
#
# The production aggregate wrapper runs this committed no-GC probe instead of
# generating temporary Simple source. Keep the printed keys stable; reports and
# system specs consume them as evidence fields.

use common.ui.draw_ir.{DRAW_IR_BACKEND_GPU, draw_ir_batch, draw_ir_embedding_config, draw_ir_rect}
use std.nogc_async_mut.gpu.engine2d.draw_ir_runtime_queue.{engine2d_draw_ir_runtime_queue_dispatch_only}
use std.nogc_async_mut.gpu.engine2d.host_gpu_event_queue.{engine2d_host_gpu_runtime_queue_with_backend_handle}

extern fn rt_host_gpu_queue_reset()
extern fn rt_host_gpu_queue_emit(lane_code: i64, kind_code: i64, payload_size: i64, backend_code: i64) -> i64
extern fn rt_host_gpu_queue_emit_payload(lane_code: i64, kind_code: i64, payload_size: i64, backend_code: i64, payload_hash: i64) -> i64
extern fn rt_host_gpu_queue_emit_payload_text(lane_code: i64, kind_code: i64, payload_size: i64, backend_code: i64, payload_hash: i64, payload_text: text) -> i64
extern fn rt_host_gpu_queue_drain(max_packets: i64) -> i64
extern fn rt_host_gpu_queue_packet_count() -> i64
extern fn rt_host_gpu_queue_submitted_count() -> i64
extern fn rt_host_gpu_queue_completed_count() -> i64
extern fn rt_host_gpu_queue_last_status() -> i64
extern fn rt_host_gpu_queue_last_backend_handle() -> i64
extern fn rt_host_gpu_queue_last_payload_size() -> i64
extern fn rt_host_gpu_queue_last_payload_hash() -> i64
extern fn rt_host_gpu_queue_last_payload_text() -> text

fn main() -> i32:
    rt_host_gpu_queue_reset()
    val unavailable_packet = rt_host_gpu_queue_emit(2, 1, 512, 0)
    val unavailable_queued_status = rt_host_gpu_queue_last_status()
    val unavailable_drained = rt_host_gpu_queue_drain(4)
    val unavailable_status = rt_host_gpu_queue_last_status()
    val unavailable_backend_handle = rt_host_gpu_queue_last_backend_handle()
    println("queue_zero_backend_packet_id=" + unavailable_packet.to_text())
    println("queue_zero_backend_queued_status=" + unavailable_queued_status.to_text())
    println("queue_zero_backend_drained=" + unavailable_drained.to_text())
    println("queue_zero_backend_last_status=" + unavailable_status.to_text())
    println("queue_zero_backend_last_backend_handle=" + unavailable_backend_handle.to_text())

    rt_host_gpu_queue_reset()
    val backend_payload_text = "queue probe payload command=draw_ir_rect id=runtime-backend"
    val backend_packet = rt_host_gpu_queue_emit_payload_text(2, 1, 512, 7, 98765, backend_payload_text)
    val backend_queued_status = rt_host_gpu_queue_last_status()
    val backend_drained = rt_host_gpu_queue_drain(4)
    val backend_status = rt_host_gpu_queue_last_status()
    val backend_handle = rt_host_gpu_queue_last_backend_handle()
    val backend_payload_size = rt_host_gpu_queue_last_payload_size()
    val backend_payload_hash = rt_host_gpu_queue_last_payload_hash()
    val backend_payload_text_readback = rt_host_gpu_queue_last_payload_text()
    println("queue_nonzero_backend_packet_id=" + backend_packet.to_text())
    println("queue_nonzero_backend_queued_status=" + backend_queued_status.to_text())
    println("queue_nonzero_backend_drained=" + backend_drained.to_text())
    println("queue_nonzero_backend_packet_count=" + rt_host_gpu_queue_packet_count().to_text())
    println("queue_nonzero_backend_submitted_count=" + rt_host_gpu_queue_submitted_count().to_text())
    println("queue_nonzero_backend_completed_count=" + rt_host_gpu_queue_completed_count().to_text())
    println("queue_nonzero_backend_last_status=" + backend_status.to_text())
    println("queue_nonzero_backend_last_backend_handle=" + backend_handle.to_text())
    println("queue_nonzero_backend_last_payload_size=" + backend_payload_size.to_text())
    println("queue_nonzero_backend_last_payload_hash=" + backend_payload_hash.to_text())
    println("queue_nonzero_backend_last_payload_text=" + backend_payload_text_readback)

    rt_host_gpu_queue_reset()
    var accepted = 0
    var i = 0
    while i < 1024:
        val packet = rt_host_gpu_queue_emit(2, 1, 8, 7)
        if packet > 0:
            accepted = accepted + 1
        i = i + 1
    val overflow_packet = rt_host_gpu_queue_emit(2, 1, 8, 7)
    println("queue_overflow_capacity=1024")
    println("queue_overflow_accepted=" + accepted.to_text())
    println("queue_overflow_packet_id=" + overflow_packet.to_text())
    println("queue_overflow_packet_count=" + rt_host_gpu_queue_packet_count().to_text())
    println("queue_overflow_drained=" + rt_host_gpu_queue_drain(1024).to_text())

    rt_host_gpu_queue_reset()
    val draw_batch = draw_ir_batch("runtime-probe", DRAW_IR_BACKEND_GPU,
        draw_ir_embedding_config("surface", "component", 0, 0, 20, 16, 1, 1000, false), [
            draw_ir_rect("body", 2, 3, 6, 5, 0xff00ff00u32)
        ])
    val draw_queue = engine2d_host_gpu_runtime_queue_with_backend_handle("vulkan", 1, 7, true, 4096)
    val draw_result = engine2d_draw_ir_runtime_queue_dispatch_only(draw_batch, true, draw_queue)
    println("queue_draw_ir_dispatched=" + draw_result.runtime_dispatch.dispatched.to_text())
    println("queue_draw_ir_backend_handle=" + draw_result.runtime_dispatch.backend_handle.to_text())
    println("queue_draw_ir_payload_nonempty=" + (draw_result.payload.payload_sdn.len() > 0).to_text())
    println("queue_draw_ir_payload_has_schema=" + draw_result.payload.payload_sdn.contains("draw_ir schema=simple-draw-ir-v2").to_text())
    println("queue_draw_ir_runtime_payload_has_schema=" + draw_result.runtime_dispatch.payload_text.contains("draw_ir schema=simple-draw-ir-v2").to_text())
    0
