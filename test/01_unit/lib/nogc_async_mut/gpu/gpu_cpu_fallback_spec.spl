use std.spec
use std.common.gpu.device.{GpuBackend, Gpu, gpu_none, gpu_cuda, gpu_vulkan}

# Tests for the CPU/None_ fallback path of the GPU tier.
# Uses std.common.gpu.device directly to avoid the torch chain
# (std.nogc_async_mut.gpu.device imports torch which has a pre-existing
# SGD.step me-method interpreter error — tracked separately).
# These tests must pass on a GPU-less CI host.

describe "GPU CPU fallback - device types":
    it "gpu_none returns None_ backend":
        val g = gpu_none()
        expect(g.backend).to_equal(GpuBackend.None_)

    it "gpu_none returns device_id -1":
        val g = gpu_none()
        expect(g.device_id).to_equal(-1)

    it "gpu_cuda returns Cuda backend":
        val g = gpu_cuda(0)
        expect(g.backend).to_equal(GpuBackend.Cuda)

    it "gpu_cuda stores device_id":
        val g = gpu_cuda(2)
        expect(g.device_id).to_equal(2)

    it "gpu_vulkan returns Vulkan backend":
        val g = gpu_vulkan(0)
        expect(g.backend).to_equal(GpuBackend.Vulkan)

    it "GpuBackend None_ is distinct from Cuda":
        val none = GpuBackend.None_
        val cuda = GpuBackend.Cuda
        expect(none == cuda).to_equal(false)

    it "GpuBackend None_ equals None_":
        val a = GpuBackend.None_
        val b = GpuBackend.None_
        expect(a).to_equal(b)

    it "GpuBackend Cuda equals Cuda":
        val a = GpuBackend.Cuda
        val b = GpuBackend.Cuda
        expect(a).to_equal(b)

    it "Gpu struct equality - same values":
        val a = gpu_none()
        val b = gpu_none()
        expect(a.backend).to_equal(b.backend)
        expect(a.device_id).to_equal(b.device_id)

    it "device_id is i64 - large value preserved":
        val g = gpu_cuda(1000000)
        expect(g.device_id).to_equal(1000000)

    it "gpu_none device_id is negative":
        val g = gpu_none()
        val is_negative = g.device_id < 0
        expect(is_negative).to_equal(true)
