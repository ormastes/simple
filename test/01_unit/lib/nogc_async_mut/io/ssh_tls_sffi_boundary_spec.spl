use std.spec
use std.nogc_async_mut.io.ssh_sffi.{ssh_sffi_boundary_kind, ssh_sffi_release_allowed, ssh_sffi_release_rejection_reason}
use std.nogc_async_mut.io.tls_sffi.{tls_sffi_server_boundary_kind, tls_sffi_server_release_allowed, tls_sffi_server_release_rejection_reason}

describe "async SSH and TLS SFFI release boundaries":

    it "re-exports SSH SFFI native protocol bypass classification":
        expect(ssh_sffi_boundary_kind()).to_equal("native-protocol-bypass")
        expect(ssh_sffi_release_allowed()).to_be(false)
        expect(ssh_sffi_release_rejection_reason()).to_contain("release mode must use Simple SSH protocol modules")

    it "re-exports TLS server SFFI native protocol bypass classification":
        expect(tls_sffi_server_boundary_kind()).to_equal("native-protocol-bypass")
        expect(tls_sffi_server_release_allowed()).to_be(false)
        expect(tls_sffi_server_release_rejection_reason()).to_contain("release mode must use Simple TLS/HTTP protocol modules")
