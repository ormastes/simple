extern fn rt_file_read_text(path: text) -> text

fn _contains_h3_stream_negative_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn _h3_varint_decode(data: [u8], offset: i64) -> (i64, i64)?:") and
        source.to_contain("if offset < 0:\n        return nil") and
        source.to_contain("val first = data[offset]")

describe "HTTP/3 stream negative offset guards":
    it "guards varint decoding before indexed reads":
        expect(_contains_h3_stream_negative_guard("src/lib/nogc_async_mut/io/quic/h3_stream.spl")).to_equal(true)
