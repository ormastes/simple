# GreenChannel closed-state signaling regression spec (H8)
#
# Verifies: close() sets the closed flag; recv on closed+empty returns
# immediately (channel_closed=true, parked=false); send after close returns
# sent=false, channel_closed=true; green_channel_close_drain drains waiters;
# happy-path (open channel) behavior is unchanged.
#
# GreenChannel is a pure-Simple functional state machine — all tests are
# synchronous and interpreter-safe (no green_spawn needed).
#
# NOTE: bare expect(cond) is a no-op; always use .to_equal(true/false).

use std.spec.*
use std.concurrent.green_channel.{
    green_channel_new,
    green_channel_len,
    green_channel_waiting_count,
    green_channel_is_closed,
    green_channel_close,
    green_channel_close_drain,
    green_channel_recv,
    green_channel_send,
    green_channel_try_send
}

describe "GreenChannel closed-state signaling (H8)":

    context "is_closed / close() flag":
        it "new channel is not closed":
            val ch = green_channel_new(2)
            expect(green_channel_is_closed(ch)).to_equal(false)

        it "close() marks channel as closed":
            val ch = green_channel_new(2)
            val closed_ch = green_channel_close(ch)
            expect(green_channel_is_closed(closed_ch)).to_equal(true)

        it "closing an already-closed channel is idempotent":
            val ch = green_channel_new(2)
            val c1 = green_channel_close(ch)
            val c2 = green_channel_close(c1)
            expect(green_channel_is_closed(c2)).to_equal(true)

    context "recv on closed + empty channel":
        it "returns channel_closed=true without parking":
            val ch = green_channel_new(2)
            val closed_ch = green_channel_close(ch)
            val result = green_channel_recv(closed_ch, 77)
            expect(result.channel_closed).to_equal(true)
            expect(result.parked).to_equal(false)
            expect(result.received).to_equal(false)
            expect(result.reason).to_equal("channel_closed")

        it "waiting_task_ids stays empty after recv-on-closed":
            val ch = green_channel_new(2)
            val closed_ch = green_channel_close(ch)
            val result = green_channel_recv(closed_ch, 55)
            val waiting = green_channel_waiting_count(result.channel)
            expect(waiting).to_equal(0)

    context "recv on closed + non-empty channel drains buffered values first":
        it "delivers buffered value before reporting closed":
            val ch = green_channel_new(2)
            val s = green_channel_send(ch, 42)
            val closed_ch = green_channel_close(s.channel)
            val result = green_channel_recv(closed_ch, 1)
            expect(result.received).to_equal(true)
            expect(result.value).to_equal(42)
            expect(result.channel_closed).to_equal(false)

        it "second recv on now-empty closed channel returns channel_closed":
            val ch = green_channel_new(2)
            val s = green_channel_send(ch, 42)
            val closed_ch = green_channel_close(s.channel)
            val r1 = green_channel_recv(closed_ch, 1)
            val r2 = green_channel_recv(r1.channel, 2)
            expect(r1.received).to_equal(true)
            expect(r2.channel_closed).to_equal(true)
            expect(r2.parked).to_equal(false)

    context "send after close":
        it "green_channel_send returns sent=false and channel_closed=true":
            val ch = green_channel_new(2)
            val closed_ch = green_channel_close(ch)
            val result = green_channel_send(closed_ch, 99)
            expect(result.sent).to_equal(false)
            expect(result.channel_closed).to_equal(true)
            expect(result.reason).to_equal("channel_closed")

        it "green_channel_try_send returns sent=false after close":
            val ch = green_channel_new(2)
            val closed_ch = green_channel_close(ch)
            val result = green_channel_try_send(closed_ch, 77)
            expect(result.sent).to_equal(false)
            expect(result.channel_closed).to_equal(true)

    context "green_channel_close_drain wakes parked receivers":
        it "drain returns the parked task IDs in woken_task_ids":
            val ch = green_channel_new(2)
            # Park two receivers
            val r1 = green_channel_recv(ch, 10)
            val r2 = green_channel_recv(r1.channel, 20)
            val drain = green_channel_close_drain(r2.channel)
            val woken_count = drain.woken_task_ids.len()
            expect(woken_count).to_equal(2)

        it "drain leaves waiting_task_ids empty in closed channel":
            val ch = green_channel_new(2)
            val r1 = green_channel_recv(ch, 10)
            val drain = green_channel_close_drain(r1.channel)
            val waiting = green_channel_waiting_count(drain.channel)
            expect(waiting).to_equal(0)

        it "drain marks channel as closed":
            val ch = green_channel_new(2)
            val r1 = green_channel_recv(ch, 10)
            val drain = green_channel_close_drain(r1.channel)
            expect(green_channel_is_closed(drain.channel)).to_equal(true)

        it "drain on channel with no waiters returns empty woken list":
            val ch = green_channel_new(2)
            val drain = green_channel_close_drain(ch)
            val woken_count = drain.woken_task_ids.len()
            expect(woken_count).to_equal(0)

    context "happy-path: open channel behavior unchanged":
        it "send + recv still works on open channel":
            val ch = green_channel_new(2)
            val s = green_channel_send(ch, 55)
            val r = green_channel_recv(s.channel, 1)
            expect(r.received).to_equal(true)
            expect(r.value).to_equal(55)
            expect(r.channel_closed).to_equal(false)

        it "park on empty open channel still sets parked=true":
            val ch = green_channel_new(2)
            val result = green_channel_recv(ch, 99)
            expect(result.parked).to_equal(true)
            expect(result.channel_closed).to_equal(false)
