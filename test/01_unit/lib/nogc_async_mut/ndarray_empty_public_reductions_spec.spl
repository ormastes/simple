use std.ndarray.*

describe "NDArray empty public reductions":
    it "returns neutral values instead of unwrapping errors":
        val empty = array([])
        expect(empty.mean()).to_equal(Float64.new(0.0))
        expect(empty.min()).to_equal(Float64.new(0.0))
        expect(empty.max()).to_equal(Float64.new(0.0))
        expect(empty.argmax()).to_equal(Index.new(0))
        val empty_f32 = array_f32([])
        expect(empty_f32.mean_f32()).to_equal(Float32.new(0.0))
