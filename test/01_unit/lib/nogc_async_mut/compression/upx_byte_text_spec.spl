use std.spec
use std.nogc_async_mut.compress.upx.{upx_path_bytes_to_text}

describe "nogc_async_mut UPX path byte conversion":
    it "decodes path bytes without text.from_utf8":
        val decoded = upx_path_bytes_to_text([47u8, 117u8, 115u8, 114u8, 47u8, 98u8, 105u8, 110u8, 47u8, 117u8, 112u8, 120u8, 10u8, 13u8, 9u8, 255u8])
        expect(decoded).to_equal("/usr/bin/upx\n\r\t?")
