"""
# PhaseResult Response Headers Specification

**Feature IDs:** #E7-phase-result-headers
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Active
**Artifacts:** src/lib/nogc_async_mut/http_server/types.spl,
               src/lib/nogc_async_mut/http_server/cors.spl,
               src/lib/nogc_async_mut/http_server/response.spl
"""

use std.spec
use std.http_server.types.{PhaseResult}
use std.http_server.cors.{
    CorsConfig, build_cors_headers, cors_handler, handle_preflight
}
use std.http_server.response.{build_phase_response, serialize_response}
use std.http_server.types.{HttpRequestData, ServerConfig}

# ============================================================================
# Helpers
# ============================================================================

fn _make_request(method: text, origin: text) -> HttpRequestData:
    """Minimal request for CORS tests."""
    var hdrs: [(text, text)] = []
    if origin != "":
        hdrs.push(("Origin", origin))
    HttpRequestData(
        method: method,
        path: "/api/data",
        query: "",
        version: "HTTP/1.1",
        headers: hdrs,
        body: "",
        params: {},
        peer_addr: "127.0.0.1:9999"
    )

fn _make_server_config() -> ServerConfig:
    ServerConfig(
        listen_addr: "0.0.0.0:8080",
        worker_count: 1,
        max_connections: 100,
        keepalive_timeout_ms: 65000,
        read_timeout_ms: 60000,
        write_timeout_ms: 60000,
        idle_timeout_ms: 120000,
        client_max_body_size: 1048576,
        server_name: "TestServer",
        locations: [],
        upstreams: [],
        access_log: "",
        error_log: "",
        tls_enabled: false,
        tls_cert_path: "",
        tls_key_path: "",
        tls_min_version: "1.2",
        drain_timeout_ms: 30000
    )

fn _make_cors_config() -> CorsConfig:
    CorsConfig(
        allowed_origins: ["https://example.com"],
        allowed_methods: ["GET", "POST", "OPTIONS"],
        allowed_headers: ["Content-Type", "Authorization"],
        expose_headers: ["X-Request-Id"],
        allow_credentials: false,
        max_age_seconds: 3600
    )

# ============================================================================
# Tests
# ============================================================================

describe "PhaseResult.Respond 4-arg constructor shape":
    """
    ## E7 — PhaseResult.Respond(status, reason, headers, body)

    Validates the updated 4-argument constructor compiles and destructures
    correctly.
    """

    it "constructs Respond with empty headers list":
        """
        PhaseResult.Respond now takes (i64, text, [(text,text)], text).
        An empty headers list must be accepted without error.
        """
        val r = PhaseResult.Respond(200, "OK", [], "hello")
        match r:
            PhaseResult.Respond(s, reason, hdrs, body):
                expect(s).to_equal(200)
                expect(reason).to_equal("OK")
                expect(hdrs.len()).to_equal(0)
                expect(body).to_equal("hello")
            _:
                expect(false).to_equal(true)

    it "constructs Respond with a non-empty headers list":
        """
        Headers supplied to Respond are preserved in the enum variant.
        """
        val hdrs: [(text, text)] = [
            ("X-Custom", "value1"),
            ("Cache-Control", "no-store")
        ]
        val r = PhaseResult.Respond(204, "No Content", hdrs, "")
        match r:
            PhaseResult.Respond(s, reason, h, body):
                expect(s).to_equal(204)
                expect(h.len()).to_equal(2)
                expect(h[0].0).to_equal("X-Custom")
                expect(h[0].1).to_equal("value1")
                expect(h[1].0).to_equal("Cache-Control")
                expect(h[1].1).to_equal("no-store")
                expect(body).to_equal("")
            _:
                expect(false).to_equal(true)

describe "build_cors_headers returns header pairs not a string":
    """
    ## E7 — cors.spl build_cors_headers

    build_cors_headers must return [(text,text)] pairs suitable for the
    PhaseResult.Respond headers slot, not a concatenated string.
    """

    it "returns Access-Control-Allow-Origin for non-wildcard origin":
        val config = _make_cors_config()
        val pairs = build_cors_headers("https://example.com", config)
        expect(pairs.len() > 0).to_equal(true)
        val first = pairs[0]
        expect(first.0).to_equal("Access-Control-Allow-Origin")
        expect(first.1).to_equal("https://example.com")

    it "includes Vary: Origin for non-wildcard origin":
        val config = _make_cors_config()
        val pairs = build_cors_headers("https://example.com", config)
        var found_vary = false
        for p in pairs:
            if p.0 == "Vary" and p.1 == "Origin":
                found_vary = true
        expect(found_vary).to_equal(true)

    it "does not include Vary: Origin for wildcard origin":
        val config = _make_cors_config()
        val pairs = build_cors_headers("*", config)
        var found_vary = false
        for p in pairs:
            if p.0 == "Vary":
                found_vary = true
        expect(found_vary).to_equal(false)

    it "includes expose headers when configured":
        val config = _make_cors_config()
        val pairs = build_cors_headers("https://example.com", config)
        var found_expose = false
        for p in pairs:
            if p.0 == "Access-Control-Expose-Headers":
                found_expose = true
        expect(found_expose).to_equal(true)

describe "cors_handler places CORS headers in Respond headers slot":
    """
    ## E7 — cors_handler output

    For a normal CORS request (not OPTIONS preflight), cors_handler must
    return PhaseResult.Respond with CORS headers in the headers list,
    not in the body.
    """

    it "normal CORS GET: ACAO header in headers slot, body is empty":
        val req = _make_request("GET", "https://example.com")
        val srv = _make_server_config()
        val config = _make_cors_config()
        val result = cors_handler(req, srv, config)
        match result:
            PhaseResult.Respond(status, reason, hdrs, body):
                # Body must be empty — headers belong in the headers slot
                expect(body).to_equal("")
                # At least one header: Access-Control-Allow-Origin
                var found_acao = false
                for h in hdrs:
                    if h.0 == "Access-Control-Allow-Origin":
                        found_acao = true
                        expect(h.1).to_equal("https://example.com")
                expect(found_acao).to_equal(true)
            _:
                expect(false).to_equal(true)

describe "handle_preflight places CORS headers in Respond headers slot":
    """
    ## E7 — handle_preflight output

    For an OPTIONS preflight, handle_preflight must return
    PhaseResult.Respond(204, ...) with CORS headers in the headers list
    and an empty body (not headers serialized into the body string).
    """

    it "preflight: 204 status with empty body":
        val req = _make_request("OPTIONS", "https://example.com")
        val srv = _make_server_config()
        val config = _make_cors_config()
        val result = cors_handler(req, srv, config)
        match result:
            PhaseResult.Respond(status, reason, hdrs, body):
                expect(status).to_equal(204)
                expect(body).to_equal("")
                val hlen = hdrs.len()
                expect(hlen > 0).to_equal(true)
            _:
                expect(false).to_equal(true)

    it "preflight: ACAO header in headers list":
        val req = _make_request("OPTIONS", "https://example.com")
        val config = _make_cors_config()
        val hdrs = _preflight_headers(config, "https://example.com")
        var found = false
        for h in hdrs:
            if h.0 == "Access-Control-Allow-Origin":
                found = true
                expect(h.1).to_equal("https://example.com")
        expect(found).to_equal(true)

    it "preflight: Vary: Origin present for non-wildcard":
        val config = _make_cors_config()
        val hdrs = _preflight_headers(config, "https://example.com")
        var found_vary = false
        for h in hdrs:
            if h.0 == "Vary" and h.1 == "Origin":
                found_vary = true
        expect(found_vary).to_equal(true)

    it "preflight: body does not contain raw header text":
        val req = _make_request("OPTIONS", "https://example.com")
        val srv = _make_server_config()
        val config = _make_cors_config()
        val result = cors_handler(req, srv, config)
        match result:
            PhaseResult.Respond(status, reason, hdrs, body):
                # Body must not contain "Access-Control" — that goes in headers
                val body_has_acao = body.contains("Access-Control")
                expect(body_has_acao).to_equal(false)
            _:
                expect(false).to_equal(true)

describe "build_phase_response serializes extra headers into wire format":
    """
    ## E7 — response.spl build_phase_response

    build_phase_response must produce an HttpResponseData whose
    serialized form contains the extra headers as separate header lines,
    and must reject (drop) headers with \\r or \\n in name or value.
    """

    it "extra headers appear in serialized response":
        val hdrs: [(text, text)] = [
            ("Access-Control-Allow-Origin", "https://example.com"),
            ("Vary", "Origin")
        ]
        val resp = build_phase_response(200, "OK", hdrs, "")
        val wire = serialize_response(resp)
        val has_acao = wire.contains("Access-Control-Allow-Origin: https://example.com")
        val has_vary = wire.contains("Vary: Origin")
        expect(has_acao).to_equal(true)
        expect(has_vary).to_equal(true)

    it "status line is correct in serialized response":
        val resp = build_phase_response(204, "No Content", [], "")
        val wire = serialize_response(resp)
        val has_status = wire.contains("HTTP/1.1 204 No Content")
        expect(has_status).to_equal(true)

    it "CRLF injection in header value is dropped":
        val hdrs: [(text, text)] = [
            ("X-Safe", "good"),
            ("X-Injected", "bad\r\nX-Evil: injected")
        ]
        val resp = build_phase_response(200, "OK", hdrs, "")
        val wire = serialize_response(resp)
        val has_safe = wire.contains("X-Safe: good")
        val has_evil = wire.contains("X-Evil")
        expect(has_safe).to_equal(true)
        expect(has_evil).to_equal(false)

    it "CRLF injection in header name is dropped":
        val hdrs: [(text, text)] = [
            ("X-Safe", "good"),
            ("X-Bad\r\nX-Evil", "injected")
        ]
        val resp = build_phase_response(200, "OK", hdrs, "")
        val wire = serialize_response(resp)
        val has_safe = wire.contains("X-Safe: good")
        val has_evil = wire.contains("X-Evil")
        expect(has_safe).to_equal(true)
        expect(has_evil).to_equal(false)

    it "LF-only injection in header value is dropped":
        val hdrs: [(text, text)] = [
            ("X-Safe", "good"),
            ("X-Lf", "bad\nvalue")
        ]
        val resp = build_phase_response(200, "OK", hdrs, "")
        val wire = serialize_response(resp)
        val has_safe = wire.contains("X-Safe: good")
        val has_lf = wire.contains("X-Lf")
        expect(has_safe).to_equal(true)
        expect(has_lf).to_equal(false)

# ============================================================================
# Internal helper for preflight header extraction
# ============================================================================

fn _preflight_headers(config: CorsConfig, origin: text) -> [(text, text)]:
    """Extract the headers list from a handle_preflight PhaseResult."""
    val req = _make_request("OPTIONS", origin)
    val srv = _make_server_config()
    val result = cors_handler(req, srv, config)
    match result:
        PhaseResult.Respond(status, reason, hdrs, body):
            hdrs
        _:
            []
