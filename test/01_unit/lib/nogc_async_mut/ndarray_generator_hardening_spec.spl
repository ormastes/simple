use std.ndarray.*

describe "NDArray generator hardening":
    it "returns empty arrays for invalid public generator inputs":
        expect(zeros(Shape.new([Index.new(-1)])).len()).to_equal(Index.new(0))
        expect(arange(Float64.new(0.0), Float64.new(4.0), Float64.new(0.0)).len()).to_equal(Index.new(0))
        expect(linspace(Float64.new(0.0), Float64.new(1.0), Index.new(0)).len()).to_equal(Index.new(0))
