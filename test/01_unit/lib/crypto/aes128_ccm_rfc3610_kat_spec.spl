#![allow(unnamed_duplicate_typed_args)]

# ============================================================================
# AES-128-CCM RFC 3610 §8 Reference Vector KAT Spec
#
# Tests aes128_ccm_encrypt / aes128_ccm_decrypt against authoritative
# RFC 3610 §8 Packet Vectors #1, #4, #7 (the M=8 and M=10 representative
# vectors covering varying header / payload sizes).
#
# RFC 3610 §8 vectors are M ∈ {8, 10} only — there are no M=16 vectors
# in §8.  For tag_len=16 we run an encrypt→decrypt round-trip test
# (no external KAT) and a tampering-rejection test.
#
# Source: RFC 3610 §8, https://datatracker.ietf.org/doc/html/rfc3610
# ============================================================================

use std.spec.*
use os.crypto.aes128_ccm.{aes128_ccm_encrypt, aes128_ccm_decrypt, Aes128CcmResult}

# ============================================================================
# Vector helpers — module-level (avoid feedback_it_block_var_mutation footgun)
# ============================================================================

# Shared AES key used by RFC 3610 §8 vectors #1–#12.
fn _key_v1_4_7() -> [u8]:
    [
     0xC0,0xC1,0xC2,0xC3,0xC4,0xC5,0xC6,0xC7,
     0xC8,0xC9,0xCA,0xCB,0xCC,0xCD,0xCE,0xCF]

# --- Vector #1 (M=8): nonce=03020100, hdr=8B, payload=23B ---

fn _v1_nonce() -> [u8]:
    [
     0x00,0x00,0x00,0x03,0x02,0x01,0x00,0xA0,
     0xA1,0xA2,0xA3,0xA4,0xA5]

fn _v1_aad() -> [u8]:
    [
     0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07]

fn _v1_plaintext() -> [u8]:
    [
     0x08,0x09,0x0A,0x0B,0x0C,0x0D,0x0E,0x0F,
     0x10,0x11,0x12,0x13,0x14,0x15,0x16,0x17,
     0x18,0x19,0x1A,0x1B,0x1C,0x1D,0x1E]

fn _v1_expected_ct() -> [u8]:
    [
     0x58,0x8C,0x97,0x9A,0x61,0xC6,0x63,0xD2,
     0xF0,0x66,0xD0,0xC2,0xC0,0xF9,0x89,0x80,
     0x6D,0x5F,0x6B,0x61,0xDA,0xC3,0x84]

fn _v1_expected_tag() -> [u8]:
    [
     0x17,0xE8,0xD1,0x2C,0xFD,0xF9,0x26,0xE0]

# --- Vector #4 (M=8): nonce=06050403, hdr=12B, payload=19B ---

fn _v4_nonce() -> [u8]:
    [
     0x00,0x00,0x00,0x06,0x05,0x04,0x03,0xA0,
     0xA1,0xA2,0xA3,0xA4,0xA5]

fn _v4_aad() -> [u8]:
    [
     0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07,
     0x08,0x09,0x0A,0x0B]

fn _v4_plaintext() -> [u8]:
    [
     0x0C,0x0D,0x0E,0x0F,0x10,0x11,0x12,0x13,
     0x14,0x15,0x16,0x17,0x18,0x19,0x1A,0x1B,
     0x1C,0x1D,0x1E]

fn _v4_expected_ct() -> [u8]:
    [
     0xA2,0x8C,0x68,0x65,0x93,0x9A,0x9A,0x79,
     0xFA,0xAA,0x5C,0x4C,0x2A,0x9D,0x4A,0x91,
     0xCD,0xAC,0x8C]

fn _v4_expected_tag() -> [u8]:
    [
     0x96,0xC8,0x61,0xB9,0xC9,0xE6,0x1E,0xF1]

# --- Vector #7 (M=10): nonce=09080706, hdr=8B, payload=23B ---

fn _v7_nonce() -> [u8]:
    [
     0x00,0x00,0x00,0x09,0x08,0x07,0x06,0xA0,
     0xA1,0xA2,0xA3,0xA4,0xA5]

fn _v7_aad() -> [u8]:
    [
     0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07]

fn _v7_plaintext() -> [u8]:
    [
     0x08,0x09,0x0A,0x0B,0x0C,0x0D,0x0E,0x0F,
     0x10,0x11,0x12,0x13,0x14,0x15,0x16,0x17,
     0x18,0x19,0x1A,0x1B,0x1C,0x1D,0x1E]

fn _v7_expected_ct() -> [u8]:
    [
     0x01,0x35,0xD1,0xB2,0xC9,0x5F,0x41,0xD5,
     0xD1,0xD4,0xFE,0xC1,0x85,0xD1,0x66,0xB8,
     0x09,0x4E,0x99,0x9D,0xFE,0xD9,0x6C]

fn _v7_expected_tag() -> [u8]:
    [
     0x04,0x8C,0x56,0x60,0x2C,0x97,0xAC,0xBB,
     0x74,0x90]

# ============================================================================
# Output split helpers (encrypt returns ct||tag concatenated)
# ============================================================================

fn _split_ct(out: [u8], ct_len: u64) -> [u8]:
    var r: [u8] = []
    var i: u64 = 0
    while i < ct_len:
        r.push(out[i])
        i = i + 1
    r

fn _split_tag(out: [u8], ct_len: u64) -> [u8]:
    var r: [u8] = []
    var i: u64 = ct_len
    while i < out.len():
        r.push(out[i])
        i = i + 1
    r

fn _corrupt_last_byte(buf: [u8]) -> [u8]:
    var r: [u8] = []
    var i: u64 = 0
    while i < buf.len():
        if (i + 1) == buf.len():
            r.push(buf[i] ^ 0x01)
        else:
            r.push(buf[i])
        i = i + 1
    r

# ============================================================================
# Specs
# ============================================================================

describe "AES-128-CCM RFC 3610 §8 reference vectors":
    """Byte-exact KAT against RFC 3610 §8 Packet Vectors #1, #4, #7.

    Each vector exercises encrypt (CT+tag match RFC) and decrypt
    (round-trip + tampering rejection)."""

    it "Vector #1 encrypt: 8-byte AAD, 23-byte PT, M=8 — CT and tag match RFC":
        """RFC 3610 §8 Packet Vector #1 byte-exact encrypt KAT."""
        val out = aes128_ccm_encrypt(_key_v1_4_7(), _v1_nonce(), _v1_aad(), _v1_plaintext(), 8)
        val ct = _split_ct(out, _v1_plaintext().len())
        val tag = _split_tag(out, _v1_plaintext().len())
        expect(ct).to_equal(_v1_expected_ct())
        expect(tag).to_equal(_v1_expected_tag())

    it "Vector #1 decrypt: correct tag returns original plaintext":
        val result = aes128_ccm_decrypt(_key_v1_4_7(), _v1_nonce(), _v1_aad(),
                                         _v1_expected_ct(), _v1_expected_tag())
        match result:
            Aes128CcmResult.Ok(data):
                expect(data).to_equal(_v1_plaintext())
            Aes128CcmResult.Err(msg):
                expect(msg).to_equal("")  # unreachable: encrypt must succeed

    it "Vector #1 decrypt: corrupted ciphertext is rejected":
        val bad_ct = _corrupt_last_byte(_v1_expected_ct())
        val result = aes128_ccm_decrypt(_key_v1_4_7(), _v1_nonce(), _v1_aad(),
                                         bad_ct, _v1_expected_tag())
        match result:
            Aes128CcmResult.Ok(data):
                expect(data.len()).to_equal(99999)  # unreachable: must take Err branch
            Aes128CcmResult.Err(msg):
                expect(msg.contains("tag mismatch")).to_equal(true)

    it "Vector #1 decrypt: modified AAD is rejected":
        val bad_aad = _corrupt_last_byte(_v1_aad())
        val result = aes128_ccm_decrypt(_key_v1_4_7(), _v1_nonce(), bad_aad,
                                         _v1_expected_ct(), _v1_expected_tag())
        match result:
            Aes128CcmResult.Ok(data):
                expect(data.len()).to_equal(99999)  # unreachable: must take Err branch
            Aes128CcmResult.Err(msg):
                expect(msg.contains("tag mismatch")).to_equal(true)

    it "Vector #4 encrypt: 12-byte AAD, 19-byte PT, M=8 — CT and tag match RFC":
        val out = aes128_ccm_encrypt(_key_v1_4_7(), _v4_nonce(), _v4_aad(), _v4_plaintext(), 8)
        val ct = _split_ct(out, _v4_plaintext().len())
        val tag = _split_tag(out, _v4_plaintext().len())
        expect(ct).to_equal(_v4_expected_ct())
        expect(tag).to_equal(_v4_expected_tag())

    it "Vector #4 decrypt: correct tag returns original plaintext":
        val result = aes128_ccm_decrypt(_key_v1_4_7(), _v4_nonce(), _v4_aad(),
                                         _v4_expected_ct(), _v4_expected_tag())
        match result:
            Aes128CcmResult.Ok(data):
                expect(data).to_equal(_v4_plaintext())
            Aes128CcmResult.Err(msg):
                expect(msg).to_equal("")  # unreachable: encrypt must succeed

    it "Vector #7 encrypt: M=10 (different tag length) — CT and tag match RFC":
        val out = aes128_ccm_encrypt(_key_v1_4_7(), _v7_nonce(), _v7_aad(), _v7_plaintext(), 10)
        val ct = _split_ct(out, _v7_plaintext().len())
        val tag = _split_tag(out, _v7_plaintext().len())
        expect(ct).to_equal(_v7_expected_ct())
        expect(tag).to_equal(_v7_expected_tag())

    it "Vector #7 decrypt: correct 10-byte tag returns original plaintext":
        val result = aes128_ccm_decrypt(_key_v1_4_7(), _v7_nonce(), _v7_aad(),
                                         _v7_expected_ct(), _v7_expected_tag())
        match result:
            Aes128CcmResult.Ok(data):
                expect(data).to_equal(_v7_plaintext())
            Aes128CcmResult.Err(msg):
                expect(msg).to_equal("")  # unreachable: encrypt must succeed

    it "Vector #7 decrypt: corrupted tag is rejected":
        val bad_tag = _corrupt_last_byte(_v7_expected_tag())
        val result = aes128_ccm_decrypt(_key_v1_4_7(), _v7_nonce(), _v7_aad(),
                                         _v7_expected_ct(), bad_tag)
        match result:
            Aes128CcmResult.Ok(data):
                expect(data.len()).to_equal(99999)  # unreachable: must take Err branch
            Aes128CcmResult.Err(msg):
                expect(msg.contains("tag mismatch")).to_equal(true)

describe "AES-128-CCM edge cases":
    """Edge cases not covered by RFC 3610 §8: empty inputs and M=16 round-trip."""

    it "empty plaintext + empty AAD round-trips at M=8":
        """Empty PT + AAD: output is just the 8-byte tag."""
        val empty: [u8] = []
        val nonce = _v1_nonce()
        val key = _key_v1_4_7()
        val out = aes128_ccm_encrypt(key, nonce, empty, empty, 8)
        # output is just the 8-byte tag (no CT bytes)
        expect(out.len()).to_equal(8)
        val tag = _split_tag(out, 0)
        val result = aes128_ccm_decrypt(key, nonce, empty, empty, tag)
        match result:
            Aes128CcmResult.Ok(data):
                expect(data.len()).to_equal(0)
            Aes128CcmResult.Err(msg):
                expect(msg).to_equal("")  # unreachable: encrypt must succeed

    it "empty AAD + non-empty PT round-trips at M=16":
        # M=16 has no RFC 3610 §8 KAT; round-trip-only.
        val empty: [u8] = []
        val nonce = _v1_nonce()
        val key = _key_v1_4_7()
        val pt = _v1_plaintext()
        val out = aes128_ccm_encrypt(key, nonce, empty, pt, 16)
        # output is 23 bytes CT + 16 bytes tag = 39 bytes total
        expect(out.len()).to_equal(pt.len() + 16)
        val ct = _split_ct(out, pt.len())
        val tag = _split_tag(out, pt.len())
        expect(tag.len()).to_equal(16)
        val result = aes128_ccm_decrypt(key, nonce, empty, ct, tag)
        match result:
            Aes128CcmResult.Ok(data):
                expect(data).to_equal(pt)
            Aes128CcmResult.Err(msg):
                expect(msg).to_equal("")  # unreachable: encrypt must succeed

    it "M=16 detects single-bit ciphertext flip":
        val empty: [u8] = []
        val nonce = _v1_nonce()
        val key = _key_v1_4_7()
        val pt = _v1_plaintext()
        val out = aes128_ccm_encrypt(key, nonce, empty, pt, 16)
        val ct = _split_ct(out, pt.len())
        val tag = _split_tag(out, pt.len())
        val bad_ct = _corrupt_last_byte(ct)
        val result = aes128_ccm_decrypt(key, nonce, empty, bad_ct, tag)
        match result:
            Aes128CcmResult.Ok(data):
                expect(data.len()).to_equal(99999)  # unreachable: must take Err branch
            Aes128CcmResult.Err(msg):
                expect(msg.contains("tag mismatch")).to_equal(true)
