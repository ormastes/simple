# HMAC-SHA-256 + HMAC-SHA-512 RFC 4231 Test Vectors
#
# Tests the pure-Simple HMAC implementation in src/lib/common/crypto/hmac.spl
# against the 7 canonical reference vectors from RFC 4231 §4.
#
# Only SHA-256 and SHA-512 variants are covered (no SHA-224 or SHA-384 in impl).
# Test Cases 1–4 and 6–7 are included. TC5 (truncation) is skipped because
# hmac_sha256_bytes / hmac_sha512_bytes do not accept a length parameter.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. MAC assertions only fire under compiled/native mode.

use std.spipe.*
use std.crypto.hmac.{hmac_sha256_bytes, hmac_sha512_bytes}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Repeated-byte helpers (used for TC3, TC4, TC6, TC7)
# ============================================================================

fn _make_repeat(byte: i64, n: i64) -> list:
    var out = []
    var i = 0
    while i < n:
        out.push(byte)
        i = i + 1
    out

# "This is a test using a larger than block-size key and a larger than
#  block-size data. The key needs to be hashed before being used by the
#  HMAC algorithm."  (152 bytes, TC7 data)
fn _tc7_data() -> list:
    # ASCII bytes hand-encoded
    val chars = [
        0x54, 0x68, 0x69, 0x73, 0x20, 0x69, 0x73, 0x20,  # "This is "
        0x61, 0x20, 0x74, 0x65, 0x73, 0x74, 0x20, 0x75,  # "a test u"
        0x73, 0x69, 0x6e, 0x67, 0x20, 0x61, 0x20, 0x6c,  # "sing a l"
        0x61, 0x72, 0x67, 0x65, 0x72, 0x20, 0x74, 0x68,  # "arger th"
        0x61, 0x6e, 0x20, 0x62, 0x6c, 0x6f, 0x63, 0x6b,  # "an block"
        0x2d, 0x73, 0x69, 0x7a, 0x65, 0x20, 0x6b, 0x65,  # "-size ke"
        0x79, 0x20, 0x61, 0x6e, 0x64, 0x20, 0x61, 0x20,  # "y and a "
        0x6c, 0x61, 0x72, 0x67, 0x65, 0x72, 0x20, 0x74,  # "larger t"
        0x68, 0x61, 0x6e, 0x20, 0x62, 0x6c, 0x6f, 0x63,  # "han bloc"
        0x6b, 0x2d, 0x73, 0x69, 0x7a, 0x65, 0x20, 0x64,  # "k-size d"
        0x61, 0x74, 0x61, 0x2e, 0x20, 0x54, 0x68, 0x65,  # "ata. The"
        0x20, 0x6b, 0x65, 0x79, 0x20, 0x6e, 0x65, 0x65,  # " key nee"
        0x64, 0x73, 0x20, 0x74, 0x6f, 0x20, 0x62, 0x65,  # "ds to be"
        0x20, 0x68, 0x61, 0x73, 0x68, 0x65, 0x64, 0x20,  # " hashed "
        0x62, 0x65, 0x66, 0x6f, 0x72, 0x65, 0x20, 0x62,  # "before b"
        0x65, 0x69, 0x6e, 0x67, 0x20, 0x75, 0x73, 0x65,  # "eing use"
        0x64, 0x20, 0x62, 0x79, 0x20, 0x74, 0x68, 0x65,  # "d by the"
        0x20, 0x48, 0x4d, 0x41, 0x43, 0x20, 0x61, 0x6c,  # " HMAC al"
        0x67, 0x6f, 0x72, 0x69, 0x74, 0x68, 0x6d, 0x2e   # "gorithm."
    ]
    var out = []
    for c in chars:
        out.push(c)
    out

# ============================================================================
# TC1: Key = 20 × 0x0b, Data = "Hi There"
# ============================================================================

fn _tc1_key() -> list:
    _make_repeat(0x0b, 20)

fn _tc1_data() -> list:
    # "Hi There" — 0x48 0x69 0x20 0x54 0x68 0x65 0x72 0x65
    [0x48, 0x69, 0x20, 0x54, 0x68, 0x65, 0x72, 0x65]

# ============================================================================
# TC2: Key = "Jefe" (4 bytes), Data = "what do ya want for nothing?"
# ============================================================================

fn _tc2_key() -> list:
    [0x4a, 0x65, 0x66, 0x65]

fn _tc2_data() -> list:
    # "what do ya want for nothing?" — 28 bytes
    [
        0x77, 0x68, 0x61, 0x74, 0x20, 0x64, 0x6f, 0x20,
        0x79, 0x61, 0x20, 0x77, 0x61, 0x6e, 0x74, 0x20,
        0x66, 0x6f, 0x72, 0x20, 0x6e, 0x6f, 0x74, 0x68,
        0x69, 0x6e, 0x67, 0x3f
    ]

# ============================================================================
# TC3: Key = 20 × 0xaa, Data = 50 × 0xdd
# ============================================================================

fn _tc3_key() -> list:
    _make_repeat(0xaa, 20)

fn _tc3_data() -> list:
    _make_repeat(0xdd, 50)

# ============================================================================
# TC4: Key = 25-byte sequence 0x01..0x19, Data = 50 × 0xcd
# ============================================================================

fn _tc4_key() -> list:
    [
        0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08,
        0x09, 0x0a, 0x0b, 0x0c, 0x0d, 0x0e, 0x0f, 0x10,
        0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17, 0x18,
        0x19
    ]

fn _tc4_data() -> list:
    _make_repeat(0xcd, 50)

# ============================================================================
# TC6: Key = 131 × 0xaa, Data = "Test Using Larger Than Block-Size Key - Hash Key First"
# ============================================================================

fn _tc6_key() -> list:
    _make_repeat(0xaa, 131)

fn _tc6_data() -> list:
    # "Test Using Larger Than Block-Size Key - Hash Key First" — 54 bytes
    [
        0x54, 0x65, 0x73, 0x74, 0x20, 0x55, 0x73, 0x69,
        0x6e, 0x67, 0x20, 0x4c, 0x61, 0x72, 0x67, 0x65,
        0x72, 0x20, 0x54, 0x68, 0x61, 0x6e, 0x20, 0x42,
        0x6c, 0x6f, 0x63, 0x6b, 0x2d, 0x53, 0x69, 0x7a,
        0x65, 0x20, 0x4b, 0x65, 0x79, 0x20, 0x2d, 0x20,
        0x48, 0x61, 0x73, 0x68, 0x20, 0x4b, 0x65, 0x79,
        0x20, 0x46, 0x69, 0x72, 0x73, 0x74
    ]

# ============================================================================
# TC7: Key = 131 × 0xaa, Data = 152-byte sentence
# ============================================================================

fn _tc7_key() -> list:
    _make_repeat(0xaa, 131)

# ============================================================================
# HMAC-SHA-256 RFC 4231 test vectors
# ============================================================================

describe "HMAC-SHA-256 RFC 4231 test vectors":

    it "TC1 short key + 'Hi There' → b0344c61...":
        # RFC 4231 §4.2: b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7
        expect(bytes_to_hex(hmac_sha256_bytes(_tc1_key(), _tc1_data()))).to_equal(
            "b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7"
        )

    it "TC2 'Jefe' key + 'what do ya want for nothing?' → 5bdcc146...":
        # RFC 4231 §4.3: 5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843
        expect(bytes_to_hex(hmac_sha256_bytes(_tc2_key(), _tc2_data()))).to_equal(
            "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843"
        )

    it "TC3 20×0xaa key + 50×0xdd → 773ea91e...":
        # RFC 4231 §4.4: 773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe
        expect(bytes_to_hex(hmac_sha256_bytes(_tc3_key(), _tc3_data()))).to_equal(
            "773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe"
        )

    it "TC4 25-byte key + 50×0xcd → 82558a38...":
        # RFC 4231 §4.5: 82558a389a443c0ea4cc819899f2083a85f0faa3e578f8077a2e3ff46729665b
        expect(bytes_to_hex(hmac_sha256_bytes(_tc4_key(), _tc4_data()))).to_equal(
            "82558a389a443c0ea4cc819899f2083a85f0faa3e578f8077a2e3ff46729665b"
        )

    it "TC6 131×0xaa key + 54-byte data → 60e43159...":
        # RFC 4231 §4.7: 60e431591ee0b67f0d8a26aacbf5b77f8e0bc6213728c5140546040f0ee37f54
        expect(bytes_to_hex(hmac_sha256_bytes(_tc6_key(), _tc6_data()))).to_equal(
            "60e431591ee0b67f0d8a26aacbf5b77f8e0bc6213728c5140546040f0ee37f54"
        )

    it "TC7 131×0xaa key + 152-byte data → 9b09ffa7...":
        # RFC 4231 §4.8: 9b09ffa71b942fcb27635fbcd5b0e944bfdc63644f0713938a7f51535c3a35e2
        expect(bytes_to_hex(hmac_sha256_bytes(_tc7_key(), _tc7_data()))).to_equal(
            "9b09ffa71b942fcb27635fbcd5b0e944bfdc63644f0713938a7f51535c3a35e2"
        )

# ============================================================================
# HMAC-SHA-512 RFC 4231 test vectors
# ============================================================================

describe "HMAC-SHA-512 RFC 4231 test vectors":

    it "TC1 short key + 'Hi There' → 87aa7cde...":
        # RFC 4231 §4.2: 87aa7cdea5ef619d4ff0b4241a1d6cb02379f4e2ce4ec2787ad0b30545e17cdedaa833b7d6b8a702038b274eaea3f4e4be9d914eeb61f1702e696c203a126854
        expect(bytes_to_hex(hmac_sha512_bytes(_tc1_key(), _tc1_data()))).to_equal(
            "87aa7cdea5ef619d4ff0b4241a1d6cb02379f4e2ce4ec2787ad0b30545e17cdedaa833b7d6b8a702038b274eaea3f4e4be9d914eeb61f1702e696c203a126854"
        )

    it "TC2 'Jefe' key + 'what do ya want for nothing?' → 164b7a7b...":
        # RFC 4231 §4.3: 164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd610270cd7ea2505549758bf75c05a994a6d034f65f8f0e6fdcaeab1a34d4a6b4b636e070a38bce737
        expect(bytes_to_hex(hmac_sha512_bytes(_tc2_key(), _tc2_data()))).to_equal(
            "164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd610270cd7ea2505549758bf75c05a994a6d034f65f8f0e6fdcaeab1a34d4a6b4b636e070a38bce737"
        )

    it "TC3 20×0xaa key + 50×0xdd → fa73b008...":
        # RFC 4231 §4.4: fa73b0089d56a284efb0f0756c890be9b1b5dbdd8ee81a3655f83e33b2279d39bf3e848279a722c806b485a47e67c807b946a337bee8942674278859e13292fb
        expect(bytes_to_hex(hmac_sha512_bytes(_tc3_key(), _tc3_data()))).to_equal(
            "fa73b0089d56a284efb0f0756c890be9b1b5dbdd8ee81a3655f83e33b2279d39bf3e848279a722c806b485a47e67c807b946a337bee8942674278859e13292fb"
        )

    it "TC4 25-byte key + 50×0xcd → b0ba4656...":
        # RFC 4231 §4.5: b0ba465637458c6990e5a8c5f61d4af7e576d97ff94b872de76f8050361ee3dba91ca5c11aa25eb4d679275cc5788063a5f19741120c4f2de2adebeb10a298dd
        expect(bytes_to_hex(hmac_sha512_bytes(_tc4_key(), _tc4_data()))).to_equal(
            "b0ba465637458c6990e5a8c5f61d4af7e576d97ff94b872de76f8050361ee3dba91ca5c11aa25eb4d679275cc5788063a5f19741120c4f2de2adebeb10a298dd"
        )

    it "TC6 131×0xaa key + 54-byte data → 80b24263...":
        # RFC 4231 §4.7: 80b24263c7c1a3ebb71493c1dd7be8b49b46d1f41b4aeec1121b013783f8f3526b56d037e05f2598bd0fd2215d6a1e5295e64f73f63f0aec8b915a985d786598
        expect(bytes_to_hex(hmac_sha512_bytes(_tc6_key(), _tc6_data()))).to_equal(
            "80b24263c7c1a3ebb71493c1dd7be8b49b46d1f41b4aeec1121b013783f8f3526b56d037e05f2598bd0fd2215d6a1e5295e64f73f63f0aec8b915a985d786598"
        )

    it "TC7 131×0xaa key + 152-byte data → e37b6a77...":
        # RFC 4231 §4.8: e37b6a775dc87dbaa4dfa9f96e5e3ffddebd71f8867289865df5a32d20cdc944b6022cac3c4982b10d5eeb55c3e4de15134676fb6de0446065c97440fa8c6a58
        expect(bytes_to_hex(hmac_sha512_bytes(_tc7_key(), _tc7_data()))).to_equal(
            "e37b6a775dc87dbaa4dfa9f96e5e3ffddebd71f8867289865df5a32d20cdc944b6022cac3c4982b10d5eeb55c3e4de15134676fb6de0446065c97440fa8c6a58"
        )
