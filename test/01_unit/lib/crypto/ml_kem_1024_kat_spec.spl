# ML-KEM-1024 — NIST FIPS 203 Property Spec
#
# Module-Lattice-Based Key-Encapsulation Mechanism Standard, August 2024.
# Parameter set ML-KEM-1024 (security category 5):
#   k = 4, η1 = 2, η2 = 2, du = 11, dv = 5
#
# Coverage:
#   ITEM-1  ML-KEM-1024 size invariants (ek = 1568, dk = 3168, ct = 1568, ss = 32)
#   ITEM-2  Parameter table (k, η1, η2, du, dv)
#   ITEM-3  Round-trip determinism harness (load-time, top-level)
#
# Per the 768 precedent, end-to-end Encaps/Decaps round-trip is verified at
# module-level top-level (this file's tail) rather than inside an `it` block,
# because the interpreter spec runner reports load-only PASS for `it` blocks
# (see `feedback_compile_mode_false_greens.md`). A top-level call that
# crashes will surface as a load-time error rather than a silent green.
#
# Reference: NIST FIPS 203 — Module-Lattice-Based Key-Encapsulation Mechanism
#            Standard, https://csrc.nist.gov/pubs/fips/203/final §8 Table 3.

use std.spipe.*
use os.crypto.ml_kem_ntt.{ml_kem_q,
    ml_kem_k_1024, ml_kem_eta1_1024, ml_kem_eta2_1024,
    ml_kem_du_1024, ml_kem_dv_1024}
use os.crypto.ml_kem.{ml_kem_1024_ek_bytes, ml_kem_1024_dk_bytes,
    ml_kem_1024_ct_bytes, ml_kem_1024_ss_bytes,
    ml_kem_keygen_1024, ml_kem_encaps_1024, ml_kem_decaps_1024}

# ----------------------------------------------------------------------------
# Top-level deterministic round-trip harness (load-time guard).
# ----------------------------------------------------------------------------

fn _ml_kem_1024_zero32() -> list:
    var v = []
    var i = 0
    while i < 32:
        v.push(0)
        i = i + 1
    v

fn ml_kem_1024_round_trip_check() -> i64:
    val d = _ml_kem_1024_zero32()
    val z = _ml_kem_1024_zero32()
    val m = _ml_kem_1024_zero32()
    val kp = ml_kem_keygen_1024(d, z)
    val ek = kp[0]
    val dk = kp[1]
    val enc = ml_kem_encaps_1024(ek, m)
    val k_send = enc[0]
    val ct = enc[1]
    val k_recv = ml_kem_decaps_1024(dk, ct)
    # Sizes must match Table 3 ML-KEM-1024 row.
    var ok = 1
    if ek.len() != 1568:
        ok = 0
    if dk.len() != 3168:
        ok = 0
    if ct.len() != 1568:
        ok = 0
    if k_send.len() != 32:
        ok = 0
    if k_recv.len() != 32:
        ok = 0
    var i = 0
    while i < 32:
        if k_send.get(i) != k_recv.get(i):
            ok = 0
        i = i + 1
    ok

val ml_kem_1024_round_trip_ok = ml_kem_1024_round_trip_check()

describe "ML-KEM-1024 size invariants (FIPS 203 §8 Table 3)":

    it "ITEM-1a ek = 1568 bytes":
        ml_kem_1024_ek_bytes().to_equal(1568)

    it "ITEM-1b dk = 3168 bytes":
        ml_kem_1024_dk_bytes().to_equal(3168)

    it "ITEM-1c ciphertext = 1568 bytes":
        ml_kem_1024_ct_bytes().to_equal(1568)

    it "ITEM-1d shared secret = 32 bytes":
        ml_kem_1024_ss_bytes().to_equal(32)

describe "ML-KEM-1024 parameter table (FIPS 203 §2.3 Table 2)":

    it "ITEM-2a k = 4":
        ml_kem_k_1024().to_equal(4)

    it "ITEM-2b η1 = 2":
        ml_kem_eta1_1024().to_equal(2)

    it "ITEM-2c η2 = 2":
        ml_kem_eta2_1024().to_equal(2)

    it "ITEM-2d du = 11":
        ml_kem_du_1024().to_equal(11)

    it "ITEM-2e dv = 5":
        ml_kem_dv_1024().to_equal(5)

    it "ITEM-2f q = 3329 (shared)":
        ml_kem_q().to_equal(3329)

describe "ML-KEM-1024 deterministic round-trip (top-level harness)":

    it "ITEM-3 KeyGen + Encaps + Decaps round-trip with d = z = m = 0^32":
        # The actual round-trip computation runs at file load via
        # `ml_kem_1024_round_trip_check()`. This `it` block records the
        # outcome flag; if loading succeeded with a wrong shared secret,
        # the flag is 0 and this assertion fails.
        ml_kem_1024_round_trip_ok.to_equal(1)
