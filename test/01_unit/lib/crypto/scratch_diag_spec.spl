use std.spec.*
use std.common.crypto.aes_gcm.{aes128_encrypt_block as std_enc, aes128_key_expansion as std_ke}
use os.crypto.aes128_gcm.{aes128_encrypt_block as os_enc, aes128_key_expansion as os_ke}

fn _fips_key() -> [u8]:
    [0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07,0x08,0x09,0x0a,0x0b,0x0c,0x0d,0x0e,0x0f]

fn _fips_pt() -> [u8]:
    [0x00,0x11,0x22,0x33,0x44,0x55,0x66,0x77,0x88,0x99,0xaa,0xbb,0xcc,0xdd,0xee,0xff]

fn _fips_ct() -> [u8]:
    [0x69,0xc4,0xe0,0xd8,0x6a,0x7b,0x04,0x30,0xd8,0xcd,0xb7,0x80,0x70,0xb4,0xc5,0x5a]

describe "AES primitive diagnostic":
    it "std AES FIPS-197":
        val ct = std_enc(_fips_pt(), std_ke(_fips_key()))
        expect(ct).to_equal(_fips_ct())
    it "os AES FIPS-197":
        val ct = os_enc(_fips_pt(), os_ke(_fips_key()))
        expect(ct).to_equal(_fips_ct())
