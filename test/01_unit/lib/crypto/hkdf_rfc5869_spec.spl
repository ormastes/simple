# HKDF-SHA-256 RFC 5869 Appendix A Test Vectors
#
# Tests the pure-Simple HKDF implementation in src/lib/common/crypto/hkdf.spl
# against the 3 canonical reference vectors from RFC 5869 Appendix A.
#
# A.1 — Basic SHA-256 (short inputs, explicit salt)
# A.2 — Longer SHA-256 inputs (80-byte IKM/salt/info)
# A.3 — SHA-256 with empty salt and empty info
#
# Boundary: L=0 returns empty list; L=1 first byte of T(1).
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. MAC assertions only fire under compiled/native mode.

use std.spipe.*
use std.crypto.hkdf.{hkdf_extract_sha256, hkdf_expand_sha256, hkdf_sha256}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# A.1 inputs: IKM=22×0x0b, salt=13 bytes, info=10 bytes, L=42
# ============================================================================

fn _a1_ikm() -> list:
    var out = []
    var i = 0
    while i < 22:
        out.push(0x0b)
        i = i + 1
    out

fn _a1_salt() -> list:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]

fn _a1_info() -> list:
    [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7, 0xf8, 0xf9]

# ============================================================================
# A.2 inputs: IKM=0x00..0x4f (80 bytes), salt=0x60..0xaf (80 bytes),
#             info=0xb0..0xff (80 bytes), L=82
# ============================================================================

fn _a2_ikm() -> list:
    var out = []
    var i = 0
    while i < 80:
        out.push(i)
        i = i + 1
    out

fn _a2_salt() -> list:
    var out = []
    var i = 0
    while i < 80:
        out.push(0x60 + i)
        i = i + 1
    out

fn _a2_info() -> list:
    var out = []
    var i = 0
    while i < 80:
        out.push(0xb0 + i)
        i = i + 1
    out

# ============================================================================
# A.3 inputs: IKM=22×0x0b, salt=empty, info=empty, L=42
# ============================================================================

fn _a3_ikm() -> list:
    var out = []
    var i = 0
    while i < 22:
        out.push(0x0b)
        i = i + 1
    out

# ============================================================================
# RFC 5869 Appendix A — SHA-256 vectors
# ============================================================================

describe "HKDF-SHA-256 RFC 5869 Appendix A vectors":

    it "A.1 PRK — explicit salt → 077709362c...":
        # RFC 5869 §A.1 PRK = 077709362c2e32df0ddc3f0dc47bba6390b6c73bb50f9c3122ec844ad7c2b3e5
        expect(bytes_to_hex(hkdf_extract_sha256(_a1_salt(), _a1_ikm()))).to_equal(
            "077709362c2e32df0ddc3f0dc47bba6390b6c73bb50f9c3122ec844ad7c2b3e5"
        )

    it "A.1 OKM — L=42 → 3cb25f25...":
        # RFC 5869 §A.1 OKM (42 bytes)
        # 3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865
        expect(bytes_to_hex(hkdf_sha256(_a1_salt(), _a1_ikm(), _a1_info(), 42))).to_equal(
            "3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865"
        )

    it "A.3 PRK — empty salt → 19ef24a3...":
        # RFC 5869 §A.3 PRK = 19ef24a32c717b167f33a91d6f648bdf96596776afdb6377ac434c1c293ccb04
        expect(bytes_to_hex(hkdf_extract_sha256([], _a3_ikm()))).to_equal(
            "19ef24a32c717b167f33a91d6f648bdf96596776afdb6377ac434c1c293ccb04"
        )

    it "A.3 OKM — empty salt + empty info L=42 → 8da4e775...":
        # RFC 5869 §A.3 OKM (42 bytes)
        # 8da4e775a563c18f715f802a063c5a31b8a11f5c5ee1879ec3454e5f3c738d2d9d201395faa4b61a96c8
        expect(bytes_to_hex(hkdf_sha256([], _a3_ikm(), [], 42))).to_equal(
            "8da4e775a563c18f715f802a063c5a31b8a11f5c5ee1879ec3454e5f3c738d2d9d201395faa4b61a96c8"
        )

    it "A.2 PRK — long inputs → 06a6b88c...":
        # RFC 5869 §A.2 PRK = 06a6b88c5853361a06104c9ceb35b45cef760014904671014a193f40c15fc244
        expect(bytes_to_hex(hkdf_extract_sha256(_a2_salt(), _a2_ikm()))).to_equal(
            "06a6b88c5853361a06104c9ceb35b45cef760014904671014a193f40c15fc244"
        )

    it "A.2 OKM — long inputs L=82 → b11e398d...":
        # RFC 5869 §A.2 OKM (82 bytes)
        # b11e398dc80327a1c8e7f78c596a49344f012eda2d4efad8a050cc4c19afa97c
        # 59045a99cac7827271cb41c65e590e09da3275600c2f09b8367793a9aca3db71
        # cc30c58179ec3e87c14c01d5c1f3434f1d87
        expect(bytes_to_hex(hkdf_sha256(_a2_salt(), _a2_ikm(), _a2_info(), 82))).to_equal(
            "b11e398dc80327a1c8e7f78c596a49344f012eda2d4efad8a050cc4c19afa97c59045a99cac7827271cb41c65e590e09da3275600c2f09b8367793a9aca3db71cc30c58179ec3e87c14c01d5c1f3434f1d87"
        )

# ============================================================================
# Boundary tests
# ============================================================================

describe "HKDF-SHA-256 boundary cases":

    it "L=0 returns empty list":
        expect(hkdf_sha256(_a1_salt(), _a1_ikm(), _a1_info(), 0).len()).to_equal(0)

    it "L=1 returns exactly 1 byte":
        expect(hkdf_sha256(_a1_salt(), _a1_ikm(), _a1_info(), 1).len()).to_equal(1)

    it "L exceeding 255*32 returns empty list":
        expect(hkdf_sha256(_a1_salt(), _a1_ikm(), _a1_info(), 8161).len()).to_equal(0)
