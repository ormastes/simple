use std.nogc_async_immut.persistent_trie.trie_node.{trie_set, trie_get}

describe "nogc_async_immut trie node native backend":
    it "stores and retrieves shared-prefix nodes":
        val root = trie_set(nil, "app", 1, 0)
        val next = trie_set(root, "apple", 2, 0)

        expect(trie_get(next, "app", 0)).to_equal(1)
        expect(trie_get(next, "apple", 0)).to_equal(2)
