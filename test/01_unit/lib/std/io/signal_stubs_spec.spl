use std.nogc_sync_mut.io.signal_stubs.{rt_signal_handler_install, signal_dispatch_pending}
use std.nogc_sync_mut.io.process_ops.{process_run_timeout}
use std.nogc_sync_mut.io.env_ops.{host_os}
use std.io_runtime.{getpid}

var _signal_marker = 0

fn _mark_first_signal():
    _signal_marker = 1

fn _mark_replacement_signal():
    _signal_marker = 2

describe "signal callback registry":
    it "dispatches the replacement callback once":
        if host_os() == "windows":
            return
        expect(rt_signal_handler_install(2, _mark_first_signal)).to_equal(true)
        expect(rt_signal_handler_install(2, _mark_replacement_signal)).to_equal(true)
        val (_out, _err, exit_code) = process_run_timeout(
            "/bin/kill", ["-INT", "{getpid()}"], 1000
        )
        expect(exit_code).to_equal(0)
        signal_dispatch_pending()
        expect(_signal_marker).to_equal(2)
