use std.spec
use std.path.{join2, path_join, normalize, relative_to}

describe "std.path two-segment join", tag: ["only-compiled"]:
    it "joins without duplicating or dropping separators":
        expect(join2("left", "right")).to_equal("left/right")
        expect(join2("left/", "/right")).to_equal("left/right")
        expect(join2("left/", "right")).to_equal("left/right")
        expect(join2("left", "/right")).to_equal("left/right")
        expect(join2("", "right")).to_equal("right")
        expect(join2("left", "")).to_equal("left")

    it "keeps array-backed path operations out of the join alias":
        expect(path_join(["left", "right", "file.spl"])).to_equal("left/right/file.spl")
        expect(normalize("left/./right/../file.spl")).to_equal("left/file.spl")
        expect(relative_to("/repo/src/file.spl", "/repo")).to_equal("src/file.spl")
