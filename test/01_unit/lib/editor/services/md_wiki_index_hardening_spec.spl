# md_wiki_index hardening spec
#
# Covers: malformed refs, path-traversal targets, tag edge cases (code fences,
# bare #, nested/dashed tags), unterminated brackets, self-links, duplicate links,
# UTF-8 targets, very long targets, whitespace-only targets, empty/frontmatter-only docs.

use std.spec
use std.editor.services.md_wiki_index.*

describe "malformed link refs: empty anchor":

    it "[[a#]] empty anchor is safe and indexes a":
        val parsed = md_wiki_parse_link_target("a#")
        expect(parsed.0).to_equal("a")

    it "[[a#b#c]] double hash: target is a, no crash":
        val parsed = md_wiki_parse_link_target("a#b#c")
        expect(parsed.0).to_equal("a")

    it "[[#anchor-only]] yields empty target and is not indexed":
        val doc = md_wiki_document("p.md", "see [[#intro]]")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len()).to_equal(0)

describe "malformed link refs: empty alias":

    it "[[a|]] empty alias: target is a, display is empty":
        val parsed = md_wiki_parse_link_target("a|")
        expect(parsed.0).to_equal("a")
        expect(parsed.1).to_equal("")

    it "[[a|b|c]] multiple pipes: target is a, display is b|c or b":
        val parsed = md_wiki_parse_link_target("a|b|c")
        expect(parsed.0).to_equal("a")

describe "malformed link refs: whitespace-only target":

    it "[[   ]] whitespace-only target is not indexed":
        val doc = md_wiki_document("p.md", "[[   ]]")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len()).to_equal(0)

    it "parse whitespace-only target returns empty string":
        val parsed = md_wiki_parse_link_target("   ")
        expect(parsed.0).to_equal("")

describe "path-traversal targets: safe indexing, no crash":

    it "[[../../../etc/passwd]] is indexed with traversal target, no crash":
        val doc = md_wiki_document("p.md", "[[../../../etc/passwd]]")
        val links = md_wiki_extract_links(doc, [doc])
        # Safe: indexed (non-empty target) or not, but must not crash
        expect(links.len() >= 0).to_equal(true)

    it "[[/absolute/path]] is safely parsed":
        val parsed = md_wiki_parse_link_target("/absolute/path")
        expect(parsed.0.len() >= 0).to_equal(true)

    it "[[back\\slash]] backslash target is safely parsed":
        val parsed = md_wiki_parse_link_target("back\\slash")
        expect(parsed.0.len() >= 0).to_equal(true)

    it "index_documents with traversal target does not crash":
        val doc = md_wiki_document("p.md", "[[../secret]]")
        val idx = md_wiki_index_documents([doc])
        expect(idx.links.len() >= 0).to_equal(true)

describe "tags: bare hash and edge cases":

    it "bare # alone is not indexed as a tag":
        val doc = md_wiki_document("p.md", "word # word")
        val tags = md_wiki_extract_tags(doc)
        # bare # followed by space is not a tag
        var found = false
        for t in tags:
            if t.tag == "":
                found = true
        expect(found).to_equal(false)

    it "# at end of line is not indexed":
        val doc = md_wiki_document("p.md", "line #")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(0)

    it "#tag123 alphanumeric tag is indexed":
        val doc = md_wiki_document("p.md", "hello #tag123 world")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(1)

    it "#tag-with-dashes is indexed":
        val doc = md_wiki_document("p.md", "#tag-with-dashes")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(1)

    it "#nested/tag is indexed":
        val doc = md_wiki_document("p.md", "#nested/tag")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(1)

describe "tags: code fence exclusion":

    it "tag inside fenced code block is NOT indexed":
        val doc = md_wiki_document("p.md", "```\n#notag\n```")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(0)

    it "tag inside tilde fenced block is NOT indexed":
        val doc = md_wiki_document("p.md", "~~~\n#notag\n~~~")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(0)

    it "tag after closing fence is indexed normally":
        val doc = md_wiki_document("p.md", "```\n#skip\n```\n#real")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(1)

    it "tag before fence is indexed, tag inside is not":
        val doc = md_wiki_document("p.md", "#before\n```\n#inside\n```")
        val tags = md_wiki_extract_tags(doc)
        expect(tags.len()).to_equal(1)

describe "unterminated brackets":

    it "unterminated [[ at end of file yields no links":
        val doc = md_wiki_document("p.md", "before [[unterminated")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len()).to_equal(0)

    it "unterminated ![[ at end of file yields no embeds":
        val doc = md_wiki_document("p.md", "before ![[unterminated")
        val embeds = md_wiki_extract_embeds(doc, [doc])
        expect(embeds.len()).to_equal(0)

    it "[[ spanning two lines yields no link (scanner is line-based)":
        val doc = md_wiki_document("p.md", "[[start\nend]]")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len()).to_equal(0)

    it "lone [[ with no closing bracket does not crash":
        val doc = md_wiki_document("p.md", "[[")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len()).to_equal(0)

describe "self-links and duplicate links":

    it "self-link [[self]] on page self.md is indexed":
        val doc = md_wiki_document("self.md", "# Self\n[[self]]")
        val idx = md_wiki_index_documents([doc])
        expect(idx.links.len()).to_equal(1)

    it "self-link appears as backlink of own page":
        val doc = md_wiki_document("self.md", "# Self\n[[self]]")
        val idx = md_wiki_index_documents([doc])
        val backs = md_wiki_backlinks(idx, "self.md")
        expect(backs.len()).to_equal(1)

    it "duplicate links to same target are both indexed":
        val doc = md_wiki_document("p.md", "[[alpha]] and [[alpha]]")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len()).to_equal(2)

    it "graph edges contain one entry per link occurrence":
        val doc = md_wiki_document("p.md", "[[alpha]] and [[alpha]]")
        val idx = md_wiki_index_documents([doc])
        expect(idx.graph_edges.len()).to_equal(2)

describe "UTF-8 and long targets":

    it "UTF-8 multi-byte target is safely parsed without crash":
        val parsed = md_wiki_parse_link_target("日本語ノート")
        expect(parsed.0.len() >= 0).to_equal(true)

    it "UTF-8 target in document is indexed safely":
        val doc = md_wiki_document("p.md", "[[日本語ノート]]")
        val links = md_wiki_extract_links(doc, [doc])
        expect(links.len() >= 0).to_equal(true)

    it "very long target name (1000 chars) is safely parsed":
        val long_name = ""
        val parsed = md_wiki_parse_link_target(long_name)
        expect(parsed.0.len() > 0).to_equal(true)

describe "empty and frontmatter-only documents":

    it "empty document yields empty index, no crash":
        val doc = md_wiki_document("p.md", "")
        val idx = md_wiki_index_documents([doc])
        expect(idx.links.len()).to_equal(0)
        expect(idx.tags.len()).to_equal(0)

    it "frontmatter-only document yields no links or tags":
        val doc = md_wiki_document("p.md", "---\ntitle: Test\n---")
        val idx = md_wiki_index_documents([doc])
        expect(idx.links.len()).to_equal(0)
        expect(idx.tags.len()).to_equal(0)

    it "frontmatter with tags key indexes those tags":
        val doc = md_wiki_document("p.md", "---\ntags: foo, bar\n---")
        val idx = md_wiki_index_documents([doc])
        expect(idx.tags.len()).to_equal(2)

    it "document with only whitespace does not crash":
        val doc = md_wiki_document("p.md", "   \n  \n   ")
        val idx = md_wiki_index_documents([doc])
        expect(idx.links.len()).to_equal(0)
