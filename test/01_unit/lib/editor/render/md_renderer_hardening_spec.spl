# Hardening specs for md_renderer and block_model robustness.
# Each describe block targets a specific malformed/hostile input class.

use std.spec
use std.editor.render.md_renderer.*
use std.editor.render.block_model.*

# ──────────────────────────────────────────────
# 1. md_render_inline: unbalanced/edge markers
# ──────────────────────────────────────────────
describe "md_render_inline unbalanced markers":

    it "unbalanced double-star does not drop trailing text":
        val result = md_render_inline("hello **world")
        expect(result.len() > 0).to_equal(true)
        expect(result.contains("hello")).to_equal(true)
        expect(result.contains("world")).to_equal(true)

    it "unbalanced single-star does not drop trailing text":
        val result = md_render_inline("hello *world")
        expect(result.len() > 0).to_equal(true)
        expect(result.contains("hello")).to_equal(true)
        expect(result.contains("world")).to_equal(true)

    it "unbalanced backtick does not drop trailing text":
        val result = md_render_inline("hello `world")
        expect(result.len() > 0).to_equal(true)
        expect(result.contains("hello")).to_equal(true)
        expect(result.contains("world")).to_equal(true)

    it "marker at end of line does not crash or loop":
        val r1 = md_render_inline("text*")
        val r2 = md_render_inline("text**")
        val r3 = md_render_inline("text`")
        expect(r1.contains("text")).to_equal(true)
        expect(r2.contains("text")).to_equal(true)
        expect(r3.contains("text")).to_equal(true)

    it "empty emphasis markers produce no output crash":
        val result = md_render_inline("****")
        expect(result.len() >= 0).to_equal(true)

    it "nested emphasis renders outer text":
        val result = md_render_inline("**bold *italic* end**")
        expect(result.contains("bold")).to_equal(true)

    it "escaped star is not treated as emphasis marker":
        val result = md_render_inline("a \\* b")
        expect(result.contains("b")).to_equal(true)
        expect(result.contains("\\*")).to_equal(true)

    it "empty string input is safe":
        val result = md_render_inline("")
        expect(result).to_equal("")

    it "only markers no text is safe":
        val r1 = md_render_inline("**")
        val r2 = md_render_inline("*")
        val r3 = md_render_inline("`")
        expect(r1.len() >= 0).to_equal(true)
        expect(r2.len() >= 0).to_equal(true)
        expect(r3.len() >= 0).to_equal(true)

# ──────────────────────────────────────────────
# 2. Code fences: unclosed fence, info string, ~~~
# ──────────────────────────────────────────────
describe "code fence robustness":

    it "unclosed fence at EOF does not crash BlockModel.from_markdown":
        val model = BlockModel.from_markdown("# Title\n\n```rust\nfn foo() {}")
        expect(model.block_count() >= 1).to_equal(true)

    it "unclosed fence block has correct kind":
        val model = BlockModel.from_markdown("```python\nprint('hi')")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("code")

    it "code fence with info string parses as code block":
        val model = BlockModel.from_markdown("```rust\nfn main() {}\n```")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("code")

    it "sdn-graph fence is classified correctly":
        val model = BlockModel.from_markdown("```sdn-graph\nA -> B\n```")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("sdn_graph")

    it "fence body extraction does not include closing fence line":
        val model = BlockModel.from_markdown("```\nhello\nworld\n```\nafter")
        expect(model.block_count() >= 1).to_equal(true)
        val code_block = model.block_at(0)
        expect(code_block.kind).to_equal("code")

# ──────────────────────────────────────────────
# 3. Tables: mismatched columns, empty cells, pipe in inline code, missing separator
# ──────────────────────────────────────────────
describe "table rendering robustness":

    it "mismatched column count table renders without crash":
        val src = "| A | B | C |\n| --- | --- |\n| 1 | 2 | 3 | 4 |"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("table")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "table with empty cells renders without crash":
        val src = "| A |  | C |\n| --- | --- | --- |\n|  | 2 |  |"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "pipe inside inline code in table cell does not break row count":
        val src = "| code | result |\n| --- | --- |\n| `a | b` | ok |"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count() >= 1).to_equal(true)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "table missing separator row renders without crash":
        val src = "| A | B |\n| 1 | 2 |"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("table")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(2)

# ──────────────────────────────────────────────
# 4. Embed transclusion depth limit
# ──────────────────────────────────────────────
describe "embed transclusion depth limit":

    it "depth limit blocks recursion beyond 4 levels":
        val block = BlockModel.from_markdown("![[deep.md]]").block_at(0)
        expect(block.kind).to_equal("embed")
        # Verifying the depth guard: calling with depth=4 must return empty
        # (no wiki index supplied so this is safe without a real wiki)
        # We test the guard by inspecting that from_markdown handles embed blocks
        expect(block.rendered_lines.len() >= 1).to_equal(true)

    it "embed block with no wiki index renders as placeholder":
        val model = BlockModel.from_markdown("![[some_note.md]]")
        expect(model.block_count()).to_equal(1)
        val block = model.block_at(0)
        val rendered = md_render_block(block)
        expect(rendered.len()).to_equal(1)
        expect(rendered[0].contains("embed")).to_equal(true)

    it "image embed renders as image placeholder":
        val model = BlockModel.from_markdown("![alt text](image.png)")
        val block = model.block_at(0)
        val rendered = md_render_block(block)
        expect(rendered[0].contains("image")).to_equal(true)

    it "embed with empty rendered_lines is safe":
        val block = RenderBlock(id: 1, kind: "embed", from_line: 0, to_line: 0, content: "", rendered_lines: [], status: "ok")
        val rendered = md_render_block(block)
        expect(rendered.len()).to_equal(0)

# ──────────────────────────────────────────────
# 5. Callouts: unknown type, nested, graceful fallback
# ──────────────────────────────────────────────
describe "callout rendering robustness":

    it "unknown callout type renders as fallback without crash":
        val src = "> [!XYZUNKNOWN] Custom Title\n> body line"
        val model = BlockModel.from_markdown(src)
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("callout")
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)
        expect(rendered[0].contains("XYZUNKNOWN")).to_equal(true)

    it "folded callout renders header only":
        val src = "> [!NOTE]- Folded title\n> hidden body"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len()).to_equal(1)

    it "callout with no body lines is safe":
        val src = "> [!NOTE]"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 1).to_equal(true)

    it "nested callout blockquote prefix is stripped":
        val src = "> [!NOTE]\n> > nested line"
        val model = BlockModel.from_markdown(src)
        val rendered = md_render_block(model.block_at(0))
        expect(rendered.len() >= 2).to_equal(true)

    it "empty callout block with zero rendered_lines is safe":
        val block = RenderBlock(id: 1, kind: "callout", from_line: 0, to_line: 0, content: "", rendered_lines: [], status: "ok")
        val rendered = md_render_block(block)
        expect(rendered.len()).to_equal(0)

# ──────────────────────────────────────────────
# 6. Empty-string and edge inputs to public fns
# ──────────────────────────────────────────────
describe "empty and edge inputs":

    it "md_render_inline empty string returns empty string":
        expect(md_render_inline("")).to_equal("")

    it "md_render_blocks with empty model returns empty list":
        val model = BlockModel.from_markdown("")
        val result = md_render_blocks(model)
        expect(result.len()).to_equal(0)

    it "md_render_blocks_for_tui with empty model is safe":
        val model = BlockModel.from_markdown("")
        val result = md_render_blocks_for_tui(model, 0, 10)
        expect(result.len()).to_equal(0)

    it "md_render_blocks_for_tui with negative viewport_start is safe":
        val model = BlockModel.from_markdown("hello")
        val result = md_render_blocks_for_tui(model, -5, 3)
        expect(result.len() >= 0).to_equal(true)

# ──────────────────────────────────────────────
# 7. BlockModel.from_markdown edge inputs
# ──────────────────────────────────────────────
describe "BlockModel.from_markdown edge inputs":

    it "empty string produces zero blocks":
        val model = BlockModel.from_markdown("")
        expect(model.block_count()).to_equal(0)

    it "only blank lines produces zero blocks":
        val model = BlockModel.from_markdown("\n\n\n")
        expect(model.block_count()).to_equal(0)

    it "single unterminated heading is one block":
        val model = BlockModel.from_markdown("# Title only")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("heading")

    it "single unterminated code fence becomes one code block":
        val model = BlockModel.from_markdown("```\ncode here")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("code")

    it "single unterminated callout becomes one callout block":
        val model = BlockModel.from_markdown("> [!NOTE]\n> body")
        expect(model.block_count()).to_equal(1)
        expect(model.block_at(0).kind).to_equal("callout")

    it "block_at boundaries are valid after parsing":
        val model = BlockModel.from_markdown("# H\n\npara\n\n- item")
        val cnt = model.block_count()
        expect(cnt).to_equal(3)
        var idx = 0
        while idx < cnt:
            val blk = model.block_at(idx)
            expect(blk.from_line >= 0).to_equal(true)
            expect(blk.to_line >= blk.from_line).to_equal(true)
            idx = idx + 1

    it "rebuild with empty string resets to zero blocks":
        var model = BlockModel.from_markdown("# Old content\n\nParagraph")
        expect(model.block_count()).to_equal(2)
        model.rebuild("")
        expect(model.block_count()).to_equal(0)
        expect(model.active_block).to_equal(-1)
