use std.spec
use std.gc_sync_mut.terminal.credential.{credential_resolve, credential_is_encrypted}
use std.gc_sync_mut.terminal.credential.store.{credential_is_encrypted as store_credential_is_encrypted}
use std.gc_sync_mut.terminal.credential.config_parser.{find_terminal_by_name, find_power_by_name}

describe "gc_sync_mut terminal credential facade":

    it "re-exports root, store, and parser helpers without I/O":
        expect(credential_resolve("plain-secret")).to_equal("plain-secret")
        expect(credential_is_encrypted("encrypted:abc123")).to_equal(true)
        expect(store_credential_is_encrypted("plain-secret")).to_equal(false)
        expect(find_terminal_by_name([], "missing")).to_be_nil()
        expect(find_power_by_name([], "missing")).to_be_nil()
