use std.spec
use std.gc_sync_mut.db.dbfs_engine.meta_store.{MetaStore}
use std.gc_sync_mut.db.dbfs_engine.schema.{InodeRow}

describe "gc_sync_mut DBFS meta store facade":

    it "re-exports the hosted metadata journal backend":
        var store = MetaStore.create("/tmp/simple_dbfs_meta_facade_gc_sync")
        val row = InodeRow(
            ino_id: 1, gen: 1, mode: 420,
            uid: 1000, gid: 1000, link_count: 1, size: 3,
            mtime: 1, ctime: 1, flags: 0
        )
        expect(store.write_inode(row)).to_equal(true)
        val entries = store.replay_journal()
        expect(entries.len()).to_equal(1)
        expect(store.last_checkpoint_gen()).to_equal(0)
