use std.spec
use std.gc_sync_mut.mcp_sdk.core.{js as package_js}
use std.gc_sync_mut.mcp_sdk.core.json.{jp, js, jo1}
use std.gc_sync_mut.mcp_sdk.core.jsonrpc.{jsonrpc_result}

describe "gc_sync_mut MCP SDK core facades":

    it "re-exports JSON and JSON-RPC helpers":
        val obj = jo1(jp("name", js("tool")))
        val result = jsonrpc_result(package_js("1"), obj)

        expect(obj).to_contain("\"name\":\"tool\"")
        expect(result).to_contain("\"id\":\"1\"")
