use std.spec
use std.gc_sync_mut.src.time.{now_micros, now_nanos, now_ms, now}

describe "gc_sync_mut src time facade":

    it "re-exports time read helpers":
        expect(now_micros() > 0).to_equal(true)
        expect(now_nanos() > 0).to_equal(true)
        expect(now_ms() > 0).to_equal(true)
        expect(now() > 0.0).to_equal(true)
