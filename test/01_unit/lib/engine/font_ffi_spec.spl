"""
Engine Font FFI Types Tests

Tests FontHandle, GlyphMetrics, and GlyphBitmap struct construction and methods.
Does not test FFI extern functions (those require runtime).
"""

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.io.font_ffi.{FontHandle, GlyphMetrics, GlyphBitmap, font_blob_sha256_hex}

extern fn rt_file_read_text(path: text) -> text

describe "FontHandle":
    it "constructs with handle and path":
        val font = FontHandle(handle: 42, generation: 0, path: "/fonts/test.ttf")
        expect(font.handle).to_equal(42)
        expect(font.path).to_equal("/fonts/test.ttf")

    it "is_valid returns true for positive handle":
        val font = FontHandle(handle: 1, generation: 0, path: "test.ttf")
        expect(font.is_valid()).to_equal(true)

    it "is_valid returns false for zero handle":
        val font = FontHandle(handle: 0, generation: 0, path: "test.ttf")
        expect(font.is_valid()).to_equal(false)

    it "is_valid returns false for negative handle":
        val font = FontHandle(handle: -1, generation: 0, path: "test.ttf")
        expect(font.is_valid()).to_equal(false)

describe "GlyphMetrics":
    it "constructs with all fields":
        val metrics = GlyphMetrics(width: 12, height: 16, advance: 14, codepoint: 65)
        expect(metrics.width).to_equal(12)
        expect(metrics.height).to_equal(16)
        expect(metrics.advance).to_equal(14)
        expect(metrics.codepoint).to_equal(65)

    it "stores zero metrics":
        val metrics = GlyphMetrics(width: 0, height: 0, advance: 0, codepoint: 32)
        expect(metrics.width).to_equal(0)
        expect(metrics.height).to_equal(0)
        expect(metrics.codepoint).to_equal(32)

describe "GlyphBitmap":
    it "constructs with dimensions, bitmap handle, and metrics":
        val metrics = GlyphMetrics(width: 8, height: 10, advance: 9, codepoint: 65)
        val bitmap = GlyphBitmap(bitmap_handle: 99, width: 8, height: 10, metrics: metrics)
        expect(bitmap.bitmap_handle).to_equal(99)
        expect(bitmap.width).to_equal(8)
        expect(bitmap.height).to_equal(10)
        expect(bitmap.metrics.codepoint).to_equal(65)

    it "is_valid returns true for positive handle and dimensions":
        val metrics = GlyphMetrics(width: 8, height: 10, advance: 9, codepoint: 65)
        val bitmap = GlyphBitmap(bitmap_handle: 99, width: 8, height: 10, metrics: metrics)
        expect(bitmap.is_valid()).to_equal(true)

    it "is_valid returns false for zero width":
        val metrics = GlyphMetrics(width: 0, height: 10, advance: 0, codepoint: 32)
        val bitmap = GlyphBitmap(bitmap_handle: 99, width: 0, height: 10, metrics: metrics)
        expect(bitmap.is_valid()).to_equal(false)

    it "is_valid returns false for zero height":
        val metrics = GlyphMetrics(width: 8, height: 0, advance: 9, codepoint: 65)
        val bitmap = GlyphBitmap(bitmap_handle: 99, width: 8, height: 0, metrics: metrics)
        expect(bitmap.is_valid()).to_equal(false)

    it "is_valid returns false for both dimensions zero":
        val metrics = GlyphMetrics(width: 0, height: 0, advance: 0, codepoint: 0)
        val bitmap = GlyphBitmap(bitmap_handle: 99, width: 0, height: 0, metrics: metrics)
        expect(bitmap.is_valid()).to_equal(false)

    it "is_valid returns false for non-positive bitmap handle":
        val metrics = GlyphMetrics(width: 8, height: 10, advance: 9, codepoint: 65)
        val bitmap = GlyphBitmap(bitmap_handle: -1, width: 8, height: 10, metrics: metrics)
        expect(bitmap.is_valid()).to_equal(false)

describe "font loader owned-byte handoff":
    it "hashes the selected blob with SHA-256":
        val empty: [u8] = []
        expect(font_blob_sha256_hex(empty)).to_equal("e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")

    it "loads exact selected paths from validated bytes and unmanaged paths by legacy ABI":
        val direct = rt_file_read_text("src/lib/nogc_sync_mut/io/font_sffi.spl")
        val rasterizer = rt_file_read_text("src/lib/nogc_sync_mut/sffi/spl_fonts.spl")
        expect(direct).to_contain("val blob = file_read_bytes(path)")
        expect(direct).to_contain("val selected = selected_font_asset_candidate_for_path(path)\n    if selected != nil:\n        val validation = validate_selected_font_asset(path, blob, font_blob_sha256_hex(blob))")
        expect(direct).to_contain("val h = if selected != nil:\n        rt_font_load_bytes(rt_array_data_ptr_u8(blob), blob.len())\n    else:\n        rt_font_load(path)")
        expect(direct.index_of("validate_selected_font_asset(path, blob") < direct.index_of("rt_font_load_bytes(rt_array_data_ptr_u8(blob)")).to_equal(true)
        expect(rasterizer).to_contain("val blob = file_read_bytes(ttf_path)")
        expect(rasterizer).to_contain("val selected = selected_font_asset_candidate_for_path(ttf_path)\n        if val candidate = selected:\n            val validation = validate_selected_font_asset(ttf_path, blob, candidate.sha256)")
        expect(rasterizer.index_of("validate_selected_font_asset(ttf_path, blob") < rasterizer.index_of("val h = spl_dlopen(dylib_path)")).to_equal(true)
        expect(rasterizer).to_contain("val init_fp = if selected != nil:\n            spl_dlsym(h, \"rt_fonts_init_verified_bytes\")\n        else:\n            spl_dlsym(h, \"rt_fonts_init\")")
        expect(rasterizer).to_contain("init_args.push(rt_array_data_ptr_u8(blob))\n            init_args.push(blob.len())\n            init_args.push(rt_array_data_ptr_u8(expected_digest_bytes))\n            init_args.push(expected_digest_bytes.len())")
        expect(rasterizer).to_contain("spl_wffi_call_i64(init_fp, init_args, 4)")
        expect(rasterizer).to_contain("spl_wffi_call_i64(init_fp, init_args, 2)")
        expect(rasterizer).to_contain("var font_cache_identity = \"\"")
        expect(rasterizer).to_contain("font_cache_identity = \"sha256={candidate.sha256};axes={candidate.default_axes}\"")
        expect(rasterizer).to_contain("font_cache_identity: font_cache_identity")
        expect(rasterizer).to_contain("val loaded_generation = spl_wffi_call_i64(generation_fp, generation_args, 0)")
        expect(rasterizer).to_contain("loaded_generation: loaded_generation")
        expect(rasterizer).to_contain("fn is_current() -> bool:\n        self.cache_identity_snapshot().0 > 0")
        expect(rasterizer).to_contain("fn cache_identity_snapshot() -> (i64, text):")
        expect(rasterizer).to_contain("val generation_before = self.generation()")
        expect(rasterizer).to_contain("generation_before != self.loaded_generation")
        expect(rasterizer).to_contain("val identity = self.font_cache_identity")
        expect(rasterizer).to_contain("val generation_after = self.generation()")
        expect(rasterizer).to_contain("generation_after != self.loaded_generation")
        expect(rasterizer).to_contain("return (0, \"\")")
        expect(rasterizer.index_of("val generation_before = self.generation()") < rasterizer.index_of("val identity = self.font_cache_identity")).to_equal(true)
        expect(rasterizer.index_of("val identity = self.font_cache_identity") < rasterizer.index_of("val generation_after = self.generation()")).to_equal(true)
        val renderer = rt_file_read_text("src/lib/nogc_sync_mut/text_layout/font_renderer.spl")
        expect(renderer).to_contain("active_rasterizer.cache_identity_snapshot()")
        expect(renderer.contains("active_rasterizer.generation()\n            font_identity = active_rasterizer.cache_identity()")).to_equal(false)
        expect(rasterizer).to_contain("if not self.is_current():\n            return nil")
        expect(rasterizer).to_contain("if not self.is_current():\n            return false")
        expect(rasterizer).to_contain("if self.is_current(): glyphs else: []")
        expect(rasterizer).to_contain("if self.is_current(): result else: 0")
        expect(rasterizer.contains("file_hash_sha256(ttf_path)")).to_equal(false)
