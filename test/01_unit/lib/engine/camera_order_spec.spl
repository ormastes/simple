# Camera Order Component Tests
#
# Tests for camera render order sorting and draw precedence logic.

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.engine.component.camera.{CameraData}
use std.nogc_sync_mut.engine.component.camera3d.{Camera3DData}
use std.nogc_sync_mut.engine.component.camera_order.{camera_draws_after}
use std.common.engine.units.{Angle}

describe("camera_order"):
    it("camera_draws_after returns true when a > b"):
        val result = camera_draws_after(10, 0)
        expect(result).to_equal(true)

    it("camera_draws_after returns false when a <= b"):
        val result = camera_draws_after(0, 10)
        expect(result).to_equal(false)

    it("CameraData default render_order is 0"):
        val cam = CameraData.create(800.0, 600.0)
        expect(cam.render_order).to_equal(0)

    it("Camera3DData perspective default render_order is 0"):
        val cam = Camera3DData.perspective(Angle(radians: 1.5707963), 1.777777, 0.1, 1000.0)
        expect(cam.render_order).to_equal(0)
