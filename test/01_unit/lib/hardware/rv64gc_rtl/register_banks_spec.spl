# Focused state check for the fixed RV64 integer and floating-point banks.
use std.hardware.rv64gc_rtl.regfile.{INIT_SP_64, regfile64_create, regfile64_read_one, regfile64_write}
use std.hardware.rv64gc_rtl.fregfile.{fregfile64_create, fregfile64_read, fregfile64_write}

fn check(name: text, ok: bool) -> i64:
    if ok:
        return 0
    print("FAIL {name}")
    1

fn main() -> i64:
    var fails: i64 = 0

    val reset = regfile64_create()
    fails = fails + check("integer reset keeps x0 and stack pointer",
        regfile64_read_one(reset, 0) == 0 and
        regfile64_read_one(reset, 2) == INIT_SP_64)

    val x31 = regfile64_write(reset, 31, 0x1234, true)
    val x0 = regfile64_write(x31, 0, 99, true)
    val disabled = regfile64_write(x0, 1, 88, false)
    fails = fails + check("integer bank preserves x0 and write enable",
        regfile64_read_one(disabled, 31) == 0x1234 and
        regfile64_read_one(disabled, 0) == 0 and
        regfile64_read_one(disabled, 1) == 0)

    val fp_reset = fregfile64_create()
    val fp31 = fregfile64_write(fp_reset, 31, 0x5566)
    val fp0 = fregfile64_write(fp31, 32, 0x7788)
    fails = fails + check("float bank writes all 32 indices and masks addresses",
        fregfile64_read(fp0, 31) == 0x5566 and
        fregfile64_read(fp0, 0) == 0x7788 and
        fregfile64_read(fp0, 32) == 0x7788)

    fails
