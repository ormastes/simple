# Integration probe: F/D FPU wired into the rv64 core (core.spl).
# Run-path probe: `bin/simple run` (interpreter — float extern is JIT-broken in
# the seed); expects "CORE FPU INTEGRATION: ALL PASS".
# Proves the CORE routing + the DI toggle (fpu unit-level math is in fpu_probe):
#  (1) enabled: FMV.D.X (int->float) then FMV.X.D (float->int) round-trips a
#      value through the float regfile and back to an integer rd, PC advances;
#  (2) disabled (core64_set_fpu(.., fpu_config_disabled())): the same FP op
#      raises an illegal-instruction trap (PC -> mtvec=0), NOT pc+4.
use std.hardware.rv64gc_rtl.core.{
    core64_init, core64_combinational, core64_update, core64_set_fpu
}
use std.hardware.rv64gc_rtl.core_types.CoreState64
use std.hardware.rv64gc_rtl.fpu.{fpu_config_disabled}
use std.hardware.rv64gc_rtl.regfile.regfile64_read_one
use std.hardware.rv64gc_rtl.csr.{csr64_fs_state}

fn check(name: text, ok: bool) -> i64:
    if ok:
        return 0
    print("FAIL {name}")
    1

fn step(st: CoreState64, insn: i64) -> CoreState64:
    val iw = insn as u32
    val comb = core64_combinational(st, iw, 0, st.rf)
    core64_update(st, iw, comb, comb.a0_val, comb.a1_val)

struct StepOut:
    state: CoreState64
    mem: i64

# step with a single-cell memory (address-agnostic; the test uses one location):
# a store latches the written value into `mem`, a load feeds `mem` back in.
fn step_mem(st: CoreState64, insn: i64, mem_in: i64) -> StepOut:
    val iw = insn as u32
    val comb = core64_combinational(st, iw, mem_in, st.rf)
    var mem_out = mem_in
    if comb.dmem_we:
        mem_out = comb.dmem_wdata
    StepOut(state: core64_update(st, iw, comb, comb.a0_val, comb.a1_val), mem: mem_out)

# encoders
fn enc_addi(rd: i64, rs1: i64, imm: i64) -> i64:
    ((imm & 0xFFF) << 20) | (rs1 << 15) | (0 << 12) | (rd << 7) | 0x13

# OP-FP: funct7 = (funct5 << 2) | fmt
fn enc_opfp(f5: i64, fmt: i64, rs2: i64, rs1: i64, rm: i64, rd: i64) -> i64:
    val funct7 = (f5 << 2) | fmt
    (funct7 << 25) | (rs2 << 20) | (rs1 << 15) | (rm << 12) | (rd << 7) | 0x53

fn enc_load_fp(funct3: i64, rd: i64, rs1: i64, imm: i64) -> i64:
    ((imm & 0xFFF) << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | 0x07

fn enc_store_fp(funct3: i64, rs2: i64, rs1: i64, imm: i64) -> i64:
    (((imm >> 5) & 0x7F) << 25) | (rs2 << 20) | (rs1 << 15) | (funct3 << 12) | ((imm & 0x1F) << 7) | 0x27

fn enc_csr(csr: i64, rs1: i64, funct3: i64, rd: i64) -> i64:
    (csr << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | 0x73

fn main() -> i64:
    var fails = 0
    val base: i64 = 0x100

    # ---- 1. enabled: round-trip 0x123 int -> f1 -> x2 through the core ----
    var st = core64_init(base)
    st = step(st, enc_addi(1, 0, 0x123))                 # x1 = 0x123 ; pc=+4
    fails = fails + check("ADDI advanced pc", st.pc == base + 4)
    st = step(st, enc_opfp(0x1E, 1, 0, 1, 0, 1))         # FMV.D.X f1, x1 ; pc=+4
    fails = fails + check("FMV.D.X advanced pc (no trap)", st.pc == base + 8)
    st = step(st, enc_opfp(0x1C, 1, 0, 1, 0, 2))         # FMV.X.D x2, f1 ; pc=+4
    fails = fails + check("FMV.X.D advanced pc", st.pc == base + 12)
    fails = fails + check("int->float->int round-trip x2==0x123", regfile64_read_one(st.rf, 2) == 0x123)

    # ---- 2. FSGNJN.D self: negate sign of f1 -> f3, move back to x4 ----
    # FSGNJN (rm=1) with rs2==rs1 flips the sign bit of f1 (0x123 -> sign set).
    st = step(st, enc_opfp(0x04, 1, 1, 1, 1, 3))         # FSGNJN.D f3, f1, f1
    st = step(st, enc_opfp(0x1C, 1, 0, 3, 0, 4))         # FMV.X.D x4, f3
    val expect_neg = 0x123 | (1 << 63)                    # sign bit set
    fails = fails + check("FSGNJN.D set sign bit", regfile64_read_one(st.rf, 4) == expect_neg)

    # ---- 2b. FCVT round-trip through the core: int 0x123 -> f5 -> int x6 ----
    st = step(st, enc_opfp(0x1A, 1, 0, 1, 0, 5))         # FCVT.D.W f5, x1 (291.0)
    st = step(st, enc_opfp(0x18, 1, 0, 5, 1, 6))         # FCVT.W.D x6, f5 (rtz->291)
    fails = fails + check("FCVT.D.W/W.D round-trip x6==291", regfile64_read_one(st.rf, 6) == 291)

    # ---- 3. DI toggle OFF: same FP op traps to mtvec(0), not pc+4 ----
    var stoff = core64_set_fpu(core64_init(base), fpu_config_disabled())
    stoff = step(stoff, enc_addi(1, 0, 0x123))           # x1 = 0x123 (integer ok)
    fails = fails + check("disabled core: ADDI still works", stoff.pc == base + 4)
    stoff = step(stoff, enc_opfp(0x1E, 1, 0, 1, 0, 1))   # FMV.D.X while FPU off
    fails = fails + check("disabled FP -> illegal trap (pc=mtvec=0)", stoff.pc == 0)

    # ---- 4. FP store/load round-trip through memory (FSD then FLD) ----
    var m = core64_init(base)
    m = step(m, enc_addi(10, 0, 0x40))                   # x10 = 0x40 (aligned addr)
    m = step(m, enc_addi(1, 0, 0x2A))                    # x1  = 42
    m = step(m, enc_opfp(0x1E, 1, 0, 1, 0, 1))           # FMV.D.X f1, x1
    var so = step_mem(m, enc_store_fp(3, 1, 10, 0), 0)   # FSD f1, 0(x10) -> mem
    fails = fails + check("FSD wrote 42 to memory", so.mem == 42)
    var lo = step_mem(so.state, enc_load_fp(3, 2, 10, 0), so.mem)  # FLD f2, 0(x10)
    var m2 = step(lo.state, enc_opfp(0x1C, 1, 0, 2, 0, 3))         # FMV.X.D x3, f2
    fails = fails + check("FLD/FSD memory round-trip x3==42", regfile64_read_one(m2.rf, 3) == 42)

    # ---- 5. fcsr CSR: write fcsr=0x51 (frm=2,fflags=0x11), read it back ----
    var c = core64_init(base)
    c = step(c, enc_addi(5, 0, 0x51))                    # x5 = 0x51
    c = step(c, enc_csr(0x003, 5, 1, 0))                 # csrrw fcsr, x5
    c = step(c, enc_csr(0x003, 0, 2, 6))                 # csrrs x6, fcsr, x0 (read)
    fails = fails + check("csrr fcsr == 0x51", regfile64_read_one(c.rf, 6) == 0x51)
    c = step(c, enc_csr(0x001, 0, 2, 7))                 # csrrs x7, fflags, x0
    fails = fails + check("csrr fflags == 0x11", regfile64_read_one(c.rf, 7) == 0x11)

    # ---- 6. mstatus.FS goes Dirty after an FP write ----
    var d = core64_init(base)
    d = step(d, enc_addi(1, 0, 0x2A))
    d = step(d, enc_opfp(0x1E, 1, 0, 1, 0, 1))           # FMV.D.X f1, x1
    fails = fails + check("FP write sets mstatus.FS=Dirty(3)", csr64_fs_state(d.csr_m) == 3)

    # ---- 7. mstatus.FS=Off gates FP even with the unit enabled ----
    var g = core64_init(base)
    g = step(g, enc_csr(0x300, 0, 1, 0))                 # csrrw mstatus, x0 -> FS=Off
    g = step(g, enc_opfp(0x1E, 1, 0, 1, 0, 1))           # FMV.D.X -> illegal (FS off)
    fails = fails + check("FS=Off -> FP traps (pc=mtvec=0)", g.pc == 0)

    if fails == 0:
        print("CORE FPU INTEGRATION: ALL PASS")
        return 0
    print("CORE FPU INTEGRATION: {fails} FAIL")
    1
