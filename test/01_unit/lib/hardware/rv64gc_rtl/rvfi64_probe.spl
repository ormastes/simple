# RV64GC RVFI self-check probe.
# Runs a small program through the real rv64 core, collects the RVFI retire
# trace via the new rv64gc_rtl.rvfi module, and asserts retire-chain
# invariants + per-retire architectural results. Non-vacuous by construction.
# Run: bin/simple run test/01_unit/lib/hardware/rv64gc_rtl/rvfi64_probe.spl
use std.hardware.rv64gc_rtl.core_types.CoreState64
use std.hardware.rv64gc_rtl.core.{core64_init, core64_combinational, core64_update}
use std.hardware.rv64gc_rtl.regfile.regfile64_read_one
use std.hardware.rv64gc_rtl.rvfi.{RvfiTrace64, rvfi64_enabled_config, rvfi64_check_traces, rvfi64_valid_retire_count, core64_rvfi_trace}
use std.hardware.riscv_common.core.riscv_formal.{check_retire_chain, render_retire_chain_report}

fn check(name: text, ok: bool) -> i64:
    if ok:
        print("PASS {name}")
        return 0
    print("FAIL {name}")
    1

fn main() -> i64:
    var fails: i64 = 0

    # Program (reset vector 0):
    #   0x00 addi x1, x0, 42     -> x1 = 42
    #   0x04 addi x2, x1, 1      -> x2 = 43
    #   0x08 sd   x2, 64(x0)     -> mem[64] = 43
    #   0x0C ld   x3, 64(x0)     -> x3 = 43
    #   0x10 jal  x0, 0          (park)
    val prog = [0x02A00093u32, 0x00108113u32, 0x04203023u32, 0x04003183u32, 0x0000006Fu32]

    var st = core64_init(0)
    var mem_slot: i64 = 0
    var traces: [RvfiTrace64] = []
    val config = rvfi64_enabled_config(0)

    var cycle: i64 = 0
    while cycle < 8:
        val idx = st.pc / 4
        var insn: u32 = 0x0000006Fu32
        if idx >= 0 and idx < 5:
            insn = prog[idx]
        var comb = core64_combinational(st, insn, 0, st.rf)
        var dmem_rdata: i64 = 0
        if comb.dmem_re:
            dmem_rdata = mem_slot
            comb = core64_combinational(st, insn, dmem_rdata, st.rf)
        if comb.dmem_we:
            mem_slot = comb.dmem_wdata
        traces = traces.push(core64_rvfi_trace(config, cycle, st, insn, dmem_rdata, comb))
        st = core64_update(st, insn, comb, comb.a0_val, comb.a1_val)
        cycle = cycle + 1

    # --- Invariant self-check (rvfi-level) ---
    val violations = rvfi64_check_traces(traces)
    for v in violations:
        print("VIOLATION {v}")
    fails = fails + check("rvfi64 invariants hold (0 violations)", violations.len() == 0)

    # --- Non-vacuity guard ---
    val retires = rvfi64_valid_retire_count(traces)
    print("valid retires: {retires}")
    fails = fails + check("non-vacuous (>= 2 valid retires)", retires >= 2)

    # --- Shared retire-chain theorem (riscv_common.core.riscv_formal) ---
    var orders: [i64] = []
    var pc_r: [i64] = []
    var pc_w: [i64] = []
    var traps: [bool] = []
    for t in traces:
        if t.rvfi_valid:
            orders = orders.push(t.rvfi_order)
            pc_r = pc_r.push(t.rvfi_pc_rdata)
            pc_w = pc_w.push(t.rvfi_pc_wdata)
            traps = traps.push(t.rvfi_trap)
    val report = check_retire_chain(orders, pc_r, pc_w, traps)
    print(render_retire_chain_report(report))
    fails = fails + check("retire-chain theorem PASS non-vacuous", report.ok and not report.vacuous)

    # --- Per-retire architectural results ---
    fails = fails + check("retire 0: addi x1 rd_wdata == 42",
        traces[0].rvfi_rd_addr == 1 and traces[0].rvfi_rd_wdata == 42)
    fails = fails + check("retire 1: addi x2 rd_wdata == 43",
        traces[1].rvfi_rd_addr == 2 and traces[1].rvfi_rd_wdata == 43)
    fails = fails + check("retire 2: sd wmask 0xFF addr 64 wdata 43",
        traces[2].rvfi_mem_wmask == 0xFF and traces[2].rvfi_mem_addr == 64
        and traces[2].rvfi_mem_wdata == 43 and traces[2].rvfi_mem_rmask == 0)
    fails = fails + check("retire 2: sd rd gated to x0 (no reg write)",
        traces[2].rvfi_rd_addr == 0 and traces[2].rvfi_rd_wdata == 0)
    fails = fails + check("retire 3: ld rmask 0xFF rd_wdata 43 mem_rdata 43",
        traces[3].rvfi_mem_rmask == 0xFF and traces[3].rvfi_rd_addr == 3
        and traces[3].rvfi_rd_wdata == 43 and traces[3].rvfi_mem_rdata == 43)
    fails = fails + check("retire 4: jal park pc_wdata == 0x10",
        traces[4].rvfi_pc_rdata == 0x10 and traces[4].rvfi_pc_wdata == 0x10)
    fails = fails + check("arch state matches trace (x1=42 x2=43 x3=43)",
        regfile64_read_one(st.rf, 1) == 42 and regfile64_read_one(st.rf, 2) == 43 and regfile64_read_one(st.rf, 3) == 43)

    # --- Negative check: a corrupted trace must be rejected (no greenwash) ---
    var bad = traces
    val t1 = traces[1]
    bad[1] = RvfiTrace64(
        rvfi_valid: t1.rvfi_valid, rvfi_order: t1.rvfi_order, rvfi_insn: t1.rvfi_insn,
        rvfi_trap: t1.rvfi_trap, rvfi_intr: t1.rvfi_intr,
        rvfi_rs1_addr: t1.rvfi_rs1_addr, rvfi_rs2_addr: t1.rvfi_rs2_addr,
        rvfi_rs1_rdata: t1.rvfi_rs1_rdata, rvfi_rs2_rdata: t1.rvfi_rs2_rdata,
        rvfi_rd_addr: t1.rvfi_rd_addr, rvfi_rd_wdata: t1.rvfi_rd_wdata,
        rvfi_pc_rdata: 0x7EAD0000, rvfi_pc_wdata: t1.rvfi_pc_wdata,
        rvfi_mem_addr: t1.rvfi_mem_addr, rvfi_mem_rmask: t1.rvfi_mem_rmask,
        rvfi_mem_wmask: t1.rvfi_mem_wmask, rvfi_mem_rdata: t1.rvfi_mem_rdata,
        rvfi_mem_wdata: t1.rvfi_mem_wdata)
    fails = fails + check("checker rejects broken pc chain",
        rvfi64_check_traces(bad).len() > 0)

    if fails == 0:
        print("RV64 RVFI PROBE: ALL PASS")
        return 0
    print("RV64 RVFI PROBE: {fails} FAILURES")
    1
