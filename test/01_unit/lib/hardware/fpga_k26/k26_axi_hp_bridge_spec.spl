# @cover src/lib/hardware/fpga_k26/k26_axi_hp_bridge.spl 0%
"""
# K26 AXI-HP Bridge Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Draft
**Requirements:** REQ-2
**Artifacts:** N/A

## Overview

Verifies AC-2: AXI-HP bridge generates correct SystemVerilog for wiring
VexRiscv-SMP AXI4 master to PS S_AXI_HP0 (128-bit burst DDR access).
Tests that the generated SV text contains required module declarations,
port names, and AXI4 signal names.

Covers:
- AC-2 (SOC integration: AXI-HP bridge for DDR access from PL core)
"""

use std.spipe.*
use lib.hardware.fpga_k26.k26_axi_hp_bridge.{generate_k26_axi_hp_bridge_sv}


# ============================================================================
# Helper: generate bridge SV once
# ============================================================================

fn bridge_sv() -> text:
    return generate_k26_axi_hp_bridge_sv()


# ============================================================================
# AC-2: AXI-HP Bridge SystemVerilog Content
# ============================================================================

describe "K26 AXI-HP Bridge SystemVerilog":
    it "AC-2: generated SV contains module declaration":
        val sv = bridge_sv()
        expect(sv).to_contain("module")

    it "AC-2: generated SV contains endmodule":
        val sv = bridge_sv()
        expect(sv).to_contain("endmodule")

    it "AC-2: generated SV declares AXI AWADDR port":
        val sv = bridge_sv()
        expect(sv).to_contain("AWADDR")

    it "AC-2: generated SV declares AXI WDATA port":
        val sv = bridge_sv()
        expect(sv).to_contain("WDATA")

    it "AC-2: generated SV declares AXI ARADDR port":
        val sv = bridge_sv()
        expect(sv).to_contain("ARADDR")

    it "AC-2: generated SV declares AXI RDATA port":
        val sv = bridge_sv()
        expect(sv).to_contain("RDATA")

    it "AC-2: generated SV declares AXI AWBURST port":
        val sv = bridge_sv()
        expect(sv).to_contain("AWBURST")

    it "AC-2: generated SV references S_AXI_HP0":
        val sv = bridge_sv()
        expect(sv).to_contain("HP0")

    it "AC-2: generated SV is non-empty":
        val sv = bridge_sv()
        val len = sv.length()
        expect(len).to_be_greater_than(0)

    it "AC-2: generated SV contains input/output port direction":
        val sv = bridge_sv()
        expect(sv).to_contain("input")
