# XLEN template differential probe (Lane NN, Wave-3 W3-2/W3-3, 2026-07-22).
#
# Proves the shared imm bit-assembly + select_alu_op templates in
# riscv_common/rtl_decode.spl reproduce, byte-for-byte, the behavior of the
# per-width rv32i_rtl / rv64gc_rtl decoders — across a broad instruction sweep
# including the sign-extension edges (0x7FF/0x800 imm, 0xFFFFF U-imm, -1).
#
# Differential contracts per instruction (all in the i64 domain — no
# `(negative_i64 as u32)` cast, which the seed JIT mis-lowers):
#   rv64:  extract_X_64(i)             ==  rtl_sign_extend(rtl_X_imm_bits, W)
#   rv32:  extract_X_u32(i) as i64     == (rtl_sign_extend(rtl_X_imm_bits, W) & 0xFFFFFFFF)
#   trunc: extract_X_u32(i) as i64     == (extract_X_64(i) & 0xFFFFFFFF)
# Plus select_alu_op == select_alu_op_64 == rtl_select_alu_op_base on the 10
# shared opcodes (rv64 M-ext short-circuit excepted).
#
# Run: bin/simple run test/01_unit/lib/hardware/riscv_common/xlen_template_probe.spl
use std.hardware.riscv_common.rtl_decode.{rtl_i_imm_bits, rtl_s_imm_bits, rtl_b_imm_bits}
use std.hardware.riscv_common.rtl_decode.{rtl_u_imm_bits, rtl_j_imm_bits, rtl_sign_extend}
use std.hardware.riscv_common.rtl_decode.rtl_select_alu_op_base
use std.hardware.rv32i_rtl.decode.{extract_i_imm_u32, extract_s_imm_u32, extract_b_imm_u32}
use std.hardware.rv32i_rtl.decode.{extract_u_imm_u32, extract_j_imm_u32, select_alu_op}
use std.hardware.rv64gc_rtl.decode.{extract_i_imm_64, extract_s_imm_64, extract_b_imm_64}
use std.hardware.rv64gc_rtl.decode.{extract_u_imm_64, extract_j_imm_64, select_alu_op_64}
use std.hardware.rv64gc_rtl.pkg.{ALU_ADDW, ALU_SUBW, ALU_SLLW, ALU_SRLW, ALU_SRAW}

var g_fail: i64 = 0

fn chk(cls: text, name: text, ok: bool) -> i64:
    if ok:
        print("PASS  [{cls}] {name}")
        return 0
    print("FAIL  [{cls}] {name}")
    g_fail = g_fail + 1
    1

# ---- encoders (mirror the isa probe) ---------------------------------------
fn enc_i(imm: i64, rs1: i64, f3: i64, rd: i64, op: i64) -> u32:
    (((imm & 0xFFF) << 20) | (rs1 << 15) | (f3 << 12) | (rd << 7) | op) as u32

fn enc_s(imm: i64, rs2: i64, rs1: i64, f3: i64, op: i64) -> u32:
    ((((imm >> 5) & 0x7F) << 25) | (rs2 << 20) | (rs1 << 15) | (f3 << 12) |
     ((imm & 0x1F) << 7) | op) as u32

fn enc_b(imm: i64, rs2: i64, rs1: i64, f3: i64, op: i64) -> u32:
    ((((imm >> 12) & 0x1) << 31) | (((imm >> 5) & 0x3F) << 25) | (rs2 << 20) |
     (rs1 << 15) | (f3 << 12) | (((imm >> 1) & 0xF) << 8) |
     (((imm >> 11) & 0x1) << 7) | op) as u32

fn enc_u(imm20: i64, rd: i64, op: i64) -> u32:
    (((imm20 & 0xFFFFF) << 12) | (rd << 7) | op) as u32

fn enc_j(imm: i64, rd: i64, op: i64) -> u32:
    ((((imm >> 20) & 0x1) << 31) | (((imm >> 1) & 0x3FF) << 21) |
     (((imm >> 11) & 0x1) << 20) | (((imm >> 12) & 0xFF) << 12) |
     (rd << 7) | op) as u32

# u32-domain sign-extend — mirrors rv32i_rtl/decode.spl `sign_extend_u32`, the
# formula the rewired rv32 shim uses. Kept in the u32 domain so the differential
# never performs a cross-width cast (which the seed JIT mis-lowers).
fn sx_u32(value: u32, width: u32) -> u32:
    val sign_bit = 1 << (width - 1)
    if (value & sign_bit) != 0:
        val fill = 0xFFFFFFFF << width
        value | fill
    else:
        value

# ---- per-instruction differential checks -----------------------------------
# rv64 proven in the i64 domain; rv32 proven in the u32 domain — both against
# the SAME shared bit-assembly (rtl_*_imm_bits). Bits are non-negative so
# `bits as u32` is exact.
fn diff_i(imm: i64) -> i64:
    val insn = enc_i(imm, 5, 0, 6, 0x13)
    val i = insn as i64
    var f: i64 = 0
    f = f + chk("i_imm", "rv64==tmpl imm={imm}", extract_i_imm_64(insn) == rtl_sign_extend(rtl_i_imm_bits(i), 12))
    f = f + chk("i_imm", "rv32==tmpl imm={imm}", extract_i_imm_u32(insn) == sx_u32(rtl_i_imm_bits(i) as u32, 12))
    f

fn diff_s(imm: i64) -> i64:
    val insn = enc_s(imm, 7, 5, 2, 0x23)
    val i = insn as i64
    var f: i64 = 0
    f = f + chk("s_imm", "rv64==tmpl imm={imm}", extract_s_imm_64(insn) == rtl_sign_extend(rtl_s_imm_bits(i), 12))
    f = f + chk("s_imm", "rv32==tmpl imm={imm}", extract_s_imm_u32(insn) == sx_u32(rtl_s_imm_bits(i) as u32, 12))
    f

fn diff_b(imm: i64) -> i64:
    val insn = enc_b(imm, 7, 5, 0, 0x63)
    val i = insn as i64
    var f: i64 = 0
    f = f + chk("b_imm", "rv64==tmpl imm={imm}", extract_b_imm_64(insn) == rtl_sign_extend(rtl_b_imm_bits(i), 13))
    f = f + chk("b_imm", "rv32==tmpl imm={imm}", extract_b_imm_u32(insn) == sx_u32(rtl_b_imm_bits(i) as u32, 13))
    f

fn diff_u(imm20: i64) -> i64:
    val insn = enc_u(imm20, 6, 0x37)
    val i = insn as i64
    var f: i64 = 0
    f = f + chk("u_imm", "rv64==tmpl imm20={imm20}", extract_u_imm_64(insn) == rtl_sign_extend(rtl_u_imm_bits(i), 32))
    # rv32 U-imm is NOT sign-extended — raw bits in place.
    f = f + chk("u_imm", "rv32==tmpl imm20={imm20}", extract_u_imm_u32(insn) == (rtl_u_imm_bits(i) as u32))
    f

fn diff_j(imm: i64) -> i64:
    val insn = enc_j(imm, 6, 0x6F)
    val i = insn as i64
    var f: i64 = 0
    f = f + chk("j_imm", "rv64==tmpl imm={imm}", extract_j_imm_64(insn) == rtl_sign_extend(rtl_j_imm_bits(i), 21))
    f = f + chk("j_imm", "rv32==tmpl imm={imm}", extract_j_imm_u32(insn) == sx_u32(rtl_j_imm_bits(i) as u32, 21))
    f

fn diff_alu(op: i64, f3: i64, f7: i64) -> i64:
    var f: i64 = 0
    val base = rtl_select_alu_op_base(op as u32, f3 as u32, f7 as u32)
    f = f + chk("alu_op", "rv32 select==base op={op} f3={f3} f7={f7}", select_alu_op(op as u32, f3 as u32, f7 as u32) == base)
    # rv64 select delegates to base for shared opcodes EXCEPT the M-extension
    # short-circuit (OP_REG with funct7==0x01), which rv64 handles locally.
    if not (op == 0x33 and f7 == 0x01):
        f = f + chk("alu_op", "rv64 select==base op={op} f3={f3} f7={f7}", select_alu_op_64(op as u32, f3 as u32, f7 as u32) == base)
    f

# RV64-only W-suffix arms (OP_OP_32 / OP_OP_IMM_32) — the two arms restructured
# in select_alu_op_64 and NOT covered by the shared base. Golden expected value
# recomputed independently; base would return the ADD default here, so this is a
# true differential on the rv64-only half of the function.
fn wop_golden(op: i64, f3: i64, f7: i64) -> i64:
    if op == 0x3B:                       # OP_OP_32
        if f7 == 0x01: return ALU_ADDW   # M-ext W placeholder
        if f3 == 0x0:
            if (f7 & 0x20) != 0: return ALU_SUBW else: return ALU_ADDW
        if f3 == 0x1: return ALU_SLLW
        if f3 == 0x5:
            if (f7 & 0x20) != 0: return ALU_SRAW else: return ALU_SRLW
        return ALU_ADDW
    # OP_OP_IMM_32 (0x1B)
    if f3 == 0x0: return ALU_ADDW
    if f3 == 0x1: return ALU_SLLW
    if f3 == 0x5:
        if (f7 & 0x20) != 0: return ALU_SRAW else: return ALU_SRLW
    ALU_ADDW

fn diff_wop(op: i64, f3: i64, f7: i64) -> i64:
    val got = select_alu_op_64(op as u32, f3 as u32, f7 as u32)
    chk("alu_wop", "rv64 select==golden op={op} f3={f3} f7={f7}", got == wop_golden(op, f3, f7))

fn main() -> i64:
    print("=== XLEN template differential probe (W3-2/W3-3) ===")
    # I/S/B/J imm sweep incl. sign-ext edges: 0x7FF(+2047), 0x800(-2048), -1, ...
    val imms: [i64] = [0, 1, -1, 0x7FF, 0x800, -2048, 2047, 0x555, -1365, 42]
    var k = 0
    while k < imms.len():
        diff_i(imms[k])
        diff_s(imms[k])
        diff_b(imms[k] * 2)   # B-imm bit0 always 0
        diff_j(imms[k] * 2)   # J-imm bit0 always 0
        k = k + 1
    # U-type sweep incl. top-bit edges: 0xFFFFF (bit31 set), 0x80000, 0x7FFFF, 0
    val u20: [i64] = [0, 1, 0x7FFFF, 0x80000, 0xFFFFF, 0x12345]
    var m = 0
    while m < u20.len():
        diff_u(u20[m])
        m = m + 1
    # ALU-op sweep: shared opcodes over funct3 0..7 x funct7 {0x00, 0x20, 0x01}.
    val ops: [i64] = [0x33, 0x13, 0x37, 0x03, 0x23, 0x63, 0x6F, 0x67]
    val f7s: [i64] = [0x00, 0x20, 0x01]
    var oi = 0
    while oi < ops.len():
        var f3 = 0
        while f3 < 8:
            var fi = 0
            while fi < f7s.len():
                diff_alu(ops[oi], f3, f7s[fi])
                fi = fi + 1
            f3 = f3 + 1
        oi = oi + 1
    # RV64-only W-suffix arms: OP_OP_32 (0x3B) / OP_OP_IMM_32 (0x1B).
    val wops: [i64] = [0x3B, 0x1B]
    var wi = 0
    while wi < wops.len():
        var wf3 = 0
        while wf3 < 8:
            var wfi = 0
            while wfi < f7s.len():
                diff_wop(wops[wi], wf3, f7s[wfi])
                wfi = wfi + 1
            wf3 = wf3 + 1
        wi = wi + 1
    if g_fail == 0:
        print("XLEN_TEMPLATE_PROBE: ALL PASS")
        return 0
    print("XLEN_TEMPLATE_PROBE: {g_fail} FAILURES")
    1
