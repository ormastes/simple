# Drift guard: the rv32 interconnect (wb_interconnect.spl) keeps its peripheral
# base addresses as same-file u32 literals because the bootstrap seed JIT
# miscompiles cross-module u32 const imports to 0 (see
# doc/08_tracking/bug/seed_jit_u32_cross_module_const_import_zero_2026-07-23.md).
# The rv64 interconnect imports them from the canonical riscv_common/mmio_map.spl.
# This probe asserts the rv32 literals still equal the canonical map, so the two
# cannot silently diverge — the "shared MMIO map" guarantee, enforced.
# Interpreter-only: it reads the u32 side via `as i64`, which the seed JIT also
# miscompiles; the interpreter is the reference.
# Run: bin/simple run test/01_unit/lib/hardware/soc_rtl/rv32_mmio_map_consistency_probe.spl
use std.hardware.riscv_common.mmio_map.{MMIO_BOOTROM_BASE, MMIO_CLINT_BASE, MMIO_UART_BASE, MMIO_DRAM_BASE}
use std.hardware.soc_rtl.wb_interconnect.{ROM_BASE, CLINT_BASE, UART_BASE, RAM_BASE}

fn check(name: text, ok: bool) -> i64:
    if ok:
        print("PASS {name}")
        return 0
    print("FAIL {name}")
    1

fn main() -> i64:
    var fails: i64 = 0
    fails = fails + check("rv32 ROM_BASE   == mmio_map BOOTROM", (ROM_BASE as i64) == MMIO_BOOTROM_BASE)
    fails = fails + check("rv32 CLINT_BASE == mmio_map CLINT",   (CLINT_BASE as i64) == MMIO_CLINT_BASE)
    fails = fails + check("rv32 UART_BASE  == mmio_map UART",    (UART_BASE as i64) == MMIO_UART_BASE)
    fails = fails + check("rv32 RAM_BASE   == mmio_map DRAM",    (RAM_BASE as i64) == MMIO_DRAM_BASE)
    if fails == 0:
        print("RV32 MMIO MAP CONSISTENCY PROBE: ALL PASS")
        return 0
    print("RV32 MMIO MAP CONSISTENCY PROBE: {fails} FAILURES")
    1
