"""Ethernet FCS (IEEE 802.3 CRC-32) synthesizable RTL core spec.

Drives the combinational per-octet CRC step over test frames and asserts the
canonical CRC-32 known-answer vectors, plus the MAC receiver-side validation
(recomputed FCS matches the transmitted trailer).
"""

use std.hardware.soc_rtl.eth_fcs.{eth_fcs_init, eth_fcs_step, eth_fcs_finalize, eth_fcs_check}

# Software testbench fold: clock each octet through the RTL step function.
fn _fcs(data: [u8]) -> i64:
    var c = eth_fcs_init()
    var i: i64 = 0
    while i < data.len():
        c = eth_fcs_step(c, data[i].to_u32())
        i = i + 1
    eth_fcs_finalize(c).to_i64()

fn _digits() -> [u8]:
    [0x31u8, 0x32u8, 0x33u8, 0x34u8, 0x35u8, 0x36u8, 0x37u8, 0x38u8, 0x39u8]

fn _check_roundtrip() -> bool:
    val frame: [u8] = [0xDEu8, 0xADu8, 0xBEu8, 0xEFu8]
    var c = eth_fcs_init()
    var i: i64 = 0
    while i < frame.len():
        c = eth_fcs_step(c, frame[i].to_u32())
        i = i + 1
    val transmitted = eth_fcs_finalize(c)
    # Receiver recomputes the same way and validates.
    var c2 = eth_fcs_init()
    var j: i64 = 0
    while j < frame.len():
        c2 = eth_fcs_step(c2, frame[j].to_u32())
        j = j + 1
    eth_fcs_check(eth_fcs_finalize(c2), transmitted)

describe "Ethernet FCS CRC-32 RTL core (IEEE 802.3)":

    it "computes the canonical check value FCS(\"123456789\") = 0xCBF43926":
        expect(_fcs(_digits())).to_equal(0xCBF43926)

    it "FCS of the empty frame is 0":
        val empty: [u8] = []
        expect(_fcs(empty)).to_equal(0)

    it "FCS of single byte 'A' (0x41) = 0xD3D99E8B":
        val a: [u8] = [0x41u8]
        expect(_fcs(a)).to_equal(0xD3D99E8B)

    it "distinct frames produce distinct FCS":
        val other: [u8] = [0x31u8, 0x32u8, 0x33u8, 0x34u8, 0x35u8, 0x36u8, 0x37u8, 0x38u8, 0x30u8]
        assert_not_equal(_fcs(_digits()), _fcs(other))

    it "receiver validation accepts a matching recomputed FCS":
        expect(_check_roundtrip()).to_equal(true)
