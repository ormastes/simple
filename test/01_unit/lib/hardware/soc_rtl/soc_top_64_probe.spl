# Standalone probe for soc_top_64 program execution through the real RV64 core.
# The SSpec runner daemon hangs on this tree (known deployed-seed bug:
# doc/08_tracking/bug/deployed_seed_test_runner_init_hang_2026-07-17.md), so
# this probe mirrors the "SocTop64 Program Execution" spec cases and prints
# PASS/FAIL. Run: bin/simple run test/01_unit/lib/hardware/soc_rtl/soc_top_64_probe.spl
use std.hardware.soc_rtl.soc_top_64.{SocTop64State, soc_top_64_init, soc_top_64_tick, soc64_uart_push_rx}
use std.hardware.soc_rtl.ram64.{ram64_read, ram64_write}

fn check(name: text, ok: bool) -> i64:
    if ok:
        print("PASS {name}")
        return 0
    print("FAIL {name}")
    1

fn main() -> i64:
    var fails: i64 = 0

    # ── Case 1: ALU/branch/jal program (NOP stepper would fail all asserts) ──
    var soc = soc_top_64_init(0x1000)
    var ram = soc.ram
    ram = ram64_write(ram, 0x00, 4, 0x02A00093)   # addi x1, x0, 42
    ram = ram64_write(ram, 0x04, 4, 0x00108113)   # addi x2, x1, 1   (x2 = 43)
    ram = ram64_write(ram, 0x08, 4, 0x00209463)   # bne  x1, x2, +8  (taken)
    ram = ram64_write(ram, 0x0C, 4, 0x00000093)   # addi x1, x0, 0   (poison, skipped)
    ram = ram64_write(ram, 0x10, 4, 0x00700193)   # addi x3, x0, 7
    ram = ram64_write(ram, 0x14, 4, 0x0000006F)   # jal  x0, 0       (park)
    soc.ram = ram
    soc.core.pc = 0x8000_0000
    var i = 0
    while i < 20:
        soc = soc_top_64_tick(soc)
        i = i + 1
    print("case1 pc={soc.core.pc} x1={soc.core.rf.regs[1]} x2={soc.core.rf.regs[2]} x3={soc.core.rf.regs[3]} mtime={soc.clint.mtime}")
    fails = fails + check("case1 pc parks at jal self-loop 0x80000014", soc.core.pc == 0x8000_0014)
    fails = fails + check("case1 x1 == 42 (poison skipped by taken bne)", soc.core.rf.regs[1] == 42)
    fails = fails + check("case1 x2 == 43", soc.core.rf.regs[2] == 43)
    fails = fails + check("case1 x3 == 7", soc.core.rf.regs[3] == 7)
    fails = fails + check("case1 clint mtime ticked 20", soc.clint.mtime == 20)

    # ── Case 2: store then load round-trip through RAM via the core ──
    var soc2 = soc_top_64_init(0x1000)
    var ram2 = soc2.ram
    ram2 = ram64_write(ram2, 0x00, 4, 0x03700093)   # addi x1, x0, 55
    ram2 = ram64_write(ram2, 0x04, 4, 0x00100293)   # addi x5, x0, 1
    ram2 = ram64_write(ram2, 0x08, 4, 0x01F29293)   # slli x5, x5, 31  (x5 = 0x8000_0000)
    ram2 = ram64_write(ram2, 0x0C, 4, 0x0412A023)   # sw   x1, 64(x5)
    ram2 = ram64_write(ram2, 0x10, 4, 0x0402A303)   # lw   x6, 64(x5)
    ram2 = ram64_write(ram2, 0x14, 4, 0x0000006F)   # jal  x0, 0       (park)
    soc2.ram = ram2
    soc2.core.pc = 0x8000_0000
    var j = 0
    while j < 12:
        soc2 = soc_top_64_tick(soc2)
        j = j + 1
    val stored = ram64_read(soc2.ram, 0x40, 4)
    print("case2 pc={soc2.core.pc} x6={soc2.core.rf.regs[6]} mem[0x40]={stored}")
    fails = fails + check("case2 pc parks at 0x80000014", soc2.core.pc == 0x8000_0014)
    fails = fails + check("case2 sw wrote 55 to RAM", stored == 55)
    fails = fails + check("case2 lw read 55 back into x6", soc2.core.rf.regs[6] == 55)

    # ── Case 3: full RV64 bootrom sequence — reset vector to DRAM handoff ──
    # bootrom_read64 zero-extends each lui with slli/srli-32 (fixes the
    # lui-sext misjump bug); after 11 insns the core lands at 0x80000000
    # with sp/a1/t0 zero-extended and executes from RAM (NOP park loop).
    var soc3 = soc_top_64_init(0x1000)
    var k = 0
    while k < 11:
        soc3 = soc_top_64_tick(soc3)
        k = k + 1
    print("case3 pc={soc3.core.pc} sp={soc3.core.rf.regs[2]} a1={soc3.core.rf.regs[11]} t0={soc3.core.rf.regs[5]}")
    fails = fails + check("case3 boot handoff lands at 0x80000000", soc3.core.pc == 0x8000_0000)
    fails = fails + check("case3 sp == 0x80100000 zero-extended", soc3.core.rf.regs[2] == 0x8010_0000)
    fails = fails + check("case3 a1 == 0x88000000 zero-extended (DTB)", soc3.core.rf.regs[11] == 0x8800_0000)
    fails = fails + check("case3 t0 == 0x80000000 zero-extended (entry)", soc3.core.rf.regs[5] == 0x8000_0000)

    # ── Case 4: MMIO — UART THR/LSR + CLINT mtime via the core ──
    # Stores 'H','I','\n' to UART THR (0x1000_0000), reads LSR into x28
    # (expect 0x60 = THRE|TEMT), reads mtime (0x200_BFF8) twice via RV64 ld
    # into x29/x30 (expect monotonic). NOP-stepper or missing MMIO fails all.
    var soc4 = soc_top_64_init(0x1000)
    var ram4 = soc4.ram
    ram4 = ram64_write(ram4, 0x00, 4, 0x100002B7)   # lui  x5, 0x10000  (x5 = 0x1000_0000 UART)
    ram4 = ram64_write(ram4, 0x04, 4, 0x04800313)   # addi x6, x0, 72   ('H')
    ram4 = ram64_write(ram4, 0x08, 4, 0x00628023)   # sb   x6, 0(x5)    THR
    ram4 = ram64_write(ram4, 0x0C, 4, 0x04900313)   # addi x6, x0, 73   ('I')
    ram4 = ram64_write(ram4, 0x10, 4, 0x00628023)   # sb   x6, 0(x5)    THR
    ram4 = ram64_write(ram4, 0x14, 4, 0x00A00313)   # addi x6, x0, 10   ('\n')
    ram4 = ram64_write(ram4, 0x18, 4, 0x00628023)   # sb   x6, 0(x5)    THR
    ram4 = ram64_write(ram4, 0x1C, 4, 0x0052CE03)   # lbu  x28, 5(x5)   LSR -> x28
    ram4 = ram64_write(ram4, 0x20, 4, 0x020003B7)   # lui  x7, 0x2000   (x7 = 0x200_0000 CLINT)
    ram4 = ram64_write(ram4, 0x24, 4, 0x0000C437)   # lui  x8, 0xC      (x8 = 0xC000)
    ram4 = ram64_write(ram4, 0x28, 4, 0xFF840413)   # addi x8, x8, -8   (x8 = 0xBFF8)
    ram4 = ram64_write(ram4, 0x2C, 4, 0x008383B3)   # add  x7, x7, x8   (x7 = 0x200_BFF8 mtime)
    ram4 = ram64_write(ram4, 0x30, 4, 0x0003BE83)   # ld   x29, 0(x7)   mtime read 1
    ram4 = ram64_write(ram4, 0x34, 4, 0x0003BF03)   # ld   x30, 0(x7)   mtime read 2
    ram4 = ram64_write(ram4, 0x38, 4, 0x0000006F)   # jal  x0, 0        (park)
    soc4.ram = ram4
    soc4.core.pc = 0x8000_0000
    var k = 0
    while k < 24:
        soc4 = soc_top_64_tick(soc4)
        k = k + 1
    print("case4 pc={soc4.core.pc} uart_tx.len={soc4.uart_tx.len()} lsr={soc4.core.rf.regs[28]} mtime1={soc4.core.rf.regs[29]} mtime2={soc4.core.rf.regs[30]}")
    fails = fails + check("case4 pc parks at 0x80000038", soc4.core.pc == 0x8000_0038)
    fails = fails + check("case4 uart_tx has 3 bytes", soc4.uart_tx.len() == 3)
    var tx_ok = false
    if soc4.uart_tx.len() == 3:
        tx_ok = soc4.uart_tx[0] == 72 and soc4.uart_tx[1] == 73 and soc4.uart_tx[2] == 10
    fails = fails + check("case4 uart_tx == [72, 73, 10] ('HI\\n')", tx_ok)
    fails = fails + check("case4 LSR read == 0x60 (THRE|TEMT)", soc4.core.rf.regs[28] == 0x60)
    fails = fails + check("case4 mtime read 1 nonzero", soc4.core.rf.regs[29] > 0)
    fails = fails + check("case4 mtime monotonic (read2 > read1)", soc4.core.rf.regs[30] > soc4.core.rf.regs[29])

    # ── Case 5: CLINT machine timer interrupt — real CSR writes + MMIO arm ──
    # Guest program: sets mtvec to a handler (0x8000_0100) via csrrw, arms
    # mtimecmp=64 via a real sd to CLINT MMIO (0x200_4000), enables mie.MTIE
    # and mstatus.MIE via csrrs, then parks on a spin loop (0x8000_0030).
    # When mtime reaches 64, mip.MTIP must be delivered from clint_tick and
    # the core must vector to mtvec. Handler stores marker 0x123 to RAM
    # 0x200, reads mcause/mepc into x12/x13 via csrrs, and parks.
    var soc5 = soc_top_64_init(0x1000)
    var ram5 = soc5.ram
    ram5 = ram64_write(ram5, 0x000, 4, 0x800002B7)   # lui  x5, 0x80000
    ram5 = ram64_write(ram5, 0x004, 4, 0x02029293)   # slli x5, x5, 32   (zero-extend)
    ram5 = ram64_write(ram5, 0x008, 4, 0x0202D293)   # srli x5, x5, 32   (x5 = 0x8000_0000)
    ram5 = ram64_write(ram5, 0x00C, 4, 0x10028293)   # addi x5, x5, 0x100 (handler)
    ram5 = ram64_write(ram5, 0x010, 4, 0x30529073)   # csrrw x0, mtvec, x5
    ram5 = ram64_write(ram5, 0x014, 4, 0x02004337)   # lui  x6, 0x2004   (x6 = 0x200_4000 mtimecmp)
    ram5 = ram64_write(ram5, 0x018, 4, 0x04000393)   # addi x7, x0, 64
    ram5 = ram64_write(ram5, 0x01C, 4, 0x00733023)   # sd   x7, 0(x6)    arm mtimecmp = 64
    ram5 = ram64_write(ram5, 0x020, 4, 0x08000393)   # addi x7, x0, 128
    ram5 = ram64_write(ram5, 0x024, 4, 0x3043A073)   # csrrs x0, mie, x7  (MTIE)
    ram5 = ram64_write(ram5, 0x028, 4, 0x00800393)   # addi x7, x0, 8
    ram5 = ram64_write(ram5, 0x02C, 4, 0x3003A073)   # csrrs x0, mstatus, x7 (MIE)
    ram5 = ram64_write(ram5, 0x030, 4, 0x0000006F)   # jal  x0, 0        (spin)
    # Handler at 0x8000_0100
    ram5 = ram64_write(ram5, 0x100, 4, 0x80000537)   # lui  x10, 0x80000
    ram5 = ram64_write(ram5, 0x104, 4, 0x02051513)   # slli x10, x10, 32
    ram5 = ram64_write(ram5, 0x108, 4, 0x02055513)   # srli x10, x10, 32 (x10 = 0x8000_0000)
    ram5 = ram64_write(ram5, 0x10C, 4, 0x12300593)   # addi x11, x0, 0x123 (marker)
    ram5 = ram64_write(ram5, 0x110, 4, 0x20B52023)   # sw   x11, 0x200(x10)
    ram5 = ram64_write(ram5, 0x114, 4, 0x34202673)   # csrrs x12, mcause, x0
    ram5 = ram64_write(ram5, 0x118, 4, 0x341026F3)   # csrrs x13, mepc, x0
    ram5 = ram64_write(ram5, 0x11C, 4, 0x0000006F)   # jal  x0, 0        (park)
    soc5.ram = ram5
    soc5.core.pc = 0x8000_0000
    var m = 0
    while m < 100:
        soc5 = soc_top_64_tick(soc5)
        m = m + 1
    val marker = ram64_read(soc5.ram, 0x200, 4)
    val expected_cause: i64 = (1 << 63) | 7
    print("case5 pc={soc5.core.pc} marker={marker} x12(mcause)={soc5.core.rf.regs[12]} x13(mepc)={soc5.core.rf.regs[13]} mip={soc5.core.csr_m.mip} mtvec={soc5.core.csr_m.mtvec}")
    fails = fails + check("case5 csrrw wrote mtvec (csr write path executed)", soc5.core.csr_m.mtvec == 0x8000_0100)
    fails = fails + check("case5 handler wrote marker 0x123 to RAM", marker == 0x123)
    fails = fails + check("case5 mcause == machine timer interrupt (bit63|7)", soc5.core.rf.regs[12] == expected_cause)
    fails = fails + check("case5 mepc == spin pc 0x80000030", soc5.core.rf.regs[13] == 0x8000_0030)
    fails = fails + check("case5 mip.MTIP delivered from CLINT (bit 7)", (soc5.core.csr_m.mip & 0x80) != 0)
    fails = fails + check("case5 pc parks in handler at 0x8000011C", soc5.core.pc == 0x8000_011C)

    # ── Case 6: PLIC + UART RX external interrupt end-to-end ──
    # Guest: mtvec -> handler, PLIC priority[10]=1, enable ctx0 bit 10,
    # threshold ctx0 = 0, UART IER.ERBFI, mie.MEIE + mstatus.MIE, spin.
    # Host pushes 'A' into the UART RX queue -> PLIC source 10 pends ->
    # mip.MEIP -> vector to handler. Handler: claim (expect 10), RBR read
    # (expect 65, pops queue), complete, second claim (expect 0), marker,
    # mcause into x12, park.
    var soc6 = soc_top_64_init(0x1000)
    var ram6 = soc6.ram
    ram6 = ram64_write(ram6, 0x000, 4, 0x800002B7)   # lui  x5, 0x80000
    ram6 = ram64_write(ram6, 0x004, 4, 0x02029293)   # slli x5, x5, 32
    ram6 = ram64_write(ram6, 0x008, 4, 0x0202D293)   # srli x5, x5, 32   (x5 = 0x8000_0000)
    ram6 = ram64_write(ram6, 0x00C, 4, 0x10028293)   # addi x5, x5, 0x100 (handler)
    ram6 = ram64_write(ram6, 0x010, 4, 0x30529073)   # csrrw x0, mtvec, x5
    ram6 = ram64_write(ram6, 0x014, 4, 0x0C000337)   # lui  x6, 0xC000   (x6 = 0xC00_0000 PLIC)
    ram6 = ram64_write(ram6, 0x018, 4, 0x00100393)   # addi x7, x0, 1
    ram6 = ram64_write(ram6, 0x01C, 4, 0x02732423)   # sw   x7, 0x28(x6)  priority[10] = 1
    ram6 = ram64_write(ram6, 0x020, 4, 0x00002437)   # lui  x8, 0x2      (x8 = 0x2000)
    ram6 = ram64_write(ram6, 0x024, 4, 0x00830433)   # add  x8, x6, x8   (enable ctx0)
    ram6 = ram64_write(ram6, 0x028, 4, 0x00100393)   # addi x7, x0, 1
    ram6 = ram64_write(ram6, 0x02C, 4, 0x00A39393)   # slli x7, x7, 10   (x7 = 1<<10)
    ram6 = ram64_write(ram6, 0x030, 4, 0x00742023)   # sw   x7, 0(x8)    enable source 10
    ram6 = ram64_write(ram6, 0x034, 4, 0x002004B7)   # lui  x9, 0x200    (x9 = 0x200000)
    ram6 = ram64_write(ram6, 0x038, 4, 0x009304B3)   # add  x9, x6, x9   (threshold ctx0)
    ram6 = ram64_write(ram6, 0x03C, 4, 0x0004A023)   # sw   x0, 0(x9)    threshold = 0
    ram6 = ram64_write(ram6, 0x040, 4, 0x10000E37)   # lui  x28, 0x10000 (UART base)
    ram6 = ram64_write(ram6, 0x044, 4, 0x00100393)   # addi x7, x0, 1
    ram6 = ram64_write(ram6, 0x048, 4, 0x007E00A3)   # sb   x7, 1(x28)   IER = 1 (ERBFI)
    ram6 = ram64_write(ram6, 0x04C, 4, 0x00100393)   # addi x7, x0, 1
    ram6 = ram64_write(ram6, 0x050, 4, 0x00B39393)   # slli x7, x7, 11   (x7 = 0x800 MEIE)
    ram6 = ram64_write(ram6, 0x054, 4, 0x3043A073)   # csrrs x0, mie, x7
    ram6 = ram64_write(ram6, 0x058, 4, 0x00800393)   # addi x7, x0, 8
    ram6 = ram64_write(ram6, 0x05C, 4, 0x3003A073)   # csrrs x0, mstatus, x7 (MIE)
    ram6 = ram64_write(ram6, 0x060, 4, 0x0000006F)   # jal  x0, 0        (spin)
    # Handler at 0x8000_0100
    ram6 = ram64_write(ram6, 0x100, 4, 0x0C200737)   # lui  x14, 0xC200  (claim block base)
    ram6 = ram64_write(ram6, 0x104, 4, 0x00472783)   # lw   x15, 4(x14)  claim -> x15
    ram6 = ram64_write(ram6, 0x108, 4, 0x10000837)   # lui  x16, 0x10000 (UART base)
    ram6 = ram64_write(ram6, 0x10C, 4, 0x00084883)   # lbu  x17, 0(x16)  RBR -> x17
    ram6 = ram64_write(ram6, 0x110, 4, 0x00F72223)   # sw   x15, 4(x14)  complete
    ram6 = ram64_write(ram6, 0x114, 4, 0x00472903)   # lw   x18, 4(x14)  second claim -> x18
    ram6 = ram64_write(ram6, 0x118, 4, 0x80000537)   # lui  x10, 0x80000
    ram6 = ram64_write(ram6, 0x11C, 4, 0x02051513)   # slli x10, x10, 32
    ram6 = ram64_write(ram6, 0x120, 4, 0x02055513)   # srli x10, x10, 32 (x10 = 0x8000_0000)
    ram6 = ram64_write(ram6, 0x124, 4, 0x32100593)   # addi x11, x0, 0x321 (marker)
    ram6 = ram64_write(ram6, 0x128, 4, 0x30B52023)   # sw   x11, 0x300(x10)
    ram6 = ram64_write(ram6, 0x12C, 4, 0x34202673)   # csrrs x12, mcause, x0
    ram6 = ram64_write(ram6, 0x130, 4, 0x0000006F)   # jal  x0, 0        (park)
    soc6.ram = ram6
    soc6.core.pc = 0x8000_0000
    var n = 0
    while n < 30:
        soc6 = soc_top_64_tick(soc6)
        n = n + 1
    # Host side: 'A' arrives on the UART RX line while the guest spins
    soc6 = soc64_uart_push_rx(soc6, 65)
    n = 0
    while n < 40:
        soc6 = soc_top_64_tick(soc6)
        n = n + 1
    val marker6 = ram64_read(soc6.ram, 0x300, 4)
    val expected_ext_cause: i64 = (1 << 63) | 11
    print("case6 pc={soc6.core.pc} marker={marker6} claim1={soc6.core.rf.regs[15]} rbr={soc6.core.rf.regs[17]} claim2={soc6.core.rf.regs[18]} mcause={soc6.core.rf.regs[12]} mepc={soc6.core.csr_m.mepc} mip={soc6.core.csr_m.mip} plic_pend={soc6.plic.pending}")
    fails = fails + check("case6 mcause == machine external interrupt (bit63|11)", soc6.core.rf.regs[12] == expected_ext_cause)
    fails = fails + check("case6 first claim returned source 10 (UART)", soc6.core.rf.regs[15] == 10)
    fails = fails + check("case6 RBR read == 65 ('A')", soc6.core.rf.regs[17] == 65)
    fails = fails + check("case6 second claim after complete returned 0", soc6.core.rf.regs[18] == 0)
    fails = fails + check("case6 handler wrote marker 0x321 to RAM", marker6 == 0x321)
    fails = fails + check("case6 mepc == spin pc 0x80000060", soc6.core.csr_m.mepc == 0x8000_0060)
    fails = fails + check("case6 pc parks in handler at 0x80000130", soc6.core.pc == 0x8000_0130)
    fails = fails + check("case6 MEIP deasserted after RX drain (mip bit 11 clear)", (soc6.core.csr_m.mip & 0x800) == 0)
    fails = fails + check("case6 PLIC pending clear after drain", soc6.plic.pending == 0)

    # ── Case a: AMOADD.W — rd gets old value, memory gets old+rs2 ──
    var soca = soc_top_64_init(0x1000)
    var rama = soca.ram
    rama = ram64_write(rama, 0x40, 4, 5)              # mem[0x40] = 5
    rama = ram64_write(rama, 0x00, 4, 0x800002B7)     # lui  x5, 0x80000
    rama = ram64_write(rama, 0x04, 4, 0x02029293)     # slli x5, x5, 32
    rama = ram64_write(rama, 0x08, 4, 0x0202D293)     # srli x5, x5, 32
    rama = ram64_write(rama, 0x0C, 4, 0x04028293)     # addi x5, x5, 0x40
    rama = ram64_write(rama, 0x10, 4, 0x00700393)     # addi x7, x0, 7
    rama = ram64_write(rama, 0x14, 4, 0x0072A32F)     # amoadd.w x6, x7, (x5)
    rama = ram64_write(rama, 0x18, 4, 0x0000006F)     # jal x0, 0 (park)
    soca.ram = rama
    soca.core.pc = 0x8000_0000
    var pa = 0
    while pa < 12:
        soca = soc_top_64_tick(soca)
        pa = pa + 1
    val amem = ram64_read(soca.ram, 0x40, 4)
    print("casea pc={soca.core.pc} x6={soca.core.rf.regs[6]} mem[0x40]={amem}")
    fails = fails + check("casea amoadd.w rd == old value 5", soca.core.rf.regs[6] == 5)
    fails = fails + check("casea amoadd.w mem == 5+7 = 12", amem == 12)
    fails = fails + check("casea pc parks at 0x80000018", soca.core.pc == 0x8000_0018)

    # ── Case b: AMOSWAP.D round-trip + AMOMAXU.W unsigned pick ──
    var socb = soc_top_64_init(0x1000)
    var ramb = socb.ram
    ramb = ram64_write(ramb, 0x48, 8, 100)            # mem64[0x48] = 100
    ramb = ram64_write(ramb, 0x50, 4, 0x8000_0000)    # mem32[0x50] = 0x80000000
    val maxu_before = ram64_read(ramb, 0x50, 4)
    ramb = ram64_write(ramb, 0x00, 4, 0x800002B7)     # lui  x5, 0x80000
    ramb = ram64_write(ramb, 0x04, 4, 0x02029293)     # slli x5, x5, 32
    ramb = ram64_write(ramb, 0x08, 4, 0x0202D293)     # srli x5, x5, 32
    ramb = ram64_write(ramb, 0x0C, 4, 0x04828293)     # addi x5, x5, 0x48
    ramb = ram64_write(ramb, 0x10, 4, 0x0C800393)     # addi x7, x0, 200
    ramb = ram64_write(ramb, 0x14, 4, 0x0872B32F)     # amoswap.d x6, x7, (x5)
    ramb = ram64_write(ramb, 0x18, 4, 0x00828493)     # addi x9, x5, 8  (0x8000_0050)
    ramb = ram64_write(ramb, 0x1C, 4, 0x00100393)     # addi x7, x0, 1
    ramb = ram64_write(ramb, 0x20, 4, 0xE074A42F)     # amomaxu.w x8, x7, (x9)
    ramb = ram64_write(ramb, 0x24, 4, 0x0000006F)     # jal x0, 0 (park)
    socb.ram = ramb
    socb.core.pc = 0x8000_0000
    var pb = 0
    while pb < 14:
        socb = soc_top_64_tick(socb)
        pb = pb + 1
    val bswap = ram64_read(socb.ram, 0x48, 8)
    val bmaxu = ram64_read(socb.ram, 0x50, 4)
    val neg31: i64 = 0 - 0x8000_0000
    print("caseb x6={socb.core.rf.regs[6]} mem64[0x48]={bswap} x8={socb.core.rf.regs[8]} mem32[0x50]={bmaxu}")
    fails = fails + check("caseb amoswap.d rd == old value 100", socb.core.rf.regs[6] == 100)
    fails = fails + check("caseb amoswap.d mem == 200", bswap == 200)
    fails = fails + check("caseb amomaxu.w rd == sign-extended old 0x80000000", socb.core.rf.regs[8] == neg31)
    fails = fails + check("caseb amomaxu.w kept 0x80000000 (unsigned max beats 1)", bmaxu == maxu_before)

    # ── Case c: LR/SC success path — sc rd=0, memory updated ──
    var socc = soc_top_64_init(0x1000)
    var ramc = socc.ram
    ramc = ram64_write(ramc, 0x60, 4, 11)             # mem[0x60] = 11
    ramc = ram64_write(ramc, 0x00, 4, 0x800002B7)     # lui  x5, 0x80000
    ramc = ram64_write(ramc, 0x04, 4, 0x02029293)     # slli x5, x5, 32
    ramc = ram64_write(ramc, 0x08, 4, 0x0202D293)     # srli x5, x5, 32
    ramc = ram64_write(ramc, 0x0C, 4, 0x06028293)     # addi x5, x5, 0x60
    ramc = ram64_write(ramc, 0x10, 4, 0x1002A32F)     # lr.w x6, (x5)
    ramc = ram64_write(ramc, 0x14, 4, 0x04D00393)     # addi x7, x0, 77
    ramc = ram64_write(ramc, 0x18, 4, 0x1872A42F)     # sc.w x8, x7, (x5)
    ramc = ram64_write(ramc, 0x1C, 4, 0x0000006F)     # jal x0, 0 (park)
    socc.ram = ramc
    socc.core.pc = 0x8000_0000
    var pcc = 0
    while pcc < 12:
        socc = soc_top_64_tick(socc)
        pcc = pcc + 1
    val cmem = ram64_read(socc.ram, 0x60, 4)
    print("casec x6={socc.core.rf.regs[6]} x8={socc.core.rf.regs[8]} mem[0x60]={cmem} resv={socc.core.atomics.reservation_valid}")
    fails = fails + check("casec lr.w loaded 11", socc.core.rf.regs[6] == 11)
    fails = fails + check("casec sc.w succeeded (rd == 0)", socc.core.rf.regs[8] == 0)
    fails = fails + check("casec sc.w wrote 77", cmem == 77)
    fails = fails + check("casec reservation cleared after sc", socc.core.atomics.reservation_valid == false)

    # ── Case d: SC fail path — intervening store clears the reservation ──
    var socd = soc_top_64_init(0x1000)
    var ramd = socd.ram
    ramd = ram64_write(ramd, 0x70, 4, 1)              # mem[0x70] = 1
    ramd = ram64_write(ramd, 0x00, 4, 0x800002B7)     # lui  x5, 0x80000
    ramd = ram64_write(ramd, 0x04, 4, 0x02029293)     # slli x5, x5, 32
    ramd = ram64_write(ramd, 0x08, 4, 0x0202D293)     # srli x5, x5, 32
    ramd = ram64_write(ramd, 0x0C, 4, 0x07028293)     # addi x5, x5, 0x70
    ramd = ram64_write(ramd, 0x10, 4, 0x1002A32F)     # lr.w x6, (x5)
    ramd = ram64_write(ramd, 0x14, 4, 0x06300393)     # addi x7, x0, 99
    ramd = ram64_write(ramd, 0x18, 4, 0x0072A023)     # sw x7, 0(x5)   (intervening store)
    ramd = ram64_write(ramd, 0x1C, 4, 0x03700393)     # addi x7, x0, 55
    ramd = ram64_write(ramd, 0x20, 4, 0x1872A42F)     # sc.w x8, x7, (x5)
    ramd = ram64_write(ramd, 0x24, 4, 0x0000006F)     # jal x0, 0 (park)
    socd.ram = ramd
    socd.core.pc = 0x8000_0000
    var pd = 0
    while pd < 14:
        socd = soc_top_64_tick(socd)
        pd = pd + 1
    val dmem = ram64_read(socd.ram, 0x70, 4)
    print("cased x6={socd.core.rf.regs[6]} x8={socd.core.rf.regs[8]} mem[0x70]={dmem}")
    fails = fails + check("cased lr.w loaded 1", socd.core.rf.regs[6] == 1)
    fails = fails + check("cased sc.w failed (rd == 1)", socd.core.rf.regs[8] == 1)
    fails = fails + check("cased mem kept intervening 99 (sc did NOT write 55)", dmem == 99)

    # ── Case e: WFI + timer wake — pc holds at wfi, then handler with ──
    # ── mepc == wfi+4 (wfi retires as NOP on wake, take uses next pc) ──
    var soce = soc_top_64_init(0x1000)
    var rame = soce.ram
    rame = ram64_write(rame, 0x000, 4, 0x800002B7)    # lui  x5, 0x80000
    rame = ram64_write(rame, 0x004, 4, 0x02029293)    # slli x5, x5, 32
    rame = ram64_write(rame, 0x008, 4, 0x0202D293)    # srli x5, x5, 32
    rame = ram64_write(rame, 0x00C, 4, 0x10028293)    # addi x5, x5, 0x100 (handler)
    rame = ram64_write(rame, 0x010, 4, 0x30529073)    # csrrw x0, mtvec, x5
    rame = ram64_write(rame, 0x014, 4, 0x02004337)    # lui  x6, 0x2004  (mtimecmp)
    rame = ram64_write(rame, 0x018, 4, 0x03C00393)    # addi x7, x0, 60
    rame = ram64_write(rame, 0x01C, 4, 0x00733023)    # sd   x7, 0(x6)   mtimecmp=60
    rame = ram64_write(rame, 0x020, 4, 0x08000393)    # addi x7, x0, 0x80 (MTIE)
    rame = ram64_write(rame, 0x024, 4, 0x3043A073)    # csrrs x0, mie, x7
    rame = ram64_write(rame, 0x028, 4, 0x00800393)    # addi x7, x0, 8   (MIE)
    rame = ram64_write(rame, 0x02C, 4, 0x3003A073)    # csrrs x0, mstatus, x7
    rame = ram64_write(rame, 0x030, 4, 0x10500073)    # wfi
    rame = ram64_write(rame, 0x034, 4, 0x07700493)    # addi x9, x0, 0x77 (post-wfi)
    rame = ram64_write(rame, 0x038, 4, 0x0000006F)    # jal x0, 0
    # Handler at 0x8000_0100
    rame = ram64_write(rame, 0x100, 4, 0x32100593)    # addi x11, x0, 0x321
    rame = ram64_write(rame, 0x104, 4, 0x20B2A023)    # sw x11, 0x200(x5) -> 0x8000_0300
    rame = ram64_write(rame, 0x108, 4, 0x34202673)    # csrrs x12, mcause, x0
    rame = ram64_write(rame, 0x10C, 4, 0x341026F3)    # csrrs x13, mepc, x0
    rame = ram64_write(rame, 0x110, 4, 0x0000006F)    # jal x0, 0 (park)
    soce.ram = rame
    soce.core.pc = 0x8000_0000
    var pe = 0
    while pe < 30:
        soce = soc_top_64_tick(soce)
        pe = pe + 1
    val held_pc_30 = soce.core.pc
    val held_x9_30 = soce.core.rf.regs[9]
    while pe < 50:
        soce = soc_top_64_tick(soce)
        pe = pe + 1
    val held_pc_50 = soce.core.pc
    while pe < 120:
        soce = soc_top_64_tick(soce)
        pe = pe + 1
    val emarker = ram64_read(soce.ram, 0x300, 4)
    val e_cause: i64 = (1 << 63) | 7
    print("casee held30={held_pc_30} held50={held_pc_50} pc={soce.core.pc} mcause(x12)={soce.core.rf.regs[12]} mepc(x13)={soce.core.rf.regs[13]} marker={emarker} x9={soce.core.rf.regs[9]}")
    fails = fails + check("casee pc held at wfi (0x80000030) at tick 30", held_pc_30 == 0x8000_0030)
    fails = fails + check("casee pc still held at wfi at tick 50 (pre-timer)", held_pc_50 == 0x8000_0030)
    fails = fails + check("casee post-wfi insn NOT executed during hold (x9==0)", held_x9_30 == 0)
    fails = fails + check("casee timer wake entered handler (marker 0x321)", emarker == 0x321)
    fails = fails + check("casee mcause == machine timer interrupt (bit63|7)", soce.core.rf.regs[12] == e_cause)
    fails = fails + check("casee mepc == wfi+4 (0x80000034) — resume after wfi", soce.core.rf.regs[13] == 0x8000_0034)
    fails = fails + check("casee pc parks in handler at 0x80000110", soce.core.pc == 0x8000_0110)

    if fails == 0:
        print("SOC64 PROBE: ALL PASS")
        return 0
    print("SOC64 PROBE: {fails} FAILURES")
    1
