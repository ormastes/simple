# Probe: OpenSBI-lane M-mode payload boots in the soc_top_64 sim RAM.
#
# Loads the payload built by scripts/os/build_opensbi_rv64_soc.shs
# (build/os/opensbi_rv64_soc/payload_mmode_uart.bin) into DRAM @ 0x8000_0000
# via ram64_write, runs the real core64 datapath, and asserts the UART marker
# "OSBI-PAYLOAD-OK" plus the CLINT-mtime flag '+' appears in the uart_tx log.
#
# Fallback: when the build artifact is absent (no cross-gcc / offline), an
# embedded hand-encoded copy of the same RV64I payload runs instead — byte
# identical to the gcc output (verified against payload_mmode_uart.dis).
#
# Cases:
#   1. M-mode UART/CLINT stub payload (32-bit only) — the original hard PASS.
#   2. Throughput wall removed — bulk 128 MiB alloc + 2 MiB fw_payload load,
#      with measured before/after numbers.
#   3. REAL OpenSBI v1.4 fw_payload boot with the boot ABI — runs as far as it
#      honestly gets.  RV64C is now implemented (Lane PP: decode.spl rvc_expand
#      + core64 pc+=2), so the old first divergence (c.li @0x80000548 stepping
#      +4) is FIXED — the core now executes the compressed fw_boot_hart and the
#      compressed _start relocate loop correctly.  The NEW frontier is a
#      dword-crossing instruction-fetch bug in ram64_read: a 32-bit insn whose
#      byte address is ≡6 (mod 8) has its top two bytes zeroed by the width-4
#      read (no cross-doubleword stitch).  First such insn is `ld t5,16(t0)`
#      @0x8000008e -> fetched 0xFFFFBF03 instead of 0x0102bf03, decoding as a
#      bogus load that traps (cause 4).  This lives in soc_rtl/ram64.spl (NOT
#      rv64gc_rtl) — cross-lane request.  See doc/07_guide/os/opensbi_rv64_soc.md
#      and doc/08_tracking/bug/rv64_core_no_c_extension_opensbi_stall_2026-07-22.md.
use std.hardware.soc_rtl.soc_top_64.{SocTop64State, soc_top_64_init, soc_top_64_tick}
use std.hardware.soc_rtl.ram64.{ram64_write, ram64_init, ram64_read, ram64_load_bytes}
use std.hardware.rv64gc_rtl.regfile.{regfile64_write}

extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_time_now_micros() -> i64

fn check(name: text, ok: bool) -> i64:
    if ok:
        print("PASS {name}")
        return 0
    print("FAIL {name}")
    1

fn payload_words() -> [i64]:
    """Hand-encoded RV64I payload, word-for-word the gcc stub output:
    print "OSBI-PAYLOAD-OK" to UART THR @ 0x1000_0000, read CLINT mtime
    @ 0x0200_BFF8, print '+' (nonzero) / '-' (zero) + NL, spin @ +0x44."""
    [
        0x100002B7,  # lui   t0, 0x10000      UART base
        0x0200C3B7,  # lui   t2, 0x200C       CLINT mtime+8
        0x00000617,  # auipc a2, 0
        0x04060613,  # addi  a2, a2, 64       a2 = &msg
        0x00064303,  # putc: lbu t1, 0(a2)
        0x00030863,  # beqz  t1, clint
        0x00628023,  # sb    t1, 0(t0)        UART THR write
        0x00160613,  # addi  a2, a2, 1
        0xFF1FF06F,  # j     putc
        0xFF83BE03,  # clint: ld t3, -8(t2)   CLINT mtime read
        0x000E0663,  # beqz  t3, dead
        0x02B00313,  # li    t1, '+'
        0x0080006F,  # j     flag
        0x02D00313,  # dead: li t1, '-'
        0x00628023,  # flag: sb t1, 0(t0)
        0x00A00313,  # li    t1, 10
        0x00628023,  # sb    t1, 0(t0)
        0x0000006F,  # spin: j spin
        0x4942534F,  # msg: "OSBI"
        0x5941502D,  #      "-PAY"
        0x44414F4C,  #      "LOAD"
        0x004B4F2D   #      "-OK\0"
    ]

# ============================================================================
# Case 1 — M-mode UART/CLINT stub payload (unchanged; 32-bit-only, hard PASS)
# ============================================================================

fn run_stub_case() -> i64:
    """Original probe: the RV64I M-mode UART+CLINT stub prints
    'OSBI-PAYLOAD-OK' + CLINT '+' + NL.  100% 32-bit encodings, so it does
    NOT exercise the C-extension gap that Case 3 pins down."""
    print("=== Case 1: M-mode UART/CLINT stub ===")
    val path = "build/os/opensbi_rv64_soc/payload_mmode_uart.bin"
    val bytes = rt_file_read_bytes(path) ?? []
    var soc = soc_top_64_init(0x1000)
    var ram = soc.ram
    var nbytes = 0
    if bytes.len() > 0:
        print("payload source: built .bin ({path}, {bytes.len()} bytes)")
        var i = 0
        while i < bytes.len():
            ram = ram64_write(ram, i, 1, bytes[i] as i64)
            i = i + 1
        nbytes = bytes.len()
    else:
        print("payload source: embedded hand-encoded fallback (build artifact missing)")
        val words = payload_words()
        var i = 0
        while i < words.len():
            ram = ram64_write(ram, i * 4, 4, words[i])
            i = i + 1
        nbytes = words.len() * 4
    soc.ram = ram
    soc.core.pc = 0x8000_0000

    var t = 0
    while t < 300:
        soc = soc_top_64_tick(soc)
        t = t + 1

    # Expected UART transcript: "OSBI-PAYLOAD-OK" + '+' (mtime ticking) + NL
    val expected: [i64] = [79, 83, 66, 73, 45, 80, 65, 89, 76, 79, 65, 68, 45, 79, 75, 43, 10]
    print("uart_tx.len={soc.uart_tx.len()} pc={soc.core.pc}")
    var fails = 0
    fails = fails + check("payload loaded into RAM @ 0x80000000 ({nbytes} bytes)", nbytes > 0)
    fails = fails + check("uart_tx has 17 bytes", soc.uart_tx.len() == expected.len())
    var all_eq = soc.uart_tx.len() == expected.len()
    if all_eq:
        var j = 0
        while j < expected.len():
            if soc.uart_tx[j] != expected[j]:
                all_eq = false
                print("  uart_tx[{j}] = {soc.uart_tx[j]} want {expected[j]}")
            j = j + 1
    fails = fails + check("uart marker 'OSBI-PAYLOAD-OK' + CLINT '+' flag + NL", all_eq)
    fails = fails + check("payload parked in spin loop @ 0x80000044", soc.core.pc == 0x8000_0044)
    fails

# ============================================================================
# Case 2 — throughput wall removed: bulk alloc + bulk fw_payload load
# ============================================================================

fn run_wall_case() -> i64:
    """Prove the sim-throughput wall is gone: allocate a real 128 MiB DRAM and
    bulk-load the 2 MiB OpenSBI fw_payload.  Old path (O(N^2) ram64_init +
    byte-wise ram64_write) made this impractical (minutes); new path
    (doubling init + ram64_load_bytes word-packing) does it in a few seconds.
    Prints the measured before/after numbers required by the gate."""
    print("=== Case 2: throughput wall (bulk alloc + load) ===")
    val ram_bytes = 0x8000000 + 0x10000    # 128 MiB + 64 KiB (room for DTB)
    val t0 = rt_time_now_micros()
    var ram = ram64_init(ram_bytes)
    val t1 = rt_time_now_micros()
    val alloc_us = t1 - t0
    print("ALLOC 128MiB+64K ({((ram_bytes + 7) >> 3)} words): {alloc_us} us")

    val fw = rt_file_read_bytes("build/os/opensbi_rv64_soc/fw_payload.bin") ?? []
    var fails = 0
    if fw.len() == 0:
        print("fw_payload.bin absent (offline) — SKIP load timing; wall-removal covered by ram64 unit tests")
        fails = fails + check("bulk alloc completed (<60s)", alloc_us < 60000000)
        return fails
    val t2 = rt_time_now_micros()
    ram = ram64_load_bytes(ram, 0, fw)
    val t3 = rt_time_now_micros()
    val load_us = t3 - t2
    print("LOAD {fw.len()} bytes (fw_payload) via ram64_load_bytes: {load_us} us")
    # round-trip verify: first fw_payload word must match raw bytes
    val w0 = ram64_read(ram, 0, 4)
    val raw0 = (fw[0] as i64) | ((fw[1] as i64) << 8) | ((fw[2] as i64) << 16) | ((fw[3] as i64) << 24)
    fails = fails + check("bulk alloc 128MiB completed (<60s)", alloc_us < 60000000)
    fails = fails + check("bulk load 2MB completed (<60s)", load_us < 60000000)
    fails = fails + check("RAM round-trips fw_payload word[0] ({w0}=={raw0})", w0 == raw0)
    fails

# ============================================================================
# Case 3 — real OpenSBI fw_payload boot: first honest divergence (RV64 C-ext)
# ============================================================================

fn run_fw_payload_boot_case() -> i64:
    """Boot the REAL OpenSBI v1.4 fw_payload on soc_top_64 with the boot ABI
    (a0=hartid=0, a1=DTB=0x88000000) and record exactly how far it gets.

    Honest result (Lane PP): RV64C is now implemented, so the OLD divergence is
    FIXED — the compressed c.li @0x80000548 now steps +2 (-> 0x8000054a) and the
    core executes the compressed fw_boot_hart (c.li/c.ret) and the compressed
    _start relocate loop (c.li t3,3 @0x84, ...) correctly.  Boot advances ~39
    instructions past the old wall into the relocate loop.

    The NEW first divergence is a dword-crossing instruction-fetch bug that
    lives in soc_rtl/ram64.spl (ram64_read), NOT the rv64gc core: a 32-bit insn
    whose byte address is ≡6 (mod 8) is read with its top two bytes zeroed
    (width-4 read does not stitch across the 8-byte doubleword boundary).  The
    first such instruction is `ld t5,16(t0)` @0x8000008e, which fetches as
    0xFFFFBF03 instead of the true 0x0102bf03 and decodes as a bogus load that
    traps (cause 4).  This case pins BOTH facts deterministically."""
    print("=== Case 3: real fw_payload boot (RVC fixed; new fetch frontier) ===")
    val fw = rt_file_read_bytes("build/os/opensbi_rv64_soc/fw_payload.bin") ?? []
    if fw.len() == 0:
        print("fw_payload.bin absent (offline) — SKIP boot attempt (needs cross-gcc build)")
        return 0

    val ram_bytes = 0x8000000 + 0x10000
    var ram = ram64_init(ram_bytes)
    ram = ram64_load_bytes(ram, 0, fw)
    # Real SoC DTB at a1 (0x88000000): memory@80000000/128MiB, clint@2000000,
    # uart@10000000, model simple-soc-rv64 — matches this SoC's map exactly.
    val dtb = rt_file_read_bytes("examples/09_embedded/simple_os/arch/riscv64/soc_virt.dtb") ?? []
    if dtb.len() > 0:
        ram = ram64_load_bytes(ram, 0x8000000, dtb)

    var soc = soc_top_64_init(0x1000)
    soc.ram = ram
    var core0 = soc.core
    core0.pc = 0x80000000
    core0.rf = regfile64_write(core0.rf, 10, 0, true)            # a0 = hartid 0
    core0.rf = regfile64_write(core0.rf, 11, 0x88000000, true)   # a1 = DTB
    soc.core = core0

    # Tick until the core reaches fw_boot_hart @ 0x80000548 (first RVC insn).
    var reached = false
    var t = 0
    val tsr = rt_time_now_micros()
    while t < 64 and not reached:
        soc = soc_top_64_tick(soc)
        if soc.core.pc == 0x80000548:
            reached = true
        t = t + 1
    val insn_lo16 = ram64_read(ram, 0x548, 4) & 0xFFFF   # low 16 bits @ 0x80000548
    print("reached fw_boot_hart @0x80000548 after {t} ticks: {reached}, insn_lo16={insn_lo16}")

    var fails = 0
    fails = fails + check("core reaches fw_boot_hart @0x80000548 executing real fw_payload", reached)
    fails = fails + check("first insn there is RVC c.li a0,-1 (0x557d={insn_lo16})", insn_lo16 == 0x557d)

    # RVC FIXED: stepping the compressed c.li advances pc by 2 (-> 0x8000054a),
    # NOT 4.  This is the deterministic proof the old no-C wall is gone.
    val pc_before = soc.core.pc
    soc = soc_top_64_tick(soc)
    val pc_after = soc.core.pc
    val delta = pc_after - pc_before
    print("RVC STEP: c.li @0x80000548 -> pc {pc_before} => {pc_after} (delta={delta}); spec RVC delta=2")
    fails = fails + check("RVC fixed: compressed c.li advances +2 not +4 (delta={delta})",
        delta == 2 and pc_after == 0x8000054a)

    # NEW FRONTIER: the width-4 fetch of a 32-bit insn at an address ≡6 (mod 8)
    # is corrupted (top 16 bits zeroed) because ram64_read does not stitch
    # across the 8-byte doubleword boundary.  First such insn: ld t5,16(t0)
    # @0x8000008e.  Pin it directly against the true fw_payload bytes.
    val fetched_8e = ram64_read(ram, 0x8e, 4)
    var true_8e: i64 = 0
    if fw.len() > 0x91:
        true_8e = (fw[0x8e] as i64) | ((fw[0x8f] as i64) << 8) |
                  ((fw[0x90] as i64) << 16) | ((fw[0x91] as i64) << 24)
    val fetched_8a = ram64_read(ram, 0x8a, 4)   # off&7=2 within a dword: OK
    print("FETCH @0x8000008e: soc_fetch={fetched_8e} true={true_8e} (off&7=6, dword-crossing)")
    print("FETCH @0x8000008a: soc_fetch={fetched_8a} (off&7=2, correct)")
    # Deterministic corrupt value: ram64_read does (raw >> 48) & 0xFFFFFFFF for
    # a width-4 read at byte_offset 6.  The high bytes (0x90,0x91) are dropped
    # (no cross-doubleword stitch) AND Simple's `>>` is arithmetic, so byte
    # 0x8f=0xbf (sign bit set) sign-extends: 0x0102bf03 -> 0xFFFFBF03 (=
    # 4294950659).  Either defect alone corrupts the fetch — both live in
    # soc_rtl/ram64.spl, outside this lane's file set.
    fails = fails + check("new frontier: ram64_read corrupts 32b insn @off 0x8e (0xFFFFBF03 != true)",
        fetched_8e == 4294950659 and true_8e == 0x0102bf03 and fetched_8e != true_8e)
    fails = fails + check("control: aligned-within-dword fetch @off 0x8a is exact (0x0002be03)",
        fetched_8a == 0x0002be03)

    # Characterization: run the real boot forward; the corrupted @0x8e fetch
    # decodes as a bogus load and the boot takes a load trap (cause 4) with
    # mtvec still 0 (OpenSBI's handler is installed later).  Deterministic
    # single-cycle behaviour — reproduces every run.
    var tt = 0
    var trapped = false
    while tt < 80 and not trapped:
        soc = soc_top_64_tick(soc)
        if soc.core.csr_m.mcause != 0:
            trapped = true
        tt = tt + 1
    val tse = rt_time_now_micros()
    print("post-RVC boot trap after {tt} more ticks: mcause={soc.core.csr_m.mcause}")
    print("ticks/sec ~= {((t + tt + 1) * 1000000) / (tse - tsr)}")
    fails = fails + check("boot progresses into relocate loop then hits fetch-bug load trap (cause 4)",
        trapped and soc.core.csr_m.mcause == 4)
    print("finding: RV64C works (old 0x548 wall gone); new wall = ram64_read dword-crossing fetch (soc_rtl, cross-lane)")
    fails

fn main() -> i64:
    var fails = 0
    fails = fails + run_stub_case()
    fails = fails + run_wall_case()
    fails = fails + run_fw_payload_boot_case()
    if fails == 0:
        print("OPENSBI BOOT PROBE: ALL PASS")
        return 0
    print("OPENSBI BOOT PROBE: {fails} FAIL")
    1
