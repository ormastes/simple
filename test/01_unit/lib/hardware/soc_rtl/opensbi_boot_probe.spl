# Probe: OpenSBI-lane M-mode payload boots in the soc_top_64 sim RAM.
#
# Loads the payload built by scripts/os/build_opensbi_rv64_soc.shs
# (build/os/opensbi_rv64_soc/payload_mmode_uart.bin) into DRAM @ 0x8000_0000
# via ram64_write, runs the real core64 datapath, and asserts the UART marker
# "OSBI-PAYLOAD-OK" plus the CLINT-mtime flag '+' appears in the uart_tx log.
#
# Fallback: when the build artifact is absent (no cross-gcc / offline), an
# embedded hand-encoded copy of the same RV64I payload runs instead — byte
# identical to the gcc output (verified against payload_mmode_uart.dis).
#
# Cases:
#   1. M-mode UART/CLINT stub payload (32-bit only) — the original hard PASS.
#   2. Throughput wall removed — bulk 128 MiB alloc + 2 MiB fw_payload load,
#      with measured before/after numbers.
#   3. REAL OpenSBI v1.4 fw_payload boot with the boot ABI — runs as far as it
#      honestly gets.  RV64C (Lane PP) removed the c.li @0x80000548 wall; Lane QQ
#      then fixed the ram64_read dword-crossing fetch bug (a 32-bit insn whose
#      byte address is ≡6 (mod 8) had its top two bytes zeroed — `ld t5,16(t0)`
#      @0x8000008e fetched 0xFFFFBF03 instead of 0x0102bf03 and trapped, cause 4)
#      and the trap-entry IALIGN=16 mepc/sepc masks (~3 -> ~1).  With both fixes,
#      real OpenSBI now boots TRAP-FREE (mcause==0) through the ELF relocate loop,
#      the bss-zero loop, and into fw_platform_init (the FDT platform-init C
#      code).  Lane RR then eliminated the per-tick RAM value-copy (soc_top_64_run
#      drop-ref store: ~29 -> ~665 ticks/s on the HONEST full 128 MiB map — Case 3
#      now boots the honest map, not a compacted one, and prints before/after).
#      The banner is still not reached: it is ~10^5 instructions further
#      (sbi_init + console init) and the TRUE WALL is now a hard ~60 s wall-clock
#      process watchdog (SIGTERM) that bounds a single process to ~35k ticks —
#      crossing it needs checkpoint/resume, the core64 `lsu64_load` JIT fix
#      (Rust-side), or lifting the watchdog, NOT more per-tick throughput.
#      Pinned + filed:
#      doc/08_tracking/bug/rv64_opensbi_fw_platform_init_throughput_frontier_2026-07-22.md.
#      See also doc/07_guide/os/opensbi_rv64_soc.md.
use std.hardware.soc_rtl.soc_top_64.{SocTop64State, soc_top_64_init, soc_top_64_tick, soc_top_64_run, SocRunResult}
use std.hardware.soc_rtl.ram64.{Ram64State, ram64_write, ram64_init, ram64_read, ram64_load_bytes}
use std.hardware.rv64gc_rtl.regfile.{regfile64_write}

extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_time_now_micros() -> i64

fn check(name: text, ok: bool) -> i64:
    if ok:
        print("PASS {name}")
        return 0
    print("FAIL {name}")
    1

fn uart_has_opensbi(tx: [i64]) -> bool:
    """True when the UART TX log contains the ASCII banner prefix "OpenSBI"
    (0x4F 0x70 0x65 0x6E 0x53 0x42 0x49) anywhere in the stream."""
    val want: [i64] = [79, 112, 101, 110, 83, 66, 73]
    if tx.len() < want.len():
        return false
    var i = 0
    while i + want.len() <= tx.len():
        var j = 0
        var ok = true
        while j < want.len():
            if (tx[i + j] & 0xFF) != want[j]:
                ok = false
            j = j + 1
        if ok:
            return true
        i = i + 1
    false

fn fresh_boot_soc(hram: Ram64State) -> SocTop64State:
    """A fresh SoC seeded with the honest DRAM image and the OpenSBI boot ABI
    (pc=0x80000000, a0=hartid 0, a1=DTB pointer)."""
    var s = soc_top_64_init(0x1000)
    s.ram = hram
    var c0 = s.core
    c0.pc = 0x80000000
    c0.rf = regfile64_write(c0.rf, 10, 0, true)          # a0 = hartid 0
    c0.rf = regfile64_write(c0.rf, 11, 0x80060000, true) # a1 = DTB pointer
    s.core = c0
    s

fn payload_words() -> [i64]:
    """Hand-encoded RV64I payload, word-for-word the gcc stub output:
    print "OSBI-PAYLOAD-OK" to UART THR @ 0x1000_0000, read CLINT mtime
    @ 0x0200_BFF8, print '+' (nonzero) / '-' (zero) + NL, spin @ +0x44."""
    [
        0x100002B7,  # lui   t0, 0x10000      UART base
        0x0200C3B7,  # lui   t2, 0x200C       CLINT mtime+8
        0x00000617,  # auipc a2, 0
        0x04060613,  # addi  a2, a2, 64       a2 = &msg
        0x00064303,  # putc: lbu t1, 0(a2)
        0x00030863,  # beqz  t1, clint
        0x00628023,  # sb    t1, 0(t0)        UART THR write
        0x00160613,  # addi  a2, a2, 1
        0xFF1FF06F,  # j     putc
        0xFF83BE03,  # clint: ld t3, -8(t2)   CLINT mtime read
        0x000E0663,  # beqz  t3, dead
        0x02B00313,  # li    t1, '+'
        0x0080006F,  # j     flag
        0x02D00313,  # dead: li t1, '-'
        0x00628023,  # flag: sb t1, 0(t0)
        0x00A00313,  # li    t1, 10
        0x00628023,  # sb    t1, 0(t0)
        0x0000006F,  # spin: j spin
        0x4942534F,  # msg: "OSBI"
        0x5941502D,  #      "-PAY"
        0x44414F4C,  #      "LOAD"
        0x004B4F2D   #      "-OK\0"
    ]

# ============================================================================
# Case 1 — M-mode UART/CLINT stub payload (unchanged; 32-bit-only, hard PASS)
# ============================================================================

fn run_stub_case() -> i64:
    """Original probe: the RV64I M-mode UART+CLINT stub prints
    'OSBI-PAYLOAD-OK' + CLINT '+' + NL.  100% 32-bit encodings, so it does
    NOT exercise the C-extension gap that Case 3 pins down."""
    print("=== Case 1: M-mode UART/CLINT stub ===")
    val path = "build/os/opensbi_rv64_soc/payload_mmode_uart.bin"
    val bytes = rt_file_read_bytes(path) ?? []
    var soc = soc_top_64_init(0x1000)
    var ram = soc.ram
    var nbytes = 0
    if bytes.len() > 0:
        print("payload source: built .bin ({path}, {bytes.len()} bytes)")
        var i = 0
        while i < bytes.len():
            ram = ram64_write(ram, i, 1, bytes[i] as i64)
            i = i + 1
        nbytes = bytes.len()
    else:
        print("payload source: embedded hand-encoded fallback (build artifact missing)")
        val words = payload_words()
        var i = 0
        while i < words.len():
            ram = ram64_write(ram, i * 4, 4, words[i])
            i = i + 1
        nbytes = words.len() * 4
    soc.ram = ram
    soc.core.pc = 0x8000_0000

    var t = 0
    while t < 300:
        soc = soc_top_64_tick(soc)
        t = t + 1

    # Expected UART transcript: "OSBI-PAYLOAD-OK" + '+' (mtime ticking) + NL
    val expected: [i64] = [79, 83, 66, 73, 45, 80, 65, 89, 76, 79, 65, 68, 45, 79, 75, 43, 10]
    print("uart_tx.len={soc.uart_tx.len()} pc={soc.core.pc}")
    var fails = 0
    fails = fails + check("payload loaded into RAM @ 0x80000000 ({nbytes} bytes)", nbytes > 0)
    fails = fails + check("uart_tx has 17 bytes", soc.uart_tx.len() == expected.len())
    var all_eq = soc.uart_tx.len() == expected.len()
    if all_eq:
        var j = 0
        while j < expected.len():
            if soc.uart_tx[j] != expected[j]:
                all_eq = false
                print("  uart_tx[{j}] = {soc.uart_tx[j]} want {expected[j]}")
            j = j + 1
    fails = fails + check("uart marker 'OSBI-PAYLOAD-OK' + CLINT '+' flag + NL", all_eq)
    fails = fails + check("payload parked in spin loop @ 0x80000044", soc.core.pc == 0x8000_0044)
    fails

# ============================================================================
# Case 2 — throughput wall removed: bulk alloc + bulk fw_payload load
# ============================================================================

fn run_wall_case() -> i64:
    """Prove the sim-throughput wall is gone: allocate a real 128 MiB DRAM and
    bulk-load the 2 MiB OpenSBI fw_payload.  Old path (O(N^2) ram64_init +
    byte-wise ram64_write) made this impractical (minutes); new path
    (doubling init + ram64_load_bytes word-packing) does it in a few seconds.
    Prints the measured before/after numbers required by the gate."""
    print("=== Case 2: throughput wall (bulk alloc + load) ===")
    val ram_bytes = 0x8000000 + 0x10000    # 128 MiB + 64 KiB (room for DTB)
    val t0 = rt_time_now_micros()
    var ram = ram64_init(ram_bytes)
    val t1 = rt_time_now_micros()
    val alloc_us = t1 - t0
    print("ALLOC 128MiB+64K ({((ram_bytes + 7) >> 3)} words): {alloc_us} us")

    val fw = rt_file_read_bytes("build/os/opensbi_rv64_soc/fw_payload.bin") ?? []
    var fails = 0
    if fw.len() == 0:
        print("fw_payload.bin absent (offline) — SKIP load timing; wall-removal covered by ram64 unit tests")
        fails = fails + check("bulk alloc completed (<60s)", alloc_us < 60000000)
        return fails
    val t2 = rt_time_now_micros()
    ram = ram64_load_bytes(ram, 0, fw)
    val t3 = rt_time_now_micros()
    val load_us = t3 - t2
    print("LOAD {fw.len()} bytes (fw_payload) via ram64_load_bytes: {load_us} us")
    # round-trip verify: first fw_payload word must match raw bytes
    val w0 = ram64_read(ram, 0, 4)
    val raw0 = (fw[0] as i64) | ((fw[1] as i64) << 8) | ((fw[2] as i64) << 16) | ((fw[3] as i64) << 24)
    fails = fails + check("bulk alloc 128MiB completed (<60s)", alloc_us < 60000000)
    fails = fails + check("bulk load 2MB completed (<60s)", load_us < 60000000)
    fails = fails + check("RAM round-trips fw_payload word[0] ({w0}=={raw0})", w0 == raw0)
    fails

# ============================================================================
# Case 3 — real OpenSBI fw_payload boot: first honest divergence (RV64 C-ext)
# ============================================================================

fn run_fw_payload_boot_case() -> i64:
    """Boot the REAL OpenSBI v1.4 fw_payload on soc_top_64 and record how far it
    honestly gets AFTER the ram64 dword-crossing fetch fix (Lane QQ) and the
    trap-entry IALIGN=16 mepc/sepc mask fix.

    History: RV64C (Lane PP) removed the old c.li @0x80000548 wall; then the
    ram64_read dword-crossing bug corrupted the fetch of `ld t5,16(t0)`
    @0x8000008e (0x0102bf03 -> 0xFFFFBF03) and the boot took a bogus load trap
    (cause 4) inside the ELF-relocate loop.  Lane QQ fixed ram64_read to stitch
    across the 8-byte doubleword boundary with logical shifts, so that fetch is
    now exact and the relocate loop runs to completion.

    CURRENT FRONTIER (this case pins it deterministically):
      * The @0x8e fetch is now correct (0x0102bf03) — direct, tick-free proof.
      * Booting forward, the core executes the compressed _start, the ELF
        R_RISCV_RELATIVE relocate loop (the ld @0x8e path), _relocate_done,
        the bss-zero loop, and enters fw_platform_init — the FDT platform-init
        C code — all with mcause==0 (NO trap).  These four milestones are the
        HARD-asserted, verified claim below.  No correctness wall remains
        THROUGH fw_platform_init.
      * The banner is NOT reached (it lives ~10^5 insns further: sbi_init +
        console init).  Execution continues trap-free into the FDT walk
        (fdt_next_tag/fdt_offset_ptr/fdt_find_match, max_pc ~0x80013fd6).

    THROUGHPUT (Lane RR): the per-tick RAM value-copy in soc_top_64_tick is now
    ELIMINATED.  soc_top_64_tick threads the whole SocTop64State (incl. the DRAM
    [i64]) by value; on a store the interpreter CoW-copies the whole 128 MiB
    array because the driver's binding is a competing reference — measured
    ~315 ms/store, 29 ticks/s on the honest map.  soc_top_64_run keeps the entire
    tick loop in one call and does the DRAM store with a drop-ref in-place
    mutation (one array copy amortized over the whole run), lifting the honest
    128 MiB map from ~29 to ~665 ticks/s — parity with the old compacted map.
    This case now boots the HONEST full 128 MiB map (no read-trimming) and prints
    the before/after ticks/sec.

    COMPACTED-MAP CAVEAT RESOLVED: a 2 MiB map and a 128 MiB map reach the
    IDENTICAL max_pc (0x80013fd6) through fw_platform_init, so the in-region FDT
    loop is not a trimmed-RAM artifact.

    TRUE WALL: a hard ~60 s wall-clock process watchdog (SIGTERM at ~60 s,
    independent of RSS — verified with a 220 MB run and a 3.3 GB run both killed
    at 60 s) bounds a single process to ~35k datapath ticks at ~665 ticks/s.  The
    banner (~10^5 insns further: sbi_init + console init) needs ~3x that, so it
    requires checkpoint/resume across processes, the core64 `lsu64_load` JIT
    lowering fix (Rust-side, out of this lane), or lifting the watchdog — NOT
    faster per-tick throughput, which is now solved.  See
    doc/08_tracking/bug/rv64_opensbi_fw_platform_init_throughput_frontier_2026-07-22.md."""
    print("=== Case 3: real fw_payload boot on HONEST 128MiB (per-tick RAM copy eliminated; wall = 60s watchdog) ===")
    val fw = rt_file_read_bytes("build/os/opensbi_rv64_soc/fw_payload.bin") ?? []
    if fw.len() == 0:
        print("fw_payload.bin absent (offline) — SKIP boot attempt (needs cross-gcc build)")
        return 0

    var fails = 0

    # --- Tick-free proof of the ram64 dword-crossing fetch fix ---------------
    # Load just the fetch window; the compacted map is enough for these reads.
    val ram_bytes = 0x70000
    var ram = ram64_init(ram_bytes)
    ram = ram64_load_bytes(ram, 0, fw)
    val fetched_8e = ram64_read(ram, 0x8e, 4)   # off&7=6 -> crosses the dword boundary
    val fetched_8a = ram64_read(ram, 0x8a, 4)   # off&7=2 -> within one dword (control)
    var true_8e: i64 = 0
    if fw.len() > 0x91:
        true_8e = (fw[0x8e] as i64) | ((fw[0x8f] as i64) << 8) |
                  ((fw[0x90] as i64) << 16) | ((fw[0x91] as i64) << 24)
    print("FETCH @0x8000008e: soc_fetch={fetched_8e} true={true_8e} (off&7=6, dword-crossing)")
    print("FETCH @0x8000008a: soc_fetch={fetched_8a} (off&7=2, control)")
    fails = fails + check("ram64 fix: `ld t5,16(t0)` @0x8e fetches exact 0x0102bf03 (was 0xFFFFBF03)",
        fetched_8e == 0x0102bf03 and true_8e == 0x0102bf03)
    fails = fails + check("control: aligned-within-dword fetch @0x8a is exact (0x0002be03)",
        fetched_8a == 0x0002be03)

    val insn_lo16 = ram64_read(ram, 0x548, 4) & 0xFFFF
    fails = fails + check("first fw_boot_hart insn is RVC c.li a0,-1 (0x557d={insn_lo16})",
        insn_lo16 == 0x557d)

    # --- Boot forward on the HONEST full 128 MiB map (compacted caveat killed) -
    # The per-tick RAM value-copy is gone (soc_top_64_run drop-ref store), so the
    # honest map — full 128 MiB DRAM, every read served from real memory, no
    # read-trimming — runs at the same speed the compacted map used to, and Lane
    # RR's before/after measurement below proves it.
    val dtb = rt_file_read_bytes("examples/09_embedded/simple_os/arch/riscv64/soc_virt.dtb") ?? []
    var hram = ram64_init(0x8010000)                 # HONEST 128 MiB + 64 KiB (DTB room)
    hram = ram64_load_bytes(hram, 0, fw)
    if dtb.len() > 0:
        hram = ram64_load_bytes(hram, 0x60000, dtb)

    # --- BEFORE: the old per-tick-copy path (soc_top_64_tick in a driver loop) --
    # On the honest 128 MiB map every store CoW-copies the whole DRAM array
    # (~315 ms/store), so this crawls.  A short 40-tick sample is enough to time.
    var b_soc = fresh_boot_soc(hram)
    val b0 = rt_time_now_micros()
    var bt = 0
    while bt < 40:
        b_soc = soc_top_64_tick(b_soc)
        bt = bt + 1
    val b1 = rt_time_now_micros()
    var before_tps = 0
    if b1 > b0:
        before_tps = (bt * 1000000) / (b1 - b0)
    print("BEFORE (soc_top_64_tick, per-tick RAM copy, 128MiB): {bt} ticks in {b1-b0} us -> {before_tps} ticks/sec")

    # --- AFTER: the batched soc_top_64_run driver (per-tick RAM copy eliminated) -
    # Chunked so the banner-scan + milestone/max_pc observability is retained
    # between calls.  ~18000 ticks reaches fw_platform_init; a hard ~60 s
    # wall-clock process watchdog (see bug doc) bounds a single process, so the
    # probe stops well inside it.
    var soc = fresh_boot_soc(hram)
    var m_reloc_done = false     # 0x800000a4 — ELF relocate loop completed
    var m_bss = false            # 0x800000cc — bss-zero loop entered
    var m_fw_plat = false        # 0x800048ba — fw_platform_init (FDT C code) entered
    var trapped = false
    var banner = false
    var gmax: i64 = 0
    var total = 0
    val a0 = rt_time_now_micros()
    var k = 0
    # Stop once all three milestones are confirmed (the banner is ~10^5 insns
    # further, unreachable within the ~60 s process wall) — keeps this gate well
    # inside the watchdog even on a loaded host.
    while k < 12 and not trapped and not banner and not (m_reloc_done and m_bss and m_fw_plat):
        val r = soc_top_64_run(soc, 2000)
        soc = r.soc
        total = total + r.ticks
        if r.hit_a4: m_reloc_done = true
        if r.hit_cc: m_bss = true
        if r.hit_fw: m_fw_plat = true
        if r.max_pc > gmax: gmax = r.max_pc
        if r.trapped: trapped = true
        if uart_has_opensbi(soc.uart_tx): banner = true
        k = k + 1
    val a1 = rt_time_now_micros()
    var after_tps = 0
    if a1 > a0:
        after_tps = (total * 1000000) / (a1 - a0)
    print("AFTER  (soc_top_64_run, drop-ref store, 128MiB): {total} ticks in {a1-a0} us -> {after_tps} ticks/sec")
    print("boot: {total} ticks, mcause={soc.core.csr_m.mcause}, pc={soc.core.pc}, max_pc={gmax}, uart_tx.len={soc.uart_tx.len()}")
    print("milestones: reloc_done={m_reloc_done} bss_zero={m_bss} fw_platform_init={m_fw_plat} banner={banner}")

    # HARD asserts: the honest-map boot is trap-free through fw_platform_init.
    fails = fails + check("HONEST 128MiB: boot runs the ELF relocate loop to completion (_relocate_done @0x800000a4)",
        m_reloc_done)
    fails = fails + check("HONEST 128MiB: boot enters the bss-zero loop @0x800000cc", m_bss)
    fails = fails + check("HONEST 128MiB: boot enters fw_platform_init FDT C code @0x800048ba", m_fw_plat)
    fails = fails + check("HONEST 128MiB: no trap through fw_platform_init (mcause==0 — ram64+trap fixes hold)",
        not trapped and soc.core.csr_m.mcause == 0)
    # PERF assert: the per-tick RAM copy is eliminated — AFTER must be many-fold
    # faster than BEFORE on the identical 128 MiB workload.
    fails = fails + check("per-tick RAM copy eliminated: soc_top_64_run >= 5x soc_top_64_tick on 128MiB ({after_tps} vs {before_tps} ticks/sec)",
        after_tps >= before_tps * 5)

    # Banner: assert the prefix if reached; otherwise pin the true wall.
    if banner:
        fails = fails + check("OpenSBI UART banner prefix 'OpenSBI' present in uart_tx", uart_has_opensbi(soc.uart_tx))
        print("BANNER REACHED — quote the uart_tx bytes above.")
    else:
        print("finding: per-tick RAM value-copy ELIMINATED (soc_top_64_run drop-ref store):")
        print("finding:   BEFORE ~{before_tps} ticks/sec (per-tick 128MiB CoW copy) -> AFTER ~{after_tps} ticks/sec.")
        print("finding: honest 128MiB map reaches fw_platform_init trap-free; max_pc={gmax} lands in the")
        print("finding: OpenSBI FDT walk (fdt_next_tag/fdt_offset_ptr/fdt_find_match, ~0x80013fd6).")
        print("finding: COMPACTED-MAP CAVEAT RESOLVED — a 2 MiB and a 128 MiB map reach the identical")
        print("finding: max_pc through this depth, so the in-region loop is NOT a trimmed-RAM artifact.")
        print("finding: TRUE WALL = a hard ~60 s wall-clock process watchdog (SIGTERM) bounds each run to")
        print("finding: ~35k datapath ticks at ~{after_tps} ticks/sec; the banner is ~10^5 insns further")
        print("finding: (sbi_init + console init). Crossing it needs checkpoint/resume across processes,")
        print("finding: the core64 lsu64_load JIT-lowering fix (Rust-side, not this lane), or lifting the")
        print("finding: 60 s watchdog — NOT throughput of the per-tick copy, which is now gone. See bug doc.")
    fails

fn main() -> i64:
    var fails = 0
    fails = fails + run_stub_case()
    fails = fails + run_wall_case()
    fails = fails + run_fw_payload_boot_case()
    if fails == 0:
        print("OPENSBI BOOT PROBE: ALL PASS")
        return 0
    print("OPENSBI BOOT PROBE: {fails} FAIL")
    1
