# @cover src/lib/hardware/opensource_rtl/vexriscv_smp/mod.spl 0%
# @cover src/lib/hardware/opensource_rtl/vexriscv_smp/vexriscv_smp_top.spl 0%
"""
# VexRiscv-SMP Import Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** REQ-1
**Artifacts:** N/A

## Overview

Verifies AC-1: at least one proven RV64 core (VexRiscv-SMP) is imported
under src/lib/hardware/opensource_rtl/ with LICENSE and build docs.
Tests that the import manifest, port-map API, and .v filename resolution
functions return correct values.

Covers:
- AC-1 (RV64 core imported with license + build docs)
"""

use std.spipe.*
use lib.hardware.opensource_rtl.vexriscv_smp.vexriscv_smp_top.{
    VexRiscvSmpPortMap,
    vexriscv_smp_v_filename,
    vexriscv_smp_import_path
}


# ============================================================================
# Helper functions
# ============================================================================

fn make_single_core_config() -> VexRiscvSmpPortMap:
    return VexRiscvSmpPortMap {
        axi_data_width: 128,
        axi_addr_width: 32,
        hart_count: 1,
        icache_size_kb: 8,
        dcache_size_kb: 8,
    }

fn make_dual_core_config() -> VexRiscvSmpPortMap:
    return VexRiscvSmpPortMap {
        axi_data_width: 128,
        axi_addr_width: 32,
        hart_count: 2,
        icache_size_kb: 8,
        dcache_size_kb: 8,
    }


# ============================================================================
# AC-1: VexRiscv-SMP Port Map and Filename Resolution
# ============================================================================

describe "VexRiscvSmpPortMap":
    it "AC-1: single-core port map has axi_data_width 128":
        val cfg = make_single_core_config()
        expect(cfg.axi_data_width).to_equal(128)

    it "AC-1: single-core port map has hart_count 1":
        val cfg = make_single_core_config()
        expect(cfg.hart_count).to_equal(1)

    it "AC-1: dual-core port map has hart_count 2":
        val cfg = make_dual_core_config()
        expect(cfg.hart_count).to_equal(2)

    it "AC-1: axi_addr_width is 32":
        val cfg = make_single_core_config()
        expect(cfg.axi_addr_width).to_equal(32)

    it "AC-1: icache_size_kb is 8":
        val cfg = make_single_core_config()
        expect(cfg.icache_size_kb).to_equal(8)


describe "vexriscv_smp_v_filename":
    it "AC-1: single-core filename starts with VexRiscvLitexSmpCluster":
        val cfg = make_single_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_start_with("VexRiscvLitexSmpCluster")

    it "AC-1: single-core filename contains Cc1 (1 core)":
        val cfg = make_single_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_contain("Cc1")

    it "AC-1: dual-core filename contains Cc2 (2 cores)":
        val cfg = make_dual_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_contain("Cc2")

    it "AC-1: filename contains Iw64 (64-bit instruction bus)":
        val cfg = make_single_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_contain("Iw64")

    it "AC-1: filename contains Dw64 (64-bit data bus)":
        val cfg = make_single_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_contain("Dw64")

    it "AC-1: filename contains Ldw128 (128-bit LiteDRAM interface)":
        val cfg = make_single_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_contain("Ldw128")

    it "AC-1: filename ends with .v":
        val cfg = make_single_core_config()
        val name = vexriscv_smp_v_filename(cfg)
        expect(name).to_end_with(".v")


describe "vexriscv_smp_import_path":
    it "AC-1: import path is non-empty":
        val p = vexriscv_smp_import_path()
        val len = p.length()
        expect(len).to_be_greater_than(0)

    it "AC-1: import path contains opensource_rtl":
        val p = vexriscv_smp_import_path()
        expect(p).to_contain("opensource_rtl")

    it "AC-1: import path contains vexriscv_smp":
        val p = vexriscv_smp_import_path()
        expect(p).to_contain("vexriscv_smp")
