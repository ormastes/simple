# @cover src/lib/hardware/fpga_linux/synthesis_wrapper.spl 0%
"""
# Synthesis Wrapper VexRiscv-SMP Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** REQ-3
**Artifacts:** N/A

## Overview

Verifies AC-3: synthesis_wrapper generates Vivado TCL that includes
VexRiscv-SMP .v sources and enables S_AXI_HP0 for K26 bitstream.
Tests that new add_verilog_sources and enable_axi_hp_port methods
produce TCL containing expected directives.

Covers:
- AC-3 (Vivado 2025.2 TCL contains HP port enable + VexRiscv sources)
"""

use std.spipe.*
use lib.hardware.fpga_linux.synthesis_wrapper.{
    SynthesisProject,
    synthesis_project_default,
    add_verilog_sources,
    enable_axi_hp_port,
    generate_vivado_tcl_rv64
}


# ============================================================================
# Helpers
# ============================================================================

fn vexriscv_v_paths() -> Vec<text>:
    var paths = Vec<text>.new()
    paths.push("src/lib/hardware/opensource_rtl/vexriscv_smp/VexRiscvLitexSmpCluster_Cc1_Iw64Is8192Iy2_Dw64Ds8192Dy2_ITs4DTs4_Ldw128.v")
    return paths

fn make_project_with_vexriscv() -> SynthesisProject:
    val base = synthesis_project_default()
    val with_v = add_verilog_sources(base, vexriscv_v_paths())
    return enable_axi_hp_port(with_v, 0)

fn tcl_with_vexriscv() -> text:
    val proj = make_project_with_vexriscv()
    return generate_vivado_tcl_rv64()


# ============================================================================
# AC-3: add_verilog_sources output
# ============================================================================

describe "SynthesisProject add_verilog_sources":
    it "AC-3: TCL contains add_files directive for .v sources":
        val tcl = tcl_with_vexriscv()
        expect(tcl).to_contain("add_files")

    it "AC-3: TCL contains VexRiscv filename":
        val tcl = tcl_with_vexriscv()
        expect(tcl).to_contain("VexRiscv")

    it "AC-3: TCL contains .v extension reference":
        val tcl = tcl_with_vexriscv()
        expect(tcl).to_contain(".v")


# ============================================================================
# AC-3: enable_axi_hp_port output
# ============================================================================

describe "SynthesisProject enable_axi_hp_port":
    it "AC-3: TCL contains S_AXI_HP0 enable directive":
        val tcl = tcl_with_vexriscv()
        expect(tcl).to_contain("S_AXI_HP0")

    it "AC-3: TCL contains PSU__USE__S_AXI_GP key or HP config":
        val tcl = tcl_with_vexriscv()
        expect(tcl).to_contain("HP")


# ============================================================================
# AC-3: Base TCL generation still correct
# ============================================================================

describe "Synthesis TCL base correctness":
    it "AC-3: TCL contains create_project":
        val tcl = generate_vivado_tcl_rv64()
        expect(tcl).to_contain("create_project")

    it "AC-3: TCL contains K26 part number":
        val tcl = generate_vivado_tcl_rv64()
        expect(tcl).to_contain("xck26")

    it "AC-3: TCL contains launch_runs synth_1":
        val tcl = generate_vivado_tcl_rv64()
        expect(tcl).to_contain("synth")
