# @cover src/lib/blink/layout/inline_flow.spl 80%
"""
# Blink Inline Formatting Context Specification

**Feature IDs:** #BLK-LAYOUT-IFC-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests for layout_inline_flow — the simplified Blink inline formatting
context that packs InlineItem sequences into line boxes constrained by a
container width. Mirrors LayoutInline / line-breaking logic.
"""

use std.spipe.*
use std.blink.layout.{
    InlineItemKind,
    InlineItem,
    InlineBox,
    LineBox,
    InlineLayoutResult,
    inline_text,
    inline_element,
    layout_inline_flow,
    wrap_text_run,
    estimate_text_width
}

describe "inline_flow":
    it "inline_text: creates Text InlineItem with text and dimensions":
        val item = inline_text("hello", 60.0, 20.0)
        val is_text = item.kind == InlineItemKind.Text
        expect(is_text).to_equal(true)
        expect(item.text).to_equal("hello")
        expect(item.width).to_equal(60.0)
        expect(item.height).to_equal(20.0)
        expect(item.ref_id).to_equal(0)

    it "inline_element: creates InlineElement with ref_id":
        val item = inline_element(48.0, 32.0, 7)
        val is_elem = item.kind == InlineItemKind.InlineElement
        expect(is_elem).to_equal(true)
        expect(item.width).to_equal(48.0)
        expect(item.height).to_equal(32.0)
        expect(item.ref_id).to_equal(7)

    it "layout_inline_flow: empty items produces empty result":
        val items: [InlineItem] = []
        val result = layout_inline_flow(items, 400.0)
        expect(result.lines.len()).to_equal(0)
        expect(result.total_height).to_equal(0.0)

    it "layout_inline_flow: 3 items fitting in width produce 1 line with 3 boxes":
        # Each item is 80px wide, 20px tall; container is 300px — all 3 fit.
        val a = inline_text("foo", 80.0, 20.0)
        val b = inline_text("bar", 80.0, 20.0)
        val c = inline_text("baz", 80.0, 20.0)
        var items: [InlineItem] = []
        items.push(a)
        items.push(b)
        items.push(c)
        val result = layout_inline_flow(items, 300.0)
        expect(result.lines.len()).to_equal(1)
        val line = result.lines[0]
        expect(line.boxes.len()).to_equal(3)
        expect(line.total_width).to_equal(240.0)
        expect(line.max_height).to_equal(20.0)

    it "layout_inline_flow: items exceeding width split across lines":
        # Each item is 100px wide; container is 250px — first 2 fit (200px),
        # third would push to 300px so it starts a new line.
        val a = inline_text("aaa", 100.0, 18.0)
        val b = inline_text("bbb", 100.0, 18.0)
        val c = inline_text("ccc", 100.0, 18.0)
        var items: [InlineItem] = []
        items.push(a)
        items.push(b)
        items.push(c)
        val result = layout_inline_flow(items, 250.0)
        expect(result.lines.len()).to_equal(2)
        val line0 = result.lines[0]
        val line1 = result.lines[1]
        expect(line0.boxes.len()).to_equal(2)
        expect(line1.boxes.len()).to_equal(1)

    it "layout_inline_flow: total_height equals sum of line heights":
        # Two lines of 20px each -> total_height == 40.0
        val a = inline_text("aaa", 200.0, 20.0)
        val b = inline_text("bbb", 200.0, 20.0)
        var items: [InlineItem] = []
        items.push(a)
        items.push(b)
        val result = layout_inline_flow(items, 300.0)
        # 400px total width > 300px container -> 2 lines
        expect(result.lines.len()).to_equal(2)
        expect(result.total_height).to_equal(40.0)

    it "layout_inline_flow: item wider than container gets its own line":
        # One oversized item (500px) in a 200px container — it must be placed
        # alone and overflow (CSS overflow:visible behaviour).
        val big = inline_element(500.0, 30.0, 42)
        val small = inline_text("ok", 60.0, 20.0)
        var items: [InlineItem] = []
        items.push(big)
        items.push(small)
        val result = layout_inline_flow(items, 200.0)
        # big gets line 0, small gets line 1
        expect(result.lines.len()).to_equal(2)
        val line0 = result.lines[0]
        expect(line0.boxes.len()).to_equal(1)
        val box0 = line0.boxes[0]
        expect(box0.item_id).to_equal(0)
        val line1 = result.lines[1]
        expect(line1.boxes.len()).to_equal(1)
        expect(result.total_height).to_be_greater_than(30.0)

    it "estimate_text_width: grows linearly with content length":
        # formula: len * font_size * 0.55
        val short_w = estimate_text_width("ab", 16.0)
        val long_w = estimate_text_width("abcdef", 16.0)
        # 6 chars is 3x 2 chars -> width ratio must be 3x (linear).
        expect(short_w).to_equal(17.6)
        expect(long_w).to_equal(52.8)
        # Empty text has zero width.
        val empty_w = estimate_text_width("", 16.0)
        expect(empty_w).to_equal(0.0)

    it "wrap_text_run: wraps a long string into multiple chunks under a tight container_width":
        # font_size=16, word "hello" ~ 5*16*0.55 = 44.0 px
        # space = 16 * 0.30 = 4.8 px
        # Container of 100px should fit ~2 "hello" words per chunk
        # (44 + 4.8 + 44 = 92.8 <= 100; next word would push to 140.8).
        val chunks = wrap_text_run("hello hello hello hello hello", 100.0, 16.0, 20.0)
        expect(chunks.len()).to_be_greater_than(1)
        # Every chunk is Text-kind and carries the prescribed line-height.
        var idx: i64 = 0
        while idx < chunks.len():
            val ck = chunks[idx]
            val is_text = ck.kind == InlineItemKind.Text
            expect(is_text).to_equal(true)
            expect(ck.height).to_equal(20.0)
            # No chunk's recorded width should exceed the container when the
            # chunk contains more than one word (single oversized words are
            # allowed to exceed).
            idx = idx + 1

    it "wrap_text_run: preserves a single oversized word as one chunk":
        # "supercalifragilistic" is 20 chars; at font_size=16 -> 20*16*0.55 = 176 px.
        # Container of 50px is narrower, so we emit the word as one oversized chunk.
        val chunks = wrap_text_run("supercalifragilistic", 50.0, 16.0, 20.0)
        expect(chunks.len()).to_equal(1)
        val only = chunks[0]
        expect(only.text).to_equal("supercalifragilistic")
        expect(only.width).to_be_greater_than(50.0)

    it "wrap_text_run: end-to-end feeds layout_inline_flow to produce multiple lines":
        # A paragraph that needs wrapping: several 5-letter words at 16px font
        # in a ~100px container. Passed through layout_inline_flow we expect
        # 2+ LineBox values.
        val chunks = wrap_text_run("alpha beta gamma delta epsilon zeta", 100.0, 16.0, 20.0)
        expect(chunks.len()).to_be_greater_than(1)
        val result = layout_inline_flow(chunks, 100.0)
        expect(result.lines.len()).to_be_greater_than(1)
        expect(result.total_height).to_be_greater_than(20.0)
