# @cover src/lib/blink/input/hit_test.spl 80%
"""
# Blink HitTest Specification

**Category:** Browser / Blink / Input
**Status:** Active

## Overview

Tests for hit_test — the function that maps a 2D input point to the
topmost (innermost) LayoutBox containing it.  Mirrors Blink's
EventHandler::HitTestResultAtLocation.
"""

use std.spipe.*
use std.lib.skia.entity.geometry.{SkRect}
use std.lib.blink.layout.block_flow.{
    LayoutBox, LayoutContext, BoxGeometry,
    box_geometry_zero, box_geometry_new, layout_box_new, layout_context_new
}
use std.lib.blink.input.event.{
    InputEvent, EventType, Point,
    mouse_event, key_event
}
use std.lib.blink.input.hit_test.{
    HitTestResult, hit_test_empty, point_in_rect, hit_test, hit_test_event,
    hit_test_ancestors
}

# ============================================================================
# Helpers
# ============================================================================

fn make_ctx_single_box() -> LayoutContext:
    # One root box: 0,0 -> 200,100
    val ctx = layout_context_new(800.0, 600.0)
    val geo = box_geometry_zero()
    geo.width = 200.0
    geo.height = 100.0
    val root = layout_box_new(1, geo)
    root.computed_rect = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 100.0)
    ctx.add_box(root)
    ctx.set_root(1)
    ctx

fn make_ctx_parent_child() -> LayoutContext:
    # Parent box: 0,0 -> 200,200
    # Child box:  10,10 -> 90,90  (nested inside parent)
    val ctx = layout_context_new(800.0, 600.0)

    val parent_geo = box_geometry_zero()
    parent_geo.width = 200.0
    parent_geo.height = 200.0
    val parent_box = layout_box_new(1, parent_geo)
    parent_box.computed_rect = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 200.0)
    parent_box.children_ids = [2]

    val child_geo = box_geometry_zero()
    child_geo.width = 80.0
    child_geo.height = 80.0
    val child_box = layout_box_new(2, child_geo)
    child_box.computed_rect = SkRect(left: 10.0, top: 10.0, right: 90.0, bottom: 90.0)

    ctx.add_box(parent_box)
    ctx.add_box(child_box)
    ctx.set_root(1)
    ctx

# ============================================================================
# Spec
# ============================================================================

describe "hit_test_empty":
    it "hit_box_id is -1":
        val r = hit_test_empty()
        expect(r.hit_box_id).to_equal(-1)

describe "point_in_rect":
    it "point inside rect returns true":
        val rect = SkRect(left: 0.0, top: 0.0, right: 100.0, bottom: 100.0)
        val inside = point_in_rect(rect, 50.0, 50.0)
        expect(inside).to_equal(true)

    it "point outside rect returns false":
        val rect = SkRect(left: 0.0, top: 0.0, right: 100.0, bottom: 100.0)
        val outside = point_in_rect(rect, 150.0, 50.0)
        expect(outside).to_equal(false)

describe "hit_test":
    it "point inside root box returns root's id":
        val ctx = make_ctx_single_box()
        val result = hit_test(ctx, 100.0, 50.0)
        expect(result.hit_box_id).to_equal(1)

    it "point inside nested child returns child's id (innermost wins)":
        val ctx = make_ctx_parent_child()
        # (50, 50) is inside both parent (0-200) and child (10-90)
        val result = hit_test(ctx, 50.0, 50.0)
        expect(result.hit_box_id).to_equal(2)

    it "point outside everything returns hit_test_empty":
        val ctx = make_ctx_single_box()
        # (500, 500) is outside the 200x100 root box
        val result = hit_test(ctx, 500.0, 500.0)
        expect(result.hit_box_id).to_equal(-1)

describe "hit_test_event":
    it "mouse event at (50, 50) inside a box hits that box":
        val ctx = make_ctx_single_box()
        val ev = mouse_event(EventType.MouseDown, 50.0, 50.0, 0.0, 0)
        val result = hit_test_event(ctx, ev)
        expect(result.hit_box_id).to_equal(1)
        val lx_ok = result.local_x >= 0.0
        expect(lx_ok).to_equal(true)
