extern fn rt_file_read_text(path: text) -> text?

describe "database row numeric guard":
    it "returns nil for malformed row integer fields":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/database/core.spl") ?? ""

        expect(source).to_contain("val parsed = value.to_int()")
        expect(source).to_contain("if parsed == nil:")
        expect(source).to_contain("return nil")
        expect(source.contains("Some(value.to_int())")).to_equal(false)
