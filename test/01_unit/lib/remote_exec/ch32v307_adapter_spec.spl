"""
# CH32V307 Adapter Host-Side Specification
#
# Host-only regression tests for the wlink-backed CH32 adapter helpers.
# These tests do not require live hardware; they verify register mapping and
# parser behavior against representative command output.
"""

use std.nogc_sync_mut.debug.remote.exec.adapter_ch32v307.{
    ch32v307_register_id,
    parse_ch32v307_register_value,
    parse_ch32v307_dump_bytes,
    strip_ansi_escape
}

val SAMPLE_REGS = "16:24:20 [INFO] Dump GPRs\n" +
    "dpc(pc):   0x2000011a\n" +
    "x0   zero: 0x00000000\n" +
    "x1     ra: 0x49c85c07\n" +
    "x2     sp: 0x20002800\n" +
    "x10    a0: 0x0000002a\n"

val SAMPLE_DUMP = "08000000:   b7 00 00 08  67 80 80 00  73 50 40 30  73 50 40 34\n" +
    "08000010:   81 40 01 41  81 41 01 42  81 42 01 43  81 43 01 44\n"

describe "Ch32V307Adapter helpers":
    it "maps PC to the CH32 DPC register id":
        expect(ch32v307_register_id(32)).to_equal(0x7B1)

    it "keeps general purpose registers mapped by index":
        expect(ch32v307_register_id(10)).to_equal(10)
        expect(ch32v307_register_id(2)).to_equal(2)

    it "parses dpc pc values from regs output":
        val value = parse_ch32v307_register_value(SAMPLE_REGS, 32)
        expect(value).to_equal(0x2000011A)

    it "parses general register values from regs output":
        val value = parse_ch32v307_register_value(SAMPLE_REGS, 10)
        expect(value).to_equal(0x2A)

    it "returns -1 when a register is absent":
        val value = parse_ch32v307_register_value(SAMPLE_REGS, 31)
        expect(value).to_equal(-1)

    it "parses byte dumps in order":
        val bytes = parse_ch32v307_dump_bytes(SAMPLE_DUMP, 8)
        expect(bytes.len()).to_equal(8)
        expect(bytes[0]).to_equal(0xB7)
        expect(bytes[3]).to_equal(0x08)
        expect(bytes[7]).to_equal(0x00)

    it "truncates dump parsing to the requested size":
        val bytes = parse_ch32v307_dump_bytes(SAMPLE_DUMP, 5)
        expect(bytes.len()).to_equal(5)
        expect(bytes[4]).to_equal(0x67)

    it "removes ANSI escape sequences from output":
        val cleaned = strip_ansi_escape("\u001b[31merror\u001b[0m")
        expect(cleaned).to_equal("error")
