use std.gc_async_mut.http.request.{parse_request, parse_request_line}

describe "gc_async_mut HTTP request parsing":
    it "falls back for malformed request line":
        val parsed = parse_request_line("GET")
        expect(parsed[0]).to_equal("GET")
        expect(parsed[1]).to_equal("/")
        expect(parsed[2]).to_equal("HTTP/1.1")

    it "falls back for empty request text":
        val parsed = parse_request("")
        expect(parsed[0]).to_equal("GET")
        expect(parsed[1]).to_equal("/")
        expect(parsed[2]).to_equal("HTTP/1.1")
