use std.spec.{describe, it, expect}

describe "scope diag":
    it "q1 annotated val read inside if":
        val cond = true
        if cond:
            val x: i32 = 5
            expect(x).to_equal(5)
        else:
            expect(2).to_equal(2)

    it "q2 statements after annotated val still run":
        val cond = true
        var seen = 0
        if cond:
            val x: i32 = 5
            seen = 1
        expect(seen).to_equal(1)

    it "q3 annotated val inside while":
        var i = 0
        var total = 0
        while i < 1:
            val x: i32 = 7
            total = total + x
            i = i + 1
        expect(total).to_equal(7)

    it "q4 annotated val inside else branch":
        val cond = false
        if cond:
            expect(1).to_equal(1)
        else:
            val x: i32 = 9
            expect(x).to_equal(9)

    it "q5 unannotated control inside if":
        val cond = true
        if cond:
            val x = 5
            expect(x).to_equal(5)
        else:
            expect(2).to_equal(2)
