use std.spec.{describe, it, expect}

fn free_take(v: u32) -> u32:
    v

class Holder:
    last: u32

impl Holder:
    static fn create() -> Holder:
        Holder(last: 0u32)
    me put(v: u32):
        self.last = v
    fn get() -> u32:
        self.last

describe "annotated u32 val arg matrix":
    it "a1 annotated small to free fn":
        val v: u32 = 5u32
        expect(free_take(v)).to_equal(5u32)
    it "a2 annotated large to free fn":
        val v: u32 = 0xFF0000FFu32
        expect(free_take(v)).to_equal(0xFF0000FFu32)
    it "a3 annotated small to me method":
        val v: u32 = 5u32
        var h = Holder.create()
        h.put(v)
        expect(h.get()).to_equal(5u32)
    it "a4 annotated large to me method":
        val v: u32 = 0xFF0000FFu32
        var h = Holder.create()
        h.put(v)
        expect(h.get()).to_equal(0xFF0000FFu32)
    it "a5 unannotated large to me method":
        val v = 0xFF0000FFu32
        var h = Holder.create()
        h.put(v)
        expect(h.get()).to_equal(0xFF0000FFu32)
    it "a6 annotated large used directly in expect":
        val v: u32 = 0xFF0000FFu32
        expect(v).to_equal(0xFF0000FFu32)
