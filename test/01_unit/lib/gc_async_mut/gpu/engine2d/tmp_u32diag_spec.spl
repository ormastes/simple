use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}

describe "annotated u32 to VulkanBackend":
    it "b1 annotated to clear on uninitialized backend (guard path)":
        val v: u32 = 0xFF0000FFu32
        var b = VulkanBackend.create()
        b.clear(v)
        expect(1).to_equal(1)

    it "b2 annotated to clear on initialized backend (device path)":
        val v: u32 = 0xFF0000FFu32
        var b = VulkanBackend.create()
        if b.init(4, 4):
            b.clear(v)
            b.shutdown()
        expect(1).to_equal(1)

    it "b3 annotated to clear then value-checked readback":
        val v: u32 = 0xFF0000FFu32
        var b = VulkanBackend.create()
        if b.init(4, 4):
            b.clear(v)
            b.present()
            val pixels = b.read_pixels()
            val ok = pixels[0] == 0xFF0000FFu32
            expect(ok).to_equal(true)
            b.shutdown()
        else:
            expect("else").to_equal("init-ok")
