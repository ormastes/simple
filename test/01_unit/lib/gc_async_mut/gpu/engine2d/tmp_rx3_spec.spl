use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}

describe "vk":
    context "n":
        it "small annotated val inside if":
            var b = VulkanBackend.create()
            if b.init(4, 4):
                val red: u32 = 5u32
                b.clear(red)
                b.present()
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(16)
                b.shutdown()
            else:
                expect("else-branch").to_equal("init-ok")
