use std.spec.*

extern fn rt_file_read_text(path: text) -> text

describe "shared multilingual GPU font performance contract":
    it "runs isolated RSS probes with the admitted Simple binary":
        val source = rt_file_read_text("test/05_perf/graphics_2d/shared_multilingual_gpu_fonts_perf_spec.spl")
        expect(source).to_contain("val simple_bin = env_get(\"SIMPLE_BIN\")")
        expect(source).to_contain("val simple_binary = env_get(\"SIMPLE_BINARY\")")
        expect(source).to_contain("_font_perf_simple_binary(), [\"run\", FONT_PERF_RSS_PROBE_PATH, mode]")
        expect(source).not_to_contain("\"bin/simple\", [\"run\", FONT_PERF_RSS_PROBE_PATH, mode]")

    it "rejects single-face tofu before measuring top-ten language performance":
        val source = rt_file_read_text("test/05_perf/graphics_2d/shared_multilingual_gpu_fonts_perf_spec.spl")
        expect(source).to_contain("MIXED_CODEPOINTS: [i32] = [0x0041, 0x4E2D, 0x0905, 0x00D1, 0x00C9, 0x0628, 0x0985, 0x042F, 0x00C3, 0x0627]")
        expect(source).to_contain("fonts.selected_face_has_glyph(codepoint)")
        expect(source).to_contain("top-10-face-coverage-unavailable")
        expect(source).to_contain("mixed-font-batch-invalid")
        expect(source.index_of("if not _selected_face_covers_mixed_fixture(engine)")).to_be_less_than(source.index_of("fonts.prepare_text(content"))
