# @cover src/lib/gc_async_mut/gpu/engine2d/backend_accel_probe.spl 80%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_accel_vulkan.spl 80%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_accel_cuda.spl 80%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_accel_metal.spl 80%
#
# Graphics Backend Acceleration Spec
#
# Self-contained 20-test spec covering probe contract, Vulkan SPIR-V,
# CUDA compute dispatch, and Metal command queue stubs.
# All classes are defined inline — no imports from src/.

# ============================================================================
# Inline stubs matching backend_accel_probe.spl public surface
# ============================================================================

class AccelProbeStatus:
    code: text
    message: text

    static fn available(msg: text) -> AccelProbeStatus:
        AccelProbeStatus(code: "available", message: msg)

    static fn unavailable(msg: text) -> AccelProbeStatus:
        AccelProbeStatus(code: "unavailable", message: msg)

    static fn fallback(msg: text) -> AccelProbeStatus:
        AccelProbeStatus(code: "fallback", message: msg)

    fn is_available(self) -> bool:
        self.code == "available"

    fn is_unavailable(self) -> bool:
        self.code == "unavailable"

    fn to_text(self) -> text:
        self.code + ": " + self.message

class AccelProbeResult:
    backend_name: text
    status: AccelProbeStatus
    device_name: text
    shader_format: text
    has_compute: bool
    has_graphics: bool

    static fn create(name: text, st: AccelProbeStatus) -> AccelProbeResult:
        AccelProbeResult(
            backend_name:  name,
            status:        st,
            device_name:   "",
            shader_format: "none",
            has_compute:   false,
            has_graphics:  false
        )

    static fn with_device(name: text, st: AccelProbeStatus, device: text, fmt: text) -> AccelProbeResult:
        AccelProbeResult(
            backend_name:  name,
            status:        st,
            device_name:   device,
            shader_format: fmt,
            has_compute:   true,
            has_graphics:  true
        )

    fn is_usable(self) -> bool:
        self.status.is_available()

    fn summary(self) -> text:
        self.backend_name + ": " + self.status.code

class StrictAccelFactory:
    required_backend: text
    strict_mode: bool

    static fn create(backend: text) -> StrictAccelFactory:
        StrictAccelFactory(required_backend: backend, strict_mode: true)

    static fn permissive() -> StrictAccelFactory:
        StrictAccelFactory(required_backend: "", strict_mode: false)

    fn is_glsl_format(self, fmt: text) -> bool:
        fmt == "glsl"

    fn is_admitted(self, res: AccelProbeResult) -> bool:
        if self.is_glsl_format(res.shader_format):
            return false
        if self.strict_mode == false:
            return res.is_usable()
        if self.required_backend == "":
            return res.is_usable()
        res.backend_name == self.required_backend and res.is_usable()

    fn rejection_reason(self, res: AccelProbeResult) -> text:
        if self.is_glsl_format(res.shader_format):
            return "GLSL shader format not admitted; use SPIR-V"
        if res.is_usable() == false:
            return "backend unavailable: " + res.status.message
        "admitted"

# ============================================================================
# Inline stubs matching backend_accel_vulkan.spl public surface
# ============================================================================

class VulkanAccelConfig:
    width: i64
    height: i64
    shader_format: text
    enable_validation: bool

    static fn default_config(w: i64, h: i64) -> VulkanAccelConfig:
        VulkanAccelConfig(width: w, height: h, shader_format: "spirv", enable_validation: false)

    fn is_glsl(self) -> bool:
        self.shader_format == "glsl"

    fn pixel_count(self) -> i64:
        self.width * self.height

class VulkanAccelPipeline:
    pipeline_id: i64
    shader_format: text
    is_compute: bool

    static fn create_graphics(pid: i64) -> VulkanAccelPipeline:
        VulkanAccelPipeline(pipeline_id: pid, shader_format: "spirv", is_compute: false)

    fn is_valid(self) -> bool:
        self.pipeline_id != 0

    fn shader_is_spirv(self) -> bool:
        self.shader_format == "spirv"

class VulkanAccelCommandBuffer:
    cmd_id: i64
    recording: bool
    command_count: i64

    static fn create(cid: i64) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(cmd_id: cid, recording: false, command_count: 0)

    fn begin(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(cmd_id: self.cmd_id, recording: true, command_count: self.command_count)

    fn end(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(cmd_id: self.cmd_id, recording: false, command_count: self.command_count)

    fn record_clear(self) -> VulkanAccelCommandBuffer:
        VulkanAccelCommandBuffer(cmd_id: self.cmd_id, recording: self.recording, command_count: self.command_count + 1)

    fn is_recording(self) -> bool:
        self.recording

class VulkanAccelBackend:
    width: i64
    height: i64
    initialized: bool
    pipeline: VulkanAccelPipeline
    readback_buf_size: i64

    static fn create(w: i64, h: i64) -> VulkanAccelBackend:
        VulkanAccelBackend(
            width:             w,
            height:            h,
            initialized:       false,
            pipeline:          VulkanAccelPipeline.create_graphics(0),
            readback_buf_size: 0
        )

    fn init(self) -> VulkanAccelBackend:
        VulkanAccelBackend(
            width:             self.width,
            height:            self.height,
            initialized:       true,
            pipeline:          VulkanAccelPipeline.create_graphics(1001),
            readback_buf_size: self.width * self.height * 4
        )

    fn is_ready(self) -> bool:
        self.initialized and self.pipeline.is_valid()

    fn name(self) -> text:
        "vulkan-accel"

# ============================================================================
# Inline stubs matching backend_accel_cuda.spl public surface
# ============================================================================

class CudaAccelBuffer:
    device_ptr: i64
    host_size: i64
    is_allocated: bool
    element_count: i64

    static fn create(elements: i64) -> CudaAccelBuffer:
        CudaAccelBuffer(device_ptr: 0, host_size: elements * 4, is_allocated: false, element_count: elements)

    static fn allocated(ptr: i64, elements: i64) -> CudaAccelBuffer:
        CudaAccelBuffer(device_ptr: ptr, host_size: elements * 4, is_allocated: true, element_count: elements)

    fn is_valid(self) -> bool:
        self.is_allocated and self.device_ptr != 0

    fn size_bytes(self) -> i64:
        self.host_size

class CudaAccelKernel:
    kernel_name: text
    block_size: i64

    static fn fill_kernel() -> CudaAccelKernel:
        CudaAccelKernel(kernel_name: "engine2d_fill", block_size: 256)

    fn grid_size(self, element_count: i64) -> i64:
        var blocks = element_count / self.block_size
        if element_count - (blocks * self.block_size) > 0:
            blocks = blocks + 1
        blocks

class CudaAccelDispatch:
    kernel: CudaAccelKernel
    grid_x: i64
    completed: bool

    static fn create(k: CudaAccelKernel, element_count: i64) -> CudaAccelDispatch:
        CudaAccelDispatch(kernel: k, grid_x: k.grid_size(element_count), completed: false)

    fn mark_complete(self) -> CudaAccelDispatch:
        CudaAccelDispatch(kernel: self.kernel, grid_x: self.grid_x, completed: true)

    fn is_complete(self) -> bool:
        self.completed

class CudaAccelBackend:
    width: i64
    height: i64
    framebuffer: CudaAccelBuffer
    initialized: bool

    static fn create(w: i64, h: i64) -> CudaAccelBackend:
        CudaAccelBackend(width: w, height: h, framebuffer: CudaAccelBuffer.create(w * h), initialized: false)

    fn init(self) -> CudaAccelBackend:
        var fb = CudaAccelBuffer.allocated(0x10000000, self.width * self.height)
        CudaAccelBackend(width: self.width, height: self.height, framebuffer: fb, initialized: true)

    fn is_ready(self) -> bool:
        self.initialized and self.framebuffer.is_valid()

    fn dispatch_fill(self, color: i64) -> CudaAccelDispatch:
        CudaAccelDispatch.create(CudaAccelKernel.fill_kernel(), self.width * self.height)

    fn readback_size(self) -> i64:
        self.framebuffer.size_bytes()

    fn name(self) -> text:
        "cuda-accel"

# ============================================================================
# Inline stubs matching backend_accel_metal.spl public surface
# ============================================================================

class MetalAccelPipeline:
    pipeline_id: i64
    function_name: text
    thread_group_size: i64

    static fn create_compute(pid: i64, fn_name: text) -> MetalAccelPipeline:
        MetalAccelPipeline(pipeline_id: pid, function_name: fn_name, thread_group_size: 64)

    static fn unavailable() -> MetalAccelPipeline:
        MetalAccelPipeline(pipeline_id: 0, function_name: "", thread_group_size: 0)

    fn is_valid(self) -> bool:
        self.pipeline_id != 0

    fn thread_groups_for(self, element_count: i64) -> i64:
        if self.thread_group_size == 0:
            return 0
        var groups = element_count / self.thread_group_size
        if element_count - (groups * self.thread_group_size) > 0:
            groups = groups + 1
        groups

class MetalAccelCommandBuffer:
    cmd_id: i64
    encoder_open: bool
    dispatch_count: i64
    committed: bool

    static fn create(cid: i64) -> MetalAccelCommandBuffer:
        MetalAccelCommandBuffer(cmd_id: cid, encoder_open: false, dispatch_count: 0, committed: false)

    fn begin_encoder(self) -> MetalAccelCommandBuffer:
        MetalAccelCommandBuffer(cmd_id: self.cmd_id, encoder_open: true, dispatch_count: self.dispatch_count, committed: self.committed)

    fn end_encoder(self) -> MetalAccelCommandBuffer:
        MetalAccelCommandBuffer(cmd_id: self.cmd_id, encoder_open: false, dispatch_count: self.dispatch_count, committed: self.committed)

    fn commit(self) -> MetalAccelCommandBuffer:
        MetalAccelCommandBuffer(cmd_id: self.cmd_id, encoder_open: self.encoder_open, dispatch_count: self.dispatch_count, committed: true)

    fn is_committed(self) -> bool:
        self.committed

class MetalAccelCompletion:
    cmd_id: i64
    success: bool
    error_message: text

    static fn make_success(cid: i64) -> MetalAccelCompletion:
        MetalAccelCompletion(cmd_id: cid, success: true, error_message: "")

    static fn make_failed(cid: i64, msg: text) -> MetalAccelCompletion:
        MetalAccelCompletion(cmd_id: cid, success: false, error_message: msg)

    fn is_ok(self) -> bool:
        self.success

class MetalAccelBackend:
    width: i64
    height: i64
    initialized: bool
    platform_available: bool
    pipeline: MetalAccelPipeline

    static fn create(w: i64, h: i64) -> MetalAccelBackend:
        MetalAccelBackend(
            width:              w,
            height:             h,
            initialized:        false,
            platform_available: false,
            pipeline:           MetalAccelPipeline.unavailable()
        )

    fn with_platform(self, available: bool) -> MetalAccelBackend:
        MetalAccelBackend(
            width:              self.width,
            height:             self.height,
            initialized:        self.initialized,
            platform_available: available,
            pipeline:           self.pipeline
        )

    fn init(self) -> MetalAccelBackend:
        if self.platform_available == false:
            return self
        MetalAccelBackend(
            width:              self.width,
            height:             self.height,
            initialized:        true,
            platform_available: self.platform_available,
            pipeline:           MetalAccelPipeline.create_compute(2001, "engine2d_fill_kernel")
        )

    fn is_ready(self) -> bool:
        self.initialized and self.platform_available and self.pipeline.is_valid()

    fn make_command_buffer(self) -> MetalAccelCommandBuffer:
        MetalAccelCommandBuffer.create(42)

    fn submit(self, cmdbuf: MetalAccelCommandBuffer) -> MetalAccelCompletion:
        if self.initialized == false:
            return MetalAccelCompletion.make_failed(cmdbuf.cmd_id, "backend not initialized")
        if cmdbuf.is_committed() == false:
            return MetalAccelCompletion.make_failed(cmdbuf.cmd_id, "command buffer not committed")
        MetalAccelCompletion.make_success(cmdbuf.cmd_id)

    fn name(self) -> text:
        "metal-accel"

# ============================================================================
# Tests
# ============================================================================

describe "graphics backend acceleration":

    context "AccelProbeStatus":
        it "available status has correct code":
            var st = AccelProbeStatus.available("ready")
            expect(st.code).to_equal("available")

        it "unavailable status is not available":
            var st = AccelProbeStatus.unavailable("no device")
            expect(st.is_available()).to_equal(false)

        it "fallback status has fallback code":
            var st = AccelProbeStatus.fallback("using cpu")
            expect(st.code).to_equal("fallback")

    context "AccelProbeResult":
        it "create returns a result with empty device and none shader format":
            var r = AccelProbeResult.create("test", AccelProbeStatus.available("ok"))
            expect(r.device_name).to_equal("")
            expect(r.shader_format).to_equal("none")

        it "with_device sets device name and shader format":
            var r = AccelProbeResult.with_device("vulkan", AccelProbeStatus.available("ok"), "AMD GPU", "spirv")
            expect(r.device_name).to_equal("AMD GPU")
            expect(r.shader_format).to_equal("spirv")

        it "is_usable reflects status availability":
            var r = AccelProbeResult.create("cpu", AccelProbeStatus.available("ok"))
            expect(r.is_usable()).to_equal(true)

        it "summary includes backend name and status code":
            var r = AccelProbeResult.create("cuda", AccelProbeStatus.unavailable("no cuda"))
            var s = r.summary()
            expect(s).to_contain("cuda")

    context "StrictAccelFactory":
        it "rejects GLSL shader format":
            var fac = StrictAccelFactory.permissive()
            var r = AccelProbeResult.with_device("vulkan", AccelProbeStatus.available("ok"), "GPU", "glsl")
            expect(fac.is_admitted(r)).to_equal(false)

        it "admits SPIR-V shader format in permissive mode":
            var fac = StrictAccelFactory.permissive()
            var r = AccelProbeResult.with_device("vulkan", AccelProbeStatus.available("ok"), "GPU", "spirv")
            expect(fac.is_admitted(r)).to_equal(true)

        it "strict mode rejects wrong backend name":
            var fac = StrictAccelFactory.create("cuda")
            var r = AccelProbeResult.with_device("vulkan", AccelProbeStatus.available("ok"), "GPU", "spirv")
            expect(fac.is_admitted(r)).to_equal(false)

        it "rejection reason mentions GLSL for glsl format":
            var fac = StrictAccelFactory.permissive()
            var r = AccelProbeResult.with_device("vulkan", AccelProbeStatus.available("ok"), "GPU", "glsl")
            var reason = fac.rejection_reason(r)
            expect(reason).to_contain("GLSL")

    context "VulkanAccelBackend":
        it "starts uninitialized with invalid pipeline":
            var b = VulkanAccelBackend.create(64, 64)
            expect(b.initialized).to_equal(false)
            expect(b.pipeline.is_valid()).to_equal(false)

        it "init makes backend ready with valid SPIR-V pipeline":
            var b = VulkanAccelBackend.create(32, 32)
            var b2 = b.init()
            expect(b2.is_ready()).to_equal(true)
            expect(b2.pipeline.shader_is_spirv()).to_equal(true)

        it "name is vulkan-accel":
            var b = VulkanAccelBackend.create(16, 16)
            expect(b.name()).to_equal("vulkan-accel")

        it "readback_buf_size equals width times height times 4 after init":
            var b = VulkanAccelBackend.create(8, 8)
            var b2 = b.init()
            expect(b2.readback_buf_size).to_equal(256)

    context "CudaAccelBackend":
        it "dispatch_fill returns a dispatch with non-zero grid":
            var b = CudaAccelBackend.create(512, 512)
            var b2 = b.init()
            var d = b2.dispatch_fill(0xFF0000FF)
            expect(d.grid_x > 0).to_equal(true)

        it "mark_complete transitions dispatch to completed":
            var b = CudaAccelBackend.create(64, 64)
            var b2 = b.init()
            var d = b2.dispatch_fill(0)
            var d2 = d.mark_complete()
            expect(d2.is_complete()).to_equal(true)

        it "readback_size equals width times height times 4":
            var b = CudaAccelBackend.create(16, 16)
            var b2 = b.init()
            expect(b2.readback_size()).to_equal(1024)

    context "MetalAccelBackend":
        it "without platform init leaves backend not ready":
            var b = MetalAccelBackend.create(64, 64)
            var b2 = b.init()
            expect(b2.is_ready()).to_equal(false)

        it "with platform enabled init makes backend ready":
            var b = MetalAccelBackend.create(64, 64)
            var b2 = b.with_platform(true)
            var b3 = b2.init()
            expect(b3.is_ready()).to_equal(true)

        it "submit fails when backend not initialized":
            var b = MetalAccelBackend.create(32, 32)
            var cmdbuf = b.make_command_buffer()
            var cmdbuf2 = cmdbuf.commit()
            var result = b.submit(cmdbuf2)
            expect(result.is_ok()).to_equal(false)

        it "submit succeeds when initialized and command buffer committed":
            var b = MetalAccelBackend.create(32, 32)
            var b2 = b.with_platform(true)
            var b3 = b2.init()
            var cmdbuf = b3.make_command_buffer()
            var cmdbuf2 = cmdbuf.commit()
            var result = b3.submit(cmdbuf2)
            expect(result.is_ok()).to_equal(true)

        it "submit fails when command buffer not committed":
            var b = MetalAccelBackend.create(32, 32)
            var b2 = b.with_platform(true)
            var b3 = b2.init()
            var cmdbuf = b3.make_command_buffer()
            var result = b3.submit(cmdbuf)
            expect(result.is_ok()).to_equal(false)

        it "pipeline thread_groups_for returns zero when not valid":
            var p = MetalAccelPipeline.unavailable()
            expect(p.thread_groups_for(1024)).to_equal(0)
