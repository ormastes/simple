# @cover src/lib/gc_async_mut/gpu/engine2d/vulkan_session.spl 5%

use spec.{describe, it, expect}
use std.io_runtime.{file_read}
use std.gc_async_mut.gpu.engine2d.sffi_vulkan.{
    vulkan_sffi_device_name, vulkan_sffi_device_type,
    vulkan_sffi_device_driver_identity
}

describe "Vulkan session device metadata":
    it "routes selected device metadata through the existing SFFI getters":
        expect(vulkan_sffi_device_name(-1)).to_equal("")
        expect(vulkan_sffi_device_type(-1)).to_equal("")
        expect(vulkan_sffi_device_driver_identity(-1)).to_equal("")

        val facade = file_read("src/lib/nogc_async_mut/gpu/engine2d/sffi_vulkan.spl")
        expect(facade).to_contain("vulkan_sffi_device_name, vulkan_sffi_device_type")
        expect(facade).to_contain("vulkan_sffi_device_driver_identity")
        expect(facade).to_contain("vulkan_sffi_selected_device_driver_identity")

        val session = file_read("src/lib/gc_async_mut/gpu/engine2d/vulkan_session.spl")
        expect(session).to_contain("self.device_name = vulkan_sffi_device_name(0)")
        expect(session).to_contain("self.device_type = vulkan_sffi_device_type(0)")
        expect(session).to_contain("self.driver_identity = vulkan_sffi_device_driver_identity(0)")
