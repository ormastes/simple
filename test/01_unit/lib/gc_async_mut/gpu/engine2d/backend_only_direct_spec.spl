# @cover src/lib/gc_async_mut/gpu/engine2d/backend_software.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cpu.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_directx.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl
# @tag: unit, engine2d, backend, drawing, direct
"""
# Backend-only direct drawing surface — below the Engine2D facade

**Category:** Testing | **Status:** Implemented
**Plan:** doc/03_plan/ui/testing/gpu_draw_event_intensive_tests.md

## Overview

This is the layer BELOW `test/03_system/gui/draw_backend_matrix/draw_backend_matrix_spec.spl`.
That matrix spec drives every backend THROUGH the `Engine2D` facade
(`probe_backend` / `create_requested_backend`). This spec instead constructs
each directly-constructible backend object with its own `create()` — no
`Engine2D`, no GUI stack — and exercises its own op surface at the lowest owned
layer: honest probe -> per-op draw -> direct `read_pixels()` buffer assert with
an ABSOLUTE oracle (a known drawn point == the draw color, a known background
point == the clear color).

Availability is never a silent skip. `software` and `cpu` are pure-CPU and
always init. `directx` and `vulkan` may have no device on this host: they then
fail-closed — `directx` asserts its honest `cpu_mirror` readback provenance plus
`leaf=` dispatch evidence, `vulkan` asserts a CLASSIFIED (never `None`)
`last_error`.

## Key Concepts

| Concept | Description |
|---------|-------------|
| Direct construct | `SoftwareBackend.create()`, `CpuBackend.create()`, `DirectXBackend.create()`, `VulkanBackend.create()` — no facade |
| name() honesty | `software`, `cpu`, `directx-software-emulation` (never plain `directx`), `vulkan` |
| Absolute oracle | filled-rect interior == RED, background == a distinct clear color (both ARGB channels compared, via the shared `assert_color_eq`) |
| Fail-closed | no-device backends assert a concrete reason, never pass green on a no-op |

## Syntax

Shared parameterized body `assert_backend_direct(kind)`; one `it` per backend.
`std.spec` matchers only; the shared `assert_color_eq` / `read_pixels_ppm`
helpers are reused (never duplicated).
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gc_async_mut.gpu.engine2d.backend_cpu.{CpuBackend}
use std.gc_async_mut.gpu.engine2d.backend_directx.{DirectXBackend, dx_platform_probe}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend, VulkanErrorKind, vulkan_classify_error}
use std.gc_async_mut.gpu.engine2d.color.{rgba, color_r, color_g, color_b, color_a}
use std.common.image.ppm_decode.{encode_ppm_p6}

# NOTE: This spec sits at depth 5 below test/, where `use
# test.helpers.gpu_draw_event_shared.{assert_color_eq, read_pixels_ppm}` cannot
# resolve (bug: doc/08_tracking/bug/test_helpers_namespace_unresolved_deep_paths_2026-07-06.md).
# Until that resolver limit is fixed, the two leaf helpers are mirrored locally
# (they are themselves thin wrappers over color_* / encode_ppm_p6). Restore the
# test.helpers import and delete these once the bug is resolved.
fn assert_color_eq(actual: u32, expected: u32):
    expect(color_r(actual)).to_equal(color_r(expected))
    expect(color_g(actual)).to_equal(color_g(expected))
    expect(color_b(actual)).to_equal(color_b(expected))
    expect(color_a(actual)).to_equal(color_a(expected))

fn read_pixels_ppm(width: i32, height: i32, pixels: [u32]) -> [u8]:
    return encode_ppm_p6(width as u32, height as u32, pixels)

val CANVAS: i32 = 20
# A distinct, non-black clear color so the background oracle is absolute (not
# just "== the SoftwareBackend init default").
val BG: u32 = rgba(3, 5, 7, 255)
val RED: u32 = rgba(255, 0, 0, 255)
# Filled rect covers x/y 4..11; (8,8) is interior, (0,0) is background.
val DRAWN_X: i32 = 8
val DRAWN_Y: i32 = 8
val BG_X: i32 = 0
val BG_Y: i32 = 0

fn px_at(pixels: [u32], x: i32, y: i32) -> u32:
    return pixels[(y * CANVAS + x) as i64]

# Absolute readback oracle shared by every available lane: filled interior ==
# RED, far corner == BG, and the P6 PPM wrapper produces a valid header.
fn assert_absolute_readback(pixels: [u32]):
    expect(pixels.len()).to_equal(CANVAS * CANVAS)
    assert_color_eq(px_at(pixels, DRAWN_X, DRAWN_Y), RED)
    assert_color_eq(px_at(pixels, BG_X, BG_Y), BG)
    val ppm = read_pixels_ppm(CANVAS, CANVAS, pixels)
    expect(ppm.len()).to_be_greater_than(CANVAS * CANVAS * 3)
    expect(ppm[0]).to_equal(80u8)   # 'P'
    expect(ppm[1]).to_equal(54u8)   # '6'

# ---------------------------------------------------------------------------
# Shared parameterized body — one `it` per directly-constructible backend.
# ---------------------------------------------------------------------------
fn assert_backend_direct(kind: text):
    if kind == "software":
        step("construct SoftwareBackend directly (no facade)")
        var b = SoftwareBackend.create()
        expect(b.name()).to_equal("software")
        step("probe: pure-CPU emulation always initializes")
        val ok = b.init(CANVAS, CANVAS)
        assert_true(ok)
        step("draw: clear(BG) + filled RED rect")
        b.clear(BG)
        b.draw_rect_filled(4, 4, 8, 8, RED)
        b.present()
        step("readback: direct read_pixels() absolute oracle")
        assert_absolute_readback(b.read_pixels())
        b.shutdown()
        return

    if kind == "cpu":
        step("construct CpuBackend directly (no facade)")
        var b = CpuBackend.create()
        expect(b.name()).to_equal("cpu")
        step("probe: pure-CPU SIMD lane always initializes")
        val ok = b.init(CANVAS, CANVAS)
        assert_true(ok)
        step("draw: clear(BG) + filled RED rect")
        b.clear(BG)
        b.draw_rect_filled(4, 4, 8, 8, RED)
        b.present()
        step("readback: direct read_pixels() absolute oracle")
        assert_absolute_readback(b.read_pixels())
        b.shutdown()
        return

    if kind == "directx":
        step("construct DirectXBackend directly (no facade)")
        var b = DirectXBackend.create()
        step("name() honesty: discloses software-emulation, never plain directx")
        expect(b.name()).to_equal("directx-software-emulation")
        expect(b.name()).to_start_with("directx")
        step("probe: init may fail without a DXVK/D3D11 device")
        val ok = b.init(CANVAS, CANVAS)
        if ok:
            step("draw: clear(BG) + filled RED rect")
            b.clear(BG)
            b.draw_rect_filled(4, 4, 8, 8, RED)
            b.present()
            step("readback: direct read_pixels() absolute oracle")
            assert_absolute_readback(b.read_pixels())
            b.shutdown()
        else:
            step("host-unavailable: fail-closed on honest cpu_mirror provenance + leaf evidence")
            val rb = b.read_pixels_with_source()
            expect(rb.source).to_equal("cpu_mirror")
            val probe = dx_platform_probe()
            expect(probe.leaf).to_contain("leaf=")
        return

    if kind == "vulkan":
        step("construct VulkanBackend directly (no facade)")
        var b = VulkanBackend.create()
        expect(b.name()).to_equal("vulkan")
        step("probe: real vkCreateInstance under the classic interpreter; may have no device")
        val ok = b.init(CANVAS, CANVAS)
        if ok:
            step("draw: clear(BG) + filled RED rect")
            b.clear(BG)
            b.draw_rect_filled(4, 4, 8, 8, RED)
            b.present()
            step("readback: direct read_pixels() absolute oracle")
            assert_absolute_readback(b.read_pixels())
            b.shutdown()
        else:
            step("host-unavailable: fail-closed on a CLASSIFIED last_error (never None)")
            val kind_err = vulkan_classify_error(b.last_error)
            assert_not_equal(kind_err, VulkanErrorKind.None)
        return

    # Unknown kind must fail loudly, never silently pass.
    expect("known-backend-kind").to_equal(kind)

describe "Backend-only direct drawing — one lane per directly-constructible backend":

    it "software (baseline): direct construct, honest name, filled-rect readback == RED / BG":
        assert_backend_direct("software")

    it "cpu: direct construct, honest name, filled-rect readback == RED / BG":
        assert_backend_direct("cpu")

    it "directx: honest directx-software-emulation name; readback == RED/BG or host-unavailable(cpu_mirror+leaf)":
        assert_backend_direct("directx")

    it "vulkan: real-device filled-rect readback == RED/BG or host-unavailable(classified last_error)":
        assert_backend_direct("vulkan")
