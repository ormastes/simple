# Vulkan Processing (Compute) Lane — Hardening Spec
#
# Tests the Vulkan compute dispatch path including:
#   - Probe and structured error reporting when Vulkan is unavailable
#   - Headless (lavapipe CpuOnly) device discovery
#   - Compute dispatch with readback when a device is available
#   - Structured error classification (VulkanErrorKind)
#   - Pipeline-barrier correctness (deterministic pixel readback)
#
# All tests run in interpreter mode.  When Vulkan is absent the tests
# verify graceful degradation via last_error and VulkanErrorKind.
# When Vulkan is available (lavapipe or real GPU) they verify concrete pixel
# values after clear + dispatch.
#
# Run: bin/simple test test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_vulkan_processing_spec.spl

use std.spec.{describe, context, it, expect, assert_true}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{
    VulkanBackend, VulkanErrorKind, vulkan_classify_error
}
use std.nogc_sync_mut.gpu.engine2d.sffi_vulkan.{
    vulkan_sffi_is_available,
    vulkan_sffi_find_headless_device,
    vulkan_sffi_select_headless
}

# ---------------------------------------------------------------------------
# Helper: pixel at (x, y) in a w-wide u32 pixel array
# ---------------------------------------------------------------------------

fn pixel_at_p(pixels: [u32], x: i32, y: i32, w: i32) -> u32:
    pixels[y * w + x]

describe "Vulkan compute processing lane — probe":

    context "SFFI availability":


        it "draw_rect_filled at origin covers top-left corner":
            var b = VulkanBackend.create()
            if b.init(8, 8):
                val bg: u32 = 0x222222FFu32
                val fg: u32 = 0xFFFFFFFFu32
                b.clear(bg)
                b.draw_rect_filled(0, 0, 4, 4, fg)
                b.present()
                val pixels = b.read_pixels()
                expect(pixel_at_p(pixels, 0, 0, 8)).to_equal(fg)
                # Bottom-right corner of canvas untouched
                expect(pixel_at_p(pixels, 7, 7, 8)).to_equal(bg)
                b.shutdown()
            else:
                val kind = vulkan_classify_error(b.last_error)
                expect(kind).to_not_equal(VulkanErrorKind.None)
