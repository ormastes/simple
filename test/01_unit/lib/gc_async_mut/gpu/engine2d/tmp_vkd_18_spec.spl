# Vulkan 2D Drawing Lane — Hardening Spec
#
# Tests the Vulkan 2D raster drawing path:
#   - VulkanBackend draws 2D primitives with concrete pixel evidence
#   - VulkanSessionBackend session adapter lifecycle
#   - Error paths: init without device, compile failure classification
#   - Headless (lavapipe) device path: deterministic readback pixels
#   - GLSL/SPIR-V parity: backend only uses spirv path, never glsl runtime
#
# All tests run in interpreter mode.  When no Vulkan device is available
# the tests verify graceful structured-error fallback.
#
# Run: bin/simple test test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_vulkan_drawing_spec.spl

use std.spec.{describe, context, it, expect, assert_true}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{
    VulkanBackend, VulkanErrorKind, vulkan_classify_error
}
use std.gc_async_mut.gpu.engine2d.backend_vulkan_session.{
    VulkanShaderMode, VulkanSessionBackend
}
use std.gc_async_mut.gpu.engine2d.backend_vulkan_spirv.{vulkan_spirv_probe}
use std.nogc_sync_mut.gpu.engine2d.sffi_vulkan.{
    vulkan_sffi_is_available
}

# ---------------------------------------------------------------------------
# Helper: pixel at (x, y) in a w-wide u32 pixel array
# ---------------------------------------------------------------------------

fn pixel_at_d(pixels: [u32], x: i32, y: i32, w: i32) -> u32:
    pixels[y * w + x]

describe "Vulkan 2D drawing lane — SPIR-V parity evidence":

    context "probe shader format":


        it "clear to distinct color is deterministic across two inits":
            val color_a: u32 = 0xDEADBEFFu32
            var b1 = VulkanBackend.create()
            var b2 = VulkanBackend.create()
            if b1.init(4, 4) and b2.init(4, 4):
                b1.clear(color_a)
                b1.present()
                b2.clear(color_a)
                b2.present()
                val p1 = b1.read_pixels()
                val p2 = b2.read_pixels()
                expect(pixel_at_d(p1, 0, 0, 4)).to_equal(pixel_at_d(p2, 0, 0, 4))
                expect(pixel_at_d(p1, 3, 3, 4)).to_equal(pixel_at_d(p2, 3, 3, 4))
                b1.shutdown()
                b2.shutdown()
            else:
                # Neither device available — verify last_error is set
                if not b1.initialized:
                    val kind = vulkan_classify_error(b1.last_error)
                    expect(kind).to_not_equal(VulkanErrorKind.None)
                else:
                    b1.shutdown()

