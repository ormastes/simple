# Vulkan 2D Drawing Lane — Hardening Spec
#
# Tests the Vulkan 2D raster drawing path:
#   - VulkanBackend draws 2D primitives with concrete pixel evidence
#   - VulkanSessionBackend session adapter lifecycle
#   - Error paths: init without device, compile failure classification
#   - Headless (lavapipe) device path: deterministic readback pixels
#   - GLSL/SPIR-V parity: backend only uses spirv path, never glsl runtime
#
# All tests run in interpreter mode.  When no Vulkan device is available
# the tests verify graceful structured-error fallback.
#
# Run: bin/simple test test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_vulkan_drawing_spec.spl

use std.spec.{describe, context, it, expect, assert_true}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{
    VulkanBackend, VulkanErrorKind, vulkan_classify_error
}
use std.gc_async_mut.gpu.engine2d.backend_vulkan_session.{
    VulkanShaderMode, VulkanSessionBackend
}
use std.gc_async_mut.gpu.engine2d.backend_vulkan_spirv.{vulkan_spirv_probe}
use std.nogc_sync_mut.gpu.engine2d.sffi_vulkan.{
    vulkan_sffi_is_available
}

# ---------------------------------------------------------------------------
# Helper: pixel at (x, y) in a w-wide u32 pixel array
# ---------------------------------------------------------------------------

fn pixel_at_d(pixels: [u32], x: i32, y: i32, w: i32) -> u32:
    pixels[y * w + x]

describe "Vulkan 2D drawing lane — SPIR-V parity evidence":

    context "probe shader format":

        it "vulkan_spirv_probe reports spirv shader_format (never glsl)":
            val probe = vulkan_spirv_probe()
            # The probe always returns spirv format regardless of device state.
            expect(probe.shader_format).to_equal("spirv")

        it "probe backend_name is vulkan":
            val probe = vulkan_spirv_probe()
            expect(probe.backend_name).to_equal("vulkan")

        it "probe api_name is vulkan":
            val probe = vulkan_spirv_probe()
            expect(probe.api_name).to_equal("vulkan")

        it "probe returns Initialized or Failed — no intermediate state":
            val probe = vulkan_spirv_probe()
            # available must match Initialized status
            if probe.available:
                expect(probe.status.to_text()).to_equal("Initialized")
            else:
                # Failed probes must carry a non-empty reason
                expect(probe.fallback_reason.len()).to_be_greater_than(0)

describe "Vulkan 2D drawing lane — VulkanSessionBackend lifecycle":

    context "creation and init":

        it "create returns uninitialised session with initialized=false":
            val s = VulkanSessionBackend.create("default")
            assert_false(s.initialized)
            expect(s.device_name).to_equal("none")

        it "create sets last_error to empty":
            val s = VulkanSessionBackend.create("default")
            expect(s.last_error).to_equal("")

        it "session counters start at zero":
            val s = VulkanSessionBackend.create("default")
            expect(s.clear_count).to_equal(0)
            expect(s.rect_count).to_equal(0)

        it "operations before init return not-initialized error":
            var s = VulkanSessionBackend.create("default")
            val err = s.clear(0, 0, 0, 255)
            expect(err).to_equal("not initialized")

        it "draw_rect before init returns not-initialized error":
            var s = VulkanSessionBackend.create("default")
            val err = s.draw_rect(0, 0, 10, 10, 0xFF0000FF)
            expect(err).to_equal("not initialized")

    context "init lifecycle — pre-init state":

        it "session_mode is stored from create":
            val s = VulkanSessionBackend.create("headless")
            expect(s.session_mode).to_equal("headless")

        it "create with different modes stores correct mode":
            val s1 = VulkanSessionBackend.create("default")
            val s2 = VulkanSessionBackend.create("strict")
            expect(s1.session_mode).to_equal("default")
            expect(s2.session_mode).to_equal("strict")

        it "uninit clear returns not-initialized error string":
            var s = VulkanSessionBackend.create("default")
            # Each call before init_device returns "not initialized"
            val e1 = s.clear(0, 0, 0, 255)
            val e2 = s.clear(128, 128, 128, 255)
            expect(e1).to_equal("not initialized")
            expect(e2).to_equal("not initialized")

        it "clear_count stays at 0 when not initialized":
            var s = VulkanSessionBackend.create("default")
            s.clear(0, 0, 0, 255)
            s.clear(255, 255, 255, 255)
            expect(s.clear_count).to_equal(0)

        it "rect_count stays at 0 when not initialized":
            var s = VulkanSessionBackend.create("default")
            s.draw_rect(0, 0, 10, 10, 0xFFFFFFFF)
            expect(s.rect_count).to_equal(0)

describe "Vulkan 2D drawing lane — VulkanBackend raster":

    context "2D primitive rendering with lavapipe or real device":

        it "draw_line does not crash backend":
            var b = VulkanBackend.create()
            if b.init(8, 8):
                val bg: u32 = 0x333333FFu32
                b.clear(bg)
                # draw_line(x1, y1, x2, y2, color, thickness)
                b.draw_line(0, 0, 7, 7, 0xFFFFFFFFu32, 1)
                b.present()
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(64)
                b.shutdown()
            else:
                val kind = vulkan_classify_error(b.last_error)
                expect(kind).to_not_equal(VulkanErrorKind.None)

        it "draw_circle does not crash backend":
            var b = VulkanBackend.create()
            if b.init(16, 16):
                val bg: u32 = 0x444444FFu32
                b.clear(bg)
                # draw_circle(cx, cy, r, color)
                b.draw_circle(8, 8, 5, 0xFF8800FFu32)
                b.present()
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(256)
                b.shutdown()
            else:
                val kind = vulkan_classify_error(b.last_error)
                expect(kind).to_not_equal(VulkanErrorKind.None)

        it "draw_rect does not crash backend":
            var b = VulkanBackend.create()
            if b.init(8, 8):
                val bg: u32 = 0x101010FFu32
                b.clear(bg)
                # draw_rect(x, y, w, h, color) — outline variant
                b.draw_rect(1, 1, 6, 6, 0xFFFFFFFFu32)
                b.present()
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(64)
                b.shutdown()
            else:
                val kind = vulkan_classify_error(b.last_error)
                expect(kind).to_not_equal(VulkanErrorKind.None)

        it "shutdown after init sets initialized to false":
            var b = VulkanBackend.create()
            if b.init(4, 4):
                b.shutdown()
                assert_false(b.initialized)
                expect(b.width()).to_equal(0)
                expect(b.height()).to_equal(0)
            else:
                val kind = vulkan_classify_error(b.last_error)
                expect(kind).to_not_equal(VulkanErrorKind.None)

    context "deterministic readback — lavapipe headless":

        it "clear to distinct color is deterministic across two inits":
            val color_a: u32 = 0xDEADBEFFu32
            var b1 = VulkanBackend.create()
            var b2 = VulkanBackend.create()
            if b1.init(4, 4) and b2.init(4, 4):
                b1.clear(color_a)
                b1.present()
                b2.clear(color_a)
                b2.present()
                val p1 = b1.read_pixels()
                val p2 = b2.read_pixels()
                expect(pixel_at_d(p1, 0, 0, 4)).to_equal(pixel_at_d(p2, 0, 0, 4))
                expect(pixel_at_d(p1, 3, 3, 4)).to_equal(pixel_at_d(p2, 3, 3, 4))
                b1.shutdown()
                b2.shutdown()
            else:
                # Neither device available — verify last_error is set
                if not b1.initialized:
                    val kind = vulkan_classify_error(b1.last_error)
                    expect(kind).to_not_equal(VulkanErrorKind.None)
                else:
                    b1.shutdown()

describe "Vulkan 2D drawing lane — error path hardening":

    context "structured error on missing device":

        it "init on host with no Vulkan sets classifiable last_error":
            var b = VulkanBackend.create()
            val ok = b.init(4, 4)
            if not ok:
                val kind = vulkan_classify_error(b.last_error)
                # Error must be classified, never None
                expect(kind).to_not_equal(VulkanErrorKind.None)
                # Must be one of the expected failure categories
                val is_known = (kind == VulkanErrorKind.NotAvailable or
                                kind == VulkanErrorKind.NoDevice or
                                kind == VulkanErrorKind.ShaderCompile or
                                kind == VulkanErrorKind.DeviceLost or
                                kind == VulkanErrorKind.MissingExtension or
                                kind == VulkanErrorKind.Other)
                assert_true(is_known)
            else:
                b.shutdown()

        it "operations after failed init do not crash":
            var b = VulkanBackend.create()
            b.init(4, 4)
            if not b.initialized:
                # These should not crash even with d_framebuffer == 0
                b.clear(0xFF000000u32)
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(0)
            else:
                b.shutdown()

        it "double shutdown is safe":
            var b = VulkanBackend.create()
            if b.init(2, 2):
                b.shutdown()
                b.shutdown()
                assert_false(b.initialized)
            else:
                # Even without init, shutdown should not crash
                b.shutdown()
                assert_false(b.initialized)
