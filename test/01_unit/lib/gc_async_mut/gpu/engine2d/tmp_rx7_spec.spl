use std.spec.{describe, it, expect}

fn take_u(v: u32) -> u32:
    v

describe "vk":
    it "annotated u32 inside if used via free fn":
        val cond = true
        if cond:
            val x: u32 = 5u32
            expect(take_u(x)).to_equal(5u32)
        else:
            expect(2).to_equal(2)
