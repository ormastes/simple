# @tag: unit, gpu, engine2d, vulkan, oracle
"""
# Vulkan Compute Oracle Spec

## Overview

A *real* reference test for the Engine2D Vulkan backend: it dispatches real
SPIR-V compute kernels (`spirv_clear`, `spirv_rect_filled`) through
`VulkanBackend`, reads the framebuffer back from device memory, and compares
every pixel against an independent CPU reference oracle computed in pure
Simple. Unlike the sentinel-style `vulkan_spirv_spec.spl` (which only checks
that the SPIR-V *selection path* is active), this spec verifies that real GPU
output equals the expected pixels — the honest "with reference" check.

## Execution requirement (IMPORTANT)

The real `rt_vulkan_*` runtime is only registered in the *classic* interpreter
(`SIMPLE_EXECUTION_MODE=interpret`). Under the default JIT path the externs
resolve to the native C stub (`rt_vulkan_device_count(){return 0;}`), and the
optimized interpreter does not register them either — both report zero devices.
So the GPU assertion only executes under classic interpret on a Vulkan-capable
host. When Vulkan is unavailable, the test asserts the *unavailability is
self-consistent* (backend reports unavailable) rather than silently passing as
if the GPU were verified — the branch that ran is printed so a reviewer can
tell which path the harness took.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** N/A

## Design

**Design:** doc/04_architecture/ui/simple_gui_stack.md
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}

extern fn rt_vulkan_device_count() -> i64

# Count pixels that differ between two equal-length framebuffers.
fn pixel_mismatches(a: [u32], b: [u32]) -> i64:
    var m = 0
    var i = 0
    val n = if a.len() < b.len(): a.len() else: b.len()
    while i < n:
        if a[i] != b[i]:
            m = m + 1
        i = i + 1
    m

# Pure-Simple CPU reference oracle: a clear to `bg` followed by a filled rect
# of `fg` covering [rx, rx+rw) x [ry, ry+rh). Returns expected ARGB per pixel.
fn oracle_pixel(x: i32, y: i32, rx: i32, ry: i32, rw: i32, rh: i32, bg: u32, fg: u32) -> u32:
    val inside = (x >= rx and x < rx + rw and y >= ry and y < ry + rh)
    if inside:
        return fg
    bg

describe "engine2d vulkan backend compute matches CPU oracle":

    it "real GPU clear+rect equals the CPU reference (classic-interpret Vulkan)":
        val w: i32 = 16
        val h: i32 = 8
        val bg: u32 = 0xFF112233u32
        val fg: u32 = 0xFFAABBCCu32
        val rx: i32 = 4
        val ry: i32 = 2
        val rw: i32 = 6
        val rh: i32 = 3

        var be = VulkanBackend.create()
        val available = be.init(w, h)

        if not available:
            # Honest unavailable branch: do NOT claim GPU verification. Assert the
            # runtime is self-consistent about having no usable Vulkan device.
            print("[vulkan_compute_oracle] UNAVAILABLE_BRANCH (no real Vulkan in this execution mode)\n")
            expect(rt_vulkan_device_count()).to_equal(0)
            return

        print("[vulkan_compute_oracle] GPU_BRANCH (real Vulkan dispatch + readback)\n")
        be.clear(bg)
        be.draw_rect_filled(rx, ry, rw, rh, fg)
        val px = be.read_pixels()

        expect(px.len()).to_equal(w * h)

        var mismatches = 0
        var y = 0
        while y < h:
            var x = 0
            while x < w:
                val idx = y * w + x
                val expected = oracle_pixel(x, y, rx, ry, rw, rh, bg, fg)
                if px[idx] != expected:
                    mismatches = mismatches + 1
                x = x + 1
            y = y + 1

        expect(mismatches).to_equal(0)

    it "Vulkan raster kernels match the SoftwareBackend reference (circle_filled, rect_outline, triangle_filled, rounded_rect)":
        # Regression guard for the noop-shader wiring bug: these primitives were
        # dispatched on a no-op SPIR-V shader and rendered nothing. Now wired to
        # their real validated kernels, they must be bit-exact with the
        # independent SoftwareBackend reference. rounded_rect additionally fixed
        # a SoftwareBackend bug (it drew an outline; CUDA/Metal/GLSL all fill).
        val w: i32 = 64
        val h: i32 = 48
        val bg: u32 = 0xFF0A0A12u32
        val fg: u32 = 0xFF40C0A0u32

        var vk = VulkanBackend.create()
        if not vk.init(w, h):
            expect(rt_vulkan_device_count()).to_equal(0)
            return

        var sw = SoftwareBackend.create()
        sw.init(w, h)

        vk.clear(bg)
        sw.clear(bg)
        vk.draw_circle_filled(30, 24, 12, fg)
        sw.draw_circle_filled(30, 24, 12, fg)
        vk.draw_rect(5, 5, 40, 30, fg)
        sw.draw_rect(5, 5, 40, 30, fg)
        vk.draw_triangle_filled(10, 44, 30, 6, 54, 44, fg)
        sw.draw_triangle_filled(10, 44, 30, 6, 54, 44, fg)

        expect(pixel_mismatches(vk.read_pixels(), sw.read_pixels())).to_equal(0)

        # rounded_rect (filled) on a fresh surface
        vk.clear(bg)
        sw.clear(bg)
        vk.draw_rounded_rect(6, 6, 50, 36, 10, fg)
        sw.draw_rounded_rect(6, 6, 50, 36, 10, fg)
        expect(pixel_mismatches(vk.read_pixels(), sw.read_pixels())).to_equal(0)

        # circle outline (distance-ring) on a fresh surface
        vk.clear(bg)
        sw.clear(bg)
        vk.draw_circle(32, 24, 12, fg)
        sw.draw_circle(32, 24, 12, fg)
        expect(pixel_mismatches(vk.read_pixels(), sw.read_pixels())).to_equal(0)

    it "Metal-on-Vulkan emulation renders through real Vulkan, matching the reference":
        # Native Metal is macOS-only; on other platforms Engine2D serves a
        # "metal" request through the real Vulkan backend (emulation) instead of
        # dropping to CPU. The emulated surface must render the verified
        # primitives bit-exact with the SoftwareBackend reference, and disclose
        # the emulation in its backend name (not claim native "metal").
        val w: i32 = 56
        val h: i32 = 40
        val r = Engine2D.create_requested_backend(w, h, "metal")
        if not r.is_ok():
            return
        var eng = r.unwrap()
        val name = eng.backend_name()
        # On a Vulkan host without native Metal, the name discloses emulation.
        # On a host with neither, it falls back (cpu) — accept either truthfully.
        val honest_name = (name == "metal-on-vulkan" or name == "metal" or name == "cpu" or name == "software")
        expect(honest_name).to_equal(true)
        if name != "metal-on-vulkan":
            return

        eng.clear(0xFF0A0A12u32)
        eng.draw_rect_filled(4, 4, 30, 20, 0xFFCC2020u32)
        eng.draw_circle_filled(40, 20, 9, 0xFF3060FFu32)
        var sw2 = SoftwareBackend.create()
        sw2.init(w, h)
        sw2.clear(0xFF0A0A12u32)
        sw2.draw_rect_filled(4, 4, 30, 20, 0xFFCC2020u32)
        sw2.draw_circle_filled(40, 20, 9, 0xFF3060FFu32)
        expect(pixel_mismatches(eng.read_pixels(), sw2.read_pixels())).to_equal(0)
