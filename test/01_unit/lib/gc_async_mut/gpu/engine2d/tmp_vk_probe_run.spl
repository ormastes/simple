use std.gpu.engine2d.backend_vulkan.{VulkanBackend, vulkan_classify_error, VulkanErrorKind}

fn main() -> i64:
    var b = VulkanBackend.create()
    val ok = b.init(4, 4)
    print "init_ok={ok}"
    print "last_error=[{b.last_error}]"
    val kind = vulkan_classify_error(b.last_error)
    print "classified={kind}"
    if ok:
        val green: u32 = 0x00FF00FFu32
        b.clear(green)
        b.present()
        val pixels = b.read_pixels()
        print "pixel_count={pixels.len()}"
        if pixels.len() > 0:
            print "pixel0={pixels[0]}"
        b.shutdown()
    0
