use std.spec.{describe, it, expect}

describe "u32 matcher sanity":
    it "u32 literal equality":
        val v: u32 = 0x00FF00FFu32
        expect(v).to_equal(0x00FF00FFu32)
    it "u32 from array equality":
        val arr: [u32] = [0x00FF00FFu32; 4]
        expect(arr[0]).to_equal(0x00FF00FFu32)
    it "u32 greater than":
        val v: u32 = 2u32
        expect(v).to_be_greater_than(1u32)
    it "u32 decimal equality":
        val v: u32 = 16711935u32
        expect(v).to_equal(16711935u32)
