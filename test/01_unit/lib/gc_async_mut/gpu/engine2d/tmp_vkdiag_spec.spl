use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}

fn vk_pixel0() -> u32:
    var b = VulkanBackend.create()
    if b.init(4, 4):
        b.clear(0x00FF00FFu32)
        b.present()
        val pixels = b.read_pixels()
        val v = pixels[0]
        b.shutdown()
        return v
    1u32

describe "vk diag":
    it "v greater than zero":
        expect(vk_pixel0()).to_be_greater_than(0u32)
    it "v equals byte swap ff00ff00":
        expect(vk_pixel0()).to_equal(0xFF00FF00u32)
    it "v equals one (init failed sentinel)":
        expect(vk_pixel0()).to_equal(1u32)
    it "v less than green":
        expect(vk_pixel0()).to_be_less_than(0x00FF00FFu32)
    it "v greater than green":
        expect(vk_pixel0()).to_be_greater_than(0x00FF00FFu32)
