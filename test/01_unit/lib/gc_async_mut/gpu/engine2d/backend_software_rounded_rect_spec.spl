# @tag: rendering, engine2d, software, regression
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_software.spl 15%
#
# Regression guard for
# doc/08_tracking/bug/engine2d_software_rounded_rect_draws_outline_not_fill_2026-07-06.md
# SoftwareBackend.draw_rounded_rect must paint a FILLED rounded rectangle (rect
# body + corner arcs), not a 1px outline. It delegates to emu_draw_rounded_rect,
# the shared raster reference. Genuine outlines are draw_rounded_rect_outline.

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gc_async_mut.gpu.engine2d.backend.{RenderBackend}

describe "SoftwareBackend.draw_rounded_rect fills the interior":
    """A filled rounded rect paints its whole interior, with rounded corners
    left as background — never just a hollow outline."""

    it "paints an interior pixel and leaves the rounded corner as background":
        var backend = SoftwareBackend.create()
        expect(backend.init(16, 16)).to_equal(true)
        # init() fills opaque black.
        backend.draw_rounded_rect(2, 2, 12, 12, 4, 0xFFFF0000u32)
        val pixels = backend.read_pixels()
        # Deep interior must be the fill color (an outline-only bug leaves it black).
        expect(pixels[8 * 16 + 8]).to_equal(0xFFFF0000u32)
        expect(pixels[7 * 16 + 4]).to_equal(0xFFFF0000u32)
        # The rounded top-left corner of the bounding box stays background.
        expect(pixels[2 * 16 + 2]).to_equal(0xFF000000u32)
        backend.shutdown()
