# @cover src/lib/gc_async_mut/gpu/browser_engine/dom_accessors.spl 80%

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.dom_accessors.{
    be_dom_find_by_id,
    be_dom_find_by_tag,
    be_dom_get_text_content
}

fn _accessor_tree() -> BeDomNode:
    var root = BeDomNode.element(1, "main")
    var first = BeDomNode.element(2, "section")
    first.children.push(BeDomNode.text_node(3, "alpha"))

    var second = BeDomNode.element(4, "section")
    var nested = BeDomNode.element(5, "span")
    nested.children.push(BeDomNode.text_node(6, "beta"))
    second.children.push(nested)

    root.children.push(first)
    root.children.push(second)
    root

describe "browser DOM accessors":
    it "concatenates descendant text in source order":
        val text_content = be_dom_get_text_content(_accessor_tree())

        expect(text_content).to_equal("alphabeta")

    it "finds descendants by id and tag through recursive scans":
        val root = _accessor_tree()
        val found = be_dom_find_by_id(root, 5)
        val sections = be_dom_find_by_tag(root, "section")

        expect(found == nil).to_be(false)
        expect(found.unwrap().tag_name).to_equal("span")
        expect(sections.len()).to_equal(2)
        expect(sections[0].node_id).to_equal(2)
        expect(sections[1].node_id).to_equal(4)
