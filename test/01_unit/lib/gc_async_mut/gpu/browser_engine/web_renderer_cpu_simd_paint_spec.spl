use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_engine2d_presenter.{
    simple_web_layout_render_html_gpu_paint_route_verdict,
    simple_web_layout_render_html_readback_paint,
    simple_web_layout_render_html_should_gpu_paint
}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_software_pixels}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels_with_engine2d_backend}
use std.gpu.engine2d.simd_provider.{reset_simd_hits, simd_hit_counts}

fn solid_html() -> text:
    "<!doctype html><meta charset='utf-8'><style>html,body{margin:0;padding:0;width:32px;height:32px;background:#ffffff}.panel{width:16px;height:16px;background:#336699}</style><body><div class='panel'></div></body>"

fn transparent_html() -> text:
    "<!doctype html><meta charset='utf-8'><style>html,body{margin:0;padding:0;width:32px;height:32px;background:#ffffff}.panel{width:16px;height:16px;background:rgba(255,0,0,.5)}</style><body><div class='panel'></div></body>"

fn opacity_html() -> text:
    "<!doctype html><meta charset='utf-8'><style>html,body{margin:0;padding:0;width:32px;height:32px;background:#ffffff}.panel{width:16px;height:16px;background-color:#336699;opacity:0.5}</style><body><div class='panel'></div></body>"

fn text_html() -> text:
    "<!doctype html><meta charset='utf-8'><style>html,body{margin:0;padding:0;width:32px;height:32px;background:#ffffff}</style><body><p>Text lane</p></body>"

describe "web renderer CPU SIMD paint":
    it "keeps cpu simd out of explicit gpu paint routing":
        expect(simple_web_layout_render_html_should_gpu_paint(solid_html(), 32, 32, "cpu_simd", true)).to_equal(false)
        expect(simple_web_layout_render_html_gpu_paint_route_verdict(solid_html(), 32, 32, "cpu_simd", true)).to_equal("cpu-backend-not-gpu-offload")
        expect(simple_web_layout_render_html_gpu_paint_route_verdict(solid_html(), 32, 32, "vulkan", false)).to_equal("gpu-paint-disabled")

    it "uses cpu simd fills for solid-only readback":
        reset_simd_hits()
        val readback = simple_web_layout_render_html_readback_paint(solid_html(), 32, 32, "cpu_simd", true)
        val hits = simd_hit_counts()
        expect(readback.pixels.len()).to_equal(1024)
        expect(readback.pixels[0]).to_equal(0xFF336699u32)
        expect(readback.source).to_equal("cpu_mirror")
        expect(hits.fill_hits).to_be_greater_than(0)
        expect(hits.copy_hits).to_equal(0)
        expect(hits.alpha_hits).to_equal(0)

    it "uses residual cpu simd presentation for text pages without pixel drift":
        val oracle = simple_web_layout_render_html_software_pixels(text_html(), 32, 32)
        reset_simd_hits()
        val readback = simple_web_layout_render_html_readback_paint(text_html(), 32, 32, "cpu_simd", true)
        val hits = simd_hit_counts()
        expect(readback.pixels.len()).to_equal(1024)
        expect(readback.pixels).to_equal(oracle)
        expect(readback.source).to_equal("cpu_mirror")
        expect(hits.fill_hits).to_be_greater_than(0)
        expect(hits.copy_hits).to_be_greater_than(0)

    it "uses residual cpu simd presentation for public text renders":
        val oracle = simple_web_layout_render_html_software_pixels(text_html(), 32, 32)
        reset_simd_hits()
        val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(text_html(), 32, 32, "cpu_simd")
        val hits = simd_hit_counts()
        expect(pixels.len()).to_equal(1024)
        expect(pixels).to_equal(oracle)
        expect(hits.fill_hits).to_be_greater_than(0)
        expect(hits.copy_hits).to_be_greater_than(0)

    it "preserves translucent color composition on the cpu_simd readback path":
        val oracle = simple_web_layout_render_html_software_pixels(transparent_html(), 32, 32)
        reset_simd_hits()
        val readback = simple_web_layout_render_html_readback_paint(transparent_html(), 32, 32, "cpu_simd", true)
        val hits = simd_hit_counts()
        expect(readback.pixels.len()).to_equal(1024)
        expect(readback.pixels[0]).to_equal(0xFFFF8080u32)
        expect(readback.pixels).to_equal(oracle)
        expect(readback.source).to_equal("cpu_mirror")
        expect(hits.fill_hits).to_be_greater_than(0)
        expect(hits.copy_hits).to_be_greater_than(0)

    it "preserves css opacity composition on the cpu_simd readback path":
        val oracle = simple_web_layout_render_html_software_pixels(opacity_html(), 32, 32)
        reset_simd_hits()
        val readback = simple_web_layout_render_html_readback_paint(opacity_html(), 32, 32, "cpu_simd", true)
        val hits = simd_hit_counts()
        expect(readback.pixels.len()).to_equal(1024)
        expect(readback.pixels[0]).to_equal(0xFF99B3CCu32)
        expect(readback.pixels).to_equal(oracle)
        expect(readback.source).to_equal("cpu_mirror")
        expect(hits.fill_hits).to_be_greater_than(0)
        expect(hits.copy_hits).to_be_greater_than(0)

    it "routes cpu simd backend aliases through residual presentation":
        val oracle = simple_web_layout_render_html_software_pixels(text_html(), 32, 32)
        reset_simd_hits()
        val simd_cpu = simple_web_layout_render_html_readback_paint(text_html(), 32, 32, "simd_cpu", true)
        val simd_cpu_hits = simd_hit_counts()
        expect(simd_cpu.pixels).to_equal(oracle)
        expect(simd_cpu.source).to_equal("cpu_mirror")
        expect(simd_cpu_hits.copy_hits).to_be_greater_than(0)
        reset_simd_hits()
        val cpu_dash_simd = simple_web_layout_render_html_readback_paint(text_html(), 32, 32, "cpu-simd", true)
        val cpu_dash_simd_hits = simd_hit_counts()
        expect(cpu_dash_simd.pixels).to_equal(oracle)
        expect(cpu_dash_simd.source).to_equal("cpu_mirror")
        expect(cpu_dash_simd_hits.copy_hits).to_be_greater_than(0)
