# @tag: web, renderer, gpu, paint, economics
# @cover src/lib/gc_async_mut/gpu/browser_engine/simple_web_html_engine2d_presenter.spl 30%

use std.spec.{describe, context, it, expect}
use common.render_scene.scene.{scene_fill_rect}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_gpu_frame, WebGpuPaintFrame}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_engine2d_presenter.{web_gpu_paint_economics}

fn solid_full_frame_html() -> text:
    "<html><body><div style='background-color:#1d4ed8;width:64px;height:64px'></div></body></html>"

fn text_only_html() -> text:
    "<html><body>hello</body></html>"

fn blank_html() -> text:
    "<html><body></body></html>"

fn many_tiny_fill_frame(cpu_paint_pixels: i32) -> WebGpuPaintFrame:
    val width = 64
    val height = 64
    val base = 0xFFFFFFFFu32
    val color = 0xFF1D4ED8u32
    var fb: [u32] = [base; width * height]
    var ops = [scene_fill_rect(0, 0, 1, 1, color as i32)]
    fb[0] = color
    var i = 1
    var x = 1
    var y = 0
    while i < 100:
        ops.push(scene_fill_rect(x, y, 1, 1, color as i32))
        fb[y * width + x] = color
        x = x + 1
        if x >= width:
            x = 0
            y = y + 1
        i = i + 1
    WebGpuPaintFrame(fb: fb, fill_ops: ops, width: width, height: height, cpu_paint_pixels: cpu_paint_pixels)

describe "Simple web renderer GPU paint economics":

    context "offload decision":
        it "offloads solid fills when transfer cost beats upload-bound presentation":
            val frame = simple_web_layout_render_html_gpu_frame(solid_full_frame_html(), 64, 64)
            val economics = web_gpu_paint_economics(frame, 0xFFFFFFFFu32)
            expect(economics.cpu_paint_pixels).to_equal(0)
            expect(economics.fill_op_count).to_be_greater_than(0)
            expect(economics.should_offload).to_equal(true)
            expect(economics.reason).to_equal("gpu-paint-transfer-win")
            expect(economics.gpu_paint_transfer_pixels).to_be_less_than(economics.upload_bound_transfer_pixels)
            expect(economics.gpu_paint_total_pixels).to_be_less_than(economics.upload_bound_total_pixels)

        it "offloads when skipped CPU paint beats command overhead overall":
            val frame = many_tiny_fill_frame(0)
            val economics = web_gpu_paint_economics(frame, 0xFFFFFFFFu32)
            expect(economics.gpu_paint_transfer_pixels).to_be_greater_than(economics.upload_bound_transfer_pixels)
            expect(economics.gpu_paint_total_pixels).to_be_less_than(economics.upload_bound_total_pixels)
            expect(economics.should_offload).to_equal(true)
            expect(economics.reason).to_equal("gpu-paint-total-win")

        it "keeps text-only frames on the upload-bound path":
            val frame = simple_web_layout_render_html_gpu_frame(text_only_html(), 64, 64)
            val economics = web_gpu_paint_economics(frame, 0xFFFFFFFFu32)
            expect(economics.cpu_paint_pixels).to_equal(64 * 64)
            expect(economics.should_offload).to_equal(false)
            expect(economics.reason).to_equal("cpu-ground-truth-required")

        it "does not offload when there is no GPU fill work":
            val frame = simple_web_layout_render_html_gpu_frame(blank_html(), 64, 64)
            val economics = web_gpu_paint_economics(frame, 0xFFFFFFFFu32)
            expect(economics.cpu_paint_pixels).to_equal(0)
            expect(economics.should_offload).to_equal(false)
            expect(economics.reason).to_equal("no-gpu-fill-ops")
