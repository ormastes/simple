use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}

val WIDTH: i32 = 40
val HEIGHT: i32 = 40

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn _count_region_color(pixels: [u32], width: i32, rx: i32, ry: i32, rw: i32, rh: i32, color: u32) -> i32:
    var count: i32 = 0
    var row: i32 = 0
    while row < rh:
        var col: i32 = 0
        while col < rw:
            val idx = (ry + row) * width + (rx + col)
            if idx >= 0 and idx < pixels.len():
                if pixels[idx] == color:
                    count = count + 1
            col = col + 1
        row = row + 1
    count

describe "display contents layout":

    it "flattens children without painting wrapper box":
        val html = "<html><body style='margin:0;background:#ffffff'><div style='display:contents;margin-top:20px;background:#ff0000'><div style='width:40px;height:10px;background:#0000ff'></div></div><div style='width:40px;height:10px;background:#00ff00'></div></body></html>"
        val pixels = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT).pixel_data
        expect(pixels.len()).to_equal(WIDTH * HEIGHT)
        expect(_count_color(pixels, 0xFFFF0000u32)).to_equal(0)
        expect(_count_region_color(pixels, WIDTH, 0, 0, 40, 10, 0xFF0000FFu32)).to_be_greater_than(0)
        expect(_count_region_color(pixels, WIDTH, 0, 10, 40, 10, 0xFF00FF00u32)).to_be_greater_than(0)
