# @cover src/lib/gc_async_mut/gpu/browser_engine/layout.spl 80%

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.layout.{
    layout_tree
}

fn _stacked_dom() -> BeDomNode:
    var root = BeDomNode.element(0, "body")
    root.style.width = 100.0
    root.style.padding_top = 2.0
    root.style.padding_left = 3.0
    root.style.background_color = "#ffffff"

    var first = BeDomNode.element(1, "div")
    first.style.height = 10.0
    first.style.background_color = "#ff0000"

    var second = BeDomNode.element(2, "div")
    second.style.height = 12.0
    second.style.background_color = "#00ff00"

    root.children.push(first)
    root.children.push(second)
    root

describe "browser layout":
    it "lays out stacked child boxes in source order":
        val box = layout_tree(_stacked_dom(), 100.0, 80.0)

        expect(box.children.len()).to_equal(2)
        expect(box.children[0].y).to_equal(2.0)
        expect(box.children[1].y).to_equal(12.0)
        expect(box.height).to_equal(24.0)
