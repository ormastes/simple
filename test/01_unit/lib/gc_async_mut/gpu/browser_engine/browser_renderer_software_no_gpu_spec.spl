use std.spec.*

# Lane BR item 1 — software-raster (no host-GPU) render path.
#
# Ground truth traced through the render call chain:
#   BrowserRenderer.create(w, h)                     -> backend_value = "software"
#     .render_html_to_pixels(html)
#       -> simple_web_engine2d_render_html_pixels(html, w, h, "software")
#         Fast-path dispatch: a narrow set of substring-recognized shapes
#         (resolved solid background, first-block color, wm-app chrome
#         markers) is drawn directly by a small heuristic surface
#         (SimpleWebHeuristicSurface — pure CPU rect fills, no imports
#         outside this module); anything else routes to:
#       -> simple_web_layout_render_html_pixels(html, w, h, "software")
#           -> simple_web_layout_render_html_readback_paint(..., gpu_paint=false)
#             -> web_gpu_paint_enabled() reads SIMPLE_WEB_GPU_PAINT (unset by
#                default) -> false, so the GPU-paint branch never triggers
#             -> pixels = simple_web_layout_render_html_software_pixels(html, w, h)
#                (pure CPU: parse_html -> compute_styles -> layout -> paint
#                 directly into a [u32] framebuffer array — this module's own
#                 `use` list is exactly glyph_bitmap_5x7 / draw_ir /
#                 render_scene.scene, none of which import Engine2D or any
#                 GPU backend)
#             -> present_layout_pixels_with_engine2d_readback(pixels, ..., "software", base)
#                -> _backend_is_cpu("software") == true -> returns the CPU
#                   pixels immediately as "cpu_mirror"; Engine2D.create_requested_backend
#                   (the call that would dlopen/init a host GPU backend) is
#                   NEVER reached on either path.
#
# So BrowserRenderer's default ("software") backend is already a genuine
# no-host-GPU raster path end to end, on both the heuristic fast path and the
# full parse/layout/paint path. This spec pins that behavior with a host-only
# (no kernel, no QEMU) render of static HTML strings to an in-memory RGBA
# (0xAARRGGBB) pixel buffer: non-blank output, an expected color present for
# a colored block, and an exact expected fill for a fully-deterministic
# solid-background page.

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

val W: i32 = 40
val H: i32 = 30
val WHITE: u32 = 0xFFFFFFFFu32
val RED: u32 = 0xFFFF0000u32

fn _non_blank_count(pixels: [u32], bg: u32) -> i32:
    var count: i32 = 0
    var i: i32 = 0
    while i < pixels.len():
        if pixels[i] != bg:
            count = count + 1
        i = i + 1
    count

describe "BrowserRenderer software backend renders with no host-GPU dependency":

    it "defaults to the software backend (BrowserRenderer.create)":
        val r = BrowserRenderer.create(W, H)
        expect(r.backend_name()).to_equal("software")

    it "renders a static HTML string to a non-blank in-memory RGBA buffer":
        val html = "<html><body style='margin:0;background:#ffffff'>" +
            "<div style='width:20px;height:15px;background-color:#ff0000'></div>" +
            "</body></html>"
        val result = BrowserRenderer.create(W, H).render_html_to_pixels(html)
        expect(result.ok).to_equal(true)
        expect(result.width).to_equal(W)
        expect(result.height).to_equal(H)
        expect(result.pixel_data.len()).to_equal(W * H)
        expect(_non_blank_count(result.pixel_data, WHITE)).to_be_greater_than(0)

    it "produces the expected block color for a known solid-color div":
        val html = "<html><body style='margin:0;background:#ffffff'>" +
            "<div style='width:20px;height:15px;background-color:#ff0000'></div>" +
            "</body></html>"
        val result = BrowserRenderer.create(W, H).render_html_to_pixels(html)
        # Exact placement inside the heuristic/fast-path fallback isn't pinned
        # by contract (it may draw an approximated block rect rather than the
        # literal 20x15 box), so assert presence of the expected color and
        # continued presence of the white background rather than an exact
        # pixel index — same discipline as browser_renderer_smoke_spec.spl.
        expect(_non_blank_count(result.pixel_data, WHITE)).to_be_greater_than(0)
        var red_count: i32 = 0
        var i: i32 = 0
        while i < result.pixel_data.len():
            if result.pixel_data[i] == RED:
                red_count = red_count + 1
            i = i + 1
        expect(red_count).to_be_greater_than(0)

    it "produces an exact uniform fill for a known solid-background page (no blocks)":
        val html = "<html><body style='margin:0;background:#0000ff'></body></html>"
        val r = BrowserRenderer.create_with_backend(W, H, "software")
        expect(r.backend_name()).to_equal("software")
        val result = r.render_html_to_pixels(html)
        expect(result.pixel_data.len()).to_equal(W * H)
        # No child block: the whole viewport resolves to the page background
        # color deterministically — every pixel must match exactly.
        expect(result.pixel_data[0]).to_equal(0xFF0000FFu32)
        expect(result.pixel_data[result.pixel_data.len() - 1]).to_equal(0xFF0000FFu32)
