# Engine3D Vulkan Backend — Hardening Spec
#
# Tests init guards, VulkanErrorKind3D classification, last_error propagation,
# and CPU-migration semantics (no silent no-op when not initialized).
#
# Run: bin/simple test test/01_unit/lib/gc_async_mut/gpu/engine3d/backend_vulkan3d_harden_spec.spl

use std.spec.{describe, context, it, expect, assert_true, assert_false, assert_equal}
use std.gc_async_mut.gpu.engine3d.backend_vulkan.{
    VulkanBackend3D, VulkanErrorKind3D, vulkan3d_classify_error
}
# backend_vulkan_ext completes the RenderBackend3D impl for VulkanBackend3D;
# importing it here satisfies the trait-completeness check.
use std.gc_async_mut.gpu.engine3d.backend_vulkan_ext
use std.gc_async_mut.gpu.engine3d.types3d.{
    Vertex3D, Material3DParams, mat4_identity, MATERIAL_UNLIT, material_unlit
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn _unlit_mat() -> Material3DParams:
    material_unlit(0xFF0000FF)

fn _v3(x: f32, y: f32, z: f32) -> Vertex3D:
    Vertex3D(
        px: x, py: y, pz: z,
        nx: 0.0, ny: 1.0, nz: 0.0,
        u: 0.0, v: 0.0,
        color: 0xFFFFFFFF
    )

describe "VulkanBackend3D — VulkanErrorKind3D classification":

    context "error classification":

        it "empty string classifies as None":
            val kind = vulkan3d_classify_error("")
            expect(kind).to_equal(VulkanErrorKind3D.None)

        it "device lost string classifies as DeviceLost":
            val kind = vulkan3d_classify_error("device lost in render pass")
            expect(kind).to_equal(VulkanErrorKind3D.DeviceLost)

        it "DEVICE_LOST classifies as DeviceLost":
            val kind = vulkan3d_classify_error("VK_ERROR_DEVICE_LOST")
            expect(kind).to_equal(VulkanErrorKind3D.DeviceLost)

        it "extension string classifies as MissingExtension":
            val kind = vulkan3d_classify_error("required extension not supported")
            expect(kind).to_equal(VulkanErrorKind3D.MissingExtension)

        it "shader compile string classifies as ShaderCompile":
            val kind = vulkan3d_classify_error("shader compile failed")
            expect(kind).to_equal(VulkanErrorKind3D.ShaderCompile)

        it "SPIR-V string classifies as ShaderCompile":
            val kind = vulkan3d_classify_error("invalid SPIR-V module")
            expect(kind).to_equal(VulkanErrorKind3D.ShaderCompile)

        it "unavailable string classifies as NotAvailable":
            val kind = vulkan3d_classify_error("Vulkan runtime unavailable")
            expect(kind).to_equal(VulkanErrorKind3D.NotAvailable)

        it "no Vulkan devices classifies as NoDevice":
            val kind = vulkan3d_classify_error("no Vulkan devices enumerated")
            expect(kind).to_equal(VulkanErrorKind3D.NoDevice)

        it "unknown error classifies as Other":
            val kind = vulkan3d_classify_error("unexpected internal error XYZ")
            expect(kind).to_equal(VulkanErrorKind3D.Other)

describe "VulkanBackend3D — init guards":

    context "uninitialized backend":

        it "create() returns initialized=false":
            val b = VulkanBackend3D.create()
            assert_false(b.initialized)

        it "create() has empty last_error":
            val b = VulkanBackend3D.create()
            assert_equal(b.last_error, "")

        it "init() with valid dimensions succeeds":
            var b = VulkanBackend3D.create()
            val ok = b.init(64, 64)
            assert_true(ok)
            assert_true(b.initialized)
            assert_equal(b.last_error, "")

        it "init() with zero width fails and sets last_error":
            var b = VulkanBackend3D.create()
            val ok = b.init(0, 64)
            assert_false(ok)
            assert_false(b.initialized)
            # last_error must be non-empty on failure
            val classified = vulkan3d_classify_error(b.last_error)
            expect(b.last_error).to_not_equal("")

        it "init() with zero height fails and sets last_error":
            var b = VulkanBackend3D.create()
            val ok = b.init(64, 0)
            assert_false(ok)
            assert_false(b.initialized)
            expect(b.last_error).to_not_equal("")

    context "draw calls before init are no-ops":

        it "clear() before init does not panic":
            var b = VulkanBackend3D.create()
            b.clear(0xFF000000)
            # No assertion needed — absence of panic is the guarantee
            assert_false(b.initialized)

        it "submit_triangle() before init does not panic and backend stays uninitialized":
            var b = VulkanBackend3D.create()
            val v0 = _v3(0.0, 0.0, 0.0)
            val v1 = _v3(1.0, 0.0, 0.0)
            val v2 = _v3(0.5, 1.0, 0.0)
            b.submit_triangle(v0, v1, v2, _unlit_mat(), mat4_identity())
            # Guard must not change initialized state
            assert_false(b.initialized)

        it "present() before init is a no-op":
            var b = VulkanBackend3D.create()
            b.present()
            assert_false(b.initialized)

        it "begin_frame() before init is a no-op":
            var b = VulkanBackend3D.create()
            b.begin_frame()
            assert_false(b.initialized)

        it "end_frame() before init is a no-op":
            var b = VulkanBackend3D.create()
            b.end_frame()
            assert_false(b.initialized)

    context "draw calls after init work correctly":

        it "clear() after init sets buf pixels":
            var b = VulkanBackend3D.create()
            b.init(4, 4)
            b.clear(0xDEADBEEFu32)
            val pixels = b.read_pixels()
            assert_equal(pixels[0], 0xDEADBEEFu32)
            assert_equal(pixels[15], 0xDEADBEEFu32)

        it "after init clear+draw_image pipeline is functional":
            var b = VulkanBackend3D.create()
            b.init(4, 4)
            b.clear(0xAABBCCDDu32)
            val pixels = b.read_pixels()
            assert_equal(pixels[0], 0xAABBCCDDu32)

    context "shutdown clears state":

        it "shutdown() resets initialized and last_error":
            var b = VulkanBackend3D.create()
            b.init(32, 32)
            b.shutdown()
            assert_false(b.initialized)
            assert_equal(b.last_error, "")

describe "VulkanBackend3D — CPU migration semantics":

    context "fallback parity":

        it "uninitialized backend buf is empty (no silent state)":
            val b = VulkanBackend3D.create()
            assert_equal(b.buf.len(), 0)

        it "after init+clear buf length matches w*h":
            var b = VulkanBackend3D.create()
            b.init(8, 8)
            b.clear(0x00000000)
            assert_equal(b.buf.len(), 64)
