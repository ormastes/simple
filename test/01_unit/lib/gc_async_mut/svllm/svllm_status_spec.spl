describe "svllm_status_from kv_cache_ready-only-true (degraded-OR fix validation)":
    it "is degraded not offline when only kv_cache_ready is true":
        # This case proves the degraded-OR branch includes kv_cache_ready.
        # Before the fix: (F,F,F,T,F) fell through to offline because the OR
        # omitted kv_cache_ready. After the fix it must be "degraded".
        val s = svllm_status_from(false, false, false, true, false, "")
        expect(s.readiness).to_equal("degraded")

    it "is not servable":
        val s = svllm_status_from(false, false, false, true, false, "")
        expect(svllm_status_is_servable(s)).to_equal(false)

    it "has 4 reasons (all flags except kv_cache_ready are false)":
        val s = svllm_status_from(false, false, false, true, false, "")
        expect(s.reasons.len()).to_equal(4)

describe "svllm_status_reasons content":
    it "includes tensor-pack-unavailable when pack_available is false":
        val r = svllm_status_reasons(false, true, true, true, true)
        expect(r.len()).to_equal(1)
        expect(r.get(0)).to_equal("tensor-pack-unavailable")

    it "includes model-loader-not-ready when loader_ready is false":
        val r = svllm_status_reasons(true, false, true, true, true)
        expect(r.len()).to_equal(1)
        expect(r.get(0)).to_equal("model-loader-not-ready")

    it "includes nvfs-client-not-wired when nvfs_ready is false":
        val r = svllm_status_reasons(true, true, false, true, true)
        expect(r.len()).to_equal(1)
        expect(r.get(0)).to_equal("nvfs-client-not-wired")

    it "includes kv-cache-not-allocated when kv_cache_ready is false":
        val r = svllm_status_reasons(true, true, true, false, true)
        expect(r.len()).to_equal(1)
        expect(r.get(0)).to_equal("kv-cache-not-allocated")

    it "includes model-not-loaded when model_loaded is false":
        val r = svllm_status_reasons(true, true, true, true, false)
        expect(r.len()).to_equal(1)
        expect(r.get(0)).to_equal("model-not-loaded")

    it "is empty when all flags are true":
        val r = svllm_status_reasons(true, true, true, true, true)
        expect(r.len()).to_equal(0)

    it "has 5 entries when all flags are false":
        val r = svllm_status_reasons(false, false, false, false, false)
        expect(r.len()).to_equal(5)

describe "svllm_status_summary":
    it "contains phase=A1":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("phase=A1")

    it "contains readiness=offline for default":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("readiness=offline")

    it "contains readiness=ready for all-true":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("readiness=ready")

    it "contains model name in summary when served_model is set":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("model=llama3")

    it "starts with svllm:":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("svllm:")

describe "svllm_status_consumer_module":
    it "returns the IDE dashboard module path":
        expect(svllm_status_consumer_module()).to_equal("app.ide.agent_dashboard")

describe "svllm_status_is_servable":
    it "returns false for default (offline) status":
        expect(svllm_status_is_servable(svllm_status_default())).to_equal(false)

    it "returns true for all-true status":
        val s = svllm_status_from(true, true, true, true, true, "model")
        expect(svllm_status_is_servable(s)).to_equal(true)

    it "returns false when readiness is degraded":
        val s = svllm_status_from(true, true, true, false, true, "model")
        expect(svllm_status_is_servable(s)).to_equal(false)

describe "svllm_status_from served_model boundary":
    it "empty served_model is preserved in status":
        val s = svllm_status_from(true, true, true, true, true, "")
        expect(s.served_model).to_equal("")

    it "all-true with empty model is still ready":
        val s = svllm_status_from(true, true, true, true, true, "")
        expect(s.readiness).to_equal("ready")

    it "non-empty served_model is preserved in offline status":
        val s = svllm_status_from(false, false, false, false, false, "stale-model")
        expect(s.served_model).to_equal("stale-model")
        expect(s.readiness).to_equal("offline")

describe "svllm_status_from counts are zero (no pack)":
    it "tensor_count is 0 for default":
        val s = svllm_status_default()
        expect(s.tensor_count).to_equal(0)

    it "chunk_count is 0 for default":
        val s = svllm_status_default()
        expect(s.chunk_count).to_equal(0)

    it "tensor_count is 0 for all-true svllm_status_from":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(s.tensor_count).to_equal(0)

    it "chunk_count is 0 for all-true svllm_status_from":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(s.chunk_count).to_equal(0)

describe "svllm_status_from_pack empty pack":
    it "pack_available is false for empty pack":
        val empty = TensorPack.empty("")
        val s = svllm_status_from_pack(empty, false, false, false, false, "")
        expect(s.pack_available).to_equal(false)

    it "tensor_count is 0 for empty pack":
        val empty = TensorPack.empty("")
        val s = svllm_status_from_pack(empty, false, false, false, false, "")
        expect(s.tensor_count).to_equal(0)

    it "chunk_count is 0 for empty pack":
        val empty = TensorPack.empty("")
        val s = svllm_status_from_pack(empty, false, false, false, false, "")
        expect(s.chunk_count).to_equal(0)

    it "readiness is offline when empty pack and all flags false":
        val empty = TensorPack.empty("")
        val s = svllm_status_from_pack(empty, false, false, false, false, "")
        expect(s.readiness).to_equal("offline")

describe "svllm_status_from_pack with plan_chunks pack":
    it "chunk_count matches pack.chunks.len()":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "embed", shape: [128, 64], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 32768))
        tensors.push(TensorInfo(name: "proj", shape: [64, 32], dtype: Dtype.F16, chunk_id: 0, offset_in_chunk: 0, byte_len: 4096))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "test-model")
        expect(s.chunk_count).to_equal(pack.chunks.len())

    it "tensor_count matches pack.tensors.len()":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "embed", shape: [128, 64], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 32768))
        tensors.push(TensorInfo(name: "proj", shape: [64, 32], dtype: Dtype.F16, chunk_id: 0, offset_in_chunk: 0, byte_len: 4096))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "test-model")
        expect(s.tensor_count).to_equal(pack.tensors.len())

    it "tensor_count is 2 for 2-tensor pack":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "embed", shape: [128, 64], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 32768))
        tensors.push(TensorInfo(name: "proj", shape: [64, 32], dtype: Dtype.F16, chunk_id: 0, offset_in_chunk: 0, byte_len: 4096))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "test-model")
        expect(s.tensor_count).to_equal(2)

    it "chunk_count is at least 1 for non-empty tensor list":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "w", shape: [4], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 16))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "")
        expect(s.chunk_count).to_equal(1)

    it "pack_available is true for non-empty tensor list":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "w", shape: [4], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 16))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "")
        expect(s.pack_available).to_equal(true)

describe "svllm_status_from_pack readiness orthogonality":
    it "pack-available-only status is degraded not ready":
        # counts do NOT affect readiness: having a pack with tensors but all
        # other flags false yields degraded, not ready.
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "w", shape: [4], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 16))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "")
        expect(s.pack_available).to_equal(true)
        expect(s.readiness).to_equal("degraded")

    it "pack-available-only status is not servable":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "w", shape: [4], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 16))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "")
        expect(svllm_status_is_servable(s)).to_equal(false)

    it "all flags true + pack with tensors is ready":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "w", shape: [4], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 16))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, true, true, true, true, "model")
        expect(s.readiness).to_equal("ready")

describe "svllm_status_summary chunks and tensors tokens":
    it "summary contains chunks= token":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("chunks=")

    it "summary contains tensors= token":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("tensors=")

    it "summary has chunks=0 for default status":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("chunks=0")

    it "summary has tensors=0 for default status":
        val s = svllm_status_default()
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("tensors=0")

    it "summary chunk and tensor counts match pack after from_pack":
        var tensors: [TensorInfo] = []
        tensors.push(TensorInfo(name: "a", shape: [8], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 32))
        tensors.push(TensorInfo(name: "b", shape: [8], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 32))
        val pack = plan_chunks(tensors, 4096, 4194304)
        val s = svllm_status_from_pack(pack, false, false, false, false, "")
        val sum = svllm_status_summary(s)
        expect(sum).to_contain("chunks=1")
        expect(sum).to_contain("tensors=2")
