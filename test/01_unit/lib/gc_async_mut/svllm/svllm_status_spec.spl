# Unit tests for svllm_status — the readiness/metrics surface for the svllm engine.
#
# Coverage:
#   - Default state (all false) → offline, 5 reasons, not servable
#   - All-true state → ready, 0 reasons, servable
#   - Each single-flag-false case → degraded, exactly 1 reason
#   - kv_cache_ready-only-true case (validates the degraded-OR fix)
#   - reasons content correctness per flag
#   - summary string stable substrings
#   - consumer_module constant
#   - served_model propagation (empty vs set)
#
# NOTE: reasons array indexing beyond [0] is known-buggy in interpreter mode
# (array.get(n>=1) corruption). All multi-reason checks use .len() only.

use std.gc_async_mut.svllm.svllm_status.{
    SvllmStatus,
    svllm_status_default,
    svllm_status_from,
    svllm_status_readiness,
    svllm_status_reasons,
    svllm_status_summary,
    svllm_status_consumer_module,
    svllm_status_is_servable
}
use std.spec.{describe, it, expect}

describe "svllm_status_default":
    it "is offline when nothing is wired":
        val s = svllm_status_default()
        expect(s.readiness).to_equal("offline")

    it "has engine_id svllm":
        val s = svllm_status_default()
        expect(s.engine_id).to_equal("svllm")

    it "has phase A1":
        val s = svllm_status_default()
        expect(s.phase).to_equal("A1")

    it "has empty served_model":
        val s = svllm_status_default()
        expect(s.served_model).to_equal("")

    it "is not servable":
        val s = svllm_status_default()
        expect(svllm_status_is_servable(s)).to_equal(false)

    it "has exactly 5 reasons":
        val s = svllm_status_default()
        expect(s.reasons.len()).to_equal(5)

    it "has all component flags false":
        val s = svllm_status_default()
        expect(s.pack_available).to_equal(false)
        expect(s.loader_ready).to_equal(false)
        expect(s.nvfs_ready).to_equal(false)
        expect(s.kv_cache_ready).to_equal(false)
        expect(s.model_loaded).to_equal(false)

describe "svllm_status_from all-true":
    it "is ready when all five flags true":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(s.readiness).to_equal("ready")

    it "is servable when all five flags true":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(svllm_status_is_servable(s)).to_equal(true)

    it "has zero reasons when fully ready":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(s.reasons.len()).to_equal(0)

    it "preserves served_model when set":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(s.served_model).to_equal("llama3")

    it "sets consumer_module to dashboard":
        val s = svllm_status_from(true, true, true, true, true, "llama3")
        expect(s.consumer_module).to_equal("app.ide.agent_dashboard")

describe "svllm_status_from single-flag-false — pack_available":
    it "is degraded when only pack_available is false":
        val s = svllm_status_from(false, true, true, true, true, "llama3")
        expect(s.readiness).to_equal("degraded")

    it "is not servable":
        val s = svllm_status_from(false, true, true, true, true, "llama3")
        expect(svllm_status_is_servable(s)).to_equal(false)

    it "has exactly 1 reason":
        val s = svllm_status_from(false, true, true, true, true, "llama3")
        expect(s.reasons.len()).to_equal(1)

