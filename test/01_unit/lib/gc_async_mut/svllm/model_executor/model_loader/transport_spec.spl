# @gc
#
# Spec for the MemNvfsClient transport adapter and load_model_from_pack_via.
# Exercises the in-memory image builder, object type guards, has/read paths,
# and the full end-to-end load with error-path coverage.
#
# Assertion style: ALL checks are top-level boolean comparisons via
# expect(bool_expr).to_equal(true/false). In compiled/native mode, non-bool
# .to_equal (e.g. i64.to_equal, text.to_equal) silently no-ops inside match
# arms; bool-receiver .to_equal on a top-level statement is the only form
# proven mutation-sensitive (see transport_spec.spl header comment).

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorInfo, ChunkInfo, TensorPack, plan_chunks}
use std.gc_async_mut.svllm.model_executor.model_loader.weight_utils.{Dtype}
use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{serialize_manifest}
use std.gc_async_mut.svllm.model_executor.model_loader.streamer.{plan_stream}
use std.gc_async_mut.svllm.model_executor.model_loader.transport.{mem_nvfs_image, load_model_from_pack_via, MemNvfsClient, MemObj, MemNvfsError}
use std.gc_async_mut.svllm.model_executor.model_loader.loader.{LoadResult, LoaderError}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Build a small two-tensor pack with align=1 so offsets are contiguous.
fn _make_test_pack() -> TensorPack:
    var tensors: [TensorInfo] = []
    tensors.push(TensorInfo(name: "weight.0", shape: [4], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 16))
    tensors.push(TensorInfo(name: "weight.1", shape: [8], dtype: Dtype.F32, chunk_id: 0, offset_in_chunk: 0, byte_len: 32))
    plan_chunks(tensors, 1, 1048576)

fn _make_manifest_text(pack: TensorPack) -> text:
    serialize_manifest(pack)

# Build a byte buffer of `n` bytes all set to fill_byte.
fn _fill_bytes(n: i64, fill_byte: u8) -> [u8]:
    var buf: [u8] = []
    var i: i64 = 0
    while i < n:
        buf.push(fill_byte)
        i = i + 1
    buf

# Build chunk byte buffers from a pack (one buffer per chunk, sized to byte_len).
fn _make_chunk_buffers(pack: TensorPack) -> [[u8]]:
    var bufs: [[u8]] = []
    var i = 0
    while i < pack.chunks.len():
        bufs.push(_fill_bytes(pack.chunks[i].byte_len, 0xAB as u8))
        i = i + 1
    bufs

# Collect chunk relative_paths from a pack into a [text].
fn _chunk_paths(pack: TensorPack) -> [text]:
    var paths: [text] = []
    var i = 0
    while i < pack.chunks.len():
        paths.push(pack.chunks[i].relative_path)
        i = i + 1
    paths

# Sum all chunk byte_lens in a pack.
fn _sum_chunk_byte_lens(pack: TensorPack) -> i64:
    var total: i64 = 0
    var i = 0
    while i < pack.chunks.len():
        total = total + pack.chunks[i].byte_len
        i = i + 1
    total

# Discriminate LoaderError variants as i64 for top-level bool assertions.
# 0=PackRootNotFound, 1=ManifestInvalid, 2=ChunkOpenFailed,
# 3=ChunkDataInvalid, 4=NvfsUnavailable, -1=Ok (not an error).
fn _loader_err_code(r: Result<LoadResult, LoaderError>) -> i64:
    match r:
        Ok(_) => -1
        Err(e) =>
            match e:
                LoaderError.PackRootNotFound => 0
                LoaderError.ManifestInvalid => 1
                LoaderError.ChunkOpenFailed => 2
                LoaderError.ChunkDataInvalid => 3
                LoaderError.NvfsUnavailable => 4

# Discriminate MemNvfsError for text reads. 0=Ok, 1=NotFound.
fn _mem_text_err_code(r: Result<text, MemNvfsError>) -> i64:
    match r:
        Ok(_) => 0
        Err(e) =>
            match e:
                MemNvfsError.NotFound => 1

# Discriminate MemNvfsError for bytes reads. 0=Ok, 1=NotFound.
fn _mem_bytes_err_code(r: Result<[u8], MemNvfsError>) -> i64:
    match r:
        Ok(_) => 0
        Err(e) =>
            match e:
                MemNvfsError.NotFound => 1

# ---------------------------------------------------------------------------
# Spec
# ---------------------------------------------------------------------------

describe "MemNvfsClient":
    describe "mem_nvfs_image + has":
        it "has() is true for the manifest path":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            expect(client.has("/root/manifest.sdn")).to_equal(true)

        it "has() is true for each chunk path":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            var j = 0
            while j < pack.chunks.len():
                expect(client.has("/root/" + pack.chunks[j].relative_path)).to_equal(true)
                j = j + 1

        it "has() is false for an absent path":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            expect(client.has("/root/nonexistent.bin")).to_equal(false)

    describe "read_text":
        it "returns Ok for the manifest path":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val r = client.read_text("/root/manifest.sdn")
            expect(_mem_text_err_code(r) == 0).to_equal(true)

        it "returned manifest text equals the stored text":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val r = client.read_text("/root/manifest.sdn")
            val got = r.unwrap()
            expect((got == mtext)).to_equal(true)

        it "returns NotFound for an absent path":
            val client = mem_nvfs_image("/root", "manifest", [], [])
            val r = client.read_text("/root/missing.sdn")
            expect((_mem_text_err_code(r) == 1)).to_equal(true)

        it "returns NotFound when reading a byte object as text (is_text guard)":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            # A chunk object has is_text=false; reading it via read_text must fail
            val chunk_path = "/root/" + pack.chunks[0].relative_path
            val r = client.read_text(chunk_path)
            expect((_mem_text_err_code(r) == 1)).to_equal(true)

    describe "read_bytes":
        it "returns Ok for a chunk path":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val r = client.read_bytes("/root/" + pack.chunks[0].relative_path)
            expect((_mem_bytes_err_code(r) == 0)).to_equal(true)

        it "returned buffer length equals chunk byte_len":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val r = client.read_bytes("/root/" + pack.chunks[0].relative_path)
            val buf = r.unwrap()
            expect((buf.len() == pack.chunks[0].byte_len)).to_equal(true)

        it "returns NotFound for an absent path":
            val client = mem_nvfs_image("/root", "manifest", [], [])
            val r = client.read_bytes("/root/data-000.bin")
            expect((_mem_bytes_err_code(r) == 1)).to_equal(true)

        it "returns NotFound when reading the manifest path as bytes (is_text guard)":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            # The manifest object has is_text=true; reading it via read_bytes must fail
            val r = client.read_bytes("/root/manifest.sdn")
            expect((_mem_bytes_err_code(r) == 1)).to_equal(true)

    describe "type-aware lookup (P3a collision fix)":
        # Construct a client where two objects share the SAME path but differ
        # in type: [text@"/root/dup", bytes@"/root/dup"].
        # Old _find returned index 0 (text) for ANY lookup at that path, so
        # read_bytes would see is_text==true and return NotFound (the bug).
        # New _find_bytes skips non-byte objects and finds index 1.
        it "read_bytes finds byte object even when text object is stored first at same path":
            var objs: [MemObj] = []
            objs.push(MemObj(path: "/root/dup", is_text: true,  text_val: "hello", bytes_val: []))
            objs.push(MemObj(path: "/root/dup", is_text: false, text_val: "",      bytes_val: [0xAB as u8, 0xCD as u8]))
            val client = MemNvfsClient(objs: objs)
            val r = client.read_bytes("/root/dup")
            # Must be Ok (err_code 0), not NotFound (err_code 1)
            expect((_mem_bytes_err_code(r) == 0)).to_equal(true)
            # Byte content must match what was stored
            val buf = r.unwrap()
            expect((buf.len() == 2)).to_equal(true)

        # Reverse ordering: [bytes@p2, text@p2].
        # Old _find returned index 0 (bytes) for any lookup at p2, so
        # read_text would see is_text==false and return NotFound (the bug).
        # New _find_text skips non-text objects and finds index 1.
        it "read_text finds text object even when byte object is stored first at same path":
            var objs2: [MemObj] = []
            objs2.push(MemObj(path: "/root/p2", is_text: false, text_val: "",      bytes_val: [0x01 as u8]))
            objs2.push(MemObj(path: "/root/p2", is_text: true,  text_val: "world", bytes_val: []))
            val client2 = MemNvfsClient(objs: objs2)
            val r2 = client2.read_text("/root/p2")
            # Must be Ok (err_code 0), not NotFound (err_code 1)
            expect((_mem_text_err_code(r2) == 0)).to_equal(true)
            val got = r2.unwrap()
            expect((got == "world")).to_equal(true)

        # has() remains type-agnostic
        it "has() returns true for a path that has only a text object":
            var objs3: [MemObj] = []
            objs3.push(MemObj(path: "/root/only_text", is_text: true, text_val: "x", bytes_val: []))
            val client3 = MemNvfsClient(objs: objs3)
            expect(client3.has("/root/only_text")).to_equal(true)

        it "has() returns true for a path that has only a byte object":
            var objs4: [MemObj] = []
            objs4.push(MemObj(path: "/root/only_bytes", is_text: false, text_val: "", bytes_val: [0x01 as u8]))
            val client4 = MemNvfsClient(objs: objs4)
            expect(client4.has("/root/only_bytes")).to_equal(true)

describe "load_model_from_pack_via":
    describe "happy path":
        it "result is Ok":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val result = load_model_from_pack_via(client, "/root", 0)
            expect(result.is_ok()).to_equal(true)

        it "staged_tensor_count equals pack.tensors.len()":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val result = load_model_from_pack_via(client, "/root", 0)
            val lr = result.unwrap()
            expect((lr.staged_tensor_count == pack.tensors.len())).to_equal(true)

        it "bytes_streamed equals sum of chunk byte_lens":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val result = load_model_from_pack_via(client, "/root", 0)
            val lr = result.unwrap()
            val expected_bytes = _sum_chunk_byte_lens(pack)
            expect((lr.bytes_streamed == expected_bytes)).to_equal(true)

        it "op_count equals plan_stream(pack, granule).op_count":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val granule: i64 = 0
            val result = load_model_from_pack_via(client, "/root", granule)
            val lr = result.unwrap()
            val expected_ops = plan_stream(pack, granule).op_count
            expect((lr.op_count == expected_ops)).to_equal(true)

        it "lr.pack.tensors.len() equals pack.tensors.len()":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            val result = load_model_from_pack_via(client, "/root", 0)
            val lr = result.unwrap()
            expect((lr.pack.tensors.len() == pack.tensors.len())).to_equal(true)

    describe "error paths":
        it "wrong pack_root -> PackRootNotFound (err_code 0)":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), _make_chunk_buffers(pack))
            # Use a different root so the manifest object is not found
            val result = load_model_from_pack_via(client, "/wrong_root", 0)
            expect(result.is_err()).to_equal(true)
            expect((_loader_err_code(result) == 0)).to_equal(true)

        it "valid manifest but no chunk objects -> ChunkOpenFailed (err_code 2)":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            # Store only the manifest text; no chunk byte objects
            val client = mem_nvfs_image("/root", mtext, [], [])
            val result = load_model_from_pack_via(client, "/root", 0)
            expect(result.is_err()).to_equal(true)
            expect((_loader_err_code(result) == 2)).to_equal(true)

        it "garbage manifest_text -> ManifestInvalid (err_code 1)":
            val client = mem_nvfs_image("/root", "this is not valid manifest content", [], [])
            val result = load_model_from_pack_via(client, "/root", 0)
            expect(result.is_err()).to_equal(true)
            expect((_loader_err_code(result) == 1)).to_equal(true)

        # P2a: stored-but-empty-chunk path.
        # chunk_paths is non-empty (chunk OBJECT EXISTS in the client) but
        # chunk_bytes is empty ([]), so the chunk object is stored with an empty
        # bytes_val ([]). read_bytes returns Ok([]) — the object IS present —
        # then stream_pack detects the zero-length buffer via ChunkTooShort and
        # propagates LoaderError.ChunkOpenFailed.
        # This is DISTINCT from the "no chunk objects" test above where the chunk
        # object is ABSENT -> read_bytes Err(NotFound) -> ChunkOpenFailed directly.
        it "chunk object exists but has empty buffer -> ChunkOpenFailed (err_code 2)":
            val pack = _make_test_pack()
            val mtext = _make_manifest_text(pack)
            # Pass chunk_paths so the chunk object IS created, but chunk_bytes=[]
            # so its buffer is stored as empty ([]).
            val client = mem_nvfs_image("/root", mtext, _chunk_paths(pack), [])
            val result = load_model_from_pack_via(client, "/root", 0)
            expect(result.is_err()).to_equal(true)
            expect((_loader_err_code(result) == 2)).to_equal(true)
