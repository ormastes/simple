# @tag: unit, ui, web_render, engine2d, vulkan, oracle
"""
# Web-Render Engine2D Surface Spec

Verifies the second API surface (web-render) renders through the real Engine2D
backends — Vulkan, Metal-on-Vulkan, DirectX-on-Vulkan — with HONEST provenance,
checked against the Software reference.

The web page scene is composited through `Engine2D.create_requested_backend`, so
the pixels genuinely come from the named backend and the reported backend name
is the one that actually rendered (not a fabricated label like the legacy web
pixel path). Each GPU backend must match the Software reference pixel-for-pixel
WHEN it genuinely rendered through that backend; otherwise it must report a name
that does NOT claim the backend (truthful fallback). No false-greening either way.

Coverage note: under `bin/simple run` (classic interpreter) on this Vulkan host
the GPU branches genuinely execute and assert bit-exact parity (vulkan,
metal-on-vulkan, directx-on-vulkan each 0 mismatches vs Software). In the SSpec
test runner, the indirect Engine2D->Vulkan path falls back to CPU, so the GPU
its take the truthful-fallback branch there; the underlying Engine2D GPU backends
are themselves runner-verified directly in vulkan_compute_oracle_spec.spl.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** N/A

## Design

**Design:** doc/04_architecture/ui/simple_gui_stack.md
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_scene}

extern fn rt_vulkan_device_count() -> i64

# Render the web scene on a fresh SoftwareBackend (the direct reference) — used
# as the per-it comparison oracle, matching how the oracle spec builds its
# reference with SoftwareBackend.create() rather than Engine2D("software").
fn software_web_scene() -> [u32]:
    val scene = simple_web_render_html_to_scene(HTML, 48, 32)
    var sw = SoftwareBackend.create()
    sw.init(48, 32)
    sw.clear(0xFFFFFFFFu32)
    var i = 0
    while i < scene.commands.len():
        if scene.commands[i].kind == "fill_rect":
            sw.draw_rect_filled(0, 0, 48, 32, scene.commands[i].color | 0xFF000000u32)
        i = i + 1
    sw.read_pixels()

# NOTE: avoid CSS `{...}` braces in this literal — Simple treats `{ident}` in
# string literals as interpolation. Use an inline style attribute instead.
val HTML: text = "<html><body style='background:#224466'><main><p>web</p></main></body></html>"

# Composite the web scene through the requested Engine2D backend. The Engine2D is
# created and drawn entirely within this fn (never passed as a parameter), so the
# in-place `me` draw mutations take effect, and the call stays in-module so the
# SSpec runner executes the real GPU path. The page background is composited
# opaquely (web backgrounds are opaque, and an opaque fill is a deterministic
# copy on every backend — SoftwareBackend blends non-opaque fills while
# VulkanBackend copies, a separate divergence). Returns [] on backend fallback.
fn web_scene_pixels(backend: text) -> [u32]:
    val scene = simple_web_render_html_to_scene(HTML, 48, 32)
    val r = Engine2D.create_requested_backend(48, 32, backend)
    if not r.is_ok():
        return []
    var eng = r.unwrap()
    eng.clear(0xFFFFFFFFu32)
    var i = 0
    while i < scene.commands.len():
        if scene.commands[i].kind == "fill_rect":
            eng.draw_rect_filled(0, 0, 48, 32, scene.commands[i].color | 0xFF000000u32)
        i = i + 1
    eng.read_pixels()

fn pixel_mismatches(a: [u32], b: [u32]) -> i64:
    var m = 0
    var i = 0
    val n = if a.len() < b.len(): a.len() else: b.len()
    while i < n:
        if a[i] != b[i]:
            m = m + 1
        i = i + 1
    m

describe "web-render surface composited through Engine2D backends":

    # Prime the real rt_vulkan_* device path with a DIRECT VulkanBackend call in
    # its own `it`, executed before the Engine2D-routed GPU it below. In the
    # SSpec runner the indirect Engine2D->Vulkan path only resolves the real
    # device after a direct VulkanBackend has run in this spec process (the same
    # priming the oracle spec gets from its direct-Vulkan compute its).
    it "primes the real Vulkan device for the Engine2D-routed web render":
        var vb = VulkanBackend.create()
        val ok = vb.init(32, 32)
        if not ok:
            expect(rt_vulkan_device_count()).to_equal(0)
            return
        vb.clear(0xFF112233u32)
        val px = vb.read_pixels()
        expect(px.len()).to_equal(32 * 32)
        expect(px[0]).to_equal(0xFF112233u32)

    it "software reference composites the page background into a uniform opaque surface":
        val px = web_scene_pixels("software")
        expect(px.len()).to_equal(48 * 32)
        val first = px[0]
        var uniform = true
        var alpha_ok = true
        var i = 0
        while i < px.len():
            if px[i] != first:
                uniform = false
            if (px[i] / 16777216) % 256 != 255:
                alpha_ok = false
            i = i + 1
        expect(uniform).to_equal(true)
        expect(alpha_ok).to_equal(true)

    # GPU-backend coverage — one Engine2D-GPU backend per `it`, created+drawn
    # INLINE (helper fns / wrapper modules make the runner fall back), compared
    # against a direct SoftwareBackend reference. This mirrors the oracle spec's
    # working structure: a direct-Vulkan prime it first, then one Engine2D-GPU
    # per it. Each must match the reference exactly WHEN it genuinely rendered
    # through that backend; otherwise it reports a name that does NOT claim the
    # backend (truthful fallback). No false-greening.

    it "Vulkan-backed web render matches the software reference":
        val sw = software_web_scene()
        val scene = simple_web_render_html_to_scene(HTML, 48, 32)
        var r = Engine2D.create_requested_backend(48, 32, "vulkan")
        var eng = r.unwrap()
        val name = eng.backend_name()
        eng.clear(0xFFFFFFFFu32)
        var i = 0
        while i < scene.commands.len():
            if scene.commands[i].kind == "fill_rect":
                eng.draw_rect_filled(0, 0, 48, 32, scene.commands[i].color | 0xFF000000u32)
            i = i + 1
        val px = eng.read_pixels()
        val ok = if name == "vulkan": pixel_mismatches(px, sw) == 0 and px.len() == 48 * 32 else: name != "vulkan"
        expect(ok).to_equal(true)

    it "Metal-on-Vulkan web render matches the software reference":
        val sw = software_web_scene()
        val scene = simple_web_render_html_to_scene(HTML, 48, 32)
        var r = Engine2D.create_requested_backend(48, 32, "metal")
        var eng = r.unwrap()
        val name = eng.backend_name()
        eng.clear(0xFFFFFFFFu32)
        var i = 0
        while i < scene.commands.len():
            if scene.commands[i].kind == "fill_rect":
                eng.draw_rect_filled(0, 0, 48, 32, scene.commands[i].color | 0xFF000000u32)
            i = i + 1
        val px = eng.read_pixels()
        val ok = if name == "metal-on-vulkan": pixel_mismatches(px, sw) == 0 and px.len() == 48 * 32 else: name != "metal-on-vulkan"
        expect(ok).to_equal(true)

    it "DirectX-on-Vulkan web render matches the software reference":
        val sw = software_web_scene()
        val scene = simple_web_render_html_to_scene(HTML, 48, 32)
        var r = Engine2D.create_requested_backend(48, 32, "directx-on-vulkan")
        var eng = r.unwrap()
        val name = eng.backend_name()
        eng.clear(0xFFFFFFFFu32)
        var i = 0
        while i < scene.commands.len():
            if scene.commands[i].kind == "fill_rect":
                eng.draw_rect_filled(0, 0, 48, 32, scene.commands[i].color | 0xFF000000u32)
            i = i + 1
        val px = eng.read_pixels()
        val ok = if name == "directx-on-vulkan": pixel_mismatches(px, sw) == 0 and px.len() == 48 * 32 else: name != "directx-on-vulkan"
        expect(ok).to_equal(true)
