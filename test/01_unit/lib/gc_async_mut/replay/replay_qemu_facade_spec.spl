use std.spec
use std.gc_async_mut.replay.qemu_replay.{qemu_binary_for_arch, machine_for_arch, supported_architectures}

describe "gc_async_mut replay QEMU facade":

    it "re-exports multi-architecture QEMU helpers":
        val archs = supported_architectures()

        expect(qemu_binary_for_arch("riscv32")).to_equal("qemu-system-riscv32")
        expect(machine_for_arch("x86_64")).to_equal("q35")
        expect(archs).to_contain("aarch64")
