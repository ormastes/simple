# Regression spec for process_run_tuple_ambiguity_2026-07-17.
#
# The Rust checker used to reject process_run's valid repeated-field return
# type `(text, text, i64)`. A labeled workaround then failed in the
# pure-Simple parser. The checker now accepts the established positional ABI;
# this spec pins indexed access, destructuring, and real subprocess results.
# See doc/08_tracking/bug/mcp_main_lazy_json_standalone_compile_process_run_tuple_ambiguity_2026-07-17.md

use std.io_runtime.{process_run}

describe "std.io_runtime.process_run positional-tuple result":
    it "reports stdout and exit_code via indexed field access":
        val result = process_run("echo", ["hello_process_run"])
        expect(result.0.contains("hello_process_run")).to_equal(true)
        expect(result.2).to_equal(0)

    it "supports 3-way destructuring assignment":
        val (stdout, stderr, code) = process_run("echo", ["hello_destructure"])
        expect(stdout.contains("hello_destructure")).to_equal(true)
        expect(code).to_equal(0)

    it "reports a nonzero exit_code for a failing command via indexed access":
        val result = process_run("sh", ["-c", "exit 7"])
        expect(result.2).to_equal(7)
