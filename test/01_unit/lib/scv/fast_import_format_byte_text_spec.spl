use std.spec
use std.scv.fast_import_format.{scv_fast_import_bytes_line}

describe "scv fast-import byte text conversion":
    it "decodes command lines without text.from_bytes":
        val stream = [99u8, 111u8, 109u8, 109u8, 105u8, 116u8, 32u8, 114u8, 101u8, 102u8, 115u8, 47u8, 104u8, 101u8, 97u8, 100u8, 115u8, 47u8, 109u8, 97u8, 105u8, 110u8, 13u8, 9u8, 255u8, 10u8]
        val (line, end) = scv_fast_import_bytes_line(stream, 0)
        expect(line).to_equal("commit refs/heads/main\r\t?")
        expect(end).to_equal(25)
