"""Engine2D-adjacent Hit-Testing / Topmost-Object-Wins Pick Specification

@tag: gpu, engine2d, hit-test, pick, click-routing

Audit tranche (E2D-AUDIT, 2026-07-20): Engine2D has NO hit-testing, point
picking, or click-routing API. Confirmed by grep across
src/lib/gc_async_mut/gpu/engine2d/*.spl (no `hit_test`/`pick`/`point_in`/
`click` function) and the WM services tree
(src/os/services/wm/{wm_service,wm_world,wm_action}.spl — window bookkeeping
by id/port/process only, no spatial mouse routing). The only `hit_test`
functions in the repo are unrelated: browser-engine DOM layout
(src/lib/gc_async_mut/gpu/browser_engine/layout.spl) and the scene editor
gizmo (src/lib/nogc_sync_mut/editor/gizmo.spl) — neither is reachable from
Engine2D's compositor/backend layer.

This spec therefore builds and tests the minimal "topmost object wins" pick
algorithm a real Engine2D hit-test API would need, directly on `Rect2`
(src/lib/common/engine/rect.spl) — the same primitive the overlap-detection
tranche (rect2_overlap_detection_spec.spl) locks down. `pick_topmost` below
is test-local (not part of any shipped API) and exists to prove the
primitives are sufficient; it is NOT a substitute for the missing
production API. See the gap list in this audit's report for the concrete
recommendation (add a `HitTestable`/`pick_topmost` seam to Engine2D or a new
`hit_test.spl` module, and wire mouse events through it from the WM side).
"""

use std.spec.{describe, context, it, expect}
use std.common.engine.rect.{Rect2}

fn pick_topmost(rects: [Rect2], z_orders: [i32], px: f64, py: f64) -> i32:
    """Return the index of the highest-z_order rect containing (px, py), or
    -1 if no rect contains the point. Ties are broken by first-seen index
    (stable), matching "topmost wins" semantics for a z-ordered object list."""
    var best_index = -1
    var best_z = 0
    var i = 0
    val n = rects.len()
    while i < n:
        if rects[i].contains_point(px, py):
            if best_index == -1 or z_orders[i] > best_z:
                best_index = i
                best_z = z_orders[i]
        i = i + 1
    best_index

describe "Hit-test: topmost object wins under overlapping rects":
    it "click inside a single, non-overlapping object hits that object":
        val rects: [Rect2] = [Rect2(x: 0.0, y: 0.0, width: 10.0, height: 10.0)]
        val zs: [i32] = [0]
        expect(pick_topmost(rects, zs, 5.0, 5.0)).to_equal(0)

    it "click outside every object hits nothing":
        val rects: [Rect2] = [Rect2(x: 0.0, y: 0.0, width: 10.0, height: 10.0)]
        val zs: [i32] = [0]
        expect(pick_topmost(rects, zs, 50.0, 50.0)).to_equal(-1)

    it "click in the overlap of two objects picks the higher z_order object":
        val rects: [Rect2] = [
            Rect2(x: 0.0, y: 0.0, width: 10.0, height: 10.0),
            Rect2(x: 5.0, y: 5.0, width: 10.0, height: 10.0)
        ]
        val zs: [i32] = [0, 1]
        expect(pick_topmost(rects, zs, 7.0, 7.0)).to_equal(1)

    it "click in the overlap picks the higher z_order object regardless of array order":
        val rects: [Rect2] = [
            Rect2(x: 5.0, y: 5.0, width: 10.0, height: 10.0),
            Rect2(x: 0.0, y: 0.0, width: 10.0, height: 10.0)
        ]
        # Index 0 has the LOWER z_order this time (array order != z order).
        val zs: [i32] = [1, 5]
        expect(pick_topmost(rects, zs, 7.0, 7.0)).to_equal(1)

    it "click in a region covered by only the lower object picks the lower object":
        val rects: [Rect2] = [
            Rect2(x: 0.0, y: 0.0, width: 10.0, height: 10.0),
            Rect2(x: 5.0, y: 5.0, width: 10.0, height: 10.0)
        ]
        val zs: [i32] = [0, 1]
        expect(pick_topmost(rects, zs, 1.0, 1.0)).to_equal(0)

    it "three overlapping objects: topmost among ALL that contain the point wins, not just the last two":
        val rects: [Rect2] = [
            Rect2(x: 0.0, y: 0.0, width: 20.0, height: 20.0),
            Rect2(x: 2.0, y: 2.0, width: 16.0, height: 16.0),
            Rect2(x: 4.0, y: 4.0, width: 12.0, height: 12.0)
        ]
        # Middle object (index 1) has the highest z_order.
        val zs: [i32] = [1, 9, 5]
        expect(pick_topmost(rects, zs, 8.0, 8.0)).to_equal(1)

    it "click exactly on a shared right/bottom edge respects Rect2's exclusive-edge convention":
        val rects: [Rect2] = [
            Rect2(x: 0.0, y: 0.0, width: 10.0, height: 10.0),
            Rect2(x: 10.0, y: 0.0, width: 10.0, height: 10.0)
        ]
        val zs: [i32] = [0, 1]
        # x=10.0 is outside rect 0 (right() is exclusive) and on rect 1's
        # left edge (inclusive) -> only rect 1 contains this point.
        expect(pick_topmost(rects, zs, 10.0, 5.0)).to_equal(1)
