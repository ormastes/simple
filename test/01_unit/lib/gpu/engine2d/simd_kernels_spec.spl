"""SIMD Kernels Specification

@tag: gpu, engine2d, simd, cpu, acceleration
@cover src/lib/gc_async_mut/gpu/engine2d/simd_kernels.spl 80%

Verifies SIMD-accelerated pixel operations with runtime CPU feature
detection. Covers AC-6: CPU acceleration via SSE4.2/AVX2/NEON.
"""

use std.spec.{describe, context, it, expect}
use std.io_runtime.{file_read}
use std.gpu.engine2d.simd_kernels.{SimdLevel, detect_simd_level, cpu_simd_runtime_evidence, simd_fill_row, engine2d_simd_fill_buffer_u32, engine2d_simd_fill_rows_u32, simd_blend_row, simd_blit_row, _scalar_blend_row}

# ============================================================================
# SimdLevel detection
# ============================================================================

describe "SimdLevel":
    it "AC-6: has None variant for scalar fallback":
        val level = SimdLevel.None_
        expect(level.to_text()).to_equal("None")

    it "AC-6: has Sse42 variant":
        val level = SimdLevel.Sse42
        expect(level.to_text()).to_equal("SSE4.2")

    it "AC-6: has Avx2 variant":
        val level = SimdLevel.Avx2
        expect(level.to_text()).to_equal("AVX2")

    it "AC-6: has Avx512 variant":
        val level = SimdLevel.Avx512
        expect(level.to_text()).to_equal("AVX-512")

    it "AC-6: has Neon variant":
        val level = SimdLevel.Neon
        expect(level.to_text()).to_equal("NEON")

# ============================================================================
# CPU feature detection
# ============================================================================

describe "detect_simd_level":
    it "AC-6: returns a valid SimdLevel on any platform":
        val level = detect_simd_level()
        val name = level.to_text()
        val valid = name == "None" or name == "SSE4.2" or name == "AVX2" or name == "AVX-512" or name == "NEON"
        expect(valid).to_equal(true)

    it "AC-6: detection is consistent across calls":
        val level1 = detect_simd_level()
        val level2 = detect_simd_level()
        expect(level1.to_text()).to_equal(level2.to_text())

    it "AC-6: records runtime execution evidence for fill copy alpha and scroll":
        val evidence = cpu_simd_runtime_evidence()
        expect(evidence.executed_fill).to_equal(true)
        expect(evidence.executed_copy).to_equal(true)
        expect(evidence.executed_alpha).to_equal(true)
        expect(evidence.executed_scroll).to_equal(true)
        expect(evidence.executed_all()).to_equal(true)
        expect(evidence.checksum).to_be_greater_than(0)
        expect(evidence.diagnostic_text()).to_contain("arch=")
        expect(evidence.diagnostic_text()).to_contain("feature=")
        expect(evidence.diagnostic_text()).to_contain("executed=true")

# ============================================================================
# simd_fill_row — vectorized pixel fill
# ============================================================================

describe "simd_fill_row":
    it "allocates and fills a complete owned framebuffer":
        val buf = engine2d_simd_fill_buffer_u32(17, 0xFF102030u32)
        expect(buf.len()).to_equal(17)
        expect(buf[0]).to_equal(0xFF102030u32)
        expect(buf[16]).to_equal(0xFF102030u32)
        expect(engine2d_simd_fill_buffer_u32(0, 0u32).len()).to_equal(0)

    it "fills bounded row chunks without changing packed color":
        val buf = engine2d_simd_fill_rows_u32(13, 37, 0x80102030u32, 8)
        expect(buf.len()).to_equal(481)
        expect(buf[0]).to_equal(0x80102030u32)
        expect(buf[480]).to_equal(0x80102030u32)
        expect(engine2d_simd_fill_rows_u32(0, 37, 0u32, 8).len()).to_equal(0)

    it "AC-6: fills row with solid color":
        var buf: [u32] = [0u32; 16]
        val color: u32 = 0xFFFF0000
        simd_fill_row(buf, 0, 16, color)
        expect(buf[0]).to_equal(0xFFFF0000)
        expect(buf[15]).to_equal(0xFFFF0000)

    it "AC-6: fills partial row with offset":
        var buf: [u32] = [0u32; 16]
        val color: u32 = 0xFF00FF00
        simd_fill_row(buf, 4, 8, color)
        expect(buf[0]).to_equal(0)
        expect(buf[4]).to_equal(0xFF00FF00)
        expect(buf[11]).to_equal(0xFF00FF00)
        expect(buf[12]).to_equal(0)

    it "AC-6: handles zero-length fill":
        var buf: [u32] = [0xFFFFFFFF; 4]
        simd_fill_row(buf, 0, 0, 0)
        expect(buf[0]).to_equal(0xFFFFFFFF)

    it "uses the cross-mode return-array span bridge for backend fills":
        val source = file_read("src/lib/nogc_sync_mut/gpu/engine2d/simd_kernels.spl")
        val backend_source = file_read("src/lib/gc_async_mut/gpu/engine2d/backend_software.spl")
        val engine_source = file_read("src/lib/gc_async_mut/gpu/engine2d/engine.spl")
        val interp_source = file_read("src/compiler_rust/compiler/src/interpreter_extern/simd.rs")
        val interp_dispatch = file_read("src/compiler_rust/compiler/src/interpreter_extern/mod.rs")
        val llvm_source = file_read("src/compiler/70.backend/backend/_MirToLlvm/asm_constraints_helpers.spl")
        val mir_source = file_read("src/compiler/50.mir/_MirLoweringExpr/switch_operators_calls.spl")
        expect(source).to_contain("rt_engine2d_simd_fill_span_u32")
        expect(backend_source).to_contain("self.buf = rt_engine2d_simd_fill_span_u32")
        expect(backend_source).to_contain("self.native_simd_spans and native_pixel_rows_enabled()")
        expect(engine_source).to_contain("var cpu_simd = CpuBackend.create_simd()")
        expect(interp_source).to_contain("pub fn rt_engine2d_simd_fill_span_u32")
        expect(interp_source).to_contain("copy_from_slice(&filled)")
        expect(interp_dispatch).to_contain("insert_simple!(\"rt_engine2d_simd_fill_span_u32\"")
        expect(interp_dispatch.contains("rt_engine2d_simd_fill_u32")).to_equal(false)
        expect(llvm_source).to_contain("declare ptr @rt_engine2d_simd_fill_span_u32(ptr, i64, i64, i64)")
        expect(mir_source).to_contain("name == \"rt_engine2d_simd_fill_span_u32\"")

    it "fills a bounded span without changing adjacent pixels":
        var buf: [u32] = [0 as u32; 8]
        buf = rt_engine2d_simd_fill_span_u32(buf, 2, 4, 0xFF102030u32)
        expect(buf[1]).to_equal(0u32)
        expect(buf[2]).to_equal(0xFF102030u32)
        expect(buf[5]).to_equal(0xFF102030u32)
        expect(buf[6]).to_equal(0u32)
        buf = rt_engine2d_simd_fill_span_u32(buf, 0, -1, 0xFFFFFFFFu32)
        expect(buf[0]).to_equal(0u32)

# ============================================================================
# simd_blend_row — Porter-Duff alpha blending
# ============================================================================

describe "simd_blend_row":
    it "AC-6: blends opaque source over destination":
        var dst: [u32] = [0xFF0000FF; 4]
        var src: [u32] = [0xFFFF0000; 4]
        simd_blend_row(dst, src, 0, 4)
        expect(dst[0]).to_equal(0xFFFF0000)

    it "AC-6: transparent source leaves destination unchanged":
        var dst: [u32] = [0xFF0000FF; 4]
        var src: [u32] = [0x00000000; 4]
        simd_blend_row(dst, src, 0, 4)
        expect(dst[0]).to_equal(0xFF0000FF)

    it "AC-6: 50% alpha blends correctly":
        var dst: [u32] = [0xFF000000; 4]
        var src: [u32] = [0x80FF0000; 4]
        simd_blend_row(dst, src, 0, 4)
        val r = (dst[0] >> 16) & 0xFF
        expect(r).to_be_greater_than(100)
        expect(r).to_be_less_than(200)

    it "translucent source over transparent destination preserves src exactly (straight-alpha over-transparent, doc/08_tracking/bug/engine2d_straight_alpha_transparent_destination_blend_2026-07-11.md)":
        # Exercises _scalar_blend_row directly (the pure-Simple reference path
        # fixed alongside color.blend). NOTE: on hosts where
        # native_pixel_rows_enabled() is true, the public simd_blend_row()
        # entry point instead routes through the native
        # rt_engine2d_simd_blend_row_u32 kernel (runtime_simd_dispatch.c),
        # which still hardcodes an opaque destination and has NOT been fixed
        # here (native runtime rebuild is out of scope for this change — see
        # the KNOWN DIVERGENCE comment in simd_kernels.spl). Calling the
        # scalar path directly keeps this assertion deterministic across
        # hosts instead of silently depending on SIMD detection.
        var dst: [u32] = [0x00000000; 4]
        var src: [u32] = [0x80FF0000; 4]
        _scalar_blend_row(dst, src, 0, 4)
        expect(dst[0]).to_equal(0x80FF0000u32)

# ============================================================================
# simd_blit_row — pixel copy
# ============================================================================

describe "simd_blit_row":
    it "AC-6: copies pixels from source to destination":
        var dst: [u32] = [0u32; 8]
        var src: [u32] = [0xFFAABBCC; 8]
        simd_blit_row(dst, 0, src, 0, 8)
        expect(dst[0]).to_equal(0xFFAABBCC)
        expect(dst[7]).to_equal(0xFFAABBCC)

    it "AC-6: copies with offset":
        var dst: [u32] = [0u32; 8]
        var src: [u32] = [0xFFDDEEFF; 8]
        simd_blit_row(dst, 2, src, 0, 4)
        expect(dst[0]).to_equal(0)
        expect(dst[2]).to_equal(0xFFDDEEFF)
        expect(dst[5]).to_equal(0xFFDDEEFF)
        expect(dst[6]).to_equal(0)

# ============================================================================
# Platform-universal guarantee (AC-6)
# ============================================================================

describe "universal fallback":
    it "AC-6: SIMD ops work even when SimdLevel is None (scalar fallback)":
        var buf: [u32] = [0u32; 4]
        simd_fill_row(buf, 0, 4, 0xFFFF0000)
        expect(buf[0]).to_equal(0xFFFF0000)

    it "AC-6: same results regardless of SIMD level":
        var buf1: [u32] = [0u32; 4]
        var buf2: [u32] = [0u32; 4]
        simd_fill_row(buf1, 0, 4, 0xFF112233)
        simd_fill_row(buf2, 0, 4, 0xFF112233)
        expect(buf1[0]).to_equal(buf2[0])
        expect(buf1[3]).to_equal(buf2[3])
