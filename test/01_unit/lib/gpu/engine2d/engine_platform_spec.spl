# @tag: gpu, engine2d, engine, platform, priority
# @cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 60%

"""
# Engine2D Platform-Aware Backend Selection Specification

## Overview

Verifies Engine2D platform-aware backend creation, priority ordering, compute
dispatch selection, strict backend diagnostics, and CPU fallback behavior for
unknown public render backend requests.

**Source:** `src/lib/gc_async_mut/gpu/engine2d/engine.spl`
**Requirements:** N/A
**Research:** doc/01_research/ui/render_path/gui_web_2d_render_optimization_2026-06-16.md
**Plan:** doc/03_plan/ui/graphics/engine/game_engine_2d3d_unification_plan_2026-06-12.md
**Design:** doc/05_design/ui/renderer_unification_2026-06-15.md

## Syntax

Use `Engine2D.create(...)`, `Engine2D.create_with_priority(...)`, and
`Engine2D.create_compute_dispatch_for_backend(...)` to check render and compute
backend selection without accepting silent GPU fallback.

## Examples

The scenarios verify automatic creation, public fallback semantics, priority
canonicalization, compute dispatch metadata, strict diagnostic probes, and
readback source reporting.
"""

use std.spec.{describe, context, it, expect}
use std.common.test_env_gate.{test_env_require, test_env_gpu_available}
use std.gpu.engine2d.backend_probe.{BackendStatus}
use std.gpu.engine2d.engine.{Engine2D}

fn _valid_compute_backend_name(name: text) -> bool:
    name == "cuda" or name == "rocm" or name == "opencl" or name == "cpu_simd" or name == "cpu_simd_x86" or name == "cpu_simd_arm" or name == "cpu_simd_riscv" or name == "cpu"

# ============================================================================
# Engine2D platform-aware creation
# ============================================================================

describe "Engine2D":
    describe "create (updated)":
        it "creates an engine through auto backend detection":
            var engine = Engine2D.create(4, 4)

            expect(engine.backend_name().len()).to_be_greater_than(0)
            expect(engine.width()).to_equal(4)
            expect(engine.height()).to_equal(4)
            engine.shutdown()

        it "AC-7: uses platform-aware detection":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: accepts optional FfiMode":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "create_with_backend (updated)":
        it "AC-5: supports qualcomm backend name":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-1: vulkan backend still selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-2: cuda backend still selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-3: rocm backend selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-4: intel backend selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "keeps unknown backend fallback on the public creation API":
            var engine = Engine2D.create_with_backend(4, 4, "missing_backend")

            expect(engine.backend_name()).to_equal("cpu")
            expect(engine.width()).to_equal(4)
            expect(engine.height()).to_equal(4)
            engine.shutdown()

    describe "create_with_priority":
        it "canonicalizes cpu SIMD aliases before selecting the backend":
            var engine = Engine2D.create_with_priority(4, 4, ["cpu-simd"])

            expect(engine.backend_name()).to_equal("cpu_simd")
            expect(engine.width()).to_equal(4)
            expect(engine.height()).to_equal(4)
            engine.shutdown()

        it "skips unknown entries before selecting cpu SIMD":
            var engine = Engine2D.create_with_priority(4, 4, ["missing_backend", "cpu_simd"])

            expect(engine.backend_name()).to_equal("cpu_simd")
            expect(engine.width()).to_equal(4)
            expect(engine.height()).to_equal(4)
            engine.shutdown()

        it "falls back to CPU after unknown priority entries":
            var engine = Engine2D.create_with_priority(4, 4, ["missing_backend", "cpu"])

            expect(engine.backend_name()).to_equal("cpu")
            expect(engine.width()).to_equal(4)
            expect(engine.height()).to_equal(4)
            engine.shutdown()

        it "does not claim explicit native framebuffer backends from dimensions":
            var engine = Engine2D.create_with_priority(4, 4, ["baremetal", "virtio_gpu", "cpu"])

            expect(engine.backend_name()).to_equal("cpu")
            expect(engine.width()).to_equal(4)
            expect(engine.height()).to_equal(4)
            engine.shutdown()

    describe "compute dispatch":
        it "exposes best compute backend without replacing render backend selection":
            val result = Engine2D.create_compute_dispatch()

            expect(_valid_compute_backend_name(result.selected_name)).to_equal(true)
            expect(result.probe.has_compute).to_equal(true)
            expect(result.probe.status == BackendStatus.Initialized).to_equal(true)
            expect(Engine2D.detect_best_compute_backend()).to_equal(result.selected_name)

        it "routes explicit compute backends through strict factory diagnostics":
            val cpu = Engine2D.create_compute_dispatch_for_backend("cpu")
            val missing = Engine2D.create_compute_dispatch_for_backend("missing_compute_backend")

            expect(cpu.selected_name).to_equal("cpu")
            expect(cpu.is_available()).to_equal(true)
            expect(missing.is_available()).to_equal(false)
            expect(missing.selected_name).to_equal("missing_compute_backend")
            expect(missing.probe.reason).to_contain("runtime evidence not available")

        it "keeps explicit GPU compute diagnostics on requested backends":
            val cuda = Engine2D.create_compute_dispatch_for_backend("cuda")
            val rocm = Engine2D.create_compute_dispatch_for_backend("rocm")
            val opencl = Engine2D.create_compute_dispatch_for_backend("opencl")

            expect(cuda.selected_name).to_equal("cuda")
            expect(cuda.probe.has_compute).to_equal(true)
            expect(cuda.probe.shader_format).to_equal("ptx")
            expect(rocm.selected_name).to_equal("rocm")
            expect(rocm.probe.has_compute).to_equal(true)
            expect(rocm.probe.shader_format).to_equal("hsaco")
            expect(opencl.selected_name).to_equal("opencl")
            expect(opencl.probe.has_compute).to_equal(true)
            expect(opencl.probe.shader_format).to_equal("opencl-c")

        it "exposes dispatch summary evidence through the Engine2D accessor path":
            val result = Engine2D.create_compute_dispatch()

            expect(result.summary()).to_contain("dispatch selected=")
            expect(result.summary()).to_contain("probe=requested=")

# ============================================================================
# FFI dispatch integration
# ============================================================================

    describe "FFI dispatch mode":
        it "AC-8: dynamic mode tries dlopen first":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: static mode uses extern fn":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: fallback to CPU when no GPU backend available":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")
