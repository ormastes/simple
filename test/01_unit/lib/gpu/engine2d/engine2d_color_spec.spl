"""Engine2D Color Utility Specification

@tag: rendering, engine2d, color
@cover src/lib/gc_async_mut/gpu/engine2d/color.spl 80%

Verifies rgb/rgba construction, channel extraction, alpha blending,
and linear interpolation for the Engine2D color utility module.
"""

use std.spec.{describe, context, it, expect}
use std.gpu.engine2d.color.{rgb, rgba, color_r, color_g, color_b, color_a, blend, lerp_color}

# ============================================================================
# rgb construction
# ============================================================================

describe "Engine2D Color Utilities":

    context "rgb construction":

        it "rgb creates correct packed color":
            val c = rgb(255, 128, 64)
            expect(color_r(c)).to_equal(255)
            expect(color_g(c)).to_equal(128)
            expect(color_b(c)).to_equal(64)

        it "rgb sets full alpha":
            val c = rgb(0, 0, 0)
            expect(color_a(c)).to_equal(255)

    context "rgba construction":

        it "rgba includes alpha channel":
            val c = rgba(255, 0, 0, 128)
            expect(color_r(c)).to_equal(255)
            expect(color_a(c)).to_equal(128)

    context "color extraction":

        it "extracts zero channels correctly":
            val c = rgb(0, 0, 0)
            expect(color_r(c)).to_equal(0)
            expect(color_g(c)).to_equal(0)
            expect(color_b(c)).to_equal(0)

        it "extracts max channels correctly":
            val c = rgb(255, 255, 255)
            expect(color_r(c)).to_equal(255)
            expect(color_g(c)).to_equal(255)
            expect(color_b(c)).to_equal(255)

    context "lerp_color":

        it "lerp at t=0 returns first color":
            val c = lerp_color(rgb(255, 0, 0), rgb(0, 0, 255), 0)
            expect(color_r(c)).to_equal(255)
            expect(color_b(c)).to_equal(0)

        it "lerp at t=255 returns second color":
            val c = lerp_color(rgb(255, 0, 0), rgb(0, 0, 255), 255)
            expect(color_r(c)).to_equal(0)
            expect(color_b(c)).to_equal(255)

    context "blend":
        # Porter-Duff src-over on straight (non-premultiplied) alpha.
        # doc/08_tracking/bug/engine2d_straight_alpha_transparent_destination_blend_2026-07-11.md

        it "opaque-over-opaque: src fully replaces dst":
            val c = blend(rgba(10, 20, 30, 255), rgba(200, 200, 200, 255))
            expect(color_r(c)).to_equal(10)
            expect(color_g(c)).to_equal(20)
            expect(color_b(c)).to_equal(30)
            expect(color_a(c)).to_equal(255)

        it "transparent-over-any: zero-alpha src leaves dst unchanged":
            val c = blend(rgba(10, 20, 30, 0), rgba(200, 200, 200, 255))
            expect(color_r(c)).to_equal(200)
            expect(color_g(c)).to_equal(200)
            expect(color_b(c)).to_equal(200)
            expect(color_a(c)).to_equal(255)

        it "semi-over-opaque: established opaque-destination result is unchanged":
            val c = blend(rgba(255, 0, 0, 128), rgba(0, 0, 255, 255))
            expect(color_a(c)).to_equal(255)
            expect(color_r(c)).to_equal(128)
            expect(color_g(c)).to_equal(0)
            expect(color_b(c)).to_equal(127)

        it "any-over-transparent: straight alpha over transparent dst preserves srcRGB and srcA (bug repro)":
            # 50% straight-alpha white over transparent black must be
            # 0x80FFFFFF (outA=srcA, outRGB=srcRGB), NOT 0x80808080.
            val c = blend(rgba(255, 255, 255, 128), rgba(0, 0, 0, 0))
            expect(color_a(c)).to_equal(128)
            expect(color_r(c)).to_equal(255)
            expect(color_g(c)).to_equal(255)
            expect(color_b(c)).to_equal(255)

        it "any-over-transparent: non-white color also preserves srcRGB/srcA over transparent dst":
            val c = blend(rgba(0, 0, 255, 64), rgba(0, 0, 0, 0))
            expect(color_a(c)).to_equal(64)
            expect(color_r(c)).to_equal(0)
            expect(color_g(c)).to_equal(0)
            expect(color_b(c)).to_equal(255)

        it "semi-over-semi: both src and dst translucent, known-value pixel math":
            val c = blend(rgba(255, 0, 0, 128), rgba(0, 0, 255, 128))
            expect(color_a(c)).to_equal(191)
            expect(color_r(c)).to_equal(170)
            expect(color_g(c)).to_equal(0)
            expect(color_b(c)).to_equal(84)
