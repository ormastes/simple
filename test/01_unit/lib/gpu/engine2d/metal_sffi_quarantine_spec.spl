use std.spec
use std.gc_async_mut.io.metal_sffi.{metal_sffi_quarantine_release_proven}

describe "Metal submission quarantine":
    it "releases dependencies after successful completion":
        expect(metal_sffi_quarantine_release_proven(true, false)).to_equal(true)

    it "releases dependencies after a terminal error removes the command owner":
        expect(metal_sffi_quarantine_release_proven(false, true)).to_equal(true)

    it "retains dependencies while completion and registry ownership are unknown":
        expect(metal_sffi_quarantine_release_proven(false, false)).to_equal(false)
