# Tests for src/lib/common/error/error.spl (import path: std.error.error)

use std.error.error.{rt_error_value, rt_method_not_found}

describe "std.error.error":
    context "rt_error_value":
        it "returns 27 (RT_ERROR = (SPECIAL_ERROR=3 << 3) | TAG_SPECIAL=3)":
            val v = rt_error_value()
            expect v == 27

        it "is consistent across calls":
            val a = rt_error_value()
            val b = rt_error_value()
            expect a == b

    context "rt_method_not_found":
        it "returns RT_ERROR value (27)":
            val res = rt_method_not_found("MyType", "some_method")
            expect res == 27

        it "returns RT_ERROR for empty strings":
            val res = rt_method_not_found("", "")
            expect res == 27
