# Specification for HPACK encoder and decoder (RFC 7541).
#
# Covers:
#   RFC 7541 Appendix C.2  — individual representation examples
#   RFC 7541 Appendix C.3  — request sequence without Huffman
#   RFC 7541 Appendix C.4  — request sequence with Huffman
#   RFC 7541 Appendix C.5  — response sequence without Huffman (max_size=256)
#   RFC 7541 Appendix C.6  — response sequence with Huffman (max_size=256)
#   Round-trip cases
#   Adversarial cases

use std.spipe.*
use std.common.hpack.encoder.{HpackHeader, HpackEncoderState, HpackDecoderState, hpack_encoder_new, hpack_decoder_new}
use std.common.hpack.decoder.{hpack_decode}

# ============================================================================
# Module-level helpers — all byte arrays and header lists must be built here
# (it-block var mutation is not preserved across loop iterations in interpreter
# mode; all helper fns run in fn scope where it works correctly).
# ============================================================================

# Return the dynamic table entry count from an encoder state.
fn _enc_table_len(s: HpackEncoderState) -> i64:
    s.table.entries.len()

# Return the dynamic table entry count from a decoder state.
fn _dec_table_len(s: HpackDecoderState) -> i64:
    s.table.entries.len()

fn _enc_table_size(s: HpackEncoderState) -> i64:
    s.table.current_size

fn _dec_table_size(s: HpackDecoderState) -> i64:
    s.table.current_size

fn _enc_entry_name(s: HpackEncoderState, idx: i64) -> text:
    s.table.entries[idx].name

fn _enc_entry_value(s: HpackEncoderState, idx: i64) -> text:
    s.table.entries[idx].value

fn _dec_entry_name(s: HpackDecoderState, idx: i64) -> text:
    s.table.entries[idx].name

fn _dec_entry_value(s: HpackDecoderState, idx: i64) -> text:
    s.table.entries[idx].value

# Append two [u8] arrays (used in helper fns below).
fn _cat(a: [u8], b: [u8]) -> [u8]:
    var r = a
    var i: i64 = 0
    while i < b.len():
        r = r + [b[i]]
        i = i + 1
    r

# Check whether two byte arrays are equal.
fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var ok = true
    var i: i64 = 0
    while i < a.len():
        if a[i] != b[i]:
            ok = false
        i = i + 1
    ok

# Check whether two header lists are equal (name+value+sensitive).
fn _headers_eq(a: [HpackHeader], b: [HpackHeader]) -> bool:
    if a.len() != b.len():
        return false
    var ok = true
    var i: i64 = 0
    while i < a.len():
        val ha = a[i]
        val hb = b[i]
        if ha.name != hb.name or ha.value != hb.value or ha.sensitive != hb.sensitive:
            ok = false
        i = i + 1
    ok

# ============================================================================
# RFC 7541 Appendix C.2 byte vectors
# ============================================================================

# C.2.1: Literal Header Field with Indexing — "custom-key: custom-header"
# Bytes: 40 0a 63 75 73 74 6f 6d 2d 6b 65 79 0d 63 75 73 74 6f 6d 2d 68 65 61 64 65 72
fn _c21_bytes() -> [u8]:
    [0x40u8,
     0x0au8, 0x63u8, 0x75u8, 0x73u8, 0x74u8, 0x6fu8, 0x6du8, 0x2du8, 0x6bu8, 0x65u8, 0x79u8,
     0x0du8, 0x63u8, 0x75u8, 0x73u8, 0x74u8, 0x6fu8, 0x6du8, 0x2du8, 0x68u8, 0x65u8, 0x61u8,
     0x64u8, 0x65u8, 0x72u8]

fn _c21_headers() -> [HpackHeader]:
    [HpackHeader(name: "custom-key", value: "custom-header", sensitive: false)]

# C.2.2: Literal Header Field without Indexing — ":path: /sample/path"
# Bytes: 04 0c 2f 73 61 6d 70 6c 65 2f 70 61 74 68
fn _c22_bytes() -> [u8]:
    [0x04u8,
     0x0cu8, 0x2fu8, 0x73u8, 0x61u8, 0x6du8, 0x70u8, 0x6cu8, 0x65u8, 0x2fu8, 0x70u8, 0x61u8,
     0x74u8, 0x68u8]

fn _c22_headers() -> [HpackHeader]:
    [HpackHeader(name: ":path", value: "/sample/path", sensitive: false)]

# C.2.3: Literal Header Field Never Indexed — "password: secret"
# Bytes: 10 08 70 61 73 73 77 6f 72 64 06 73 65 63 72 65 74
fn _c23_bytes() -> [u8]:
    [0x10u8,
     0x08u8, 0x70u8, 0x61u8, 0x73u8, 0x73u8, 0x77u8, 0x6fu8, 0x72u8, 0x64u8,
     0x06u8, 0x73u8, 0x65u8, 0x63u8, 0x72u8, 0x65u8, 0x74u8]

fn _c23_headers() -> [HpackHeader]:
    [HpackHeader(name: "password", value: "secret", sensitive: true)]

# C.2.4: Indexed Header Field — ":method: GET" → 0x82
fn _c24_bytes() -> [u8]:
    [0x82u8]

fn _c24_headers() -> [HpackHeader]:
    [HpackHeader(name: ":method", value: "GET", sensitive: false)]

# ============================================================================
# RFC 7541 Appendix C.3 — Request Examples without Huffman
# ============================================================================

# C.3.1: First Request
# Headers: :method=GET, :scheme=http, :path=/, :authority=www.example.com
# Bytes: 82 86 84 41 0f 77 77 77 2e 65 78 61 6d 70 6c 65 2e 63 6f 6d
fn _c31_headers() -> [HpackHeader]:
    [
        HpackHeader(name: ":method", value: "GET", sensitive: false),
        HpackHeader(name: ":scheme", value: "http", sensitive: false),
        HpackHeader(name: ":path", value: "/", sensitive: false),
        HpackHeader(name: ":authority", value: "www.example.com", sensitive: false)
    ]

fn _c31_bytes() -> [u8]:
    [0x82u8, 0x86u8, 0x84u8,
     0x41u8, 0x0fu8, 0x77u8, 0x77u8, 0x77u8, 0x2eu8, 0x65u8, 0x78u8, 0x61u8, 0x6du8, 0x70u8,
     0x6cu8, 0x65u8, 0x2eu8, 0x63u8, 0x6fu8, 0x6du8]

# C.3.2: Second Request
# Headers: :method=GET, :scheme=http, :path=/, :authority=www.example.com, cache-control=no-cache
# Bytes: 82 86 84 be 58 08 6e 6f 2d 63 61 63 68 65
fn _c32_headers() -> [HpackHeader]:
    [
        HpackHeader(name: ":method", value: "GET", sensitive: false),
        HpackHeader(name: ":scheme", value: "http", sensitive: false),
        HpackHeader(name: ":path", value: "/", sensitive: false),
        HpackHeader(name: ":authority", value: "www.example.com", sensitive: false),
        HpackHeader(name: "cache-control", value: "no-cache", sensitive: false)
    ]

fn _c32_bytes() -> [u8]:
    [0x82u8, 0x86u8, 0x84u8, 0xbeu8,
     0x58u8, 0x08u8, 0x6eu8, 0x6fu8, 0x2du8, 0x63u8, 0x61u8, 0x63u8, 0x68u8, 0x65u8]

# C.3.3: Third Request
# Headers: :method=GET, :scheme=https, :path=/index.html, :authority=www.example.com,
#          custom-key=custom-value
# Bytes: 82 87 85 bf 40 0a 63 75 73 74 6f 6d 2d 6b 65 79 0c 63 75 73 74 6f 6d 2d 76 61 6c 75 65
fn _c33_headers() -> [HpackHeader]:
    [
        HpackHeader(name: ":method", value: "GET", sensitive: false),
        HpackHeader(name: ":scheme", value: "https", sensitive: false),
        HpackHeader(name: ":path", value: "/index.html", sensitive: false),
        HpackHeader(name: ":authority", value: "www.example.com", sensitive: false),
        HpackHeader(name: "custom-key", value: "custom-value", sensitive: false)
    ]

fn _c33_bytes() -> [u8]:
    [0x82u8, 0x87u8, 0x85u8, 0xbfu8,
     0x40u8,
     0x0au8, 0x63u8, 0x75u8, 0x73u8, 0x74u8, 0x6fu8, 0x6du8, 0x2du8, 0x6bu8, 0x65u8, 0x79u8,
     0x0cu8, 0x63u8, 0x75u8, 0x73u8, 0x74u8, 0x6fu8, 0x6du8, 0x2du8, 0x76u8, 0x61u8, 0x6cu8,
     0x75u8, 0x65u8]

# ============================================================================
# RFC 7541 Appendix C.4 — Request Examples with Huffman
# ============================================================================

# C.4.1: First Request (Huffman)
# Bytes: 82 86 84 41 8c f1 e3 c2 e5 f2 3a 6b a0 ab 90 f4 ff
fn _c41_bytes() -> [u8]:
    [0x82u8, 0x86u8, 0x84u8,
     0x41u8, 0x8cu8, 0xf1u8, 0xe3u8, 0xc2u8, 0xe5u8, 0xf2u8, 0x3au8, 0x6bu8, 0xa0u8, 0xabu8,
     0x90u8, 0xf4u8, 0xffu8]

# C.4.2: Second Request (Huffman)
# Bytes: 82 86 84 be 58 86 a8 eb 10 64 9c bf
fn _c42_bytes() -> [u8]:
    [0x82u8, 0x86u8, 0x84u8, 0xbeu8,
     0x58u8, 0x86u8, 0xa8u8, 0xebu8, 0x10u8, 0x64u8, 0x9cu8, 0xbfu8]

# C.4.3: Third Request (Huffman)
# Bytes: 82 87 85 bf 40 88 25 a8 49 e9 5b a9 7d 7f 89 25 a8 49 e9 5b b8 e8 b4 bf
fn _c43_bytes() -> [u8]:
    [0x82u8, 0x87u8, 0x85u8, 0xbfu8,
     0x40u8,
     0x88u8, 0x25u8, 0xa8u8, 0x49u8, 0xe9u8, 0x5bu8, 0xa9u8, 0x7du8, 0x7fu8,
     0x89u8, 0x25u8, 0xa8u8, 0x49u8, 0xe9u8, 0x5bu8, 0xb8u8, 0xe8u8, 0xb4u8, 0xbfu8]

# ============================================================================
# RFC 7541 Appendix C.5 — Response Examples without Huffman (max_size=256)
# ============================================================================

fn _c51_headers() -> [HpackHeader]:
    [
        HpackHeader(name: ":status", value: "302", sensitive: false),
        HpackHeader(name: "cache-control", value: "private", sensitive: false),
        HpackHeader(name: "date", value: "Mon, 21 Oct 2013 20:13:21 GMT", sensitive: false),
        HpackHeader(name: "location", value: "https://www.example.com", sensitive: false)
    ]

