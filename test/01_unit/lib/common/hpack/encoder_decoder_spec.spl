     0x77u8, 0x38u8,
     0x66u8, 0x6fu8, 0x6fu8, 0x3du8, 0x41u8, 0x53u8, 0x44u8, 0x4au8, 0x4bu8, 0x48u8,
     0x51u8, 0x4bu8, 0x42u8, 0x5au8, 0x58u8, 0x4fu8, 0x51u8, 0x57u8, 0x45u8, 0x4fu8,
     0x50u8, 0x49u8, 0x55u8, 0x41u8, 0x58u8, 0x51u8, 0x57u8, 0x45u8, 0x4fu8, 0x49u8,
     0x55u8, 0x3bu8, 0x20u8, 0x6du8, 0x61u8, 0x78u8, 0x2du8, 0x61u8, 0x67u8, 0x65u8,
     0x3du8, 0x33u8, 0x36u8, 0x30u8, 0x30u8, 0x3bu8, 0x20u8, 0x76u8, 0x65u8, 0x72u8,
     0x73u8, 0x69u8, 0x6fu8, 0x6eu8, 0x3du8, 0x31u8]

# ============================================================================
# RFC 7541 Appendix C.6 — Response Examples with Huffman (max_size=256)
# ============================================================================

