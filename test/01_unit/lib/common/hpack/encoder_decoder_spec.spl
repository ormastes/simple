    # RFC 7541 Appendix C.5.3 — Third Response without Huffman (max_size=256).
    # set-cookie value = "foo=ASDJKHQKBZXOQWEOPIUAXQWEOIU; max-age=3600; version=1" (56 bytes = 0x38)
    [0x88u8,
     0xc1u8,
     0x61u8, 0x1du8,
     0x4du8, 0x6fu8, 0x6eu8, 0x2cu8, 0x20u8, 0x32u8, 0x31u8, 0x20u8, 0x4fu8, 0x63u8,
