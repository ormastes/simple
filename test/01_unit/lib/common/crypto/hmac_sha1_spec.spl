# HMAC-SHA-1 Reference Vectors
#
# Tests the pure-Simple HMAC-SHA-1 implementation in
# src/lib/common/crypto/hmac.spl against RFC 2202 §3 test vectors.
#
# RFC 2202 "Test Cases for HMAC-MD5 and HMAC-SHA-1" specifies 7 canonical
# HMAC-SHA-1 vectors. We exercise 4+ here covering: short key+data, ASCII
# key, full block-size key with binary data, longer-than-block-size key
# (forces the inner SHA-1 hash of the key), and the "larger than one
# block-size data" case (forces multi-block message processing).
#
# WARNING: SHA-1 is cryptographically broken. HMAC-SHA-1 retains PRF
# strength under current best public attacks but should be used only for
# legacy interop (TLS 1.2 PRF, HOTP/TOTP, RFC 6070 PBKDF2 vectors).

use std.spipe.*
use std.crypto.hmac.{hmac_sha1, hmac_sha1_bytes}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — input builders in module-level fns to avoid the it-block var
# mutation interpreter quirk (feedback_it_block_var_mutation.md).
# ============================================================================

# n copies of byte b
fn _bytes_repeat(b: i64, n: i64) -> list:
    var out = []
    var i = 0
    while i < n:
        out.push(b)
        i = i + 1
    out

# 25-byte ascending key 0x01..0x19 (RFC 2202 TC4)
fn _tc4_key() -> list:
    [
        0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08,
        0x09, 0x0a, 0x0b, 0x0c, 0x0d, 0x0e, 0x0f, 0x10,
        0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17, 0x18,
        0x19
    ]

# ============================================================================
# RFC 2202 §3 — HMAC-SHA-1 reference vectors
# ============================================================================

describe "HMAC-SHA-1 — RFC 2202 §3 reference vectors":

    it "TC1: K=20*0x0b, M='Hi There'":
        # MAC = b617318655057264e28bc0b6fb378c8ef146be00
        expect(bytes_to_hex(hmac_sha1_bytes(_bytes_repeat(0x0b, 20), [0x48, 0x69, 0x20, 0x54, 0x68, 0x65, 0x72, 0x65]))).to_equal(
            "b617318655057264e28bc0b6fb378c8ef146be00"
        )

    it "TC2: K='Jefe', M='what do ya want for nothing?'":
        # MAC = effcdf6ae5eb2fa2d27416d5f184df9c259a7c79
        expect(bytes_to_hex(hmac_sha1("Jefe", "what do ya want for nothing?"))).to_equal(
            "effcdf6ae5eb2fa2d27416d5f184df9c259a7c79"
        )

    it "TC3: K=20*0xaa, M=50*0xdd":
        # MAC = 125d7342b9ac11cd91a39af48aa17b4f63f175d3
        expect(bytes_to_hex(hmac_sha1_bytes(_bytes_repeat(0xaa, 20), _bytes_repeat(0xdd, 50)))).to_equal(
            "125d7342b9ac11cd91a39af48aa17b4f63f175d3"
        )

    it "TC4: K=25-byte 0x01..0x19, M=50*0xcd":
        # MAC = 4c9007f4026250c6bc8414f9bf50c86c2d7235da
        expect(bytes_to_hex(hmac_sha1_bytes(_tc4_key(), _bytes_repeat(0xcd, 50)))).to_equal(
            "4c9007f4026250c6bc8414f9bf50c86c2d7235da"
        )

    it "TC6: K=80*0xaa (longer than block), short data — exercises inner-hash key path":
        # 'Test Using Larger Than Block-Size Key - Hash Key First'
        # MAC = aa4ae5e15272d00e95705637ce8a3b55ed402112
        val msg = [
            0x54, 0x65, 0x73, 0x74, 0x20, 0x55, 0x73, 0x69, 0x6e, 0x67, 0x20, 0x4c, 0x61, 0x72, 0x67, 0x65,
            0x72, 0x20, 0x54, 0x68, 0x61, 0x6e, 0x20, 0x42, 0x6c, 0x6f, 0x63, 0x6b, 0x2d, 0x53, 0x69, 0x7a,
            0x65, 0x20, 0x4b, 0x65, 0x79, 0x20, 0x2d, 0x20, 0x48, 0x61, 0x73, 0x68, 0x20, 0x4b, 0x65, 0x79,
            0x20, 0x46, 0x69, 0x72, 0x73, 0x74
        ]
        expect(bytes_to_hex(hmac_sha1_bytes(_bytes_repeat(0xaa, 80), msg))).to_equal(
            "aa4ae5e15272d00e95705637ce8a3b55ed402112"
        )

# ============================================================================
# Output shape
# ============================================================================

describe "HMAC-SHA-1 — output shape":

    it "MAC is exactly 20 bytes":
        expect(hmac_sha1("k", "m").len()).to_equal(20)

    it "hex form is exactly 40 chars":
        expect(bytes_to_hex(hmac_sha1("k", "m")).len()).to_equal(40)
