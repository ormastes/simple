use std.spec.{describe, it, assert_equal}
use std.crypto.types.{bytes_to_text}

describe "crypto bytes_to_text guards":
    it "keeps valid byte conversion":
        assert_equal(bytes_to_text([65, 66, 67]), "ABC")

    it "rejects negative byte values":
        assert_equal(bytes_to_text([-1]), "")

    it "rejects byte values above 255":
        assert_equal(bytes_to_text([65, 300]), "")
