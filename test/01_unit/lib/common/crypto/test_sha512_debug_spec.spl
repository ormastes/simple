use std.spipe.*
use std.crypto.sha512.{sha512_256_bytes}

describe "sha512_256 debug":
    it "empty input":
        val result = sha512_256_bytes([])
        expect(result.len()).to_equal(32)
    it "small 4-byte input":
        val result = sha512_256_bytes([1, 2, 3, 4])
        expect(result.len()).to_equal(32)
    it "68-byte input":
        var data: [i64] = []
        var i = 0
        while i < 68:
            data.push(i & 255)
            i = i + 1
        val result = sha512_256_bytes(data)
        expect(result.len()).to_equal(32)
    it "128-byte input":
        var data: [i64] = []
        var i = 0
        while i < 128:
            data.push(i & 255)
            i = i + 1
        val result = sha512_256_bytes(data)
        expect(result.len()).to_equal(32)
