use std.spec.{describe, it, assert_equal}
use std.crypto.types.{bytes_to_hex}

describe "crypto bytes_to_hex guards":
    it "keeps valid byte formatting":
        assert_equal(bytes_to_hex([0, 15, 16, 255]), "000f10ff")

    it "rejects negative byte values":
        assert_equal(bytes_to_hex([-1]), "")

    it "rejects byte values above 255":
        assert_equal(bytes_to_hex([0, 300]), "")
