use std.common.crypto.sha256.{sha256_u8_hex}

fn main() -> i64:
    if sha256_u8_hex([]) != "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855":
        return 10
    if sha256_u8_hex([0x61 as u8, 0x62 as u8, 0x63 as u8]) != "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad":
        return 11
    var bytes: [u8] = []
    var index: i64 = 0
    while index < 65592:
        bytes.push(((index * 31 + 7) & 255) as u8)
        index = index + 1
    if sha256_u8_hex(bytes) != "5fead3eebbc232ecb6d7e4282cacff608ab274c3a6e58fbe5b15500354cddbae":
        return 12
    while index < 1708408:
        bytes.push(((index * 31 + 7) & 255) as u8)
        index = index + 1
    if sha256_u8_hex(bytes) != "e3a1cf8bf5e5804af5d29989c8c48e3374bdbf54ddf054e7d18c232e49a162fa":
        return 13
    0
