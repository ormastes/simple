use std.spipe.*

fn _lshr64(x: i64, n: i64) -> i64:
    if n == 0:
        return x
    if n >= 64:
        return 0
    val without_sign = x & 9223372036854775807
    val shifted_low = without_sign >> n
    if x < 0:
        val high_bit = 9223372036854775807 >> (n - 1)
        shifted_low | high_bit
    else:
        shifted_low

describe "lshr64 v3 correct value":
    it "correct test value >> 56 = 0xcf":
        val test = -3493701266030217027  # correct h0 for sha512('')
        val r = _lshr64(test, 56)
        expect(r & 255).to_equal(207)  # 0xcf
    it "correct test value >> 48 = 0x83":
        val test = -3493701266030217027
        expect(_lshr64(test, 48) & 255).to_equal(0x83)
