use std.spipe.*

# Logical right shift: treat x as unsigned 64-bit, shift right by n.
fn _lshr64(x: i64, n: i64) -> i64:
    if n == 0:
        return x
    if n >= 64:
        return 0
    # Strip sign bit, shift, add back the shifted high bit contribution.
    val without_sign = x & 9223372036854775807  # 0x7FFFFFFFFFFFFFFF
    val shifted_low = without_sign >> n
    if x < 0:
        # bit 63 was set; its contribution after logical shift right by n is bit (63-n)
        val high_bit = 9223372036854775807 >> (n - 1)  # = 2^(63-n)
        shifted_low | high_bit
    else:
        shifted_low

describe "lshr64 v2":
    it "-1 >> 1 = max_i64":
        expect(_lshr64(-1, 1)).to_equal(9223372036854775807)
    it "-1 >> 8 = 0x00FFFFFFFFFFFFFF":
        expect(_lshr64(-1, 8)).to_equal(72057594037927935)
    it "-1 >> 63 = 1":
        expect(_lshr64(-1, 63)).to_equal(1)
    it "positive unchanged":
        expect(_lshr64(100, 2)).to_equal(25)
    it "0xcf83 >> 56 = 0xcf":
        # cf83e135... first byte of sha512('')
        # h0 after sha512 compression
        val test = -3502672086076662267  # 0xcf83e13... as signed i64
        expect(_lshr64(test, 56) & 255).to_equal(0xcf)
