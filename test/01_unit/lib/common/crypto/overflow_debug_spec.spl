use std.spipe.*

describe "i64 overflow behavior":
    it "max i64 + 1 wraps to min":
        val max = 9223372036854775807
        val result = max + 1
        expect(result).to_equal(-9223372036854775808)
    it "large left shift stays in 64 bits":
        val x = 1
        val shifted = x << 63
        # Should be -9223372036854775808 (min i64, bit 63 set)
        expect(shifted).to_equal(-9223372036854775808)
    it "mask with -1 works as no-op":
        val x = 100
        val r = x & -1
        expect(r).to_equal(100)
    it "two large values add with wrap":
        val a = 9223372036854775807
        val b = 9223372036854775807
        val r = a + b
        expect(r).to_equal(-2)
