use std.spec
use std.common.crypto.typed.seam.{alpha_run_span, alpha_run_digest}
use std.common.bytes.span.{ByteSpan}
use std.common.crypto.typed.ctypes.{Digest}

# NOTE: Digest.hex() returns garbage when seam.spl and ctypes are both imported
# in fn main() context (double-import interpreter corruption).
# Filed: doc/08_tracking/bug/digest_hex_double_import_corruption_2026-06-15.md
# Workaround: assert agreement via ct_eq and byte-level ByteSpan.get(); assert
# mismatch via .len() == 0.  ct_eq and get() are proven correct in this context.

describe "alpha_run_span":
    it "agreement: two closures returning the same ByteSpan yield that value":
        # Known 4-byte payload: [0x01, 0x02, 0x03, 0x04]
        val known: [u8] = [1u8, 2u8, 3u8, 4u8]
        val s = alpha_run_span(
            "test",
            "agree",
            fn(): ByteSpan.new(known),
            fn(): ByteSpan.new(known)
        )
        expect(s.len()).to_equal(4)
        expect(s.get(0).to_i64()).to_equal(1)
        expect(s.get(1).to_i64()).to_equal(2)
        expect(s.get(2).to_i64()).to_equal(3)
        expect(s.get(3).to_i64()).to_equal(4)

    it "mismatch: two closures returning different ByteSpans yield empty (alpha logs, not abort)":
        # Alpha mode on mismatch: _dual_backend_alpha_halt logs then returns [].
        # The seam wraps [] as ByteSpan.new([]) — len == 0.
        val a: [u8] = [1u8, 2u8, 3u8]
        val b: [u8] = [4u8, 5u8, 6u8]
        val s = alpha_run_span(
            "test",
            "mismatch",
            fn(): ByteSpan.new(a),
            fn(): ByteSpan.new(b)
        )
        expect(s.len()).to_equal(0)

describe "alpha_run_digest":
    it "agreement: two closures returning the same ByteSpan yield that digest (ct_eq check)":
        # Known 3-byte digest: 0x01 0x02 0x03
        # Digest.hex() is broken cross-module (see file header); use ct_eq instead.
        val known: [u8] = [1u8, 2u8, 3u8]
        val d = alpha_run_digest(
            "test",
            "digest_agree",
            fn(): ByteSpan.new(known),
            fn(): ByteSpan.new(known)
        )
        val expected = Digest.new(known)
        expect(d.len()).to_equal(3)
        expect(d.ct_eq(expected)).to_equal(true)

    it "mismatch: two different closures yield empty Digest (alpha not-fail-closed contract)":
        # Bug alpha_mode_not_fail_closed_2026-06-15: alpha logs, returns [].
        # Digest.new([]).len() == 0, ct_eq(Digest.new([])) == true.
        val a: [u8] = [170u8]
        val b: [u8] = [187u8]
        val d = alpha_run_digest(
            "test",
            "digest_mismatch",
            fn(): ByteSpan.new(a),
            fn(): ByteSpan.new(b)
        )
        val empty = Digest.new([])
        expect(d.len()).to_equal(0)
        expect(d.ct_eq(empty)).to_equal(true)
