use std.spec
use std.common.crypto.typed.seam.{alpha_run_span, alpha_run_digest}
use std.common.bytes.span.{ByteSpan}
use std.common.crypto.typed.ctypes.{Digest}

# NOTE: Digest.hex() returns garbage when seam.spl and ctypes are both imported
# in fn main() context (double-import interpreter corruption).
# Filed: doc/08_tracking/bug/digest_hex_double_import_corruption_2026-06-15.md
# Workaround: assert agreement via ct_eq and byte-level ByteSpan.get().
#
# Alpha is now fail-CLOSED (alpha_mode_not_fail_closed_2026-06-15 fixed): a true
# runtime/pure mismatch (both sides non-empty and differing) calls rt_exit(70) and
# aborts the process. That behavior CANNOT be asserted in-process — it would crash
# this spec file's child process — so it is verified out-of-process by a
# bin/simple run probe that triggers a mismatch and checks the non-zero exit code.
# Here we assert (a) agreement returns the value and (b) the absent-oracle
# degradation path (one backend empty) still returns the other side WITHOUT halting
# — the load-bearing path for callers that have no real runtime oracle.

describe "alpha_run_span":
    it "agreement: two closures returning the same ByteSpan yield that value":
        # Known 4-byte payload: [0x01, 0x02, 0x03, 0x04]
        val known: [u8] = [1u8, 2u8, 3u8, 4u8]
        val s = alpha_run_span(
            "test",
            "agree",
            fn(): ByteSpan.new(known),
            fn(): ByteSpan.new(known)
        )
        expect(s.len()).to_equal(4)
        expect(s.get(0).to_i64()).to_equal(1)
        expect(s.get(1).to_i64()).to_equal(2)
        expect(s.get(2).to_i64()).to_equal(3)
        expect(s.get(3).to_i64()).to_equal(4)

    it "absent-oracle degradation: runtime empty, pure present -> returns pure, no halt":
        # When one backend is absent (returns []), alpha must NOT halt — it
        # degrades to the present side. This guards the path every stubbed-runtime
        # caller relies on; a regression here would abort real crypto calls.
        val empty: [u8] = []
        val known: [u8] = [1u8, 2u8, 3u8, 4u8]
        val s = alpha_run_span(
            "test",
            "degrade",
            fn(): ByteSpan.new(empty),
            fn(): ByteSpan.new(known)
        )
        expect(s.len()).to_equal(4)
        expect(s.get(0).to_i64()).to_equal(1)
        expect(s.get(3).to_i64()).to_equal(4)

describe "alpha_run_digest":
    it "agreement: two closures returning the same ByteSpan yield that digest (ct_eq check)":
        # Known 3-byte digest: 0x01 0x02 0x03
        # Digest.hex() is broken cross-module (see file header); use ct_eq instead.
        val known: [u8] = [1u8, 2u8, 3u8]
        val d = alpha_run_digest(
            "test",
            "digest_agree",
            fn(): ByteSpan.new(known),
            fn(): ByteSpan.new(known)
        )
        val expected = Digest.new(known)
        expect(d.len()).to_equal(3)
        expect(d.ct_eq(expected)).to_equal(true)

    it "absent-oracle degradation: runtime empty, pure present -> returns pure digest, no halt":
        # Same degradation guard for the digest seam: a missing runtime backend
        # must yield the pure digest, never an abort.
        val empty: [u8] = []
        val known: [u8] = [1u8, 2u8, 3u8]
        val d = alpha_run_digest(
            "test",
            "digest_degrade",
            fn(): ByteSpan.new(empty),
            fn(): ByteSpan.new(known)
        )
        val expected = Digest.new(known)
        expect(d.len()).to_equal(3)
        expect(d.ct_eq(expected)).to_equal(true)
