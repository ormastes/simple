# Tests for src/lib/common/contracts/contracts.spl (import path: std.contracts.contracts)
#
# Note: the abort() path (condition=0) cannot be tested — it terminates the process.
# Only the happy-path (condition != 0 => returns silently) is verified here.

use std.contracts.contracts.{simple_contract_check, simple_contract_check_msg}

describe "std.contracts.contracts":
    context "simple_contract_check (passing condition)":
        it "returns silently when condition is 1":
            simple_contract_check(1, 0, "test_fn")
            expect("test_fn").to_equal("test_fn")

        it "returns silently when condition is non-zero":
            simple_contract_check(100, 1, "another_fn")
            expect(100).to_be_greater_than(1)

        it "accepts kind=2 (error postcondition)":
            simple_contract_check(1, 2, "err_post_fn")
            expect(2).to_equal(2)

        it "accepts empty function name":
            simple_contract_check(1, 0, "")
            expect("").to_equal("")

        it "accepts kind=5 (assertion)":
            simple_contract_check(1, 5, "assert_fn")
            expect(5).to_equal(5)

    context "simple_contract_check_msg (passing condition)":
        it "returns silently when condition is 1":
            simple_contract_check_msg(1, 0, "fn_name", "all good")
            expect("all good").to_contain("good")

        it "accepts empty message":
            simple_contract_check_msg(1, 1, "fn_name", "")
            expect("").to_equal("")

        it "accepts empty function name and message":
            simple_contract_check_msg(1, 3, "", "")
            expect(3).to_equal(3)
