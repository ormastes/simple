# @cover src/lib/gc_async_mut/web/browser_session_ui_access.spl 80%

use std.spec.{describe, it, expect}
use std.gc_async_mut.web.browser_session.{BrowserSession}
use std.gc_async_mut.web.browser_session_ui_access.*

fn _link_text(snapshot, widget_id: text) -> text:
    var i = 0
    val node_count = snapshot.nodes.len()
    while i < node_count:
        val node = snapshot.nodes[i]
        if node.widget_id == widget_id:
            return node.text_value
        i = i + 1
    ""

describe "BrowserSession UI access":
    it "strips inline tags from link labels in source order":
        var session = BrowserSession.new()
        session.current_url = "https://example.com/base/index.html"
        session.current_title = "Links"
        session.current_body_html = "<a href=\"next.html\">Alpha <strong>Beta</strong> <span>Gamma</span></a>"

        val snapshot = session.ui_access_snapshot()
        expect(_link_text(snapshot, "link_0")).to_equal("Alpha Beta Gamma")
