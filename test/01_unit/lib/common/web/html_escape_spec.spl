# Canonical html_escape unification.
#
# Verifies the single implementation in std.common.web.html_escape, and that
# every wrapper across the previously duplicated copies (app.ui.render.html,
# common.ui.html_window, common.ui.mobile_html_gen,
# gc_async_mut.web.browser_session_html) now escapes all 5 HTML special
# characters identically -- including `'`, which several of the older
# hand-rolled copies missed.

use std.spec
use common.web.html_escape.{html_escape, html_attr_escape, html_escape_core}
use app.ui.render.html.{html_escape as render_html_escape}
use common.ui.html_window.{html_escape as window_html_escape, html_attr_escape as window_html_attr_escape}
use common.ui.mobile_html_gen.{html_gen_escape_text, html_gen_escape_attr}
use std.gc_async_mut.web.browser_session_html.{escape_html_text}

describe "canonical html_escape":

    it "escapes all 5 special characters, amp first":
        expect(html_escape("& < > \" '")).to_equal("&amp; &lt; &gt; &quot; &#39;")

    it "does not double-escape when amp is escaped first":
        expect(html_escape("&amp;")).to_equal("&amp;amp;")

    it "html_attr_escape matches html_escape (double-quoted attrs)":
        expect(html_attr_escape("a\"b'c")).to_equal(html_escape("a\"b'c"))

    it "html_escape_core matches html_escape (same underlying implementation)":
        expect(html_escape_core("a\"b'c")).to_equal(html_escape("a\"b'c"))

    it "passes through text with no special characters":
        expect(html_escape("hello world")).to_equal("hello world")

describe "html_escape wrapper parity across all former duplicates":

    val sample = "<script>alert('x & y \"z\"')</script>"
    val expected = html_escape(sample)

    it "app.ui.render.html.html_escape matches canonical":
        expect(render_html_escape(sample)).to_equal(expected)

    it "common.ui.html_window.html_escape matches canonical":
        expect(window_html_escape(sample)).to_equal(expected)

    it "common.ui.html_window.html_attr_escape matches canonical":
        expect(window_html_attr_escape(sample)).to_equal(expected)

    it "common.ui.mobile_html_gen.html_gen_escape_text matches canonical":
        expect(html_gen_escape_text(sample)).to_equal(expected)

    it "common.ui.mobile_html_gen.html_gen_escape_attr matches canonical":
        expect(html_gen_escape_attr(sample)).to_equal(expected)

    it "gc_async_mut.web.browser_session_html.escape_html_text matches canonical":
        expect(escape_html_text(sample)).to_equal(expected)

    it "every wrapper escapes a lone apostrophe (older copies missed this)":
        expect(render_html_escape("'")).to_equal("&#39;")
        expect(window_html_escape("'")).to_equal("&#39;")
        expect(html_gen_escape_text("'")).to_equal("&#39;")
        expect(escape_html_text("'")).to_equal("&#39;")
