use std.spec.*
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.{JsValue}

fn _display_js(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

fn _eval_text(runtime: JsRuntime, source: text) -> text:
    match runtime.eval(source):
        Ok(value): _display_js(value)
        Err(e): "error:{e}"

describe "new Promise(executor) construction":

    it "constructs a real Promise object instead of undefined":
        val runtime = JsRuntime.new(Logger.new("new-promise-typeof", LogLevel.Error))
        val result = _eval_text(runtime, "typeof (new Promise((resolve, reject) => { resolve(1); }))")
        expect(result).to_equal("object")

    it "runs the executor synchronously":
        val runtime = JsRuntime.new(Logger.new("new-promise-sync", LogLevel.Error))
        val result = _eval_text(runtime, "var ran = false; new Promise((resolve, reject) => { ran = true; resolve(1); }); ran")
        expect(result).to_equal("true")

    it "resolves the constructed promise via the executor's resolve callback":
        # Assigned to a variable rather than chained directly (`new Promise(...).then(...)`)
        # to sidestep an unrelated, pre-existing subset-parser limitation where a
        # postfix chain immediately after `new Ctor(...)` is mis-attributed to the
        # `new` expression itself; not in scope for this fix.
        val runtime = JsRuntime.new(Logger.new("new-promise-resolve", LogLevel.Error))
        val setup = runtime.eval("var out = 0; var p = new Promise((resolve, reject) => { resolve(41); }); p.then((v) => { out = v + 1; }); 'ok'")
        match setup:
            Ok(_): pass_dn
            Err(e): fail("setup eval failed: {e}")
        val _ = runtime.interpreter.drain_pending_microtasks()
        expect(_eval_text(runtime, "out")).to_equal("42")

    it "rejects the constructed promise via the executor's reject callback":
        val runtime = JsRuntime.new(Logger.new("new-promise-reject", LogLevel.Error))
        val setup = runtime.eval("var errOut = ''; var p = new Promise((resolve, reject) => { reject('boom'); }); p.catch((e) => { errOut = e; }); 'ok'")
        match setup:
            Ok(_): pass_dn
            Err(e): fail("setup eval failed: {e}")
        val _ = runtime.interpreter.drain_pending_microtasks()
        expect(_eval_text(runtime, "errOut")).to_equal("boom")
