extern fn rt_file_read_text(path: text) -> text

fn pure_list_source() -> text:
    rt_file_read_text("src/lib/common/pure/list.spl") ?? ""

describe "Utils":
    it "keeps immutable pure list constructors available":
        val source = pure_list_source()

        expect(source).to_contain("enum List<T>:")
        expect(source).to_contain("Nil")
        expect(source).to_contain("Cons(head: T, tail: List<T>)")
        expect(source).to_contain("fn list_empty<T>() -> List<T>")
        expect(source).to_contain("fn list_cons<T>(head: T, tail: List<T>) -> List<T>")

    it "keeps pure list query and conversion helpers available":
        val source = pure_list_source()

        expect(source).to_contain("fn list_len<T>(l: List<T>) -> i64")
        expect(source).to_contain("fn list_is_empty<T>(l: List<T>) -> bool")
        expect(source).to_contain("fn list_head<T>(l: List<T>) -> Option<T>")
        expect(source).to_contain("fn list_tail<T>(l: List<T>) -> List<T>")
        expect(source).to_contain("fn list_to_array<T>(l: List<T>) -> [T]")
        expect(source).to_contain("fn list_from_array<T>(arr: [T]) -> List<T>")
