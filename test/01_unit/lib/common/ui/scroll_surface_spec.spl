# @cover src/lib/common/ui/scroll_surface.spl 70%
# @req FR-UI-SCROLL-VIRTUALIZATION
#
# visible_range() is the virtualization primitive: given a scroll offset, a
# viewport height, and a row height, it returns the [first, first+count) band
# of absolute content rows a viewport actually needs — never the full row
# list. paint_content_band() is refactored to walk exactly that window; these
# specs assert the row window itself (top/bottom edges, partial rows, and a
# large list) plus that paint_content_band's fill_rect count matches count.

use std.spec.{describe, it, expect}
use common.ui.scroll_surface.{
    FrameBuffer, ScrollModel, visible_range, paint_content_band, content_height, max_scroll, ROW_H
}

describe "visible_range":

    it "top of a large list: scroll 0 covers exactly the rows that fit the viewport":
        # 480px viewport / 48px rows = exactly 10 rows, no partial.
        val r = visible_range(0, 480, 48)
        expect(r.first).to_equal(0)
        expect(r.count).to_equal(10)

    it "a partial scroll includes a partially-visible row at both edges":
        # scroll=24 (half a row past row 0): top partial row 0, then rows
        # 1..9 fully, then a partial row 10 at the bottom edge => 11 rows.
        val r = visible_range(24, 480, 48)
        expect(r.first).to_equal(0)
        expect(r.count).to_equal(11)

    it "mid-list scroll offsets `first` by whole rows scrolled past":
        # scroll=480 (10 rows in) with an exact-fit viewport => rows 10..19.
        val r = visible_range(480, 480, 48)
        expect(r.first).to_equal(10)
        expect(r.count).to_equal(10)

    it "bottom edge: max_scroll of a 100-row list still lands on whole rows":
        val m = ScrollModel(total_rows: 100, view_w: 400, view_h: 480)
        val ms = max_scroll(m)
        val r = visible_range(ms, m.view_h, ROW_H)
        # last visible row must be the final row (99); never past it.
        expect(r.first + r.count - 1).to_equal(99)

    it "returns count 0 for a degenerate (non-positive) viewport_h":
        val r = visible_range(0, 0, 48)
        expect(r.count).to_equal(0)

    it "returns count 0 for a degenerate (non-positive) row_h":
        val r = visible_range(0, 480, 0)
        expect(r.count).to_equal(0)

    it "a huge list (100k rows) still returns a small, viewport-bounded window":
        val r = visible_range(50000 * 48, 480, 48)
        expect(r.count).to_equal(10)
        expect(r.first).to_equal(50000)

describe "paint_content_band virtualization":

    it "paints exactly visible_range's row count worth of fill_rect calls for a huge list":
        val m = ScrollModel(total_rows: 100000, view_w: 400, view_h: 480)
        val fb = FrameBuffer.create(m.view_w, m.view_h)
        # scroll to the middle of a 100k-row list — if this were NOT
        # virtualized (walked all 100000 rows) this spec would time out.
        val scroll = 50000 * ROW_H
        val written = paint_content_band(fb, m, scroll, 0, m.view_h)
        val r = visible_range(scroll, m.view_h, ROW_H)
        # Every visible row fills a full-width strip: content_w * row_h_or_less
        # per row: written must be > 0 and bounded by r.count rows worth of
        # pixels (content_w * view_h at most, since rows never exceed the band).
        expect(written > 0).to_equal(true)
        val content_w: i64 = (m.view_w - 24).to_i64()
        expect(written <= content_w * m.view_h.to_i64()).to_equal(true)
        expect(r.count).to_equal(10)
