# @cover src/lib/common/ui/window_scene_draw_ir.spl 20%
# @tag: unit, ui, draw_ir, wm, perf

use std.spec
use common.ui.draw_ir.{DRAW_IR_BACKEND_GPU}
use common.ui.taskbar_model.{AppRef, TaskbarModel, TrayItem, WindowRef}
use common.ui.window_surface_registry.{UI_SURFACE_KIND_SIMPLE_WEB}
use common.ui.window_scene.{SharedWmScene, SharedWmWindow, WM_CHROME_KIND_TITLED, shared_wm_background_color}
use common.ui.window_scene_draw_ir.{shared_wm_scene_draw_ir_composition}
use common.ui.wm_chrome_theme.{wm_chrome_theme}

fn _taskbar() -> TaskbarModel:
    TaskbarModel(
        pinned: [
            AppRef(app_id: "terminal", display_name: "Terminal", icon: "term")
        ],
        running: [
            WindowRef(window_id: "bottom", app_id: "demo.app", title: "Bottom", minimized: false),
            WindowRef(window_id: "middle-a", app_id: "demo.app", title: "Middle A", minimized: false),
            WindowRef(window_id: "middle-b", app_id: "demo.app", title: "Middle B", minimized: false),
            WindowRef(window_id: "top", app_id: "demo.app", title: "Top", minimized: false)
        ],
        tray: [
            TrayItem(item_id: "clock", label: "09:41", icon: "clock")
        ]
    )

fn _layered_window(surface_id: text, z_index: i32, minimized: bool) -> SharedWmWindow:
    SharedWmWindow(
        surface_id: surface_id,
        window_id: surface_id,
        surface_kind: UI_SURFACE_KIND_SIMPLE_WEB,
        process_id: 1u64,
        app_id: "demo.app",
        title: surface_id,
        language: "und",
        x: 10,
        y: 40,
        width: 300,
        height: 200,
        tree: nil,
        html: "",
        minimized: minimized,
        focused: false,
        z_index: z_index,
        chrome_kind: WM_CHROME_KIND_TITLED
    )

fn _layered_scene() -> SharedWmScene:
    SharedWmScene(
        width: 800,
        height: 600,
        backend: "simple",
        windows: [
            _layered_window("top", 5, false),
            _layered_window("hidden", 2, true),
            _layered_window("bottom", 1, false),
            _layered_window("middle-a", 3, false),
            _layered_window("middle-b", 3, false)
        ],
        background: shared_wm_background_color(wm_chrome_theme().compositor_bg)
    )

fn _sparse_layered_scene() -> SharedWmScene:
    SharedWmScene(
        width: 800,
        height: 600,
        backend: "simple",
        windows: [
            _layered_window("top", 1000000, false),
            _layered_window("middle-a", 500000, false),
            _layered_window("bottom", -1000000, false),
            _layered_window("middle-b", 500000, false),
            _layered_window("hidden", -500000, true)
        ],
        background: shared_wm_background_color(wm_chrome_theme().compositor_bg)
    )

describe "window scene Draw IR z-layer ordering":

    it "orders visible window batches by z-index with stable equal-layer order":
        val composition = shared_wm_scene_draw_ir_composition(_layered_scene(), _taskbar(), DRAW_IR_BACKEND_GPU, 1000, "09:41", 2)

        expect(composition.batches.len()).to_equal(7)
        expect(composition.batches[2].embedding.surface_id).to_equal("bottom")
        expect(composition.batches[3].embedding.surface_id).to_equal("middle-a")
        expect(composition.batches[4].embedding.surface_id).to_equal("middle-b")
        expect(composition.batches[5].embedding.surface_id).to_equal("top")
        expect(composition.batches[6].embedding.component_id).to_equal("wm-taskbar-objects")

    it "orders sparse z-index windows without losing stable equal-layer order":
        val composition = shared_wm_scene_draw_ir_composition(_sparse_layered_scene(), _taskbar(), DRAW_IR_BACKEND_GPU, 1000, "09:41", 2)

        expect(composition.batches.len()).to_equal(7)
        expect(composition.batches[2].embedding.surface_id).to_equal("bottom")
        expect(composition.batches[3].embedding.surface_id).to_equal("middle-a")
        expect(composition.batches[4].embedding.surface_id).to_equal("middle-b")
        expect(composition.batches[5].embedding.surface_id).to_equal("top")
        expect(composition.batches[6].embedding.component_id).to_equal("wm-taskbar-objects")
