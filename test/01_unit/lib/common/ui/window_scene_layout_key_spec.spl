# @cover src/lib/common/ui/window_scene.spl 20%
# @tag: unit, ui, wm, perf

use std.spec
use common.ui.window_surface_registry.{UI_SURFACE_KIND_SIMPLE_WEB}
use common.ui.window_scene.{SharedWmScene, SharedWmWindow, WM_CHROME_KIND_TITLED, shared_wm_background_color, shared_wm_scene_layout_key}
use common.ui.wm_chrome_theme.{wm_chrome_theme}

fn _window(surface_id: text, x: i32, z_index: i32, focused: bool) -> SharedWmWindow:
    SharedWmWindow(
        surface_id: surface_id,
        window_id: surface_id,
        surface_kind: UI_SURFACE_KIND_SIMPLE_WEB,
        process_id: 1u64,
        app_id: "demo.app",
        title: surface_id,
        language: "und",
        x: x,
        y: 40,
        width: 300,
        height: 200,
        tree: nil,
        html: "",
        minimized: false,
        focused: focused,
        z_index: z_index,
        chrome_kind: WM_CHROME_KIND_TITLED
    )

fn _scene(x: i32) -> SharedWmScene:
    SharedWmScene(
        width: 800,
        height: 600,
        backend: "simple",
        windows: [
            _window("surf1", 10, 1, false),
            _window("surf2", x, 2, true)
        ],
        background: shared_wm_background_color(wm_chrome_theme().compositor_bg)
    )

describe "shared WM scene layout key":

    it "keeps exact window-sensitive cache key format":
        val key = shared_wm_scene_layout_key(_scene(80))

        expect(key).to_equal("w=800;h=600;backend=simple;count=2;surf1:surf1:10,40,300,200:z1:minfalse:focusfalse;surf2:surf2:80,40,300,200:z2:minfalse:focustrue")

    it "changes when window geometry changes":
        expect(shared_wm_scene_layout_key(_scene(80))).to_contain("surf2:surf2:80,40,300,200")
        expect(shared_wm_scene_layout_key(_scene(120))).to_contain("surf2:surf2:120,40,300,200")
