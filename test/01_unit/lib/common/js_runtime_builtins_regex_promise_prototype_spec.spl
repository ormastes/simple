use std.spec.*
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.{JsValue}

# Repro for doc/08_tracking/bug/js_engine_missing_builtins_regex_promise_prototype_2026-07-11.md
# 1. String.prototype.replace with a regex literal was a no-op.
# 2. typeof Promise reported "undefined" even though Promise is a working pseudo-global.
# 3. typeof on present prototype methods ([].forEach, ''.replace) reported "undefined".

fn _runtime_eval_text(source: text) -> text:
    val runtime = JsRuntime.new(Logger.new("builtins-gap", LogLevel.Error))
    val result = runtime.eval(source)
    match result:
        Ok(value):
            match value:
                JsValue.String(v): v
                JsValue.Number(v):
                    var s = "{v}"
                    if s.ends_with(".0"):
                        return s.substring(0, s.len() - 2)
                    s
                JsValue.Boolean(v): if v: "true" else: "false"
                JsValue.Undefined: "undefined"
                _: "object"
        Err(err): "error"

describe "JS engine builtin gaps: regex replace, Promise typeof, prototype introspection":
    it "performs regex substitution for String.prototype.replace with a regex literal":
        expect(_runtime_eval_text("'abc'.replace(/b/, 'X')")).to_equal("aXc")

    it "replaces only the first match without the g flag":
        expect(_runtime_eval_text("'abcabc'.replace(/b/, 'X')")).to_equal("aXcabc")

    it "supports character classes and quantifiers in the regex literal":
        expect(_runtime_eval_text("'a1 b22'.replace(/[0-9]+/, 'N')")).to_equal("aN b22")
        expect(_runtime_eval_text("'hello world'.replace(/o/, '0')")).to_equal("hell0 world")

    it "reports typeof Promise as function":
        expect(_runtime_eval_text("typeof Promise")).to_equal("function")

    it "reports typeof on present Array.prototype methods as function":
        expect(_runtime_eval_text("typeof [].forEach")).to_equal("function")
        expect(_runtime_eval_text("typeof [].map")).to_equal("function")

    it "reports typeof on present String.prototype methods as function":
        expect(_runtime_eval_text("typeof ''.replace")).to_equal("function")
        expect(_runtime_eval_text("typeof ''.split")).to_equal("function")

    it "still runs the working reference scripts from the bug report":
        expect(_runtime_eval_text("1 + 2")).to_equal("3")
        expect(_runtime_eval_text("[1,2,3].map(function(n){return n*2;}).join(',')")).to_equal("2,4,6")

# Lane B2 — remaining deferred regex gaps from lane N5 (bac65baa7b1), all
# wired through the existing regex engine at src/lib/common/js/builtins/regexp.spl:
#   (a) chained regex-literal calls /re/.test(x) / /re/.exec(x)
#   (b) .match/.search/.split/.replaceAll + RegExp.prototype.test/.exec
#   (c) new RegExp(pattern, flags)
describe "JS engine regex gaps (lane B2): chained literals, match/search/split/replaceAll, new RegExp":
    it "recognizes a chained regex-literal .test() call (not just whole-expression usage)":
        expect(_runtime_eval_text("/b/.test('abc')")).to_equal("true")
        expect(_runtime_eval_text("/z/.test('abc')")).to_equal("false")

    it "recognizes a chained regex-literal .exec() call and returns the match":
        expect(_runtime_eval_text("/b/.exec('abc')[0]")).to_equal("b")
        expect(_runtime_eval_text("/z/.exec('abc') === null")).to_equal("true")

    it "String.prototype.match consumes a regex literal":
        expect(_runtime_eval_text("'a1 b22'.match(/[0-9]+/)[0]")).to_equal("1")
        expect(_runtime_eval_text("'abc'.match(/z/) === null")).to_equal("true")

    it "String.prototype.search consumes a regex literal":
        expect(_runtime_eval_text("'hello world'.search(/wor/)")).to_equal("6")
        expect(_runtime_eval_text("'hello world'.search(/zzz/)")).to_equal("-1")

    it "String.prototype.split consumes a regex literal":
        expect(_runtime_eval_text("'a1b22c'.split(/[0-9]+/).length")).to_equal("3")
        expect(_runtime_eval_text("'a1b22c'.split(/[0-9]+/)[2]")).to_equal("c")

    it "String.prototype.replaceAll consumes a regex literal":
        expect(_runtime_eval_text("'a1b2c3'.replaceAll(/[0-9]/, 'X')")).to_equal("aXbXcX")

    it "RegExp.prototype.test/.exec work on a regex value stored in a variable":
        expect(_runtime_eval_text("var re = /b/; re.test('abc')")).to_equal("true")
        expect(_runtime_eval_text("var re = /b/; re.exec('abc')[0]")).to_equal("b")

    it "new RegExp(pattern, flags) constructs a working regex value":
        expect(_runtime_eval_text("var re = new RegExp('b', 'i'); re.test('ABC')")).to_equal("true")
        expect(_runtime_eval_text("var re = new RegExp('b', 'gi'); re.source")).to_equal("b")
        expect(_runtime_eval_text("var re = new RegExp('b', 'gi'); re.flags")).to_equal("gi")
        expect(_runtime_eval_text("'abcabc'.replace(new RegExp('b', 'g'), 'X')")).to_equal("aXcaXc")
