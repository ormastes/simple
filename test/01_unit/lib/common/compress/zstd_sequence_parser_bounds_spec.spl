use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.zstd_seq.{_zstd_parse_sequence_count}

fn check(condition: bool):
    expect condition == true

describe "Zstd sequence parser bounds validation":
    it "rejects negative sequence count offsets before indexing":
        val decoded = _zstd_parse_sequence_count([0x00u8], -1, 1)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.TruncatedInput(message):
                check(message.contains("zstd sequences header"))
            _:
                check(false)
