use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.snappy.{try_snappy_decompress}

describe "Snappy length varint bounds validation":
    it "rejects over-wide length varints before decoding payload":
        val data: [u8] = [0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0x00u8]
        val result = try_snappy_decompress(data)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                expect(message).to_contain("varint length")
            _:
                expect(false).to_equal(true)
