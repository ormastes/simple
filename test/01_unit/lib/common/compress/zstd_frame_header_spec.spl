use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.zstd.{zstd_decompress_frame}
use std.common.compress.zstd_frame.{_zstd_parse_frame_header}

fn check(condition: bool):
    expect condition == true

describe "Zstd frame header validation":
    it "rejects the unused frame header bit before later parsing":
        var frame: [u8] = [
            0x28u8, 0xB5u8, 0x2Fu8, 0xFDu8,
            0x10u8
        ]
        val decoded = _zstd_parse_frame_header(frame, 0)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("unused frame header bit"))
            _:
                check(false)

    it "public decompressor rejects the unused frame header bit":
        var frame: [u8] = [
            0x28u8, 0xB5u8, 0x2Fu8, 0xFDu8,
            0x10u8
        ]
        val decoded = zstd_decompress_frame(frame)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("unused frame header bit"))
            _:
                check(false)
