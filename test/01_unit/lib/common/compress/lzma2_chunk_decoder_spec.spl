use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.lzma2_chunk_decoder.{_lzma_decode_chunk, _lzma_decode_chunk_3_0_2}
use std.common.compress.lzma2_range_coder.{LzmaProperties, LzmaState, _lzma_init_probs, LZMA_PROBS_TOTAL}

fn check(condition: bool):
    expect condition == true

fn fresh_state() -> LzmaState:
    LzmaState(state: 0, rep0: 0, rep1: 0, rep2: 0, rep3: 0)

describe "LZMA2 chunk decoder validation":
    it "rejects truncated legacy range decoder bodies":
        var input: [u8] = [0x00u8, 0x00u8, 0x00u8, 0x00u8]
        val decoded = _lzma_decode_chunk_3_0_2(input, 0, input.len(), 1, [], fresh_state(), _lzma_init_probs(LZMA_PROBS_TOTAL), true)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.TruncatedInput(message):
                check(message.contains("range decoder init"))
            _:
                check(false)

    it "rejects truncated parameterized range decoder bodies":
        var input: [u8] = [0x00u8, 0x00u8, 0x00u8, 0x00u8]
        val props = LzmaProperties(lc: 3, lp: 0, pb: 2)
        val decoded = _lzma_decode_chunk(input, 0, input.len(), 1, [], fresh_state(), [], true, props)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.TruncatedInput(message):
                check(message.contains("range decoder init"))
            _:
                check(false)
