use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.lzma2_xz_format.{_xz_read_u32_le, _xz_read_u64_le}

fn expect_truncated_u32(result: Result<u32, CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_truncated_u64(result: Result<u64, CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

describe "XZ little-endian reader bounds validation":
    it "rejects negative u32 offsets before indexing":
        expect_truncated_u32(_xz_read_u32_le([0x01u8, 0x02u8, 0x03u8, 0x04u8], -1), "need 4 bytes")

    it "rejects negative u64 offsets before indexing":
        expect_truncated_u64(_xz_read_u64_le([
            0x01u8, 0x02u8, 0x03u8, 0x04u8,
            0x05u8, 0x06u8, 0x07u8, 0x08u8
        ], -1), "need 8 bytes")
