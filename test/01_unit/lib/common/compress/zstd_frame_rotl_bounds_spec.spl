use std.spec
use std.common.compress.zstd_frame.{_zstd_xxh64_rotl}

describe "Zstd frame xxh64 rotate bounds":
    it "does not shift by 64 for zero-width rotation":
        expect(_zstd_xxh64_rotl(0x123456789ABCDEF0u64, 0u64)).to_equal(0x123456789ABCDEF0u64)

    it "wraps full-width rotation to the original value":
        expect(_zstd_xxh64_rotl(0x123456789ABCDEF0u64, 64u64)).to_equal(0x123456789ABCDEF0u64)

    it "wraps oversized rotation amounts modulo 64":
        expect(_zstd_xxh64_rotl(0x8000000000000001u64, 65u64)).to_equal(0x0000000000000003u64)
