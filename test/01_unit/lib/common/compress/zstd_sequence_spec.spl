use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.zstd.{zstd_execute_sequences_for_test}
use std.common.compress.zstd_types.{ZstdSequence, ZstdRepeatOffsets}

fn check(condition: bool):
    expect condition == true

describe "Zstd sequence execution validation":
    it "rejects non-positive match lengths":
        var base: [u8] = [0x41u8]
        var literals: [u8] = []
        var sequences: [ZstdSequence] = [
            ZstdSequence(literal_length: 0, match_length: 0, offset_value: 4)
        ]
        val history = ZstdRepeatOffsets(rep1: 1, rep2: 4, rep3: 8)
        val decoded = zstd_execute_sequences_for_test(base, literals, sequences, history)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("match length"))
            _:
                check(false)

    it "rejects negative literal lengths before slicing":
        var base: [u8] = [0x41u8]
        var literals: [u8] = []
        var sequences: [ZstdSequence] = [
            ZstdSequence(literal_length: -1, match_length: 3, offset_value: 4)
        ]
        val history = ZstdRepeatOffsets(rep1: 1, rep2: 4, rep3: 8)
        val decoded = zstd_execute_sequences_for_test(base, literals, sequences, history)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("literal length"))
            _:
                check(false)

    it "rejects non-positive offset codes":
        var base: [u8] = [0x41u8]
        var literals: [u8] = []
        var sequences: [ZstdSequence] = [
            ZstdSequence(literal_length: 0, match_length: 3, offset_value: 0)
        ]
        val history = ZstdRepeatOffsets(rep1: 1, rep2: 4, rep3: 8)
        val decoded = zstd_execute_sequences_for_test(base, literals, sequences, history)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.len() > 0)
            _:
                check(false)
