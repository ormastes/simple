use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.zstd_bits.{ZstdBackwardBits, zstd_bits_peek, zstd_bits_remaining}

fn check(condition: bool):
    expect condition == true

describe "Zstd bit reader bounds validation":
    it "rejects malformed refill state before indexing":
        var data: [u8] = [0x80u8]
        val state = ZstdBackwardBits(
            data: data,
            start: 0,
            byte_pos: 4,
            reservoir: 0u64,
            bits_in_reservoir: 0
        )
        val decoded = zstd_bits_peek(state, 1)
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.TruncatedInput(message):
                check(message.contains("bitstream bits"))
            _:
                check(false)

    it "does not count bytes beyond the backing buffer":
        var data: [u8] = [0x80u8]
        val state = ZstdBackwardBits(
            data: data,
            start: 0,
            byte_pos: 4,
            reservoir: 0u64,
            bits_in_reservoir: 3
        )
        check(zstd_bits_remaining(state) == 3)
