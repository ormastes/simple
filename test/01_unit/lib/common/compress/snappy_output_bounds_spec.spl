use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.snappy.{try_snappy_decompress}

fn expect_overrun(result: Result<[u8], CompressionError>):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.CorruptStream(message):
            expect(message).to_contain("length overrun")
        _:
            expect(false).to_equal(true)

describe "Snappy decoded output bounds validation":
    it "rejects literal output that exceeds the declared length before append":
        val data: [u8] = [0x01u8, 0x04u8, 0x41u8, 0x42u8]
        expect_overrun(try_snappy_decompress(data))

    it "rejects copy output that exceeds the declared length before append":
        val data: [u8] = [
            0x05u8,
            0x0Cu8, 0x41u8, 0x42u8, 0x43u8, 0x44u8,
            0x01u8, 0x01u8
        ]
        expect_overrun(try_snappy_decompress(data))
