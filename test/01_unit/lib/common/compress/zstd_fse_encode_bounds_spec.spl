use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.zstd_fse.{ZstdFseEncodeSlot, ZstdFseEncodeTable, _zstd_fse_find_slot}

fn check(condition: bool):
    expect condition == true

fn table_with_slot(bits: i64) -> ZstdFseEncodeTable:
    var bucket: [ZstdFseEncodeSlot] = [ZstdFseEncodeSlot(p: 0, bits: bits, baseline: 0)]
    var slots: [[ZstdFseEncodeSlot]] = [bucket]
    ZstdFseEncodeTable(table_log: 5, slots: slots)

describe "Zstd FSE encode table validation":
    it "rejects negative slot bit widths before shifting":
        val result = _zstd_fse_find_slot(table_with_slot(-1), 0, 0)
        check(result.is_err())
        val err = result.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("slot bits"))
            _:
                check(false)

    it "rejects oversized slot bit widths before shifting":
        val result = _zstd_fse_find_slot(table_with_slot(63), 0, 0)
        check(result.is_err())
        val err = result.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("slot bits"))
            _:
                check(false)
