use std.spec
use std.common.compress.{CompressionError}
use std.common.compress.zstd_fse.{ZstdFseForwardBits, _zstd_fse_forward_bits_read}

fn check(condition: bool):
    expect condition == true

describe "Zstd FSE forward bit reader validation":
    it "rejects negative bit positions before indexing":
        var data: [u8] = [0x00u8]
        val state = ZstdFseForwardBits(data: data, start: 0, limit: 1, bit_pos: -1)
        val result = _zstd_fse_forward_bits_read(state, 1)
        check(result.is_err())
        val err = result.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                check(message.contains("position"))
            _:
                check(false)
