# Tests for src/lib/common/math/math.spl (import path: std.math.math)
#
# Note: libm-backed extern fn wrappers (rt_math_sin, rt_math_cos, etc.) require
# a bootstrap rebuild to resolve in interpreter mode. These tests only verify
# the pure-Simple pass-through layer works structurally.
# Numeric correctness of libm functions is assumed from the C implementation.
#
# Pure-Simple helpers (gcd, clamp, abs_i64, min, max) are tested via std.math
# (the existing math_comprehensive_spec.spl covers those).

use std.math.math.{math_sin, math_cos, math_sqrt, math_pow, math_exp}
use std.math.math.{math_abs, math_trunc, math_round}

describe "std.math.math (transcendental SFFI wrappers)":
    context "math_sqrt":
        it "sqrt of 4 is 2":
            val res = math_sqrt(4.0)
            expect res == 2.0

        it "sqrt of 1 is 1":
            val res = math_sqrt(1.0)
            expect res == 1.0

        it "sqrt of 0 is 0":
            val res = math_sqrt(0.0)
            expect res == 0.0

    context "math_pow":
        it "2 raised to 3 is 8":
            val res = math_pow(2.0, 3.0)
            expect res == 8.0

        it "anything to power 0 is 1":
            val res = math_pow(5.0, 0.0)
            expect res == 1.0

    context "math_abs":
        it "abs of negative is positive":
            val res = math_abs(-3.5)
            expect res == 3.5

        it "abs of positive is unchanged":
            val res = math_abs(3.5)
            expect res == 3.5

        it "abs of zero is zero":
            val res = math_abs(0.0)
            expect res == 0.0

    context "math_trunc":
        it "truncates positive":
            val res = math_trunc(3.9)
            expect res == 3.0

        it "truncates negative toward zero":
            val res = math_trunc(-3.9)
            expect res == -3.0

    context "math_round":
        it "rounds half up":
            val res = math_round(2.5)
            expect res == 3.0

        it "rounds down when below half":
            val res = math_round(2.4)
            expect res == 2.0

        it "rounds negative half away from zero":
            val res = math_round(-2.5)
            expect res == -3.0
