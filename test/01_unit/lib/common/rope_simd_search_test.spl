# Rope SIMD Search Wiring Tests

use std.spec.{describe, it, expect}
use common.rope.types.{rope_length}
use common.rope.utilities.{rope_to_string, rope_to_upper, rope_to_lower}
use common.rope.search.{
    rope_find, rope_find_all, rope_contains,
    rope_starts_with, rope_ends_with, rope_equals
}

fn leaf(s: text) -> any:
    ("leaf", s.len(), nil, nil, s)

fn concat(left: any, right: any) -> any:
    ("concat", rope_length(left), left, right, nil)

describe "rope search delegates to optimized string core":
    it "preserves first search and contains semantics":
        val rope = concat(leaf("Hello "), leaf("世界 😀 world"))
        expect rope_find(rope, "世界") == 6
        expect rope_find(rope, "missing") == -1
        expect rope_contains(rope, "😀") == true
        expect rope_contains(rope, "xyz") == false

    it "preserves prefix suffix and equality semantics":
        val rope = concat(leaf("prefix-"), leaf("middle-suffix"))
        val same = leaf("prefix-middle-suffix")
        val different = leaf("prefix-middle-other")

        expect rope_starts_with(rope, "prefix") == true
        expect rope_starts_with(rope, "middle") == false
        expect rope_ends_with(rope, "suffix") == true
        expect rope_ends_with(rope, "prefix") == false
        expect rope_equals(rope, same) == true
        expect rope_equals(rope, different) == false

    it "preserves find-all byte offsets":
        val rope = leaf("ababa")
        val matches = rope_find_all(rope, "aba")
        expect matches.len() == 1
        expect matches[0] == 0

    it "preserves case conversion semantics":
        val rope = leaf("Hello café")
        expect rope_to_string(rope_to_upper(rope)) == "HELLO CAFé"
        expect rope_to_string(rope_to_lower(leaf("HELLO CAFé"))) == "hello café"
