use std.spec.*
use common.text.{escape_json}
use lib.json.parser.{json_parse_with_error}

describe "common JSON string escaping":
    it "escapes every JSON control family":
        val escaped = escape_json("a\b\f\u0001z")
        expect(escaped).to_equal("a\\b\\f\\u0001z")
        val parsed = json_parse_with_error("{\"value\":\"{escaped}\"}")
        expect(parsed.1).to_equal("")
