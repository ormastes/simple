use std.spec.{describe, it, assert_equal}
use std.encoding.msgpack.{msgpack_encode_str}

describe "MessagePack encode string guards":
    it "rejects characters outside byte range":
        val text_value = 256.chr()
        val result = msgpack_encode_str(text_value)
        assert_equal(result.len(), 0)

    it "keeps empty string encoding":
        val result = msgpack_encode_str("")
        assert_equal(result.len(), 1)
        assert_equal(result[0].to_i64(), 0xA0)
