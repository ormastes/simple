use std.spec.{describe, it, assert_equal}
use std.common.encoding.utf16.{utf16_decode_one}

describe "utf16 decode unit guards":
    it "keeps valid unit decode":
        assert_equal(utf16_decode_one([0x41], 0), [0x41, 1])

    it "rejects negative code units":
        assert_equal(utf16_decode_one([-1], 0), [0xFFFD, 1])

    it "rejects code units above 16 bits":
        assert_equal(utf16_decode_one([0x10041], 0), [0xFFFD, 1])

    it "rejects malformed low surrogate units":
        assert_equal(utf16_decode_one([0xD83D, 0x1DE00], 0), [0xFFFD, 1])
