use std.common.encoding.sfnt.{_sfnt_utf16be_text}

fn main() -> i64:
    val ascii: [u8] = [0u8, 0x4eu8, 0u8, 0x6fu8, 0u8, 0x74u8, 0u8, 0x6fu8]
    val ascii_text = _sfnt_utf16be_text(ascii, 0, ascii.len() as i64)
    if ascii_text == None:
        return 1
    if ascii_text.? != "Noto":
        return 3
    val unicode: [u8] = [0x4eu8, 0x2du8, 0xd8u8, 0x3du8, 0xdeu8, 0u8]
    val unicode_text = _sfnt_utf16be_text(unicode, 0, unicode.len() as i64)
    if unicode_text == None:
        return 2
    if unicode_text.? != "中😀":
        return 4
    0
