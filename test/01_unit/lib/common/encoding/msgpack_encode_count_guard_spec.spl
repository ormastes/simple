use std.spec.{describe, it, assert_equal}
use std.encoding.msgpack.{msgpack_encode_array_header, msgpack_encode_map_header}

describe "MessagePack encode count guards":
    it "rejects negative array header counts":
        val result = msgpack_encode_array_header(-1)
        assert_equal(result.len(), 0)

    it "rejects negative map header counts":
        val result = msgpack_encode_map_header(-1)
        assert_equal(result.len(), 0)

    it "rejects collection counts that exceed uint32":
        val array_result = msgpack_encode_array_header(4294967296)
        val map_result = msgpack_encode_map_header(4294967296)
        assert_equal(array_result.len(), 0)
        assert_equal(map_result.len(), 0)

    it "keeps valid zero and positive count headers":
        val array_zero = msgpack_encode_array_header(0)
        val map_zero = msgpack_encode_map_header(0)
        val array_one = msgpack_encode_array_header(1)
        val map_one = msgpack_encode_map_header(1)
        assert_equal(array_zero[0], 0x90)
        assert_equal(map_zero[0], 0x80)
        assert_equal(array_one[0], 0x91)
        assert_equal(map_one[0], 0x81)
