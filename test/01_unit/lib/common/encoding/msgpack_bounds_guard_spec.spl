use std.spec.{describe, it, assert_equal}
use std.encoding.msgpack.{msgpack_decode_type, msgpack_decode_int, msgpack_decode_str}

describe "MessagePack decode bounds guards":
    it "rejects negative decode positions":
        val r = msgpack_decode_int([0x01], -1)
        assert_equal(r[0], -1)
        assert_equal(r[1], -1)

    it "rejects truncated multi-byte integer payloads":
        val r = msgpack_decode_int([0xCD, 0x01], 0)
        assert_equal(r[0], -1)
        assert_equal(r[1], 0)

    it "rejects truncated type headers":
        val r = msgpack_decode_type([0xDA, 0x00], 0)
        assert_equal(r[0], 0xFF)
        assert_equal(r[1], -1)
        assert_equal(r[2], 0)

    it "rejects truncated binary type headers":
        val bin8 = msgpack_decode_type([0xC4], 0)
        val bin16 = msgpack_decode_type([0xC5, 0x00], 0)
        assert_equal(bin8[0], 0xFF)
        assert_equal(bin8[1], -1)
        assert_equal(bin16[0], 0xFF)
        assert_equal(bin16[1], -1)

    it "rejects truncated collection type headers":
        val array16 = msgpack_decode_type([0xDC, 0x00], 0)
        val map16 = msgpack_decode_type([0xDE, 0x00], 0)
        assert_equal(array16[0], 0xFF)
        assert_equal(array16[1], -1)
        assert_equal(map16[0], 0xFF)
        assert_equal(map16[1], -1)

    it "rejects truncated string payloads":
        val r = msgpack_decode_str([0xA3, 0x61], 0)
        assert_equal(r[0], "")
        assert_equal(r[1], 0)

    it "keeps valid int and string decodes":
        val i = msgpack_decode_int([0x2A], 0)
        assert_equal(i[0], 42)
        val s = msgpack_decode_str([0xA0], 0)
        assert_equal(s[0], "")
