use std.spec.{describe, it, expect}
use std.common.encoding.font_registry.{selected_font_asset_candidates, selected_font_asset_candidate_for_path, validate_selected_font_asset, selected_font_language_ranking_source, font_language_ranking_evidence, selected_font_language_ranks, selected_font_coverage_languages, selected_font_coverage_categories, selected_font_coverage_matrix, selected_font_coverage_cell}
use std.nogc_sync_mut.sffi.io.{file_exists, file_read_bytes}

describe "selected font asset manifest":
    it "validates selected runtime assets in deterministic fail-fast order":
        val unmanaged = validate_selected_font_asset("tmp/unmanaged.ttf", [])
        expect(unmanaged.selected).to_be(false)
        expect(unmanaged.valid).to_be(true)
        expect(unmanaged.family).to_equal("")
        expect(unmanaged.reason).to_equal("unmanaged")

        val assets = selected_font_asset_candidates()
        var asset_index: i64 = 0
        while asset_index < assets.len():
            val asset = assets[asset_index]
            val result = validate_selected_font_asset(asset.local_path, file_read_bytes(asset.local_path))
            expect(result.selected).to_be(true)
            expect(result.valid).to_be(true)
            expect(result.family).to_equal(asset.family)
            expect(result.reason).to_equal("valid")
            asset_index = asset_index + 1
        val static_asset = assets[13]
        val static_blob = file_read_bytes(static_asset.local_path)
        expect(selected_font_asset_candidate_for_path(static_asset.local_path).?.family).to_equal(static_asset.family)
        expect(selected_font_asset_candidate_for_path("tmp/unmanaged.ttf")).to_be_nil()
        expect(validate_selected_font_asset(static_asset.local_path, []).reason).to_equal("byte-length")

        var malformed = static_blob
        malformed[malformed.len() - 1] = (malformed[malformed.len() - 1].to_i64() ^ 1).to_u8()
        expect(validate_selected_font_asset(static_asset.local_path, malformed).reason).to_equal("sha256")

        val valid = validate_selected_font_asset(static_asset.local_path, static_blob)
        expect(valid.selected).to_be(true)
        expect(valid.valid).to_be(true)
        expect(valid.family).to_equal("UnifrakturCook")
        expect(valid.reason).to_equal("valid")

    it "pins the deterministic CLDR top ten and eleventh-place boundary":
        val source = selected_font_language_ranking_source()
        val selected = selected_font_language_ranks()
        val evidence = font_language_ranking_evidence()
        expect(source.release).to_equal("release-48-2")
        expect(source.source_commit).to_equal("11299982335beb974c1c63c45265184e759c0f41")
        expect(source.supplemental_data_sha256.len()).to_equal(64)
        expect(selected.len()).to_equal(10)
        expect(evidence.len()).to_equal(11)
        expect(selected[0].language).to_equal("en")
        expect(selected[8].language).to_equal("ur")
        expect(selected[9].language).to_equal("id")
        expect(evidence[10].language).to_equal("bn")
        expect(selected[9].literate_functional_total).to_be_greater_than(evidence[10].literate_functional_total)

    it "pins sixteen unchanged candidates with immutable acquisition metadata":
        val assets = selected_font_asset_candidates()
        expect(assets.len()).to_equal(16)
        var total_bytes: i64 = 0
        var paths = "|"
        var hashes = "|"
        var i: i64 = 0
        while i < assets.len():
            val asset = assets[i]
            expect(asset.upstream_repository).to_equal("https://github.com/google/fonts")
            expect(asset.upstream_revision).to_equal("ec0464b978de222073645d6d3366f3fdf03376d8")
            expect(asset.sha256.len()).to_equal(64)
            expect(asset.byte_len).to_be_greater_than(0)
            expect(asset.upstream_path).to_end_with(".ttf")
            expect(asset.local_path).to_start_with("assets/fonts/google-fonts/")
            expect(file_exists(asset.local_path)).to_be(true)
            expect(asset.metadata_path).to_end_with("/METADATA.pb")
            expect(asset.modification_state).to_equal("unchanged")
            expect(asset.coverage_state.len()).to_be_greater_than(0)
            expect(asset.embedded_style.len()).to_be_greater_than(0)
            expect(asset.embedded_full_name.len()).to_be_greater_than(0)
            expect(asset.embedded_postscript_name.len()).to_be_greater_than(0)
            expect(asset.embedded_version).to_start_with("Version ")
            expect(asset.default_axes.len()).to_be_greater_than(0)
            expect(asset.coverage_corpus_ref).to_contain("CORPUS.sdn#sha256:")
            expect(asset.fallback_role.len()).to_be_greater_than(0)
            expect(paths.contains("|" + asset.upstream_path + "|")).to_be(false)
            expect(hashes.contains("|" + asset.sha256 + "|")).to_be(false)
            paths = paths + asset.upstream_path + "|"
            hashes = hashes + asset.sha256 + "|"
            total_bytes = total_bytes + asset.byte_len
            i = i + 1
        expect(total_bytes).to_equal(51764704)
        expect(total_bytes).to_be_less_than(80 * 1024 * 1024 + 1)
        expect(assets[0].embedded_full_name).to_equal("Noto Sans SC Thin")
        expect(assets[0].embedded_postscript_name).to_equal("NotoSansSC-Thin")
        expect(assets[0].default_axes).to_equal("wght=100")
        expect(assets[2].default_axes).to_equal("wght=400,wdth=100")
        expect(assets[13].embedded_full_name).to_equal("UnifrakturCook")
        expect(assets[13].embedded_version).to_equal("Version 2011-09-01 ")
        expect(assets[15].fallback_role).to_equal("common-emoji-fallback")

    it "covers every selected sparse category exactly once or more":
        val assets = selected_font_asset_candidates()
        val categories = "|sans|serif|mono|display|rounded|handwriting|slab|blackletter|pixel|emoji|"
        var seen = "|"
        var i: i64 = 0
        while i < assets.len():
            val marker = "|" + assets[i].category + "|"
            expect(categories).to_contain(marker)
            if not seen.contains(marker):
                seen = seen + assets[i].category + "|"
            i = i + 1
        expect(seen).to_equal(categories)

    it "provides exactly one valid status for every selected language-category cell":
        val languages = selected_font_coverage_languages()
        val categories = selected_font_coverage_categories()
        val cells = selected_font_coverage_matrix()
        expect(languages.len()).to_equal(10)
        expect(categories.len()).to_equal(10)
        expect(cells.len()).to_equal(100)
        var seen = "|"
        var native_count: i64 = 0
        var fallback_count: i64 = 0
        var not_designed_count: i64 = 0
        var unavailable_count: i64 = 0
        var i: i64 = 0
        while i < cells.len():
            val cell = cells[i]
            val key = "|" + cell.language + ":" + cell.category + "|"
            val allowed = "|native|fallback|not-designed-for-script|unavailable|"
            expect(seen.contains(key)).to_be(false)
            expect(allowed).to_contain("|" + cell.status + "|")
            seen = seen + cell.language + ":" + cell.category + "|"
            if cell.status == "native": native_count = native_count + 1
            elif cell.status == "fallback": fallback_count = fallback_count + 1
            elif cell.status == "not-designed-for-script": not_designed_count = not_designed_count + 1
            elif cell.status == "unavailable": unavailable_count = unavailable_count + 1
            i = i + 1
        expect(native_count).to_equal(0)
        expect(fallback_count).to_equal(0)
        expect(not_designed_count).to_equal(26)
        expect(unavailable_count).to_equal(74)
        expect(cells[10].status).to_equal("unavailable")
        expect(cells[32].status).to_equal("unavailable")
        expect(cells[73].status).to_equal("not-designed-for-script")
        expect(cells[81].status).to_equal("unavailable")
        expect(cells[9].status).to_equal("unavailable")

    it "resolves selected coverage policy and rejects unknown axes":
        val unavailable = selected_font_coverage_cell("en", "sans")
        val not_designed = selected_font_coverage_cell("zh", "display")

        expect(unavailable != nil).to_be(true)
        expect(unavailable.?.status).to_equal("unavailable")
        expect(not_designed != nil).to_be(true)
        expect(not_designed.?.status).to_equal("not-designed-for-script")
        expect(selected_font_coverage_cell("xx", "sans")).to_be_nil()
        expect(selected_font_coverage_cell("en", "unknown")).to_be_nil()
