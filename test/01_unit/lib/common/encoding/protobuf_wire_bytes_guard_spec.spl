use std.spec.{describe, it, assert_equal}
use std.common.encoding.protobuf_wire.{pb_encode_bytes_field}

describe "Protobuf wire bytes field guards":
    it "rejects invalid bytes field numbers":
        assert_equal(pb_encode_bytes_field(0, [65]).len(), 0)
        assert_equal(pb_encode_bytes_field(-1, [65]).len(), 0)
        assert_equal(pb_encode_bytes_field(536870912, [65]).len(), 0)

    it "rejects invalid byte payload values":
        assert_equal(pb_encode_bytes_field(1, [-1]).len(), 0)
        assert_equal(pb_encode_bytes_field(1, [256]).len(), 0)

    it "keeps valid bytes field encoding":
        val result = pb_encode_bytes_field(1, [65, 66])
        assert_equal(result.len(), 4)
        assert_equal(result[0], 0x0A)
        assert_equal(result[1], 2)
        assert_equal(result[2], 65)
        assert_equal(result[3], 66)
