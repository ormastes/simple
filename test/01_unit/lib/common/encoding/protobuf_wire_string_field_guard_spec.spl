use std.spec.{describe, it, assert_equal}
use std.common.encoding.protobuf_wire.{pb_encode_string}

describe "Protobuf wire string field guards":
    it "rejects invalid string field numbers":
        assert_equal(pb_encode_string(0, "A").len(), 0)
        assert_equal(pb_encode_string(-1, "A").len(), 0)
        assert_equal(pb_encode_string(536870912, "A").len(), 0)

    it "rejects characters outside byte range":
        val text_value = 256.chr()
        assert_equal(pb_encode_string(1, text_value).len(), 0)

    it "keeps empty string field encoding":
        val result = pb_encode_string(1, "")
        assert_equal(result.len(), 2)
        assert_equal(result[0], 10)
        assert_equal(result[1], 0)
