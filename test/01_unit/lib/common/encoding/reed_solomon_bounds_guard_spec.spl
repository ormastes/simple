use std.spec.{describe, it, assert_equal}
use std.common.encoding.reed_solomon.{rs_encode, rs_decode}

describe "Reed-Solomon bounds guards":
    it "rejects negative parity during encode":
        val data: [u8] = [1, 2, 3]
        val result = rs_encode(data, -1)
        assert_equal(result.is_err(), true)

    it "rejects negative parity during decode":
        val received: [u8] = [1, 2, 3]
        val erasures: [i64] = []
        val result = rs_decode(received, -1, erasures)
        assert_equal(result.is_err(), true)

    it "keeps valid parity counts":
        val data: [u8] = [1, 2, 3]
        val result = rs_encode(data, 1)
        assert_equal(result.is_ok(), true)
