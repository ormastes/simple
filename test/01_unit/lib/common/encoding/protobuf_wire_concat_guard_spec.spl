use std.spec.{describe, it, assert_equal}
use std.common.encoding.protobuf_wire.{pb_bytes_concat}

describe "Protobuf wire byte concat guards":
    it "rejects invalid bytes in either input":
        assert_equal(pb_bytes_concat([-1], [1]).len(), 0)
        assert_equal(pb_bytes_concat([1], [256]).len(), 0)

    it "keeps valid byte concatenation":
        val result = pb_bytes_concat([1, 2], [3])
        assert_equal(result.len(), 3)
        assert_equal(result[0], 1)
        assert_equal(result[1], 2)
        assert_equal(result[2], 3)
