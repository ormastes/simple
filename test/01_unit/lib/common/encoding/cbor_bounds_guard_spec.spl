use std.spec.{describe, it, assert_equal}
use std.common.encoding.cbor.{cbor_decode_type, cbor_decode_text, cbor_decode_bytes, cbor_decode}

describe "CBOR decoder bounds guards":
    it "rejects negative decode offsets":
        val data: [u8] = [0x00]
        val decoded = cbor_decode_type(data, -1)
        assert_equal(decoded[3], 0)

    it "rejects truncated text payloads":
        val data: [u8] = [0x62, 0x41]
        val decoded = cbor_decode_text(data, 0)
        assert_equal(decoded[0], "")
        assert_equal(decoded[1], 0)
        val value_result = cbor_decode(data, 0)
        assert_equal(value_result.1, 0)

    it "rejects truncated byte payloads":
        val data: [u8] = [0x42, 0x01]
        val decoded = cbor_decode_bytes(data, 0)
        assert_equal(decoded.len(), 0)
        val value_result = cbor_decode(data, 0)
        assert_equal(value_result.1, 0)
