use std.spec.{describe, it, assert_equal}
use std.common.encoding.protobuf_wire.{pb_bytes_to_text}

describe "Protobuf wire text conversion guards":
    it "rejects out of range text slices":
        assert_equal(pb_bytes_to_text([65], 0, 2), "")
        assert_equal(pb_bytes_to_text([65], -1, 1), "")
        assert_equal(pb_bytes_to_text([65], 0, -1), "")

    it "rejects invalid byte values":
        assert_equal(pb_bytes_to_text([65, 300], 0, 2), "")
        assert_equal(pb_bytes_to_text([-1], 0, 1), "")

    it "keeps valid byte conversion":
        assert_equal(pb_bytes_to_text([65, 66], 0, 2), "AB")
