use std.spec.{describe, it, assert_equal}
use std.common.base_encoding.{bytes_to_text}

describe "base encoding facade UTF-8 byte guards":
    it "keeps valid multi-byte UTF-8":
        assert_equal(bytes_to_text([0xC3, 0xA9]), "é")

    it "rejects invalid continuation bytes":
        assert_equal(bytes_to_text([0xC3, 0x41]), "�A")

    it "rejects out-of-range leading bytes":
        assert_equal(bytes_to_text([0xFF, 0xBF, 0xBF, 0xBF]), "����")
