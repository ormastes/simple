# @cover src/lib/nogc_sync_mut/text_layout/font_rasterizer.spl 70%
# @tag: unit, ui, font, gpu, offload
#
# Bitmap-font GPU offload parity spec.
#
# Mirrors the vector-font ROCm payload test: a bitmap glyph rasterized on a GPU
# backend is published through the `{PREFIX}_BITMAP_FONT_*` env transport. The
# discriminating property is payload-gating:
#   - with NO payload  -> CPU fallback (gpu_returned_glyphs == 0, cpu_fallback > 0)
#   - with a payload   -> GPU stats     (gpu_returned_glyphs == 1, cpu_fallback == 0)
# If the implementation reported GPU offload regardless of payload it would be a
# cover-up; this spec fails in that case.

use std.spec.{describe, it, expect}
use common.text_layout.font_renderer.{FontRenderer}
use common.text_layout.font_rasterizer.{
    reset_bitmap_font_raster_stats,
    bitmap_font_accelerator_stats,
    rasterize_bitmap
}

extern fn rt_env_set(key: text, value: text) -> bool

# Local replica of font_rasterizer `_vector_font_pixels_checksum` (private there).
fn _bitmap_checksum(pixels: [u8], width: i32, height: i32, advance: i32) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        val alpha = pixels[i].to_i32().to_i64()
        if alpha > 0:
            sum = sum + alpha * ((i + 1) as i64)
        i = i + 1
    sum + (width.to_i64() * 31) + (height.to_i64() * 17) + advance.to_i64()

fn _clear_rocm_bitmap_glyph_payload():
    rt_env_set("ROCM_BITMAP_FONT_STATUS", "")
    rt_env_set("ROCM_BITMAP_FONT_REASON", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_COUNT", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_CODEPOINT", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_FONT_SIZE", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_WIDTH", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_HEIGHT", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_ADVANCE", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_PIXELS", "")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_CHECKSUM", "")

fn _set_rocm_bitmap_glyph_payload():
    var px: [u8] = [255u8, 0u8, 0u8, 255u8]
    val checksum = _bitmap_checksum(px, 2, 2, 3)
    rt_env_set("ROCM_BITMAP_FONT_STATUS", "pass")
    rt_env_set("ROCM_BITMAP_FONT_REASON", "rocm-bitmap-font-glyph-pixels-returned")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_COUNT", "1")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_CODEPOINT", "66")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_FONT_SIZE", "16")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_WIDTH", "2")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_HEIGHT", "2")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_ADVANCE", "3")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_PIXELS", "255,0,0,255")
    rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_CHECKSUM", checksum.to_text())

describe "bitmap font GPU offload":
    it "keeps the built-in monochrome VGA glyph deterministic":
        val glyph = rasterize_bitmap(65, 16)
        expect(glyph.width).to_equal(8)
        expect(glyph.height).to_equal(16)
        expect(glyph.advance).to_equal(8)
        expect(glyph.pixels.len()).to_equal(128)
        expect(_bitmap_checksum(glyph.pixels, glyph.width, glyph.height, glyph.advance)).to_equal(563568)

    it "falls back to CPU when no GPU payload is present":
        _clear_rocm_bitmap_glyph_payload()
        reset_bitmap_font_raster_stats()
        var renderer = FontRenderer.new()
        renderer.use_vector = false
        renderer.use_bitmap = true

        val glyph = renderer.get_glyph(65, 16)
        val stats = bitmap_font_accelerator_stats()

        expect(glyph.width).to_be_greater_than(0)
        expect(stats.gpu_returned_glyphs).to_equal(0)
        expect(stats.cpu_fallback_hits).to_be_greater_than(0)
        expect(stats.unavailable_reason).to_equal("production-gpu-dispatch-not-wired")

    it "accepts a ROCm bitmap glyph payload before CPU fallback":
        _clear_rocm_bitmap_glyph_payload()
        reset_bitmap_font_raster_stats()
        _set_rocm_bitmap_glyph_payload()
        var renderer = FontRenderer.new()
        renderer.use_vector = false
        renderer.use_bitmap = true

        val glyph = renderer.get_glyph(66, 16)
        val stats = bitmap_font_accelerator_stats()

        expect(glyph.width).to_equal(2)
        expect(glyph.height).to_equal(2)
        expect(glyph.advance).to_equal(3)
        expect(glyph.pixels[0].to_i32()).to_equal(255)
        expect(glyph.pixels[1].to_i32()).to_equal(0)
        expect(stats.gpu_returned_glyphs).to_equal(1)
        expect(stats.gpu_returned_glyph_pixels).to_equal(4)
        expect(stats.cpu_fallback_hits).to_equal(0)
        expect(stats.unavailable_reason).to_equal("rocm-bitmap-font-glyph-pixels-returned")
        _clear_rocm_bitmap_glyph_payload()

    it "rejects a payload whose checksum does not match (anti-spoof)":
        _clear_rocm_bitmap_glyph_payload()
        reset_bitmap_font_raster_stats()
        _set_rocm_bitmap_glyph_payload()
        # Corrupt the checksum so the payload must be rejected.
        rt_env_set("ROCM_BITMAP_FONT_GLYPH_0_CHECKSUM", "1")
        var renderer = FontRenderer.new()
        renderer.use_vector = false
        renderer.use_bitmap = true

        val glyph = renderer.get_glyph(66, 16)
        val stats = bitmap_font_accelerator_stats()

        expect(stats.gpu_returned_glyphs).to_equal(0)
        expect(stats.cpu_fallback_hits).to_be_greater_than(0)
        _clear_rocm_bitmap_glyph_payload()
