use std.spec.{describe, it, expect}
use common.text_layout.font_renderer.{
    browser_chrome_compatible_normal_font_name,
    browser_chrome_compatible_normal_font_path,
    browser_chrome_compatible_vector_font_name,
    CachedGlyph, GlyphCache, FontRenderer, browser_font_download_script_path, browser_font_face_source_urls,
    browser_font_face_family_value, browser_font_face_source_from_family_value,
    browser_font_cache_dir, browser_font_face_cached_source_path, ensure_browser_font_face_sources,
    browser_font_candidates_for_family, browser_mono_font_candidates,
    browser_provided_font_paths, browser_sans_font_candidates,
    browser_serif_font_candidates,
    ensure_browser_provided_fonts}
use common.text_layout.font_rasterizer.{reset_vector_font_raster_stats, vector_font_accelerator_stats}

extern fn rt_env_set(key: text, value: text) -> bool

fn _count_nonzero_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        if alpha.to_i32() > 0:
            count = count + 1
    count

fn _count_full_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        if alpha.to_i32() == 255:
            count = count + 1
    count

fn _count_partial_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        val a = alpha.to_i32()
        if a > 0 and a < 255:
            count = count + 1
    count

fn _count_painted_pixels(pixels: [u32], bg: u32) -> i32:
    var count = 0
    for pixel in pixels:
        if pixel != bg:
            count = count + 1
    count

fn _count_antialiased_argb_pixels(pixels: [u32], bg: u32, fg: u32) -> i32:
    var count = 0
    for pixel in pixels:
        if pixel != bg and pixel != fg:
            count = count + 1
    count

fn _vector_payload_checksum(pixels: [u8], width: i32, height: i32, advance: i32) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        val alpha = pixels[i].to_i32().to_i64()
        if alpha > 0:
            sum = sum + alpha * ((i + 1) as i64)
        i = i + 1
    sum + (width.to_i64() * 31) + (height.to_i64() * 17) + advance.to_i64()

fn _set_rocm_vector_glyph_payload():
    val pixels = [0u8, 64u8, 128u8, 255u8, 0u8, 32u8]
    val checksum = _vector_payload_checksum(pixels, 3, 2, 4)
    rt_env_set("ROCM_VECTOR_FONT_STATUS", "pass")
    rt_env_set("ROCM_VECTOR_FONT_REASON", "rocm-vector-font-glyph-pixels-returned")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_COUNT", "1")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CODEPOINT", "65")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_FONT_SIZE", "24")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_WIDTH", "3")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_HEIGHT", "2")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_ADVANCE", "4")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_PIXELS", "0,64,128,255,0,32")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CHECKSUM", checksum.to_text())

fn _clear_rocm_vector_glyph_payload():
    rt_env_set("ROCM_VECTOR_FONT_STATUS", "")
    rt_env_set("ROCM_VECTOR_FONT_REASON", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_COUNT", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CODEPOINT", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_FONT_SIZE", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_WIDTH", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_HEIGHT", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_ADVANCE", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_PIXELS", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CHECKSUM", "")

describe "shared font renderer fallbacks":
    it "renders vector glyph coverage with antialiasing evidence":
        var renderer = FontRenderer.new()
        renderer.use_bitmap = false

        val glyph = renderer.get_glyph(65, 24)

        expect(glyph.width).to_be_greater_than(0)
        expect(glyph.height).to_equal(24)
        expect(_count_nonzero_alpha(glyph.pixels)).to_be_greater_than(0)
        expect(_count_partial_alpha(glyph.pixels)).to_be_greater_than(0)

    it "accepts ROCm vector font glyph payloads before CPU fallback":
        _clear_rocm_vector_glyph_payload()
        reset_vector_font_raster_stats()
        _set_rocm_vector_glyph_payload()
        var renderer = FontRenderer.new()
        renderer.use_bitmap = false

        val glyph = renderer.get_glyph(65, 24)
        val stats = vector_font_accelerator_stats()

        expect(glyph.width).to_equal(3)
        expect(glyph.height).to_equal(2)
        expect(glyph.advance).to_equal(4)
        expect(glyph.pixels[1]).to_equal(64u8)
        expect(stats.gpu_returned_glyphs).to_equal(1)
        expect(stats.gpu_returned_glyph_pixels).to_equal(6)
        expect(stats.cpu_fallback_hits).to_equal(0)
        expect(stats.unavailable_reason).to_equal("rocm-vector-font-glyph-pixels-returned")
        _clear_rocm_vector_glyph_payload()

    it "renders Simple Vector Outline glyphs into an ARGB buffer":
        var renderer = FontRenderer.new()
        renderer.use_bitmap = false
        val bg = 0xFFFFFFFFu32
        val fg = 0xFF000000u32
        val buffer = [bg; 40 * 32]

        val rendered = renderer.render_text(buffer, 40, 32, 2, 3, "A", fg, 24)

        expect(_count_painted_pixels(rendered, bg)).to_be_greater_than(0)
        expect(_count_antialiased_argb_pixels(rendered, bg, fg)).to_be_greater_than(0)

    it "renders bitmap glyph fallback with exact mask evidence":
        var renderer = FontRenderer.new()
        renderer.use_vector = false

        val glyph = renderer.get_glyph(65, 16)

        expect(glyph.width).to_equal(8)
        expect(glyph.height).to_equal(16)
        expect(_count_nonzero_alpha(glyph.pixels)).to_be_greater_than(0)
        expect(_count_full_alpha(glyph.pixels)).to_be_greater_than(0)

    it "keeps Chrome-compatible serif font candidates ahead of fallback fonts":
        val candidates = browser_serif_font_candidates()
        expect(candidates[0]).to_equal(browser_chrome_compatible_normal_font_path())
        expect(candidates[1]).to_equal("examples/09_embedded/simple_os/fonts/serif/NotoSerif-Regular.ttf")
        expect(candidates[2]).to_equal("examples/09_embedded/simple_os/fonts/serif/NotoSerifSC-Regular.otf")

    it "keeps provided browser sans and mono candidates ahead of host fallbacks":
        val sans = browser_sans_font_candidates()
        val mono = browser_mono_font_candidates()
        expect(sans[0]).to_equal("examples/09_embedded/simple_os/fonts/sans/NotoSans-Regular.ttf")
        expect(sans[1]).to_equal("/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf")
        expect(mono[0]).to_equal("examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf")
        expect(mono[1]).to_equal("/usr/share/fonts/truetype/liberation/LiberationMono-Regular.ttf")

    it "maps browser CSS font-family names to provided font lanes":
        expect(browser_font_candidates_for_family("monospace")[0]).to_equal("examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf")
        expect(browser_font_candidates_for_family("'Fira Code', monospace")[0]).to_equal("examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf")
        expect(browser_font_candidates_for_family("Arial, sans-serif")[0]).to_equal("examples/09_embedded/simple_os/fonts/sans/NotoSans-Regular.ttf")
        expect(browser_font_candidates_for_family("system")[0]).to_equal(browser_chrome_compatible_normal_font_path())
        expect(browser_font_candidates_for_family("Times New Roman, serif")[0]).to_equal(browser_chrome_compatible_normal_font_path())

    it "defaults unspecified text to Fira Code Nerd mono":
        # Unspecified / unmatched family falls back to Fira Code Nerd mono,
        # while explicit families above keep their own lanes.
        expect(browser_font_candidates_for_family("")[0]).to_equal("examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf")
        expect(browser_font_candidates_for_family("UnknownFamily")[0]).to_equal("examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf")

    it "selects one Chrome-compatible normal font and one vector fallback":
        expect(browser_chrome_compatible_normal_font_name()).to_equal("Liberation Serif Regular")
        expect(browser_chrome_compatible_normal_font_path()).to_equal("/usr/share/fonts/truetype/liberation/LiberationSerif-Regular.ttf")
        expect(browser_chrome_compatible_vector_font_name()).to_equal("Simple Vector Outline")

    it "builds browser default renderers from selected font lanes":
        val renderer = FontRenderer.browser_serif_default()
        expect(renderer.use_vector).to_equal(true)
        expect(renderer.use_bitmap).to_equal(true)
        val mono_renderer = FontRenderer.browser_default_for_family("monospace")
        expect(mono_renderer.use_vector).to_equal(true)
        expect(mono_renderer.use_bitmap).to_equal(true)

    it "exposes an opt-in browser default font materialization surface":
        val provided = browser_provided_font_paths()
        expect(provided).to_contain("examples/09_embedded/simple_os/fonts/sans/NotoSans-Regular.ttf")
        expect(provided).to_contain("examples/09_embedded/simple_os/fonts/serif/NotoSerif-Regular.ttf")
        expect(provided).to_contain("examples/09_embedded/simple_os/fonts/mono/FiraCodeNerdFontMono-Regular.ttf")
        expect(browser_font_download_script_path()).to_equal("examples/09_embedded/simple_os/fonts/download_fonts.shs")

        val result = ensure_browser_provided_fonts(false, 1)
        expect(result.attempted_download).to_equal(false)
        expect("available,missing").to_contain(result.status)

    it "extracts font-face source URLs for browser font materialization":
        val css = "@font-face { font-family: Demo; src: url('/fonts/demo.woff2') format('woff2'), url(\"https://cdn.example/demo.ttf\") format('truetype'); } body { color: red }"
        val urls = browser_font_face_source_urls(css)
        expect(urls.len()).to_equal(2)
        expect(urls[0]).to_equal("/fonts/demo.woff2")
        expect(urls[1]).to_equal("https://cdn.example/demo.ttf")

    it "puts resolved local font-face sources ahead of generic fallback candidates":
        val family = browser_font_face_family_value("Demo Serif, serif", "examples/09_embedded/simple_os/fonts/serif/NotoSerif-Regular.ttf")
        val candidates = browser_font_candidates_for_family(family)
        expect(browser_font_face_source_from_family_value(family)).to_equal("examples/09_embedded/simple_os/fonts/serif/NotoSerif-Regular.ttf")
        expect(candidates[0]).to_equal("examples/09_embedded/simple_os/fonts/serif/NotoSerif-Regular.ttf")
        expect(candidates[1]).to_equal(browser_chrome_compatible_normal_font_path())

    it "keeps remote font-face sources out of renderer file candidates until fetched":
        val family = browser_font_face_family_value("Remote Serif, serif", "https://cdn.example/font.ttf")
        expect(family).to_equal("Remote Serif, serif")
        expect(browser_font_candidates_for_family(family)[0]).to_equal(browser_chrome_compatible_normal_font_path())

    it "maps remote font-face sources to deterministic cache paths without implicit download":
        val url = "https://cdn.example/fonts/demo.woff2"
        expect(browser_font_cache_dir()).to_equal("build/browser-font-cache")
        expect(browser_font_face_cached_source_path(url)).to_equal("build/browser-font-cache/https___cdn_example_fonts_demo_woff2.woff2")

        val css = "@font-face { font-family: Remote; src: url('https://cdn.example/fonts/demo.woff2') format('woff2'); }"
        val result = ensure_browser_font_face_sources(css, false)
        expect(result.attempted_download).to_equal(false)
        expect(result.status).to_equal("remote_sources_missing")

    it "enforces glyph-cache entry and alpha-payload bounds":
        var cache = GlyphCache.new(512)
        expect(cache.max_entries).to_equal(512)
        expect(cache.max_bytes).to_equal(33554432)
        var codepoint = 0
        while codepoint < 513:
            cache.insert(CachedGlyph(codepoint: codepoint, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [1u8]))
            codepoint = codepoint + 1
        val stats = cache.stats()
        expect(stats.entries).to_equal(512)
        expect(stats.bytes).to_equal(512)
        expect(stats.evictions).to_equal(1)
        val oversized = CachedGlyph(codepoint: 600, font_size: 16, width: 33554433, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [1u8; 33554433])
        expect(cache.insert(oversized)).to_be(false)
        val after_reject = cache.stats()
        expect(after_reject.entries).to_equal(512)
        expect(after_reject.bytes).to_equal(512)
        expect(after_reject.evictions).to_equal(1)
        cache.lookup(512, 16)
        expect(cache.stats().hits).to_equal(1)
        expect(cache.lookup(512, 17)).to_be_nil()
        expect(cache.stats().misses).to_equal(1)
        cache.sync_generation(1)
        expect(cache.stats().entries).to_equal(0)
