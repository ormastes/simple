    expect(rt_env_set(prefix + "_VECTOR_FONT_REASON", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_COUNT", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_CODEPOINT", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_FONT_SIZE", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_WIDTH", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_HEIGHT", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_ADVANCE", ""))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_PIXELS", ""))
