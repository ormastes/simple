use std.spec.{describe, it, expect}
use common.text_layout.font_renderer.{
    browser_chrome_compatible_normal_font_name,
    browser_chrome_compatible_normal_font_path,
    browser_chrome_compatible_vector_font_name,
    CachedGlyph, GlyphCache, FontRenderer, FontRenderBatch, ResolvedFontMetrics, resolve_font_metrics, resolve_font_metrics_with_language,
    font_renderer_register_selected_bytes,
    font_renderer_use_registered_selected_bytes_only,
    browser_font_download_script_path, browser_font_face_source_urls,
    browser_font_face_family_value, browser_font_face_source_from_family_value,
    browser_font_cache_dir, browser_font_face_cached_source_path, ensure_browser_font_face_sources,
    browser_font_candidates_for_family, browser_mono_font_candidates,
    browser_provided_font_paths, browser_sans_font_candidates,
    browser_serif_font_candidates,
    _font_atlas_dependency_generation_after, _resolved_font_metric_key, _resolved_font_metrics_cacheable,
    ensure_browser_provided_fonts}
use common.text_layout.font_provider.{browser_bundled_font_path_for_family}
use std.common.encoding.font_registry.{selected_font_asset_candidates, selected_font_asset_identity}
use std.common.gpu.font_atlas_composite.{FONT_ATLAS_COMPOSITE_PROGRAM_VERSION, FONT_ATLAS_COMPOSITE_SEMANTICS_VERSION, font_atlas_composite_program_version_valid, font_atlas_subrect_pixels}
use std.common.crypto.sha256.{sha256_u8_hex}
use std.nogc_sync_mut.sffi.io.{file_read_bytes}

fn expect_resolved_font_metrics(metrics: ResolvedFontMetrics):
    expect(metrics.valid).to_be(true)
    expect(metrics.identity).to_start_with("sha256=")
    expect(metrics.identity).to_contain(";axes=")
    expect(metrics.advances.len()).to_equal(3)
    var width = 0
    for advance in metrics.advances:
        expect(advance).to_be_greater_than(0)
        width = width + advance
    expect(metrics.width).to_equal(width)
    expect(metrics.line_height).to_be_greater_than(0)

extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn _count_nonzero_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        if alpha.to_i32() > 0:
            count = count + 1
    count

fn _black_composite_rgb_bytes(pixels: [u32]) -> [u8]:
    var rgb: [u8] = []
    for pixel in pixels:
        val alpha = ((pixel >> 24) & 0xFF).to_u8()
        rgb.push(alpha)
        rgb.push(alpha)
        rgb.push(alpha)
    rgb

describe "SFFI font liveness":
    it "rejects nil or stale rasterizers through is_current":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/text_layout/font_renderer.spl")
        expect(source).to_contain("fn has_sffi_ttf() -> bool:\n        val rasterizer = self.ttf_rasterizer\n        if rasterizer == nil:\n            return false\n        rasterizer.is_current()")

    it "renders a selected face from owned bytes without a hosted dylib":
        val path = "assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf"
        var renderer = FontRenderer.new()
        expect(renderer.try_load_selected_bytes(path, file_read_bytes(path))).to_be(true)
        val batch = renderer.prepare_text("A", 0xffffffffu32, 32)
        expect(batch.valid).to_be(true)
        expect(batch.font_identity).to_start_with("sha256=2cb2adb378a8f574")
        expect(batch.quads.len()).to_equal(1)
        expect(batch.quads[0].width).to_equal(18)
        expect(batch.quads[0].height).to_equal(23)
        val quad = batch.quads[0]
        val pixels = font_atlas_subrect_pixels(batch.atlas_pixels, batch.atlas_width,
            batch.atlas_height, quad.atlas_x, quad.atlas_y, quad.width, quad.height, quad.color)
        expect(sha256_u8_hex(_black_composite_rgb_bytes(pixels))).to_equal("65f5480aa1d19b4496b2f9f45ab0e7a8a0ec9e02c9a9d674879ececa138ff73c")
        renderer.clear_ttf()

    it "registers exact bytes for every selected identity and rejects corruption":
        val candidates = selected_font_asset_candidates()
        expect(candidates.len()).to_equal(16)
        for candidate in candidates:
            val blob = file_read_bytes(candidate.local_path)
            var malformed = blob
            malformed[malformed.len() - 1] = (malformed[malformed.len() - 1].to_i64() ^ 1).to_u8()
            expect(font_renderer_register_selected_bytes(candidate.local_path, malformed)).to_be(false)
            expect(font_renderer_register_selected_bytes(candidate.local_path, blob)).to_be(true)
            var renderer = FontRenderer.new()
            expect(renderer.try_load_registered_identity(selected_font_asset_identity(candidate))).to_be(true)
            expect(renderer.current_font_identity()).to_equal(selected_font_asset_identity(candidate))
            renderer.clear_ttf()

describe "font atlas composite program version":
    it "accepts only version one and stamps every renderer outcome":
        expect(FONT_ATLAS_COMPOSITE_PROGRAM_VERSION).to_equal(1)
        expect(FONT_ATLAS_COMPOSITE_SEMANTICS_VERSION).to_equal(2)
        expect(font_atlas_composite_program_version_valid(1)).to_be(true)
        expect(font_atlas_composite_program_version_valid(0)).to_be(false)
        expect(font_atlas_composite_program_version_valid(-1)).to_be(false)
        expect(font_atlas_composite_program_version_valid(2)).to_be(false)
        var renderer = FontRenderer.new()
        expect(renderer.prepare_text("", 0u32, 16).program_version).to_equal(1)
        expect(renderer.prepare_text("A", 0u32, 0).program_version).to_equal(1)

describe "font atlas dependency generation":
    it "uses facade-owned locks with a freestanding-safe lazy path":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/text_layout/font_renderer.spl")
        expect(source.contains("extern fn rt_mutex_")).to_be(false)
        expect(source).to_contain("use std.nogc_sync_mut.concurrent.mutex.{Mutex, mutex_new}")
        expect(source).to_contain("var _resolved_font_metric_lock: Mutex? = mutex_new(0)")
        expect(source).to_contain("var _browser_default_font_lock: Mutex? = mutex_new(0)")
        expect(source).to_contain("var _font_atlas_dependency_generation_lock: Mutex? = mutex_new(0)")
        expect(source).to_contain("_font_atlas_dependency_generation_lock = _font_mutex_acquire(_font_atlas_dependency_generation_lock)")
        expect(source).to_contain("_font_mutex_release(_font_atlas_dependency_generation_lock)")

    it "is distinct across sequential renderers, stable while warm, and advances when dirty":
        var first_renderer = FontRenderer.new()
        var second_renderer = FontRenderer.new()
        val first = first_renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        val second = second_renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        expect(first.atlas_generation).to_be_greater_than(0)
        expect(second.atlas_generation).to_be_greater_than(0)
        expect(second.atlas_generation == first.atlas_generation).to_be(false)
        val warm = first_renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        expect(warm.atlas_generation).to_equal(first.atlas_generation)
        expect(warm.dirty_rects.len()).to_equal(0)
        val dirty = first_renderer.prepare_text("AB", 0xFFFFFFFFu32, 16)
        expect(dirty.atlas_generation).to_be_greater_than(warm.atlas_generation)
        expect(dirty.dirty_rects.len()).to_be_greater_than(0)

    it "keys raster material by canonical font size while preserving warm reuse":
        var renderer = FontRenderer.new()
        val small = renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        val small_warm = renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        val large = renderer.prepare_text("A", 0xFFFFFFFFu32, 32)
        val large_warm = renderer.prepare_text("A", 0xFFFFFFFFu32, 32)
        expect(small_warm.atlas_generation).to_equal(small.atlas_generation)
        expect(small_warm.dirty_rects.len()).to_equal(0)
        expect(large.atlas_generation).to_be_greater_than(small.atlas_generation)
        expect(large.dirty_rects.len()).to_be_greater_than(0)
        expect(large.quads[0].height).to_be_greater_than(small.quads[0].height)
        expect(large_warm.atlas_generation).to_equal(large.atlas_generation)
        expect(large_warm.dirty_rects.len()).to_equal(0)

    it "returns zero instead of wrapping an exhausted token":
        expect(_font_atlas_dependency_generation_after(-1)).to_equal(0)
        expect(_font_atlas_dependency_generation_after(9223372036854775806)).to_equal(9223372036854775807)
        expect(_font_atlas_dependency_generation_after(9223372036854775807)).to_equal(0)

    it "keys atlas ownership by font face program dimensions and dependency generation":
        val base = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        val same = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        val changed_face = FontRenderBatch(program_version: 1, font_identity: "sha256=b;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        val changed_face_generation = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 4,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        val changed_generation = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 8, dirty_rects: [])
        val changed_program = FontRenderBatch(program_version: 2, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        val changed_dimensions = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 9, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        val changed_config = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [],
            render_config_identity: "coverage8;hint=light;subpixel=none")
        val changed_transform = FontRenderBatch(program_version: 1, font_identity: "sha256=a;axes=wght=400", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [],
            transform_identity: "nonuniform-scale")
        val shared_other_face = FontRenderBatch(program_version: 1, font_identity: "font-faces-v1|1:a|1:b", face_generation: 4,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [],
            atlas_owner_generation: -2)
        val shared_base = FontRenderBatch(program_version: 1, font_identity: "font-faces-v1|1:a|1:b", face_generation: 3,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [],
            atlas_owner_generation: -2)
        val unowned_shared_claim = FontRenderBatch(program_version: 1, font_identity: "font-faces-v1|1:a|1:b", face_generation: 4,
            valid: true, atlas_width: 8, atlas_height: 4, atlas_pixels: [], quads: [], atlas_generation: 7, dirty_rects: [])
        expect(base.atlas_owner_identity()).to_equal(same.atlas_owner_identity())
        expect(base.atlas_cache_identity()).to_equal(same.atlas_cache_identity())
        expect(base.material_supported()).to_be(true)
        expect(changed_program.material_supported()).to_be(false)
        expect(changed_transform.material_supported()).to_be(false)
        expect(base.atlas_owner_identity() == changed_face.atlas_owner_identity()).to_be(false)
        expect_not(base.atlas_owner_identity() == changed_face_generation.atlas_owner_identity())
        expect(base.atlas_owner_identity() == changed_program.atlas_owner_identity()).to_be(false)
        expect_not(base.atlas_owner_identity() == changed_config.atlas_owner_identity())
        expect_not(base.atlas_owner_identity() == changed_transform.atlas_owner_identity())
        expect(base.atlas_owner_identity() == changed_dimensions.atlas_owner_identity()).to_be(false)
        expect(base.atlas_owner_identity()).to_equal(changed_generation.atlas_owner_identity())
        expect(base.atlas_cache_identity() == changed_generation.atlas_cache_identity()).to_be(false)
        expect(shared_base.face_generation == shared_other_face.face_generation).to_be(false)
        expect(shared_base.atlas_owner_identity()).to_equal(shared_other_face.atlas_owner_identity())
        expect(shared_base.atlas_cache_identity()).to_equal(shared_other_face.atlas_cache_identity())
        expect(shared_base.atlas_owner_identity() == unowned_shared_claim.atlas_owner_identity()).to_be(false)

    it "includes live font identity in resolved metric keys":
        val first = _resolved_font_metric_key(" Noto Sans ", "AB", 16, "sha256=a;axes=wght=400")
        expect(first).to_equal(_resolved_font_metric_key("noto sans", "AB", 16, "sha256=a;axes=wght=400"))
        expect(first == _resolved_font_metric_key("noto sans", "AB", 16, "sha256=b;axes=wght=400")).to_be(false)
        expect(first == _resolved_font_metric_key("noto sans", "AB", 16, "sha256=a;axes=wght=700")).to_be(false)
        expect(_resolved_font_metrics_cacheable("font", "A" * 4096)).to_be(true)
        expect(_resolved_font_metrics_cacheable("font", "A" * 4097)).to_be(false)
        expect(_resolved_font_metrics_cacheable("F" * 1025, "A")).to_be(false)

fn _count_full_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        if alpha.to_i32() == 255:
            count = count + 1
    count

fn _count_partial_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        val a = alpha.to_i32()
        if a > 0 and a < 255:
            count = count + 1
    count

fn _count_painted_pixels(pixels: [u32], bg: u32) -> i32:
    var count = 0
    for pixel in pixels:
        if pixel != bg:
            count = count + 1
    count

fn _count_antialiased_argb_pixels(pixels: [u32], bg: u32, fg: u32) -> i32:
    var count = 0
    for pixel in pixels:
        if pixel != bg and pixel != fg:
            count = count + 1
    count

fn _vector_payload_checksum(pixels: [u8], width: i32, height: i32, advance: i32) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        val alpha = pixels[i].to_i32().to_i64()
        if alpha > 0:
            sum = sum + alpha * ((i + 1) as i64)
        i = i + 1
    sum + (width.to_i64() * 31) + (height.to_i64() * 17) + advance.to_i64()

fn _set_rocm_vector_glyph_payload():
    val pixels = [0u8, 64u8, 128u8, 255u8, 0u8, 32u8]
    val checksum = _vector_payload_checksum(pixels, 3, 2, 4)
    rt_env_set("ROCM_VECTOR_FONT_STATUS", "pass")
    rt_env_set("ROCM_VECTOR_FONT_REASON", "rocm-vector-font-glyph-pixels-returned")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_COUNT", "1")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CODEPOINT", "65")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_FONT_SIZE", "24")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_WIDTH", "3")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_HEIGHT", "2")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_ADVANCE", "4")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_PIXELS", "0,64,128,255,0,32")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CHECKSUM", checksum.to_text())

fn _clear_rocm_vector_glyph_payload():
    rt_env_set("ROCM_VECTOR_FONT_STATUS", "")
    rt_env_set("ROCM_VECTOR_FONT_REASON", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_COUNT", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CODEPOINT", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_FONT_SIZE", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_WIDTH", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_HEIGHT", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_ADVANCE", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_PIXELS", "")
    rt_env_set("ROCM_VECTOR_FONT_GLYPH_0_CHECKSUM", "")

describe "shared font renderer fallbacks":
    it "measures ordered advances through the canonical renderer":
        var renderer = FontRenderer.new()
        val advances = renderer.measure_text_advances("ABC", 16)
        expect(advances.len()).to_equal(3)
        var width = 0
        for advance in advances:
            expect(advance).to_be_greater_than(0)
            width = width + advance
        expect(renderer.measure_text_width("ABC", 16)).to_equal(width)

    it "resolves a pinned family or reports the unavailable runtime honestly":
        val metrics = resolve_font_metrics("Noto Sans Mono", "ABC", 16)
        if metrics.valid:
            expect_resolved_font_metrics(metrics)
            expect(metrics.family).to_equal("Noto Sans Mono")
        else:
            expect(metrics.reason).to_equal("font-runtime-unavailable")

    it "renders vector glyph coverage with antialiasing evidence":
        var renderer = FontRenderer.new()
        renderer.use_bitmap = false

        val glyph = renderer.get_glyph(65, 24)

        expect(glyph.width).to_be_greater_than(0)
        expect(glyph.height).to_equal(24)
        expect(_count_nonzero_alpha(glyph.pixels)).to_be_greater_than(0)
        expect(_count_partial_alpha(glyph.pixels)).to_be_greater_than(0)

    it "ignores forged vector glyph environment when preparing a batch":
        _clear_rocm_vector_glyph_payload()
        var expected_renderer = FontRenderer.new()
        expected_renderer.use_bitmap = false
        val expected = expected_renderer.prepare_text("A", 0xFFFFFFFFu32, 24)
        _set_rocm_vector_glyph_payload()
        var renderer = FontRenderer.new()
        renderer.use_bitmap = false

        val actual = renderer.prepare_text("A", 0xFFFFFFFFu32, 24)
        expect(expected.valid).to_be(true)
        expect(actual.valid).to_be(true)
        expect(actual.program_version).to_equal(expected.program_version)
        expect(actual.font_identity).to_equal(expected.font_identity)
        expect(actual.render_config_identity).to_equal(expected.render_config_identity)
        expect(actual.atlas_width).to_equal(expected.atlas_width)
        expect(actual.atlas_height).to_equal(expected.atlas_height)
        expect(expected.quads.len()).to_equal(1)
        expect(actual.quads.len()).to_equal(1)
        val expected_quad = expected.quads[0]
        val actual_quad = actual.quads[0]
        expect(actual_quad.width).to_equal(expected_quad.width)
        expect(actual_quad.height).to_equal(expected_quad.height)
        expect(actual_quad.dst_x).to_equal(expected_quad.dst_x)
        expect(actual_quad.dst_y).to_equal(expected_quad.dst_y)
        expect(actual_quad.atlas_x).to_equal(expected_quad.atlas_x)
        expect(actual_quad.atlas_y).to_equal(expected_quad.atlas_y)
        expect(actual_quad.color).to_equal(expected_quad.color)
        val expected_pixels = font_atlas_subrect_pixels(expected.atlas_pixels, expected.atlas_width,
            expected.atlas_height, expected_quad.atlas_x, expected_quad.atlas_y,
            expected_quad.width, expected_quad.height, expected_quad.color)
        val actual_pixels = font_atlas_subrect_pixels(actual.atlas_pixels, actual.atlas_width,
            actual.atlas_height, actual_quad.atlas_x, actual_quad.atlas_y,
            actual_quad.width, actual_quad.height, actual_quad.color)
        expect(actual_pixels).to_equal(expected_pixels)
        _clear_rocm_vector_glyph_payload()

    it "renders Simple Vector Outline glyphs into an ARGB buffer":
        var renderer = FontRenderer.new()
        renderer.use_bitmap = false
        val bg = 0xFFFFFFFFu32
        val fg = 0xFF000000u32
        val buffer = [bg; 40 * 32]

        val rendered = renderer.render_text(buffer, 40, 32, 2, 3, "A", fg, 24)

        expect(_count_painted_pixels(rendered, bg)).to_be_greater_than(0)
        expect(_count_antialiased_argb_pixels(rendered, bg, fg)).to_be_greater_than(0)

    it "reuses a persistent glyph atlas without warm dirty uploads":
        var renderer = FontRenderer.browser_serif_default()
        val cold = renderer.prepare_text("AB", 0xFF336699u32, 16)
        val warm = renderer.prepare_text("AB", 0xFFCC8844u32, 16)

        expect(cold.valid).to_be(true)
        expect(cold.quads.len()).to_equal(2)
        expect(cold.dirty_rects.len()).to_equal(2)
        for dirty in cold.dirty_rects:
            expect(dirty.atlas_x).to_be_greater_than(-1)
            expect(dirty.atlas_y).to_be_greater_than(-1)
            expect(dirty.width).to_be_greater_than(0)
            expect(dirty.height).to_be_greater_than(0)
            expect(dirty.atlas_x + dirty.width).to_be_less_than(1025)
            expect(dirty.atlas_y + dirty.height).to_be_less_than(1025)
        expect(cold.atlas_pixels.len()).to_equal(1024 * 1024)
        expect(cold.quads[0].codepoint).to_equal(65)
        expect(cold.quads[1].codepoint).to_equal(66)
        expect(cold.quads[0].byte_offset).to_equal(0)
        expect(cold.quads[1].byte_offset).to_equal(1)
        expect(cold.quads[1].dst_x).to_be_greater_than(cold.quads[0].dst_x)
        expect(cold.quads[1].atlas_x).to_be_greater_than(cold.quads[0].atlas_x)
        expect(warm.atlas_generation).to_equal(cold.atlas_generation)
        expect(warm.dirty_rects.len()).to_equal(0)
        expect(warm.quads[0].atlas_x).to_equal(cold.quads[0].atlas_x)
        expect(warm.quads[1].dst_x).to_equal(cold.quads[1].dst_x)
        expect(warm.quads[0].color).to_equal(0xFFCC8844u32)

    it "applies Draw IR resolved advances without moving atlas ownership":
        var renderer = FontRenderer.browser_serif_default()
        val natural = renderer.prepare_text("AB", 0xFFFFFFFFu32, 16)
        val advances = renderer.measure_text_advances("AB", 16)
        val resolved = renderer.prepare_text_with_advances("AB", [advances[0] + 10, advances[1]], 0xFFFFFFFFu32, 16)

        expect(resolved.valid).to_be(true)
        expect(resolved.quads.len()).to_equal(2)
        expect(resolved.quads[0].dst_x).to_equal(natural.quads[0].dst_x)
        expect(resolved.quads[1].dst_x).to_equal(natural.quads[1].dst_x + 10)
        expect(resolved.quads[0].atlas_x).to_equal(natural.quads[0].atlas_x)
        expect(resolved.quads[1].atlas_x).to_equal(natural.quads[1].atlas_x)
        expect(resolved.atlas_cache_identity()).to_equal(natural.atlas_cache_identity())

    it "maps multibyte Draw IR advances by UTF-8 byte offset":
        var renderer = FontRenderer.browser_serif_default()
        val natural = renderer.prepare_text("AéB", 0xFFFFFFFFu32, 16)
        val advances = renderer.measure_text_advances("AéB", 16)
        val resolved = renderer.prepare_text_with_advances("AéB", [advances[0], advances[1] + 9, advances[2]], 0xFFFFFFFFu32, 16)

        expect(resolved.valid).to_be(true)
        expect(resolved.quads.len()).to_equal(3)
        expect(resolved.quads[0].byte_offset).to_equal(0)
        expect(resolved.quads[1].byte_offset).to_equal(1)
        expect(resolved.quads[2].byte_offset).to_equal(3)
        expect(resolved.quads[0].dst_x).to_equal(natural.quads[0].dst_x)
        expect(resolved.quads[1].dst_x).to_equal(natural.quads[1].dst_x)
        expect(resolved.quads[2].dst_x).to_equal(natural.quads[2].dst_x + 9)

    it "resets and repacks the atlas when the face generation changes":
        var renderer = FontRenderer.browser_serif_default()
        val first = renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        renderer.atlas_face_generation = renderer.atlas_face_generation + 1
        val reset = renderer.prepare_text("A", 0xFFFFFFFFu32, 16)

        expect(reset.valid).to_be(true)
        expect(reset.atlas_generation).to_be_greater_than(first.atlas_generation)
        expect(reset.dirty_rects.len()).to_equal(1)

    it "resets and repacks the atlas when identity changes at the same generation":
        var renderer = FontRenderer.new()
        val first = renderer.prepare_text("A", 0xFFFFFFFFu32, 16)
        renderer.atlas_font_identity = "stale-checksum-or-axes"
        val reset = renderer.prepare_text("A", 0xFFFFFFFFu32, 16)

        expect(reset.valid).to_be(true)
        expect(reset.atlas_generation).to_be_greater_than(first.atlas_generation)
        expect(reset.dirty_rects.len()).to_equal(1)

    it "renders bitmap glyph fallback with exact mask evidence":
        var renderer = FontRenderer.new()
        renderer.use_vector = false

        val glyph = renderer.get_glyph(65, 16)

        expect(glyph.width).to_equal(8)
        expect(glyph.height).to_equal(16)
        expect(_count_nonzero_alpha(glyph.pixels)).to_be_greater_than(0)
        expect(_count_full_alpha(glyph.pixels)).to_be_greater_than(0)

    it "keeps Chrome-compatible serif font candidates ahead of fallback fonts":
        val candidates = browser_serif_font_candidates()
