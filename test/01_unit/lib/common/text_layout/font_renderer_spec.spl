        expect(mono[1]).to_equal("/usr/share/fonts/truetype/liberation/LiberationMono-Regular.ttf")

    it "maps browser CSS font-family names to provided font lanes":
        expect(browser_font_candidates_for_family("monospace")[0]).to_equal("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
        expect(browser_font_candidates_for_family("'Fira Code', monospace")[0]).to_equal("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
        expect(browser_font_candidates_for_family("Arial, sans-serif")[0]).to_equal("assets/fonts/google-fonts/ofl/notosanssc/NotoSansSC[wght].ttf")
        expect(browser_font_candidates_for_family("system")[0]).to_equal(browser_chrome_compatible_normal_font_path())
        expect(browser_font_candidates_for_family("Times New Roman, serif")[0]).to_equal(browser_chrome_compatible_normal_font_path())

    it "defaults unspecified text to bundled Noto Sans Mono":
        # Unspecified / unmatched family falls back to bundled Noto Sans Mono,
        # while explicit families above keep their own lanes.
        expect(browser_font_candidates_for_family("")[0]).to_equal("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
        expect(browser_font_candidates_for_family("UnknownFamily")[0]).to_equal("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")

    it "selects one Chrome-compatible normal font and one vector fallback":
        expect(browser_chrome_compatible_normal_font_name()).to_equal("Liberation Serif Regular")
        expect(browser_chrome_compatible_normal_font_path()).to_equal("/usr/share/fonts/truetype/liberation/LiberationSerif-Regular.ttf")
        expect(browser_chrome_compatible_vector_font_name()).to_equal("Simple Vector Outline")

    it "builds browser default renderers from selected font lanes":
        val renderer = FontRenderer.browser_serif_default()
        expect(renderer.use_vector).to_equal(true)
        expect(renderer.use_bitmap).to_equal(true)
        val mono_renderer = FontRenderer.browser_default_for_family("monospace")
        expect(mono_renderer.use_vector).to_equal(true)
        expect(mono_renderer.use_bitmap).to_equal(true)

    it "resolves accepted Arabic through a handle-free shaped cluster payload":
        val metrics = resolve_font_metrics_with_language("sans-serif", "العربية", 32, "ar")
        expect(metrics.valid).to_equal(true)
        expect(metrics.family).to_equal("Noto Sans Arabic")
        expect(metrics.shaping_required).to_equal(true)
        expect(metrics.glyph_run.valid).to_equal(true)
        expect(metrics.glyph_run.glyph_ids.len()).to_be_greater_than(0)
        expect(metrics.glyph_run.glyph_ids.len()).to_equal(metrics.glyph_run.clusters.len())
        for cluster in metrics.glyph_run.clusters:
            expect(cluster).to_be_greater_than(-1)
            expect(cluster).to_be_less_than(metrics.advances.len())

        var renderer = FontRenderer.browser_default_for_family(metrics.family)
        val rasterizer = renderer.ttf_rasterizer
        expect(rasterizer != nil).to_equal(true)
        if rasterizer != nil:
            val bitmap = rasterizer.rasterize_glyph_index(metrics.glyph_run.glyph_ids[0].to_i64(), 32)
            expect(bitmap != nil).to_equal(true)
            val batch = renderer.prepare_selected_glyph_run(metrics.glyph_run, 0xFFFFFFFFu32, 32)
            expect(batch.valid).to_equal(true)
            if bitmap != nil:
                val glyph = bitmap.?
                val ascent = renderer.horizontal_line_metric(32, 0)
                expect(glyph.bearing_x != 0 or glyph.bearing_y != 0).to_equal(true)
                expect(batch.quads[0].dst_x).to_equal(metrics.glyph_run.xs[0] + glyph.bearing_x.to_i32())
                expect(batch.quads[0].dst_y).to_equal(ascent + metrics.glyph_run.ys[0] - glyph.bearing_y.to_i32() - glyph.height.to_i32())
                val quad = batch.quads[0]
                val pixels = font_atlas_subrect_pixels(batch.atlas_pixels, batch.atlas_width,
                    batch.atlas_height, quad.atlas_x, quad.atlas_y, quad.width, quad.height, quad.color)
                expect(pixels.len()).to_equal(glyph.pixels.len())
                var pixel_index: i64 = 0
                while pixel_index < pixels.len():
                    expect((pixels[pixel_index] >> 24) & 0xFFu32).to_equal(glyph.pixels[pixel_index].to_u32())
                    pixel_index = pixel_index + 1
        renderer.clear_ttf()

        val unspecified = resolve_font_metrics("sans-serif", "العربية", 32)
        expect(unspecified.shaping_required).to_equal(true)
        expect(unspecified.glyph_run.valid).to_equal(false)

    it "selects accepted language faces and the declared Chinese mono fallback":
        val chinese = resolve_font_metrics_with_language("monospace", "中文", 32, "zh")
        expect(chinese.valid).to_equal(true)
        expect(chinese.family).to_equal("Noto Sans SC")

        val hindi = resolve_font_metrics_with_language("sans-serif", "हिन्दी", 32, "hi")
        expect(hindi.valid).to_equal(true)
        expect(hindi.family).to_equal("Noto Sans Devanagari")
        expect(hindi.glyph_run.valid).to_equal(true)

        val urdu = resolve_font_metrics_with_language("sans-serif", "اردو", 32, "ur")
        expect(urdu.valid).to_equal(true)
        expect(urdu.family).to_equal("Noto Sans Arabic")
        expect(urdu.glyph_run.valid).to_equal(true)

    it "exposes an opt-in browser default font materialization surface":
        val provided = browser_provided_font_paths()
        expect(provided).to_contain("assets/fonts/google-fonts/ofl/notosanssc/NotoSansSC[wght].ttf")
        expect(provided).to_contain("assets/fonts/google-fonts/ofl/notoserifsc/NotoSerifSC[wght].ttf")
        expect(provided).to_contain("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
        expect(browser_font_download_script_path()).to_equal("")

        val result = ensure_browser_provided_fonts(false, 1)
        expect(result.attempted_download).to_equal(false)
        expect("available,missing").to_contain(result.status)

    it "keeps all provided font paths in pinned manifest order":
        val assets = selected_font_asset_candidates()
        val paths = browser_provided_font_paths()
        expect(paths.len()).to_equal(16)
        expect(paths.len()).to_equal(assets.len())
        var i = 0
        while i < assets.len():
            expect(paths[i]).to_equal(assets[i].local_path)
            i = i + 1

    it "resolves each exact bundled family to its sole pinned candidate":
        val assets = selected_font_asset_candidates()
        val paths = browser_provided_font_paths()
        var i = 0
        while i < assets.len():
            expect(browser_bundled_font_path_for_family(assets[i].family)).to_equal(paths[i])
            expect(browser_font_candidates_for_family(assets[i].family)).to_equal([paths[i]])
            i = i + 1
        expect(browser_bundled_font_path_for_family("nOtO sAnS aRaBiC")).to_equal(paths[2])
        expect(browser_bundled_font_path_for_family("  Noto Emoji  ")).to_equal(paths[15])

    it "uses the first CSS family token for bundled lookup":
        val paths = browser_provided_font_paths()
        expect(browser_bundled_font_path_for_family("")).to_equal("")
        expect(browser_bundled_font_path_for_family("Unknown Family")).to_equal("")
        expect(browser_bundled_font_path_for_family("Noto Sans SC, sans-serif")).to_equal(paths[0])
        expect(browser_bundled_font_path_for_family("\"Roboto Slab\", serif")).to_equal(paths[12])
        expect(browser_font_candidates_for_family("monospace")[0]).to_equal(browser_mono_font_candidates()[0])
        expect(browser_font_candidates_for_family("Arial, sans-serif")[0]).to_equal(browser_sans_font_candidates()[0])
        expect(browser_font_candidates_for_family("Times New Roman, serif")[0]).to_equal(browser_serif_font_candidates()[0])

    it "extracts font-face source URLs for browser font materialization":
        val css = "@font-face { font-family: Demo; src: url('/fonts/demo.woff2') format('woff2'), url(\"https://cdn.example/demo.ttf\") format('truetype'); } body { color: red }"
        val urls = browser_font_face_source_urls(css)
        expect(urls.len()).to_equal(2)
        expect(urls[0]).to_equal("/fonts/demo.woff2")
        expect(urls[1]).to_equal("https://cdn.example/demo.ttf")

    it "puts resolved local font-face sources ahead of generic fallback candidates":
        val family = browser_font_face_family_value("Demo Serif, serif", "assets/fonts/google-fonts/ofl/notoserifsc/NotoSerifSC[wght].ttf")
        val candidates = browser_font_candidates_for_family(family)
        expect(browser_font_face_source_from_family_value(family)).to_equal("assets/fonts/google-fonts/ofl/notoserifsc/NotoSerifSC[wght].ttf")
        expect(candidates[0]).to_equal("assets/fonts/google-fonts/ofl/notoserifsc/NotoSerifSC[wght].ttf")
        expect(candidates[1]).to_equal(browser_chrome_compatible_normal_font_path())

        val exact_family = browser_font_face_family_value("Noto Sans SC", "assets/fonts/google-fonts/ofl/bungee/Bungee-Regular.ttf")
        expect(browser_font_candidates_for_family(exact_family)[0]).to_equal("assets/fonts/google-fonts/ofl/bungee/Bungee-Regular.ttf")

    it "keeps remote font-face sources out of renderer file candidates until fetched":
        val family = browser_font_face_family_value("Remote Serif, serif", "https://cdn.example/font.ttf")
        expect(family).to_equal("Remote Serif, serif")
        expect(browser_font_candidates_for_family(family)[0]).to_equal(browser_chrome_compatible_normal_font_path())

    it "maps remote font-face sources to deterministic cache paths without implicit download":
        val url = "https://cdn.example/fonts/demo.woff2"
        expect(browser_font_cache_dir()).to_equal("build/browser-font-cache")
        expect(browser_font_face_cached_source_path(url)).to_equal("build/browser-font-cache/https___cdn_example_fonts_demo_woff2.woff2")

        val css = "@font-face { font-family: Remote; src: url('https://cdn.example/fonts/demo.woff2') format('woff2'); }"
        val result = ensure_browser_font_face_sources(css, false)
        expect(result.attempted_download).to_equal(false)
        expect(result.status).to_equal("remote_sources_missing")

    it "enforces glyph-cache entry and alpha-payload bounds":
        var cache = GlyphCache.new(512)
        expect(cache.max_entries).to_equal(512)
        expect(cache.max_bytes).to_equal(33554432)
        var codepoint = 0
        while codepoint < 513:
            cache.insert(CachedGlyph(codepoint: codepoint, face_id: 0, face_generation: 0, glyph_index: -1, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [1u8]))
            codepoint = codepoint + 1
        val stats = cache.stats()
        expect(stats.entries).to_equal(512)
        expect(stats.bytes).to_equal(512)
        expect(stats.evictions).to_equal(1)
        val oversized = CachedGlyph(codepoint: 600, face_id: 0, face_generation: 0, glyph_index: -1, font_size: 16, width: 33554433, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [1u8; 33554433])
        expect(cache.insert(oversized)).to_be(false)
        val after_reject = cache.stats()
        expect(after_reject.entries).to_equal(512)
        expect(after_reject.bytes).to_equal(512)
        expect(after_reject.evictions).to_equal(1)
        cache.lookup(512, 16)
        expect(cache.stats().hits).to_equal(1)
        expect(cache.lookup(512, 17)).to_be_nil()
        expect(cache.stats().misses).to_equal(1)
        cache.sync_generation(1)
        expect(cache.stats().entries).to_equal(0)

    it "keys shaped glyphs by face, glyph index, and size":
        var cache = GlyphCache.new(8)
        cache.insert(CachedGlyph(codepoint: -1, face_id: 11, face_generation: 7, glyph_index: 3, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [255u8]))
        expect(cache.lookup_index(11, 7, 3, 16)).to_not_be_nil()
        expect(cache.lookup_index(11, 8, 3, 16)).to_be_nil()
        expect(cache.lookup_index(12, 7, 3, 16)).to_be_nil()
        expect(cache.lookup_index(11, 7, 4, 16)).to_be_nil()
        expect(cache.lookup_index(11, 7, 3, 17)).to_be_nil()

    it "keeps entries for a stable face identity and preserves identity across stats reset and invalidation":
        var cache = GlyphCache.new(8)
        cache.sync_face_identity(7, "sha256=a;axes=wght:400")
        cache.insert(CachedGlyph(codepoint: 65, face_id: 0, face_generation: 7, glyph_index: -1, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [255u8]))
        cache.sync_face_identity(7, "sha256=a;axes=wght:400")
        expect(cache.stats().entries).to_equal(1)
        expect(cache.lookup(65, 16)).to_not_be_nil()
        expect(cache.stats().hits).to_equal(1)
        cache.reset_stats()
        expect(cache.stats().font_identity).to_equal("sha256=a;axes=wght:400")
        cache.invalidate()
        expect(cache.stats().font_identity).to_equal("sha256=a;axes=wght:400")

    it "invalidates on generation or same-generation checksum and axis identity changes":
        var cache = GlyphCache.new(8)
        cache.sync_face_identity(3, "sha256=a;axes=wght:400")
        cache.insert(CachedGlyph(codepoint: 65, face_id: 0, face_generation: 3, glyph_index: -1, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [255u8]))
        cache.sync_face_identity(4, "sha256=a;axes=wght:400")
        expect(cache.stats().entries).to_equal(0)
        expect(cache.stats().generation).to_equal(4)
        cache.insert(CachedGlyph(codepoint: 65, face_id: 0, face_generation: 4, glyph_index: -1, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [255u8]))
        cache.sync_face_identity(4, "sha256=b;axes=wght:400")
        expect(cache.stats().entries).to_equal(0)
        cache.insert(CachedGlyph(codepoint: 65, face_id: 0, face_generation: 4, glyph_index: -1, font_size: 16, width: 1, height: 1, advance: 1, bearing_x: 0, bearing_y: 0, pixels: [255u8]))
        cache.sync_face_identity(4, "sha256=b;axes=wght:700")
        expect(cache.stats().entries).to_equal(0)
        expect(cache.stats().font_identity).to_equal("sha256=b;axes=wght:700")
        expect(cache.max_entries).to_equal(8)
        expect(cache.max_bytes).to_equal(33554432)

    it "shapes registered-only Arabic and Devanagari without filesystem reads":
        val candidates = selected_font_asset_candidates()
        var registered = 0
        for candidate in candidates:
            if candidate.family == "Noto Sans Arabic" or candidate.family == "Noto Sans Devanagari":
                expect(font_renderer_register_selected_bytes(candidate.local_path, file_read_bytes(candidate.local_path))).to_be(true)
                registered = registered + 1
        expect(registered).to_equal(2)
        font_renderer_use_registered_selected_bytes_only()
        val arabic = resolve_font_metrics_with_language("sans-serif", "العربية", 32, "ar")
        val hindi = resolve_font_metrics_with_language("sans-serif", "हिन्दी", 32, "hi")
        expect(arabic.valid).to_be(true)
        expect(arabic.reason).to_equal("resolved")
        expect(arabic.glyph_run.valid).to_be(true)
        expect(arabic.glyph_run.glyph_ids.len()).to_be_greater_than(0)
        expect(hindi.valid).to_be(true)
        expect(hindi.reason).to_equal("resolved")
        expect(hindi.glyph_run.valid).to_be(true)
        expect(hindi.glyph_run.glyph_ids.len()).to_be_greater_than(0)
        var renderer = FontRenderer.new()
        expect(renderer.try_load_registered_identity(arabic.identity)).to_be(true)
        val arabic_batch = renderer.prepare_selected_glyph_run(arabic.glyph_run, 4294967295u32, 32)
        expect(arabic_batch.valid).to_be(true)
        expect(arabic_batch.quads.len()).to_be_greater_than(0)
        expect(renderer.try_load_registered_identity(hindi.identity)).to_be(true)
        val hindi_batch = renderer.prepare_selected_glyph_run(hindi.glyph_run, 4294967295u32, 32)
        expect(hindi_batch.valid).to_be(true)
        expect(hindi_batch.quads.len()).to_be_greater_than(0)
