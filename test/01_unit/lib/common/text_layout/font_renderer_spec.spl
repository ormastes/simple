    expect(rt_env_set(prefix + "_VECTOR_FONT_REASON", reason))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_COUNT", "1"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_CODEPOINT", "65"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_FONT_SIZE", "24"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_WIDTH", "1"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_HEIGHT", "1"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_ADVANCE", "2"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_PIXELS", "255"))
    expect(rt_env_set(prefix + "_VECTOR_FONT_GLYPH_0_CHECKSUM", "305"))

