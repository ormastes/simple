use std.spec.{describe, it, expect}
use std.nogc_sync_mut.text_layout.font_renderer.{
    browser_chrome_compatible_normal_font_name,
    browser_chrome_compatible_normal_font_path,
    browser_chrome_compatible_vector_font_name,
    FontRenderer, browser_font_download_script_path, browser_font_face_source_urls,
    browser_font_face_family_value, browser_font_face_source_from_family_value,
    browser_font_cache_dir, browser_font_face_cached_source_path, ensure_browser_font_face_sources,
    browser_font_candidates_for_family, browser_mono_font_candidates,
    browser_provided_font_paths, browser_sans_font_candidates,
    browser_serif_font_candidates,
    ensure_browser_provided_fonts}
use std.nogc_sync_mut.text_layout.font_rasterizer.{reset_vector_font_raster_stats, vector_font_accelerator_stats, reset_bitmap_font_raster_stats, bitmap_font_accelerator_stats}

extern fn rt_env_set(key: text, value: text) -> bool

fn _count_nonzero_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        if alpha.to_i32() > 0:
            count = count + 1
    count

fn _count_full_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        if alpha.to_i32() == 255:
            count = count + 1
    count

fn _count_partial_alpha(pixels: [u8]) -> i32:
    var count = 0
    for alpha in pixels:
        val a = alpha.to_i32()
        if a > 0 and a < 255:
            count = count + 1
    count

fn _count_painted_pixels(pixels: [u32], bg: u32) -> i32:
    var count = 0
    for pixel in pixels:
        if pixel != bg:
            count = count + 1
    count

fn _count_antialiased_argb_pixels(pixels: [u32], bg: u32, fg: u32) -> i32:
    var count = 0
    for pixel in pixels:
        if pixel != bg and pixel != fg:
            count = count + 1
    count

fn _set_cuda_bitmap_font_probe_glyph():
    expect(rt_env_set("CUDA_BITMAP_FONT_STATUS", "pass"))
    expect(rt_env_set("CUDA_BITMAP_FONT_REASON", "cuda-bitmap-font-glyph-pixels-returned"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_COUNT", "1"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_CODEPOINT", "65"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_FONT_SIZE", "16"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_WIDTH", "1"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_HEIGHT", "1"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_ADVANCE", "2"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_PIXELS", "255"))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_CHECKSUM", "305"))

fn _clear_cuda_bitmap_font_probe_glyph():
    expect(rt_env_set("CUDA_BITMAP_FONT_STATUS", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_REASON", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_COUNT", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_CODEPOINT", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_FONT_SIZE", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_WIDTH", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_HEIGHT", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_ADVANCE", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_PIXELS", ""))
    expect(rt_env_set("CUDA_BITMAP_FONT_GLYPH_0_CHECKSUM", ""))

