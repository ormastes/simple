    expect(rt_env_set(prefix + "_BITMAP_FONT_REASON", reason))
    expect(rt_env_set(prefix + "_BITMAP_FONT_GLYPH_COUNT", "1"))
    expect(rt_env_set(prefix + "_BITMAP_FONT_GLYPH_0_CODEPOINT", "65"))
    expect(rt_env_set(prefix + "_BITMAP_FONT_GLYPH_0_FONT_SIZE", "16"))
