use std.spec.{describe, it, assert_equal}
use std.common.cbor.encode.{cbor_encode_unsigned}
use std.common.cbor.decode.{cbor_validate, cbor_validate_sequence}

describe "CBOR validate trailing data guard":
    it "rejects trailing data for single item validation":
        val encoded = [0x01, 0x02]
        assert_equal(cbor_validate(encoded), false)

    it "keeps complete single items valid":
        val encoded = cbor_encode_unsigned(1)
        assert_equal(cbor_validate(encoded), true)

    it "keeps explicit sequence validation for concatenated items":
        val encoded = [0x01, 0x02]
        assert_equal(cbor_validate_sequence(encoded), true)
