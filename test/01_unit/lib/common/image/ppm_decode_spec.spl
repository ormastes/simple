use std.spec.*
use std.common.image.ppm_decode.{decode_ppm_to_argb, encode_ppm_p6}

describe "PPM decode/encode helpers":

    it "encodes P6 headers and round-trips ARGB pixels":
        val pixels: [u32] = [0xFFFF0000u32, 0xFF00FF00u32, 0xFF0000FFu32, 0xFFFFFFFFu32]
        val encoded = encode_ppm_p6(2u32, 2u32, pixels)
        expect(encoded.len()).to_equal(23)
        expect(encoded[0]).to_equal(80)
        expect(encoded[1]).to_equal(54)
        expect(encoded[2]).to_equal(10)
        val decoded = decode_ppm_to_argb(encoded)
        expect(decoded.is_ok()).to_equal(true)
        val image = decoded.unwrap()
        expect(image.width).to_equal(2)
        expect(image.height).to_equal(2)
        expect(image.pixels.len()).to_equal(4)
        expect(image.pixels[0]).to_equal(0xFFFF0000u32)
        expect(image.pixels[1]).to_equal(0xFF00FF00u32)
        expect(image.pixels[2]).to_equal(0xFF0000FFu32)
        expect(image.pixels[3]).to_equal(0xFFFFFFFFu32)
