# Tests for src/lib/common/random_pure.spl
#
# Uses a local inline LCG (same constants) to pre-compute expected values
# so assertions are concrete bit-for-bit checks rather than just range checks.
#
# LCG: state = (1664525 * state + 1013904223) % 4294967296
# seed=42 sequence: 1083814273, 378494188, 2479403867, 955863294, 1613448261
#
# NOTE: Module-level fn helpers are used for multi-call loops because
# interpreter mode does not persist it-block var mutations across while
# iterations (feedback_it_block_var_mutation).

use std.common.random_pure.{
    seed, getstate, setstate, lcg_next, randint, random,
    lcg_rng, lcg_advance, lcg_value
}

# ---------------------------------------------------------------------------
# Module-level helpers for multi-step sequences (avoids it-block var loss)
# ---------------------------------------------------------------------------

fn check_randint_in_range(lo: i64, hi: i64, n: i64) -> bool:
    """Return true iff n calls to randint(lo,hi) all land in [lo,hi]."""
    var ok = true
    var i = 0
    while i < n:
        val v = randint(lo, hi)
        if v < lo or v > hi:
            ok = false
        i = i + 1
    ok

fn count_low_half(n: i64) -> i64:
    """Count how many of n randint(0,99) calls return < 50."""
    var low = 0
    var i = 0
    while i < n:
        val v = randint(0, 99)
        if v < 50:
            low = low + 1
        i = i + 1
    low

fn check_random_in_unit(n: i64) -> bool:
    """Return true iff n calls to random() all land in [0.0, 1.0)."""
    var ok = true
    var i = 0
    while i < n:
        val v = random()
        if v < 0.0 or v >= 1.0:
            ok = false
        i = i + 1
    ok

fn check_lcg_matches_ref(n: i64) -> bool:
    """
    Advance both module LCG and inline reference LCG n steps from seed=123
    and check they produce identical outputs.
    """
    var ref_s: i64 = 123
    seed(123)
    var all_match = true
    var i = 0
    while i < n:
        ref_s = (1664525 * ref_s + 1013904223) % 4294967296
        val got = lcg_next()
        if got != ref_s:
            all_match = false
        i = i + 1
    all_match

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "random_pure — seeding and determinism":
    it "seed then lcg_next matches known LCG output (seed=42 step 1)":
        seed(42)
        val v = lcg_next()
        expect(v).to_equal(1083814273)

    it "second lcg_next after seed=42 matches known output":
        seed(42)
        lcg_next()
        val v2 = lcg_next()
        expect(v2).to_equal(378494188)

    it "same seed produces same first value":
        seed(42)
        val a1 = lcg_next()
        seed(42)
        val b1 = lcg_next()
        expect(a1).to_equal(b1)

    it "same seed produces same second value":
        seed(42)
        lcg_next()
        val a2 = lcg_next()
        seed(42)
        lcg_next()
        val b2 = lcg_next()
        expect(a2).to_equal(b2)

    it "different seeds produce different first values":
        seed(42)
        val a = lcg_next()
        seed(99)
        val b = lcg_next()
        val differ = a != b
        expect(differ).to_equal(true)

describe "random_pure — getstate / setstate":
    it "getstate returns seed value before any advance":
        seed(7)
        val s = getstate()
        expect(s).to_equal(7)

    it "setstate restores state for exact replay":
        seed(42)
        lcg_next()
        val saved = getstate()
        val v1 = lcg_next()
        setstate(saved)
        val v2 = lcg_next()
        expect(v1).to_equal(v2)

    it "setstate(42) produces same first output as seed(42)":
        seed(42)
        val direct = lcg_next()
        setstate(42)
        val via_set = lcg_next()
        expect(direct).to_equal(via_set)

describe "random_pure — randint range":
    it "randint(0,0) returns 0":
        seed(42)
        val v = randint(0, 0)
        expect(v).to_equal(0)

    it "randint when min > max returns min":
        seed(42)
        val v = randint(10, 5)
        expect(v).to_equal(10)

    it "randint(1,10) first call is in range":
        seed(42)
        val v = randint(1, 10)
        val ok = v >= 1 and v <= 10
        expect(ok).to_equal(true)

    it "randint(1,10) stays in range for 50 calls":
        seed(42)
        val ok = check_randint_in_range(1, 10, 50)
        expect(ok).to_equal(true)

    it "randint covers low half of range in 100 calls":
        seed(42)
        val low = count_low_half(100)
        expect(low).to_be_greater_than(10)

    it "randint covers high half of range in 100 calls":
        seed(42)
        val low = count_low_half(100)
        val high = 100 - low
        expect(high).to_be_greater_than(10)

describe "random_pure — random float":
    it "random() first call is in [0.0, 1.0)":
        seed(42)
        val v = random()
        val ok = v >= 0.0 and v < 1.0
        expect(ok).to_equal(true)

    it "random() is non-constant across two calls":
        seed(42)
        val v1 = random()
        val v2 = random()
        val differ = v1 != v2
        expect(differ).to_equal(true)

    it "random() stays in [0.0, 1.0) for 50 calls":
        seed(42)
        val ok = check_random_in_unit(50)
        expect(ok).to_equal(true)

describe "random_pure — LcgRng struct API":
    it "lcg_rng seed=42 first advance matches known output":
        var rng = lcg_rng(42)
        rng = lcg_advance(rng)
        val v = lcg_value(rng)
        expect(v).to_equal(1083814273)

    it "lcg_rng seed=42 second advance matches known output":
        var rng = lcg_rng(42)
        rng = lcg_advance(rng)
        rng = lcg_advance(rng)
        val v = lcg_value(rng)
        expect(v).to_equal(378494188)

    it "lcg_rng struct value is independent of module-level seed":
        seed(99)
        var rng = lcg_rng(42)
        rng = lcg_advance(rng)
        val struct_val = lcg_value(rng)
        expect(struct_val).to_equal(1083814273)

describe "random_pure — matches inline reference LCG":
    it "lcg_next matches inline reference for 5 steps from seed=123":
        val ok = check_lcg_matches_ref(5)
        expect(ok).to_equal(true)
