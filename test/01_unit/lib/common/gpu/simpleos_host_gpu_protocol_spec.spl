use std.spec.*
use std.common.gpu.simpleos_host_gpu_protocol.*

fn protocol_hello(guest_isa: text) -> SimpleOsHostGpuHello:
    return SimpleOsHostGpuHello(version: 1, guest_isa: guest_isa, region_bytes: SIMPLEOS_HOST_GPU_REGION_BYTES, max_payload_bytes: SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES, max_readback_bytes: simpleos_host_gpu_max_readback_bytes(), render_backend: "vulkan", processing_backend: "cuda")

fn render_batch() -> SimpleOsHostGpuBatch:
    return SimpleOsHostGpuBatch(version: 1, generation: 7, run_id: "run-7", frame_id: 9, kind: "render", backend: "vulkan", width: 1280, height: 720, element_count: 0, payload_bytes: 1024, payload_checksum: 12345)

fn device_receipt(source: text, handle: i64) -> SimpleOsHostGpuReceipt:
    var identity = ""
    if handle > 0:
        identity = "device-0"
    return SimpleOsHostGpuReceipt(version: 1, generation: 7, run_id: "run-7", frame_id: 9, status: "pass", backend: "vulkan", reason: "pass", native_handle: handle, native_device_identity: identity, readback_source: source, output_bytes: 1280 * 720 * 4, output_checksum: 98765, elapsed_us: 8000)

describe "SimpleOS host-GPU protocol":
    it "keeps the ivshmem wire layout aligned and backend codes reversible":
        expect(SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION % 8).to_equal(0)
        expect(SIMPLEOS_HOST_GPU_WIRE_COMPLETION_RUN_ID_HASH % 8).to_equal(0)
        expect(SIMPLEOS_HOST_GPU_WIRE_COMPLETION_FRAME_ID % 8).to_equal(0)
        expect(SIMPLEOS_HOST_GPU_WIRE_COMPLETION_BACKEND % 8).to_equal(0)
        expect(SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_COUNT).to_equal(256)
        expect(SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_BYTES).to_equal(264)
        expect(SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_CHECKSUM).to_equal(272)
        expect(SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_CHECKSUM % 8).to_equal(0)
        expect(SIMPLEOS_HOST_GPU_IMAGE_RESOURCE_HEADER_BYTES).to_equal(48)
        expect(simpleos_host_gpu_wire_payload_offset()).to_equal(SIMPLEOS_HOST_GPU_CONTROL_BYTES)
        expect(simpleos_host_gpu_wire_readback_offset()).to_equal(simpleos_host_gpu_wire_payload_offset() + SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES)
        expect(simpleos_host_gpu_wire_readback_offset() + simpleos_host_gpu_max_readback_bytes()).to_equal(SIMPLEOS_HOST_GPU_REGION_BYTES)
        expect(simpleos_host_gpu_backend_name(simpleos_host_gpu_backend_code("vulkan"))).to_equal("vulkan")
        expect(simpleos_host_gpu_backend_name(simpleos_host_gpu_backend_code("metal"))).to_equal("metal")
        expect(simpleos_host_gpu_wire_checksum_words([1, 2, 3])).to_equal(6)
        expect(simpleos_host_gpu_backend_mask(SIMPLEOS_HOST_GPU_BACKEND_VULKAN)).to_equal(SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN)
        expect(simpleos_host_gpu_guest_isa_name(simpleos_host_gpu_guest_isa_code("aarch64"))).to_equal("aarch64")

    it "accepts only monotonic request generations":
        expect(simpleos_host_gpu_generation_is_fresh(8, 7)).to_be(true)
        expect(simpleos_host_gpu_generation_is_fresh(7, 7)).to_be(false)
        expect(simpleos_host_gpu_generation_is_fresh(6, 7)).to_be(false)
        expect(simpleos_host_gpu_generation_is_fresh(0, 0)).to_be(false)

    it "checksums an exact readback prefix and rejects invalid counts":
        val pixels: [u32] = [0x80000000u32, 0xFFFFFFFFu32, 1u32, 99u32]
        val empty: [u32] = []
        expect(simpleos_host_gpu_readback_checksum(pixels, 3)).to_equal(1)
        expect(simpleos_host_gpu_readback_checksum([0u32], 1)).to_equal(1)
        expect(simpleos_host_gpu_readback_checksum(empty, 0)).to_equal(1)
        expect(simpleos_host_gpu_readback_checksum(pixels, -1)).to_equal(0)
        expect(simpleos_host_gpu_readback_checksum(pixels, 5)).to_equal(0)

    it "negotiates one bounded protocol on all target ISAs":
        step("Probe the QEMU guest GPU capability")
        expect(SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US).to_equal(500000)
        expect(simpleos_host_gpu_validate_hello(protocol_hello("x86_64")).status).to_equal("pass")
        expect(simpleos_host_gpu_validate_hello(protocol_hello("aarch64")).status).to_equal("pass")
        expect(simpleos_host_gpu_validate_hello(protocol_hello("riscv64")).status).to_equal("pass")

    it "rejects incompatible handshakes":
        val bad_version = SimpleOsHostGpuHello(version: 2, guest_isa: "x86_64", region_bytes: SIMPLEOS_HOST_GPU_REGION_BYTES, max_payload_bytes: 1, max_readback_bytes: 1, render_backend: "vulkan", processing_backend: "cuda")
        expect(simpleos_host_gpu_validate_hello(bad_version).reason).to_equal("unsupported-protocol-version")
        expect(simpleos_host_gpu_validate_hello(protocol_hello("mips64")).reason).to_equal("unsupported-guest-isa")
        val small = SimpleOsHostGpuHello(version: 1, guest_isa: "x86_64", region_bytes: 4096, max_payload_bytes: 1, max_readback_bytes: 1, render_backend: "vulkan", processing_backend: "cuda")
        expect(simpleos_host_gpu_validate_hello(small).reason).to_equal("shared-region-too-small")

    it "accepts bounded rendering and processing batches":
        step("Render and read back the Simple 2D parity fixture")
        expect(simpleos_host_gpu_validate_batch(render_batch()).status).to_equal("pass")
        expect(simpleos_host_gpu_batch_output_bytes(render_batch())).to_equal(3686400)
        step("Run the ProcessingIR parity fixture")
        val processing = SimpleOsHostGpuBatch(version: 1, generation: 8, run_id: "run-8", frame_id: 10, kind: "processing", backend: "cuda", width: 0, height: 0, element_count: 1024, payload_bytes: 64, payload_checksum: 222)
        expect(simpleos_host_gpu_validate_batch(processing).status).to_equal("pass")
        expect(simpleos_host_gpu_batch_output_bytes(processing)).to_equal(4096)

    it "accepts bounded canonical Draw IR as a render batch":
        val draw_ir = SimpleOsHostGpuBatch(version: 1, generation: 9, run_id: "run-9", frame_id: 11, kind: "draw_ir", backend: "vulkan", width: 64, height: 48, element_count: 2, payload_bytes: 512, payload_checksum: 333)
        expect(simpleos_host_gpu_validate_batch(draw_ir).status).to_equal("pass")
        expect(simpleos_host_gpu_batch_output_bytes(draw_ir)).to_equal(64 * 48 * 4)

    it "rejects malformed and oversized batches":
        val unknown = SimpleOsHostGpuBatch(version: 1, generation: 1, run_id: "r", frame_id: 1, kind: "unknown", backend: "vulkan", width: 1, height: 1, element_count: 0, payload_bytes: 1, payload_checksum: 1)
        expect(simpleos_host_gpu_validate_batch(unknown).reason).to_equal("unsupported-batch-kind")
        val huge = SimpleOsHostGpuBatch(version: 1, generation: 1, run_id: "r", frame_id: 1, kind: "render", backend: "vulkan", width: 4096, height: 4096, element_count: 0, payload_bytes: 1, payload_checksum: 1)
        expect(simpleos_host_gpu_validate_batch(huge).reason).to_equal("output-exceeds-shared-region")
        val no_checksum = SimpleOsHostGpuBatch(version: 1, generation: 1, run_id: "r", frame_id: 1, kind: "processing", backend: "cuda", width: 0, height: 0, element_count: 10, payload_bytes: 1, payload_checksum: 0)
        expect(simpleos_host_gpu_validate_batch(no_checksum).reason).to_equal("invalid-payload-checksum")

    it "requires positive numeric wire correlation for non-HELLO requests":
        expect(simpleos_host_gpu_wire_correlation_valid(7, 9)).to_equal(true)
        expect(simpleos_host_gpu_wire_correlation_valid(0, 9)).to_equal(false)
        expect(simpleos_host_gpu_wire_correlation_valid(7, 0)).to_equal(false)
        expect(simpleos_host_gpu_wire_correlation_valid(-7, 9)).to_equal(false)

    it "accepts device proof and honest fallback":
        step("Report device-backed host acceleration evidence")
        val batch = render_batch()
        expect(simpleos_host_gpu_validate_receipt(batch, device_receipt("device_readback", 42)).status).to_equal("pass")
        val fallback = SimpleOsHostGpuReceipt(version: 1, generation: 7, run_id: "run-7", frame_id: 9, status: "fallback", backend: "software", reason: "host-service-unavailable", native_handle: 0, native_device_identity: "", readback_source: "cpu_reference", output_bytes: 3686400, output_checksum: 98765, elapsed_us: 10000)
        expect(simpleos_host_gpu_validate_receipt(batch, fallback).status).to_equal("pass")

    it "rejects stale and synthetic device receipts":
        val batch = render_batch()
        val stale = SimpleOsHostGpuReceipt(version: 1, generation: 6, run_id: "run-7", frame_id: 9, status: "pass", backend: "vulkan", reason: "pass", native_handle: 42, native_device_identity: "device-0", readback_source: "device_readback", output_bytes: 3686400, output_checksum: 1, elapsed_us: 1)
        expect(simpleos_host_gpu_validate_receipt(batch, stale).reason).to_equal("stale-generation")
        expect(simpleos_host_gpu_validate_receipt(batch, device_receipt("cpu_mirror", 0)).reason).to_equal("missing-native-device-provenance")
