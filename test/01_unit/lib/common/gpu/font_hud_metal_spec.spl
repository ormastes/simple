use std.spipe.*
use std.common.gpu.font_hud_metal.{FONT_HUD_METAL_VERTEX_ENTRY, FONT_HUD_METAL_FRAGMENT_ENTRY, FONT_HUD_METAL_VERTEX_BYTES, FONT_HUD_METAL_ATLAS_FORMAT, FONT_HUD_METAL_RGBA8_FORMAT, FONT_HUD_METAL_BGRA8_FORMAT, font_hud_metal_source}

describe "Metal font HUD contract":
    it "freezes exact entry names and a packed 20-byte vertex source layout":
        val source = font_hud_metal_source()
        expect FONT_HUD_METAL_VERTEX_ENTRY to_equal "simple_font_hud_vertex_v1"
        expect FONT_HUD_METAL_FRAGMENT_ENTRY to_equal "simple_font_hud_fragment_v1"
        expect FONT_HUD_METAL_VERTEX_BYTES to_equal 20
        expect FONT_HUD_METAL_ATLAS_FORMAT to_equal 1
        expect FONT_HUD_METAL_RGBA8_FORMAT to_equal 70
        expect FONT_HUD_METAL_BGRA8_FORMAT to_equal 80
        expect source to_contain "struct FontHudVertex { packed_float2 position; packed_float2 uv; uint color; };"
        expect source to_contain "static_assert(sizeof(FontHudVertex) == 20, \"FontHudVertex ABI\");"
        expect source to_contain "vertex FontHudVarying simple_font_hud_vertex_v1("
        expect source to_contain "fragment float4 simple_font_hud_fragment_v1("
        expect source to_contain "texture2d<float> atlas [[texture(0)]]"
        expect source to_contain "sampler atlas_sampler [[sampler(0)]]"
