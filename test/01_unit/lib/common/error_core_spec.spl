extern fn rt_file_read_text(path: text) -> text

fn common_error_source() -> text:
    rt_file_read_text("src/lib/common/error/error.spl") ?? ""

describe "ErrorCore":
    it "keeps canonical runtime error tagged value helper available":
        val source = common_error_source()

        expect(source).to_contain("pub fn rt_error_value() -> i64")
        expect(source).to_contain("Return the canonical RT_ERROR tagged value")
        expect(source).to_contain("27")

    it "keeps method-not-found reporting aligned with RT_ERROR semantics":
        val source = common_error_source()

        expect(source).to_contain("pub fn rt_method_not_found(type_name: text, method_name: text) -> i64")
        # NOTE: avoid `{...}` in the literal — Simple interpolates braces in string
        # literals, so assert the brace-free anchors of the source format string.
        expect(source).to_contain("Runtime error: Method '")
        expect(source).to_contain("' not found on type '")
        expect(source).to_contain("returns RT_ERROR")
