use std.spec.{describe, it, assert_equal}
use std.common.cbor.decode.{cbor_decode_type, cbor_decode_unsigned, cbor_decode_int, cbor_is_unsigned_int}

describe "CBOR decode type invalid guards":
    it "does not report invalid offsets as unsigned integer zero":
        val bytes = [0]
        val type_info = cbor_decode_type(bytes, -1)
        assert_equal(type_info.0, -1)
        assert_equal(type_info.1, -1)
        assert_equal(type_info.2, 0)

    it "rejects negative offsets in unsigned and signed integer decoders":
        val bytes = [0]
        val unsigned_result = cbor_decode_unsigned(bytes, -1)
        val int_result = cbor_decode_int(bytes, -1)
        assert_equal(unsigned_result.1, 0)
        assert_equal(int_result.1, 0)

    it "rejects out-of-range offsets in type predicates":
        val bytes = [0]
        assert_equal(cbor_is_unsigned_int(bytes, -1), false)
        assert_equal(cbor_is_unsigned_int(bytes, 10), false)
