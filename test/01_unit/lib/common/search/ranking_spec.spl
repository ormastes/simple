# ============================================================================
# ranking_spec.spl — BM25 / TF-IDF lexical ranking + top-k over Score (AC Phase 2)
#
# ABSOLUTE ORACLE discipline: the expected scores are HAND-COMPUTED from the
# real BM25/TF-IDF mathematics (true natural log), then truncated to Score's
# milli scale. They are NOT replayed from the implementation's integer ln
# series — that would be self-comparison. The 3-digit gap between the internal
# fixed-point precision (1e6) and the asserted milli scale (1e3) absorbs the
# series/rounding error, so an independent true-math oracle matches exactly.
#
# Hand corpus (3 docs, query = ["cat","dog"]):
#   doc0: dl=4, tf_cat=3, tf_dog=0   (dog ABSENT)
#   doc1: dl=6, tf_cat=1, tf_dog=2
#   doc2: dl=8, tf_cat=0, tf_dog=2   (cat ABSENT)
#   N=3, avgdl=(4+6+8)/3=6, df_cat=2, df_dog=2, k1=1.2, b=0.75
#
# True-math BM25 scores (×1000, truncated):
#   doc0 = 795.391 -> 795
#   doc1 = 1116.259 -> 1116
#   doc2 = 590.862 -> 590
#   ranked: doc1 > doc0 > doc2
#
# KNOWN BUGS designed around: no for-in over custom structs (index loops only);
# `text + i64` garbage (we never build text). f64 untrusted (integer asserts).
# ============================================================================

use std.spec
use lib.common.search.types.{Score}
use lib.common.search.ranking.{ScoredDoc, top_k, rank_all, bm25_score_default, tfidf_score, avg_doc_len_fixed}

# avgdl in fixed-point for the hand corpus: 6 * 1_000_000.
fn corpus_avgdl() -> i64:
    avg_doc_len_fixed([4, 6, 8])

# Convenience: pull the milli raw value out of a Score for integer asserts.
fn milli_of(s: Score) -> i64:
    s.raw_value()

describe "avg_doc_len_fixed":
    it "computes a fixed-point mean (6.0 -> 6_000_000)":
        expect(avg_doc_len_fixed([4, 6, 8])).to_equal(6000000)

    it "keeps fractional averages in fixed-point (5/2 = 2.5 -> 2_500_000)":
        expect(avg_doc_len_fixed([2, 3])).to_equal(2500000)

    it "is 0 for an empty corpus":
        expect(avg_doc_len_fixed([])).to_equal(0)

describe "BM25 absolute-oracle scores (k1=1.2, b=0.75)":
    it "doc0 (cat x3, dog absent, dl=4) scores 795 milli":
        # tfs aligned to query [cat, dog]; df aligned the same way.
        val s = bm25_score_default([3, 0], [2, 2], 4, corpus_avgdl(), 3)
        expect(milli_of(s)).to_equal(795)

    it "doc1 (cat x1, dog x2, dl=6) scores 1116 milli":
        val s = bm25_score_default([1, 2], [2, 2], 6, corpus_avgdl(), 3)
        expect(milli_of(s)).to_equal(1116)

    it "doc2 (cat absent, dog x2, dl=8) scores 590 milli":
        val s = bm25_score_default([0, 2], [2, 2], 8, corpus_avgdl(), 3)
        expect(milli_of(s)).to_equal(590)

    it "a term absent in a doc contributes nothing (tf=0 term dropped)":
        # doc with only cat present must equal the same doc scored cat-only.
        val both = bm25_score_default([3, 0], [2, 2], 4, corpus_avgdl(), 3)
        val cat_only = bm25_score_default([3], [2], 4, corpus_avgdl(), 3)
        expect(milli_of(both)).to_equal(milli_of(cat_only))
        expect(milli_of(cat_only)).to_equal(795)

describe "TF-IDF absolute-oracle scores":
    # idf = ln(1 + (2N - 2df + 1)/(2df + 1)). For N=3, df=3:
    #   = ln(1 + (6 - 6 + 1)/7) = ln(1 + 1/7) = ln(8/7) = 0.133531...
    # Both fixtures sit mid-interval so integer-series and true-math truncate
    # to the SAME milli value:
    #   tf=1 -> 0.133531 -> 133 milli   (frac .531)
    #   tf=3 -> 0.400594 -> 400 milli   (frac .594)
    it "tf=1, df=3, N=3 -> 133 milli (ln(8/7))":
        val s = tfidf_score([1], [3], 3)
        expect(milli_of(s)).to_equal(133)

    it "tf=3, df=3, N=3 -> 400 milli (3 * ln(8/7))":
        val s = tfidf_score([3], [3], 3)
        expect(milli_of(s)).to_equal(400)

    it "tf=0 contributes 0":
        val s = tfidf_score([0], [3], 3)
        expect(milli_of(s)).to_equal(0)

describe "ranking order over the hand corpus":
    it "ranks doc1 > doc0 > doc2 by BM25 score":
        val avg = corpus_avgdl()
        val d0 = ScoredDoc.of(0, bm25_score_default([3, 0], [2, 2], 4, avg, 3))
        val d1 = ScoredDoc.of(1, bm25_score_default([1, 2], [2, 2], 6, avg, 3))
        val d2 = ScoredDoc.of(2, bm25_score_default([0, 2], [2, 2], 8, avg, 3))
        val ranked = rank_all([d0, d1, d2])
        expect(ranked.len()).to_equal(3)
        expect(ranked[0].doc_id()).to_equal(1)
        expect(ranked[1].doc_id()).to_equal(0)
        expect(ranked[2].doc_id()).to_equal(2)
        # exact scaled scores survive into the ranked output
        expect(milli_of(ranked[0].relevance())).to_equal(1116)
        expect(milli_of(ranked[1].relevance())).to_equal(795)
        expect(milli_of(ranked[2].relevance())).to_equal(590)

describe "top_k selection over Score":
    it "returns the k best in ranked order":
        val a = ScoredDoc.of(10, Score.from_milli(500))
        val b = ScoredDoc.of(11, Score.from_milli(900))
        val c = ScoredDoc.of(12, Score.from_milli(700))
        val d = ScoredDoc.of(13, Score.from_milli(300))
        val r = top_k([a, b, c, d], 2)
        expect(r.len()).to_equal(2)
        expect(r[0].doc_id()).to_equal(11)
        expect(r[1].doc_id()).to_equal(12)

    it "breaks ties by ascending id (deterministic, no stability reliance)":
        # three docs share score 700; ids 5, 2, 9 must come out 2, 5, 9.
        val x = ScoredDoc.of(5, Score.from_milli(700))
        val y = ScoredDoc.of(2, Score.from_milli(700))
        val z = ScoredDoc.of(9, Score.from_milli(700))
        val r = top_k([x, y, z], 3)
        expect(r.len()).to_equal(3)
        expect(r[0].doc_id()).to_equal(2)
        expect(r[1].doc_id()).to_equal(5)
        expect(r[2].doc_id()).to_equal(9)

    it "mixed tie and ordering: top score wins, then id tie-break":
        val p = ScoredDoc.of(8, Score.from_milli(900))
        val q = ScoredDoc.of(3, Score.from_milli(900))
        val rr = ScoredDoc.of(1, Score.from_milli(400))
        val r = top_k([p, q, rr], 3)
        expect(r[0].doc_id()).to_equal(3)
        expect(r[1].doc_id()).to_equal(8)
        expect(r[2].doc_id()).to_equal(1)

    it "k larger than corpus returns all, k=0 returns none":
        val a = ScoredDoc.of(1, Score.from_milli(100))
        val b = ScoredDoc.of(2, Score.from_milli(200))
        expect(top_k([a, b], 9).len()).to_equal(2)
        expect(top_k([a, b], 0).len()).to_equal(0)
        expect(top_k([], 3).len()).to_equal(0)
