# @cover src/lib/common/search/exact.spl 90%
# Spec: exact single-pattern matching (AC-2) — memmem, Two-Way (Crochemore-
# Perrin), Boyer-Moore-Horspool, and find_all over Haystack/Pattern.
#
# Oracle discipline: every algorithm is cross-checked against an INDEPENDENT
# naive double-loop oracle implemented inline below (naive_first / naive_all),
# plus absolute hand-written position assertions. No self-comparison, no
# boolean-wrapper asserts.

use std.spec
use lib.common.search.exact.{memmem, two_way, boyer_moore_horspool, find_all}
use lib.common.search.types.{Haystack, Pattern, MatchSpan}

# ---------------------------------------------------------------------------
# Fixtures: bytes built explicitly so positions are hand-verifiable.
# ---------------------------------------------------------------------------
fn bytes_of(s: text) -> [u8]:
    s.bytes()

fn hay_of(s: text) -> Haystack:
    Haystack.new(s.bytes())

fn pat_of(s: text) -> Pattern:
    Pattern.new(s.bytes())

# ---------------------------------------------------------------------------
# Independent naive oracle (the absolute reference).
# Empty-pattern convention MUST match exact.spl: matches at every position.
# ---------------------------------------------------------------------------
fn naive_matches_at(h: [u8], p: [u8], pos: i64) -> bool:
    val pl = p.len()
    if pos + pl > h.len():
        return false
    var j = 0
    var ok = true
    while j < pl and ok:
        if h[pos + j] != p[j]:
            ok = false
        else:
            j = j + 1
    ok

fn naive_all(h: [u8], p: [u8]) -> [i64]:
    var out: [i64] = []
    val pl = p.len()
    val hl = h.len()
    if pl == 0:
        var z = 0
        while z <= hl:
            out.push(z)
            z = z + 1
        return out
    if pl > hl:
        return out
    var i = 0
    while i <= hl - pl:
        if naive_matches_at(h, p, i):
            out.push(i)
        i = i + 1
    out

fn naive_first(h: [u8], p: [u8]) -> i64:
    val all = naive_all(h, p)
    if all.len() == 0:
        return 0 - 1
    all[0]

# Collect just the start indices from a [MatchSpan] for comparison.
fn starts_of(spans: [MatchSpan]) -> [i64]:
    var out: [i64] = []
    var i = 0
    while i < spans.len():
        val sp = spans[i]
        out.push(sp.start())
        i = i + 1
    out

fn lists_equal(a: [i64], b: [i64]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    var ok = true
    while i < a.len() and ok:
        if a[i] != b[i]:
            ok = false
        else:
            i = i + 1
    ok

# Cross-check every algorithm's FIRST match against the naive oracle for one
# fixture, returning whether they all agree (with absolute oracle as truth).
fn first_agrees(hs: text, ps: text) -> bool:
    val h = bytes_of(hs)
    val p = bytes_of(ps)
    val oracle = naive_first(h, p)
    val hay = hay_of(hs)
    val pat = pat_of(ps)
    val mm = memmem(hay, pat).start()
    val tw = two_way(hay, pat).start()
    val bm = boyer_moore_horspool(hay, pat).start()
    (mm == oracle) and (tw == oracle) and (bm == oracle)

describe("exact single-pattern: absolute positions"):

    it("memmem finds 'ana' in 'banana' at index 1"):
        val r = memmem(hay_of("banana"), pat_of("ana"))
        expect(r.start()).to_equal(1)

    it("two_way finds 'ana' in 'banana' at index 1"):
        val r = two_way(hay_of("banana"), pat_of("ana"))
        expect(r.start()).to_equal(1)

    it("boyer_moore_horspool finds 'ana' in 'banana' at index 1"):
        val r = boyer_moore_horspool(hay_of("banana"), pat_of("ana"))
        expect(r.start()).to_equal(1)

    it("find_all reports overlapping 'ana' in 'banana' at 1 and 3"):
        val all = find_all(hay_of("banana"), pat_of("ana"))
        val starts = starts_of(all)
        expect(lists_equal(starts, [1, 3])).to_equal(true)

    it("absent pattern returns no-match sentinel (-1)"):
        val r = memmem(hay_of("banana"), pat_of("xyz"))
        expect(r.start()).to_equal(0 - 1)

    it("absent pattern find_all returns empty"):
        val all = find_all(hay_of("banana"), pat_of("xyz"))
        expect(all.len()).to_equal(0)

    it("pattern at start matches index 0"):
        val r = two_way(hay_of("hello world"), pat_of("hello"))
        expect(r.start()).to_equal(0)

    it("pattern at end matches"):
        # "world" starts at index 6 of "hello world"
        val r = boyer_moore_horspool(hay_of("hello world"), pat_of("world"))
        expect(r.start()).to_equal(6)

    it("match span has correct length"):
        val r = memmem(hay_of("banana"), pat_of("ana"))
        expect(r.length()).to_equal(3)

    it("match span end index is correct"):
        val r = memmem(hay_of("banana"), pat_of("ana"))
        expect(r.end()).to_equal(4)

describe("exact: edge cases"):

    it("pattern longer than haystack -> no match (memmem)"):
        val r = memmem(hay_of("hi"), pat_of("hello"))
        expect(r.start()).to_equal(0 - 1)

    it("pattern longer than haystack -> no match (two_way)"):
        val r = two_way(hay_of("hi"), pat_of("hello"))
        expect(r.start()).to_equal(0 - 1)

    it("pattern longer than haystack -> no match (BMH)"):
        val r = boyer_moore_horspool(hay_of("hi"), pat_of("hello"))
        expect(r.start()).to_equal(0 - 1)

    it("empty pattern matches at index 0 (memmem)"):
        val r = memmem(hay_of("abc"), pat_of(""))
        expect(r.start()).to_equal(0)

    it("empty pattern find_all matches every position 0..=len"):
        val all = find_all(hay_of("abc"), pat_of(""))
        # "abc" has len 3 -> positions 0,1,2,3
        expect(all.len()).to_equal(4)

    it("empty haystack with non-empty pattern -> no match"):
        val r = two_way(hay_of(""), pat_of("a"))
        expect(r.start()).to_equal(0 - 1)

    it("single-char pattern found at all positions"):
        val all = find_all(hay_of("aXaXa"), pat_of("a"))
        val starts = starts_of(all)
        expect(lists_equal(starts, [0, 2, 4])).to_equal(true)

describe("exact: cross-check vs naive oracle"):

    it("agrees on 'ana' in 'banana'"):
        expect(first_agrees("banana", "ana")).to_equal(true)

    it("agrees on overlap fixture 'aaa' in 'aaaaa'"):
        expect(first_agrees("aaaaa", "aaa")).to_equal(true)

    it("agrees on periodic 'abab' in 'ababab'"):
        expect(first_agrees("ababab", "abab")).to_equal(true)

    it("agrees on pattern-at-start"):
        expect(first_agrees("hello world", "hello")).to_equal(true)

    it("agrees on pattern-at-end"):
        expect(first_agrees("hello world", "world")).to_equal(true)

    it("agrees on absent pattern"):
        expect(first_agrees("abcdef", "gh")).to_equal(true)

    it("agrees on pattern longer than haystack"):
        expect(first_agrees("ab", "abcdef")).to_equal(true)

    it("agrees on repeated-suffix pattern"):
        expect(first_agrees("xabcabcabz", "abcab")).to_equal(true)

    it("agrees on single byte pattern"):
        expect(first_agrees("mississippi", "s")).to_equal(true)

    it("find_all all-positions match naive_all for 'iss' in 'mississippi'"):
        val starts = starts_of(find_all(hay_of("mississippi"), pat_of("iss")))
        val oracle = naive_all(bytes_of("mississippi"), bytes_of("iss"))
        expect(lists_equal(starts, oracle)).to_equal(true)

    it("find_all all-positions match naive_all for periodic 'aa' in 'aaaa'"):
        val starts = starts_of(find_all(hay_of("aaaa"), pat_of("aa")))
        val oracle = naive_all(bytes_of("aaaa"), bytes_of("aa"))
        expect(lists_equal(starts, oracle)).to_equal(true)

describe("exact: Two-Way periodic memory path"):

    it("two_way agrees with oracle on long periodic 'abcabc' in repeated text"):
        expect(first_agrees("abcabcabcabcabc", "abcabc")).to_equal(true)

    it("two_way agrees on all-same long pattern"):
        expect(first_agrees("aaaaaaaaaa", "aaaaaa")).to_equal(true)

    it("two_way agrees when periodic pattern is absent"):
        expect(first_agrees("abcabcabd", "abcabcabc")).to_equal(true)
