"""Track-changes spec.

Verifies the revision model (TextSpan.revision_id + RichDocument.revisions)
and the operations in track_changes.spl: tracked_insert/tracked_delete split
spans at exact offsets; accept/reject resolve a revision in the Office
direction (accept-insert keeps text, accept-delete removes it; reject is the
inverse); revisions_summary reports every pending revision; final_text is
the accepted-preview reading (delete-marked text excluded, insert-marked
text included) while spans_to_plain_text stays the "display / show markup"
reading (everything present, including delete-marked text) — every fixture
is hand-constructed and every assertion is over exact strings.
"""

use std.spec
use common.rich_text.attributed_text.{RichDocument, DocBlock, BlockKind, TextSpan, InlineStyle, spans_to_plain_text}
use common.rich_text.track_changes.{tracked_insert, tracked_delete, tracked_delete_range, tracked_insert_block, tracked_split_block, accept_revision, reject_revision, accept_all, reject_all, revisions_summary, final_text}

fn _plain_span(t: text) -> TextSpan:
    TextSpan(text: t, style: InlineStyle.Normal, link_url: "", footnote_id: "", comment_id: "", revision_id: "")

fn _doc1(spans: [TextSpan]) -> RichDocument:
    RichDocument(title: "T", blocks: [DocBlock(kind: BlockKind.Paragraph, spans: spans)], comments: [], revisions: [])

fn _doc2(a: text, b: text) -> RichDocument:
    """Two single-span plain paragraph blocks, for cross-block ops."""
    RichDocument(title: "T", blocks: [DocBlock(kind: BlockKind.Paragraph, spans: [_plain_span(a)]), DocBlock(kind: BlockKind.Paragraph, spans: [_plain_span(b)])], comments: [], revisions: [])

fn _doc3(a: text, b: text, c: text) -> RichDocument:
    """Three single-span plain paragraph blocks, for cross-block ops that
    need a genuine "middle" block."""
    RichDocument(title: "T", blocks: [DocBlock(kind: BlockKind.Paragraph, spans: [_plain_span(a)]), DocBlock(kind: BlockKind.Paragraph, spans: [_plain_span(b)]), DocBlock(kind: BlockKind.Paragraph, spans: [_plain_span(c)])], comments: [], revisions: [])

fn _span_texts(doc: RichDocument, block_idx: i32) -> [text]:
    var out: [text] = []
    for s in doc.blocks[block_idx].spans:
        out.push(s.text)
    out

describe "track changes: tracked_insert splits spans":
    """Inserting mid-span produces before/new/after spans with exact text;
    the new span carries a fresh insert revision."""

    it "splits a single span into before, inserted, after":
        val doc = _doc1([_plain_span("Hello world")])
        val d2 = tracked_insert(doc, 0, 5, " there", "Alice")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(3)
        expect(spans[0].text).to_equal("Hello")
        expect(spans[0].revision_id).to_equal("")
        expect(spans[1].text).to_equal(" there")
        expect(spans[1].revision_id).to_equal("1")
        expect(spans[2].text).to_equal(" world")
        expect(spans[2].revision_id).to_equal("")
        expect(d2.revisions.len()).to_equal(1)
        expect(d2.revisions[0].id).to_equal("1")
        expect(d2.revisions[0].author).to_equal("Alice")
        expect(d2.revisions[0].kind).to_equal("insert")

    it "inserts at offset 0 with no before-part":
        val doc = _doc1([_plain_span("Hello world")])
        val d2 = tracked_insert(doc, 0, 0, "Hi ", "Bob")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(2)
        expect(spans[0].text).to_equal("Hi ")
        expect(spans[0].revision_id).to_equal("1")
        expect(spans[1].text).to_equal("Hello world")

    it "inserts at the end with no after-part":
        val doc = _doc1([_plain_span("Hello world")])
        val d2 = tracked_insert(doc, 0, 11, "!", "Bob")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(2)
        expect(spans[0].text).to_equal("Hello world")
        expect(spans[1].text).to_equal("!")
        expect(spans[1].revision_id).to_equal("1")

describe "track changes: tracked_delete marks, does not remove":
    """A delete-revision span keeps its text (display view still recovers
    the original string) but is excluded from final_text (accepted view)."""

    it "marks the deleted range instead of removing it":
        val doc = _doc1([_plain_span("Hello world")])
        val d2 = tracked_delete(doc, 0, 0, 5, "Carol")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(2)
        expect(spans[0].text).to_equal("Hello")
        expect(spans[0].revision_id).to_equal("1")
        expect(spans[1].text).to_equal(" world")
        expect(spans[1].revision_id).to_equal("")
        expect(spans_to_plain_text(spans)).to_equal("Hello world")
        expect(final_text(d2)).to_equal(" world")
        expect(d2.revisions[0].kind).to_equal("delete")
        expect(d2.revisions[0].author).to_equal("Carol")

    it "splits a delete across 3 spans at exact boundaries":
        val doc = _doc1([_plain_span("AAA"), _plain_span("BBB"), _plain_span("CCC")])
        val d2 = tracked_delete(doc, 0, 1, 8, "Dave")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(5)
        expect(spans[0].text).to_equal("A")
        expect(spans[0].revision_id).to_equal("")
        expect(spans[1].text).to_equal("AA")
        expect(spans[1].revision_id).to_equal("1")
        expect(spans[2].text).to_equal("BBB")
        expect(spans[2].revision_id).to_equal("1")
        expect(spans[3].text).to_equal("CC")
        expect(spans[3].revision_id).to_equal("1")
        expect(spans[4].text).to_equal("C")
        expect(spans[4].revision_id).to_equal("")
        expect(spans_to_plain_text(spans)).to_equal("AAABBBCCC")
        expect(final_text(d2)).to_equal("AC")

describe "track changes: accept / reject":
    """accept keeps an insert's text (strips the mark) and removes a
    delete's spans; reject is the exact inverse."""

    it "accept_revision on an insert strips the mark and keeps the text":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_insert(doc, 0, 5, " there", "Alice")
        val d2 = accept_revision(d1, "1")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(3)
        expect(spans[1].text).to_equal(" there")
        expect(spans[1].revision_id).to_equal("")
        expect(d2.revisions.len()).to_equal(0)

    it "reject_revision on an insert removes the inserted span":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_insert(doc, 0, 5, " there", "Alice")
        val d2 = reject_revision(d1, "1")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(2)
        expect(spans[0].text).to_equal("Hello")
        expect(spans[1].text).to_equal(" world")
        expect(spans_to_plain_text(spans)).to_equal("Hello world")
        expect(d2.revisions.len()).to_equal(0)

    it "accept_revision on a delete removes the deleted span":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_delete(doc, 0, 0, 5, "Carol")
        val d2 = accept_revision(d1, "1")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(1)
        expect(spans[0].text).to_equal(" world")
        expect(d2.revisions.len()).to_equal(0)

    it "reject_revision on a delete restores the text and strips the mark":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_delete(doc, 0, 0, 5, "Carol")
        val d2 = reject_revision(d1, "1")
        val spans = d2.blocks[0].spans
        expect(spans.len()).to_equal(2)
        expect(spans[0].text).to_equal("Hello")
        expect(spans[0].revision_id).to_equal("")
        expect(spans_to_plain_text(spans)).to_equal("Hello world")
        expect(d2.revisions.len()).to_equal(0)

describe "track changes: accept_all / reject_all":
    """Resolving every pending revision at once, insert and delete mixed."""

    it "accept_all resolves both an insert and a delete revision":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_insert(doc, 0, 0, "Hi ", "Alice")
        val d2 = tracked_delete(d1, 0, 3, 8, "Bob")
        val d3 = accept_all(d2)
        expect(d3.revisions.len()).to_equal(0)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hi  world")

    it "reject_all undoes the insert and restores the deleted text":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_insert(doc, 0, 0, "Hi ", "Alice")
        val d2 = tracked_delete(d1, 0, 3, 8, "Bob")
        val d3 = reject_all(d2)
        expect(d3.revisions.len()).to_equal(0)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hello world")

describe "track changes: revisions_summary (multi-author)":
    """One '<id>|<author>|<kind>|<affected text>' line per pending revision."""

    it "reports insert then delete revisions from two different authors":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_insert(doc, 0, 0, "Hi ", "Alice")
        val d2 = tracked_delete(d1, 0, 3, 8, "Bob")
        val lines = revisions_summary(d2)
        expect(lines.len()).to_equal(2)
        expect(lines[0]).to_equal("1|Alice|insert|Hi ")
        expect(lines[1]).to_equal("2|Bob|delete|Hello")

describe "track changes: final_text vs display text":
    """final_text (accepted preview) excludes delete-marked text and keeps
    insert-marked text; spans_to_plain_text (display / show-markup) always
    keeps everything, unaffected by revisions."""

    it "final_text differs from the display text when a delete is pending":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_delete(doc, 0, 0, 5, "Carol")
        expect(spans_to_plain_text(d1.blocks[0].spans)).to_equal("Hello world")
        expect(final_text(d1)).to_equal(" world")

    it "final_text keeps pending insert text (accepted by default in that view)":
        val doc = _doc1([_plain_span("Hello world")])
        val d1 = tracked_insert(doc, 0, 5, " there", "Alice")
        expect(final_text(d1)).to_equal("Hello there world")

describe "track changes: tracked_delete_range pending state (2 blocks)":
    """A cross-block delete over 2 blocks marks the tail of the first block
    and the head of the second, both under ONE revision id, kind
    "delete_range"; block count is unchanged while pending."""

    it "marks the tail of block 0 and the head of block 1 with one shared id":
        val doc = _doc2("Hello world", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 1, 7, "Alice")
        expect(d2.blocks.len()).to_equal(2)
        val b0 = d2.blocks[0].spans
        expect(b0.len()).to_equal(2)
        expect(b0[0].text).to_equal("Hello ")
        expect(b0[0].revision_id).to_equal("")
        expect(b0[1].text).to_equal("world")
        expect(b0[1].revision_id).to_equal("1")
        val b1 = d2.blocks[1].spans
        expect(b1.len()).to_equal(2)
        expect(b1[0].text).to_equal("Goodbye")
        expect(b1[0].revision_id).to_equal("1")
        expect(b1[1].text).to_equal(" moon")
        expect(b1[1].revision_id).to_equal("")
        expect(d2.revisions.len()).to_equal(1)
        expect(d2.revisions[0].kind).to_equal("delete_range")
        expect(d2.revisions[0].author).to_equal("Alice")

describe "track changes: tracked_delete_range pending state (3 blocks, middle fully marked)":
    """A cross-block delete spanning 3 blocks marks the tail of the first,
    ALL of the middle block, and the head of the last — one shared id."""

    it "marks tail, full middle, and head under the same revision id":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        expect(d2.blocks.len()).to_equal(3)
        expect(d2.blocks[0].spans[1].text).to_equal("world")
        expect(d2.blocks[0].spans[1].revision_id).to_equal("1")
        val mid = d2.blocks[1].spans
        expect(mid.len()).to_equal(1)
        expect(mid[0].text).to_equal("Middle stuff")
        expect(mid[0].revision_id).to_equal("1")
        expect(d2.blocks[2].spans[0].text).to_equal("Goodbye")
        expect(d2.blocks[2].spans[0].revision_id).to_equal("1")
        expect(d2.blocks[2].spans[1].text).to_equal(" moon")
        expect(d2.blocks[2].spans[1].revision_id).to_equal("")

describe "track changes: accept_revision on a delete_range merges the block range":
    """Accepting a cross-block delete drops the deleted spans AND merges
    the whole touched block range into ONE block — the middle block(s)
    don't survive as empty paragraphs."""

    it "2-block case: accept merges into one block with the surviving text":
        val doc = _doc2("Hello world", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 1, 7, "Alice")
        val d3 = accept_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(1)
        expect(d3.blocks[0].spans.len()).to_equal(2)
        expect(d3.blocks[0].spans[0].text).to_equal("Hello ")
        expect(d3.blocks[0].spans[1].text).to_equal(" moon")
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hello  moon")
        expect(d3.revisions.len()).to_equal(0)

    it "3-block case: accept drops the middle block, merges head+tail":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        val d3 = accept_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(1)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hello  moon")
        expect(d3.revisions.len()).to_equal(0)

describe "track changes: reject_revision on a delete_range unmarks in place":
    """Rejecting a cross-block delete restores every tagged span's text and
    strips the mark — block count is UNCHANGED (blocks stay separate, same
    as before the delete was ever proposed)."""

    it "3-block case: reject restores exact original per-block text":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        val d3 = reject_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(3)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hello world")
        expect(spans_to_plain_text(d3.blocks[1].spans)).to_equal("Middle stuff")
        expect(spans_to_plain_text(d3.blocks[2].spans)).to_equal("Goodbye moon")
        expect(d3.blocks[0].spans[1].revision_id).to_equal("")
        expect(d3.blocks[1].spans[0].revision_id).to_equal("")
        expect(d3.blocks[2].spans[0].revision_id).to_equal("")
        expect(d3.revisions.len()).to_equal(0)

describe "track changes: tracked_delete_range degenerates to a same-block delete":
    """from_block == to_block behaves exactly like tracked_delete — no
    separate code path needed, the merge logic degenerates to lo == hi."""

    it "same-block delete_range marks and accepts like an ordinary delete":
        val doc = _doc1([_plain_span("Hello world")])
        val d2 = tracked_delete_range(doc, 0, 0, 0, 5, "Carol")
        expect(d2.blocks.len()).to_equal(1)
        expect(d2.revisions[0].kind).to_equal("delete_range")
        val d3 = accept_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(1)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal(" world")

describe "track changes: tracked_insert_block inserts whole marked paragraphs":
    """A whole-paragraph insert creates one new DocBlock per string in
    `paragraphs`, each a single span tagged with a fresh "insert_block"
    revision, placed right after `after_block_index`."""

    it "inserts 2 new blocks after block 0, tagged insert_block":
        val doc = _doc2("First", "Second")
        val d2 = tracked_insert_block(doc, 0, ["New1", "New2"], "Bob")
        expect(d2.blocks.len()).to_equal(4)
        expect(spans_to_plain_text(d2.blocks[0].spans)).to_equal("First")
        expect(spans_to_plain_text(d2.blocks[1].spans)).to_equal("New1")
        expect(d2.blocks[1].spans[0].revision_id).to_equal("1")
        expect(spans_to_plain_text(d2.blocks[2].spans)).to_equal("New2")
        expect(d2.blocks[2].spans[0].revision_id).to_equal("1")
        expect(spans_to_plain_text(d2.blocks[3].spans)).to_equal("Second")
        expect(d2.revisions[0].kind).to_equal("insert_block")

    it "after_block_index -1 prepends at the very start":
        val doc = _doc2("First", "Second")
        val d2 = tracked_insert_block(doc, -1, ["Lead"], "Bob")
        expect(d2.blocks.len()).to_equal(3)
        expect(spans_to_plain_text(d2.blocks[0].spans)).to_equal("Lead")
        expect(spans_to_plain_text(d2.blocks[1].spans)).to_equal("First")

describe "track changes: accept/reject on insert_block":
    """Accept reuses the plain "insert" strip-the-mark path (blocks already
    exist); reject removes the whole inserted block(s), not just their
    spans — the block only ever existed because of this revision."""

    it "accept keeps the new blocks, strips the mark, block count unchanged":
        val doc = _doc2("First", "Second")
        val d2 = tracked_insert_block(doc, 0, ["New1", "New2"], "Bob")
        val d3 = accept_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(4)
        expect(d3.blocks[1].spans[0].revision_id).to_equal("")
        expect(spans_to_plain_text(d3.blocks[1].spans)).to_equal("New1")
        expect(d3.revisions.len()).to_equal(0)

    it "reject removes the new blocks entirely, restoring the original 2":
        val doc = _doc2("First", "Second")
        val d2 = tracked_insert_block(doc, 0, ["New1", "New2"], "Bob")
        val d3 = reject_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(2)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("First")
        expect(spans_to_plain_text(d3.blocks[1].spans)).to_equal("Second")
        expect(d3.revisions.len()).to_equal(0)

describe "track changes: tracked_split_block models pressing Enter mid-paragraph":
    """Pending state is an ACTUAL split into head/tail blocks; the new
    paragraph mark is a zero-length "split"-tagged marker span prepended
    to the tail block."""

    it "splits one block into head and tail blocks with a marker on the tail":
        val doc = _doc2("Hello world", "Second")
        val d2 = tracked_split_block(doc, 0, 5, "Carol")
        expect(d2.blocks.len()).to_equal(3)
        expect(spans_to_plain_text(d2.blocks[0].spans)).to_equal("Hello")
        val tail = d2.blocks[1].spans
        expect(tail[0].text).to_equal("")
        expect(tail[0].revision_id).to_equal("1")
        expect(tail[1].text).to_equal(" world")
        expect(spans_to_plain_text(d2.blocks[1].spans)).to_equal(" world")
        expect(spans_to_plain_text(d2.blocks[2].spans)).to_equal("Second")
        expect(d2.revisions[0].kind).to_equal("split")

describe "track changes: split accept/reject are exact inverses":
    """accept keeps the split (drops the inert marker); reject re-joins
    head+tail back into one block — reject(split(doc)) reproduces the
    original text and block count exactly."""

    it "accept keeps the two blocks, strips the marker":
        val doc = _doc2("Hello world", "Second")
        val d2 = tracked_split_block(doc, 0, 5, "Carol")
        val d3 = accept_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(3)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hello")
        expect(spans_to_plain_text(d3.blocks[1].spans)).to_equal(" world")
        expect(d3.revisions.len()).to_equal(0)

    it "reject re-joins into one block, reproducing the original text exactly":
        val doc = _doc2("Hello world", "Second")
        val d2 = tracked_split_block(doc, 0, 5, "Carol")
        val d3 = reject_revision(d2, "1")
        expect(d3.blocks.len()).to_equal(2)
        expect(spans_to_plain_text(d3.blocks[0].spans)).to_equal("Hello world")
        expect(spans_to_plain_text(d3.blocks[1].spans)).to_equal("Second")
        expect(d3.revisions.len()).to_equal(0)

describe "track changes: multi-author interleaved (cross-block delete + insert_block)":
    """Two different authors' pending revisions with DISJOINT block ranges
    resolve independently regardless of order — accepting one does not
    disturb the other's not-yet-resolved block(s)."""

    it "accept Alice's cross-block delete, then reject Bob's insert_block":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d1 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        val d2 = tracked_insert_block(d1, 2, ["Injected"], "Bob")
        expect(d2.blocks.len()).to_equal(4)
        val d3 = accept_revision(d2, "1")
        val d4 = reject_revision(d3, "2")
        expect(d4.blocks.len()).to_equal(1)
        expect(spans_to_plain_text(d4.blocks[0].spans)).to_equal("Hello  moon")
        expect(d4.revisions.len()).to_equal(0)

    it "same scenario resolved in the opposite order (reject Bob, then accept Alice)":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d1 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        val d2 = tracked_insert_block(d1, 2, ["Injected"], "Bob")
        val d3 = reject_revision(d2, "2")
        val d4 = accept_revision(d3, "1")
        expect(d4.blocks.len()).to_equal(1)
        expect(spans_to_plain_text(d4.blocks[0].spans)).to_equal("Hello  moon")
        expect(d4.revisions.len()).to_equal(0)

describe "track changes: revisions_summary aggregates a cross-block delete_range":
    """The affected-text column concatenates every tagged span across ALL
    touched blocks, in doc.revisions order — no change needed to
    revisions_summary itself, it was already block-agnostic."""

    it "reports the delete_range's affected text spanning all 3 blocks":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        val lines = revisions_summary(d2)
        expect(lines.len()).to_equal(1)
        expect(lines[0]).to_equal("1|Alice|delete_range|worldMiddle stuffGoodbye")

describe "track changes: final_text for pending cross-block states":
    """final_text excludes a pending delete_range's deleted middle blocks
    AND joins the surviving head+tail with no paragraph break — the
    accepted-preview reading already looks merged, matching what accept
    would do structurally. A pending insert_block's new paragraphs are
    included (accepted by default); a pending split's two paragraphs
    render as two separate lines (the split already visually happened)."""

    it "cross-block delete: middle block vanishes, head+tail join with no break":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 2, 7, "Alice")
        expect(final_text(d2)).to_equal("Hello  moon")

    it "2-block cross-block delete: no blank line, head+tail join directly":
        val doc = _doc2("Hello world", "Goodbye moon")
        val d2 = tracked_delete_range(doc, 0, 6, 1, 7, "Alice")
        expect(final_text(d2)).to_equal("Hello  moon")

    it "pending insert_block: new paragraphs appear as their own lines":
        val doc = _doc2("First", "Second")
        val d2 = tracked_insert_block(doc, 0, ["New1"], "Bob")
        expect(final_text(d2)).to_equal("First\nNew1\nSecond")

    it "pending split: two paragraphs already separate in the final reading":
        val doc = _doc2("Hello world", "Second")
        val d2 = tracked_split_block(doc, 0, 5, "Carol")
        expect(final_text(d2)).to_equal("Hello\n world\nSecond")

    it "unrelated single-block delete still uses a newline-joined final_text (regression)":
        val doc = _doc3("Hello world", "Middle stuff", "Goodbye moon")
        val d1 = tracked_delete(doc, 1, 0, 6, "Dave")
        expect(final_text(d1)).to_equal("Hello world\n stuff\nGoodbye moon")
