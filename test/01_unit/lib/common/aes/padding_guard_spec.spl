use std.spec.{describe, it, assert_equal}
use std.common.aes.padding.{pkcs7_pad, pkcs7_unpad}

describe "AES PKCS7 padding guards":
    it "pads valid data":
        assert_equal(pkcs7_pad([1, 2, 3], 4), [1, 2, 3, 1])

    it "does not pad invalid block sizes":
        assert_equal(pkcs7_pad([1, 2, 3], 0), [1, 2, 3])
        assert_equal(pkcs7_pad([1, 2, 3], -1), [1, 2, 3])

    it "unpads valid padding":
        assert_equal(pkcs7_unpad([1, 2, 2, 2]), [1, 2])

    it "keeps data when padding bytes do not match":
        assert_equal(pkcs7_unpad([1, 2, 3, 2]), [1, 2, 3, 2])

    it "keeps data for invalid padding lengths":
        assert_equal(pkcs7_unpad([1, 2, 3, 0]), [1, 2, 3, 0])
        assert_equal(pkcs7_unpad([1, 2, 3, 9]), [1, 2, 3, 9])
