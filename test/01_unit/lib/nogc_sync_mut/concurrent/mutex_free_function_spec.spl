use std.spec.*
use std.nogc_sync_mut.concurrent.mutex.{mutex_new, mutex_lock, mutex_try_lock, mutex_unlock}

describe "native-safe mutex free functions":
    it "locks and updates one explicit mutex argument":
        val mutex = mutex_new(7)
        expect(mutex_lock(mutex)).to_equal(7)
        expect(mutex_unlock(mutex, 11)).to_equal(1)
        expect(mutex_try_lock(mutex)).to_equal(11)
        expect(mutex_unlock(mutex, 13)).to_equal(1)
