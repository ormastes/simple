use std.spec
use std.nogc_sync_mut.engine.render.vulkan_commands.{
    VulkanCommand3D, VulkanCommand3DKind,
    vk_cmd3d_begin_render_pass, vk_cmd3d_set_pipeline,
    vk_cmd3d_bind_vertex_buffer, vk_cmd3d_bind_index_buffer,
    vk_cmd3d_bind_texture, vk_cmd3d_bind_uniform_buffer,
    vk_cmd3d_bind_font_texture, vk_cmd3d_draw_indexed, vk_cmd3d_draw,
    vk_cmd3d_end_render_pass
}
use std.nogc_sync_mut.engine.render.vulkan_backend3d.{VulkanRenderBackend3D}
use std.nogc_sync_mut.engine.render.backend3d.{
    PipelineHandle, BufferHandle, TextureHandle, RenderPassHandle, PipelineDesc3D, TextureFormat3D
}
use std.nogc_sync_mut.engine.render.capability3d.{RenderBackendKind3D}

# ============================================================================
# Module-level helpers — enum data cannot be inside it blocks
# ============================================================================

fn make_begin_render_pass_cmd() -> VulkanCommand3D:
    vk_cmd3d_begin_render_pass(10, 20)

fn make_set_pipeline_cmd() -> VulkanCommand3D:
    vk_cmd3d_set_pipeline(5)

fn make_bind_vertex_buffer_cmd() -> VulkanCommand3D:
    vk_cmd3d_bind_vertex_buffer(1, 0)

fn make_bind_index_buffer_cmd() -> VulkanCommand3D:
    vk_cmd3d_bind_index_buffer(2)

fn make_bind_texture_cmd() -> VulkanCommand3D:
    vk_cmd3d_bind_texture(3, 0)

fn make_bind_uniform_buffer_cmd() -> VulkanCommand3D:
    vk_cmd3d_bind_uniform_buffer(4, 0)

fn make_bind_font_texture_cmd() -> VulkanCommand3D:
    vk_cmd3d_bind_font_texture(5, 3, 7)

fn make_draw_indexed_cmd() -> VulkanCommand3D:
    vk_cmd3d_draw_indexed(36, 0)

fn make_draw_cmd() -> VulkanCommand3D:
    vk_cmd3d_draw(6)

fn make_end_render_pass_cmd() -> VulkanCommand3D:
    vk_cmd3d_end_render_pass()

fn make_pipeline_desc() -> PipelineDesc3D:
    PipelineDesc3D(
        vertex_shader_spirv: [],
        fragment_shader_spirv: [],
        vertex_shader_wgsl: "",
        fragment_shader_wgsl: "",
        vertex_stride: 32,
        cull_back_faces: true,
        depth_write: true,
        depth_test: true
    )

# ============================================================================
# Stream B — vulkan_commands.spl + vulkan_backend3d.spl specs
# AC-1 (Vulkan impl), AC-10
# ============================================================================

describe "Stream B: VulkanCommand3D kind-tag construction":

    describe "BeginRenderPass":
        it "AC-1: kind is BeginRenderPass":
            val cmd = make_begin_render_pass_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.BeginRenderPass
            expect(matches).to_equal(true)

        it "AC-1: stores color_image":
            val cmd = make_begin_render_pass_cmd()
            expect(cmd.color_image).to_equal(10)

        it "AC-1: stores depth_image":
            val cmd = make_begin_render_pass_cmd()
            expect(cmd.depth_image).to_equal(20)

    describe "SetPipeline":
        it "AC-1: kind is SetPipeline":
            val cmd = make_set_pipeline_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.SetPipeline
            expect(matches).to_equal(true)

        it "AC-1: stores pipeline_id":
            val cmd = make_set_pipeline_cmd()
            expect(cmd.pipeline_id).to_equal(5)

    describe "BindVertexBuffer":
        it "AC-1: kind is BindVertexBuffer":
            val cmd = make_bind_vertex_buffer_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.BindVertexBuffer
            expect(matches).to_equal(true)

        it "AC-1: stores buffer_id and slot":
            val cmd = make_bind_vertex_buffer_cmd()
            val ok = cmd.buffer_id == 1 and cmd.slot == 0
            expect(ok).to_equal(true)

    describe "BindIndexBuffer":
        it "AC-1: kind is BindIndexBuffer":
            val cmd = make_bind_index_buffer_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.BindIndexBuffer
            expect(matches).to_equal(true)

        it "AC-1: stores buffer_id":
            val cmd = make_bind_index_buffer_cmd()
            expect(cmd.buffer_id).to_equal(2)

    describe "BindTexture":
        it "AC-1: kind is BindTexture":
            val cmd = make_bind_texture_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.BindTexture
            expect(matches).to_equal(true)

        it "AC-1: stores image_id and slot":
            val cmd = make_bind_texture_cmd()
            val ok = cmd.image_id == 3 and cmd.slot == 0
            expect(ok).to_equal(true)

    describe "BindUniformBuffer":
        it "AC-1: kind is BindUniformBuffer":
            val cmd = make_bind_uniform_buffer_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.BindUniformBuffer
            expect(matches).to_equal(true)

        it "AC-1: stores buffer_id and slot":
            val cmd = make_bind_uniform_buffer_cmd()
            val ok = cmd.buffer_id == 4 and cmd.slot == 0
            expect(ok).to_equal(true)

    describe "BindFontTexture":
        it "records the dedicated pipeline, atlas, and reusable sampler handles":
            val cmd = make_bind_font_texture_cmd()
            val ok = cmd.kind == VulkanCommand3DKind.BindFontTexture and cmd.pipeline_id == 5 and cmd.image_id == 3 and cmd.buffer_id == 7
            expect(ok).to_equal(true)

    describe "DrawIndexed":
        it "AC-1: kind is DrawIndexed":
            val cmd = make_draw_indexed_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.DrawIndexed
            expect(matches).to_equal(true)

        it "AC-1: stores index_count and base_vertex":
            val cmd = make_draw_indexed_cmd()
            val ok = cmd.index_count == 36 and cmd.base_vertex == 0
            expect(ok).to_equal(true)

    describe "Draw":
        it "records the six non-indexed vertices of one font quad":
            val cmd = make_draw_cmd()
            val ok = cmd.kind == VulkanCommand3DKind.Draw and cmd.index_count == 6
            expect(ok).to_equal(true)

    describe "EndRenderPass":
        it "AC-1: kind is EndRenderPass":
            val cmd = make_end_render_pass_cmd()
            val matches = cmd.kind == VulkanCommand3DKind.EndRenderPass
            expect(matches).to_equal(true)

describe "Stream B: VulkanRenderBackend3D command recording":

    describe "canonical Vertex3D pipeline state":
        it "carries the 32-byte mesh wire layout plus topology and blend defaults":
            val desc = make_pipeline_desc()
            expect(desc.vertex_stride).to_equal(32)
            expect(desc.topology).to_equal(3)
            expect(desc.blend_mode).to_equal(1)

    describe "native device evidence":

        it "resolves native pipeline and texture handles by logical identity":
            var backend = VulkanRenderBackend3D.create()
            backend.pipeline_ids = [11, 22]
            backend.pipeline_native = [101, 202]
            backend.texture_ids = [33, 44]
            backend.texture_native = [303, 404]
            expect(backend.pipeline_native_handle(PipelineHandle(id: 22))).to_equal(202)
            expect(backend.pipeline_native_handle(PipelineHandle(id: 99))).to_equal(0)
            expect(backend.texture_native_handle(TextureHandle(id: 33))).to_equal(303)
            expect(backend.texture_native_handle(TextureHandle(id: 99))).to_equal(0)

        it "clears prior-frame color and readback provenance at frame start":
            var backend = VulkanRenderBackend3D.create()
            backend.last_color_image = 7
            backend.last_readback_image = 7
            backend.begin_frame()
            expect(backend.last_color_image).to_equal(0)
            expect(backend.last_readback_image).to_equal(0)

        it "reuses one framebuffer for repeated passes on the same color target":
            var backend = VulkanRenderBackend3D.create()
            if backend.init(4, 4):
                val color = backend.create_texture(4, 4, TextureFormat3D.Rgba8Unorm)
                val depth = backend.create_texture(4, 4, TextureFormat3D.Depth32Float)
                backend.begin_render_pass(color, depth)
                backend.begin_render_pass(color, depth)
                expect(backend.cached_framebuffer_count()).to_equal(1)
                backend.shutdown()

        it "borrows an already active Vulkan session without taking shutdown ownership":
            var owner = VulkanRenderBackend3D.create()
            if owner.init(4, 4):
                var borrower = VulkanRenderBackend3D.create()
                expect(borrower.init(4, 4)).to_equal(true)
                expect(borrower.owns_vulkan_session()).to_equal(false)
                borrower.shutdown()
                owner.shutdown()
        it "reports real handles only after native init or explicit unavailability":
            var backend = VulkanRenderBackend3D.create()
            val initialized = backend.init(4, 4)
            val evidence = backend.device_evidence()
            if initialized:
                expect(evidence.device_handle).to_be_greater_than(0)
                expect(evidence.device_name.len()).to_be_greater_than(0)
            else:
                expect(evidence.status).to_equal("unavailable")
                expect(evidence.reason.len()).to_be_greater_than(0)
            expect(evidence.texture_binding_ready).to_equal(false)
            expect(evidence.submitted_command_handle).to_equal(0)
            expect(evidence.color_image_handle).to_equal(0)
            expect(evidence.readback_source).to_equal("unavailable")
            if initialized:
                backend.shutdown()

        it "discards the command buffer when texture binding blocks recording":
            var backend = VulkanRenderBackend3D.create()
            val initialized = backend.init(4, 4)
            if initialized:
                backend.begin_frame()
                val texture = backend.create_texture(4, 4, TextureFormat3D.Rgba8Unorm)
                backend.bind_texture(RenderPassHandle.invalid(), texture, 0)
                backend.end_frame()
            val evidence = backend.device_evidence()
            expect(evidence.command_handle).to_equal(0)
            expect(evidence.submitted_command_handle).to_equal(0)
            expect(evidence.color_image_handle).to_equal(0)
            expect(evidence.readback_source).to_equal("unavailable")
            expect(evidence.status).to_equal("unavailable")
            expect(evidence.texture_binding_ready).to_equal(false)
            if initialized:
                backend.shutdown()

    describe "capabilities":
        it "AC-1: backend kind is Vulkan":
            var backend = VulkanRenderBackend3D.create()
            val cap = backend.capabilities()
            val is_vulkan = cap.backend == RenderBackendKind3D.Vulkan
            expect(is_vulkan).to_equal(true)

    describe "create_vertex_buffer records command":
        it "AC-1: create_vertex_buffer returns non-invalid handle":
            var backend = VulkanRenderBackend3D.create()
            val buf = backend.create_vertex_buffer(256)
            expect(buf.id).to_be_greater_than(-1)

    describe "create_index_buffer":
        it "AC-1: create_index_buffer returns non-invalid handle":
            var backend = VulkanRenderBackend3D.create()
            val buf = backend.create_index_buffer(64)
            expect(buf.id).to_be_greater_than(-1)

    describe "create_uniform_buffer":
        it "AC-1: create_uniform_buffer returns non-invalid handle":
            var backend = VulkanRenderBackend3D.create()
            val buf = backend.create_uniform_buffer(64)
            expect(buf.id).to_be_greater_than(-1)

    describe "create_texture":
        it "AC-1: create_texture returns non-invalid TextureHandle":
            var backend = VulkanRenderBackend3D.create()
            val tex = backend.create_texture(128, 128, TextureFormat3D.Rgba8Unorm)
            expect(tex.id).to_be_greater_than(-1)

    describe "create_pipeline":
        it "AC-1: create_pipeline returns non-invalid PipelineHandle":
            var backend = VulkanRenderBackend3D.create()
            val desc = make_pipeline_desc()
            val pip = backend.create_pipeline(desc)
            expect(pip.id).to_be_greater_than(-1)

    describe "dedicated font pipeline recording":
        it "keeps sampled-font binding separate from the fail-closed generic texture path":
            var backend = VulkanRenderBackend3D.create()
            val pipeline = backend.create_font_pipeline([], [])
            val atlas = backend.create_texture(4, 2, TextureFormat3D.R8Unorm)
            val rph = RenderPassHandle.invalid()
            backend.bind_font_texture(rph, pipeline, atlas)
            backend.draw_font_vertices(rph, 6)
            val ok = backend.cmds.len() == 2 and backend.cmds[0].kind == VulkanCommand3DKind.BindFontTexture and backend.cmds[1].kind == VulkanCommand3DKind.Draw
            expect(ok).to_equal(true)

    describe "frame + render pass recording sequence":
        it "AC-1: begin_frame does not crash":
            var backend = VulkanRenderBackend3D.create()
            backend.begin_frame()
            expect(backend.cmds.len()).to_equal(0)

        it "AC-1: begin_render_pass returns non-invalid RenderPassHandle":
            var backend = VulkanRenderBackend3D.create()
            backend.begin_frame()
            val color_tex = backend.create_texture(320, 240, TextureFormat3D.Rgba8Unorm)
            val depth_tex = backend.create_texture(320, 240, TextureFormat3D.Depth32Float)
            val rph = backend.begin_render_pass(color_tex, depth_tex)
            expect(rph.id).to_be_greater_than(-1)

        it "AC-1: end_render_pass after begin does not crash":
            var backend = VulkanRenderBackend3D.create()
            backend.begin_frame()
            val color_tex = backend.create_texture(320, 240, TextureFormat3D.Rgba8Unorm)
            val depth_tex = backend.create_texture(320, 240, TextureFormat3D.Depth32Float)
            val rph = backend.begin_render_pass(color_tex, depth_tex)
            backend.end_render_pass(rph)
            expect(backend.cmds.len()).to_equal(2)
            val is_end = backend.cmds[1].kind == VulkanCommand3DKind.EndRenderPass
            expect(is_end).to_equal(true)

        it "AC-1: end_frame after full sequence does not crash":
            var backend = VulkanRenderBackend3D.create()
            backend.begin_frame()
            val color_tex = backend.create_texture(320, 240, TextureFormat3D.Rgba8Unorm)
            val depth_tex = backend.create_texture(320, 240, TextureFormat3D.Depth32Float)
            val rph = backend.begin_render_pass(color_tex, depth_tex)
            val desc = make_pipeline_desc()
            val pip = backend.create_pipeline(desc)
            val vbuf = backend.create_vertex_buffer(128)
            val ibuf = backend.create_index_buffer(48)
            backend.set_pipeline(rph, pip)
            backend.bind_vertex_buffer(rph, vbuf, 0)
            backend.bind_index_buffer(rph, ibuf)
            backend.draw_indexed(rph, 12, 0)
            backend.end_render_pass(rph)
            backend.end_frame()
            expect(backend.cmds.len()).to_equal(0)
