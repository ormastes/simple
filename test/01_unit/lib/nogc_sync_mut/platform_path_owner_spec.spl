use std.io_runtime.{file_read}
use std.spec.{describe, it, expect}

describe "nogc_sync_mut platform path ownership":

    it "retains canonical path implementations through native entry closure":
        val source = file_read("src/lib/nogc_sync_mut/platform.spl")
        expect(source).to_contain("use nogc_sync_mut.path")
        expect(source).to_contain("path.normalize_path(input_path)")
        expect(source).to_contain("path.is_absolute_path(input_path)")
        expect(source).to_contain("path.join_path(base, child)")
        expect(source.contains(" as path_normalize_path")).to_equal(false)
        expect(source.contains(" as path_is_absolute_path")).to_equal(false)
        expect(source.contains(" as path_join_path")).to_equal(false)
