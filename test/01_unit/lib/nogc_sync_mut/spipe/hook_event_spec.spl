use std.nogc_sync_mut.spipe.hook_event.{spipe_hook_event, spipe_hook_normalize_provider, spipe_hook_phase, spipe_hook_rules}

fn test_provider_normalization():
    assert(spipe_hook_normalize_provider("OpenAI Codex") == "codex")
    assert(spipe_hook_normalize_provider("Claude") == "claude")
    assert(spipe_hook_normalize_provider("Gemini") == "gemini")
    assert(spipe_hook_normalize_provider("Cursor") == "cursor")

fn test_phase_mapping():
    assert(spipe_hook_phase("claude", "PreToolUse") == "pre_tool")
    assert(spipe_hook_phase("codex", "turn_finish") == "post_turn")
    assert(spipe_hook_phase("gemini", "prompt_submit") == "pre_prompt")
    assert(spipe_hook_phase("cursor", "before_edit") == "pre_edit")
    assert(spipe_hook_phase("cursor", "post_edit") == "post_edit")

fn test_hook_event_render():
    val out = spipe_hook_event("codex", "tool_start", "{\"x\":1}", "Shell", "/repo", "simple", "a.spl,b.spl", "diff --git", "run test")
    assert(out.contains("@hook v=1"))
    assert(out.contains("client=codex"))
    assert(out.contains("phase=pre_tool"))
    assert(out.contains("@files a.spl b.spl"))
    assert(out.contains("@raw_payload present=true"))

fn test_hook_rules():
    val out = spipe_hook_rules("claude")
    assert(out.contains("PreToolUse=pre_tool"))
    assert(out.contains("Stop=session_end"))
    val cursor = spipe_hook_rules("cursor")
    assert(cursor.contains("pre_edit=pre_edit"))
