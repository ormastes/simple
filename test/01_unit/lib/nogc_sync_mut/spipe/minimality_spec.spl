use std.nogc_sync_mut.spipe.minimality.{spipe_minimality_check, spipe_minimality_debt, spipe_minimality_review}

fn test_minimality_prefers_native_date_input():
    val out = spipe_minimality_check("add date picker", "custom DatePicker component", "full")
    assert(out.contains("@decision rung=native"))
    assert(out.contains("<input type=\"date\">"))
    assert(out.contains("keep validation"))

fn test_minimality_check_covers_core_ponytail_rungs():
    assert(spipe_minimality_check("remove unused helper", "dead code", "full").contains("@decision rung=delete"))
    assert(spipe_minimality_check("maybe later hook", "future-proof extension", "full").contains("@decision rung=yagni"))
    assert(spipe_minimality_check("cache class", "custom cache", "full").contains("@decision rung=stdlib"))
    assert(spipe_minimality_check("single provider", "one interface adapter", "full").contains("@decision rung=shrink"))

fn test_minimality_review_finds_abstraction_and_dependency():
    val out = spipe_minimality_review("dead code\nclass WidgetFactory:\n# npm install huge-picker", "full")
    assert(out.contains("delete:L1"))
    assert(out.contains("shrink:L2"))
    assert(out.contains("dependency:L3"))

fn test_minimality_debt_lists_markers():
    val out = spipe_minimality_debt("// ponytail: global lock, split by workspace if throughput matters")
    assert(out.contains("@minimality v=1 kind=debt count=1"))
    assert(out.contains("global lock"))
