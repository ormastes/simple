use std.nogc_sync_mut.spipe.tree_context.{spipe_parse_text, spipe_render_tree, spipe_raw_range, spipe_match_parser, spipe_context_store_new, spipe_context_put, spipe_context_get, spipe_context_search, spipe_context_raw, spipe_raw_context, spipe_source_blob}

fn test_level_grouping_and_raw_pointers():
    val raw = "[ERROR] src/app/mcp/main.spl:441: undefined symbol\nplain line"
    val doc = spipe_parse_text("command_output", "simple build", raw)
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@group level=ERROR count=1"))
    assert(rendered.contains("@group level=NONE count=1"))
    assert(rendered.contains("@node id=n1 d=5 kind=file level=ERROR"))
    assert(rendered.contains("@parent d=1 kind=dir path=\"src\""))
    assert(rendered.contains("raw=raw:src:1#L1-L1"))

fn test_no_level_skips_grouping():
    val doc = spipe_parse_text("command_output", "find .", "./src/app\n./src/lib")
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("level_detected=false"))
    assert(not rendered.contains("@group level="))

fn test_find_output_classifies_parent_paths_as_dirs():
    val doc = spipe_parse_text("command_output", "find .", "./src\n./src/app\n./src/app/main.spl")
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@node id=n1 d=2 kind=dir"))
    assert(rendered.contains("@node id=n2 d=3 kind=dir"))
    assert(rendered.contains("@node id=n3 d=4 kind=file"))
    assert(rendered.contains("@parent d=2 kind=dir path=\"src/app\""))

fn test_tree_command_preserves_parent_dirs():
    val raw = ".\n├── src\n│   └── app\n│       └── main.spl"
    val doc = spipe_parse_text("command_output", "tree", raw)
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@node id=n2 d=2 kind=dir"))
    assert(rendered.contains("@node id=n3 d=3 kind=dir"))
    assert(rendered.contains("@node id=n4 d=4 kind=file"))
    assert(rendered.contains("@parent d=1 kind=dir path=\"src\""))
    assert(rendered.contains("@parent d=2 kind=dir path=\"src/app\""))
    assert(rendered.contains("@parent d=3 kind=file path=\"src/app/main.spl\""))

fn test_ls_long_output_extracts_entries():
    val raw = "total 8\ndrwxr-xr-x 2 user group 64 Jul 1 00:00 src\n-rw-r--r-- 1 user group 12 Jul 1 00:00 README.md"
    val doc = spipe_parse_text("command_output", "ls -l", raw)
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@node id=n2 d=2 kind=dir"))
    assert(rendered.contains("@node id=n3 d=2 kind=file"))
    assert(rendered.contains("path=\"src\""))
    assert(rendered.contains("path=\"README.md\""))

fn test_git_status_extracts_paths():
    val raw = "Changes not staged for commit:\n\tmodified:   src/app/main.spl\n\trenamed:    old.spl -> src/app/new.spl"
    val doc = spipe_parse_text("command_output", "git status", raw)
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@node id=n2 d=4 kind=file"))
    assert(rendered.contains("path=\"src/app/main.spl\""))
    assert(rendered.contains("path=\"src/app/new.spl\""))

fn test_git_diff_extracts_header_path():
    val raw = "diff --git a/src/app/main.spl b/src/app/main.spl\nindex 111..222 100644"
    val doc = spipe_parse_text("command_output", "git diff", raw)
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@node id=n1 d=4 kind=file"))
    assert(rendered.contains("path=\"src/app/main.spl\""))

fn test_git_log_extracts_name_only_paths():
    val raw = "commit abc123\nAuthor: A <a@example.com>\n\nsrc/app/main.spl"
    val doc = spipe_parse_text("command_output", "git log --name-only", raw)
    val rendered = spipe_render_tree(doc)
    assert(rendered.contains("@node id=n4 d=4 kind=file"))
    assert(rendered.contains("path=\"src/app/main.spl\""))

fn test_raw_context_exact_lines():
    val raw = "a\nb\nc\nd"
    val out = spipe_raw_range(raw, "exec:9", 2, 2, 1, 1)
    assert(out.contains("@raw id=exec:9 range=L1-L3 mode=exact"))
    assert(out.contains("| a"))
    assert(out.contains("| c"))

fn test_direct_raw_context_includes_parent_chain():
    val raw = "[ERROR] src/app/mcp/main.spl:441: undefined symbol\nplain line"
    val out = spipe_raw_context("exec:9", "command_output", "simple build", raw, 1, 1, 0, 0)
    assert(out.contains("@context line=1"))
    assert(out.contains("@parent d=1 kind=dir path=\"src\""))
    assert(out.contains("@raw id=exec:9 range=L1-L1 mode=exact"))

fn test_parser_matcher_common_ubuntu_tools():
    assert(spipe_match_parser("command_output", "rg TODO src", "src/a:1:TODO").to_string() == "rg")
    assert(spipe_match_parser("command_output", "git diff", "diff --git a/a b/a").to_string() == "git_diff")
    assert(spipe_match_parser("command_output", "repomix", "<file path=\"src/app/main.spl\">").to_string() == "repomix_xml")
    assert(spipe_match_parser("markdown", "notes.md", "# Title\n\n## Next").to_string() == "markdown_headings")

fn test_context_store_get_search_and_raw():
    var store = spipe_context_store_new()
    store = spipe_context_put(store, spipe_source_blob("exec:7", "command_output", "simple build", "[ERROR] src/main.spl:1: no\nok"))
    val got = spipe_context_get(store, "exec:7")
    assert(got.contains("@source id=exec:7"))
    assert(got.contains("@parent d=1 kind=dir path=\"src\""))
    val found = spipe_context_search(store, "no")
    assert(found.contains("@group level=ERROR count=1"))
    val raw = spipe_context_raw(store, "exec:7", 1, 1, 0, 1)
    assert(raw.contains("@context line=1"))
    assert(raw.contains("@parent d=1 kind=dir path=\"src\""))
    assert(raw.contains("@raw id=exec:7 range=L1-L2 mode=exact"))
