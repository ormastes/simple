use std.nogc_sync_mut.spipe.codebase_ingest.{spipe_codebase_get, spipe_codebase_ingest, spipe_codebase_profile, spipe_codebase_save_text, spipe_codebase_search, spipe_codebase_validate_patterns}
use std.nogc_sync_mut.spipe.tree_context.{spipe_context_store_new}

fn test_codebase_profile_contains_focused_mcp_paths():
    val profile = spipe_codebase_profile()
    assert(profile.contains("src/app/mcp/**"))
    assert(profile.contains("src/app/simple_lsp_mcp/**"))
    assert(profile.contains(".git/**"))

fn test_codebase_pattern_validation_blocks_shell_chars():
    assert(spipe_codebase_validate_patterns("src/**") == "ok")
    assert(spipe_codebase_validate_patterns("src/**; rm -rf /").contains("invalid"))

fn test_codebase_ingest_search_get():
    var store = spipe_context_store_new()
    val packed = "## File: src/app/mcp/main.spl\nfn main() -> i64:\n    0\n"
    store = spipe_codebase_ingest(store, "codebase:7", packed)
    val found = spipe_codebase_search(store, "main.spl")
    assert(found.contains("@source id=codebase:7"))
    val got = spipe_codebase_get(store, "codebase:7")
    assert(got.contains("repomix"))

fn test_codebase_save_metadata():
    val out = spipe_codebase_save_text("codebase:9", "abc")
    assert(out.contains("source_id=\"codebase:9\""))
    assert(out.contains("bytes=3"))
