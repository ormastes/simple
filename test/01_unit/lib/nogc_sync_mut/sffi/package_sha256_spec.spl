use std.spec.*
use std.io.{file_delete, file_write, time_now_unix_micros}
use std.nogc_sync_mut.sffi.package.{package_sha256}

describe "pure Simple package SHA-256":
    it "hashes file bytes without a hosted package runtime symbol":
        val path = "/tmp/simple_package_sha256_{time_now_unix_micros()}.txt"
        expect(file_write(path, "abc")).to_be(true)
        expect(package_sha256(path)).to_equal("sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
        expect(file_delete(path)).to_be(true)

    it "fails closed for a missing file":
        expect(package_sha256("/tmp/simple_package_sha256_missing.txt")).to_equal("")

    it "hashes a padded multi-block vector":
        val path = "/tmp/simple_package_sha256_multiblock_{time_now_unix_micros()}.txt"
        val payload = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
        expect(file_write(path, payload)).to_be(true)
        expect(package_sha256(path)).to_equal("sha256:248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1")
        expect(file_delete(path)).to_be(true)
