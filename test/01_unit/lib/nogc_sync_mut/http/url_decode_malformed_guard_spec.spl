use std.spec.{describe, it, assert_equal}
use std.nogc_sync_mut.http.url.{url_decode}

describe "HTTP URL decode malformed percent guard":
    it "decodes valid percent escapes":
        assert_equal(url_decode("a%20b%2Fc"), "a b/c")

    it "preserves short percent tails":
        assert_equal(url_decode("abc%"), "abc%")
        assert_equal(url_decode("abc%2"), "abc%2")

    it "preserves invalid percent escapes":
        assert_equal(url_decode("a%GGb"), "a%GGb")
        assert_equal(url_decode("a%2Xb"), "a%2Xb")
