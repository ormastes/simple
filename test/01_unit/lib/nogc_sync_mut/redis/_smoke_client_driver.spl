"""
# Redis server smoke driver (manual, not a spec)

Connects a real RedisClient to a running simple redis-server and exercises a
PING/SET/GET/DEL/INCR round-trip over a real socket. Prints OK/FAIL lines.
Run the server first, then:  bin/simple run THIS_FILE
"""

use std.nogc_sync_mut.redis.client.{RedisClient}

fn main():
    val c = RedisClient.connect("127.0.0.1", 6399)
    match c:
        case Err(e):
            print("FAIL connect: {e.message}")
            return
        case Ok(client):
            run_checks(client)

fn run_checks(client: RedisClient):
    var cl = client
    val pong = cl.ping()
    match pong:
        case Ok(s): print("ping -> {s}")
        case Err(e): print("FAIL ping: {e.message}")

    val setr = cl.set("smoke", "value42")
    match setr:
        case Ok(_): print("set -> OK")
        case Err(e): print("FAIL set: {e.message}")

    val getr = cl.get("smoke")
    match getr:
        case Ok(v):
            if v.?:
                print("get -> {v.unwrap()}")
            else:
                print("FAIL get: nil")
        case Err(e): print("FAIL get: {e.message}")

    val incr1 = cl.incr("counter")
    match incr1:
        case Ok(n): print("incr -> {n}")
        case Err(e): print("FAIL incr: {e.message}")

    val delr = cl.del("smoke")
    match delr:
        case Ok(n): print("del -> {n}")
        case Err(e): print("FAIL del: {e.message}")

    val exr = cl.key_exists("smoke")
    match exr:
        case Ok(b): print("exists_after_del -> {b}")
        case Err(e): print("FAIL exists: {e.message}")

    val _ = cl.close()
    print("DONE")
