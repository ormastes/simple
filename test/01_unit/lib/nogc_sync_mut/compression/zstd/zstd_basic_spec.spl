# zstd_basic_spec.spl
#
# Smoke tests for the Zstd decoder.
#
# These tests verify:
#   - Empty input returns Err (TruncatedInput)
#   - Bad magic returns Err (InvalidHeader)
#   - A minimal Raw_Block frame decodes correctly
#   - A minimal RLE_Block frame decodes correctly
#   - Skippable frame is skipped (empty output)
#   - Chained frames: two raw-block frames concatenated

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.zstd.decoder.{zstd_decode}
use std.common.compress.types.{CompressionError}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# Build a minimal Zstd frame with a single Raw_Block.
# Frame layout (Single_Segment=1, FCS=1byte, no checksum):
#   Magic(4) + FHD(1) + FCS(1) + Block_Header(3) + Block_Content(N)
fn make_raw_frame(content: [u8]) -> [u8]:
    var out: [u8] = []
    # Magic: 0xFD2FB528 LE
    out.push(0x28u8)
    out.push(0xB5u8)
    out.push(0x2Fu8)
    out.push(0xFDu8)
    # FHD: FCS_Flag=00 (1-byte FCS since single_seg=1), Single_Segment=1, no checksum, DID=0
    # FHD = 0b00100000 = 0x20  (single_seg bit)
    out.push(0x20u8)
    # FCS: 1 byte (content size <= 255)
    out.push(content.len().to_u8())
    # Block_Header: Last=1, Type=Raw(0), Size=N
    # raw: (1 | 0<<1 | N<<3) packed in 3 LE bytes
    val n = content.len()
    val hdr = 1 | (n << 3)
    out.push((hdr & 0xFF).to_u8())
    out.push(((hdr >> 8) & 0xFF).to_u8())
    out.push(((hdr >> 16) & 0xFF).to_u8())
    # Block content
    var i = 0
    while i < content.len():
        out.push(content[i])
        i = i + 1
    out

# Build a minimal Zstd frame with a single RLE_Block.
fn make_rle_frame(byte_val: i64, count: i64) -> [u8]:
    var out: [u8] = []
    # Magic
    out.push(0x28u8)
    out.push(0xB5u8)
    out.push(0x2Fu8)
    out.push(0xFDu8)
    # FHD: Single_Segment=1, FCS=1-byte
    out.push(0x20u8)
    # FCS
    out.push(count.to_u8())
    # Block_Header: Last=1, Type=RLE(1), Size=count
    val hdr = 1 | (1 << 1) | (count << 3)
    out.push((hdr & 0xFF).to_u8())
    out.push(((hdr >> 8) & 0xFF).to_u8())
    out.push(((hdr >> 16) & 0xFF).to_u8())
    # Single payload byte
    out.push(byte_val.to_u8())
    out

# Build a skippable frame (magic 0x184D2A50, payload_size=0).
fn make_skippable_frame() -> [u8]:
    var out: [u8] = []
    # Skip magic: 0x184D2A50 LE
    out.push(0x50u8)
    out.push(0x2Au8)
    out.push(0x4Du8)
    out.push(0x18u8)
    # Payload size: 0
    out.push(0x00u8)
    out.push(0x00u8)
    out.push(0x00u8)
    out.push(0x00u8)
    out

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "zstd decoder":
    it "returns error on empty input":
        val result = zstd_decode([])
        expect(result.is_err()).to_equal(true)

    it "returns error on bad magic":
        val bad: [u8] = [0x00u8, 0x01u8, 0x02u8, 0x03u8]
        val result = zstd_decode(bad)
        expect(result.is_err()).to_equal(true)

    it "decodes a single raw block frame":
        val content: [u8] = [0x48u8, 0x65u8, 0x6Cu8, 0x6Cu8, 0x6Fu8]  # "Hello"
        val frame = make_raw_frame(content)
        val result = zstd_decode(frame)
        expect(result.is_ok()).to_equal(true)
        val output = result.unwrap()
        expect(bytes_equal(output, content)).to_equal(true)

    it "decodes an empty raw block frame":
        val frame = make_raw_frame([])
        val result = zstd_decode(frame)
        expect(result.is_ok()).to_equal(true)
        val output = result.unwrap()
        expect(output.len()).to_equal(0)

    it "decodes a single rle block frame":
        val frame = make_rle_frame(0x41, 5)  # 'A' repeated 5 times
        val result = zstd_decode(frame)
        expect(result.is_ok()).to_equal(true)
        val output = result.unwrap()
        expect(output.len()).to_equal(5)
        var all_a = true
        var i = 0
        while i < output.len():
            if output[i] != 0x41u8:
                all_a = false
            i = i + 1
        expect(all_a).to_equal(true)

    it "skips a skippable frame producing empty output":
        val frame = make_skippable_frame()
        val result = zstd_decode(frame)
        expect(result.is_ok()).to_equal(true)
        val output = result.unwrap()
        expect(output.len()).to_equal(0)

    it "decodes chained raw-block frames":
        val c1: [u8] = [0x41u8, 0x42u8]   # "AB"
        val c2: [u8] = [0x43u8, 0x44u8]   # "CD"
        val f1 = make_raw_frame(c1)
        val f2 = make_raw_frame(c2)
        var combined: [u8] = []
        var i = 0
        while i < f1.len():
            combined.push(f1[i])
            i = i + 1
        var j = 0
        while j < f2.len():
            combined.push(f2[j])
            j = j + 1
        val result = zstd_decode(combined)
        expect(result.is_ok()).to_equal(true)
        val output = result.unwrap()
        expect(output.len()).to_equal(4)

    it "skippable frame followed by raw block frame":
        val content: [u8] = [0x58u8, 0x59u8]  # "XY"
        val skip = make_skippable_frame()
        val data = make_raw_frame(content)
        var combined: [u8] = []
        var i = 0
        while i < skip.len():
            combined.push(skip[i])
            i = i + 1
        var j = 0
        while j < data.len():
            combined.push(data[j])
            j = j + 1
        val result = zstd_decode(combined)
        expect(result.is_ok()).to_equal(true)
        val output = result.unwrap()
        expect(bytes_equal(output, content)).to_equal(true)
