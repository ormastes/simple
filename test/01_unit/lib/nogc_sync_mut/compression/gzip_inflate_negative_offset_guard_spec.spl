extern fn rt_file_read_text(path: text) -> text

fn _contains_gzip_inflate_negative_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn deflate_block_parse(data, offset):") and
        source.to_contain("if offset < 0:\n        return nil") and
        source.to_contain("val header_byte = data[offset].to_i64()")

describe "GZIP inflate negative offset guards":
    it "guards legacy block parsing before indexed reads":
        expect(_contains_gzip_inflate_negative_guard("src/lib/nogc_sync_mut/compression/gzip/inflate.spl")).to_equal(true)
