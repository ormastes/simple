extern fn rt_file_read_text(path: text) -> text

describe "nogc sync udp utils numeric guard":
    it "defaults malformed port parsing":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/udp_utils.spl") ?? ""

        expect(source.contains("val port = port_text.to_int() ?? 0")).to_equal(true)
        expect(source.contains("val port = port_text.to_int()\n")).to_equal(false)

    it "guards malformed fragmentation inputs":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/udp_utils.spl") ?? ""

        expect(source).to_contain("if fragment_size <= 0:")
        expect(source).to_contain("if offset < 0 or length < 0 or offset > payload.len():")
        expect(source).to_contain("val safe_end = if end > payload.len():")
