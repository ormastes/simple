use std.src.{Column, Table}

describe "Column empty stats":
    it "returns zero for empty numeric reductions":
        val values: [i64] = []
        val col = Column.from_ints("empty", values)
        expect col.mean() == 0.0
        expect col.std() == 0.0
        expect col.median() == 0.0
        expect col.min() == nil
        expect col.max() == nil
        val table = Table.from_columns([col])
        expect table.agg({"empty": "min"}).get("empty_min").get(0) == 0.0
        expect table.agg({"empty": "max"}).get("empty_max").get(0) == 0.0
