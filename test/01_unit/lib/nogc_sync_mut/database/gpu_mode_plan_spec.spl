use std.spec.*
use std.database.gpu_mode_plan.*
use std.web_db_offload.contract.{GpuWdbRuntimeSnapshot, GpuWdbDecisionPath, GpuWdbWorkKind, GpuWdbCoarseDataPath, gpu_wdb_default_budget}

"""
# DB GPU Mode Planner

## Overview

These scenarios verify the DB-facing planner that maps RAM-only,
SSD-accelerated, NoSQL document, and vector DB modes onto the shared
web/database GPU offload contract.

## Requirements

**Requirements:** doc/02_requirements/feature/gpu_web_db_offload.md

- RAM-only DB batches may use GPU-resident coarse batch profiles.
- SSD-accelerated DB batches keep WAL/durability CPU-owned and fall back on
  stale generations.
- NoSQL document metadata filtering remains CPU-owned before GPU batch
  accounting.
- Vector search reuses the shared vector GPU target and index-style profile.

## Design

**Design:** doc/05_design/gpu_web_db_offload.md

## Plan

**Plan:** doc/03_plan/agent_tasks/gpu_web_db_offload_impl_status.md

## Research

**Research:** doc/01_research/lib/networking/reverse_proxy_gpu_boundary_2026-06-16.md

## Examples

Call `db_gpu_mode_plan_default` before DB execution. The returned
`DbGpuModePlan` contains both the admission decision and the reusable
`GpuWdbCoarseBatchProfile` describing whether data is RAM/GPU-resident,
SSD-staged, index-backed, or CPU-only.
"""

fn db_gpu_snapshot(queue_depth: i64, gpu_available: bool, generation_current: bool,
                   cpu_fallback_available: bool) -> GpuWdbRuntimeSnapshot:
    GpuWdbRuntimeSnapshot(
        queue_depth: queue_depth,
        gpu_available: gpu_available,
        generation_current: generation_current,
        cpu_fallback_available: cpu_fallback_available
    )

describe "database GPU mode planner":
    it "should estimate DB batch bytes":
        step("Estimate bytes from row count and row width")
        expect(db_gpu_mode_estimate_batch_bytes(128, 64)).to_equal(8192)
        expect(db_gpu_mode_estimate_batch_bytes(0, 64)).to_equal(0)

    it "should plan RAM-only scan batches for GPU when coarse enough":
        step("Plan a RAM-only scan/filter/project batch")
        val plan = db_gpu_mode_plan_default(
            DbGpuMode.RamOnly,
            128,
            64,
            db_gpu_snapshot(0, true, true, true),
            true,
            true
        )
        expect(plan.work_kind).to_equal(GpuWdbWorkKind.DbScanFilterProject)
        expect(plan.batch.execution.decision.path).to_equal(GpuWdbDecisionPath.GpuEvidence)
        expect(plan.batch.execution.target).to_equal("gpu_db_columnar_scan_batch")
        expect(plan.profile.data_path).to_equal(GpuWdbCoarseDataPath.GpuResidentBatch)
        expect(plan.profile.gpu_resident_allowed).to_be(true)
        expect(db_gpu_mode_plan_uses_gpu(plan)).to_be(true)

    it "should fall back for stale SSD WAL generations":
        step("Plan an SSD-accelerated batch with stale WAL generation")
        val plan = db_gpu_mode_plan_default(
            DbGpuMode.SsdAccelerated,
            128,
            64,
            db_gpu_snapshot(0, true, true, true),
            false,
            true
        )
        expect(plan.batch.execution.decision.path).to_equal(GpuWdbDecisionPath.CpuFallback)
        expect(plan.batch.execution.decision.reason).to_equal("stale-generation")
        expect(plan.profile.data_path).to_equal(GpuWdbCoarseDataPath.SsdStagedBatch)
        expect(plan.profile.cpu_durability_path).to_be(true)
        expect(db_gpu_mode_plan_uses_gpu(plan)).to_be(false)

    it "should reject NoSQL metadata filtering unless CPU-owned":
        step("Plan a NoSQL document batch with GPU-owned metadata filtering")
        val plan = db_gpu_mode_plan_default(
            DbGpuMode.NoSqlDocument,
            128,
            64,
            db_gpu_snapshot(0, true, true, true),
            true,
            false
        )
        expect(plan.batch.execution.decision.path).to_equal(GpuWdbDecisionPath.Reject)
        expect(plan.batch.execution.decision.reason).to_equal("metadata-filter-must-stay-cpu-owned")
        expect(plan.profile.data_path).to_equal(GpuWdbCoarseDataPath.GpuIndexBatch)
        expect(plan.profile.cpu_durability_path).to_be(true)
        expect(db_gpu_mode_plan_uses_gpu(plan)).to_be(false)

    it "should reuse vector search GPU target for vector mode":
        step("Plan a vector search batch through the general DB mode planner")
        val plan = db_gpu_mode_plan(
            DbGpuMode.VectorSearch,
            128,
            64,
            db_gpu_snapshot(1, true, true, true),
            true,
            true,
            gpu_wdb_default_budget()
        )
        expect(plan.work_kind).to_equal(GpuWdbWorkKind.DbVectorSearch)
        expect(plan.batch.execution.target).to_equal("gpu_db_vector_search_batch")
        expect(plan.batch.queue_depth_after).to_equal(2)
        expect(plan.profile.data_path).to_equal(GpuWdbCoarseDataPath.GpuIndexBatch)
        expect(plan.profile.stream_count).to_equal(4)
