            sql_offload_profile(),
            DbStorageOffloadMode.RamOnly,
            true,
            512,
            gpu_wdb_device_backend("cuda", 11, ["gpu_db_join_aggregate_batch"], true, "cuda-device-0"),
            11,
            candidate_rows,
            [0, 1],
            100,
            230,
            81,
            "cuda-event"
