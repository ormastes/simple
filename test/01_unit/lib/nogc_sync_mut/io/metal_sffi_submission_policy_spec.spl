use std.spec.{describe, it, expect}
use std.nogc_sync_mut.io.metal_sffi.metal_sffi_quarantine_release_proven

describe "Metal deferred-submission release policy":
    it "retains a command when completion and registry ownership are both unknown":
        expect(metal_sffi_quarantine_release_proven(false, false)).to_equal(false)

    it "releases dependencies after a successful completion wait":
        expect(metal_sffi_quarantine_release_proven(true, false)).to_equal(true)

    it "releases dependencies after terminal registry removal proves ownership":
        expect(metal_sffi_quarantine_release_proven(false, true)).to_equal(true)

    it "keeps release monotonic when both proofs are present":
        expect(metal_sffi_quarantine_release_proven(true, true)).to_equal(true)
