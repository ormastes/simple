use std.spec.{describe, it, expect}
use std.nogc_sync_mut.net.stun.{
    StunHeaderResult,
    stun_decode_attributes,
    stun_emit_header,
    stun_parse_header
}

fn _txn_id() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 12:
        out.push(i.to_u8())
        i = i + 1
    return out

fn _valid_header() -> [u8]:
    return stun_emit_header(0x0001, 0, _txn_id())

fn _is_header_error(result: StunHeaderResult) -> bool:
    match result:
        case Err(_):
            return true
        case Ok(_):
            return false
    return false

describe "STUN malformed offset guards":
    it "rejects negative header offsets without indexing before the buffer":
        expect(_is_header_error(stun_parse_header(_valid_header(), -1))).to_equal(true)

    it "ignores malformed attribute decode ranges without indexing out of bounds":
        val bytes = _valid_header()
        val negative_offset_attrs = stun_decode_attributes(bytes, -1, 4)
        val too_long_attrs = stun_decode_attributes(bytes, 18, 8)
        expect(negative_offset_attrs.len()).to_equal(0)
        expect(too_long_attrs.len()).to_equal(0)
