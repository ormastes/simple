# std.diag — unit specifications (easy debug infrastructure P0)
#
# Covers: disabled-by-default (no emission), facet filtering, stage delta
# monotonicity, cooperative deadline fires once with stage history, timing
# aggregation math, and always-on provenance mismatch.
#
# NOTE (interpreter): module globals mutated inside functions are only
# visible through accessor functions, not via direct global reads from `it`
# blocks — all assertions below go through the module's dbg_* accessors.
# dbg_force_facet()/dbg_diag_reset() are the documented test-only hooks:
# SIMPLE_DIAG is read once and cached, so env changes mid-process are
# intentionally invisible.

use std.diag.{
    dbg_stage, dbg_stage_on, dbg_watchdog_on, dbg_timers_on, dbg_events_on,
    dbg_force_facet, dbg_diag_reset, dbg_last_emit,
    dbg_stage_history, dbg_stage_dump,
    dbg_deadline, dbg_deadline_check, dbg_deadline_clear,
    dbg_deadline_breach_count, dbg_last_breach, dbg_deadline_active_count,
    dbg_time_begin, dbg_time_end, dbg_count, dbg_timer_stats,
    dbg_counter_value, dbg_summary,
    dbg_event_hop,
    dbg_provenance, dbg_provenance_mismatches, dbg_last_mismatch
}

describe "std.diag disabled by default":
    it "emits nothing when no SIMPLE_DIAG facet is enabled":
        dbg_diag_reset()
        expect(dbg_stage_on()).to_equal(false)
        expect(dbg_watchdog_on()).to_equal(false)
        expect(dbg_timers_on()).to_equal(false)
        expect(dbg_events_on()).to_equal(false)

        dbg_stage("browser", "first_frame_start")
        dbg_event_hop("c42", "hit_test", "x=1 y=2")
        dbg_time_begin("reflow")
        dbg_time_end("reflow")
        dbg_deadline("first-frame", -1)
        dbg_stage("browser", "first_frame_done")

        expect(dbg_last_emit()).to_equal("")
        expect(dbg_stage_history().len()).to_equal(0)
        expect(dbg_deadline_breach_count()).to_equal(0)
        expect(dbg_timer_stats("reflow").count).to_equal(0)

describe "std.diag facet filtering":
    it "stage facet emits stage lines but leaves events silent":
        dbg_diag_reset()
        dbg_force_facet("stage")

        dbg_stage("browser", "parse_html")
        expect(dbg_last_emit()).to_contain("[browser] stage parse_html +")
        expect(dbg_last_emit()).to_contain("ms")

        val before = dbg_last_emit()
        dbg_event_hop("c1", "dispatch", "target=button")
        expect(dbg_last_emit()).to_equal(before)

    it "events facet emits hop lines in the contract format":
        dbg_diag_reset()
        dbg_force_facet("events")

        dbg_event_hop("c42", "hit_test", "x=12 y=40 verdict=miss")
        expect(dbg_last_emit()).to_equal("[event c42] hit_test x=12 y=40 verdict=miss")

describe "std.diag stage ring + monotonicity":
    it "records history in order with non-decreasing timestamps":
        dbg_diag_reset()
        dbg_force_facet("stage")

        dbg_stage("wm", "a")
        dbg_stage("wm", "b")
        dbg_stage("wm", "c")

        val hist = dbg_stage_history()
        expect(hist.len()).to_equal(3)
        expect(hist[0].stage).to_equal("a")
        expect(hist[2].stage).to_equal("c")
        expect(hist[1].t_ms >= hist[0].t_ms).to_equal(true)
        expect(hist[2].t_ms >= hist[1].t_ms).to_equal(true)

describe "std.diag cooperative watchdog":
    it "fires exactly once with stage history in the breach block":
        dbg_diag_reset()
        dbg_force_facet("watchdog")
        dbg_force_facet("stage")

        dbg_stage("browser", "render_start")
        dbg_stage("browser", "render_mid")

        # budget -1 guarantees elapsed (>= 0) > budget on the next check,
        # without real sleeps.
        dbg_deadline("first-frame", -1)
        expect(dbg_deadline_active_count()).to_equal(1)

        dbg_stage("browser", "render_next")

        expect(dbg_deadline_breach_count()).to_equal(1)
        expect(dbg_deadline_active_count()).to_equal(0)
        expect(dbg_last_breach()).to_contain("DEADLINE EXCEEDED first-frame budget=-1ms")
        expect(dbg_last_breach()).to_contain("stage render_mid")

        # fire-once: further stages do not re-fire
        dbg_stage("browser", "render_after")
        expect(dbg_deadline_breach_count()).to_equal(1)

    it "does not fire when cleared on the success path":
        dbg_diag_reset()
        dbg_force_facet("watchdog")

        dbg_deadline("safe-op", 600000)
        dbg_deadline_clear("safe-op")
        dbg_stage("browser", "after_clear")

        expect(dbg_deadline_breach_count()).to_equal(0)
        expect(dbg_deadline_active_count()).to_equal(0)

    it "explicit dbg_deadline_check reports and fires the breach":
        dbg_diag_reset()
        dbg_force_facet("watchdog")

        dbg_deadline("explicit", -1)
        expect(dbg_deadline_check("explicit")).to_equal(true)
        expect(dbg_deadline_check("explicit")).to_equal(false)
        expect(dbg_deadline_breach_count()).to_equal(1)

describe "std.diag timers and counters":
    it "accumulates count/total/max across begin-end pairs":
        dbg_diag_reset()
        dbg_force_facet("timers")

        dbg_time_begin("css_apply")
        dbg_time_end("css_apply")
        dbg_time_begin("css_apply")
        dbg_time_end("css_apply")
        dbg_time_begin("css_apply")
        dbg_time_end("css_apply")

        val stats = dbg_timer_stats("css_apply")
        expect(stats.count).to_equal(3)
        expect(stats.total_ms >= 0).to_equal(true)
        expect(stats.total_ms >= stats.max_ms).to_equal(true)

    it "adds counter deltas and reports them in the summary":
        dbg_diag_reset()
        dbg_force_facet("timers")

        dbg_count("bytes_sent", 5)
        dbg_count("bytes_sent", 3)

        expect(dbg_counter_value("bytes_sent")).to_equal(8)
        expect(dbg_summary()).to_contain("counter bytes_sent = 8")

    it "summary formats timer lines per contract":
        dbg_diag_reset()
        dbg_force_facet("timers")

        dbg_time_begin("layout")
        dbg_time_end("layout")

        expect(dbg_summary()).to_contain("layout count=1 total=")
        expect(dbg_summary()).to_contain("max=")

    it "summary handles multiple labels (sorted-by-total path)":
        dbg_diag_reset()
        dbg_force_facet("timers")

        dbg_time_begin("paint")
        dbg_time_end("paint")
        dbg_time_begin("style")
        dbg_time_end("style")
        dbg_time_begin("paint")
        dbg_time_end("paint")

        expect(dbg_summary()).to_contain("paint count=2")
        expect(dbg_summary()).to_contain("style count=1")

describe "std.diag provenance (always-on)":
    it "reports a mismatch even with every facet disabled":
        dbg_diag_reset()
        expect(dbg_stage_on()).to_equal(false)

        val ok = dbg_provenance("device_readback", "cpu_mirror", "readback")

        expect(ok).to_equal(false)
        expect(dbg_provenance_mismatches()).to_equal(1)
        expect(dbg_last_mismatch()).to_equal(
            "DIAG-PROVENANCE context=readback claimed=device_readback actual=cpu_mirror")

    it "returns true and stays silent when provenance matches":
        dbg_diag_reset()
        val ok = dbg_provenance("metal", "metal", "backend_resolve")

        expect(ok).to_equal(true)
        expect(dbg_provenance_mismatches()).to_equal(0)
        expect(dbg_last_emit()).to_equal("")
