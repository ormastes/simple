extern fn rt_file_read_text(path: text) -> text

fn _contains_checkpoint_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn decode_i64(data: [i32], offset: i32) -> i64:") and
        source.to_contain("if offset < 0 or offset + 1 >= data.len():\n        return 0") and
        source.to_contain("fn decode_text(data: [i32], offset: i32) -> text:") and
        source.to_contain("if offset < 0 or offset >= data.len():\n        return \"\"") and
        source.to_contain("if length < 0 or offset + length >= data.len():\n        return \"\"") and
        source.to_contain("val lo = data[offset] as i64") and
        source.to_contain("val length = data[offset]")

describe "Replay checkpoint negative offset guards":
    it "guards checkpoint decoders before indexed reads":
        expect(_contains_checkpoint_negative_guards("src/lib/nogc_sync_mut/replay/container/checkpoint_format.spl")).to_equal(true)
