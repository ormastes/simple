# Spike spec: minimal KAT coverage for the limb primitives.
#
# Three hand-picked KATs that exercise the highest-risk corners of the
# 30-bit base layer:
#   - LIMB_MASK^2 (worst-case 30 x 30 -> 60 multiplication).
#   - Single-limb add at the LIMB_BASE boundary (carry chain).
#   - Single-limb sub at the underflow boundary (borrow chain).

use std.math.bignum.limb.{
    LIMB_BITS, LIMB_BASE, LIMB_MASK,
    limb_mul, add_limbs, sub_limbs
}

describe "math.bignum.limb":
    describe "limb_mul":
        it "LIMB_MASK^2 = (1, LIMB_BASE - 2)":
            # (2^30 - 1)^2 = 2^60 - 2^31 + 1
            #              = (2^30 - 2) * 2^30 + 1
            # so low limb = 1, high limb = LIMB_BASE - 2.
            val r = limb_mul(LIMB_MASK, LIMB_MASK)
            expect(r[0]).to_equal(1)
            expect(r[1]).to_equal(LIMB_BASE - 2)

    describe "add_limbs":
        it "carries at LIMB_BASE":
            # LIMB_MASK + 1 = LIMB_BASE -> carry out, limb 0.
            val r = add_limbs(LIMB_MASK, 1, 0)
            expect(r[0]).to_equal(0)
            expect(r[1]).to_equal(1)

    describe "sub_limbs":
        it "borrows when a < b":
            # 0 - 1 = LIMB_MASK with borrow_out 1.
            val r = sub_limbs(0, 1, 0)
            expect(r[0]).to_equal(LIMB_MASK)
            expect(r[1]).to_equal(1)
