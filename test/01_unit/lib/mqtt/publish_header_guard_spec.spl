extern fn rt_file_read_text(path: text) -> text

describe "mqtt publish header guard":
    it "defaults malformed publish and connack headers before tuple indexing":
        val sync_source = rt_file_read_text("src/lib/nogc_sync_mut/mqtt/publish.spl") ?? ""
        val nogc_async_source = rt_file_read_text("src/lib/nogc_async_mut/mqtt/publish.spl") ?? ""
        val async_source = rt_file_read_text("src/lib/gc_async_mut/mqtt/publish.spl") ?? ""

        expect(sync_source).to_contain("fn mqtt_connack_headers_or_default(headers):")
        expect(sync_source).to_contain("fn mqtt_publish_headers_or_default(headers):")
        expect(sync_source).to_contain("val parts = mqtt_publish_headers_or_default(headers)")
        expect(nogc_async_source).to_contain("fn mqtt_connack_headers_or_default(headers):")
        expect(nogc_async_source).to_contain("fn mqtt_publish_headers_or_default(headers):")
        expect(nogc_async_source).to_contain("val parts = mqtt_publish_headers_or_default(headers)")
        expect(async_source).to_contain("fn mqtt_connack_headers_or_default(headers):")
        expect(async_source).to_contain("fn mqtt_publish_headers_or_default(headers):")
        expect(async_source).to_contain("val parts = mqtt_publish_headers_or_default(headers)")
