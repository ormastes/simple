# Daemon SDK Lock Specification
#
# Tests PID-based singleton lock acquisition, release, and stale detection.
# Uses module-level mock state since nested closures can't modify vars.
#
# **Feature IDs:** #DSDK-011 to #DSDK-020
# **Category:** Infrastructure

# ============================================================================
# Module-level mock state
# ============================================================================

var mock_lock_paths: [text] = []
var mock_lock_pids: [i64] = []
var mock_alive_pids: [i64] = []
var mock_our_pid: i64 = 12345

fn lk_reset():
    mock_lock_paths = []
    mock_lock_pids = []
    mock_alive_pids = [12345]
    mock_our_pid = 12345

fn lk_find(path: text) -> i64:
    var i = 0
    while i < mock_lock_paths.len():
        if mock_lock_paths[i] == path:
            return i
        i = i + 1
    -1

fn lk_write(path: text, pid: i64):
    val idx = lk_find(path)
    if idx >= 0:
        mock_lock_pids[idx] = pid
    else:
        mock_lock_paths = mock_lock_paths + [path]
        mock_lock_pids = mock_lock_pids + [pid]

fn lk_read_pid(path: text) -> i64:
    val idx = lk_find(path)
    if idx >= 0:
        return mock_lock_pids[idx]
    -1

fn lk_exists(path: text) -> bool:
    lk_find(path) >= 0

fn lk_delete(path: text):
    val idx = lk_find(path)
    if idx < 0:
        return
    var new_paths: [text] = []
    var new_pids: [i64] = []
    var i = 0
    while i < mock_lock_paths.len():
        if i != idx:
            new_paths = new_paths + [mock_lock_paths[i]]
            new_pids = new_pids + [mock_lock_pids[i]]
        i = i + 1
    mock_lock_paths = new_paths
    mock_lock_pids = new_pids

fn lk_is_alive(pid: i64) -> bool:
    var i = 0
    while i < mock_alive_pids.len():
        if mock_alive_pids[i] == pid:
            return true
        i = i + 1
    false

fn lk_add_alive(pid: i64):
    mock_alive_pids = mock_alive_pids + [pid]

fn lk_remove_alive(pid: i64):
    var new_pids: [i64] = []
    var i = 0
    while i < mock_alive_pids.len():
        if mock_alive_pids[i] != pid:
            new_pids = new_pids + [mock_alive_pids[i]]
        i = i + 1
    mock_alive_pids = new_pids

# Mock try_acquire
fn mock_try_acquire(lock_path: text) -> i64:
    if lk_exists(lock_path):
        val existing = lk_read_pid(lock_path)
        if existing > 0 and lk_is_alive(existing):
            return -1
        lk_delete(lock_path)
    lk_write(lock_path, mock_our_pid)
    mock_our_pid

# Mock release
fn mock_release(pid: i64, lock_path: text) -> bool:
    if not lk_exists(lock_path):
        return true
    val lock_pid = lk_read_pid(lock_path)
    if lock_pid != pid:
        return false
    lk_delete(lock_path)
    true

# Mock is_running
fn mock_is_running(lock_path: text) -> bool:
    if not lk_exists(lock_path):
        return false
    val pid = lk_read_pid(lock_path)
    if pid <= 0:
        return false
    lk_is_alive(pid)

# Getters
fn lk_lock_count() -> i64:
    mock_lock_paths.len()

# ============================================================================
# Tests
# ============================================================================

describe "DaemonLock":
    describe "acquisition":
        it "acquires lock when none exists":
            lk_reset()
            val pid = mock_try_acquire(".build/test.lock")
            expect(pid).to_equal(12345)
            expect(lk_exists(".build/test.lock")).to_equal(true)

        it "fails when another daemon holds lock":
            lk_reset()
            lk_write(".build/test.lock", 99999)
            lk_add_alive(99999)
            val pid = mock_try_acquire(".build/test.lock")
            expect(pid).to_equal(-1)

        it "takes over stale lock":
            lk_reset()
            lk_write(".build/test.lock", 99999)
            # 99999 is NOT in alive list → stale
            val pid = mock_try_acquire(".build/test.lock")
            expect(pid).to_equal(12345)
            expect(lk_read_pid(".build/test.lock")).to_equal(12345)

        it "handles multiple lock paths independently":
            lk_reset()
            val p1 = mock_try_acquire(".build/daemon_a.lock")
            val p2 = mock_try_acquire(".build/daemon_b.lock")
            expect(p1).to_equal(12345)
            expect(p2).to_equal(12345)
            expect(lk_lock_count()).to_equal(2)

    describe "release":
        it "releases owned lock":
            lk_reset()
            mock_try_acquire(".build/test.lock")
            val ok = mock_release(12345, ".build/test.lock")
            expect(ok).to_equal(true)
            expect(lk_exists(".build/test.lock")).to_equal(false)

        it "refuses to release lock owned by another":
            lk_reset()
            lk_write(".build/test.lock", 99999)
            val ok = mock_release(12345, ".build/test.lock")
            expect(ok).to_equal(false)
            expect(lk_exists(".build/test.lock")).to_equal(true)

        it "succeeds when lock does not exist":
            lk_reset()
            val ok = mock_release(12345, ".build/nonexistent.lock")
            expect(ok).to_equal(true)

    describe "is_running":
        it "returns false when no lock":
            lk_reset()
            expect(mock_is_running(".build/test.lock")).to_equal(false)

        it "returns true when lock held by alive process":
            lk_reset()
            lk_write(".build/test.lock", 12345)
            expect(mock_is_running(".build/test.lock")).to_equal(true)

        it "returns false when lock held by dead process":
            lk_reset()
            lk_write(".build/test.lock", 99999)
            expect(mock_is_running(".build/test.lock")).to_equal(false)

    describe "stale lock recovery":
        it "replaces stale lock and acquires":
            lk_reset()
            lk_write(".build/test.lock", 88888)
            # 88888 not alive
            val pid = mock_try_acquire(".build/test.lock")
            expect(pid).to_equal(12345)
            expect(lk_read_pid(".build/test.lock")).to_equal(12345)

        it "does not replace active lock":
            lk_reset()
            lk_write(".build/test.lock", 77777)
            lk_add_alive(77777)
            val pid = mock_try_acquire(".build/test.lock")
            expect(pid).to_equal(-1)
            expect(lk_read_pid(".build/test.lock")).to_equal(77777)
