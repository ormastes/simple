# Daemon SDK Runner Specification
#
# Tests the generic daemon runner: poll cycle, request dispatch,
# handler callback, and shutdown.
#
# **Feature IDs:** #DSDK-031 to #DSDK-040
# **Category:** Infrastructure

# ============================================================================
# Module-level daemon runner state
# ============================================================================

val DR_IDLE: i64 = 0
val DR_POLLING: i64 = 1
val DR_PROCESSING: i64 = 2
val DR_SHUTTING: i64 = 3

var dr_running: bool = false
var dr_status: i64 = 0
var dr_cycle_count: i64 = 0
var dr_items_processed: i64 = 0
var dr_lock_pid: i64 = 0

# Handler tracking
var dr_handled_ids: [text] = []
var dr_handled_kinds: [i64] = []

# Request queue (simulates file reading)
var dr_queue_ids: [text] = []
var dr_queue_kinds: [i64] = []
var dr_queue_field_keys: [text] = []
var dr_queue_field_vals: [text] = []

# Response tracking
var dr_resp_ids: [text] = []
var dr_resp_statuses: [i64] = []

fn dr_reset():
    dr_running = false
    dr_status = DR_IDLE
    dr_cycle_count = 0
    dr_items_processed = 0
    dr_lock_pid = 0
    dr_handled_ids = []
    dr_handled_kinds = []
    dr_queue_ids = []
    dr_queue_kinds = []
    dr_queue_field_keys = []
    dr_queue_field_vals = []
    dr_resp_ids = []
    dr_resp_statuses = []

fn dr_start(pid: i64):
    dr_lock_pid = pid
    dr_running = pid > 0

fn dr_enqueue(req_id: text, kind: i64):
    dr_queue_ids = dr_queue_ids + [req_id]
    dr_queue_kinds = dr_queue_kinds + [kind]

fn dr_poll_cycle():
    if not dr_running:
        return
    dr_status = DR_POLLING

    # Process queued requests
    if dr_queue_ids.len() > 0:
        dr_status = DR_PROCESSING
        var i = 0
        while i < dr_queue_ids.len():
            val req_id = dr_queue_ids[i]
            val kind = dr_queue_kinds[i]
            # Call handler
            dr_handled_ids = dr_handled_ids + [req_id]
            dr_handled_kinds = dr_handled_kinds + [kind]
            # Write response
            dr_resp_ids = dr_resp_ids + [req_id]
            dr_resp_statuses = dr_resp_statuses + [0]
            dr_items_processed = dr_items_processed + 1
            i = i + 1
        # Clear queue
        dr_queue_ids = []
        dr_queue_kinds = []

    dr_cycle_count = dr_cycle_count + 1
    dr_status = DR_IDLE

fn dr_shutdown():
    dr_running = false
    dr_status = DR_SHUTTING

# Getters
fn dr_get_running() -> bool:
    dr_running
fn dr_get_status() -> i64:
    dr_status
fn dr_get_cycle_count() -> i64:
    dr_cycle_count
fn dr_get_items() -> i64:
    dr_items_processed
fn dr_get_handled_count() -> i64:
    dr_handled_ids.len()
fn dr_get_handled_id(idx: i64) -> text:
    dr_handled_ids[idx]
fn dr_get_handled_kind(idx: i64) -> i64:
    dr_handled_kinds[idx]
fn dr_get_resp_count() -> i64:
    dr_resp_ids.len()
fn dr_get_resp_id(idx: i64) -> text:
    dr_resp_ids[idx]
fn dr_get_lock_pid() -> i64:
    dr_lock_pid

# ============================================================================
# Tests
# ============================================================================

describe "DaemonRunner":
    describe "lifecycle":
        it "starts when lock acquired (pid > 0)":
            dr_reset()
            dr_start(12345)
            expect(dr_get_running()).to_equal(true)
            expect(dr_get_lock_pid()).to_equal(12345)

        it "does not start when lock fails (pid = -1)":
            dr_reset()
            dr_start(-1)
            expect(dr_get_running()).to_equal(false)

        it "shuts down cleanly":
            dr_reset()
            dr_start(12345)
            dr_shutdown()
            expect(dr_get_running()).to_equal(false)
            expect(dr_get_status()).to_equal(DR_SHUTTING)

    describe "poll_cycle":
        it "does nothing when not running":
            dr_reset()
            dr_enqueue("r1", 1)
            dr_poll_cycle()
            expect(dr_get_handled_count()).to_equal(0)
            expect(dr_get_cycle_count()).to_equal(0)

        it "processes empty queue":
            dr_reset()
            dr_start(12345)
            dr_poll_cycle()
            expect(dr_get_cycle_count()).to_equal(1)
            expect(dr_get_handled_count()).to_equal(0)
            expect(dr_get_status()).to_equal(DR_IDLE)

        it "dispatches single request to handler":
            dr_reset()
            dr_start(12345)
            dr_enqueue("req_1", 3)
            dr_poll_cycle()
            expect(dr_get_handled_count()).to_equal(1)
            expect(dr_get_handled_id(0)).to_equal("req_1")
            expect(dr_get_handled_kind(0)).to_equal(3)

        it "dispatches multiple requests":
            dr_reset()
            dr_start(12345)
            dr_enqueue("r1", 1)
            dr_enqueue("r2", 2)
            dr_enqueue("r3", 3)
            dr_poll_cycle()
            expect(dr_get_handled_count()).to_equal(3)
            expect(dr_get_items()).to_equal(3)

        it "writes response for each request":
            dr_reset()
            dr_start(12345)
            dr_enqueue("r1", 1)
            dr_enqueue("r2", 2)
            dr_poll_cycle()
            expect(dr_get_resp_count()).to_equal(2)
            expect(dr_get_resp_id(0)).to_equal("r1")
            expect(dr_get_resp_id(1)).to_equal("r2")

        it "clears queue after processing":
            dr_reset()
            dr_start(12345)
            dr_enqueue("r1", 1)
            dr_poll_cycle()
            dr_poll_cycle()
            expect(dr_get_handled_count()).to_equal(1)
            expect(dr_get_cycle_count()).to_equal(2)

        it "returns to idle after cycle":
            dr_reset()
            dr_start(12345)
            dr_enqueue("r1", 1)
            dr_poll_cycle()
            expect(dr_get_status()).to_equal(DR_IDLE)

    describe "accumulation":
        it "accumulates items across cycles":
            dr_reset()
            dr_start(12345)
            dr_enqueue("r1", 1)
            dr_poll_cycle()
            dr_enqueue("r2", 2)
            dr_enqueue("r3", 3)
            dr_poll_cycle()
            expect(dr_get_items()).to_equal(3)
            expect(dr_get_cycle_count()).to_equal(2)

        it "accumulates handler calls across cycles":
            dr_reset()
            dr_start(12345)
            dr_enqueue("a", 1)
            dr_poll_cycle()
            dr_enqueue("b", 2)
            dr_poll_cycle()
            expect(dr_get_handled_count()).to_equal(2)
            expect(dr_get_handled_id(0)).to_equal("a")
            expect(dr_get_handled_id(1)).to_equal("b")
