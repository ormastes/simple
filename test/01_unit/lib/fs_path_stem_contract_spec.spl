use std.fs.{Path}

extern fn rt_file_read_text(path: text) -> text

describe "filesystem path stem ownership":
    it "keeps both profiles on the pure-Simple owner":
        val sync_source = rt_file_read_text("src/lib/nogc_sync_mut/fs.spl") ?? ""
        val async_source = rt_file_read_text("src/lib/nogc_async_mut/fs.spl") ?? ""
        for source in [sync_source, async_source]:
            expect(source).to_contain("use std.path.{stem as std_path_stem}")
            expect(source).to_contain("val value = std_path_stem(path_value.replace")
            expect(source.contains("extern fn path_stem")).to_equal(false)

    it "preserves Unix Windows and empty-stem behavior":
        val archive = Path.new("/tmp/archive.tar")
        val windows_archive = Path.new("C:\\tmp\\archive.tar")
        val root = Path.new("/")
        val empty = Path.new("")
        expect(archive.stem().unwrap()).to_equal("archive")
        expect(windows_archive.stem().unwrap()).to_equal("archive")
        expect(root.stem()).to_be_nil()
        expect(empty.stem()).to_be_nil()
