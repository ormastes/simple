use std.fs.{Path}

extern fn rt_file_read_text(path: text) -> text

describe "filesystem pure-Simple path helper ownership":
    it "keeps both profiles on the pure-Simple owner":
        val sync_source = rt_file_read_text("src/lib/nogc_sync_mut/fs.spl") ?? ""
        val async_source = rt_file_read_text("src/lib/nogc_async_mut/fs.spl") ?? ""
        for source in [sync_source, async_source]:
            expect(source).to_contain("use std.path.{basename as std_path_basename}")
            expect(source).to_contain("use std.path.{extension as std_path_extension}")
            expect(source).to_contain("use std.path.{parent_dir_option as std_path_parent_dir_option}")
            expect(source).to_contain("use std.path.{split_path as std_path_split_path}")
            expect(source).to_contain("use std.path.{stem as std_path_stem}")
            expect(source).to_contain("val value = std_path_stem(path_value.replace")
            for helper in ["path_parent", "path_filename", "path_extension", "path_stem", "path_components"]:
                expect(source.contains("extern fn {helper}")).to_equal(false)

    it "preserves Unix Windows and empty-stem behavior":
        val archive = Path.new("/tmp/archive.tar")
        val windows_archive = Path.new("C:\\tmp\\archive.tar")
        val root = Path.new("/")
        val empty = Path.new("")
        expect(archive.stem().unwrap()).to_equal("archive")
        expect(windows_archive.stem().unwrap()).to_equal("archive")
        expect(root.stem()).to_be_nil()
        expect(empty.stem()).to_be_nil()

    it "preserves filename and extension edges":
        val windows_file = Path.new("C:\\tmp\\file.txt")
        expect(Path.new("/tmp/dir/").filename()).to_be_nil()
        expect(windows_file.filename().unwrap()).to_equal("file.txt")
        expect(windows_file.extension().unwrap()).to_equal("txt")
        expect(Path.new(".gitignore").extension()).to_be_nil()
        expect(Path.new("name.").extension()).to_be_nil()

    it "preserves Unix and Windows parent edges":
        expect(Path.new("/").parent()).to_be_nil()
        expect(Path.new("/home").parent().unwrap().to_string()).to_equal("/")
        expect(Path.new("leaf").parent()).to_be_nil()
        expect(Path.new("/home/user/").parent().unwrap().to_string()).to_equal("/home")
        expect(Path.new("C:\\").parent()).to_be_nil()
        expect(Path.new("C:\\home").parent().unwrap().to_string()).to_equal("C:/")

    it "preserves normalized rooted relative drive and UNC components":
        expect(Path.new("").components().len()).to_equal(0)
        expect(Path.new("/").components()).to_equal(["/"])
        expect(Path.new("/home/user").components()).to_equal(["/", "home", "user"])
        expect(Path.new("src/./lib/../main.spl").components()).to_equal(["src", "main.spl"])
        expect(Path.new("../src").components()).to_equal(["..", "src"])
        expect(Path.new("C:\\tmp\\file").components()).to_equal(["C:", "tmp", "file"])
        expect(Path.new("\\\\server\\share\\dir").components()).to_equal(["/", "server", "share", "dir"])
