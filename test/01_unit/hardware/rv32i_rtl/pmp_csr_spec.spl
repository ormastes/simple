# tag: only-compiled

import std.spec
use std.hardware.rv32i_rtl.pmp_csr.{pmp32_entries_reset, pmp32_cfg_normalize, pmp32_csr_read, pmp32_csr_write}

val CSR_PMPCFG0: u32 = 0x3A0
val CSR_PMPCFG3: u32 = 0x3A3
val CSR_PMPADDR0: u32 = 0x3B0

describe "RV32 PMP CSR production owner":
    it "resets entries and packs configuration and address reads":
        var entries = pmp32_entries_reset()
        expect(entries.cfg_0).to_equal(0)
        expect(entries.cfg_15).to_equal(0)
        expect(entries.addr_0).to_equal(0)
        expect(entries.addr_15).to_equal(0)

        entries.cfg_0 = 0x01
        entries.cfg_1 = 0x02
        entries.cfg_2 = 0x04
        entries.cfg_3 = 0x80
        entries.cfg_15 = 0x80
        entries.addr_5 = 0x12345678

        val cfg0 = pmp32_csr_read(entries, CSR_PMPCFG0)
        val cfg3 = pmp32_csr_read(entries, CSR_PMPCFG3)
        val addr5 = pmp32_csr_read(entries, CSR_PMPADDR0 + 5)
        expect(cfg0.handled).to_equal(true)
        expect(cfg0.value).to_equal(0x80040201)
        expect(cfg3.value).to_equal(0x80000000)
        expect(addr5.handled).to_equal(true)
        expect(addr5.value).to_equal(0x12345678)

    it "normalizes reserved configuration bits and W without R":
        expect(pmp32_cfg_normalize(0x7A)).to_equal(0x18)
        expect(pmp32_cfg_normalize(0xFF)).to_equal(0x9F)

    it "preserves only locked bytes during a packed configuration write":
        var entries = pmp32_entries_reset()
        entries.cfg_0 = 0x99

        val result = pmp32_csr_write(entries, CSR_PMPCFG0, 0xFF7A1A01)
        expect(result.handled).to_equal(true)
        expect(result.entries.cfg_0).to_equal(0x99)
        expect(result.entries.cfg_1).to_equal(0x18)
        expect(result.entries.cfg_2).to_equal(0x18)
        expect(result.entries.cfg_3).to_equal(0x9F)

    it "lets a locked TOR entry lock its predecessor pmpaddr":
        var entries = pmp32_entries_reset()
        entries.cfg_15 = 0x88
        entries.addr_14 = 0x111
        entries.addr_15 = 0x333

        val predecessor = pmp32_csr_write(entries, CSR_PMPADDR0 + 14, 0x222)
        val own = pmp32_csr_write(entries, CSR_PMPADDR0 + 15, 0x444)
        expect(predecessor.handled).to_equal(true)
        expect(predecessor.entries.addr_14).to_equal(0x111)
        expect(own.handled).to_equal(true)
        expect(own.entries.addr_15).to_equal(0x333)

    it "writes a normal unlocked pmpaddr":
        val entries = pmp32_entries_reset()
        val result = pmp32_csr_write(entries, CSR_PMPADDR0 + 7, 0x89ABCDEF)
        expect(result.handled).to_equal(true)
        expect(result.entries.addr_7).to_equal(0x89ABCDEF)

    it "leaves state unchanged for invalid CSR addresses":
        var entries = pmp32_entries_reset()
        entries.cfg_0 = 0x19
        entries.addr_0 = 0x400

        val read = pmp32_csr_read(entries, 0x3AF)
        val write = pmp32_csr_write(entries, 0x3AF, 0xFFFFFFFF)
        expect(read.handled).to_equal(false)
        expect(read.value).to_equal(0)
        expect(write.handled).to_equal(false)
        expect(write.entries.cfg_0).to_equal(0x19)
        expect(write.entries.addr_0).to_equal(0x400)
