use std.spipe.*
use std.hardware.soc_rtl.soc_top.{SocState, soc_create, soc_tick, soc_mem_write}
use std.hardware.soc_rtl.ram.ram_write
use std.hardware.soc_rtl.wb_interconnect.{RAM_BASE, UART_BASE}
use std.hardware.soc_rtl.plic.{PLIC_BASE, PLIC_S_ENABLE_OFF}
use std.hardware.soc_rtl.plic.PLIC_S_THRESHOLD_OFF
use std.hardware.soc_rtl.uart16550.IER_THRI
use std.hardware.rv32i_rtl.regfile.{regfile_read, regfile_write}
use std.hardware.rv32i_rtl.core.{core32_restart_fetch, CORE32_FETCH}
use std.hardware.rv32i_rtl.memory_access.MEMORY32_REQUEST
use std.hardware.rv32i_rtl.pmp_csr.pmp32_csr_write
use std.hardware.rv32i_rtl.mmu_sv32.mmu_satp_value
use std.hardware.rv32i_rtl.csr.{MSTATUS_MPRV_MASK, MEDELEG_SUPPORTED_MASK}
use std.hardware.rv32i_rtl.csr.{MIDELEG_SUPPORTED_MASK, csr_create, csr_write}
use std.hardware.rv32i_rtl.csr.{CSR_ADDR_MIP, MIP_MSIP_MASK, MIP_SSIP_MASK}
use std.hardware.rv32i_rtl.csr.MIP_STIP_MASK
use std.hardware.rv32i_rtl.csr.{MIP_SEIP_MASK, MIP_SUPERVISOR_MASK}
use std.hardware.rv32i_rtl.trap.{CAUSE_STI, CAUSE_SEI}
use std.hardware.rv32i_rtl.atomics.atomics32_lr
use std.hardware.rv32i_rtl.csr_s.{SSTATUS_SIE_MASK, SSTATUS_SPIE_MASK}
use std.hardware.rv32i_rtl.csr_s.{SSTATUS_SPP_MASK, SSTATUS_SUM_MASK}

val PMPADDR0: u32 = 0x3B0
val PMPCFG0: u32 = 0x3A0
val RAM_4K_NAPOT: u32 = 0x200001FF
val RAM_8K_NAPOT: u32 = 0x200003FF
val PMP_LOCKED_X: u32 = 0x9C
val PMP_RWX: u32 = 0x1F

fn csr_instruction(addr: u32, rs1: u32, funct3: u32, rd: u32) -> u32:
    (addr << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | 0x73

fn retire_one(state: SocState) -> SocState:
    var out = state
    out.response_valid = false
    out.response_error = false
    out.core = core32_restart_fetch(out.core)
    val retired = out.core.csr_m.minstret
    val mepc = out.core.csr_m.mepc
    val sepc = out.core.csr_s.sepc
    var cycles: u32 = 0
    while cycles < 32:
        out = soc_tick(out).state
        if out.core.csr_m.minstret != retired:
            return out
        if out.core.csr_m.mepc != mepc or out.core.csr_s.sepc != sepc:
            return out
        if (out.core.pipeline_phase == CORE32_FETCH and
            out.core.memory.phase == MEMORY32_REQUEST):
            return out
        cycles = cycles + 1
    out

fn executable_ram(state: SocState) -> SocState:
    var out = state
    out.core.pmp = pmp32_csr_write(out.core.pmp, PMPADDR0,
        RAM_4K_NAPOT).entries
    out.core.pmp = pmp32_csr_write(out.core.pmp, PMPCFG0,
        PMP_LOCKED_X).entries
    out

describe "RV32 supervisor CSR and trap routing":
    it "delegates a U-mode ECALL horizontally to S-mode":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.csr_m.mepc = RAM_BASE + 4
        state.core.csr_m.medeleg = 1 << 8
        state.core.csr_m.mtvec = 0x1000
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0, 0x30200073, 2)
        state.ram = ram_write(state.ram, 4, 0x00000073, 2)
        state = executable_ram(state)

        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(0)
        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(1)
        expect(state.core.pc).to_equal(0x2000)
        expect(state.core.csr_s.scause).to_equal(8)
        expect(state.core.csr_s.sepc).to_equal(RAM_BASE + 4)
        expect(state.core.csr_m.mcause).to_equal(0)
        expect(state.core.csr_m.mstatus & SSTATUS_SPP_MASK).to_equal(0)

    it "never delegates a trap originating in M-mode":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.csr_m.medeleg = 0xFFFFFFFF
        state.core.csr_m.mtvec = 0x1000
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0, 0x00000073, 2)
        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(3)
        expect(state.core.pc).to_equal(0x1000)
        expect(state.core.csr_m.mcause).to_equal(11)
        expect(state.core.csr_s.scause).to_equal(0)

    it "uses SRET to restore U and the supervisor interrupt-enable stack":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.core.csr_s.sepc = RAM_BASE + 4
        state.core.csr_m.mstatus = SSTATUS_SPIE_MASK | MSTATUS_MPRV_MASK
        state.ram = ram_write(state.ram, 0, 0x10200073, 2)
        state = executable_ram(state)
        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(0)
        expect(state.core.pc).to_equal(RAM_BASE + 4)
        expect(state.core.csr_m.mstatus & SSTATUS_SIE_MASK).to_equal(
            SSTATUS_SIE_MASK)
        expect(state.core.csr_m.mstatus & SSTATUS_SPIE_MASK).to_equal(
            SSTATUS_SPIE_MASK)
        expect(state.core.csr_m.mstatus & MSTATUS_MPRV_MASK).to_equal(0)

    it "reads and writes sstatus as the canonical mstatus alias":
        var write_state = soc_create(64)
        write_state.core.pc = RAM_BASE
        write_state.core.priv_mode = 1
        write_state.ram = ram_write(write_state.ram, 0,
            csr_instruction(0x100, 1, 1, 2), 2)
        write_state.core.rf = regfile_write(write_state.core.rf, 1,
            SSTATUS_SIE_MASK | SSTATUS_SUM_MASK, true)
        write_state = executable_ram(write_state)
        write_state = retire_one(write_state)
        expect(write_state.core.csr_m.mstatus &
            (SSTATUS_SIE_MASK | SSTATUS_SUM_MASK)).to_equal(
            SSTATUS_SIE_MASK | SSTATUS_SUM_MASK)

        var read_state = soc_create(64)
        read_state.core.pc = RAM_BASE
        read_state.core.priv_mode = 1
        read_state.core.csr_m.mstatus = SSTATUS_SUM_MASK
        read_state.ram = ram_write(read_state.ram, 0,
            csr_instruction(0x100, 0, 2, 2), 2)
        read_state = executable_ram(read_state)
        read_state = retire_one(read_state)
        expect(regfile_read(read_state.core.rf, 2, 0).rs1_data).to_equal(
            SSTATUS_SUM_MASK)

    it "rejects an S-mode machine CSR write without mutating its target":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.core.csr_m.medeleg = 1 << 2
        state.core.csr_m.mscratch = 0x55
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0,
            csr_instruction(0x340, 1, 1, 2), 2)
        state.core.rf = regfile_write(state.core.rf, 1, 0xAA, true)
        state = executable_ram(state)
        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(1)
        expect(state.core.pc).to_equal(0x2000)
        expect(state.core.csr_s.scause).to_equal(2)
        expect(state.core.csr_m.mscratch).to_equal(0x55)
        expect(state.core.csr_m.mcause).to_equal(0)

    it "traps a non-canonical MRET encoding as illegal":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.csr_m.mtvec = 0x1000
        # MRET with rd=x1 is reserved rather than an MRET instruction.
        state.ram = ram_write(state.ram, 0, 0x302000F3, 2)
        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(3)
        expect(state.core.pc).to_equal(0x1000)
        expect(state.core.csr_m.mcause).to_equal(2)
        expect(state.core.csr_m.mtval).to_equal(0x302000F3)

    it "masks delegation CSRs to implemented causes":
        val delegated = csr_write(csr_create(0), 0x302, 0xFFFFFFFF)
        expect(delegated.medeleg).to_equal(MEDELEG_SUPPORTED_MASK)
        val interrupts = csr_write(delegated, 0x303, 0xFFFFFFFF)
        expect(interrupts.mideleg).to_equal(MIDELEG_SUPPORTED_MASK)

    it "routes sie and sip through masked machine CSR aliases":
        var sie_state = soc_create(64)
        sie_state.core.pc = RAM_BASE
        sie_state.core.priv_mode = 1
        sie_state.core.csr_m.mideleg = MIP_STIP_MASK | MIP_SEIP_MASK
        sie_state.core.csr_m.mie = MIP_MSIP_MASK
        sie_state.ram = ram_write(sie_state.ram, 0,
            csr_instruction(0x104, 1, 1, 2), 2)
        sie_state.core.rf = regfile_write(sie_state.core.rf, 1,
            0xFFFFFFFF, true)
        sie_state = executable_ram(sie_state)
        sie_state = retire_one(sie_state)
        expect(sie_state.core.csr_m.mie & MIP_SUPERVISOR_MASK).to_equal(
            MIP_STIP_MASK | MIP_SEIP_MASK)
        expect(sie_state.core.csr_m.mie & MIP_MSIP_MASK).to_equal(
            MIP_MSIP_MASK)

        var sip_state = soc_create(64)
        sip_state.core.pc = RAM_BASE
        sip_state.core.priv_mode = 1
        sip_state.core.csr_m.mideleg = MIP_SUPERVISOR_MASK
        sip_state.core.csr_m = csr_write(sip_state.core.csr_m,
            CSR_ADDR_MIP, MIP_STIP_MASK | MIP_SEIP_MASK)
        sip_state.ram = ram_write(sip_state.ram, 0,
            csr_instruction(0x144, 1, 1, 2), 2)
        sip_state.core.rf = regfile_write(sip_state.core.rf, 1,
            0xFFFFFFFF, true)
        sip_state = executable_ram(sip_state)
        sip_state = retire_one(sip_state)
        expect(regfile_read(sip_state.core.rf, 2, 0).rs1_data).to_equal(
            MIP_STIP_MASK | MIP_SEIP_MASK)
        expect(sip_state.core.csr_m.mip & MIP_SUPERVISOR_MASK).to_equal(
            MIP_SUPERVISOR_MASK)

    it "retires before taking delegated STIP and clears the reservation":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.core.csr_m.mideleg = MIP_STIP_MASK
        state.core.csr_m.mie = MIP_STIP_MASK
        state.core.csr_m.mip = MIP_STIP_MASK
        state.core.csr_m.mstatus = SSTATUS_SIE_MASK
        state.core.csr_s.stvec = 0x2000
        state.core.atomics = atomics32_lr(state.core.atomics,
            RAM_BASE as i64, 4)
        state.ram = ram_write(state.ram, 0, 0x00000013, 2)
        state = executable_ram(state)

        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(1)
        expect(state.core.pc).to_equal(0x2000)
        expect(state.core.csr_s.scause).to_equal(CAUSE_STI)
        expect(state.core.csr_s.sepc).to_equal(RAM_BASE + 4)
        expect(state.core.csr_m.minstret).to_equal(1)
        expect(state.core.atomics.reservation_valid).to_equal(false)

    it "takes a delegated UART PLIC interrupt at an instruction boundary":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.core.csr_m.mideleg = MIP_SEIP_MASK
        state.core.csr_m.mie = MIP_SEIP_MASK
        state.core.csr_m.mstatus = SSTATUS_SIE_MASK
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0, 0x00000013, 2)
        state = executable_ram(state)
        state = soc_mem_write(state, PLIC_BASE + (10 << 2), 3, 2).state
        state = soc_mem_write(state, PLIC_BASE + PLIC_S_ENABLE_OFF,
            1 << 10, 2).state
        state = soc_mem_write(state, PLIC_BASE + PLIC_S_THRESHOLD_OFF,
            0, 2).state
        state = soc_mem_write(state, UART_BASE + 1, IER_THRI, 0).state

        state = retire_one(state)
        expect(state.core.priv_mode).to_equal(1)
        expect(state.core.pc).to_equal(0x2000)
        expect(state.core.csr_s.scause).to_equal(CAUSE_SEI)
        expect(state.core.csr_s.sepc).to_equal(RAM_BASE + 4)
        expect(state.core.csr_m.minstret).to_equal(1)

    it "writes satp, translates fetches, and flushes with SFENCE.VMA":
        var state = soc_create(2048)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.ram = ram_write(state.ram, 0,
            csr_instruction(0x180, 1, 1, 2), 2)
        state.ram = ram_write(state.ram, 4,
            csr_instruction(0x180, 0, 2, 3), 2)
        state.ram = ram_write(state.ram, 8, 0x12000073, 2)
        state.ram = ram_write(state.ram, 12, 0x00700293, 2)
        # Root VPN[1]=0x200 points to the second RAM page; its first leaf maps
        # virtual RAM_BASE back to the executable first page.
        state.ram = ram_write(state.ram, 0x800, 0x20000401, 2)
        state.ram = ram_write(state.ram, 0x1000, 0x2000004B, 2)
        state.core.rf = regfile_write(state.core.rf, 1, 0x80080000, true)
        state.core.pmp = pmp32_csr_write(state.core.pmp, PMPADDR0,
            RAM_8K_NAPOT).entries
        state.core.pmp = pmp32_csr_write(state.core.pmp, PMPCFG0,
            PMP_RWX).entries

        state = retire_one(state)
        expect(regfile_read(state.core.rf, 2, 0).rs1_data).to_equal(0)
        expect(mmu_satp_value(state.core.mmu)).to_equal(0x80080000)

        val before_walk_cycle = state.core.csr_m.mcycle
        val before_walk_retire = state.core.csr_m.minstret
        state = soc_tick(state).state
        expect(state.core.csr_m.mcycle).to_equal(before_walk_cycle + 1)
        expect(state.core.csr_m.minstret).to_equal(before_walk_retire)

        state = retire_one(state)
        expect(regfile_read(state.core.rf, 3, 0).rs1_data).to_equal(
            0x80080000)
        expect(state.core.mmu.tlb_count).to_be_greater_than(0)

        state = retire_one(state)
        expect(state.core.mmu.tlb_count).to_equal(0)

        state = retire_one(state)
        expect(regfile_read(state.core.rf, 5, 0).rs1_data).to_equal(7)
        expect(state.core.pc).to_equal(RAM_BASE + 16)
        expect(state.core.csr_m.minstret).to_equal(4)
        expect(state.core.csr_m.mcycle).to_be_greater_than(
            state.core.csr_m.minstret)
