use std.spipe.*
use std.hardware.soc_rtl.soc_top.{SocState, soc_create, soc_tick}
use std.hardware.soc_rtl.ram.ram_write
use std.hardware.soc_rtl.wb_interconnect.RAM_BASE
use std.hardware.rv32i_rtl.regfile.{regfile_read, regfile_write}
use std.hardware.rv32i_rtl.pmp_csr.pmp32_csr_write
use std.hardware.rv32i_rtl.csr.{MSTATUS_MPRV_MASK, MEDELEG_SUPPORTED_MASK}
use std.hardware.rv32i_rtl.csr.{MIDELEG_SUPPORTED_MASK, csr_create, csr_write}
use std.hardware.rv32i_rtl.csr_s.{SSTATUS_SIE_MASK, SSTATUS_SPIE_MASK}
use std.hardware.rv32i_rtl.csr_s.{SSTATUS_SPP_MASK, SSTATUS_SUM_MASK}

val PMPADDR0: u32 = 0x3B0
val PMPCFG0: u32 = 0x3A0
val RAM_4K_NAPOT: u32 = 0x200001FF
val PMP_LOCKED_X: u32 = 0x9C

fn csr_instruction(addr: u32, rs1: u32, funct3: u32, rd: u32) -> u32:
    (addr << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | 0x73

fn executable_ram(state: SocState) -> SocState:
    var out = state
    out.core.pmp = pmp32_csr_write(out.core.pmp, PMPADDR0,
        RAM_4K_NAPOT).entries
    out.core.pmp = pmp32_csr_write(out.core.pmp, PMPCFG0,
        PMP_LOCKED_X).entries
    out

describe "RV32 supervisor CSR and trap routing":
    it "delegates a U-mode ECALL horizontally to S-mode":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.csr_m.mepc = RAM_BASE + 4
        state.core.csr_m.medeleg = 1 << 8
        state.core.csr_m.mtvec = 0x1000
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0, 0x30200073, 2)
        state.ram = ram_write(state.ram, 4, 0x00000073, 2)
        state = executable_ram(state)

        state = soc_tick(state).state
        expect(state.core.priv_mode).to_equal(0)
        state = soc_tick(state).state
        expect(state.core.priv_mode).to_equal(1)
        expect(state.core.pc).to_equal(0x2000)
        expect(state.core.csr_s.scause).to_equal(8)
        expect(state.core.csr_s.sepc).to_equal(RAM_BASE + 4)
        expect(state.core.csr_m.mcause).to_equal(0)
        expect(state.core.csr_m.mstatus & SSTATUS_SPP_MASK).to_equal(0)

    it "never delegates a trap originating in M-mode":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.csr_m.medeleg = 0xFFFFFFFF
        state.core.csr_m.mtvec = 0x1000
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0, 0x00000073, 2)
        state = soc_tick(state).state
        expect(state.core.priv_mode).to_equal(3)
        expect(state.core.pc).to_equal(0x1000)
        expect(state.core.csr_m.mcause).to_equal(11)
        expect(state.core.csr_s.scause).to_equal(0)

    it "uses SRET to restore U and the supervisor interrupt-enable stack":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.core.csr_s.sepc = RAM_BASE + 4
        state.core.csr_m.mstatus = SSTATUS_SPIE_MASK | MSTATUS_MPRV_MASK
        state.ram = ram_write(state.ram, 0, 0x10200073, 2)
        state = executable_ram(state)
        state = soc_tick(state).state
        expect(state.core.priv_mode).to_equal(0)
        expect(state.core.pc).to_equal(RAM_BASE + 4)
        expect(state.core.csr_m.mstatus & SSTATUS_SIE_MASK).to_equal(
            SSTATUS_SIE_MASK)
        expect(state.core.csr_m.mstatus & SSTATUS_SPIE_MASK).to_equal(
            SSTATUS_SPIE_MASK)
        expect(state.core.csr_m.mstatus & MSTATUS_MPRV_MASK).to_equal(0)

    it "reads and writes sstatus as the canonical mstatus alias":
        var write_state = soc_create(64)
        write_state.core.pc = RAM_BASE
        write_state.core.priv_mode = 1
        write_state.ram = ram_write(write_state.ram, 0,
            csr_instruction(0x100, 1, 1, 2), 2)
        write_state.regfile = regfile_write(write_state.regfile, 1,
            SSTATUS_SIE_MASK | SSTATUS_SUM_MASK, true)
        write_state = executable_ram(write_state)
        write_state = soc_tick(write_state).state
        expect(write_state.core.csr_m.mstatus &
            (SSTATUS_SIE_MASK | SSTATUS_SUM_MASK)).to_equal(
            SSTATUS_SIE_MASK | SSTATUS_SUM_MASK)

        var read_state = soc_create(64)
        read_state.core.pc = RAM_BASE
        read_state.core.priv_mode = 1
        read_state.core.csr_m.mstatus = SSTATUS_SUM_MASK
        read_state.ram = ram_write(read_state.ram, 0,
            csr_instruction(0x100, 0, 2, 2), 2)
        read_state = executable_ram(read_state)
        read_state = soc_tick(read_state).state
        expect(regfile_read(read_state.regfile, 2, 0).rs1_data).to_equal(
            SSTATUS_SUM_MASK)

    it "rejects an S-mode machine CSR write without mutating its target":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.core.csr_m.medeleg = 1 << 2
        state.core.csr_m.mscratch = 0x55
        state.core.csr_s.stvec = 0x2000
        state.ram = ram_write(state.ram, 0,
            csr_instruction(0x340, 1, 1, 2), 2)
        state.regfile = regfile_write(state.regfile, 1, 0xAA, true)
        state = executable_ram(state)
        state = soc_tick(state).state
        expect(state.core.priv_mode).to_equal(1)
        expect(state.core.pc).to_equal(0x2000)
        expect(state.core.csr_s.scause).to_equal(2)
        expect(state.core.csr_m.mscratch).to_equal(0x55)

    it "traps a non-canonical MRET encoding as illegal":
        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.csr_m.mtvec = 0x1000
        # MRET with rd=x1 is reserved rather than an MRET instruction.
        state.ram = ram_write(state.ram, 0, 0x302000F3, 2)
        state = soc_tick(state).state
        expect(state.core.priv_mode).to_equal(3)
        expect(state.core.pc).to_equal(0x1000)
        expect(state.core.csr_m.mcause).to_equal(2)
        expect(state.core.csr_m.mtval).to_equal(0x302000F3)

    it "keeps interrupt delegation and Sv32 WARL-disabled until connected":
        val delegated = csr_write(csr_create(0), 0x302, 0xFFFFFFFF)
        expect(delegated.medeleg).to_equal(MEDELEG_SUPPORTED_MASK)
        val interrupts = csr_write(delegated, 0x303, 0xFFFFFFFF)
        expect(interrupts.mideleg).to_equal(MIDELEG_SUPPORTED_MASK)

        var state = soc_create(64)
        state.core.pc = RAM_BASE
        state.core.priv_mode = 1
        state.ram = ram_write(state.ram, 0,
            csr_instruction(0x180, 1, 1, 2), 2)
        state.ram = ram_write(state.ram, 4,
            csr_instruction(0x180, 0, 2, 3), 2)
        state.regfile = regfile_write(state.regfile, 1, 0x80000001, true)
        state = executable_ram(state)
        state = soc_tick(state).state
        expect(regfile_read(state.regfile, 2, 0).rs1_data).to_equal(0)
        state = soc_tick(state).state
        expect(regfile_read(state.regfile, 3, 0).rs1_data).to_equal(0)
