use std.hardware.rv32i_rtl.regfile.{regfile_create, regfile_read, regfile_write}
use std.hardware.rv64gc_rtl.regfile.{regfile64_create, regfile64_read, regfile64_write}

describe "synthesizable RISC-V register files":
    it "maps every RV32 GPR lane and preserves x0":
        var rf = regfile_create()
        expect(regfile_read(rf, 2, 0).rs1_data).to_equal(0xFFC)

        for index in 1..32:
            val addr = index as u32
            rf = regfile_write(rf, addr, (index * 3) as u32, true)

        for index in 1..32:
            val addr = index as u32
            expect(regfile_read(rf, addr, 0).rs1_data).to_equal((index * 3) as u32)

        rf = regfile_write(rf, 0, 99, true)
        rf = regfile_write(rf, 1, 99, false)
        val ports = regfile_read(rf, 0, 32)
        expect(ports.rs1_data).to_equal(0)
        expect(ports.rs2_data).to_equal(0)
        expect(ports.a0_val).to_equal(30)
        expect(ports.a1_val).to_equal(33)
        expect(regfile_read(rf, 1, 0).rs1_data).to_equal(3)

    it "maps every RV64 GPR lane and preserves x0":
        var rf = regfile64_create()
        expect(regfile64_read(rf, 2, 0).rs1_data).to_equal(0xFFC)

        for index in 1..32:
            val addr = index as u32
            rf = regfile64_write(rf, addr, (index as i64) << 33, true)

        for index in 1..32:
            val addr = index as u32
            expect(regfile64_read(rf, addr, 0).rs1_data).to_equal((index as i64) << 33)

        rf = regfile64_write(rf, 0, -1, true)
        rf = regfile64_write(rf, 1, -1, false)
        val ports = regfile64_read(rf, 0, 32)
        expect(ports.rs1_data).to_equal(0)
        expect(ports.rs2_data).to_equal(0)
        expect(ports.a0_val).to_equal((10 as i64) << 33)
        expect(ports.a1_val).to_equal((11 as i64) << 33)
        expect(regfile64_read(rf, 1, 0).rs1_data).to_equal((1 as i64) << 33)
