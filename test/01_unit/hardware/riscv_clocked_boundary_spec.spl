use std.hardware.rv32i_rtl.core.core_reset
use std.hardware.rv32i_rtl.clocked.core32_clocked
use std.hardware.rv64gc_rtl.core.core64_reset
use std.hardware.rv64gc_rtl.clocked.core64_clocked

describe "RISC-V registered product boundaries":
    it "initializes and starts the RV32 protected fetch path":
        val reset_pc: u32 = 0x8000_0000
        val initial = core32_clocked(false, core_reset(0), reset_pc,
            false, false, false, 0)
        expect(initial.initialized).to_be(true)
        expect(initial.cycle.state.pc).to_equal(reset_pc)
        expect(initial.cycle.bus_valid).to_be(false)

        val fetch = core32_clocked(initial.initialized, initial.cycle.state,
            reset_pc, true, false, false, 0)
        expect(fetch.cycle.bus_valid).to_be(true)
        expect(fetch.cycle.bus_addr).to_equal(reset_pc as i64)

    it "initializes and starts the RV64 protected fetch path":
        val reset_pc: i64 = 0x8000_0000
        val initial = core64_clocked(false, core64_reset(0), reset_pc,
            false, false, false, 0)
        expect(initial.initialized).to_be(true)
        expect(initial.cycle.state.pc).to_equal(reset_pc)
        expect(initial.cycle.state.atomic_bus_exclusive).to_be(true)
        expect(initial.cycle.bus_valid).to_be(false)

        val fetch = core64_clocked(initial.initialized, initial.cycle.state,
            reset_pc, true, false, false, 0)
        expect(fetch.cycle.bus_valid).to_be(true)
        expect(fetch.cycle.bus_addr).to_equal(reset_pc)
