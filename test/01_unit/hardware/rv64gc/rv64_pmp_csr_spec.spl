use std.spec.*
use std.hardware.rv64gc_rtl.pmp_csr.{pmp64_entries_reset, pmp64_cfg_normalize, pmp64_csr_read, pmp64_csr_write}

describe "RV64 production PMP CSR owner":
    it "resets all sixteen entries":
        val entries = pmp64_entries_reset()
        expect(entries.cfg_0).to_equal(0)
        expect(entries.cfg_15).to_equal(0)
        expect(entries.addr_0).to_equal(0)
        expect(entries.addr_15).to_equal(0)

    it "normalizes reserved bits and reserved W without R":
        expect(pmp64_cfg_normalize(0xFF)).to_equal(0x9F)
        expect(pmp64_cfg_normalize(0xE2)).to_equal(0x80)

    it "packs and reads pmpcfg0":
        var entries = pmp64_entries_reset()
        entries.cfg_0 = 0x01
        entries.cfg_7 = 0x80
        val result = pmp64_csr_read(entries, 0x3A0)
        expect(result.handled).to_equal(true)
        expect(result.value & 0xFF).to_equal(0x01)
        expect((result.value >> 56) & 0xFF).to_equal(0x80)

    it "packs writes and reads pmpcfg2":
        val reset = pmp64_entries_reset()
        val written = pmp64_csr_write(reset, 0x3A2, 0x1804)
        val read = pmp64_csr_read(written.entries, 0x3A2)
        expect(written.handled).to_equal(true)
        expect(written.entries.cfg_8).to_equal(0x04)
        expect(written.entries.cfg_9).to_equal(0x18)
        expect(read.handled).to_equal(true)
        expect(read.value & 0xFFFF).to_equal(0x1804)

    it "rejects odd RV64 pmpcfg CSRs":
        val entries = pmp64_entries_reset()
        val read = pmp64_csr_read(entries, 0x3A1)
        val written = pmp64_csr_write(entries, 0x3A1, 1)
        expect(read.handled).to_equal(false)
        expect(written.handled).to_equal(false)

    it "keeps configuration locks byte local":
        var entries = pmp64_entries_reset()
        entries.cfg_0 = 0x80
        val result = pmp64_csr_write(entries, 0x3A0, 0x0101)
        expect(result.entries.cfg_0).to_equal(0x80)
        expect(result.entries.cfg_1).to_equal(0x01)

    it "locks a TOR entry predecessor address":
        var entries = pmp64_entries_reset()
        entries.addr_0 = 0x100
        entries.cfg_1 = 0x88
        val result = pmp64_csr_write(entries, 0x3B0, 0x200)
        expect(result.handled).to_equal(true)
        expect(result.entries.addr_0).to_equal(0x100)

    it "masks pmpaddr writes to fifty four bits":
        val entries = pmp64_entries_reset()
        val result = pmp64_csr_write(entries, 0x3B5, 0x7FFFFFFFFFFFFFFF)
        val read = pmp64_csr_read(result.entries, 0x3B5)
        expect(result.entries.addr_5).to_equal(0x003FFFFFFFFFFFFF)
        expect(read.value).to_equal(0x003FFFFFFFFFFFFF)

    it "rejects unrelated CSRs":
        val entries = pmp64_entries_reset()
        val read = pmp64_csr_read(entries, 0x300)
        val written = pmp64_csr_write(entries, 0x300, 1)
        expect(read.handled).to_equal(false)
        expect(written.handled).to_equal(false)
