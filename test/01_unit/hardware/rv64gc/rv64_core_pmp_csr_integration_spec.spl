use std.spec.*
use std.hardware.rv64gc_rtl.core.{CoreState64, core64_combinational, core64_init, core64_update}
use std.hardware.rv64gc_rtl.regfile.{RegFile64, regfile64_create, regfile64_write}
use std.hardware.rv64gc_rtl.mmu_sv39.mmu64_tlb_insert
use std.hardware.rv64gc_rtl.csr.csr64_write
use std.hardware.rv64gc_rtl.csr_s.csr_s64_write

fn csr_instruction(addr: u32, rs1: u32, funct3: u32, rd: u32) -> u32:
    (addr << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | 0x73

fn apply_csr(state: CoreState64, rf: RegFile64, insn: u32) -> CoreState64:
    val comb = core64_combinational(state, insn, 0, rf)
    core64_update(state, insn, comb, 0, 0)

describe "RV64 core PMP and privileged CSR integration":
    it "executes PMP CSR write and read through the clocked core state":
        var state = core64_init(0x1000)
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, 0x12345, true)

        val write_insn = csr_instruction(0x3B0, 1, 1, 2)
        val write_comb = core64_combinational(state, write_insn, 0, rf)
        expect(write_comb.dec.is_csr).to_be(true)
        expect(write_comb.rd_write).to_be(true)
        expect(write_comb.rd_data).to_equal(0)
        state = core64_update(state, write_insn, write_comb, 0, 0)
        expect(state.pmp.addr_0).to_equal(0x12345)
        expect(state.pc).to_equal(0x1004)

        val read_insn = csr_instruction(0x3B0, 0, 2, 3)
        val read_comb = core64_combinational(state, read_insn, 0, regfile64_create())
        expect(read_comb.rd_data).to_equal(0x12345)
        val read_state = core64_update(state, read_insn, read_comb, 0, 0)
        expect(read_state.pmp.addr_0).to_equal(0x12345)
        expect(read_state.pc).to_equal(0x1008)

    it "rejects PMP access below M mode before register writeback":
        var state = core64_init(0x2000)
        state.priv_mode = 1
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, 0x55, true)
        val insn = csr_instruction(0x3B0, 1, 1, 2)
        val comb = core64_combinational(state, insn, 0, rf)
        expect(comb.rd_write).to_be(false)
        val next = core64_update(state, insn, comb, 0, 0)
        expect(next.halt).to_be(false)
        expect(next.priv_mode).to_equal(3)
        expect(next.csr_m.mcause).to_equal(2)
        expect(next.csr_m.mepc).to_equal(0x2000)
        expect(next.csr_m.mtval).to_equal(insn as i64)
        expect(next.pmp.addr_0).to_equal(0)

    it "synchronizes a legal SATP write with MMU state and a safe TLB flush":
        var state = core64_init(0x3000)
        state.priv_mode = 1
        state.mmu = mmu64_tlb_insert(state.mmu, 0x10, 0x20, 0xCF)
        val satp = (8 as i64) << 60 | 0x12345
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, satp, true)
        val insn = csr_instruction(0x180, 1, 1, 2)
        val comb = core64_combinational(state, insn, 0, rf)
        val next = core64_update(state, insn, comb, 0, 0)
        expect(next.halt).to_be(false)
        expect(next.csr_s.satp).to_equal(satp)
        expect(next.mmu.satp_mode).to_equal(8)
        expect(next.mmu.satp_ppn).to_equal(0x12345)
        expect(next.mmu.tlb_count).to_equal(0)
        expect(next.mmu.tlb_0.valid).to_be(false)

    it "executes all register and immediate CSR operation forms":
        var state = core64_init(0x3800)
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, 0xF0, true)
        rf = regfile64_write(rf, 2, 0x0F, true)

        state = apply_csr(state, rf, csr_instruction(0x340, 1, 1, 3))
        expect(state.csr_m.mscratch).to_equal(0xF0)
        state = apply_csr(state, rf, csr_instruction(0x340, 2, 2, 3))
        expect(state.csr_m.mscratch).to_equal(0xFF)
        state = apply_csr(state, rf, csr_instruction(0x340, 2, 3, 3))
        expect(state.csr_m.mscratch).to_equal(0xF0)
        state = apply_csr(state, rf, csr_instruction(0x340, 3, 5, 3))
        expect(state.csr_m.mscratch).to_equal(3)
        state = apply_csr(state, rf, csr_instruction(0x340, 4, 6, 3))
        expect(state.csr_m.mscratch).to_equal(7)
        state = apply_csr(state, rf, csr_instruction(0x340, 1, 7, 3))
        expect(state.csr_m.mscratch).to_equal(6)

    it "keeps an unsupported Sv48 SATP write from diverging the Sv39 MMU":
        var state = core64_init(0x3C00)
        state.priv_mode = 1
        state.mmu = mmu64_tlb_insert(state.mmu, 0x10, 0x20, 0xCF)
        val sv48_satp = (9 as i64) << 60 | 0x54321
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, sv48_satp, true)
        val insn = csr_instruction(0x180, 1, 1, 2)
        val next = apply_csr(state, rf, insn)
        expect(next.csr_s.satp).to_equal(0)
        expect(next.mmu.satp_mode).to_equal(0)
        expect(next.mmu.tlb_count).to_equal(1)

    it "rejects writes to read-only or unknown CSRs":
        var state = core64_init(0x4000)
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, 1, true)
        val read_only = csr_instruction(0xF14, 1, 1, 2)
        val read_only_comb = core64_combinational(state, read_only, 0, rf)
        expect(read_only_comb.rd_write).to_be(false)
        val read_only_next = core64_update(state, read_only, read_only_comb, 0, 0)
        expect(read_only_next.halt).to_be(false)
        expect(read_only_next.csr_m.mcause).to_equal(2)
        expect(read_only_next.csr_m.mtval).to_equal(read_only as i64)

        val unknown = csr_instruction(0x7C0, 1, 1, 2)
        val unknown_comb = core64_combinational(state, unknown, 0, rf)
        expect(unknown_comb.rd_write).to_be(false)
        val unknown_next = core64_update(state, unknown, unknown_comb, 0, 0)
        expect(unknown_next.halt).to_be(false)
        expect(unknown_next.csr_m.mcause).to_equal(2)
        expect(unknown_next.csr_m.mtval).to_equal(unknown as i64)

    it "does not decode reserved SYSTEM funct3 four as a CSR":
        val state = core64_init(0x4400)
        val insn = csr_instruction(0x340, 1, 4, 2)
        val comb = core64_combinational(state, insn, 0, regfile64_create())
        expect(comb.dec.is_csr).to_be(false)
        expect(comb.rd_write).to_be(false)
        val next = core64_update(state, insn, comb, 0, 0)
        expect(next.csr_m.mcause).to_equal(2)
        expect(next.csr_m.mtval).to_equal(insn as i64)

    it "returns delegated illegal CSR traps with updated supervisor state":
        var state = core64_init(0x4800)
        state.priv_mode = 1
        state.csr_m = csr64_write(state.csr_m, 0x302, 1 << 2)
        state.csr_s = csr_s64_write(state.csr_s, 0x105, 0x9000)
        val insn = csr_instruction(0x3B0, 0, 2, 2)
        val comb = core64_combinational(state, insn, 0, regfile64_create())
        val next = core64_update(state, insn, comb, 0, 0)
        expect(next.priv_mode).to_equal(1)
        expect(next.pc).to_equal(0x9000)
        expect(next.csr_s.sepc).to_equal(0x4800)
        expect(next.csr_s.scause).to_equal(2)
        expect(next.csr_s.stval).to_equal(insn as i64)
