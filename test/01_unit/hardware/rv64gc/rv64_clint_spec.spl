"""
# RV64 CLINT Unit Tests

**Feature IDs:** #RV64-CLINT-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** Draft

## Overview

Unit tests for Core Local Interruptor: mtime, mtimecmp, MSIP for IPI.
CLINT base address: 0x2000000.
"""

# tag: only-compiled

import std.spec

class _Clint:
    mtime: i64
    mtimecmp: [i64]  # Per-hart
    msip: [i64]      # Per-hart

    fn timer_interrupt_pending(hart: i64) -> bool:
        self.mtime >= self.mtimecmp[hart]

    fn software_interrupt_pending(hart: i64) -> bool:
        (self.msip[hart] and 1) != 0

    me tick():
        self.mtime = self.mtime + 1

    me set_msip(hart: i64, value: i64):
        self.msip[hart] = value and 1

fn _create_clint(num_harts: i64) -> _Clint:
    var mtimecmp: [i64] = []
    var msip: [i64] = []
    var i = 0
    while i < num_harts:
        mtimecmp = mtimecmp + [0x7FFFFFFFFFFFFFFF]
        msip = msip + [0]
        i = i + 1
    _Clint(mtime: 0, mtimecmp: mtimecmp, msip: msip)

describe "mtime":
    it "initial value is 0":
        val clint = _create_clint(2)
        expect(clint.mtime).to_equal(0)

    it "tick increments mtime":
        var clint = _create_clint(2)
        clint.tick()
        clint.tick()
        expect(clint.mtime).to_equal(2)

describe "mtimecmp":
    it "write and read mtimecmp":
        var clint = _create_clint(2)
        clint.mtimecmp[0] = 1000
        expect(clint.mtimecmp[0]).to_equal(1000)

    it "per-hart mtimecmp independent":
        var clint = _create_clint(2)
        clint.mtimecmp[0] = 100
        clint.mtimecmp[1] = 200
        expect(clint.mtimecmp[0]).to_equal(100)
        expect(clint.mtimecmp[1]).to_equal(200)

describe "Timer Interrupt":
    it "mtime >= mtimecmp triggers interrupt":
        var clint = _create_clint(2)
        clint.mtimecmp[0] = 5
        var i = 0
        while i < 5:
            clint.tick()
            i = i + 1
        expect(clint.timer_interrupt_pending(0)).to_equal(true)

    it "mtime < mtimecmp no interrupt":
        var clint = _create_clint(2)
        clint.mtimecmp[0] = 100
        clint.tick()
        expect(clint.timer_interrupt_pending(0)).to_equal(false)

    it "update mtimecmp clears interrupt":
        var clint = _create_clint(2)
        clint.mtimecmp[0] = 1
        clint.tick()
        expect(clint.timer_interrupt_pending(0)).to_equal(true)
        clint.mtimecmp[0] = 100
        expect(clint.timer_interrupt_pending(0)).to_equal(false)

describe "MSIP (Software Interrupt / IPI)":
    it "set MSIP triggers software interrupt":
        var clint = _create_clint(2)
        clint.set_msip(0, 1)
        expect(clint.software_interrupt_pending(0)).to_equal(true)

    it "clear MSIP clears interrupt":
        var clint = _create_clint(2)
        clint.set_msip(0, 1)
        clint.set_msip(0, 0)
        expect(clint.software_interrupt_pending(0)).to_equal(false)

    it "IPI: hart 0 writes MSIP[1]":
        var clint = _create_clint(2)
        clint.set_msip(1, 1)
        expect(clint.software_interrupt_pending(1)).to_equal(true)
        expect(clint.software_interrupt_pending(0)).to_equal(false)
