use std.spec.*
use std.hardware.rv64gc_rtl.mmu_sv39.{mmu64_create, mmu64_set_satp}
use std.hardware.rv64gc_rtl.mmu_sv39.{ACCESS_FETCH_64, ACCESS_LOAD_64, ACCESS_STORE_64}
use std.hardware.rv64gc_rtl.mmu_sv39.{PRIV_S_64, PRIV_M_64}
use std.hardware.rv64gc_rtl.memory_access.{memory64_start, memory64_cycle}
use std.hardware.rv64gc_rtl.pmp.PmpEntries64
use std.hardware.rv64gc_rtl.pmp_csr.{pmp64_entries_reset, pmp64_csr_write}

val PTE_V: i64 = 1
val PTE_R: i64 = 2
val PTE_A: i64 = 64

fn satp_sv39(root_ppn: i64) -> i64:
    ((8 as i64) << 60) | root_ppn

fn gigapage_pte(ppn2: i64) -> i64:
    ((ppn2 << 18) << 10) | PTE_V | PTE_R | PTE_A

fn pmp_allow_all() -> PmpEntries64:
    var entries = pmp64_entries_reset()
    entries = pmp64_csr_write(entries, 0x3B0, 0x003FFFFFFFFFFFFF).entries
    pmp64_csr_write(entries, 0x3A0, 0x1F).entries

fn pmp_allow_root_page_only() -> PmpEntries64:
    var entries = pmp64_entries_reset()
    entries = pmp64_csr_write(entries, 0x3B0, 0x401FF).entries
    pmp64_csr_write(entries, 0x3A0, 0x19).entries

describe "RV64 translated and protected memory frontend":
    it "issues and completes a Bare M-mode instruction parcel":
        val mmu = mmu64_create()
        val pmp = pmp64_entries_reset()
        val state = memory64_start(mmu, pmp, 0x1000, ACCESS_FETCH_64, 2, PRIV_M_64, false, false, 0)
        val request = memory64_cycle(state, mmu, pmp, false, false, false, 0)
        expect(request.bus_valid).to_be(true)
        expect(request.bus_addr).to_equal(0x1000)
        expect(request.bus_size).to_equal(2)
        expect(request.bus_is_pte).to_be(false)
        val done = memory64_cycle(request.state, request.mmu, pmp, true, true, false, 0x1234)
        expect(done.done).to_be(true)
        expect(done.fault).to_be(false)
        expect(done.read_data).to_equal(0x1234)

    it "suppresses a Bare S-mode load denied by final PMP":
        val mmu = mmu64_create()
        val pmp = pmp64_entries_reset()
        val state = memory64_start(mmu, pmp, 0x2000, ACCESS_LOAD_64, 8, PRIV_S_64, false, false, 0)
        val denied = memory64_cycle(state, mmu, pmp, false, false, false, 0)
        expect(denied.bus_valid).to_be(false)
        expect(denied.fault).to_be(true)
        expect(denied.fault_cause).to_equal(5)

    it "walks Sv39 before issuing the translated physical load":
        val vaddr: i64 = 0x0000000040001000
        val mmu = mmu64_set_satp(mmu64_create(), satp_sv39(0x100))
        val pmp = pmp_allow_all()
        val state = memory64_start(mmu, pmp, vaddr, ACCESS_LOAD_64, 8, PRIV_S_64, false, false, 0)
        val pte_request = memory64_cycle(state, mmu, pmp, true, false, false, 0)
        expect(pte_request.bus_valid).to_be(true)
        expect(pte_request.bus_is_pte).to_be(true)
        expect(pte_request.bus_size).to_equal(8)
        val translated = memory64_cycle(pte_request.state, pte_request.mmu, pmp, false, true, false, gigapage_pte(2))
        expect(translated.bus_valid).to_be(false)
        val load_request = memory64_cycle(translated.state, translated.mmu, pmp, false, false, false, 0)
        expect(load_request.bus_valid).to_be(true)
        expect(load_request.bus_is_pte).to_be(false)
        expect(load_request.bus_addr).to_equal(0x0000000080001000)

    it "allows the PTE read but suppresses a translated target denied by PMP":
        val vaddr: i64 = 0x0000000040001000
        val mmu = mmu64_set_satp(mmu64_create(), satp_sv39(0x100))
        val pmp = pmp_allow_root_page_only()
        val state = memory64_start(mmu, pmp, vaddr, ACCESS_LOAD_64, 8, PRIV_S_64, false, false, 0)
        val pte_request = memory64_cycle(state, mmu, pmp, true, false, false, 0)
        expect(pte_request.bus_valid).to_be(true)
        val denied = memory64_cycle(pte_request.state, pte_request.mmu, pmp, false, true, false, gigapage_pte(2))
        expect(denied.done).to_be(true)
        expect(denied.fault).to_be(true)
        expect(denied.fault_cause).to_equal(5)
        expect(denied.bus_valid).to_be(false)

    it "raises a precise misaligned store before translation or bus issue":
        val mmu = mmu64_create()
        val pmp = pmp_allow_all()
        val state = memory64_start(mmu, pmp, 0x1003, ACCESS_STORE_64, 8, PRIV_M_64, false, false, 0x55)
        val fault = memory64_cycle(state, mmu, pmp, false, false, false, 0)
        expect(fault.bus_valid).to_be(false)
        expect(fault.fault).to_be(true)
        expect(fault.fault_cause).to_equal(6)
        expect(fault.fault_tval).to_equal(0x1003)
