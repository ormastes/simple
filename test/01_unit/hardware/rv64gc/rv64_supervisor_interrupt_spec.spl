use std.spipe.*
use std.hardware.rv64gc_rtl.core.{CoreState64, core64_init, core64_cycle}
use std.hardware.rv64gc_rtl.core.{core64_combinational, core64_update}
use std.hardware.rv64gc_rtl.regfile.{RegFile64, regfile64_create, regfile64_write}
use std.hardware.rv64gc_rtl.csr.{csr64_create, csr64_write, csr64_update_mip_ext}
use std.hardware.rv64gc_rtl.csr.{MIP_SEIP_MASK, MIP_SSIP_MASK, MIP_STIP_MASK}
use std.hardware.rv64gc_rtl.csr.MIP_SUPERVISOR_MASK
use std.hardware.rv64gc_rtl.csr_s.{csr_s64_write, SSTATUS_SIE_MASK_64, SSTATUS_SPIE_MASK_64}
use std.hardware.rv64gc_rtl.pmp_csr.pmp64_csr_write
use std.hardware.rv64gc_rtl.trap.{cause_sei, cause_ssi, cause_sti}
use std.hardware.soc_rtl.plic.{plic_create, plic_mmio_read, plic_mmio_read_update, plic_mmio_write}
use std.hardware.soc_rtl.plic.{plic_set_pending, plic_check_interrupt}
use std.hardware.soc_rtl.plic.{PLIC_ENABLE_OFF, PLIC_S_ENABLE_OFF}
use std.hardware.soc_rtl.plic.{PLIC_S_THRESHOLD_OFF, PLIC_S_CLAIM_OFF}

fn csr_instruction(addr: u32, rs1: u32, funct3: u32, rd: u32) -> u32:
    (addr << 20) | (rs1 << 15) | (funct3 << 12) | (rd << 7) | 0x73

fn apply_csr(state: CoreState64, rf: RegFile64, instruction: u32) -> CoreState64:
    val comb = core64_combinational(state, instruction, 0, rf)
    core64_update(state, instruction, comb, 0, 0)

fn execute32(state: CoreState64, instruction: u32) -> CoreState64:
    val low = core64_cycle(state, true, true, false,
        (instruction & 0xFFFF) as i64)
    core64_cycle(low.state, true, true, false,
        ((instruction >> 16) & 0xFFFF) as i64).state

fn allow_all_pmp(state: CoreState64) -> CoreState64:
    var out = state
    out.pmp = pmp64_csr_write(out.pmp, 0x3B0,
        0x003F_FFFF_FFFF_FFFF).entries
    out.pmp = pmp64_csr_write(out.pmp, 0x3A0, 0x1F).entries
    out

describe "RV64 supervisor interrupt CSR aliases":
    it "WARL-masks delegation and routes sie/sip through mie/mip":
        var state = core64_init(0x8000_0000)
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, -1, true)
        state = apply_csr(state, rf, csr_instruction(0x303, 1, 1, 0))
        expect(state.csr_m.mideleg).to_equal(MIP_SUPERVISOR_MASK)
        expect(state.csr_s.mideleg).to_equal(MIP_SUPERVISOR_MASK)

        state = apply_csr(state, rf, csr_instruction(0x304, 1, 1, 0))
        state.priv_mode = 1
        var srf = regfile64_create()
        srf = regfile64_write(srf, 1, MIP_STIP_MASK | MIP_SEIP_MASK, true)
        state = apply_csr(state, srf, csr_instruction(0x104, 1, 1, 0))
        expect(state.csr_m.mie & MIP_SUPERVISOR_MASK).to_equal(
            MIP_STIP_MASK | MIP_SEIP_MASK)
        expect(state.csr_s.sie).to_equal(MIP_STIP_MASK | MIP_SEIP_MASK)

        var pending = csr64_write(state.csr_m, 0x344, MIP_STIP_MASK)
        pending = csr64_update_mip_ext(pending, false, false, false, true)
        state.csr_m = pending
        val sip_read = core64_combinational(state,
            csr_instruction(0x144, 0, 2, 2), 0, regfile64_create())
        expect(sip_read.rd_data).to_equal(MIP_STIP_MASK | MIP_SEIP_MASK)

        var ssip_rf = regfile64_create()
        ssip_rf = regfile64_write(ssip_rf, 1, MIP_SSIP_MASK, true)
        state = apply_csr(state, ssip_rf,
            csr_instruction(0x144, 1, 1, 0))
        expect(state.csr_m.mip & MIP_SSIP_MASK).to_equal(MIP_SSIP_MASK)

    it "ORs software and external SEIP while preserving injected STIP":
        var csr = csr64_write(csr64_create(0), 0x344, MIP_STIP_MASK)
        csr = csr64_update_mip_ext(csr, false, false, false, true)
        expect(csr.mip & MIP_STIP_MASK).to_equal(MIP_STIP_MASK)
        expect(csr.mip & MIP_SEIP_MASK).to_equal(MIP_SEIP_MASK)
        csr = csr64_update_mip_ext(csr, false, false, false, false)
        expect(csr.mip & MIP_STIP_MASK).to_equal(MIP_STIP_MASK)
        expect(csr.mip & MIP_SEIP_MASK).to_equal(0)

        csr = csr64_write(csr, 0x344, MIP_STIP_MASK | MIP_SEIP_MASK)
        csr = csr64_update_mip_ext(csr, false, false, false, false)
        expect(csr.mip & MIP_SEIP_MASK).to_equal(MIP_SEIP_MASK)
        csr = csr64_update_mip_ext(csr, false, false, false, true)
        csr = csr64_write(csr, 0x344, MIP_STIP_MASK)
        expect(csr.mip & MIP_SEIP_MASK).to_equal(MIP_SEIP_MASK)
        csr = csr64_update_mip_ext(csr, false, false, false, false)
        expect(csr.mip & MIP_SEIP_MASK).to_equal(0)

    it "does not copy external SEIP into its software latch during CSRRS":
        var state = core64_init(0x8000_0000)
        state.csr_m = csr64_update_mip_ext(state.csr_m, false, false,
            false, true)
        var rf = regfile64_create()
        rf = regfile64_write(rf, 1, MIP_STIP_MASK, true)
        state = apply_csr(state, rf, csr_instruction(0x344, 1, 2, 0))
        expect(state.csr_m.mip & MIP_SEIP_MASK).to_equal(MIP_SEIP_MASK)
        state.csr_m = csr64_update_mip_ext(state.csr_m, false, false,
            false, false)
        expect(state.csr_m.mip & MIP_SEIP_MASK).to_equal(0)
        expect(state.csr_m.mip & MIP_STIP_MASK).to_equal(MIP_STIP_MASK)

describe "RV64 supervisor interrupt delivery":
    it "takes delegated STIP at an S-mode instruction boundary":
        val reset_pc: i64 = 0x8000_0000
        var state = allow_all_pmp(core64_init(reset_pc))
        state.priv_mode = 1
        state.csr_m = csr64_write(state.csr_m, 0x303, MIP_STIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x304, MIP_STIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x344, MIP_STIP_MASK)
        state.csr_s = csr_s64_write(state.csr_s, 0x100,
            SSTATUS_SIE_MASK_64)
        state.csr_s = csr_s64_write(state.csr_s, 0x105, 0x9000)
        state = execute32(state, 0x00000013)
        expect(state.priv_mode).to_equal(1)
        expect(state.pc).to_equal(0x9000)
        expect(state.csr_s.scause).to_equal(cause_sti())
        expect(state.csr_s.sepc).to_equal(reset_pc + 4)
        expect(state.csr_s.sstatus & SSTATUS_SIE_MASK_64).to_equal(0)
        expect(state.csr_s.sstatus & SSTATUS_SPIE_MASK_64).to_equal(
            SSTATUS_SPIE_MASK_64)

    it "does not deliver a delegated supervisor interrupt while in M-mode":
        val reset_pc: i64 = 0x8000_0000
        var state = core64_init(reset_pc)
        state.csr_m = csr64_write(state.csr_m, 0x303, MIP_STIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x304, MIP_STIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x344, MIP_STIP_MASK)
        state = execute32(state, 0x00000013)
        expect(state.priv_mode).to_equal(3)
        expect(state.pc).to_equal(reset_pc + 4)

    it "prioritizes SEIP in U-mode without requiring the SIE global bit":
        val reset_pc: i64 = 0x8000_0000
        var state = allow_all_pmp(core64_init(reset_pc))
        state.priv_mode = 0
        state.csr_m = csr64_write(state.csr_m, 0x303,
            MIP_SSIP_MASK | MIP_STIP_MASK | MIP_SEIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x304,
            MIP_SSIP_MASK | MIP_STIP_MASK | MIP_SEIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x344,
            MIP_SSIP_MASK | MIP_STIP_MASK | MIP_SEIP_MASK)
        state.csr_s = csr_s64_write(state.csr_s, 0x105, 0x9000)
        state = execute32(state, 0x00000013)
        expect(state.priv_mode).to_equal(1)
        expect(state.pc).to_equal(0x9000)
        expect(state.csr_s.scause).to_equal(cause_sei())

    it "takes every M-target interrupt before a delegated S-target interrupt":
        val reset_pc: i64 = 0x8000_0000
        var state = allow_all_pmp(core64_init(reset_pc))
        state.priv_mode = 0
        state.csr_m = csr64_write(state.csr_m, 0x303, MIP_SEIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x304,
            MIP_SEIP_MASK | MIP_SSIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x344,
            MIP_SEIP_MASK | MIP_SSIP_MASK)
        state.csr_m = csr64_write(state.csr_m, 0x305, 0xA000)
        state.csr_s = csr_s64_write(state.csr_s, 0x105, 0x9000)
        state = execute32(state, 0x00000013)
        expect(state.priv_mode).to_equal(3)
        expect(state.pc).to_equal(0xA000)
        expect(state.csr_m.mcause).to_equal(cause_ssi())

describe "RV64 PLIC supervisor context":
    it "signals, claims, and completes an S-context interrupt independently":
        var plic = plic_create()
        plic = plic_mmio_write(plic, 10 << 2, 3)
        plic = plic_mmio_write(plic, PLIC_ENABLE_OFF, 1 << 10)
        plic = plic_mmio_write(plic, PLIC_S_ENABLE_OFF, 1 << 10)
        plic = plic_mmio_write(plic, PLIC_S_THRESHOLD_OFF, 0)
        plic = plic_set_pending(plic, 10, true)
        val check = plic_check_interrupt(plic)
        expect(check.meip).to_be(true)
        expect(check.seip).to_be(true)
        expect(check.s_source_id).to_equal(10)
        expect(plic_mmio_read(plic, PLIC_S_CLAIM_OFF)).to_equal(10)
        plic = plic_mmio_read_update(plic, PLIC_S_CLAIM_OFF)
        expect(plic.pending & (1 << 10)).to_equal(0)
        plic = plic_set_pending(plic, 10, true)
        val held = plic_check_interrupt(plic)
        expect(held.meip).to_be(false)
        expect(held.seip).to_be(false)
        plic = plic_mmio_write(plic, PLIC_S_CLAIM_OFF, 10)
        expect(plic.s_claim_complete).to_equal(0)
        val completed = plic_check_interrupt(plic)
        expect(completed.meip).to_be(true)
        expect(completed.seip).to_be(true)
