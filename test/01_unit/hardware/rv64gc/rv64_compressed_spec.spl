use std.spipe.*
use std.hardware.rv64gc_rtl.compressed.rvc64_decompress
use std.hardware.rv64gc_rtl.core.{CoreState64, core64_init, core64_cycle}
use std.hardware.rv64gc_rtl.regfile.{regfile64_read, regfile64_write}
use std.hardware.rv64gc_rtl.pkg.{SEMI_ENTRY, SEMI_BREAK, SEMI_EXIT, SYS_EXIT}

fn expect_expansion(parcel: u32, instruction: u32):
    val decoded = rvc64_decompress(parcel)
    expect(decoded.valid).to_be(true)
    expect(decoded.instruction).to_equal(instruction)

fn execute32(state: CoreState64, instruction: u32) -> CoreState64:
    val low = core64_cycle(state, true, true, false,
        (instruction & 0xFFFF) as i64)
    core64_cycle(low.state, true, true, false,
        ((instruction >> 16) & 0xFFFF) as i64).state

describe "RV64C integer decompression":
    it "matches exact GNU assembler expansions across quadrants":
        # Each compressed/base pair was independently assembled and
        # disassembled with the RISC-V GNU toolchain. The set covers CIW, CL,
        # CS, CI, CJ, CB, CSS, and CR formats.
        expect_expansion(0x0800, 0x01010413)  # c.addi4spn x8, sp, 16
        expect_expansion(0x4544, 0x00C52483)  # c.lw x9, 12(x10)
        expect_expansion(0x6E0C, 0x01863583)  # c.ld x11, 24(x12)
        expect_expansion(0xF714, 0x02D73423)  # c.sd x13, 40(x14)
        expect_expansion(0x157D, 0xFFF50513)  # c.addi x10, -1
        expect_expansion(0x2585, 0x0015859B)  # c.addiw x11, 1
        expect_expansion(0x713D, 0xFE010113)  # c.addi16sp sp, -32
        expect_expansion(0x050E, 0x00351513)  # c.slli x10, 3
        expect_expansion(0x65E2, 0x01813583)  # c.ldsp x11, 24(sp)
        expect_expansion(0xF432, 0x02C13423)  # c.sdsp x12, 40(sp)
        expect_expansion(0x8502, 0x00050067)  # c.jr x10
        expect_expansion(0x9582, 0x000580E7)  # c.jalr x11
        expect_expansion(0x9002, 0x00100073)  # c.ebreak
        expect_expansion(0xBFFD, 0xFFFFF06F)  # c.j -2
        expect_expansion(0xDC7D, 0xFE040FE3)  # c.beqz x8, -2
        expect_expansion(0xFCFD, 0xFE049FE3)  # c.bnez x9, -2
        expect_expansion(0x4542, 0x01012503)  # c.lwsp x10, 16(sp)
        expect_expansion(0xCA2E, 0x00B12A23)  # c.swsp x11, 20(sp)

    it "fails closed for reserved integer encodings":
        expect(rvc64_decompress(0x0000).valid).to_be(false)  # zero ADDI4SPN
        expect(rvc64_decompress(0x2001).valid).to_be(false)  # ADDIW rd=x0
        expect(rvc64_decompress(0x4002).valid).to_be(false)  # LWSP rd=x0
        expect(rvc64_decompress(0x6002).valid).to_be(false)  # LDSP rd=x0
        expect(rvc64_decompress(0x9C61).valid).to_be(false)  # reserved CA word op
        expect(rvc64_decompress(0x2000).valid).to_be(false)  # C.FLD unsupported
        expect(rvc64_decompress(0xA000).valid).to_be(false)  # C.FSD unsupported
        expect(rvc64_decompress(0x2002).valid).to_be(false)  # C.FLDSP unsupported
        expect(rvc64_decompress(0xA002).valid).to_be(false)  # C.FSDSP unsupported

describe "RV64C protected clock path":
    it "commits a compressed ADDI after one parcel and advances by two":
        val reset_pc: i64 = 0x8000_0000
        val cycle = core64_cycle(core64_init(reset_pc), true, true, false,
            0x157D)
        expect(cycle.state.pc).to_equal(reset_pc + 2)
        expect(cycle.state.instruction_bytes).to_equal(2)
        expect(regfile64_read(cycle.state.rf, 10, 0).rs1_data).to_equal(-1)

    it "uses pc plus two for C.JALR link and clears target bit zero":
        val reset_pc: i64 = 0x8000_0000
        var state = core64_init(reset_pc)
        state.rf = regfile64_write(state.rf, 11, 0x8000_0101, true)
        val cycle = core64_cycle(state, true, true, false, 0x9582)
        expect(cycle.state.pc).to_equal(0x8000_0100)
        expect(regfile64_read(cycle.state.rf, 1, 0).rs1_data).to_equal(
            reset_pc + 2)

    it "retains two-byte length through a compressed load transaction":
        val reset_pc: i64 = 0x8000_0000
        val data_addr: i64 = 0x8000_0200
        var state = core64_init(reset_pc)
        state.rf = regfile64_write(state.rf, 12, data_addr - 24, true)
        val fetch = core64_cycle(state, true, true, false, 0x6E0C)
        expect(fetch.state.pc).to_equal(reset_pc)
        val load = core64_cycle(fetch.state, true, true, false,
            0x1122_3344_5566_7788)
        expect(load.bus_addr).to_equal(data_addr)
        expect(load.state.pc).to_equal(reset_pc + 2)
        expect(regfile64_read(load.state.rf, 11, 0).rs1_data).to_equal(
            0x1122_3344_5566_7788)

    it "reports the original parcel for an illegal compressed instruction":
        val reset_pc: i64 = 0x8000_0002
        val cycle = core64_cycle(core64_init(reset_pc), true, true, false,
            0x2001)
        expect(cycle.state.csr_m.mcause).to_equal(2)
        expect(cycle.state.csr_m.mepc).to_equal(reset_pc)
        expect(cycle.state.csr_m.mtval).to_equal(0x2001)

    it "reports zero mtval when an unsupported long prefix has only 16 bits":
        val reset_pc: i64 = 0x8000_0000
        val cycle = core64_cycle(core64_init(reset_pc), true, true, false,
            0x001F)
        expect(cycle.state.csr_m.mcause).to_equal(2)
        expect(cycle.state.csr_m.mepc).to_equal(reset_pc)
        expect(cycle.state.csr_m.mtval).to_equal(0)

    it "treats compressed EBREAK as a trap, not a semihost marker":
        val reset_pc: i64 = 0x8000_0000
        var state = core64_init(reset_pc)
        state.semi_phase = 1
        val cycle = core64_cycle(state, true, true, false, 0x9002)
        expect(cycle.state.csr_m.mcause).to_equal(3)
        expect(cycle.state.csr_m.mepc).to_equal(reset_pc)
        expect(cycle.state.semi_trigger).to_be(false)

    it "does not start semihosting when a C hint expands to its entry marker":
        val reset_pc: i64 = 0x8000_0000
        # C.SLLI x0, 31 expands to the semihost entry instruction, but the
        # architectural parcel is only two bytes and is merely a C hint.
        val cycle = core64_cycle(core64_init(reset_pc), true, true, false,
            0x007E)
        expect(cycle.state.pc).to_equal(reset_pc + 2)
        expect(cycle.state.semi_phase).to_equal(0)
        expect(cycle.state.semi_trigger).to_be(false)

    it "still advances through the complete 32-bit semihost sequence":
        val reset_pc: i64 = 0x8000_0000
        var state = core64_init(reset_pc)
        state.rf = regfile64_write(state.rf, 10, SYS_EXIT as i64, true)
        state = execute32(state, SEMI_ENTRY)
        expect(state.pc).to_equal(reset_pc + 4)
        expect(state.semi_phase).to_equal(1)
        state = execute32(state, SEMI_BREAK)
        expect(state.pc).to_equal(reset_pc + 8)
        expect(state.semi_phase).to_equal(2)
        state = execute32(state, SEMI_EXIT)
        expect(state.halt).to_be(true)
        expect(state.semi_trigger).to_be(true)

    it "keeps the original PC when the high parcel faults across a page":
        val reset_pc: i64 = 0x8000_0FFE
        val low = core64_cycle(core64_init(reset_pc), true, true, false,
            0x0093)
        expect(low.state.pc).to_equal(reset_pc)
        val fault = core64_cycle(low.state, true, true, true, 0)
        expect(fault.state.csr_m.mcause).to_equal(1)
        expect(fault.state.csr_m.mepc).to_equal(reset_pc)
        expect(fault.state.csr_m.mtval).to_equal(0x8000_1000)
