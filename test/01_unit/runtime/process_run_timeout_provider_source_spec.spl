extern fn rt_file_read_text(path: text) -> text

use std.spec.{describe, it, expect}

describe "core C process timeout provider":
    it "owns the four-word tagged tuple ABI":
        val header = rt_file_read_text("src/runtime/runtime.h") ?? ""
        val provider = rt_file_read_text("src/runtime/runtime_process.c") ?? ""
        val codegen = rt_file_read_text("src/compiler_rust/compiler/src/codegen/runtime_sffi.rs") ?? ""
        val calls = rt_file_read_text("src/compiler_rust/compiler/src/codegen/instr/calls.rs") ?? ""

        expect(header).to_contain("SplArray* rt_process_run_timeout(const char* cmd, uint64_t cmd_len, SplArray* args, int64_t timeout_ms);")
        expect(provider).to_contain("SplArray* rt_process_run_timeout(const char* cmd, uint64_t cmd_len, SplArray* args, int64_t timeout_ms)")
        expect(provider).to_contain("rt_array_new(3)")
        expect(provider).to_contain("rt_string_new")
        expect(provider).to_contain("rt_value_int(code)")
        expect(codegen).to_contain("RuntimeFuncSpec::new(\"rt_process_run_timeout\", &[I64, I64, I64, I64], &[I64])")
        expect(calls).to_contain("\"rt_process_run\" | \"rt_process_spawn\" | \"rt_process_execute\" | \"rt_process_run_timeout\" => Some((&[0], &[1]))")

    it "captures POSIX output and cleans the timed process group":
        val provider = rt_file_read_text("src/runtime/runtime_process.c") ?? ""
        val fork_owner = rt_file_read_text("src/runtime/runtime_fork.c") ?? ""

        expect(provider).to_contain("rt_fork_child_setup()")
        expect(provider).to_contain("execvp(cmd_c, argv)")
        expect(provider).to_contain("rt_fork_parent_wait(child_pid, timeout_ms > 0 ? timeout_ms : 0)")
        expect(provider).to_contain("rt_fork_parent_stdout()")
        expect(provider).to_contain("rt_fork_parent_stderr()")
        expect(provider).to_contain("if (rt_fork_parent_signaled()) code = -1")
        expect(fork_owner).to_contain("clock_gettime(CLOCK_MONOTONIC")
        expect(fork_owner).to_contain("setpgid(0, 0)")
        expect(fork_owner).to_contain("kill(-(pid_t)child_pid, SIGKILL)")
        expect(fork_owner).to_contain("cleanup_descendants = stdout_open || stderr_open")
        expect(fork_owner).to_contain("waitpid_nointr((pid_t)child_pid, &child_status, WNOHANG)")

    it "captures Windows output and assigns the suspended child to a Job Object":
        val provider = rt_file_read_text("src/runtime/runtime_process.c") ?? ""
        val windows_start = provider.find("/* Windows process timeout/capture owner. */")
        val posix_start = provider.find("#else /* POSIX */")
        expect(windows_start).to_be_greater_than(-1)
        expect(posix_start).to_be_greater_than(windows_start)
        val windows = provider.substring(windows_start, posix_start)
        val run_start = windows.find("SplArray* rt_process_run_timeout")
        val run_end = windows.find("int64_t rt_process_spawn_piped")
        expect(run_start).to_be_greater_than(-1)
        expect(run_end).to_be_greater_than(run_start)
        val run = windows.substring(run_start, run_end)

        expect(windows).to_contain("PROC_THREAD_ATTRIBUTE_HANDLE_LIST")
        expect(windows).to_contain("JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE")
        expect(windows).to_contain("PeekNamedPipe")
        expect(windows).to_contain("ReadFile")
        expect(windows).to_contain("GetTickCount64")
        expect(windows.find("rt_process_run_timeout unsupported on Windows")).to_equal(-1)

        val pipe_pos = run.find("CreatePipe(&stdout_read")
        val stderr_pipe_pos = run.find("CreatePipe(&stderr_read")
        val restrict_pos = run.find("SetHandleInformation(stdout_read, HANDLE_FLAG_INHERIT, 0)")
        val stderr_restrict_pos = run.find("SetHandleInformation(stderr_read, HANDLE_FLAG_INHERIT, 0)")
        val kill_flag_pos = run.find("JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE")
        val job_pos = run.find("SetInformationJobObject")
        val attribute_pos = run.find("UpdateProcThreadAttribute")
        val handle_list_pos = run.find("PROC_THREAD_ATTRIBUTE_HANDLE_LIST")
        val stdio_pos = run.find("STARTF_USESTDHANDLES")
        val suspended_pos = run.find("CREATE_SUSPENDED")
        val create_pos = run.find("if (!CreateProcessA")
        val assign_pos = run.find("AssignProcessToJobObject")
        val resume_pos = run.find("ResumeThread")
        val drain_pos = run.find("win_capture_drain(stdout_read")
        val wait_pos = run.find("WaitForSingleObject(process.hProcess, wait_ms)")
        val terminate_pos = run.find("TerminateJobObject")
        expect(pipe_pos).to_be_greater_than(-1)
        expect(stderr_pipe_pos).to_be_greater_than(pipe_pos)
        expect(restrict_pos).to_be_greater_than(pipe_pos)
        expect(stderr_restrict_pos).to_be_greater_than(stderr_pipe_pos)
        expect(kill_flag_pos).to_be_greater_than(-1)
        expect(job_pos).to_be_greater_than(kill_flag_pos)
        expect(attribute_pos).to_be_greater_than(job_pos)
        expect(handle_list_pos).to_be_greater_than(attribute_pos)
        expect(stdio_pos).to_be_greater_than(handle_list_pos)
        expect(suspended_pos).to_be_greater_than(stdio_pos)
        expect(create_pos).to_be_greater_than(pipe_pos)
        expect(create_pos).to_be_greater_than(stderr_pipe_pos)
        expect(create_pos).to_be_greater_than(restrict_pos)
        expect(create_pos).to_be_greater_than(stderr_restrict_pos)
        expect(create_pos).to_be_greater_than(job_pos)
        expect(create_pos).to_be_greater_than(attribute_pos)
        expect(create_pos).to_be_greater_than(handle_list_pos)
        expect(create_pos).to_be_greater_than(suspended_pos)
        expect(assign_pos).to_be_greater_than(create_pos)
        expect(resume_pos).to_be_greater_than(assign_pos)
        expect(drain_pos).to_be_greater_than(resume_pos)
        expect(wait_pos).to_be_greater_than(drain_pos)
        expect(terminate_pos).to_be_greater_than(wait_pos)
