"""Vulkan compute descriptor-layout provider contract.

The interpreter provider must expose the three storage-buffer bindings used by
the font-atlas composite shader: atlas, destination, and parameters.
"""

extern fn rt_file_read_text(path: text) -> text

use std.spec.{describe, it, expect}

describe "Vulkan interpreter compute descriptor layout":
    it "declares storage-buffer bindings zero one and two in order":
        val source = rt_file_read_text("src/compiler_rust/compiler/src/interpreter_extern/gpu.rs")
        val pipeline_start = source.index_of("pub fn rt_vulkan_create_compute_pipeline_fn")
        expect(pipeline_start).to_be_greater_than(-1)
        val provider_tail = source.substring(pipeline_start, source.len())
        val pipeline_end = provider_tail.index_of("pub fn rt_vulkan_destroy_pipeline_fn")
        expect(pipeline_end).to_be_greater_than(0)
        val pipeline = provider_tail.substring(0, pipeline_end)
        val binding_zero = pipeline.index_of("binding: 0")
        val binding_one = pipeline.index_of("binding: 1")
        val binding_two = pipeline.index_of("binding: 2")
        expect(binding_zero).to_be_greater_than(-1)
        expect(binding_one).to_be_greater_than(binding_zero)
        expect(binding_two).to_be_greater_than(binding_one)
        expect(pipeline).to_contain("binding_count: bindings.len() as u32")
        expect(pipeline).to_contain("descriptor_type: 7, // STORAGE_BUFFER")
