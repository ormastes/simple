extern fn rt_file_read_text(path: text) -> text

use std.spec.{describe, it, expect}

describe "native environment lookup ABI":
    it "preserves ptr-length callers and routes text-value calls through a facade":
        val header = rt_file_read_text("src/runtime/runtime.h") ?? ""
        val native = rt_file_read_text("src/runtime/runtime_native.c") ?? ""
        val llvm = rt_file_read_text("src/compiler/70.backend/backend/_MirToLlvm/core_codegen.spl") ?? ""
        val declarations = rt_file_read_text("src/compiler/70.backend/backend/_MirToLlvm/asm_constraints_helpers.spl") ?? ""
        val cranelift = rt_file_read_text("src/compiler/70.backend/backend/cranelift_codegen_adapter.spl") ?? ""

        expect(header).to_contain("int64_t     rt_env_get(const uint8_t* key, uint64_t key_len);")
        expect(header).to_contain("int64_t     rt_env_get_value(int64_t key);")
        expect(native).to_contain("char* key = rt_core_text_arg_to_cstr(key_ptr, key_len);")
        expect(native).to_contain("int64_t rt_env_get_value(int64_t key)")
        expect(native).to_contain("return rt_env_get_cstr(rt_interp_cstr(key));")
        expect(llvm).to_contain("bare_name_for_call == \"rt_env_get\" and args.len() == 1: \"@rt_env_get_value\"")
        expect(declarations).to_contain("declare ptr @rt_env_get_value(i64)")
        expect(declarations).to_contain("self.remember_function_param_types(\"rt_env_get_value\", [\"i64\"])")
        expect(declarations).to_contain("self.remember_function_return_type(\"rt_env_get_value\", \"ptr\")")
        expect(cranelift).to_contain("if name == \"rt_env_get\" and arg_vals.len() == 1:")
        expect(cranelift).to_contain("\"rt_env_get_value\", arg_vals")
