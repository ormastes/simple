# @cover src/lib/gc_async_mut/gpu/browser_engine/net/entity/url_types.spl 80%
"""
# URL Types Specification

**Feature IDs:** #M16-AC1
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Draft

## Overview

Verifies URL and Origin entity types: construction, field access, scheme/host/port/path
extraction, and origin computation. No network calls — pure value-type logic.
"""

use std.spipe.*

use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url, Origin}


# ============================================================================
# Url Construction and Field Access
# ============================================================================

describe "Url entity type":
    """
    ## Url construction and field extraction

    Url represents a parsed URL with scheme, host, port, path, query, and fragment.
    All fields must be readable after construction.
    """

    context "when constructing a simple http URL":
        it "AC-1: stores scheme correctly":
            val u = make_http_url()
            expect(u.scheme).to_equal("http")

        it "AC-1: stores host correctly":
            val u = make_http_url()
            expect(u.host).to_equal("example.com")

        it "AC-1: stores default port 80 for http":
            val u = make_http_url()
            expect(u.port).to_equal(80)

        it "AC-1: stores path correctly":
            val u = make_http_url()
            expect(u.path).to_equal("/index.html")

    context "when constructing an https URL with explicit port":
        it "AC-1: stores https scheme":
            val u = make_https_explicit_port_url()
            expect(u.scheme).to_equal("https")

        it "AC-1: stores explicit port 8443":
            val u = make_https_explicit_port_url()
            expect(u.port).to_equal(8443)

        it "AC-1: stores host without port":
            val u = make_https_explicit_port_url()
            expect(u.host).to_equal("api.example.com")

    context "when URL has query string":
        it "AC-1: stores query string":
            val u = make_url_with_query()
            expect(u.query).to_equal("foo=bar&baz=1")

    context "when URL has fragment":
        it "AC-1: stores fragment":
            val u = make_url_with_fragment()
            expect(u.fragment).to_equal("section-2")

    context "when URL has empty path":
        it "AC-1: path is empty string or slash":
            val u = make_root_url()
            val ok = (u.path == "/" or u.path == "")
            expect(ok).to_equal(true)


# ============================================================================
# Origin Computation
# ============================================================================

describe "Origin from Url":
    """
    ## Same-origin computation

    Two Origins are equal if scheme, host, and port all match.
    """

    it "AC-5: same scheme+host+port is same origin":
        val a = make_origin("https", "example.com", 443)
        val b = make_origin("https", "example.com", 443)
        expect(a.scheme).to_equal(b.scheme)
        expect(a.host).to_equal(b.host)
        expect(a.port).to_equal(b.port)

    it "AC-5: different scheme is different origin":
        val a = make_origin("http", "example.com", 80)
        val b = make_origin("https", "example.com", 443)
        val same = (a.scheme == b.scheme)
        expect(same).to_equal(false)

    it "AC-5: different host is different origin":
        val a = make_origin("https", "example.com", 443)
        val b = make_origin("https", "other.com", 443)
        val same = (a.host == b.host)
        expect(same).to_equal(false)

    it "AC-5: different port is different origin":
        val a = make_origin("https", "example.com", 443)
        val b = make_origin("https", "example.com", 8443)
        val same = (a.port == b.port)
        expect(same).to_equal(false)


# ============================================================================
# Helpers
# ============================================================================

fn make_http_url() -> Url:
    return Url {
        scheme: "http",
        host: "example.com",
        port: 80,
        path: "/index.html",
        query: "",
        fragment: ""
    }

fn make_https_explicit_port_url() -> Url:
    return Url {
        scheme: "https",
        host: "api.example.com",
        port: 8443,
        path: "/v1/resource",
        query: "",
        fragment: ""
    }

fn make_url_with_query() -> Url:
    return Url {
        scheme: "https",
        host: "search.example.com",
        port: 443,
        path: "/search",
        query: "foo=bar&baz=1",
        fragment: ""
    }

fn make_url_with_fragment() -> Url:
    return Url {
        scheme: "https",
        host: "docs.example.com",
        port: 443,
        path: "/guide",
        query: "",
        fragment: "section-2"
    }

fn make_root_url() -> Url:
    return Url {
        scheme: "https",
        host: "example.com",
        port: 443,
        path: "/",
        query: "",
        fragment: ""
    }

fn make_origin(scheme: text, host: text, port: i64) -> Origin:
    return Origin {
        scheme: scheme,
        host: host,
        port: port
    }
