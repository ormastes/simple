# @cover src/lib/nogc_async_mut_noalloc/baremetal/riscv/dtb_gen.spl 0%
# @cover src/os/kernel/arch/riscv64/fpga_boot.spl 0%
# @cover src/lib/nogc_async_mut_noalloc/baremetal/riscv/sbi.spl 0%
"""
# FPGA Linux Product DT Specification

**Feature IDs:** rv32-rv64-fpga-linux-product-dtb
**Category:** Infrastructure
**Difficulty:** 4/5
**Status:** Draft
**Requirements:** REQ-14, REQ-15
**Research:** doc/01_research/domain/vhdl_backend_linux_rtl.md
**Artifacts:** N/A

## Overview

Tests the binding-complete RV32 K26 product DT and the fail-closed RV64 product
DT gate. QEMU DTBs remain software-media oracles, not FPGA product topology.

Covers the fixed RV32 memory map, CPU/CLINT/PLIC/UART bindings, and the RV64
contract-not-ready boundary. FPGA boot and userspace evidence remain separate.

## Compiled-Mode Notes

The RV64 product DT remains unavailable until its emitted topology is
authoritative. Actual UART output verification and userspace boot require FPGA
hardware or GHDL cosimulation.
"""

use std.spipe.*
use std.nogc_async_mut_noalloc.baremetal.riscv.dtb_gen.{
    Rv32SocMemoryMap,
    rv32_linux_dtb_generate,
    rv32_linux_dtb_to_dts,
    Rv64SocMemoryMap,
    rv64_linux_dtb_generate,
    rv64_linux_dtb_to_dts
}


# ============================================================================
# AC-6/AC-7: DTB Generation — FDT Structure (REQ-14)
# ============================================================================

describe "RV32 K26 Product DTB":
    it "exposes the canonical product map":
        val mem_map = Rv32SocMemoryMap.k26()
        expect(mem_map.dram_base).to_equal(0x8000_0000)
        expect(mem_map.dram_size).to_equal(0x0800_0000)
        expect(mem_map.uart_addr).to_equal(0x1000_0000)
        expect(mem_map.uart_clock_hz).to_equal(100_000_000)
        expect(mem_map.clint_addr).to_equal(0x0200_0000)
        expect(mem_map.plic_addr).to_equal(0x0C00_0000)
        expect(mem_map.mailbox_addr).to_equal(0x80FF_0000)
        expect(mem_map.mailbox_reserved_size).to_equal(0x1000)
        expect(mem_map.timebase_hz).to_equal(100_000_000)
        expect(mem_map.boot_hartid).to_equal(0)

    it "generates a non-empty FDT blob":
        val dtb = rv32_linux_dtb_generate(Rv32SocMemoryMap.k26())
        expect(dtb.length()).to_be_greater_than(40)
        expect(dtb[0]).to_equal(0xD0)
        expect(dtb[1]).to_equal(0x0D)
        expect(dtb[2]).to_equal(0xFE)
        expect(dtb[3]).to_equal(0xED)

    it "reports exact CPU, interrupt-controller, and memory bindings":
        val dts = rv32_linux_dtb_to_dts(Rv32SocMemoryMap.k26())
        expect(dts).to_contain("timebase-frequency = <100000000>;")
        expect(dts).to_contain("riscv,isa = \"rv32ima_zicsr_zifencei\";")
        expect(dts).to_contain("mmu-type = \"riscv,sv32\";")
        expect(dts).to_contain("compatible = \"riscv,cpu-intc\";")
        expect(dts).to_contain("phandle = <1>;")
        expect(dts).to_contain("reg = <0x0 0x80000000 0x0 0x8000000>;")
        expect(dts).to_contain("mailbox@80ff0000 {")
        expect(dts).to_contain("reg = <0x0 0x80ff0000 0x0 0x1000>;")
        expect(dts).to_contain("no-map;")

    it "reports exact CLINT and PLIC bindings":
        val dts = rv32_linux_dtb_to_dts(Rv32SocMemoryMap.k26())
        expect(dts).to_contain("compatible = \"sifive,clint0\", \"riscv,clint0\";")
        expect(dts).to_contain("interrupts-extended = <1 3 1 7>;")
        expect(dts).to_contain("compatible = \"sifive,plic-1.0.0\", \"riscv,plic0\";")
        expect(dts).to_contain("reg = <0x0 0xc000000 0x0 0x400000>;")
        expect(dts).to_contain("riscv,ndev = <31>;")
        expect(dts).to_contain("phandle = <2>;")
        expect(dts).to_contain("interrupts-extended = <1 11 1 9>;")

    it "reports exact UART interrupt, clock, and register spacing":
        val dts = rv32_linux_dtb_to_dts(Rv32SocMemoryMap.k26())
        expect(dts).to_contain("serial@10000000 {")
        expect(dts).to_contain("clock-frequency = <100000000>;")
        expect(dts).to_contain("reg-shift = <0>;")
        expect(dts).to_contain("reg-io-width = <1>;")
        expect(dts).to_contain("interrupt-parent = <2>;")
        expect(dts).to_contain("interrupts = <10>;")

describe "RV64 Product DTB Gate":
    it "AC-6: binary generation fails closed":
        val dtb = rv64_linux_dtb_generate(rv64_soc_memory_map_default())
        expect(dtb.length()).to_equal(0)

    it "AC-6: diagnostic names the unimplemented generated topology":
        val blocker = rv64_linux_dtb_to_dts(rv64_soc_memory_map_default())
        expect(blocker).to_contain("contract-not-ready")
        expect(blocker).to_contain("GENERATED_RTL_NOT_IMPLEMENTED lane=rv64")


# ============================================================================
# AC-6/AC-7: DTB Memory Map Values
# ============================================================================

describe "DTB Memory Map Values":
    it "AC-6: Rv64SocMemoryMap default DRAM base is 0x8000_0000":
        val mem_map = rv64_soc_memory_map_default()
        expect(mem_map.dram_base).to_equal(0x8000_0000)

    it "AC-6: Rv64SocMemoryMap default UART addr is 0x1000_0000":
        val mem_map = rv64_soc_memory_map_default()
        expect(mem_map.uart_addr).to_equal(0x1000_0000)

    it "AC-6: Rv64SocMemoryMap default CLINT addr is 0x200_0000":
        val mem_map = rv64_soc_memory_map_default()
        expect(mem_map.clint_addr).to_equal(0x200_0000)

    it "AC-6: Rv64SocMemoryMap default PLIC addr is 0xC00_0000":
        val mem_map = rv64_soc_memory_map_default()
        expect(mem_map.plic_addr).to_equal(0xC00_0000)

    it "AC-7: Rv64SocMemoryMap default boot hartid is 0":
        val mem_map = rv64_soc_memory_map_default()
        expect(mem_map.boot_hartid).to_equal(0)


# ============================================================================
# AC-6/AC-7: Boot Register Preconditions (REQ-15)
# ============================================================================

describe "FPGA Boot Contract":
    it "AC-6: Linux boot contract requires a0 = hartid":
        # Linux RISC-V boot protocol: a0 must contain the hart ID
        val a0_hartid = 0
        expect(a0_hartid).to_equal(0)

    it "AC-6: Linux boot contract requires satp = 0 (bare mode)":
        # satp must be 0 on kernel entry (no virtual memory yet)
        val satp_bare = 0
        expect(satp_bare).to_equal(0)

# ============================================================================
# AC-6: SBI Interface Verification
# ============================================================================

describe "SBI Interface":
    it "AC-6: SBI timer extension ID is 0x54494D45":
        val sbi_timer_eid = 0x54494D45
        expect(sbi_timer_eid).to_equal(0x54494D45)

    it "AC-6: SBI IPI extension ID is 0x735049":
        val sbi_ipi_eid = 0x735049
        expect(sbi_ipi_eid).to_equal(0x735049)

    it "AC-6: SBI base extension ID is 0x10":
        val sbi_base_eid = 0x10
        expect(sbi_base_eid).to_equal(0x10)


fn rv64_soc_memory_map_default() -> Rv64SocMemoryMap:
    return Rv64SocMemoryMap(
        dram_base: 0x8000_0000,
        dram_size: 0x800_0000,
        uart_addr: 0x1000_0000,
        clint_addr: 0x200_0000,
        plic_addr: 0xC00_0000,
        boot_hartid: 0
    )
