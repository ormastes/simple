use app.wrapper_gen.mod.{emit_plugin_manifest, collect_exported_functions, scaffold_output_dir}
use app.wrapper_gen.spec_parser.{WrapperSpec, FunctionSpec, MethodSpec, ParamSpec}

fn empty_params() -> [ParamSpec]:
    []

describe "Wrapper generator plugin manifest":
    it "collects exported functions from free functions and methods":
        val spec = WrapperSpec(
            name: "regex",
            version: "0.1.0",
            lang: "rust",
            link_libs: [],
            search_paths: [],
            cpp_include: "",
            include_paths: [],
            handle_types: [],
            functions: [
                FunctionSpec(name: "new", cpp_fn: "", params: empty_params(), return_type: "i64")
            ],
            methods: [
                MethodSpec(handle: "Regex", name: "is_match", cpp_method: "", params: empty_params(), return_type: "bool")
            ],
            rust_crate: "regex",
            rust_crate_version: "1"
        )
        val exported = collect_exported_functions(spec)
        expect(exported.len()).to_equal(2)
        expect(exported[0]).to_equal("rt_regex_new")
        expect(exported[1]).to_equal("rt_regex_is_match")

    it "emits plugin manifest content with library path and functions":
        val spec = WrapperSpec(
            name: "regex",
            version: "0.1.0",
            lang: "rust",
            link_libs: [],
            search_paths: [],
            cpp_include: "",
            include_paths: [],
            handle_types: [],
            functions: [
                FunctionSpec(name: "new", cpp_fn: "", params: empty_params(), return_type: "i64")
            ],
            methods: [],
            rust_crate: "regex",
            rust_crate_version: "1"
        )
        val output_dir = scaffold_output_dir(spec, "")
        val manifest = emit_plugin_manifest(spec, output_dir)
        expect(manifest).to_contain("name: regex")
        expect(manifest).to_contain("functions: [rt_regex_new]")
        expect(manifest).to_contain("library:")
