# CLI Passthrough Spec
#
# Tests that vestigial "name" passthrough is removed for feature_gen and
# task_gen in cli_passthrough.spl.

use std.spec.{describe, it, expect}
use app.mcp.cli_passthrough (_append_cli_args_for_name, _effective_cli_timeout_s, _cli_shell_quote)

describe "cli_passthrough: shell arguments":
    it "quotes embedded apostrophes without exposing shell operators":
        expect(_cli_shell_quote("a'b")).to_equal("'a'\\''b'")

    it "quotes JSON-derived paths":
        val cmd = _append_cli_args_for_name("simple check", "{\"path\":\"src/a; touch /tmp/pwn.spl\"}", "simple_check")
        expect(cmd).to_equal("simple check 'src/a; touch /tmp/pwn.spl'")

describe "cli_passthrough: feature_gen":
    it "does not append a name arg when name is provided":
        val args = _append_cli_args_for_name("", "{\"name\":\"MyFeature\"}", "simple_feature_gen")
        val has_name_val = args.contains("MyFeature")
        expect(has_name_val).to_equal(false)

    it "builds empty args list for feature_gen with no props":
        val args = _append_cli_args_for_name("", "{}", "simple_feature_gen")
        expect(args).to_equal("")

describe "cli_passthrough: task_gen":
    it "does not append a name arg when name is provided":
        val args = _append_cli_args_for_name("", "{\"name\":\"MyTask\"}", "simple_task_gen")
        val has_name_val = args.contains("MyTask")
        expect(has_name_val).to_equal(false)

    it "builds empty args list for task_gen with no props":
        val args = _append_cli_args_for_name("", "{}", "simple_task_gen")
        expect(args).to_equal("")

describe "cli_passthrough: spec_gen still passes path":
    it "appends path value positionally for spec_gen":
        val args = _append_cli_args_for_name("", "{\"path\":\"src/foo/bar.spl\"}", "simple_spec_gen")
        expect(args.contains("src/foo/bar.spl")).to_equal(true)

describe "cli_passthrough: simple_test timeout handling":
    it "keeps outer timeout above requested per-test timeout":
        val body = "{\"timeout\":\"240\"}"
        expect(_effective_cli_timeout_s("simple_test", body, 120)).to_equal(270)

    it "keeps default outer timeout when requested timeout is lower":
        val body = "{\"timeout\":\"30\"}"
        expect(_effective_cli_timeout_s("simple_test", body, 120)).to_equal(120)

    it "ignores nonnumeric simple_test timeout values":
        val cmd = _append_cli_args_for_name("timeout 120 bin/simple test", "{\"timeout\":\"60;rm -rf /\",\"path\":\"test/unit/foo.spl\"}", "simple_test")
        expect(cmd).to_contain("test/unit/foo.spl")
        expect(cmd).to_contain("--timeout 60")
        expect(cmd.contains("60;rm")).to_equal(false)

    it "preserves numeric simple_test timeout values":
        val cmd = _append_cli_args_for_name("timeout 270 bin/simple test", "{\"timeout\":\"240\",\"path\":\"test/unit/foo.spl\"}", "simple_test")
        expect(cmd).to_contain("--timeout 240")

    it "ignores oversized simple_test timeout values":
        val body = "{\"timeout\":\"999999999999999999999999999999999999999999\"}"
        expect(_effective_cli_timeout_s("simple_test", body, 120)).to_equal(120)
