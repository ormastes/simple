use std.spec.*
use std.io_runtime.{rt_file_read_text}
use std.test_runner.doctest_runner.{extract_doctests}

describe "whole release test gate":
    it "keeps release, bootstrap, and the runner on one fail-closed command":
        val workflow = rt_file_read_text(".github/workflows/release.yml") ?? ""
        val bootstrap = rt_file_read_text("scripts/bootstrap/bootstrap-from-scratch.sh") ?? ""
        val prepare = rt_file_read_text("src/app/release/prepare.spl") ?? ""
        val runner = rt_file_read_text("src/lib/nogc_sync_mut/test_runner/test_runner_args.spl") ?? ""
        val sdoctest_runner = rt_file_read_text("src/lib/nogc_sync_mut/test_runner/sdoctest/runner.spl") ?? ""
        val app_runner = rt_file_read_text("src/app/test_runner_new/test_runner_main.spl") ?? ""

        expect(workflow).to_contain("needs: [build-bootstrap, build-installers, simpleos-build, whole-tests]")
        expect(workflow).to_contain("\"$SIMPLE_WHOLE_TEST_BIN\" test test --whole --mode=interpreter")
        expect(bootstrap).to_contain("run_logged stage6-whole-tests \"${deployed_bin}\" test test --whole --mode=interpreter")
        expect(prepare).to_contain("[\"test\", \"test\", \"--whole\", \"--mode=interpreter\"]")
        expect(runner).to_contain("elif arg == \"--whole\":")
        expect(runner).to_contain("sdoctest = true")
        expect(runner).to_contain("spl_doctest = true")
        expect(sdoctest_runner).to_contain("options.path != \"test/\" and options.path != \"test\"")
        expect(app_runner).to_contain("use std.test_runner.test_runner_modes.{run_spl_doctest_mode}")
        val sdoc_override = app_runner.index_of("if options.sdoctest:") ?? -1
        val md_override = app_runner.index_of("if options.path.ends_with(\".md\"):") ?? -1
        val spl_override = app_runner.index_of("if options.spl_doctest:") ?? -1
        val disabled_guard = app_runner.index_of("if not run_spec and not run_sdoc and not run_spl_doc:") ?? -1
        expect(sdoc_override).to_be_greater_than(-1)
        expect(md_override).to_be_greater_than(-1)
        expect(spl_override).to_be_greater_than(-1)
        expect(disabled_guard).to_be_greater_than(sdoc_override)
        expect(disabled_guard).to_be_greater_than(md_override)
        expect(disabled_guard).to_be_greater_than(spl_override)
        expect(app_runner).to_contain("if run_spl_doc:")
        expect(app_runner).to_contain("if run_sdoc:")

    it "discovers code-comment sdoctests":
        val blocks = extract_doctests("src/compiler/00.common/gc_config.spl")

        expect(blocks.len()).to_be_greater_than(0)
        expect(blocks[0].code).to_contain("expect(")
