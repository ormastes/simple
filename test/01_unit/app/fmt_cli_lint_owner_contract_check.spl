use app.io.cli_lint_commands.{run_fmt_command}

extern fn rt_exit(code: i32)

val missing = "test/fixtures/lint/no_such_fmt_input.spl"
val invalid_exit = run_fmt_command(["fmt", missing, "--bogus"])
val check_exit = run_fmt_command(["fmt", missing, "--check"])
val write_exit = run_fmt_command(["fmt", missing, "--write"])
val help_exit = run_fmt_command(["fmt", "--help"])

if invalid_exit != 2 or check_exit != 1 or write_exit != 1 or help_exit != 0:
    print "FAIL: lint-entry fmt owner did not reject before I/O or preserve documented forms"
    rt_exit(1)

print "PASS: lint-entry fmt owner is fail-closed without mutating a file"
rt_exit(0)
