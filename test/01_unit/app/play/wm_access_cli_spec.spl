use std.spec.*
use std.play.types.{WindowInfo}
use app.play.wm_access_cli.{WM_ACCESS_TIMEOUT_MS, wm_access_descriptors, wm_access_is_command, wm_access_snapshot_from_windows, wm_access_validate_action_args}
use common.ui.access.{ACCESS_OPERATION_LIST, access_find_descriptor, access_result_from_snapshot, access_render_json, win_text_host_wm_single_window_snapshot}

fn _window(id: text, title: text, focused: bool) -> WindowInfo:
    WindowInfo(window_id: id, target_id: id, title: title, url: "", width: 800, height: 600, focused: focused)

describe "Play WM access CLI adapter":
    it "shares the windows grammar without removing wm-list":
        expect(wm_access_is_command("windows")).to_be(true)
        expect(wm_access_is_command("wm-list")).to_be(true)
        match access_find_descriptor("wm-list", "", wm_access_descriptors()):
            Some(descriptor): expect(descriptor.operation).to_equal(ACCESS_OPERATION_LIST)
            nil: fail("wm-list compatibility alias was not found")

    it "normalizes scalar WM snapshots and delegates deterministic rendering":
        val snapshot = wm_access_snapshot_from_windows([_window("20", "Zulu", false), _window("10", "Alpha", true)], 1000)
        val result = access_result_from_snapshot(ACCESS_OPERATION_LIST, "host_wm", "", snapshot.access, 100)
        expect(result.rows.len()).to_equal(3)
        expect(result.rows[1][0]).to_equal("wm:10")
        expect(result.rows[1][1]).to_equal("Alpha")
        expect(result.rows[1][6]).to_equal("yes")
        expect(result.rows[2][0]).to_equal("wm:20")
        expect(access_render_json(result)).to_contain("\"source\":{\"id\":\"host_wm\"")

    it "preserves known WM capture metadata without inventing geometry":
        val snapshot = win_text_host_wm_single_window_snapshot("10", "10", "Alpha", "", 800, 600, false, 1000, 5, 2000)
        val result = access_result_from_snapshot(ACCESS_OPERATION_LIST, "host_wm", "", snapshot.access, 100)
        expect(access_render_json(result)).to_contain("\"surface_kind\":\"host_window\",\"state\":\"ready\",\"geometry\":null,\"focused\":false,\"visible\":true,\"parent_id\":null,\"capabilities\":[\"focus\",\"type_text\",\"click_xy\",\"screenshot\"],\"captured_revision\":0,\"captured_at\":\"1000\",\"stale\":true")

    it "advertises the bounded end-to-end WM command budget":
        expect(WM_ACCESS_TIMEOUT_MS).to_equal(20000)
        for descriptor in wm_access_descriptors():
            expect(descriptor.safety.timeout_ms).to_equal(WM_ACCESS_TIMEOUT_MS)

    it "rejects unbounded or malformed WM action arguments before dispatch":
        if not wm_access_validate_action_args("type_text", ["target", "type_text"]).is_err(): fail("missing type_text was accepted")
        if not wm_access_validate_action_args("type_text", ["target", "type_text", "x" * 4097]).is_err(): fail("oversized type_text was accepted")
        if not wm_access_validate_action_args("click_xy", ["target", "click_xy", "x", "0"]).is_err(): fail("non-numeric coordinate was accepted")
        if not wm_access_validate_action_args("click_xy", ["target", "click_xy", "1000001", "0"]).is_err(): fail("out-of-range coordinate was accepted")
        if not wm_access_validate_action_args("screenshot", ["target", "screenshot", ""]).is_err(): fail("empty screenshot path was accepted")
        if not wm_access_validate_action_args("type_text", ["target", "type_text", "ok"]).is_ok(): fail("bounded type_text was rejected")
