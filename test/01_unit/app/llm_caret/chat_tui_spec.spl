# LLM Caret - Interactive Chat TUI Specification
#
# Exercises the PURE, terminal-free surface of chat_tui.spl:
#   - turn / tool-line formatting (user vs assistant visually distinct)
#   - the renderer-seam mode selection (tui vs plain given flag + tty)
#   - the transcript rendering ops (render_turn / render_tool_call)
#   - one driven agent-loop iteration proving render_tool_call fires (TUI mode)
#     while the plain print path leaves the transcript untouched.
#
# These are executable it-blocks with real assertions - no live terminal needed.

use app.llm_caret.types.{Message, new_user_message}
use app.llm_caret.tools.{
    PermissionPolicy, ToolCall, ToolResult, ModelResponse,
    default_policy, new_tool_call, new_model_text, new_model_tools
}
use app.llm_caret.chat.{AgentResult, run_agent_loop, run_agent_loop_rendered}
use app.llm_caret.chat_tui.{
    ChatTui, make_chat_tui,
    format_turn_line, format_tool_line, tui_role_label,
    tui_role_style, tui_tool_style, select_renderer_mode,
    render_turn, render_tool_call, tui_tool_renderer,
    tui_transcript_reset, tui_transcript_len, tui_transcript_line_text
}
use std.tui.style.{Style, COLOR_CYAN, COLOR_GREEN, COLOR_RED, COLOR_YELLOW}

val WS_ROOT = "build/tmp/llm_caret_tui_test"

# Injected fake model: first turn asks for a bash tool, then finishes. Under
# default_policy (non-interactive) bash resolves to a permission-denied error
# result - deterministic, no filesystem side effects - so the renderer fires
# with status "error".
fn _one_tool(msgs: [Message]) -> ModelResponse:
    if msgs.len() <= 1:
        return new_model_tools("", [new_tool_call("t1", "bash", "{\"command\":\"echo hi\"}")])
    new_model_text("done")

# ============================================================================
describe "TUI pure formatting":
    it "labels user and assistant turns distinctly":
        expect(tui_role_label("user")).to_equal("You")
        expect(tui_role_label("assistant")).to_equal("Claude")

    it "formats a turn line with its role label":
        expect(format_turn_line("user", "hello")).to_equal("You: hello")
        expect(format_turn_line("assistant", "hi")).to_equal("Claude: hi")

    it "styles user vs assistant turns differently":
        val us = tui_role_style("user")
        val asst = tui_role_style("assistant")
        expect(us.fg).to_equal(COLOR_CYAN)
        expect(asst.fg).to_equal(COLOR_GREEN)
        assert_true(us.fg != asst.fg)

    it "formats a tool-call line":
        expect(format_tool_line("bash", "ok", "output")).to_equal("  -> tool bash [ok]: output")

    it "styles error tool lines red and ok tool lines yellow":
        expect(tui_tool_style("error").fg).to_equal(COLOR_RED)
        expect(tui_tool_style("ok").fg).to_equal(COLOR_YELLOW)

describe "Renderer-seam selection":
    it "explicit plain flag forces plain even on a tty":
        expect(select_renderer_mode("plain", true)).to_equal("plain")

    it "explicit tui flag forces tui even without a tty":
        expect(select_renderer_mode("tui", false)).to_equal("tui")

    it "auto picks tui on a tty":
        expect(select_renderer_mode("auto", true)).to_equal("tui")

    it "auto falls back to plain when not a tty":
        expect(select_renderer_mode("auto", false)).to_equal("plain")

describe "Transcript rendering":
    it "appends a styled user turn to the transcript":
        tui_transcript_reset()
        render_turn("user", "hi there")
        expect(tui_transcript_len()).to_equal(1)
        expect(tui_transcript_line_text(0)).to_equal("You: hi there")

    it "appends a styled tool-call line to the transcript":
        tui_transcript_reset()
        render_tool_call("bash", "ok", "42")
        expect(tui_transcript_len()).to_equal(1)
        expect(tui_transcript_line_text(0)).to_contain("tool bash [ok]")

describe "Agent-loop renderer seam":
    it "routes tool calls through render_tool_call in TUI mode":
        tui_transcript_reset()
        val p = default_policy(WS_ROOT)
        val result = run_agent_loop_rendered(p, [new_user_message("go")], _one_tool, 25, tui_tool_renderer)
        expect(result.tool_calls_made).to_equal(1)
        expect(tui_transcript_len()).to_equal(1)
        expect(tui_transcript_line_text(0)).to_contain("tool bash")
        expect(tui_transcript_line_text(0)).to_contain("[error]")

    it "leaves the TUI transcript untouched on the plain print path":
        tui_transcript_reset()
        val p = default_policy(WS_ROOT)
        val result = run_agent_loop(p, [new_user_message("go")], _one_tool, 25)
        expect(result.tool_calls_made).to_equal(1)
        expect(tui_transcript_len()).to_equal(0)
