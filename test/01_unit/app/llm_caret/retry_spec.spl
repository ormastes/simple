# LLM Caret Retry/Backoff/Timeout Specification
#
# Verifies the pure decision functions (should_retry, backoff_delay_ms,
# effective_delay_ms) and the with_retry driver using injected closures —
# no live HTTP calls.

use app.llm_caret.retry.{
    RetryPolicy, RetryOutcome,
    default_retry_policy, is_retryable_status, should_retry,
    backoff_delay_ms, effective_delay_ms, with_retry
}

fn _test_policy() -> RetryPolicy:
    RetryPolicy(
        max_attempts: 4,
        base_delay_ms: 1000,
        max_delay_ms: 32000,
        timeout_ms: 600000
    )

# with_retry actually sleeps between attempts (rt_sleep_ms), so integration
# tests use a policy with tiny delays to keep the suite fast. The delay
# math itself is covered precisely by the backoff_delay_ms/effective_delay_ms
# tests above, which use _test_policy's production-realistic values.
fn _fast_policy() -> RetryPolicy:
    RetryPolicy(
        max_attempts: 4,
        base_delay_ms: 5,
        max_delay_ms: 20,
        timeout_ms: 600000
    )

describe "default_retry_policy":
    it "should has sane production defaults":
        val p = default_retry_policy()
        expect(p.max_attempts).to_equal(4)
        expect(p.base_delay_ms).to_equal(1000)
        expect(p.max_delay_ms).to_equal(32000)
        expect(p.timeout_ms).to_equal(600000)

describe "is_retryable_status":
    it "should retries 429":
        expect(is_retryable_status(429)).to_be(true)

    it "should retries 500":
        expect(is_retryable_status(500)).to_be(true)

    it "should retries 502 and 503":
        expect(is_retryable_status(502)).to_be(true)
        expect(is_retryable_status(503)).to_be(true)

    it "should retries connection error (status <= 0)":
        expect(is_retryable_status(-1)).to_be(true)
        expect(is_retryable_status(0)).to_be(true)

    it "should does not retry 400":
        expect(is_retryable_status(400)).to_be(false)

    it "should does not retry 401 or 403":
        expect(is_retryable_status(401)).to_be(false)
        expect(is_retryable_status(403)).to_be(false)

    it "should does not retry 404":
        expect(is_retryable_status(404)).to_be(false)

    it "should does not retry 200":
        expect(is_retryable_status(200)).to_be(false)

describe "should_retry":
    it "should retries 429 within max_attempts":
        val p = _test_policy()
        expect(should_retry(429, 1, p)).to_be(true)

    it "should retries 500 within max_attempts":
        val p = _test_policy()
        expect(should_retry(500, 1, p)).to_be(true)

    it "should does not retry 400":
        val p = _test_policy()
        expect(should_retry(400, 1, p)).to_be(false)

    it "should does not retry once max_attempts is reached":
        val p = _test_policy()
        expect(should_retry(500, 4, p)).to_be(false)

    it "should does not retry beyond max_attempts":
        val p = _test_policy()
        expect(should_retry(500, 10, p)).to_be(false)

describe "backoff_delay_ms":
    it "should produces increasing delays for successive attempts":
        val p = _test_policy()
        val d1 = backoff_delay_ms(1, p)
        val d2 = backoff_delay_ms(2, p)
        val d3 = backoff_delay_ms(3, p)
        expect(d1).to_be_greater_than(0)
        expect(d2).to_be_greater_than(d1)
        expect(d3).to_be_greater_than(d2)

    it "should attempt 1 is close to base_delay_ms":
        val p = _test_policy()
        val d1 = backoff_delay_ms(1, p)
        expect(d1).to_be_greater_than(999)
        expect(d1).to_be_less_than(1300)

    it "should attempt 2 is roughly double base_delay_ms":
        val p = _test_policy()
        val d2 = backoff_delay_ms(2, p)
        expect(d2).to_be_greater_than(1999)
        expect(d2).to_be_less_than(2300)

    it "should caps at max_delay_ms":
        val p = _test_policy()
        val d_big = backoff_delay_ms(20, p)
        expect(d_big).to_equal(p.max_delay_ms)

    it "should is deterministic for the same inputs":
        val p = _test_policy()
        val a = backoff_delay_ms(3, p)
        val b = backoff_delay_ms(3, p)
        expect(a).to_equal(b)

describe "effective_delay_ms":
    it "should honors Retry-After when positive":
        val p = _test_policy()
        val delay = effective_delay_ms(1, p, 5000)
        expect(delay).to_equal(5000)

    it "should falls back to backoff when Retry-After is zero":
        val p = _test_policy()
        val delay = effective_delay_ms(1, p, 0)
        val expected = backoff_delay_ms(1, p)
        expect(delay).to_equal(expected)

    it "should caps Retry-After at max_delay_ms":
        val p = _test_policy()
        val delay = effective_delay_ms(1, p, 999999)
        expect(delay).to_equal(p.max_delay_ms)

describe "with_retry":
    it "should does not retry on immediate success":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            (200, "ok", "", 0)
        )
        expect(outcome.status).to_equal(200)
        expect(outcome.attempts).to_equal(1)
        expect(outcome.error).to_equal("")

    it "should retries on 429 then succeeds":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            if attempt < 2:
                (429, "", "", 0)
            else:
                (200, "ok", "", 0)
        )
        expect(outcome.status).to_equal(200)
        expect(outcome.attempts).to_equal(2)

    it "should retries on 500 then succeeds":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            if attempt < 3:
                (500, "", "", 0)
            else:
                (200, "ok", "", 0)
        )
        expect(outcome.status).to_equal(200)
        expect(outcome.attempts).to_equal(3)

    it "should does not retry 400 (fails on first attempt)":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            (400, "bad request", "", 0)
        )
        expect(outcome.status).to_equal(400)
        expect(outcome.attempts).to_equal(1)

    it "should exhausts max_attempts and returns the final error":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            (503, "still down", "", 0)
        )
        expect(outcome.attempts).to_equal(p.max_attempts)
        expect(outcome.status).to_equal(503)
        expect(outcome.body).to_equal("still down")

    it "should retries on connection error (non-empty error string)":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            if attempt < 2:
                (0, "", "connection refused", 0)
            else:
                (200, "ok", "", 0)
        )
        expect(outcome.status).to_equal(200)
        expect(outcome.attempts).to_equal(2)

    it "should honors Retry-After hint on a retried attempt":
        val p = _fast_policy()
        val outcome = with_retry(p, fn(attempt: i64) -> (i64, text, text, i64):
            if attempt < 2:
                (429, "", "", 10)
            else:
                (200, "ok", "", 0)
        )
        expect(outcome.status).to_equal(200)
        expect(outcome.attempts).to_equal(2)

    it "should stops before a backoff would exceed the retry timeout budget":
        val p = RetryPolicy(
            max_attempts: 4,
            base_delay_ms: 20,
            max_delay_ms: 20,
            timeout_ms: 1
        )
        val outcome = with_retry(
            p,
            fn(attempt: i64) -> (i64, text, text, i64):
                (503, "still down", "", 0)
        )
        expect(outcome.attempts).to_equal(1)
        expect(outcome.error).to_equal("retry timeout exceeded")
