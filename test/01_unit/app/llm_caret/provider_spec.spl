# LLM Caret Provider Specification

use app.llm_caret.provider.{
    list_providers, is_valid_provider, new_llm_error,
    dispatch_send, dispatch_send_advanced
}

# ============================================================================
# Tests
# ============================================================================

describe "Provider List":
    it "should list all providers":
        val providers = list_providers()
        expect(providers.len()).to_equal(7)

    it "should include dummy":
        expect(is_valid_provider("dummy")).to_be(true)

    it "should include claude_cli":
        val providers = list_providers()
        var found = false
        for p in providers:
            if p == "claude_cli":
                found = true
        expect(found).to_be(true)

    it "should include opencode_cli":
        val providers = list_providers()
        var found = false
        for p in providers:
            if p == "opencode_cli":
                found = true
        expect(found).to_be(true)

    it "should include claude_api":
        val providers = list_providers()
        var found = false
        for p in providers:
            if p == "claude_api":
                found = true
        expect(found).to_be(true)

    it "should include openai":
        val providers = list_providers()
        var found = false
        for p in providers:
            if p == "openai":
                found = true
        expect(found).to_be(true)

    it "should include openai_compat":
        val providers = list_providers()
        var found = false
        for p in providers:
            if p == "openai_compat":
                found = true
        expect(found).to_be(true)

    it "should include local_torch":
        val providers = list_providers()
        var found = false
        for p in providers:
            if p == "local_torch":
                found = true
        expect(found).to_be(true)

describe "Provider Validation":
    it "should validate claude_cli":
        expect(is_valid_provider("claude_cli")).to_be(true)

    it "should validate opencode_cli":
        expect(is_valid_provider("opencode_cli")).to_be(true)

    it "should validate claude_api":
        expect(is_valid_provider("claude_api")).to_be(true)

    it "should validate openai":
        expect(is_valid_provider("openai")).to_be(true)

    it "should validate openai_compat":
        expect(is_valid_provider("openai_compat")).to_be(true)

    it "should validate local_torch":
        expect(is_valid_provider("local_torch")).to_be(true)

    it "should reject an unknown provider":
        expect(is_valid_provider("unknown")).to_be(false)

    it "should reject an empty provider":
        expect(is_valid_provider("")).to_be(false)

describe "LLMResponse Error":
    it "should create an error response":
        val resp = new_llm_error("claude_cli", "connection refused")
        expect(resp.is_error).to_be(true)
        expect(resp.error).to_equal("connection refused")
        expect(resp.provider).to_equal("claude_cli")
        expect(resp.stop_reason).to_equal("error")
        expect(resp.content).to_equal("")

describe "Dummy Provider":
    it "should always return hello without external configuration":
        val resp = dispatch_send("dummy", "anything", "", "", "", "", "", "", 0, 0, "[]")
        expect(resp.is_error).to_be(false)
        expect(resp.content).to_equal("hello")
        expect(resp.model).to_equal("dummy-hello")

    it "should reject Claude-only advanced arguments for another provider":
        val resp = dispatch_send_advanced(
            "dummy", "anything", "", "", "", "", "", "", 0, 0, "[]",
            "{\"type\":\"object\"}", ["Read"], []
        )
        expect(resp.is_error).to_be(true)
        expect(resp.provider).to_equal("dummy")
        expect(resp.error).to_contain("require claude_cli")
