use app.cli.check_options.{check_option_error}

extern fn rt_exit(code: i32)

val unknown = check_option_error(["--not-a-check-option"])
val bare_log_mode = check_option_error(["--log-mode"])
val swallowed_progress = check_option_error(["--progress", "--json"])
val invalid_log_mode = check_option_error(["--log-mode=noisy"])
val invalid_surface = check_option_error(["--surface", "plain"])
val empty_progress = check_option_error(["--progress="])
val valid_split = check_option_error(["--log-mode", "json", "--progress", "dot"])
val valid_surface_split = check_option_error(["--surface", "tui"])
val valid_equals = check_option_error(["--surface=stdout", "--progress=none"])
val valid_source = check_option_error(["fixture.spl"])

val failed = unknown == "" or bare_log_mode == "" or swallowed_progress == "" or invalid_log_mode == "" or invalid_surface == "" or empty_progress == "" or valid_split != "" or valid_surface_split != "" or valid_equals != "" or valid_source != ""
if failed:
    print "FAIL: check option preflight did not fail closed"
    rt_exit(1)

print "PASS: check rejects invalid options before file discovery"
rt_exit(0)
