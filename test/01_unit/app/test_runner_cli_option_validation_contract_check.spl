use std.test_runner.test_runner_args.{test_args_validation_error}

extern fn rt_exit(code: i32)

val unknown = test_args_validation_error(["--not-a-test-option"])
val missing_tag = test_args_validation_error(["--tag"])
val tag_swallows_unknown = test_args_validation_error(["--tag", "--unknown"])
val tag_swallows_unit = test_args_validation_error(["--tag", "--unit"])
val empty_tag = test_args_validation_error(["--tag", ""])
val empty_mode = test_args_validation_error(["--mode="])
val signed_value = test_args_validation_error(["--timeout", "-1"])
val trailing_equals_value = test_args_validation_error(["--sdoctest-env=KEY="])

if (unknown == "" or missing_tag == "" or tag_swallows_unknown == "" or
    tag_swallows_unit == "" or empty_tag == "" or empty_mode == "" or
    signed_value != "" or trailing_equals_value != ""):
    print "FAIL: test runner option preflight did not fail closed"
    rt_exit(1)

print "PASS: test runner rejects unknown and bare options before discovery"
rt_exit(0)
