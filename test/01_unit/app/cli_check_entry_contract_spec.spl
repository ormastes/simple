use std.spec.{describe, it, expect}
use std.io_runtime.{file_read}

describe "CLI check worker resolution":
    it "uses the configured admitted binary before release-path fallback":
        val source = file_read("src/app/cli/check_entry.spl")
        val configured = source.index_of("val configured = env_get(\"SIMPLE_BINARY\")")
        val host_probe = source.index_of("process_run_timeout(\"uname\"")
        expect(configured).to_be_greater_than(0)
        expect(configured).to_be_less_than(host_probe)
        expect(source).to_contain("configured != nil and configured != \"\" and file_exists(configured)")
        expect(source).to_contain("return configured")
