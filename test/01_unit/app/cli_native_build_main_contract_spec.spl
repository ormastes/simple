describe "native-build main fast path contract":
    extern fn rt_file_read_text(path: text) -> text

    it "calls the pure Simple native-build implementation before worker fallback":
        val source = rt_file_read_text("src/app/cli/native_build_main.spl") ?? ""

        expect(source).to_contain("app.io.cli_compile")
        expect(source).to_contain("cli_native_build")
        expect(source).to_contain("if not should_use_worker_fallback() and not args_request_timeout(args):")
        expect(source).to_contain("return cli_native_build(args)")
        expect(source).to_contain("a == \"--timeout\"")
        expect(source).to_contain("a.starts_with(\"--timeout=\")")
        expect(source).to_contain("args[i].starts_with(\"--timeout=\")")
        expect(source).to_contain("args[i].substring(10)")
        expect(source).to_contain("SIMPLE_NATIVE_BUILD_FORCE_WORKER")
        expect(source).to_contain("SIMPLE_BOOTSTRAP")
        expect(source).to_contain("SIMPLE_EXECUTION_MODE")
        expect(source).to_contain("[\"run\", \"src/app/cli/native_build_worker.spl\"]")
