# @cover src/lib/editor/core/session.spl 80%
# @cover src/app/svim/buffer_manager.spl 90%
# @cover src/app/svim/split_pane_render.spl 80%
"""
svim multi-buffer editing and split pane layout specification

Self-contained tests for buffer management, split pane layout,
and EditSession split/focus implementation. Uses inline helpers
to avoid import-chain issues.
"""

use std.spipe.*

# ============================================================================
# Inline types and helpers for split pane layout
# ============================================================================

class TestPane:
    pane_id: i64
    buf_idx: i64

class TestSplitLayout:
    panes: [TestPane]
    active_pane_id: i64
    next_pane_id: i64

fn test_layout_new() -> TestSplitLayout:
    TestSplitLayout(
        panes: [TestPane(pane_id: 1, buf_idx: -1)],
        active_pane_id: 1,
        next_pane_id: 2
    )

fn test_layout_split(layout: TestSplitLayout) -> TestSplitLayout:
    """Add a new pane, keeping the same buffer index as active."""
    val new_id = layout.next_pane_id
    val active_buf = _test_active_buf_idx(layout)
    var new_panes = layout.panes
    new_panes.push(TestPane(pane_id: new_id, buf_idx: active_buf))
    TestSplitLayout(
        panes: new_panes,
        active_pane_id: new_id,
        next_pane_id: new_id + 1
    )

fn test_layout_close_others(layout: TestSplitLayout) -> TestSplitLayout:
    """Close all panes except the active one."""
    var kept: [TestPane] = []
    var i = 0
    while i < layout.panes.len():
        if layout.panes[i].pane_id == layout.active_pane_id:
            kept.push(layout.panes[i])
        i = i + 1
    TestSplitLayout(
        panes: kept,
        active_pane_id: layout.active_pane_id,
        next_pane_id: layout.next_pane_id
    )

fn test_layout_focus_next(layout: TestSplitLayout) -> TestSplitLayout:
    """Focus the next pane (wraps around)."""
    val ids = _test_pane_ids(layout)
    var idx = 0
    var i = 0
    while i < ids.len():
        if ids[i] == layout.active_pane_id:
            idx = i
        i = i + 1
    idx = (idx + 1) % ids.len()
    TestSplitLayout(
        panes: layout.panes,
        active_pane_id: ids[idx],
        next_pane_id: layout.next_pane_id
    )

fn test_layout_focus_prev(layout: TestSplitLayout) -> TestSplitLayout:
    """Focus the previous pane (wraps around)."""
    val ids = _test_pane_ids(layout)
    var idx = 0
    var i = 0
    while i < ids.len():
        if ids[i] == layout.active_pane_id:
            idx = i
        i = i + 1
    idx = (idx - 1 + ids.len()) % ids.len()
    TestSplitLayout(
        panes: layout.panes,
        active_pane_id: ids[idx],
        next_pane_id: layout.next_pane_id
    )

fn test_layout_bind(layout: TestSplitLayout, buf_idx: i64) -> TestSplitLayout:
    """Bind the active pane to a buffer index."""
    var new_panes: [TestPane] = []
    var i = 0
    while i < layout.panes.len():
        if layout.panes[i].pane_id == layout.active_pane_id:
            new_panes.push(TestPane(pane_id: layout.panes[i].pane_id, buf_idx: buf_idx))
        else:
            new_panes.push(layout.panes[i])
        i = i + 1
    TestSplitLayout(
        panes: new_panes,
        active_pane_id: layout.active_pane_id,
        next_pane_id: layout.next_pane_id
    )

fn _test_pane_ids(layout: TestSplitLayout) -> [i64]:
    var ids: [i64] = []
    var i = 0
    while i < layout.panes.len():
        ids.push(layout.panes[i].pane_id)
        i = i + 1
    ids

fn _test_active_buf_idx(layout: TestSplitLayout) -> i64:
    var i = 0
    while i < layout.panes.len():
        if layout.panes[i].pane_id == layout.active_pane_id:
            return layout.panes[i].buf_idx
        i = i + 1
    -1

# ============================================================================
# Inline buffer manager helpers
# ============================================================================

class TestBufferEntry:
    name: text
    modified: bool

class TestBufferManager:
    entries: [TestBufferEntry]
    active: i64

fn test_bm_new() -> TestBufferManager:
    TestBufferManager(entries: [], active: -1)

fn test_bm_add(bm: TestBufferManager, name: text) -> TestBufferManager:
    var new_entries = bm.entries
    new_entries.push(TestBufferEntry(name: name, modified: false))
    TestBufferManager(entries: new_entries, active: new_entries.len() - 1)

fn test_bm_switch_next(bm: TestBufferManager) -> TestBufferManager:
    if bm.entries.len() == 0:
        return bm
    val n = bm.entries.len()
    TestBufferManager(entries: bm.entries, active: (bm.active + 1) % n)

fn test_bm_switch_prev(bm: TestBufferManager) -> TestBufferManager:
    if bm.entries.len() == 0:
        return bm
    val n = bm.entries.len()
    TestBufferManager(entries: bm.entries, active: (bm.active - 1 + n) % n)

fn test_bm_switch_by_name(bm: TestBufferManager, target: text) -> TestBufferManager:
    var i = 0
    while i < bm.entries.len():
        if bm.entries[i].name == target or bm.entries[i].name.ends_with(target):
            return TestBufferManager(entries: bm.entries, active: i)
        i = i + 1
    bm

fn test_bm_switch_by_index(bm: TestBufferManager, idx: i64) -> TestBufferManager:
    if idx < 0 or idx >= bm.entries.len():
        return bm
    TestBufferManager(entries: bm.entries, active: idx)

fn test_bm_list(bm: TestBufferManager) -> text:
    var out = ""
    var i = 0
    while i < bm.entries.len():
        val marker = if i == bm.active then "*" else: " "
        out = out + "  {marker} {i + 1}: {bm.entries[i].name}\n"
        i = i + 1
    out

# ============================================================================
# Inline pane region computation
# ============================================================================

class TestRegion:
    pane_id: i64
    x: i64
    y: i64
    w: i64
    h: i64

fn test_compute_single(pane_id: i64, w: i64, h: i64) -> [TestRegion]:
    [TestRegion(pane_id: pane_id, x: 0, y: 0, w: w, h: h)]

fn test_compute_vsplit(id1: i64, id2: i64, w: i64, h: i64) -> [TestRegion]:
    val left_w = (w - 1) / 2
    val right_w = w - left_w - 1
    [
        TestRegion(pane_id: id1, x: 0, y: 0, w: left_w, h: h),
        TestRegion(pane_id: id2, x: left_w + 1, y: 0, w: right_w, h: h)
    ]

fn test_compute_hsplit(id1: i64, id2: i64, w: i64, h: i64) -> [TestRegion]:
    val top_h = (h - 1) / 2
    val bot_h = h - top_h - 1
    [
        TestRegion(pane_id: id1, x: 0, y: 0, w: w, h: top_h),
        TestRegion(pane_id: id2, x: 0, y: top_h + 1, w: w, h: bot_h)
    ]

fn test_pane_status(buf_idx: i64, buf_count: i64, pane_idx: i64, pane_count: i64, modified: bool) -> text:
    val mod_flag = if modified then " [+]" else: ""
    "[No Name]{mod_flag} [buf {buf_idx}/{buf_count}] [pane {pane_idx}/{pane_count}]"

# ============================================================================
# Tests: split pane layout (5 tests)
# ============================================================================

describe "split pane layout":

    it "starts with one pane":
        val layout = test_layout_new()
        expect layout.panes.len() == 1

    it "split adds a new pane":
        var layout = test_layout_new()
        layout = test_layout_split(layout)
        expect layout.panes.len() == 2

    it "close_others reduces to one pane":
        var layout = test_layout_new()
        layout = test_layout_split(layout)
        layout = test_layout_split(layout)
        expect layout.panes.len() == 3
        layout = test_layout_close_others(layout)
        expect layout.panes.len() == 1

    it "focus_next cycles through panes":
        var layout = test_layout_new()
        layout = test_layout_split(layout)
        val second_id = layout.active_pane_id
        layout = test_layout_focus_next(layout)
        expect layout.active_pane_id == 1
        layout = test_layout_focus_next(layout)
        expect layout.active_pane_id == second_id

    it "focus_prev wraps around":
        var layout = test_layout_new()
        layout = test_layout_split(layout)
        val second_id = layout.active_pane_id
        layout = test_layout_focus_prev(layout)
        expect layout.active_pane_id == 1
        layout = test_layout_focus_prev(layout)
        expect layout.active_pane_id == second_id

# ============================================================================
# Tests: buffer management (5 tests)
# ============================================================================

describe "buffer management":

    it "add buffer updates active index":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "file_a.spl")
        expect bm.active == 0
        bm = test_bm_add(bm, "file_b.spl")
        expect bm.active == 1

    it "switch_next wraps around":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "a.spl")
        bm = test_bm_add(bm, "b.spl")
        expect bm.active == 1
        bm = test_bm_switch_next(bm)
        expect bm.active == 0

    it "switch_prev wraps around":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "a.spl")
        bm = test_bm_add(bm, "b.spl")
        bm = test_bm_switch_prev(bm)
        expect bm.active == 0
        bm = test_bm_switch_prev(bm)
        expect bm.active == 1

    it "switch_by_name finds matching buffer":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "src/main.spl")
        bm = test_bm_add(bm, "src/lib.spl")
        bm = test_bm_switch_by_name(bm, "main.spl")
        expect bm.active == 0

    it "switch_by_index rejects invalid index":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "a.spl")
        bm = test_bm_switch_by_index(bm, 99)
        expect bm.active == 0

# ============================================================================
# Tests: pane region computation (4 tests)
# ============================================================================

describe "pane region computation":

    it "single pane fills entire area":
        val regions = test_compute_single(1, 80, 24)
        expect regions.len() == 1
        expect regions[0].w == 80
        expect regions[0].h == 24

    it "vertical split creates side-by-side regions":
        val regions = test_compute_vsplit(1, 2, 80, 24)
        expect regions.len() == 2
        expect regions[0].x == 0
        expect regions[1].x > regions[0].x

    it "horizontal split creates stacked regions":
        val regions = test_compute_hsplit(1, 2, 80, 24)
        expect regions.len() == 2
        expect regions[0].y == 0
        expect regions[1].y > regions[0].y

    it "split regions do not overlap":
        val regions = test_compute_vsplit(1, 2, 80, 24)
        val left_end = regions[0].x + regions[0].w
        expect left_end < regions[1].x

# ============================================================================
# Tests: status bar (2 tests)
# ============================================================================

describe "pane status bar":

    it "shows buffer and pane counts":
        val status = test_pane_status(1, 2, 1, 3, false)
        expect status.contains("buf 1/2")
        expect status.contains("pane 1/3")

    it "shows modified flag":
        val status = test_pane_status(1, 1, 1, 1, true)
        expect status.contains("[+]")

# ============================================================================
# Tests: buffer list rendering (2 tests)
# ============================================================================

describe "buffer list rendering":

    it "list shows active marker":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "file_a.spl")
        bm = test_bm_add(bm, "file_b.spl")
        val listing = test_bm_list(bm)
        expect listing.contains("*")
        expect listing.contains("file_a.spl")
        expect listing.contains("file_b.spl")

    it "list marks correct active buffer":
        var bm = test_bm_new()
        bm = test_bm_add(bm, "first.spl")
        bm = test_bm_add(bm, "second.spl")
        bm = test_bm_switch_by_index(bm, 0)
        val listing = test_bm_list(bm)
        expect listing.contains("* 1: first.spl")
