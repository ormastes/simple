# @cover src/app/svim/search_repeat.spl 90%
# @cover src/app/svim/text_object.spl 90%
# @cover src/app/svim/quickfix_traversal.spl 90%
# @cover src/app/svim/language_bridge_ext.spl 90%
"""
svim extension modules specification

Self-contained tests for search repeat, text-object, quickfix traversal,
and language bridge helpers. All types are defined inline.
"""

use std.spipe.*

# ============================================================================
# Inline types for search_repeat
# ============================================================================

fn search_find_next(content: text, start_col: i64, pattern: text) -> i64:
    val plen = pattern.len()
    if plen == 0:
        return -1
    val clen = content.len()
    var i = start_col
    while i <= clen - plen:
        val slice = content.slice(i, i + plen)
        if slice == pattern:
            return i
        i = i + 1
    -1

fn search_find_prev(content: text, before_col: i64, pattern: text) -> i64:
    val plen = pattern.len()
    if plen == 0:
        return -1
    var i = before_col - 1
    while i >= 0:
        if i + plen <= content.len():
            val slice = content.slice(i, i + plen)
            if slice == pattern:
                return i
        i = i - 1
    -1

fn search_next(content: text, current_col: i64, pattern: text) -> i64:
    val after = search_find_next(content, current_col + 1, pattern)
    if after >= 0:
        return after
    search_find_next(content, 0, pattern)

fn search_prev(content: text, current_col: i64, pattern: text) -> i64:
    val before = search_find_prev(content, current_col, pattern)
    if before >= 0:
        return before
    val clen = content.len()
    search_find_prev(content, clen, pattern)

# ============================================================================
# Inline types for text_object
# ============================================================================

fn is_word_char(ch: text) -> bool:
    if ch == "_":
        return true
    val code = ch.char_code_at(0)
    if code >= 48 and code <= 57:
        return true
    if code >= 65 and code <= 90:
        return true
    if code >= 97 and code <= 122:
        return true
    false

fn inner_word(line: text, col: i64) -> [i64]:
    val llen = line.len()
    if llen == 0:
        return [0, 0]
    var safe_col = col
    if safe_col >= llen:
        safe_col = llen - 1
    var start = safe_col
    while start > 0 and is_word_char(line.slice(start - 1, start)):
        start = start - 1
    var end = safe_col
    while end < llen and is_word_char(line.slice(end, end + 1)):
        end = end + 1
    [start, end]

fn around_word(line: text, col: i64) -> [i64]:
    val inner = inner_word(line, col)
    val llen = line.len()
    var end = inner[1]
    while end < llen and line.slice(end, end + 1) == " ":
        end = end + 1
    [inner[0], end]

fn inner_line(line: text) -> [i64]:
    val llen = line.len()
    var start = 0
    while start < llen and line.slice(start, start + 1) == " ":
        start = start + 1
    var end = llen
    while end > start and line.slice(end - 1, end) == " ":
        end = end - 1
    [start, end]

# ============================================================================
# Inline types for quickfix_traversal
# ============================================================================

class QfEntry:
    row: i64
    col: i64
    severity: text
    message: text

class QfTraversal:
    entries: [QfEntry]
    current_index: i64

impl QfTraversal:

    static fn new() -> QfTraversal:
        QfTraversal(entries: [], current_index: 0)

    static fn from_list(items: [QfEntry]) -> QfTraversal:
        QfTraversal(entries: items, current_index: 0)

    me next_entry() -> bool:
        if self.entries.len() == 0:
            return false
        if self.current_index + 1 < self.entries.len():
            self.current_index = self.current_index + 1
            return true
        false

    me prev_entry() -> bool:
        if self.entries.len() == 0:
            return false
        if self.current_index > 0:
            self.current_index = self.current_index - 1
            return true
        false

    fn current_entry() -> QfEntry:
        if self.entries.len() == 0:
            return QfEntry(row: 0, col: 0, severity: "", message: "")
        self.entries[self.current_index]

    fn entry_count() -> i64:
        self.entries.len()

    me jump_index(idx: i64) -> bool:
        if idx >= 0 and idx < self.entries.len():
            self.current_index = idx
            return true
        false

fn qf_filter_severity(entries: [QfEntry], sev: text) -> [QfEntry]:
    var out: [QfEntry] = []
    for entry in entries:
        if entry.severity == sev:
            out.push(entry)
    out

# ============================================================================
# Inline types for language_bridge_ext
# ============================================================================

class ParseDiag:
    row: i64
    col: i64
    severity: text
    message: text
    source: text

class BridgeDiag:
    row: i64
    col: i64
    severity: text
    message: text

class BridgeQfEntry:
    row: i64
    col: i64
    severity: text
    message: text
    label: text

fn bridge_diag(pd: ParseDiag) -> BridgeDiag:
    BridgeDiag(row: pd.row, col: pd.col, severity: pd.severity, message: pd.message)

fn bridge_qf(pd: ParseDiag) -> BridgeQfEntry:
    val label = "{pd.source}:{pd.row + 1}:{pd.col + 1}: {pd.severity}"
    BridgeQfEntry(row: pd.row, col: pd.col, severity: pd.severity, message: pd.message, label: label)

fn bridge_all_diags(pds: [ParseDiag]) -> [BridgeDiag]:
    var out: [BridgeDiag] = []
    for pd in pds:
        out.push(bridge_diag(pd))
    out

fn bridge_has_errors(pds: [ParseDiag]) -> bool:
    var count = 0
    for pd in pds:
        if pd.severity == "error":
            count = count + 1
    count > 0

# ============================================================================
# Tests: search repeat (5 tests)
# ============================================================================

describe "svim search_repeat":

    it "finds pattern at start of string":
        val idx = search_find_next("hello world", 0, "hello")
        expect(idx).to_equal(0)

    it "finds pattern after start offset":
        val idx = search_find_next("abcabc", 1, "abc")
        expect(idx).to_equal(3)

    it "returns -1 when pattern not found":
        val idx = search_find_next("hello", 0, "xyz")
        expect(idx).to_equal(-1)

    it "search_next wraps around to beginning":
        val idx = search_next("abcabc", 3, "abc")
        expect(idx).to_equal(0)

    it "search_prev finds occurrence before current col":
        val idx = search_prev("abcabc", 3, "abc")
        expect(idx).to_equal(0)

# ============================================================================
# Tests: text_object (5 tests)
# ============================================================================

describe "svim text_object":

    it "inner_word returns full word bounds":
        val bounds = inner_word("hello world", 2)
        expect(bounds[0]).to_equal(0)
        expect(bounds[1]).to_equal(5)

    it "inner_word handles col at word boundary":
        val bounds = inner_word("foo bar", 4)
        expect(bounds[0]).to_equal(4)
        expect(bounds[1]).to_equal(7)

    it "around_word includes trailing space":
        val bounds = around_word("foo bar", 0)
        expect(bounds[0]).to_equal(0)
        expect(bounds[1]).to_equal(4)

    it "inner_line strips leading and trailing spaces":
        val bounds = inner_line("  hello  ")
        expect(bounds[0]).to_equal(2)
        expect(bounds[1]).to_equal(7)

    it "inner_word on empty string returns 0 0":
        val bounds = inner_word("", 0)
        expect(bounds[0]).to_equal(0)
        expect(bounds[1]).to_equal(0)

# ============================================================================
# Tests: quickfix traversal (5 tests)
# ============================================================================

describe "svim quickfix_traversal":

    it "new traversal starts at index 0 with empty entries":
        val qt = QfTraversal.new()
        expect(qt.entry_count()).to_equal(0)
        expect(qt.current_index).to_equal(0)

    it "next advances to second entry":
        var qt = QfTraversal.from_list([
            QfEntry(row: 1, col: 0, severity: "error", message: "e1"),
            QfEntry(row: 2, col: 0, severity: "warn", message: "w1")
        ])
        val moved = qt.next_entry()
        expect(moved).to_equal(true)
        expect(qt.current_index).to_equal(1)

    it "prev returns to previous entry":
        var qt = QfTraversal.from_list([
            QfEntry(row: 1, col: 0, severity: "error", message: "e1"),
            QfEntry(row: 2, col: 0, severity: "warn", message: "w1")
        ])
        qt.next_entry()
        val moved = qt.prev_entry()
        expect(moved).to_equal(true)
        expect(qt.current_index).to_equal(0)

    it "jump_index sets current index":
        var qt = QfTraversal.from_list([
            QfEntry(row: 0, col: 0, severity: "error", message: "a"),
            QfEntry(row: 1, col: 0, severity: "error", message: "b"),
            QfEntry(row: 2, col: 0, severity: "warn", message: "c")
        ])
        val ok = qt.jump_index(2)
        expect(ok).to_equal(true)
        expect(qt.current_entry().message).to_equal("c")

    it "qf_filter_severity returns only matching severity":
        val entries = [
            QfEntry(row: 0, col: 0, severity: "error", message: "e1"),
            QfEntry(row: 1, col: 0, severity: "warn", message: "w1"),
            QfEntry(row: 2, col: 0, severity: "error", message: "e2")
        ]
        val errors = qf_filter_severity(entries, "error")
        expect(errors.len()).to_equal(2)

# ============================================================================
# Tests: language bridge (5 tests)
# ============================================================================

describe "svim language_bridge_ext":

    it "bridge_diag preserves row col severity message":
        val pd = ParseDiag(row: 3, col: 5, severity: "error", message: "unexpected token", source: "parser")
        val bd = bridge_diag(pd)
        expect(bd.row).to_equal(3)
        expect(bd.col).to_equal(5)
        expect(bd.severity).to_equal("error")
        expect(bd.message).to_equal("unexpected token")

    it "bridge_qf label includes source and 1-based line col":
        val pd = ParseDiag(row: 0, col: 0, severity: "error", message: "boom", source: "myfile.spl")
        val bq = bridge_qf(pd)
        expect(bq.label).to_equal("myfile.spl:1:1: error")

    it "bridge_all_diags converts list":
        val pds = [
            ParseDiag(row: 0, col: 0, severity: "error", message: "a", source: "f.spl"),
            ParseDiag(row: 1, col: 2, severity: "warn", message: "b", source: "f.spl")
        ]
        val bds = bridge_all_diags(pds)
        expect(bds.len()).to_equal(2)
        expect(bds[1].row).to_equal(1)

    it "bridge_has_errors returns true when errors present":
        val pds = [
            ParseDiag(row: 0, col: 0, severity: "error", message: "x", source: "s"),
            ParseDiag(row: 1, col: 0, severity: "warn", message: "y", source: "s")
        ]
        val has = bridge_has_errors(pds)
        expect(has).to_equal(true)

    it "bridge_has_errors returns false with no errors":
        val pds = [
            ParseDiag(row: 0, col: 0, severity: "warn", message: "x", source: "s")
        ]
        val has = bridge_has_errors(pds)
        expect(has).to_equal(false)
