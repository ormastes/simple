# Feature: Browser Shell Input Translation — mouse button parity [C24]
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec. Verifies app.ui.browser.event_bridge's
# translate_mouse_event maps left/middle/right press+release (and an
# unknown button code) to the right UIEvent. Pure translator — no winit /
# FFI / compositor bring-up required.

use app.ui.browser.event_bridge.{translate_mouse_event}
use common.ui.widget.{UIEvent}

describe "Browser Event Bridge — mouse button translation":

    it "maps left press (button=0) to TouchPress":
        val ev = translate_mouse_event(120, 240, 0, "press")
        match ev:
            UIEvent.TouchPress(x, y) =>
                expect(x == 120).to_be_true()
                expect(y == 240).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps left release (button=0) to TouchRelease":
        val ev = translate_mouse_event(120, 240, 0, "release")
        match ev:
            UIEvent.TouchRelease(x, y) =>
                expect(x == 120).to_be_true()
                expect(y == 240).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps middle press (button=1) to MouseEvent(button: middle, kind: down)":
        val ev = translate_mouse_event(50, 60, 1, "press")
        match ev:
            UIEvent.MouseEvent(x, y, button, kind) =>
                expect(x == 50.0).to_be_true()
                expect(y == 60.0).to_be_true()
                expect(button == "middle").to_be_true()
                expect(kind == "down").to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps middle release (button=1) to MouseEvent(button: middle, kind: up)":
        val ev = translate_mouse_event(50, 60, 1, "release")
        match ev:
            UIEvent.MouseEvent(x, y, button, kind) =>
                expect(button == "middle").to_be_true()
                expect(kind == "up").to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps right press (button=2) to MouseEvent(button: right, kind: down)":
        val ev = translate_mouse_event(10, 20, 2, "press")
        match ev:
            UIEvent.MouseEvent(x, y, button, kind) =>
                expect(x == 10.0).to_be_true()
                expect(y == 20.0).to_be_true()
                expect(button == "right").to_be_true()
                expect(kind == "down").to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps right release (button=2) to MouseEvent(button: right, kind: up)":
        val ev = translate_mouse_event(10, 20, 2, "release")
        match ev:
            UIEvent.MouseEvent(x, y, button, kind) =>
                expect(button == "right").to_be_true()
                expect(kind == "up").to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps move regardless of button to TouchMove":
        val ev = translate_mouse_event(5, 6, 0, "move")
        match ev:
            UIEvent.TouchMove(x, y) =>
                expect(x == 5).to_be_true()
                expect(y == 6).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps an unknown button code (3) on press to nil":
        val ev = translate_mouse_event(1, 1, 3, "press")
        match ev:
            nil =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps an unknown action to nil":
        val ev = translate_mouse_event(1, 1, 0, "drag")
        match ev:
            nil =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()
