use app.mcp.main.{mcp_clean_log_args, mcp_cli_option_error}
use app.simple_lsp_mcp.main.{simple_lsp_mcp_clean_args, simple_lsp_mcp_cli_option_error, simple_lsp_mcp_log_option_error}

extern fn rt_exit(code: i32)

val mcp_stdio_tail = mcp_cli_option_error(mcp_clean_log_args(["--stdio", "--bogus"]))
val mcp_help_tail = mcp_cli_option_error(mcp_clean_log_args(["--help", "--bogus"]))
val mcp_progress_help = mcp_cli_option_error(mcp_clean_log_args(["--progress=dot", "--help"]))
val lsp_bare = simple_lsp_mcp_cli_option_error(simple_lsp_mcp_clean_args(["fixture.spl"]))
val lsp_help_tail = simple_lsp_mcp_cli_option_error(simple_lsp_mcp_clean_args(["--help", "--bogus"]))
val lsp_surface_split = simple_lsp_mcp_cli_option_error(simple_lsp_mcp_clean_args(["--surface", "stdout"]))
val lsp_progress_help = simple_lsp_mcp_cli_option_error(simple_lsp_mcp_clean_args(["--progress=dot", "--help"]))
val lsp_split_log = simple_lsp_mcp_log_option_error(["--log-mode", "json"])
val lsp_bad_progress = simple_lsp_mcp_log_option_error(["--progress", "many"])
val lsp_repeated_prefix = simple_lsp_mcp_log_option_error(["--log-mode=--log-mode=json"])

if (mcp_stdio_tail == "" or mcp_help_tail == "" or mcp_progress_help != "" or
        lsp_bare == "" or lsp_help_tail == "" or lsp_surface_split == "" or
        lsp_progress_help != "" or lsp_split_log != "" or lsp_bad_progress == "" or
        lsp_repeated_prefix == ""):
    print "FAIL: MCP/LSP CLI admission accepted an invalid argument shape"
    rt_exit(1)

print "PASS: MCP/LSP CLI admission is fail-closed"
rt_exit(0)
