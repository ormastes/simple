use app.io.cli_ops.{
    context_generate, context_stats, settlement_main,
    fault_set_stack_overflow_detection, fault_set_max_recursion_depth,
    fault_set_timeout, fault_set_execution_limit,
    get_args, cli_get_args
}

describe "Cli Ops Ext":
    it "returns empty context generation output for unsupported local requests":
        val result = context_generate("path", "target", "format")
        expect(result).to_equal("")

    it "returns empty context stats output for unsupported local requests":
        val result = context_stats("path", "target")
        expect(result).to_equal("")

    it "returns success for settlement main placeholder implementation":
        val result = settlement_main()
        expect(result).to_equal(0)

    it "keeps fault configuration hooks callable without changing context stats":
        fault_set_stack_overflow_detection(true)
        fault_set_stack_overflow_detection(false)
        fault_set_max_recursion_depth(100)
        fault_set_timeout(30)
        fault_set_execution_limit(1000)

        expect(context_stats("path", "target")).to_equal("")

    it "returns argument lists from both public argument accessors":
        val args = get_args()
        val cli_args = cli_get_args()

        expect(args.len()).to_be_greater_than(-1)
        expect(cli_args.len()).to_be_greater_than(-1)
