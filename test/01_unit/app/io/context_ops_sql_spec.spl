use app.io.context_ops.{context_sql_get_pack, context_sql_put_pack, context_sql_query_packs_by_source}

fn test_context_sql_put_get_search_roundtrip():
    val db_path = "build/spipe_context_sql_spec.db"
    val source = "spipe-sql-spec"
    val tree = "@source id=spipe-sql-spec parser=pytest\n@parent d=1 kind=dir path=\"src\"\n@node path=\"src/app/main.spl\" text=\"failed assert\""

    val put = context_sql_put_pack(source, "spipe-tree", tree, db_path, "text")
    assert(put.contains("status: ready"))

    val got = context_sql_get_pack(source, db_path, "text")
    assert(got.contains("@parent d=1 kind=dir path=\"src\""))
    assert(got.contains("failed assert"))

    val found = context_sql_query_packs_by_source([], "", "failed", source, db_path, "text")
    assert(found.contains("matches: 1"))
    assert(found.contains("spipe-sql-spec"))
