use app.io.cli_lint_commands.{run_fix_command}
use std.io.{file_write, file_read, file_delete}

extern fn rt_exit(code: i32)

val path = "/tmp/simple_fix_cli_option_validation.spl"
val original = "if let value = item:\n    print value\n"
if not file_write(path, original):
    print "FAIL: could not create fix fixture"
    rt_exit(1)

val malformed_exit = run_fix_command(["fix", path, "--dry-run=true"])
val unknown_exit = run_fix_command(["fix", path, "--bogus"])
val empty_id_exit = run_fix_command(["fix", path, "--fix-id="])
val after_invalid = file_read(path)
val dry_run_exit = run_fix_command(["fix", path, "--dry-run", "--fix-all", "--fix-id=L:deprecated_if_let"])
val after_dry_run = file_read(path)
val _ = file_delete(path)

if malformed_exit != 2 or unknown_exit != 2 or empty_id_exit != 2 or dry_run_exit != 0 or after_invalid != original or after_dry_run != original:
    print "FAIL: fix accepted an invalid option or mutated a dry-run fixture"
    rt_exit(1)

print "PASS: fix rejects invalid options before writes and preserves valid dry runs"
rt_exit(0)
