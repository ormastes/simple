extern fn rt_file_read_text(path: text) -> text?

describe "macos smf dynlib evidence numeric guard":
    it "falls back when evidence numeric fields fail to parse":
        val source = rt_file_read_text("src/app/gui_perf/macos_smf_dynlib_evidence_core.spl") ?? ""

        expect(source).to_contain("gui_mac_smf_dynlib_row_value(row, key).to_int() ?? -1")
        expect(source).to_contain("value.to_int() ?? -1")
        expect(source.contains("to_int() as i64")).to_equal(false)
