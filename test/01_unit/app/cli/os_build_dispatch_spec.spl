use std.spec.*

extern fn rt_file_read_text(path: text) -> text

fn cli_os_dispatch_source() -> text:
    rt_file_read_text("src/app/cli/_CliMain/args_and_os_commands.spl") ?? ""

describe "SimpleOS build dispatch":
    it "uses kernel smoke targets for os build arch dispatch":
        val src = cli_os_dispatch_source()
        expect(src.contains("fn handle_os_build_inline(args: [text]) -> i64:")).to_equal(true)
        expect(src.contains("val target = get_target(arch_value)")).to_equal(true)
        expect(src.contains("val target = get_qemu_target(arch_value)\n            val ok = build_os(target)")).to_equal(false)
