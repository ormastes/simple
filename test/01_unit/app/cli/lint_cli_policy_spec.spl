extern fn rt_file_read_text(path: text) -> text

describe "lint CLI policy wiring":
    it "uses the canonical file policy and preserves earlier --all failures":
        val source = rt_file_read_text("src/app/io/cli_lint_commands.spl") ?? ""
        expect(source).to_contain("run_lint_file(file_path, args)")
        expect(source).to_contain("if perf_exit != 0 and exit_code == 0")
        expect(source).to_contain("if files.len() == 0:\n            return exit_code")
        expect(source.contains("return perf_exit")).to_equal(false)
