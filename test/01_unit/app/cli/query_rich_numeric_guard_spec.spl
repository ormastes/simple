extern fn rt_file_read_text(path: text) -> text?

describe "query rich numeric guard":
    it "defaults malformed rich query coordinates":
        val source = rt_file_read_text("src/app/cli/query_rich_common.spl") ?? ""

        expect(source).to_contain("fn query_rich_nonnegative_int_or_zero(value: text) -> i64")
        expect(source).to_contain("trimmed.to_int() ?? 0")
        expect(source.contains("trimmed.to_int()\n")).to_equal(false)
