extern fn rt_file_read_text(path: text) -> text

fn bootstrap_main_source() -> text:
    rt_file_read_text("src/app/cli/bootstrap_main.spl") ?? ""

describe "bootstrap main source":
    it "reads compiled user argv from slot one":
        val source = bootstrap_main_source()

        expect(source).to_contain("get_cli_args().len() < 2")
        expect(source).to_contain("get_cli_args()[1] == \"--version\"")
        expect(source).to_contain("get_cli_args()[1] == \"native-build\"")
        expect(source).to_contain("get_cli_args()[2]")
        expect(source).to_contain("print \"simple-bootstrap 1.0.0-beta\"")
        expect(source).to_contain("print \"Simple Bootstrap Compiler v1.0.0-beta\"")
