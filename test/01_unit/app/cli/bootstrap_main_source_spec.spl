extern fn rt_file_read_text(path: text) -> text
use std.spec.{describe, it, expect}

fn bootstrap_main_source() -> text:
    rt_file_read_text("src/app/cli/bootstrap_main.spl") ?? ""

describe "bootstrap main source":
    it "dispatches commands before considering their arguments":
        val source = bootstrap_main_source()

        expect(source).to_contain("val first = all_args[1]")
        expect(source).to_contain("if first == \"native-build\"")
        expect(source).to_contain("return run_native_build_bootstrap(all_args)")
        expect(source.contains("if argc > 2")).to_equal(false)
        expect(source).to_contain("print \"simple-bootstrap 1.0.0-beta\"")
        expect(source).to_contain("print \"Simple Bootstrap Compiler v1.0.0-beta\"")
