extern fn rt_file_read_text(path: text) -> text
use std.spec.{describe, it, expect}
use compiler.driver.driver_source_loading.{_driver_resolve_entry_import, _driver_collect_entry_import_source}

fn bootstrap_main_source() -> text:
    rt_file_read_text("src/app/cli/bootstrap_main.spl") ?? ""

describe "bootstrap main source":
    it "dispatches commands before considering their arguments":
        val source = bootstrap_main_source()

        expect(source).to_contain("val first = all_args[1]")
        expect(source).to_contain("if first == \"native-build\"")
        expect(source).to_contain("return run_native_build_bootstrap(all_args)")
        expect(source.contains("if argc > 2")).to_equal(false)
        expect(source).to_contain("print \"simple-bootstrap 1.0.0-beta\"")
        expect(source).to_contain("print \"Simple Bootstrap Compiler v1.0.0-beta\"")
    it "routes only the canonical Stage4 entry through the pure Simple driver":
        val source = bootstrap_main_source()
        val api_source = rt_file_read_text("src/compiler/80.driver/bootstrap_api.spl") ?? ""
        val driver_source = rt_file_read_text("src/compiler/80.driver/driver.spl") ?? ""

        expect(source).to_contain("fn native_build_entry_from_args(args: [text], i: i64) -> text:")
        expect(source).to_contain("val explicit_entry = native_build_entry_from_args(args, 0)")
        expect(source).to_contain("if env_get(\"SIMPLE_BOOTSTRAP_STAGE4\") != \"1\":")
        expect(source).to_contain("return run_rt_native_build(args)")
        expect(source).to_contain("if explicit_entry != \"src/app/cli/main.spl\":")
        expect(source).to_contain("if mode != \"one-binary\":")
        expect(source).to_contain("env_set(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\", \"1\")")
        expect(source).to_contain("aot_native_project_with_backend_fixed(")
        expect(source).to_contain("env_set(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\", \"0\")")
        expect(source).to_contain("\"\", \"\", \"\", \"\", \"\", 0,")
        expect(source.contains("\"src/compiler\", \"src/app\", \"src/lib\", \"examples/10_tooling\", \"\", 4,")).to_equal(false)
        expect(source.contains("if native_build_has_explicit_entry(args) == 1:")).to_equal(false)
        expect(api_source).to_contain("use compiler.driver.driver.{compiler_driver_create, compiler_driver_run_compile}")
        expect(driver_source).to_contain("var closure_seen_mods = _driver_text_bucket_set_new(8192)")
        expect(driver_source).to_contain("var closure_scanned_paths = _driver_text_bucket_set_new(8192)")
        expect(driver_source).to_contain("if _driver_text_bucket_set_has(closure_scanned_paths, closure_physical_key):")
        expect(driver_source).to_contain("closure_scanned_paths = _driver_text_bucket_set_add(closure_scanned_paths, closure_physical_key)")
        expect(driver_source).to_contain("_driver_collect_entry_import_source(closure_file)")

    it "propagates entry-closure state into the bootstrap runtime":
        val source = bootstrap_main_source()

        expect(source).to_contain("fn native_build_has_entry_closure(args: [text]) -> i64:")
        expect(source).to_contain("val old_entry_closure = env_get(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\")")
        expect(source).to_contain("env_set(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\", \"1\")")
        expect(source).to_contain("val result = rt_native_build(args)")
        expect(source).to_contain("env_set(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\", old_entry_closure)")
        expect(source).to_contain("return run_rt_native_build(args)")

    it "uses the interpreter and codegen canonical CLI argument extern":
        val source = bootstrap_main_source()

        expect(source).to_contain("extern fn sys_get_args() -> [text]")
        expect(source).to_contain("sys_get_args()")
        expect(source.contains("extern fn rt_get_args() -> [text]")).to_equal(false)

    it "resolves closure aliases, terminal symbols, and relative modules":
        expect(_driver_resolve_entry_import("compiler.core.parser", "src/app/cli")).to_equal("src/compiler/10.frontend/core/parser.spl")
        expect(_driver_resolve_entry_import("compiler.backend.backend_api", "src/app/cli")).to_equal("src/compiler/70.backend/backend/backend_api.spl")
        expect(_driver_resolve_entry_import("std.test_runner.test_runner_args.parse_test_args", "src/app/cli")).to_equal("src/lib/nogc_async_mut/test_runner/test_runner_args.spl")
        expect(_driver_resolve_entry_import("app.ui.browser.app", "src/app/cli")).to_equal("src/app/ui.browser/app.spl")
        expect(_driver_resolve_entry_import(".types", "src/compiler/40.mono/monomorphize")).to_equal("src/compiler/40.mono/monomorphize/types.spl")

    it "loads an explicitly imported command excluded only from bulk scans":
        val loaded = _driver_collect_entry_import_source("src/app/cli/check.spl")
        expect(loaded.len()).to_be_greater_than(0)

    it "preserves dedents after generic field types":
        val parser = rt_file_read_text("src/compiler/10.frontend/core/parser.spl") ?? ""
        val lexer = rt_file_read_text("src/compiler/10.frontend/core/lexer.spl") ?? ""

        expect(parser).to_contain("lex_mark_current_token_as_generic_close()")
        expect(parser).to_contain("parser_expect(TOK_GT)")
        expect(lexer).to_contain("loaded.next_token_after_generic_close()")

    it "constructs bootstrap frontend maps before key iteration (bug #185)":
        # These files execute live during the self-hosted Stage4 frontend.
        # Explicit builtin construction avoids malformed native `{}` values;
        # the seed interpreter recognizes Map/Dict aliases as empty dicts.
        val assembly = rt_file_read_text("src/compiler/10.frontend/_FlatAstBridge/module_assembly.spl") ?? ""
        val empty_module = rt_file_read_text("src/compiler/10.frontend/_FlatAstBridge/convert_nodes.spl") ?? ""
        val desugar = rt_file_read_text("src/compiler/10.frontend/desugar/desugar_async.spl") ?? ""

        expect(assembly).to_contain("var functions: Dict<text, Function> = Map.new()")
        expect(assembly).to_contain("actors: Map.new()")
        expect(empty_module).to_contain("functions: Map.new()")
        expect(desugar).to_contain("var desugared_functions: Dict<text, Function> = Map.new()")
        expect(desugar).to_contain("var generated_helper_functions: Dict<text, Function> = Map.new()")

    it "reuses flat AST arena storage between Stage4 module parses":
        val bootstrap = rt_file_read_text("src/app/cli/bootstrap_main.spl") ?? ""
        val state = rt_file_read_text("src/compiler/10.frontend/core/_Ast/module_state.spl") ?? ""
        val expressions = rt_file_read_text("src/compiler/10.frontend/core/_AstExpr/nodes.spl") ?? ""
        val expression_accessors = rt_file_read_text("src/compiler/10.frontend/core/_AstExpr/accessors.spl") ?? ""
        val statements = rt_file_read_text("src/compiler/10.frontend/core/ast_stmt.spl") ?? ""

        expect(state).to_contain("decl_tag.clear()")
        expect(state).to_contain("decl_body_stmts.clear()")
        expect(state).to_contain("module_decl_slots.clear()")
        expect(state).to_contain("lexer_state_core_pos_slot[0] = \"0\"")
        expect(expressions).to_contain("expr_tag.clear()")
        expect(statements).to_contain("stmt_tag.clear()")
        expect(statements).to_contain("stmt_gpu_grid_exprs.clear()")
        expect(bootstrap).to_contain("val old_native_arena_decls = env_get(\"SIMPLE_NATIVE_ARENA_DECLS\")")
        expect(bootstrap).to_contain("env_set(\"SIMPLE_NATIVE_ARENA_DECLS\", \"1\")")
        expect(bootstrap).to_contain("env_set(\"SIMPLE_NATIVE_ARENA_DECLS\", old_native_arena_decls)")
        expect(expressions).to_contain("if expr_env_mirror_enabled():")
        expect(expressions).to_contain("expr_env_read(expr_key(idx, field))")
        expect(expression_accessors).to_contain("val direct = expr_env_read(expr_key(idx, \"TAG\"))")
        expect(statements).to_contain("if stmt_env_mirror_enabled():")
        expect(statements).to_contain("val direct = stmt_env_read(stmt_key(idx, \"TAG\"))")
        # One allocation remains only in each native-zero-init guard; the hot
        # reset path must not replace the arena again.
        expect(state.split("decl_tag = []").len()).to_equal(2)
        expect(expressions.split("expr_tag = []").len()).to_equal(2)
        expect(statements.split("stmt_tag = []").len()).to_equal(2)
