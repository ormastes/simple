extern fn rt_file_read_text(path: text) -> text

describe "bootstrap single-file native build transport":
    it "seeds scalar entry slots before import closure discovery":
        val source = rt_file_read_text("src/app/cli/bootstrap_main.spl") ?? ""
        expect(source).to_contain("options.input_files = [entry_path]")
        expect(source).to_contain("options.bootstrap_input_count = 1")
        expect(source).to_contain("options.bootstrap_input_0 = entry_path")
        expect(source).to_contain("env_set(\"SIMPLE_NATIVE_BUILD_ENTRY\", entry_path)")
        expect(source).to_contain("env_set(\"SIMPLE_NATIVE_BUILD_ENTRY_CLOSURE\", \"0\")")
        expect(source).to_contain("options.opt_level = 3")
        expect(source).to_contain("fn run_compile_bootstrap(args: [text]) -> i64:")
        expect(source).to_contain("options.output_format = driver_output_format_smf()")
        expect(source).to_contain("fn bootstrap_compile_option_takes_value(arg: text) -> bool:")
        expect(source).to_contain("file_size(output)")
        expect(source.contains("app.io._CliCompile.compile_options")).to_equal(false)
