use std.io_runtime.{file_read}

describe "SPipe docgen full-CLI dispatch":
    it "calls the compiled tool instead of interpreting or delegating its entry file":
        val commands = file_read("src/app/io/_CliCommands/run_commands.spl")
        val common = file_read("src/app/spipe_docgen/spipe_docgen/common.spl")

        expect(commands).to_contain("use app.spipe_docgen.spipe_docgen.main.{run_spipe_docgen}")
        expect(commands).to_contain("run_spipe_docgen(run_args)")
        expect(commands.contains("cli_run_file(\"src/app/spipe_docgen/main.spl\"")).to_be(false)
        expect(common).to_contain("use std.io_runtime.{dir_create_all}")
        expect(common.contains("use app.io.mod.{process_run}")).to_be(false)

    it "keeps deployment admission pinned to docgen and clocked VHDL":
        val smoke = file_read("scripts/check/check-bootstrap-essential-tools-smoke.shs")
        val surfaces = file_read("src/app/cli/surface_alignment.spl")

        expect(smoke).to_contain("essential_spipe_docgen_smoke=true")
        expect(smoke).to_contain("essential_vhdl_clocked_smoke=true")
        expect(smoke).to_contain("clocked_labeled_tuple.spl")
        expect(surfaces).to_contain("name: \"spipe-docgen\", kind: \"direct\"")
