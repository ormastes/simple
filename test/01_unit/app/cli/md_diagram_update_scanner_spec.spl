use app.md_diagram_update.scanner.{scan_diagram_regions}

fn _region(id: text) -> text:
    ["<!-- sdn-diagram:id=" + id + " -->", "```sdn", "A: A", "```", "<!-- sdn-diagram:end -->"].join("\n")

fn _region_no_space_close(id: text) -> text:
    ["<!-- sdn-diagram:id=" + id + "-->", "```sdn", "A: A", "```", "<!-- sdn-diagram:end -->"].join("\n")

describe "md-diagram-update scanner":
    it "extracts normal diagram marker ids":
        val normal = scan_diagram_regions(_region("doc.arch"))
        expect(normal.len()).to_equal(1)
        expect(normal[0].id).to_equal("doc.arch")

    it "extracts marker ids without a space before comment close":
        val no_space_close = scan_diagram_regions(_region_no_space_close("doc.arch"))
        expect(no_space_close.len()).to_equal(1)
        expect(no_space_close[0].id).to_equal("doc.arch")

    it "ignores blank diagram marker ids":
        val blank = scan_diagram_regions(_region(""))
        expect(blank.len()).to_equal(0)

    it "ignores whitespace diagram marker ids":
        val whitespace = scan_diagram_regions(_region("doc arch"))
        expect(whitespace.len()).to_equal(0)

    it "ignores diagram marker ids with fence syntax injection characters":
        val quote = scan_diagram_regions(_region("doc\"arch"))
        val backtick = scan_diagram_regions(_region("doc`arch"))
        val equals = scan_diagram_regions(_region("doc=arch"))
        expect(quote.len()).to_equal(0)
        expect(backtick.len()).to_equal(0)
        expect(equals.len()).to_equal(0)

    it "ignores diagram marker ids without a comment close":
        val missing_close = scan_diagram_regions(["<!-- sdn-diagram:id=doc.arch", "```sdn", "A: A", "```", "<!-- sdn-diagram:end -->"].join("\n"))
        expect(missing_close.len()).to_equal(0)
