extern fn rt_file_read_text(path: text) -> text

describe "_CliMain main_and_help depth guard":
    it "defaults malformed test depth parsing":
        val source = rt_file_read_text("src/app/cli/_CliMain/main_and_help.spl") ?? ""

        expect(source).to_contain("_depth_str.to_int() ?? 0")
        expect(source.contains("_depth_str.to_int()\n")).to_equal(false)

    it "keeps the Stage4 test bridge scalar-only across the mixed array ABI":
        val source = rt_file_read_text("src/app/cli/_CliMain/main_and_help.spl") ?? ""
        val io_source = rt_file_read_text("src/app/io/cli_ops.spl") ?? ""

        expect(source).to_contain("return cli_run_tests_process_args(flags.gc_log, flags.gc_off)")
        expect(source.contains("return cli_run_tests(test_args, flags.gc_log, flags.gc_off)")).to_equal(false)
        expect(io_source).to_contain("extern fn rt_cli_run_tests_process_args(gc_log: bool, gc_off: bool) -> i64")
        expect(io_source).to_contain("rt_cli_run_tests_process_args(gc_log, gc_off)")
