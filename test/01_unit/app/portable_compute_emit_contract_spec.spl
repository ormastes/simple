use std.spec.*
use std.io_runtime.{file_read}

describe "portable compute emitter target aliases":
    it "routes canonical rocm and the hip alias through one HIP emitter":
        val source = file_read("src/app/portable_compute_emit/main.spl")
        val spipe = file_read(".codex/skills/sp_dev/SKILL.md")
        val system_test = file_read(".codex/skills/system_test/SKILL.md")
        expect(source).to_contain("<cuda|hip|rocm|opencl|metal|webgpu|vulkan>")
        expect(source).to_contain("target == \"hip\" or target == \"rocm\"")
        expect(source).to_contain("return emit_portable(PortableComputeTarget.Hip)")
        expect(spipe).to_contain("Use canonical target name `rocm`; accept `hip` only")
        expect(system_test).to_contain("canonical target `rocm`")
