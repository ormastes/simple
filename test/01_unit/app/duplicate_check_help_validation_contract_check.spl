use compiler.tools.duplicate_check.main.{run_duplicate_check}

extern fn rt_exit(code: i32)

val help_exit = run_duplicate_check(["duplicate-check", "--help"])
val mixed_help_exit = run_duplicate_check(["duplicate-check", "--help", "--bogus"])

if help_exit != 0:
    print "FAIL: sole --help did not return 0"
    rt_exit(1)
if mixed_help_exit != 2:
    print "FAIL: mixed --help did not return 2"
    rt_exit(1)

print "PASS: duplicate-check help validation contract"
rt_exit(0)
