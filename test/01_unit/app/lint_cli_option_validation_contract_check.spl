use app.io.cli_lint_commands.{run_lint_command}

extern fn rt_exit(code: i32)

val clean = "test/fixtures/lint/clean.spl"
val unknown_exit = run_lint_command(["lint", clean, "--bogus"])
val missing_profile_exit = run_lint_command(["lint", clean, "--profile"])
val empty_profile_exit = run_lint_command(["lint", clean, "--profile="])
val json_unknown_exit = run_lint_command(["lint", clean, "--json", "--bogus"])
val help_exit = run_lint_command(["lint", "--help"])
val help_bogus_exit = run_lint_command(["lint", "--help", "--bogus"])
val help_file_exit = run_lint_command(["lint", "--help", clean])
val help_profile_exit = run_lint_command(["lint", "--help", "--profile=reliable"])

if unknown_exit != 2 or missing_profile_exit != 2 or empty_profile_exit != 2 or json_unknown_exit != 2 or help_exit != 0 or help_bogus_exit != 2 or help_file_exit != 2 or help_profile_exit != 2:
    print "FAIL: lint option validation or mixed-help contract failed"
    rt_exit(1)

print "PASS: lint rejects invalid options before honoring help"
rt_exit(0)
