use app.io.cli_lint_commands.{run_lint_command}

extern fn rt_exit(code: i32)

val clean = "test/fixtures/lint/clean.spl"
val unknown_exit = run_lint_command(["lint", clean, "--bogus"])
val missing_profile_exit = run_lint_command(["lint", clean, "--profile"])
val empty_profile_exit = run_lint_command(["lint", clean, "--profile="])
val json_unknown_exit = run_lint_command(["lint", clean, "--json", "--bogus"])

if unknown_exit != 2 or missing_profile_exit != 2 or empty_profile_exit != 2 or json_unknown_exit != 2:
    print "FAIL: lint accepted an unknown option or missing profile tier"
    rt_exit(1)

print "PASS: lint rejects unknown options and missing profile tiers with exit 2"
rt_exit(0)
