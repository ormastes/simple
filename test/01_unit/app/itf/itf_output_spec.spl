# @cover src/app/itf/output.spl 60%
#
# output.spl helpers that don't need a tty/network: size formatting and the
# dynamic-width table column-sizing used by `itf github` listings.
#
# should_page() is pure by design specifically so it can be unit-tested here
# without ever spawning a real pager subprocess (see _emit_lines()'s
# docstring in output.spl for the hang risk that would come with testing
# the side-effecting path directly).

use app.itf.output.{format_size, _table_col_widths, _visible_len, _pad_visible, relative_time_at, format_transfer_summary, should_page, resolve_pager_cmd, _split_pager_cmd}

extern fn rt_env_get(key: text) -> text?
extern fn rt_env_set(key: text, value: text) -> bool


describe "format_size":

    it "shows byte counts under 1 KiB as-is":
        expect(format_size(0)).to_equal("0 B")
        expect(format_size(512)).to_equal("512 B")
        expect(format_size(1023)).to_equal("1023 B")

    it "formats KiB with one decimal":
        expect(format_size(1024)).to_equal("1.0 KiB")
        expect(format_size(1536)).to_equal("1.5 KiB")

    it "formats MiB with one decimal":
        expect(format_size(1048576)).to_equal("1.0 MiB")
        expect(format_size(134217728)).to_equal("128.0 MiB")

    it "formats GiB with one decimal":
        expect(format_size(1073741824)).to_equal("1.0 GiB")

    it "formats TiB with one decimal":
        expect(format_size(1099511627776)).to_equal("1.0 TiB")

    it "passes through a negative (unknown) size unchanged":
        expect(format_size(-1)).to_equal("-1")


describe "_table_col_widths (dynamic-width table sizing)":

    it "seeds each column width from the header when rows are shorter":
        val widths = _table_col_widths(["NUMBER", "TITLE"], [["#1", "x"]])
        expect(widths[0]).to_equal(6)
        expect(widths[1]).to_equal(5)

    it "grows a column width to fit the longest cell":
        val widths = _table_col_widths(["NUMBER", "TITLE"], [["#1", "a very long title indeed"]])
        expect(widths[0]).to_equal(6)
        expect(widths[1]).to_equal(24)

    it "takes the max across multiple rows":
        val widths = _table_col_widths(["K"], [["short"], ["a much longer value"]])
        expect(widths[0]).to_equal(19)


describe "_visible_len / _pad_visible (ANSI-aware table alignment)":
    # Regression coverage for a real bug found in review: colorize_state()
    # wraps a word in `\x1b[32m...\x1b[0m`, and feeding that straight into
    # _table_col_widths/pad_right (both byte-length-based) inflated the
    # measured width by the escape-code bytes — misaligning STATE/AUTHOR/
    # UPDATED columns in `itf github issue list` whenever color was on.

    it "counts an ANSI-colored word by its visible characters, not its byte length":
        val colored = "\u{001b}[32mOPEN\u{001b}[0m"
        expect(_visible_len(colored)).to_equal(4)

    it "matches plain-text length when there is no escape code":
        expect(_visible_len("CLOSED")).to_equal(6)

    it "_table_col_widths measures colored cells by visible width, not byte length":
        val colored_open = "\u{001b}[32mOPEN\u{001b}[0m"
        val colored_closed = "\u{001b}[2mCLOSED\u{001b}[0m"
        val widths = _table_col_widths(["STATE"], [[colored_open], [colored_closed]])
        # Visible widths are 4 ("OPEN") and 6 ("CLOSED"); header "STATE" is 5.
        # Max visible width must be 6 — not the byte-inflated 13/14 that
        # `.len()` would have measured before this fix.
        expect(widths[0]).to_equal(6)

    it "_pad_visible pads a colored cell to the same visible width as a plain one":
        val colored = "\u{001b}[32mOPEN\u{001b}[0m"
        val padded_colored = _pad_visible(colored, 6)
        val padded_plain = _pad_visible("AB", 6)
        # Both should have 4 trailing spaces after their visible content —
        # i.e. same total visible width once the escape codes are stripped.
        expect(_visible_len(padded_colored)).to_equal(6)
        expect(_visible_len(padded_plain)).to_equal(6)
