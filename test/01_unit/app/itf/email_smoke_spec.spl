# Smoke spec — just proves cmd_email.spl compiles/loads and the basic
# no-args / unknown-command / no-account paths work. Full fake-binary
# coverage lives in email_cmd_spec.spl.

use app.itf.cmd_email.{handle_email}


describe "cmd_email smoke":

    it "prints help and exits 0 with no args":
        expect(handle_email([])).to_equal(0)

    it "exits 1 for an unknown subcommand (before touching any config)":
        expect(handle_email(["bogus"])).to_equal(1)
