# @cover src/app/itf/cmd_api.spl 60%
#
# `itf api` (J2): pure-function coverage for the parts that don't need a
# live network call. cmd_api.spl now sends requests via
# std.nogc_sync_mut.io.http_sffi.rt_http_request (the real extern-backed
# transport — the prior std.nogc_sync_mut.http_client-based version only
# ever built a request tuple and never sent it, see cmd_api.spl's header
# comment), so the actual send isn't exercised here — only the pure
# URL-resolution and header-building helpers it calls first, plus the
# --jira/confluence REST base builders in auth.spl.

use app.itf.cmd_api.{_resolve_api_url, _build_api_headers}
use app.itf.auth.{jira_api_base, confluence_api_base}
use app.itf.config.{ItfConfig}


describe "_resolve_api_url":

    it "prefixes a relative path with the base":
        expect(_resolve_api_url("/pages?limit=5", "https://x.atlassian.net/wiki/api/v2")).to_equal("https://x.atlassian.net/wiki/api/v2/pages?limit=5")

    it "leaves an absolute URL unchanged even when a base is available":
        expect(_resolve_api_url("https://other.example.com/thing", "https://x.atlassian.net/wiki/api/v2")).to_equal("https://other.example.com/thing")

    it "leaves a relative path unchanged when no base is configured":
        expect(_resolve_api_url("/pages", "")).to_equal("/pages")


describe "_build_api_headers":

    it "always includes Accept: application/json":
        val headers = _build_api_headers("", "", false)
        expect(headers.len()).to_equal(1)
        expect(headers[0]).to_equal("Accept: application/json")

    it "adds Authorization when auth is configured":
        val headers = _build_api_headers("Basic xyz", "", false)
        expect(headers.contains("Authorization: Basic xyz")).to_equal(true)

    it "adds Content-Type when a body is present":
        val headers = _build_api_headers("", "", true)
        expect(headers.contains("Content-Type: application/json")).to_equal(true)

    it "attaches --header verbatim — the fix for the previously-dead flag":
        val headers = _build_api_headers("", "X-Custom: value", false)
        expect(headers.contains("X-Custom: value")).to_equal(true)

    it "combines all four when everything is set":
        val headers = _build_api_headers("Basic xyz", "X-Custom: value", true)
        expect(headers.len()).to_equal(4)


fn _config_with_jira_url(url: text) -> ItfConfig:
    ItfConfig(
        confluence_url: "", confluence_user: "", confluence_default_space: "",
        jira_url: url, jira_acli_path: "acli", jira_email: "",
        default_output: "text", color_mode: "auto",
        editor_override: "", pager_override: "", token_cmds: [],
    )


fn _config_with_confluence_url(url: text) -> ItfConfig:
    ItfConfig(
        confluence_url: url, confluence_user: "", confluence_default_space: "",
        jira_url: "", jira_acli_path: "acli", jira_email: "",
        default_output: "text", color_mode: "auto",
        editor_override: "", pager_override: "", token_cmds: [],
    )


describe "jira_api_base / confluence_api_base (--jira REST base selection)":

    it "jira_api_base appends rest/api/3":
        expect(jira_api_base(_config_with_jira_url("https://x.atlassian.net"))).to_equal("https://x.atlassian.net/rest/api/3")

    it "jira_api_base handles a trailing slash":
        expect(jira_api_base(_config_with_jira_url("https://x.atlassian.net/"))).to_equal("https://x.atlassian.net/rest/api/3")

    it "jira_api_base is empty when jira.url isn't configured":
        expect(jira_api_base(_config_with_jira_url(""))).to_equal("")

    it "confluence_api_base still appends api/v2 (default, unchanged by --jira)":
        expect(confluence_api_base(_config_with_confluence_url("https://x.atlassian.net/wiki"))).to_equal("https://x.atlassian.net/wiki/api/v2")
