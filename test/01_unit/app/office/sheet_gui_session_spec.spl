"""Sheet GUI session spec: cell selection + cell edit + recalculation.

SheetGuiSession (session_new/session_select/session_edit) plus
sheet_gui_view_with_selection are the first sheet-GUI INTERACTION: select a
cell (marks it in the dump with "[...]" brackets and, per gui.spl's
office_gui_sheet_session_pixels, the widget carries the framework's real
"focused" CSS class), edit a cell's raw content (recalculates every formula
cell and returns a NEW session -- copy semantics, callers reassign), and
selection survives an edit.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.file_formats.{recalculate_formula_cells}
use app.office.gui.{session_new, session_select, session_edit, sheet_gui_view_with_selection, session_click, sheet_gui_cell_click_point, session_key}
use common.ui.layout.{compute_layout, find_rect}

fn _dump_contains(haystack: text, needle: text) -> bool:
    """Substring check via index_of's Option -- matches html_widgets.spl's
    text_contains idiom (avoids a bare-boolean `==` assertion, which the
    test runner silently no-ops)."""
    val idx = haystack.index_of(needle)
    match idx:
        case Some(_):
            return true
        case _:
            return false

fn _demo_sheet() -> Sheet:
    """A2/B2/C2/D2 form a =B2*C2 product row; D5 sums D2:D3, so editing B2
    ripples into both D2 and D5."""
    var sheet = Sheet.new("S1")
    sheet.set_value("A2", "Widget")
    sheet.set_value("B2", "10")
    sheet.set_value("C2", "2")
    sheet.set_value("D2", "=B2*C2")
    sheet.set_value("A3", "Gadget")
    sheet.set_value("B3", "20")
    sheet.set_value("C3", "3")
    sheet.set_value("D3", "=B3*C3")
    sheet.set_value("D5", "=SUM(D2:D3)")
    sheet = recalculate_formula_cells(sheet)
    sheet

fn _demo_sheet_with_hidden_row() -> Sheet:
    """Like _demo_sheet, but row 4 (blank in _demo_sheet) is hidden -- the
    fixture for arrow-key hidden-row-skip coverage below."""
    var sheet = _demo_sheet()
    sheet.hide_row(4)
    sheet

describe "session_select: marks the right cell":

    it "brackets the selected cell's text and leaves other cells plain":
        val session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("[20]")
        assert_false(_dump_contains(view.text_dump, "[10]"))
        assert_false(_dump_contains(view.text_dump, "[2]"))

    it "re-selecting a different ref moves the bracket":
        var session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        session = session_select(session, "B2")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("[10]")
        assert_false(_dump_contains(view.text_dump, "[20]"))

describe "session_edit: updates the cell":

    it "a plain-value cell shows its new text after edit":
        var session = session_new(_demo_sheet(), "A2")
        session = session_edit(session, "A2", "Sprocket")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("Sprocket")
        assert_false(_dump_contains(view.text_dump, "Widget"))

describe "session_edit: dependent formula cells recalculate":

    it "editing B2 from 10 to 40 recalculates D2 (=B2*C2) and D5 (=SUM(D2:D3))":
        var session = session_new(_demo_sheet(), "D2")
        val before = sheet_gui_view_with_selection(session, 5, 4)
        expect(before.text_dump).to_contain("[20]")

        session = session_edit(session, "B2", "40")
        val after = sheet_gui_view_with_selection(session, 5, 4)
        expect(after.text_dump).to_contain("[80]")
        expect(after.text_dump).to_contain("140")
        assert_false(_dump_contains(after.text_dump, "[20]"))

describe "session_edit: selection survives an edit":

    it "the selected_ref is unchanged after editing a different cell":
        var session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        session = session_edit(session, "B2", "40")
        expect(session.selected_ref).to_equal("D2")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("[80]")

describe "session_edit: editing a formula cell replaces the formula":

    it "overwriting D2 (=B2*C2) with a literal drops the formula entirely":
        var session = session_new(_demo_sheet(), "D2")
        session = session_edit(session, "D2", "999")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("999")
        assert_false(_dump_contains(view.text_dump, "=B2*C2"))
        # D5 (=SUM(D2:D3)) now sums the literal 999 + D3's 60, not 20 + 60
        expect(view.text_dump).to_contain("1059")

describe "pointer selection":
    """Real event-dispatch coverage for the office_gui_no_per_cell_click_
    target_2026-07-04.md gap: session_click builds the tree, routes a
    genuine UIEvent.Resize + UIEvent.MouseEvent("down") through common.ui.
    event's process_event/handle_pointer, and reads the hit widget id back
    off state.focused_id -- no parallel coordinate mapper."""

    it "a click computed to land on cell B2 selects B2":
        val session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        val point = sheet_gui_cell_click_point(view, "B2", 640, 480)
        val click_x = point.0
        val click_y = point.1
        assert_true(click_x >= 0)
        assert_true(click_y >= 0)

        val clicked = session_click(session, click_x, click_y, 5, 4, 640, 480)
        expect(clicked.selected_ref).to_equal("B2")
        val clicked_view = sheet_gui_view_with_selection(clicked, 5, 4)
        expect(clicked_view.text_dump).to_contain("[10]")
        assert_false(_dump_contains(clicked_view.text_dump, "[20]"))

    it "a click outside the rendered viewport leaves the selection unchanged":
        val session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        # (-10, -10) is outside every widget's rect at this viewport (the
        # tree's root rect itself starts at (0, 0)) -- handle_pointer's
        # hit-test finds nothing, so the real click-miss path (state
        # unchanged) applies, not a fallback stub.
        val clicked = session_click(session, -10, -10, 5, 4, 640, 480)
        expect(clicked.selected_ref).to_equal("D2")

    it "a click on a column-header widget (non-cell id) leaves the selection unchanged":
        val session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        val rects = compute_layout(view.tree.root_node(), 0, 0, 640, 480)
        var header_x = -1
        var header_y = -1
        match find_rect(rects, "sheet_sel_hdr_B"):
            case Some(r):
                header_x = r.x + r.w / 2
                header_y = r.y + r.h / 2
            case _:
                pass
        assert_true(header_x >= 0)
        assert_true(header_y >= 0)

        val clicked = session_click(session, header_x, header_y, 5, 4, 640, 480)
        expect(clicked.selected_ref).to_equal("D2")

    it "clicked-then-edited flow: click selects B2, then editing B2 recalculates D2 and D5":
        var session = session_select(session_new(_demo_sheet(), "D2"), "D2")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        val point = sheet_gui_cell_click_point(view, "B2", 640, 480)
        session = session_click(session, point.0, point.1, 5, 4, 640, 480)
        expect(session.selected_ref).to_equal("B2")

        session = session_edit(session, "B2", "40")
        val after = sheet_gui_view_with_selection(session, 5, 4)
        expect(after.text_dump).to_contain("[40]")
        expect(after.text_dump).to_contain("140")
        assert_false(_dump_contains(after.text_dump, "[10]"))

describe "keyboard":
    """session_key routes arrow-key grid navigation, a typed pending-input
    buffer, and enter/escape/backspace through a thin session-level
    translator -- see gui.spl's "Keyboard interaction" comment block for why
    this is not routed through common.ui.event.process_event (its key
    machinery has no 2D-grid movement and widget_dispatch_key only accepts
    input/textfield widget kinds, never the text_widget kind sheet cells
    use)."""

    it "arrow keys move the selection one cell at a time, looping back to the start":
        var session = session_new(_demo_sheet(), "B2")
        session = session_key(session, "down", 5, 4)
        expect(session.selected_ref).to_equal("B3")
        session = session_key(session, "right", 5, 4)
        expect(session.selected_ref).to_equal("C3")
        session = session_key(session, "up", 5, 4)
        expect(session.selected_ref).to_equal("C2")
        session = session_key(session, "left", 5, 4)
        expect(session.selected_ref).to_equal("B2")

    it "arrow keys clamp at the grid's top-left edge instead of moving off-grid":
        var session = session_new(_demo_sheet(), "A1")
        session = session_key(session, "up", 5, 4)
        expect(session.selected_ref).to_equal("A1")
        session = session_key(session, "left", 5, 4)
        expect(session.selected_ref).to_equal("A1")

    it "down/up skip a hidden row instead of landing on it":
        val hidden_sheet = _demo_sheet_with_hidden_row()
        var session = session_new(hidden_sheet, "B3")
        session = session_key(session, "down", 5, 4)
        expect(session.selected_ref).to_equal("B5")
        session = session_key(session, "up", 5, 4)
        expect(session.selected_ref).to_equal("B3")

    it "typing accumulates a pending buffer, shown as ref:buffer in the dump":
        var session = session_new(_demo_sheet(), "B3")
        session = session_key(session, "9", 5, 4)
        var view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("B3:9")
        session = session_key(session, "9", 5, 4)
        view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("B3:99")
        assert_false(_dump_contains(view.text_dump, "[20]"))

    it "enter commits the pending buffer and recalculates dependent formula cells":
        var session = session_new(_demo_sheet(), "B3")
        session = session_key(session, "9", 5, 4)
        session = session_key(session, "9", 5, 4)
        session = session_key(session, "enter", 5, 4)
        expect(session.pending_input).to_equal("")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("[99]")
        expect(view.text_dump).to_contain("297")
        expect(view.text_dump).to_contain("317")
        assert_false(_dump_contains(view.text_dump, "[20]"))

    it "escape cancels the pending buffer without committing or changing the sheet":
        var session = session_new(_demo_sheet(), "B3")
        session = session_key(session, "9", 5, 4)
        session = session_key(session, "escape", 5, 4)
        expect(session.pending_input).to_equal("")
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("[20]")
        assert_false(_dump_contains(view.text_dump, "B3:9"))

    it "backspace trims the last character off the pending buffer":
        var session = session_new(_demo_sheet(), "B3")
        session = session_key(session, "9", 5, 4)
        session = session_key(session, "9", 5, 4)
        session = session_key(session, "backspace", 5, 4)
        val view = sheet_gui_view_with_selection(session, 5, 4)
        expect(view.text_dump).to_contain("B3:9")
        assert_false(_dump_contains(view.text_dump, "B3:99"))
