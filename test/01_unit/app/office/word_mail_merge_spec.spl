"""Mail merge spec.

Verifies field discovery, per-row placeholder substitution (via
edit_ops.document_replace, so span styling is preserved), missing-column
handling, batch merge across all data rows, and markdown rendering of the
merged batch. Template document comes from markdown; data source is a Sheet
built with set_value (header row 1 + 2 data rows)."""

use std.spec
use app.office.file_formats.{parse_markdown_document, document_to_markdown}
use app.office.word.mail_merge.{merge_fields, merge_document, merge_all, merge_all_markdown}
use app.office.sheets.spreadsheet.{Sheet}
use common.rich_text.attributed_text.{RichDocument, InlineStyle}

# Placeholder braces must never appear as a literal "{{" in Simple string
# source (it would be parsed as interpolation) — build them by concatenation.
fn _ph(field: text) -> text:
    "{" + "{" + field + "}" + "}"

fn _template_md() -> text:
    val name_ph = _ph("Name")
    val city_ph = _ph("City")
    val zip_ph = _ph("Zip")
    "Dear " + name_ph + ",\n\n**" + city_ph + "** awaits you, " + name_ph + "!\n\nYour code: " + zip_ph

fn _template_doc() -> RichDocument:
    parse_markdown_document(_template_md(), "letter")

fn _data_sheet() -> Sheet:
    var sh = Sheet.new("recipients")
    sh.set_value("A1", "Name")
    sh.set_value("B1", "City")
    sh.set_value("A2", "Alice")
    sh.set_value("B2", "Paris")
    sh.set_value("A3", "Bob")
    sh.set_value("B3", "Tokyo")
    sh

val _row1_expected = "Dear Alice,\n\n**Paris** awaits you, Alice!\n\nYour code: "
val _row2_expected = "Dear Bob,\n\n**Tokyo** awaits you, Bob!\n\nYour code: "

describe "merge_fields: discover placeholders":
    """Distinct {field} names in document order, first occurrence wins."""

    it "returns distinct field names in document order":
        val doc = _template_doc()
        val fields = merge_fields(doc)
        expect(fields.len()).to_equal(3)
        expect(fields.get(0)).to_equal("Name")
        expect(fields.get(1)).to_equal("City")
        expect(fields.get(2)).to_equal("Zip")

    it "returns empty list for a document with no placeholders":
        val doc = parse_markdown_document("Plain text, no fields here.", "plain")
        val fields = merge_fields(doc)
        expect(fields.len()).to_equal(0)

describe "merge_document: substitute one data row":
    """Row N (1-based data row) reads sheet row N+1; row 1 = sheet row 2."""

    it "substitutes every field for row 1":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val merged = merge_document(doc, sheet, 1)
        val md = document_to_markdown(merged)
        expect(md).to_equal(_row1_expected)

    it "substitutes independently for row 2":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val merged = merge_document(doc, sheet, 2)
        val md = document_to_markdown(merged)
        expect(md).to_equal(_row2_expected)

    it "preserves bold styling around a merged placeholder":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val merged = merge_document(doc, sheet, 1)
        val block1 = merged.blocks.get(1)
        val span0 = block1.spans.get(0)
        expect(span0.text).to_equal("Paris")
        expect(span0.style).to_equal(InlineStyle.Bold)
        val span1 = block1.spans.get(1)
        expect(span1.text).to_equal(" awaits you, Alice!")
        expect(span1.style).to_equal(InlineStyle.Normal)

    it "substitutes missing-column field with empty string":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val merged = merge_document(doc, sheet, 1)
        val block2 = merged.blocks.get(2)
        val span0 = block2.spans.get(0)
        expect(span0.text).to_equal("Your code: ")

    it "does not mutate the original template document":
        val doc = _template_doc()
        val sheet = _data_sheet()
        merge_document(doc, sheet, 1)
        val original_md = document_to_markdown(doc)
        expect(original_md).to_equal(_template_md())

describe "merge_all: one document per data row":
    """Batch merges every data row (sheet rows below the header)."""

    it "returns one merged document per data row":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val docs = merge_all(doc, sheet)
        expect(docs.len()).to_equal(2)

    it "each merged document matches the per-row merge_document result":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val docs = merge_all(doc, sheet)
        val md0 = document_to_markdown(docs.get(0))
        val md1 = document_to_markdown(docs.get(1))
        expect(md0).to_equal(_row1_expected)
        expect(md1).to_equal(_row2_expected)

describe "merge_all_markdown: rendered batch output":
    """Merged docs rendered to markdown, joined by a '---' separator line."""

    it "joins merged documents with the separator":
        val doc = _template_doc()
        val sheet = _data_sheet()
        val out = merge_all_markdown(doc, sheet)
        val expected = _row1_expected + "\n\n---\n\n" + _row2_expected
        expect(out).to_equal(expected)
