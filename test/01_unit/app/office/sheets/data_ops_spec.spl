"""Office sheets data operations spec.

Comprehensive tests for sheet_sort_range and sheet_filter_rows.
Tests numeric sorting, text sorting, header preservation, and filtering.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.data_ops.{sheet_sort_range, sheet_filter_rows, sheet_autofilter, sheet_clear_filter}
use app.office.sheets.cell.{CellValue, cell_display_text}
use app.office.file_formats.{recalculate_formula_cells}

describe "sheet_sort_range: numeric sorting":
    """Sort rows by numeric column, ascending and descending."""

    it "sorts numeric values ascending":
        var sheet = Sheet.new("S1")
        # Simple numeric data: 30, 10, 20
        sheet.set_value("A1", "30")
        sheet.set_value("A2", "10")
        sheet.set_value("A3", "20")
        # Also set B column to track row movement
        sheet.set_value("B1", "X")
        sheet.set_value("B2", "Y")
        sheet.set_value("B3", "Z")

        val sorted = sheet_sort_range(sheet, "A1:B3", 0, true, false)

        # Expected: A should be 10, 20, 30
        val a1_cell = sorted.get_cell("A1")
        match a1_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 10.0)
            _:
                assert_true(false)

        val a2_cell = sorted.get_cell("A2")
        match a2_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 20.0)
            _:
                assert_true(false)

        val a3_cell = sorted.get_cell("A3")
        match a3_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 30.0)
            _:
                assert_true(false)

    it "sorts numeric values descending":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "5")
        sheet.set_value("A2", "15")
        sheet.set_value("A3", "10")

        val sorted = sheet_sort_range(sheet, "A1:A3", 0, false, false)

        # Expected: 15, 10, 5
        val a1_cell = sorted.get_cell("A1")
        match a1_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 15.0)
            _:
                assert_true(false)

        val a2_cell = sorted.get_cell("A2")
        match a2_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 10.0)
            _:
                assert_true(false)

        val a3_cell = sorted.get_cell("A3")
        match a3_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 5.0)
            _:
                assert_true(false)

describe "sheet_sort_range: text sorting":
    """Sort rows by text column."""

    it "sorts text values lexicographically":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "charlie")
        sheet.set_value("A2", "alice")
        sheet.set_value("A3", "bob")

        val sorted = sheet_sort_range(sheet, "A1:A3", 0, true, false)

        # Expected: alice, bob, charlie
        val a1_cell = sorted.get_cell("A1")
        match a1_cell.value:
            CellValue.TextVal(v):
                assert_true(v.lower() == "alice")
            _:
                assert_true(false)

        val a2_cell = sorted.get_cell("A2")
        match a2_cell.value:
            CellValue.TextVal(v):
                assert_true(v.lower() == "bob")
            _:
                assert_true(false)

        val a3_cell = sorted.get_cell("A3")
        match a3_cell.value:
            CellValue.TextVal(v):
                assert_true(v.lower() == "charlie")
            _:
                assert_true(false)

describe "sheet_sort_range: header preservation":
    """First row should remain in place when has_header is true."""

    it "preserves header row at top when has_header=true":
        var sheet = Sheet.new("S1")
        # Header row
        sheet.set_value("A1", "Name")
        sheet.set_value("B1", "Score")
        # Data rows (to be sorted)
        sheet.set_value("A2", "30")
        sheet.set_value("B2", "Alice")
        sheet.set_value("A3", "10")
        sheet.set_value("B3", "Bob")

        val sorted = sheet_sort_range(sheet, "A1:B3", 0, true, true)

        # Row 1 should still be Name/Score
        val a1_cell = sorted.get_cell("A1")
        match a1_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "Name")
            _:
                assert_true(false)

        val b1_cell = sorted.get_cell("B1")
        match b1_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "Score")
            _:
                assert_true(false)

        # Row 2 should be 10/Bob
        val a2_cell = sorted.get_cell("A2")
        match a2_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 10.0)
            _:
                assert_true(false)

        val b2_cell = sorted.get_cell("B2")
        match b2_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "Bob")
            _:
                assert_true(false)

        # Row 3 should be 30/Alice
        val a3_cell = sorted.get_cell("A3")
        match a3_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 30.0)
            _:
                assert_true(false)

describe "sheet_sort_range: mixed numeric and text":
    """Numbers sort before text in same column."""

    it "sorts numbers before text":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "apple")
        sheet.set_value("A2", "5")
        sheet.set_value("A3", "10")
        sheet.set_value("A4", "banana")

        val sorted = sheet_sort_range(sheet, "A1:A4", 0, true, false)

        # Expected: 5, 10, apple, banana
        val a1_cell = sorted.get_cell("A1")
        match a1_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 5.0)
            _:
                assert_true(false)

        val a2_cell = sorted.get_cell("A2")
        match a2_cell.value:
            CellValue.NumberVal(v):
                assert_true(v == 10.0)
            _:
                assert_true(false)

        val a3_cell = sorted.get_cell("A3")
        match a3_cell.value:
            CellValue.TextVal(v):
                assert_true(v.lower() == "apple")
            _:
                assert_true(false)

        val a4_cell = sorted.get_cell("A4")
        match a4_cell.value:
            CellValue.TextVal(v):
                assert_true(v.lower() == "banana")
            _:
                assert_true(false)

describe "sheet_sort_range: multi-column sort":
    """Sort by a specific column within a multi-column range."""

    it "sorts by second column (key_col=1)":
        var sheet = Sheet.new("S1")
        # Set up a 3-column range where we'll sort by column B (index 1)
        sheet.set_value("A1", "X")
        sheet.set_value("B1", "30")
        sheet.set_value("C1", "red")
        sheet.set_value("A2", "Y")
        sheet.set_value("B2", "10")
        sheet.set_value("C2", "blue")
        sheet.set_value("A3", "Z")
        sheet.set_value("B3", "20")
        sheet.set_value("C3", "green")

        # Sort by column B (the 2nd column, index 1)
        val sorted = sheet_sort_range(sheet, "A1:C3", 1, true, false)

        # After sort by B ascending: row with B=10, B=20, B=30
        val a1_cell = sorted.get_cell("A1")
        match a1_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "Y")
            _:
                assert_true(false)

        val a2_cell = sorted.get_cell("A2")
        match a2_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "Z")
            _:
                assert_true(false)

        val a3_cell = sorted.get_cell("A3")
        match a3_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "X")
            _:
                assert_true(false)

describe "sheet_filter_rows: numeric criteria":
    """Filter rows using numeric comparison operators."""

    it "filters rows with > criteria":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "5")
        sheet.set_value("A2", "15")
        sheet.set_value("A3", "10")
        sheet.set_value("A4", "25")

        val result = sheet_filter_rows(sheet, "A1:A4", 0, ">10")

        # Expected: rows 2 (15) and 4 (25) - these are 1-based
        expect(result.len()).to_equal(2)
        if result.len() >= 2:
            assert_true(result[0] == 2)
            assert_true(result[1] == 4)

    it "filters rows with <= criteria":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "5")
        sheet.set_value("A2", "15")
        sheet.set_value("A3", "10")

        val result = sheet_filter_rows(sheet, "A1:A3", 0, "<=10")

        # Expected: rows 1 (5) and 3 (10)
        expect(result.len()).to_equal(2)
        if result.len() >= 2:
            assert_true(result[0] == 1)
            assert_true(result[1] == 3)

describe "sheet_filter_rows: text criteria":
    """Filter rows using text matching."""

    it "filters rows with bare text (case-insensitive equality)":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "Apple")
        sheet.set_value("A2", "Banana")
        sheet.set_value("A3", "apple")

        val result = sheet_filter_rows(sheet, "A1:A3", 0, "apple")

        # Expected: rows 1 and 3 (case-insensitive match)
        expect(result.len()).to_equal(2)
        if result.len() >= 2:
            assert_true(result[0] == 1)
            assert_true(result[1] == 3)

    it "filters rows with <> (not equal) criteria":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "X")
        sheet.set_value("A2", "Y")
        sheet.set_value("A3", "X")
        sheet.set_value("A4", "Z")

        val result = sheet_filter_rows(sheet, "A1:A4", 0, "<>X")

        # Expected: rows 2 (Y) and 4 (Z)
        expect(result.len()).to_equal(2)
        if result.len() >= 2:
            assert_true(result[0] == 2)
            assert_true(result[1] == 4)

describe "sheet_filter_rows: multi-column filtering":
    """Filter a specific column within a multi-column range."""

    it "filters by column index in a multi-column range":
        var sheet = Sheet.new("S1")
        # 3-column range: A=names, B=scores, C=grades
        sheet.set_value("A1", "Alice")
        sheet.set_value("B1", "85")
        sheet.set_value("C1", "B")
        sheet.set_value("A2", "Bob")
        sheet.set_value("B2", "92")
        sheet.set_value("C2", "A")
        sheet.set_value("A3", "Charlie")
        sheet.set_value("B3", "78")
        sheet.set_value("C3", "C")

        # Filter by column B (index 1): scores >= 85
        val result = sheet_filter_rows(sheet, "A1:C3", 1, ">=85")

        # Expected: rows 1 (85) and 2 (92)
        expect(result.len()).to_equal(2)
        if result.len() >= 2:
            assert_true(result[0] == 1)
            assert_true(result[1] == 2)

describe "sheet_filter_rows: edge cases":
    """Empty ranges, out-of-bounds columns, and no matches."""

    it "returns empty list for invalid range":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "10")

        val result = sheet_filter_rows(sheet, "INVALID", 0, "10")

        expect(result.len()).to_equal(0)

    it "returns empty list when no rows match":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "5")
        sheet.set_value("A2", "10")

        val result = sheet_filter_rows(sheet, "A1:A2", 0, ">100")

        expect(result.len()).to_equal(0)

    it "returns empty list for out-of-bounds column":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "10")

        val result = sheet_filter_rows(sheet, "A1:A1", 5, "10")

        expect(result.len()).to_equal(0)

describe "sheet_sort_range: stable sort":
    """Stable insertion sort preserves order of equal elements."""

    it "maintains relative order of equal elements":
        var sheet = Sheet.new("S1")
        # Column A has same values; column B tracks original order
        sheet.set_value("A1", "5")
        sheet.set_value("B1", "first")
        sheet.set_value("A2", "5")
        sheet.set_value("B2", "second")
        sheet.set_value("A3", "5")
        sheet.set_value("B3", "third")

        val sorted = sheet_sort_range(sheet, "A1:B3", 0, true, false)

        # All A values should still be 5, but B should maintain order
        val b1_cell = sorted.get_cell("B1")
        match b1_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "first")
            _:
                assert_true(false)

        val b2_cell = sorted.get_cell("B2")
        match b2_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "second")
            _:
                assert_true(false)

        val b3_cell = sorted.get_cell("B3")
        match b3_cell.value:
            CellValue.TextVal(v):
                assert_true(v == "third")
            _:
                assert_true(false)

describe "sheet_autofilter: hides non-matching data rows":
    """4-row table with header row 1: Name (A) / Amount (B). Filtering
    Amount>15 keeps rows where Amount is strictly greater than 15 (20 and
    25) and hides the rest (10 and 15 — 15 is NOT > 15). Criteria semantics
    reuse _cell_matches_criteria, the same matcher sheet_filter_rows uses."""

    it "hides rows that fail the criteria and keeps rows that pass":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "Name")
        sheet.set_value("B1", "Amount")
        sheet.set_value("A2", "a")
        sheet.set_value("B2", "10")
        sheet.set_value("A3", "b")
        sheet.set_value("B3", "20")
        sheet.set_value("A4", "c")
        sheet.set_value("B4", "15")
        sheet.set_value("A5", "d")
        sheet.set_value("B5", "25")

        sheet.set_value("Z1", "=SUBTOTAL(109,B2:B5)")
        sheet = sheet_autofilter(sheet, 1, "B", ">15")

        assert_false(sheet.is_row_hidden(1))  # header never hidden
        assert_true(sheet.is_row_hidden(2))   # 10 -> hidden
        assert_false(sheet.is_row_hidden(3))  # 20 -> visible
        assert_true(sheet.is_row_hidden(4))   # 15 -> hidden (not > 15)
        assert_false(sheet.is_row_hidden(5))  # 25 -> visible

    it "re-filtering with a new criteria updates visibility (unhides stale hides)":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "Name")
        sheet.set_value("B1", "Amount")
        sheet.set_value("A2", "a")
        sheet.set_value("B2", "10")
        sheet.set_value("A3", "b")
        sheet.set_value("B3", "20")

        sheet = sheet_autofilter(sheet, 1, "B", ">15")
        assert_true(sheet.is_row_hidden(2))
        assert_false(sheet.is_row_hidden(3))

        sheet = sheet_autofilter(sheet, 1, "B", "<15")
        assert_false(sheet.is_row_hidden(2))
        assert_true(sheet.is_row_hidden(3))

describe "sheet_clear_filter: unhides every row":
    it "restores all rows hidden by sheet_autofilter":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "Name")
        sheet.set_value("B1", "Amount")
        sheet.set_value("A2", "a")
        sheet.set_value("B2", "10")
        sheet.set_value("A3", "b")
        sheet.set_value("B3", "20")
        sheet.set_value("A4", "c")
        sheet.set_value("B4", "15")
        sheet.set_value("A5", "d")
        sheet.set_value("B5", "25")

        sheet = sheet_autofilter(sheet, 1, "B", ">15")
        assert_true(sheet.is_row_hidden(2))
        assert_true(sheet.is_row_hidden(4))

        sheet = sheet_clear_filter(sheet)
        assert_false(sheet.is_row_hidden(2))
        assert_false(sheet.is_row_hidden(3))
        assert_false(sheet.is_row_hidden(4))
        assert_false(sheet.is_row_hidden(5))

describe "sheet_autofilter + SUBTOTAL(109,...): the flagship filter+subtotal case":
    """Excel's headline AutoFilter behavior: a SUBTOTAL(109,...) formula
    over the filtered column tracks the VISIBLE rows only, updating as the
    filter changes -- this is why Excel authors use SUBTOTAL instead of SUM
    under a filtered table. Ground truth: visible Amounts after Amount>15
    are 20 and 25, sum 45."""

    it "SUBTOTAL(109, B2:B5) returns the sum of only the visible rows":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "Name")
        sheet.set_value("B1", "Amount")
        sheet.set_value("A2", "a")
        sheet.set_value("B2", "10")
        sheet.set_value("A3", "b")
        sheet.set_value("B3", "20")
        sheet.set_value("A4", "c")
        sheet.set_value("B4", "15")
        sheet.set_value("A5", "d")
        sheet.set_value("B5", "25")
        sheet.set_value("Z1", "=SUBTOTAL(109,B2:B5)")

        sheet = sheet_autofilter(sheet, 1, "B", ">15")
        sheet = recalculate_formula_cells(sheet)

        assert_equal(cell_display_text(sheet.get_cell("Z1")), "45")

    it "SUM(B2:B5) still includes hidden rows (contrast with SUBTOTAL(109,...))":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "Name")
        sheet.set_value("B1", "Amount")
        sheet.set_value("A2", "a")
        sheet.set_value("B2", "10")
        sheet.set_value("A3", "b")
        sheet.set_value("B3", "20")
        sheet.set_value("A4", "c")
        sheet.set_value("B4", "15")
        sheet.set_value("A5", "d")
        sheet.set_value("B5", "25")
        sheet.set_value("Z1", "=SUM(B2:B5)")

        sheet = sheet_autofilter(sheet, 1, "B", ">15")
        sheet = recalculate_formula_cells(sheet)

        assert_equal(cell_display_text(sheet.get_cell("Z1")), "70")
