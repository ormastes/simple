"""Calc chart spec.

SVG bar charts from sheet ranges: labels from one range, values (including
computed formula results) from another; bars scale to the max; labels escaped.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.chart.{chart_series_from_ranges, render_bar_chart_svg, sheet_bar_chart_svg, sheet_line_chart_svg, sheet_pie_chart_svg, sheet_area_chart_svg, sheet_scatter_chart_svg}
use app.office.file_formats.{recalculate_formula_cells}

fn _count(hay: text, needle: text) -> i64:
    val removed = hay.replace(needle, "")
    (hay.len() - removed.len()) / needle.len()

fn _chart_sheet() -> Sheet:
    var sh = Sheet.new("c")
    sh.set_value("A1", "Revenue")
    sh.set_value("B1", "1200")
    sh.set_value("A2", "Costs")
    sh.set_value("B2", "800")
    sh.set_value("A3", "Profit")
    sh.set_value("B3", "=B1-B2")
    recalculate_formula_cells(sh)

fn _scatter_sheet() -> Sheet:
    var sh = Sheet.new("s")
    sh.set_value("C1", "1")
    sh.set_value("D1", "10")
    sh.set_value("C2", "2")
    sh.set_value("D2", "40")
    sh.set_value("C3", "3")
    sh.set_value("D3", "30")
    sh.set_value("C4", "4")
    sh.set_value("D4", "80")
    sh

describe "Calc charts: series and SVG":
    it "collects labels and values, including computed formulas":
        val sh = _chart_sheet()
        val series = chart_series_from_ranges(sh, "A1:A3", "B1:B3")
        expect(series.labels.len()).to_equal(3)
        expect(series.labels[2]).to_equal("Profit")
        expect(series.values[0]).to_equal(1200.0)
        expect(series.values[2]).to_equal(400.0)

    it "renders a self-contained SVG with a bar and value per row":
        val sh = _chart_sheet()
        val svg = sheet_bar_chart_svg(sh, "A1:A3", "B1:B3", "Q1 Budget")
        expect(svg).to_start_with("<svg xmlns=")
        expect(svg).to_contain("Q1 Budget")
        expect(svg).to_contain("<rect")
        expect(svg).to_contain(">Profit</text>")
        expect(svg).to_contain(">400</text>")

    it "escapes hostile labels and titles":
        var sh = Sheet.new("c")
        sh.set_value("A1", "<b>bad</b>")
        sh.set_value("B1", "5")
        val svg = sheet_bar_chart_svg(sh, "A1:A1", "B1:B1", "T<i>")
        expect(svg).to_contain("&lt;b&gt;bad&lt;/b&gt;")
        expect(svg).to_contain("T&lt;i&gt;")
        expect(svg.contains("<b>")).to_be(false)

    it "renders a no-data placeholder for empty ranges":
        val sh = Sheet.new("c")
        val svg = sheet_bar_chart_svg(sh, "A1:A1", "B1:B1", "Empty")
        expect(svg).to_contain("<svg")

    it "renders a line chart with a polyline and x labels":
        val sh = _chart_sheet()
        val svg = sheet_line_chart_svg(sh, "A1:A3", "B1:B3", "Trend")
        expect(svg).to_contain("<polyline")
        expect(svg).to_contain("Trend")
        expect(svg).to_contain("Profit")

    it "renders a pie chart with donut segments and a value legend":
        val sh = _chart_sheet()
        val svg = sheet_pie_chart_svg(sh, "A1:A3", "B1:B3", "Share")
        expect(svg).to_contain("stroke-dasharray")
        expect(svg).to_contain("Costs: 800")

describe "Calc charts: axis ticks, legend, area, scatter":
    it "puts nice Y-axis tick labels on the column chart":
        # values 1200/800/400 -> nice step 500 -> ticks 0,500,1000,1500
        val sh = _chart_sheet()
        val svg = sheet_bar_chart_svg(sh, "A1:A3", "B1:B3", "Q1 Budget")
        expect(svg).to_contain(">0</text>")
        expect(svg).to_contain(">500</text>")
        expect(svg).to_contain(">1000</text>")
        expect(svg).to_contain(">1500</text>")

    it "draws a series legend with a swatch and name":
        val sh = _chart_sheet()
        val svg = sheet_bar_chart_svg(sh, "A1:A3", "B1:B3", "Q1 Budget")
        expect(svg).to_contain("class=\"legend\"")
        expect(svg).to_contain(">Series 1</text>")

    it "renders an area chart with a fill polygon over a Y axis":
        val sh = _chart_sheet()
        val svg = sheet_area_chart_svg(sh, "A1:A3", "B1:B3", "Trend")
        expect(svg).to_contain("<polygon")
        expect(svg).to_contain("fill-opacity")
        expect(svg).to_contain("<polyline")
        expect(svg).to_contain(">1000</text>")
        expect(svg).to_contain(">Profit</text>")

    it "renders a scatter chart with one circle per row and both axes":
        # X 1..4 -> ticks 1,2,3,4 ; Y max 80 -> nice step 20 -> ticks 0..80
        val sh = _scatter_sheet()
        val svg = sheet_scatter_chart_svg(sh, "C1:C4", "D1:D4", "XY")
        expect(_count(svg, "<circle")).to_equal(4)
        expect(svg).to_contain(">20</text>")
        expect(svg).to_contain(">80</text>")
        expect(svg).to_contain(">3</text>")
        expect(svg).to_contain("class=\"legend\"")

    it "renders a no-data placeholder for an empty scatter range":
        val sh = Sheet.new("s")
        val svg = sheet_scatter_chart_svg(sh, "C1:C1", "D1:D1", "Empty")
        expect(svg).to_contain("<svg")
