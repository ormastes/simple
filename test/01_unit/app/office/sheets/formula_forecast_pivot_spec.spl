        sh.set_value("A1", "10")
        sh.set_value("B1", "1")
        sh.set_value("Z1", '=FORECAST.ETS(5, A1:A1, B1:B1)')
        sh = recalculate_formula_cells(sh)
        cell_display_text(sh.get_cell("Z1")).to_contain("#ERR")

