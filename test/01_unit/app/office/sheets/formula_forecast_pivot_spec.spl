        sh.set_value("A1", "10")
        sh.set_value("A2", "12")
        sh.set_value("A3", "14")
        sh.set_value("A4", "16")
        sh.set_value("A5", "18")
        sh.set_value("A6", "20")
        sh.set_value("B1", "1")
        sh.set_value("B2", "2")
        sh.set_value("B3", "3")
        sh.set_value("B4", "4")
        sh.set_value("B5", "5")
        sh.set_value("B6", "6")
        sh.set_value("Z1", '=FORECAST.ETS.CONFINT(8, A1:A6, B1:B6)')
        sh = recalculate_formula_cells(sh)
        cell_display_text(sh.get_cell("Z1")).to_start_with("0")

