use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}
use app.office.sheets.pivot.{pivot_build}
use app.office.file_formats.{recalculate_formula_cells}

fn _eval_with_setup(setup_fn: (Sheet) -> text) -> text:
    var sh = Sheet.new("f")
    setup_fn(sh)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("Z1"))

fn _eval(formula: text) -> text:
    var sh = Sheet.new("f")
    sh.set_value("B1", formula)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("B1"))

fn _pivot_col_letter(pc: i32) -> text:
    """Column letter for the pc-th pivot-render column starting at E.
    Widened past the old E-H hardcode (elif chain capped at H clobbered
    any pivot wider than 4 columns) so wider cross-tabs can be rendered
    into the sheet for GETPIVOTDATA intersection tests."""
    val letters: [text] = ["E", "F", "G", "H", "I", "J", "K", "L", "M", "N"]
    letters[pc]

describe "FORECAST.ETS":
    it "detects no seasonality in linear trend":
        # values 10,12,14,16,18,20 on timeline 1..6: trend = 8 + 2t, no seasonality
        var sh = Sheet.new("f")
        sh.set_value("A1", "10")
        sh.set_value("A2", "12")
        sh.set_value("A3", "14")
        sh.set_value("A4", "16")
        sh.set_value("A5", "18")
        sh.set_value("A6", "20")
        sh.set_value("B1", "1")
        sh.set_value("B2", "2")
        sh.set_value("B3", "3")
        sh.set_value("B4", "4")
        sh.set_value("B5", "5")
        sh.set_value("B6", "6")
        sh.set_value("Z1", '=FORECAST.ETS(8, A1:A6, B1:B6)')
        sh = recalculate_formula_cells(sh)
        cell_display_text(sh.get_cell("Z1")).to_start_with("24")

    it "predicts with zero residuals at t=8":
        var sh = Sheet.new("f")
        sh.set_value("A1", "10")
        sh.set_value("A2", "12")
        sh.set_value("A3", "14")
        sh.set_value("A4", "16")
        sh.set_value("A5", "18")
        sh.set_value("A6", "20")
        sh.set_value("B1", "1")
        sh.set_value("B2", "2")
        sh.set_value("B3", "3")
        sh.set_value("B4", "4")
        sh.set_value("B5", "5")
        sh.set_value("B6", "6")
        sh.set_value("Z1", '=FORECAST.ETS(8, A1:A6, B1:B6)')
        sh = recalculate_formula_cells(sh)
        cell_display_text(sh.get_cell("Z1")).to_start_with("24")

    it "detects seasonality period=2 in alternating pattern":
        # values 5,9,5,9,5,9,5,9 on timeline 1..8: period=2
        var sh = Sheet.new("f")
        sh.set_value("A1", "5")
        sh.set_value("A2", "9")
        sh.set_value("A3", "5")
        sh.set_value("A4", "9")
        sh.set_value("A5", "5")
        sh.set_value("A6", "9")
        sh.set_value("A7", "5")
        sh.set_value("A8", "9")
        sh.set_value("B1", "1")
        sh.set_value("B2", "2")
        sh.set_value("B3", "3")
        sh.set_value("B4", "4")
        sh.set_value("B5", "5")
        sh.set_value("B6", "6")
        sh.set_value("B7", "7")
        sh.set_value("B8", "8")
        sh.set_value("Z1", '=FORECAST.ETS(9, A1:A8, B1:B8)')
        sh = recalculate_formula_cells(sh)
        cell_display_text(sh.get_cell("Z1")).to_start_with("5")

    it "accepts explicit seasonality parameter":
        var sh = Sheet.new("f")
        sh.set_value("A1", "5")
        sh.set_value("A2", "9")
        sh.set_value("A3", "5")
        sh.set_value("A4", "9")
        sh.set_value("A5", "5")
        sh.set_value("A6", "9")
        sh.set_value("A7", "5")
        sh.set_value("A8", "9")
        sh.set_value("B1", "1")
        sh.set_value("B2", "2")
        sh.set_value("B3", "3")
        sh.set_value("B4", "4")
        sh.set_value("B5", "5")
        sh.set_value("B6", "6")
        sh.set_value("B7", "7")
        sh.set_value("B8", "8")
        sh.set_value("Z1", '=FORECAST.ETS(9, A1:A8, B1:B8, 2)')
        sh = recalculate_formula_cells(sh)
        cell_display_text(sh.get_cell("Z1")).to_start_with("5")

    it "errors on mismatched values and timeline":
        var sh = Sheet.new("f")
        sh.set_value("A1", "10")
        sh.set_value("A2", "12")
        sh.set_value("A3", "14")
        sh.set_value("B1", "1")
