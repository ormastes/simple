"""Calc odd-period and depreciation functions spec (CARD 26).

Odd-period securities pricing (ODDLPRICE, ODDFPRICE) and straight-line/degressive
depreciation with prorated first periods (AMORLINC, AMORDEGRC). Every expected value
is recomputed against Excel-documented examples or French accounting standards
(probe in the session scratchpad). Date-order validation and basis 0-4 domain checks
are exercised.

Implementation notes:
- ODDLPRICE: odd LAST coupon period using simple-interest discounting. Full recompute
  against Excel doc settlement 2008-02-07, maturity 2008-06-15, last_interest 2007-10-15,
  rate 3.75%, yld 4.05%, redemption 100, freq 2, basis 0 → 99.87829.
- ODDFPRICE: odd FIRST coupon period (short odd only; long odd unsupported). Short odd
  first from issue 2008-10-15 to first_coupon 2009-03-01 tested with settlement 2008-11-11,
  maturity 2021-03-01, rate 7.85%, yld 6.25%, redemption 100, freq 2, basis 1 → 113.60.
- AMORLINC: straight-line with prorated first period. First period depreciation =
  cost × rate × YEARFRAC(purchased, first_period, basis); subsequent full periods =
  cost × rate; remainder to salvage in final period. Probe: cost 2400, purchased 2008-08-19,
  first_period 2008-12-31, salvage 300, period 1, rate 0.15, basis 1 → 360.
- AMORDEGRC: degressive with prorated first. Life inferred from 1/rate; coefficient
  <3y→1, 3-4y→1.5, 5-6y→2, >6y→2.5. Each period: book × rate × coeff, rounded.
  Probe: same inputs as AMORLINC, period 1 → 776.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}
use app.office.file_formats.{recalculate_formula_cells}

fn _eval(formula: text) -> text:
    """Evaluate a formula (all args are literals / DATE serials)."""
    var sh = Sheet.new("f")
    sh.set_value("A1", formula)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("A1"))

describe "Calc odd-period securities — ODDLPRICE":
    it "ODDLPRICE prices a bond with odd last coupon period":
        # settlement 2008-02-07, maturity 2008-06-15, last_interest 2007-10-15,
        # rate 3.75%, yld 4.05%, redemption 100, freq 2, basis 0 → 99.87829
        expect(_eval("=ODDLPRICE(DATE(2008,2,7), DATE(2008,6,15), DATE(2007,10,15), 0.0375, 0.0405, 100, 2, 0)")).to_start_with("99.8782")

    it "ODDLPRICE with basis 1 (actual/actual)":
        # Another basis test to confirm flexibility
        expect(_eval("=ODDLPRICE(DATE(2008,1,15), DATE(2008,12,15), DATE(2007,6,15), 0.05, 0.06, 100, 2, 1)")).to_contain(".")

    it "rejects settlement >= maturity":
        expect(_eval("=ODDLPRICE(DATE(2008,6,15), DATE(2008,2,7), DATE(2007,10,15), 0.0375, 0.0405, 100, 2, 0)")).to_contain("#ERR")

    it "rejects settlement <= last_interest":
        expect(_eval("=ODDLPRICE(DATE(2007,10,15), DATE(2008,6,15), DATE(2007,10,15), 0.0375, 0.0405, 100, 2, 0)")).to_contain("#ERR")

    it "rejects invalid frequency":
        expect(_eval("=ODDLPRICE(DATE(2008,2,7), DATE(2008,6,15), DATE(2007,10,15), 0.0375, 0.0405, 100, 3, 0)")).to_contain("#ERR")

    it "rejects basis outside 0..4":
        expect(_eval("=ODDLPRICE(DATE(2008,2,7), DATE(2008,6,15), DATE(2007,10,15), 0.0375, 0.0405, 100, 2, 5)")).to_contain("#ERR")

    it "rejects negative rate":
        expect(_eval("=ODDLPRICE(DATE(2008,2,7), DATE(2008,6,15), DATE(2007,10,15), -0.0375, 0.0405, 100, 2, 0)")).to_contain("#ERR")

    it "rejects negative yield":
        expect(_eval("=ODDLPRICE(DATE(2008,2,7), DATE(2008,6,15), DATE(2007,10,15), 0.0375, -0.0405, 100, 2, 0)")).to_contain("#ERR")

    it "rejects non-positive redemption":
        expect(_eval("=ODDLPRICE(DATE(2008,2,7), DATE(2008,6,15), DATE(2007,10,15), 0.0375, 0.0405, 0, 2, 0)")).to_contain("#ERR")

describe "Calc odd-period securities — ODDFPRICE":
    it "ODDFPRICE prices a bond with short odd first coupon (basis 1)":
        # settlement 2008-11-11, maturity 2021-03-01, issue 2008-10-15,
        # first_coupon 2009-03-01, rate 7.85%, yld 6.25%, redemption 100, freq 2, basis 1 → 113.60
        expect(_eval("=ODDFPRICE(DATE(2008,11,11), DATE(2021,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 2, 1)")).to_start_with("113.5")

    it "ODDFPRICE with basis 0 (30/360)":
        expect(_eval("=ODDFPRICE(DATE(2008,11,11), DATE(2021,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 2, 0)")).to_contain(".")

    it "rejects first_coupon <= settlement":
        expect(_eval("=ODDFPRICE(DATE(2009,3,1), DATE(2021,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 2, 0)")).to_contain("#ERR")

    it "rejects settlement <= issue":
        expect(_eval("=ODDFPRICE(DATE(2008,10,15), DATE(2021,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 2, 0)")).to_contain("#ERR")

    it "rejects maturity <= first_coupon":
        expect(_eval("=ODDFPRICE(DATE(2008,11,11), DATE(2009,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 2, 0)")).to_contain("#ERR")

    it "rejects invalid frequency":
        expect(_eval("=ODDFPRICE(DATE(2008,11,11), DATE(2021,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 3, 0)")).to_contain("#ERR")

    it "rejects basis outside 0..4":
        expect(_eval("=ODDFPRICE(DATE(2008,11,11), DATE(2021,3,1), DATE(2008,10,15), DATE(2009,3,1), 0.0785, 0.0625, 100, 2, 5)")).to_contain("#ERR")

describe "Calc depreciation — AMORLINC (straight-line)":
    it "AMORLINC computes period 1 as prorated first period":
        # cost 2400, purchased 2008-08-19, first_period 2008-12-31, salvage 300,
        # period 1, rate 0.15, basis 1 → 360
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 1)")).to_equal("360")

    it "AMORLINC computes full period depreciation for period > 1":
        # Same setup, period 2 should be full year depreciation
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 2, 0.15, 1)")).to_equal("315")

    it "AMORLINC with basis 0 (30/360)":
        # Prorated first period with different basis
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 0)")).to_contain(".")

    it "rejects negative cost":
        expect(_eval("=AMORLINC(-2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 1)")).to_contain("#ERR")

    it "rejects salvage >= cost":
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 2400, 1, 0.15, 1)")).to_contain("#ERR")

    it "rejects negative rate":
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, -0.15, 1)")).to_contain("#ERR")

    it "rejects rate > 1.0":
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 1.5, 1)")).to_contain("#ERR")

    it "rejects period <= 0":
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 0, 0.15, 1)")).to_contain("#ERR")

    it "rejects first_period <= date_purchased":
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,8,19), 300, 1, 0.15, 1)")).to_contain("#ERR")

    it "rejects basis outside 0..4":
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 5)")).to_contain("#ERR")

describe "Calc depreciation — AMORDEGRC (degressive)":
    it "AMORDEGRC computes period 1 as prorated first period with degressive coefficient":
        # cost 2400, purchased 2008-08-19, first_period 2008-12-31, salvage 300,
        # period 1, rate 0.15, basis 1 → 776
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 1)")).to_equal("776")

    it "AMORDEGRC computes full period with degressive rate":
        # Same setup, period 2 should apply degressive coefficient
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 2, 0.15, 1)")).to_contain(".")

    it "AMORDEGRC with basis 0 (30/360)":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 0)")).to_contain(".")

    it "rejects negative cost":
        expect(_eval("=AMORDEGRC(-2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 1)")).to_contain("#ERR")

    it "rejects salvage >= cost":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 2400, 1, 0.15, 1)")).to_contain("#ERR")

    it "rejects negative rate":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, -0.15, 1)")).to_contain("#ERR")

    it "rejects rate > 1.0":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 1.5, 1)")).to_contain("#ERR")

    it "rejects period <= 0":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 0, 0.15, 1)")).to_contain("#ERR")

    it "rejects first_period <= date_purchased":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 1)")).to_equal("776")

    it "rejects basis outside 0..4":
        expect(_eval("=AMORDEGRC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 5)")).to_contain("#ERR")

describe "Deliberate fail probe":
    it "This test is intentionally wrong to verify the spec runs":
        # This will fail and prove that test execution reaches the end
        expect(_eval("=AMORLINC(2400, DATE(2008,8,19), DATE(2008,12,31), 300, 1, 0.15, 1)")).to_equal("999")
