# Test math_bridge functions - verify they use stdlib correctly
#
# This test verifies that the math_bridge functions correctly delegate
# to stdlib math functions and produce expected results.

use app.office.sheets.math_bridge.{
    excel_sin, excel_cos, excel_tan, excel_sinh, excel_cosh, excel_tanh,
    excel_ln, excel_log10, excel_exp, excel_sqrt, excel_sqrt_pi,
    excel_sum, excel_average, excel_count, excel_min, excel_max,
    excel_product, excel_sumsq, excel_roundup, excel_rounddown,
    excel_even, excel_odd, excel_degrees, excel_radians
}

describe "Math Bridge Functions":
    it "SIN computes correctly":
        val result = excel_sin(1.570796327)  # π/2
        assert_true(result > 0.999999 and result < 1.000001)

    it "COS computes correctly":
        val result = excel_cos(0.0)
        assert_true(result > 0.999999 and result < 1.000001)

    it "EXP computes e^1 correctly":
        val result = excel_exp(1.0)
        assert_true(result > 2.71828 and result < 2.71829)

    it "LN computes natural log":
        val result = excel_ln(2.718281828)
        assert_true(result > 0.999999 and result < 1.000001)

    it "SQRT computes square root":
        val result = excel_sqrt(4.0)
        assert_equal(result, 2.0)

    it "SUM aggregates array":
        val arr: [f64] = [1.0, 2.0, 3.0, 4.0]
        assert_equal(excel_sum(arr), 10.0)

    it "AVERAGE computes mean":
        val arr: [f64] = [1.0, 2.0, 3.0, 4.0]
        assert_equal(excel_average(arr), 2.5)

    it "COUNT returns array length":
        val arr: [f64] = [1.0, 2.0, 3.0, 4.0]
        assert_equal(excel_count(arr), 4)

    it "MIN finds minimum":
        val arr: [f64] = [3.0, 1.0, 4.0, 2.0]
        assert_equal(excel_min(arr), 1.0)

    it "MAX finds maximum":
        val arr: [f64] = [3.0, 1.0, 4.0, 2.0]
        assert_equal(excel_max(arr), 4.0)

    it "PRODUCT multiplies values":
        val arr: [f64] = [2.0, 3.0, 4.0]
        assert_equal(excel_product(arr), 24.0)

    it "SUMSQ sums squares":
        val arr: [f64] = [1.0, 2.0, 3.0]
        assert_equal(excel_sumsq(arr), 14.0)  # 1 + 4 + 9

    it "EMPTY array handling":
        val empty: [f64] = []
        assert_equal(excel_sum(empty), 0.0)
        assert_equal(excel_product(empty), 1.0)

    it "DEGREES converts radians to degrees":
        val result = excel_degrees(3.141592654)
        assert_true(result > 179.999 and result < 180.001)

    it "RADIANS converts degrees to radians":
        val result = excel_radians(180.0)
        assert_true(result > 3.14159 and result < 3.14160)
