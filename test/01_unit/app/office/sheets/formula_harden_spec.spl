"""Office sheets formula-engine hardening spec.

Verifies the headline slice-1 hardening of `src/app/office/sheets/formula.spl`:
depth-bounded cycle detection. A circular reference now terminates and yields
an empty display instead of recursing until the stack overflows.

These examples run on the integer-safe display path
(`evaluate_formula_display_text`) and pass under the test runner's compiled
execution. The float-returning additions in the same change — ROUND (half away
from zero), SQRT, POWER, MOD, INT, PRODUCT, FLOOR, CEILING, SIGN, the
AND/OR/NOT logical functions, and the '&' string-concatenation operator — are
implemented but NOT yet verified to produce correct values: f64 results are
unreliable on every available backend (interpreter/SMF/runner zero them, native
cores, and even shallow leaf-math calls return garbage bits). They are correct
by construction only. The toolchain blocker — which also makes the pre-existing
SUM/AVERAGE functions return 0 — is tracked in
`doc/08_tracking/bug/interp_f64_nested_struct_payload_zero_2026-06-14.md` and
must be fixed before these functions can be asserted.
"""

use std.spec
use app.office.sheets.formula.{evaluate_formula_display_text}
use app.office.sheets.spreadsheet.{Sheet}

describe "formula engine: cycle detection terminates":
    """A reference chain longer than the evaluator's depth cap — which every
    circular reference eventually is — resolves to an empty display rather than
    overflowing the stack."""

    it "a self-referential formula returns an empty display instead of overflowing":
        var sheet = Sheet.new("S1")
        sheet.set_value("C1", "=C1+1")
        expect(evaluate_formula_display_text("=C1", sheet)).to_equal("")

    it "mutually-circular references terminate":
        var sheet = Sheet.new("S1")
        sheet.set_value("A1", "=B1")
        sheet.set_value("B1", "=A1")
        expect(evaluate_formula_display_text("=A1", sheet)).to_equal("")

    it "an empty formula yields an empty display":
        var sheet = Sheet.new("S1")
        expect(evaluate_formula_display_text("=", sheet)).to_equal("")
