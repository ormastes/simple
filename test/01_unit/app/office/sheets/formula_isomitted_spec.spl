"""ISOMITTED function tests."""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}
use app.office.file_formats.{recalculate_formula_cells}

fn _eval(formula: text) -> text:
    var sh = Sheet.new("f")
    sh.set_value("Z1", formula)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("Z1"))

describe "ISOMITTED basic":
    it "LAMBDA(x, y, IF(ISOMITTED(y), x, x+y))(5) = 5":
        expect(_eval("=LAMBDA(x, y, IF(ISOMITTED(y), x, x+y))(5)")).to_equal("5")

    it "LAMBDA(x, y, IF(ISOMITTED(y), x, x+y))(5, 3) = 8":
        expect(_eval("=LAMBDA(x, y, IF(ISOMITTED(y), x, x+y))(5, 3)")).to_equal("8")
