"""Calc LET (and immediately-invoked LAMBDA) spec.

LET(name1, value1, [name2, value2, ...], calculation) binds names on a
module-level binding stack (see formula.spl's _let_names/_let_values next to
the CARD 14 _formula_origin_key precedent) that is pushed right before
evaluating anything that might reference a name and popped again before
_eval_let returns, on every path (success or #ERR) — so bindings never leak
across sibling LET calls or across cells. Ground truths below are hand
computed (LET is pure arithmetic/binding, not a numeric-library function, so
there is no external reference table to check against beyond direct
computation).

LAMBDA ships IMMEDIATE-INVOCATION ONLY: `LAMBDA(x, x*2)(3)` = 6. A LAMBDA
stored in a name via LET and invoked later (`LET(f, LAMBDA(x,x*2), f(3))`)
would need a callable CellValue variant plumbed through the whole engine —
out of scope; it fails closed with #ERR (see the "LAMBDA must be immediately
invoked" case below) rather than shipping half-working callable semantics.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}
use app.office.file_formats.{recalculate_formula_cells}

fn _eval(formula: text) -> text:
    var sh = Sheet.new("f")
    sh.set_value("Z1", formula)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("Z1"))

fn _eval_with_a1(formula: text, a1: text) -> text:
    var sh = Sheet.new("f")
    sh.set_value("A1", a1)
    sh.set_value("Z1", formula)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("Z1"))

describe "Calc LET basic binding":
    it "LET(x, 5, x*2) = 10":
        expect(_eval("=LET(x, 5, x*2)")).to_equal("10")

    it "LET(x, 5, y, x+1, x*y) = 30":
        expect(_eval("=LET(x, 5, y, x+1, x*y)")).to_equal("30")

    it "value1 can reference a cell: LET(x, A1, x+1) with A1=10 -> 11":
        expect(_eval_with_a1("=LET(x, A1, x+1)", "10")).to_equal("11")

    it "a bound name can be used more than once in the calculation":
        expect(_eval("=LET(x, 3, x*x+x)")).to_equal("12")

    it "value expressions may use string concatenation (full grammar, not just numeric)":
        expect(_eval("=LET(s, \"ab\"&\"c\", s)")).to_equal("abc")

describe "Calc LET scoping (no leakage, nesting, shadowing)":
    it "LET(x, 1, x) does not leak into a sibling LET(x, 2, x) in another cell":
        expect(_eval("=LET(x, 1, x)")).to_equal("1")
        expect(_eval("=LET(x, 2, x)")).to_equal("2")

    it "nested LET(x,1,LET(y,2,x+y)) = 3 (outer name visible inside inner)":
        expect(_eval("=LET(x,1,LET(y,2,x+y))")).to_equal("3")

    it "shadowing: LET(x,1,LET(x,5,x)) = 5 (innermost binding wins)":
        expect(_eval("=LET(x,1,LET(x,5,x))")).to_equal("5")

    it "after a nested LET returns, the outer binding is restored":
        expect(_eval("=LET(x,1,LET(x,5,x)) & \"-\" & LET(x,1,x)")).to_equal("5-1")

describe "Calc LET #ERR domains":
    it "a name matching a cell-ref pattern is rejected at bind time: LET(A1, 5, A1)":
        expect(_eval("=LET(A1, 5, A1)")).to_contain("#ERR")

    it "a name reusing a built-in function name is rejected: LET(SUM, 5, SUM)":
        expect(_eval("=LET(SUM, 5, SUM)")).to_contain("#ERR")

    it "an even argument count (missing calculation) is #ERR: LET(x, 5)":
        expect(_eval("=LET(x, 5)")).to_contain("#ERR")

    it "an even argument count (two pairs, no calculation) is #ERR: LET(x,5,y,6)":
        expect(_eval("=LET(x,5,y,6)")).to_contain("#ERR")

    it "LET with no arguments is #ERR":
        expect(_eval("=LET()")).to_contain("#ERR")

describe "Calc LAMBDA (immediate invocation only)":
    it "LAMBDA(x, x*2)(3) = 6":
        expect(_eval("=LAMBDA(x, x*2)(3)")).to_equal("6")

    it "LAMBDA(x, y, x+y)(2, 5) = 7 (multi-parameter)":
        expect(_eval("=LAMBDA(x, y, x+y)(2, 5)")).to_equal("7")

    it "LAMBDA composes with LET's value expressions":
        expect(_eval("=LET(f, LAMBDA(x, x*2)(3), f+1)")).to_equal("7")

    it "a LAMBDA not immediately invoked is unsupported and fails closed with #ERR":
        expect(_eval("=LAMBDA(x, x*2)")).to_contain("#ERR")

    it "LAMBDA arity mismatch (too few invocation arguments) is #ERR":
        expect(_eval("=LAMBDA(x, y, x+y)(2)")).to_contain("#ERR")

# Deliberate-fail probe (run once, saw it fail, then reverted to the correct
# assertion below) proving the tail of this file executes:
#   expect(_eval("=LET(x, 5, x*2)")).to_equal("999")   # <- failed as expected
describe "Calc LET deliberate-fail probe tail marker":
    it "tail of the file executes: LET(x, 5, x*2) still = 10":
        expect(_eval("=LET(x, 5, x*2)")).to_equal("10")
