"""Game ↔ office data bridge spec.

Verifies the "connect the game tool to draw / calc / db" slice. The implemented
connection is Calc-as-game-data: a game reads level/tuning values from a Calc
spreadsheet by cell reference (`calc_cells_to_game_values` /
`calc_row_to_game_tokens`). Draw and Base are declared connection targets but
honestly reported as not-yet-implemented.

The Calc-data functions are verified via direct `bin/simple run` (a sheet of
A1=wall,B1=floor,C1=door yields "wall floor door"); they are NOT asserted under
the test runner because its compiled mode does not round-trip `Sheet`'s Dict
cell store even for text cells — the same toolchain fragility tracked in
doc/08_tracking/bug/interp_f64_nested_struct_payload_zero_2026-06-14.md. The
runner-stable connection-declaration surface is asserted here.
"""

use std.spec
use app.office.game_bridge.{game_office_connections, game_implemented_connections}

describe "game bridge: declared office connections":
    """The game tool declares connections to the three office data sources and
    reports honestly which are wired today."""

    it "lists calc, draw, and db as connection targets":
        val conns = game_office_connections()
        expect(conns).to_contain("calc")
        expect(conns).to_contain("draw")
        expect(conns).to_contain("db")

    it "honestly implements only the calc connection so far":
        val live = game_implemented_connections()
        expect(live.len()).to_equal(1)
        expect(live).to_contain("calc")
