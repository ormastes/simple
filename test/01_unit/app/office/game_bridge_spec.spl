"""Game ↔ office data bridge spec.

Verifies the "connect the game tool to draw / calc / db" slice. Calc exposes
spreadsheet display values as level/tuning tokens, Draw exposes SDD nodes as
sprite records, and Base exposes exact-match query rows as game state records.

Calc, Draw, and Base bridge adapters are runner-stable and asserted here.
"""

use std.spec
use app.office.base_db.{DbTable, insert_row, new_table}
use app.office.game_bridge.{base_query_to_game_records, base_query_to_game_state, base_table_game_summary, calc_row_to_game_tokens, draw_sdd_to_game_sprite_manifest, draw_sdd_to_game_sprites, game_office_connections, game_implemented_connections}
use app.office.sheets.spreadsheet.{Sheet}

fn _game_table() -> DbTable:
    var t = new_table("game_state", ["scope", "key", "value"])
    t = insert_row(t, ["level1", "hp", "100"])
    t = insert_row(t, ["level1", "spawn", "gate"])
    t = insert_row(t, ["level2", "hp", "200"])
    t

describe "game bridge: declared office connections":
    """The game tool declares connections to the three office data sources and
    reports honestly which are wired today."""

    it "lists calc, draw, and db as connection targets":
        val conns = game_office_connections()
        expect(conns).to_contain("calc")
        expect(conns).to_contain("draw")
        expect(conns).to_contain("db")

    it "reports calc, draw, and db as implemented":
        val live = game_implemented_connections()
        expect(live.len()).to_equal(3)
        expect(live).to_contain("calc")
        expect(live).to_contain("draw")
        expect(live).to_contain("db")

describe "game bridge: Calc token data":
    """Calc cells become deterministic game level/tuning tokens."""

    it "exports referenced Calc cells as game tokens":
        val sheet = Sheet.new("Level")
        sheet.set_value("A1", "wall")
        sheet.set_value("B1", "floor")
        sheet.set_value("C1", "door")
        expect(calc_row_to_game_tokens(sheet, ["A1", "B1", "C1"])).to_equal("wall floor door")

describe "game bridge: Draw sprite data":
    """SDD Draw nodes become deterministic sprite records for a game tool."""

    it "exports SDD nodes as game sprite records":
        val sprites = draw_sdd_to_game_sprites("graph: Level\nplayer: Player @hero shape: circle x: 10 y: 20 width: 16 height: 16 layer: 2\ndoor: Door x: 40 y: 20 width: 12 height: 24")
        expect(sprites.len()).to_equal(2)
        expect(sprites).to_contain("sprite player label=Player shape=circle style=hero rect=10,20,16,16 layer=2")
        expect(sprites).to_contain("sprite door label=Door shape=rect style=default rect=40,20,12,24 layer=0")

    it "exports a newline-separated sprite manifest":
        val manifest = draw_sdd_to_game_sprite_manifest("graph: Level\nspawn: Spawn x: 1 y: 2 width: 3 height: 4")
        expect(manifest).to_contain("sprite spawn")
        expect(manifest).to_contain("rect=1,2,3,4")

describe "game bridge: Base state data":
    """Base exact-match query rows become game state records."""

    it "exports matched Base rows as key value records":
        val records = base_query_to_game_records(_game_table(), "scope", "level1", "key", "value")
        expect(records.len()).to_equal(2)
        expect(records).to_contain("hp=100")
        expect(records).to_contain("spawn=gate")

    it "exports a compact game state line and fails closed for missing columns":
        val state = base_query_to_game_state(_game_table(), "scope", "level1", "key", "value")
        val missing = base_query_to_game_records(_game_table(), "scope", "level1", "missing", "value")
        expect(state).to_contain("hp=100")
        expect(state).to_contain("spawn=gate")
        expect(missing.len()).to_equal(0)

    it "summarizes the Base table exposed to game tooling":
        expect(base_table_game_summary(_game_table())).to_equal("db game_state rows=3")
