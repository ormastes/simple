"""LibreOffice Base — relational table spec.

Verifies the Base database component: an in-memory text table with row
insertion, exact-match filtering (`select_where`), and column projection
(`project_column`). Inner-row cells are read via iteration to avoid the
interpreter's `.get(>=1)` array-element corruption, so filtering by a non-first
column works correctly.
"""

use std.spec
use app.office.base_db.{DbTable, new_table, insert_row, row_count, select_where, project_column, column_index}

fn _sample() -> DbTable:
    var t = new_table("enemies", ["name", "type"])
    t = insert_row(t, ["goblin", "melee"])
    t = insert_row(t, ["archer", "ranged"])
    t = insert_row(t, ["orc", "melee"])
    t

describe "Base table: rows and columns":
    """A table accumulates rows and resolves column indices."""

    it "counts inserted rows":
        val t = _sample()
        expect(row_count(t)).to_equal(3)

    it "resolves a non-first column index":
        val t = _sample()
        expect(column_index(t, "type")).to_equal(1)

    it "returns -1 for an unknown column":
        val t = _sample()
        expect(column_index(t, "nope")).to_equal(0 - 1)

describe "Base table: query":
    """Filtering and projection read non-first columns correctly."""

    it "filters rows by a non-first column value":
        val t = _sample()
        val melee = select_where(t, "type", "melee")
        expect(melee.len()).to_equal(2)

    it "filters a single match":
        val t = _sample()
        val ranged = select_where(t, "type", "ranged")
        expect(ranged.len()).to_equal(1)

    it "projects a non-first column":
        val t = _sample()
        val types = project_column(t, "type")
        expect(types.len()).to_equal(3)
        expect(types).to_contain("ranged")
