# Publisher master-page / template spec.
#
# Verifies apply_master merges a MasterPage's frames onto content pages,
# substituting the `#` page-number placeholder token, and that
# apply_master_to_all numbers a whole document sequentially.
#
# Master: header frame "hdr" (fixed text "Report"), footer frame "ftr"
# (placeholder text "Page #"). Two content pages, each with one content
# frame ("body1" / "body2"). Applying the master to both starting at page
# number 1 should give:
#   page 1: 1 body frame + 2 master frames = 3 frames total; ftr -> "Page 1"
#   page 2: 1 body frame + 2 master frames = 3 frames total; ftr -> "Page 2"
# and "hdr" -> "Report" unchanged (no placeholder) on both.

use std.spec
use app.office.publisher.page_layout.{Page, TextFrame, page_new, page_add_frame, frame_new, frame_text, page_frame_count, page_render_html}
use app.office.publisher.template.{MasterPage, master_new, master_add_frame, master_frame_count, apply_master, apply_master_to_all}

fn _report_master() -> MasterPage:
    """Master with a fixed-text header and a page-number-placeholder footer."""
    var master = master_new("report_master")
    val header = TextFrame(id: "hdr", x: 0, y: 0, w: 200, h: 16, text: "Report", next_id: "")
    val footer = TextFrame(id: "ftr", x: 0, y: 380, w: 200, h: 16, text: "Page #", next_id: "")
    master = master_add_frame(master, header)
    master = master_add_frame(master, footer)
    master

fn _content_pages() -> [Page]:
    """Two content pages, each with a single body frame."""
    var page1 = page_new(200, 400)
    page1 = page_add_frame(page1, frame_new("body1", 0, 20, 200, 350, ""))
    var page2 = page_new(200, 400)
    page2 = page_add_frame(page2, frame_new("body2", 0, 20, 200, 350, ""))
    var pages: [Page] = []
    pages.push(page1)
    pages.push(page2)
    pages

describe "publisher template: master construction":
    it "counts frames added to the master":
        val master = _report_master()
        expect(master_frame_count(master)).to_equal(2)

describe "publisher template: apply_master_to_all":
    it "gives each result page its own frames plus the master's frames":
        val master = _report_master()
        val pages = _content_pages()
        val result = apply_master_to_all(master, pages, 1)
        expect(page_frame_count(result[0])).to_equal(3)
        expect(page_frame_count(result[1])).to_equal(3)

    it "carries the master header text onto both pages":
        val master = _report_master()
        val pages = _content_pages()
        val result = apply_master_to_all(master, pages, 1)
        expect(frame_text(result[0], "hdr")).to_equal("Report")
        expect(frame_text(result[1], "hdr")).to_equal("Report")

    it "substitutes the # placeholder with each page's own number":
        val master = _report_master()
        val pages = _content_pages()
        val result = apply_master_to_all(master, pages, 1)
        expect(frame_text(result[0], "ftr")).to_equal("Page 1")
        expect(frame_text(result[1], "ftr")).to_equal("Page 2")

    it "preserves each page's own content frame text":
        val master = _report_master()
        val pages = _content_pages()
        val result = apply_master_to_all(master, pages, 1)
        expect(frame_text(result[0], "body1")).to_equal("")
        expect(frame_text(result[1], "body2")).to_equal("")

    it "renders the master header text into the page's HTML":
        val master = _report_master()
        val pages = _content_pages()
        val result = apply_master_to_all(master, pages, 1)
        val html = page_render_html(result[0])
        expect(html).to_contain("Report")

    describe "deliberate-fail probe (must stay green)":
        it "sanity-checks page-number substitution ground truth":
            val master = _report_master()
            val pages = _content_pages()
            val result = apply_master_to_all(master, pages, 1)
            # Probe verified live: asserting "Page 1" for result[1]'s footer
            # (should be page 2, not page 1) failed with "expected Page 2 to
            # equal Page 1", confirming the harness executes this assertion.
            # Correct ground truth: apply_master_to_all numbers sequentially
            # from start_number, so result[1]'s footer is "Page 2".
            expect(frame_text(result[1], "ftr")).to_equal("Page 2")
