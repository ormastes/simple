# Publisher WordArt spec.
#
# Verifies the four built-in presets' SVG/HTML ground truths:
#   plain:    exactly ONE <text element, no stroke attribute.
#   outline:  <text plus the fill hex plus a stroke attribute.
#   shadow:   exactly TWO <text elements (gray #888888 copy behind the
#             main fill copy).
#   gradient: a <linearGradient in <defs, referenced via url(#...).
# Plus preset listing/validation and content escaping.

use std.spec
use app.office.publisher.wordart.{wordart_new, wordart_to_svg, wordart_to_html, wordart_preset_names, wordart_is_valid_preset}

describe "wordart: plain preset":
    it "renders exactly one <text element":
        val art = wordart_new("Big Sale", "plain", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        val text_count = svg.split("<text").len() - 1
        expect(text_count).to_equal(1)

    it "has no stroke attribute":
        val art = wordart_new("Big Sale", "plain", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        assert_false(svg.contains("stroke"))

describe "wordart: outline preset":
    it "contains a <text element, the fill hex, and a stroke":
        val art = wordart_new("Big Sale", "outline", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        expect(svg).to_contain("<text")
        expect(svg).to_contain("#c00000")
        expect(svg).to_contain("stroke")

describe "wordart: shadow preset":
    it "renders exactly two <text elements":
        val art = wordart_new("Big Sale", "shadow", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        val text_count = svg.split("<text").len() - 1
        expect(text_count).to_equal(2)

    it "includes the gray #888888 shadow copy":
        val art = wordart_new("Big Sale", "shadow", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        expect(svg).to_contain("#888888")

describe "wordart: gradient preset":
    it "defines a linearGradient and references it via url(#":
        val art = wordart_new("Big Sale", "gradient", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        expect(svg).to_contain("<linearGradient")
        expect(svg).to_contain("url(#")

describe "wordart: html rendering":
    it "contains the content and a color style":
        val art = wordart_new("Big Sale", "outline", "#c00000", 10, 20, 48)
        val html = wordart_to_html(art)
        expect(html).to_contain("Big Sale")
        expect(html).to_contain("color:")

describe "wordart: preset listing and validation":
    it "lists exactly four preset names":
        val names = wordart_preset_names()
        expect(names.len()).to_equal(4)

    it "validates a known preset name":
        assert_true(wordart_is_valid_preset("outline"))

    it "rejects an unknown preset name":
        assert_false(wordart_is_valid_preset("bogus"))

describe "wordart: content escaping":
    it "escapes < in the content to &lt;":
        val art = wordart_new("A < B", "plain", "#c00000", 10, 20, 48)
        val svg = wordart_to_svg(art)
        expect(svg).to_contain("A &lt; B")

    describe "deliberate-fail probe (must stay green)":
        it "sanity-checks the shadow text-element count ground truth":
            val art = wordart_new("Big Sale", "shadow", "#c00000", 10, 20, 48)
            val svg = wordart_to_svg(art)
            val text_count = svg.split("<text").len() - 1
            # Probe verified live: asserting 3 <text elements (one more
            # than shadow's real count) failed with "expected 2 to equal
            # 3", confirming the harness executes this assertion. Correct
            # ground truth: shadow renders exactly 2 <text elements.
            expect(text_count).to_equal(2)
