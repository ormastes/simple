# Publisher page-layout spec.
#
# Verifies the DTP page model: linked text frames, word-accurate text flow
# with overflow down the `next_id` chain, and absolutely-positioned HTML
# rendering.
#
# Capacity math (see page_layout.spl): CHAR_W = 6, LINE_H = 16.
# Frame "f1" is w=66, h=16  -> chars_per_line = 66/6 = 11, lines = 16/16 = 1
#   -> capacity = 11 chars.
# Words flowed: "The cat sat on the mat" (6 words).
#   "The"(3) -> len 3 <= 11, keep
#   "The cat" -> 3+1+3=7 <= 11, keep
#   "The cat sat" -> 7+1+3=11 <= 11, keep (exactly fills capacity)
#   + "on" -> 11+1+2=14 > 11, overflow -> frame f1 holds exactly 3 words:
#   "The cat sat"
# Frame "f2" is w=100, h=32 -> chars_per_line = 100/6 = 16, lines = 32/16 = 2
#   -> capacity = 32 chars, comfortably fits the remaining "on the mat"
#   (2+1+3+1+3 = 10 chars), so nothing overflows past f2.

use std.spec
use app.office.publisher.page_layout.{Page, TextFrame, page_new, page_add_frame, frame_new, page_flow_text, frame_text, page_frame_count, page_render_html}

fn _linked_page() -> Page:
    """Two-frame linked page: f1 (small, overflows) -> f2 (roomy)."""
    var page = page_new(200, 100)
    val f1 = frame_new("f1", 0, 0, 66, 16, "f2")
    val f2 = frame_new("f2", 0, 20, 100, 32, "")
    page = page_add_frame(page, f1)
    page = page_add_frame(page, f2)
    page

describe "publisher page layout: frame construction":
    it "counts frames added to the page":
        val page = _linked_page()
        expect(page_frame_count(page)).to_equal(2)

    it "starts with empty frame text":
        val page = _linked_page()
        expect(frame_text(page, "f1")).to_equal("")
        expect(frame_text(page, "f2")).to_equal("")

describe "publisher page layout: text flow and overflow":
    it "fills frame f1 with exactly 3 words up to its char capacity":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        expect(frame_text(page, "f1")).to_equal("The cat sat")

    it "overflows the remaining words into linked frame f2":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        expect(frame_text(page, "f2")).to_equal("on the mat")

    it "never splits a word across frames":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        expect(frame_text(page, "f1").contains("o")).to_be(false)

    it "preserves frame count after flowing text":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        expect(page_frame_count(page)).to_equal(2)

describe "publisher page layout: HTML rendering":
    it "renders a positioned div for each frame":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        val html = page_render_html(page)
        expect(html).to_contain("id=\"f1\"")
        expect(html).to_contain("id=\"f2\"")

    it "positions frames with absolute left/top/width/height styles":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        val html = page_render_html(page)
        expect(html).to_contain("position:absolute;left:0px;top:0px;width:66px;height:16px;")
        expect(html).to_contain("position:absolute;left:0px;top:20px;width:100px;height:32px;")

    it "contains both frames' flowed text":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        val html = page_render_html(page)
        expect(html).to_contain("The cat sat")
        expect(html).to_contain("on the mat")

    it "wraps the page in a relatively-positioned container":
        var page = _linked_page()
        page = page_flow_text(page, "f1", "The cat sat on the mat")
        val html = page_render_html(page)
        expect(html).to_start_with("<div class=\"pub-page\"")
        expect(html).to_contain("position:relative;width:200px;height:100px;")

    describe "deliberate-fail probe (must stay green)":
        it "sanity-checks capacity math holds (fixed, was deliberately wrong)":
            var page = _linked_page()
            page = page_flow_text(page, "f1", "The cat sat on the mat")
            # Probe verified live: asserting "The cat sat on" (4 words) here
            # failed with "expected The cat sat to equal The cat sat on",
            # confirming the harness executes this assertion. Capacity math
            # (11 chars) only admits 3 words in f1, so the correct assertion
            # is the 3-word split below.
            expect(frame_text(page, "f1")).to_equal("The cat sat")
