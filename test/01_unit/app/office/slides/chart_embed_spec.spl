"""Chart-embedded-on-a-slide spec.

Verifies the `app.office.slides.chart_embed` model: a chart (bar/column/pie)
embedded as a positioned graphic frame on a slide. Covers the rendered
per-point bars (hand-computed pct-of-max / pct-of-total), the SVG rendering
(rect count + title), the pptx `<p:graphicFrame>` fragment, and the point
count.
"""

use std.spec
use app.office.slides.chart_embed.{series_new, embed_new, chart_bars, chart_to_svg, embed_to_pptx_xml, chart_point_count}

describe "chart_embed: rendered bars":
    """chart_bars() returns one "<label>:<value>:<pct>" line per data point,
    hand-computed against the fixed series labels=[Q1,Q2,Q3] values=[10,30,20]."""

    it "computes pct-of-max for a column chart (max=30)":
        val series = series_new(["Q1", "Q2", "Q3"], ["10", "30", "20"])
        val chart = embed_new("column", 100, 100, 400, 300, "Sales", series)
        val bars = chart_bars(chart)
        expect(bars).to_equal(["Q1:10:33", "Q2:30:100", "Q3:20:66"])

    it "computes pct-of-total for a pie chart (total=60)":
        val series = series_new(["Q1", "Q2", "Q3"], ["10", "30", "20"])
        val chart = embed_new("pie", 100, 100, 400, 300, "Sales", series)
        val bars = chart_bars(chart)
        expect(bars).to_equal(["Q1:10:16", "Q2:30:50", "Q3:20:33"])

describe "chart_embed: SVG rendering":
    """A column chart embed renders one rect per data point plus the title."""

    it "renders an <svg> with 3 rects and the title Sales":
        val series = series_new(["Q1", "Q2", "Q3"], ["10", "30", "20"])
        val chart = embed_new("column", 100, 100, 400, 300, "Sales", series)
        val svg = chart_to_svg(chart)
        expect(svg).to_contain("<svg")
        expect(svg).to_contain("Sales")
        val rect_count = svg.split("<rect").len() - 1
        expect(rect_count).to_equal(3)

describe "chart_embed: pptx graphic frame":
    """embed_to_pptx_xml() carries the slide position/size and names the
    chart kind + series count."""

    it "emits a graphicFrame with the x/y offset and a c:chart child":
        val series = series_new(["Q1", "Q2", "Q3"], ["10", "30", "20"])
        val chart = embed_new("column", 100, 100, 400, 300, "Sales", series)
        val xml = embed_to_pptx_xml(chart)
        expect(xml).to_contain("<p:graphicFrame")
        expect(xml).to_contain("x=\"100\"")
        expect(xml).to_contain("y=\"100\"")
        expect(xml).to_contain("<c:chart")

describe "chart_embed: point count":
    """chart_point_count() reports the number of data points in the series."""

    it "reports 3 points for the Q1/Q2/Q3 series":
        val series = series_new(["Q1", "Q2", "Q3"], ["10", "30", "20"])
        val chart = embed_new("column", 100, 100, 400, 300, "Sales", series)
        expect(chart_point_count(chart)).to_equal(3)

    describe "deliberate-fail probe (fixed to green)":
        """A probe that intentionally asserted the wrong count first, to
        confirm the example is actually exercised, then corrected."""

        it "has exactly 3 points, not 4":
            val series = series_new(["Q1", "Q2", "Q3"], ["10", "30", "20"])
            val chart = embed_new("column", 100, 100, 400, 300, "Sales", series)
            expect(chart_point_count(chart)).to_equal(3)
