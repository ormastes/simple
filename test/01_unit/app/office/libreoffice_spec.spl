"""LibreOffice branding spec.

Verifies the "rename to LibreOffice" slice: the office suite is branded
"LibreOffice" and each component maps to its LibreOffice application identity
(Writer / Calc / Impress / Draw / Base / Math). The `implemented` flag keeps the
branding honest — only the components that render/compute through the shared
substrate today are reported as implemented.
"""

use std.spec
use app.office.libreoffice.{libreoffice_suite_name, libreoffice_app_name, libreoffice_apps, libreoffice_implemented_apps, libreoffice_plugin_entries}

describe "LibreOffice branding: suite and application names":
    """The suite and its six applications carry their LibreOffice names."""

    it "names the suite LibreOffice":
        expect(libreoffice_suite_name()).to_equal("LibreOffice")

    it "maps word/excel/ppt to Writer/Calc/Impress":
        expect(libreoffice_app_name("word")).to_equal("Writer")
        expect(libreoffice_app_name("excel")).to_equal("Calc")
        expect(libreoffice_app_name("ppt")).to_equal("Impress")

    it "maps draw/db/math to Draw/Base/Math":
        expect(libreoffice_app_name("draw")).to_equal("Draw")
        expect(libreoffice_app_name("db")).to_equal("Base")
        expect(libreoffice_app_name("math")).to_equal("Math")

    it "lists all six LibreOffice applications":
        expect(libreoffice_apps().len()).to_equal(6)

describe "LibreOffice branding: honest implemented status":
    """Only the three substrate-backed apps are reported implemented."""

    it "reports Writer, Calc, Impress, Draw, and Base as implemented":
        val names = libreoffice_implemented_apps()
        expect(names.len()).to_equal(5)
        expect(names).to_contain("Writer")
        expect(names).to_contain("Calc")
        expect(names).to_contain("Impress")
        expect(names).to_contain("Draw")
        expect(names).to_contain("Base")

    it "emits a LibreOffice-branded plugin entry per application":
        val entries = libreoffice_plugin_entries()
        expect(entries.len()).to_equal(6)
        val first = entries[0]
        expect(first.name).to_equal("libreoffice-writer")
