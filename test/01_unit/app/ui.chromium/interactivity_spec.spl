# Feature: Chromium Shell Interactivity (V3, Row 5 — M7)
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec. Verifies the M7 interactivity layer wires the
# M6 `TabManager` into the chromium shell:
#
#   * `chromium_hotkey_action` maps Ctrl+T / Ctrl+W / Ctrl+Tab /
#     Ctrl+Shift+Tab to the matching symbolic tab action, and returns
#     `"none"` for unmatched combinations.
#   * `apply_hotkey_action` mutates a `TabManager` according to that
#     symbol (new tab / close tab / next / prev).
#   * `hit_test_tab_strip` resolves a (window-space) click on the tab
#     strip to a tab index.
#
# No winit / FFI / compositor bring-up — the whole M7 decision surface
# is pure, so the spec can exercise synthetic events directly.

use app.ui.chromium.app.{
    chromium_hotkey_action,
    apply_hotkey_action,
    hit_test_tab_strip,
    TAB_STRIP_HEIGHT
}
use app.ui.chromium.tab_manager.{TabManager}

# =========================================================================
# Test Group 1: chromium_hotkey_action — modifier decoding
# =========================================================================

describe "Chromium M7 hotkey table":
    """The pure `chromium_hotkey_action` decision function mapping
    raw (keycode, modifier-bitmask) pairs to symbolic tab actions."""

    it "Ctrl+T returns new_tab":
        """Ctrl (0x02) + T (84) is the Chrome/Firefox new-tab shortcut."""
        expect(chromium_hotkey_action(84, 2) == "new_tab").to_be_true()

    it "Ctrl+W returns close_tab":
        """Ctrl+W closes the active tab."""
        expect(chromium_hotkey_action(87, 2) == "close_tab").to_be_true()

    it "Ctrl+Tab returns next_tab":
        expect(chromium_hotkey_action(9, 2) == "next_tab").to_be_true()

    it "Ctrl+Shift+Tab returns prev_tab":
        # Ctrl + Shift = 0x03
        expect(chromium_hotkey_action(9, 3) == "prev_tab").to_be_true()

    it "bare T (no Ctrl) returns none":
        expect(chromium_hotkey_action(84, 0) == "none").to_be_true()

    it "Alt+T (no Ctrl) returns none":
        # Alt only = 0x04
        expect(chromium_hotkey_action(84, 4) == "none").to_be_true()

# =========================================================================
# Test Group 2: apply_hotkey_action — TabManager mutation
# =========================================================================

describe "Chromium M7 apply_hotkey_action":

    it "new_tab grows the manager by one":
        var mgr = TabManager.new()
        val before = mgr.count()
        val changed = apply_hotkey_action("new_tab", mgr)
        expect(changed).to_be_true()
        expect(mgr.count() == before + 1).to_be_true()

    it "close_tab on empty manager is a no-op":
        var mgr = TabManager.new()
        val changed = apply_hotkey_action("close_tab", mgr)
        expect(changed == false).to_be_true()
        expect(mgr.is_empty()).to_be_true()

    it "close_tab removes the active tab":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        val changed = apply_hotkey_action("close_tab", mgr)
        expect(changed).to_be_true()
        expect(mgr.count() == 1).to_be_true()

    it "next_tab wraps from last back to zero":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        # active is 1 (freshly created "b"); next wraps to 0.
        val changed = apply_hotkey_action("next_tab", mgr)
        expect(changed).to_be_true()
        expect(mgr.active_index_of() == 0).to_be_true()

    it "prev_tab wraps from zero to last":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.new_tab("c")
        mgr.switch_to(0)
        val changed = apply_hotkey_action("prev_tab", mgr)
        expect(changed).to_be_true()
        expect(mgr.active_index_of() == 2).to_be_true()

    it "next_tab on a single-tab manager is a no-op":
        var mgr = TabManager.new()
        mgr.new_tab("only")
        val changed = apply_hotkey_action("next_tab", mgr)
        expect(changed == false).to_be_true()
        expect(mgr.active_index_of() == 0).to_be_true()

    it "unknown action is a no-op":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        val changed = apply_hotkey_action("bogus", mgr)
        expect(changed == false).to_be_true()

# =========================================================================
# Test Group 3: hit_test_tab_strip — click routing
# =========================================================================

describe "Chromium M7 tab-strip hit testing":

    it "returns -1 when the click is below the strip":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        expect(hit_test_tab_strip(mgr, 10, TAB_STRIP_HEIGHT + 5, 1024) == -1).to_be_true()

    it "returns -1 on an empty manager":
        var mgr = TabManager.new()
        expect(hit_test_tab_strip(mgr, 10, 5, 1024) == -1).to_be_true()

    it "returns 0 for a click in the first slot":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        # Two tabs, 1024 px strip -> slot = 512; x=10 is in slot 0.
        expect(hit_test_tab_strip(mgr, 10, 5, 1024) == 0).to_be_true()

    it "returns 1 for a click in the second slot":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        expect(hit_test_tab_strip(mgr, 600, 5, 1024) == 1).to_be_true()

    it "clamps to the last tab for a click past the end":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.new_tab("c")
        # 1024 / 3 = 341 per slot; x=1023 is past idx 2 due to rounding.
        val idx = hit_test_tab_strip(mgr, 1023, 5, 1024)
        expect(idx == 2).to_be_true()

    it "returns -1 for a negative x":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        expect(hit_test_tab_strip(mgr, -1, 5, 1024) == -1).to_be_true()
