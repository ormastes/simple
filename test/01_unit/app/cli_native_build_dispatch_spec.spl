describe "native-build dispatch fast path":
    extern fn rt_file_read_text(path: text) -> text

    it "routes native-build directly to the compiled implementation":
        val source = rt_file_read_text("src/app/cli/dispatch.spl") ?? ""

        expect(source).to_contain("cli_native_build")
        expect(source).to_contain("if entry.name == \"native-build\":")
        expect(source).to_contain("return cli_native_build(args)")

    it "treats llvm native-build as a pure Simple backend":
        val source = rt_file_read_text("src/app/cli/_CliMain/main_and_help.spl") ?? ""

        expect(source).to_contain("backend == \"llvm\"")
        expect(source).to_contain("return cli_native_build(args)")
