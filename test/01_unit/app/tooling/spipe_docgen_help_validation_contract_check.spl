use app.spipe_docgen.spipe_docgen.main.{run_spipe_docgen}
use app.io.mod.{dir_remove_all, file_exists}
use std.nogc_sync_mut.io.time_ops.{time_now_unix_micros}

extern fn rt_exit(code: i32)

val output = "/tmp/spipe_docgen_mixed_help_contract_" + time_now_unix_micros().to_string()
val _cleanup_before = dir_remove_all(output)
val sole_help = run_spipe_docgen(["--help"])
val direct_help = run_spipe_docgen(["spipe-docgen", "-h"])
val mixed_spec = run_spipe_docgen(["missing_spec.spl", "--help", "--output", output])
val mixed_unknown = run_spipe_docgen(["--help", "--outpt", output])
val repeated_help = run_spipe_docgen(["--help", "-h"])
val repeated_command = run_spipe_docgen(["spipe-docgen", "spipe_docgen", "--help"])
val late_command = run_spipe_docgen(["--help", "spipe-docgen"])
val output_exists = file_exists(output)
val _cleanup_after = dir_remove_all(output)

if (sole_help != 0 or direct_help != 0 or mixed_spec != 2 or
    mixed_unknown != 2 or repeated_help != 2 or repeated_command != 2 or
    late_command != 2 or output_exists):
    print "FAIL: spipe-docgen accepted mixed help"
    rt_exit(1)

print "PASS: spipe-docgen accepts help only when used alone"
rt_exit(0)
