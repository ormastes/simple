use compiler.tools.duplicate_check.detector.{find_duplicates, collect_files, read_detector_source}
use compiler.tools.duplicate_check.cache.{new_token_cache_manager}
use compiler.tools.duplicate_check.config.{default_config, apply_analysis_mode}
use app.io.mod.{shell}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool

fn ensure_clean_dir(path: text):
    shell("rm -rf '{path}'")
    expect(rt_dir_create(path, true)).to_equal(true)

fn write_test_file(path: text, content: text):
    expect(rt_file_write_text(path, content)).to_equal(true)

fn lexical_config():
    var config = apply_analysis_mode(default_config(), "token")
    config.min_tokens = 8
    config.min_lines = 3
    config.min_impact = 1
    config.exclude_patterns = []
    config.quiet = true
    config

fn cosine_config():
    var config = lexical_config()
    config = apply_analysis_mode(config, "cosine")
    config.similarity_threshold = 0.55
    config

fn contains_path(files: [text], expected: text) -> bool:
    for file in files:
        if file == expected:
            return true
    false

fn has_tail_pair(groups, file_a: text, file_b: text, tail_line: i64) -> bool:
    for group in groups:
        var has_a = false
        var has_b = false
        for block in group.blocks:
            if block.line_start >= tail_line:
                if block.file == file_a:
                    has_a = true
                if block.file == file_b:
                    has_b = true
        if has_a and has_b and group.occurrences == 2 and group.blocks.len() == 2:
            return true
    false

describe "duplicate_check detector grouping regressions":
    it "ignores identical comment-only code-shaped windows in token mode":
        val root = "/tmp/simple_duplicate_detector_comment_only"
        ensure_clean_dir(root)

        val comments = "# fn fake(seed: i64) -> i64:\n#     val total = seed + 1\n#     return total\n"
        val file_a = "{root}/a.spl"
        val file_b = "{root}/b.spl"
        write_test_file(file_a, comments)
        write_test_file(file_b, comments)

        val groups = find_duplicates([file_a, file_b], lexical_config(), new_token_cache_manager())

        expect(groups.len()).to_equal(0)

    it "ignores identical triple-docstring-only code-shaped windows in token mode":
        val root = "/tmp/simple_duplicate_detector_docstring_only"
        ensure_clean_dir(root)

        val docstring = "\"\"\"\nfn fake(seed: i64) -> i64:\n    val total = seed + 1\n    return total\n\"\"\"\n"
        val file_a = "{root}/a.spl"
        val file_b = "{root}/b.spl"
        write_test_file(file_a, docstring)
        write_test_file(file_b, docstring)

        val groups = find_duplicates([file_a, file_b], lexical_config(), new_token_cache_manager())

        expect(groups.len()).to_equal(0)

    it "keeps real duplicated functions in token mode":
        val root = "/tmp/simple_duplicate_detector_real_function"
        ensure_clean_dir(root)

        val body = "fn shared_logic(seed: i64) -> i64:\n    val base = seed + 1\n    val total = base * 2\n    return total\n"
        val file_a = "{root}/a.spl"
        val file_b = "{root}/b.spl"
        write_test_file(file_a, body)
        write_test_file(file_b, body)

        val groups = find_duplicates([file_a, file_b], lexical_config(), new_token_cache_manager())

        expect(groups.len()).to_be_greater_than(0)
        expect(groups[0].blocks[0].token_count).to_be_greater_than(8)

    it "honors the minimum token count in token mode":
        val root = "/tmp/simple_duplicate_detector_min_tokens"
        ensure_clean_dir(root)

        val body = "fn shared(seed: i64) -> i64:\n    val next = seed + 1\n    return next\n"
        val file_a = "{root}/a.spl"
        val file_b = "{root}/b.spl"
        write_test_file(file_a, body)
        write_test_file(file_b, body)

        var config = lexical_config()
        config.min_tokens = 100
        val groups = find_duplicates([file_a, file_b], config, new_token_cache_manager())

        expect(groups.len()).to_equal(0)

    it "keeps exact-match occurrences across three files":
        val root = "/tmp/simple_duplicate_detector_exact"
        ensure_clean_dir(root)

        val body = "fn shared_logic(seed: i64) -> i64:\n    val base = seed + 1\n    val total = base * 2\n    return total\n"
        val file_a = "{root}/a.spl"
        val file_b = "{root}/b.spl"
        val file_c = "{root}/c.spl"
        write_test_file(file_a, body)
        write_test_file(file_b, body)
        write_test_file(file_c, body)

        val groups = find_duplicates([file_a, file_b, file_c], cosine_config(), new_token_cache_manager())

        expect(groups.len()).to_be_greater_than(0)
        expect(groups[0].occurrences).to_equal(3)

    it "keeps cosine groups across similar files":
        val root = "/tmp/simple_duplicate_detector_cosine"
        ensure_clean_dir(root)

        val file_a = "{root}/alpha.spl"
        val file_b = "{root}/beta.spl"
        val content_a = "fn alpha_logic(seed: i64) -> i64:\n    val alpha_base = seed + 1\n    val alpha_total = alpha_base * 2\n    if alpha_total > seed:\n        return alpha_total\n    return seed\n"
        val content_b = "fn beta_logic(seed: i64) -> i64:\n    val beta_base = seed + 2\n    val beta_total = beta_base * 2\n    if beta_total > seed:\n        return beta_total\n    return seed\n"
        write_test_file(file_a, content_a)
        write_test_file(file_b, content_b)

        val groups = find_duplicates([file_a, file_b], cosine_config(), new_token_cache_manager())

        expect(groups.len()).to_be_greater_than(0)
        expect(groups[0].occurrences).to_equal(2)

    it "keeps one cosine group for non-overlapping renamed blocks in one file":
        val root = "/tmp/simple_duplicate_detector_cosine_same_file"
        ensure_clean_dir(root)

        val file = "{root}/both.spl"
        val content = "fn alpha_logic(seed: i64) -> i64:\n    val alpha_base = seed + 1\n    val alpha_total = alpha_base * 2\n    if alpha_total > seed:\n        return alpha_total\n    return seed\n\nfn beta_logic(seed: i64) -> i64:\n    val beta_base = seed + 2\n    val beta_total = beta_base * 2\n    if beta_total > seed:\n        return beta_total\n    return seed\n"
        write_test_file(file, content)

        val groups = find_duplicates([file], cosine_config(), new_token_cache_manager())

        expect(groups.len()).to_equal(1)
        expect(groups[0].occurrences).to_equal(2)
        expect(groups[0].blocks.len()).to_equal(2)
        expect(groups[0].blocks[0].line_end).to_be_less_than(groups[0].blocks[1].line_start)

    it "does not report overlapping windows as separate cosine occurrences":
        val root = "/tmp/simple_duplicate_detector_cosine_overlap"
        ensure_clean_dir(root)

        val file = "{root}/overlap.spl"
        val content = "fn overlap(seed: i64) -> i64:\n    val first = seed + 1\n    val second = seed + 1\n    val third = seed + 1\n    val fourth = seed + 1\n    return seed\n"
        write_test_file(file, content)

        val groups = find_duplicates([file], cosine_config(), new_token_cache_manager())

        expect(groups.len()).to_equal(0)

    it "keeps tail cosine clones after more than 320 earlier candidates":
        val root = "/tmp/simple_duplicate_detector_cosine_tail"
        ensure_clean_dir(root)

        val file_a = "{root}/alpha.spl"
        val file_b = "{root}/beta.spl"
        var content_a = ""
        var content_b = ""
        var i = 0
        while i < 165:
            content_a = content_a + "fn noise_alpha_{i}(value_alpha_{i}: i64) -> i64:\n    val unique_alpha_{i} = value_alpha_{i} + {i}\n    unique_alpha_{i} * 3\n\n"
            content_b = content_b + "fn noise_beta_{i}(value_beta_{i}: i64) -> i64:\n    val unique_beta_{i} = value_beta_{i} + {i + 1000}\n    unique_beta_{i} * 7\n\n"
            i = i + 1
        val tail_line = content_a.split("\n").len()
        content_a = content_a + "fn alpha_logic(seed: i64) -> i64:\n    val alpha_base = seed + 1\n    val alpha_total = alpha_base * 2\n    if alpha_total > seed:\n        return alpha_total\n    seed\n"
        content_b = content_b + "fn beta_logic(seed: i64) -> i64:\n    val beta_base = seed + 2\n    val beta_total = beta_base * 2\n    if beta_total > seed:\n        return beta_total\n    seed\n"
        write_test_file(file_a, content_a)
        write_test_file(file_b, content_b)

        val groups = find_duplicates([file_a, file_b], cosine_config(), new_token_cache_manager())

        expect(has_tail_pair(groups, file_a, file_b, tail_line)).to_equal(true)

    it "applies wildcard excludes during directory collection":
        val root = "/tmp/simple_duplicate_detector_collect"
        ensure_clean_dir(root)

        val keep = "{root}/keep_module.spl"
        val spec = "{root}/skip_module_spec.spl"
        val nested = "{root}/doc/skip_doc.spl"
        write_test_file(keep, "fn keep():\n    1\n")
        expect(rt_dir_create("{root}/doc", true)).to_equal(true)
        write_test_file(spec, "fn skip_spec():\n    2\n")
        write_test_file(nested, "fn skip_doc():\n    3\n")

        var config = lexical_config()
        config.exclude_patterns = ["**/*_spec.spl", "doc/"]

        val files = collect_files(root, config)

        expect(contains_path(files, keep)).to_equal(true)
        expect(contains_path(files, spec)).to_equal(false)
        expect(contains_path(files, nested)).to_equal(false)

    it "does not execute shell metacharacters in a collection path":
        val sentinel = "/tmp/simple_duplicate_detector_shell_injection"
        val _ = rt_file_delete(sentinel)
        val hostile_path = "/tmp/missing; touch {sentinel} #"

        val files = collect_files(hostile_path, lexical_config())

        expect(files.len()).to_equal(0)
        expect(rt_file_exists(sentinel)).to_equal(false)

    it "does not execute shell metacharacters in a source path":
        val sentinel = "/tmp/simple_duplicate_detector_read_shell_injection"
        val _ = rt_file_delete(sentinel)
        val hostile_path = "/tmp/missing'; touch {sentinel}; #"

        val source = read_detector_source(hostile_path)

        expect(source).to_equal("")
        expect(rt_file_exists(sentinel)).to_equal(false)
