use app.verify.options.{verify_option_error}

extern fn rt_exit(code: i32)

val unknown = verify_option_error(["--not-a-verify-option"])
val typo_help = verify_option_error(["--not-a-verify-option", "--help"])
val bare_files = verify_option_error(["--files"])
val empty_files = verify_option_error(["--files="])
val empty_csv_item = verify_option_error(["--files=a.spl,"])
val empty_positional = verify_option_error([""])
val whitespace_positional = verify_option_error(["  "])
val repeated_all = verify_option_error(["--all", "--all"])
val repeated_files = verify_option_error(["--files=a.spl", "--files=b.spl"])
val conflicting_all = verify_option_error(["--all", "a.spl"])
val all_and_files = verify_option_error(["--all", "--files=a.spl"])
val files_and_positional = verify_option_error(["--files=a.spl", "b.spl"])
val status_tail = verify_option_error(["status", "--bogus"])
val valid_default = verify_option_error(["--files=a.spl,b.spl", "--no-write-report"])
val valid_quality = verify_option_error(["quality", "a.spl", "--no-write-report"])
val valid_lean_status = verify_option_error(["--lean-status"])
val valid_help = verify_option_error(["--help"])

# A non-empty preflight error is returned before main() reaches run_worker(),
# which is the only path that writes verification reports.
val failed = unknown == "" or typo_help == "" or bare_files == "" or empty_files == "" or empty_csv_item == "" or empty_positional == "" or whitespace_positional == "" or repeated_all == "" or repeated_files == "" or conflicting_all == "" or all_and_files == "" or files_and_positional == "" or status_tail == "" or valid_default != "" or valid_quality != "" or valid_lean_status != "" or valid_help != ""
if failed:
    print "FAIL: verify option preflight did not fail closed before report work"
    rt_exit(1)

print "PASS: verify rejects invalid options before report work"
rt_exit(0)
