extern fn rt_file_read_text(path: text) -> text

describe "test daemon full owner routing":
    it "starts the full daemon entry instead of the light protocol":
        val client = rt_file_read_text("src/app/test_daemon/client.spl") ?? ""
        val launcher = rt_file_read_text("src/app/test_daemon/daemon_launcher.spl") ?? ""
        expect(client).to_contain("src/app/test_daemon/daemon_launcher.spl")
        expect(launcher).to_contain("src/app/test_daemon/daemon_main.spl")
        expect(client.contains("test-daemon\", \"start")).to_equal(false)

    it "uses one canonical daemon configuration in the CLI":
        val main = rt_file_read_text("src/app/test_daemon/main.spl") ?? ""
        expect(main).to_contain("test_daemon_config_default()")
        expect(main.contains("test_daemon_light")).to_equal(false)

    it "transports timeouts and routes classified sessions through the broker":
        val client = rt_file_read_text("src/app/test_daemon/client.spl") ?? ""
        val daemon = rt_file_read_text("src/app/test_daemon/daemon.spl") ?? ""
        expect(client).to_contain("req.fields[\"timeout_ms\"]")
        expect(daemon).to_contain("classify_test_session(test_path)")
        expect(daemon).to_contain("self.session_broker.execute_in_session")
        expect(daemon).to_contain("self.session_broker.reset_session")
        expect(daemon).to_contain("self.session_broker.release")
        expect(daemon).to_contain("daemon_response_new(request_id, result.status)")
