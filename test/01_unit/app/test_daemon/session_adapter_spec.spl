use app.test_daemon.session_adapter.{run_test_child, run_test_child_env, test_result_from_child_output}
use app.test_daemon.adapters.container_adapter.{container_create_args}
use app.test_daemon.adapters.remote_pc_adapter.{remote_pc_adapter_new, remote_test_command, remote_test_path_is_valid}
use app.test_daemon.session_broker.{session_broker_new}
use app.io.mod.{env_get, env_set}
use std.debug.remote.protocol.openocd.{openocd_program_command}
use std.terminal.types.{make_telnet_config}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool

describe "test daemon child execution":
    it "retains real runner counts and fails closed on unparseable output":
        val counted = test_result_from_child_output(
            "test/sample_spec.spl",
            "Results: 3 total, 2 passed, 1 failed, 2 skipped\n",
            "",
            1,
            25,
            1000
        )
        expect(counted.passed).to_equal(2)
        expect(counted.failed).to_equal(1)
        expect(counted.skipped).to_equal(2)

        val green = test_result_from_child_output(
            "test/sample_spec.spl", "Passed: 2\nFailed: 0\nSkipped: 1\n", "", 0, 10, 1000
        )
        expect(green.passed).to_equal(2)
        expect(green.failed).to_equal(0)
        expect(green.skipped).to_equal(1)

        val crashed_after_green = test_result_from_child_output(
            "test/sample_spec.spl", "Passed: 2\nFailed: 0\n", "crash", 7, 10, 1000
        )
        expect(crashed_after_green.failed).to_equal(1)

        val unparseable = test_result_from_child_output(
            "test/sample_spec.spl", "child exited quietly", "", 0, 5, 1000
        )
        expect(unparseable.passed).to_equal(0)
        expect(unparseable.failed).to_equal(1)

    it "retains configured remote PC adapters by terminal name":
        var broker = session_broker_new()
        broker.register_remote_pc(remote_pc_adapter_new(
            make_telnet_config("lab_pc", "192.0.2.1", 23)
        ))
        expect(broker.remote_pcs.len()).to_equal(1)
        expect(broker.remote_pcs[0].terminal_config.name).to_equal("lab_pc")

    it "quotes hostile remote test paths":
        expect(remote_test_command("a'b; touch /tmp/nope")).to_equal(
            "bin/simple test 'a'\\''b; touch /tmp/nope' --no-session-daemon --sequential 2>&1"
        )

    it "accepts only repo-relative Simple test paths for remote execution":
        expect(remote_test_path_is_valid("test/03_system/app/example_spec.spl")).to_equal(true)
        expect(remote_test_path_is_valid("../test/example_spec.spl")).to_equal(false)
        expect(remote_test_path_is_valid("test/../src/main.spl")).to_equal(false)
        expect(remote_test_path_is_valid("test/example_spec.spl\nfalse")).to_equal(false)

    it "rejects OpenOCD command injection in program paths":
        expect(openocd_program_command("build/firmware.elf").is_ok()).to_equal(true)
        expect(openocd_program_command("build/fw.elf; shutdown").is_err()).to_equal(true)

    it "keeps hostile container values in single argv entries":
        val name = "name; touch /tmp/nope"
        val image = "registry/image with spaces:latest"
        val args = container_create_args(name, image)
        expect(args.len()).to_equal(14)
        expect(args[2]).to_equal(name)
        expect(args[11]).to_equal(image)

    it "preserves hostile test and adapter arguments as argv":
        val path_sentinel = "/tmp/simple_test_daemon_path_injection"
        val adapter_sentinel = "/tmp/simple_test_daemon_adapter_injection"
        val _path_cleanup = rt_file_delete(path_sentinel)
        val _adapter_cleanup = rt_file_delete(adapter_sentinel)
        val hostile_path = "/tmp/missing; touch {path_sentinel} #"
        val hostile_socket = "/tmp/socket; touch {adapter_sentinel} #"

        val result = run_test_child(
            hostile_path,
            5000,
            ["--qemu-socket", hostile_socket]
        )

        expect(result.failed).to_equal(1)
        expect(rt_file_exists(path_sentinel)).to_equal(false)
        expect(rt_file_exists(adapter_sentinel)).to_equal(false)

    it "restores parent environment after bounded child execution":
        val key = "SIMPLE_TEST_DAEMON_ENV_RESTORE"
        val sentinel = "/tmp/simple_test_daemon_env_injection"
        val _cleanup = rt_file_delete(sentinel)
        env_set(key, "before")
        var child_env: {text: text} = {}
        child_env[key] = "hostile; touch {sentinel} #"

        val result = run_test_child_env(
            "/tmp/missing",
            5000,
            [],
            child_env
        )

        expect(result.failed).to_equal(1)
        expect(env_get(key)).to_equal("before")
        expect(rt_file_exists(sentinel)).to_equal(false)
