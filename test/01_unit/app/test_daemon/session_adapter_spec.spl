use app.test_daemon.session_adapter.{run_test_child}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool

describe "test daemon child execution":
    it "preserves hostile test and adapter arguments as argv":
        val path_sentinel = "/tmp/simple_test_daemon_path_injection"
        val adapter_sentinel = "/tmp/simple_test_daemon_adapter_injection"
        val _path_cleanup = rt_file_delete(path_sentinel)
        val _adapter_cleanup = rt_file_delete(adapter_sentinel)
        val hostile_path = "/tmp/missing; touch {path_sentinel} #"
        val hostile_socket = "/tmp/socket; touch {adapter_sentinel} #"

        val result = run_test_child(
            hostile_path,
            5000,
            ["--qemu-socket", hostile_socket]
        )

        expect(result.failed).to_equal(1)
        expect(rt_file_exists(path_sentinel)).to_equal(false)
        expect(rt_file_exists(adapter_sentinel)).to_equal(false)
