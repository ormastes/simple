use std.spec
use app.test_daemon.light_protocol.{LIGHT_REQUEST_DEFAULT_TIMEOUT_MS, LIGHT_REQUEST_MAX_TIMEOUT_MS, LIGHT_REQUEST_V1_HEADER, light_request_deadline, light_request_encode, light_request_expiry_micros, light_request_parse, light_request_timeout_ms_from_seconds}

describe "test daemon light request protocol":
    it "round-trips a tagged deadline and newline-containing path":
        val timeout_ms = light_request_timeout_ms_from_seconds(3)
        val expiry_micros = light_request_expiry_micros(1000000, timeout_ms)
        val path = "test/line\nbreak_spec.spl"
        val encoded = light_request_encode(path, expiry_micros)
        val request = light_request_parse(encoded)
        expect(encoded).to_equal("{LIGHT_REQUEST_V1_HEADER}\n4000000\n{path}")
        expect(request.0).to_equal(path)
        expect(request.1).to_equal(4000000)

    it "preserves the whole legacy path and default deadline":
        val path = "test/legacy\nnewline_spec.spl"
        val request = light_request_parse(path)
        val deadline = light_request_deadline(request.1, 5000000)
        expect(request.0).to_equal(path)
        expect(deadline.0).to_equal(false)
        expect(deadline.1).to_equal(LIGHT_REQUEST_DEFAULT_TIMEOUT_MS)

    it "reduces queued work to its remaining deadline and clamps long requests":
        val expiry_micros = light_request_expiry_micros(1000000, 10000)
        val queued = light_request_deadline(expiry_micros, 3500000)
        val clamped = light_request_deadline(999999999999, 1000000)
        expect(queued.0).to_equal(false)
        expect(queued.1).to_equal(7500)
        expect(clamped.1).to_equal(LIGHT_REQUEST_MAX_TIMEOUT_MS)

    it "rejects expired and malformed tagged requests before execution":
        val expired = light_request_deadline(4000000, 4000000)
        val malformed = light_request_parse("{LIGHT_REQUEST_V1_HEADER}\nnot-a-time\ntest/example_spec.spl")
        val malformed_deadline = light_request_deadline(malformed.1, 4000000)
        expect(expired.0).to_equal(true)
        expect(expired.1).to_equal(0)
        expect(malformed_deadline.0).to_equal(true)
