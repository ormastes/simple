use app.verify.test_quality_gate.{rg_scan_failed}

extern fn rt_exit(code: i32)
extern fn rt_file_read_text(path: text) -> text

val source = rt_file_read_text("src/app/verify/test_quality_gate.spl")

if (rg_scan_failed(0) or rg_scan_failed(1) or
    not rg_scan_failed(2) or not rg_scan_failed(127) or
    not rg_scan_failed(-1) or
    source.split("if rg_scan_failed(exit_code):").len() != 3):
    print "FAIL: verify quality scanner errors can false-green"
    rt_exit(1)

print "PASS: verify distinguishes no matches from scanner failure"
rt_exit(0)
