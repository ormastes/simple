use app.verify.full_verify.{select_scope_files}

extern fn rt_exit(code: i32)

val changed = ["src/app/cli/check.spl"]
val tracked = ["src/app/verify/main.spl", "src/app/mcp/main.spl"]
val all_scope = select_scope_files(["--all"], changed, tracked)
val changed_scope = select_scope_files([], changed, tracked)

if all_scope.len() != 2 or all_scope[0] != "src/app/verify/main.spl" or all_scope[1] != "src/app/mcp/main.spl" or changed_scope.len() != 1 or changed_scope[0] != "src/app/cli/check.spl":
    print "FAIL: verify --all did not select tracked project scope"
    rt_exit(1)

print "PASS: verify --all selects tracked files instead of changed files"
rt_exit(0)
