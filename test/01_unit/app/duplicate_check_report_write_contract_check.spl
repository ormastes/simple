use compiler.tools.duplicate_check.detector.{DuplicateGroup}
use compiler.tools.duplicate_check.formatter.{write_sdn_database}
use std.nogc_sync_mut.io.file_ops.{file_exists, file_read}

extern fn rt_exit(code: i32)

val report_path = "/tmp/duplicate_check_report_write_contract.sdn"
var groups: [DuplicateGroup] = []
val created = write_sdn_database(groups, report_path)
val report = file_read(report_path)
val rejected = write_sdn_database(groups, "/dev/null/duplicate_check_report_write_contract.sdn")

if not created or not file_exists(report_path) or not report.contains("total_groups: 0") or rejected:
    print "FAIL: duplicate-check report write contract"
    rt_exit(1)

print "PASS: duplicate-check writes reports and exposes write failures"
rt_exit(0)
