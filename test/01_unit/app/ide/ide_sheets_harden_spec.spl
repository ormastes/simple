# IDE sheets_compat hardening spec.
#
# Verifies that empty workbooks and empty formulas are handled gracefully.

use std.spec
use app.ide.sheets_compat.{ide_sheet_compat_probe, ide_sheet_compat_probe_empty, ide_sheet_compat_empty_formula_safe}

describe "sheets_compat: empty workbook and empty formula do not crash":

    it "empty workbook probe returns non-crashing result with correct app_id":
        val probe = ide_sheet_compat_probe_empty()
        expect(probe.app_id).to_equal("sheets")

    it "empty workbook used_range is safe (non-crash)":
        val probe = ide_sheet_compat_probe_empty()
        expect(probe.sample_range.len() >= 0).to_equal(true)

    it "empty formula display text does not return #CRASH":
        expect(ide_sheet_compat_empty_formula_safe()).to_equal(true)

    it "standard sheet probe formula_evaluator_ok is true":
        val probe = ide_sheet_compat_probe()
        expect(probe.formula_evaluator_ok).to_equal(true)

    it "standard sheet probe owner_module is non-empty":
        val probe = ide_sheet_compat_probe()
        expect(probe.owner_module.len() > 0).to_equal(true)
