use compiler.tools.duplicate_check.config.{default_config, config_validation_error}
use compiler.tools.duplicate_check.main.{run_duplicate_check}

extern fn rt_exit(code: i32)

var config = default_config()
config.similarity_threshold = 1.01
val similarity_error = config_validation_error(config)

config = default_config()
config.semantic_threshold = -0.01
val semantic_error = config_validation_error(config)

config = default_config()
config.semantic_drift_threshold = 1.01
val drift_error = config_validation_error(config)

config = default_config()
config.similarity_threshold = 0.0
config.semantic_threshold = 1.0
config.semantic_drift_threshold = 0.0
val boundary_error = config_validation_error(config)

config = default_config()
var big = 1.0e308
val infinity = big * 10.0
config.semantic_threshold = infinity - infinity
val nan_error = config_validation_error(config)

config = default_config()
config.min_tokens = 0
val min_tokens_error = config_validation_error(config)

config = default_config()
config.min_lines = 0
val min_lines_error = config_validation_error(config)

config = default_config()
config.min_impact = -1
val min_impact_error = config_validation_error(config)

config = default_config()
config.max_allowed = -1
val max_allowed_error = config_validation_error(config)

val clean = "test/fixtures/duplication/clean_pair"
val split_exit = run_duplicate_check(["duplicate-check", clean, "--semantic-threshold", "2"])
val equals_exit = run_duplicate_check(["duplicate-check", clean, "--similarity-threshold=1.1"])
val min_tokens_exit = run_duplicate_check(["duplicate-check", clean, "--min-tokens=-1"])
val min_lines_exit = run_duplicate_check(["duplicate-check", clean, "--min-lines=0"])
val min_impact_exit = run_duplicate_check(["duplicate-check", clean, "--min-impact=-1"])
val max_allowed_exit = run_duplicate_check(["duplicate-check", clean, "--max-allowed=-1"])
val malformed_integer_exit = run_duplicate_check(["duplicate-check", clean, "--min-tokens=nope"])
val malformed_similarity_exit = run_duplicate_check(["duplicate-check", clean, "--similarity-threshold=nope"])
val malformed_semantic_exit = run_duplicate_check(["duplicate-check", clean, "--semantic-threshold=nope"])

if (similarity_error == "" or semantic_error == "" or drift_error == "" or
    boundary_error != "" or nan_error == "" or min_tokens_error == "" or
    min_lines_error == "" or min_impact_error == "" or max_allowed_error == "" or
    split_exit != 2 or equals_exit != 2 or min_tokens_exit != 2 or
    min_lines_exit != 2 or min_impact_exit != 2 or max_allowed_exit != 2 or
    malformed_integer_exit != 2 or malformed_similarity_exit != 2 or
    malformed_semantic_exit != 2):
    print "FAIL: duplicate-check accepted an invalid threshold"
    rt_exit(1)

print "PASS: duplicate-check rejects invalid thresholds"
rt_exit(0)
