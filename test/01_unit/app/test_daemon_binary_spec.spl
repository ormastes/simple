use std.spec.{describe, it, expect}
use app.test_daemon.binary.{test_daemon_simple_binary}
use app.io.mod.{env_get, env_set, file_write, file_delete}

describe "test daemon binary selection":
    it "keeps a pre-deploy candidate through daemon child launches":
        val candidate = "/tmp/simple-test-daemon-candidate"
        val previous = env_get("SIMPLE_BINARY") ?? ""
        file_write(candidate, "candidate")
        env_set("SIMPLE_BINARY", candidate)
        val selected = test_daemon_simple_binary()
        env_set("SIMPLE_BINARY", previous)
        file_delete(candidate)
        expect(selected).to_equal(candidate)
