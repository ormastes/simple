use common.ui.builder.{button, panel, text_widget, build_tree_with_title}
use common.ui.state.{init_state}
use app.ui.browser.backend.{BrowserBackend}

extern fn rt_host_gpu_queue_reset()

fn browser_frame_checksum(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = (checksum + pixels[i].to_i64() * (i.to_i64() + 1)) % 2147483647
        i = i + 1
    checksum

fn browser_frame_nonuniform_count(pixels: [u32]) -> i64:
    if pixels.len() == 0:
        return 0
    val first = pixels[0]
    var count: i64 = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] != first:
            count = count + 1
        i = i + 1
    count

val root = panel("browser_queue_root", "Browser Queue", [
    text_widget("browser_queue_copy", "Queued frame"),
    button("browser_queue_action", "Run", "run")
])
val tree = build_tree_with_title(root, "Browser Queue", "dark")
val state = init_state(tree)

rt_host_gpu_queue_reset()
val backend = BrowserBackend.create(64, 48, "vulkan").unwrap()
backend.render_frame(state.tree, state)
val first_pixels = backend.pixels_argb_u32()
print("backend=" + backend.gpu_backend())
print("first_pixel_count=" + str(first_pixels.len()))
print("first_checksum=" + str(browser_frame_checksum(first_pixels)))
print("first_nonuniform_count=" + str(browser_frame_nonuniform_count(first_pixels)))
print("first_submit=" + backend.last_artifact_queue_submit_status)
print("first_drain=" + backend.last_artifact_queue_drain_status)
print("first_packet=" + str(backend.last_artifact_queue_packet_id))
print("first_drained=" + str(backend.last_artifact_queue_drained))
print("first_backend_handle=" + str(backend.last_artifact_queue_backend_handle))
print("first_reason=" + backend.last_artifact_queue_reason)
print("first_readback_status=" + backend.last_artifact_readback_status)
print("first_readback_backend=" + backend.last_artifact_readback_backend)
print("first_readback_pixel_count=" + str(backend.last_artifact_readback_pixel_count))
print("first_readback_checksum=" + str(backend.last_artifact_readback_checksum))
print("first_readback_reason=" + backend.last_artifact_readback_reason)

backend.render_frame(state.tree, state)
print("second_fast_hits=" + str(backend.static_frame_fast_hits))
print("second_submit=" + backend.last_artifact_queue_submit_status)
print("second_drain=" + backend.last_artifact_queue_drain_status)
print("second_packet=" + str(backend.last_artifact_queue_packet_id))
print("second_drained=" + str(backend.last_artifact_queue_drained))
print("second_backend_handle=" + str(backend.last_artifact_queue_backend_handle))
print("second_reason=" + backend.last_artifact_queue_reason)
print("second_readback_status=" + backend.last_artifact_readback_status)
print("second_readback_backend=" + backend.last_artifact_readback_backend)
print("second_readback_pixel_count=" + str(backend.last_artifact_readback_pixel_count))
print("second_readback_checksum=" + str(backend.last_artifact_readback_checksum))
print("second_readback_reason=" + backend.last_artifact_readback_reason)
