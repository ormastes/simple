use app.examples_check.main.{examples_check_option_error}

extern fn rt_exit(code: i32)

val unknown = examples_check_option_error(["examples-check", "--runx"])
val missing_timeout = examples_check_option_error(["examples-check", "--timeout"])
val swallowed_option = examples_check_option_error(["examples-check", "--binary", "--run"])
val empty_report = examples_check_option_error(["examples-check", "--report="])
val option_equals = examples_check_option_error(["examples-check", "--limit=--run"])
val bare_surface = examples_check_option_error(["examples-check", "--surface", "--run"])
val negative_timeout = examples_check_option_error(["examples-check", "--timeout", "-1"])
val negative_limit = examples_check_option_error(["examples-check", "--limit", "-1"])
val plus_limit = examples_check_option_error(["examples-check", "--limit=+1"])
val plus_timeout = examples_check_option_error(["examples-check", "--timeout=+1"])
val zero_timeout = examples_check_option_error(["examples-check", "--timeout=0"])
val timeout_overflow = examples_check_option_error(["examples-check", "--timeout=9223372036854776"])
val limit_overflow = examples_check_option_error(["examples-check", "--limit", "9223372036854775808"])
val numeric_boundaries = examples_check_option_error(["examples-check", "--timeout", "9223372036854775", "--limit=9223372036854775807"])
val leading_zeros = examples_check_option_error(["examples-check", "--timeout=0001", "--limit", "000"])
val zero_limit = examples_check_option_error(["examples-check", "--limit=0"])
val split_log = examples_check_option_error(["examples-check", "--log-mode", "json", "--progress", "dot"])
val valid = examples_check_option_error(["examples-check", "examples", "--run", "--timeout=20", "--limit", "3", "--binary=bin/simple", "--report", "report.md", "--log-mode=json"])

if (unknown == "" or missing_timeout == "" or swallowed_option == "" or
    empty_report == "" or option_equals == "" or bare_surface == "" or
    negative_timeout == "" or negative_limit == "" or plus_limit == "" or
    plus_timeout == "" or zero_timeout == "" or
    timeout_overflow == "" or limit_overflow == "" or
    numeric_boundaries != "" or leading_zeros != "" or zero_limit != "" or
    split_log != "" or valid != ""):
    print "FAIL: examples-check option preflight did not fail closed"
    rt_exit(1)

print "PASS: examples-check rejects malformed options before discovery"
rt_exit(0)
