use app.io._CliCommands.run_commands.{cli_run_fmt}

extern fn rt_exit(code: i32)

val missing = "test/fixtures/lint/no_such_fmt_input.spl"
val invalid_exit = cli_run_fmt(["fmt", missing, "--bogus"])
val check_exit = cli_run_fmt(["fmt", missing, "--check"])
val write_exit = cli_run_fmt(["fmt", missing, "--write"])
val help_exit = cli_run_fmt(["fmt", "-h"])

if invalid_exit != 2 or check_exit != 1 or write_exit != 1 or help_exit != 0:
    print "FAIL: dispatch fmt owner did not reject before I/O or preserve documented forms"
    rt_exit(1)

print "PASS: dispatch fmt owner is fail-closed without mutating a file"
rt_exit(0)
