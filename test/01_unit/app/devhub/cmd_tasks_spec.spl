# @cover src/app/devhub/cmd_tasks.spl 60%
#
# `devhub tasks` / `itf task_manager` (gh-issue-shaped facade over Jira +
# GitHub): fake-binary fixture spec, mirroring cmd_github_spec.spl's and
# cmd_jira_spec.spl's write-shim-and-override-PATH recipe (stub `gh`/`acli`
# scripts on PATH, record argv, emit canned JSON) plus a HOME override so
# load_config()/_tasks_config_value() see a fixture ~/.config/itf instead of
# the real one — NEVER contacts real GitHub/Jira.
#
# Covers: verb dispatch (list/view/create/comment/close/edit/search) for
# both backends, G1 JQL synthesis (incl. the `@me` -> `currentUser()`
# golden case, D3/D4), D6 `--backend all` merge + partial-failure
# semantics, the G5 github-edit workaround, the G1b jira label/assignee
# gap error, and unknown-verb/invalid-backend errors. Pure flag-mapping/
# JQL-synthesis helpers are also covered directly (no process/fixture
# needed) since they're the part unique to this file.

use app.devhub.cmd_tasks.{handle_tasks, _jira_build_list_jql, _looks_like_jira_key, _parse_limit, _strip_first_positional, _tasks_github_rows_from_json}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool
extern fn rt_env_get(key: text) -> text?
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

val FIXTURE_DIR = "build/test-itf-tasks-fixture"
val ARGV_LOG = "{FIXTURE_DIR}/argv.log"
val FIXTURE_HOME = "build/test-itf-tasks-fixture/home"


fn shell_ok(cmd: text) -> bool:
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
    exit_code == 0


fn install_fake_bin(name: text, script_body: text):
    """Write build/test-itf-tasks-fixture/<name> (chmod +x)."""
    val path = "{FIXTURE_DIR}/{name}"
    val _write = rt_file_write_text(path, script_body)
    shell_ok("/bin/chmod +x \"{path}\"")


fn write_fixture_config(backend: text, jira_done_status: text, jira_url: text, jira_email: text, jira_token: text):
    """Write config.sdn (jira: + tasks: sections) + auth.sdn under
    FIXTURE_HOME/.config/itf so load_config()/_tasks_config_value() see
    fixture values once HOME is overridden. Empty `backend`/
    `jira_done_status` omit those keys (so _tasks_backend_default()/
    _tasks_jira_done_status() fall back to their built-in defaults).
    `backend` writes the real `tasks: default_backend:` ItfConfig field
    (ItfConfig.tasks_default_backend); `jira_done_status` still writes the
    raw-parsed `tasks: jira_done_status:` key (no ItfConfig field yet,
    unscoped remainder of gap G6)."""
    val dir = "{FIXTURE_HOME}/.config/itf"
    val _mk = rt_dir_create_all(dir)
    var config_body = "jira:\n    url: {jira_url}\n    acli_path: acli\n    email: {jira_email}\n"
    config_body = config_body + "\ntasks:\n"
    if backend != "":
        config_body = config_body + "    default_backend: {backend}\n"
    if jira_done_status != "":
        config_body = config_body + "    jira_done_status: {jira_done_status}\n"
    val _cfg = rt_file_write_text("{dir}/config.sdn", config_body)
    val auth_body = if jira_token != "": "jira:\n    token: \"{jira_token}\"\n" else: ""
    rt_file_write_text("{dir}/auth.sdn", auth_body)


fn clear_fixture_config():
    """Remove any config.sdn/auth.sdn so backend-default/jira-url reads
    behave as "unconfigured" (github default, no jira curl fallback)."""
    val dir = "{FIXTURE_HOME}/.config/itf"
    val _a = rt_file_delete("{dir}/config.sdn")
    val _b = rt_file_delete("{dir}/auth.sdn")


fn reset_fixture():
    val _mk = rt_dir_create_all(FIXTURE_DIR)
    rt_file_delete(ARGV_LOG)


fn run_tasks(args: [text]) -> (i64, text):
    """Run handle_tasks(args) with FIXTURE_DIR prepended to PATH (so `gh`/
    `acli`/`curl` resolve to fakes) and HOME pointed at FIXTURE_HOME (so
    config/auth reads never touch the real ~/.config/itf). Always restores
    PATH/HOME afterward. Returns (exit_code, argv_log_contents)."""
    val original_path = rt_env_get("PATH") ?? ""
    val original_home = rt_env_get("HOME") ?? ""
    val _set_path = rt_env_set("PATH", "{FIXTURE_DIR}:{original_path}")
    val _set_home = rt_env_set("HOME", FIXTURE_HOME)
    val code = handle_tasks(args)
    val _restore_path = rt_env_set("PATH", original_path)
    val _restore_home = rt_env_set("HOME", original_home)
    val log = rt_file_read_text(ARGV_LOG)
    (code, log)


# gh fake: records argv; --version for gh_available(); `issue list` returns
# an empty array (exercises the "no issues" path harmlessly); anything else
# (view/create/comment/close/edit passthrough) prints "ok" and exits 0.
val FAKE_GH_OK = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\ncase \"$1\" in\n  --version) echo 'gh version 2.0.0 (fake)'; exit 0 ;;\nesac\nif [ \"$1\" = issue ] && [ \"$2\" = list ]; then\n  echo '[]'\n  exit 0\nfi\necho 'ok'\nexit 0\n"

val FAKE_GH_NOT_FOUND = "#!/bin/sh\nexit 127\n"

# acli fake: records argv; `jira workitem search` -> empty array; `view` ->
# a minimal valid issue; `create` -> a key; anything else (edit/comment/
# transition) exits 0 with no output, matching cmd_jira_spec.spl's
# FAKE_ACLI_OK shape for mutation calls.
val FAKE_ACLI_OK = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\ncase \"$3\" in\n  search) echo '[]'; exit 0 ;;\n  view) echo '{{\"key\":\"PROJ-1\",\"summary\":\"Fixture bug\",\"status\":{{\"name\":\"Open\"}}}}'; exit 0 ;;\n  create) echo '{{\"key\":\"PROJ-9\"}}'; exit 0 ;;\nesac\nexit 0\n"

val FAKE_ACLI_FAIL = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\necho 'acli: not authenticated' >&2\nexit 1\n"

# Non-empty variants, so the --backend all merge/prefix loop in
# _tasks_list_all actually runs a row through it instead of hitting the
# empty-array short-circuit every other fixture above uses.
val FAKE_GH_LIST_ONE = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\ncase \"$1\" in\n  --version) echo 'gh version 2.0.0 (fake)'; exit 0 ;;\nesac\nif [ \"$1\" = issue ] && [ \"$2\" = list ]; then\n  echo '[{{\"number\":42,\"title\":\"fixture issue\",\"state\":\"OPEN\",\"author\":{{\"login\":\"alice\"}},\"updatedAt\":\"2026-07-01T00:00:00Z\"}}]'\n  exit 0\nfi\necho 'ok'\nexit 0\n"

val FAKE_ACLI_SEARCH_ONE = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\ncase \"$3\" in\n  search) echo '[{{\"key\":\"PROJ-1\",\"fields\":{{\"summary\":\"Fixture bug\",\"status\":{{\"name\":\"In Progress\"}},\"assignee\":{{\"displayName\":\"Bob\"}},\"updated\":\"2026-07-01T00:00:00Z\"}}}}]'; exit 0 ;;\nesac\nexit 0\n"


describe "cmd_tasks pure helpers":

    context "_jira_build_list_jql (G1 — D2/D3/D4 synthesis)":

        it "golden case: @me assignee synthesizes currentUser(), default open state":
            expect(_jira_build_list_jql("@me", "", "open", "")).to_equal("assignee = currentUser() AND statusCategory != Done")

        it "a literal (non-@me) assignee becomes a quoted JQL literal":
            expect(_jira_build_list_jql("alice", "", "", "")).to_equal("assignee = \"alice\"")

        it "label filter":
            expect(_jira_build_list_jql("", "bug", "", "")).to_equal("labels = \"bug\"")

        it "state=closed maps to statusCategory = Done":
            expect(_jira_build_list_jql("", "", "closed", "")).to_equal("statusCategory = Done")

        it "state=all omits the statusCategory clause entirely":
            expect(_jira_build_list_jql("", "", "all", "")).to_equal("")

        it "search text becomes a JQL text ~ clause":
            expect(_jira_build_list_jql("", "", "", "urgent")).to_equal("text ~ \"urgent\"")

        it "combines multiple filters with AND, in assignee/label/state/search order":
            expect(_jira_build_list_jql("@me", "bug", "open", "urgent")).to_equal("assignee = currentUser() AND labels = \"bug\" AND statusCategory != Done AND text ~ \"urgent\"")

        it "no filters at all yields an empty JQL string":
            expect(_jira_build_list_jql("", "", "", "")).to_equal("")

    context "_looks_like_jira_key (backend auto-detect from id shape)":

        it "recognizes a standard jira key":
            expect(_looks_like_jira_key("PROJ-123")).to_equal(true)

        it "rejects a bare github issue number":
            expect(_looks_like_jira_key("123")).to_equal(false)

        it "rejects a lowercase prefix":
            expect(_looks_like_jira_key("proj-123")).to_equal(false)

        it "rejects a non-numeric suffix":
            expect(_looks_like_jira_key("PROJ-abc")).to_equal(false)

        it "rejects a missing suffix":
            expect(_looks_like_jira_key("PROJ-")).to_equal(false)

    context "_parse_limit":

        it "parses a plain decimal string":
            expect(_parse_limit("10", 30)).to_equal(10)

        it "falls back to the default on empty input":
            expect(_parse_limit("", 30)).to_equal(30)

        it "falls back to the default on non-digit input":
            expect(_parse_limit("abc", 30)).to_equal(30)

        it "falls back to the default on a leading-negative sign":
            expect(_parse_limit("-5", 30)).to_equal(30)

    context "_tasks_github_rows_from_json (D6 merge row extraction)":

        it "extracts number/state/author/title/updated from a one-item gh --json array":
            # NOTE: braces doubled ({{/}}) per cmd_github_spec.spl's nested-JSON
            # literal rule (a single flat `{"a":"b"}` is fine, but nesting two
            # levels deep like `{"a":{"b":"c"}}` needs doubling).
            val raw = "[{{\"number\":42,\"title\":\"fixture issue\",\"state\":\"OPEN\",\"author\":{{\"login\":\"alice\"}},\"updatedAt\":\"2026-07-01T00:00:00Z\"}}]"
            val rows = _tasks_github_rows_from_json(raw)
            expect(rows.len()).to_equal(1)
            expect(rows[0][0]).to_equal("#42")
            expect(rows[0][2]).to_equal("alice")
            expect(rows[0][3]).to_equal("fixture issue")

        it "returns an empty row list for a non-array payload":
            expect(_tasks_github_rows_from_json("{{\"not\":\"an array\"}}").len()).to_equal(0)

    context "_strip_first_positional (search -> list --search delegation)":

        it "removes only the first bare positional, keeping flag+value pairs":
            expect(_strip_first_positional(["urgent", "--backend", "github"])).to_equal(["--backend", "github"])

        it "keeps a second positional if present":
            expect(_strip_first_positional(["urgent", "--backend", "github", "extra"])).to_equal(["--backend", "github", "extra"])

        it "returns an empty array unchanged":
            expect(_strip_first_positional([])).to_equal([])


describe "itf tasks (fake-binary fixture)":

    context "list — github backend":

        it "exits 0 and forwards default --json fields to gh":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["list", "--backend", "github"])
            expect(code).to_equal(0)
            expect(log.contains("issue list --json number,title,state,author,updatedAt")).to_equal(true)

        it "passes --assignee/--label/--state/--search/--limit through to gh verbatim (D2/D4)":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["list", "--backend", "github", "--assignee", "@me", "--state", "closed", "--label", "bug", "--search", "urgent", "--limit", "5"])
            expect(code).to_equal(0)
            expect(log.contains("--assignee @me")).to_equal(true)
            expect(log.contains("--state closed")).to_equal(true)
            expect(log.contains("--label bug")).to_equal(true)
            expect(log.contains("--search urgent")).to_equal(true)
            expect(log.contains("--limit 5")).to_equal(true)

    context "list — jira backend":

        it "exits 0 and synthesizes a JQL query passed to acli --jql":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["list", "--backend", "jira", "--state", "open"])
            expect(code).to_equal(0)
            expect(log.contains("--jql statusCategory != Done")).to_equal(true)

        it "@me golden path: --assignee @me reaches acli as currentUser()":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["list", "--backend", "jira", "--assignee", "@me"])
            expect(code).to_equal(0)
            expect(log.contains("currentUser()")).to_equal(true)

    context "list — --backend all (D6 merge)":

        it "queries both backends, merges non-empty rows, and exits 0":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_LIST_ONE)
            install_fake_bin("acli", FAKE_ACLI_SEARCH_ONE)
            val (code, log) = run_tasks(["list", "--backend", "all"])
            expect(code).to_equal(0)
            expect(log.contains("issue list")).to_equal(true)
            expect(log.contains("jira workitem search")).to_equal(true)

        it "partial failure: github missing, jira succeeds -> still exits 0":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_NOT_FOUND)
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["list", "--backend", "all"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem search")).to_equal(true)

        it "both backends fail -> exits 1":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_NOT_FOUND)
            install_fake_bin("acli", FAKE_ACLI_FAIL)
            val (code, _log) = run_tasks(["list", "--backend", "all"])
            expect(code).to_equal(1)

    context "search — thin alias for list --search":

        it "github: promotes the positional query into --search":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["search", "urgent", "--backend", "github"])
            expect(code).to_equal(0)
            expect(log.contains("--search urgent")).to_equal(true)

        it "exits 1 when no query is given":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["search", "--backend", "github"])
            expect(code).to_equal(1)

    context "view — backend auto-detect from id shape":

        it "a PROJ-123-shaped id routes to jira even with no --backend flag":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["view", "PROJ-1"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem view PROJ-1")).to_equal(true)

        it "a bare number with configured tasks:default_backend=github routes to gh":
            reset_fixture()
            clear_fixture_config()
            write_fixture_config("github", "", "", "", "")
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["view", "42"])
            expect(code).to_equal(0)
            expect(log.contains("issue view 42")).to_equal(true)

        it "D1: an explicit --backend flag overrides a configured tasks:default_backend":
            # Uses a bare number (not a PROJ-123-shaped id) so id-shape
            # auto-detection can't also explain a jira result: config
            # default is "github" here, so only an honored --backend flag
            # routes this to jira (an ignored flag would fall through to
            # "42" -> not jira-shaped -> configured "github" -> gh, which
            # isn't installed in this fixture and would fail).
            reset_fixture()
            clear_fixture_config()
            write_fixture_config("github", "", "", "", "")
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["view", "42", "--backend", "jira"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem view 42")).to_equal(true)

        it "--backend all is rejected for a single-item verb":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["view", "PROJ-1", "--backend", "all"])
            expect(code).to_equal(1)

    context "create":

        it "github: requires --title":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["create", "--backend", "github", "--body", "B"])
            expect(code).to_equal(1)

        it "github: forwards --title/--body to gh":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["create", "--backend", "github", "--title", "T", "--body", "B"])
            expect(code).to_equal(0)
            expect(log.contains("issue create --title T --body B")).to_equal(true)

        it "jira: requires --project":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, _log) = run_tasks(["create", "--backend", "jira", "--title", "T"])
            expect(code).to_equal(1)

        it "jira: --title translates to --summary for acli":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["create", "--backend", "jira", "--project", "PROJ", "--title", "New bug", "--body", "desc"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem create --project PROJ --summary New bug")).to_equal(true)
            expect(log.contains("--description desc")).to_equal(true)

    context "comment":

        it "requires --body regardless of backend":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["comment", "42", "--backend", "github"])
            expect(code).to_equal(1)

        it "github: forwards id + --body to gh":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["comment", "42", "--backend", "github", "--body", "hi"])
            expect(code).to_equal(0)
            expect(log.contains("issue comment 42 --body hi")).to_equal(true)

        it "jira: forwards id + --body to acli":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["comment", "PROJ-1", "--backend", "jira", "--body", "status update"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem comment PROJ-1 --body status update")).to_equal(true)

    context "close (D5 — jira transitions to a configured done-status)":

        it "github: passthrough to gh issue close":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["close", "42", "--backend", "github"])
            expect(code).to_equal(0)
            expect(log.contains("issue close 42")).to_equal(true)

        it "jira: transitions to the default 'Done' status when unconfigured":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["close", "PROJ-1", "--backend", "jira"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem transition PROJ-1 --status Done")).to_equal(true)

        it "jira: honors a configured tasks:jira_done_status override":
            reset_fixture()
            clear_fixture_config()
            write_fixture_config("", "Resolved", "", "", "")
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["close", "PROJ-1", "--backend", "jira"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem transition PROJ-1 --status Resolved")).to_equal(true)

        it "jira: --reason has no equivalent and is not forwarded to acli":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["close", "PROJ-1", "--backend", "jira", "--reason", "not planned"])
            expect(code).to_equal(0)
            expect(log.contains("--reason")).to_equal(false)

    context "edit":

        it "github: G5 workaround calls gh directly for `issue edit`":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("gh", FAKE_GH_OK)
            val (code, log) = run_tasks(["edit", "123", "--backend", "github", "--add-label", "bug"])
            expect(code).to_equal(0)
            expect(log.contains("issue edit 123 --add-label bug")).to_equal(true)

        it "jira: --title/--body translate to `update --summary/--description`":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["edit", "PROJ-1", "--backend", "jira", "--title", "New T", "--body", "New B"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem edit PROJ-1 --summary New T --description New B")).to_equal(true)

        it "jira: --status transitions via `transition`":
            reset_fixture()
            clear_fixture_config()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_tasks(["edit", "PROJ-1", "--backend", "jira", "--status", "In Progress"])
            expect(code).to_equal(0)
            expect(log.contains("jira workitem transition PROJ-1 --status In Progress")).to_equal(true)

        it "jira: --add-label is a defined not-yet-supported gap (G1b), exits 1":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["edit", "PROJ-1", "--backend", "jira", "--add-label", "bug"])
            expect(code).to_equal(1)

        it "jira: no edit flags at all exits 1":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["edit", "PROJ-1", "--backend", "jira"])
            expect(code).to_equal(1)

    context "errors":

        it "unknown top-level verb exits 1":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["bogus"])
            expect(code).to_equal(1)

        it "invalid --backend value exits 1":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["list", "--backend", "nope"])
            expect(code).to_equal(1)

        it "missing id for view exits 1":
            reset_fixture()
            clear_fixture_config()
            val (code, _log) = run_tasks(["view"])
            expect(code).to_equal(1)
