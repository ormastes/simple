# @cover src/app/devhub/config.spl 60%

use app.devhub.config.{ItfConfig, resolve_editor, _apply_config_value, load_config, save_auth_token, load_auth_token}
use app.devhub.errors.{ItfError}

extern fn rt_env_get(key: text) -> text?
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool

# Fixture-HOME harness (same pattern as wiki_backend_routing_spec.spl /
# cmd_jira_spec.spl / cmd_tasks_spec.spl): points HOME at a throwaway
# build/ directory so load_config()/load_auth_token()/save_auth_token()
# never touch the real ~/.config/itf, and always restores HOME afterward.
val FIXTURE_HOME = "build/test-itf-config-colon-fixture/home"


fn _load_config_with_fixture_config(config_body: text) -> ItfConfig:
    """Write FIXTURE_HOME/.config/itf/config.sdn with `config_body` (via the
    real rt_file_write_text extern — NOT save_config, so this isolates the
    READ side while reproducing bug itf-config-colon-value-split), then call
    load_config() with HOME pointed at the fixture. Always restores HOME."""
    val dir = "{FIXTURE_HOME}/.config/itf"
    val _mk = rt_dir_create_all(dir)
    val _cfg = rt_file_write_text("{dir}/config.sdn", config_body)
    val _no_auth = rt_file_delete("{dir}/auth.sdn")
    val original_home = rt_env_get("HOME") ?? ""
    val _set_home = rt_env_set("HOME", FIXTURE_HOME)
    val config = load_config()
    val _restore_home = rt_env_set("HOME", original_home)
    config


fn _auth_token_roundtrip(provider: text, token: text) -> text:
    """save_auth_token(provider, token) then load_auth_token(provider), with
    HOME pointed at the fixture. Always restores HOME."""
    val dir = "{FIXTURE_HOME}/.config/itf"
    val _mk = rt_dir_create_all(dir)
    val original_home = rt_env_get("HOME") ?? ""
    val _set_home = rt_env_set("HOME", FIXTURE_HOME)
    val _saved = save_auth_token(provider, token)
    val loaded = load_auth_token(provider)
    val _restore_home = rt_env_set("HOME", original_home)
    loaded


describe "ITF configuration":

    context "ItfConfig.default":
        it "creates config with sensible defaults":
            val config = ItfConfig.default()
            expect(config.confluence_url).to_equal("")
            expect(config.jira_acli_path).to_equal("acli")
            expect(config.default_output).to_equal("text")
            expect(config.color_mode).to_equal("auto")

        it "tasks_default_backend defaults to unset (cmd_tasks.spl falls back to github)":
            val config = ItfConfig.default()
            expect(config.tasks_default_backend).to_equal("")

        it "tasks_jira_done_status defaults to unset (cmd_tasks.spl falls back to Done)":
            val config = ItfConfig.default()
            expect(config.tasks_jira_done_status).to_equal("")

    context "_apply_config_value (tasks.default_backend, D1/gap G6)":
        it "parses `tasks: default_backend:` into ItfConfig.tasks_default_backend":
            val config = _apply_config_value(ItfConfig.default(), "tasks", "default_backend", "jira")
            expect(config.tasks_default_backend).to_equal("jira")

        it "leaves wiki_default_backend untouched when only tasks.default_backend is set":
            val config = _apply_config_value(ItfConfig.default(), "tasks", "default_backend", "jira")
            expect(config.wiki_default_backend).to_equal("")

    context "_apply_config_value (tasks.jira_done_status, D5/gap G6)":
        it "parses `tasks: jira_done_status:` into ItfConfig.tasks_jira_done_status":
            val config = _apply_config_value(ItfConfig.default(), "tasks", "jira_done_status", "Resolved")
            expect(config.tasks_jira_done_status).to_equal("Resolved")

        it "leaves tasks_default_backend untouched when only tasks.jira_done_status is set":
            val config = _apply_config_value(ItfConfig.default(), "tasks", "jira_done_status", "Resolved")
            expect(config.tasks_default_backend).to_equal("")

    context "load_config colon-split (bug itf-config-colon-value-split)":
        it "a URL value containing its own colon round-trips through load_config unchanged":
            val config = _load_config_with_fixture_config("confluence:\n    url: https://x.atlassian.net/wiki\n")
            expect(config.confluence_url).to_equal("https://x.atlassian.net/wiki")

        it "a plain single-word value is unaffected by the first-colon-only split":
            val config = _load_config_with_fixture_config("output:\n    format: json\n")
            expect(config.default_output).to_equal("json")

        it "a token_cmd value containing its own colon (e.g. a URI-shaped command) round-trips unchanged":
            val config = _load_config_with_fixture_config("token_cmd:\n    jira: op read op://vault/item/token\n")
            expect(config.token_cmds.len()).to_equal(1)
            expect(config.token_cmds[0].1).to_equal("op read op://vault/item/token")

    context "load_auth_token colon-split (bug itf-config-colon-value-split)":
        it "a token value containing its own colon round-trips through save_auth_token/load_auth_token unchanged":
            val loaded = _auth_token_roundtrip("confluence", "user:pass:extra")
            expect(loaded).to_equal("user:pass:extra")

        it "a plain token without a colon is unaffected":
            val loaded = _auth_token_roundtrip("jira", "plaintoken123")
            expect(loaded).to_equal("plaintoken123")

    context "ItfError":
        it "auth error has exit code 4":
            val err = ItfError.auth("missing token")
            expect(err.exit_code()).to_equal(4)

        it "cancelled error has exit code 2":
            val err = ItfError.cancelled()
            expect(err.exit_code()).to_equal(2)

        it "api error has exit code 1":
            val err = ItfError.api(500, "internal error")
            expect(err.exit_code()).to_equal(1)

        it "not found has exit code 1":
            val err = ItfError.not_found("page 123")
            expect(err.exit_code()).to_equal(1)

        it "conflict error has exit code 1":
            val err = ItfError.conflict(5, 6)
            expect(err.exit_code()).to_equal(1)

        it "displays trace id when present":
            var err = ItfError.api(500, "server error")
            err = ItfError(kind: err.kind, message: err.message, status_code: err.status_code, trace_id: "ABC123")
            val display = err.display()
            expect(display).to_contain("trace: ABC123")

        it "omits trace id when empty":
            val err = ItfError.api(500, "server error")
            val display = err.display()
            expect(display).to_contain("error: server error")

    context "resolve_editor":
        it "returns vi as default when no overrides":
            val config = ItfConfig.default()
            val editor = resolve_editor(config)
            # Will return vi or whatever EDITOR env var is set
            expect(editor.len()).to_be_greater_than(0)

        it "uses config override when set":
            val config = ItfConfig(
                confluence_url: "",
                confluence_user: "",
                confluence_default_space: "",
                jira_url: "",
                jira_acli_path: "acli",
                jira_email: "",
                default_output: "text",
                color_mode: "auto",
                editor_override: "nano",
                pager_override: "",
                token_cmds: [],
                wiki_default_backend: "",
                tasks_default_backend: "",
                tasks_jira_done_status: ""
            )
            val editor = resolve_editor(config)
            expect(editor).to_equal("nano")
