# @cover src/app/devhub/cmd_jira.spl 60%
#
# `itf jira update/comment/transition` (J2): fake-binary fixture spec.
# Drives handle_jira() end-to-end against stub `acli`/`curl` scripts on PATH
# (each records its argv to a log file, emits a canned exit code) — NEVER
# contacts real Jira. Mirrors cmd_github_spec.spl's write-shim-and-
# override-PATH recipe, plus a HOME override so load_config()/auth.sdn
# point at a fixture config dir instead of the real ~/.config/itf.
#
# Assertions cover exit codes + the argv actually passed to acli/curl
# (proves acli-first dispatch, and fallback-to-curl on any acli failure
# when jira curl credentials are configured) — view/search/create already
# have coverage via adapter_jira_curl_spec.spl's pure-function tests.

use app.devhub.cmd_jira.{handle_jira}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool
extern fn rt_env_get(key: text) -> text?
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

val FIXTURE_DIR = "build/test-itf-jira-fixture"
val ARGV_LOG = "{FIXTURE_DIR}/argv.log"
val FIXTURE_HOME = "build/test-itf-jira-fixture/home"


fn shell_ok(cmd: text) -> bool:
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
    exit_code == 0


fn install_fake_bin(name: text, script_body: text):
    """Write build/test-itf-jira-fixture/<name> (chmod +x)."""
    val path = "{FIXTURE_DIR}/{name}"
    val _write = rt_file_write_text(path, script_body)
    shell_ok("/bin/chmod +x \"{path}\"")


fn write_fixture_config(jira_url: text, jira_email: text, jira_token: text):
    """Write config.sdn + auth.sdn under FIXTURE_HOME/.config/itf so
    load_config()/resolve_auth_token() see jira curl-fallback credentials
    once HOME is overridden to FIXTURE_HOME. An empty jira_token writes an
    empty auth.sdn (load_auth_token then returns "" — "not configured")."""
    val dir = "{FIXTURE_HOME}/.config/itf"
    val _mk = rt_dir_create_all(dir)
    val config_body = "jira:\n    url: {jira_url}\n    acli_path: acli\n    email: {jira_email}\n"
    val _cfg = rt_file_write_text("{dir}/config.sdn", config_body)
    val auth_body = if jira_token != "": "jira:\n    token: \"{jira_token}\"\n" else: ""
    rt_file_write_text("{dir}/auth.sdn", auth_body)


fn run_jira_with_fixture(args: [text], override_home: bool) -> (i64, text):
    """Run handle_jira(args) with FIXTURE_DIR prepended to PATH (so `acli`
    and `curl` resolve to the fakes) and, if `override_home`, HOME pointed
    at FIXTURE_HOME (so load_config()/auth.sdn see fixture credentials
    instead of the real ~/.config/itf). Always restores PATH/HOME
    afterward. Returns (exit_code, argv_log_contents)."""
    val original_path = rt_env_get("PATH") ?? ""
    val original_home = rt_env_get("HOME") ?? ""
    val _set_path = rt_env_set("PATH", "{FIXTURE_DIR}:{original_path}")
    if override_home:
        val _set_home = rt_env_set("HOME", FIXTURE_HOME)
    val code = handle_jira(args)
    val _restore_path = rt_env_set("PATH", original_path)
    if override_home:
        val _restore_home = rt_env_set("HOME", original_home)
    val log = rt_file_read_text(ARGV_LOG)
    (code, log)


fn reset_fixture():
    val _mk = rt_dir_create_all(FIXTURE_DIR)
    rt_file_delete(ARGV_LOG)


val FAKE_ACLI_OK = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\nexit 0\n"
val FAKE_ACLI_FAIL = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\necho 'unknown command: edit' >&2\nexit 1\n"

# All three curl mutation paths (PUT update, POST comment, POST transition)
# use the same `-w "\n%{http_code}"` write-out suffix, so a fake that emits
# an empty body + newline + a 2xx status satisfies _split_response for any
# of them.
val FAKE_CURL_OK = "#!/bin/sh\necho \"$@\" >> \"{ARGV_LOG}\"\nprintf '\\n204'\n"


describe "itf jira update/comment/transition (fake-binary fixture)":

    context "acli succeeds — curl is never invoked":

        it "update: routes to `acli jira workitem edit KEY --summary ...`":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_jira_with_fixture(["update", "PROJ-1", "--summary", "New title"], false)
            expect(code).to_equal(0)
            expect(log.contains("jira workitem edit PROJ-1 --summary New title")).to_equal(true)

        it "comment: routes to `acli jira workitem comment KEY --body ...`":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_jira_with_fixture(["comment", "PROJ-1", "--body", "status update"], false)
            expect(code).to_equal(0)
            expect(log.contains("jira workitem comment PROJ-1 --body status update")).to_equal(true)

        it "transition: routes to `acli jira workitem transition KEY --status ...`":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, log) = run_jira_with_fixture(["transition", "PROJ-1", "In Progress"], false)
            expect(code).to_equal(0)
            expect(log.contains("jira workitem transition PROJ-1 --status In Progress")).to_equal(true)

    context "acli fails, jira curl credentials configured — falls back to curl":

        it "update: falls back to a PUT on /rest/api/3/issue/KEY":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_FAIL)
            install_fake_bin("curl", FAKE_CURL_OK)
            write_fixture_config("https://fixture.atlassian.net", "fixture@example.com", "fixture-token")
            val (code, log) = run_jira_with_fixture(["update", "PROJ-1", "--summary", "New title"], true)
            expect(code).to_equal(0)
            expect(log.contains("-X")).to_equal(true)
            expect(log.contains("PUT")).to_equal(true)
            expect(log.contains("rest/api/3/issue/PROJ-1")).to_equal(true)

        it "comment: falls back to a POST on /rest/api/3/issue/KEY/comment":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_FAIL)
            install_fake_bin("curl", FAKE_CURL_OK)
            write_fixture_config("https://fixture.atlassian.net", "fixture@example.com", "fixture-token")
            val (code, log) = run_jira_with_fixture(["comment", "PROJ-1", "--body", "status update"], true)
            expect(code).to_equal(0)
            expect(log.contains("rest/api/3/issue/PROJ-1/comment")).to_equal(true)

        it "transition --id: falls back directly to POST /transitions without listing":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_FAIL)
            install_fake_bin("curl", FAKE_CURL_OK)
            write_fixture_config("https://fixture.atlassian.net", "fixture@example.com", "fixture-token")
            val (code, log) = run_jira_with_fixture(["transition", "PROJ-1", "--id", "31"], true)
            expect(code).to_equal(0)
            expect(log.contains("rest/api/3/issue/PROJ-1/transitions")).to_equal(true)
            expect(log.contains("\"id\":\"31\"")).to_equal(true)

    context "acli fails, jira curl not configured — clean failure, no crash":

        it "update: exits 1 without touching curl":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_FAIL)
            write_fixture_config("", "", "")
            val (code, _log) = run_jira_with_fixture(["update", "PROJ-1", "--summary", "New title"], true)
            expect(code).to_equal(1)

    context "usage errors":

        it "update: exits 1 when neither --summary nor --description given":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, _log) = run_jira_with_fixture(["update", "PROJ-1"], false)
            expect(code).to_equal(1)

        it "comment: exits 1 when --body is missing":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, _log) = run_jira_with_fixture(["comment", "PROJ-1"], false)
            expect(code).to_equal(1)

        it "transition: exits 1 when no status name or --id is given":
            reset_fixture()
            install_fake_bin("acli", FAKE_ACLI_OK)
            val (code, _log) = run_jira_with_fixture(["transition", "PROJ-1"], false)
            expect(code).to_equal(1)
