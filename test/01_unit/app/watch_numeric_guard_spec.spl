extern fn rt_file_read_text(path: text) -> text?

describe "watch numeric guard":
    it "guards malformed timing options":
        val source = rt_file_read_text("src/app/watch/main.spl") ?? ""

        expect(source).to_contain("fn parse_watch_ms_or_default(value: text, default_value: i64) -> i64")
        expect(source).to_contain("config.poll_interval_ms = parse_watch_ms_or_default(arg[11:], config.poll_interval_ms)")
        expect(source).to_contain("config.debounce_ms = parse_watch_ms_or_default(arg[11:], config.debounce_ms)")
        expect(source.contains("config.poll_interval_ms = arg[11:].to_int()")).to_equal(false)
        expect(source.contains("config.debounce_ms = arg[11:].to_int()")).to_equal(false)
