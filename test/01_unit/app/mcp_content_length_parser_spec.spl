extern fn rt_file_read_text(path: text) -> text

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "MCP Content-Length parser":
    it "keeps native entry parsing free of optional integer conversion":
        val source = read_source("src/app/mcp/main.spl")

        expect(source).to_contain("fn _mcp_parse_decimal_raw(s: text) -> i64:")
        expect(source).to_contain("s.char_code_at(0) - 48")
        expect(source).to_contain("if n < 1 or n > 9:")
        expect(source).to_contain("MCP frame sizes over 999,999,999 bytes are rejected")
        expect(source).to_contain("print \"  --quiet | --verbose\"")
        expect(source).to_not_contain("s.to_i64() ?? 0")
        expect(source).to_not_contain("s.to_int() ?? 0")
        expect(source).to_not_contain("_mcp_parse_decimal_at")
        expect(source).to_not_contain("for line in log_options_help()")
