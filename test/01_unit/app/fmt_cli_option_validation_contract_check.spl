use app.io.cli_fmt_options.{fmt_option_error}

extern fn rt_exit(code: i32)

val unknown = fmt_option_error(["fmt", "file.spl", "--bogus"])
val malformed_check = fmt_option_error(["fmt", "file.spl", "--check=always"])
val malformed_write = fmt_option_error(["fmt", "file.spl", "--write=always"])
val valid_check = fmt_option_error(["fmt", "file.spl", "--check"])
val valid_write = fmt_option_error(["fmt", "file.spl", "--write"])
val valid_help = fmt_option_error(["fmt", "--help"])

if unknown == "" or malformed_check == "" or malformed_write == "" or valid_check != "" or valid_write != "" or valid_help != "":
    print "FAIL: fmt option validation has an incorrect allowlist"
    rt_exit(1)

print "PASS: fmt option validation rejects malformed flags and accepts documented forms"
rt_exit(0)
