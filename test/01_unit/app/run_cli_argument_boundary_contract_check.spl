use app.run.main.{run_clean_log_args, run_wrapper_log_args, run_wrapper_option_error, run_requests_help}

extern fn rt_exit(code: i32)

val leading_wrapper = run_wrapper_log_args(["--json", "fixture.spl", "--json"])
val leading_forward = run_clean_log_args(["--json", "fixture.spl", "--json"])
val program_wrapper = run_wrapper_log_args(["fixture.spl", "--", "--log-mode", "noisy"])
val program_forward = run_clean_log_args(["fixture.spl", "--", "--log-mode", "noisy"])
val mixed_wrapper = run_wrapper_log_args(["--gc-log", "--json", "fixture.spl"])
val mixed_forward = run_clean_log_args(["--gc-log", "--json", "fixture.spl"])
val invalid_surface = run_wrapper_option_error(["--gc-log", "--surface", "stdout", "fixture.spl"])
val program_surface = run_wrapper_option_error(["fixture.spl", "--surface", "stdout"])
val help_wrapper = run_wrapper_log_args(["--gc-log", "--json", "--help"])
val help_forward = run_clean_log_args(["--gc-log", "--json", "--help"])
val language_wrapper = run_wrapper_log_args(["--lang", "en", "--json", "fixture.spl"])
val language_forward = run_clean_log_args(["--lang", "en", "--json", "fixture.spl"])
val gc_wrapper = run_wrapper_log_args(["--gc=off", "--json", "fixture.spl"])
val gc_forward = run_clean_log_args(["--gc=off", "--json", "fixture.spl"])

val failed = leading_wrapper.len() != 1 or leading_wrapper[0] != "--json" or leading_forward.len() != 2 or leading_forward[0] != "fixture.spl" or leading_forward[1] != "--json" or program_wrapper.len() != 0 or program_forward.len() != 4 or program_forward[0] != "fixture.spl" or program_forward[1] != "--" or program_forward[2] != "--log-mode" or program_forward[3] != "noisy" or mixed_wrapper.len() != 1 or mixed_wrapper[0] != "--json" or mixed_forward.len() != 2 or mixed_forward[0] != "--gc-log" or mixed_forward[1] != "fixture.spl" or invalid_surface == "" or program_surface != "" or help_wrapper.len() != 1 or help_wrapper[0] != "--json" or help_forward.len() != 2 or help_forward[0] != "--gc-log" or help_forward[1] != "--help" or not run_requests_help(help_forward) or language_wrapper.len() != 1 or language_wrapper[0] != "--json" or language_forward.len() != 3 or language_forward[0] != "--lang" or language_forward[1] != "en" or language_forward[2] != "fixture.spl" or gc_wrapper.len() != 1 or gc_wrapper[0] != "--json" or gc_forward.len() != 2 or gc_forward[0] != "--gc=off" or gc_forward[1] != "fixture.spl"
if failed:
    print "FAIL: run wrapper changed program arguments"
    rt_exit(1)

print "PASS: run preserves post-file program arguments"
rt_exit(0)
