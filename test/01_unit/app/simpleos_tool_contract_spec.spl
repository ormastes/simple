use std.spec.*
use std.io_runtime.{file_read}

describe "SimpleOS focused Simple tool":
    it "uses a concrete standalone pipeline without generic backend dispatch":
        val main_source = file_read("src/app/simpleos_tool/main.spl")
        val pipeline = file_read("src/app/simpleos_tool/focused_pipeline.spl")
        val llvm_adapter = file_read("src/compiler/70.backend/backend/llvm_codegen_adapter.spl")
        val mir_lowering = file_read("src/compiler/50.mir/_MirLowering/module_lowering.spl")
        val llvm_builder = file_read("src/compiler/70.backend/backend/llvm_ir_builder.spl")
        val hir_lowering = file_read("src/compiler/20.hir/hir_lowering/types.spl")
        val flat_convert = file_read("src/compiler/10.frontend/_FlatAstBridge/convert_nodes.spl")
        val flat_assembly = file_read("src/compiler/10.frontend/_FlatAstBridge/module_assembly.spl")
        val simple_runtime = file_read("src/os/libc/simpleos_simple_runtime.c")
        expect(main_source).to_contain("simpleos_interpret_file(command)")
        expect(main_source).to_contain("use app.io.args_ops.{get_args}")
        expect(main_source).to_contain("use app.io.env_ops.{env_set}")
        expect(main_source.contains("extern fn rt_")).to_be(false)
        expect(main_source).to_contain("elif args[i] == \"--emit-object\":")
        expect(main_source).to_contain("elif args[i] == \"--emit-llvm\":")
        expect(main_source).to_contain("simpleos_compile_native_file(source, output, emit_object, emit_llvm)")
        expect(main_source).to_contain("SIMPLE_NATIVE_BUILD_TARGET")
        expect(main_source).to_contain("SIMPLEOS_FOCUSED_HIR_DIAG")
        expect(main_source).to_contain("Simple v1.0.0-beta")
        expect(main_source).to_contain("unsupported compile option")
        expect(pipeline).to_contain("parse_and_build_module")
        expect(pipeline).to_contain("desugar_collections_static")
        expect(pipeline).to_contain("var lowering: HirLowering = HirLowering.with_filename(path)")
        expect(pipeline).to_contain("InterpreterBackendImpl.new().interpret_hir_module")
        expect(pipeline).to_contain("CodegenTarget.SimpleOS_X86_64")
        expect(pipeline).to_contain("llvm_compile_module_direct_compiled")
        expect(pipeline).to_contain("llvm_translate_module_direct_ir")
        expect(pipeline).to_contain("rt_file_write_text(output, llvm_ir)")
        expect(pipeline).to_contain("simpleos_current_cs()")
        expect(pipeline).to_contain(r"[simpleos-cpl] phase={phase} cs=0x2b cpl=3")
        expect(pipeline).to_contain("require_user_cpl(\"post-read\")")
        expect(pipeline).to_contain("require_user_cpl(\"post-write\")")
        expect(pipeline).to_contain("val object_path = if emit_object: output else: \"/tmp/SIMPLEUSR.O\"")
        expect(pipeline).to_contain("if emit_object:\n        return 0")
        expect(llvm_adapter).to_contain("val compiled_module: CompiledModule = CompiledModule(")
        expect(llvm_adapter).to_contain("Ok(compiled_module)")
        expect(llvm_adapter.contains("Ok(CompiledModule(")).to_be(false)
        expect(mir_lowering).to_contain("current_function_symbols: []")
        expect(mir_lowering).to_contain("current_function_names: []")
        expect(mir_lowering).to_contain("val empty_loop_stack: [(BlockId, BlockId)] = []")
        expect(mir_lowering).to_contain("val empty_errors: [MirError] = []")
        expect(mir_lowering.contains("loop_stack: [],")).to_be(false)
        expect(mir_lowering.contains("errors: [],")).to_be(false)
        expect(llvm_builder).to_contain("val target = self.target")
        expect(hir_lowering).to_contain(r"[simpleos-hir-push] {message}")
        expect(hir_lowering).to_contain("hir_type_env_get(\"SIMPLEOS_FOCUSED_HIR_DIAG\") == \"1\"")
        expect(flat_convert).to_contain("val converted: Function = parser_function_new(")
        expect(flat_convert).to_contain("if type_expr_idx > 1 and type_expr_idx < 3:")
        expect(flat_convert).to_contain("val inferred_ret: Type = if has_ret: convert_flat_type(ret)")
        expect(flat_assembly).to_contain("val fn_: Function = convert_decl_fn(idx)")
        expect(flat_assembly).to_contain("val fn_: Function = convert_decl_extern_fn(idx)")
        expect(flat_assembly).to_contain(r"[flat-function-roundtrip] phase={stage} name={fn_.name} return={return_name}")
        expect(simple_runtime).to_contain("void rt_print(const char *value)")
        expect(simple_runtime).to_contain("void rt_println(const char *value)")
        expect(pipeline).to_contain("link_simpleos_x86_64_external")
        expect(pipeline.contains("use compiler.driver")).to_be(false)
