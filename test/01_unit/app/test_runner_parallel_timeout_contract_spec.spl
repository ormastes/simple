use std.spec
use std.io.{file_write, file_exists, time_now_unix_micros}
use std.test_runner.test_runner_async.{AsyncTestRun, create_temp_files, collect_async_result}

describe "parallel test timeout classification contract":
    it "classifies an explicit monitor deadline without sleeping or trusting exit minus one":
        val (stdout_file, stderr_file) = create_temp_files("parallel_timeout_contract")
        expect(file_write(stdout_file, "child output")).to_equal(true)
        expect(file_write(stderr_file, "child crash marker")).to_equal(true)
        val run = AsyncTestRun(
            pid: -1,
            file_path: "parallel_timeout_contract.spl",
            start_time: time_now_unix_micros(),
            stdout_file: stdout_file,
            stderr_file: stderr_file,
            timeout_ms: 1000
        )

        val result = collect_async_result(run, -1, true)

        expect(result.failed).to_equal(1)
        expect(result.timed_out).to_equal(true)
        expect(result.error).to_equal("TIMEOUT after 1s")
        expect(file_exists(stdout_file)).to_equal(false)
        expect(file_exists(stderr_file)).to_equal(false)
