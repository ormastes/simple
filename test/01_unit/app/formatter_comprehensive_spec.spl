extern fn rt_file_read_text(path: text) -> text

describe "formatter containment wiring":
    it "guards every formatted result with the CoreLexer fingerprint":
        val source = rt_file_read_text("src/compiler/90.tools/formatter/main.spl") ?? ""
        expect(source).to_contain("formatter_require_lexical_equivalence(source, result.join")
        expect(source).to_contain("core_lexer_token_start")
        expect(source).to_contain("core_lexer_token_end")
        expect(source.contains("fn fix_missing_commas")).to_equal(false)
