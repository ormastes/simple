use app.io._CliCommands.run_commands.{cli_run_fix}
use std.io.{file_write, file_read, file_delete}
use app.io.mod.{dir_create, dir_remove_all}
use std.nogc_sync_mut.io.time_ops.{time_now_unix_micros}

extern fn rt_exit(code: i32)

val path = "/tmp/simple_fix_production_cli_option_validation.spl"
val original = "if let value = item:\n    print value\n"
if not file_write(path, original):
    print "FAIL: could not create production fix fixture"
    rt_exit(1)

val malformed_exit = cli_run_fix(["fix", path, "--dry-run=true"])
val unknown_exit = cli_run_fix(["fix", path, "--bogus"])
val empty_id_exit = cli_run_fix(["fix", path, "--fix-id="])
val after_invalid = file_read(path)
val dry_run_exit = cli_run_fix(["fix", path, "--dry-run", "--fix-all", "--fix-id=L:deprecated_if_let"])
val after_dry_run = file_read(path)
val _ = file_delete(path)

val nonce = time_now_unix_micros().to_string()
val directory = "/tmp/simple_fix_production_directory_target_" + nonce
val _directory_cleanup_before = dir_remove_all(directory)
val _directory_created = dir_create(directory, true)
val sentinel = directory + "/sentinel.txt"
val _sentinel_written = file_write(sentinel, "keep")
val directory_exit = cli_run_fix(["fix", directory, "--fix-all"])
val sentinel_after = file_read(sentinel)
val _directory_cleanup_after = dir_remove_all(directory)

val empty_path = "/tmp/simple_fix_production_empty_" + nonce + ".spl"
val _empty_written = file_write(empty_path, "")
val empty_exit = cli_run_fix(["fix", empty_path, "--fix-all"])
val empty_after = file_read(empty_path)
val _empty_deleted = file_delete(empty_path)

if (malformed_exit != 2 or unknown_exit != 2 or empty_id_exit != 2 or
    dry_run_exit != 0 or after_invalid != original or after_dry_run != original or
    directory_exit != 1 or sentinel_after != "keep" or empty_exit != 0 or
    empty_after != ""):
    print "FAIL: production fix accepted an invalid option or mutated a dry-run fixture"
    rt_exit(1)

print "PASS: production fix rejects invalid options before writes and preserves valid dry runs"
rt_exit(0)
