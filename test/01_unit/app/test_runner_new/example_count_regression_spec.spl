# Example-count regression spec for the SSpec `simple test` runner.
#
# Bug: doc/08_tracking/bug/sspec_test_runner_undercounts_it_blocks_2026-07-24.md
# `simple test <spec>` undercounted registered `it` examples relative to
# `simple run <spec>` (74 registered -> "34 total" reported) on specs with
# many `describe` blocks. Root cause: src/app/test_runner_new/
# test_runner_single.spl trusted the per-describe "N examples, M failures"
# summary line over the actual executed-example count and never raised
# `passed` back up when the real ✓/✗ tally exceeded it.
#
# This spec is a synthetic, dependency-free reproducer: 16 `describe` blocks
# (2 of them with a nested `context`) registering 50 `it` examples, plus one
# top-level orphan `it` (outside any `describe`) for 51 total — the orphan
# is what actually exercises the bug: it prints its own real ✓ marker but
# has no enclosing `describe` to fold it into any "N examples, M failures"
# summary line, so the buggy runner's summary-derived total silently missed
# it (verified: reverting the fix reproduces "3 total" vs 4 declared on a
# 4-case version of this pattern; see the bug doc's root-cause section).
# All examples pass (matcher choice kept to `to_equal`/`to_be_true`/
# `to_be_false` so the spec is green on every evaluator, keeping the count
# check isolated from matcher-support differences).
# scripts/check/check-sspec-count-truthful.shs asserts the runner's reported
# "Results: N total" equals the statically-declared `it` count (51) for this
# file — any regression that undercounts again will fail that gate.

use std.spec.*

describe "group 01":
    it "case 01":
        expect(1 + 1).to_equal(2)
    it "case 02":
        expect(2 + 2).to_equal(4)
    it "case 03":
        expect(3 + 3).to_equal(6)

describe "group 02":
    it "case 01":
        expect(1).to_equal(1)
    it "case 02":
        expect(2).to_equal(2)
    it "case 03":
        expect(3).to_equal(3)

describe "group 03":
    it "case 01":
        expect(true).to_be_true()
    it "case 02":
        expect(false).to_be_false()
    it "case 03":
        expect("a").to_equal("a")

describe "group 04":
    it "case 01":
        expect([1, 2, 3].len()).to_equal(3)
    it "case 02":
        expect([1, 2].len()).to_equal(2)
    it "case 03":
        expect([].len()).to_equal(0)

describe "group 05":
    context "nested a":
        it "case 01":
            expect(10 - 4).to_equal(6)
        it "case 02":
            expect(10 - 5).to_equal(5)
    context "nested b":
        it "case 03":
            expect(10 - 6).to_equal(4)
        it "case 04":
            expect(10 - 7).to_equal(3)

describe "group 06":
    it "case 01":
        expect(2 * 2).to_equal(4)
    it "case 02":
        expect(2 * 3).to_equal(6)
    it "case 03":
        expect(2 * 4).to_equal(8)

describe "group 07":
    it "case 01":
        expect(4 / 2).to_equal(2)
    it "case 02":
        expect(6 / 2).to_equal(3)
    it "case 03":
        expect(8 / 2).to_equal(4)

describe "group 08":
    it "case 01":
        expect("abc".len()).to_equal(3)
    it "case 02":
        expect("ab".contains("a")).to_be_true()
    it "case 03":
        expect("ab".contains("z")).to_be_false()

describe "group 09":
    it "case 01":
        expect(1 < 2).to_be_true()
    it "case 02":
        expect(2 < 1).to_be_false()
    it "case 03":
        expect(2 <= 2).to_be_true()

describe "group 10":
    context "nested a":
        it "case 01":
            expect(1 < 2).to_be_true()
        it "case 02":
            expect(2 > 1).to_be_true()
    context "nested b":
        it "case 03":
            expect(2 >= 2).to_be_true()
        it "case 04":
            expect(2 <= 2).to_be_true()

describe "group 11":
    it "case 01":
        expect(1).to_equal(1)
    it "case 02":
        expect(2).to_equal(2)
    it "case 03":
        expect("").to_equal("")

describe "group 12":
    it "case 01":
        expect("hi".starts_with("h")).to_be_true()
    it "case 02":
        expect("hi".ends_with("i")).to_be_true()
    it "case 03":
        expect("hi".contains("h")).to_be_true()

describe "group 13":
    it "case 01":
        expect(1.0).to_equal(1.0)
    it "case 02":
        expect(1.5).to_equal(1.5)
    it "case 03":
        expect(2.0).to_equal(2.0)

describe "group 14":
    it "case 01":
        expect([1, 2].len()).to_equal(2)
    it "case 02":
        expect([1, 2, 3].len()).to_equal(3)
    it "case 03":
        expect([].len()).to_equal(0)

describe "group 15":
    it "case 01":
        expect("match").to_equal("match")
    it "case 02":
        expect(5).to_equal(5)
    it "case 03":
        expect(6).to_equal(6)

describe "group 16":
    it "case 01":
        expect(7).to_equal(7)
    it "case 02":
        expect(8).to_equal(8)
    it "case 03":
        expect(9).to_equal(9)

it "orphan case (no enclosing describe) still counts toward the total":
    expect(10).to_equal(10)
