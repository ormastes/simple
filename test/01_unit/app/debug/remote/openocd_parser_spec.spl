# OpenOCD Parser Tests
# Tests OpenOCD telnet output parsing, hex formatting, reset markers.

# --- Local helpers ---

fn rt_hex(value: i64) -> text:
    if value == 0:
        return "0"
    var result = ""
    var v = value
    val hex_chars = "0123456789abcdef"
    while v > 0:
        val digit = v % 16
        result = hex_chars[digit] + result
        v = v / 16
    result

fn parse_mdw_output(output: text) -> [i64]:
    var result: [i64] = []
    val parts = output.split(" ")
    for part in parts:
        if part.starts_with("0x"):
            val hex_val = part[2..]
            val num = hex_val.parse_int() ?? 0
            result = result + [num]
    result

fn format_address(addr: i64) -> text:
    "0x" + rt_hex(addr)

# --- Tests ---

describe "OpenOCD hex formatting":
    it "formats 0 as 0":
        expect(rt_hex(0)).to_equal("0")

    it "formats 255 as ff":
        expect(rt_hex(255)).to_equal("ff")

    it "formats 256 as 100":
        expect(rt_hex(256)).to_equal("100")

    it "formats 0x1000 as 1000":
        expect(rt_hex(4096)).to_equal("1000")

    it "formats address with 0x prefix":
        expect(format_address(4096)).to_equal("0x1000")

describe "OpenOCD mdw output parsing":
    it "parses single word":
        val result = parse_mdw_output("0x08000000: 0xDEADBEEF")
        expect(result.len()).to_be_greater_than(0)

    it "parses hex values from output":
        val result = parse_mdw_output("0x20000000: 0x0 0x0 0x0 0x0")
        expect(result.len()).to_be_greater_than(0)

describe "OpenOCD process config":
    it "OpenOCD config path for STM32H7":
        val cfg = "board/stm32h7x3i_eval.cfg"
        expect(cfg).to_contain("stm32h7")

    it "OpenOCD config path for STM32WB":
        val cfg = "board/stm32wb5x_nucleo.cfg"
        expect(cfg).to_contain("stm32wb")

    it "GDB port defaults for STM32H7":
        val port = 3333
        expect(port).to_equal(3333)

    it "telnet port is GDB port + 1000":
        val gdb_port = 3333
        val telnet_port = gdb_port + 1000
        expect(telnet_port).to_equal(4333)
