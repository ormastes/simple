# CH32V307 Target Tests
# Tests Ch32v307Target defaults, serials, memory map.
# CH32V307 connects via WCH-Link (wlink), not OpenOCD/ST-LINK.

# --- Local copy ---

class Ch32v307Target:
    wlink_serial: text
    chip_id: text
    wlink_chip: text
    flash_base: i64
    flash_size: i64
    ram_base: i64
    ram_size: i64
    isa: text
    core_name: text

impl Ch32v307Target:
    static fn default() -> Ch32v307Target:
        Ch32v307Target(
            wlink_serial: "711A8F06F64D",
            chip_id: "0x30700568",
            wlink_chip: "CH32V30X",
            flash_base: 0x08000000,
            flash_size: 288 * 1024,
            ram_base: 0x20000000,
            ram_size: 32 * 1024,
            isa: "RV32ACFIMUX",
            core_name: "WCH-V4F"
        )

    fn name() -> text:
        "CH32V307 (RV32IMAC+F)"

# --- Tests ---

describe "Ch32v307Target defaults":
    it "has correct name":
        val t = Ch32v307Target.default()
        expect(t.name()).to_equal("CH32V307 (RV32IMAC+F)")

    it "has correct WCH-Link serial":
        val t = Ch32v307Target.default()
        expect(t.wlink_serial).to_equal("711A8F06F64D")

    it "has correct chip ID":
        val t = Ch32v307Target.default()
        expect(t.chip_id).to_equal("0x30700568")

    it "has correct flash base and size":
        val t = Ch32v307Target.default()
        expect(t.flash_base).to_equal(0x08000000)
        expect(t.flash_size).to_equal(294912)

    it "has correct RAM base and size":
        val t = Ch32v307Target.default()
        expect(t.ram_base).to_equal(0x20000000)
        expect(t.ram_size).to_equal(32768)

    it "has correct ISA":
        val t = Ch32v307Target.default()
        expect(t.isa).to_equal("RV32ACFIMUX")
