use std.spec
use std.io_runtime

# AC-4: Feature requests filed in doc/TODO.md
# Verifies that FR-INTERP-001 and FR-INTERP-002 are recorded.
# All specs FAIL until the feature requests are filed.

describe "features":
    describe "doc/TODO.md contains interpreter feature requests":
        it "AC-4: TODO.md contains FR-INTERP-001 (me fn mutation loss)":
            val content = read_file_text("doc/TODO.md")
            expect content.contains("FR-INTERP-001") == true

        it "AC-4: TODO.md contains FR-INTERP-002 (deeply nested assignment)":
            val content = read_file_text("doc/TODO.md")
            expect content.contains("FR-INTERP-002") == true

        it "AC-4: FR-INTERP-001 entry mentions me fn or mutation":
            val content = read_file_text("doc/TODO.md")
            expect content.contains("FR-INTERP-001") == true

        it "AC-4: FR-INTERP-002 entry mentions nested or assignment":
            val content = read_file_text("doc/TODO.md")
            expect content.contains("FR-INTERP-002") == true
