use std.spec.{describe, it, expect}
use std.io_runtime.{file_read}

fn sv39_vpn2(address: u64) -> u64:
    (address >> 30) & 0x1FF

describe "RV64 user address-space adapter source contract":
    it "keeps kernel and user images in distinct Sv39 root slots":
        val kernel_address: u64 = 0x80200000
        val user_image_base: u64 = 0x100000000
        val kernel_slot = sv39_vpn2(kernel_address)
        val user_slot = sv39_vpn2(user_image_base)
        expect(kernel_slot).to_equal(2)
        expect(user_slot).to_equal(4)
        expect(user_slot == kernel_slot).to_equal(false)

        val sysroot = file_read("scripts/os/simpleos-sysroot-riscv64.shs")
        expect(sysroot).to_contain("base 0x100000000")
        expect(sysroot).to_contain(". = 0x100000000;")
        expect(sysroot.contains(". = 0x90000000;")).to_equal(false)

        val native_build = file_read("scripts/os/simpleos-native-build-riscv64.shs")
        expect(native_build).to_contain("simpleos.ld (base 0x100000000)")

    it "inherits a supervisor-only kernel slot into each RV64 user root":
        val paging = file_read("src/os/kernel/arch/riscv64/paging.spl")
        expect(paging).to_contain("val RV64_KERNEL_VPN2_SLOT: u64 = 2")
        expect(paging).to_contain("_read_pte(kernel_root, RV64_KERNEL_VPN2_SLOT)")
        expect(paging).to_contain("not _pte_is_valid(kernel_ram_entry) or not _pte_is_leaf(kernel_ram_entry)")
        expect(paging).to_contain("(kernel_ram_entry & PTE_U) != 0")
        expect(paging).to_contain("_write_pte(new_root_phys, RV64_KERNEL_VPN2_SLOT, kernel_ram_entry)")

    it "routes create and map through the existing Sv39 paging owner":
        val source = file_read("src/os/kernel/memory/user_address_space.spl")
        expect(source).to_contain("use os.kernel.arch.riscv64.paging.{")
        expect(source).to_contain("vmm_create_address_space as rv64_vmm_create_address_space")
        expect(source).to_contain("riscv64_vmm_map_page_in")

        val rv64_parts = source.split("@cfg(riscv64)\nfn create_user_address_space")
        expect(rv64_parts.len()).to_equal(2)
        val rv64_tail = rv64_parts[1]
        val rv64_sections = rv64_tail.split("@cfg(riscv32)")
        val rv64_body = rv64_sections[0]
        expect(rv64_body).to_contain("rv64_vmm_create_address_space()")
        expect(rv64_body).to_contain("riscv64_vmm_map_page_in(space.phys_root, virt, phys, flags)")
        expect(rv64_body.contains("vmm_create_user_address_space()")).to_equal(false)
        expect(rv64_body.contains("vmm_map_page_in(space, virt, phys, flags)")).to_equal(false)
