## Spec for src/os/kernel/memory/vmm.spl — per-process address space API (Phase 1).
##
## Covers `create_user_address_space` / `destroy_user_address_space`.
## Runs in the spec harness (host process) where the PMM is not initialised,
## so allocations take the documented early-boot fallback path
## (`phys_root == 1`, `id == 0`). Boot-mode QEMU integration additionally
## verifies that `phys_root` is a real PMM-allocated 4 KiB frame.

use std.spec
use os.kernel.memory.vmm.{create_user_address_space, destroy_user_address_space}
use os.kernel.types.task_types.{AddressSpace}

val PAGE_SIZE: u64 = 4096

fn _page_offset(phys: u64) -> u64:
    """Remainder of `phys` mod 4 KiB. Always 0 for a valid page-aligned root."""
    phys % PAGE_SIZE

fn _is_sentinel(phys: u64) -> u64:
    """Returns 1 when `phys` is the documented early-boot sentinel, else 0."""
    if phys == 1:
        return 1
    0

describe "vmm per-process address space":
    """Phase 1: `create_user_address_space` returns fresh handles,
    `destroy_user_address_space` accepts them without error."""

    describe "create_user_address_space":
        """Fresh handle allocation."""

        it "returns the legacy sentinel phys_root when PMM is offline":
            """In the spec harness the PMM is not running, so the wrapper
            falls back to `phys_root == 1`. This asserts the fallback
            contract directly, not a boolean combinator."""
            val space = create_user_address_space()
            expect(_is_sentinel(space.phys_root)).to_equal(1)

        it "returns id 0 for every sentinel handle":
            """The monotonic id counter is only advanced on successful
            allocation. In the offline path every handle reports id 0."""
            val space = create_user_address_space()
            expect(space.id).to_equal(0)

        it "produces a handle whose phys_root stays stable across reads":
            """Smoke-check: repeated field reads return identical values."""
            val space = create_user_address_space()
            val first = space.phys_root
            val second = space.phys_root
            expect(second).to_equal(first)

    describe "destroy_user_address_space":
        """Cleanup path accepts freshly-created handles."""

        it "leaves the caller's phys_root field value unchanged":
            """Structs are passed by value: destroy must not mutate the
            caller's local copy."""
            val space = create_user_address_space()
            val before = space.phys_root
            destroy_user_address_space(space)
            expect(space.phys_root).to_equal(before)

        it "leaves the caller's id field unchanged":
            """Same invariant, projected onto the id field."""
            val space = create_user_address_space()
            val before_id = space.id
            destroy_user_address_space(space)
            expect(space.id).to_equal(before_id)

        it "is a no-op on the legacy sentinel":
            """Passing the legacy sentinel must leave phys_root == 1."""
            val sentinel = AddressSpace(phys_root: 1, id: 0)
            destroy_user_address_space(sentinel)
            expect(sentinel.phys_root).to_equal(1)
