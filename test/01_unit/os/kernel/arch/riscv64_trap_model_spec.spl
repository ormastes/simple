use std.spec
use os.kernel.arch.riscv64.trap_model.{RV64_CAUSE_INTERRUPT_BIT, RV64_CAUSE_S_TIMER_INTERRUPT, RV64_CAUSE_ECALL_FROM_U, RV64_SSTATUS_SPIE, RV64_SSTATUS_SPP, RV64_CONTEXT_BYTES, RV64_KERNEL_RETURN_COOKIE, Rv64TrapKind, rv64_initial_kernel_sstatus, rv64_initial_user_sstatus, rv64_prepare_kernel_exit_context, create_rv64_user_context, create_rv64_kernel_context, classify_rv64_trap, rv64_syscall_args_from_context, rv64_apply_syscall_result}
use os.kernel.arch.arch_context.{Riscv64Context}
use os.kernel.types.syscall_types.{SyscallResult}

describe "rv64 trap model":
    it "prepares a validated kernel continuation with the user exit code":
        expect(RV64_CONTEXT_BYTES).to_equal(272)
        var saved = create_rv64_kernel_context(0x80201000, 0x80402000, 0)
        saved.ra = 0x80203000
        saved.s0 = 0xA5A5
        saved.scause = RV64_KERNEL_RETURN_COOKIE

        val result = rv64_prepare_kernel_exit_context(saved, 37)
        expect(result.is_ok()).to_equal(true)
        val resumed = result.unwrap()
        expect(resumed.a0).to_equal(37)
        expect(resumed.scause).to_equal(0)
        expect(resumed.sstatus & RV64_SSTATUS_SPP).to_equal(RV64_SSTATUS_SPP)
        expect(resumed.sepc).to_equal(saved.sepc)
        expect(resumed.sp).to_equal(saved.sp)
        expect(resumed.ra).to_equal(saved.ra)
        expect(resumed.s0).to_equal(saved.s0)

    it "rejects malformed kernel continuations":
        var wrong_cookie = create_rv64_kernel_context(0x80201000, 0x80402000, 0)
        val wrong_cookie_result = rv64_prepare_kernel_exit_context(wrong_cookie, 1)
        val wrong_cookie_error = wrong_cookie_result.err()
        expect(wrong_cookie_error.unwrap()).to_contain("cookie")

        var missing_sepc = wrong_cookie
        missing_sepc.scause = RV64_KERNEL_RETURN_COOKIE
        missing_sepc.sepc = 0
        val missing_sepc_result = rv64_prepare_kernel_exit_context(missing_sepc, 1)
        val missing_sepc_error = missing_sepc_result.err()
        expect(missing_sepc_error.unwrap()).to_contain("sepc")

        var missing_sp = wrong_cookie
        missing_sp.scause = RV64_KERNEL_RETURN_COOKIE
        missing_sp.sp = 0
        val missing_sp_result = rv64_prepare_kernel_exit_context(missing_sp, 1)
        val missing_sp_error = missing_sp_result.err()
        expect(missing_sp_error.unwrap()).to_contain("sp")

        var user_privilege = wrong_cookie
        user_privilege.scause = RV64_KERNEL_RETURN_COOKIE
        user_privilege.sstatus = user_privilege.sstatus & ~RV64_SSTATUS_SPP
        val user_privilege_result = rv64_prepare_kernel_exit_context(user_privilege, 1)
        val user_privilege_error = user_privilege_result.err()
        expect(user_privilege_error.unwrap()).to_contain("privilege")

    it "builds kernel contexts that return to supervisor mode":
        val ctx = create_rv64_kernel_context(0x80200000, 0x80400000, 7)
        expect(rv64_initial_kernel_sstatus() & RV64_SSTATUS_SPIE).to_equal(RV64_SSTATUS_SPIE)
        expect(rv64_initial_kernel_sstatus() & RV64_SSTATUS_SPP).to_equal(RV64_SSTATUS_SPP)
        expect(ctx.sepc).to_equal(0x80200000)
        expect(ctx.sp).to_equal(0x80400000)
        expect(ctx.a0).to_equal(7)
        expect(ctx.sstatus & RV64_SSTATUS_SPP).to_equal(RV64_SSTATUS_SPP)

    it "builds user contexts that return to user mode":
        val ctx = create_rv64_user_context(0x400000, 0x410000, 11)
        expect(rv64_initial_user_sstatus() & RV64_SSTATUS_SPIE).to_equal(RV64_SSTATUS_SPIE)
        expect(rv64_initial_user_sstatus() & RV64_SSTATUS_SPP).to_equal(0)
        expect(ctx.sepc).to_equal(0x400000)
        expect(ctx.sp).to_equal(0x410000)
        expect(ctx.a0).to_equal(0)
        expect(ctx.sstatus & RV64_SSTATUS_SPP).to_equal(0)

    it "classifies user ecalls":
        val kind = classify_rv64_trap(RV64_CAUSE_ECALL_FROM_U)
        expect(kind).to_equal(Rv64TrapKind.UserEcall)

    it "classifies supervisor timer interrupts":
        val kind = classify_rv64_trap(RV64_CAUSE_INTERRUPT_BIT | RV64_CAUSE_S_TIMER_INTERRUPT)
        expect(kind).to_equal(Rv64TrapKind.TimerInterrupt)

    it "marshals syscall registers from rv64 user context":
        val ctx = Riscv64Context(
            ra: 0, sp: 0, gp: 0, tp: 0,
            t0: 0, t1: 0, t2: 0,
            s0: 0, s1: 0,
            a0: 10, a1: 11, a2: 12, a3: 13, a4: 14, a5: 15, a6: 0, a7: 60,
            s2: 0, s3: 0, s4: 0, s5: 0, s6: 0, s7: 0, s8: 0, s9: 0, s10: 0, s11: 0,
            t3: 0, t4: 0, t5: 0, t6: 0,
            sepc: 0x1000,
            sstatus: 0,
            scause: 0
        )
        val args = rv64_syscall_args_from_context(ctx)
        expect(args.id).to_equal(60)
        expect(args.arg0).to_equal(10)
        expect(args.arg1).to_equal(11)
        expect(args.arg2).to_equal(12)
        expect(args.arg3).to_equal(13)
        expect(args.arg4).to_equal(14)
        expect(args.arg5).to_equal(15)

    it "applies syscall results back into rv64 user context":
        val ctx = create_rv64_user_context(0x400000, 0x410000, 1)
        val updated = rv64_apply_syscall_result(ctx, SyscallResult(value: 42))
        expect(updated.a0).to_equal(42)
        expect(updated.sepc).to_equal(0x400004)
        expect(updated.sp).to_equal(0x410000)
