use std.spec.{describe, it, expect}
use std.io_runtime.{file_read}

describe "RV64 filesystem exec user-entry contract":
    it "prepares one image and passes its exact scheduler to the RV64 handoff":
        val active = file_read("src/os/kernel/loader/fs_exec_spawn.spl")
        val spawn = file_read("src/os/kernel/loader/riscv64_fs_exec_spawn.spl")
        val bridge = file_read("src/os/kernel/arch/user_entry_bridge.spl")

        expect(active).to_contain("use os.kernel.loader.riscv64_fs_exec_spawn.{riscv64_fs_exec_spawn_ring3}")
        expect(active).to_contain("riscv64_fs_exec_spawn_ring3(path, argv, envp)")
        expect(spawn).to_contain("val prepared = fs_exec_prepare_spawn(path, argv, envp)")
        expect(spawn).to_contain("dispatch_fs_exec_user_handoff(Architecture.Riscv64, prepared.pid as u64, prepared.scheduler)")
        expect(spawn.contains("fs_exec_spawn(path, argv, envp)")).to_equal(false)
        expect(bridge).to_contain("Architecture.Riscv64:")
        expect(bridge).to_contain("dispatch_rv64_enter_user(pid_hint, scheduler)")
