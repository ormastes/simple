"""SimpleOS exec-from-filesystem specification tests.

Self-contained: all types defined inline (no kernel imports in interpreter mode).
Covers capability gate, FAT32 binary read, ELF64 magic detection,
hardening probe report, and exec spawn pipeline.
AC-7 from simpleos-harden-exec feature.
"""

use std.spipe.*

# ---------------------------------------------------------------------------
# Inline types (self-contained per test rules)
# ---------------------------------------------------------------------------

enum CapabilityKind:
    FileExec
    ProcessSpawn
    FileRead

class CapCheckResult:
    allowed: bool
    denied_reason: text

    static fn permit() -> CapCheckResult:
        CapCheckResult(allowed: true, denied_reason: "")

    static fn deny(reason: text) -> CapCheckResult:
        CapCheckResult(allowed: false, denied_reason: reason)

fn exec_cap_check(caller_task: i64, path: text, has_file_exec: bool, has_process_spawn: bool) -> i32:
    if caller_task == 0:
        return 0
    if not has_file_exec:
        return -13
    if not has_process_spawn:
        return -13
    return 0

class ElfHeader:
    magic: [i32]
    elf_class: i32
    data_encoding: i32
    elf_type: i32
    machine: i32
    entry: i64

fn elf64_has_magic(bytes: [i32]) -> bool:
    if bytes.len() < 4:
        return false
    return bytes[0] == 127 and bytes[1] == 69 and bytes[2] == 76 and bytes[3] == 70

fn make_valid_elf_magic() -> [i32]:
    return [127, 69, 76, 70, 2, 1, 1, 0]

fn make_invalid_magic() -> [i32]:
    return [0, 0, 0, 0, 0, 0, 0, 0]

class Fat32ReadResult:
    data_len: i32
    success: bool
    error: text

    static fn ok(len: i32) -> Fat32ReadResult:
        Fat32ReadResult(data_len: len, success: true, error: "")

    static fn fail(err: text) -> Fat32ReadResult:
        Fat32ReadResult(data_len: 0, success: false, error: err)

class HardeningReport:
    nx: i32
    smep: i32
    smap: i32
    wp: i32
    aslr_seed: i64
    canary: i64

    static fn empty() -> HardeningReport:
        HardeningReport(nx: 0, smep: 0, smap: 0, wp: 0, aslr_seed: 0, canary: 0)

    static fn hardened() -> HardeningReport:
        HardeningReport(nx: 1, smep: 1, smap: 1, wp: 1, aslr_seed: 12345, canary: 67890)

class ExecSpawnResult:
    pid: i64
    error_code: i32

    static fn ok(pid: i64) -> ExecSpawnResult:
        ExecSpawnResult(pid: pid, error_code: 0)

    static fn err(code: i32) -> ExecSpawnResult:
        ExecSpawnResult(pid: -1, error_code: code)

fn simulate_fs_exec_spawn(caller: i64, path: text, has_exec: bool, has_spawn: bool, file_exists: bool, valid_elf: bool) -> ExecSpawnResult:
    val cap_result = exec_cap_check(caller, path, has_exec, has_spawn)
    if cap_result != 0:
        return ExecSpawnResult.err(cap_result)
    if not file_exists:
        return ExecSpawnResult.err(-2)
    if not valid_elf:
        return ExecSpawnResult.err(-8)
    return ExecSpawnResult.ok(42)

# ---------------------------------------------------------------------------
# Spec blocks
# ---------------------------------------------------------------------------

describe "SimpleOS exec-from-filesystem pipeline":

    it "capability_gate_denies_unprivileged_exec":
        val result = exec_cap_check(100, "/apps/hello", false, false)
        expect(result).to_equal(-13)

    it "capability_gate_denies_missing_process_spawn":
        val result = exec_cap_check(100, "/apps/hello", true, false)
        expect(result).to_equal(-13)

    it "capability_gate_permits_privileged_exec":
        val result = exec_cap_check(100, "/apps/hello", true, true)
        expect(result).to_equal(0)

    it "capability_gate_bypasses_for_kernel_origin":
        val result = exec_cap_check(0, "/apps/hello", false, false)
        expect(result).to_equal(0)

    it "elf64_magic_detection_succeeds_on_valid_header":
        val bytes = make_valid_elf_magic()
        expect(elf64_has_magic(bytes)).to_equal(true)

    it "elf64_magic_detection_rejects_invalid_header":
        val bytes = make_invalid_magic()
        expect(elf64_has_magic(bytes)).to_equal(false)

    it "elf64_magic_detection_rejects_short_input":
        val bytes: [i32] = [127, 69]
        expect(elf64_has_magic(bytes)).to_equal(false)

    it "fat32_binary_read_returns_nonempty_bytes":
        val result = Fat32ReadResult.ok(4096)
        expect(result.success).to_equal(true)
        expect(result.data_len > 0).to_equal(true)

    it "fat32_binary_read_reports_missing_file":
        val result = Fat32ReadResult.fail("file not found")
        expect(result.success).to_equal(false)
        expect(result.data_len).to_equal(0)

    it "hardening_probe_reports_nonzero_nx_when_hardened":
        val report = HardeningReport.hardened()
        expect(report.nx).to_equal(1)
        expect(report.smep).to_equal(1)
        expect(report.smap).to_equal(1)
        expect(report.wp).to_equal(1)
        expect(report.aslr_seed != 0).to_equal(true)

    it "hardening_probe_empty_has_zero_fields":
        val report = HardeningReport.empty()
        expect(report.nx).to_equal(0)
        expect(report.smep).to_equal(0)
        expect(report.smap).to_equal(0)

    it "exec_spawn_succeeds_with_full_privileges":
        val result = simulate_fs_exec_spawn(100, "/apps/hello", true, true, true, true)
        expect(result.error_code).to_equal(0)
        expect(result.pid > 0).to_equal(true)

    it "exec_spawn_fails_without_capability":
        val result = simulate_fs_exec_spawn(100, "/apps/hello", false, false, true, true)
        expect(result.error_code).to_equal(-13)

    it "exec_spawn_fails_on_missing_file":
        val result = simulate_fs_exec_spawn(100, "/apps/hello", true, true, false, true)
        expect(result.error_code).to_equal(-2)

    it "exec_spawn_fails_on_invalid_elf":
        val result = simulate_fs_exec_spawn(100, "/apps/hello", true, true, true, false)
        expect(result.error_code).to_equal(-8)

    it "exec_spawn_kernel_origin_bypasses_cap_check":
        val result = simulate_fs_exec_spawn(0, "/apps/hello", false, false, true, true)
        expect(result.error_code).to_equal(0)
        expect(result.pid > 0).to_equal(true)
