# SMF Dyload Gate (H8) — proves SMF dynamic-library loading works in practice
#
# Exercises the full kernel dyload pipeline at the public loader-API level:
#   .smf envelope bytes → loader_dynopen_smf_library_bytes_for_arch /
#   loader_dynopen_path → dylib_registry → loader_dynsym symbol resolution,
# including the role/arch/ABI validation matrix (fail-closed) and a real
# on-disk .smf file round-trip through rt_file_read_bytes.
#
# Seed-verifiable here: envelope parse, registry registration, symbol
# resolution by name, metadata validation (role-2 library, arch, ABI), and
# the on-disk file leg. BOOT-GATED (not provable under the seed): actually
# executing a resolved symbol — that needs the library mapped PF_X into a
# live process VM space in-guest; the spec pins that boundary by asserting
# unmapped symbols stay non-process-callable.
#
# FORMAT-SKEW NOTE (documented by the last test): the kernel reads role/arch/
# ABI at trailer bytes 60/61/62, but the compiler SMF v1.1 writer
# (src/compiler/70.backend/linker/smf_header.spl) stores module_hash (u64,
# default 0) at bytes 60-67 and its own arch at byte 7. Writer output is
# therefore always role=0 "unspecified": accepted by the executable-envelope
# path, but REJECTED by the strict role-2 library gate. No toolchain writer
# can emit a kernel-recognized role-2 SMF library today.

use std.spec
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.loader_api.{
    loader_dynopen_bytes,
    loader_dynopen_smf_library_bytes_for_arch,
    loader_dynopen_path,
    loader_dynsym,
    loader_dynsym_is_process_callable,
    loader_dynclose
}
use os.kernel.loader.dylib_registry.{dylib_registry_reset_for_test}

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

# ============================================================================
# Byte fixture builders
# ============================================================================

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn push_text_bytes(buf: [u8], value: text) -> [u8]:
    var out = buf
    val chars = value.bytes()
    var i = 0
    while i < chars.len():
        out.push(chars[i])
        i = i + 1
    out

fn pad_to(buf: [u8], target: i64) -> [u8]:
    while buf.len() < target:
        buf.push(0.to_u8())
    buf

fn make_elf64_lib_with_two_exports() -> [u8]:
    """Minimal ELF64 library stub exporting smf_hello (0xBEEF) and smf_add (0xF00D) via .dynsym."""
    var b: [u8] = []
    # ELF ident
    b.push(0x7F.to_u8())
    b.push(0x45.to_u8())
    b.push(0x4C.to_u8())
    b.push(0x46.to_u8())
    b.push(2.to_u8())
    b.push(1.to_u8())
    b.push(1.to_u8())
    b = pad_to(b, 16)
    # e_type=ET_EXEC, e_machine=x86_64, e_version=1
    b = push_u16_le(b, 2)
    b = push_u16_le(b, 62)
    b = push_u32_le(b, 1)
    # e_entry=0x400000, e_phoff=64, e_shoff=224
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 64)
    b = push_u64_le(b, 224)
    # e_flags=0, e_ehsize=64, e_phentsize=56, e_phnum=1, e_shentsize=64, e_shnum=3, e_shstrndx=0
    b = push_u32_le(b, 0)
    b = push_u16_le(b, 64)
    b = push_u16_le(b, 56)
    b = push_u16_le(b, 1)
    b = push_u16_le(b, 64)
    b = push_u16_le(b, 3)
    b = push_u16_le(b, 0)
    # PT_LOAD program header at 64: R+X, vaddr 0x400000, covers file
    b = push_u32_le(b, 1)
    b = push_u32_le(b, 5)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 216)
    b = push_u64_le(b, 216)
    b = push_u64_le(b, 0x1000)
    # .strtab at 128: \0 smf_hello \0 smf_add \0  (19 bytes)
    b = pad_to(b, 128)
    b.push(0.to_u8())
    b = push_text_bytes(b, "smf_hello")
    b.push(0.to_u8())
    b = push_text_bytes(b, "smf_add")
    b.push(0.to_u8())
    # .dynsym at 152: null sym + smf_hello + smf_add (3 * 24 bytes)
    b = pad_to(b, 152)
    b = pad_to(b, 176)   # null symbol (24 zero bytes)
    # smf_hello: st_name=1, st_info=0x12 (GLOBAL FUNC), st_shndx=1, st_value=0xBEEF
    b = push_u32_le(b, 1)
    b.push(0x12.to_u8())
    b.push(0.to_u8())
    b = push_u16_le(b, 1)
    b = push_u64_le(b, 0xBEEF)
    b = push_u64_le(b, 8)
    # smf_add: st_name=11, st_info=0x12, st_shndx=1, st_value=0xF00D
    b = push_u32_le(b, 11)
    b.push(0x12.to_u8())
    b.push(0.to_u8())
    b = push_u16_le(b, 1)
    b = push_u64_le(b, 0xF00D)
    b = push_u64_le(b, 8)
    # Section headers at 224: SHT_NULL + .dynsym + .strtab
    b = pad_to(b, 224)
    b = pad_to(b, 288)   # SHT_NULL (64 zero bytes)
    # .dynsym: sh_type=11, sh_offset=152, sh_size=72, sh_link=2 (strtab), sh_entsize=24
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 11)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 152)
    b = push_u64_le(b, 72)
    b = push_u32_le(b, 2)
    b = push_u32_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 24)
    # .strtab: sh_type=3, sh_offset=128, sh_size=19
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 3)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 128)
    b = push_u64_le(b, 19)
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b

fn make_smf_lib_envelope(role: i64, arch: i64, abi: i64) -> [u8]:
    """Wrap the ELF library stub in an SMF v1.1 EOF-128 trailer with explicit role/arch/ABI."""
    var b = make_elf64_lib_with_two_exports()
    val stub_size = b.len()
    val trailer = b.len()
    # magic "SMF\0"
    b.push(83.to_u8())
    b.push(77.to_u8())
    b.push(70.to_u8())
    b.push(0.to_u8())
    b = pad_to(b, trailer + 44)
    # entry point (u64 LE at trailer+44)
    b = push_u64_le(b, 0x400000)
    # stub_size (u32 at +52), smf_data_offset (u32 at +56)
    b = push_u32_le(b, stub_size)
    b = push_u32_le(b, stub_size)
    # role (+60), arch (+61), abi (+62)
    b.push(role.to_u8())
    b.push(arch.to_u8())
    b.push(abi.to_u8())
    b = pad_to(b, trailer + 128)
    b

fn make_writer_layout_envelope() -> [u8]:
    """Replicate what the compiler SMF v1.1 writer emits today (smf_header.spl to_bytes defaults).

    Byte 4/5 = version 1.1, byte 6 = platform, byte 7 = writer-side arch, and
    module_hash (default 0) occupies bytes 60-67 — so the kernel reads
    role=0, arch=0, abi=0 from every toolchain-written envelope.
    """
    var b = make_elf64_lib_with_two_exports()
    val stub_size = b.len()
    val trailer = b.len()
    b.push(83.to_u8())
    b.push(77.to_u8())
    b.push(70.to_u8())
    b.push(0.to_u8())
    b.push(1.to_u8())    # version_major
    b.push(1.to_u8())    # version_minor
    b.push(1.to_u8())    # platform = linux
    b.push(0.to_u8())    # writer arch code (x86_64 = 0 in smf_enums — NOT read by the kernel)
    b = pad_to(b, trailer + 44)
    b = push_u64_le(b, 0x400000)
    b = push_u32_le(b, stub_size)
    b = push_u32_le(b, stub_size)
    # bytes 60..67: module_hash = 0 (writer default) → kernel role/arch/abi all read 0
    b = pad_to(b, trailer + 128)
    b

# ============================================================================
# Gate
# ============================================================================

describe "smf_dyload gate (H8)":
    it "dynloads a role-2 x86_64 SMF library and resolves exported symbols by name":
        """A matching role-2/x86_64/simpleos-ABI envelope registers through the
        arch-validated loader API and both exported functions resolve via
        loader_dynsym, alongside the entry-symbol fast path."""
        dylib_registry_reset_for_test()
        val env = make_smf_lib_envelope(2, 1, 1)
        val handle = loader_dynopen_smf_library_bytes_for_arch("/lib/h8_hot.smf", env, Architecture.X86_64)
        expect(handle).to_be_greater_than(0)
        # exported symbols via .dynsym slow path
        expect(loader_dynsym(handle, "smf_hello")).to_equal(0xBEEF)
        expect(loader_dynsym(handle, "smf_add")).to_equal(0xF00D)
        # entry-symbol fast path
        expect(loader_dynsym(handle, "_start")).to_equal(0x400000)
        expect(loader_dynsym(handle, "main")).to_equal(0x400000)
        # missing symbol → -ENOENT
        expect(loader_dynsym(handle, "smf_missing")).to_equal(-2)
        expect(loader_dynclose(handle)).to_equal(0)

    it "accepts arch-matching and arch-unspecified envelopes":
        dylib_registry_reset_for_test()
        # arm64 envelope on an arm64 target
        val arm_env = make_smf_lib_envelope(2, 3, 1)
        val arm_handle = loader_dynopen_smf_library_bytes_for_arch("/lib/h8_arm64.smf", arm_env, Architecture.Arm64)
        expect(arm_handle).to_be_greater_than(0)
        expect(loader_dynsym(arm_handle, "smf_hello")).to_equal(0xBEEF)
        # arch/abi = 0 (unspecified) is accepted for any target
        val any_env = make_smf_lib_envelope(2, 0, 0)
        val any_handle = loader_dynopen_smf_library_bytes_for_arch("/lib/h8_anyarch.smf", any_env, Architecture.X86_64)
        expect(any_handle).to_be_greater_than(0)

    it "fails closed for wrong-arch, wrong-role, and wrong-ABI envelopes":
        """Mismatched metadata must never register a handle: each rejection
        returns -ENOEXEC (-8) before the registry is touched."""
        dylib_registry_reset_for_test()
        # arm64-tagged library on an x86_64 target
        val wrong_arch = make_smf_lib_envelope(2, 3, 1)
        expect(loader_dynopen_smf_library_bytes_for_arch("/lib/h8_bad.smf", wrong_arch, Architecture.X86_64)).to_equal(-8)
        # executable role (1) through the library gate
        val wrong_role = make_smf_lib_envelope(1, 1, 1)
        expect(loader_dynopen_smf_library_bytes_for_arch("/lib/h8_bad.smf", wrong_role, Architecture.X86_64)).to_equal(-8)
        # unknown ABI (2)
        val wrong_abi = make_smf_lib_envelope(2, 1, 2)
        expect(loader_dynopen_smf_library_bytes_for_arch("/lib/h8_bad.smf", wrong_abi, Architecture.X86_64)).to_equal(-8)
        # empty bytes / empty path
        val empty: [u8] = []
        expect(loader_dynopen_smf_library_bytes_for_arch("/lib/h8_bad.smf", empty, Architecture.X86_64)).to_equal(-2)
        expect(loader_dynopen_smf_library_bytes_for_arch("", make_smf_lib_envelope(2, 1, 1), Architecture.X86_64)).to_equal(-22)

    it "dynloads a real on-disk .smf file via loader_dynopen_path":
        """The file leg of the pipeline: envelope bytes written to disk are
        read back through rt_file_read_bytes and register end-to-end."""
        dylib_registry_reset_for_test()
        val path = "/tmp/h8_smf_dyload_gate.smf"
        val env = make_smf_lib_envelope(2, 1, 1)
        expect(rt_file_write_bytes(path, env)).to_equal(true)
        val handle = loader_dynopen_path(path)
        expect(handle).to_be_greater_than(0)
        expect(loader_dynsym(handle, "smf_hello")).to_equal(0xBEEF)
        expect(loader_dynsym(handle, "smf_add")).to_equal(0xF00D)
        expect(loader_dynclose(handle)).to_equal(0)

    it "keeps unmapped SMF symbols non-process-callable (execution is boot-gated)":
        """Resolving a symbol from registry bytes is not the same as being able
        to call it: until the library is mapped PF_X into a live process VM
        space in-guest, the loader must report non-callable. Actually invoking
        the loaded code is the boot-gated half of this gate."""
        dylib_registry_reset_for_test()
        val env = make_smf_lib_envelope(2, 1, 1)
        val handle = loader_dynopen_smf_library_bytes_for_arch("/lib/h8_hot.smf", env, Architecture.X86_64)
        expect(handle).to_be_greater_than(0)
        expect(loader_dynsym(handle, "smf_hello")).to_equal(0xBEEF)
        expect(loader_dynsym_is_process_callable(handle, "smf_hello")).to_equal(false)

    it "documents the writer/kernel trailer skew: toolchain output cannot pass the role-2 library gate":
        """The compiler's SMF v1.1 writer stores module_hash at trailer bytes
        60-67 where the kernel reads role/arch/abi, so every written envelope
        arrives role=0: tolerated as an executable envelope, fail-closed as a
        role-2 library. This pins the current skew until a writer learns to
        emit kernel role/arch/ABI bytes."""
        dylib_registry_reset_for_test()
        val writer_env = make_writer_layout_envelope()
        # executable-envelope tolerance: role=0 registers via the generic path
        val handle = loader_dynopen_bytes("/lib/h8_writer.smf", writer_env)
        expect(handle).to_be_greater_than(0)
        expect(loader_dynsym(handle, "smf_hello")).to_equal(0xBEEF)
        # strict role-2 library gate fails closed on writer-default metadata
        expect(loader_dynopen_smf_library_bytes_for_arch("/lib/h8_writer2.smf", writer_env, Architecture.X86_64)).to_equal(-8)
