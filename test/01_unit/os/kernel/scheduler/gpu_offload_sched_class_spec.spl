"""
# SimpleOS GPU-Offload Scheduling — Pure Decision Logic Specification

[OS-DESIGN-ONLY] Boot-independent pure functions for the CPU/GPU offload model
(#39, Gaps #4/#5). The SimpleOS kernel wiring is boot-blocked (freestanding
B1/B2 + bootstrap stage-2), so this pins ONLY the pure decisions the design adds
over the existing green scheduler + SOSIX substrate + memory_leveling capsule.

Grounds (design mirrors these existing files):
- sched_class_rank      src/os/kernel/scheduler/scheduler_algorithm.spl:26-35
- SchedulerPolicy       src/os/kernel/types/task_types.spl:49-57
- green_task_park       src/os/kernel/scheduler/green_task.spl:55-65
- process_queue EAGAIN  src/os/kernel/ipc/process_queue.spl:151-152
- seal-before-share     src/os/kernel/ipc/shared_dataset.spl:98
- queue_send sealed gate src/os/kernel/ipc/syscall_spm.spl:393-395
- memory_leveling pin   src/os/kernel/memory/memory_leveling.spl (pin_device/GPU-resident)
"""

use std.spec.*

# Gap #4 rank extension — additive: GpuOffload at the Fair tier (3), no existing
# rank renumbered. Mirrors scheduler_algorithm.spl:26-35.
fn gpu_offload_sched_class_rank(policy: text) -> i32:
    if policy == "Internal": 0
    elif policy == "Deadline": 1
    elif policy == "RtFifo": 2
    elif policy == "RtRoundRobin": 2
    elif policy == "GpuOffload": 3
    elif policy == "Fair": 3
    elif policy == "Background": 4
    elif policy == "Idle": 5
    else: 5

# Gap #4 placement + backpressure fork — offload only when eligible AND host
# state is not mutated AND the bounded dispatch queue has room; a full queue
# yields backpressure (process_queue.spl:151-152).
fn gpu_offload_placement(op_eligible: bool, host_no_mutation: bool, queue_depth: i64, queue_cap: i64) -> text:
    if (not op_eligible) or (not host_no_mutation):
        "cpu_mirror"
    elif queue_depth >= queue_cap:
        "backpressure"
    else:
        "offload"

# Gap #4b memory_leveling integration — GPU offload is only active under the
# heterogeneous_device profile (GPU tier enabled). baremetal_static and
# simpleos_default have no GPU tier -> always cpu_mirror.
fn gpu_offload_profile_gate(profile: text) -> bool:
    profile == "heterogeneous_device"

# Gap #4b pin lifecycle — a sealed command buffer's page is pin_device on submit
# and released to keep on completion (the completion token is the coherence
# proof). Mirrors "GPU-resident pages reject swap/demotion until a coherence
# proof exists" (memory_leveling.spl).
fn gpu_offload_pin_lifecycle(phase: text) -> text:
    if phase == "submit":
        "pin_device"
    elif phase == "completed":
        "keep"
    elif phase == "unavailable":
        "keep"
    else:
        "pin_device"

# Gap #5 sealed command-buffer protocol — seal-before-enqueue (shared_dataset.spl:98;
# syscall_spm.spl:393-395 requires attached sealed). Illegal transitions are named.
fn sealed_cmd_buffer_next(state: text, event: text) -> text:
    if state == "building" and event == "seal":
        "sealed"
    elif state == "building" and event == "enqueue":
        "rejected_unsealed"
    elif state == "sealed" and event == "enqueue":
        "queued"
    elif state == "sealed" and event == "write":
        "rejected_sealed"
    elif state == "queued" and event == "submit":
        "submitted"
    elif state == "submitted" and event == "complete":
        "completed"
    else:
        state

describe "GPU-offload scheduling pure decision logic (OS-DESIGN-ONLY)":
    describe "Gap #4 sched-class rank (additive over scheduler_algorithm.spl:26-35)":
        it "places GpuOffload at the interactive/Fair tier":
            assert_equal(gpu_offload_sched_class_rank("GpuOffload"), 3)
            assert_equal(gpu_offload_sched_class_rank("Fair"), 3)
        it "never preempts RT or Deadline":
            assert_true(gpu_offload_sched_class_rank("GpuOffload") > gpu_offload_sched_class_rank("RtFifo"))
            assert_true(gpu_offload_sched_class_rank("GpuOffload") > gpu_offload_sched_class_rank("Deadline"))
        it "is never starved below Idle":
            assert_true(gpu_offload_sched_class_rank("GpuOffload") < gpu_offload_sched_class_rank("Idle"))
        it "leaves existing class ranks unchanged":
            assert_equal(gpu_offload_sched_class_rank("Internal"), 0)
            assert_equal(gpu_offload_sched_class_rank("Deadline"), 1)
            assert_equal(gpu_offload_sched_class_rank("RtFifo"), 2)
            assert_equal(gpu_offload_sched_class_rank("Background"), 4)
            assert_equal(gpu_offload_sched_class_rank("Idle"), 5)

    describe "Gap #4 placement + backpressure fork":
        it "offloads an eligible host-immutable op when the queue has room":
            assert_equal(gpu_offload_placement(true, true, 0, 1024), "offload")
        it "stays on the CPU mirror when the op is ineligible":
            assert_equal(gpu_offload_placement(false, true, 0, 1024), "cpu_mirror")
        it "stays on the CPU mirror when the op mutates host state":
            assert_equal(gpu_offload_placement(true, false, 0, 1024), "cpu_mirror")
        it "signals backpressure when the bounded queue is full":
            assert_equal(gpu_offload_placement(true, true, 1024, 1024), "backpressure")

    describe "Gap #4b memory_leveling integration":
        it "activates GPU offload only under the heterogeneous_device profile":
            assert_true(gpu_offload_profile_gate("heterogeneous_device"))
        it "disables GPU offload under baremetal_static and simpleos_default":
            assert_false(gpu_offload_profile_gate("baremetal_static"))
            assert_false(gpu_offload_profile_gate("simpleos_default"))
        it "pins the command-buffer page on submit and releases it on completion":
            assert_equal(gpu_offload_pin_lifecycle("submit"), "pin_device")
            assert_equal(gpu_offload_pin_lifecycle("completed"), "keep")
        it "releases the pin even on an unavailable (fallback) completion":
            assert_equal(gpu_offload_pin_lifecycle("unavailable"), "keep")

    describe "Gap #5 sealed command-buffer protocol":
        it "seals a building buffer before it can be shared":
            assert_equal(sealed_cmd_buffer_next("building", "seal"), "sealed")
        it "rejects enqueue of an unsealed buffer (seal-before-share)":
            assert_equal(sealed_cmd_buffer_next("building", "enqueue"), "rejected_unsealed")
        it "rejects a write to a sealed buffer (immutability)":
            assert_equal(sealed_cmd_buffer_next("sealed", "write"), "rejected_sealed")
        it "runs seal -> enqueue -> submit -> complete to completion":
            val s1 = sealed_cmd_buffer_next("building", "seal")
            val s2 = sealed_cmd_buffer_next(s1, "enqueue")
            val s3 = sealed_cmd_buffer_next(s2, "submit")
            val s4 = sealed_cmd_buffer_next(s3, "complete")
            assert_equal(s4, "completed")
