# Unit spec for simplebox_dispatch multi-call router
use std.spec
use os.tools.simplebox.simplebox_dispatch.{simplebox_dispatch, simplebox_applet_names, simplebox_has_applet}

describe "simplebox multi-call dispatcher":
    describe "simplebox_dispatch by argv[0] basename":
        it "dispatches echo via full path basename":
            val result = simplebox_dispatch(["/usr/bin/echo", "hello"])
            expect(result).to_equal(0)

        it "dispatches true via bare name":
            val result = simplebox_dispatch(["true"])
            expect(result).to_equal(0)

        it "dispatches false via bare name":
            val result = simplebox_dispatch(["false"])
            expect(result).to_equal(1)

        it "dispatches pwd via bare name":
            val result = simplebox_dispatch(["pwd"])
            expect(result).to_equal(0)

    describe "simplebox_dispatch via simplebox/busybox argv[1]":
        it "dispatches echo via simplebox":
            val result = simplebox_dispatch(["simplebox", "echo", "hello"])
            expect(result).to_equal(0)

        it "dispatches false via simplebox":
            val result = simplebox_dispatch(["simplebox", "false"])
            expect(result).to_equal(1)

        it "dispatches true via busybox":
            val result = simplebox_dispatch(["busybox", "true"])
            expect(result).to_equal(0)

        it "dispatches false via busybox":
            val result = simplebox_dispatch(["/bin/busybox", "false"])
            expect(result).to_equal(1)

    describe "simplebox_dispatch edge cases":
        it "returns 127 for unknown applet via basename":
            val result = simplebox_dispatch(["unknowncmd"])
            expect(result).to_equal(127)

        it "returns 127 for unknown applet via simplebox":
            val result = simplebox_dispatch(["simplebox", "unknowncmd"])
            expect(result).to_equal(127)

        it "returns 0 for --list via simplebox":
            val result = simplebox_dispatch(["simplebox", "--list"])
            expect(result).to_equal(0)

        it "returns 0 for --list as basename":
            val result = simplebox_dispatch(["--list"])
            expect(result).to_equal(0)

        it "returns 127 for empty argv":
            val result = simplebox_dispatch([])
            expect(result).to_equal(127)

        it "returns 127 for simplebox with no applet argv":
            val result = simplebox_dispatch(["simplebox"])
            expect(result).to_equal(127)

    describe "simplebox_has_applet":
        it "returns true for echo":
            expect(simplebox_has_applet("echo")).to_equal(true)

        it "returns true for true":
            expect(simplebox_has_applet("true")).to_equal(true)

        it "returns true for false":
            expect(simplebox_has_applet("false")).to_equal(true)

        it "returns true for pwd":
            expect(simplebox_has_applet("pwd")).to_equal(true)

        it "returns false for unknown":
            expect(simplebox_has_applet("unknowncmd")).to_equal(false)

        it "returns false for empty string":
            expect(simplebox_has_applet("")).to_equal(false)

    describe "simplebox_applet_names":
        it "returns exactly 4 applets":
            val names = simplebox_applet_names()
            expect(names.len()).to_equal(4)

        it "first applet is echo":
            val names = simplebox_applet_names()
            expect(names[0]).to_equal("echo")

        it "second applet is true":
            val names = simplebox_applet_names()
            expect(names[1]).to_equal("true")

        it "third applet is false":
            val names = simplebox_applet_names()
            expect(names[2]).to_equal("false")

        it "fourth applet is pwd":
            val names = simplebox_applet_names()
            expect(names[3]).to_equal("pwd")
