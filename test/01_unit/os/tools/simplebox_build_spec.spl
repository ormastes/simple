"""simplebox build wiring — native-build compiles simplebox for the SimpleOS
target into the rootfs (where image_builder packs it as /bin/simplebox).

This locks the build half of the userland->image wire: the command targets
simpleos, compiles the libc-consuming entry, and outputs to the rootfs path the
image builder reads.
"""

use std.spec
use os.tools.simplebox.simplebox_build.{simplebox_native_build_cmd, simplebox_output_path}

describe "simplebox build wiring":
    context "native-build command for the simpleos target":
        it "passes --target":
            expect(simplebox_native_build_cmd("simpleos").contains("--target")).to_equal(true)
        it "targets simpleos":
            expect(simplebox_native_build_cmd("simpleos").contains("simpleos")).to_equal(true)
        it "compiles the libc-consuming simplebox entry":
            expect(simplebox_native_build_cmd("simpleos").contains("src/os/tools/simplebox/simplebox_main.spl")).to_equal(true)
        it "emits to the rootfs path the image builder packs":
            expect(simplebox_native_build_cmd("simpleos").contains("build/os/rootfs/bin/simplebox")).to_equal(true)

    context "output path matches the image pack source":
        it "is the rootfs bin path":
            expect(simplebox_output_path()).to_equal("build/os/rootfs/bin/simplebox")
