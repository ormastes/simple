# Unit spec for simplebox applet cores
use std.spec
use os.tools.simplebox.simplebox_applets_core.{applet_dd, applet_timeout_parse, applet_chown_parse, ChownReq}

describe "simplebox extra applets":
    describe "applet_dd":
        it "returns count bytes from offset":
            # Build test array: [1, 2, 3, 4, 5]
            var src: [u8] = []
            src.push(1)
            src.push(2)
            src.push(3)
            src.push(4)
            src.push(5)
            val result = applet_dd(src, 1, 2)
            expect(result.len()).to_equal(2)
            expect(result[0]).to_equal(2)
            expect(result[1]).to_equal(3)

        it "clamps to end of array":
            var src: [u8] = []
            src.push(1)
            src.push(2)
            src.push(3)
            src.push(4)
            src.push(5)
            val result = applet_dd(src, 2, 10)  # count extends past end
            expect(result.len()).to_equal(3)
            expect(result[0]).to_equal(3)
            expect(result[1]).to_equal(4)
            expect(result[2]).to_equal(5)

        it "returns empty when skip >= length":
            var src: [u8] = []
            src.push(1)
            src.push(2)
            src.push(3)
            val result = applet_dd(src, 10, 5)
            expect(result.len()).to_equal(0)

        it "handles zero count":
            var src: [u8] = []
            src.push(1)
            src.push(2)
            src.push(3)
            val result = applet_dd(src, 0, 0)
            expect(result.len()).to_equal(0)

    describe "applet_timeout_parse":
        it "parses plain digits as seconds":
            expect(applet_timeout_parse("5")).to_equal(5)
            expect(applet_timeout_parse("123")).to_equal(123)

        it "parses seconds suffix":
            expect(applet_timeout_parse("5s")).to_equal(5)
            expect(applet_timeout_parse("30s")).to_equal(30)

        it "parses minutes suffix":
            expect(applet_timeout_parse("2m")).to_equal(120)
            expect(applet_timeout_parse("1m")).to_equal(60)

        it "parses hours suffix":
            expect(applet_timeout_parse("1h")).to_equal(3600)
            expect(applet_timeout_parse("2h")).to_equal(7200)

        it "returns -1 on invalid spec":
            expect(applet_timeout_parse("")).to_equal(-1)
            expect(applet_timeout_parse("5x")).to_equal(-1)
            expect(applet_timeout_parse("abc")).to_equal(-1)
            expect(applet_timeout_parse("5s5")).to_equal(-1)

        it "returns -1 when starting with non-digit":
            expect(applet_timeout_parse("s5")).to_equal(-1)

    describe "applet_chown_parse":
        it "parses uid:gid format":
            val req = applet_chown_parse("1000:1000")
            expect(req.uid).to_equal(1000)
            expect(req.gid).to_equal(1000)
            expect(req.has_uid).to_equal(true)
            expect(req.has_gid).to_equal(true)

        it "parses uid only":
            val req = applet_chown_parse("1000")
            expect(req.uid).to_equal(1000)
            expect(req.gid).to_equal(-1)
            expect(req.has_uid).to_equal(true)
            expect(req.has_gid).to_equal(false)

        it "parses :gid only":
            val req = applet_chown_parse(":1000")
            expect(req.uid).to_equal(-1)
            expect(req.gid).to_equal(1000)
            expect(req.has_uid).to_equal(false)
            expect(req.has_gid).to_equal(true)

        it "parses empty spec":
            val req = applet_chown_parse("")
            expect(req.uid).to_equal(-1)
            expect(req.gid).to_equal(-1)
            expect(req.has_uid).to_equal(false)
            expect(req.has_gid).to_equal(false)

        it "parses multiple digits":
            val req = applet_chown_parse("1234:5678")
            expect(req.uid).to_equal(1234)
            expect(req.gid).to_equal(5678)

        it "parses just colon":
            val req = applet_chown_parse(":")
            expect(req.uid).to_equal(-1)
            expect(req.gid).to_equal(-1)
            expect(req.has_uid).to_equal(false)
            expect(req.has_gid).to_equal(false)
