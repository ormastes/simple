use std.spec.*
use os.qemu_runner.{scenario_exists, scenario_by_name_direct, scenario_target}

describe "SimpleOS x86 host-GPU QEMU scenario":
    it "routes the named scenario to the dedicated probe ELF and ivshmem device":
        expect(scenario_exists("simpleos-host-gpu-x64")).to_be(true)
        val scenario = scenario_by_name_direct("simpleos-host-gpu-x64")
        val target = scenario_target(scenario)
        expect(target.entry).to_equal("examples/09_embedded/simple_os/arch/x86_64/host_gpu_smoke_entry.spl")
        expect(target.output).to_equal("build/os/simpleos_x86_64_host_gpu_probe.elf")
        expect(scenario.qemu_extra.join(" ")).to_contain("ivshmem-plain")
        expect(scenario.qemu_extra.join(" ")).to_contain("ivshmem-live.bin")
