fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn ring_next(idx: i64, size: i64) -> i64:
    (idx + 1) - ((idx + 1) / size) * size

fn desc_addr(base: i64, idx: i64) -> i64:
    base + idx * 16

fn simulated_alloc_queue_base(use_fixed: bool) -> i64:
    # Simulate: old path returned fixed 0x200000; new path uses PMM
    if use_fixed:
        0x200000
    else:
        # PMM returns a dynamically allocated address (not 0x200000)
        0x300000

fn main():
    print "=== VirtIO ==="
    check("r0", ring_next(0, 128) == 1)
    check("r127", ring_next(127, 128) == 0)
    check("r64", ring_next(64, 128) == 65)
    check("d0", desc_addr(0x1000, 0) == 0x1000)
    check("d1", desc_addr(0x1000, 1) == 0x1010)
    check("d10", desc_addr(0x1000, 10) == 0x10A0)
    # B3: virtio_common no longer uses hardcoded 0x200000 for queue_base
    val pmm_base = simulated_alloc_queue_base(false)
    check("queue_base_not_hardcoded", pmm_base != 0x200000)
    print "=== DONE ==="
