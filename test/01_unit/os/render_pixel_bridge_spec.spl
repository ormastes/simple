# @cover src/os/gui/render.spl 70%
# @req FR-SOS-PIXEL-BRIDGE
#
# The widget/compositor pixel-buffer path (common.ui SharedWmPixelBufferBackend)
# reaches the MMIO framebuffer through os.gui.render.render_blit_frame: it copies
# a row-major [u32] ARGB frame into the shadow buffer, marks the whole frame
# dirty, and presents. With no real framebuffer address (fb_addr == 0) present is
# a no-op, so this asserts the copy landed in the shadow buffer via px_read.

use std.spec.*
use os.gui.render.{render_init, render_blit_frame, px_read, render_shadow_buf}

describe "widget pixels -> render shadow buffer bridge":

    it "copies a composed 2x2 frame into the shadow buffer, in order":
        # fb_addr = 0 -> present() is skipped; only the shadow buffer is written.
        render_init(0, 2, 2)
        assert_true(render_shadow_buf() != 0)
        val pixels: [u32] = [0xFF112233u32, 0xFF445566u32, 0xFF778899u32, 0xFFAABBCCu32]
        render_blit_frame(pixels, 2, 2)
        val e00: u64 = 0xFF112233
        val e10: u64 = 0xFF445566
        val e01: u64 = 0xFF778899
        val e11: u64 = 0xFFAABBCC
        expect(px_read(0, 0)).to_equal(e00)
        expect(px_read(1, 0)).to_equal(e10)
        expect(px_read(0, 1)).to_equal(e01)
        expect(px_read(1, 1)).to_equal(e11)

    it "clamps an over-long source to the framebuffer capacity without overrun":
        render_init(0, 2, 1)
        # 4 pixels supplied for a 2x1 (2-pixel) buffer: only the first two land.
        val pixels: [u32] = [0xFF010101u32, 0xFF020202u32, 0xFF030303u32, 0xFF040404u32]
        render_blit_frame(pixels, 2, 1)
        val a: u64 = 0xFF010101
        val b: u64 = 0xFF020202
        expect(px_read(0, 0)).to_equal(a)
        expect(px_read(1, 0)).to_equal(b)
