fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn csec(c: i64, s: i64, spc: i64) -> i64: s + (c - 2) * spc
fn eoc(e: i64) -> bool: e >= 0x0FFFFFF8
fn main():
    print "=== FAT32 ==="
    check("c2", csec(2, 100, 8) == 100)
    check("c3", csec(3, 100, 8) == 108)
    check("c10", csec(10, 100, 8) == 164)
    check("eoc+", eoc(0x0FFFFFF8))
    check("eoc++", eoc(0x0FFFFFFF))
    check("!eoc", not eoc(2))
    check("!eoc7", not eoc(0x0FFFFFF7))
    print "=== DONE ==="
