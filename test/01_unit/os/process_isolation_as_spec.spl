# Process Isolation — Address Space + Process Table Spec
#
# Covers:
#   - AddressSpace handle accessors (as_phys_root, as_id, as_is_kernel)
#   - as_switch_to dedup (no-op when root unchanged)
#   - as_create / as_destroy lifecycle
#   - pt_ext_alloc_pid monotonic counter
#   - pt_ext_register + pt_ext_lookup round-trip
#   - pt_ext_set_state update
#   - pt_ext_reap tombstones entry
#   - pt_ext_count and pt_ext_list_pids
#   - pt_ext_spawn convenience helper
#   - pt_ext_spawn_with_kernel_as kernel thread path
#   - pt_ext_address_space_for present and absent cases
#   - as_switch_to idempotency (same root twice)
#   - as_kernel_sentinel returns zero root

use std.spec.{describe, it, expect}
use os.kernel.types.task_types.{AddressSpace}
use os.kernel.scheduler.address_space_switch.{
    as_phys_root, as_id, as_is_kernel, as_kernel_sentinel,
    as_current_phys_root, as_switch_to, as_create, as_destroy
}
use os.kernel.scheduler.process_table_extended.{
    pt_ext_alloc_pid, pt_ext_register, pt_ext_lookup,
    pt_ext_set_state, pt_ext_reap, pt_ext_count,
    pt_ext_list_pids, pt_ext_spawn, pt_ext_spawn_with_kernel_as,
    pt_ext_address_space_for
}

# @cover address_space_switch
# @cover process_table_extended

describe "AddressSpace handle accessors":
    it "as_phys_root returns the physical root":
        val space = AddressSpace(phys_root: 0x1000, id: 7)
        expect as_phys_root(space) == 0x1000

    it "as_id returns the monotonic id":
        val space = AddressSpace(phys_root: 0x2000, id: 42)
        expect as_id(space) == 42

    it "as_is_kernel true for zero root":
        val space = AddressSpace(phys_root: 0, id: 0)
        expect as_is_kernel(space) == true

    it "as_is_kernel false for nonzero root":
        val space = AddressSpace(phys_root: 0x3000, id: 1)
        expect as_is_kernel(space) == false

    it "as_kernel_sentinel returns zero root":
        val sentinel = as_kernel_sentinel()
        expect sentinel.phys_root == 0
        expect sentinel.id == 0

describe "as_switch_to deduplication":
    it "as_switch_to updates current root":
        as_switch_to(0x4000)
        expect as_current_phys_root() == 0x4000

    it "as_switch_to is idempotent (same root twice)":
        as_switch_to(0x5000)
        as_switch_to(0x5000)
        expect as_current_phys_root() == 0x5000

    it "as_switch_to zero root is a no-op after the root is set":
        as_switch_to(0x6000)
        as_switch_to(0)
        # zero means no-op; current root stays from previous call
        expect as_current_phys_root() == 0x6000

describe "as_create / as_destroy lifecycle":
    it "as_create returns an AddressSpace (phys_root may be 1 if VMM not init)":
        val space = as_create()
        val root = as_phys_root(space)
        expect (root == 0 or root == 1 or root > 4096) == true

    it "as_destroy on kernel sentinel is a no-op":
        val sentinel = as_kernel_sentinel()
        as_destroy(sentinel)
        expect as_phys_root(sentinel) == 0

    it "as_destroy on sentinel root=1 is a no-op":
        val legacy = AddressSpace(phys_root: 1, id: 0)
        as_destroy(legacy)
        expect as_phys_root(legacy) == 1

describe "Process Table Extended — alloc and register":
    it "pt_ext_alloc_pid is monotonically increasing":
        val p1 = pt_ext_alloc_pid()
        val p2 = pt_ext_alloc_pid()
        expect p2 > p1

    it "pt_ext_alloc_pid always > 0":
        val pid = pt_ext_alloc_pid()
        expect pid > 0

    it "pt_ext_register + pt_ext_lookup round-trip":
        val pid = pt_ext_alloc_pid()
        val space = AddressSpace(phys_root: 0x9000, id: 99)
        pt_ext_register(pid, space)
        val opt = pt_ext_lookup(pid)
        expect opt.is_some == true
        expect opt.entry.pid == pid
        expect opt.entry.space.phys_root == 0x9000

    it "pt_ext_lookup absent PID returns is_some = false":
        val opt = pt_ext_lookup(-999)
        expect opt.is_some == false

    it "pt_ext_set_state updates state field":
        val pid = pt_ext_alloc_pid()
        val space = AddressSpace(phys_root: 0xA000, id: 3)
        pt_ext_register(pid, space)
        pt_ext_set_state(pid, "blocked")
        val opt = pt_ext_lookup(pid)
        expect opt.is_some == true
        expect opt.entry.state == "blocked"

    it "pt_ext_reap tombstones the entry":
        val pid = pt_ext_alloc_pid()
        val space = AddressSpace(phys_root: 1, id: 0)
        pt_ext_register(pid, space)
        pt_ext_reap(pid)
        val opt = pt_ext_lookup(pid)
        expect opt.is_some == false

describe "Process Table Extended — count and list":
    it "pt_ext_count increases after register":
        val before = pt_ext_count()
        val pid = pt_ext_alloc_pid()
        pt_ext_register(pid, AddressSpace(phys_root: 1, id: 0))
        val after = pt_ext_count()
        expect after == before + 1

    it "pt_ext_list_pids contains newly registered pid":
        val pid = pt_ext_alloc_pid()
        pt_ext_register(pid, AddressSpace(phys_root: 1, id: 0))
        val pids = pt_ext_list_pids()
        var found = false
        var i = 0
        while i < pids.len():
            if pids[i] == pid:
                found = true
            i = i + 1
        expect found == true

describe "Convenience helpers":
    it "pt_ext_spawn returns a positive pid":
        val pid = pt_ext_spawn()
        expect pid > 0

    it "pt_ext_spawn registers a live entry":
        val pid = pt_ext_spawn()
        val opt = pt_ext_lookup(pid)
        expect opt.is_some == true

    it "pt_ext_spawn_with_kernel_as registers with phys_root 0":
        val pid = pt_ext_spawn_with_kernel_as()
        val opt = pt_ext_lookup(pid)
        expect opt.is_some == true
        expect opt.entry.space.phys_root == 0

    it "pt_ext_address_space_for returns sentinel for unknown pid":
        val space = pt_ext_address_space_for(-777)
        expect space.phys_root == 0
