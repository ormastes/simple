# @tag:unit
# @tag:os

use std.spec.*
use app.io.mod.{file_read}

describe "x86 SSH boot contracts":

    it "accepts QEMU host-forwarded SSH SYNs delivered to guest port 2222":
        val source = file_read("examples/09_embedded/simple_os/arch/x86_64/boot/baremetal_stubs.c")
        expect(source).to_contain("static int _tcp_listener_accepts_port(uint16_t listen_port, uint16_t dst_port)")
        expect(source).to_contain("listen_port == dst_port || (listen_port == 22 && dst_port == 2222)")
        expect(source).to_contain("_tcp_listener_accepts_port(_sockets[i].local_port, dst_port)")
        expect(source).to_contain("_tcp_listener_accepts_port(_sockets[i].local_port, s->local_port)")

    it "implements live OpenSSH Curve25519 exchange hash on x86":
        val source = file_read("examples/09_embedded/simple_os/arch/x86_64/boot/baremetal_stubs.c")
        expect(source).to_contain("RuntimeValue rt_ssh_curve25519_exchange_hash(RuntimeValue client_version_rv")
        expect(source).to_contain("_ssh_hash_append_string(input, &off, sizeof(input), cv, cv_len)")
        expect(source).to_contain("_ssh_hash_append_mpint(input, &off, sizeof(input), ss, ss_len)")
        expect(source).to_contain("_tls_sha256_digest(input, off, out)")
