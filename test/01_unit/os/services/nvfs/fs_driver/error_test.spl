# @cover examples/nvfs/src/fs_driver/error.spl 80%
"""
# NVFS FsError Unit Tests

**Feature IDs:** #NVFS-FS-DRIVER-ERR
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** In Progress
**Design:** doc/05_design/nvfs_design.md §5.2

## Overview

Tests for the FsError enum and errno_of function:
  - NotFound → errno 2
  - Permission → errno 13
  - Busy → errno 16
  - AlreadyExists → errno 17
  - InvalidArg → errno 22
  - TooLarge → errno 27
  - NoSpace → errno 28
  - ReadOnly → errno 30
  - Unsupported → errno 38
  - Interrupted → errno 4
  - Construct-and-match for Transient and IoError
"""

use std.sspec.*
use std.fs_driver.error.*


# ============================================================================
# errno_of mappings
# ============================================================================

describe "FsError — errno_of mappings":
    """
    ## POSIX errno mappings

    errno_of must return the canonical POSIX errno for each FsError variant.
    """

    it "NotFound maps to errno 2 (ENOENT)":
        val e = FsError.NotFound
        expect(errno_of(e)).to_equal(2)

    it "Permission maps to errno 13 (EACCES)":
        val e = FsError.Permission
        expect(errno_of(e)).to_equal(13)

    it "Busy maps to errno 16 (EBUSY)":
        val e = FsError.Busy
        expect(errno_of(e)).to_equal(16)

    it "AlreadyExists maps to errno 17 (EEXIST)":
        val e = FsError.AlreadyExists
        expect(errno_of(e)).to_equal(17)

    it "InvalidArg maps to errno 22 (EINVAL)":
        val e = FsError.InvalidArg
        expect(errno_of(e)).to_equal(22)

    it "TooLarge maps to errno 27 (EFBIG)":
        val e = FsError.TooLarge
        expect(errno_of(e)).to_equal(27)

    it "NoSpace maps to errno 28 (ENOSPC)":
        val e = FsError.NoSpace
        expect(errno_of(e)).to_equal(28)

    it "ReadOnly maps to errno 30 (EROFS)":
        val e = FsError.ReadOnly
        expect(errno_of(e)).to_equal(30)

    it "Unsupported maps to errno 38 (ENOSYS)":
        val e = FsError.Unsupported
        expect(errno_of(e)).to_equal(38)

    it "Interrupted maps to errno 4 (EINTR)":
        val e = FsError.Interrupted
        expect(errno_of(e)).to_equal(4)


# ============================================================================
# Construct-and-match
# ============================================================================

describe "FsError — construct and match":
    """
    ## Variant construction

    Transient and IoError carry payloads; match must expose them correctly.
    """

    it "Transient(i32) carries payload and matches":
        val e = FsError.Transient(42)
        var matched = false
        match e:
            FsError.Transient(code):
                matched = (code == 42)
            _:
                matched = false
        expect(matched).to_equal(true)

    it "IoError(u32) carries payload and matches":
        val e = FsError.IoError(0xDEAD)
        var matched = false
        match e:
            FsError.IoError(code):
                matched = (code == 0xDEAD)
            _:
                matched = false
        expect(matched).to_equal(true)

    it "Corrupt variant constructs without payload":
        val e = FsError.Corrupt
        var is_corrupt = false
        match e:
            FsError.Corrupt:
                is_corrupt = true
            _:
                is_corrupt = false
        expect(is_corrupt).to_equal(true)
