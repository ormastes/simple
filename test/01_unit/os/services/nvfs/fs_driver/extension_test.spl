# @cover examples/nvfs/src/fs_driver/extension.spl 80%
"""
# NVFS Extension Unit Tests

**Feature IDs:** #NVFS-FS-DRIVER-EXT
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** In Progress
**Design:** doc/05_design/nvfs_design.md §5.5

## Overview

Tests for Extension enum (11 variants):
  - Snapshot, Dedup, Checksum, SendReceive, Scrub
  - Compress, Encrypt, Quota, Reflink, PosixCompat, DirectIo
  - Each wraps its own Ext struct with relevant fields
"""

use std.spipe.*
use std.fs_driver.extension.*


# ============================================================================
# PosixCompatExt
# ============================================================================

describe "Extension — PosixCompatExt":
    """
    ## PosixCompat extension

    PosixCompatExt carries flags and mode fields.
    """

    it "PosixCompatExt stores flags and mode":
        val ext = Extension.PosixCompat(PosixCompatExt(flags: 0x1, mode: 0o755))
        match ext:
            Extension.PosixCompat(inner):
                expect(inner.flags).to_equal(0x1)
                expect(inner.mode).to_equal(0o755)
            _:
                expect(false).to_equal(true)

    it "PosixCompatExt with zero flags is valid":
        val ext = Extension.PosixCompat(PosixCompatExt(flags: 0, mode: 0o644))
        match ext:
            Extension.PosixCompat(inner):
                expect(inner.flags).to_equal(0)
            _:
                expect(false).to_equal(true)


# ============================================================================
# SnapshotExt
# ============================================================================

describe "Extension — SnapshotExt":
    """
    ## Snapshot extension

    SnapshotExt stores snapshot metadata.
    """

    it "SnapshotExt constructs and matches":
        val ext = Extension.Snapshot(SnapshotExt(volume_name: "root", snap_count: 64))
        match ext:
            Extension.Snapshot(inner):
                expect(inner.snap_count).to_equal(64)
            _:
                expect(false).to_equal(true)


# ============================================================================
# ReflinkExt
# ============================================================================

describe "Extension — ReflinkExt":
    """
    ## Reflink extension

    ReflinkExt stores reflink-specific settings.
    """

    it "ReflinkExt constructs and matches":
        val ext = Extension.Reflink(ReflinkExt(shared_extents: 2, cow_pending: true))
        match ext:
            Extension.Reflink(inner):
                expect(inner.cow_pending).to_equal(true)
            _:
                expect(false).to_equal(true)


# ============================================================================
# Exhaustive match over all variants
# ============================================================================

describe "Extension — exhaustive match":
    """
    ## All variants

    An exhaustive match over all variants must cover every case.
    """

    it "match covers all Extension variants":
        val variants: [Extension] = [
            Extension.Snapshot(SnapshotExt(volume_name: "root", snap_count: 1)),
            Extension.Dedup(DedupExt(bytes_saved: 0, scan_active: false)),
            Extension.Checksum(ChecksumExt(algo_tag: 0, block_size: 4096)),
            Extension.SendReceive(SendRecvExt(last_sent_gen: 0, stream_format: 1)),
            Extension.Scrub(ScrubExt(blocks_verified: 0, errors_found: 0)),
            Extension.Compress(CompressExt(default_algo: 1, enabled: true)),
            Extension.Encrypt(EncryptExt(key_id: 7, key_bits: 256)),
            Extension.Quota(QuotaExt(marker: 1)),
            Extension.Reflink(ReflinkExt(shared_extents: 1, cow_pending: true)),
            Extension.PosixCompat(PosixCompatExt(flags: 0, mode: 0o755)),
            Extension.DirectIo(DirectIoExt(sector_alignment: 512, file_alignment: 512, max_io_bytes: 4096, backend_tag: "test", bounce_allowed: false))
        ]
        expect(variants.len()).to_equal(11)
        var count = 0
        for v in variants:
            match v:
                Extension.Snapshot(_): count = count + 1
                Extension.Dedup(_): count = count + 1
                Extension.Checksum(_): count = count + 1
                Extension.SendReceive(_): count = count + 1
                Extension.Scrub(_): count = count + 1
                Extension.Compress(_): count = count + 1
                Extension.Encrypt(_): count = count + 1
                Extension.Quota(_): count = count + 1
                Extension.Reflink(_): count = count + 1
                Extension.PosixCompat(_): count = count + 1
                Extension.DirectIo(_): count = count + 1
        expect(count).to_equal(11)
