use std.spec.{describe, it, expect}
use std.io_runtime.{read_file}

extern fn rt_dir_walk(path: text) -> [text]

fn _assert_no_legacy_fat_driver(path: text):
    val source = read_file(path)
    val legacy_type = "Fat32" + "Driver"
    expect(source.contains("use os.services.fat32.fat32")).to_equal(false)
    expect(source.contains("use os.services.fat32.fat32_write")).to_equal(false)
    expect(source.contains("use os.services.fat32.fat32_filesystem_ops")).to_equal(false)
    expect(source.contains("use os.services.fat32.fat32_write_helpers")).to_equal(false)
    expect(source.contains(" " + legacy_type + ".new(")).to_equal(false)
    expect(source.contains("=" + legacy_type + ".new(")).to_equal(false)
    expect(source.contains("(" + legacy_type + ".new(")).to_equal(false)

fn _assert_no_legacy_fat_module_import(path: text):
    val source = read_file(path)
    if source.contains("use os.services.fat32."):
        expect(source.contains("use os.services.fat32.shared_fat32_driver")).to_equal(true)
        expect(source.contains("use os.services.fat32.fat32")).to_equal(false)
        expect(source.contains("use os.services.fat32.fat32_write")).to_equal(false)
        expect(source.contains("use os.services.fat32.fat32_filesystem_ops")).to_equal(false)
        expect(source.contains("use os.services.fat32.fat32_write_helpers")).to_equal(false)

fn _is_legacy_fat_implementation(path: text) -> bool:
    path == "src/os/services/fat32/fat32.spl" or
        path == "src/os/services/fat32/fat32_write.spl" or
        path == "src/os/services/fat32/fat32_filesystem_ops.spl" or
        path == "src/os/services/fat32/fat32_write_helpers.spl"

fn _assert_os_tree_no_production_legacy_fat_driver():
    for path in rt_dir_walk("src/os"):
        if path.ends_with(".spl") and not _is_legacy_fat_implementation(path):
            _assert_no_legacy_fat_driver(path)
            _assert_no_legacy_fat_module_import(path)

describe "SimpleOS production FAT purity guard":
    it "keeps VFS and boot production paths on the shared pure Simple FAT core":
        _assert_no_legacy_fat_driver("src/os/services/vfs/vfs_boot_init.spl")
        _assert_no_legacy_fat_driver("src/os/services/vfs/vfs_init.spl")
        _assert_no_legacy_fat_driver("src/os/services/vfs/vfs_write_ops.spl")
        _assert_no_legacy_fat_driver("src/os/services/vfs/nvme_filesystem_mounts.spl")
        _assert_no_legacy_fat_driver("src/os/kernel/boot/boot_fs_mount.spl")

        val boot_source = read_file("src/os/services/vfs/vfs_boot_init.spl")
        val mount_source = read_file("src/os/services/vfs/nvme_filesystem_mounts.spl")
        val shared_source = read_file("src/os/services/fat32/shared_fat32_driver.spl")
        val shared_fat = "SharedFat32" + "Driver"
        val fs_fat = "FsFat32" + "Driver"
        expect(boot_source.contains("use os.services.fat32.shared_fat32_driver.{" + shared_fat + " as Fat32Core}")).to_equal(true)
        expect(boot_source.contains("var g_pure_nvme_root_fat32: Fat32Core = Fat32Core.new(g_adapter)")).to_equal(true)
        expect(boot_source.contains("var g_pure_nvme_root_fat32_ready: bool = false")).to_equal(true)
        expect(boot_source.contains("fn _vfs_boot_init_pure_nvme_fat32(nvme_idx: u64) -> bool:\n    \"\"\"Try the pure-Simple NVMe -> BlockDevice -> FAT32 stack first.\"\"\"\n    g_pure_nvme_root_fat32_ready = false")).to_equal(true)
        expect(boot_source.contains("g_pure_nvme_root_fat32 = Fat32Core.new(g_adapter)\n    val pure_root_mount = g_pure_nvme_root_fat32.mount(\"\", \"\")")).to_equal(true)
        expect(boot_source.contains("if pure_root_mount.is_ok():\n        g_pure_nvme_root_fat32_ready = true")).to_equal(true)
        expect(boot_source.contains("serial_println(\"[vfs-init] shared FAT32 root mount failed\")\n        return false")).to_equal(true)
        val direct_bootstrap = boot_source.index_of("    if not _vfs_boot_init_direct_fat32_reader_from_addr(boot_shared.cpu_virt_addr):") ?? -1
        val shared_mount = boot_source.index_of("    g_pure_nvme_root_fat32 = Fat32Core.new(g_adapter)") ?? -1
        expect(direct_bootstrap).to_be_greater_than(-1)
        expect(shared_mount).to_be_greater_than(direct_bootstrap)
        val shared_read = boot_source.index_of("    if g_pure_nvme_root_fat32_ready:") ?? -1
        val raw_fallback = boot_source.index_of("    if not g_boot_fat32_direct_ready:") ?? -1
        expect(shared_read).to_be_greater_than(-1)
        expect(raw_fallback).to_be_greater_than(shared_read)
        expect(boot_source.contains("_g_vfs_root_read_file_bytes_once(g_pure_nvme_root_fat32, path)")).to_equal(true)
        expect(boot_source.contains("val short_name = _vfs_boot_short_name_for_path(path)")).to_equal(true)
        expect(boot_source.contains("if upper.starts_with(\"/SYS/FONTS/\"):")).to_equal(true)
        expect(boot_source.contains("_vfs_boot_find_dirent_cluster(sys_cluster_fonts, \"FONTS\", true)")).to_equal(true)
        expect(boot_source.contains("g_root_fat32 = nil")).to_equal(true)
        expect(boot_source.contains("g_vfs_nvme_active_leases = [lease]\n    g_vfs_nvme_direct_adapter_leases = [lease]\n    g_vfs_nvme_direct_adapters = [g_adapter]")).to_equal(true)
        expect(mount_source.contains("use std.fs_driver.fat32_stub.{" + fs_fat + "}")).to_equal(true)
        expect(shared_source.contains("me fn sync() -> Result<bool, text>:")).to_equal(true)
        expect(shared_source.contains("val rc = self.inner.sync()")).to_equal(true)

    it "keeps the SimpleOS source tree off legacy FAT outside the isolated compatibility module":
        _assert_os_tree_no_production_legacy_fat_driver()

    it "keeps legacy FAT unit coverage from instantiating the retired driver":
        val source = read_file("test/unit/os/services/fat32/fat32_spec.spl")
        val legacy_type = "Fat32" + "Driver"
        expect(source.contains(legacy_type + ".new(")).to_equal(false)
        expect(source.contains("resolve_path(")).to_equal(false)
        expect(source.contains("readdir(")).to_equal(false)
