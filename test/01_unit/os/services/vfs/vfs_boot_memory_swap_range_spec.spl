use std.spec.*
use os.services.vfs.vfs_boot_init.{vfs_boot_memory_swap_range}

describe "SimpleOS production swap range":

    it "uses only the NVMe tail beyond the declared FAT32 volume":
        match vfs_boot_memory_swap_range(32768u64, 4096u32, 524288u64, 512u32):
            Some(swap_range):
                expect(swap_range.base_lba).to_equal(262144u64)
                expect(swap_range.capacity_slots).to_equal(32768u64)
            None: expect(false).to_equal(true)
        expect(vfs_boot_memory_swap_range(65536u64, 512u32, 65536u64, 512u32)).to_be_nil()
