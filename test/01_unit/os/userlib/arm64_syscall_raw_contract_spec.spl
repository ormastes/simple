use std.spec
use std.io_runtime.{file_read}

describe "ARM64 raw syscall ABI contract":
    it "loads the syscall id and five arguments into the live SVC ABI":
        val source = file_read("src/os/userlib/syscall_raw.spl")
        expect(source).to_contain("@cfg(arm64)")
        expect(source).to_contain("\"mov x8, {id}\"")
        expect(source).to_contain("\"mov x0, {arg0}\"")
        expect(source).to_contain("\"mov x1, {arg1}\"")
        expect(source).to_contain("\"mov x2, {arg2}\"")
        expect(source).to_contain("\"mov x3, {arg3}\"")
        expect(source).to_contain("\"mov x4, {arg4}\"")
        expect(source).to_contain("\"svc #0\"")
        expect(source).to_contain("\"mov {out}, x0\"")
        expect(source).to_contain("out(reg) result")
        expect(source).to_contain("clobber(\"x0\", \"x1\", \"x2\", \"x3\", \"x4\", \"x8\")")

    it "matches the live EL1 saved-register dispatch":
        val handler = file_read("examples/09_embedded/simple_os/arch/arm64/boot/crt0.S")
        expect(handler).to_contain("stp     x0,  x1,  [sp, #0]")
        expect(handler).to_contain("stp     x2,  x3,  [sp, #16]")
        expect(handler).to_contain("stp     x4,  x5,  [sp, #32]")
        expect(handler).to_contain("stp     x8,  x9,  [sp, #64]")
        expect(handler).to_contain("mov     x5, x4                 /* syscall arg4 */")
        expect(handler).to_contain("mov     x4, x3                 /* syscall arg3 */")
        expect(handler).to_contain("mov     x3, x2                 /* syscall arg2 */")
        expect(handler).to_contain("mov     x2, x1                 /* syscall arg1 */")
        expect(handler).to_contain("mov     x1, x0                 /* syscall arg0 */")
        expect(handler).to_contain("mov     x0, x8                 /* syscall id */")
        expect(handler).to_contain("str     x0, [sp, #0]           /* syscall return value -> user x0 */")
