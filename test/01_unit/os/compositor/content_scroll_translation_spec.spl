# Live paint-time scroll-translation coverage for the shared-WM Simple Web
# content path.
#
# host_compositor_content_scroll_spec.spl (deleted 2026-07-11 de-fake sweep)
# exercised canned/synthetic helpers that no longer exist. This spec covers
# the LIVE path that ships in production instead:
#   - HostCompositor.scroll_offsets / scroll_offset_for (host_compositor_core.spl)
#     accumulate wheel delta per window and feed it into render_frame() as
#     `scroll_y`.
#   - simple_web_content_frame_cached(..., scroll_y) (simple_web_window_renderer.spl)
#     renders the window's HTML at an enlarged viewport
#     (content_paint_full_height(ch, scroll_y) = ch + clamp(scroll_y, 0, 4000))
#     and then crops+translates the visible `ch`-tall window out of it
#     (private `_window_scrolled_pixels`: out[row] = full[scroll_y + row]).
#
# `_window_scrolled_pixels` and the internal clamp are private (leading `_`),
# so this spec proves the same translation contract through the PUBLIC
# `simple_web_content_frame_cached` API — the exact function host_compositor_core
# calls — plus the public `content_paint_full_height` clamp helper it also
# imports. No canned helpers, no fixture-only branches.
"""
# Content Scroll Translation

**Category:** Runtime
**Status:** Implemented

## Overview

Scrolling a hosted window's content does not re-render a different scroll
position from scratch — it renders the HTML once at an enlarged viewport
(visible height + scroll offset, capped at 4000px) and then copies the
visible window of rows out of that taller buffer. This proves that copy is a
byte-exact row shift, and that the render-height cap does not blow up.
"""

use std.spec.*
use os.compositor.simple_web_window_renderer.{simple_web_content_frame_cached, content_paint_full_height}
use std.gc_async_mut.ui.web_render_pixel_software_backend.{web_render_pixel_artifact_cache}

val THEME: text = "aetheric_dark"
val BG_COLOR: u32 = 0xFF182230u32   # aetheric_dark .wm-app-content background
val BAND_EVEN: u32 = 0xFF102030u32  # row i, i % 2 == 0
val BAND_ODD: u32 = 0xFF405060u32   # row i, i % 2 == 1

# `rows` stacked 1px-tall divs tiling the full canvas width, alternating two
# colors so a row-shift-by-N translation is bit-distinguishable from a
# row-shift-by-anything-else translation (a uniform-color fixture could not
# catch an off-by-N bug).
fn _row_band_html(rows: i32, width: i32) -> text:
    var html = ""
    var i = 0
    while i < rows:
        val color = if i % 2 == 0: "#102030" else: "#405060"
        html = html + "<div style='height:1px;width:" + width.to_text() + "px;background-color:" + color + "'></div>"
        i = i + 1
    html

describe "Live scroll-translation path (simple_web_content_frame_cached scroll_y)":

    it "shifts the painted rows by exactly scroll_y pixels, not an approximation":
        val width = 8
        val ch = 6          # visible window height
        val scroll_y = 5    # wheel-accumulated offset threaded from HostCompositor
        val full_h = ch + scroll_y
        val body = _row_band_html(full_h, width)

        step("Render the same HTML directly at the full enlarged viewport height (scroll_y=0, height=full_h) as the reference buffer")
        val full_cache = web_render_pixel_artifact_cache(width, full_h, "software")
        val full = simple_web_content_frame_cached(full_cache, "full-ref", 1, 1, THEME, "scroll-ref", body, width, full_h, 0)
        expect(full.pixels.len()).to_equal(width * full_h)
        expect(full.pixels[0]).to_equal(BAND_EVEN)
        expect(full.pixels[width]).to_equal(BAND_ODD)

        step("Render the live scrolled window (visible height=ch, scroll_y=5) through the same production entrypoint HostCompositor uses")
        val scrolled_cache = web_render_pixel_artifact_cache(width, ch, "software")
        val scrolled = simple_web_content_frame_cached(scrolled_cache, "scrolled", 2, 2, THEME, "scroll-ref", body, width, ch, scroll_y)
        expect(scrolled.pixels.len()).to_equal(width * ch)

        step("Row 0 of the scrolled frame is row `scroll_y` of the reference, not row 0 (parity flips: row 5 is odd)")
        expect(scrolled.pixels[0]).to_equal(BAND_ODD)
        expect(scrolled.pixels[0]).to_equal(full.pixels[scroll_y * width])

        step("Every visible row is a verbatim copy of reference row (scroll_y + row) — full-buffer, not spot-check, translation proof")
        var expected: [u32] = [0u32; width * ch]
        var row = 0
        while row < ch:
            var col = 0
            while col < width:
                expected[row * width + col] = full.pixels[(scroll_y + row) * width + col]
                col = col + 1
            row = row + 1
        expect(scrolled.pixels).to_equal(expected)

    it "leaves the paint untranslated when scroll_y is 0 or negative":
        val width = 6
        val ch = 4
        val body = _row_band_html(ch, width)
        val cache_zero = web_render_pixel_artifact_cache(width, ch, "software")
        val at_zero = simple_web_content_frame_cached(cache_zero, "zero", 1, 1, THEME, "t", body, width, ch, 0)
        val cache_neg = web_render_pixel_artifact_cache(width, ch, "software")
        val at_negative = simple_web_content_frame_cached(cache_neg, "neg", 1, 1, THEME, "t", body, width, ch, -30)

        step("scroll_y <= 0 renders row 0 first (no translation applied)")
        expect(at_zero.pixels[0]).to_equal(BAND_EVEN)
        expect(at_negative.pixels[0]).to_equal(BAND_EVEN)
        expect(at_zero.pixels).to_equal(at_negative.pixels)

    it "caps the enlarged paint height at 4000px regardless of how far scroll_offsets has accumulated":
        val ch = 24
        step("Below the cap, the paint grows by exactly scroll_y")
        expect(content_paint_full_height(ch, 0)).to_equal(ch)
        expect(content_paint_full_height(ch, 500)).to_equal(ch + 500)
        expect(content_paint_full_height(ch, 3999)).to_equal(ch + 3999)

        step("At and beyond 4000px of accumulated wheel delta, the paint height stays clamped, not unbounded")
        expect(content_paint_full_height(ch, 4000)).to_equal(ch + 4000)
        expect(content_paint_full_height(ch, 4001)).to_equal(ch + 4000)
        expect(content_paint_full_height(ch, 250000)).to_equal(ch + 4000)

        step("A negative accumulated offset (should not occur via handle_mouse_wheel's own clamp, but defended here) floors to 0")
        expect(content_paint_full_height(ch, -1)).to_equal(ch)

    it "scrolling past the window's real content renders background, not garbage or a crash":
        val width = 4
        val ch = 6
        val content_rows = 11         # real HTML content is only 11px tall
        val scroll_y = 20             # scrolled well past the real content
        val body = _row_band_html(content_rows, width)

        step("Render scrolled past the live content height at a scroll_y still far under the 4000px cap")
        val cache = web_render_pixel_artifact_cache(width, ch, "software")
        val frame = simple_web_content_frame_cached(cache, "past-content", 1, 1, THEME, "t", body, width, ch, scroll_y)

        step("The frame stays exactly the requested visible size — no truncation, no crash")
        expect(frame.pixels.len()).to_equal(width * ch)

        step("Every visible pixel is the page background (the enlarged viewport's min-height:100vh area beyond the real content)")
        var i = 0
        var all_background = true
        while i < frame.pixels.len():
            if frame.pixels[i] != BG_COLOR:
                all_background = false
            i = i + 1
        expect(all_background).to_equal(true)
