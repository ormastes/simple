"""
# Frame Pacer Contract Specification

**Feature IDs:** #OS-COMPOSITOR
**Category:** Infrastructure
**Difficulty:** 1/5

## Overview

Tests `FramePacer.contract()`, which returns the pacing snapshot as a
struct (target_fps, frame_budget_ms, frame_count, warm_startup_ms,
warm_startup_available) instead of only printing it. `report_contract()`
is a thin wrapper that prints the same values — the struct is now the
source of truth so gate scripts/specs can assert on values directly.
"""

use std.spec.{describe, it, expect, assert_false}
use os.compositor.frame_pacer.{FramePacer}

describe "FramePacer.contract":
    it "reports target_fps and frame_budget_ms for a fresh 60hz pacer":
        val pacer = FramePacer.for_60hz()
        val c = pacer.contract()
        expect(c.target_fps).to_equal(60)
        expect(c.frame_budget_ms).to_equal(16)

    it "reports frame_budget_ms for 30hz":
        val pacer = FramePacer.for_30hz()
        val c = pacer.contract()
        expect(c.target_fps).to_equal(30)
        expect(c.frame_budget_ms).to_equal(33)

    it "reports zero frame_count and unavailable warm_startup before any frame":
        val pacer = FramePacer.for_60hz()
        val c = pacer.contract()
        expect(c.frame_count).to_equal(0)
        assert_false(c.warm_startup_available)

    it "reports frame_count and available warm_startup after a frame completes":
        var pacer = FramePacer.for_60hz()
        pacer.mark_frame_start()
        pacer.mark_frame_end()
        val c = pacer.contract()
        expect(c.frame_count).to_equal(1)
        expect(c.warm_startup_available).to_equal(true)

    it "accumulates frame_count across repeated frames":
        var pacer = FramePacer.for_60hz()
        pacer.mark_frame_start()
        pacer.mark_frame_end()
        pacer.mark_frame_start()
        pacer.mark_frame_end()
        pacer.mark_frame_start()
        pacer.mark_frame_end()
        val c = pacer.contract()
        expect(c.frame_count).to_equal(3)

    it "custom fps target derives frame_budget_ms as 1000/fps":
        val pacer = FramePacer.for_fps(25)
        val c = pacer.contract()
        expect(c.target_fps).to_equal(25)
        expect(c.frame_budget_ms).to_equal(40)
