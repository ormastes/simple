# @cover src/os/compositor/shared_mdi_framebuffer_scene.spl 80%

use std.spec.{describe, it, expect}
use std.io_runtime.{file_read}
use os.compositor.shared_mdi_framebuffer_scene.{SharedMdiFramebufferBackend, draw_shared_mdi_taskbar, render_shared_mdi_framebuffer_scene_limited, render_shared_mdi_framebuffer_scene_for_lifecycle_windows, render_shared_mdi_framebuffer_scene_for_taskbar_render_input, shared_mdi_lifecycle_seed_windows, shared_mdi_seed_windows}
use os.compositor.shared_mdi_setup.{shared_mdi_surfaces}
use os.compositor.wm_action_applier.{wm_taskbar_item_x}
use common.ui.wm_chrome_theme.{wm_chrome_theme}
use common.ui.window_scene.{WM_CHROME_KIND_BORDERLESS, WM_CONTENT_ORIGIN_SIMPLE_WEB, SharedWmRenderInput, SharedWmTaskbarRenderInput, WmContentFrame, WmRenderMetrics, WmSceneRevision, simple_gui_internal_window_scene, simple_gui_internal_window_with_chrome_kind, wm_content_frame_checksum}
use common.ui.taskbar_model.{AppRef, TaskbarModel, TrayItem, WindowRef}

fn _rich_framebuffer_input(valid_checksum: bool) -> SharedWmTaskbarRenderInput:
    val window = simple_gui_internal_window_with_chrome_kind(
        "surface-rich", "window-rich", 7u64, "browser", "Browser",
        20, 20, 100, 70, "", false, true, 0, WM_CHROME_KIND_BORDERLESS
    )
    val scene = simple_gui_internal_window_scene(180, 160, "unit-rich-framebuffer", [window])
    val revision = WmSceneRevision(scene_revision: 9, input_revision: 10, taskbar_revision: 11)
    val pixels: [u32] = [0xFF123456u32; 7000]
    val checksum = if valid_checksum: wm_content_frame_checksum(pixels) else: 0u64
    val frame = WmContentFrame(window_id: "window-rich", scene_revision: 9, content_revision: 2, origin_kind: WM_CONTENT_ORIGIN_SIMPLE_WEB, width: 100, height: 70, pixels: pixels, checksum: checksum, parent_window_id: "", offset_x: 0, offset_y: 0)
    val metrics = WmRenderMetrics(scale_milli: 1000, top_lane_height: 44, titlebar_height: 28, taskbar_height: 56, min_hit_target: 56)
    val render = SharedWmRenderInput(scene: scene, revision: revision, content_frames: [frame], metrics: metrics, t_micros: 0)
    val taskbar = TaskbarModel(
        pinned: [AppRef(app_id: "editor", display_name: "Editor", icon: "E")],
        running: [WindowRef(window_id: "window-rich", app_id: "browser", title: "Browser", minimized: false)],
        tray: [TrayItem(item_id: "network", label: "Online", icon: "N")]
    )
    SharedWmTaskbarRenderInput(render: render, taskbar: taskbar, clock_label: "12:34")

describe "shared MDI framebuffer scene":

    it "renders validated Simple Web pixels and authoritative taskbar objects through the rich framebuffer entry":
        val scene = render_shared_mdi_framebuffer_scene_for_taskbar_render_input(_rich_framebuffer_input(true))
        expect(scene.web_pixel_count).to_equal(7000)
        expect(scene.pixels[20 * 180 + 20]).to_equal(0xFF123456u32)
        expect(scene.fallback_reason).to_equal("")
        expect(scene.readback_status).to_equal("verified:cpu-framebuffer-mirror")

    it "bounds rich taskbar labels to their object slots":
        val scene = render_shared_mdi_framebuffer_scene_for_taskbar_render_input(_rich_framebuffer_input(true))
        expect(scene.pixels.len()).to_equal(180 * 160)
        expect(scene.fallback_reason).to_equal("")

    it "fails closed and reports rejected rich content instead of canned pixels":
        val scene = render_shared_mdi_framebuffer_scene_for_taskbar_render_input(_rich_framebuffer_input(false))
        expect(scene.web_pixel_count).to_equal(0)
        expect(scene.pixels[20 * 180 + 20]).to_equal(0xFFFF00FFu32)
        expect(scene.fallback_reason).to_equal("rejected-invalid-simple-web-content-frame")
        expect(scene.readback_status).to_equal("verified:cpu-framebuffer-mirror")

    it "uses the canonical five MDI surfaces for QEMU framebuffer lanes":
        val surfaces = shared_mdi_surfaces()
        expect(surfaces.len()).to_equal(5)
        expect(surfaces[0].title).to_equal("Terminal")
        expect(surfaces[2].title).to_equal("Browser")
        expect(surfaces[4].title).to_equal("Calculator")

    it "bulk-blits WebRender artifact pixels into the framebuffer mirror":
        val backend = SharedMdiFramebufferBackend.create(8, 6, 0xFF000000u32)
        val pixels: [u32] = [
            0xFF112233u32, 0xFF445566u32,
            0xFF778899u32, 0xFF99AABBu32
        ]
        backend.blit_pixels(2, 1, 2, 2, pixels)
        expect(backend.web_pixel_count).to_equal(4)
        expect(backend.pixels[1 * 8 + 2]).to_equal(0xFF112233u32)
        expect(backend.pixels[2 * 8 + 3]).to_equal(0xFF99AABBu32)

    it "renders visible chrome text and taskbar pixels from the shared renderer":
        val scene = render_shared_mdi_framebuffer_scene_limited(320, 240, "unit-shared", 180, 110)
        expect(scene.surface_count).to_equal(5)
        expect(scene.web_pixel_count).to_be_greater_than(0)
        var white_pixels = 0
        var accent_pixels = 0
        var i = 0
        while i < scene.pixels.len():
            if scene.pixels[i] == 0xFFFFFFFFu32:
                white_pixels = white_pixels + 1
            if scene.pixels[i] == 0xFF2563EBu32:
                accent_pixels = accent_pixels + 1
            i = i + 1
        expect(white_pixels).to_be_greater_than(0)
        expect(accent_pixels).to_be_greater_than(0)

    it "draws taskbar item bodies instead of only the taskbar band":
        val theme = wm_chrome_theme()
        val backend = SharedMdiFramebufferBackend.create(320, 240, theme.compositor_bg)
        val windows = shared_mdi_seed_windows()
        draw_shared_mdi_taskbar(backend, windows, 320, 240, theme)
        val first_item_x = wm_taskbar_item_x(320, 5, 0) + 10
        val focused_item_x = wm_taskbar_item_x(320, 5, 4) + 10
        val item_y = 196
        expect(backend.pixels[item_y * 320 + first_item_x]).to_equal(theme.title_unfocused)
        expect(backend.pixels[item_y * 320 + focused_item_x]).to_equal(theme.accent)

    it "keeps the x86_64 QEMU entry on the shared renderer instead of a dummy rectangle scene":
        val src = file_read("examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d.spl")
        expect(src).to_contain("render_shared_mdi_framebuffer_scene")
        expect(src).to_contain("wm_lifecycle_pointer_move")
        expect(src).to_contain("qemu-shared-pointer-event source=wm_lifecycle_pointer_move")
        expect(src).to_contain("source=shared_mdi_framebuffer_scene")
        expect(src).to_contain("renderer=shared_mdi_framebuffer_scene")
        expect(src).to_contain("present=direct-mmio-commit source=shared_mdi_framebuffer_scene")
        expect(src).to_contain("html-renderable window=browser renderer=shared_mdi_framebuffer_scene")
        expect(src).to_contain("_poll_qemu_mouse_input")
        expect(src).to_contain("qemu-mouse-packet left=1")
        expect(src.contains("simple-web-qemu-panel-contract")).to_equal(false)
        expect(src.contains("baremetal-direct-mdi-surface-render")).to_equal(false)

    it "renders lifecycle-mutated windows through the same shared framebuffer renderer":
        var windows = shared_mdi_lifecycle_seed_windows()
        var editor = windows[1]
        editor.x = 76
        editor.y = 68
        editor.focused = true
        windows[1] = editor
        val scene = render_shared_mdi_framebuffer_scene_for_lifecycle_windows(320, 240, "unit-shared-lifecycle", windows)
        expect(scene.surface_count).to_equal(5)
        expect(scene.web_pixel_count).to_be_greater_than(0)
        expect(scene.pixels.len()).to_equal(320 * 240)

    it "routes internal-window rendering through the Simple GUI scene contract":
        val src = file_read("src/os/compositor/shared_mdi_framebuffer_scene.spl")
        expect(src).to_contain("simple_gui_internal_window(")
        expect(src).to_contain("simple_gui_internal_window_scene(")
        expect(src).to_contain("render_shared_mdi_framebuffer_scene_for_simple_gui_scene")
        expect(src).to_contain("_shared_mdi_scene_from_render_windows")
