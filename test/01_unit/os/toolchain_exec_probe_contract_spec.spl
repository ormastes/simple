use std.spec.{describe, it, expect}
use os.toolchain_exec_probe_contract.{
    toolchain_exec_probe_ok_marker_fragments,
    toolchain_exec_probe_blocked_marker_fragments,
    toolchain_exec_probe_serial_accepts_completion,
    toolchain_exec_probe_serial_is_blocked
}

fn exec_probe_ok_serial() -> text:
    toolchain_exec_probe_ok_marker_fragments().join("\n")

fn exec_probe_blocked_serial() -> text:
    toolchain_exec_probe_blocked_marker_fragments().join("\n")

# status=fail (exec live, clang absent) must NOT be accepted and is NOT blocked.
fn exec_probe_fail_serial() -> text:
    ["[toolchain-exec] storage-ready", "[toolchain-exec] compiler-ran app=clang status=fail reason=clang-payload-absent", "TEST FAILED"].join("\n")

# spawn:image + spawn:prepared markers exist today with NO live handoff.
fn exec_probe_pid_only_serial() -> text:
    ["[toolchain-exec] storage-ready", "[fs-exec] spawn:image path=/sys/apps/clang entry=0 segments=1 stub_bytes=274 argv_count=4 env_count=0 pid=1", "[fs-exec] spawn:prepared path=/sys/apps/clang pid=1 entry=0"].join("\n")

describe "toolchain EXEC probe completion contract":
    it "accepts only the real compile-artifact ok terminal":
        expect(toolchain_exec_probe_serial_accepts_completion(exec_probe_ok_serial())).to_equal(true)

    it "rejects the blocked until-Phase-1 terminal as a pass":
        expect(toolchain_exec_probe_serial_accepts_completion(exec_probe_blocked_serial())).to_equal(false)

    it "recognizes the blocked terminal distinctly from broken":
        expect(toolchain_exec_probe_serial_is_blocked(exec_probe_blocked_serial())).to_equal(true)

    it "does not treat the ok terminal as blocked":
        expect(toolchain_exec_probe_serial_is_blocked(exec_probe_ok_serial())).to_equal(false)

    it "rejects a status fail terminal as a pass":
        expect(toolchain_exec_probe_serial_accepts_completion(exec_probe_fail_serial())).to_equal(false)

    it "does not call a status fail terminal blocked":
        expect(toolchain_exec_probe_serial_is_blocked(exec_probe_fail_serial())).to_equal(false)

    it "never accepts a spawn pid marker alone as compiler operation":
        expect(toolchain_exec_probe_serial_accepts_completion(exec_probe_pid_only_serial())).to_equal(false)
