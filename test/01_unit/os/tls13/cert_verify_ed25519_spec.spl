# cert_verify Ed25519 CertificateVerify path spec
#
# Exercises the Ed25519 (sig_scheme 0x0807) path in:
#   - verify_certificate_verify_msg_scheme (happy path, wrong key, corrupted sig)
#   - verify_certificate_verify_msg (shim — confirms delegation to 0x0807)
#
# Key derivation:
#   Uses ed25519_keypair_from_seed with a fixed 32-byte seed so tests are
#   fully deterministic without needing a DER X.509 cert fixture.
#
# Module-level fn helpers are used for all fixtures to avoid the
# it-block var-mutation footgun (interpreter mode doesn't persist
# var rebindings across while-loop iterations).
#
# Reference: RFC 8446 §4.2.3, §4.4.3
# Reference: RFC 8410 (Ed25519 in X.509, OID 1.3.101.112)

use std.spipe.*
use os.tls13.cert_verify.{
    verify_certificate_verify_msg,
    verify_certificate_verify_msg_scheme,
    CertVerifyResult
}
use os.crypto.ed25519.{
    ed25519_keypair_from_seed,
    ed25519_sign
}

# ============================================================================
# Key material — deterministic from fixed seeds
# ============================================================================

fn _seed_a() -> [u8]:
    # 32-byte fixed seed A
    [0x01u8, 0x02u8, 0x03u8, 0x04u8, 0x05u8, 0x06u8, 0x07u8, 0x08u8,
     0x09u8, 0x0au8, 0x0bu8, 0x0cu8, 0x0du8, 0x0eu8, 0x0fu8, 0x10u8,
     0x11u8, 0x12u8, 0x13u8, 0x14u8, 0x15u8, 0x16u8, 0x17u8, 0x18u8,
     0x19u8, 0x1au8, 0x1bu8, 0x1cu8, 0x1du8, 0x1eu8, 0x1fu8, 0x20u8]

fn _seed_b() -> [u8]:
    # 32-byte fixed seed B (different key — used for wrong-key negative test)
    [0xa1u8, 0xa2u8, 0xa3u8, 0xa4u8, 0xa5u8, 0xa6u8, 0xa7u8, 0xa8u8,
     0xa9u8, 0xaau8, 0xabu8, 0xacu8, 0xadu8, 0xaeu8, 0xafu8, 0xb0u8,
     0xb1u8, 0xb2u8, 0xb3u8, 0xb4u8, 0xb5u8, 0xb6u8, 0xb7u8, 0xb8u8,
     0xb9u8, 0xbau8, 0xbbu8, 0xbcu8, 0xbdu8, 0xbeu8, 0xbfu8, 0xc0u8]

fn _pubkey_a() -> [u8]:
    val (_, pubkey) = ed25519_keypair_from_seed(_seed_a())
    pubkey

fn _pubkey_b() -> [u8]:
    val (_, pubkey) = ed25519_keypair_from_seed(_seed_b())
    pubkey

fn _transcript_hash() -> [u8]:
    # 32-byte synthetic transcript hash (SHA-256 sized)
    [0xdeu8, 0xadu8, 0xbeu8, 0xefu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8,
     0xdeu8, 0xadu8, 0xbeu8, 0xefu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8,
     0xdeu8, 0xadu8, 0xbeu8, 0xefu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8,
     0xdeu8, 0xadu8, 0xbeu8, 0xefu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8]

# Build the RFC 8446 §4.4.3 content buffer:
#   64 x 0x20 || "TLS 1.3, server CertificateVerify" || 0x00 || transcript_hash
fn _build_content(transcript_hash: [u8]) -> [u8]:
    var content: [u8] = []
    var i: u64 = 0
    while i < 64:
        content.push(0x20u8)
        i = i + 1
    content.push(0x54u8)  # T
    content.push(0x4cu8)  # L
    content.push(0x53u8)  # S
    content.push(0x20u8)  # (space)
    content.push(0x31u8)  # 1
    content.push(0x2eu8)  # .
    content.push(0x33u8)  # 3
    content.push(0x2cu8)  # ,
    content.push(0x20u8)  # (space)
    content.push(0x73u8)  # s
    content.push(0x65u8)  # e
    content.push(0x72u8)  # r
    content.push(0x76u8)  # v
    content.push(0x65u8)  # e
    content.push(0x72u8)  # r
    content.push(0x20u8)  # (space)
    content.push(0x43u8)  # C
    content.push(0x65u8)  # e
    content.push(0x72u8)  # r
    content.push(0x74u8)  # t
    content.push(0x69u8)  # i
    content.push(0x66u8)  # f
    content.push(0x69u8)  # i
    content.push(0x63u8)  # c
    content.push(0x61u8)  # a
    content.push(0x74u8)  # t
    content.push(0x65u8)  # e
    content.push(0x56u8)  # V
    content.push(0x65u8)  # e
    content.push(0x72u8)  # r
    content.push(0x69u8)  # i
    content.push(0x66u8)  # f
    content.push(0x79u8)  # y
    content.push(0x00u8)  # separator
    i = 0
    while i < transcript_hash.len():
        content.push(transcript_hash[i])
        i = i + 1
    content

fn _sign_content() -> [u8]:
    val (privkey, pubkey) = ed25519_keypair_from_seed(_seed_a())
    val content = _build_content(_transcript_hash())
    ed25519_sign(privkey, pubkey, content)

fn _flip_byte_at(bytes: [u8], idx: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < bytes.len():
        if i == idx:
            out.push((bytes[i].to_i64() ^ 0x01).to_u8())
        else:
            out.push(bytes[i])
        i = i + 1
    out

# ============================================================================
# verify_certificate_verify_msg_scheme — Ed25519 (0x0807)
# ============================================================================

describe "verify_certificate_verify_msg_scheme Ed25519 (0x0807)":

    it "verifies a valid Ed25519 CertificateVerify message":
        val pubkey = _pubkey_a()
        val sig = _sign_content()
        val result = verify_certificate_verify_msg_scheme(pubkey, 0x0807u16, _transcript_hash(), sig)
        if val CertVerifyResult.Ok = result:
            expect(pubkey.len()).to_equal(32u64)
            expect(sig.len()).to_equal(64u64)
        else:
            expect(false).to_equal(true)

    it "rejects signature verified under a different public key":
        val other_pubkey = _pubkey_b()
        val sig = _sign_content()
        val result = verify_certificate_verify_msg_scheme(other_pubkey, 0x0807u16, _transcript_hash(), sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect(other_pubkey.len()).to_equal(32u64)
            expect(err_msg.len()).to_be_greater_than(40u64)
            expect(err_msg == "unsupported signature scheme").to_equal(false)
        else:
            expect(false).to_equal(true)

    it "rejects a signature with a flipped byte":
        val pubkey = _pubkey_a()
        val sig = _sign_content()
        val bad_sig = _flip_byte_at(sig, 4u64)
        val result = verify_certificate_verify_msg_scheme(pubkey, 0x0807u16, _transcript_hash(), bad_sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect(bad_sig.len()).to_equal(64u64)
            expect(err_msg.len()).to_be_greater_than(40u64)
            expect(err_msg == "unsupported signature scheme").to_equal(false)
        else:
            expect(false).to_equal(true)

    it "rejects an unknown sig_scheme":
        val pubkey = _pubkey_a()
        val sig = _sign_content()
        val result = verify_certificate_verify_msg_scheme(pubkey, 0x0000u16, _transcript_hash(), sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect(err_msg).to_equal("unsupported signature scheme")
        else:
            expect(false).to_equal(true)

# ============================================================================
# verify_certificate_verify_msg — shim (delegates to 0x0807)
# ============================================================================

describe "verify_certificate_verify_msg shim":

    it "delegates to Ed25519 and accepts a valid signature":
        val pubkey = _pubkey_a()
        val sig = _sign_content()
        val result = verify_certificate_verify_msg(pubkey, _transcript_hash(), sig)
        if val CertVerifyResult.Ok = result:
            expect(pubkey.len()).to_equal(32u64)
            expect(sig.len()).to_equal(64u64)
        else:
            expect(false).to_equal(true)

    it "delegates to Ed25519 and rejects a bad signature":
        val pubkey = _pubkey_a()
        val sig = _sign_content()
        val bad_sig = _flip_byte_at(sig, 0u64)
        val result = verify_certificate_verify_msg(pubkey, _transcript_hash(), bad_sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect(bad_sig.len()).to_equal(64u64)
            expect(err_msg.len()).to_be_greater_than(40u64)
            expect(err_msg == "unsupported signature scheme").to_equal(false)
        else:
            expect(false).to_equal(true)
