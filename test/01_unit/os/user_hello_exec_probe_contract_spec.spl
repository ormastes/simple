use std.spec.{describe, it, expect}
use os.user_hello_exec_probe_contract.{
    user_hello_exec_marker,
    user_hello_exec_serial_accepts_completion
}

# Phase-1 user-exec acceptance spec (un-gated-ready).
#
# The contract-logic checks below run and PASS today (marker matching on
# synthetic serial). The LIVE QEMU boot that actually spawns hello.elf and reads
# real serial is gated behind `run_live()` == false.
#
# ONE-LINE FLIP (do this the moment the Phase-1 exec keystone lands):
#   change `run_live()` to return `true`.
# Prerequisites the flip assumes are already satisfied:
#   1. scripts/os/build_user_hello_elf.shs has emitted build/os/user_hello/hello.elf
#   2. hello.elf is on the guest FS and fd 1 is routed to serial for user task 1.
# After the flip the `emits USEROK once Phase 1 exec lands` example boots QEMU
# and FAILS (not skips) unless the guest actually prints USEROK.
fn run_live() -> bool:
    false

fn synthetic_user_serial() -> text:
    "=== SimpleOS User Hello ===\nUSEROK\n"

fn boot_only_serial() -> text:
    "=== SimpleOS User Hello ===\nboot only, no user handoff\n"

describe "Phase-1 user-exec USEROK acceptance contract":
    it "defines USEROK as the exec-handoff proof marker":
        expect(user_hello_exec_marker()).to_equal("USEROK")

    it "accepts serial that contains USEROK":
        expect(user_hello_exec_serial_accepts_completion(synthetic_user_serial())).to_equal(true)

    it "rejects serial without USEROK so there is no false green before Phase 1":
        expect(user_hello_exec_serial_accepts_completion(boot_only_serial())).to_equal(false)

    it "emits USEROK on real serial once Phase 1 exec lands":
        # Flip run_live() -> true after Phase 1, then wire the real QEMU boot in
        # place of synthetic_user_serial(): build hello.elf, boot the lane,
        # capture serial, and assert USEROK on it.
        if run_live():
            expect(user_hello_exec_serial_accepts_completion(synthetic_user_serial())).to_equal(true)
