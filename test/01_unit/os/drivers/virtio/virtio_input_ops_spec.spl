"""
# VirtIO-Input Event Translation Specification

**Feature IDs:** #OS-VIRTIO-INPUT
**Category:** Infrastructure
**Difficulty:** 3/5

## Overview

Tests the pure evdev -> internal-event translation layer that lets a
virtio-input device emit the SAME `Key`/`KeyEvent`/`MouseEvent` types the
PS/2 drivers produce: the KEY_* -> Key table, press/release/repeat
handling, and the REL/BTN/SYN mouse accumulator (buffering a frame until
SYN_REPORT, edge-triggered buttons, screen-bounds clamping).
"""

use std.spec.*
use os.drivers.input.ps2_keyboard.{Key, KeyEvent}
use os.drivers.virtio.virtio_input_ops.{
    evdev_key_to_key, virtio_input_key_event, virtio_input_key_is_modifier_code,
    VirtioMouseAccum,
    KEY_ESC, KEY_A, KEY_Z, KEY_0, KEY_9, KEY_ENTER, KEY_BACKSPACE, KEY_TAB,
    KEY_SPACE, KEY_UP, KEY_DOWN, KEY_LEFT, KEY_RIGHT,
    KEY_LEFTSHIFT, KEY_RIGHTSHIFT, KEY_LEFTCTRL, KEY_LEFTALT,
    REL_X, REL_Y, REL_WHEEL, BTN_LEFT, BTN_RIGHT, BTN_MIDDLE
}

# ============================================================================
# Test Group 1: evdev KEY_* -> Key table
# ============================================================================

describe "evdev_key_to_key":
    it "maps KEY_ESC to Key.Escape":
        expect(evdev_key_to_key(KEY_ESC)).to_equal(Key.Escape)

    it "maps KEY_A through KEY_Z to the matching letter keys":
        expect(evdev_key_to_key(KEY_A)).to_equal(Key.A)
        expect(evdev_key_to_key(KEY_Z)).to_equal(Key.Z)

    it "maps KEY_0/KEY_9 to Num0/Num9":
        expect(evdev_key_to_key(KEY_0)).to_equal(Key.Num0)
        expect(evdev_key_to_key(KEY_9)).to_equal(Key.Num9)

    it "maps KEY_ENTER/KEY_BACKSPACE/KEY_TAB/KEY_SPACE":
        expect(evdev_key_to_key(KEY_ENTER)).to_equal(Key.Enter)
        expect(evdev_key_to_key(KEY_BACKSPACE)).to_equal(Key.Backspace)
        expect(evdev_key_to_key(KEY_TAB)).to_equal(Key.Tab)
        expect(evdev_key_to_key(KEY_SPACE)).to_equal(Key.Space)

    it "maps arrow keys":
        expect(evdev_key_to_key(KEY_UP)).to_equal(Key.Up)
        expect(evdev_key_to_key(KEY_DOWN)).to_equal(Key.Down)
        expect(evdev_key_to_key(KEY_LEFT)).to_equal(Key.Left)
        expect(evdev_key_to_key(KEY_RIGHT)).to_equal(Key.Right)

    it "maps shift/ctrl/alt modifier keys":
        expect(evdev_key_to_key(KEY_LEFTSHIFT)).to_equal(Key.LeftShift)
        expect(evdev_key_to_key(KEY_RIGHTSHIFT)).to_equal(Key.RightShift)
        expect(evdev_key_to_key(KEY_LEFTCTRL)).to_equal(Key.LeftCtrl)
        expect(evdev_key_to_key(KEY_LEFTALT)).to_equal(Key.LeftAlt)

    it "maps an unrecognized code to Key.Unknown":
        expect(evdev_key_to_key(9999)).to_equal(Key.Unknown)

# ============================================================================
# Test Group 2: EV_KEY (code, value) -> KeyEvent
# ============================================================================

describe "virtio_input_key_event":
    it "value=1 (press) produces KeyEvent.Press":
        val ev = virtio_input_key_event(KEY_A, 1)
        expect(ev).to_equal(KeyEvent.Press(key: Key.A))

    it "value=0 (release) produces KeyEvent.Release":
        val ev = virtio_input_key_event(KEY_A, 0)
        expect(ev).to_equal(KeyEvent.Release(key: Key.A))

    it "value=2 (autorepeat) produces another KeyEvent.Press":
        val ev = virtio_input_key_event(KEY_A, 2)
        expect(ev).to_equal(KeyEvent.Press(key: Key.A))

    it "unmapped code still produces a Press/Release event carrying Key.Unknown":
        val ev = virtio_input_key_event(9999, 1)
        expect(ev).to_equal(KeyEvent.Press(key: Key.Unknown))

describe "virtio_input_key_is_modifier_code":
    it "is true for left/right shift, ctrl, and alt, false for a plain letter key":
        expect(virtio_input_key_is_modifier_code(KEY_LEFTSHIFT)).to_equal(true)
        expect(virtio_input_key_is_modifier_code(KEY_RIGHTSHIFT)).to_equal(true)
        expect(virtio_input_key_is_modifier_code(KEY_LEFTCTRL)).to_equal(true)
        expect(virtio_input_key_is_modifier_code(KEY_LEFTALT)).to_equal(true)
        assert_false(virtio_input_key_is_modifier_code(KEY_A))

# ============================================================================
# Test Group 3: VirtioMouseAccum — REL/BTN buffering until SYN_REPORT
# ============================================================================

describe "VirtioMouseAccum":
    it "starts centered on the given screen dimensions":
        val m = VirtioMouseAccum.create(800, 600)
        expect(m.x).to_equal(400)
        expect(m.y).to_equal(300)

    it "buffers REL_X/REL_Y until feed_syn, then reports the accumulated delta":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_rel(REL_X, 5)
        m.feed_rel(REL_Y, -3)
        m.feed_rel(REL_X, 2)
        val ev = m.feed_syn()
        expect(ev.dx).to_equal(7)
        expect(ev.dy).to_equal(-3)
        expect(ev.x).to_equal(407)
        expect(ev.y).to_equal(297)

    it "resets pending deltas after feed_syn (next frame starts at zero)":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_rel(REL_X, 10)
        val _first = m.feed_syn()
        val second = m.feed_syn()
        expect(second.dx).to_equal(0)
        expect(second.dy).to_equal(0)

    it "clamps position to screen bounds":
        var m = VirtioMouseAccum.create(10, 10)
        m.feed_rel(REL_X, -100)
        m.feed_rel(REL_Y, 100)
        val ev = m.feed_syn()
        expect(ev.x).to_equal(0)
        expect(ev.y).to_equal(9)

    it "tracks BTN_LEFT press/release and reports edge-triggered transitions":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_key(BTN_LEFT, true)
        val pressed = m.feed_syn()
        expect(pressed.left_pressed).to_equal(true)
        expect(pressed.left_just_pressed).to_equal(true)

        val held = m.feed_syn()
        expect(held.left_pressed).to_equal(true)
        assert_false(held.left_just_pressed)

        m.feed_key(BTN_LEFT, false)
        val released = m.feed_syn()
        assert_false(released.left_pressed)
        expect(released.left_just_released).to_equal(true)

    it "tracks BTN_RIGHT and BTN_MIDDLE independently of BTN_LEFT":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_key(BTN_RIGHT, true)
        m.feed_key(BTN_MIDDLE, true)
        val ev = m.feed_syn()
        expect(ev.right_pressed).to_equal(true)
        expect(ev.middle_pressed).to_equal(true)
        assert_false(ev.left_pressed)

    it "ignores an unrecognized REL code":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_rel(99, 42)
        val ev = m.feed_syn()
        expect(ev.dx).to_equal(0)
        expect(ev.dy).to_equal(0)

    it "ignores an unrecognized BTN code":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_key(9999, true)
        val ev = m.feed_syn()
        expect(ev.dx).to_equal(0)
        assert_false(ev.left_pressed)
        assert_false(ev.right_pressed)
        assert_false(ev.middle_pressed)

    it "buffers REL_WHEEL scroll and resets it on feed_syn":
        var m = VirtioMouseAccum.create(800, 600)
        m.feed_rel(REL_WHEEL, 3)
        expect(m.pending_scroll).to_equal(3)
        val _ev = m.feed_syn()
        expect(m.pending_scroll).to_equal(0)
