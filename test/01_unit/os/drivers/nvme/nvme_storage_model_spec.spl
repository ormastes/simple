"""
# NVMe Storage Model Specification

**Feature IDs:** #OS-STORAGE-NVME-CAPS
**Category:** Runtime
**Difficulty:** 3/5
**Status:** Draft contract

BDD coverage for the multi-namespace NVMe queue policy constants and data-only
contracts used by capability-backed storage.
"""

use std.spec.{describe, it, expect}
use os.drivers.nvme.nvme_storage_model.{NvmeQueueRole, NvmeNamespaceMode, NvmeFilesystemConsumer, NvmeNamespaceIdentity, NvmePartitionIdentity, NvmeQueueAssignment, nvme_queue_role_for_id, nvme_queue_is_system_reserved, nvme_first_data_queue_id, nvme_transfer_evidence, nvme_transfer_readiness_reason, nvme_transfer_ready, nvme_filesystem_lease, nvme_filesystem_lease_from_transfer_evidence, nvme_filesystem_lease_reason, nvme_filesystem_lease_ready, nvme_filesystem_consumer_name, nvme_namespace_mode_name, nvme_shared_filesystem_interface, nvme_shared_filesystem_interface_reason, nvme_shared_filesystem_interface_consumers, nvme_shared_filesystem_interface_acceptance_reason, nvme_filesystem_lease_sector_size, nvme_filesystem_lease_sector_count, nvme_filesystem_lease_absolute_lba, nvme_filesystem_lease_conflict_reason, nvme_filesystem_lease_set_acceptance_reason, nvme_filesystem_lease_same_assignment}
use os.kernel.types.capability_types.{CAP_RIGHT_READ, CAP_RIGHT_WRITE, CAP_RIGHT_QUEUE_SUBMIT, SIMPLEOS_NVME_ADMIN_QUEUE_ID, SIMPLEOS_NVME_SYSTEM_QUEUE_ID, SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID}
use os.kernel.types.device_mem_types.{DeviceGrant, device_grant_token_base, device_grant_bar_token, device_grant_irq_token, device_grant_dma_token, device_grant_iommu_token, device_grant_iommu_domain_id, device_grant_resource_set_label, device_grant_is_isolated}

describe "NVMe storage model":
    describe "queue role policy":
        it "reserves queue 0 for admin commands":
            val role = nvme_queue_role_for_id(SIMPLEOS_NVME_ADMIN_QUEUE_ID)
            val is_admin = match role:
                NvmeQueueRole.Admin: true
                _: false
            expect(is_admin).to_equal(true)

        it "reserves queue 1 for system I/O":
            val role = nvme_queue_role_for_id(SIMPLEOS_NVME_SYSTEM_QUEUE_ID)
            val is_system = match role:
                NvmeQueueRole.System: true
                _: false
            expect(is_system).to_equal(true)

        it "uses queue 2 and above for data traffic":
            val role = nvme_queue_role_for_id(SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID)
            val is_data = match role:
                NvmeQueueRole.Data: true
                _: false
            expect(is_data).to_equal(true)

        it "marks admin and system queues as reserved":
            expect(nvme_queue_is_system_reserved(SIMPLEOS_NVME_ADMIN_QUEUE_ID)).to_equal(true)
            expect(nvme_queue_is_system_reserved(SIMPLEOS_NVME_SYSTEM_QUEUE_ID)).to_equal(true)
            expect(nvme_queue_is_system_reserved(SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID)).to_equal(false)

        it "publishes the first data queue id":
            expect(nvme_first_data_queue_id()).to_equal(2)

    describe "namespace and partition identities":
        it "stores namespace identity separately from partition identity":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 2,
                lba_size: 4096,
                lba_count: 1024,
                eui64: 0,
                nguid_lo: 11,
                nguid_hi: 12,
                uuid_lo: 21,
                uuid_hi: 22
            )
            val part = NvmePartitionIdentity(
                controller_id: 0,
                nsid: 2,
                part_index: 1,
                base_lba: 128,
                lba_count: 256,
                type_guid_lo: 31,
                type_guid_hi: 32,
                unique_guid_lo: 41,
                unique_guid_hi: 42
            )
            expect(ns.nsid).to_equal(part.nsid)
            expect(part.base_lba).to_equal(128)

        it "stores queue assignment owner, depth, and rights":
            val assignment = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 1,
                owner_task: 99,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            expect(assignment.queue_id).to_equal(2)
            expect(assignment.owner_task).to_equal(99)

    describe "filesystem namespace leases":
        it "names all filesystem consumers and namespace modes":
            expect(nvme_filesystem_consumer_name(NvmeFilesystemConsumer.Fat32)).to_equal("fat32")
            expect(nvme_filesystem_consumer_name(NvmeFilesystemConsumer.Nvfs)).to_equal("nvfs")
            expect(nvme_filesystem_consumer_name(NvmeFilesystemConsumer.Dbfs)).to_equal("dbfs")
            expect(nvme_namespace_mode_name(NvmeNamespaceMode.System)).to_equal("system")
            expect(nvme_namespace_mode_name(NvmeNamespaceMode.UserAssigned)).to_equal("user-assigned")

        it "allows FAT32 NVFS and DBFS to share a system namespace lease through the system queue":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 1,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 1,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 0u64, 2048u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", true, true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Fat32)).to_equal(true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Nvfs)).to_equal(true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Dbfs)).to_equal(true)

            val wrong_role = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 1,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val wrong_role_lease = nvme_filesystem_lease(ns, 0u64, 2048u64, NvmeNamespaceMode.System, wrong_role, "simple-driver", "none", true, true)
            expect(nvme_filesystem_lease_reason(wrong_role_lease, NvmeFilesystemConsumer.Fat32)).to_equal("nvme-fs-system-namespace-not-system-queue-role")

        it "mints one shared interface proof for FAT32 NVFS and DBFS on the same lease":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 7,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 7,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 0u64, 4096u64, NvmeNamespaceMode.System, queue, "simple-driver", "kernel-owned-resource", true, true)
            val iface = nvme_shared_filesystem_interface(lease)

            expect(nvme_shared_filesystem_interface_reason(lease)).to_equal("ready")
            expect(nvme_shared_filesystem_interface_consumers()).to_equal("fat32,nvfs,dbfs")
            expect(iface.is_ok()).to_equal(true)
            expect(iface.unwrap().provider).to_equal("simple-driver")
            expect(iface.unwrap().queue_id).to_equal(SIMPLEOS_NVME_SYSTEM_QUEUE_ID)
            expect(iface.unwrap().fat32_ready).to_equal(true)
            expect(iface.unwrap().nvfs_ready).to_equal(true)
            expect(iface.unwrap().dbfs_ready).to_equal(true)

        it "rejects shared interface admission when a user lease conflicts with a system namespace":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 8,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val system_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 8,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val data_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 8,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val system_lease = nvme_filesystem_lease(ns, 0u64, 8192u64, NvmeNamespaceMode.System, system_queue, "simple-driver", "kernel-owned-resource", true, true)
            val user_lease = nvme_filesystem_lease(ns, 0u64, 8192u64, NvmeNamespaceMode.UserAssigned, data_queue, "simple-driver", "resource-grant-set:tok=42", true, true)

            expect(nvme_shared_filesystem_interface_acceptance_reason([system_lease], user_lease)).to_equal("nvme-fs-namespace-mode-conflict:system:user-assigned")

        it "requires user-assigned namespaces to use data queues and issued user-space grants":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 2,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val system_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 2,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val data_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 2,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val wrong_role_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 2,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val bad_queue = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, system_queue, "simple-driver", "resource-grant-set:tok=99", true, true)
            val wrong_role = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, wrong_role_queue, "simple-driver", "resource-grant-set:tok=99", true, true)
            val missing_token = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, data_queue, "simple-driver", "resource-grant-set", true, true)
            val ready = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, data_queue, "simple-driver", "resource-grant-set:tok=100", true, true)
            expect(nvme_filesystem_lease_reason(bad_queue, NvmeFilesystemConsumer.Nvfs)).to_equal("nvme-fs-user-namespace-uses-reserved-queue")
            expect(nvme_filesystem_lease_reason(wrong_role, NvmeFilesystemConsumer.Nvfs)).to_equal("ready")
            expect(nvme_filesystem_lease_reason(missing_token, NvmeFilesystemConsumer.Dbfs)).to_contain("missing-issued-device-grant-token")
            expect(nvme_filesystem_lease_ready(ready, NvmeFilesystemConsumer.Fat32)).to_equal(true)

        it "accepts user-assigned namespaces with tokenized DeviceGrant metadata":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 5,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 5,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val base = device_grant_token_base(0u8, 4u8, 0u8, 42u64)
            val grant = DeviceGrant(
                pci_vendor: 0x1B36u16,
                pci_device: 0x5845u16,
                pci_bus: 0u8,
                pci_dev: 4u8,
                pci_func: 0u8,
                pci_class: 1u8,
                pci_subclass: 8u8,
                bar0_phys: 0xFEB90000u64,
                bar0_size: 0x1000u64,
                bar0_cap: device_grant_bar_token(base),
                irq_vector: 43u32,
                irq_notification_id: 1u64,
                irq_notification_bit: 1u64,
                irq_cap: device_grant_irq_token(base),
                dma_device_addr: 0u64,
                dma_host_addr: 0u64,
                dma_size: 0u64,
                dma_cap: device_grant_dma_token(base),
                iommu_domain_id: device_grant_iommu_domain_id(0u8, 4u8, 0u8),
                iommu_cap: device_grant_iommu_token(base)
            )
            val lease = nvme_filesystem_lease(
                ns,
                128u64,
                1024u64,
                NvmeNamespaceMode.UserAssigned,
                queue,
                "simple-driver",
                device_grant_resource_set_label(grant),
                true,
                device_grant_is_isolated(grant)
            )
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Fat32)).to_equal(true)

        it "rejects filesystem leases that do not expose the shared block interface":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 3,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 3,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 0u64, 512u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", false, true)
            expect(nvme_filesystem_lease_reason(lease, NvmeFilesystemConsumer.Fat32)).to_equal("nvme-fs-lease-missing-shared-block-interface")

        it "requires read write and queue-submit rights on filesystem leases":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 6,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val missing_write = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 6,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 0u64, 512u64, NvmeNamespaceMode.System, missing_write, "simple-driver", "none", true, true)
            expect(nvme_filesystem_lease_reason(lease, NvmeFilesystemConsumer.Dbfs)).to_equal("nvme-fs-queue-missing-write-right")

        it "translates filesystem-relative LBAs inside the namespace lease only":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 4,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 4,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 128u64, 256u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", true, true)
            expect(nvme_filesystem_lease_sector_size(lease)).to_equal(4096)
            expect(nvme_filesystem_lease_sector_count(lease)).to_equal(256u64)
            expect(nvme_filesystem_lease_absolute_lba(lease, 0u64).unwrap()).to_equal(128u64)
            expect(nvme_filesystem_lease_absolute_lba(lease, 255u64).unwrap()).to_equal(383u64)
            expect(nvme_filesystem_lease_absolute_lba(lease, 256u64).unwrap_err()).to_equal("nvme-fs-lease-lba-out-of-range")

        it "rejects simultaneous system and user ownership of one namespace":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 9,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val other_ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 10,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val system_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 9,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val user_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 9,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val other_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 10,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val system_lease = nvme_filesystem_lease(ns, 0u64, 1024u64, NvmeNamespaceMode.System, system_queue, "simple-driver", "kernel-owned-resource", true, true)
            val user_lease = nvme_filesystem_lease(ns, 0u64, 1024u64, NvmeNamespaceMode.UserAssigned, user_queue, "simple-driver", "resource-grant-set:tok=200", true, true)
            val other_user = nvme_filesystem_lease(other_ns, 0u64, 1024u64, NvmeNamespaceMode.UserAssigned, other_queue, "simple-driver", "resource-grant-set:tok=200", true, true)

            expect(nvme_filesystem_lease_conflict_reason(system_lease, user_lease)).to_equal("nvme-fs-namespace-mode-conflict:system:user-assigned")
            expect(nvme_filesystem_lease_conflict_reason(system_lease, other_user)).to_equal("ready")
            expect(nvme_filesystem_lease_set_acceptance_reason([system_lease], user_lease)).to_equal("nvme-fs-namespace-mode-conflict:system:user-assigned")

        it "allows repeated user filesystem views only for the same grant owner and queue":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 11,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue_a = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 11,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val queue_b = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID + 1u16,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 11,
                owner_task: 43,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val active = nvme_filesystem_lease(ns, 0u64, 1024u64, NvmeNamespaceMode.UserAssigned, queue_a, "simple-driver", "resource-grant-set:tok=201", true, true)
            val same_owner = nvme_filesystem_lease(ns, 128u64, 512u64, NvmeNamespaceMode.UserAssigned, queue_a, "simple-driver", "resource-grant-set:tok=201", true, true)
            val other_owner = nvme_filesystem_lease(ns, 128u64, 512u64, NvmeNamespaceMode.UserAssigned, queue_b, "simple-driver", "resource-grant-set:tok=202", true, true)

            expect(nvme_filesystem_lease_conflict_reason(active, same_owner)).to_equal("ready")
            expect(nvme_filesystem_lease_conflict_reason(active, other_owner)).to_equal("nvme-fs-user-namespace-grant-conflict")
            expect(nvme_filesystem_lease_same_assignment(active, same_owner)).to_equal(true)
            expect(nvme_filesystem_lease_same_assignment(active, other_owner)).to_equal(false)

    describe "pure Simple transfer evidence":
        it "rejects the C boot bridge as NVMe transfer completion":
            val bridge = nvme_transfer_evidence(
                "c-boot-bridge",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=31",
                "non-secure-resource-namespace",
                true,
                true
            )
            expect(nvme_transfer_ready(bridge)).to_equal(false)
            expect(nvme_transfer_readiness_reason(bridge)).to_equal("nvme-transfer-provider-not-simple:c-boot-bridge")

        it "requires queues doorbells completion and reversible sector I/O":
            val missing_completion = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                false,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=32",
                "non-secure-resource-namespace",
                true,
                true
            )
            val missing_restore = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                false,
                true,
                "user-space-driver",
                "resource-grant-set:tok=33",
                "non-secure-resource-namespace",
                true,
                true
            )
            val ready = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=34",
                "non-secure-resource-namespace",
                true,
                true
            )

            expect(nvme_transfer_readiness_reason(missing_completion)).to_equal("missing-nvme-completion")
            expect(nvme_transfer_readiness_reason(missing_restore)).to_equal("missing-nvme-sector-restore")
            expect(nvme_transfer_ready(ready)).to_equal(true)

        it "requires issued grants non-secure namespace and common driver logic":
            val no_token = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set",
                "non-secure-resource-namespace",
                true,
                true
            )
            val bad_namespace = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=35",
                "secure-kernel-namespace",
                true,
                true
            )
            val missing_common = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=36",
                "non-secure-resource-namespace",
                false,
                true
            )

            expect(nvme_transfer_readiness_reason(no_token)).to_contain("missing-issued-device-grant-token:resource-grant-set")
            expect(nvme_transfer_readiness_reason(bad_namespace)).to_contain("missing-non-secure-resource-namespace:secure-kernel-namespace")
            expect(nvme_transfer_readiness_reason(missing_common)).to_contain("missing-common-driver-logic")

        it "accepts system-driver transfer evidence only for kernel-owned system namespace resources":
            val system_ready = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "system-driver",
                "kernel-owned-resource",
                "system-kernel-namespace",
                true,
                true
            )
            val bad_system_grant = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "system-driver",
                "resource-grant-set:tok=37",
                "system-kernel-namespace",
                true,
                true
            )

            expect(nvme_transfer_readiness_reason(system_ready)).to_equal("ready")
            expect(nvme_transfer_readiness_reason(bad_system_grant)).to_contain("missing-kernel-owned-resource")

        it "mints filesystem leases from ready system-driver transfer evidence":
            val evidence = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "system-driver",
                "kernel-owned-resource",
                "system-kernel-namespace",
                true,
                true
            )
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 1,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 1,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )

            val lease = nvme_filesystem_lease_from_transfer_evidence(evidence, ns, 128u64, 1024u64, queue, NvmeFilesystemConsumer.Nvfs).unwrap()
            expect(lease.mode).to_equal(NvmeNamespaceMode.System)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Fat32)).to_equal(true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Nvfs)).to_equal(true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Dbfs)).to_equal(true)

        it "mints user-assigned filesystem leases only from ready user transfer evidence":
            val evidence = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=41",
                "non-secure-resource-namespace",
                true,
                true
            )
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 7,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val data_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 7,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val system_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 7,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )

            val lease = nvme_filesystem_lease_from_transfer_evidence(evidence, ns, 256u64, 1024u64, data_queue, NvmeFilesystemConsumer.Dbfs).unwrap()
            val rejected = nvme_filesystem_lease_from_transfer_evidence(evidence, ns, 256u64, 1024u64, system_queue, NvmeFilesystemConsumer.Fat32)
            expect(lease.mode).to_equal(NvmeNamespaceMode.UserAssigned)
            expect(lease.grant_kind).to_equal("resource-grant-set:tok=41")
            expect(rejected.unwrap_err()).to_equal("nvme-fs-user-namespace-uses-reserved-queue")

        it "rejects filesystem leases when transfer evidence is not ready":
            val evidence = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                false,
                true,
                true,
                "system-driver",
                "kernel-owned-resource",
                "system-kernel-namespace",
                true,
                true
            )
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 8,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 8,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val result = nvme_filesystem_lease_from_transfer_evidence(evidence, ns, 0u64, 1024u64, queue, NvmeFilesystemConsumer.Fat32)
            expect(result.unwrap_err()).to_equal("nvme-fs-transfer-not-ready:missing-nvme-sector-write")
