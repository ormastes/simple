# @cover src/os/drivers/audio/hda_controller.spl 70%
#
# Intel HD Audio controller register-sequencing specification.
#
# Runs the driver's real MMIO register writes (os.kernel.boot.mmio) against
# the module's in-memory test-mode register model (mmio_reset_for_test) —
# no real hardware or QEMU boot needed to prove the driver programs the
# right registers with the right values in the right order. What this
# CANNOT prove: genuine asynchronous hardware behavior (a real codec
# actually DMA'ing a RIRB response after seeing a CORB verb, an IRQ line
# actually firing) — those tests seed the response by hand via mmio_write*,
# which is a stand-in for what real silicon/QEMU would do. End-to-end proof
# against `-device intel-hda` is scripts/check/check-hda-qemu.shs (blocked
# on the in-flight toolchain redeploy — see that script's header).

use std.spec.{describe, it, expect}
use os.kernel.boot.mmio.{mmio_reset_for_test, mmio_write16, mmio_write32, mmio_read32}
use os.drivers.audio.hda_controller.{HdaController}

val BAR0: i64 = 0x1000
val CORB_DMA: i64 = 0x200000
val RIRB_DMA: i64 = 0x201000

describe "HdaController.initialize":

    it "fails closed (initialized=false) when STATESTS reports no codec present":
        mmio_reset_for_test()
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        val status = ctl.initialize()
        expect(ctl.initialized).to_equal(false)
        expect(status).to_contain("hda_init FAILED")
        expect(status).to_contain("no_codec_present")

    it "reaches initialized=true and identifies a Realtek ALC892 codec from a seeded Vendor ID response":
        mmio_reset_for_test()
        # STATESTS (bar0+0x0E) bit0 -> codec present at address 0.
        mmio_write16((BAR0 + 0x0E) as u64, 1u16)
        # RIRB response slot 0 (rirb base) = packed (vendor:16)(device:16) for
        # Realtek ALC892 (vendor 0x10EC, device 0x0892) — Intel HD Audio spec
        # 7.3.4.1 GET_PARAMETER(Vendor ID) response format.
        mmio_write32(RIRB_DMA as u64, 0x10EC0892u32)

        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        val status = ctl.initialize()

        expect(ctl.initialized).to_equal(true)
        expect(ctl.codec_vendor_id).to_equal(0x10EC)
        expect(ctl.codec_device_id).to_equal(0x0892)
        expect(status).to_contain("hda_init ok")

    it "programs GCTL with CRST=1 (exits reset) as part of a successful bring-up":
        mmio_reset_for_test()
        mmio_write16((BAR0 + 0x0E) as u64, 1u16)
        mmio_write32(RIRB_DMA as u64, 0x10EC0892u32)
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        ctl.initialize()
        val gctl = mmio_read32((BAR0 + 0x08) as u64)
        expect((gctl & 1u32)).to_equal(1u32)

    it "programs CORBLBASE/RIRBLBASE with the ring buffers' own DMA addresses":
        mmio_reset_for_test()
        mmio_write16((BAR0 + 0x0E) as u64, 1u16)
        mmio_write32(RIRB_DMA as u64, 0x10EC0892u32)
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        ctl.initialize()
        expect(mmio_read32((BAR0 + 0x40) as u64)).to_equal(CORB_DMA as u32)
        expect(mmio_read32((BAR0 + 0x50) as u64)).to_equal(RIRB_DMA as u32)

    it "enables global + controller interrupts (INTCTL bits 31/30 set)":
        mmio_reset_for_test()
        mmio_write16((BAR0 + 0x0E) as u64, 1u16)
        mmio_write32(RIRB_DMA as u64, 0x10EC0892u32)
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        ctl.initialize()
        val intctl = mmio_read32((BAR0 + 0x20) as u64)
        expect((intctl & 0xC0000000u32)).to_equal(0xC0000000u32)

describe "HdaController stream lifecycle":

    it "start_stream sets the RUN bit and stop_stream clears it, tracking stream_count":
        mmio_reset_for_test()
        mmio_write16((BAR0 + 0x0E) as u64, 1u16)
        mmio_write32(RIRB_DMA as u64, 0x10EC0892u32)
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        ctl.initialize()

        ctl.configure_stream(0, 0x300000, 0x0011u16)
        expect(ctl.stream_count).to_equal(0)

        ctl.start_stream(0)
        expect(ctl.stream_count).to_equal(1)
        val ctl_after_start = mmio_read32((BAR0 + 0x80) as u64)
        expect((ctl_after_start & 0x02u32)).to_equal(0x02u32)  # RUN bit set

        ctl.stop_stream(0)
        expect(ctl.stream_count).to_equal(0)
        val ctl_after_stop = mmio_read32((BAR0 + 0x80) as u64)
        expect((ctl_after_stop & 0x02u32)).to_equal(0u32)  # RUN bit cleared

describe "HdaController.handle_irq":

    it "is a no-op (spurious) when INTSTS reads 0":
        mmio_reset_for_test()
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        val result = ctl.handle_irq()
        expect(result).to_equal("hda_irq spurious")
        expect(ctl.timer.elapsed_periods).to_equal(0)

    it "ticks the period timer once per set stream bit and RW1C-acknowledges INTSTS":
        mmio_reset_for_test()
        var ctl = HdaController.create(BAR0, 11, CORB_DMA, RIRB_DMA)
        # Simulate stream 0's completion IRQ (bit0) — a real intel-hda device
        # sets this after a period boundary; QEMU lane proves that part.
        mmio_write32((BAR0 + 0x24) as u64, 1u32)
        val result = ctl.handle_irq()
        expect(ctl.timer.elapsed_periods).to_equal(1)
        expect(ctl.irq_count).to_equal(1)
        expect(result).to_contain("streams_fired=1")
