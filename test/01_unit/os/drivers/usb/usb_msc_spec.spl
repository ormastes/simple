# USB Mass Storage Class (Bulk-Only Transport) Spec
#
# Drives the real usb_msc BOT/SCSI state machine (CBW -> data -> CSW,
# INQUIRY / READ CAPACITY / READ(10) / WRITE(10)) against a device-side fake
# bulk transport that parses CBWs like a real usb-storage device, then
# proves the headline contract: a FAT32 volume mounts on a UsbMscDevice
# through the SAME stdlib BlockDevice trait NVMe uses, and a file reads back
# through the filesystem unchanged.
#
# Fail-closed behavior is asserted for: corrupt CSW signature, non-zero CSW
# status, CSW tag mismatch, and short data stages.

use std.spec
use os.drivers.usb.usb_msc.{
    UsbBulkTransport, UsbMscDevice, usb_msc_init,
    usb_msc_inquiry, usb_msc_read_capacity, usb_msc_test_unit_ready
}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{Fat32Core}

# ---------------------------------------------------------------------------
# Fake device-side BOT transport (module-level store: interpreter
# value-semantics — copies of the class must share state)
# ---------------------------------------------------------------------------

val FAKE_SECTOR_SIZE: i64 = 512
val FAKE_SECTOR_COUNT: i64 = 64

# fault modes
val FAULT_NONE: i64 = 0
val FAULT_BAD_CSW_SIG: i64 = 1
val FAULT_CSW_STATUS: i64 = 2
val FAULT_SHORT_DATA: i64 = 3
val FAULT_WRONG_TAG: i64 = 4

var _fake_next_id: i64 = 1
var _fake_ids: [i64] = []
var _fake_disks: [[u8]] = []      # flat sector_count*sector_size bytes
var _fake_in_fifo: [[u8]] = []    # queued device->host bytes (data + CSW)
var _fake_write_lba: [i64] = []   # pending WRITE(10) lba, -1 = none
var _fake_write_count: [i64] = []
var _fake_write_tag: [i64] = []
var _fake_fault: [i64] = []

fn _fake_find(inst_id: i64) -> i64:
    var i: i64 = 0
    while i < _fake_ids.len():
        if _fake_ids[i] == inst_id:
            return i
        i = i + 1
    -1

class FakeBotTransport:
    inst_id: i64

impl FakeBotTransport:
    static fn create() -> FakeBotTransport:
        val id = _fake_next_id
        _fake_next_id = _fake_next_id + 1
        _fake_ids.push(id)
        var disk: [u8] = []
        var i: i64 = 0
        while i < FAKE_SECTOR_COUNT * FAKE_SECTOR_SIZE:
            disk.push(0x00u8)
            i = i + 1
        _fake_disks.push(disk)
        _fake_in_fifo.push([])
        _fake_write_lba.push(-1)
        _fake_write_count.push(0)
        _fake_write_tag.push(0)
        _fake_fault.push(FAULT_NONE)
        FakeBotTransport(inst_id: id)

    fn set_fault(mode: i64):
        val idx = _fake_find(self.inst_id)
        if idx >= 0:
            _fake_fault[idx] = mode

    fn poke_sector(lba: i64, data: [u8]):
        """Directly write backing-store bytes (test image setup)."""
        val idx = _fake_find(self.inst_id)
        if idx < 0:
            return
        var disk = _fake_disks[idx]
        var i: i64 = 0
        while i < data.len() and i < FAKE_SECTOR_SIZE:
            disk[lba * FAKE_SECTOR_SIZE + i] = data[i]
            i = i + 1
        _fake_disks[idx] = disk

fn _fake_csw(tag: i64, status: i64, fault: i64) -> [u8]:
    var csw: [u8] = []
    if fault == FAULT_BAD_CSW_SIG:
        csw.push(0xDEu8)
    else:
        csw.push(0x55u8)
    csw.push(0x53u8)
    csw.push(0x42u8)
    csw.push(0x53u8)
    var out_tag = tag
    if fault == FAULT_WRONG_TAG:
        out_tag = tag + 7
    csw.push((out_tag & 0xFF).to_u8())
    csw.push(((out_tag >> 8) & 0xFF).to_u8())
    csw.push(((out_tag >> 16) & 0xFF).to_u8())
    csw.push(((out_tag >> 24) & 0xFF).to_u8())
    # dCSWDataResidue = 0
    csw.push(0x00u8)
    csw.push(0x00u8)
    csw.push(0x00u8)
    csw.push(0x00u8)
    if fault == FAULT_CSW_STATUS:
        csw.push(0x01u8)
    else:
        csw.push(0x00u8)
    csw

fn _fake_queue(idx: i64, data: [u8]):
    var fifo = _fake_in_fifo[idx]
    for b in data:
        fifo.push(b)
    _fake_in_fifo[idx] = fifo

impl UsbBulkTransport for FakeBotTransport:
    fn bulk_out(data: [u8]) -> Result<i64, text>:
        val idx = _fake_find(self.inst_id)
        if idx < 0:
            return Err("fake: unregistered transport")
        val fault = _fake_fault[idx]

        # Pending WRITE(10) data stage?
        if _fake_write_lba[idx] >= 0:
            val lba = _fake_write_lba[idx]
            var disk = _fake_disks[idx]
            var i: i64 = 0
            while i < data.len():
                disk[lba * FAKE_SECTOR_SIZE + i] = data[i]
                i = i + 1
            _fake_disks[idx] = disk
            val wtag = _fake_write_tag[idx]
            _fake_write_lba[idx] = -1
            _fake_queue(idx, _fake_csw(wtag, 0, fault))
            return Ok(data.len())

        # Otherwise this must be a 31-byte CBW
        if data.len() != 31:
            return Err("fake: expected CBW, got " + data.len().to_text() + " bytes")
        val sig = data[0].to_i64() | (data[1].to_i64() << 8) | (data[2].to_i64() << 16) | (data[3].to_i64() << 24)
        if sig != 0x43425355:
            return Err("fake: bad CBW signature")
        val tag = data[4].to_i64() | (data[5].to_i64() << 8) | (data[6].to_i64() << 16) | (data[7].to_i64() << 24)
        val opcode = data[15].to_i64()

        if opcode == 0x00:
            # TEST UNIT READY: no data stage
            _fake_queue(idx, _fake_csw(tag, 0, fault))
            return Ok(31)
        if opcode == 0x12:
            # INQUIRY: 36 bytes, type 0x00 (direct access)
            var inq: [u8] = []
            var i: i64 = 0
            while i < 36:
                inq.push(0x00u8)
                i = i + 1
            inq[1] = 0x80u8   # removable
            inq[4] = 31u8     # additional length
            if fault == FAULT_SHORT_DATA:
                inq = inq.slice(0, 35)
            _fake_queue(idx, inq)
            _fake_queue(idx, _fake_csw(tag, 0, fault))
            return Ok(31)
        if opcode == 0x25:
            # READ CAPACITY(10): last LBA + block size, big-endian
            val last = FAKE_SECTOR_COUNT - 1
            var cap: [u8] = []
            cap.push(((last >> 24) & 0xFF).to_u8())
            cap.push(((last >> 16) & 0xFF).to_u8())
            cap.push(((last >> 8) & 0xFF).to_u8())
            cap.push((last & 0xFF).to_u8())
            cap.push(0x00u8)
            cap.push(0x00u8)
            cap.push(0x02u8)   # 512 BE
            cap.push(0x00u8)
            _fake_queue(idx, cap)
            _fake_queue(idx, _fake_csw(tag, 0, fault))
            return Ok(31)
        if opcode == 0x28:
            # READ(10)
            val lba = (data[17].to_i64() << 24) | (data[18].to_i64() << 16) | (data[19].to_i64() << 8) | data[20].to_i64()
            val count = (data[22].to_i64() << 8) | data[23].to_i64()
            val disk = _fake_disks[idx]
            var payload: [u8] = []
            var i: i64 = 0
            while i < count * FAKE_SECTOR_SIZE:
                payload.push(disk[lba * FAKE_SECTOR_SIZE + i])
                i = i + 1
            if fault == FAULT_SHORT_DATA and payload.len() > 0:
                payload = payload.slice(0, payload.len() - 1)
            _fake_queue(idx, payload)
            _fake_queue(idx, _fake_csw(tag, 0, fault))
            return Ok(31)
        if opcode == 0x2A:
            # WRITE(10): remember lba, CSW queued after the data stage arrives
            val lba = (data[17].to_i64() << 24) | (data[18].to_i64() << 16) | (data[19].to_i64() << 8) | data[20].to_i64()
            _fake_write_lba[idx] = lba
            _fake_write_tag[idx] = tag
            return Ok(31)
        Err("fake: unsupported SCSI opcode " + opcode.to_text())

    fn bulk_in(max_len: i64) -> Result<[u8], text>:
        val idx = _fake_find(self.inst_id)
        if idx < 0:
            return Err("fake: unregistered transport")
        var fifo = _fake_in_fifo[idx]
        var out: [u8] = []
        var i: i64 = 0
        while i < max_len and i < fifo.len():
            out.push(fifo[i])
            i = i + 1
        _fake_in_fifo[idx] = fifo.slice(i, fifo.len())
        Ok(out)

# ---------------------------------------------------------------------------
# Minimal FAT32 volume (64 sectors): BPB, 1 FAT sector, root dir cluster 2,
# HELLO.TXT content in cluster 3
# ---------------------------------------------------------------------------

fn _zero_sector() -> [u8]:
    var s: [u8] = []
    var i: i64 = 0
    while i < FAKE_SECTOR_SIZE:
        s.push(0x00u8)
        i = i + 1
    s

fn _stage_fat32_volume(t: FakeBotTransport):
    # Sector 0: BPB — 512 B/sector, 1 sector/cluster, 1 reserved, 1 FAT of
    # 1 sector, 64 total sectors, root cluster 2. data_start = 1 + 1 = 2.
    var bpb = _zero_sector()
    bpb[11] = 0x00u8
    bpb[12] = 0x02u8    # bytes/sector = 512
    bpb[13] = 0x01u8    # sectors/cluster
    bpb[14] = 0x01u8
    bpb[15] = 0x00u8    # reserved sectors = 1
    bpb[16] = 0x01u8    # num FATs
    bpb[21] = 0xF8u8    # media type
    bpb[32] = 64u8
    bpb[33] = 0x00u8
    bpb[34] = 0x00u8
    bpb[35] = 0x00u8    # total sectors 32 = 64
    bpb[36] = 0x01u8
    bpb[37] = 0x00u8
    bpb[38] = 0x00u8
    bpb[39] = 0x00u8    # FAT size = 1 sector
    bpb[44] = 0x02u8
    bpb[45] = 0x00u8
    bpb[46] = 0x00u8
    bpb[47] = 0x00u8    # root cluster = 2
    bpb[510] = 0x55u8
    bpb[511] = 0xAAu8
    t.poke_sector(0, bpb)

    # Sector 1: FAT — entries 0/1 reserved, cluster 2 (root) EOC, cluster 3
    # (file) EOC. 32-bit little-endian entries.
    var fat = _zero_sector()
    fat[0] = 0xF8u8
    fat[1] = 0xFFu8
    fat[2] = 0xFFu8
    fat[3] = 0x0Fu8
    fat[4] = 0xFFu8
    fat[5] = 0xFFu8
    fat[6] = 0xFFu8
    fat[7] = 0x0Fu8
    fat[8] = 0xF8u8
    fat[9] = 0xFFu8
    fat[10] = 0xFFu8
    fat[11] = 0x0Fu8
    fat[12] = 0xF8u8
    fat[13] = 0xFFu8
    fat[14] = 0xFFu8
    fat[15] = 0x0Fu8
    t.poke_sector(1, fat)

    # Sector 2 (cluster 2): root directory with one 8.3 entry HELLO.TXT,
    # first cluster 3, size 14
    var root = _zero_sector()
    root[0] = 0x48u8   # H
    root[1] = 0x45u8   # E
    root[2] = 0x4Cu8   # L
    root[3] = 0x4Cu8   # L
    root[4] = 0x4Fu8   # O
    root[5] = 0x20u8
    root[6] = 0x20u8
    root[7] = 0x20u8
    root[8] = 0x54u8   # T
    root[9] = 0x58u8   # X
    root[10] = 0x54u8  # T
    root[11] = 0x20u8  # ATTR_ARCHIVE
    root[26] = 0x03u8
    root[27] = 0x00u8  # first cluster lo = 3
    root[28] = 14u8
    root[29] = 0x00u8
    root[30] = 0x00u8
    root[31] = 0x00u8  # size = 14
    t.poke_sector(2, root)

    # Sector 3 (cluster 3): "hello from usb" (14 ASCII bytes)
    var content = _zero_sector()
    val message_bytes: [u8] = [
        0x68u8, 0x65u8, 0x6Cu8, 0x6Cu8, 0x6Fu8,   # hello
        0x20u8,
        0x66u8, 0x72u8, 0x6Fu8, 0x6Du8,           # from
        0x20u8,
        0x75u8, 0x73u8, 0x62u8                    # usb
    ]
    var i: i64 = 0
    while i < message_bytes.len():
        content[i] = message_bytes[i]
        i = i + 1
    t.poke_sector(3, content)

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "usb_msc SCSI bring-up over BOT":
    it "answers TEST UNIT READY":
        val t = FakeBotTransport.create()
        val rc = usb_msc_test_unit_ready(t)
        expect(rc.is_ok()).to_equal(true)

    it "reads INQUIRY and READ CAPACITY through CBW/CSW":
        val t = FakeBotTransport.create()
        val inq = usb_msc_inquiry(t)
        expect(inq.is_ok()).to_equal(true)
        val cap = usb_msc_read_capacity(t)
        expect(cap.is_ok()).to_equal(true)
        if val Ok(c) = cap:
            expect(c.sector_count.to_i64()).to_equal(64)
            expect(c.sector_size.to_i64()).to_equal(512)

    it "initializes a UsbMscDevice with the probed geometry":
        val t = FakeBotTransport.create()
        val dev_rc = usb_msc_init(t)
        expect(dev_rc.is_ok()).to_equal(true)
        if val Ok(dev) = dev_rc:
            expect(dev.sector_size().to_i64()).to_equal(512)
            expect(dev.sector_count().to_i64()).to_equal(64)

describe "usb_msc BlockDevice read/write":
    it "round-trips a sector through WRITE(10) then READ(10)":
        val t = FakeBotTransport.create()
        val dev_rc = usb_msc_init(t)
        expect(dev_rc.is_ok()).to_equal(true)
        if val Ok(dev) = dev_rc:
            var payload = _zero_sector()
            payload[0] = 0xABu8
            payload[511] = 0xCDu8
            val wrc = dev.write_sector(5u64, payload)
            expect(wrc.is_ok()).to_equal(true)
            val rrc = dev.read_sector(5u64)
            expect(rrc.is_ok()).to_equal(true)
            if val Ok(back) = rrc:
                expect(back.len()).to_equal(512)
                expect(back[0].to_i64()).to_equal(0xAB)
                expect(back[511].to_i64()).to_equal(0xCD)

    it "rejects out-of-range LBAs":
        val t = FakeBotTransport.create()
        if val Ok(dev) = usb_msc_init(t):
            expect(dev.read_sector(64u64).is_err()).to_equal(true)
            expect(dev.write_sector(64u64, _zero_sector()).is_err()).to_equal(true)

describe "usb_msc fail-closed on transfer errors":
    it "rejects a corrupt CSW signature":
        val t = FakeBotTransport.create()
        t.set_fault(FAULT_BAD_CSW_SIG)
        expect(usb_msc_inquiry(t).is_err()).to_equal(true)

    it "rejects a failing CSW status":
        val t = FakeBotTransport.create()
        t.set_fault(FAULT_CSW_STATUS)
        expect(usb_msc_inquiry(t).is_err()).to_equal(true)

    it "rejects a CSW tag mismatch":
        val t = FakeBotTransport.create()
        t.set_fault(FAULT_WRONG_TAG)
        expect(usb_msc_inquiry(t).is_err()).to_equal(true)

    it "rejects short data stages instead of returning partial sectors":
        val t = FakeBotTransport.create()
        if val Ok(dev) = usb_msc_init(t):
            t.set_fault(FAULT_SHORT_DATA)
            expect(dev.read_sector(0u64).is_err()).to_equal(true)

describe "FAT32 mounts on usb-storage via the BlockDevice trait":
    it "mounts and reads /HELLO.TXT through the MSC device unchanged":
        val t = FakeBotTransport.create()
        _stage_fat32_volume(t)
        val dev_rc = usb_msc_init(t)
        expect(dev_rc.is_ok()).to_equal(true)
        if val Ok(dev) = dev_rc:
            var fs = Fat32Core.new(dev)
            val mounted = fs.mount()
            expect(mounted.is_ok()).to_equal(true)
            val opened = fs.open("/HELLO.TXT")
            expect(opened.is_ok()).to_equal(true)
            if val Ok(handle) = opened:
                val bytes_rc = fs.read_bytes(handle, 14)
                expect(bytes_rc.is_ok()).to_equal(true)
                if val Ok(bytes) = bytes_rc:
                    expect(bytes.len()).to_equal(14)
                    # "hello from usb" as ASCII bytes
                    val want: [u8] = [
                        0x68u8, 0x65u8, 0x6Cu8, 0x6Cu8, 0x6Fu8,
                        0x20u8,
                        0x66u8, 0x72u8, 0x6Fu8, 0x6Du8,
                        0x20u8,
                        0x75u8, 0x73u8, 0x62u8
                    ]
                    var mismatches = 0
                    var i = 0
                    while i < 14:
                        if bytes[i].to_i64() != want[i].to_i64():
                            mismatches = mismatches + 1
                        i = i + 1
                    expect(mismatches).to_equal(0)
