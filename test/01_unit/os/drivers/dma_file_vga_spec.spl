"""DMA, File Driver, and VGA/Display Driver Specification.

**Feature IDs:** #FR-DRIVER-0009, #FR-DRIVER-0010, #FR-DRIVER-0011
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** In Progress
**Plan:** doc/03_plan/agent_tasks/dma_file_vga_driver_remaining_2026-04-21.md

## Overview

Self-contained specification covering:
- Canonical DMA descriptor with cache policy (P0)
- SR-IOV/IOMMU isolation gating (P0)
- File/block direct I/O extension (P1)
- Display capability naming and dirty-rect flushing (P1)
- Failure-mode safety gates (P2)

20 tests total. All classes defined inline.
"""

use std.spipe.*

# ---------------------------------------------------------------------------
# Inline class definitions (self-contained per test rules)
# ---------------------------------------------------------------------------

class CacheKind:
    name: text

    static fn coherent() -> CacheKind:
        CacheKind(name: "coherent")

    static fn flush_required() -> CacheKind:
        CacheKind(name: "flush_required")

    static fn write_combining() -> CacheKind:
        CacheKind(name: "write_combining")

    me needs_flush() -> bool:
        self.name == "flush_required"

    me is_coherent() -> bool:
        self.name == "coherent"

class DmaBuf:
    vaddr: i64
    paddr: i64
    dev_addr: i64
    byte_len: i64
    cache_name: text
    owner_task: i32
    owner_dev: i32
    active: bool

    static fn create(v: i64, p: i64, da: i64, bl: i64, cache_name: text, ot: i32, od: i32) -> DmaBuf:
        DmaBuf(
            vaddr: v,
            paddr: p,
            dev_addr: da,
            byte_len: bl,
            cache_name: cache_name,
            owner_task: ot,
            owner_dev: od,
            active: true
        )

    me validate_release(task_id: i32) -> text:
        if self.active == false:
            return "error:already_released"
        if self.owner_task == task_id:
            return ""
        return "error:owner_mismatch expected=" + self.owner_task.to_text() + " got=" + task_id.to_text()

    me matches_owner(task_id: i32, dev_id: i32) -> bool:
        self.owner_task == task_id and self.owner_dev == dev_id

class SyncHelper:
    cache_name: text
    flush_count: i64

    static fn for_cache(cache_name: text) -> SyncHelper:
        SyncHelper(cache_name: cache_name, flush_count: 0)

    me cpu_to_dev(buf: DmaBuf) -> text:
        if buf.cache_name == "coherent":
            return "noop"
        if buf.cache_name == "flush_required":
            self.flush_count = self.flush_count + 1
            return "flush"
        return "noop"

    me dev_to_cpu(buf: DmaBuf) -> text:
        if buf.cache_name == "coherent":
            return "noop"
        if buf.cache_name == "flush_required":
            self.flush_count = self.flush_count + 1
            return "invalidate"
        return "noop"

    me total_flushes() -> i64:
        self.flush_count

class IsolDomain:
    has_iommu: bool
    mode: text

    static fn isolated() -> IsolDomain:
        IsolDomain(has_iommu: true, mode: "isolated")

    static fn trusted() -> IsolDomain:
        IsolDomain(has_iommu: false, mode: "trusted")

    static fn none_isol() -> IsolDomain:
        IsolDomain(has_iommu: false, mode: "none")

    me can_assign_vf() -> bool:
        self.has_iommu

    me advertises_isolation() -> bool:
        if self.mode == "trusted":
            return false
        return self.has_iommu

class DioCapability:
    supported: bool
    min_alignment: i64
    max_transfer: i64

    static fn available(alignment: i64, max_transfer: i64) -> DioCapability:
        DioCapability(supported: true, min_alignment: alignment, max_transfer: max_transfer)

    static fn unavailable() -> DioCapability:
        DioCapability(supported: false, min_alignment: 0, max_transfer: 0)

    me validate_offset(offset: i64) -> bool:
        if self.min_alignment == 0:
            return true
        var rem = offset - (offset / self.min_alignment) * self.min_alignment
        return rem == 0

    me requires_dma_buf() -> bool:
        self.supported

class DioReq:
    op: text
    file_offset: i64
    byte_len: i64
    dma_vaddr: i64
    owner_task: i32

    static fn read_at(offset: i64, byte_len: i64, dma_vaddr: i64, owner_task: i32) -> DioReq:
        DioReq(op: "read", file_offset: offset, byte_len: byte_len, dma_vaddr: dma_vaddr, owner_task: owner_task)

    static fn write_at(offset: i64, byte_len: i64, dma_vaddr: i64, owner_task: i32) -> DioReq:
        DioReq(op: "write", file_offset: offset, byte_len: byte_len, dma_vaddr: dma_vaddr, owner_task: owner_task)

    me is_read() -> bool:
        self.op == "read"

    me is_write() -> bool:
        self.op == "write"

class BlockBackend:
    name: text
    queue_id: i32
    timeout_ms: i32

    static fn nvme(queue_id: i32, timeout_ms: i32) -> BlockBackend:
        BlockBackend(name: "nvme", queue_id: queue_id, timeout_ms: timeout_ms)

    static fn virtio_blk(queue_id: i32, timeout_ms: i32) -> BlockBackend:
        BlockBackend(name: "virtio_blk", queue_id: queue_id, timeout_ms: timeout_ms)

    me is_nvme() -> bool:
        self.name == "nvme"

    me is_virtio() -> bool:
        self.name == "virtio_blk"

class DisplayCap:
    backend: text
    is_dma: bool
    is_accel: bool

    static fn framebuffer_mmio() -> DisplayCap:
        DisplayCap(backend: "framebuffer-mmio", is_dma: false, is_accel: false)

    static fn bga_write_combining() -> DisplayCap:
        DisplayCap(backend: "bga-write-combining", is_dma: false, is_accel: false)

    static fn virtio_gpu_dma() -> DisplayCap:
        DisplayCap(backend: "virtio-gpu-dma", is_dma: true, is_accel: true)

    me label() -> text:
        self.backend

    me is_legacy() -> bool:
        if self.is_dma == false:
            return true
        return false

class DirtyRectFlush:
    x: i32
    y: i32
    w: i32
    h: i32
    is_full_frame: bool

    static fn region(x: i32, y: i32, w: i32, h: i32) -> DirtyRectFlush:
        DirtyRectFlush(x: x, y: y, w: w, h: h, is_full_frame: false)

    static fn full_frame(sw: i32, sh: i32) -> DirtyRectFlush:
        DirtyRectFlush(x: 0, y: 0, w: sw, h: sh, is_full_frame: true)

    me is_bounded() -> bool:
        self.is_full_frame == false

    me area() -> i64:
        self.w as i64 * self.h as i64

class DmaOwnerGate:
    buf_owner: i32
    requester: i32

    static fn check(buf_owner: i32, requester: i32) -> DmaOwnerGate:
        DmaOwnerGate(buf_owner: buf_owner, requester: requester)

    me is_allowed() -> bool:
        self.buf_owner == self.requester

    me denial_reason() -> text:
        if self.is_allowed():
            return ""
        return "wrong_owner:buf=" + self.buf_owner.to_text() + " req=" + self.requester.to_text()

class DisplayFallback:
    dma_available: bool

    static fn with_dma() -> DisplayFallback:
        DisplayFallback(dma_available: true)

    static fn fallback_only() -> DisplayFallback:
        DisplayFallback(dma_available: false)

    me effective_path() -> text:
        if self.dma_available:
            return "virtio-gpu-dma"
        return "framebuffer-mmio"

# ---------------------------------------------------------------------------
# Specification
# ---------------------------------------------------------------------------

describe "DMA Descriptor":
    it "canonical descriptor holds all required fields":
        val buf = DmaBuf.create(0x1000, 0x2000, 0x3000, 4096, "coherent", 1, 5)
        expect(buf.vaddr).to_equal(0x1000)
        expect(buf.paddr).to_equal(0x2000)
        expect(buf.byte_len).to_equal(4096)
        expect(buf.owner_task).to_equal(1)
        expect(buf.owner_dev).to_equal(5)

    it "release succeeds for valid owner":
        val buf = DmaBuf.create(0x1000, 0x2000, 0x3000, 4096, "coherent", 7, 2)
        val msg = buf.validate_release(7)
        expect(msg).to_equal("")

    it "release rejected for wrong owner":
        val buf = DmaBuf.create(0x1000, 0x2000, 0x3000, 4096, "coherent", 7, 2)
        val msg = buf.validate_release(99)
        expect(msg).to_not_equal("")

    it "coherent sync cpu_to_dev is noop":
        var buf = DmaBuf.create(0x1000, 0x2000, 0x3000, 512, "coherent", 1, 1)
        var syncer = SyncHelper.for_cache("coherent")
        expect(syncer.cpu_to_dev(buf)).to_equal("noop")

    it "flush_required sync increments flush count":
        var buf = DmaBuf.create(0x1000, 0x2000, 0x3000, 512, "flush_required", 1, 1)
        var syncer = SyncHelper.for_cache("flush_required")
        syncer.cpu_to_dev(buf)
        syncer.dev_to_cpu(buf)
        expect(syncer.total_flushes()).to_equal(2)

describe "SR-IOV Isolation":
    it "isolated domain with IOMMU allows VF assignment":
        val dom = IsolDomain.isolated()
        expect(dom.can_assign_vf()).to_equal(true)

    it "no-isolation domain rejects VF assignment":
        val dom = IsolDomain.none_isol()
        expect(dom.can_assign_vf()).to_equal(false)

    it "trusted mode does not advertise isolation":
        val dom = IsolDomain.trusted()
        expect(dom.advertises_isolation()).to_equal(false)

    it "isolated domain advertises isolation":
        val dom = IsolDomain.isolated()
        expect(dom.advertises_isolation()).to_equal(true)

describe "Direct I/O":
    it "direct IO capability requires DMA buffer":
        val cap = DioCapability.available(4096, 1048576)
        expect(cap.requires_dma_buf()).to_equal(true)

    it "unavailable capability does not require DMA buffer":
        val cap = DioCapability.unavailable()
        expect(cap.requires_dma_buf()).to_equal(false)

    it "aligned offset passes validation":
        val cap = DioCapability.available(4096, 1048576)
        expect(cap.validate_offset(4096)).to_equal(true)

    it "unaligned offset fails validation":
        val cap = DioCapability.available(4096, 1048576)
        expect(cap.validate_offset(100)).to_equal(false)

    it "NVMe backend is identified correctly":
        val backend = BlockBackend.nvme(0, 5000)
        expect(backend.is_nvme()).to_equal(true)
        expect(backend.is_virtio()).to_equal(false)

    it "VirtIO-BLK backend is identified correctly":
        val backend = BlockBackend.virtio_blk(1, 3000)
        expect(backend.is_virtio()).to_equal(true)
        expect(backend.is_nvme()).to_equal(false)

describe "Display Capability":
    it "framebuffer-mmio is not DMA capable":
        val cap = DisplayCap.framebuffer_mmio()
        expect(cap.is_dma).to_equal(false)
        expect(cap.label()).to_equal("framebuffer-mmio")

    it "bga-write-combining is not DMA accelerated":
        val cap = DisplayCap.bga_write_combining()
        expect(cap.is_legacy()).to_equal(true)
        expect(cap.is_dma).to_equal(false)

    it "virtio-gpu-dma is DMA capable":
        val cap = DisplayCap.virtio_gpu_dma()
        expect(cap.is_dma).to_equal(true)
        expect(cap.is_accel).to_equal(true)

    it "dirty rect flush marks bounded region":
        val rect = DirtyRectFlush.region(10, 10, 100, 50)
        expect(rect.is_bounded()).to_equal(true)
        expect(rect.area()).to_equal(5000)

    it "wrong-owner DMA free is denied":
        val gate = DmaOwnerGate.check(1, 2)
        expect(gate.is_allowed()).to_equal(false)
        assert_not_equal(gate.denial_reason(), "")

    it "display falls back to framebuffer when DMA unavailable":
        val dp = DisplayFallback.fallback_only()
        expect(dp.effective_path()).to_equal("framebuffer-mmio")
