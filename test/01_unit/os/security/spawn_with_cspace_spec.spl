"""
# spawn_with_cspace Specification (OCap Privilege — P1)

**Feature IDs:** #OS-OCAP-P1
**Category:** Runtime / Security
**Difficulty:** 4/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** doc/04_architecture/os/security/ocap_privilege_architecture.md (§P1)
**Design:** doc/01_research/os/security/llm_role_cspace_container_design.md (§3.2)
**Research:** doc/01_research/os/security/llm_role_cspace_container_design.md

## Overview

The headline OCap property: the SAME immutable binary (identical `image_hash`)
spawned at DIFFERENT privilege, where the role IS the injected capability pouch —
no config file, no `if role == ...` branch.

An orchestrator holding a BROAD pouch mints two disjoint C-Spaces from one image:
  - a "ticketing" C-Space: only an IpcConnect cap to `svc.tickets`, NO FileWrite,
    NO calendar.
  - a "scheduling" C-Space: a calendar SharedDataset rw cap, NO ticket cap.

The gate asserts (via capability_kind_allows / CapabilitySet.has):
  - ticketing DENIES FileWrite and DENIES the calendar cap;
  - scheduling DENIES the ticket cap and ALLOWS the calendar cap;
  - a spawn with an empty recipe yields a PLEDGED empty set (deny-all), NOT the
    ambient allow-all of `CapabilitySet.full()`;
  - attenuation is monotonic — a child cannot gain a cap the parent lacks, nor
    widen rights the parent holds; a narrowing recipe (rw -> r) drops write;
  - fork = inherit-attenuated (depth - 1), never full; forking ambient full()
    yields deny-all;
  - revoke_transitive on the parent source kills the child's derived cap.
"""

use std.spec.{describe, it, expect}
use os.kernel.types.task_types.{TaskId}
use os.kernel.types.capability_types.{CapabilityToken, CapabilityKind, CapabilitySet, CAP_RIGHT_READ, CAP_RIGHT_WRITE}
use os.kernel.ipc.capability.{CapabilityManager}
use os.kernel.ipc.cspace_spawn.{SpawnSpec, CapGrant, AttenuationSpec, CspaceMint, spawn_with_cspace, fork_cspace, spawn_full, atten_identity, atten_rights}

# ============================================================================
# Fixtures — the same binary, two role recipes
# ============================================================================

val IMAGE_HASH: text = "blake3:9f3a-llm_worker"
val CAL_OBJ: u64 = 4242u64
val CAL_GEN: u64 = 7u64

fn _tickets() -> CapabilityKind:
    CapabilityKind.IpcConnect(port_name: "svc.tickets")

fn _calendar_rw() -> CapabilityKind:
    CapabilityKind.SharedDataset(object_id: CAL_OBJ, generation: CAL_GEN, rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE)

fn _calendar_ro() -> CapabilityKind:
    CapabilityKind.SharedDataset(object_id: CAL_OBJ, generation: CAL_GEN, rights: CAP_RIGHT_READ)

fn _fwrite() -> CapabilityKind:
    CapabilityKind.FileWrite(path_prefix: "/var")

fn _tok(kind: CapabilityKind, generation: u64, tid: u64, depth: i64) -> CapabilityToken:
    CapabilityToken(kind: kind, generation: generation, owner: 1u64, token_id: tid, parent_token_id: 0u64, depth: depth)

fn make_orchestrator() -> CapabilitySet:
    """Broad orchestrator pouch: tickets(rw, tid 100), calendar(rw, tid 101),
    filewrite(/var, tid 102). Concrete, delegable tokens (depth 2)."""
    val tickets = _tok(_tickets(), 1u64, 100u64, 2)
    val calendar = _tok(_calendar_rw(), 2u64, 101u64, 2)
    val fwrite = _tok(_fwrite(), 3u64, 102u64, 2)
    CapabilitySet(caps: [tickets, calendar, fwrite], is_pledged: true)

fn ticketing_spec() -> SpawnSpec:
    SpawnSpec(
        image_hash: IMAGE_HASH,
        grants: [CapGrant(label: "ipc.tickets", requested: _tickets(), atten: atten_identity())],
        isolation: "sandbox",
        budget: 0u64
    )

fn scheduling_spec() -> SpawnSpec:
    SpawnSpec(
        image_hash: IMAGE_HASH,
        grants: [CapGrant(label: "mem.calendar", requested: _calendar_rw(), atten: atten_identity())],
        isolation: "sandbox",
        budget: 0u64
    )

# ============================================================================
# Group 1 — Same binary, different privilege (the headline gate)
# ============================================================================

describe "spawn_with_cspace: same image_hash, two disjoint pouches":
    """Two C-Spaces minted from ONE binary differ ONLY in their injected pouch."""

    it "both roles pin the SAME immutable image_hash":
        expect(ticketing_spec().image_hash).to_equal(scheduling_spec().image_hash)

    it "ticketing C-Space ALLOWS its ticket cap":
        val orch = make_orchestrator()
        val tk = spawn_with_cspace(orch, ticketing_spec(), 20u64, 1000u64, 300u64)
        expect(tk.caps.has(_tickets())).to_equal(true)

    it "ticketing C-Space DENIES FileWrite (no ambient FS authority)":
        val orch = make_orchestrator()
        val tk = spawn_with_cspace(orch, ticketing_spec(), 20u64, 1000u64, 300u64)
        expect(tk.caps.has(_fwrite())).to_equal(false)

    it "ticketing C-Space DENIES the calendar cap":
        val orch = make_orchestrator()
        val tk = spawn_with_cspace(orch, ticketing_spec(), 20u64, 1000u64, 300u64)
        expect(tk.caps.has(_calendar_ro())).to_equal(false)

    it "scheduling C-Space ALLOWS the calendar cap":
        val orch = make_orchestrator()
        val sc = spawn_with_cspace(orch, scheduling_spec(), 21u64, 2000u64, 400u64)
        expect(sc.caps.has(_calendar_ro())).to_equal(true)

    it "scheduling C-Space DENIES the ticket cap":
        val orch = make_orchestrator()
        val sc = spawn_with_cspace(orch, scheduling_spec(), 21u64, 2000u64, 400u64)
        expect(sc.caps.has(_tickets())).to_equal(false)

    it "both minted C-Spaces are pledged (never ambient full)":
        val orch = make_orchestrator()
        val tk = spawn_with_cspace(orch, ticketing_spec(), 20u64, 1000u64, 300u64)
        val sc = spawn_with_cspace(orch, scheduling_spec(), 21u64, 2000u64, 400u64)
        expect(tk.caps.is_pledged).to_equal(true)
        expect(sc.caps.is_pledged).to_equal(true)

# ============================================================================
# Group 2 — Default is least-authority, NOT full()
# ============================================================================

describe "spawn_with_cspace: empty recipe = deny-all, not full()":
    """A spawn without explicit grants gets an EMPTY C-Space (no ambient authority)."""

    it "empty recipe yields a pledged, zero-token set":
        val orch = make_orchestrator()
        val empty_spec = SpawnSpec(image_hash: IMAGE_HASH, grants: [], isolation: "sandbox", budget: 0u64)
        val em = spawn_with_cspace(orch, empty_spec, 22u64, 3000u64, 500u64)
        expect(em.caps.caps.len()).to_equal(0)
        expect(em.caps.is_pledged).to_equal(true)

    it "empty C-Space denies every capability check":
        val orch = make_orchestrator()
        val empty_spec = SpawnSpec(image_hash: IMAGE_HASH, grants: [], isolation: "sandbox", budget: 0u64)
        val em = spawn_with_cspace(orch, empty_spec, 22u64, 3000u64, 500u64)
        expect(em.caps.has(_fwrite())).to_equal(false)
        expect(em.caps.has(CapabilityKind.ProcessSpawn)).to_equal(false)

    it "spawn_full() remains the explicit ambient (unpledged) boot marker":
        val full_caps = spawn_full()
        expect(full_caps.is_pledged).to_equal(false)

# ============================================================================
# Group 3 — Monotonic attenuation (narrow only)
# ============================================================================

describe "spawn_with_cspace: monotonic attenuation":
    """A child cannot gain a cap the parent lacks, nor widen the parent's rights."""

    it "child cannot gain a cap the parent does not hold":
        val calendar = _tok(_calendar_rw(), 2u64, 101u64, 2)
        val fwrite = _tok(_fwrite(), 3u64, 102u64, 2)
        val no_ticket_parent = CapabilitySet(caps: [calendar, fwrite], is_pledged: true)
        val m = spawn_with_cspace(no_ticket_parent, ticketing_spec(), 30u64, 5000u64, 600u64)
        expect(m.rejected).to_equal(1)
        expect(m.caps.caps.len()).to_equal(0)
        expect(m.caps.has(_tickets())).to_equal(false)

    it "child cannot widen rights the parent holds (read-only parent, rw request)":
        val ro_cal = _tok(_calendar_ro(), 2u64, 200u64, 2)
        val ro_parent = CapabilitySet(caps: [ro_cal], is_pledged: true)
        val widen_spec = SpawnSpec(
            image_hash: IMAGE_HASH,
            grants: [CapGrant(label: "mem.calendar", requested: _calendar_rw(), atten: atten_identity())],
            isolation: "sandbox",
            budget: 0u64
        )
        val mm = spawn_with_cspace(ro_parent, widen_spec, 31u64, 6000u64, 700u64)
        expect(mm.rejected).to_equal(1)
        expect(mm.caps.caps.len()).to_equal(0)
        expect(mm.caps.has(_calendar_rw())).to_equal(false)

    it "attenuation narrows rw -> r (write dropped) when parent holds rw":
        val orch = make_orchestrator()
        val narrow_spec = SpawnSpec(
            image_hash: IMAGE_HASH,
            grants: [CapGrant(label: "mem.calendar", requested: _calendar_rw(), atten: atten_rights(CAP_RIGHT_READ))],
            isolation: "sandbox",
            budget: 0u64
        )
        val mn = spawn_with_cspace(orch, narrow_spec, 32u64, 7000u64, 800u64)
        expect(mn.rejected).to_equal(0)
        expect(mn.caps.has(_calendar_ro())).to_equal(true)
        expect(mn.caps.has(_calendar_rw())).to_equal(false)

    it "delegated child token consumes a delegation-depth budget (parent 2 -> child 1)":
        val orch = make_orchestrator()
        val sc = spawn_with_cspace(orch, scheduling_spec(), 21u64, 2000u64, 400u64)
        expect(sc.caps.caps[0].depth).to_equal(1)

# ============================================================================
# Group 4 — fork = inherit-attenuated, never full
# ============================================================================

describe "fork_cspace: inherit-attenuated, never full":
    """Fork re-delegates the parent pouch at depth - 1; it never yields ambient authority."""

    it "fork of a role pouch keeps the authority but decrements depth":
        val orch = make_orchestrator()
        val tk = spawn_with_cspace(orch, ticketing_spec(), 20u64, 1000u64, 300u64)
        val fk = fork_cspace(tk.caps, 40u64, 9000u64, 900u64)
        expect(fk.caps.is_pledged).to_equal(true)
        expect(fk.caps.has(_tickets())).to_equal(true)
        expect(fk.caps.caps[0].depth).to_equal(0)

    it "fork of ambient full() does NOT propagate ambient authority":
        val fk_full = fork_cspace(spawn_full(), 41u64, 9500u64, 950u64)
        expect(fk_full.caps.is_pledged).to_equal(true)
        expect(fk_full.caps.caps.len()).to_equal(0)
        expect(fk_full.caps.has(CapabilityKind.ProcessSpawn)).to_equal(false)

# ============================================================================
# Group 5 — revoke_transitive on the parent kills the child's derived cap
# ============================================================================

describe "spawn_with_cspace: revocation liveness":
    """A revoke on the parent source cascades to the minted child C-Space."""

    it "revoke_transitive(parent source) removes the child's calendar cap":
        var mgr = CapabilityManager.new()
        val parent_task = TaskId(id: 1)
        val child_task = TaskId(id: 21)
        val orch = make_orchestrator()
        mgr.install_sandbox_capability_set(parent_task, orch)
        val sc = spawn_with_cspace(orch, scheduling_spec(), 21u64, 2000u64, 400u64)
        mgr.install_sandbox_capability_set(child_task, sc.caps)
        # Child holds the derived calendar cap before revocation.
        expect(mgr.check(child_task, _calendar_ro())).to_equal(true)
        # The child cap was derived from parent source token 101.
        val src_id = sc.source_token_ids[0]
        expect(src_id).to_equal(101u64)
        # Transitive revoke of the parent source cascades to the child.
        val n = mgr.revoke_transitive(src_id)
        expect(n).to_be_greater_than(0)
        expect(mgr.check(child_task, _calendar_ro())).to_equal(false)
