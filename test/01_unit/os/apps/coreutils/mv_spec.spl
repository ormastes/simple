"""
# coreutils/mv argument parsing
**Feature IDs:** #WAVE5-G9
**Category:** Userland coreutils
"""
use std.spec.*
use os.apps.coreutils.mv.{main_mv}

describe "mv argument parsing":
    """Argument handling paths."""

    it "zero args returns 1 (usage error)":
        """mv with nothing must error."""
        val rc = main_mv([])
        expect rc.to_equal(1i32)

    it "one arg returns 1 (usage error)":
        """mv SRC alone lacks a destination."""
        val rc = main_mv(["only_one"])
        expect rc.to_equal(1i32)

    it "two args returns an i32":
        """Happy-path signature."""
        val rc = main_mv(["src", "dst"])
        val is_int: bool = rc == 0i32 or rc != 0i32
        expect is_int.to_equal(true)
