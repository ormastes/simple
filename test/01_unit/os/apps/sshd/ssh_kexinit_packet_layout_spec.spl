# @cover src/os/apps/sshd/ssh_kex.spl
# RFC 4253 §6 binary-packet layout lock for the live sshd KEXINIT path.
#
# Regression trap for the live-lane corruption where the first payload byte
# reached the wire as 0x54 ('T') instead of 0x14 (SSH_MSG_KEXINIT) and the
# payload collapsed to the 62-byte skeleton (1 msg + 16 cookie + 10 empty
# name-list length fields + 1 bool + 4 reserved) because the ASCII-table
# text->bytes conversion silently dropped/shifted name-list characters.
# See doc/08_tracking/bug/simpleos_ssh_qemu_gate_uses_probe_service_not_sshd_2026-06-06.md
use std.spipe.*
use os.apps.sshd.ssh_kex.{ssh_build_kexinit_for_host_keys_and_certs}
use os.apps.sshd.ssh_kex_primitives.{HostKeySet, HostCertificateSet}
use os.apps.sshd.ssh_packet.{ssh_packet_build, ssh_get_u32, ssh_ascii_text_to_bytes, ssh_ascii_byte_to_text}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _ed25519_seed() -> [u8]:
    var seed: [u8] = []
    var i: u64 = 0
    while i < 32:
        seed.push((i + 1).to_u8())
        i = i + 1
    seed

fn _no_certs() -> HostCertificateSet:
    HostCertificateSet(
        ssh_ed25519_cert: nil,
        rsa_sha2_256_cert: nil,
        rsa_sha2_512_cert: nil
    )

fn _ed25519_keys() -> HostKeySet:
    HostKeySet(
        ed25519_seed: _ed25519_seed(),
        rsa_pkcs8: nil,
        rsa_public_blob: nil,
        ecdsa_p256_pkcs8: nil
    )

fn _rsa_only_keys() -> HostKeySet:
    HostKeySet(
        ed25519_seed: nil,
        rsa_pkcs8: [0x30, 0x82, 0x01, 0x02],
        rsa_public_blob: [0x00, 0x00, 0x00, 0x07],
        ecdsa_p256_pkcs8: nil
    )

fn _walk_kexinit_structure(payload: [u8]) -> u64:
    """Walk msg byte + 16-byte cookie + 10 name-lists + bool + reserved u32.

    Returns payload.len() when the structure closes exactly at the payload
    end; returns 0 for any truncation/overrun. A KEXINIT whose name-list
    contents were dropped or whose lengths are inconsistent cannot close
    exactly, so a nonzero return proves the name-lists are intact.
    """
    if payload.len() < 17:
        return 0
    var off: u64 = 17
    var lists: u64 = 0
    var bad = false
    while lists < 10:
        if off + 4 > payload.len():
            bad = true
            lists = 10
        else:
            val list_len = ssh_get_u32(payload, off).to_u64()
            off = off + 4 + list_len
            lists = lists + 1
    if bad:
        return 0
    # first_kex_packet_follows (1) + reserved uint32 (4)
    if off + 5 != payload.len():
        return 0
    payload.len()

val KEX_LIST: text = "curve25519-sha256,ext-info-s,kex-strict-s-v00@openssh.com"

describe "SSHD live KEXINIT payload (RFC 4253 §7.1)":
    it "emits SSH_MSG_KEXINIT 0x14 as payload byte 0 on the ed25519 live lane":
        val payload = ssh_build_kexinit_for_host_keys_and_certs(_ed25519_keys(), _no_certs())
        expect(_u8_at(payload, 0)).to_equal(0x14)
        # regression: live lane once emitted 0x54 ('T') here
        assert_not_equal(_u8_at(payload, 0), 0x54)

    it "keeps all ten name-lists intact behind the 16-byte cookie (ed25519 lane)":
        val payload = ssh_build_kexinit_for_host_keys_and_certs(_ed25519_keys(), _no_certs())
        # 62 bytes is the corrupt skeleton with every name-list content dropped
        expect(payload.len() > 62).to_equal(true)
        expect(_walk_kexinit_structure(payload)).to_equal(payload.len())
        # kex_algorithms starts right after cookie: length 57, first byte 'c'
        expect(ssh_get_u32(payload, 17).to_u64()).to_equal(57)
        expect(_u8_at(payload, 21)).to_equal(0x63)

    it "emits SSH_MSG_KEXINIT 0x14 with intact name-lists on the RSA live lane":
        val payload = ssh_build_kexinit_for_host_keys_and_certs(_rsa_only_keys(), _no_certs())
        expect(_u8_at(payload, 0)).to_equal(0x14)
        expect(_walk_kexinit_structure(payload)).to_equal(payload.len())
        # host key list = "rsa-sha2-256,rsa-sha2-512" (25 bytes), after kex list
        expect(ssh_get_u32(payload, 17 + 4 + 57).to_u64()).to_equal(25)
        expect(_u8_at(payload, 17 + 4 + 57 + 4)).to_equal(0x72)

    it "emits SSH_MSG_KEXINIT 0x14 with intact name-lists on the certificate path":
        val certs = HostCertificateSet(
            ssh_ed25519_cert: [0x01, 0x02, 0x03, 0x04],
            rsa_sha2_256_cert: nil,
            rsa_sha2_512_cert: nil
        )
        val payload = ssh_build_kexinit_for_host_keys_and_certs(_ed25519_keys(), certs)
        expect(_u8_at(payload, 0)).to_equal(0x14)
        expect(_walk_kexinit_structure(payload)).to_equal(payload.len())

describe "SSHD live KEXINIT binary packet (RFC 4253 §6)":
    it "frames the KEXINIT as uint32 length, padding byte, payload at offset 5":
        val payload = ssh_build_kexinit_for_host_keys_and_certs(_ed25519_keys(), _no_certs())
        val packet = ssh_packet_build(payload, 0)
        # uint32 packet_length covers everything after the length field
        expect(ssh_get_u32(packet, 0).to_u64()).to_equal(packet.len() - 4)
        # padding_length byte: at least 4 bytes of padding
        val padding_len = _u8_at(packet, 4).to_u64()
        expect(padding_len >= 4).to_equal(true)
        # payload byte 0 sits at offset 5 and is SSH_MSG_KEXINIT
        expect(_u8_at(packet, 5)).to_equal(0x14)
        # packet_length = 1 (padding byte) + payload + padding
        expect(packet.len()).to_equal(4 + 1 + payload.len() + padding_len)
        # pre-KEX block size: total length multiple of 8
        expect(packet.len() % 8).to_equal(0)

    it "preserves every payload byte between the header and the padding":
        val payload = ssh_build_kexinit_for_host_keys_and_certs(_ed25519_keys(), _no_certs())
        val packet = ssh_packet_build(payload, 0)
        var i: u64 = 0
        var mismatches: u64 = 0
        while i < payload.len():
            if _u8_at(packet, 5 + i) != _u8_at(payload, i):
                mismatches = mismatches + 1
            i = i + 1
        expect(mismatches).to_equal(0)

describe "SSH ASCII name-list text/byte conversion":
    it "converts the kex algorithm name-list losslessly":
        val bytes = ssh_ascii_text_to_bytes(KEX_LIST)
        expect(bytes.len()).to_equal(57)
        expect(_u8_at(bytes, 0)).to_equal(0x63)
        # '@' of kex-strict-s-v00@openssh.com
        expect(_u8_at(bytes, 45)).to_equal(0x40)

    it "round-trips every printable byte without shifting":
        # the historical corruption shifted bytes by +0x20 per table pass
        # (0x14 -> 0x34 -> 0x54); identity here locks the table offsets
        var b: u64 = 32
        var shifted: u64 = 0
        while b < 127:
            val txt = ssh_ascii_byte_to_text(b.to_u8())
            val back = ssh_ascii_text_to_bytes(txt)
            if back.len() != 1:
                shifted = shifted + 1
            elif back[0].to_u64() != b:
                shifted = shifted + 1
            b = b + 1
        expect(shifted).to_equal(0)

    it "does not map the non-printable SSH_MSG_KEXINIT byte to any character":
        expect(ssh_ascii_byte_to_text(0x14)).to_equal("")
