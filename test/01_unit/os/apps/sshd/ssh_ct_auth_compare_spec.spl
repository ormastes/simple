# Plan A3: constant-time auth comparison helpers in the SimpleOS sshd.
# Verifies _ct_bytes_equal and _payload_field_is_simpleos return the correct
# accept/reject decision for equal, unequal, and length-mismatched inputs
# (timing constancy is a property of the code shape, not observable here).

use std.spec.{describe, it, expect}
use os.apps.sshd.ssh_session_auth.{_ct_bytes_equal, _payload_field_is_simpleos}

describe "A3 constant-time byte comparison":
    it "returns true for equal byte arrays":
        expect(_ct_bytes_equal([1u8, 2u8, 3u8, 4u8], [1u8, 2u8, 3u8, 4u8])).to_equal(true)

    it "returns false when a single byte differs":
        expect(_ct_bytes_equal([1u8, 2u8, 3u8, 4u8], [1u8, 2u8, 9u8, 4u8])).to_equal(false)

    it "returns false when the first byte differs":
        expect(_ct_bytes_equal([9u8, 2u8, 3u8], [1u8, 2u8, 3u8])).to_equal(false)

    it "returns false on a length mismatch (shorter)":
        expect(_ct_bytes_equal([1u8, 2u8], [1u8, 2u8, 3u8])).to_equal(false)

    it "returns false on a length mismatch (longer)":
        expect(_ct_bytes_equal([1u8, 2u8, 3u8, 4u8], [1u8, 2u8, 3u8])).to_equal(false)

    it "returns true for two empty arrays":
        expect(_ct_bytes_equal([], [])).to_equal(true)

describe "A3 constant-time password-field match":
    it "matches the length-prefixed simpleos password at an offset":
        val payload: [u8] = [0xAA, 0, 0, 0, 8, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x6F, 0x73]
        expect(_payload_field_is_simpleos(payload, 1)).to_equal(true)

    it "rejects a wrong password byte":
        val payload: [u8] = [0xAA, 0, 0, 0, 8, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x6F, 0x74]
        expect(_payload_field_is_simpleos(payload, 1)).to_equal(false)

    it "rejects when the field runs past the payload end":
        val payload: [u8] = [0, 0, 0, 8, 0x73]
        expect(_payload_field_is_simpleos(payload, 1)).to_equal(false)

    it "rejects a wrong length prefix":
        val payload: [u8] = [0xAA, 0, 0, 0, 7, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x6F, 0x73]
        expect(_payload_field_is_simpleos(payload, 1)).to_equal(false)
