# SimpleOS Compiled Logic Test — All OS algorithms

fn check(name: text, v: bool):
    if v:
        print "OK: {name}"
    else:
        print "FAIL: {name}"

fn pfn_to_phys(pfn: i64) -> i64: pfn * 4096
fn phys_to_pfn(addr: i64) -> i64: addr / 4096
fn scancode_key(code: i64) -> i64:
    if code == 0x1E: return 1
    if code == 0x39: return 2
    if code == 0x1C: return 3
    if code == 0x01: return 4
    if code == 0x0E: return 5
    0
fn pci_addr(bus: i64, dev: i64, func: i64, off: i64) -> i64:
    (1 << 31) | (bus << 16) | (dev << 11) | (func << 8) | (off & 0xFC)
fn cluster_sec(c: i64, s: i64, spc: i64) -> i64: s + (c - 2) * spc
fn is_eoc(e: i64) -> bool: e >= 0x0FFFFFF8
fn color_argb(r: i64, g: i64, b: i64, a: i64) -> i64:
    ((a & 0xFF) << 24) | ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF)

fn main():
    print "=== SimpleOS Compiled Logic Test ==="
    check("pfn 42", pfn_to_phys(42) == 172032)
    check("pfn 0", pfn_to_phys(0) == 0)
    check("pfn rev", phys_to_pfn(172032) == 42)
    check("pfn round", phys_to_pfn(pfn_to_phys(100)) == 100)
    check("scan A", scancode_key(0x1E) == 1)
    check("scan Space", scancode_key(0x39) == 2)
    check("scan Enter", scancode_key(0x1C) == 3)
    check("scan Esc", scancode_key(0x01) == 4)
    check("scan Unk", scancode_key(0xFF) == 0)
    val a = pci_addr(1, 2, 3, 0x10)
    check("PCI en", (a >> 31) == 1)
    check("PCI bus", ((a >> 16) & 0xFF) == 1)
    check("PCI dev", ((a >> 11) & 0x1F) == 2)
    check("PCI fn", ((a >> 8) & 7) == 3)
    check("clust 2", cluster_sec(2, 100, 8) == 100)
    check("clust 3", cluster_sec(3, 100, 8) == 108)
    check("eoc y", is_eoc(0x0FFFFFF8))
    check("eoc n", not is_eoc(2))
    check("black", color_argb(0, 0, 0, 255) == 0xFF000000)
    check("white", color_argb(255, 255, 255, 255) == 0xFFFFFFFF)
    check("W^X", (1 | 2 | 4 | 32) == 39)
    check("mmio", (1 | 2 | 8 | 16 | 32) == 59)
    check("shift", (1 << 31) != 0)
    check("AND", (0xFF & 0x0F) == 0x0F)
    check("OR", (0x55 | 0xAA) == 0xFF)
    print "=== DONE ==="
