# Whirlpool ISO/IEC 10118-3 Known-Answer Test Vectors
#
# Tests whirlpool() against two standard reference vectors:
#   whirlpool("") = 19FA61D75522A4669B44E39C1D2E1726...
#   whirlpool("a") = 8ACA2602792AEC6F11A67206531FB7D7...
#
# Only first 16 hex chars (8 bytes) compared to keep interpreter runtime short.
#
# Reference: Barreto & Rijmen, "The Whirlpool Hashing Function" (2003).
#            ISO/IEC 10118-3:2004 section 13.

use std.spipe.*
use os.crypto.whirlpool.{whirlpool}

# ============================================================================
# Test data helpers — module-level to avoid it-block var-mutation footgun
# ============================================================================

fn _empty_bytes() -> [u8]:
    var buf: [u8] = []
    buf

fn _a_bytes() -> [u8]:
    var buf: [u8] = []
    val b: u8 = 0x61
    buf.push(b)
    buf

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_to_hex(b: [u8], count: i64) -> text:
    """Convert first `count` bytes to lowercase hex string."""
    var s: text = ""
    var i: u64 = 0
    while i < count.to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _whirlpool_empty_first8() -> text:
    val digest = whirlpool(_empty_bytes())
    _bytes_to_hex(digest, 8)

fn _whirlpool_a_first8() -> text:
    val digest = whirlpool(_a_bytes())
    _bytes_to_hex(digest, 8)

fn _whirlpool_empty_len() -> i64:
    val digest = whirlpool(_empty_bytes())
    digest.len().to_i64()

# ============================================================================
# KAT specs
# ============================================================================

describe "Whirlpool ISO/IEC 10118-3 known-answer vectors":

    it "whirlpool(\"\") first 8 bytes = 19fa61d75522a466":
        expect(_whirlpool_empty_first8()).to_equal("19fa61d75522a466")

    it "whirlpool(\"a\") first 8 bytes = 8aca2602792aec6f":
        expect(_whirlpool_a_first8()).to_equal("8aca2602792aec6f")

    it "whirlpool output length is 64 bytes":
        expect(_whirlpool_empty_len()).to_equal(64)
