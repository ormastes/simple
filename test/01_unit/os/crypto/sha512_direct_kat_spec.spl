use std.spipe.*
use os.crypto.sha512.{sha512}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _hex(data: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < data.len():
        val b = data[i]
        out = out + _hex_nibble((b >> 4) & 0x0f)
        out = out + _hex_nibble(b & 0x0f)
        i = i + 1
    out

describe "os.crypto.sha512 direct KAT":
    it "matches SHA-512 empty":
        expect(_hex(sha512([]))).to_equal("cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")

    it "matches SHA-512 abc":
        expect(_hex(sha512([0x61, 0x62, 0x63]))).to_equal("ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f")
