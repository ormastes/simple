use std.spec.*
use app.io.mod.{file_read}

describe "SimpleOS production desktop render entry":
    it "boots validated dynamic scanout into persistent Engine2D shared shell rendering":
        val src = file_read("examples/09_embedded/simple_os/arch/x86_64/gui_entry_desktop.spl")
        expect(src).to_contain("bga_init_scanout")
        expect(src).to_contain("mmio_disable_test_mode()")
        expect(src).to_contain("scanout_evidence_is_valid(scanout)")
        expect(src).to_contain("pitch: scanout.stride")
        expect(src).to_contain("var engine = create_fb_engine(fb)")
        expect(src).to_contain("shell.launch_app_baremetal(\"Terminal\")")
        expect(src).to_contain("shell.launch_app_baremetal(\"Editor\")")
        expect(src).to_contain("shell.launch_app_baremetal(\"Calculator\")")
        expect(src).to_contain("surface.process_id > 0 and surface.app_id != \"\"")
        expect(src).to_contain("[production-readiness-failed]")
        expect(src).to_contain("port_outb(0xF4, 1)")
        expect(src).to_contain("shell.init()")
        expect(src).to_contain("shell.run_baremetal(engine)")
        expect(src).to_contain("[production-readiness]")
        expect(src.contains("val FB_W:")).to_equal(false)
        expect(src.contains("val DIRECT_QEMU_TOTAL_MEMORY:")).to_equal(false)
        expect(src.contains("shared_mdi")).to_equal(false)
        expect(src.contains("create_window(")).to_equal(false)
        expect(src.contains("update_window_content(")).to_equal(false)
        expect(src.contains("shell.run()")).to_equal(false)

    it "routes WM Simple Web evidence through the production desktop entry":
        val src = file_read("src/os/_QemuRunner/runner_targets.spl")
        expect(src).to_contain("entry: \"examples/09_embedded/simple_os/arch/x86_64/gui_entry_desktop.spl\"")
