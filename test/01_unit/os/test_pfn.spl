fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn pfn2phys(p: i64) -> i64: p * 4096
fn phys2pfn(a: i64) -> i64: a / 4096
fn main():
    print "=== PageFrame ==="
    check("42→172032", pfn2phys(42) == 172032)
    check("0→0", pfn2phys(0) == 0)
    check("rev 42", phys2pfn(172032) == 42)
    check("round 100", phys2pfn(pfn2phys(100)) == 100)
    check("round 1M", phys2pfn(pfn2phys(1000000)) == 1000000)
    check("4GB", pfn2phys(1048576) == 4294967296)
    print "=== DONE ==="
