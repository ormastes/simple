use std.spec
use os.desktop.shell.{DesktopShell}
use os.compositor.compositor.{Compositor}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.input_backend.{InputBackend}
use os.drivers.input.ps2_keyboard.{KeyEvent, Key}
use os.drivers.input.ps2_mouse.{MouseEvent}
use os.services.launcher.launcher.{launcher_init}

class SilentInputBackend:
    _unused: bool

impl InputBackend for SilentInputBackend:
    me poll_key() -> KeyEvent?:
        nil

    me poll_mouse() -> MouseEvent?:
        nil

    fn alt_held() -> bool:
        false

    fn shift_held() -> bool:
        false

    fn ctrl_held() -> bool:
        false

    fn key_to_char(key: Key) -> text?:
        nil

impl SilentInputBackend:
    static fn new() -> SilentInputBackend:
        SilentInputBackend(_unused: false)

fn _make_test_shell() -> DesktopShell:
    val backend = BrowserCompositorBackend.new(800, 600)
    val input = SilentInputBackend.new()
    val compositor = Compositor.with_backends(backend, input, 800, 600)
    var shell = DesktopShell.new(compositor)
    shell.set_task_reaper_enabled(false)
    shell

describe "DesktopShell live WM runtime loop wiring":
    it "consumes pending compositor pointer steps through the SimpleOS WM bridge":
        launcher_init()
        var shell = _make_test_shell()
        val first = shell.compositor.create_window("One", 10, 40, 300, 200)
        val second = shell.compositor.create_window("Two", 80, 120, 300, 200)
        shell.compositor.set_window_identity(first, 42, "demo.one")
        shell.compositor.set_window_identity(second, 43, "demo.two")

        shell.compositor.note_pending_wm_pointer_step(90, 125, "left", "down")
        shell.handle_pending_wm_pointer_step()

        expect(shell.compositor.has_pending_wm_pointer_step()).to_equal(false)
        expect(shell.last_wm_loop_marker).to_contain("[simpleos-wm] loop-step command=window_drag_begin")
        expect(shell.last_wm_loop_marker).to_contain("window={second}")
        expect(shell.wm_runtime_state.focused_window_id).to_equal("{second}")
        expect(shell.wm_runtime_state.dragging_surface_id).to_equal("{second}")
        expect(shell.compositor.dragging).to_equal(true)
        expect(shell.compositor.drag_window_id).to_equal(second)

    it "routes live taskbar running-window clicks through shared focus state":
        launcher_init()
        var shell = _make_test_shell()
        val first = shell.compositor.create_window("One", 10, 40, 300, 200)
        val second = shell.compositor.create_window("Two", 80, 120, 300, 200)
        shell.compositor.set_window_identity(first, 42, "demo.one")
        shell.compositor.set_window_identity(second, 43, "demo.two")

        val marker = shell.handle_wm_pointer_event_loop_step(360, 575, "left", "down")

        expect(marker).to_contain("command=window_focus")
        expect(shell.wm_runtime_state.focused_window_id).to_equal("{second}")
        expect(shell.compositor.surfaces[shell.compositor.surfaces.len() - 1].id).to_equal(second)
