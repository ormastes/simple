# Feature: SimpleOS WM pointer step decode parity [C23]
# Category: OS / Desktop Shell
# Status: Implemented
#
# Compile-only smoke spec for the pure decode helpers extracted from
# handle_pending_wm_pointer_step (shell.spl): wm_pointer_button_from_code
# and wm_pointer_kind_from_code. Producer side lives in compositor.spl's
# _handle_input_ps2 / _ps2_wm_pointer_button_code (PS/2 status byte
# bits 0/1/2) — this spec covers the decode contract only, matching the
# convention of test/01_unit/app/ui.chromium/input_translation_spec.spl.

use os.desktop.shell.{wm_pointer_button_from_code, wm_pointer_kind_from_code}

describe "SimpleOS WM pointer step — button code decode":

    it "decodes 0 to none":
        expect(wm_pointer_button_from_code(0)).to_equal("none")

    it "decodes 1 to left (pre-existing value, must be unchanged)":
        expect(wm_pointer_button_from_code(1)).to_equal("left")

    it "decodes 2 to middle":
        expect(wm_pointer_button_from_code(2)).to_equal("middle")

    it "decodes 3 to right":
        expect(wm_pointer_button_from_code(3)).to_equal("right")

    it "decodes an unknown button code to none":
        expect(wm_pointer_button_from_code(7)).to_equal("none")

describe "SimpleOS WM pointer step — kind code decode":

    it "decodes 0 to none":
        expect(wm_pointer_kind_from_code(0)).to_equal("none")

    it "decodes 1 to down (pre-existing value, must be unchanged)":
        expect(wm_pointer_kind_from_code(1)).to_equal("down")

    it "decodes 2 to up":
        expect(wm_pointer_kind_from_code(2)).to_equal("up")

    it "decodes 3 to move":
        expect(wm_pointer_kind_from_code(3)).to_equal("move")

    it "decodes an unknown kind code to none":
        expect(wm_pointer_kind_from_code(9)).to_equal("none")

describe "SimpleOS WM pointer step — left-down regression (exact pre-fix pair)":

    it "still decodes the original (1, 1) pair to (left, down)":
        expect(wm_pointer_button_from_code(1)).to_equal("left")
        expect(wm_pointer_kind_from_code(1)).to_equal("down")
