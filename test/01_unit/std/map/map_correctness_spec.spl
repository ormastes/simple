# Map Correctness - Parser-Safe Local Coverage
#
# This spec preserves the intent of the original map correctness checks at a
# smaller scale using a self-contained local harness.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn check_text(actual: text, expected: text):
    expect(actual).to_equal(expected)

class MiniEntry:
    key: text
    value: i64
    bucket: i64

class MiniMap:
    capacity: i64
    buckets: [i64]
    items: [MiniEntry]

    static fn zero_counts(capacity: i64) -> [i64]:
        var counts: [i64] = []
        for _ in 0..capacity:
            counts = counts + [0]
        counts

    static fn new() -> MiniMap:
        MiniMap(capacity: 4, buckets: MiniMap.zero_counts(4), items: [])

    static fn with_capacity(capacity: i64) -> MiniMap:
        var actual = capacity
        if actual < 2:
            actual = 2
        MiniMap(capacity: actual, buckets: MiniMap.zero_counts(actual), items: [])

    static fn bump_count(counts: [i64], bucket: i64) -> [i64]:
        var updated: [i64] = []
        var index = 0
        for count in counts:
            if index == bucket:
                updated = updated + [count + 1]
            else:
                updated = updated + [count]
            index = index + 1
        updated

    static fn decrement_count(counts: [i64], bucket: i64) -> [i64]:
        var updated: [i64] = []
        var index = 0
        for count in counts:
            if index == bucket:
                updated = updated + [count - 1]
            else:
                updated = updated + [count]
            index = index + 1
        updated

    fn len() -> i64:
        self.items.len()

    fn is_empty() -> bool:
        self.items.len() == 0

    fn index_of(key: text) -> i64:
        var found = -1
        var index = 0
        for entry in self.items:
            if entry.key == key:
                found = index
            index = index + 1
        found

    fn rebucket_to(new_capacity: i64):
        self.capacity = new_capacity
        var counts = MiniMap.zero_counts(new_capacity)
        var updated: [MiniEntry] = []
        var index = 0
        for entry in self.items:
            val bucket = index % new_capacity
            counts = MiniMap.bump_count(counts, bucket)
            updated = updated + [MiniEntry(key: entry.key, value: entry.value, bucket: bucket)]
            index = index + 1
        self.items = updated
        self.buckets = counts

    fn maybe_grow():
        val next_size = self.items.len() + 1
        if next_size > (self.capacity * 3 / 4):
            self.rebucket_to(self.capacity * 2)

    fn insert(key: text, value: i64):
        val index = self.index_of(key)
        if index == -1:
            self.maybe_grow()
            val bucket = self.items.len() % self.capacity
            self.items = self.items + [MiniEntry(key: key, value: value, bucket: bucket)]
            self.buckets = MiniMap.bump_count(self.buckets, bucket)
        else:
            var updated: [MiniEntry] = []
            var i = 0
            for entry in self.items:
                if i == index:
                    updated = updated + [MiniEntry(key: entry.key, value: value, bucket: entry.bucket)]
                else:
                    updated = updated + [entry]
                i = i + 1
            self.items = updated

    fn get(key: text) -> Option<i64>:
        val index = self.index_of(key)
        if index == -1:
            None
        else:
            Some(self.items[index].value)

    fn has(key: text) -> bool:
        self.index_of(key) != -1

    fn remove(key: text) -> Option<i64>:
        val index = self.index_of(key)
        if index == -1:
            None
        else:
            var removed = Some(self.items[index].value)
            var updated: [MiniEntry] = []
            var i = 0
            for entry in self.items:
                if i != index:
                    updated = updated + [entry]
                else:
                    self.buckets = MiniMap.decrement_count(self.buckets, entry.bucket)
                i = i + 1
            self.items = updated
            removed

    fn clear():
        self.items = []
        self.buckets = MiniMap.zero_counts(self.capacity)

    fn keys() -> [text]:
        var values: [text] = []
        for entry in self.items:
            values = values + [entry.key]
        values

    fn values() -> [i64]:
        var values: [i64] = []
        for entry in self.items:
            values = values + [entry.value]
        values

    fn entries() -> [MiniEntry]:
        var values: [MiniEntry] = []
        for entry in self.items:
            values = values + [entry]
        values

    fn copy_items() -> [MiniEntry]:
        var values: [MiniEntry] = []
        for entry in self.items:
            values = values + [entry]
        values

    fn copy_counts() -> [i64]:
        var counts: [i64] = []
        for count in self.buckets:
            counts = counts + [count]
        counts

    fn clone() -> MiniMap:
        MiniMap(capacity: self.capacity, buckets: self.copy_counts(), items: self.copy_items())

fn sum_counts(counts: [i64]) -> i64:
    var total = 0
    for count in counts:
        total = total + count
    total

describe "Map correctness":
    it "creates an empty map":
        val map = MiniMap.new()
        check(map.is_empty())
        check(map.len() == 0)
        check(map.capacity == 4)

    it "inserts and retrieves entries":
        var map = MiniMap.new()
        map.insert("key", 42)
        check(not map.is_empty())
        check(map.len() == 1)
        check(map.get("key") == Some(42))
        check(map.has("key"))

    it "updates an existing key without duplicating it":
        var map = MiniMap.new()
        map.insert("key", 1)
        map.insert("key", 2)
        check(map.len() == 1)
        check(map.get("key") == Some(2))

    it "returns None for a missing key":
        val map = MiniMap.new()
        check(map.get("missing") == None)
        check(not map.has("missing"))

    it "removes entries and keeps other entries intact":
        var map = MiniMap.new()
        map.insert("a", 1)
        map.insert("b", 2)
        map.insert("c", 3)

        val removed = map.remove("b")
        check(removed == Some(2))
        check(map.len() == 2)
        check(map.get("a") == Some(1))
        check(map.get("b") == None)
        check(map.get("c") == Some(3))

    it "clears all entries":
        var map = MiniMap.new()
        map.insert("a", 1)
        map.insert("b", 2)
        map.clear()

        check(map.is_empty())
        check(map.len() == 0)
        check(map.get("a") == None)
        check(sum_counts(map.buckets) == 0)

    it "returns keys values and entries in insertion order":
        var map = MiniMap.new()
        map.insert("a", 1)
        map.insert("b", 2)

        val keys = map.keys()
        val values = map.values()
        val entries = map.entries()

        check(keys.len() == 2)
        check_text(keys[0], "a")
        check_text(keys[1], "b")
        check(values.len() == 2)
        check(values[0] == 1)
        check(values[1] == 2)
        check(entries.len() == 2)
        check_text(entries[0].key, "a")
        check(entries[0].value == 1)
        check_text(entries[1].key, "b")
        check(entries[1].value == 2)

    it "grows capacity when the load threshold is exceeded":
        var map = MiniMap.with_capacity(4)
        val initial_capacity = map.capacity
        map.insert("a", 1)
        map.insert("bb", 2)
        map.insert("ccc", 3)
        map.insert("dddd", 4)

        check(map.capacity == initial_capacity * 2)
        check(map.len() == 4)
        check(map.get("a") == Some(1))
        check(map.get("bb") == Some(2))
        check(map.get("ccc") == Some(3))
        check(map.get("dddd") == Some(4))

    it "clones independently":
        var original = MiniMap.new()
        original.insert("a", 1)
        original.insert("b", 2)

        val copy = original.clone()
        original.insert("c", 3)

        check(original.len() == 3)
        check(copy.len() == 2)
        check(copy.get("c") == None)
        check(copy.get("a") == Some(1))
        check(copy.get("b") == Some(2))

    it "tracks bucket counts for inserted entries":
        var map = MiniMap.with_capacity(4)
        map.insert("a", 1)
        map.insert("bb", 2)
        map.insert("ccc", 3)
        map.insert("dddd", 4)

        check(sum_counts(map.buckets) == 4)
        check(map.buckets.len() == map.capacity)
        check(map.capacity >= 4)

    it "handles special and unicode keys":
        var map = MiniMap.new()
        map.insert("key\nwith\nnewlines", 1)
        map.insert("key\twith\ttabs", 2)
        map.insert("héllo", 3)

        check(map.get("key\nwith\nnewlines") == Some(1))
        check(map.get("key\twith\ttabs") == Some(2))
        check(map.get("héllo") == Some(3))
