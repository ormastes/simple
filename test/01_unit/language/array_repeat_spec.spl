describe "array repeat [value; count]":
    it "const count builds an array of the right length":
        val zeros: [u32] = [0u32; 16]
        expect(zeros.len()).to_equal(16)

    it "const count fills every element with the repeated value":
        val zeros: [u32] = [0u32; 16]
        expect(zeros[0]).to_equal(0u32)
        expect(zeros[7]).to_equal(0u32)
        expect(zeros[15]).to_equal(0u32)

    it "const count repeats a non-zero i64 value":
        val sevens = [7; 4]
        expect(sevens.len()).to_equal(4)
        expect(sevens[0]).to_equal(7)
        expect(sevens[3]).to_equal(7)

    it "dynamic count uses the runtime helper":
        val n = 5
        val v = 9
        val arr = [v; n]
        expect(arr.len()).to_equal(5)
        expect(arr[0]).to_equal(9)
        expect(arr[4]).to_equal(9)

    it "dynamic count of zero yields an empty array":
        val n = 0
        val arr = [3; n]
        expect(arr.len()).to_equal(0)
