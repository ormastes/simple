# Test: yes tool
# Feature: TOOL-YES - Repeatedly output string
# @cover tools/shell/yes/yes_tool.spl

describe "yes tool":
    context "default output":
        it "outputs y by default":
            val default_msg = "y"
            expect(default_msg).to_equal("y")

    context "custom string":
        it "outputs custom message":
            val msg = "hello"
            expect(msg).to_equal("hello")
