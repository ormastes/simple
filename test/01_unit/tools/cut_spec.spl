# Test: cut tool
# Feature: TOOL-CUT - Remove sections from lines
#
# Local reimplementation of cut functions to avoid interpreter-mode issues
# (importing app.tools.cut.main fails because parse_ranges uses .to_int()
# which triggers "cannot convert enum to int" in interpreter mode)

fn parse_ranges(spec: text) -> [(i64, i64)]:
    """Parse a field/char specification like '1,3,5-7' into ranges."""
    var ranges: [(i64, i64)] = []
    val parts = spec.split(",")
    for part in parts:
        val trimmed = part.trim()
        val dash_parts = trimmed.split("-")
        if dash_parts.len() >= 2:
            val start_str = dash_parts[0]
            val end_str = dash_parts[1]
            var start_val = 1
            var end_val = 999999
            if start_str.len() > 0:
                start_val = int(start_str)
            if end_str.len() > 0:
                end_val = int(end_str)
            ranges.push((start_val, end_val))
        else:
            val num = int(trimmed)
            ranges.push((num, num))
    ranges

fn is_in_ranges(pos: i64, ranges: [(i64, i64)]) -> bool:
    """Check if position is within any range (1-based)."""
    for range in ranges:
        if pos >= range.0 and pos <= range.1:
            return true
    false

fn cut_fields(line: text, ranges: [(i64, i64)], delimiter: text, suppress: bool) -> text:
    """Extract fields from line based on ranges."""
    val parts = line.split(delimiter)
    if parts.len() <= 1 and suppress:
        return ""
    var result: [text] = []
    var pos = 1
    for part in parts:
        if is_in_ranges(pos, ranges):
            result.push(part)
        pos = pos + 1
    result.join(delimiter)

fn cut_chars(line: text, ranges: [(i64, i64)]) -> text:
    """Extract characters from line based on ranges."""
    var result = ""
    var pos = 1
    val chars = line.split("")
    for ch in chars:
        if ch.len() > 0:
            if is_in_ranges(pos, ranges):
                result = result + ch
            pos = pos + 1
    result

describe "cut tool":
    context "range parsing":
        it "parses single field":
            val ranges = parse_ranges("2")
            expect(ranges.len()).to_equal(1)
            expect(ranges[0].0).to_equal(2)
            expect(ranges[0].1).to_equal(2)

        it "parses field range":
            val ranges = parse_ranges("1-3")
            expect(ranges.len()).to_equal(1)
            expect(ranges[0].0).to_equal(1)
            expect(ranges[0].1).to_equal(3)

        it "parses multiple fields":
            val ranges = parse_ranges("1,3,5")
            expect(ranges.len()).to_equal(3)

    context "range checking":
        it "detects position in range":
            val ranges = [(1, 3)]
            expect(is_in_ranges(2, ranges)).to_equal(true)

        it "rejects position outside range":
            val ranges = [(1, 3)]
            expect(is_in_ranges(5, ranges)).to_equal(false)

    context "field cutting":
        it "extracts single field with tab delimiter":
            val result = cut_fields("a\tb\tc", [(2, 2)], "\t", false)
            expect(result).to_equal("b")

        it "extracts field range":
            val result = cut_fields("a\tb\tc\td", [(2, 3)], "\t", false)
            expect(result).to_equal("b\tc")

    context "character cutting":
        it "extracts characters by position":
            val result = cut_chars("hello", [(1, 3)])
            expect(result).to_equal("hel")

        it "extracts single character":
            val result = cut_chars("hello", [(2, 2)])
            expect(result).to_equal("e")
