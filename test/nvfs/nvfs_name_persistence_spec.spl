# NVFS Name Table Persistence Specification
#
# Verifies that NvfsPosixDriver persists the name→arena mapping to NVMe
# sectors so files can be found after a simulated remount.
#
# Run: bin/simple test test/nvfs/nvfs_name_persistence_spec.spl

use std.spec
use std.fs_driver.types.{Path, OpenFlags, MountOptions}
use std.fs_driver.nvfs_posix_driver.{NvfsPosixDriver}
use os.port.cached_raw_image_block_device.{CachedRawImageBlockDevice}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_bytes_alloc(len: i64) -> [u8]

struct RemountResult:
    file_found:  bool
    read_ok:     bool
    read_n:      i64
    first_byte:  u8

fn _make_persist_device() -> CachedRawImageBlockDevice:
    val root = "/tmp/nvfs_name_persistence_spec"
    val _ = rt_dir_create_all(root)
    val img = rt_bytes_alloc(131072)
    val _ = rt_file_write_bytes(root + "/disk.img", img)
    val r = CachedRawImageBlockDevice.from_bytes(root + "/disk.img", img, 512u32)
    r.unwrap()

fn _do_write_remount_read(dev: CachedRawImageBlockDevice) -> RemountResult:
    val _ = dev
    var drv1 = NvfsPosixDriver.new("remount-1")
    val _ = drv1.mount(MountOptions.default())
    val flags = OpenFlags.write_only().with_append().with_create()
    val open1 = drv1.open(Path(raw: "/data.bin"), flags)
    if open1.is_err():
        return RemountResult(file_found: false, read_ok: false, read_n: -1, first_byte: 0u8)
    val fh1 = open1.unwrap()
    val payload: [u8] = [0xAB, 0xCD, 0xEF]
    val _ = drv1.write(fh1, 0, payload)
    val _ = drv1.close(fh1)
    val _ = drv1.unmount()
    var drv2 = NvfsPosixDriver.new("remount-2")
    val _ = drv2.mount(MountOptions.default())
    val stat_r = drv2.stat(Path(raw: "/data.bin"))
    if stat_r.is_err():
        return RemountResult(file_found: false, read_ok: false, read_n: -1, first_byte: 0u8)
    val open2 = drv2.open(Path(raw: "/data.bin"), OpenFlags.read_only())
    if open2.is_err():
        return RemountResult(file_found: false, read_ok: false, read_n: -1, first_byte: 0u8)
    val fh2 = open2.unwrap()
    val rbuf = rt_bytes_alloc(3)
    val rr = drv2.read(fh2, 0, rbuf)
    val _ = drv2.close(fh2)
    if rr.is_err():
        return RemountResult(file_found: true, read_ok: false, read_n: -1, first_byte: 0u8)
    val rn = rr.unwrap()
    val fb = if rbuf.len() > 0: rbuf[0] else: 0u8
    RemountResult(file_found: true, read_ok: true, read_n: rn, first_byte: fb)

fn _do_multi_file_remount(dev: CachedRawImageBlockDevice) -> i64:
    val _ = dev
    var drv1 = NvfsPosixDriver.new("multi-1")
    val _ = drv1.mount(MountOptions.default())
    val flags = OpenFlags.write_only().with_append().with_create()
    val _ = drv1.open(Path(raw: "/a.txt"), flags)
    val _ = drv1.open(Path(raw: "/b.txt"), flags)
    val _ = drv1.open(Path(raw: "/c.txt"), flags)
    val _ = drv1.unmount()
    var drv2 = NvfsPosixDriver.new("multi-2")
    val _ = drv2.mount(MountOptions.default())
    var found: i64 = 0
    if drv2.stat(Path(raw: "/a.txt")).is_ok():
        found = found + 1
    if drv2.stat(Path(raw: "/b.txt")).is_ok():
        found = found + 1
    if drv2.stat(Path(raw: "/c.txt")).is_ok():
        found = found + 1
    found

describe "NvfsPosixDriver name table persistence":

    it "file created on first mount survives remount":
        var dev = _make_persist_device()
        val res = _do_write_remount_read(dev)
        expect(res.file_found).to_equal(true)
        expect(res.read_ok).to_equal(true)
        expect(res.read_n).to_equal(3)
        expect(res.first_byte).to_equal(0xABu8)

    it "multiple files persist across remount":
        var dev = _make_persist_device()
        val found = _do_multi_file_remount(dev)
        expect(found).to_equal(3)
