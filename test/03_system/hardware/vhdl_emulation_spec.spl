# @tag:system
#
# Portable smoke for VHDL emulation contracts.

use std.spec.*

describe "VHDL emulation portable smoke":
    it "records simulator phases":
        val phases = ["elaborate", "simulate", "compare"]
        expect(phases.len()).to_equal(3)
        expect(phases[1]).to_equal("simulate")

    it "records signal value shape":
        val signal_name = "clk"
        val value = "1"
        expect(signal_name).to_equal("clk")
        expect(value).to_equal("1")

    it "records backend name":
        val backend = "vhdl"
        expect(backend).to_equal("vhdl")
