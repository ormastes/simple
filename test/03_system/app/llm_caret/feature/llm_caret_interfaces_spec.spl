# @cover src/app/llm_caret/provider.spl 80%
# @cover src/app/llm_caret/gui.spl 80%

use app.llm_caret.provider.{LLMResponse, dispatch_send}
use app.llm_caret.interface_text.{caret_turn_line}
use app.llm_caret.gui.{caret_gui_html, caret_gui_prompt,
    caret_gui_json_content, caret_gui_json_error}

fn _dummy(prompt: text) -> LLMResponse:
    dispatch_send("dummy", prompt, "", "", "", "", "", "", 0, 0, "[]")

describe "LLM Caret CLI, TUI, and GUI interfaces":
    it "REQ-001 CLI dispatch returns hello from dummy":
        val response = _dummy("test")
        expect(response.provider).to_equal("dummy")
        expect(response.content).to_equal("hello")

    it "REQ-002 TUI formats the dummy response as an assistant turn":
        val response = _dummy("test")
        expect(caret_turn_line("assistant", response.content)).to_equal("Assistant: hello")

    it "REQ-003 GUI exposes semantic chat controls":
        val page = caret_gui_html()
        expect(page).to_contain("aria-label=\"LLM Caret chat\"")
        expect(page).to_contain("id=\"prompt\"")
        expect(page).to_contain("id=\"send\"")

    it "REQ-004 GUI sends a prompt through the same dummy provider":
        val prompt = caret_gui_prompt("{\"content\":\"test\"}")
        val response = caret_gui_json_content(_dummy(prompt).content)
        expect(response).to_contain("hello")

    it "REQ-005 GUI rejects blank messages":
        val prompt = caret_gui_prompt("{\"content\":\"\"}")
        val response = caret_gui_json_error("message required")
        expect(prompt).to_equal("")
        expect(response).to_contain("message required")
