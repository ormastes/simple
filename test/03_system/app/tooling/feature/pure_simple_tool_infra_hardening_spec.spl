# codex-system-test
"""
# Pure-Simple Tool and Infrastructure Hardening

## Overview

Qualifies the production Simple runtime and the developer-tool trust chain.
The scenarios fail closed when the deployed runtime is a seed, a test result is
greenwashed, CLI-controlled paths cross a shell, or launchers select source or
debug fallbacks.

**Requirements:** REQ-001 through REQ-015
**Plan:** doc/03_plan/sys_test/pure_simple_tool_infra_hardening.md
**Design:** doc/05_design/pure_simple_tool_infra_hardening.md
**Research:** doc/01_research/local/pure_simple_tool_infra_hardening.md
"""

use std.spec.*
use std.io_runtime.{env_get}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

fn qualification_binary() -> text:
    val configured = env_get("SIMPLE_BINARY")
    if configured != nil and configured != "":
        return configured
    "bin/simple"

fn qualification_runtime_identity() -> text:
    val (out, err, code) = rt_process_run(qualification_binary(), ["--version"])
    val identity = out + err
    if code != 0:
        return "unrunnable"
    if identity.contains("bootstrap seed") or identity.contains("Rust-built"):
        return "seed"
    if identity.contains("debug"):
        return "debug"
    "pure-simple"

fn qualification_run_command(args: [text], timeout_ms: i64) -> (text, text, i32, i64):
    val start = rt_time_now_unix_micros()
    val (out, err, code) = rt_process_run_timeout(qualification_binary(), args, timeout_ms)
    val elapsed_ms = (rt_time_now_unix_micros() - start) / 1000
    (out, err, code, elapsed_ms)

fn qualification_exit_class(code: i32) -> text:
    if code == 0: return "pass"
    if code == 1: return "assertion_failure"
    if code == 2: return "usage_error"
    if code == 3: return "internal_error"
    if code == 4: return "empty_discovery"
    if code == 124 or code == -1: return "timeout_resource"
    "unknown"

fn qualification_source_contract(path: text, required: [text], forbidden: [text]) -> text:
    val source = rt_file_read_text(path)
    if source == "":
        return "missing"
    for marker in required:
        if not source.contains(marker):
            return "missing-required:{marker}"
    for marker in forbidden:
        if source.contains(marker):
            return "forbidden:{marker}"
    "safe"

fn qualification_hostile_path_probe() -> text:
    val root = "build/qualification-duplicate;touch build/qualification-pwned #"
    val sentinel = "build/qualification-pwned"
    val setup = "rm -rf '" + root + "' '" + sentinel + "'; mkdir -p '" + root + "'; printf 'fn alpha(): 1\nfn beta(): 1\n' > '" + root + "/fixture.spl'"
    val (_setup_out, _setup_err, setup_code) = rt_process_run("/bin/sh", ["-c", setup])
    if setup_code != 0:
        return "setup-failed"
    val (_out, _err, _code) = rt_process_run_timeout(qualification_binary(), ["duplicate-check", root], 30000)
    if rt_file_exists(sentinel):
        return "shell-executed"
    "safe"

fn qualification_daemon_done(result: text) -> text:
    val (_out, _err, _code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "stop"], 30000)
    result

fn qualification_daemon_cache_probe() -> text:
    val root = "build/qualification-test-daemon"
    val path = "{root}/cache_probe_spec.spl"
    rt_dir_create_all(root)
    val green = "use std.spec.*\ndescribe \"cache probe\":\n    it \"passes\":\n        expect(1).to_equal(1)\n"
    val red = "use std.spec.*\ndescribe \"cache probe changed\":\n    it \"fails after invalidation\":\n        expect(1).to_equal(2)\n"
    if not rt_file_write_text(path, green): return "setup-failed"
    val (_stop_out, _stop_err, _stop_code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "stop"], 30000)
    val (clean_out, clean_err, clean_code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "clean", path], 30000)
    if clean_code != 0 or not (clean_out + clean_err).contains("test_daemon_cache=clean"): return qualification_daemon_done("clean-failed")
    val (hit_out, hit_err, hit_code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "run", path], 30000)
    if hit_code != 0 or not (hit_out + hit_err).contains("test_daemon_cache=hit"): return qualification_daemon_done("hit-failed")
    if not rt_file_write_text(path, red): return qualification_daemon_done("edit-failed")
    val (miss_out, miss_err, miss_code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "run", path], 30000)
    if miss_code == 0 or not (miss_out + miss_err).contains("test_daemon_cache=miss"): return qualification_daemon_done("stale-hit")
    val (_status_out, _status_err, status_code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "status"], 30000)
    val (_done_out, _done_err, done_code) = rt_process_run_timeout(qualification_binary(), ["test-daemon", "stop"], 30000)
    if status_code != 0 or done_code != 0: return "lifecycle-failed"
    "safe"

fn qualification_termination_probe() -> text:
    val (_check_out, _check_err, check_code) = rt_process_run_timeout(
        qualification_binary(), ["--quiet", "check", "test/fixtures/pure_simple_tooling/clean.spl"], 30000)
    if check_code != 0: return "check-failed-or-timeout"
    val (_lean_out, _lean_err, lean_code) = rt_process_run_timeout(
        qualification_binary(), ["gen-lean", "not-a-command"], 30000)
    if lean_code == 0 or lean_code == -1: return "gen-lean-did-not-fail-bounded"
    "safe"

fn qualification_measure_warm(args: [text]) -> i64:
    val (_warm_out, _warm_err, _warm_code, _warm_ms) = qualification_run_command(args, 30000)
    var samples: [i64] = []
    var i = 0
    while i < 20:
        val (_out, _err, code, elapsed_ms) = qualification_run_command(args, 30000)
        if code != 0:
            return 30000
        samples.push(elapsed_ms)
        i = i + 1
    # Nearest-rank p95 for 20 samples is the 19th sorted value.
    var a = 1
    while a < samples.len():
        val value = samples[a]
        var b = a - 1
        while b >= 0 and samples[b] > value:
            samples[b + 1] = samples[b]
            b = b - 1
        samples[b + 1] = value
        a = a + 1
    samples[18]

describe "Pure-Simple tool and infrastructure hardening":
    it "REQ-001 REQ-002 REQ-011 admits only a truthful production runtime and inventory":
        step("Admit a pure-Simple production runtime")
        expect(qualification_runtime_identity()).to_equal("pure-simple")
        expect(qualification_source_contract(
            "scripts/setup/setup.shs",
            ["candidate_frontend_admission"],
            []
        )).to_equal("safe")
        expect(qualification_source_contract(
            "scripts/bootstrap/bootstrap-from-scratch.sh",
            ["deploy_simple_binary_atomically \"${full_bin}\" \"${deployed_bin}\"", "rm -f \"${deploy_dir}/simple_seed${exe_suffix}\"", "mcp_hash_tmp"],
            ["install -m755 \"${full_bin}\" \"${deployed_bin}\"", "Installed current seed delegate"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "scripts/check/cert/redeploy_gate/candidate_frontend_admission.shs",
            ["deploy_simple_binary_atomically() (", "retained_previous", "trap cleanup_deploy_transaction 0", "mv \"$deploy_tmp\" \"$live\"", "simple_binary_is_valid \"$live\"", "mv \"$restore_tmp\" \"$live\""],
            []
        )).to_equal("safe")
        val (_rollback_out, _rollback_err, rollback_code) = rt_process_run_timeout(
            "sh", ["scripts/check/check-deploy-rollback-contract.shs"], 30000)
        expect(rollback_code).to_equal(0)
        expect(qualification_source_contract(
            "src/app/cli/dispatch.spl",
            ["get_command_table"],
            ["g_command_count = 53", "g_simple_impl_count = 53"]
        )).to_equal("safe")

    it "REQ-003 through REQ-006 REQ-009 REQ-010 REQ-014 preserves developer-tool failures":
        step("Run truth-preserving developer tools")
        expect(qualification_source_contract(
            "src/lib/nogc_sync_mut/test_runner/test_executor_parsing.spl",
            ["exit_code != 0", "timeout"],
            ["elif exit_code != 0 and passed == 0"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/lib/nogc_sync_mut/test_runner/test_runner_async.spl",
            ["install_signal_handlers", "signal_dispatch_pending()", "cleanup_all_children"],
            []
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/lib/nogc_sync_mut/io/signal_stubs.spl",
            ["rt_signal_install(signal) <= 0", "_signal_handlers[i] = (signal, handler)"],
            ["_signal_handlers.push((signal, handler))\n    rt_signal_install"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/lib/nogc_sync_mut/test_runner/process_tracker.spl",
            ["else:\n                surviving.push(pid)"],
            []
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/test_runner_new/test_runner_client.spl",
            ["SIMPLE_TEST_DAEMON_CHILD", "--no-session-daemon", "process_spawn_async", "[\"-0\", pid]", "if not atomic_write_text"],
            ["src/compiler_rust/target/debug/simple", "[\"-c\", \"pid=$(cat", "rt_file_write_text(path, content)"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/test_runner_new/test_runner_main.spl",
            ["process_run_timeout(binary, child_args", "TimeoutResourceFailure", "test_batch_result_matches_manifest(batch_files, batch_result)"],
            ["process_run(binary, child_args"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/lib/nogc_sync_mut/io/process_ops.spl",
            ["1 + (timeout_ms - 1) / 1000", r"exec timeout --kill-after=5s {timeout_sec}s {full_cmd}"],
            ["timeout_buffer", "timeout_sec + 5"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/lib/nogc_sync_mut/daemon_sdk/client.spl",
            ["while rt_time_now_unix_micros() < deadline:"],
            ["attempts < 600"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/test_dep_graph_shared.spl",
            ["extract_transitive_deps(module_path)", "seen[file_path] = true"],
            ["extract_transitive_deps(module_path, 5)", "pending_depths"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/compiler/90.tools/verify/lake_runner.spl",
            ["timeout_ms: i64", "shell_timeout(", "self.timeout_ms"],
            ["val result = shell("]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/compiler/90.tools/verify/checker.spl",
            ["LakeRunner.new(config.project_dir, config.timeout_ms)"],
            ["LakeRunner.new(config.project_dir)"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/io/cli_lint_commands.spl",
            ["fn cli_run_lint", "fn cli_run_fmt", "fn cli_run_fix", "lint_source", "if run_repo_gates:", "check-ui-backend-isolation.shs", "check-cpu-hotloop-idiom.shs", "--mcp-perf is unavailable until its repository scanner has a production owner"],
            ["file_allows_lint", "[\"build\", \"lint\", \"--mcp-perf\"]"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/io/_CliCommands/run_commands.spl",
            [],
            ["fn cli_run_lint", "fn cli_run_fmt", "fn cli_run_fix"]
        )).to_equal("safe")
        expect(qualification_exit_class(0)).to_equal("pass")
        expect(qualification_exit_class(1)).to_equal("assertion_failure")
        expect(qualification_exit_class(2)).to_equal("usage_error")
        expect(qualification_exit_class(3)).to_equal("internal_error")
        expect(qualification_exit_class(4)).to_equal("empty_discovery")
        expect(qualification_exit_class(124)).to_equal("timeout_resource")
        val (_outcome_out, _outcome_err, outcome_code) = rt_process_run_timeout(
            "sh", ["scripts/check/check-test-runner-outcome-exits.shs"], 90000)
        expect(outcome_code).to_equal(0)
        expect(qualification_source_contract(
            "scripts/check/check-test-runner-outcome-exits.shs",
            ["kill -INT \"$RUNNER_PID\"", "signal_exit", "signal child survived cleanup"],
            []
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/gen_lean/main.spl",
            ["process_run_timeout", "src/compiler/90.tools/verify/main.spl"],
            ["[\"gen-lean\"]"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/compiler/90.tools/verify/main.spl",
            ["get_cli_args()", "val command = argv[0]"],
            ["get_args()", "val command = argv[1]"]
        )).to_equal("safe")
        expect(qualification_source_contract(
            "src/app/io/_CliCommands/run_commands.spl",
            ["cli_run_file(\"src/app/gen_lean/main.spl\""],
            ["_cli_process_run(\"./bin/simple\", args)"]
        )).to_equal("safe")
        val (_fix_out, _fix_err, fix_code, _fix_ms) = qualification_run_command(
            ["fix", "test/fixtures/pure_simple_tooling/clean.spl", "--dry-run"], 30000)
        expect(fix_code).to_equal(0)
        expect(qualification_termination_probe()).to_equal("safe")

