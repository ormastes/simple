# codex-system-test
"""
# MCP Command-Line Handshake

**Requirements:** doc/02_requirements/app/build/bootstrap.md
**Plan:** doc/03_plan/sys_test/mcp_cmdline_handshake.md
**Design:** N/A
**Research:** N/A

## Overview

Build and launch the pure-Simple MCP server, send real MCP
`initialize`, `notifications/initialized`, and `tools/list` JSONL frames,
and require a bounded response. Then call `simple_pipe` and `simple_search`.

## Examples

`simple_mcp_server` must identify `Simple MCP Server`, list `simple_pipe`,
report `spipe: linked`, and return a bounded no-match search result.
"""

use std.spec.{describe, it, expect, step}
use std.nogc_sync_mut.io.file_ops.{file_delete, file_exists, file_write}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.io_runtime.{host_arch, host_os}
use std.nogc_sync_mut.sffi.system.{process_run_timeout}

struct McpCmdlineProbe:
    label: text
    command: text
    timeout_seconds: i64
    max_elapsed_ms: i64
    exit_code: i64
    elapsed_ms: i64
    stdout: text
    stderr: text
    ready_json: text
    ok: bool
    reason: text

fn mcp_frame(body: text) -> text:
    body + "\n"

fn mcp_initialize_frame(id: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"simple-system-test\",\"version\":\"1\"}}}"
    mcp_frame(body)

fn mcp_initialized_frame() -> text:
    mcp_frame("{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\",\"params\":{}}")

fn mcp_tools_list_frame(id: text) -> text:
    mcp_frame("{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"tools/list\",\"params\":{}}")

fn mcp_tool_call_frame(id: text, name: text, arguments: text) -> text:
    mcp_frame("{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"tools/call\",\"params\":{\"name\":\"" + name + "\",\"arguments\":" + arguments + "}}")

fn bootstrap_triple() -> text:
    val os = host_os()
    val arch = host_arch()
    if os == "linux":
        return arch + "-unknown-linux-gnu"
    if os == "macos":
        return arch + "-apple-darwin-macho"
    arch + "-unknown-" + os

fn pure_stage2_binary() -> text:
    "build/bootstrap/stage2/" + bootstrap_triple() + "/simple"

fn pure_simple_mcp_binary() -> text:
    "build/bootstrap/mcp-package/simple_mcp_server"

fn build_pure_simple_mcp() -> (text, text, i32):
    process_run_timeout("env", [
        "SIMPLE_NO_STUB_FALLBACK=1",
        pure_stage2_binary(), "native-build",
        "--backend", "cranelift",
        "--source", "src/compiler",
        "--source", "src/app",
        "--source", "src/lib",
        "--entry-closure",
        "--mode", "dynload",
        "--entry", "src/app/mcp/main.spl",
        "--runtime-path", "src/compiler_rust/target/bootstrap",
        "-o", pure_simple_mcp_binary()
    ], 600000)

fn shell_escape_text(value: text) -> text:
    "'" + value.replace("'", "'\\''") + "'"

fn mcp_cmdline_probe(label: text, command: text, timeout_seconds: i64, max_elapsed_ms: i64, expected_ready: text, expected_tool: text, feature_frames: text, expected_feature: text) -> McpCmdlineProbe:
    val input_path = "/tmp/simple_mcp_cmdline_" + label + "_" + current_time_ms().to_string() + ".in"
    val input = mcp_initialize_frame("1") + mcp_initialized_frame() + mcp_tools_list_frame("2") + feature_frames
    if not file_write(input_path, input):
        return McpCmdlineProbe(label: label, command: command, timeout_seconds: timeout_seconds, max_elapsed_ms: max_elapsed_ms, exit_code: 1, elapsed_ms: 0, stdout: "", stderr: "input write failed", ready_json: "", ok: false, reason: "input_write_failed")

    val (ready_stdout, ready_stderr, ready_exit) = process_run_timeout(command, ["--json"], timeout_seconds * 1000)
    val start_ms = current_time_ms()
    val full_cmd = shell_escape_text(command) + " < " + shell_escape_text(input_path)
    val (stdout, stderr, exit_code) = process_run_timeout("/bin/sh", ["-c", full_cmd], timeout_seconds * 1000)
    val elapsed = current_time_ms() - start_ms
    file_delete(input_path)

    val ready_out = ready_stdout.trim()
    val combined_stderr = ready_stderr + stderr
    var ok = true
    var reason = ""
    if ready_exit != 0:
        ok = false
        reason = "ready_json_failed"
    elif expected_ready != "" and not ready_out.contains(expected_ready):
        ok = false
        reason = "ready_json_missing_marker"
    elif exit_code != 0:
        ok = false
        reason = "handshake_exit_" + exit_code.to_string()
    elif elapsed > max_elapsed_ms:
        ok = false
        reason = "elapsed_ms_" + elapsed.to_string()
    elif not stdout.contains("\"jsonrpc\""):
        ok = false
        reason = "missing_jsonrpc_response"
    elif not stdout.contains("\"id\":\"1\"") and not stdout.contains("\"id\":1"):
        ok = false
        reason = "missing_initialize_response"
    elif not stdout.contains("\"id\":\"2\"") and not stdout.contains("\"id\":2"):
        ok = false
        reason = "missing_tools_list_response"
    elif not stdout.contains("\"tools\""):
        ok = false
        reason = "missing_tools_array"
    elif expected_tool != "" and not stdout.contains(expected_tool):
        ok = false
        reason = "missing_expected_tool_" + expected_tool
    elif expected_feature != "" and not stdout.contains(expected_feature):
        ok = false
        reason = "missing_expected_feature_" + expected_feature
    elif stdout.contains("parse error") or combined_stderr.contains("parse error"):
        ok = false
        reason = "parse_error"
    elif stdout.contains("native_missing") or combined_stderr.contains("native_missing"):
        ok = false
        reason = "native_missing"

    McpCmdlineProbe(label: label, command: command, timeout_seconds: timeout_seconds, max_elapsed_ms: max_elapsed_ms, exit_code: exit_code, elapsed_ms: elapsed, stdout: stdout, stderr: combined_stderr, ready_json: ready_out, ok: ok, reason: reason)

describe "Pure-Simple MCP Launch and Handshake":
    describe "REQ-MCP-CMD-001: pure-Simple MCP answers real stdio handshakes":
        it "should build the exact MCP artifact with pure Stage 2":
            step("Strictly native-build src/app/mcp/main.spl with pure Stage 2")
            val (_, build_stderr, build_exit) = build_pure_simple_mcp()
            expect(build_exit).to_equal(0)
            expect(file_exists(pure_simple_mcp_binary())).to_equal(true)
            expect(build_stderr.contains("stub fallback")).to_equal(false)

        it "should launch the exact MCP artifact and list Simple tools within the time limit":
            step("Run the Stage 2-built MCP artifact with initialize and tools/list frames")
            val probe = mcp_cmdline_probe("simple_mcp", pure_simple_mcp_binary(), 15, 15000, "Simple MCP Server", "simple_pipe", "", "")
            step("Require readiness, successful exit, bounded latency, and simple_pipe")
            expect(probe.ok).to_equal(true)
            expect(probe.exit_code).to_equal(0)
            expect(probe.elapsed_ms).to_be_less_than(15001)
            expect(probe.ready_json).to_contain("Simple MCP Server")
            expect(probe.stdout).to_contain("simple_pipe")

        it "should run core Simple MCP features without source or Rust fallback":
            step("Launch the cached native Simple MCP artifact")
            val calls = (
                mcp_tool_call_frame("3", "simple_pipe", "{\"surface\":\"spipe\"}") +
                mcp_tool_call_frame("4", "simple_search", "{\"query\":\"__PURE_SIMPLE_MCP_SANITY_NO_MATCH__\",\"scope\":\"src\"}")
            )
            val probe = mcp_cmdline_probe("simple_mcp_features", pure_simple_mcp_binary(), 15, 15000, "Simple MCP Server", "simple_search", calls, "status: ready")
            step("Check the linked SPipe surface and bounded empty search result")
            expect(probe.ok).to_equal(true)
            expect(probe.stdout).to_contain("spipe: linked")
            expect(probe.stdout).to_contain("No results found.")
            expect(probe.stderr.contains("bootstrap-only")).to_equal(false)
            expect(probe.stderr.contains("mode=source")).to_equal(false)
