# codex-system-test
# @req REQ-001 REQ-002 REQ-003 REQ-004 REQ-005 REQ-006 REQ-007 REQ-008 REQ-009 REQ-010 NFR-001 NFR-002 NFR-003 NFR-004 NFR-005 NFR-006 NFR-007 NFR-008
# @evidence-display: links
"""# RV32/RV64 Simple-Generated FPGA CPU and Linux

Qualifies RV32 and RV64 independently from tracked Simple hardware source
through compiler-generated RTL, MMU/PMP protection, Linux login, terminal
interaction, and a connected KV260.

The acceptance path is deliberately fail-closed. QEMU, copied or string-
emitted RTL, empty cores, constant RVFI, unconditional testbench markers,
output-only UART, ILA-only markers, stale artifacts, or evidence from the other
XLEN cannot satisfy a row. Until the corresponding production checker exists,
the helper fails explicitly instead of publishing a placeholder pass.
"""
use std.spec.*

fn generate_dual_arch_rtl_evidence():
    fail("implement with the canonical pure-Simple VHDL compiler, tracked RV32/RV64 hardware roots, source maps, deterministic hashes, nonempty clocked/bus entities, and semantic RVFI; reject stubs, fallback, emitted strings, copied or external CPU RTL")

fn require_dual_arch_mmu_pmp_evidence():
    fail("implement with executing production RV32 MmuState/mmu_* Sv32 and RV64 MmuState64/mmu64_* Sv39 call sites followed by CPU PMP checks for fetch, load, and store, including faults, SATP, SFENCE.VMA, permissions, A/D policy, and lock behavior")

fn require_generated_rtl_linux_login_evidence():
    fail("implement with pinned OpenSBI Linux DT and rootfs hashes booted by generated RV32 and RV64 RTL to DUT-origin login prompts; QEMU is a separate media oracle and cannot satisfy this checker")

fn require_terminal_login_ls_evidence():
    fail("implement with bidirectional DUT UART evidence that transmits credentials and ls /, observes accepted shell prompts and deterministic root entries, and rejects wrapper-origin or output-only markers")

fn require_dual_arch_board_origin_evidence():
    fail("implement with independent KV260 RV32 and RV64 board identity, timing resources bitstream and programming hashes, proved bidirectional terminal, cold boot, warm reset, Linux login, and ls transcripts")

fn reject_noncanonical_rtl_evidence():
    fail("implement negative fixtures for empty or constant cores, copied or emitted-string RTL, Rust-seed or stub fallback, unconditional PASS testbenches, missing source maps, and mismatched compiler or RTL hashes")

fn reject_unprotected_or_cross_arch_evidence():
    fail("implement negative fixtures for identity or disconnected MMU paths, missing PMP enforcement, bus side effects after faults, wrong XLEN profiles, and evidence reused between RV32 and RV64")

fn reject_qemu_or_output_only_evidence():
    fail("implement negative fixtures for QEMU counted as generated RTL, missing pinned artifact hashes, synthesized login prompts, missing UART RX commands, reordered output, and TX-only terminal capture")

fn reject_vacuous_formal_evidence():
    fail("implement calibration fixtures for constant RVFI, no assertions, unbound DUT, missing solver output, timeouts, and ACT4 profiles that claim absent extensions or omit MMU/PMP behavior")

fn reject_stale_physical_evidence():
    fail("implement negative fixtures for missing or wrong board identity, stale or cross-architecture bitstreams, negative timing slack, DRC errors, optimized-away logic, ILA-only markers, and absent cold or warm interactive transcripts")

fn reject_incomplete_manual_or_provenance():
    fail("implement freshness and provenance fixtures for missing requirement links, incomplete hashes or commands, stale generated manuals, docgen stubs, executable specs under doc/06_spec, and unreviewed sidecar done marks")

describe "RV32/RV64 Simple-generated FPGA CPU and Linux production qualification":
    # @capture(exec)
    # @capture(log)
    # @capture(protocol)
    # @capture(binary)
    # @capture(artifact)
    it "should qualify compiler-generated RV32 and RV64 through interactive Linux on KV260":
        step("Generate RV32 and RV64 RTL from Simple sources")
        # @step: Verify compiler provenance source maps deterministic hashes and semantic RVFI
        generate_dual_arch_rtl_evidence()

        step("Exercise Sv32 and Sv39 translation plus PMP protection")
        # @step: Verify translated protected fetch load store and precise faults for both XLENs
        require_dual_arch_mmu_pmp_evidence()

        step("Boot Linux to an interactive login on generated RTL")
        # @step: Verify pinned media and separate generated-RTL login evidence
        require_generated_rtl_linux_login_evidence()

        step("Run terminal login and list guest files")
        # @step: Verify bidirectional terminal commands prompts and root entries
        require_terminal_login_ls_evidence()

        step("Program each FPGA image and capture board-origin evidence")
        # @step: Verify independent RV32 and RV64 KV260 cold and warm boot evidence
        require_dual_arch_board_origin_evidence()

    # @manual: folded
    # @capture(exec)
    # @capture(log)
    it "should reject noncanonical generated RTL and false testbench success":
        step("Substitute empty constant copied external fallback or emitted-string CPU RTL")
        step("Run compiler provenance and generated RTL validation")
        reject_noncanonical_rtl_evidence()

    # @manual: folded
    # @capture(protocol)
    # @capture(log)
    it "should reject bypassed protection and evidence reused across architectures":
        step("Bypass Sv32 Sv39 or PMP before a memory bus request")
        step("Reuse an RV32 profile artifact or transcript for RV64 or vice versa")
        reject_unprotected_or_cross_arch_evidence()

    # @manual: folded
    # @capture(protocol)
    # @capture(log)
    it "should reject QEMU output-only or synthesized Linux terminal evidence":
        step("Submit QEMU media output or a TX-only marker as generated RTL or board proof")
        step("Remove UART input command evidence or alter pinned Linux artifact hashes")
        reject_qemu_or_output_only_evidence()

    # @manual: folded
    # @capture(log)
    # @capture(artifact)
    it "should reject vacuous RVFI formal and inaccurate ACT4 evidence":
        step("Hold RVFI constant remove formal assertions or disconnect the emitted DUT")
        step("Declare unsupported ISA privilege MMU or PMP behavior in the ACT4 profile")
        reject_vacuous_formal_evidence()

    # @manual: folded
    # @capture(binary)
    # @capture(log)
    # @capture(protocol)
    it "should reject stale mismatched or noninteractive physical FPGA evidence":
        step("Program a stale wrong-architecture or timing-failing bitstream")
        step("Provide only ILA output or omit cold warm login and ls terminal interaction")
        reject_stale_physical_evidence()

    # @manual: folded
    # @capture(exec)
    # @capture(artifact)
    it "should reject incomplete provenance stale manuals and unreviewed done marks":
        step("Remove commands hashes requirement links generated manual content or review records")
        step("Run SPipe documentation and production-readiness audits")
        reject_incomplete_manual_or_provenance()
