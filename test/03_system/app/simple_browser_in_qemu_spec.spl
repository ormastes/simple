# @tag:system
# @platform: composite
# @session:mutating
# @arch:x86_64
#
# System spec — Lane BR item 4 board-adjacent gate.
#
# Boots src/os/apps/simple_browser/main.spl directly as a QEMU kernel via
# native-build --entry-closure (the same proven convention as
# browser_engine_in_qemu_spec.spl's "browser software smoke ELF" case),
# and asserts that a kernel with no asset-backed VFS fails closed before paint.
#
# This is a direct-kernel-boot smoke gate, NOT the full "/usr/bin/simple-browser
# staged on a FAT32 disk, SSH-exec'd in ring-3" board gate described in the
# Lane BR task. That fuller gate requires a Simple-source ring-3 userland ELF
# target; every `--target x86_64-unknown-simpleos` invocation found in this
# repo (scripts/os/build_user_hello_elf.shs, build_simpleos_llvm_image.shs,
# scp_retrieve_over_ssh*.shs, fhs_path_exec_gate_uefi.shs) cross-compiles C
# source with the ported clang/LLVM toolchain — none compiles a .spl file to
# that target. See scripts/os/simple_browser_board_gate.shs for the staged
# attempt and its precise blocker report.

use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

val SIMPLE_BIN: text = "bin/simple"
val LINKER_SCRIPT: text = "examples/09_embedded/simple_os/arch/x86_64/linker.ld"
val BUILD_SOURCES_LIB_ONLY: text = "--source src/lib --source src/os"
val BUILD_PREFIX: text = "{SIMPLE_BIN} native-build"
val QEMU_BASE: text =
    "qemu-system-x86_64 -machine q35 -cpu qemu64 -serial stdio -display none -no-reboot"
val DEBUG_EXIT: text = "-device isa-debug-exit,iobase=0xf4,iosize=0x04"

fn artifact_exists(path: text) -> bool:
    rt_file_exists(path)

fn _run_shell(command: text) -> (text, text, i64):
    rt_process_run("/bin/sh", ["-c", command])

fn _build_target(entry: text, output: text) -> bool:
    val command = "{BUILD_PREFIX} {BUILD_SOURCES_LIB_ONLY} --backend cranelift --entry-closure --entry {entry} --target x86_64-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    if result[2] != 0:
        print result[0]
        print result[1]
        return false
    true

fn _run_qemu(kernel: text, memory: text, extra: text, timeout_secs: text) -> text:
    val command = "timeout {timeout_secs} {QEMU_BASE} -m {memory} -kernel {kernel} {DEBUG_EXIT} {extra} 2>&1 | tr -d '\\000'"
    val result = _run_shell(command)
    result[0] + result[1]

describe "Simple Browser in QEMU baremetal ELF execution (direct-kernel-boot smoke gate)":

    it "rejects a direct kernel that has no staged font catalog":
        val output_path = "build/os/simpleos_simple_browser_catalog_guard.elf"
        expect(_build_target(
            "src/os/apps/simple_browser/main.spl",
            output_path
        )).to_equal(true)
        expect(artifact_exists(output_path)).to_equal(true)

        val output = _run_qemu(output_path, "384M", "-vga std", "15s")
        expect(output.contains("[simple-browser] start")).to_equal(true)
        expect(output.contains("font catalog incomplete registered=0 required=16")).to_equal(true)
        expect(output.contains("simple_browser render pid=0 wid=0")).to_equal(false)
        expect(output.contains("[PASS] simple_browser_entry")).to_equal(false)
        expect(output.contains("TEST PASSED")).to_equal(false)
        expect(output.contains("[FAIL] simple_browser_entry")).to_equal(true)
        expect(output.contains("TEST FAILED")).to_equal(true)
