# codex-system-test
# @tag: rendering, font, manifest, multilingual
"""# Shared Multilingual Font Manifest

Checks the selected CLDR ranking, immutable bundled assets, and complete sparse
coverage matrix through the canonical Simple registry. No renderer or native
GPU claim is made here.
"""

use std.spec.*
use std.nogc_sync_mut.sffi.io.{file_exists, file_read_text, file_read_bytes}
use std.nogc_sync_mut.sffi.package.{package_sha256}
use std.nogc_sync_mut.sffi.spl_fonts.{FontRasterizer}
use std.nogc_sync_mut.text_layout.font_provider.{browser_font_dylib_candidates}
use std.common.encoding.font_registry.{FontAssetCandidate, FontCoverageCell, selected_font_language_ranking_source, font_language_ranking_evidence, selected_font_language_ranks, selected_font_asset_candidates, selected_font_coverage_languages, selected_font_coverage_categories, selected_font_coverage_matrix}
use std.common.encoding.font_cldr_rank.{CldrLanguagePopulationRow, cldr_scan_language_population, cldr_rank_languages, cldr_serialize_language_totals}
use std.common.encoding.sfnt.{validate_default_glyf_font, sfnt_manifest_tables_match, sfnt_manifest_default_axes_match, sfnt_manifest_names_match}

val FONT_ASSET_ROOT = "assets/fonts/google-fonts/"
val FONT_CORPUS_PATH = FONT_ASSET_ROOT + "CORPUS.sdn"
val FONT_CORPUS_SHA256 = "c7cffbf3e1a29c75dcd481593c6880d071966c5cbf0611e2185fe0d73e0c83f6"
val FONT_CORPUS_REF = FONT_CORPUS_PATH + "#sha256:" + FONT_CORPUS_SHA256
val CLDR_ROOT = "assets/fonts/cldr/release-48-2/"
val CLDR_DATA = CLDR_ROOT + "common/supplemental/supplementalData.xml"
val CLDR_METADATA = CLDR_ROOT + "common/supplemental/supplementalMetadata.xml"
val CLDR_LIKELY = CLDR_ROOT + "common/supplemental/likelySubtags.xml"
val CLDR_RANKING = CLDR_ROOT + "RANKING.sdn"

fn expected_cldr_contribution(row: CldrLanguagePopulationRow) -> i64:
    val denominator: i64 = 100000000
    val first = row.population * row.population_percent_micros
    val first_q = first / denominator
    val first_r = first % denominator
    val second = first_q * row.literacy_percent_micros
    val base = second / denominator
    val remainder = ((second % denominator) * denominator +
        first_r * row.literacy_percent_micros)
    val denominator_squared = denominator * denominator
    base + (remainder + denominator_squared / 2) / denominator_squared

fn setup_shared_font_fixture() -> [FontAssetCandidate]:
    val assets = selected_font_asset_candidates()
    expect(assets.len()).to_equal(16)
    assets

fn expect_font_license(asset: FontAssetCandidate):
    expect(asset.upstream_revision).to_equal("ec0464b978de222073645d6d3366f3fdf03376d8")
    expect(asset.sha256.len()).to_equal(64)
    expect(asset.byte_len).to_be_greater_than(0)
    expect(asset.modification_state).to_equal("unchanged")
    expect(asset.sfnt_tables).to_contain("cmap")
    expect(asset.sfnt_tables).to_contain("glyf")
    expect(asset.rfn_state.len()).to_be_greater_than(0)
    expect(asset.copyright_notice.len()).to_be_greater_than(0)
    expect(asset.embedded_style.len()).to_be_greater_than(0)
    expect(asset.embedded_full_name.len()).to_be_greater_than(0)
    if asset.family == "Noto Emoji":
        expect(asset.embedded_full_name).to_equal("Noto Emoji Regular")
    expect(asset.embedded_postscript_name.len()).to_be_greater_than(0)
    expect(asset.embedded_version).to_start_with("Version ")
    expect(asset.default_axes.len()).to_be_greater_than(0)
    expect(asset.coverage_corpus_ref).to_equal(FONT_CORPUS_REF)
    expect("|candidate-script-primary|candidate-category-witness|rank11-cutoff-only|common-emoji-fallback|").to_contain("|" + asset.fallback_role + "|")
    expect("|OFL-1.1|Apache-2.0|").to_contain("|" + asset.license + "|")
    expect(file_exists(asset.local_path)).to_be(true)
    expect(package_sha256(asset.local_path)).to_equal("sha256:" + asset.sha256)
    val font_bytes = file_read_bytes(asset.local_path)
    val format = validate_default_glyf_font(font_bytes)
    expect(format.supported).to_be(true)
    expect(format.reason).to_equal("supported-default-glyf")
    expect(sfnt_manifest_tables_match(font_bytes, asset.sfnt_tables)).to_be(true)
    expect(sfnt_manifest_default_axes_match(font_bytes, asset.default_axes)).to_be(true)
    expect(sfnt_manifest_names_match(font_bytes, asset.family, asset.embedded_style,
        asset.embedded_full_name, asset.embedded_postscript_name,
        asset.embedded_version)).to_be(true)
    val metadata_path = FONT_ASSET_ROOT + asset.metadata_path
    val license_path = FONT_ASSET_ROOT + asset.license_path
    expect(file_exists(metadata_path)).to_be(true)
    expect(file_exists(license_path)).to_be(true)
    expect(file_read_text(metadata_path).len()).to_be_greater_than(0)
    expect(file_read_text(license_path).len()).to_be_greater_than(0)

fn expect_language_coverage(cells: [FontCoverageCell]):
    expect(selected_font_coverage_languages().len()).to_equal(10)
    expect(selected_font_coverage_categories().len()).to_equal(10)
    expect(cells.len()).to_equal(100)
    var seen = "|"
    var native_count: i64 = 0
    var fallback_count: i64 = 0
    var not_designed_count: i64 = 0
    var unavailable_count: i64 = 0
    for cell in cells:
        val key = "|" + cell.language + ":" + cell.category + "|"
        val allowed = "|native|fallback|not-designed-for-script|unavailable|"
        expect(seen.contains(key)).to_be(false)
        expect(allowed).to_contain("|" + cell.status + "|")
        seen = seen + cell.language + ":" + cell.category + "|"
        if cell.status == "native": native_count = native_count + 1
        elif cell.status == "fallback": fallback_count = fallback_count + 1
        elif cell.status == "not-designed-for-script": not_designed_count = not_designed_count + 1
        elif cell.status == "unavailable": unavailable_count = unavailable_count + 1
    expect(native_count).to_equal(0)
    expect(fallback_count).to_equal(0)
    expect(not_designed_count).to_equal(26)
    expect(unavailable_count).to_equal(74)

fn expect_candidate_witness(assets: [FontAssetCandidate], family: text, witness: text):
    var found = false
    var loaded = false
    for asset in assets:
        if asset.family == family:
            found = true
            expect(asset.coverage_state).to_start_with("candidate:")
            for dylib_path in browser_font_dylib_candidates():
                val rasterizer = FontRasterizer.load(dylib_path, asset.local_path)
                if rasterizer != nil:
                    loaded = true
                    # Diagnostic layout availability is not shaping acceptance.
                    val layout = rasterizer.layout_text(witness, 32, 0)
                    expect(layout.len()).to_be_greater_than(0)
                    for ch in witness:
                        val codepoint = ch.char_code_at(0).to_i64()
                        expect(rasterizer.has_glyph(codepoint)).to_be(true)
                        val glyph = rasterizer.rasterize(codepoint, 32)
                        expect(glyph != nil).to_be(true)
                        if glyph != nil:
                            expect(glyph.pixels.len()).to_equal(glyph.width * glyph.height)
                    rasterizer.close()
                    break
    expect(found).to_be(true)
    expect(loaded).to_be(true)

describe "shared multilingual font manifest":
    # @req REQ-001 REQ-002
    it "should pin the CLDR source, selected top ten, and cutoff evidence":
        step("Load the pinned multilingual font manifest")
        val source = selected_font_language_ranking_source()
        val selected = selected_font_language_ranks()
        val evidence = font_language_ranking_evidence()
        expect(source.release).to_equal("release-48-2")
        expect(source.tag_object).to_equal("fc1fd058cc6f50544a450a3b15a4bba0e0c1e653")
        expect(source.source_commit).to_equal("11299982335beb974c1c63c45265184e759c0f41")
        expect(package_sha256(CLDR_DATA)).to_equal("sha256:" + source.supplemental_data_sha256)
        expect(package_sha256(CLDR_METADATA)).to_equal("sha256:" + source.supplemental_metadata_sha256)
        expect(package_sha256(CLDR_LIKELY)).to_equal("sha256:" + source.likely_subtags_sha256)
        expect(package_sha256(CLDR_ROOT + "LICENSE")).to_equal("sha256:b49d0e9f8ead51ca8b7df6fec89cc3ae6809198b4b9d43c74216da0118f23f5b")
        expect(package_sha256(CLDR_ROOT + "TAG.txt")).to_equal("sha256:b95ecf54f9dc853dbf6d2f5bb2fd3c418d3ecc72922b06f8481e8004210e2e05")
        expect(package_sha256(CLDR_ROOT + "SOURCE.sdn")).to_equal("sha256:f64ee0280b246a5f0f47b39cca6bddcdfe2e0d3e93488e5558b76ca7d626f4b4")
        expect(package_sha256(CLDR_RANKING)).to_equal("sha256:e4279236032d02966eaaeb502af7b19edc8d371e454a3fc6beb676ef4e7c70df")
        expect(file_read_text(CLDR_ROOT + "TAG.txt")).to_contain("object " + source.source_commit)
        expect(source.license).to_equal("Unicode-3.0")
        expect(selected.len()).to_equal(10)
        expect(evidence.len()).to_equal(11)
        expect(selected[0].language).to_equal("en")
        expect(selected[8].language).to_equal("ur")
        expect(selected[9].language).to_equal("id")
        expect(evidence[10].language).to_equal("bn")
        expect(selected[9].literate_functional_total).to_be_greater_than(evidence[10].literate_functional_total)

        step("Regenerate the top eleven twice from the exact pinned XML bytes")
        val population_xml = file_read_text(CLDR_DATA)
        val metadata_xml = file_read_text(CLDR_METADATA)
        val likely_xml = file_read_text(CLDR_LIKELY)
        val first = cldr_rank_languages(population_xml, metadata_xml, likely_xml)
        val second = cldr_rank_languages(population_xml, metadata_xml, likely_xml)
        val contributions = cldr_scan_language_population(population_xml)
        match contributions:
            case Ok(rows):
                expect(rows.len()).to_equal(1589)
                for row in rows:
                    expect(row.contribution).to_equal(expected_cldr_contribution(row))
            case Err(message):
                fail("pinned CLDR contribution replay failed: {message}")
        match first:
            case Ok(first_rows):
                match second:
                    case Ok(second_rows):
                        val first_bytes = cldr_serialize_language_totals(first_rows, 11)
                        val second_bytes = cldr_serialize_language_totals(second_rows, 11)
                        expect(first_bytes).to_equal(second_bytes)
                        expect(first_bytes).to_equal(file_read_text(CLDR_RANKING))
                        var i: i64 = 0
                        while i < 11:
                            expect(first_rows[i].language).to_equal(evidence[i].language)
                            expect(first_rows[i].likely_script).to_equal(evidence[i].likely_script)
                            expect(first_rows[i].total).to_equal(evidence[i].literate_functional_total)
                            var script_totals = ""
                            var j: i64 = 0
                            while j < first_rows[i].script_totals.len():
                                if j > 0:
                                    script_totals = script_totals + ","
                                val script = first_rows[i].script_totals[j]
                                script_totals = script_totals + script.script + "=" + script.total.to_text()
                                j = j + 1
                            expect(script_totals).to_equal(evidence[i].script_totals)
                            i = i + 1
                    case Err(message):
                        fail("second pinned CLDR regeneration failed: {message}")
            case Err(message):
                fail("first pinned CLDR regeneration failed: {message}")

    # @req REQ-004 REQ-005
    # @req NFR-001 NFR-003
    it "should verify every immutable bundled font and adjacent notice":
        val assets = setup_shared_font_fixture()
        expect(file_exists(FONT_CORPUS_PATH)).to_be(true)
        expect(package_sha256(FONT_CORPUS_PATH)).to_equal("sha256:" + FONT_CORPUS_SHA256)
        var total_bytes: i64 = 0
        var paths = "|"
        var hashes = "|"
        for asset in assets:
            expect_font_license(asset)
            expect(paths.contains("|" + asset.upstream_path + "|")).to_be(false)
            expect(hashes.contains("|" + asset.sha256 + "|")).to_be(false)
            paths = paths + asset.upstream_path + "|"
            hashes = hashes + asset.sha256 + "|"
            total_bytes = total_bytes + asset.byte_len
        expect(total_bytes).to_equal(51764704)
        expect(total_bytes).to_be_less_than(80 * 1024 * 1024 + 1)

    # @req REQ-005
    it "should keep candidates provisional while checking exact corpus codepoints and rasters":
        step("Check every candidate against its exact CORPUS codepoints without claiming shaping acceptance")
        val assets = setup_shared_font_fixture()
        for asset in assets:
            expect(asset.coverage_state).to_start_with("candidate:")
            expect(asset.coverage_state).to_contain("executable Simple shaping acceptance pending")
            expect(asset.coverage_state.contains("accepted")).to_be(false)
        expect_candidate_witness(assets, "Noto Sans SC", "English中文EspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Noto Sans Devanagari", "EnglishEspañolहिन्दीfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Noto Sans Arabic", "EnglishEspañolالعربيةfrançaisPortuguêsاردوIndonesia")
        expect_candidate_witness(assets, "Noto Sans Bengali", "বাংলা")
        expect_candidate_witness(assets, "Noto Serif SC", "English中文EspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Noto Serif Devanagari", "EnglishEspañolहिन्दीfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Noto Naskh Arabic", "EnglishEspañolالعربيةfrançaisPortuguêsاردوIndonesia")
        expect_candidate_witness(assets, "Noto Serif Bengali", "বাংলা")
        expect_candidate_witness(assets, "Noto Sans Mono", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Bungee", "EnglishEspañolfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Nunito", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Caveat", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Roboto Slab", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "UnifrakturCook", "EnglishEspañolfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Pixelify Sans", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Noto Emoji", "😀")

    # @req REQ-004 REQ-005
    it "should preserve the separate Roboto Slab copyright notice":
        val copyright_path = FONT_ASSET_ROOT + "apache/robotoslab/COPYRIGHT.txt"
        expect(file_exists(copyright_path)).to_be(true)
        val copyright_text = file_read_text(copyright_path)
        expect(copyright_text.len()).to_be_greater_than(0)
        expect(copyright_text).to_contain("Copyright 2018 The Roboto Slab Project Authors")

    # @req REQ-003
    it "should provide one honest status for all one hundred sparse cells":
        val cells = selected_font_coverage_matrix()
        expect_language_coverage(cells)
        expect(cells[10].status).to_equal("unavailable")
        expect(cells[32].status).to_equal("unavailable")
        expect(cells[73].status).to_equal("not-designed-for-script")
        expect(cells[81].status).to_equal("unavailable")
        expect(cells[9].status).to_equal("unavailable")
