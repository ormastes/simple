# codex-system-test
# @tag: rendering, font, manifest, multilingual
"""# Shared Multilingual Font Manifest

Checks the selected CLDR ranking, immutable bundled assets, and complete sparse
coverage matrix through the canonical Simple registry. No renderer or native
GPU claim is made here.
"""

use std.spec.*
use std.nogc_sync_mut.sffi.io.{file_exists, file_read_text, file_read_bytes, dir_walk}
use std.nogc_sync_mut.sffi.package.{package_sha256}
use std.nogc_sync_mut.sffi.spl_fonts.{FontRasterizer}
use std.nogc_sync_mut.text_layout.font_provider.{browser_font_dylib_candidates}
use std.common.encoding.font_registry.{FontAssetCandidate, FontBundleAssetPin, FontCoverageCell, selected_font_language_ranking_source, font_language_ranking_evidence, selected_font_language_ranks, selected_font_asset_candidates, selected_font_bundle_asset_pins, selected_font_coverage_languages, selected_font_coverage_categories, selected_font_coverage_matrix, selected_font_simple_tuple_accepted}
use std.common.encoding.font_cldr_rank.{CldrLanguagePopulationRow, cldr_scan_language_population, cldr_rank_languages, cldr_serialize_language_totals}
use std.common.encoding.sfnt.{validate_default_glyf_font, sfnt_manifest_tables_match, sfnt_manifest_default_axes_match, sfnt_manifest_names_match}
use std.skia.feature.glyph.ot_parser.{OtFont, OtTable, parse_offset_table, find_table, read_u16_be, read_i16_be, read_u32_be}
use std.skia.feature.glyph.ot_parser_cmap.{cmap_glyph_id}
use std.skia.feature.glyph.ot_parser_glyf.{parse_glyf_outline}

val FONT_ASSET_ROOT = "assets/fonts/google-fonts/"
val FONT_CORPUS_PATH = FONT_ASSET_ROOT + "CORPUS.sdn"
val CLDR_ROOT = "assets/fonts/cldr/release-48-2/"
val CLDR_DATA = CLDR_ROOT + "common/supplemental/supplementalData.xml"
val CLDR_METADATA = CLDR_ROOT + "common/supplemental/supplementalMetadata.xml"
val CLDR_LIKELY = CLDR_ROOT + "common/supplemental/likelySubtags.xml"
val CLDR_RANKING = CLDR_ROOT + "RANKING.sdn"

fn expected_cldr_contribution(row: CldrLanguagePopulationRow) -> i64:
    val denominator: i64 = 100000000
    val first = row.population * row.population_percent_micros
    val first_q = first / denominator
    val first_r = first % denominator
    val second = first_q * row.literacy_percent_micros
    val base = second / denominator
    val remainder = ((second % denominator) * denominator +
        first_r * row.literacy_percent_micros)
    val denominator_squared = denominator * denominator
    base + (remainder + denominator_squared / 2) / denominator_squared

fn setup_shared_font_fixture() -> [FontAssetCandidate]:
    val assets = selected_font_asset_candidates()
    expect(assets.len()).to_equal(16)
    assets

fn font_bundle_pin_sha256(pins: [FontBundleAssetPin], path: text) -> text:
    for pin in pins:
        if pin.path == path: return pin.sha256
    fail("missing font bundle pin: " + path)
    ""

fn expect_font_bundle(pins: [FontBundleAssetPin]):
    expect(pins.len()).to_equal(57)
    var pinned_paths = "|"
    for pin in pins:
        expect(pin.path).to_start_with("assets/fonts/")
        expect(pin.sha256.len()).to_equal(64)
        expect(pinned_paths.contains("|" + pin.path + "|")).to_be(false)
        expect(file_exists(pin.path)).to_be(true)
        expect(package_sha256(pin.path)).to_equal("sha256:" + pin.sha256)
        pinned_paths = pinned_paths + pin.path + "|"
    val actual_paths = dir_walk("assets/fonts")
    expect(actual_paths.len()).to_equal(pins.len())
    for path in actual_paths:
        expect(pinned_paths).to_contain("|" + path + "|")

fn expect_font_license(asset: FontAssetCandidate, corpus_ref: text):
    expect(asset.upstream_revision).to_equal("ec0464b978de222073645d6d3366f3fdf03376d8")
    expect(asset.sha256.len()).to_equal(64)
    expect(asset.byte_len).to_be_greater_than(0)
    expect(asset.modification_state).to_equal("unchanged")
    expect(asset.sfnt_tables).to_contain("cmap")
    expect(asset.sfnt_tables).to_contain("glyf")
    expect(asset.rfn_state.len()).to_be_greater_than(0)
    expect(asset.copyright_notice.len()).to_be_greater_than(0)
    expect(asset.embedded_style.len()).to_be_greater_than(0)
    expect(asset.embedded_full_name.len()).to_be_greater_than(0)
    if asset.family == "Noto Emoji":
        expect(asset.embedded_full_name).to_equal("Noto Emoji Regular")
    expect(asset.embedded_postscript_name.len()).to_be_greater_than(0)
    expect(asset.embedded_version).to_start_with("Version ")
    expect(asset.default_axes.len()).to_be_greater_than(0)
    expect(asset.metadata_scripts.len()).to_be_greater_than(0)
    expect(asset.coverage_corpus_ref).to_equal(corpus_ref)
    expect("|candidate-script-primary|candidate-category-witness|rank11-cutoff-only|common-emoji-fallback|").to_contain("|" + asset.fallback_role + "|")
    expect("|OFL-1.1|Apache-2.0|").to_contain("|" + asset.license + "|")
    expect(file_exists(asset.local_path)).to_be(true)
    expect(package_sha256(asset.local_path)).to_equal("sha256:" + asset.sha256)
    val font_bytes = file_read_bytes(asset.local_path)
    val format = validate_default_glyf_font(font_bytes)
    expect(format.supported).to_be(true)
    expect(format.reason).to_equal("supported-default-glyf")
    expect(sfnt_manifest_tables_match(font_bytes, asset.sfnt_tables)).to_be(true)
    expect(sfnt_manifest_default_axes_match(font_bytes, asset.default_axes)).to_be(true)
    expect(sfnt_manifest_names_match(font_bytes, asset.family, asset.embedded_style,
        asset.embedded_full_name, asset.embedded_postscript_name,
        asset.embedded_version)).to_be(true)
    val metadata_path = FONT_ASSET_ROOT + asset.metadata_path
    val license_path = FONT_ASSET_ROOT + asset.license_path
    expect(file_exists(metadata_path)).to_be(true)
    expect(file_exists(license_path)).to_be(true)
    expect(package_sha256(metadata_path)).to_equal("sha256:" + asset.metadata_sha256)
    expect(package_sha256(license_path)).to_equal("sha256:" + asset.license_sha256)
    if asset.notice_path != "":
        expect(package_sha256(FONT_ASSET_ROOT + asset.notice_path)).to_equal("sha256:" + asset.notice_sha256)
    else:
        expect(asset.notice_sha256).to_equal("")

fn expect_language_coverage(cells: [FontCoverageCell]):
    expect(selected_font_coverage_languages().len()).to_equal(10)
    expect(selected_font_coverage_categories().len()).to_equal(10)
    expect(cells.len()).to_equal(100)
    var seen = "|"
    var native_count: i64 = 0
    var fallback_count: i64 = 0
    var not_designed_count: i64 = 0
    var unavailable_count: i64 = 0
    for cell in cells:
        val key = "|" + cell.language + ":" + cell.category + "|"
        val allowed = "|native|fallback|not-designed-for-script|unavailable|"
        expect(seen.contains(key)).to_be(false)
        expect(allowed).to_contain("|" + cell.status + "|")
        seen = seen + cell.language + ":" + cell.category + "|"
        if cell.status == "native": native_count = native_count + 1
        elif cell.status == "fallback": fallback_count = fallback_count + 1
        elif cell.status == "not-designed-for-script": not_designed_count = not_designed_count + 1
        elif cell.status == "unavailable": unavailable_count = unavailable_count + 1
    expect(native_count).to_equal(67)
    expect(fallback_count).to_equal(4)
    expect(not_designed_count).to_equal(26)
    expect(unavailable_count).to_equal(3)
    val assets = selected_font_asset_candidates()
    var promoted: i64 = 0
    for cell in cells:
        if cell.status == "native" or cell.status == "fallback":
            promoted = promoted + 1
            expect(cell.witness_family.len()).to_be_greater_than(0)
            expect(selected_font_simple_tuple_accepted(cell.witness_family, cell.language)).to_be(true)
            var matches: i64 = 0
            for asset in assets:
                if asset.family == cell.witness_family:
                    matches = matches + 1
                    expect(asset.coverage_state).to_start_with("accepted-simple:")
            expect(matches).to_equal(1)
        else:
            expect(cell.witness_family).to_equal("")
    expect(promoted).to_equal(71)
    for asset in assets:
        if asset.coverage_state.starts_with("accepted-simple:"):
            var tuple_count: i64 = 0
            var accepted_language_list = ""
            for language in selected_font_coverage_languages():
                if selected_font_simple_tuple_accepted(asset.family, language):
                    tuple_count = tuple_count + 1
                    if accepted_language_list != "": accepted_language_list = accepted_language_list + ","
                    accepted_language_list = accepted_language_list + language
                    var witnessed = false
                    for cell in cells:
                        if (cell.language == language and cell.witness_family == asset.family and
                            (cell.status == "native" or cell.status == "fallback")):
                            witnessed = true
                    expect(witnessed).to_be(true)
            expect(tuple_count).to_be_greater_than(0)
            val prefix = if asset.family == "Noto Sans Devanagari" or asset.family == "Noto Sans Arabic":
                "accepted-simple: exact Pure Simple selected shaping accepted for "
            else:
                "accepted-simple: exact Pure Simple identity shaping accepted for "
            expect(asset.coverage_state).to_equal(prefix + accepted_language_list)

fn expect_candidate_witness(assets: [FontAssetCandidate], family: text, witness: text):
    var found = false
    var loaded = false
    for asset in assets:
        if asset.family == family:
            found = true
            expect(asset.coverage_state.starts_with("candidate:") or
                asset.coverage_state.starts_with("accepted-simple:")).to_be(true)
            for dylib_path in browser_font_dylib_candidates():
                val rasterizer = FontRasterizer.load(dylib_path, asset.local_path)
                if rasterizer != nil:
                    loaded = true
                    # Diagnostic layout availability is not shaping acceptance.
                    val layout = rasterizer.layout_text(witness, 32, 0)
                    expect(layout.len()).to_be_greater_than(0)
                    for ch in witness:
                        val codepoint = ch.char_code_at(0).to_i64()
                        expect(rasterizer.has_glyph(codepoint)).to_be(true)
                        val glyph = rasterizer.rasterize(codepoint, 32)
                        expect(glyph != nil).to_be(true)
                        if glyph != nil:
                            expect(glyph.pixels.len()).to_equal(glyph.width * glyph.height)
                    rasterizer.close()
                    break
    expect(found).to_be(true)
    expect(loaded).to_be(true)

fn corpus_witnesses() -> [text]:
    ["English", "中文", "Español", "हिन्दी", "العربية", "français",
        "Português", "Русский", "اردو", "Indonesia", "বাংলা", "😀"]

fn table_or_fail(font: OtFont, tag: u32) -> OtTable:
    val table = find_table(font, tag)
    if table == nil: fail("missing required compound-oracle table")
    table.unwrap()

fn loca_value(font: OtFont, loca: OtTable, glyph_id: i64, long_loca: bool) -> i64:
    val pos = loca.offset as i64 + glyph_id * (if long_loca: 4 else: 2)
    if long_loca: read_u32_be(font.blob, pos) as i64
    else: read_u16_be(font.blob, pos) as i64 * 2

# Test-only raw oracle: -1 is simple/empty, -2 is malformed, otherwise direct components.
fn raw_compound_components(font: OtFont, glyph_id: i64) -> i64:
    val head = table_or_fail(font, 1751474532)
    val loca = table_or_fail(font, 1819239265)
    val glyf = table_or_fail(font, 1735162214)
    val long_loca = read_i16_be(font.blob, head.offset as i64 + 50) == 1
    val start = loca_value(font, loca, glyph_id, long_loca)
    val end = loca_value(font, loca, glyph_id + 1, long_loca)
    if start == end: return -1
    if start < 0 or end < start or end > glyf.length as i64 or end - start < 10: return -2
    var pos = glyf.offset as i64 + start
    val limit = glyf.offset as i64 + end
    if read_i16_be(font.blob, pos) >= 0: return -1
    pos = pos + 10
    var count: i64 = 0
    var more = true
    while more:
        if pos + 4 > limit: return -2
        val flags = read_u16_be(font.blob, pos)
        pos = pos + 4
        count = count + 1
        pos = pos + (if (flags & 1) != 0: 4 else: 2)
        if (flags & 8) != 0: pos = pos + 2
        elif (flags & 64) != 0: pos = pos + 4
        elif (flags & 128) != 0: pos = pos + 8
        if pos > limit or count > 64: return -2
        more = (flags & 32) != 0
    count

fn expect_compound_corpus(assets: [FontAssetCandidate]):
    var compound_faces: i64 = 0
    var corpus_roots: i64 = 0
    var corpus_components: i64 = 0
    for asset in assets:
        val font = parse_offset_table(file_read_bytes(asset.local_path))
        expect(font != nil).to_be(true)
        val parsed = font.unwrap()
        val maxp = table_or_fail(parsed, 1835104368)
        val glyph_count = read_u16_be(parsed.blob, maxp.offset as i64 + 4) as i64
        var has_compound = false
        for glyph_id in 0..glyph_count:
            val components = raw_compound_components(parsed, glyph_id)
            expect(components).to_be_greater_than(-2)
            if components >= 0:
                has_compound = true
                break
        if has_compound: compound_faces = compound_faces + 1
        var seen = "|"
        for witness in corpus_witnesses():
            for ch in witness:
                val glyph_id = cmap_glyph_id(parsed, ch.char_code_at(0) as u32)
                val key = "|" + (glyph_id as i64).to_text() + "|"
                if glyph_id > 0 and not seen.contains(key):
                    seen = seen + (glyph_id as i64).to_text() + "|"
                    val components = raw_compound_components(parsed, glyph_id as i64)
                    if components >= 0:
                        val outline = parse_glyf_outline(parsed, glyph_id)
                        expect(outline != nil).to_be(true)
                        if outline != nil: expect(outline.unwrap().is_empty()).to_be(false)
                        corpus_roots = corpus_roots + 1
                        corpus_components = corpus_components + components
    expect(compound_faces).to_equal(14)
    expect(corpus_roots).to_equal(76)
    expect(corpus_components).to_equal(124)

describe "shared multilingual font manifest":
    # @req REQ-001 REQ-002
    it "should pin the CLDR source, selected top ten, and cutoff evidence":
        step("Load the pinned multilingual font manifest")
        val source = selected_font_language_ranking_source()
        val bundle_pins = selected_font_bundle_asset_pins()
        val selected = selected_font_language_ranks()
        val evidence = font_language_ranking_evidence()
        expect(source.release).to_equal("release-48-2")
        expect(source.tag_object).to_equal("fc1fd058cc6f50544a450a3b15a4bba0e0c1e653")
        expect(source.source_commit).to_equal("11299982335beb974c1c63c45265184e759c0f41")
        expect(source.supplemental_data_sha256).to_equal(font_bundle_pin_sha256(bundle_pins, CLDR_DATA))
        expect(source.supplemental_metadata_sha256).to_equal(font_bundle_pin_sha256(bundle_pins, CLDR_METADATA))
        expect(source.likely_subtags_sha256).to_equal(font_bundle_pin_sha256(bundle_pins, CLDR_LIKELY))
        for path in [CLDR_DATA, CLDR_METADATA, CLDR_LIKELY, CLDR_ROOT + "LICENSE", CLDR_ROOT + "TAG.txt", CLDR_ROOT + "SOURCE.sdn", CLDR_RANKING]:
            expect(package_sha256(path)).to_equal("sha256:" + font_bundle_pin_sha256(bundle_pins, path))
        expect(file_read_text(CLDR_ROOT + "TAG.txt")).to_contain("object " + source.source_commit)
        expect(source.license).to_equal("Unicode-3.0")
        expect(selected.len()).to_equal(10)
        expect(evidence.len()).to_equal(11)
        expect(selected[0].language).to_equal("en")
        expect(selected[8].language).to_equal("ur")
        expect(selected[9].language).to_equal("id")
        expect(evidence[10].language).to_equal("bn")
        expect(selected[9].literate_functional_total).to_be_greater_than(evidence[10].literate_functional_total)

        step("Regenerate the top eleven twice from the exact pinned XML bytes")
        val population_xml = file_read_text(CLDR_DATA)
        val metadata_xml = file_read_text(CLDR_METADATA)
        val likely_xml = file_read_text(CLDR_LIKELY)
        val first = cldr_rank_languages(population_xml, metadata_xml, likely_xml)
        val second = cldr_rank_languages(population_xml, metadata_xml, likely_xml)
        val contributions = cldr_scan_language_population(population_xml)
        match contributions:
            case Ok(rows):
                expect(rows.len()).to_equal(1589)
                for row in rows:
                    expect(row.contribution).to_equal(expected_cldr_contribution(row))
            case Err(message):
                fail("pinned CLDR contribution replay failed: {message}")
        match first:
            case Ok(first_rows):
                match second:
                    case Ok(second_rows):
                        val first_bytes = cldr_serialize_language_totals(first_rows, 11)
                        val second_bytes = cldr_serialize_language_totals(second_rows, 11)
                        expect(first_bytes).to_equal(second_bytes)
                        expect(first_bytes).to_equal(file_read_text(CLDR_RANKING))
                        var i: i64 = 0
                        while i < 11:
                            expect(first_rows[i].language).to_equal(evidence[i].language)
                            expect(first_rows[i].likely_script).to_equal(evidence[i].likely_script)
                            expect(first_rows[i].total).to_equal(evidence[i].literate_functional_total)
                            var script_totals = ""
                            var j: i64 = 0
                            while j < first_rows[i].script_totals.len():
                                if j > 0:
                                    script_totals = script_totals + ","
                                val script = first_rows[i].script_totals[j]
                                script_totals = script_totals + script.script + "=" + script.total.to_text()
                                j = j + 1
                            expect(script_totals).to_equal(evidence[i].script_totals)
                            i = i + 1
                    case Err(message):
                        fail("second pinned CLDR regeneration failed: {message}")
            case Err(message):
                fail("first pinned CLDR regeneration failed: {message}")

    # @req REQ-004 REQ-005
    # @req NFR-001 NFR-003
    it "should verify every immutable bundled font and adjacent notice":
        val assets = setup_shared_font_fixture()
        val bundle_pins = selected_font_bundle_asset_pins()
        val corpus_sha256 = font_bundle_pin_sha256(bundle_pins, FONT_CORPUS_PATH)
        val corpus_ref = FONT_CORPUS_PATH + "#sha256:" + corpus_sha256
        expect_font_bundle(bundle_pins)
        expect(file_exists(FONT_CORPUS_PATH)).to_be(true)
        expect(package_sha256(FONT_CORPUS_PATH)).to_equal("sha256:" + corpus_sha256)
        var total_bytes: i64 = 0
        var paths = "|"
        var hashes = "|"
        for asset in assets:
            expect_font_license(asset, corpus_ref)
            expect(paths.contains("|" + asset.upstream_path + "|")).to_be(false)
            expect(hashes.contains("|" + asset.sha256 + "|")).to_be(false)
            paths = paths + asset.upstream_path + "|"
            hashes = hashes + asset.sha256 + "|"
            total_bytes = total_bytes + asset.byte_len
        val distribution_paths = dir_walk("assets/fonts")
        var distribution_bytes = (file_read_bytes("LICENSE").len() +
            file_read_bytes("THIRD_PARTY_NOTICES.md").len())
        for path in distribution_paths:
            distribution_bytes = distribution_bytes + file_read_bytes(path).len()
        expect(total_bytes).to_equal(51764704)
        expect(distribution_paths.len()).to_equal(57)
        expect(distribution_paths.len() + 2).to_equal(59)
        expect(distribution_bytes).to_equal(53433272)
        expect(distribution_bytes).to_be_less_than(80 * 1024 * 1024 + 1)

    # @req REQ-005 REQ-009
    it "should fail closed when a second selected face stales the first wrapper":
        step("Reject a stale global-face wrapper after loading a second selected face")
        val assets = setup_shared_font_fixture()
        val first_asset = assets[13]
        val second_asset = assets[14]
        var dylib_available = false
        var exercised = false
        for dylib_path in browser_font_dylib_candidates():
            if file_exists(dylib_path) and not exercised:
                dylib_available = true
                val first_loaded = FontRasterizer.load(dylib_path, first_asset.local_path)
                if first_loaded == nil:
                    fail("font rasterizer dylib exists but selected face A could not load")
                var first = first_loaded.?
                defer:
                    if first.lib_handle != 0:
                        first.close()
                expect(first.is_current()).to_be(true)
                expect(first.cache_identity()).to_equal("sha256={first_asset.sha256};axes={first_asset.default_axes}")

                val second_loaded = FontRasterizer.load(dylib_path, second_asset.local_path)
                if second_loaded == nil:
                    first.close()
                    fail("font rasterizer dylib exists but selected face B could not load")
                var second = second_loaded.?
                defer:
                    if second.lib_handle != 0:
                        second.close()
                expect(second.is_current()).to_be(true)
                expect(second.cache_identity()).to_equal("sha256={second_asset.sha256};axes={second_asset.default_axes}")
                expect(first.is_current()).to_be(false)
                expect(first.cache_identity()).to_equal("")
                expect(first.has_glyph(65)).to_be(false)
                expect(first.rasterize(65, 24)).to_be_nil()
                expect(first.rasterize_subpixel(65, 24)).to_be_nil()
                expect(first.layout_text("A", 24, 0).len()).to_equal(0)
                expect(first.horizontal_kern(65, 86, 24)).to_equal(0)
                expect(first.horizontal_line_metric(24, 0)).to_equal(0)
                first.close()
                expect(second.is_current()).to_be(true)
                expect(second.has_glyph(65)).to_be(true)
                expect(second.rasterize(65, 24) != nil).to_be(true)
                second.close()
                exercised = true
        if not dylib_available:
            fail("unavailable: no font rasterizer dylib exists; stale-wrapper evidence did not run")
        expect(exercised).to_be(true)

    # @req REQ-005
    it "should bind accepted-simple policy to the exact candidate corpus":
        step("Check every candidate against its exact CORPUS codepoints and accepted-simple policy")
        val assets = setup_shared_font_fixture()
        var accepted_simple: i64 = 0
        var candidate: i64 = 0
        for asset in assets:
            if asset.coverage_state.starts_with("accepted-simple:"):
                accepted_simple = accepted_simple + 1
            elif asset.coverage_state.starts_with("candidate:"):
                candidate = candidate + 1
            else:
                fail("unknown coverage state: " + asset.coverage_state)
        expect(accepted_simple).to_equal(12)
        expect(candidate).to_equal(4)
        expect_candidate_witness(assets, "Noto Sans SC", "English中文EspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Noto Sans Devanagari", "EnglishEspañolहिन्दीfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Noto Sans Arabic", "EnglishEspañolالعربيةfrançaisPortuguêsاردوIndonesia")
        expect_candidate_witness(assets, "Noto Sans Bengali", "বাংলা")
        expect_candidate_witness(assets, "Noto Serif SC", "English中文EspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Noto Serif Devanagari", "EnglishEspañolहिन्दीfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Noto Naskh Arabic", "EnglishEspañolالعربيةfrançaisPortuguêsاردوIndonesia")
        expect_candidate_witness(assets, "Noto Serif Bengali", "বাংলা")
        expect_candidate_witness(assets, "Noto Sans Mono", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Bungee", "EnglishEspañolfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Nunito", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Caveat", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Roboto Slab", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "UnifrakturCook", "EnglishEspañolfrançaisPortuguêsIndonesia")
        expect_candidate_witness(assets, "Pixelify Sans", "EnglishEspañolfrançaisPortuguêsРусскийIndonesia")
        expect_candidate_witness(assets, "Noto Emoji", "😀")

    # @req REQ-008
    it "should reconstruct every compound outline reached by exact corpus mappings":
        step("Replay exact CORPUS mappings through the bounded Pure Simple glyf parser")
        expect_compound_corpus(setup_shared_font_fixture())

    # @req REQ-004 REQ-005
    it "should preserve the separate Roboto Slab copyright notice":
        val copyright_path = FONT_ASSET_ROOT + "apache/robotoslab/COPYRIGHT.txt"
        expect(file_exists(copyright_path)).to_be(true)
        val copyright_text = file_read_text(copyright_path)
        expect(copyright_text.len()).to_be_greater_than(0)
        expect(copyright_text).to_contain("Copyright 2018 The Roboto Slab Project Authors")

    # @req REQ-003
    it "should provide one honest status for all one hundred sparse cells":
        val cells = selected_font_coverage_matrix()
        expect_language_coverage(cells)
        expect(cells[10].status).to_equal("native")
        expect(cells[10].witness_family).to_equal("Noto Sans SC")
        expect(cells[31].status).to_equal("unavailable")
        expect(cells[32].status).to_equal("fallback")
        expect(cells[32].witness_family).to_equal("Noto Sans Devanagari")
        expect(cells[41].status).to_equal("unavailable")
        expect(cells[42].status).to_equal("fallback")
        expect(cells[42].witness_family).to_equal("Noto Sans Arabic")
        expect(cells[73].status).to_equal("not-designed-for-script")
        expect(cells[81].status).to_equal("unavailable")
        expect(cells[82].status).to_equal("fallback")
        expect(cells[82].witness_family).to_equal("Noto Sans Arabic")
        expect(cells[9].status).to_equal("native")
        expect(cells[9].witness_family).to_equal("Noto Emoji")
