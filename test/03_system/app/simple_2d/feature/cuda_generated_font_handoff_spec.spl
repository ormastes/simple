# @tag: rendering, font, engine2d, cuda
# @req REQ-010 REQ-014 NFR-002 NFR-008
# @evidence-display: links

"""# CUDA Generated Font Handoff

Conditional supporting evidence that the checker-produced Simple CUDA font
artifact is authenticated, installed through Engine2D, dispatched on CUDA, and
compared with an exact CPU pixel oracle. It is release-blocking only when CUDA
is the selected promotion lane. Missing compiler provenance, hardware, or
device-origin readback fails explicitly.
"""

use std.spec.{describe, it, expect, step, fail_test}
use std.io_runtime.{env_get, file_exists, file_read, file_hash_sha256}
use std.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.text_layout.font_renderer.{FontRenderBatch, FontRenderQuad}
use std.common.gpu.font_atlas_composite.{
    FONT_ATLAS_COMPOSITE_ENTRY, FONT_ATLAS_COMPOSITE_PROGRAM_VERSION
}
use compiler.backend.gpu_portable_compute.{
    PortableComputeTarget, emit_portable_font_atlas_composite_kernel
}

describe "CUDA generated font handoff evidence":
    it "should dispatch the checker-produced CUDA font artifact and read back its pixels":
        step("Prove native submission and device readback")
        val evidence_path = env_get("CUDA_FONT_TOOLCHAIN_EVIDENCE") ?? "build/portable_compute_toolchains/evidence.env"
        if not file_exists(evidence_path):
            fail_test("CUDA font handoff unavailable: portable toolchain evidence is missing")
        else:
            val record = file_read(evidence_path)
            var artifact_status = ""
            var artifact_path = ""
            var artifact_sha256 = ""
            var required_symbols = ""
            var emitter_source_sha256 = ""
            var emitter_version_sha256 = ""
            var generated_source_sha256 = ""
            var simple_invocation_path = ""
            var simple_invocation_sha256 = ""
            var simple_runtime_path = ""
            var simple_runtime_sha256 = ""
            var simple_runtime_format = ""
            for line in record.split("\n"):
                if line.starts_with("cuda_font_status="):
                    artifact_status = line.substring("cuda_font_status=".len())
                elif line.starts_with("cuda_font_artifact="):
                    artifact_path = line.substring("cuda_font_artifact=".len())
                elif line.starts_with("cuda_font_artifact_sha256="):
                    artifact_sha256 = line.substring("cuda_font_artifact_sha256=".len())
                elif line.starts_with("cuda_font_required_symbols="):
                    required_symbols = line.substring("cuda_font_required_symbols=".len())
                elif line.starts_with("cuda_font_emitter_source_sha256="):
                    emitter_source_sha256 = line.substring("cuda_font_emitter_source_sha256=".len())
                elif line.starts_with("cuda_font_emitter_version_sha256="):
                    emitter_version_sha256 = line.substring("cuda_font_emitter_version_sha256=".len())
                elif line.starts_with("cuda_font_generated_source_sha256="):
                    generated_source_sha256 = line.substring("cuda_font_generated_source_sha256=".len())
                elif line.starts_with("simple_invocation_path="):
                    simple_invocation_path = line.substring("simple_invocation_path=".len())
                elif line.starts_with("simple_invocation_sha256="):
                    simple_invocation_sha256 = line.substring("simple_invocation_sha256=".len())
                elif line.starts_with("simple_runtime_path="):
                    simple_runtime_path = line.substring("simple_runtime_path=".len())
                elif line.starts_with("simple_runtime_sha256="):
                    simple_runtime_sha256 = line.substring("simple_runtime_sha256=".len())
                elif line.starts_with("simple_runtime_format="):
                    simple_runtime_format = line.substring("simple_runtime_format=".len())

            if (artifact_status != "compiled_artifact_verified" or
                required_symbols != FONT_ATLAS_COMPOSITE_ENTRY or
                artifact_path == "" or artifact_sha256.len() != 64 or
                not artifact_path.ends_with(".ptx") or not file_exists(artifact_path) or
                emitter_source_sha256.len() != 64 or emitter_version_sha256.len() != 64 or
                generated_source_sha256.len() != 64 or
                simple_invocation_sha256.len() != 64 or simple_runtime_sha256.len() != 64 or
                not file_exists(simple_invocation_path) or not file_exists(simple_runtime_path) or
                (simple_runtime_format != "elf" and simple_runtime_format != "mach-o")):
                fail_test("CUDA font handoff unavailable: checker artifact contract is incomplete")
            else:
                val current = emit_portable_font_atlas_composite_kernel(PortableComputeTarget.Cuda)
                val generated_source_path = artifact_path.substring(0, artifact_path.len() - 4) + ".cu"
                val generated_source = if file_exists(generated_source_path): file_read(generated_source_path) else: ""
                val provenance_valid = (emitter_source_sha256 == current.source_hash() and
                    emitter_version_sha256 == current.version_hash() and
                    generated_source.trim() == current.source.trim() and
                    file_hash_sha256(generated_source_path) == generated_source_sha256 and
                    file_hash_sha256(simple_invocation_path) == simple_invocation_sha256 and
                    file_hash_sha256(simple_runtime_path) == simple_runtime_sha256)
                if not provenance_valid:
                    fail_test("CUDA font handoff unavailable: Simple emitter provenance is stale or unauthenticated")
                else:
                    val ptx = file_read(artifact_path)
                    var engine = Engine2D.create_with_backend(4, 4, "cuda")
                    if engine.backend_name() != "cuda":
                        engine.shutdown()
                        fail_test("CUDA font handoff unavailable: native CUDA Engine2D backend is unavailable")
                    else:
                        val installed = engine.install_cuda_font_artifact(
                            ptx, artifact_sha256, FONT_ATLAS_COMPOSITE_PROGRAM_VERSION)
                        engine.clear(0xff000000u32)
                        val batch = FontRenderBatch(
                            program_version: FONT_ATLAS_COMPOSITE_PROGRAM_VERSION,
                            font_identity: "cuda-generated-font-handoff", face_generation: 1,
                            valid: true, atlas_width: 1, atlas_height: 1,
                            atlas_pixels: [0xff000000u32],
                            quads: [FontRenderQuad(
                                codepoint: 65, byte_offset: 0, dst_x: 1, dst_y: 1,
                                width: 1, height: 1, atlas_x: 0, atlas_y: 0,
                                color: 0xffff0000u32)],
                            atlas_generation: 1, dirty_rects: [])
                        val drawn = engine._draw_font_batch_plan(0, 0, batch, ["cuda"])
                        val readback = engine.read_pixels_with_source()
                        val execution_target = engine.font_execution_target()
                        val execution_attempts = engine.font_execution_attempts()
                        val pinned_identity = engine.cuda_backend.?.session.font_module_identity
                        engine.shutdown()

                        var oracle = [0xff000000u32; 16]
                        oracle[5] = 0xffff0000u32
                        var mismatches: i64 = if readback.pixels.len() == oracle.len(): 0 else: 1
                        var pixel_index: i64 = 0
                        while pixel_index < readback.pixels.len() and pixel_index < oracle.len():
                            if readback.pixels[pixel_index] != oracle[pixel_index]:
                                mismatches = mismatches + 1
                            pixel_index = pixel_index + 1

                        expect(installed).to_be(true)
                        expect(drawn).to_be(true)
                        expect(execution_target).to_equal("cuda")
                        expect(execution_attempts).to_contain("cuda:success")
                        expect(pinned_identity).to_equal("generated-ptx:" + artifact_sha256)
                        expect(readback.source).to_equal("device_readback")
                        expect(readback.backend_handle).to_be_greater_than(0)
                        expect(readback.pixel_count).to_equal(16)
                        expect(mismatches).to_equal(0)
