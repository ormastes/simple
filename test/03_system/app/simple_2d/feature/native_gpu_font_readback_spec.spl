# @tag: rendering, font, engine3d, simpleos, performance
# @req REQ-012 REQ-013 REQ-014 NFR-002 NFR-004 NFR-005 NFR-006 NFR-008
# @evidence-display: links

"""# Native GPU Font Readback

Release-blocking native evidence for Engine3D font texture rendering, SimpleOS
pinned-font pixels, and warm performance/resource bounds. Unavailable hardware
and missing durable artifacts fail explicitly; CPU rendering and uploaded-only
textures cannot satisfy this spec.
"""

use std.spec.{describe, it, expect, step, fail_test}
use std.io_runtime.{file_read, file_size, file_hash_sha256}
use std.gpu.engine3d.engine.{Engine3D}
use std.gpu.engine3d.types3d.{mat4_translate, mat4_perspective}
use test.system.qemu.os.common.qemu_os_harness.{file_exists}
use test.helpers.shared_multilingual_gpu_fonts_perf_evidence.{
    expect_font_perf_budget, read_font_perf_evidence
}

val FONT_PATH = "assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf"
val FONT_ASSET_SHA256 = "2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081"
val FONT_REGION_RGB_SHA256 = "65f5480aa1d19b4496b2f9f45ab0e7a8a0ec9e02c9a9d674879ececa138ff73c"

class Engine3DFontReadbackEvidence:
    status: text
    reason: text
    device_handle: i64
    device_name: text
    device_type: text
    driver_identity: text
    submitted_command_handle: i64
    pipeline_handle: i64
    texture_handle: i64
    sampler_handle: i64
    hud_draws: i64
    hud_placement_verified: bool
    world_draws: i64
    world_depth_transform_verified: bool
    fence_handle: i64
    fence_waited: bool
    fence_destroyed: bool
    readback_source: text
    color_image_handle: i64
    readback_bytes: i64
    readback_matches_evidence: bool
    nonblank_pixels: bool
    cpu_oracle_parity: bool

class SimpleOsFontPixelEvidence:
    status: text
    reason: text
    asset_sha256: text
    region_rgb_sha256: text
    device_origin: text
    region_rgb_bytes: i64

fn expect_engine3d_font_readback(evidence: Engine3DFontReadbackEvidence) -> bool:
    evidence.status == "pass" and evidence.device_handle > 0 and
        evidence.device_name != "" and (evidence.device_type == "discrete" or evidence.device_type == "integrated" or evidence.device_type == "virtual") and
        evidence.driver_identity != "" and evidence.submitted_command_handle > 0 and
        evidence.pipeline_handle > 0 and evidence.texture_handle > 0 and
        evidence.sampler_handle > 0 and evidence.hud_draws > 0 and evidence.hud_placement_verified and
        evidence.world_draws > 0 and evidence.world_depth_transform_verified and
        evidence.fence_handle > 0 and evidence.fence_waited and
        evidence.fence_destroyed and evidence.readback_source == "device_image_readback" and
        evidence.color_image_handle > 0 and evidence.readback_bytes == 16384 and
        evidence.readback_matches_evidence and evidence.nonblank_pixels and
        evidence.cpu_oracle_parity

fn expect_simpleos_font_pixel_oracle(evidence: SimpleOsFontPixelEvidence) -> bool:
    evidence.status == "pass" and evidence.asset_sha256 == FONT_ASSET_SHA256 and
        evidence.region_rgb_sha256 == FONT_REGION_RGB_SHA256 and
        evidence.device_origin == "qemu-pmemsave" and evidence.region_rgb_bytes == 1242

fn _collect_engine3d_font_readback() -> Engine3DFontReadbackEvidence:
    var engine = Engine3D.create(64, 64)
    if not engine.install_vulkan_font_backend():
        return Engine3DFontReadbackEvidence(
            status: "unavailable", reason: "public-vulkan-font-install-failed",
            device_handle: 0, device_name: "", device_type: "", driver_identity: "", submitted_command_handle: 0, pipeline_handle: 0,
            texture_handle: 0, sampler_handle: 0, hud_draws: 0, hud_placement_verified: false, world_draws: 0,
            world_depth_transform_verified: false, fence_handle: 0,
            fence_waited: false, fence_destroyed: false, readback_source: "none",
            color_image_handle: 0, readback_bytes: 0, readback_matches_evidence: false, nonblank_pixels: false, cpu_oracle_parity: false)
    if not engine.load_font(FONT_PATH):
        engine.shutdown()
        return Engine3DFontReadbackEvidence(
            status: "unavailable", reason: "runtime-font-face-unavailable",
            device_handle: 0, device_name: "", device_type: "", driver_identity: "", submitted_command_handle: 0, pipeline_handle: 0, texture_handle: 0,
            sampler_handle: 0, hud_draws: 0, hud_placement_verified: false, world_draws: 0,
            world_depth_transform_verified: false, fence_handle: 0,
            fence_waited: false, fence_destroyed: false, readback_source: "none",
            color_image_handle: 0, readback_bytes: 0, readback_matches_evidence: false, nonblank_pixels: false, cpu_oracle_parity: false)
    engine.set_camera(mat4_translate(-0.5, 0.0, -2.0), mat4_perspective(1.0, 1.0, 0.1, 100.0))
    engine.begin_frame()
    val near_only_drawn = engine.draw_text_world(0.5, 0.0, 0.0, "A", 0xff00ff00u32, 14)
    engine.end_frame()
    val near_only = engine.read_pixels()
    engine.begin_frame()
    val far_only_drawn = engine.draw_text_world(0.5, 0.0, -1.0, "A", 0xffff0000u32, 14)
    engine.end_frame()
    val far_only = engine.read_pixels()
    engine.begin_frame()
    val far_first_drawn = engine.draw_text_world(0.5, 0.0, -1.0, "A", 0xffff0000u32, 14)
    val near_last_drawn = engine.draw_text_world(0.5, 0.0, 0.0, "A", 0xff00ff00u32, 14)
    engine.end_frame()
    val far_then_near = engine.read_pixels()
    engine.begin_frame()
    val near_first_drawn = engine.draw_text_world(0.5, 0.0, 0.0, "A", 0xff00ff00u32, 14)
    val far_last_drawn = engine.draw_text_world(0.5, 0.0, -1.0, "A", 0xffff0000u32, 14)
    engine.end_frame()
    val near_then_far = engine.read_pixels()
    var opaque_overlap_count: i64 = 0
    var near_wins_both_orders = true
    var depth_i: i64 = 0
    while (depth_i < near_only.len() and depth_i < far_only.len() and
        depth_i < far_then_near.len() and depth_i < near_then_far.len()):
        if near_only[depth_i] == 0xff00ff00u32 and far_only[depth_i] == 0xffff0000u32:
            opaque_overlap_count = opaque_overlap_count + 1
            if far_then_near[depth_i] != 0xff00ff00u32 or near_then_far[depth_i] != 0xff00ff00u32:
                near_wins_both_orders = false
        depth_i = depth_i + 1
    val world_depth_verified = (near_only_drawn and far_only_drawn and far_first_drawn and near_last_drawn and
        near_first_drawn and far_last_drawn and near_only.len() == 4096 and far_only.len() == 4096 and
        far_then_near.len() == 4096 and near_then_far.len() == 4096 and
        opaque_overlap_count > 0 and near_wins_both_orders)

    var hud_fonts = engine.fonts()
    val hud_batch = hud_fonts.prepare_text("HUD", 0xffffffffu32, 18)
    var expected_hud_min_x: i64 = 64
    var expected_hud_min_y: i64 = 64
    var expected_hud_max_x: i64 = -1
    var expected_hud_max_y: i64 = -1
    var expected_hud_pixel_count: i64 = 0
    for quad in hud_batch.quads:
        var hud_row: i32 = 0
        while hud_row < quad.height:
            var hud_col: i32 = 0
            while hud_col < quad.width:
                val alpha = (hud_batch.atlas_pixels[(quad.atlas_y + hud_row) * hud_batch.atlas_width + quad.atlas_x + hud_col] >> 24u32) & 255u32
                val hud_x = 4 + quad.dst_x + hud_col
                val hud_y = 4 + quad.dst_y + hud_row
                if alpha > 0u32 and hud_x >= 0 and hud_x < 64 and hud_y >= 0 and hud_y < 64:
                    expected_hud_pixel_count = expected_hud_pixel_count + 1
                    if hud_x.to_i64() < expected_hud_min_x: expected_hud_min_x = hud_x.to_i64()
                    if hud_y.to_i64() < expected_hud_min_y: expected_hud_min_y = hud_y.to_i64()
                    if hud_x.to_i64() > expected_hud_max_x: expected_hud_max_x = hud_x.to_i64()
                    if hud_y.to_i64() > expected_hud_max_y: expected_hud_max_y = hud_y.to_i64()
                hud_col = hud_col + 1
            hud_row = hud_row + 1
    engine.begin_frame()
    val hud_drawn = engine.draw_text_hud(4, 4, "HUD", 0xffffffffu32, 18)
    engine.end_frame()
    val hud_pixels = engine.read_pixels()
    var actual_hud_min_x: i64 = 64
    var actual_hud_min_y: i64 = 64
    var actual_hud_max_x: i64 = -1
    var actual_hud_max_y: i64 = -1
    var actual_hud_pixel_count: i64 = 0
    var hud_i: i64 = 0
    while hud_i < hud_pixels.len():
        if hud_pixels[hud_i] != 0u32:
            val hud_x = hud_i % 64
            val hud_y = hud_i / 64
            actual_hud_pixel_count = actual_hud_pixel_count + 1
            if hud_x < actual_hud_min_x: actual_hud_min_x = hud_x
            if hud_y < actual_hud_min_y: actual_hud_min_y = hud_y
            if hud_x > actual_hud_max_x: actual_hud_max_x = hud_x
            if hud_y > actual_hud_max_y: actual_hud_max_y = hud_y
        hud_i = hud_i + 1
    val hud_placement_verified = (hud_batch.valid and hud_drawn and hud_pixels.len() == 4096 and
        expected_hud_pixel_count > 0 and expected_hud_pixel_count == actual_hud_pixel_count and
        expected_hud_min_x == actual_hud_min_x and expected_hud_min_y == actual_hud_min_y and
        expected_hud_max_x == actual_hud_max_x and expected_hud_max_y == actual_hud_max_y)

    engine.clear(0u32)
    engine.enable_font_cpu_comparator(true)
    engine.begin_frame()
    val mixed_hud_drawn = engine.draw_text_hud(4, 4, "HUD", 0xffffffffu32, 18)
    val world_drawn = engine.draw_text_world(0.5f32, 0.0f32, 0.0f32, "WORLD", 0xff40ff40u32, 14)
    engine.end_frame()
    val installed = engine.vulkan_font_evidence()
    if installed == nil:
        engine.shutdown()
        return Engine3DFontReadbackEvidence(
            status: "unavailable", reason: "native-vulkan-font-evidence-missing",
            device_handle: 0, device_name: "", device_type: "", driver_identity: "", submitted_command_handle: 0, pipeline_handle: 0, texture_handle: 0,
            sampler_handle: 0, hud_draws: 0, hud_placement_verified: false, world_draws: 0,
            world_depth_transform_verified: false, fence_handle: 0,
            fence_waited: false, fence_destroyed: false, readback_source: "none",
            color_image_handle: 0, readback_bytes: 0, readback_matches_evidence: false, nonblank_pixels: false, cpu_oracle_parity: false)
    val native = installed.?
    val device_pixels = engine.read_pixels()
    val cpu_pixels = engine.read_cpu_comparator_pixels()
    var nonblank = false
    var parity = device_pixels.len() == cpu_pixels.len() and device_pixels.len() > 0
    var matches_evidence = (native.device.readback_bytes == native.pixels_rgba8.len() and
        native.pixels_rgba8.len() == device_pixels.len() * 4)
    var i: i64 = 0
    while i < device_pixels.len():
        if device_pixels[i] != 0u32:
            nonblank = true
        if parity and device_pixels[i] != cpu_pixels[i]:
            parity = false
        val byte_index = i * 4
        if matches_evidence:
            val pixel = device_pixels[i]
            matches_evidence = (native.pixels_rgba8[byte_index] == ((pixel >> 16u32) & 255u32).to_u8() and
                native.pixels_rgba8[byte_index + 1] == ((pixel >> 8u32) & 255u32).to_u8() and
                native.pixels_rgba8[byte_index + 2] == (pixel & 255u32).to_u8() and
                native.pixels_rgba8[byte_index + 3] == ((pixel >> 24u32) & 255u32).to_u8())
        i = i + 1
    val passed = native.ready and hud_placement_verified and mixed_hud_drawn and world_drawn and world_depth_verified and nonblank and parity
    val evidence = Engine3DFontReadbackEvidence(
        status: if passed: "pass" else: "unavailable",
        reason: if not world_depth_verified: "native-world-depth-oracle-failed" elif not hud_placement_verified: "native-hud-placement-oracle-failed" else: native.reason,
        device_handle: native.device.device_handle, device_name: native.device.device_name,
        device_type: native.device.device_type,
        driver_identity: native.device.driver_identity,
        submitted_command_handle: native.device.submitted_command_handle,
        pipeline_handle: native.hud_pipeline_handle,
        texture_handle: native.atlas_handle, sampler_handle: native.sampler_handle,
        hud_draws: native.hud_draws, hud_placement_verified: hud_placement_verified,
        world_draws: native.world_draws,
        world_depth_transform_verified: world_depth_verified,
        fence_handle: native.device.fence_handle, fence_waited: native.device.fence_waited,
        fence_destroyed: native.device.fence_destroyed, readback_source: native.device.readback_source,
        color_image_handle: native.device.color_image_handle,
        readback_bytes: native.device.readback_bytes, readback_matches_evidence: matches_evidence,
        nonblank_pixels: nonblank,
        cpu_oracle_parity: parity)
    engine.shutdown()
    evidence

fn _collect_simpleos_pixel_evidence() -> SimpleOsFontPixelEvidence:
    val root = "build/simpleos_wm_fullscreen_evidence/"
    val evidence_path = root + "evidence.env"
    if not file_exists(evidence_path):
        return SimpleOsFontPixelEvidence(
            status: "unavailable", reason: "retained QEMU evidence.env is missing",
            asset_sha256: "", region_rgb_sha256: "", device_origin: "none",
            region_rgb_bytes: 0)
    val record = file_read(evidence_path)
    val font_region_path = root + "font-region.rgb"
    val valid = (record.contains("simpleos_wm_fullscreen_status=pass") and
        record.contains("simpleos_wm_fullscreen_disk_image_status=pass") and
        record.contains("simpleos_wm_fullscreen_font_asset_sha256=" + FONT_ASSET_SHA256) and
        record.contains("simpleos_wm_fullscreen_font_region_rgb_bytes=1242") and
        record.contains("simpleos_wm_fullscreen_font_region_rgb_sha256=" + FONT_REGION_RGB_SHA256) and
        record.contains("simpleos_wm_fullscreen_scanout_pixel_format=argb8888") and
        file_exists(font_region_path) and file_size(font_region_path) == 1242 and
        file_hash_sha256(font_region_path) == FONT_REGION_RGB_SHA256 and
        file_exists(root + "serial.log") and file_exists(root + "baseline.ppm.raw") and
        file_exists(root + "baseline.ppm") and file_exists(root + "capture.out"))
    SimpleOsFontPixelEvidence(
        status: if valid: "pass" else: "unavailable",
        reason: if valid: "" else: "retained QEMU record or artifacts are incomplete",
        asset_sha256: if valid: FONT_ASSET_SHA256 else: "",
        region_rgb_sha256: if valid: FONT_REGION_RGB_SHA256 else: "",
        device_origin: if valid: "qemu-pmemsave" else: "none",
        region_rgb_bytes: if valid: 1242 else: 0)

describe "native GPU font promotion evidence":
    it "should render HUD and world text through real native font resources":
        step("Prove native submission and device readback")
        step("Render Engine3D HUD and world text on the promoted backend")
        val evidence = _collect_engine3d_font_readback()
        print "engine3d_font status={evidence.status} reason={evidence.reason} device={evidence.device_handle} pipeline={evidence.pipeline_handle} texture={evidence.texture_handle} sampler={evidence.sampler_handle} fence={evidence.fence_handle} readback_bytes={evidence.readback_bytes}"
        if not expect_engine3d_font_readback(evidence):
            fail_test("Engine3D native font promotion unavailable: " + evidence.reason)
        expect(expect_engine3d_font_readback(evidence)).to_be(true)

    it "should capture the pinned SimpleOS glyph from guest framebuffer memory":
        step("Boot SimpleOS with the pinned font asset")
        step("Capture SimpleOS pinned-font pixels")
        val evidence = _collect_simpleos_pixel_evidence()
        if not expect_simpleos_font_pixel_oracle(evidence):
            fail_test("SimpleOS pinned-font pixel oracle unavailable: " + evidence.reason)
        expect(expect_simpleos_font_pixel_oracle(evidence)).to_be(true)

    it "should meet warm latency, GPU benefit, upload, RSS, and resource budgets":
        step("Measure warm font rendering and resource bounds")
        val evidence = read_font_perf_evidence()
        if not expect_font_perf_budget(evidence):
            fail_test("native font performance evidence unavailable: " + evidence.reason)
        expect(expect_font_perf_budget(evidence)).to_be(true)
