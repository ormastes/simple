# codex-system-test
# @tag: rendering, font, web, gui, wm, draw_ir, engine2d
"""# Legacy Web GUI and WM Shared Font Route

Proves the canonical Web, GUI widget, and WM producers retain resolved font
identity and advance metadata in DrawIrComposition, then submit those same
compositions through the shared Engine2D CPU Draw IR route while the
caller-owned Draw IR metadata remains unchanged.
"""

use std.spec.*
use common.ui.builder.{column, label}
use common.ui.draw_ir.{DRAW_IR_BACKEND_CPU, DRAW_IR_COMMAND_TEXT, DrawIrCommand, DrawIrComposition}
use common.ui.taskbar_model.{AppRef, TaskbarModel}
use common.ui.widget_draw_ir.{widget_tree_to_draw_ir_cpu}
use common.ui.window.{WindowManager}
use common.ui.window_scene.{shared_wm_scene_from_window_manager}
use common.ui.window_scene_draw_ir.{shared_wm_scene_draw_ir_composition}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry}
use std.gc_async_mut.gpu.browser_engine.web_render_backend.{WebRenderBackend}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{Engine2dDrawIrAdvResult, engine2d_draw_ir_adv_composition}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}

fn _text_command(composition: DrawIrComposition, value: text) -> DrawIrCommand:
    var match_count = 0
    for batch in composition.batches:
        for command in batch.commands:
            if command.kind == DRAW_IR_COMMAND_TEXT and command.text_value == value:
                match_count = match_count + 1
    if match_count != 1:
        fail("expected exactly one text command for '" + value + "', got " + match_count.to_string())
    for batch in composition.batches:
        for command in batch.commands:
            if command.kind == DRAW_IR_COMMAND_TEXT and command.text_value == value:
                return command
    fail("unreachable text-command lookup failure: " + value)
    composition.batches[0].commands[0]

fn _style_value(command: DrawIrCommand, key: text) -> text:
    for prop in command.computed_style:
        if prop.key == key:
            return prop.value
    ""

fn _command_count(composition: DrawIrComposition) -> i32:
    var count = 0
    for batch in composition.batches:
        count = count + batch.commands.len()
    count

fn _expect_valid_advances(command: DrawIrCommand, advances: text):
    val parts = advances.split(",")
    var character_count = 0
    for ch in command.text_value:
        character_count = character_count + 1
    expect(parts.len()).to_equal(character_count)
    var measured_width = 0
    for raw in parts:
        val advance = raw.to_int() ?? -1
        expect(advance).to_be_greater_than(-1)
        measured_width = measured_width + advance
    expect(measured_width).to_equal(command.width)

fn expect_resolved_font_metrics(command: DrawIrCommand):
    val advances = _style_value(command, "font-advance-widths")
    expect(advances.len()).to_be_greater_than(0)
    expect(command.width).to_be_greater_than(0)
    expect(command.height).to_be_greater_than(0)
    _expect_valid_advances(command, advances)

fn expect_draw_ir_font_identity(command: DrawIrCommand) -> text:
    val identity = _style_value(command, "font-identity")
    expect(identity).to_start_with("sha256=")
    expect_resolved_font_metrics(command)
    identity

fn expect_font_render_parity(before: DrawIrCommand, after: DrawIrCommand, result: Engine2dDrawIrAdvResult, identity: text, advances: text, command_count: i32, width: i32, height: i32):
    # CPU route/metadata parity; native glyph pixel promotion is a separate gate.
    expect(result.selected_backend).to_equal("cpu")
    expect(result.skipped_command_count).to_equal(0)
    expect(result.rendered_command_count).to_equal(command_count)
    expect(result.pixels.len()).to_equal(width * height)
    expect(_style_value(after, "font-identity")).to_equal(identity)
    expect(_style_value(after, "font-advance-widths")).to_equal(advances)
    expect(after.x).to_equal(before.x)
    expect(after.y).to_equal(before.y)
    expect(after.width).to_equal(before.width)
    expect(after.height).to_equal(before.height)

fn expect_legacy_draw_ir_font_parity(composition: DrawIrComposition, value: text, width: i32, height: i32) -> text:
    val before = _text_command(composition, value)
    val identity = expect_draw_ir_font_identity(before)
    val advances = _style_value(before, "font-advance-widths")
    expect(before.kind).to_equal(DRAW_IR_COMMAND_TEXT)

    var engine = Engine2D.create_with_backend(width, height, "cpu")
    engine.clear(0xff000000u32)
    val result = engine2d_draw_ir_adv_composition(engine, composition, false)
    engine.shutdown()

    val after = _text_command(composition, value)
    expect_font_render_parity(before, after, result, identity, advances, _command_count(composition), width, height)
    identity

fn _wm_composition() -> DrawIrComposition:
    val manager = WindowManager.new()
    val registry = UiWindowSurfaceRegistry.new()
    val scene = shared_wm_scene_from_window_manager(manager, registry, 320, 160)
    val taskbar = TaskbarModel(
        pinned: [AppRef(app_id: "route", display_name: "WM route", icon: "")],
        running: [],
        tray: []
    )
    shared_wm_scene_draw_ir_composition(scene, taskbar, DRAW_IR_BACKEND_CPU, 1000, "12:00", 0)

describe "legacy Web GUI and WM shared font route":
    # @req REQ-006 REQ-011
    it "should preserve resolved font metadata and geometry through canonical CPU execution":
        step("Render legacy Web GUI and WM text through DrawIR")
        step("Resolve one selected font for layout and DrawIR paint")
        val web_backend = WebRenderBackend.create("pure_simple", 160, 80)
        val web = web_backend.render_html_to_draw_ir(
            "<html><body style='font-family:Noto Sans Mono;font-size:12px'>Web route</body></html>"
        )
        val gui = widget_tree_to_draw_ir_cpu(column("route-root", [label("route-label", "GUI route")]), 160, 80)
        val wm = _wm_composition()

        step("Render legacy and WebIR text with one face identity")
        val web_identity = expect_legacy_draw_ir_font_parity(web, "Web route", 160, 80)
        val gui_identity = expect_legacy_draw_ir_font_parity(gui, "GUI route", 160, 80)
        val wm_identity = expect_legacy_draw_ir_font_parity(wm, "WM route", 320, 160)
        expect(gui_identity).to_equal(web_identity)
        expect(wm_identity).to_equal(web_identity)
