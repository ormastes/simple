"""
NVMe base-spec command floor for the Simple firmware model.

**Feature IDs:** #NVME-BASESPEC-001
**Category:** Firmware
**Difficulty:** 3/5
**Status:** Implemented
**Requirements:** doc/02_requirements/feature/nvme_firmware_production.md
**Plan:** doc/03_plan/sys_test/nvme_base_spec_commands.md

This system spec is the must-have NVMe command baseline. It verifies the
controller lifecycle through the host-facing demo and the scalar rv32-compatible
command guards used by the bare-metal firmware evidence path.
"""

use std.spec.*
use std.io_runtime.{process_run}

val FW: text = "examples/09_embedded/simpleos_nvme_fw/fw"
val RV32: text = "examples/09_embedded/simpleos_nvme_fw/fw_rv32"

fn _run(cmd: text) -> (text, text, i64):
    process_run("/bin/sh", ["-c", cmd])

describe "NVMe base-spec command floor":
    it "covers identify, queue lifecycle, IO, flush, features, namespace guards, and abort":
        step("Run the host-facing controller lifecycle demo")
        val (ctrl_out, ctrl_err, ctrl_code) = _run("bin/simple run " + FW + "/nvme_main.spl")
        expect(ctrl_code).to_equal(0)

        step("Identify controller and namespace data is visible through the admin queue")
        expect(ctrl_out).to_contain("identify controller ok")
        expect(ctrl_out).to_contain("controller reports max IO queues")
        expect(ctrl_out).to_contain("namespace size == LBA_COUNT")

        step("Create and delete IO queues in legal order, with illegal queue binding rejected")
        expect(ctrl_out).to_contain("create IO CQ 1")
        expect(ctrl_out).to_contain("create IO SQ 1 -> CQ 1")
        expect(ctrl_out).to_contain("SQ -> missing CQ rejected")
        expect(ctrl_out).to_contain("delete bound CQ rejected")
        expect(ctrl_out).to_contain("delete SQ 1 ok")
        expect(ctrl_out).to_contain("delete CQ 1 ok")

        step("Run the rv32-compatible scalar command floor")
        val (base_out, base_err, base_code) = _run("bin/simple run " + RV32 + "/base_spec_check.spl")
        expect(base_code).to_equal(0)

        step("Admin Identify, Get/Set Features, logs, Format NVM, and firmware command guards pass")
        expect(base_out).to_contain("NVME-ADMIN-IDENTIFY-FEATURES-LOG-FORMAT-FW PASS")

        step("Queue phase handling and host opcode/bounds validation pass")
        expect(base_out).to_contain("NVME-QUEUE-PHASE-CREATE-DELETE PASS")
        expect(base_out).to_contain("NVME-HIL-OPCODE-BOUNDS PASS")

        step("NVM Read, Write Zeroes, DSM Trim, and Flush semantics pass")
        expect(base_out).to_contain("NVME-NVM-READ-WRITE-ZEROES-DSM-TRIM PASS")
        expect(base_out).to_contain("NVME-NVM-FLUSH PASS")

        step("Reserved-field, namespace, and abort/backpressure fail-closed guards pass")
        expect(base_out).to_contain("NVME-FEATURE-RESERVED-FIELD-GUARD PASS")
        expect(base_out).to_contain("NVME-NAMESPACE-RESERVED-FIELD-GUARD PASS")
        expect(base_out).to_contain("NVME-ABORT-BACKPRESSURE PASS")
        expect(base_out).to_contain("NVME BASE SPEC CHECKS PASS")
