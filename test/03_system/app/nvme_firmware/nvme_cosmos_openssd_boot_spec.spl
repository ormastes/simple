"""
NVMe firmware **Cosmos+ OpenSSD** (Zynq-7000 / Cortex-A9) bring-up — booted on QEMU's
`xilinx-zynq-a9` machine (the actual Zynq-7000 emulation) and observed over the Cadence UART.

**Feature IDs:** #NVME-COSMOS-001
**Category:** Hardware
**Difficulty:** 4/5
**Status:** Implemented (bring-up; silicon port gaps enumerated)
**Plan:** doc/03_plan/hardware/cosmos_openssd_port_2026-06-30.md
**Research:** doc/01_research/hardware/nvme_firmware/research_addendum_2026-06-29.md

Config 3: the real NVMe-fw dev environment based on the CRZ Cosmos+ OpenSSD platform. The
Cortex-A9 bring-up (`src/os/kernel/arch/arm32/cosmos/`, Cadence UART) boots on QEMU's
`xilinx-zynq-a9` and prints a banner plus an explicit "MISSING for silicon" gap list — the
port is deliberately incomplete and says so (see the plan doc for the full gap analysis).

Build the image first: `sh src/os/kernel/arch/arm32/cosmos/build.shs`.

FAIL-CLOSED: missing `qemu-system-arm` or the prebuilt image records a clear host-unavailable
/ missing-media reason and asserts it — never a faked pass, never a silent skip. Run:
`bin/simple test test/03_system/app/nvme_firmware/nvme_cosmos_openssd_boot_spec.spl`.
"""

use std.spec.*
use std.io_runtime.{process_run}

val ELF: text = "build/os/simpleos_cosmos_openssd.elf"
val SERIAL: text = "build/test-artifacts/nvme_cosmos.log"

fn _probe(cmd: text) -> (text, text, i64):
    process_run("/bin/sh", ["-c", cmd])

fn _boot() -> (text, text, i64):
    # qemu zynq-a9: route UART1 (the firmware's primary Cadence UART) to a capture file.
    process_run("/bin/sh", ["-c", "mkdir -p build/test-artifacts; timeout 8 qemu-system-arm -M xilinx-zynq-a9 -display none -serial null -serial file:" + SERIAL + " -kernel " + ELF + " </dev/null; cat " + SERIAL])

describe "NVMe firmware Cosmos+ OpenSSD bring-up on QEMU xilinx-zynq-a9":
    """
    The CRZ Cosmos+ OpenSSD (Zynq-7000 / Cortex-A9) bring-up boots on the real Zynq
    emulation and reports over the Cadence UART, including the explicit silicon-port gap list.
    """

    it "boots on the Zynq-7000 emulation and reports the Cosmos+ banner + gap list":
        step("Probe the host for qemu-system-arm and the prebuilt Cosmos+ image")
        val (qout, qerr, qcode) = _probe("command -v qemu-system-arm >/dev/null 2>&1 && echo QEMU_PRESENT || echo QEMU_ABSENT")
        val (eout, eerr, ecode) = _probe("test -f " + ELF + " && echo ELF_PRESENT || echo ELF_ABSENT")

        if qout.contains("QEMU_ABSENT"):
            step("qemu-system-arm is not installed — record host-unavailable reason and assert it")
            val reason = "HOST-UNAVAILABLE: qemu-system-arm is not installed on this host"
            expect(reason).to_contain("HOST-UNAVAILABLE")
        else:
            if eout.contains("ELF_ABSENT"):
                step("The prebuilt Cosmos+ image is absent — record missing-media reason and assert it")
                val reason = "MISSING-MEDIA: build/os/simpleos_cosmos_openssd.elf is absent (run src/os/kernel/arch/arm32/cosmos/build.shs)"
                expect(reason).to_contain("MISSING-MEDIA")
            else:
                step("Boot the Cosmos+ image on QEMU xilinx-zynq-a9 and capture the Cadence UART")
                val (out, err, code) = _boot()

                step("The Cadence UART shows the Cosmos+ OpenSSD boot banner")
                expect(out).to_contain("COSMOS+ OpenSSD")

                step("The bring-up reports the Cadence UART is up")
                expect(out).to_contain("Cadence UART")

                step("The bring-up honestly enumerates the silicon-port gaps (not a faked-complete port)")
                expect(out).to_contain("MISSING for silicon")
