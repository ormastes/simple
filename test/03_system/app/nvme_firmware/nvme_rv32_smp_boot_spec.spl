"""
NVMe firmware rv32 **3-core SMP** boot — the Simple-compiled rv32 kernel booted on
QEMU with `-smp 3` and observed over the serial console.

**Feature IDs:** #NVME-RV32SMP-001
**Category:** Hardware
**Difficulty:** 3/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** doc/03_plan/hardware/nvme_fw_baremetal_parallel_agent_plan.md
**Design:** N/A
**Research:** doc/01_research/hardware/nvme_firmware/nvme_ssd_firmware_architecture.md

The rv32 kernel `_start` is hart-gated: every hart atomically checks in to a counter
(`_smp_online_count`, rv32imac `amoadd.w`) that lives outside the BSS-clear range, then
only hart 0 runs the primary boot while secondary harts park in WFI. Hart 0 reads the
counter and prints `[BOOT] SMP harts: N`, where N is the number of cores that came
online. Without the gate, all harts would race the BSS clear and heap init.

This spec boots the prebuilt rv32 kernel ELF (build/os/simpleos_riscv32.elf) under
`qemu-system-riscv32 -machine virt -smp 3` and asserts the 3-hart census marker, which
proves all three cores executed real code. As a control it also boots with `-smp 1` and
asserts a 1-hart census (the gate must not invent harts).

FAIL-CLOSED: this spec passes ONLY when the kernel genuinely boots and the serial shows
every required census marker (including the -smp 1 control). If `qemu-system-riscv32` is
absent, the prebuilt ELF is missing, or the census is wrong, the single classification
assertion below goes RED — it never asserts a self-containing literal and never skips. The
ELF is built by the rv32-kernel native-build recipe (see
doc/03_plan/hardware/nvme_fw_baremetal_parallel_agent_plan.md). Run:
`bin/simple test test/03_system/app/nvme_firmware/nvme_rv32_smp_boot_spec.spl`.
"""

use std.spec.*
use std.io_runtime.{process_run}

val ELF: text = "build/os/simpleos_riscv32.elf"

# process_run does not faithfully surface a child's nonzero exit status under the
# spec runner, so host/media availability is detected from stdout TOKENS.
fn _probe(cmd: text) -> (text, text, i64):
    process_run("/bin/sh", ["-c", cmd])

fn _boot_smp(n: text) -> (text, text, i64):
    val serial = "build/test-artifacts/nvme_rv32_smp" + n + ".log"
    process_run("/bin/sh", ["-c", "mkdir -p build/test-artifacts; timeout 12 qemu-system-riscv32 -machine virt -cpu rv32 -smp " + n + " -m 128M -nographic -bios none -kernel " + ELF + " -serial file:" + serial + " </dev/null; cat " + serial])

describe "NVMe firmware rv32 3-core SMP boot on QEMU":
    """
    The Simple-generated rv32 kernel boots on a 3-hart QEMU machine: every core
    atomically checks in and hart 0 reports the census, proving multi-core boot.
    """

    it "boots cleanly under -smp 3 and reports all 3 harts online":
        step("Probe the host for qemu-system-riscv32 and the prebuilt rv32 kernel ELF")
        val (qout, qerr, qcode) = _probe("command -v qemu-system-riscv32 >/dev/null 2>&1 && echo QEMU_PRESENT || echo QEMU_ABSENT")
        val (eout, eerr, ecode) = _probe("test -f " + ELF + " && echo ELF_PRESENT || echo ELF_ABSENT")

        # Single fail-closed classification: GREEN only on a genuine boot whose serial shows
        # every required marker. Missing host, missing image, or a wrong census all yield a
        # non-"pass" verdict, so the one assertion below goes RED — no self-asserting literal,
        # no silent skip.
        var verdict: text = "pass"
        if qout.contains("QEMU_ABSENT"):
            verdict = "host-unavailable: qemu-system-riscv32 not installed"
        else:
            if eout.contains("ELF_ABSENT"):
                verdict = "missing-media: " + ELF + " not built (see header for the build recipe)"
            else:
                step("Boot the rv32 kernel under -smp 3 and capture the serial console")
                val (out3, err3, code3) = _boot_smp("3")
                if not out3.contains("SimpleOS RV32"):
                    verdict = "boot-fail: SimpleOS RV32 banner absent under -smp 3"
                else:
                    if out3.contains("FAIL"):
                        verdict = "boot-fail: serial failure marker under -smp 3"
                    else:
                        if not out3.contains("[BOOT] SMP harts: 3"):
                            verdict = "boot-fail: 3-hart census marker absent under -smp 3"
                        else:
                            step("Control: booting -smp 1 must report exactly one hart (the gate invents no cores)")
                            val (out1, err1, code1) = _boot_smp("1")
                            if out1.contains("FAIL"):
                                verdict = "boot-fail: serial failure marker under -smp 1"
                            else:
                                if not out1.contains("[BOOT] SMP harts: 1"):
                                    verdict = "boot-fail: control -smp 1 did not report a single hart"

        step("Fail-closed: only a real 3-hart boot (with the 1-hart control) classifies as pass")
        expect(verdict).to_equal("pass")
