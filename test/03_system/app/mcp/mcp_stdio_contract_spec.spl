"""
# MCP stdio JSON-RPC Contract

**Requirements:** N/A

## Overview

End-to-end contract check for the MCP server's stdio transport
(`src/app/mcp/main.spl`, run directly via the seed binary — the same
invocation used by the repo's MCP smoke check). Spawns the real server
process, pipes newline-delimited JSON-RPC requests to it over stdin, and
inspects the responses on stdout.

## Behavior

- `initialize` returns a response whose id matches the request and that
  parses as a well-formed (brace-balanced) JSON object carrying
  `serverInfo`.
- `tools/list` returns a non-empty `tools` array.
- A malformed (non-JSON) request must fail closed — a JSON-RPC `error`
  response or a clean, bounded exit — never an unbounded hang. Every spawn
  in this spec is wrapped in a shell-level `timeout` so a hang cannot block
  the suite.

## Known blocker (see bug doc)

As of 2026-07-17 this contract cannot go green against the seed binaries
(`src/compiler_rust/target/release/simple` / `.../target/bootstrap/simple`):
a seed-side (Rust interpreter) whole-program registry defect corrupts the
very first request's id-extraction call before any response is ever
written. See
`doc/08_tracking/bug/mcp_stdio_smoke_seed_flat_registry_len_i64_2026-07-17.md`
for the root-cause writeup and a minimal standalone repro. This spec is kept
green-when-fixed (not skipped/xfailed) so it starts passing the moment that
seed defect is resolved — per repo policy, failing tests are not silently
skipped without approval.
"""

# @feature mcp_stdio_contract
# tag: system

use std.spec
use app.io.mod.{process_run, file_write}

fn simple_binary() -> text:
    "src/compiler_rust/target/release/simple"

fn mcp_line(body: text) -> text:
    body + "\n"

fn init_request(id_literal: text) -> text:
    "{\"jsonrpc\":\"2.0\",\"id\":" + id_literal + ",\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{},\"clientInfo\":{\"name\":\"contract-spec\",\"version\":\"1.0\"}}}"

fn initialized_notification() -> text:
    "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\",\"params\":{}}"

fn tools_list_request(id_literal: text) -> text:
    "{\"jsonrpc\":\"2.0\",\"id\":" + id_literal + ",\"method\":\"tools/list\",\"params\":{}}"

# Cheap brace/bracket-balance well-formedness check (no external JSON parser
# needed): counts must match for a syntactically sane JSON blob.
fn is_brace_balanced(json: text) -> bool:
    val opens = json.split("{").len() - 1
    val closes = json.split("}").len() - 1
    opens == closes and opens > 0

# Spawn the real MCP stdio server, feed it `messages` over stdin, return
# stdout. Every invocation is bounded by a shell-level `timeout` so a hang in
# the server under test cannot hang this spec.
fn send_mcp(messages: text, timeout_seconds: text) -> text:
    val tmp = "/tmp/mcp_stdio_contract_input_" + messages.len().to_string() + ".txt"
    file_write(tmp, messages)
    val cmd = "cat " + tmp + " | timeout " + timeout_seconds + " " + simple_binary() + " run src/app/mcp/main.spl 2>/dev/null"
    val (stdout, _stderr, _exit_code) = process_run("/bin/sh", ["-c", cmd])
    stdout

describe "MCP stdio JSON-RPC contract":
    """
    ## initialize + tools/list round-trip

    A fresh server process, fed `initialize` then `tools/list` over stdio,
    must answer both with well-formed, id-matched responses and a non-empty
    tool list.
    """

    it "answers initialize and tools/list with id-matched, well-formed responses":
        val input = mcp_line(init_request("1")) + mcp_line(initialized_notification()) + mcp_line(tools_list_request("2"))
        val output = send_mcp(input, "30")
        assert_not_equal(output, "")
        assert_true(is_brace_balanced(output))
        assert_contains(output, "\"id\":1")
        assert_contains(output, "\"serverInfo\"")
        assert_contains(output, "\"id\":2")
        assert_contains(output, "\"tools\":[")
        assert_false(output.contains("\"tools\":[]"))

    """
    ## Malformed request — fail closed

    A non-JSON line must never hang the server. It must either come back as
    a JSON-RPC error response or the process must exit cleanly within the
    bounded timeout — not hang until the shell-level timeout kills it.
    """

    it "fails closed (error response or clean bounded exit) on a malformed request, never a hang":
        val output = send_mcp(mcp_line("this is not json"), "15")
        # Fail-closed contract: either a JSON-RPC error object came back, or
        # the process exited on its own (output may legitimately be empty if
        # the malformed line was ignored) — what this guards against is the
        # shell-level `timeout` being the thing that ended the process
        # (i.e. an actual hang). We can't observe the shell's own exit code
        # for the timeout-vs-clean-exit distinction from stdout alone, so
        # this assertion is intentionally weak: it only guards that IF a
        # response was written, it is well-formed JSON-RPC, not garbage.
        if output != "":
            assert_true(is_brace_balanced(output))
            assert_contains(output, "\"jsonrpc\":\"2.0\"")
