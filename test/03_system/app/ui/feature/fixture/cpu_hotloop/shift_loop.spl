# Fixture: content-keyed ratchet survives line shifts. This loop sits well below
# the top of the file (as if lines were inserted above it); the committed
# content-keyed baseline (shift_baseline.txt — no line numbers) still matches,
# so the gate reports new=0.
fn a() -> i32:
    0

fn b() -> i32:
    0

fn paint(buf: [i32], w: i32):
    var x = 0
    while x < w:
        buf[x] = 0
        x = x + 1
