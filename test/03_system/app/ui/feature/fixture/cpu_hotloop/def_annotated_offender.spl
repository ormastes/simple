# Fixture: annotation on the DEF line does NOT reach a loop nested below it —
# the loop must still be flagged (new=1). This is the item #5 bug shape that
# motivates relocating annotations onto each loop header.
fn fill(buf: [i32], w: i32):  # cpu-lane-loop-ok: def-line annotation (WRONG placement)
    var x = 0
    while x < w:
        buf[x] = 0
        x = x + 1
