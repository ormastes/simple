# System contract spec for the duplicate-check CLI (dispatched via
# src/app/cli/dispatch/table.spl "duplicate-check" -> app_path
# src/compiler/90.tools/duplicate_check/main.spl). Runnable form established
# for this task: `simple run src/compiler/90.tools/duplicate_check/main.spl --
# <path> [options]` (the seed binary does not recognize "duplicate-check" as
# a native subcommand; the dispatch table only wires it up on the
# self-hosted binary).
#
# The duplicated fixture stays under test/ so this contract also proves that
# --no-default-excludes reaches the scanner instead of silently scanning zero
# files.

use std.nogc_sync_mut.io.process_ops.{shell, ProcessResult}

fn simple_binary() -> text:
    val result = shell("test -x src/compiler_rust/target/release/simple && echo src/compiler_rust/target/release/simple || echo bin/simple")
    result.stdout.trim()

fn stage_fixture(scratch_dir: text, fixture_dir: text) -> i64:
    val result = shell("rm -rf {scratch_dir} && mkdir -p {scratch_dir} && cp {fixture_dir}/*.spl {scratch_dir}/")
    result.exit_code

fn run_duplicate_check(simple: text, path: text) -> ProcessResult:
    val cmd = "timeout 60 {simple} run src/compiler/90.tools/duplicate_check/main.spl -- {path} --no-default-excludes --mode token --min-tokens 10 --min-lines 5 --max-allowed 0"
    shell(cmd)

describe "duplicate-check CLI contract":
    it "scans an excluded fixture when --no-default-excludes is set":
        val simple = simple_binary()
        val result = run_duplicate_check(simple, "test/fixtures/duplication/dup_pair")

        # Bounded-time: `timeout 60` kills a runaway process with exit code
        # 124. On these two tiny fixture files, the token-mode scan must
        # finish well inside that budget.
        assert_not_equal(result.exit_code, 124)

        expect(result.exit_code).to_equal(1)
        expect(result.stdout).to_contain("duplicate groups")
        expect(result.stdout.contains("Found 0 duplicate groups")).to_equal(false)

    it "reports silence for a scratch copy of clean_pair (exit 0)":
        val simple = simple_binary()
        val scratch_dir = "/tmp/duplicate_check_contract_clean_pair"
        expect(stage_fixture(scratch_dir, "test/fixtures/duplication/clean_pair")).to_equal(0)

        val result = run_duplicate_check(simple, scratch_dir)

        assert_not_equal(result.exit_code, 124)

        expect(result.exit_code).to_equal(0)
        expect(result.stdout).to_contain("Found 0 duplicate groups")
