use std.io_runtime
use std.spec.{describe, it, expect}
use std.nogc_sync_mut.engine.physics.data.contact_cache.{ContactCache, CachedContact}

fn store_one(cache: ContactCache, ba: i64, bb: i64, fa: i64, fb: i64, ln: f64, lt: f64):
    var body_a_arr: [i64] = []
    var body_b_arr: [i64] = []
    var feat_a_arr: [i64] = []
    var feat_b_arr: [i64] = []
    var ln_arr: [f64] = []
    var lt_arr: [f64] = []
    body_a_arr.push(ba)
    body_b_arr.push(bb)
    feat_a_arr.push(fa)
    feat_b_arr.push(fb)
    ln_arr.push(ln)
    lt_arr.push(lt)
    cache.store_from_constraints(body_a_arr, body_b_arr, feat_a_arr, feat_b_arr, ln_arr, lt_arr, 1)

fn store_three(cache: ContactCache):
    var body_a_arr: [i64] = []
    var body_b_arr: [i64] = []
    var feat_a_arr: [i64] = []
    var feat_b_arr: [i64] = []
    var ln_arr: [f64] = []
    var lt_arr: [f64] = []
    body_a_arr.push(0)
    body_a_arr.push(1)
    body_a_arr.push(2)
    body_b_arr.push(1)
    body_b_arr.push(2)
    body_b_arr.push(3)
    feat_a_arr.push(0)
    feat_a_arr.push(0)
    feat_a_arr.push(0)
    feat_b_arr.push(0)
    feat_b_arr.push(0)
    feat_b_arr.push(0)
    ln_arr.push(1.0)
    ln_arr.push(2.0)
    ln_arr.push(3.0)
    lt_arr.push(0.1)
    lt_arr.push(0.2)
    lt_arr.push(0.3)
    cache.store_from_constraints(body_a_arr, body_b_arr, feat_a_arr, feat_b_arr, ln_arr, lt_arr, 3)

describe "Physics2 ContactCache":
    it "store and retrieve cached impulse":
        var cache = ContactCache.create()
        store_one(cache, 0, 1, 0, 0, 5.0, 1.5)
        val result = cache.find_cached(0, 1, 0, 0)
        expect(result.0).to_equal(5.0)
        expect(result.1).to_equal(1.5)
        expect(result.2).to_equal(true)

    it "miss returns zero":
        var cache = ContactCache.create()
        val result = cache.find_cached(99, 100, 0, 0)
        expect(result.0).to_equal(0.0)
        expect(result.1).to_equal(0.0)
        expect(result.2).to_equal(false)

    it "clear empties cache":
        var cache = ContactCache.create()
        store_one(cache, 0, 1, 0, 0, 3.0, 0.5)
        cache.clear()
        val result = cache.find_cached(0, 1, 0, 0)
        expect(result.2).to_equal(false)

    it "multiple contacts stored":
        var cache = ContactCache.create()
        store_three(cache)
        val r0 = cache.find_cached(0, 1, 0, 0)
        val r1 = cache.find_cached(1, 2, 0, 0)
        val r2 = cache.find_cached(2, 3, 0, 0)
        expect(r0.2).to_equal(true)
        expect(r1.2).to_equal(true)
        expect(r2.2).to_equal(true)
        expect(r0.0).to_equal(1.0)
        expect(r1.0).to_equal(2.0)
        expect(r2.0).to_equal(3.0)
