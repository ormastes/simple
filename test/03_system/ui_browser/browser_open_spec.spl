# @tag:system
#
# Portable smoke for the browser open/snapshot contract.

use std.spec.*

describe "Browser Engine portable snapshot smoke":
    it "records snapshot path and format":
        val snapshot = ".build/ui_browser/test_hello.ppm"
        val format = "P3"
        expect(snapshot).to_end_with(".ppm")
        expect(format).to_equal("P3")

    it "records default snapshot dimensions":
        val width = 1280
        val height = 720
        expect(width).to_equal(1280)
        expect(height).to_equal(720)

    it "records non-background paint colors":
        val panel_rgb = "45 45 45"
        val text_rgb = "224 224 224"
        expect(panel_rgb).to_contain("45")
        expect(text_rgb).to_contain("224")

describe "Browser Engine portable GUI gate":
    it "keeps GUI open behavior opt-in":
        val env_name = "SIMPLE_GUI_TEST"
        expect(env_name).to_equal("SIMPLE_GUI_TEST")
