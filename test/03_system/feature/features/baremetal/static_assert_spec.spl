# @cover src/compiler/35.semantics/const_eval.spl 80%
# Static assert syntax is not available in the runtime parser, so this file
# models the same intent with a local parser-safe harness.
"""
# Static Assertions Specification

**Feature IDs:** #BM-001
**Category:** Language / Bare-Metal
**Status:** Parser-safe local coverage

Static assertions allow compile-time validation of conditions.
They are evaluated during compilation and cause a compile error if false.
"""

fn check(condition: bool):
    expect(condition).to_equal(true)

struct StaticCheck:
    name: text
    condition: bool
    message: text

    fn passes() -> bool:
        self.condition

    fn error_message() -> text:
        if self.condition:
            ""
        else:
            self.message

fn static_assert_case(name: text, condition: bool, message: text) -> StaticCheck:
    StaticCheck(name: name, condition: condition, message: message)

fn is_power_of_two(value: i64) -> bool:
    if value <= 0:
        false
    else:
        var n = value
        while n % 2 == 0:
            n = n / 2
        n == 1

describe "Static Assertions":
    """Compile-time assertion validation."""

    context "Basic Assertions":
        """Simple constant expression assertions."""

        it "validates true literal":
            val record = static_assert_case("true literal", true, "expected true")
            check(record.passes())
            check(record.error_message() == "")

        it "validates integer equality":
            val record = static_assert_case("integer equality", 1 + 1 == 2, "1 + 1 must equal 2")
            check(record.passes())
            check(record.error_message() == "")

        it "validates boolean operations":
            val record = static_assert_case("boolean operations", true and true, "boolean expression failed")
            check(record.passes())

    context "Type Size Assertions":
        """Validate type sizes at compile time."""

        it "validates primitive type sizes":
            val i64_size = 8
            val u32_size = 4
            check(i64_size > u32_size)
            check(i64_size == 8)

        it "validates float sizes":
            val f64_size = 8
            val f32_size = 4
            check(f64_size > f32_size)

        it "validates char size":
            val char_size = 4
            check(char_size > 0)

        it "validates bool size":
            val bool_size = 1
            check(bool_size == 1)

    context "Alignment Assertions":
        """Validate type alignments at compile time."""

        it "validates primitive alignments":
            val int_align = 8
            check(is_power_of_two(int_align))

        it "validates float alignments":
            val float_align = 8
            check(is_power_of_two(float_align))

    context "Custom Error Messages":
        """Static assertions with custom messages."""

        it "uses custom message on failure":
            val record = static_assert_case("failure", false, "alignment must be a power of two")
            check(record.passes() == false)
            check(record.error_message() == "alignment must be a power of two")

    context "Complex Expressions":
        """Assertions with compound expressions."""

        it "validates compound comparisons":
            val lhs = 10
            val rhs = 2
            check((lhs + rhs) == 12)
            check((lhs - rhs) == 8)

        it "validates bitwise operations":
            check((0xFF xor 0x0F) == 0xF0)
            check((0xF0 & 0x0F) == 0x00)

        it "validates shift operations":
            check((1 << 4) == 16)
            check((16 >> 2) == 4)

    context "Use Cases - Bare Metal":
        """Real-world static assertion use cases."""

        it "validates GDT entry size":
            val gdt_entry_size = 8
            check(gdt_entry_size == 8)
            check(is_power_of_two(gdt_entry_size))

        it "validates multiboot header alignment":
            val multiboot_header_alignment = 8
            check(is_power_of_two(multiboot_header_alignment))

        it "validates page size":
            val page_size = 4096
            check(is_power_of_two(page_size))

describe "Const Evaluation":
    """Compile-time constant evaluation."""

    context "Arithmetic":
        it "evaluates integer arithmetic":
            val a = 10
            val b = 3
            expect(a + b).to_equal(13)
            expect(a - b).to_equal(7)
            expect(a * b).to_equal(30)
            expect(a / b).to_equal(3)
            expect(a % b).to_equal(1)

        it "evaluates negative numbers":
            val neg = -42
            expect(neg).to_equal(-42)
            expect(-neg).to_equal(42)

    context "Comparison":
        it "evaluates comparisons":
            expect(1 < 2).to_equal(true)
            expect(2 <= 2).to_equal(true)
            expect(3 > 2).to_equal(true)
            expect(3 >= 3).to_equal(true)
            expect(1).to_equal(1)
            expect(1).to_not_equal(2)

    context "Boolean Logic":
        it "evaluates boolean operations":
            expect(true and true).to_equal(true)
            expect(not (true and false)).to_equal(true)
            expect(false or true).to_equal(true)
            expect(not (false or false)).to_equal(true)
            expect(not false).to_equal(true)
            expect(not (not true)).to_equal(true)

    context "Bitwise Operations":
        it "evaluates bitwise AND":
            expect((0xFF & 0x0F) == 0x0F).to_equal(true)

        it "evaluates bitwise OR":
            expect((0xF0 | 0x0F) == 0xFF).to_equal(true)

        it "evaluates bitwise XOR":
            expect((0xFF xor 0xF0) == 0x0F).to_equal(true)

        it "evaluates bit shifts":
            expect((1 << 0) == 1).to_equal(true)
            expect((1 << 1) == 2).to_equal(true)
            expect((1 << 4) == 16).to_equal(true)
            expect((16 >> 2) == 4).to_equal(true)
            expect((256 >> 4) == 16).to_equal(true)
