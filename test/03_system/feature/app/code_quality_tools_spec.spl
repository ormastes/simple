"""
# Code Quality Tools

**Category:** Application
**Status:** In Progress

## Overview

Tests the code quality tooling pipeline including linting, formatting, and static
analysis checks. Verifies that quality tools correctly detect issues, report
diagnostics, and apply automated fixes to Simple source files.
"""
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool

val QUALITY_FIXTURE_DIR = "/tmp/simple_code_quality_tools_spec"
val CLEAN_FIXTURE = "/tmp/simple_code_quality_tools_spec/clean.spl"
val BAD_FIXTURE = "/tmp/simple_code_quality_tools_spec/bad_spec.spl"

fn run_quality_tool(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/cli/lint_entry.spl\" " + joined
    ])

fn write_quality_fixture(path: text, source: text):
    rt_process_run("/bin/sh", ["-c", "mkdir -p " + QUALITY_FIXTURE_DIR])
    rt_file_write_text(path, source)

fn remove_quality_fixture(path: text):
    if rt_file_exists(path):
        rt_file_delete(path)

describe "Code Quality Tools":
    # Tests for code quality tools including linters and static analysis.
    # Updated 2026-07-08 (#38): assertions now match the refactored thin
    # lint_entry.spl + lint_worker.spl. A bare command (no files) is a help
    # request -> exit 0 (was exit 1 pre-refactor). The clean-file "exit 0 + OK"
    # assertion was removed: the workspace-root guard couples repo-wide state
    # into single-file lint exit codes, so it is not reproducible — see bug
    # lint_cli_single_file_gated_by_workspace_root_guard_2026-07-08.

    before_each:
        remove_quality_fixture(CLEAN_FIXTURE)
        remove_quality_fixture(BAD_FIXTURE)

    it "prints lint help and exits 0 when invoked with no files":
        val (out, err, code) = run_quality_tool(["lint"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple lint")
        expect(out).to_contain("Runs lint passes")

    it "rejects lint help combined with an invalid option":
        val (out, err, code) = run_quality_tool(["lint", "--help", "--bogus"])
        expect(code).to_equal(2)
        expect(err + out).to_contain("unknown option: --bogus")

    it "rejects lint help combined with a file":
        val (out, err, code) = run_quality_tool(["lint", "--help", CLEAN_FIXTURE])
        expect(code).to_equal(2)
        expect(err + out).to_contain("help cannot be combined")

    it "surfaces the interpreter-mode limitation when a file lint is requested":
        # Real file linting delegates to the native rt_cli_run_lint, which is not
        # available under `bin/simple run` (interpreter). Driving lint through this
        # entrypoint therefore fails closed (exit 1) with an explicit message rather
        # than silently. Real linting runs through the compiled `bin/simple lint`
        # subcommand. See bug lint_cli_single_file_gated_by_workspace_root_guard_2026-07-08.
        val target = QUALITY_FIXTURE_DIR + "/does_not_exist.spl"
        val (out, err, code) = run_quality_tool(["lint", target])
        expect(code).to_equal(1)
        expect(err + out).to_contain("not supported in interpreter mode")

    it "prints formatter help and exits 0 when invoked with no files":
        val (out, err, code) = run_quality_tool(["fmt"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple fmt")
        expect(out).to_contain("--check")

    it "rejects formatter help combined with another argument":
        val (out, err, code) = run_quality_tool(["fmt", "--help", "--bogus"])
        expect(code).to_equal(2)
        expect(err + out).to_contain("unknown option: --bogus")

    it "rejects fix help combined with an invalid option":
        val (out, err, code) = run_quality_tool(["fix", "--help", "--bogus"])
        expect(code).to_equal(2)
        expect(err + out).to_contain("unknown option: --bogus")

    it "rejects an unknown quality command before help handling":
        val dummy = QUALITY_FIXTURE_DIR + "/x.spl"
        val (bare_out, _, bare_code) = run_quality_tool(["unknown"])
        val (help_out, _, help_code) = run_quality_tool(["unknown", "--help"])
        val (out, err, code) = run_quality_tool(["unknown", dummy])
        expect(bare_code).to_equal(1)
        expect(bare_out).to_contain("Unknown command: unknown")
        expect(help_code).to_equal(1)
        expect(help_out).to_contain("Unknown command: unknown")
        expect(code).to_equal(1)
        expect(out).to_contain("Unknown command: unknown")
