use std.nogc_async_mut_noalloc.baremetal.allocator.BumpAllocator
use std.nogc_async_mut_noalloc.collections.fixed_array.{FixedArray}
use std.nogc_async_mut_noalloc.collections.fixed_map.FixedMap
use std.nogc_async_mut_noalloc.collections.fixed_set.FixedSet

fn run_baremetal_library_workload() -> i64:
    var allocator = BumpAllocator(base: 0x20000000, size: 64, offset: 0, allocated: 0)
    val first = allocator.alloc(5)
    if first != 0x20000000:
        return 10
    if allocator.total_allocated() != 8:
        return 11

    val second = allocator.alloc_aligned(4, 16)
    if second != 0x20000010:
        return 12
    if allocator.remaining() != 40:
        return 13

    val arr = FixedArray.new(3)
    if not arr.push(10):
        return 20
    if not arr.push(20):
        return 21
    if not arr.push(30):
        return 22
    if arr.push(40):
        return 23
    if arr.remove(1) != 20:
        return 24
    if arr.size() != 2:
        return 25
    if arr.get(0) != 10:
        return 26
    if arr.get(1) != 30:
        return 27

    val map = FixedMap.new(8)
    if not map.put(1, 10):
        return 30
    if not map.put(9, 90):
        return 31
    if not map.put(1, 11):
        return 32
    if map.get(1) != 11:
        return 33
    if map.get(9) != 90:
        return 34
    if not map.contains(9):
        return 35
    if not map.remove(1):
        return 36
    if map.contains(1):
        return 37
    if map.get(9) != 90:
        return 38

    val set = FixedSet.new(3)
    if not set.add(5):
        return 40
    if not set.add(7):
        return 41
    if not set.add(5):
        return 42
    if set.size() != 2:
        return 43
    if not set.contains(7):
        return 44
    if not set.remove(5):
        return 45
    if set.contains(5):
        return 46
    if set.capacity() != 3:
        return 47

    0
