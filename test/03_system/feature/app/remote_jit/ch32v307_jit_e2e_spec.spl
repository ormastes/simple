"""
# CH32V307 Direct Hardware E2E
#
# This replaces the stale adapter-based CH32 JIT path with the real hardware
# control path that exists in this repo today: WCH-Link direct commands.
#
# Current scope:
# - tool and chip discovery
# - direct RAM write/readback on live hardware
# - direct register dump on live hardware
# - real shared-workload execution attempt through a checked-in RV32 ELF
#
# If SDI serial access is blocked on the host, the workload execution attempt is
# classified as blocked instead of failing.
"""

use std.io_runtime.{shell}
use app.io.file_ops.{file_read}

val CHIP = "CH32V30X"
val SHARED_WORKLOAD = "test/fixtures/remote_jit/baremetal_lib_workload_main.spl"
val WORKLOAD_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_collections.elf"
val RAM_ADDR = "0x20000120"
val RAM_WORD = "0x55667788"

fn wlink_available() -> bool:
    val wlink = shell("command -v wlink >/dev/null 2>&1")
    wlink.exit_code == 0

fn ch32v307_detected() -> bool:
    val result = shell("timeout 10 wlink status --chip {CHIP} 2>&1")
    val combined = result.stdout + result.stderr
    result.exit_code == 0 and combined.contains("CH32V307")

fn shared_workload_available() -> bool:
    file_read(SHARED_WORKLOAD).len() > 0

fn workload_elf_available() -> bool:
    shell("test -f '{WORKLOAD_ELF}'").exit_code == 0

fn ram_write_readback_ok() -> bool:
    val write = shell("timeout 10 wlink write-mem {RAM_ADDR} {RAM_WORD} --chip {CHIP} 2>&1")
    if write.exit_code != 0:
        return false
    val dump = shell("sh -c 'timeout 10 wlink dump {RAM_ADDR} 16 --chip {CHIP} 2>&1 | sed -r \"s/\\\\x1B\\[[0-9;]*[A-Za-z]//g\"'")
    if dump.exit_code != 0:
        return false
    val combined = dump.stdout + dump.stderr
    combined.contains("88 77 66 55")

fn register_dump_ok() -> bool:
    val regs = shell("timeout 10 wlink regs --chip {CHIP} 2>&1")
    if regs.exit_code != 0:
        return false
    val combined = regs.stdout + regs.stderr
    combined.contains("dpc(pc):") and combined.contains("x10")

fn workload_flash_output() -> text:
    val run = shell("timeout 20 wlink flash '{WORKLOAD_ELF}' --chip {CHIP} --enable-sdi-print --watch-serial 2>&1")
    run.stdout + run.stderr

describe "CH32V307 Direct Hardware E2E":
    slow_it "discovers WCH-Link tools":
        if not wlink_available():
            print "[skip] wlink not installed"
        else:
            val version = shell("wlink --version 2>&1")
            expect(version.exit_code).to_equal(0)

    slow_it "reuses the shared baremetal workload fixture":
        expect(shared_workload_available()).to_equal(true)
        expect(workload_elf_available()).to_equal(true)

    slow_it "detects CH32V307 through WCH-Link":
        if not wlink_available():
            print "[skip] wlink not installed"
        else if not ch32v307_detected():
            print "[skip] WCH-Link probe not detected through wlink status"
        else:
            expect(ch32v307_detected()).to_equal(true)

    slow_it "writes and reads back RAM through WCH-Link":
        if not wlink_available():
            print "[skip] wlink not installed"
        else if not ch32v307_detected():
            print "[skip] WCH-Link probe not detected through wlink status"
        else:
            expect(ram_write_readback_ok()).to_equal(true)

    slow_it "reads registers through WCH-Link":
        if not wlink_available():
            print "[skip] wlink not installed"
        else if not ch32v307_detected():
            print "[skip] WCH-Link probe not detected through wlink status"
        else:
            expect(register_dump_ok()).to_equal(true)

    slow_it "attempts the shared collections workload through flashed RV32 ELF":
        if not wlink_available():
            print "[skip] wlink not installed"
        else if not ch32v307_detected():
            print "[skip] WCH-Link probe not detected through wlink status"
        else if not workload_elf_available():
            print "[skip] workload ELF unavailable"
        else:
            val output = workload_flash_output()
            if output.contains("Permission denied"):
                print "[skip] WCH-Link serial permission denied for SDI workload output"
            else:
                expect(output).to_contain("PASS: FixedArray push/pop order correct")
                expect(output).to_contain("PASS: FixedMap hash/put/get correct")
                expect(output).to_contain("PASS: RingBuffer enqueue/dequeue with wrap-around correct")
