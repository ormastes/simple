use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}
use std.gc_async_mut.gpu.browser_engine.html_string_parser.{browser_renderer_normalize_style_rules}

val WIDTH: i32 = 32
val HEIGHT: i32 = 24

fn _render(style: text, body: text) -> [u32]:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT).pixel_data

fn _pixel_at(pixels: [u32], x: i32, y: i32) -> u32:
    val idx = y * WIDTH + x
    if idx < 0 or idx >= pixels.len():
        return 0x00000000u32
    pixels[idx]

describe "WPT-derived background gradient fallback rendering":

    it "renders vertical two-color linear gradients":
        val pixels = _render("div { width: 8px; height: 6px; background: linear-gradient(180deg, #dc2626, #2563eb); }", "<div></div>")
        expect(_pixel_at(pixels, 1, 0)).to_equal(0xFFDC2626u32)
        expect(_pixel_at(pixels, 1, 5)).to_equal(0xFF2563EBu32)

    it "renders horizontal two-color linear gradients":
        val pixels = _render("div { width: 8px; height: 6px; background: linear-gradient(90deg, #dc2626, #2563eb); }", "<div></div>")
        expect(_pixel_at(pixels, 0, 1)).to_equal(0xFFDC2626u32)
        expect(_pixel_at(pixels, 7, 1)).to_equal(0xFF2563EBu32)
