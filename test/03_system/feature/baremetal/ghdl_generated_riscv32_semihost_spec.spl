#!/usr/bin/env simple

use std.spec.*

val GENERATED_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_semihost_runner.shs"
val HELLO_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_semihost.elf"
val SPIPE_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_spipe.elf"

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn runner_tools_available() -> bool:
    val result = rt_process_run("bash", ["-lc", "command -v ghdl >/dev/null && command -v riscv64-linux-gnu-objcopy >/dev/null"])
    result[2] == 0

fn run_ghdl_output(elf_path: text, timeout_ms: i64) -> (text, i32):
    val result = rt_process_run_timeout("bash", [GENERATED_RUNNER, elf_path, "--timeout=30"], timeout_ms)
    (result[0] + result[1], result[2])

describe "Generated RV32 GHDL semihosting":
    it "runner script exists and is syntax-valid":
        expect(rt_file_exists(GENERATED_RUNNER)).to_equal(true)
        val result = rt_process_run("bash", ["-n", GENERATED_RUNNER])
        expect(result[2]).to_equal(0)

    slow_it "runs hello semihost ELF through the generated core":
        if not runner_tools_available():
            return "skip: ghdl or riscv objcopy not available"
        val result = run_ghdl_output(HELLO_ELF, 120000)
        val output = result[0]
        expect(result[1]).to_equal(0)
        expect(output).to_contain("Hello, RISC-V 32!")
        expect(output).to_contain("SEMIHOST TEST")
        expect(output).to_contain("Success")
        expect(output).to_contain("Test PASSED")
        expect(output).to_contain("Cycles:")

    slow_it "runs SPipe semihost ELF through the generated core":
        if not runner_tools_available():
            return "skip: ghdl or riscv objcopy not available"
        val result = run_ghdl_output(SPIPE_ELF, 120000)
        val output = result[0]
        expect(result[1]).to_equal(0)
        expect(output).to_contain("Baremetal Semihosting")
        expect(output).to_contain("hello_semihost")
        expect(output).to_contain("1 examples, 0 failures")
        expect(output).to_contain("Test PASSED")
