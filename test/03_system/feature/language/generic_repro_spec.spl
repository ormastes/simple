use std.spec

class ReproMyVec:
    var items: [i64]

    fn push(item: i64):
        me.items.push(item)

    fn length() -> i64:
        me.items.length

type ReproIntVec = ReproMyVec

class ReproBox<T>:
    val value: T

    fn get() -> T:
        me.value

fn repro_identity<T>(x: T) -> T:
    x

describe "generic syntax repros":
    it "dispatches methods through a generic type alias":
        val values = ReproIntVec(items: [])
        values.push(10)
        expect(values.length()).to_equal(1)

    it "parses generic instance method calls":
        val box = ReproBox<i64>(value: 42)
        expect(box.get()).to_equal(42)

    it "parses explicit generic function calls":
        expect(repro_identity<i64>(42)).to_equal(42)
