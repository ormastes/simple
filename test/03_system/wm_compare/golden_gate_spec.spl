# @tag: sys, wm_compare, golden, drift, framebuffer
# @cover src/app/wm_compare/golden_gate.spl 0%
# @cover src/app/wm_compare/backend_parity.spl 0%
#
# wm_compare Golden-Image Gate — golden gate of GUI drawing-layer matrix
#
# Locks the contract that every parity scene's framebuffer baseline render output stays
# byte-stable against the checked-in golden PPMs in
# `test/system/wm_compare/goldens/`. A failing run means either:
#
#   * framebuffer baseline rendering changed (`fb_driver` / `fb_backend` regressed), OR
#   * software reference rendering changed and framebuffer/software gate parity now diverges (in which case
#     the framebuffer/software gate spec would also fail), OR
#   * The scenes themselves changed and goldens need to be regenerated.
#
# To regenerate goldens after an intentional change:
#
#     REGEN_GOLDENS=1 bin/simple test test/system/wm_compare/golden_gate_spec.spl
#
# Then `jj diff` the goldens, eyeball them, and commit.
#
# See doc/03_plan/gui_drawing_layer_variations.md (golden gate) and
# doc/06_spec/app/compiler/feature/windows_spec.md (Golden-image gate).

use std.spec.{describe, context, it, expect}
use app.wm_compare.golden_gate.{
    check_golden, encode_ppm_p6, decode_ppm_p6, all_gate_scenes,
    GoldenGateResult,
}
use app.wm_compare.backend_parity.{
    scene_solid_fill, scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend,
    render_framebuffer_baseline,
}

describe "wm_compare golden-image gate":

    context "solid_fill golden":

        it "loads from disk":
            val r = check_golden(scene_solid_fill())
            expect(r.loaded_ok).to_equal(true)

        it "matches the golden exactly":
            val r = check_golden(scene_solid_fill())
            expect(r.pass_gate).to_equal(true)

    context "fill_rect_row_edge golden":

        it "loads from disk":
            val r = check_golden(scene_fill_rect_row_edge())
            expect(r.loaded_ok).to_equal(true)

        it "stays within drift budget":
            val r = check_golden(scene_fill_rect_row_edge())
            expect(r.pass_gate).to_equal(true)

    context "text_with_bg golden":

        it "loads from disk":
            val r = check_golden(scene_text_with_bg())
            expect(r.loaded_ok).to_equal(true)

        it "stays within drift budget":
            val r = check_golden(scene_text_with_bg())
            expect(r.pass_gate).to_equal(true)

    context "glass_blend golden":

        it "loads from disk":
            val r = check_golden(scene_glass_blend())
            expect(r.loaded_ok).to_equal(true)

        it "stays within drift budget":
            val r = check_golden(scene_glass_blend())
            expect(r.pass_gate).to_equal(true)

    context "PPM encoder/decoder roundtrip":

        it "round-trips a freshly rendered scene exactly":
            val pixels = render_framebuffer_baseline(scene_solid_fill())
            val bytes = encode_ppm_p6(32u32, 16u32, pixels)
            val decoded = decode_ppm_p6(bytes)
            expect(decoded.len() == pixels.len()).to_equal(true)

        it "writes a P6 magic header":
            val pixels = render_framebuffer_baseline(scene_solid_fill())
            val bytes = encode_ppm_p6(32u32, 16u32, pixels)
            # 'P' = 80, '6' = 54, '\n' = 10
            expect(bytes[0] == 80u8).to_equal(true)
            expect(bytes[1] == 54u8).to_equal(true)
            expect(bytes[2] == 10u8).to_equal(true)
