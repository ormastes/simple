# nvim_plugin_live_spec
#
# Verifies the worktree Neovim plugin smoke remains executable as Simple code.

use std.spec
use std.io_runtime.{process_run}

describe "Neovim plugin live smoke":

    it "runs isolated headless plugin checks from the worktree":
        val result = process_run("bin/simple", ["run", "scripts/smoke/nvim_plugin_smoke.spl"])
        expect(result.2).to_equal(0)
        if result.0.contains("SKIP: nvim not found"):
            expect(result.0).to_contain("SKIP: nvim not found")
        else:
            expect(result.0).to_contain("STATUS: PASS nvim_plugin_smoke")
