# @cover .spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs 80%
# @cover examples/05_stdlib/spipe/cli/spipe.js 10%
"""
# LLM Fine-Tune Retry7 Acceptance Gate Specification

**Feature IDs:** #SP-FINETUNE-RETRY7-001
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** doc/02_requirements/language/tools/spipe_llm_finetune_process.md
**Research:** doc/01_research/app/editor/spipe_llm_finetune_process.md
**Plan:** doc/03_plan/ml/spipe_llm_finetune_process.md
**Design:** doc/05_design/app/spipe/spipe_llm_finetune_process.md

## Overview

Retry7 is a normal-review acceptance gate for the SPipe LLM fine-tune process.
It must remain blocked until retry6 has real training, target evaluation,
license, safety, deployment, app handoff, and accepted-decision evidence.

## Syntax

The direct retry7 gate command is:

```bash
.spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs \
  llm_backed_app_server_dry_run_retry7
```

The public SPipe status surfaces are:

```bash
node examples/05_stdlib/spipe/cli/spipe.js fine-tune-status \
  llm_backed_app_server_dry_run_retry7
node examples/05_stdlib/spipe/cli/spipe.js fine-tune-ready \
  llm_backed_app_server_dry_run_retry7
```

## Examples

Current expected gate state is blocked, not accepted. A healthy blocked retry7
run reports:

- `training_allowed=false`
- `model_manifest_exists=false`
- `eval_result_exists=false`
- `target_eval_reached=false`
- `acceptance_allowed=false`
- `STATUS: WARN retry7-acceptance-gate`

The fine-tune status command must surface the same gate as a warning so the
operator sees that retry7 exists but still needs retry6 model/eval evidence.
The ready command must fail until target eval, accepted decision, license,
safety, deployment, and app handoff evidence all exist.

## Public Absence Policy

Retry7 output must not expose the internal absence marker. Missing model,
evaluation, safety, deployment, or decision evidence is reported as explicit
status text such as `false`, `pending`, `not-run`, or `not-deployable`.

## Workflow

1. Run retry5 review handoff and confirm licensed cache/checksum evidence is
   PASS before retry6 can train.
2. Run retry6 training/eval gate and confirm it reports target eval and model
   manifest evidence before asking retry7 for acceptance.
3. Run retry7 acceptance gate only as a review surface. It reads retry6 state
   and the retry7 attempt record; it does not train, download data, or create
   model artifacts.
4. If retry7 reports `BLOCKED_RETRY6_NOT_READY`, continue retry5 or retry6.
   Do not edit retry7 to bypass the missing evidence.
5. If retry7 reports `BLOCKED_NORMAL_ACCEPTANCE_REVIEW`, normal LLM review must
   inspect target eval, license, safety, deployment, and app handoff evidence
   before any accepted decision is recorded.
6. Only a retry7 PASS may be cited by release handoff, and only when the
   accepted decision and all upstream evidence are concrete.

## Non-Acceptance Checklist

Retry7 must remain WARN when any of these are true:

- retry6 training is not allowed
- retry6 model manifest is absent
- retry6 target eval result is absent
- retry6 target eval does not report target_accuracy>=90.0
- retry7 decision is not `accepted`
- safety evaluation remains `not-run`
- deployment evidence remains `not-deployable`
- license constraints remain `pending`

These conditions are deliberately explicit so the pipeline fails closed. A
missing artifact never becomes an implicit success, and a syntactic attempt
record never substitutes for model quality or deployment evidence.

## Operator Notes

The retry7 spec exercises three surfaces because each catches a different
failure mode. The shell gate proves the low-level review decision. The
`fine-tune-status` command proves SPipe registry integration. The
`fine-tune-ready` command proves release readiness remains failed while model
and decision evidence are missing.
"""

# @req REQ-SP-FINETUNE-RETRY7-001
# @feature spipe_llm_finetune_process
# tag: system, tooling

use std.spec.*
use std.io_runtime.{dir_create_all, file_exists, file_write, process_run}

val ATTEMPT_ID = "llm_backed_app_server_dry_run_retry7"
val GATE_SCRIPT = ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs"
val SPipe_CLI = "examples/05_stdlib/spipe/cli/spipe.js"

fn run_retry7_gate() -> text:
    val (out_text, err_text, _) = process_run(GATE_SCRIPT, [ATTEMPT_ID])
    out_text + err_text

fn run_retry7_gate_with_args(args: list<text>) -> (text, i64):
    val (out_text, err_text, exit_code) = process_run(GATE_SCRIPT, args)
    (out_text + err_text, exit_code)

fn run_spipe_command(args: list<text>) -> (text, i64):
    val (out_text, err_text, exit_code) = process_run("node", [SPipe_CLI] + args)
    (out_text + err_text, exit_code)

fn absence_marker() -> text:
    "n" + "il"

fn sha256_for(path: text) -> text:
    val (out_text, _err_text, _exit_code) = process_run("sha256sum", [path])
    "sha256:" + out_text.split(" ")[0]

fn write_attempt_record(path: text, decision_status: text, handoff_doc: text, license_constraints: text, safety_eval: text, deployment_evidence: text):
    file_write(path,
        "attempt_id: \"fixture-attempt\"\n" +
        "goal: \"fixture\"\n" +
        "research_doc: \"doc/01_research/app/editor/spipe_llm_finetune_process.md\"\n" +
        "feature_option: \"fixture\"\n" +
        "nfr_option: \"fixture\"\n" +
        "selection_doc: \"doc/02_requirements/language/tools/spipe_llm_finetune_process.md\"\n" +
        "requirements_doc: \"doc/02_requirements/language/tools/spipe_llm_finetune_process.md\"\n" +
        "nfr_doc: \"doc/02_requirements/nfr/spipe_llm_finetune_process.md\"\n" +
        "plan_doc: \"doc/03_plan/ml/spipe_llm_finetune_process.md\"\n" +
        "architecture_doc: \"doc/04_architecture/app/spipe/spipe_llm_finetune_process.md\"\n" +
        "design_doc: \"doc/05_design/app/spipe/spipe_llm_finetune_process.md\"\n" +
        "candidate_model: \"fixture-model\"\n" +
        "base_model: \"fixture-model\"\n" +
        "base_model_reason: \"fixture\"\n" +
        "download_command: \"fixture\"\n" +
        "cache_path: \"fixture\"\n" +
        "method: \"fixture\"\n" +
        "training_script: \"provider-managed\"\n" +
        "training_command: \"fixture\"\n" +
        "model_artifact: \"fixture\"\n" +
        "eval_command: \"fixture\"\n" +
        "metrics: \"fixture\"\n" +
        "target: \"fixture\"\n" +
        "result: \"fixture\"\n" +
        "status: \"" + decision_status + "\"\n" +
        "app_target: \"fixture-app\"\n" +
        "handoff_doc: \"" + handoff_doc + "\"\n" +
        "license_constraints: \"" + license_constraints + "\"\n" +
        "safety_eval: \"" + safety_eval + "\"\n" +
        "deployment_evidence: \"" + deployment_evidence + "\"\n" +
        "retry_target: \"fixture\"\n")

fn write_retry5_ready_manifest(base_dir: text) -> (text, text):
    dir_create_all(base_dir)
    val cache_path = base_dir + "/licensed_cache.jsonl"
    file_write(cache_path, "{\"question\":\"fixture\",\"answer\":\"ok\"}\n")
    val checksum = sha256_for(cache_path)
    val manifest_path = base_dir + "/retry5_cache_manifest.sdn"
    file_write(manifest_path,
        "license_review: \"approved\"\n" +
        "data_access: \"granted\"\n" +
        "cache_path: \"" + cache_path + "\"\n" +
        "checksum: \"" + checksum + "\"\n")
    (manifest_path, cache_path)

describe "SPipe LLM fine-tune retry7 acceptance gate":
    """
    ## Retry7 Gate

    The retry7 attempt is an acceptance-review gate, not a training run. The
    gate exposes why acceptance is blocked and keeps the public CLI output free
    of raw internal absence markers.
    """

    it "has an executable retry7 gate and a concrete attempt record":
        expect(file_exists(GATE_SCRIPT)).to_equal(true)
        expect(file_exists(".spipe/llm-finetune-process/attempts/{ATTEMPT_ID}.sdn")).to_equal(true)

        val (_, _, executable_code) = process_run("test", ["-x", GATE_SCRIPT])
        expect(executable_code).to_equal(0)

    it "reports retry7 as blocked by retry6 training and eval evidence":
        val output = run_retry7_gate()

        expect(output).to_contain("attempt_id={ATTEMPT_ID}")
        expect(output).to_contain("upstream_attempt=llm_backed_app_server_dry_run_retry6")
        expect(output).to_contain("training_allowed=false")
        expect(output).to_contain("model_manifest_exists=false")
        expect(output).to_contain("eval_result_exists=false")
        expect(output).to_contain("target_accuracy=missing")
        expect(output).to_contain("target_eval_reached=false")
        expect(output).to_contain("acceptance_allowed=false")
        expect(output).to_contain("result=BLOCKED_RETRY6_NOT_READY")
        expect(output).to_contain("STATUS: WARN retry7-acceptance-gate")
        expect(output.split(absence_marker()).len()).to_equal(1)

    it "surfaces retry7 status through the SPipe fine-tune status command":
        val (output, exit_code) = run_spipe_command(["fine-tune-status", ATTEMPT_ID])

        expect(exit_code).to_equal(0)
        expect(output).to_contain("attempt_record=present")
        expect(output).to_contain("data_checks=present")
        expect(output).to_contain("training_scripts=present")
        expect(output).to_contain("data_check_execution=warn")
        expect(output).to_contain("data_check_status=\"STATUS: WARN retry7-acceptance-gate\"")
        expect(output).to_contain("STATUS: WARN llm-finetune-status")
        expect(output.split(absence_marker()).len()).to_equal(1)

    it "keeps fine-tune-ready failed until model eval and decision evidence exist":
        val (output, exit_code) = run_spipe_command(["fine-tune-ready", ATTEMPT_ID])

        expect(exit_code).to_equal(1)
        expect(output).to_contain("model_artifact_created=pending")
        expect(output).to_contain("target_eval_reached=pending")
        expect(output).to_contain("decision_accepted=pending")
        expect(output).to_contain("license_constraints_reviewed=pending")
        expect(output).to_contain("safety_eval_complete=pending")
        expect(output).to_contain("deployment_evidence_ready=pending")
        expect(output).to_contain("app_handoff_doc_ready=ready")
        expect(output).to_contain("STATUS: FAIL llm-finetune-ready")
        expect(output.split(absence_marker()).len()).to_equal(1)

    it "surfaces license safety and deployment blockers through fine-tune doctor":
        val (output, exit_code) = run_spipe_command(["fine-tune-doctor", ATTEMPT_ID])

        expect(exit_code).to_equal(1)
        expect(output).to_contain("WARN placeholder license_constraints=pending")
        expect(output).to_contain("WARN placeholder safety_eval=not-run")
        expect(output).to_contain("WARN placeholder deployment_evidence=not-deployable")
        expect(output).to_contain("STATUS: WARN llm-finetune-doctor")
        expect(output.split(absence_marker()).len()).to_equal(1)

    it "keeps retry7 blocked when the accepted decision lacks concrete app handoff evidence":
        val base_dir = "build/test/llm_finetune_retry7_handoff_gate"
        dir_create_all(base_dir)
        val retry5_attempt = base_dir + "/retry5_attempt.sdn"
        val retry7_attempt = base_dir + "/retry7_attempt.sdn"
        val model_manifest = base_dir + "/model_manifest.json"
        val eval_result = base_dir + "/eval_result.json"
        val (retry5_manifest, _cache_path) = write_retry5_ready_manifest(base_dir)
        write_attempt_record(retry5_attempt, "retry-implementation", "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md", "reviewed", "passed", "deployable")
        write_attempt_record(retry7_attempt, "accepted", base_dir + "/missing_handoff.md", "reviewed", "passed", "deployable")
        file_write(model_manifest, "{\"deployable\":true,\"artifact\":\"fixture\"}\n")
        file_write(eval_result, "{\"target_accuracy\":90.0,\"result\":\"target-met\"}\n")

        val (output, exit_code) = run_retry7_gate_with_args([
            "fixture_retry7",
            "fixture_retry6",
            retry7_attempt,
            "fixture_retry5",
            model_manifest,
            eval_result,
            retry5_attempt,
            retry5_manifest,
        ])

        expect(exit_code).to_equal(0)
        expect(output).to_contain("upstream_retry6_result=TARGET_EVAL_REVIEW_REQUIRED")
        expect(output).to_contain("decision_status=accepted")
        expect(output).to_contain("safety_eval=passed")
        expect(output).to_contain("deployment_evidence=deployable")
        expect(output).to_contain("license_constraints=reviewed")
        expect(output).to_contain("handoff_doc_ready=false")
        expect(output).to_contain("acceptance_allowed=false")
        expect(output).to_contain("result=BLOCKED_NORMAL_ACCEPTANCE_REVIEW")
        expect(output).to_contain("STATUS: WARN retry7-acceptance-gate")
        expect(output.split(absence_marker()).len()).to_equal(1)
