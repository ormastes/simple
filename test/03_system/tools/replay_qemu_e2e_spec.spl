use std.spec.*
use std.nogc_sync_mut.replay.types.{ReplayConfig, ReplayMode, Arch, TargetDesc, Address, Endian}

# ── ReplayConfig record mode helpers ─────────────────────────────────────────

fn _record_arch() -> text:
    val cfg = ReplayConfig.for_record(Arch.X86_64, "/boot/vmlinux", "/tmp/r.srrq")
    cfg.arch.to_text()

fn _record_mode() -> text:
    val cfg = ReplayConfig.for_record(Arch.X86_64, "/boot/vmlinux", "/tmp/r.srrq")
    cfg.mode.to_text()

fn _record_kernel() -> text:
    val cfg = ReplayConfig.for_record(Arch.X86_64, "/boot/vmlinux", "/tmp/r.srrq")
    cfg.kernel_path

# ── ReplayConfig replay mode helpers ─────────────────────────────────────────

fn _replay_gdb_port() -> i32:
    val cfg = ReplayConfig.for_replay(Arch.AARCH64, "/boot/vmlinux", "/tmp/r.srrq")
    cfg.gdb_port

fn _replay_mode() -> text:
    val cfg = ReplayConfig.for_replay(Arch.AARCH64, "/boot/vmlinux", "/tmp/r.srrq")
    cfg.mode.to_text()

# ── Arch.from_text helpers ────────────────────────────────────────────────────

fn _from_text_x86_32() -> text:
    Arch.from_text("x86_32").to_text()

fn _from_text_x86_64() -> text:
    Arch.from_text("x86_64").to_text()

fn _from_text_arm32() -> text:
    Arch.from_text("arm32").to_text()

fn _from_text_aarch64() -> text:
    Arch.from_text("aarch64").to_text()

fn _from_text_riscv32() -> text:
    Arch.from_text("riscv32").to_text()

fn _from_text_riscv64() -> text:
    Arch.from_text("riscv64").to_text()

# ── Arch.qemu_system_cmd helpers ─────────────────────────────────────────────

fn _qemu_cmd_x86_32() -> text:
    Arch.X86_32.qemu_system_cmd()

fn _qemu_cmd_x86_64() -> text:
    Arch.X86_64.qemu_system_cmd()

fn _qemu_cmd_arm32() -> text:
    Arch.ARM32.qemu_system_cmd()

fn _qemu_cmd_aarch64() -> text:
    Arch.AARCH64.qemu_system_cmd()

fn _qemu_cmd_riscv32() -> text:
    Arch.RISCV32.qemu_system_cmd()

fn _qemu_cmd_riscv64() -> text:
    Arch.RISCV64.qemu_system_cmd()

# ── Arch.default_machine helpers ─────────────────────────────────────────────

fn _machine_x86_32() -> text:
    Arch.X86_32.default_machine()

fn _machine_x86_64() -> text:
    Arch.X86_64.default_machine()

fn _machine_arm32() -> text:
    Arch.ARM32.default_machine()

fn _machine_aarch64() -> text:
    Arch.AARCH64.default_machine()

fn _machine_riscv32() -> text:
    Arch.RISCV32.default_machine()

fn _machine_riscv64() -> text:
    Arch.RISCV64.default_machine()

# ── Arch.pointer_bits helpers ─────────────────────────────────────────────────

fn _bits_x86_32() -> i32:
    Arch.X86_32.pointer_bits()

fn _bits_x86_64() -> i32:
    Arch.X86_64.pointer_bits()

fn _bits_arm32() -> i32:
    Arch.ARM32.pointer_bits()

fn _bits_aarch64() -> i32:
    Arch.AARCH64.pointer_bits()

fn _bits_riscv32() -> i32:
    Arch.RISCV32.pointer_bits()

fn _bits_riscv64() -> i32:
    Arch.RISCV64.pointer_bits()

# ── TargetDesc helpers ────────────────────────────────────────────────────────

fn _target_arch() -> text:
    val td = TargetDesc.for_arch(Arch.RISCV64)
    td.arch.to_text()

fn _target_page_size() -> i32:
    val td = TargetDesc.for_arch(Arch.X86_64)
    td.page_size

fn _target_schema_x86_64() -> text:
    val td = TargetDesc.for_arch(Arch.X86_64)
    td.register_schema_id

fn _target_schema_aarch64() -> text:
    val td = TargetDesc.for_arch(Arch.AARCH64)
    td.register_schema_id

fn _target_endian_x86_64() -> text:
    val td = TargetDesc.for_arch(Arch.X86_64)
    td.endian.to_text()

# =============================================================================
# Spec
# =============================================================================

describe "SReplay QEMU E2E — mock level":

    describe "ReplayConfig record mode":
        it "arch field matches requested arch":
            expect(_record_arch()).to_equal("x86_64")

        it "mode field is record":
            expect(_record_mode()).to_equal("record")

        it "kernel_path field is preserved":
            expect(_record_kernel()).to_equal("/boot/vmlinux")

    describe "ReplayConfig replay mode":
        it "mode field is replay":
            expect(_replay_mode()).to_equal("replay")

        it "gdb_port defaults to 1234":
            expect(_replay_gdb_port()).to_equal(1234)

    describe "Arch.from_text":
        it "parses x86_32":
            expect(_from_text_x86_32()).to_equal("x86_32")

        it "parses x86_64":
            expect(_from_text_x86_64()).to_equal("x86_64")

        it "parses arm32":
            expect(_from_text_arm32()).to_equal("arm32")

        it "parses aarch64":
            expect(_from_text_aarch64()).to_equal("aarch64")

        it "parses riscv32":
            expect(_from_text_riscv32()).to_equal("riscv32")

        it "parses riscv64":
            expect(_from_text_riscv64()).to_equal("riscv64")

    describe "Arch.qemu_system_cmd":
        it "x86_32 → qemu-system-i386":
            expect(_qemu_cmd_x86_32()).to_equal("qemu-system-i386")

        it "x86_64 → qemu-system-x86_64":
            expect(_qemu_cmd_x86_64()).to_equal("qemu-system-x86_64")

        it "arm32 → qemu-system-arm":
            expect(_qemu_cmd_arm32()).to_equal("qemu-system-arm")

        it "aarch64 → qemu-system-aarch64":
            expect(_qemu_cmd_aarch64()).to_equal("qemu-system-aarch64")

        it "riscv32 → qemu-system-riscv32":
            expect(_qemu_cmd_riscv32()).to_equal("qemu-system-riscv32")

        it "riscv64 → qemu-system-riscv64":
            expect(_qemu_cmd_riscv64()).to_equal("qemu-system-riscv64")

    describe "Arch.default_machine":
        it "x86_32 → q35":
            expect(_machine_x86_32()).to_equal("q35")

        it "x86_64 → q35":
            expect(_machine_x86_64()).to_equal("q35")

        it "arm32 → virt":
            expect(_machine_arm32()).to_equal("virt")

        it "aarch64 → virt":
            expect(_machine_aarch64()).to_equal("virt")

        it "riscv32 → virt":
            expect(_machine_riscv32()).to_equal("virt")

        it "riscv64 → virt":
            expect(_machine_riscv64()).to_equal("virt")

    describe "Arch.pointer_bits":
        it "x86_32 is 32-bit":
            expect(_bits_x86_32()).to_equal(32)

        it "x86_64 is 64-bit":
            expect(_bits_x86_64()).to_equal(64)

        it "arm32 is 32-bit":
            expect(_bits_arm32()).to_equal(32)

        it "aarch64 is 64-bit":
            expect(_bits_aarch64()).to_equal(64)

        it "riscv32 is 32-bit":
            expect(_bits_riscv32()).to_equal(32)

        it "riscv64 is 64-bit":
            expect(_bits_riscv64()).to_equal(64)

    describe "TargetDesc.for_arch":
        it "arch field matches requested arch":
            expect(_target_arch()).to_equal("riscv64")

        it "page_size is 4096":
            expect(_target_page_size()).to_equal(4096)

        it "x86_64 register schema is x86_64-sysv-v1":
            expect(_target_schema_x86_64()).to_equal("x86_64-sysv-v1")

        it "aarch64 register schema is aarch64-v1":
            expect(_target_schema_aarch64()).to_equal("aarch64-v1")

        it "x86_64 endian is little":
            expect(_target_endian_x86_64()).to_equal("little")
