"""
# Claude Full debug filter

Pure Simple coverage for debug filter parsing and category visibility.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.debugFilter.*

describe "Claude full debug filter":
    it "returns nil for empty or mixed filters":
        step("Check nil filters")
        expect(parseDebugFilter("")).to_be_nil()
        expect(parseDebugFilter(" , ")).to_be_nil()
        expect(parseDebugFilter("api,!file")).to_be_nil()

    it "parses inclusive filters":
        step("Check include filter")
        val filter = parseDebugFilter("api, hooks")
        expect(filter.isExclusive).to_equal(false)
        expect(filter.include).to_equal(["api", "hooks"])
        expect(filter.exclude).to_equal([])

    it "parses exclusive filters":
        step("Check exclude filter")
        val filter = parseDebugFilter("!1p,!file")
        expect(filter.isExclusive).to_equal(true)
        expect(filter.include).to_equal([])
        expect(filter.exclude).to_equal(["1p", "file"])

    it "shows matching inclusive categories only":
        step("Check inclusive decision")
        val filter = parseDebugFilter("api,hooks")
        expect(shouldShowDebugCategories(["api"], filter)).to_equal(true)
        expect(shouldShowDebugCategories(["file"], filter)).to_equal(false)
        expect(shouldShowDebugCategories([], filter)).to_equal(false)

    it "hides matching exclusive categories":
        step("Check exclusive decision")
        val filter = parseDebugFilter("!1p,!file")
        expect(shouldShowDebugCategories(["api"], filter)).to_equal(true)
        expect(shouldShowDebugCategories(["file"], filter)).to_equal(false)
        expect(shouldShowDebugCategories([], filter)).to_equal(false)

    it "shows everything without a filter":
        step("Check no filter decision")
        expect(shouldShowDebugCategories([], nil)).to_equal(true)
