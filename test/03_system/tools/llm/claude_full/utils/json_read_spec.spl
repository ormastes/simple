"""
# Claude Full jsonRead utils

Pure Simple coverage for jsonRead BOM stripping.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.jsonRead.*

describe "Claude full jsonRead utils":
    it "delegates leading BOM stripping to the shared encoding helper":
        expect(stripBOM("﻿{\"tool\":true}")).to_equal("{\"tool\":true}")

    it "leaves non-BOM content unchanged":
        expect(stripBOM("{\"tool\":true}")).to_equal("{\"tool\":true}")
