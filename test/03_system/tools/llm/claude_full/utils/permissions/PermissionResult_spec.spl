"""
# Claude Full permission result helper

Pure Simple coverage for permission behavior prose.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.permissions.PermissionResult.*

describe "Claude full permission result helper":
    it "maps rule behavior to prose":
        step("Check behavior descriptions")
        expect(getRuleBehaviorDescription("allow")).to_equal("allowed")
        expect(getRuleBehaviorDescription("deny")).to_equal("denied")
        expect(getRuleBehaviorDescription("ask")).to_equal("asked for confirmation for")
        expect(getRuleBehaviorDescription("unknown")).to_equal("asked for confirmation for")
