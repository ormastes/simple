"""
# Claude full managed env constants
"""

use std.spec.*
use app.llm_caret.claude_full.utils.managedEnvConstants.*

describe "Claude full managed env constants":
    it "detects provider-managed env vars case-insensitively":
        expect(isProviderManagedEnvVar("anthropic_model")).to_equal(true)
        expect(isProviderManagedEnvVar("CLAUDE_CODE_USE_VERTEX")).to_equal(true)
        expect(isProviderManagedEnvVar("PATH")).to_equal(false)

    it "detects Vertex region overrides by prefix":
        expect(isProviderManagedEnvVar("vertex_region_claude_future_model")).to_equal(true)

    it "keeps dangerous shell settings available":
        expect(dangerousShellSettings()).to_contain("apiKeyHelper")
        expect(dangerousShellSettings()).to_contain("statusLine")

    it "keeps representative safe env vars available":
        expect(safeEnvVars()).to_contain("ANTHROPIC_CUSTOM_HEADERS")
        expect(safeEnvVars()).to_contain("MAX_MCP_OUTPUT_TOKENS")
        expect(safeEnvVars()).to_contain("VERTEX_REGION_CLAUDE_4_5_SONNET")
