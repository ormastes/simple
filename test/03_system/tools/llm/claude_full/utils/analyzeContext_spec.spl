"""
# Claude Full analyzeContext Slice

Focused pure-Simple post-processing coverage for analyzeContext.
"""

use std.spec.*
use app.llm_caret.claude_full.components.ContextVisualization.*
use app.llm_caret.claude_full.utils.analyzeContext.*

describe "Claude full analyzeContext parity":
    it "should extract section names":
        step("Check headings and fallback previews")
        expect(extractSectionNameRoute("intro\n## System Rules\nbody")).to_equal("System Rules")
        expect(extractSectionNameRoute("\nplain first line\nbody")).to_equal("plain first line")
        expect(extractSectionNameRoute("abcdefghijklmnopqrstuvwxyz0123456789EXTRA")).to_equal("abcdefghijklmnopqrstuvwxyz0123456789EXTR...")

    it "should compute reserves and actual usage":
        step("Check deferred exclusion and reserve labels")
        val categories = [
            ContextCategory.new("System prompt", 100, "primary", false),
            ContextCategory.new("Deferred MCP tools", 500, "muted", true),
            ContextCategory.new("Messages", 50, "purple", false),
        ]
        expect(actualUsageTokensRoute(categories)).to_equal(150)
        expect(reserveCategoryNameRoute(true)).to_equal("Autocompact buffer")
        expect(reserveCategoryNameRoute(false)).to_equal("Compact buffer")
        expect(reserveTokensRoute(200000, 167000, true, false)).to_equal(33000)
        expect(reserveTokensRoute(200000, 0, false, false)).to_equal(3000)
        expect(reserveTokensRoute(200000, 167000, true, true)).to_equal(0)
        expect(freeSpaceTokensRoute(1000, 900, 200)).to_equal(0)

    it "should prefer API usage totals":
        step("Check total selection")
        expect(finalTotalTokensRoute(true, 10, 20, 30, 999)).to_equal(60)
        expect(finalTotalTokensRoute(false, 10, 20, 30, 999)).to_equal(999)

    it "should size context grids":
        step("Check terminal-width grid rules")
        expect(gridWidthRoute(200000, 120)).to_equal(10)
        expect(gridHeightRoute(200000, 120)).to_equal(10)
        expect(gridWidthRoute(200000, 60)).to_equal(5)
        expect(gridHeightRoute(200000, 60)).to_equal(5)
        expect(gridWidthRoute(1000000, 120)).to_equal(20)
        expect(gridHeightRoute(1000000, 60)).to_equal(10)
        expect(roundedGridSquaresRoute(1, 200000, 100, false)).to_equal(1)
        expect(roundedGridSquaresRoute(0, 200000, 100, true)).to_equal(0)
        expect(analyzeContextSourceLinesModeled()).to_equal(1382)
