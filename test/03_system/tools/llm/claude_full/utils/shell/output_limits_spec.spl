"""
# Claude Full shell output limits

Pure Simple coverage for bounded bash output limit validation.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.shell.outputLimits.*

describe "Claude full shell output limits":
    it "uses upstream constants":
        step("Check constants")
        expect(bashMaxOutputDefault()).to_equal(30000)
        expect(bashMaxOutputUpperLimit()).to_equal(150000)
        expect(bashMaxOutputEnvName()).to_equal("BASH_MAX_OUTPUT_LENGTH")

    it "defaults missing values":
        step("Check empty env value")
        val result = validateBoundedIntEnvVar("BASH_MAX_OUTPUT_LENGTH", "", 30000, 150000)
        expect(result.effective).to_equal(30000)
        expect(result.status).to_equal("valid")
        expect(getMaxOutputLengthFromEnvValue("")).to_equal(30000)

    it "accepts positive bounded integers":
        step("Check valid env value")
        val result = validateBoundedIntEnvVar("BASH_MAX_OUTPUT_LENGTH", "1200", 30000, 150000)
        expect(result.effective).to_equal(1200)
        expect(result.status).to_equal("valid")

    it "rejects invalid or non-positive values":
        step("Check invalid env values")
        expect(validateBoundedIntEnvVar("BASH_MAX_OUTPUT_LENGTH", "nope", 30000, 150000).status).to_equal("invalid")
        expect(validateBoundedIntEnvVar("BASH_MAX_OUTPUT_LENGTH", "0", 30000, 150000).effective).to_equal(30000)
        expect(validateBoundedIntEnvVar("BASH_MAX_OUTPUT_LENGTH", "-1", 30000, 150000).message).to_equal("Invalid value \"-1\" (using default: 30000)")

    it "caps values above the upper limit":
        step("Check capped env value")
        val result = validateBoundedIntEnvVar("BASH_MAX_OUTPUT_LENGTH", "200000", 30000, 150000)
        expect(result.effective).to_equal(150000)
        expect(result.status).to_equal("capped")
        expect(result.message).to_equal("Capped from 200000 to 150000")
