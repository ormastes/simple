"""
# Claude Full PDF utils

Pure Simple coverage for PDF extension detection.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.pdfUtils.*

describe "Claude full PDF utils":
    it "accepts pdf extensions with or without leading dot":
        step("Check canonical PDF extensions")
        expect(isPDFExtension("pdf")).to_equal(true)
        expect(isPDFExtension(".pdf")).to_equal(true)

    it "matches PDF extension case-insensitively":
        step("Check uppercase variants")
        expect(isPDFExtension("PDF")).to_equal(true)
        expect(isPDFExtension(".Pdf")).to_equal(true)

    it "rejects non-pdf extensions":
        step("Check non-PDF values")
        expect(isPDFExtension("txt")).to_equal(false)
        expect(isPDFExtension(".json")).to_equal(false)
        expect(isPDFExtension("pdfx")).to_equal(false)
        expect(isPDFExtension("")).to_equal(false)
        expect(isPDFExtension(" pdf")).to_equal(false)
        expect(isPDFExtension("pdf ")).to_equal(false)
        expect(isPDFExtension("..pdf")).to_equal(false)
