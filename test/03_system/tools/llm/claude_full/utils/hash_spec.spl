"""
# Claude full hash utilities
"""

use std.spec.*
use app.llm_caret.claude_full.utils.hash.{djb2Hash}

describe "claude full utils hash":
    it "exposes djb2Hash parity wrapper":
        expect(djb2Hash("Claude Code")).to_equal(114934063)

    it "preserves signed 32-bit wrapping":
        expect(djb2Hash("zzzzzzzz")).to_equal(-1910022912)
