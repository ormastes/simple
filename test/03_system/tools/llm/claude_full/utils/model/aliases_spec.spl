"""
# Claude Full model aliases

Pure Simple coverage for model alias membership helpers.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.model.aliases.*

describe "Claude full model aliases":
    it "matches model aliases exactly":
        step("Check model alias membership")
        expect(isModelAlias("sonnet")).to_equal(true)
        expect(isModelAlias("opusplan")).to_equal(true)
        expect(isModelAlias("Sonnet")).to_equal(false)

    it "matches model family aliases exactly":
        step("Check model family membership")
        expect(isModelFamilyAlias("sonnet")).to_equal(true)
        expect(isModelFamilyAlias("opus")).to_equal(true)
        expect(isModelFamilyAlias("sonnet[1m]")).to_equal(false)
