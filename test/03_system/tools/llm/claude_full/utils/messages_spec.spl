"""
# Claude Full Utils Messages Slice

Focused coverage for visible transcript message creation and hidden API
normalization/tool-pairing behavior from `utils/messages.ts`.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.messages.*

describe "Claude full utils messages parity":
    it "should model visible user and assistant transcript routes":
        step("Check visible message creation behavior")
        expect(withMemoryCorrectionHint(true)).to_equal("append memory correction hint")
        expect(isSyntheticMessage("synthetic")).to_equal(true)
        expect(isSyntheticMessage("claude")).to_equal(false)
        expect(baseCreateAssistantMessageRoute(true, false)).to_equal("assistant message with tool use")
        expect(baseCreateAssistantMessageRoute(false, true)).to_equal("assistant message with thinking")
        expect(createAssistantMessageRoute("apiError", false)).to_equal("assistant api error message")
        expect(createAssistantMessageRoute("normal", true)).to_equal("ensure non empty assistant content")
        expect(createUserMessageRoute(true, false)).to_equal("user message with normalized attachments")
        expect(createUserMessageRoute(false, true)).to_equal("user command input message")
        expect(createSyntheticUserCaveatMessageRoute()).to_equal("synthetic user caveat")
        expect(formatCommandInputTagsRoute(true, true, true)).to_equal("command stdout stderr tags")
        expect(formatCommandInputTagsRoute(true, true, false)).to_equal("command stdout tags")
        expect(formatCommandInputTagsRoute(true, false, true)).to_equal("command stderr tags")
        expect(formatCommandInputTagsRoute(false, true, true)).to_equal("no command tags")
        expect(shouldShowUserMessageRoute("assistant", false, false, "", false, false, false)).to_equal(false)
        expect(shouldShowUserMessageRoute("user", true, false, "", false, false, false)).to_equal(false)
        expect(shouldShowUserMessageRoute("user", false, true, "channel", true, false, false)).to_equal(true)
        expect(shouldShowUserMessageRoute("user", false, false, "", true, false, false)).to_equal(false)
        expect(shouldShowUserMessageRoute("user", false, false, "", true, true, false)).to_equal(true)

    it "should model hidden normalization and API pairing routes":
        step("Check normalization and pairing behavior")
        expect(normalizeMessagesRoute(false, false, true)).to_equal("drop empty messages")
        expect(normalizeMessagesRoute(true, false, false)).to_equal("merge adjacent user messages")
        expect(normalizeMessagesRoute(false, true, false)).to_equal("merge adjacent assistant messages")
        expect(reorderMessagesInUIRoute(true, true)).to_equal("move tool result after tool use")
        expect(reorderMessagesInUIRoute(true, false)).to_equal("group tool use siblings")
        expect(normalizeMessagesForAPIRoute(false, true, false)).to_equal("strip unavailable tool references")
        expect(normalizeMessagesForAPIRoute(true, false, false)).to_equal("ensure tool result pairing")
        expect(mergeUserMessagesAndToolResultsRoute(true, true)).to_equal("merge user text and tool results")
        expect(mergeUserMessagesAndToolResultsRoute(true, false)).to_equal("merge user content blocks")
        expect(mergeUserMessagesAndToolResultsRoute(false, true)).to_equal("hoist tool results")
        expect(ensureNonEmptyAssistantContentRoute(true)).to_equal("insert synthetic placeholder text")
        expect(stripSignatureBlocksRoute(true, true)).to_equal("strip signature from thinking blocks")
        expect(stripSignatureBlocksRoute(true, false)).to_equal("strip signature blocks")
        expect(ensureToolResultPairingRoute(true, false)).to_equal("insert synthetic tool result placeholder")
        expect(ensureToolResultPairingRoute(false, true)).to_equal("drop orphaned tool result")
        expect(filterOrphanedThinkingOnlyMessagesRoute(false, true)).to_equal("drop orphaned thinking only message")
        expect(filterOrphanedThinkingOnlyMessagesRoute(true, true)).to_equal("keep thinking message")
        expect(buildMessageLookupsRoute(1, 1, 0)).to_equal("tool use result lookup")
        expect(buildMessageLookupsRoute(1, 0, 0)).to_equal("tool use lookup")
        expect(buildMessageLookupsRoute(0, 1, 0)).to_equal("tool result lookup")
        expect(buildMessageLookupsRoute(0, 0, 1)).to_equal("hook lookup")
        expect(buildMessageLookupsRoute(0, 0, 0)).to_equal("empty lookup")

    it "should check source size export type and class counts":
        step("Read modeled counts from tmp/claude source")
        expect(messagesSourceLinesModeled()).to_equal(5512)
        expect(messagesExportCountModeled()).to_equal(106)
        expect(messagesTypeCountModeled()).to_equal(3)
        expect(messagesClassCountModeled()).to_equal(0)
