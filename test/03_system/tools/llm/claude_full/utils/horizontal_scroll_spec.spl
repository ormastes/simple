"""
# Claude Full horizontal scroll

Pure Simple coverage for horizontal scroll window math.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.horizontalScroll.*

describe "Claude full horizontal scroll":
    it "returns an empty window for no items":
        val window = calculateHorizontalScrollWindow([], 10, 2, 0, true)
        expect(window.startIndex).to_equal(0)
        expect(window.endIndex).to_equal(0)
        expect(window.showLeftArrow).to_equal(false)
        expect(window.showRightArrow).to_equal(false)

    it "shows every item when all widths fit":
        val window = calculateHorizontalScrollWindow([2, 3, 4], 9, 2, 1, true)
        expect(window.startIndex).to_equal(0)
        expect(window.endIndex).to_equal(3)
        expect(window.showRightArrow).to_equal(false)

    it "preserves zero-width items in the visible range":
        val window = calculateHorizontalScrollWindow([0, 5, 5], 6, 1, 1, true)
        expect(window.startIndex).to_equal(0)
        expect(window.endIndex).to_equal(2)
        expect(window.showRightArrow).to_equal(true)

    it "keeps initial visible range when selected item is already visible":
        val window = calculateHorizontalScrollWindow([3, 3, 4, 4], 9, 2, 1, true)
        expect(window.startIndex).to_equal(0)
        expect(window.endIndex).to_equal(2)
        expect(window.showRightArrow).to_equal(true)

    it "scrolls right to keep selected item visible":
        val window = calculateHorizontalScrollWindow([4, 4, 4, 4], 9, 2, 3, true)
        expect(window.startIndex).to_equal(2)
        expect(window.endIndex).to_equal(4)
        expect(window.showLeftArrow).to_equal(true)
        expect(window.showRightArrow).to_equal(false)

    it "clamps negative selected index to the first item":
        val window = calculateHorizontalScrollWindow([4, 4, 4, 4], 9, 2, -1, true)
        expect(window.startIndex).to_equal(0)
        expect(window.endIndex).to_equal(1)
        expect(window.showLeftArrow).to_equal(false)
        expect(window.showRightArrow).to_equal(true)

    it "uses arrow width to reduce the visible range":
        val withArrow = calculateHorizontalScrollWindow([3, 3, 1], 6, 2, 0, true)
        val withoutArrow = calculateHorizontalScrollWindow([3, 3, 1], 6, 0, 0, true)
        expect(withArrow.endIndex).to_equal(1)
        expect(withoutArrow.endIndex).to_equal(2)

    it "clamps selected index before calculating the window":
        val window = calculateHorizontalScrollWindow([4, 4, 4], 8, 2, 99, true)
        expect(window.startIndex).to_equal(2)
        expect(window.endIndex).to_equal(3)

    it "uses first visible separator adjustment when starting after zero":
        val withAdjustment = calculateHorizontalScrollWindow([3, 3, 3], 6, 1, 2, true)
        val withoutAdjustment = calculateHorizontalScrollWindow([3, 3, 3], 6, 1, 2, false)
        expect(withAdjustment.startIndex).to_equal(1)
        expect(withoutAdjustment.startIndex).to_equal(2)
