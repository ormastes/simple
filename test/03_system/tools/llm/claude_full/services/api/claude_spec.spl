"""
# Claude Full Services API Claude Slice

Focused coverage for Claude API request construction, nonstreaming fallback,
media trimming, stream cleanup, usage, caching, and model selection routes.
"""

use std.spec.*
use app.llm_caret.claude_full.services.api.claude.*

describe "Claude full services api claude parity":
    it "should model request params cache metadata and auth routes":
        step("Check request building routes")
        val options = Options.new(true, "sonnet")
        expect(options.streaming).to_equal(true)
        val budget = TaskBudgetParam.new(5, 1000)
        expect(budget.maxTokens).to_equal(1000)
        expect(getExtraBodyParamsRoute(true, true, true)).to_equal("extra body thinking metadata cache")
        expect(getPromptCachingEnabledRoute(false, true)).to_equal(true)
        expect(getPromptCachingEnabledRoute(true, true)).to_equal(false)
        expect(getCacheControlRoute(true, true)).to_equal("cache control 1h")
        expect(getCacheControlRoute(false, false)).to_equal("no cache control")
        expect(configureEffortParamsRoute("sonnet", "high")).to_equal("configure reasoning effort high")
        expect(configureEffortParamsRoute("haiku", "high")).to_equal("effort unsupported")
        expect(configureTaskBudgetParamsRoute(true, false)).to_equal("task budget params")
        expect(configureTaskBudgetParamsRoute(true, true)).to_equal("task budget exceeded")
        expect(getAPIMetadataRoute(true, true)).to_equal("api metadata session request")
        expect(verifyApiKeyRoute(true, true)).to_equal("api key verified")
        expect(verifyApiKeyRoute(true, false)).to_equal("api key rejected")

    it "should model message conversion fallback media and deferred tools":
        step("Check message and fallback routes")
        expect(messageParamRoute("user", false, true)).to_equal("user message with media")
        expect(messageParamRoute("user", true, false)).to_equal("user tool result message")
        expect(messageParamRoute("assistant", true, false)).to_equal("assistant tool use message")
        expect(previousRequestIdRoute(true, true)).to_equal("previous request id")
        expect(previousRequestIdRoute(true, false)).to_equal("no previous request id")
        expect(mediaBlockRoute("image", false)).to_equal("media block")
        expect(mediaBlockRoute("text", true)).to_equal("tool result block preserved")
        expect(queryModelWithoutStreamingRoute(true, false, false)).to_equal("nonstreaming response")
        expect(queryModelWithoutStreamingRoute(false, true, false)).to_equal("nonstreaming timeout")
        expect(queryModelWithoutStreamingRoute(false, false, true)).to_equal("fallback to streaming")
        expect(shouldDeferLspToolRoute("LSPDefinition", false)).to_equal(true)
        expect(getNonstreamingFallbackTimeoutMsRoute(0)).to_equal(10000)
        expect(mediaTrimRoute(5, 3, true)).to_equal("trim media preserve tool results")
        expect(mediaTrimRoute(5, 3, false)).to_equal("trim excess media")
        expect(deferredToolsRoute(true, false)).to_equal("defer tools")
        expect(deferredToolsRoute(true, true)).to_equal("include deferred tools")
        expect(paramsFromContextRoute(true, true, true)).to_equal("params context tools mcp config")
        expect(paramsFromContextRoute(false, false, false)).to_equal("params context base")

    it "should model streaming usage cache and model query routes":
        step("Check streaming and cache routes")
        expect(streamResourceRoute("release")).to_equal("release stream resources")
        expect(streamResourceRoute("clearIdle")).to_equal("clear stream idle timers")
        expect(streamResourceRoute("resetIdle")).to_equal("reset stream idle timer")
        expect(streamResourceRoute("cleanup")).to_equal("cleanup stream")
        expect(streamResourceRoute("abortIdle")).to_equal("abort stalled stream")
        expect(usageRoute(10, 5)).to_equal(15)
        expect(updateUsageRoute(10, 15)).to_equal(15)
        expect(updateUsageRoute(15, 10)).to_equal(15)
        expect(accumulateUsageRoute(10, 0)).to_equal(10)
        expect(accumulateUsageRoute(10, 5)).to_equal(15)
        expect(cacheBreakpointRoute(true, false)).to_equal("add cache breakpoints for pinned edits")
        expect(cacheBreakpointRoute(false, true)).to_equal("add cache breakpoints for system blocks")
        expect(cacheReferenceRoute(true, true)).to_equal("cache reference applied")
        expect(cacheReferenceRoute(true, false)).to_equal("cache reference ignored")
        expect(deduplicateEditsRoute(5, 3)).to_equal("deduplicate edits")
        expect(buildSystemPromptBlocksRoute(true, true)).to_equal("system prompt tools reminders")
        expect(queryModelRoute("haiku", true, false)).to_equal("query haiku")
        expect(queryModelRoute("normal", true, true)).to_equal("query model nonstreaming")
        expect(adjustParamsForNonStreamingRoute(true, 0)).to_equal("remove streaming only params")
        expect(adjustParamsForNonStreamingRoute(false, 100)).to_equal("set nonstreaming max tokens")
        expect(maxOutputTokensRoute(true, 2000, 1000)).to_equal(1000)
        expect(maxOutputTokensRoute(false, 2000, 1000)).to_equal(2000)
        expect(claudeApiSourceLinesModeled()).to_equal(3419)
