"""
# Claude Full Tool Execution Slice

Focused Simple coverage for pure tool execution helpers and thin runToolUse
envelope routes from services/tools/toolExecution.ts.
"""

use std.spec.*
use app.llm_caret.claude_full.services.tools.toolExecution.*

describe "Claude full tool execution parity":
    it "should model tool error classification":
        step("Check error classification")
        expect(HOOK_TIMING_DISPLAY_THRESHOLD_MS).to_equal(1000)
        expect(classifyToolErrorRoute("telemetry_safe", "safe", "", "")).to_equal("safe")
        expect(classifyToolErrorRoute("node", "", "ENOENT", "")).to_equal("Error:ENOENT")
        expect(classifyToolErrorRoute("named", "", "", "AbortError")).to_equal("AbortError")
        expect(classifyToolErrorRoute("generic", "", "", "Error")).to_equal("Error")

    it "should model schema hints and helper routes":
        step("Check helper routes")
        expect(buildSchemaNotSentHintRoute(false, true, true, false, "Bash")).to_equal("none")
        expect(buildSchemaNotSentHintRoute(true, false, true, false, "Bash")).to_equal("none")
        expect(buildSchemaNotSentHintRoute(true, true, false, false, "Bash")).to_equal("none")
        expect(buildSchemaNotSentHintRoute(true, true, true, true, "Bash")).to_equal("none")
        expect(buildSchemaNotSentHintRoute(true, true, true, false, "Bash")).to_equal("select:Bash")
        expect(ruleSourceToOTelSourceRoute("project")).to_equal("project")
        expect(decisionReasonToOTelSourceRoute("deny")).to_equal("deny")
        expect(getNextImagePasteIdRoute(4)).to_equal(5)
        expect(mcpLookupRoute(true, true)).to_equal("mcp tool")

    it "should model run tool envelope routes":
        step("Check runToolUse envelope")
        expect(runToolUseEnvelopeRoute(false, false, "a1")).to_equal("tool_result error No such tool available a1")
        expect(runToolUseEnvelopeRoute(true, true, "a2")).to_equal("cancel message a2")
        expect(runToolUseEnvelopeRoute(true, false, "a3")).to_equal("tool_result ok a3")
        expect(toolExecutionSourceLinesModeled()).to_equal(1745)
