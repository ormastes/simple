"""
# Claude Full Constants

Mirrors the smallest Claude constant-only source files so the full-parity
matrix has executable evidence for literal values, not just target paths.
"""

use std.spec.*
use app.llm_caret.claude_full.constants.errorIds.{E_TOOL_USE_SUMMARY_GENERATION_FAILED}
use app.llm_caret.claude_full.constants.messages.{NO_CONTENT_MESSAGE}
use app.llm_caret.claude_full.constants.toolLimits.*
use app.llm_caret.claude_full.constants.turnCompletionVerbs.{turnCompletionVerbs}
use app.llm_caret.claude_full.tools.ConfigTool.constants.{CONFIG_TOOL_NAME}

describe "Claude full constant parity":
    it "should expose the no-content placeholder used by Claude output":
        step("Read the constant mapped from constants/messages.ts")
        expect(NO_CONTENT_MESSAGE).to_equal("(no content)")

    it "should expose the tool-use summary error id":
        step("Read the constant mapped from constants/errorIds.ts")
        expect(E_TOOL_USE_SUMMARY_GENERATION_FAILED).to_equal(344)

    it "should expose turn completion verbs":
        step("Read constants mapped from constants/turnCompletionVerbs.ts")
        expect(turnCompletionVerbs()).to_equal(["Baked", "Brewed", "Churned", "Cogitated", "Cooked", "Crunched", "Sautéed", "Worked"])

    it "should expose tool limit constants":
        step("Read constants mapped from constants/toolLimits.ts")
        expect(DEFAULT_MAX_RESULT_SIZE_CHARS).to_equal(50000)
        expect(MAX_TOOL_RESULT_TOKENS).to_equal(100000)
        expect(BYTES_PER_TOKEN).to_equal(4)
        expect(MAX_TOOL_RESULT_BYTES).to_equal(400000)
        expect(MAX_TOOL_RESULTS_PER_MESSAGE_CHARS).to_equal(200000)
        expect(TOOL_SUMMARY_MAX_LENGTH).to_equal(50)

    it "should expose the Config tool name literal":
        step("Read the constant mapped from tools/ConfigTool/constants.ts")
        expect(CONFIG_TOOL_NAME).to_equal("Config")
