"""
# Claude Full Btw Command

Mirrors `tmp/claude/claude-code-main/src/commands/btw` for command metadata,
blank argument handling, side-question cache params, and keyboard decisions.
"""

use std.spec.*
use app.llm_caret.claude_full.commands.btw.index.{btwCommand, btwIndexSourceLinesModeled}
use app.llm_caret.claude_full.commands.btw.btw.{BtwContext, BtwMessage, LastCacheSafeParams, btwChromeRows, btwDismissDisplay, btwDismissesKey, btwFailureFallbackText, btwHelpText, btwLoadingText, btwMaxContentHeight, btwNoResponseText, btwOuterChromeRows, btwScrollDelta, btwScrollLines, btwSourceLinesModeled, buildCacheSafeParams, callBtw, stripInProgressAssistantMessage}

describe "Claude full btw command":
    it "matches command descriptor metadata":
        val command = btwCommand()

        expect(command.typeName).to_equal("local-jsx")
        expect(command.name).to_equal("btw")
        expect(command.description).to_equal("Ask a quick side question without interrupting the main conversation")
        expect(command.immediate).to_equal(true)
        expect(command.argumentHint).to_equal("<question>")
        expect(command.loadPath).to_equal("./btw.js")
        expect(btwIndexSourceLinesModeled()).to_equal(13)

    it "handles blank and present questions like Claude":
        val blank = callBtw("   ", 4)
        expect(blank.doneMessage).to_equal("Usage: /btw <your question>")
        expect(blank.display).to_equal("system")
        expect(blank.renderedSideQuestion).to_equal(false)
        expect(blank.btwUseCount).to_equal(4)

        val present = callBtw("  explain this diff  ", 4)
        expect(present.question).to_equal("explain this diff")
        expect(present.renderedSideQuestion).to_equal(true)
        expect(present.btwUseCount).to_equal(5)
        expect(present.doneMessage).to_equal("")

    it "strips only an in-progress assistant tail before forking":
        val messages = [
            BtwMessage.new("user", "end_turn"),
            BtwMessage.new("assistant", ""),
        ]
        val stripped = stripInProgressAssistantMessage(messages)
        expect(stripped.len()).to_equal(1)
        expect(stripped[0].typeName).to_equal("user")

        val complete = stripInProgressAssistantMessage([BtwMessage.new("assistant", "end_turn")])
        expect(complete.len()).to_equal(1)

    it "prefers last cache-safe params and falls back to rebuilt context":
        val context = BtwContext.new("ctx-1", [BtwMessage.new("user", "end_turn"), BtwMessage.new("assistant", "")], ["Read"], "sonnet", ["mcp"])
        val saved = buildCacheSafeParams(context, LastCacheSafeParams.saved("saved-system", "saved-user", "saved-context"), "raw-system", "raw-user", "raw-context")
        expect(saved.source).to_equal("last-cache-safe")
        expect(saved.systemPrompt).to_equal("saved-system")
        expect(saved.userContext).to_equal("saved-user")
        expect(saved.systemContext).to_equal("saved-context")
        expect(saved.toolUseContextId).to_equal("ctx-1")
        expect(saved.forkContextMessages.len()).to_equal(1)

        val rebuilt = buildCacheSafeParams(context, LastCacheSafeParams.none(), "raw-system", "raw-user", "raw-context")
        expect(rebuilt.source).to_equal("rebuilt")
        expect(rebuilt.systemPrompt).to_equal("raw-system")
        expect(rebuilt.userContext).to_equal("raw-user")
        expect(rebuilt.systemContext).to_equal("raw-context")

    it "matches btw UI constants and key decisions":
        expect(btwHelpText()).to_equal("Usage: /btw <your question>")
        expect(btwLoadingText()).to_equal("Answering...")
        expect(btwNoResponseText()).to_equal("No response received")
        expect(btwFailureFallbackText()).to_equal("Failed to get response")
        expect(btwDismissDisplay()).to_equal("skip")
        expect(btwScrollLines()).to_equal(3)
        expect(btwChromeRows()).to_equal(5)
        expect(btwOuterChromeRows()).to_equal(6)
        expect(btwMaxContentHeight(80)).to_equal(69)
        expect(btwMaxContentHeight(10)).to_equal(5)
        expect(btwDismissesKey("escape", false)).to_equal(true)
        expect(btwDismissesKey("c", true)).to_equal(true)
        expect(btwDismissesKey("x", false)).to_equal(false)
        expect(btwScrollDelta("up", false)).to_equal(-3)
        expect(btwScrollDelta("n", true)).to_equal(3)
        expect(btwScrollDelta("x", false)).to_equal(0)
        expect(btwSourceLinesModeled()).to_equal(242)
