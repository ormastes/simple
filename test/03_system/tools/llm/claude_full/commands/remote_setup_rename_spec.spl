"""
# Claude Full Remote Setup And Rename Commands

Checks remote-setup command parity and rename command naming behavior.
"""

use std.spec.*
use app.llm_caret.claude_full.commands.remote_setup.index.{remoteSetupCommand, remoteSetupIndexSourceLinesModeled}
use app.llm_caret.claude_full.commands.remote_setup.remote_setup.{RemoteSetupState, callRemoteSetup, remoteSetupCodeUrl, remoteSetupNextStep, remoteSetupSourceLinesModeled, remoteSetupStatusLabel}
use app.llm_caret.claude_full.commands.rename.generateSessionName.{generateSessionName, generateSessionNameFromMessages, generateSessionNameSourceLinesModeled}
use app.llm_caret.claude_full.commands.rename.index.{renameCommand, renameIndexSourceLinesModeled}
use app.llm_caret.claude_full.commands.rename.rename.{RenameState, callRenameCommand, renameShouldPersist, renameSourceLinesModeled}

describe "Claude full remote-setup and rename commands":
    it "exposes remote setup command metadata and setup decisions":
        val command = remoteSetupCommand()
        expect(command.typeName).to_equal("local-jsx")
        expect(command.name).to_equal("remote-setup")
        expect(command.argumentHint).to_equal("[github-token]")
        expect(command.loadPath).to_equal("./remote-setup.js")

        expect(remoteSetupNextStep(RemoteSetupState.new(false, "", false, 0, false, false))).to_equal("signin")
        expect(remoteSetupNextStep(RemoteSetupState.new(true, "ghp_token", false, 0, false, false))).to_equal("import-github-token")
        expect(remoteSetupNextStep(RemoteSetupState.new(true, "", false, 0, false, false))).to_equal("create-default-environment")
        expect(remoteSetupNextStep(RemoteSetupState.new(true, "", false, 1, false, false))).to_equal("open-code")
        expect(remoteSetupStatusLabel(RemoteSetupState.new(true, "", false, 1, false, false))).to_equal("Ready")
        expect(remoteSetupCodeUrl("https://claude.ai/")).to_equal("https://claude.ai/code")

    it "maps remote setup call outcomes":
        val network = callRemoteSetup(RemoteSetupState.new(true, "", false, 1, false, true), "https://claude.ai")
        expect(network.ok).to_equal(false)
        expect(network.stepName).to_equal("network")

        val done = callRemoteSetup(RemoteSetupState.new(true, "", true, 1, false, false), "https://claude.ai")
        expect(done.ok).to_equal(true)
        expect(done.shouldOpenCode).to_equal(true)
        expect(done.message).to_contain("https://claude.ai/code")
        expect(remoteSetupSourceLinesModeled()).to_equal(186)
        expect(remoteSetupIndexSourceLinesModeled()).to_equal(20)

    it "generates session names from prompt text":
        expect(generateSessionName(" Human:  fix\n\nthis\tbug now ")).to_equal("fix this bug now")
        expect(generateSessionName("")).to_equal("Untitled conversation")
        expect(generateSessionNameFromMessages(["", "User: second prompt"])).to_equal("second prompt")
        expect(generateSessionNameSourceLinesModeled()).to_equal(67)

    it "renames with explicit or generated names":
        val command = renameCommand()
        expect(command.typeName).to_equal("local-jsx")
        expect(command.name).to_equal("rename")
        expect(command.argumentHint).to_equal("[name]")

        val state = RenameState.new("session-1", "old", "/tmp/session.jsonl", ["Human: summarize logs"])
        val explicit = callRenameCommand("new title", state)
        expect(explicit.ok).to_equal(true)
        expect(explicit.name).to_equal("new title")
        expect(renameShouldPersist(explicit)).to_equal(true)

        val generated = callRenameCommand("", state)
        expect(generated.name).to_equal("summarize logs")
        expect(generated.message).to_contain("Generated conversation name")
        expect(renameSourceLinesModeled()).to_equal(87)
        expect(renameIndexSourceLinesModeled()).to_equal(12)
