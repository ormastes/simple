"""
# Claude Full PressEnterToContinue

Pure Simple/TUI-compatible static continue prompt.
"""

use std.spec.*
use app.llm_caret.claude_full.components.PressEnterToContinue.*

describe "Claude full PressEnterToContinue":
    it "renders the continue prompt":
        step("Check text and styling metadata")
        val view = PressEnterToContinue()
        expect(view.text).to_equal("Press Enter to continue...")
        expect(view.color).to_equal("permission")
        expect(view.boldSegment).to_equal("Enter")
        expect(view.sourceEllipsis).to_equal("u2026")
        expect(pressEnterToContinueText()).to_equal(view.text)
