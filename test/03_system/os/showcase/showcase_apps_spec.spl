# Showcase applications across standalone, hosted WM, and SimpleOS WM.
# @req REQ-SHOWCASE-001 REQ-SHOWCASE-002 REQ-SHOWCASE-003 REQ-SHOWCASE-004
# @evidence-display: links
# @tag: system, gui, web, 2d, wm, simpleos, qemu, showcase

"""
Launches each canonical showcase through every required surface. Acceptance
requires the real installed identity, process-owned window, nonblank rendered
frame, and a state or pixel change caused by production input routing.

The launch/evidence adapter is deliberately fail-fast until the standalone,
host-WM, and SimpleOS/QEMU wrappers expose correlated evidence. Source scans,
dummy frames, synthetic handles, and synthetic input cannot satisfy this spec.
"""

use std.spec.*
use common.ui.showcase_catalog.{ShowcaseEntry, showcase_find}
use os.hosted.hosted_wm_evidence.{host_wm_evidence_config_from_env, host_wm_evidence_parse_command}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_file_write_text_at(path: text, offset: i64, data: text) -> i64

val GRAPHICS_2D: text = "graphics_2d_showcase"
val WEB_STANDARDS: text = "web_standards_showcase"
val GUI_WIDGETS: text = "gui_widget_showcase"

val STANDALONE: text = "standalone"
val HOST_WM: text = "host_wm"
val SIMPLEOS_WM: text = "simpleos_wm"

# These five names are the shared wrapper interface (design/showcase_apps.md).
# Each one routes through the production catalog readiness flags
# (common.ui.showcase_catalog) and the hosted WM production evidence adapter
# (os.hosted.hosted_wm_evidence) instead of a bare fail(). Every failure
# carries app/surface/phase/cause so the specs stay honestly RED through the
# production path until a readiness flag is proven true by a deployed run.

fn _surface_ready(entry: ShowcaseEntry, surface: text) -> bool:
    if surface == STANDALONE:
        return entry.standalone_ready
    if surface == HOST_WM:
        return entry.host_wm_ready
    if surface == SIMPLEOS_WM:
        return entry.simpleos_wm_ready
    false

fn _showcase_fail(app_id: text, surface: text, phase: text, cause: text, detail: text):
    fail("app={app_id} surface={surface} phase={phase} cause={cause} detail={detail}")

fn _read_capture_bytes(path: text) -> [u8]:
    val r = rt_file_read_bytes(path)
    if val bytes = r:
        bytes
    else:
        []

fn _ppm_payload_offset(bytes: [u8]) -> i32:
    # P6 header = magic, dimensions, maxval separated by whitespace; the pixel
    # payload starts after the third newline. Uniform header bytes must not
    # count as "nonblank" pixels.
    var newlines = 0
    var i = 0
    while i < bytes.len():
        if bytes[i] == 10:
            newlines = newlines + 1
            if newlines == 3:
                return i + 1
        i = i + 1
    -1

fn _ppm_is_nonblank(bytes: [u8]) -> bool:
    val start = _ppm_payload_offset(bytes)
    if start < 0 or start >= bytes.len():
        return false
    val ref_byte = bytes[start]
    var all_same = true
    var i = start
    while i < bytes.len():
        if bytes[i] != ref_byte:
            all_same = false
        i = i + 1
    not all_same

# Shared precondition gate for every wrapper below: catalog readiness for
# this app/surface, then a valid production evidence configuration. Fails
# closed through _showcase_fail and returns false on any gap.
fn _showcase_ready(app_id: text, surface: text, phase: text) -> bool:
    if val entry = showcase_find(app_id):
        if not _surface_ready(entry, surface):
            _showcase_fail(app_id, surface, phase, "surface-not-ready", "catalog readiness flag is false for {app_id} on {surface}; the production launch/evidence adapter has not proven this surface yet")
            return false
    else:
        _showcase_fail(app_id, surface, phase, "surface-not-ready", "no catalog entry for {app_id}")
        return false
    val evidence = host_wm_evidence_config_from_env()
    if not (evidence.enabled and evidence.valid):
        val why = if evidence.valid: "SIMPLE_WM_EVIDENCE_SNAPSHOT_PATH, SIMPLE_WM_EVIDENCE_CAPTURE_PATH, and SIMPLE_WM_EVIDENCE_INPUT_FIFO must all be set" else: evidence.failure_reason
        _showcase_fail(app_id, surface, phase, "evidence-config-missing", why)
        return false
    true

fn launch_showcase(app_id: text, surface: text):
    if _showcase_ready(app_id, surface, "launch"):
        print "[showcase-spec] {app_id}/{surface} launch preconditions satisfied via the production catalog and evidence adapter; the deployed launcher route is not wired yet"

fn require_installed_identity(app_id: text, surface: text):
    if not _showcase_ready(app_id, surface, "installed-identity"):
        return
    if val entry = showcase_find(app_id):
        if not rt_file_exists(entry.installed_path):
            _showcase_fail(app_id, surface, "installed-identity", "installed-identity-missing", "expected installed application bytes at {entry.installed_path}")
    else:
        _showcase_fail(app_id, surface, "installed-identity", "surface-not-ready", "no catalog entry for {app_id}")

fn require_owned_window(app_id: text, surface: text):
    if _showcase_ready(app_id, surface, "owned-window"):
        print "[showcase-spec] {app_id}/{surface} owned-window preconditions satisfied via the production catalog and evidence adapter; process/window ownership wiring is future work"

fn require_nonblank_frame(app_id: text, surface: text):
    if not _showcase_ready(app_id, surface, "nonblank-frame"):
        return
    val evidence = host_wm_evidence_config_from_env()
    if not _ppm_is_nonblank(_read_capture_bytes(evidence.capture_path)):
        _showcase_fail(app_id, surface, "nonblank-frame", "blank-frame", "capture at {evidence.capture_path} is missing or has no nonblank pixel bytes")

fn require_post_input_change(app_id: text, surface: text):
    if not _showcase_ready(app_id, surface, "post-input-change"):
        return
    val evidence = host_wm_evidence_config_from_env()
    val before = rt_file_read_text(evidence.snapshot_path)
    val command = host_wm_evidence_parse_command("1 tab")
    if not command.valid:
        _showcase_fail(app_id, surface, "post-input-change", "command-round-trip-failed", "adapter rejected the production input command before it was routed")
        return
    if rt_file_write_text_at(evidence.input_fifo, 0, "1 tab") < 0:
        _showcase_fail(app_id, surface, "post-input-change", "input-route-failed", "could not write the production input command to {evidence.input_fifo}")
        return
    val after = rt_file_read_text(evidence.snapshot_path)
    if before == after:
        _showcase_fail(app_id, surface, "post-input-change", "unchanged-frame", "snapshot at {evidence.snapshot_path} did not change after routing the production input command")

# @inline
fn run_showcase_acceptance(app_id: text, surface: text):
    step("Launch {app_id} through the {surface} catalog action")
    expect(app_id.ends_with("showcase")).to_be(true)
    expect(surface == STANDALONE or surface == HOST_WM or surface == SIMPLEOS_WM).to_be(true)
    launch_showcase(app_id, surface)
    step("Verify the canonical installed application identity")
    require_installed_identity(app_id, surface)
    step("Verify the guest or host process owns the visible window")
    require_owned_window(app_id, surface)
    step("Capture a nonblank frame with real backend provenance")
    require_nonblank_frame(app_id, surface)
    step("Send production input and capture the resulting change")
    require_post_input_change(app_id, surface)

fn rejected_evidence_reason(
    source_only: bool,
    blank_frame: bool,
    dummy_renderer: bool,
    synthetic_handle: bool,
    synthetic_input: bool,
    frame_changed: bool
) -> text:
    if source_only:
        return "source-only"
    if blank_frame:
        return "blank-frame"
    if dummy_renderer:
        return "dummy-renderer"
    if synthetic_handle:
        return "synthetic-handle"
    if synthetic_input:
        return "synthetic-input"
    if not frame_changed:
        return "unchanged-frame"
    ""

describe "Showcase applications on every launch surface":
    # codex-system-test
    it "should run the 2D rendering showcase as a standalone app":
        run_showcase_acceptance(GRAPHICS_2D, STANDALONE)

    it "should run the 2D rendering showcase inside the host WM":
        run_showcase_acceptance(GRAPHICS_2D, HOST_WM)

    it "should run the installed 2D rendering showcase inside SimpleOS WM":
        run_showcase_acceptance(GRAPHICS_2D, SIMPLEOS_WM)

    it "should run the web standards showcase as a standalone app":
        run_showcase_acceptance(WEB_STANDARDS, STANDALONE)

    it "should run the web standards showcase inside the host WM":
        run_showcase_acceptance(WEB_STANDARDS, HOST_WM)

    it "should run the installed web standards showcase inside SimpleOS WM":
        run_showcase_acceptance(WEB_STANDARDS, SIMPLEOS_WM)

    it "should run the GUI widget showcase as a standalone app":
        run_showcase_acceptance(GUI_WIDGETS, STANDALONE)

    it "should run the GUI widget showcase inside the host WM":
        run_showcase_acceptance(GUI_WIDGETS, HOST_WM)

    it "should run the installed GUI widget showcase inside SimpleOS WM":
        run_showcase_acceptance(GUI_WIDGETS, SIMPLEOS_WM)

describe "Showcase evidence rejects non-production substitutes":
    it "should reject source inspection without a launched surface":
        step("Submit source-only evidence without a live application")
        expect(rejected_evidence_reason(true, false, false, false, false, true)).to_equal("source-only")

    it "should reject blank and unchanged framebuffer captures":
        step("Submit a blank framebuffer capture")
        expect(rejected_evidence_reason(false, true, false, false, false, true)).to_equal("blank-frame")
        step("Submit equal before and after framebuffer hashes")
        expect(rejected_evidence_reason(false, false, false, false, false, false)).to_equal("unchanged-frame")

    it "should reject dummy renderers and synthetic backend handles":
        step("Substitute a dummy renderer")
        expect(rejected_evidence_reason(false, false, true, false, false, true)).to_equal("dummy-renderer")
        step("Substitute a synthetic backend handle")
        expect(rejected_evidence_reason(false, false, false, true, false, true)).to_equal("synthetic-handle")

    it "should reject synthetic input even when pixels differ":
        step("Mutate pixels through a synthetic event rather than the production input route")
        expect(rejected_evidence_reason(false, false, false, false, true, true)).to_equal("synthetic-input")
