# codex-system-test
# @req REQ-001 REQ-002 REQ-003 REQ-004 REQ-005 REQ-006 REQ-007 REQ-008 REQ-009 REQ-010 REQ-011 REQ-012
# @evidence-display: links
"""# SimpleOS QEMU Host-GPU 2D

Proves that each supported guest uses one bounded protocol to execute Draw IR
and ProcessingIR on a real host device, while unsupported rows fall back
honestly and malformed evidence fails closed.
"""

use std.spec.*
use std.io_runtime.{process_run}
use app.io.mod.{file_read_text}

fn host_gpu_wrapper_source() -> text:
    file_read_text("scripts/check/check-simpleos-qemu-host-gpu-2d.shs")

fn qemu_runner_build_source() -> text:
    file_read_text("src/os/_QemuRunner/os_build_run.spl")

fn process_ops_source() -> text:
    file_read_text("src/lib/nogc_sync_mut/io/process_ops.spl")

fn host_gpu_probe_source() -> text:
    file_read_text("examples/09_embedded/simple_os/arch/common/host_gpu_ivshmem_probe_entry.spl")

fn host_gpu_guest_bridge_source() -> text:
    file_read_text("src/os/lib/gpu_bridge/host_gpu_ivshmem.spl")

fn host_gpu_protocol_source() -> text:
    file_read_text("src/lib/common/gpu/simpleos_host_gpu_protocol.spl")

fn production_wm_executor_source() -> text:
    file_read_text("src/os/compositor/engine2d_wm_frame_executor.spl")

fn vulkan_backend_source() -> text:
    file_read_text("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl")

fn vulkan_backend_helpers_source() -> text:
    file_read_text("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_helpers.spl")

fn vulkan_sffi_owner_source() -> text:
    file_read_text("src/lib/nogc_sync_mut/gpu/engine2d/sffi_vulkan.spl")

fn vulkan_processing_source() -> text:
    file_read_text("src/lib/gc_async_mut/processing/vulkan_fill_u32.spl")

fn host_gpu_daemon_source() -> text:
    file_read_text("src/app/simpleos_gpu_host/main.spl")

fn time_ops_source() -> text:
    file_read_text("src/app/io/time_ops.spl")

fn metal_processing_source() -> text:
    file_read_text("src/lib/gc_async_mut/processing/metal_fill_u32.spl")

fn cuda_processing_source() -> text:
    file_read_text("src/lib/gc_async_mut/processing/cuda_fill_u32.spl")

fn cuda_readback_wrapper_source() -> text:
    file_read_text("scripts/check/check-cuda-generated-2d-readback.shs")

fn run_cuda_readback_wrapper_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-cuda-generated-2d-readback.shs", "--self-test"])
    expect(code).to_equal(0)
    out

fn run_generated_2d_matrix_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-generated-2d-backend-readback-matrix-evidence.shs", "--self-test"])
    expect(code).to_equal(0)
    out

fn draw_ir_executor_source() -> text:
    file_read_text("src/lib/gc_async_mut/gpu/engine2d/draw_ir_adv.spl")

fn windows_platform_source() -> text:
    file_read_text("src/runtime/platform/platform_win.h")

fn windows_native_linker_source() -> text:
    file_read_text("src/compiler/70.backend/linker/_LinkerWrapper/native_linking.spl")

fn windows_shared_linker_source() -> text:
    file_read_text("src/compiler/70.backend/linker/_LinkerWrapper/shared_linking.spl")

fn run_host_gpu_wrapper_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-simpleos-qemu-host-gpu-2d.shs", "--self-test"])
    expect(code).to_equal(0)
    out

fn run_host_gpu_metrics_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-simpleos-qemu-host-gpu-2d.shs", "--self-test-metrics"])
    expect(code).to_equal(0)
    out

describe "SimpleOS QEMU host-GPU rendering and processing":
    # @capture(protocol)
    # @capture(log)
    it "negotiates one bounded protocol on x86_64 AArch64 and RISC-V":
        step("Reject an unusable compiler candidate")
        step("Probe the QEMU guest GPU capability")
        step("Validate version limits backend sets readback and readiness")
        val source = host_gpu_wrapper_source()
        val runner = qemu_runner_build_source()
        val process_ops = process_ops_source()
        val probe = host_gpu_probe_source()
        expect(source).to_contain("simpleos-host-gpu-x86_64")
        expect(source).to_contain("simpleos-host-gpu-aarch64")
        expect(source).to_contain("simpleos-host-gpu-riscv64")
        expect(source).to_contain("EXPECTED_RENDER_MASK")
        expect(source).to_contain("EXPECTED_PROCESSING_MASK")
        expect(source).to_contain("simple_binary_is_valid")
        expect(source).to_contain("bootstrap seed only")
        expect(source).to_contain("--mode definitely-invalid-mode")
        expect(source).to_contain("Error: invalid --mode 'definitely-invalid-mode' (expected dynload or one-binary)")
        expect(source).to_contain("COMPILER_PROBE_TIMEOUT_SECONDS=5")
        expect(source).to_contain("COMPILER_CHECK_TIMEOUT_SECONDS=10")
        expect(source).to_contain("COMPILER_CHECK_KILL_GRACE_SECONDS=1")
        expect(source).to_contain("version=$(\"$timeout_bin\" -k \"${COMPILER_CHECK_KILL_GRACE_SECONDS}s\" \\\n        \"${COMPILER_PROBE_TIMEOUT_SECONDS}s\" \"$candidate\" --version")
        expect(source).to_contain("SIMPLE_LIB=\"$ROOT_DIR/src\" \"$timeout_bin\" \\\n        -k \"${COMPILER_CHECK_KILL_GRACE_SECONDS}s\" \\\n        \"${COMPILER_CHECK_TIMEOUT_SECONDS}s\" \"$candidate\" check")
        expect(source).to_contain("probe=$(\"$timeout_bin\" -k \"${COMPILER_CHECK_KILL_GRACE_SECONDS}s\" \\\n        \"${COMPILER_PROBE_TIMEOUT_SECONDS}s\" \"$candidate\" native-build")
        expect(source).to_contain("test/05_perf/io_parity/startup_simple.spl >/dev/null 2>&1 || return 1")
        expect(source).to_contain("frontend_hanging_simple")
        expect(runner).to_contain("[\"check\", \"test/05_perf/io_parity/startup_simple.spl\"],\n        10000")
        expect(runner).to_contain("frontend_exit_code == 0")
        expect(process_ops).to_contain("\"-k\", \"{PROCESS_TIMEOUT_KILL_GRACE_SECONDS}s\"")
        expect(probe).to_contain("render_backend = \"metal\"")
        expect(probe).to_contain("render_backend = \"directx\"")
        expect(probe).to_contain("render_backend = \"vulkan\"")
        expect(probe).to_contain("(hello.processing_mask & processing_mask) == hello.processing_mask")
        expect(probe.contains("(hello.processing_mask & render_mask) != 0")).to_equal(false)
        expect(probe).to_contain("SIMPLEOS_HOST_GPU_BACKEND_MASK_CUDA) != 0: \"cuda\"")
        expect(probe).to_contain("SIMPLEOS_HOST_GPU_BACKEND_MASK_VULKAN) != 0: \"vulkan\"")
        expect(source).to_contain("BACKEND=directx")
        expect(source).to_contain("EXPECTED_PROCESSING_MASK='(1|8|9)'")
        expect(windows_platform_source()).to_contain("DWORD share = FILE_SHARE_READ | FILE_SHARE_WRITE;")
        expect(windows_native_linker_source()).to_contain("\"d3d11.lib\", \"dxgi.lib\"")
        expect(windows_shared_linker_source()).to_contain("\"d3d11\", \"dxgi\"")

    # @capture(artifact)
    it "returns an exact device-backed Simple 2D readback":
        step("Submit the canonical full-frame IMAGE composition through the shared guest bridge")
        step("Compare Draw IR readback and correlated device receipt across all three ISAs")
        val source = host_gpu_wrapper_source()
        val probe = host_gpu_probe_source()
        expect(probe).to_contain("host_gpu_ivshmem_submit_draw_ir")
        expect(draw_ir_executor_source()).to_contain("val apply_clip = embedding.clip and not fills_target_exactly")
        expect(probe).to_contain("host_gpu_ivshmem_device_receipt_valid(render_receipt")
        expect(probe).to_contain("host_gpu_ivshmem_device_receipt_valid(draw_ir_receipt")
        expect(probe).to_contain("host_gpu_ivshmem_device_receipt_valid(processing_receipt")
        expect(probe.contains("_host_gpu_device_receipt_ok")).to_equal(false)
        expect(probe.contains("mmio_read64")).to_equal(false)
        val bridge = host_gpu_guest_bridge_source()
        val protocol = host_gpu_protocol_source()
        expect(protocol).to_contain("run_id_hash > 0 and frame_id > 0")
        expect(bridge).to_contain("simpleos_host_gpu_wire_correlation_valid(expected_run_id_hash, expected_frame_id)")
        expect(host_gpu_daemon_source()).to_contain("if not simpleos_host_gpu_wire_correlation_valid(run_id_hash, frame_id):")
        expect(bridge).to_contain("receipt.completed and receipt.generation == expected_generation")
        expect(bridge).to_contain("receipt.status == SIMPLEOS_HOST_GPU_STATUS_PASS and receipt.reason == 0")
        expect(bridge).to_contain("receipt.native_handle > 0 and receipt.device_identity > 0 and receipt.output_addr > 0u64")
        expect(bridge).to_contain("receipt.output_bytes == expected_bytes and receipt.output_checksum > 0 and receipt.elapsed_us > 0")
        expect(bridge).to_contain("receipt.readback_source == SIMPLEOS_HOST_GPU_READBACK_DEVICE")
        expect(bridge).to_contain("receipt.run_id_hash == expected_run_id_hash and receipt.frame_id == expected_frame_id")
        expect(bridge).to_contain("receipt.backend_code == expected_backend")
        expect(source).to_contain("checksum=405589360 bg=2112 rect=960 other=0")
        expect(source).to_contain("HOST_GPU_DRAW_IR_OK")
        expect(source).to_contain("checksum=405589360 bg=2112 image=960 other=0")
        expect(source).to_contain("handle=[1-9][0-9]* identity=[1-9][0-9]*")

    # @capture(log)
    it "proves one correlated AArch64 production desktop frame":
        step("Prove the AArch64 production desktop frame")
        val source = host_gpu_wrapper_source()
        val production = production_wm_executor_source()
        val validate = production.index_of("if not host_gpu_ivshmem_device_receipt_valid(receipt")
        val present = production.index_of("if not self.framebuffer.present_argb32_from_mmio(receipt.output_addr")
        val marker = production.index_of("serial_println(\"[wm-frame] host-gpu-presented")
        expect(validate).to_be_greater_than(0)
        expect(validate).to_be_less_than(present)
        expect(present).to_be_less_than(marker)
        expect(source).to_contain("arm64_production_serial_has_correlated_frame")
        expect(source).to_contain("arm64_production_evidence_valid")
        expect(source).to_contain("encoded_argv_field \"$probe_args\" 13")
        expect(source).to_contain("[ \"$isa\" != aarch64 ] || grep -Fq ramfb")
        expect(source).to_contain("daemon_pid=\nrss_monitor_pid=\ntrap 'cleanup_active_guest' EXIT")
        expect(source).to_contain("GUEST_BUILD_REASON=guest-artifact-missing")
        expect(source).to_contain("trap 'cleanup_active_guest' EXIT")
        expect(source).to_contain("arm64-desktop-engine2d")
        expect(source).to_contain("simpleos_arm64_desktop_engine2d.elf")
        expect(source).to_contain("qemu_argv_evidence_valid \"$report_isa\" \"$row_production_qemu_device_args\" production")
        expect(source).to_contain("_production_serial_log")
        expect(source).to_contain("_production_qemu_device_args")
        expect(source).to_contain("[wm-frame] host-gpu-presented")
        expect(source).to_contain("[ \"$presented_generation\" -eq \"$((ready_generation + 1))\" ]")
        expect(source).to_contain("[ \"$presented_run\" -eq \"$ready_generation\" ]")
        expect(source).to_contain("[ \"$presented_frame\" -eq \"$presented_generation\" ]")

    # @capture(protocol)
    it "requires checked raw native backend completion before a device receipt":
        step("Dispatch the raw CLEAR and solid RECT fixture through strict Engine2D selection")
        step("Reject unchecked or fallback raw rendering before device-backed receipt")
        val helpers = vulkan_backend_helpers_source()
        val owner = vulkan_sffi_owner_source()
        val backend = vulkan_backend_source()
        expect(helpers).to_contain("fn vulkan_dispatch_framebuffer_compute_checked")
        expect(helpers).to_contain("vulkan_sffi_dispatch_buffer_compute_checked")
        expect(owner).to_contain("fn vulkan_sffi_dispatch_buffer_compute_checked")
        expect(owner).to_contain("vulkan_sffi_submit_and_wait_fence(cmd)")
        expect(helpers.contains("fn vulkan_dispatch_compute(")).to_equal(false)
        expect(helpers).to_contain("if dispatched > 0:")
        expect(helpers).to_contain("if dispatched < 0:")
        expect(helpers).to_contain("elif self.initialized and self.d_framebuffer > 0:")
        expect(helpers).to_contain("me _dispatch_framebuffer_checked")
        expect(backend).to_contain("self._dispatch_framebuffer_checked")
        expect(backend.contains("vulkan_dispatch_compute(")).to_equal(false)
        val daemon = host_gpu_daemon_source()
        expect(daemon).to_contain("Engine2D.create_requested_backend(width.to_i32(), height.to_i32(), backend)")
        expect(daemon).to_contain("engine.backend_name() != backend")

    # @capture(protocol)
    it "admits only strict native Metal Draw IR with stable device identity":
        val daemon = host_gpu_daemon_source()
        expect(daemon).to_contain("Engine2D.create_requested_backend(1, 1, name)")
        expect(daemon).to_contain("engine.backend_name() == name")
        expect(daemon).to_contain("metal_device_info(0)")
        expect(daemon).to_contain("processing_metal_device_identity(info.name, info.total_memory)")
        expect(daemon).to_contain("directx_hardware_adapter_identity()")
        expect(daemon).to_contain("if backend == \"directx\": result.device_identity")
        expect(daemon).to_contain("if backend == \"directx\": readback.device_identity")
        expect(daemon).to_contain("backend != \"vulkan\" and backend != \"metal\" and backend != \"directx\"")
        expect(host_gpu_wrapper_source()).to_contain("[ \"$render_identity\" = \"$draw_ir_identity\" ]")
        expect(daemon.contains("backend != \"vulkan\" and kind == SIMPLEOS_HOST_GPU_KIND_DRAW_IR")).to_equal(false)

    # @capture(artifact)
    it "returns an exact device-backed ProcessingIR result":
        step("Run the ProcessingIR parity fixture")
        step("Compare the result buffer and correlated completion with the CPU oracle")
        val source = host_gpu_wrapper_source()
        val vulkan = vulkan_processing_source()
        val unknown = vulkan.index_of("if dispatch_status < 0:")
        val cleanup = vulkan.index_of("# Known-safe dispatch statuses may release their dependent resources.")
        expect(source).to_contain("checksum=1792 mismatches=0")
        expect(source).to_contain("PROCESSING_BACKEND")
        expect(vulkan).to_contain("vulkan_sffi_dispatch_buffer_compute_checked")
        expect(vulkan).to_contain("if dispatch_status == 1: vulkan_sffi_read_buffer_bytes")
        expect(vulkan).to_contain("vulkan-dispatch-completion-unknown")
        expect(unknown).to_be_greater_than(0)
        expect(unknown).to_be_less_than(cleanup)
        expect(vulkan.contains("vulkan_submit_and_wait(command)")).to_equal(false)
        expect(vulkan.contains("vulkan_begin_compute()")).to_equal(false)
        expect(cuda_processing_source()).to_contain("cuda_device_identity(device_handle)")
        expect(cuda_processing_source()).to_contain("if identity <= 0:")
        expect(host_gpu_daemon_source()).to_contain("if not completed or backend_handle <= 0 or device_identity <= 0:")
        expect(cuda_readback_wrapper_source()).to_contain("cuda_generated_2d_readback_device_identity")
        expect(cuda_readback_wrapper_source()).to_contain("cuDeviceGetUuid_v2")
        expect(run_cuda_readback_wrapper_self_test()).to_contain("cuda-submit-readback-identity-checksum-gate")
        expect(run_generated_2d_matrix_self_test()).to_contain("submit-readback-checksum-proof-fails-closed")
        expect(run_host_gpu_wrapper_self_test()).to_contain("simpleos_qemu_host_gpu_2d_self_test=pass")

    # @capture(protocol)
    it "keeps native Metal ProcessingIR separate from Engine2D rendering":
        val daemon = host_gpu_daemon_source()
        val metal = metal_processing_source()
        expect(daemon).to_contain("processing_ir_execute_metal")
        expect(daemon).to_contain("SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL")
        expect(daemon).to_contain("processing_ir_outputs_equal(probe.values, processing_ir_cpu_execute(probe_ir))")
        expect(daemon).to_contain("SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_PROCESSING_MASK, negotiated_processing_mask")
        expect(metal).to_contain("metal_sffi_run_compute_frame")
        expect(metal).to_contain("metal_buffer_download_ptr")
        expect(metal.contains("MetalSession")).to_equal(false)
        expect(metal.contains("Engine2D")).to_equal(false)

    # @manual: folded
    it "keeps the guest bootable when acceleration is unavailable":
        step("Disable the host service or requested backend")
        step("Select the existing software or CPU fallback with a stable reason")
        step("Select host presentation or the existing local production renderer")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("runtime-artifact-missing")
        expect(source).to_contain("qemu-host-gpu-capability-missing")
        val production = production_wm_executor_source()
        expect(production).to_contain("host_gpu_ivshmem_submit_draw_ir")
        expect(production).to_contain("host_gpu_ivshmem_device_receipt_valid")
        expect(production).to_contain("self.framebuffer.present_argb32_from_mmio")
        expect(production).to_contain("engine2d_draw_ir_adv_composition_present_with_images")

    # @manual: folded
    it "rejects malformed duplicate and stale protocol traffic":
        step("Submit unknown oversized out-of-range duplicate and stale requests")
        step("Require every invalid case to fail before device execution")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("handle=0 identity=0")
        expect(source).to_contain("if serial_has_pass")

    # @capture(log)
    it "publishes honest cross-host and cross-ISA evidence rows":
        step("Report device-backed host acceleration evidence")
        step("Validate cached rows before aggregation")
        step("Reject flags screenshots scanout CPU mirrors and synthetic handles")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_rows=3")
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_passed=")
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_blocked=")
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_failed=")
        expect(source).to_contain("--validate-report")
        expect(source).to_contain("validate_report")
        expect(source).to_contain("serial_has_pass \"$row_log\" \"$report_isa\"")
        expect(source).to_contain("_qemu_version=$3")
        expect(source).to_contain("_qemu_device_args=$4")
        expect(source).to_contain("_daemon_max_rss_kib=$5")
        expect(source).to_contain("_qemu_max_rss_kib=$6")
        expect(source).to_contain("_combined_max_rss_kib=$7")
        expect(source).to_contain("encode_argv_hex")
        expect(source).to_contain("encoded_argv_valid")
        expect(source).to_contain("qemu_argv_evidence_valid \"$report_isa\" \"$row_qemu_device_args\"")
        expect(source).to_contain("qemu_argv_evidence_valid \"$isa\" \"$qemu_device_args\"")
        expect(source).to_contain("memory-backend-file,id=hostgpu,share=on,mem-path=")
        expect(source).to_contain("ivshmem-plain,memdev=hostgpu")
        expect(source).to_contain("monitor_guest_max_rss")
        expect(source).to_contain("QEMU_KILL_GRACE_SECONDS=${SIMPLEOS_HOST_GPU_QEMU_KILL_GRACE_SECONDS:-2}")
        expect(source).to_contain("\"$TIMEOUT_BIN\" -k \"${QEMU_KILL_GRACE_SECONDS}s\"")
        expect(source).to_contain("printf \"%s\\n\" \"$$\" >\"$qemu_pid_file\"; exec \"$@\"")
        expect(source).to_contain("sampled_combined_rss_kib=$((sampled_daemon_rss_kib + sampled_qemu_rss_kib))")
        expect(source).to_contain("row_rss_evidence_valid \"$row_daemon_rss\" \"$row_qemu_rss\" \"$row_combined_rss\"")
        expect(run_host_gpu_metrics_self_test()).to_contain("simpleos_qemu_host_gpu_2d_metrics_self_test=pass")
        val probe = host_gpu_probe_source()
        expect(probe).to_contain("hello.elapsed_us > 0")
        expect(probe).to_contain("protocol={hello.version} elapsed_us={hello.elapsed_us}")
        expect(probe).to_contain("run={render_receipt.run_id_hash} frame={render_receipt.frame_id}")
        expect(probe).to_contain("run={draw_ir_receipt.run_id_hash} frame={draw_ir_receipt.frame_id}")
        expect(probe).to_contain("run={processing_receipt.run_id_hash} frame={processing_receipt.frame_id}")
        val time_ops = time_ops_source()
        expect(time_ops).to_contain("extern fn rt_time_now_nanos() -> i64")
        expect(time_ops).to_contain("fn time_now_nanos() -> i64:")
        expect(time_ops).to_contain("rt_time_now_nanos()")
