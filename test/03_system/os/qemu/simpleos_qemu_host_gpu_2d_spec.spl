# codex-system-test
# @req REQ-001 REQ-002 REQ-003 REQ-004 REQ-005 REQ-006 REQ-007 REQ-008 REQ-009 REQ-010 REQ-011 REQ-012
# @evidence-display: links
"""# SimpleOS QEMU Host-GPU 2D

Proves that each supported guest uses one bounded protocol to execute Draw IR
and ProcessingIR on a real host device, while unsupported rows fall back
honestly and malformed evidence fails closed.
"""

use std.spec.*
use std.io_runtime.{process_run}
use app.io.mod.{file_read_text}

fn host_gpu_wrapper_source() -> text:
    file_read_text("scripts/check/check-simpleos-qemu-host-gpu-2d.shs")

fn host_gpu_probe_source() -> text:
    file_read_text("examples/09_embedded/simple_os/arch/common/host_gpu_ivshmem_probe_entry.spl")

fn host_gpu_guest_bridge_source() -> text:
    file_read_text("src/os/lib/gpu_bridge/host_gpu_ivshmem.spl")

fn production_wm_executor_source() -> text:
    file_read_text("src/os/compositor/engine2d_wm_frame_executor.spl")

fn vulkan_backend_source() -> text:
    file_read_text("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl")

fn vulkan_backend_helpers_source() -> text:
    file_read_text("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_helpers.spl")

fn host_gpu_daemon_source() -> text:
    file_read_text("src/app/simpleos_gpu_host/main.spl")

fn metal_processing_source() -> text:
    file_read_text("src/lib/gc_async_mut/processing/metal_fill_u32.spl")

fn run_host_gpu_wrapper_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-simpleos-qemu-host-gpu-2d.shs", "--self-test"])
    expect(code).to_equal(0)
    out

describe "SimpleOS QEMU host-GPU rendering and processing":
    # @capture(protocol)
    # @capture(log)
    it "negotiates one bounded protocol on x86_64 AArch64 and RISC-V":
        step("Probe the QEMU guest GPU capability")
        step("Validate version limits backend sets readback and readiness")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("simpleos-host-gpu-x86_64")
        expect(source).to_contain("simpleos-host-gpu-aarch64")
        expect(source).to_contain("simpleos-host-gpu-riscv64")
        expect(source).to_contain("render_mask=1 processing_mask=9")

    # @capture(artifact)
    it "returns an exact device-backed Simple 2D readback":
        step("Submit the canonical full-frame IMAGE composition through the shared guest bridge")
        step("Compare Draw IR readback and correlated device receipt across all three ISAs")
        val source = host_gpu_wrapper_source()
        val probe = host_gpu_probe_source()
        expect(probe).to_contain("host_gpu_ivshmem_submit_draw_ir")
        expect(probe).to_contain("host_gpu_ivshmem_device_receipt_valid(render_receipt")
        expect(probe).to_contain("host_gpu_ivshmem_device_receipt_valid(draw_ir_receipt")
        expect(probe).to_contain("host_gpu_ivshmem_device_receipt_valid(processing_receipt")
        expect(probe.contains("_host_gpu_device_receipt_ok")).to_equal(false)
        expect(probe.contains("mmio_read64")).to_equal(false)
        val bridge = host_gpu_guest_bridge_source()
        expect(bridge).to_contain("receipt.completed and receipt.generation == expected_generation")
        expect(bridge).to_contain("receipt.status == SIMPLEOS_HOST_GPU_STATUS_PASS and receipt.reason == 0")
        expect(bridge).to_contain("receipt.native_handle > 0 and receipt.device_identity > 0 and receipt.output_addr > 0u64")
        expect(bridge).to_contain("receipt.output_bytes == expected_bytes and receipt.output_checksum > 0 and receipt.elapsed_us > 0")
        expect(bridge).to_contain("receipt.readback_source == SIMPLEOS_HOST_GPU_READBACK_DEVICE")
        expect(bridge).to_contain("receipt.run_id_hash == expected_run_id_hash and receipt.frame_id == expected_frame_id")
        expect(bridge).to_contain("receipt.backend_code == expected_backend")
        expect(source).to_contain("checksum=405589360 bg=2112 rect=960 other=0")
        expect(source).to_contain("HOST_GPU_DRAW_IR_OK")
        expect(source).to_contain("checksum=405589360 bg=2112 image=960 other=0")
        expect(source).to_contain("handle=[1-9][0-9]* identity=[1-9][0-9]*")

    # @capture(protocol)
    it "requires checked raw Vulkan completion before a device receipt":
        step("Dispatch the raw CLEAR and solid RECT fixture through checked Vulkan commands")
        step("Reject unchecked or fallback raw rendering before device-backed receipt")
        val helpers = vulkan_backend_helpers_source()
        val backend = vulkan_backend_source()
        expect(helpers).to_contain("fn vulkan_dispatch_framebuffer_compute_checked")
        expect(helpers).to_contain("vulkan_sffi_submit_and_wait_fence(cmd)")
        expect(helpers.contains("fn vulkan_dispatch_compute(")).to_equal(false)
        expect(helpers).to_contain("if dispatched > 0:")
        expect(helpers).to_contain("if dispatched < 0:")
        expect(helpers).to_contain("elif self.initialized and self.d_framebuffer > 0:")
        expect(helpers).to_contain("me _dispatch_framebuffer_checked")
        expect(backend).to_contain("self._dispatch_framebuffer_checked")
        expect(backend.contains("vulkan_dispatch_compute(")).to_equal(false)

    # @capture(protocol)
    it "admits only strict native Metal Draw IR with stable device identity":
        val daemon = host_gpu_daemon_source()
        expect(daemon).to_contain("Engine2D.create_requested_backend(1, 1, name)")
        expect(daemon).to_contain("engine.backend_name() == name")
        expect(daemon).to_contain("metal_device_info(0)")
        expect(daemon).to_contain("processing_metal_device_identity(info.name, info.total_memory)")
        expect(daemon).to_contain("kind == SIMPLEOS_HOST_GPU_KIND_RENDER and backend != \"vulkan\"")
        expect(daemon.contains("backend != \"vulkan\" and kind == SIMPLEOS_HOST_GPU_KIND_DRAW_IR")).to_equal(false)

    # @capture(artifact)
    it "returns an exact device-backed ProcessingIR result":
        step("Run the ProcessingIR parity fixture")
        step("Compare the result buffer and correlated completion with the CPU oracle")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("checksum=1792 mismatches=0")
        expect(source).to_contain("cuda-preferred-vulkan-fallback")
        expect(run_host_gpu_wrapper_self_test()).to_contain("simpleos_qemu_host_gpu_2d_self_test=pass")

    # @capture(protocol)
    it "keeps native Metal ProcessingIR separate from Engine2D rendering":
        val daemon = host_gpu_daemon_source()
        val metal = metal_processing_source()
        expect(daemon).to_contain("processing_ir_execute_metal")
        expect(daemon).to_contain("SIMPLEOS_HOST_GPU_BACKEND_MASK_METAL")
        expect(daemon).to_contain("processing_ir_outputs_equal(probe.values, processing_ir_cpu_execute(probe_ir))")
        expect(daemon).to_contain("SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_PROCESSING_MASK, negotiated_processing_mask")
        expect(metal).to_contain("metal_sffi_run_compute_frame")
        expect(metal).to_contain("metal_buffer_download_ptr")
        expect(metal.contains("MetalSession")).to_equal(false)
        expect(metal.contains("Engine2D")).to_equal(false)

    # @manual: folded
    it "keeps the guest bootable when acceleration is unavailable":
        step("Disable the host service or requested backend")
        step("Select the existing software or CPU fallback with a stable reason")
        step("Select host presentation or the existing local production renderer")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("vulkan-cuda-runtime-artifact-missing")
        expect(source).to_contain("host-daemon-backend-not-implemented")
        val production = production_wm_executor_source()
        expect(production).to_contain("host_gpu_ivshmem_submit_draw_ir")
        expect(production).to_contain("host_gpu_ivshmem_device_receipt_valid")
        expect(production).to_contain("self.framebuffer.present_argb32_from_mmio")
        expect(production).to_contain("engine2d_draw_ir_adv_composition_present_with_images")

    # @manual: folded
    it "rejects malformed duplicate and stale protocol traffic":
        step("Submit unknown oversized out-of-range duplicate and stale requests")
        step("Require every invalid case to fail before device execution")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("handle=0 identity=0")
        expect(source).to_contain("if serial_has_pass")

    # @capture(log)
    it "publishes honest cross-host and cross-ISA evidence rows":
        step("Report device-backed host acceleration evidence")
        step("Validate cached rows before aggregation")
        step("Reject flags screenshots scanout CPU mirrors and synthetic handles")
        val source = host_gpu_wrapper_source()
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_rows=3")
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_passed=")
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_blocked=")
        expect(source).to_contain("simpleos_qemu_host_gpu_2d_failed=")
        expect(source).to_contain("--validate-report")
        expect(source).to_contain("validate_report")
        expect(source).to_contain("serial_has_pass \"$row_log\" \"$report_isa\"")
