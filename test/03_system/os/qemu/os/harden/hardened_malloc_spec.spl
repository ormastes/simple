"""
QEMU System Test — Harden Hardened-Malloc Guard (AC-2).

**Feature IDs:** #SIMPLEOS-HARDEN-AC2
**Category:** OS system test

Boots the SimpleOS x86_64 harden probe under QEMU and validates that the
hardened allocator traps guard-page overflows and double-free attempts.
Kernel: build/os/simpleos_x86_64_harden_probe.elf
Image:  build/os/fat32-x86_64-harden.img

A missing kernel is a diagnosed RED failure. Never uses skip().
"""
use std.spec.*
use os.qemu_systest_contract.{
    run_qemu_systest,
    harden_kernel_path,
    harden_image_path,
    harden_qemu_bin,
    harden_qemu_args,
    harden_malloc_markers,
    harden_timeout_ms,
    SYSTEST_PASS
}

extern fn rt_file_exists(path: text) -> bool

describe "qemu system test — harden hardened-malloc guard (AC-2)":

    it "harden kernel and image are present (media check)":
        val kernel_present = rt_file_exists(harden_kernel_path())
        if not kernel_present:
            print "[harden_malloc] MISSING KERNEL: " + harden_kernel_path()
        expect(kernel_present).to_equal(true)
        val image_present = rt_file_exists(harden_image_path())
        if not image_present:
            print "[harden_malloc] MISSING IMAGE: " + harden_image_path()
        expect(image_present).to_equal(true)

    it "harden probe boots and hardened-malloc guard markers appear in serial":
        val classification = run_qemu_systest(
            "harden_malloc",
            harden_kernel_path(),
            harden_image_path(),
            harden_qemu_bin(),
            harden_qemu_args(),
            harden_malloc_markers(),
            harden_timeout_ms()
        )
        if classification != SYSTEST_PASS:
            print "[harden_malloc] FAILED: " + classification
        expect(classification).to_equal(SYSTEST_PASS)
