"""
QEMU System Test — Harden PIE/SSP/RELRO Preset (AC-8/9/10).

**Feature IDs:** #SIMPLEOS-HARDEN-AC8 #SIMPLEOS-HARDEN-AC9 #SIMPLEOS-HARDEN-AC10
**Category:** OS system test

Boots the SimpleOS x86_64 harden probe under QEMU and validates that the
hardening preset flags PIE, RELRO+BIND_NOW, NX/SMEP/SMAP, and stack canary
are all active on the running image.
Kernel: build/os/simpleos_x86_64_harden_probe.elf
Image:  build/os/fat32-x86_64-harden.img

A missing kernel is a diagnosed RED failure. Never uses skip().
"""
use std.spec.*
use os.qemu_systest_contract.{
    run_qemu_systest,
    harden_kernel_path,
    harden_image_path,
    harden_qemu_bin,
    harden_qemu_args,
    harden_pie_relro_markers,
    harden_timeout_ms,
    SYSTEST_PASS
}

extern fn rt_file_exists(path: text) -> bool

describe "qemu system test — harden PIE/SSP/RELRO preset (AC-8/9/10)":

    it "harden kernel and image are present (media check)":
        val kernel_present = rt_file_exists(harden_kernel_path())
        if not kernel_present:
            print "[harden_pie_relro] MISSING KERNEL: " + harden_kernel_path()
        expect(kernel_present).to_equal(true)
        val image_present = rt_file_exists(harden_image_path())
        if not image_present:
            print "[harden_pie_relro] MISSING IMAGE: " + harden_image_path()
        expect(image_present).to_equal(true)

    it "harden probe boots and PIE/RELRO/NX/SSP markers appear in serial":
        val classification = run_qemu_systest(
            "harden_pie_relro",
            harden_kernel_path(),
            harden_image_path(),
            harden_qemu_bin(),
            harden_qemu_args(),
            harden_pie_relro_markers(),
            harden_timeout_ms()
        )
        if classification != SYSTEST_PASS:
            print "[harden_pie_relro] FAILED: " + classification
        expect(classification).to_equal(SYSTEST_PASS)
