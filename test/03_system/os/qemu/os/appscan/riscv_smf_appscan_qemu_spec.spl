# RISC-V SMF Appscan QEMU Tests
#
# Verifies the supported RISC-V filesystem/SMF launch lane, including catalog
# discovery, CLI app launch, WM GUI launch, and native GUI process rendering.
#
# @tag: os,qemu,appscan,riscv,smf

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 120000

var g_riscv32_output: text = ""
var g_riscv32_ran: bool = false
var g_riscv64_output: text = ""
var g_riscv64_ran: bool = false

fn _can_run(qemu_bin: text) -> bool:
    val qemu_check = rt_process_run_timeout("which", [qemu_bin], 5000)
    if qemu_check[2] != 0:
        print "SKIP: {qemu_bin} not found"
        return false
    true

fn _simple_bin() -> text:
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    "src/compiler_rust/target/debug/simple"

fn _run_riscv_appscan(arch: text) -> text:
    val result = rt_process_run_timeout(_simple_bin(), ["os", "test", "--arch={arch}"], TIMEOUT_MS)
    result[0] + result[1]

fn _riscv32_output() -> text:
    if not g_riscv32_ran:
        g_riscv32_output = _run_riscv_appscan("riscv32")
        g_riscv32_ran = true
    g_riscv32_output

fn _riscv64_output() -> text:
    if not g_riscv64_ran:
        g_riscv64_output = _run_riscv_appscan("riscv64")
        g_riscv64_ran = true
    g_riscv64_output

fn _assert_riscv_smf_appscan(output: text, arch: text):
    expect(output).to_contain("SMF_DISCOVERY_OK")
    expect(output).to_contain("ELF_LOAD_OK arch={arch} app=/sys/apps/hello_world.smf")
    expect(output).to_contain("SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf")
    expect(output).to_contain("SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf wm=manifest")
    expect(output).to_contain("NATIVE_GUI_PROCESS_RENDER_OK app=/sys/apps/browser_demo.smf")
    expect(output).to_contain("SIMPLEOS_RISCV_SMF_FS_PASS")
    expect(output).to_contain("TEST PASSED")

describe "RISC-V SMF appscan QEMU":
    slow_it "discovers and launches RV32 SMF apps through the supported filesystem lane":
        if _can_run("qemu-system-riscv32"):
            _assert_riscv_smf_appscan(_riscv32_output(), "riscv32")

    slow_it "discovers and launches RV64 SMF apps through the supported filesystem lane":
        if _can_run("qemu-system-riscv64"):
            _assert_riscv_smf_appscan(_riscv64_output(), "riscv64")
