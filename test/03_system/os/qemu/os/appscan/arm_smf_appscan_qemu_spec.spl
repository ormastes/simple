# ARM SMF Appscan QEMU Tests
#
# Verifies the supported ARM filesystem/SMF launch lanes. ARM64 exposes
# readable process-backed app markers; ARM32 currently uses trace markers plus
# the shared arm-fs-exec completion contract.
#
# @tag: os,qemu,appscan,arm,smf

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 180000

var g_arm32_output: text = ""
var g_arm32_ran: bool = false
var g_arm64_output: text = ""
var g_arm64_ran: bool = false

fn _can_run(qemu_bin: text) -> bool:
    val qemu_check = rt_process_run_timeout("which", [qemu_bin], 5000)
    if qemu_check[2] != 0:
        print "SKIP: {qemu_bin} not found"
        return false
    true

fn _simple_bin() -> text:
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    "src/compiler_rust/target/debug/simple"

fn _run_arm_appscan(arch: text) -> text:
    val result = rt_process_run_timeout(_simple_bin(), ["os", "test", "--arch={arch}"], TIMEOUT_MS)
    result[0] + result[1]

fn _arm32_output() -> text:
    if not g_arm32_ran:
        g_arm32_output = _run_arm_appscan("arm32")
        g_arm32_ran = true
    g_arm32_output

fn _arm64_output() -> text:
    if not g_arm64_ran:
        g_arm64_output = _run_arm_appscan("arm64")
        g_arm64_ran = true
    g_arm64_output

fn _assert_arm_common_smf_appscan(output: text):
    expect(output).to_contain("[arm-fs-exec] vfs:ok")
    expect(output).to_contain("[arm-fs-exec] smf:/sys/apps/hello_world.smf")
    expect(output).to_contain("TEST PASSED")

fn _assert_arm64_process_appscan(output: text):
    expect(output).to_contain("[desktop-e2e] process-backed:ok app=hello_world")
    expect(output).to_contain("[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_compiler")
    expect(output).to_contain("[desktop-e2e] process-backed:ok app=simple_compiler")
    expect(output).to_contain("[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_interpreter")
    expect(output).to_contain("[desktop-e2e] process-backed:ok app=simple_interpreter")
    expect(output).to_contain("[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_loader")
    expect(output).to_contain("[desktop-e2e] process-backed:ok app=simple_loader")
    expect(output).to_contain("[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/clang")
    expect(output).to_contain("[desktop-e2e] process-backed:ok app=clang")

fn _assert_arm32_trace_appscan(output: text):
    expect(output).to_contain("[arm-fs-trace] 201 0xc9")
    expect(output).to_contain("[arm-fs-trace] 214 0xd6")
    expect(output).to_contain("[arm-fs-trace] 218 0xda")
    expect(output).to_contain("[arm-fs-trace] 230 0xe6")
    expect(output).to_contain("[arm-fs-trace] 244 0xf4")
    expect(output).to_contain("[arm-fs-trace] 206 0xce")

describe "ARM SMF appscan QEMU":
    slow_it "discovers and launches ARM32 SMF apps through the supported filesystem lane":
        if _can_run("qemu-system-arm"):
            val output = _arm32_output()
            _assert_arm_common_smf_appscan(output)
            _assert_arm32_trace_appscan(output)

    slow_it "discovers and launches ARM64 SMF apps through the supported filesystem lane":
        if _can_run("qemu-system-aarch64"):
            val output = _arm64_output()
            _assert_arm_common_smf_appscan(output)
            _assert_arm64_process_appscan(output)
