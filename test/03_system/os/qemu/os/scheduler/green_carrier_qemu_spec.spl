**Design:** N/A

## Research

**Research:** doc/01_research/local/multicore_green.md

## Syntax

Run the fast cached/default lane:

```sh
bin/release/simple test test/03_system/os/qemu/os/scheduler/green_carrier_qemu_spec.spl --mode=interpreter
```

Run the live QEMU lane:

```sh
SIMPLEOS_GREEN_CARRIER_QEMU_LIVE=1 bin/release/simple test test/03_system/os/qemu/os/scheduler/green_carrier_qemu_spec.spl --mode=interpreter --clean
```

Run the future final hardware handoff lane after the AP ring/user proof markers
exist:

```sh
SIMPLEOS_GREEN_CARRIER_QEMU_HW_HANDOFF_LIVE=1 bin/release/simple test test/03_system/os/qemu/os/scheduler/green_carrier_qemu_spec.spl --mode=interpreter --clean
```

## Examples

The live serial output must include:

```text
[smp] AP reached 64-bit entry
[green-carrier-qemu] PASS=true
[green-carrier-qemu] PREEMPT_PASS=true
[green-carrier-qemu] SCHED_HANDOFF_PASS=true
[green-carrier-qemu] USER_HANDOFF_READY=true
```

The future final hardware handoff lane must additionally include all of:

```text
[green-carrier-qemu] HW_HANDOFF_PASS=true
[green-carrier-qemu] USER_ENTRY_PASS=true
[green-carrier-qemu] USER_SYSCALL_PASS=true
```
"""

use std.spec.*

extern fn rt_env_get(name: text) -> text?
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

val DEFAULT_SIMPLE_BIN: text = "bin/release/simple"
val BOOTSTRAP_SIMPLE_BIN: text = "src/compiler_rust/target/bootstrap/simple"
val LINKER_SCRIPT: text = "examples/09_embedded/simple_os/arch/x86_64/linker.ld"
val BUILD_SOURCES: text = "--source src/os --source src/lib --source examples/09_embedded/simple_os"
val ENTRY: text = "examples/09_embedded/simple_os/arch/x86_64/green_carrier_probe_entry.spl"
val QEMU_BASE: text =
    "qemu-system-x86_64 -machine q35 -cpu qemu64 -smp 2 -serial stdio -display none -no-reboot"
val DEBUG_EXIT: text = "-device isa-debug-exit,iobase=0xf4,iosize=0x04"
val AP_ONLINE_MARKER: text = "[smp] AP reached 64-bit entry"
val GREEN_PASS_MARKER: text = "[green-carrier-qemu] PASS=true"
val GREEN_PREEMPT_MARKER: text = "[green-carrier-qemu] PREEMPT_PASS=true"
val GREEN_SCHED_HANDOFF_MARKER: text = "[green-carrier-qemu] SCHED_HANDOFF_PASS=true"
val GREEN_USER_HANDOFF_READY_MARKER: text = "[green-carrier-qemu] USER_HANDOFF_READY=true"
val GREEN_HW_HANDOFF_MARKER: text = "[green-carrier-qemu] HW_HANDOFF_PASS=true"
val GREEN_USER_ENTRY_MARKER: text = "[green-carrier-qemu] USER_ENTRY_PASS=true"
val GREEN_USER_SYSCALL_MARKER: text = "[green-carrier-qemu] USER_SYSCALL_PASS=true"

fn _enabled() -> bool:
    (rt_env_get("SIMPLEOS_GREEN_CARRIER_QEMU_LIVE") ?? "") == "1"

fn _hw_handoff_enabled() -> bool:
    (rt_env_get("SIMPLEOS_GREEN_CARRIER_QEMU_HW_HANDOFF_LIVE") ?? "") == "1"

fn _run_shell(command: text) -> (text, text, i64):
    rt_process_run("/bin/sh", ["-c", command])

fn _qemu_available() -> bool:
    val result = _run_shell("command -v qemu-system-x86_64 >/dev/null 2>&1")
    result[2] == 0

fn _simple_bin() -> text:
    val override_bin = rt_env_get("SIMPLEOS_QEMU_SIMPLE_BIN") ?? ""
    if override_bin != "":
        override_bin
    elif rt_file_exists(BOOTSTRAP_SIMPLE_BIN):
        BOOTSTRAP_SIMPLE_BIN
    else:
        DEFAULT_SIMPLE_BIN

fn _build_probe(output: text, backend: text) -> bool:
    val command = "SIMPLE_BOOTSTRAP=1 SIMPLE_LIB=\"$(pwd)/src\" PATH=\"/usr/bin:$PATH\" {_simple_bin()} native-build {BUILD_SOURCES} --backend {backend} --entry-closure --entry {ENTRY} --target x86_64-unknown-none -o {output} --linker-script {LINKER_SCRIPT}"
    val result = _run_shell(command)
    if result[2] != 0:
        print "[green_carrier_qemu_spec] {backend} build failed exit={result[2]}"
        print result[0] + result[1]
        return false
    if not rt_file_exists(output):
        print "[green_carrier_qemu_spec] build output missing: {output}"
        return false
    true

fn _run_probe(kernel: text) -> (text, i64):
    val command = "timeout 20s {QEMU_BASE} -m 512M -kernel {kernel} {DEBUG_EXIT} 2>&1 | tr -d '\\000'"
    val result = _run_shell(command)
    (result[0] + result[1], result[2])

fn _has_required_markers(serial: text) -> bool:
    serial.contains(AP_ONLINE_MARKER) and serial.contains(GREEN_PASS_MARKER) and serial.contains(GREEN_PREEMPT_MARKER) and serial.contains(GREEN_SCHED_HANDOFF_MARKER) and serial.contains(GREEN_USER_HANDOFF_READY_MARKER)

fn _print_probe_debug(serial: text, qemu_exit: i64):
    val saw_boot = serial.contains("[green-carrier-qemu] boot")
    val saw_ap_marker = serial.contains(AP_ONLINE_MARKER)
    val saw_green_pass = serial.contains(GREEN_PASS_MARKER)
    val saw_green_preempt = serial.contains(GREEN_PREEMPT_MARKER)
    val saw_scheduler_handoff = serial.contains(GREEN_SCHED_HANDOFF_MARKER)
    val saw_user_handoff_ready = serial.contains(GREEN_USER_HANDOFF_READY_MARKER)
    val saw_hardware_handoff = serial.contains(GREEN_HW_HANDOFF_MARKER)
    val saw_user_entry = serial.contains(GREEN_USER_ENTRY_MARKER)
    val saw_user_syscall = serial.contains(GREEN_USER_SYSCALL_MARKER)
    print "[green_carrier_qemu_spec] qemu exit={qemu_exit}"
    print "[green_carrier_qemu_spec] saw boot={saw_boot}"
    print "[green_carrier_qemu_spec] saw ap-marker={saw_ap_marker}"
    print "[green_carrier_qemu_spec] saw green-pass={saw_green_pass}"
    print "[green_carrier_qemu_spec] saw green-preempt={saw_green_preempt}"
    print "[green_carrier_qemu_spec] saw scheduler-handoff={saw_scheduler_handoff}"
    print "[green_carrier_qemu_spec] saw user-handoff-ready={saw_user_handoff_ready}"
    print "[green_carrier_qemu_spec] saw hardware-handoff={saw_hardware_handoff}"
    print "[green_carrier_qemu_spec] saw user-entry={saw_user_entry}"
    print "[green_carrier_qemu_spec] saw user-syscall={saw_user_syscall}"
    print serial

describe "SimpleOS green carrier live QEMU proof":
    """Live green-carrier validation, disabled unless SIMPLEOS_GREEN_CARRIER_QEMU_LIVE=1."""

    it "boots two CPUs and dispatches green work through the scheduler-owned AP carrier":
        """When enabled, QEMU serial output must show AP startup plus fixed dispatch, preemption, scheduler handoff, and user handoff readiness PASS markers."""
        if not _enabled():
            step("Skip the live QEMU lane unless SIMPLEOS_GREEN_CARRIER_QEMU_LIVE is enabled")
            expect(_enabled()).to_equal(false)
        elif not _qemu_available():
            step("Skip live QEMU execution on hosts without qemu-system-x86_64")
            expect(_qemu_available()).to_equal(false)
        else:
            step("Build the SimpleOS green carrier guest probe")
            val output_path = "build/os/simpleos_green_carrier_probe.elf"
            val built = _build_probe(output_path, "cranelift") or _build_probe(output_path, "llvm")
            expect(built).to_equal(true)
            # @capture(tui)
            step("Boot the two-CPU guest probe under QEMU")
            val result = _run_probe(output_path)
            val serial = result[0]
            if not _has_required_markers(serial):
                _print_probe_debug(serial, result[1])
            # @capture(tui)
            step("Verify AP startup and all green carrier proof markers")
            expect(serial.contains(AP_ONLINE_MARKER)).to_equal(true)
            expect(serial.contains(GREEN_PASS_MARKER)).to_equal(true)
            expect(serial.contains(GREEN_PREEMPT_MARKER)).to_equal(true)
            expect(serial.contains(GREEN_SCHED_HANDOFF_MARKER)).to_equal(true)
            expect(serial.contains(GREEN_USER_HANDOFF_READY_MARKER)).to_equal(true)

    it "keeps final hardware handoff proof behind separate opt-in markers":
        """The final AP ring/user handoff markers are intentionally separate from SCHED_HANDOFF_PASS."""
        if not _hw_handoff_enabled():
            step("Skip the final hardware handoff lane unless its explicit live gate is enabled")
            expect(_hw_handoff_enabled()).to_equal(false)
        elif not _qemu_available():
            step("Skip final hardware handoff execution on hosts without qemu-system-x86_64")
            expect(_qemu_available()).to_equal(false)
        else:
            step("Build the SimpleOS green carrier guest probe for final handoff evidence")
            val output_path = "build/os/simpleos_green_carrier_probe.elf"
            val built = _build_probe(output_path, "cranelift") or _build_probe(output_path, "llvm")
            expect(built).to_equal(true)
            # @capture(tui)
            step("Boot the two-CPU guest probe under QEMU")
            val result = _run_probe(output_path)
            val serial = result[0]
            if not serial.contains(GREEN_HW_HANDOFF_MARKER) or not serial.contains(GREEN_USER_ENTRY_MARKER) or not serial.contains(GREEN_USER_SYSCALL_MARKER):
                _print_probe_debug(serial, result[1])
            # @capture(tui)
            step("Verify AP startup, scheduler handoff, final hardware handoff, user entry, and syscall markers")
            expect(serial).to_contain(AP_ONLINE_MARKER)
            expect(serial).to_contain(GREEN_SCHED_HANDOFF_MARKER)
            expect(serial).to_contain(GREEN_HW_HANDOFF_MARKER)
            expect(serial).to_contain(GREEN_USER_ENTRY_MARKER)
            expect(serial).to_contain(GREEN_USER_SYSCALL_MARKER)
