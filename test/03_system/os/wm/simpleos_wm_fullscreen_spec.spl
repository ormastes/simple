# codex-system-test
# @req REQ-2 REQ-3 REQ-4 REQ-5 REQ-6 REQ-7 REQ-8 NFR-4 NFR-6 NFR-7
# @evidence-display: links
"""# SimpleOS WM Fullscreen

Boots the production pure-Simple SimpleOS desktop in QEMU at its detected
scanout size, drives the emulated input device and guest IRQ path, and captures
the live desktop before maximize, while maximized, and after restore. Evidence
must correlate input, compositor, render, scanout, and capture generations.

This spec deliberately fails closed until its runtime helpers are backed by
the production QEMU wrapper. The wrapper must derive QMP capture address and
size from the guest `[scanout-evidence]` marker, respect its byte pitch, inject
an action through QEMU hardware input, and map each host action nonce to a new
guest-owned monotonic `input_seq`. The same sequence must appear in guest IRQ,
WM-state, and framebuffer-generation acknowledgements. Source
inspection, automatic boot choreography, demo markers, direct shell actions,
fixed framebuffer metadata, and fabricated captures cannot pass.
"""
use std.spec.*

# @inline
fn boot_production_simpleos_desktop():
    step("Boot the production pure-Simple SimpleOS image in QEMU")
    step("Wait for the live desktop at the detected framebuffer scanout")

# @inline
fn drive_internal_window_maximize_restore():
    step("Submit maximize through the QEMU emulated input device")
    step("Observe the guest input IRQ driver and WM revision sequence")
    step("Submit restore through the QEMU emulated input device")

# @inline
fn validate_three_correlated_captures():
    step("Capture the baseline framebuffer through QMP")
    step("Capture the maximized framebuffer through QMP")
    step("Capture the restored framebuffer through QMP")
    step("Validate semantic pixels hashes metadata and backend provenance")

fn require_production_qemu_boot_and_dynamic_scanout():
    fail("runtime helper must boot the production pure-Simple SimpleOS entrypoint and prove the desktop fills detected nonzero scanout address width height stride pixel format and generation without fixed metadata or demo markers")

fn require_emulated_input_irq_revision_path():
    fail("runtime helper must inject keyboard or pointer input through QEMU input-send-event or send-key, map each host nonce to a newly observed guest monotonic input_seq above baseline, and require the same sequence in guest device IRQ acknowledgement WM action state revision and later framebuffer generation; automatic boot choreography and direct shell action calls are forbidden")

fn require_live_maximize_restore_state_preservation():
    fail("runtime helper must maximize and restore one live internal window and prove only its rect maximized flag and expected focus or z revisions change while every non-target window and taskbar field is preserved")

fn require_shared_render_and_content_provenance():
    fail("runtime helper must prove shared taskbar and top title command lane use SharedWmScene objects and backend-neutral Simple 2D while internal content comes from canonical Simple GUI and Simple Web artifacts with matching scene and content revisions")

fn require_three_verified_framebuffer_captures():
    fail("runtime helper must produce distinct baseline maximized and restored QMP framebuffer captures with semantic desktop titlebar window and taskbar pixels plus matching producer scanout frame revision timestamp dimensions stride format generation and cryptographic hashes")

fn require_fail_closed_qemu_lifecycle():
    fail("runtime helper must reject QEMU early exit boot timeout missing readiness input submission failure missing IRQ or driver acknowledgement and framebuffer generation timeout")

fn require_fail_closed_capture_contract():
    fail("runtime helper must reject missing partial corrupt blank stale duplicate unverified or wrong-process captures and any capture whose hash dimensions stride format generation revision or timestamp mismatches guest metadata")

fn require_fail_closed_scanout_metadata():
    fail("runtime helper must reject missing zero fixed default stale malformed overflowed or invalid framebuffer address visible dimensions byte stride pixel format generation and any QMP pmemsave address size or conversion mismatch; capture size must equal checked byte_stride times height")

fn require_qemu_input_latency_budget():
    fail("runtime helper must measure 30 emulated-device input submissions on the documented fixed idle QEMU configuration using a monotonic clock and require nearest-rank p95 submission-to-matching-framebuffer-generation latency at or below 500 ms")

fn require_performance_row_provenance():
    fail("runtime helper must record QEMU machine CPU RAM idle-load policy renderer backend fallback viewport revision executable hash and version readback checksum sample durations and nearest-rank p95 with no seed provenance or silent fallback")

describe "SimpleOS production WM fullscreen":
    # @capture(protocol)
    # @capture(gui)
    # @capture(artifact)
    it "should boot at detected full scanout and preserve live state across input-driven maximize and restore":
        step("Boot the production pure-Simple SimpleOS image in QEMU")
        step("Wait for the live desktop at the detected framebuffer scanout")
        step("Capture the baseline framebuffer through QMP")
        step("Submit maximize through the QEMU emulated input device")
        step("Observe the guest input IRQ driver and WM revision sequence")
        step("Capture the maximized framebuffer through QMP")
        step("Submit restore through the QEMU emulated input device")
        step("Capture the restored framebuffer through QMP")
        step("Validate semantic pixels hashes metadata and backend provenance")
        # @step: Verify production boot and dynamic detected scanout metadata
        require_production_qemu_boot_and_dynamic_scanout()
        # @step: Verify the emulated input device IRQ and correlated revision path
        require_emulated_input_irq_revision_path()
        # @step: Verify maximize and restore preserve every non-target state field
        require_live_maximize_restore_state_preservation()
        # @step: Verify shared taskbar top lane Simple GUI Web and 2D provenance
        require_shared_render_and_content_provenance()
        # @step: Verify all three framebuffer captures and their correlated hashes
        require_three_verified_framebuffer_captures()

    # @manual: folded
    # @capture(protocol)
    it "should reject early exit timeout or an uncorrelated emulated input path":
        boot_production_simpleos_desktop()
        step("Interrupt boot input delivery IRQ acknowledgement or frame production")
        require_fail_closed_qemu_lifecycle()
        require_emulated_input_irq_revision_path()

    # @manual: folded
    # @capture(protocol)
    # @capture(artifact)
    it "should reject invalid fixed stale or mismatched framebuffer metadata":
        boot_production_simpleos_desktop()
        step("Replace detected scanout metadata with invalid or mismatched values")
        step("Validate semantic pixels hashes metadata and backend provenance")
        require_fail_closed_scanout_metadata()

    # @manual: folded
    # @capture(gui)
    # @capture(artifact)
    it "should reject missing partial stale blank or unverifiable framebuffer captures":
        boot_production_simpleos_desktop()
        validate_three_correlated_captures()
        step("Remove or corrupt capture identity freshness metadata pixels or hash")
        require_fail_closed_capture_contract()

    # @manual: folded
    # @capture(protocol)
    it "should reject demo source-only seed or fabricated render provenance":
        boot_production_simpleos_desktop()
        step("Substitute demo markers fixed scenes source inspection seed execution or silent renderer fallback")
        step("Validate semantic pixels hashes metadata and backend provenance")
        require_shared_render_and_content_provenance()
        require_performance_row_provenance()

    # @manual: folded
    # @capture(protocol)
    # @capture(artifact)
    it "should keep emulated input to matching framebuffer generation at or below 500 milliseconds p95":
        boot_production_simpleos_desktop()
        step("Discard setup activity and submit 30 maximize restore input pairs at idle load")
        step("Correlate every input submission with its matching framebuffer generation")
        step("Calculate nearest-rank p95 from monotonic-clock durations")
        require_qemu_input_latency_budget()
        require_performance_row_provenance()
