"""Static ownership contract for device-backed SimpleOS IMAGE and TEXT execution."""

use std.io_runtime.{file_read}
use std.spec.*

describe "SimpleOS host GPU IMAGE and TEXT execution":
    it "admits resources only through the fresh-device Draw IR path with strict provenance":
        val daemon = file_read("src/app/simpleos_gpu_host/main.spl")
        val draw_ir = file_read("src/lib/gc_async_mut/gpu/engine2d/draw_ir_adv.spl")
        val font_renderer = file_read("src/lib/nogc_sync_mut/text_layout/font_renderer.spl")
        val font_owner = file_read("src/lib/nogc_sync_mut/sffi/spl_fonts.spl")
        expect(daemon).to_contain("engine2d_draw_ir_adv_fresh_device_composition_with_images")
        expect(daemon).to_contain("result.readback_source == \"device_readback\"")
        expect(daemon).to_contain("result.backend_handle > 0")
        expect(daemon.contains("if decoded_resources.resources.len() > 0")).to_equal(false)
        val fresh_start = draw_ir.index_of("fn engine2d_draw_ir_adv_fresh_device_composition_with_images") ?? 0
        val shared_start = draw_ir.index_of("fn _engine2d_draw_ir_adv_composition_with_images") ?? draw_ir.len()
        val fresh_body = draw_ir.slice(fresh_start, shared_start)
        expect(fresh_body).to_contain("_engine2d_draw_ir_fresh_device_reason")
        expect(fresh_body).to_contain("_engine2d_draw_ir_prepare_fresh_device_text")
        expect(fresh_body).to_contain("preflight_rejected")
        expect(fresh_body).to_contain("plan, 0, 1")
        val reason_pos = fresh_body.index_of("val reason") ?? fresh_body.len()
        val render_pos = fresh_body.index_of("_engine2d_draw_ir_adv_composition_with_images(prepared.0") ?? 0
        expect(reason_pos < render_pos).to_be(true)
        val exact_start = draw_ir.index_of("fn _engine2d_draw_ir_fresh_device_command_supported") ?? 0
        val generic_start = draw_ir.index_of("fn _engine2d_draw_ir_preflight_commands") ?? draw_ir.len()
        val exact_body = draw_ir.slice(exact_start, generic_start)
        expect(exact_body).to_contain("command.kind == DRAW_IR_COMMAND_RECT")
        expect(exact_body).to_contain("command.kind == DRAW_IR_COMMAND_TEXT")
        expect(exact_body).to_contain("font-advance-widths")
        expect(exact_body).to_contain("eng.select_font_identity(identity)")
        expect(exact_body).to_contain("fonts.prepare_text")
        expect(exact_body).to_contain("font_atlas_subrect_pixels")
        expect(exact_body).to_contain("val max_pixel_work = width.to_i64() * height.to_i64()")
        expect(exact_body).to_contain("fresh-device-font-work-limit-exceeded")
        expect(exact_body).to_contain("_engine2d_draw_ir_fresh_device_rect_style_supported")
        expect(draw_ir).to_contain("prop.key != \"source\"")
        expect(exact_body).to_contain("allow_clipped")
        expect(exact_body).to_contain("allow_translucent_initializer")
        expect(exact_body).to_contain("command.kind != DRAW_IR_COMMAND_IMAGE")
        expect(exact_body).to_contain("command.width == image.width")
        expect(exact_body).to_contain("_engine2d_draw_ir_image_is_opaque")
        expect(exact_body).to_contain("fresh-device-bounded-embedding-required")
        expect(exact_body).to_contain("fresh-device-embedded-surface-required")
        expect(exact_body).to_contain("fresh-device-opaque-full-target-first-command-required")
        expect(draw_ir).to_contain("eng.create_shared_vulkan_offscreen")
        expect(draw_ir).to_contain("child.source == \"device_readback\"")
        expect(draw_ir).to_contain("eng.draw_vulkan_image_blend_checked")
        expect(draw_ir).to_contain("offscreen.shutdown()")
        expect(draw_ir).to_contain("eng.draw_image_blend(x, y, image.width, image.height, image.pixels)")
        expect(font_renderer).to_contain("renderer.try_load_runtime_ttf(font_path)")
        expect(font_renderer).to_contain("FontRasterizer.load_selected(ttf_path)")
        expect(font_owner).to_contain("FontRasterizer.load_selected_bytes(ttf_path, file_read_bytes(ttf_path))")

    it "uses fenced tri-state cleanup and quarantines completion-unknown dependencies":
        val helper = file_read("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_helpers.spl")
        val backend = file_read("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl")
        expect(helper).to_contain("vulkan_sffi_submit_and_wait_fence(cmd)")
        expect(helper).to_contain("if fence < 0:")
        expect(helper).to_contain("if not vulkan_sffi_wait_idle():\n            return -1")
        expect(helper).to_contain("vulkan_sffi_discard_command(cmd)")
        expect(backend).to_contain("if self.completion_unknown: return")
        expect(backend).to_contain("if self.completion_unknown or not self.initialized")
        expect(backend).to_contain("return engine2d_readback([], \"completion_unknown\")")
        expect(backend).to_contain("if color_a(color) < 255:")
        expect(backend).to_contain("self.draw_image_blend(x, y, w, h, pixels)")

    it "shares the validated blit shader across standalone and session backends":
        val backend = file_read("src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl")
        val session = file_read("src/lib/gc_async_mut/gpu/engine2d/vulkan_session.spl")
        expect(backend).to_contain("vulkan_sffi_compile_spirv(spirv_blit())")
        expect(session).to_contain("vulkan_sffi_compile_spirv(spirv_blit())")
