# OS Crypto Primitive Tests — RFC Test Vectors
#
# Tests: SHA-256, HMAC-SHA-256, AES-256-GCM, ChaCha20, Poly1305, ChaCha20-Poly1305
# Target: 100% branch coverage on crypto primitives
#
# This test runs as a baremetal OS entry point, not under the SPipe harness.

use os.crypto.sha256.{sha256, sha256_hmac}
use os.crypto.aes_gcm.{aes256_gcm_encrypt, aes256_gcm_decrypt, AesGcmResult}
use os.crypto.chacha20.{chacha20_encrypt}
use os.crypto.poly1305.{poly1305_mac}
use os.crypto.chacha20_poly1305.{chacha20_poly1305_encrypt, chacha20_poly1305_decrypt, Chacha20Poly1305Result}
use os.crypto.curve25519.{x25519, x25519_base}
use os.crypto.ed25519.{ed25519_keypair_from_seed, ed25519_sign, ed25519_verify}

extern fn serial_println(msg: text)

var _pass_count: u32 = 0
var _fail_count: u32 = 0

fn _assert(condition: bool, name: text):
    if condition:
        serial_println("[TEST PASS] {name}")
        _pass_count = _pass_count + 1
    else:
        serial_println("[TEST FAIL: {name}]")
        _fail_count = _fail_count + 1

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _hex_byte(b: u8) -> text:
    # Convert byte to 2-char hex string for debugging.
    val hi = (b >> 4) & 0x0F
    val lo = b & 0x0F
    val hex_chars = "0123456789abcdef"
    var result: text = ""
    result = result + hex_chars[hi]
    result = result + hex_chars[lo]
    result

fn os_crypto_test():
    """Entry point for crypto primitive tests."""
    serial_println("=== OS Crypto Primitive Tests ===")
    serial_println("")

    _test_sha256()
    _test_hmac_sha256()
    _test_aes_gcm()
    _test_chacha20()
    _test_poly1305()
    _test_chacha20_poly1305()
    _test_x25519()
    _test_ed25519()

    serial_println("")
    serial_println("Crypto tests: {_pass_count} passed, {_fail_count} failed")
    if _fail_count == 0:
        serial_println("[ALL TESTS PASSED]")
    else:
        serial_println("[TESTS FAILED: {_fail_count}]")

# ============================================================================
# SHA-256 Tests
# ============================================================================

fn _test_sha256():
    serial_println("--- SHA-256 ---")

    # S1: SHA-256 of empty string
    # Expected: e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
    var empty: [u8] = []
    val h_empty = sha256(empty)
    _assert(h_empty.len() == 32, "S1: SHA-256 empty produces 32 bytes")
    _assert(h_empty[0] == 0xe3 and h_empty[1] == 0xb0, "S1b: SHA-256 empty first 2 bytes")

    # S2: SHA-256 of "abc"
    # Expected: ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
    var abc: [u8] = [0x61, 0x62, 0x63]
    val h_abc = sha256(abc)
    _assert(h_abc[0] == 0xba and h_abc[1] == 0x78, "S2: SHA-256('abc') first 2 bytes")
    _assert(h_abc[31] == 0xad, "S2b: SHA-256('abc') last byte")

    # S3: SHA-256 of 56 bytes (exactly one block after padding)
    var fifty6: [u8] = []
    var i: u64 = 0
    while i < 56:
        fifty6.push(0x61)
        i = i + 1
    val h56 = sha256(fifty6)
    _assert(h56.len() == 32, "S3: SHA-256(56 bytes 'a') produces 32 bytes")

    # S4: SHA-256 two different inputs produce different hashes
    var data1: [u8] = [0x01]
    var data2: [u8] = [0x02]
    val h1 = sha256(data1)
    val h2 = sha256(data2)
    _assert(not _bytes_eq(h1, h2), "S4: Different inputs produce different hashes")

    # S5: SHA-256 deterministic
    val h1b = sha256(data1)
    _assert(_bytes_eq(h1, h1b), "S5: Same input produces same hash")

    # S6: SHA-256 of 64 bytes (exactly two blocks after padding)
    var sixty4: [u8] = []
    i = 0
    while i < 64:
        sixty4.push(0x61)
        i = i + 1
    val h64 = sha256(sixty4)
    _assert(h64.len() == 32, "S6: SHA-256(64 bytes 'a') produces 32 bytes")

    # S7: SHA-256 of 63 bytes (padding crosses block boundary)
    var sixty3: [u8] = []
    i = 0
    while i < 63:
        sixty3.push(0x61)
        i = i + 1
    val h63 = sha256(sixty3)
    _assert(h63.len() == 32, "S7: SHA-256(63 bytes) produces 32 bytes")
    _assert(not _bytes_eq(h63, h64), "S7b: 63 bytes differs from 64 bytes")

    # S8: SHA-256 of 55 bytes (padding boundary)
    var fifty5: [u8] = []
    i = 0
    while i < 55:
        fifty5.push(0x61)
        i = i + 1
    val h55 = sha256(fifty5)
    _assert(h55.len() == 32, "S8: SHA-256(55 bytes) produces 32 bytes")
    _assert(not _bytes_eq(h55, h56), "S8b: 55 bytes differs from 56 bytes")

    # S9: SHA-256 of 1 byte
    var one_byte: [u8] = [0x61]
    val h_one = sha256(one_byte)
    _assert(h_one.len() == 32, "S9: SHA-256(1 byte) produces 32 bytes")
    _assert(not _bytes_eq(h_one, h_empty), "S9b: 1 byte differs from empty")

    # S10: NIST vector "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    var nist_msg: [u8] = [
        0x61, 0x62, 0x63, 0x64, 0x62, 0x63, 0x64, 0x65,
        0x63, 0x64, 0x65, 0x66, 0x64, 0x65, 0x66, 0x67,
        0x65, 0x66, 0x67, 0x68, 0x66, 0x67, 0x68, 0x69,
        0x67, 0x68, 0x69, 0x6a, 0x68, 0x69, 0x6a, 0x6b,
        0x69, 0x6a, 0x6b, 0x6c, 0x6a, 0x6b, 0x6c, 0x6d,
        0x6b, 0x6c, 0x6d, 0x6e, 0x6c, 0x6d, 0x6e, 0x6f,
        0x6d, 0x6e, 0x6f, 0x70, 0x6e, 0x6f, 0x70, 0x71
    ]
    val h_nist = sha256(nist_msg)
    _assert(h_nist[0] == 0x24 and h_nist[1] == 0x8d, "S10: NIST vector first 2 bytes 0x24,0x8d")

# ============================================================================
# HMAC-SHA-256 Tests
# ============================================================================

fn _test_hmac_sha256():
    serial_println("--- HMAC-SHA-256 ---")

    # H1: HMAC with known key and data
    var hmac_key: [u8] = []
    var i: u64 = 0
    while i < 20:
        hmac_key.push(0x0b)
        i = i + 1
    var hmac_data: [u8] = [0x48, 0x69, 0x20, 0x54, 0x68, 0x65, 0x72, 0x65]  # "Hi There"
    val hmac_result = sha256_hmac(hmac_key, hmac_data)
    _assert(hmac_result.len() == 32, "H1: HMAC-SHA-256 produces 32 bytes")

    # H2: Different keys produce different MACs
    var hmac_key2: [u8] = []
    i = 0
    while i < 20:
        hmac_key2.push(0x0c)
        i = i + 1
    val hmac_result2 = sha256_hmac(hmac_key2, hmac_data)
    _assert(not _bytes_eq(hmac_result, hmac_result2), "H2: Different keys produce different MACs")

    # H3: Deterministic
    val hmac_result_dup = sha256_hmac(hmac_key, hmac_data)
    _assert(_bytes_eq(hmac_result, hmac_result_dup), "H3: HMAC is deterministic")

    # H4: Empty data
    var empty_data: [u8] = []
    val hmac_empty = sha256_hmac(hmac_key, empty_data)
    _assert(hmac_empty.len() == 32, "H4: HMAC of empty data produces 32 bytes")

    # H5: Key > 64 bytes (triggers hash-key path in HMAC)
    var long_key: [u8] = []
    i = 0
    while i < 80:
        long_key.push((i & 0xFF).to_u8())
        i = i + 1
    val hmac_long = sha256_hmac(long_key, hmac_data)
    _assert(hmac_long.len() == 32, "H5: HMAC with key > 64 bytes produces 32 bytes")
    _assert(not _bytes_eq(hmac_long, hmac_result), "H5b: Long key produces different MAC")

    # H6: Key exactly 64 bytes
    var key64: [u8] = []
    i = 0
    while i < 64:
        key64.push((i & 0xFF).to_u8())
        i = i + 1
    val hmac_k64 = sha256_hmac(key64, hmac_data)
    _assert(hmac_k64.len() == 32, "H6: HMAC with 64-byte key produces 32 bytes")
    _assert(not _bytes_eq(hmac_k64, hmac_long), "H6b: 64-byte key differs from 80-byte key")

    # H7: Key 1 byte
    var key1: [u8] = [0x42]
    val hmac_k1 = sha256_hmac(key1, hmac_data)
    _assert(hmac_k1.len() == 32, "H7: HMAC with 1-byte key produces 32 bytes")
    _assert(not _bytes_eq(hmac_k1, hmac_result), "H7b: 1-byte key differs from 20-byte key")

# ============================================================================
# AES-256-GCM Tests
# ============================================================================

fn _test_aes_gcm():
    serial_println("--- AES-256-GCM ---")

    # G1: Encrypt then decrypt round-trip
    var key: [u8] = []
    var i: u64 = 0
    while i < 32:
        key.push(i.to_u8())
        i = i + 1
    var nonce: [u8] = []
    i = 0
    while i < 12:
        nonce.push((0x10 + i).to_u8())
        i = i + 1
    var plaintext: [u8] = [0x48, 0x65, 0x6c, 0x6c, 0x6f]  # "Hello"
    var aad: [u8] = [0x01, 0x02, 0x03]

    val encrypted = aes256_gcm_encrypt(key, nonce, plaintext, aad)
    _assert(encrypted.len() == plaintext.len() + 16, "G1: Encrypted = plaintext + 16 byte tag")

    # G2: Decrypt produces original plaintext
    var ct: [u8] = []
    i = 0
    while i < plaintext.len():
        ct.push(encrypted[i])
        i = i + 1
    var tag: [u8] = []
    while i < encrypted.len():
        tag.push(encrypted[i])
        i = i + 1
    val decrypted = aes256_gcm_decrypt(key, nonce, ct, aad, tag)
    match decrypted:
        AesGcmResult.Ok(pt):
            _assert(_bytes_eq(pt, plaintext), "G2: Decrypted matches plaintext")
        AesGcmResult.Err(msg):
            _assert(false, "G2: Decryption should succeed")

    # G3: Tampered tag rejected
    var bad_tag: [u8] = []
    i = 0
    while i < 16:
        bad_tag.push(tag[i] ^ 0xFF)
        i = i + 1
    val bad_result = aes256_gcm_decrypt(key, nonce, ct, aad, bad_tag)
    match bad_result:
        AesGcmResult.Ok(pt):
            _assert(false, "G3: Tampered tag should be rejected")
        AesGcmResult.Err(msg):
            _assert(true, "G3: Tampered tag rejected")

    # G4: Empty plaintext
    var empty_pt: [u8] = []
    val enc_empty = aes256_gcm_encrypt(key, nonce, empty_pt, aad)
    _assert(enc_empty.len() == 16, "G4: Empty plaintext produces 16-byte tag only")

    # G5: Empty AAD
    var empty_aad: [u8] = []
    val enc_no_aad = aes256_gcm_encrypt(key, nonce, plaintext, empty_aad)
    _assert(enc_no_aad.len() == plaintext.len() + 16, "G5: Empty AAD still works")

    # G6: Decrypt with wrong key -> tag mismatch
    var wrong_key: [u8] = []
    i = 0
    while i < 32:
        wrong_key.push((i.to_u8()) ^ 0xFF)
        i = i + 1
    val g6_result = aes256_gcm_decrypt(wrong_key, nonce, ct, aad, tag)
    match g6_result:
        AesGcmResult.Ok(pt):
            _assert(false, "G6: Wrong key should be rejected")
        AesGcmResult.Err(msg):
            _assert(true, "G6: Wrong key rejected")

    # G7: Decrypt with wrong nonce -> tag mismatch
    var wrong_nonce: [u8] = []
    i = 0
    while i < 12:
        wrong_nonce.push((0x10 + i).to_u8() ^ 0xFF)
        i = i + 1
    val g7_result = aes256_gcm_decrypt(key, wrong_nonce, ct, aad, tag)
    match g7_result:
        AesGcmResult.Ok(pt):
            _assert(false, "G7: Wrong nonce should be rejected")
        AesGcmResult.Err(msg):
            _assert(true, "G7: Wrong nonce rejected")

    # G8: 16-byte plaintext (one AES block)
    var pt16: [u8] = []
    i = 0
    while i < 16:
        pt16.push((0x30 + i).to_u8())
        i = i + 1
    val enc16 = aes256_gcm_encrypt(key, nonce, pt16, aad)
    _assert(enc16.len() == 16 + 16, "G8: 16-byte plaintext produces 32 bytes")
    var ct16: [u8] = []
    i = 0
    while i < 16:
        ct16.push(enc16[i])
        i = i + 1
    var tag16: [u8] = []
    while i < enc16.len():
        tag16.push(enc16[i])
        i = i + 1
    val dec16 = aes256_gcm_decrypt(key, nonce, ct16, aad, tag16)
    match dec16:
        AesGcmResult.Ok(pt):
            _assert(_bytes_eq(pt, pt16), "G8b: 16-byte round-trip matches")
        AesGcmResult.Err(msg):
            _assert(false, "G8b: 16-byte decrypt should succeed")

    # G9: 17-byte plaintext (crosses block boundary)
    var pt17: [u8] = []
    i = 0
    while i < 17:
        pt17.push((0x40 + i).to_u8())
        i = i + 1
    val enc17 = aes256_gcm_encrypt(key, nonce, pt17, aad)
    _assert(enc17.len() == 17 + 16, "G9: 17-byte plaintext produces 33 bytes")
    var ct17: [u8] = []
    i = 0
    while i < 17:
        ct17.push(enc17[i])
        i = i + 1
    var tag17: [u8] = []
    while i < enc17.len():
        tag17.push(enc17[i])
        i = i + 1
    val dec17 = aes256_gcm_decrypt(key, nonce, ct17, aad, tag17)
    match dec17:
        AesGcmResult.Ok(pt):
            _assert(_bytes_eq(pt, pt17), "G9b: 17-byte round-trip matches")
        AesGcmResult.Err(msg):
            _assert(false, "G9b: 17-byte decrypt should succeed")

    # G10: 32-byte plaintext (two AES blocks)
    var pt32: [u8] = []
    i = 0
    while i < 32:
        pt32.push((i & 0xFF).to_u8())
        i = i + 1
    val enc32 = aes256_gcm_encrypt(key, nonce, pt32, aad)
    _assert(enc32.len() == 32 + 16, "G10: 32-byte plaintext produces 48 bytes")
    var ct32: [u8] = []
    i = 0
    while i < 32:
        ct32.push(enc32[i])
        i = i + 1
    var tag32: [u8] = []
    while i < enc32.len():
        tag32.push(enc32[i])
        i = i + 1
    val dec32 = aes256_gcm_decrypt(key, nonce, ct32, aad, tag32)
    match dec32:
        AesGcmResult.Ok(pt):
            _assert(_bytes_eq(pt, pt32), "G10b: 32-byte round-trip matches")
        AesGcmResult.Err(msg):
            _assert(false, "G10b: 32-byte decrypt should succeed")

    # G11: 48-byte plaintext (three AES blocks)
    var pt48: [u8] = []
    i = 0
    while i < 48:
        pt48.push((i & 0xFF).to_u8())
        i = i + 1
    val enc48 = aes256_gcm_encrypt(key, nonce, pt48, aad)
    _assert(enc48.len() == 48 + 16, "G11: 48-byte plaintext produces 64 bytes")
    var ct48: [u8] = []
    i = 0
    while i < 48:
        ct48.push(enc48[i])
        i = i + 1
    var tag48: [u8] = []
    while i < enc48.len():
        tag48.push(enc48[i])
        i = i + 1
    val dec48 = aes256_gcm_decrypt(key, nonce, ct48, aad, tag48)
    match dec48:
        AesGcmResult.Ok(pt):
            _assert(_bytes_eq(pt, pt48), "G11b: 48-byte round-trip matches")
        AesGcmResult.Err(msg):
            _assert(false, "G11b: 48-byte decrypt should succeed")

# ============================================================================
# ChaCha20 Tests
# ============================================================================

fn _test_chacha20():
    serial_println("--- ChaCha20 ---")

    # C1: Encrypt then decrypt round-trip (ChaCha20 is XOR-based)
    var key: [u8] = []
    var i: u64 = 0
    while i < 32:
        key.push(i.to_u8())
        i = i + 1
    var nonce: [u8] = []
    i = 0
    while i < 12:
        nonce.push(0)
        i = i + 1
    var plaintext: [u8] = [0x48, 0x65, 0x6c, 0x6c, 0x6f]

    val ct = chacha20_encrypt(key, 0, nonce, plaintext)
    _assert(ct.len() == plaintext.len(), "C1: Ciphertext same length as plaintext")

    # C2: Decrypt (same operation)
    val pt = chacha20_encrypt(key, 0, nonce, ct)
    _assert(_bytes_eq(pt, plaintext), "C2: ChaCha20 decrypt round-trip")

    # C3: Ciphertext differs from plaintext
    _assert(not _bytes_eq(ct, plaintext), "C3: Ciphertext differs from plaintext")

    # C4: Empty plaintext
    var empty_pt: [u8] = []
    val ct_empty = chacha20_encrypt(key, 0, nonce, empty_pt)
    _assert(ct_empty.len() == 0, "C4: Empty plaintext produces empty ciphertext")

    # C5: Different nonces produce different ciphertext
    var nonce2: [u8] = []
    i = 0
    while i < 12:
        nonce2.push(1)
        i = i + 1
    val ct2 = chacha20_encrypt(key, 0, nonce2, plaintext)
    _assert(not _bytes_eq(ct, ct2), "C5: Different nonces produce different output")

    # C6: 256-byte payload round-trip
    var big_pt: [u8] = []
    i = 0
    while i < 256:
        big_pt.push((i & 0xFF).to_u8())
        i = i + 1
    val big_ct = chacha20_encrypt(key, 0, nonce, big_pt)
    _assert(big_ct.len() == 256, "C6: 256-byte ciphertext same length")
    val big_rt = chacha20_encrypt(key, 0, nonce, big_ct)
    _assert(_bytes_eq(big_rt, big_pt), "C6b: 256-byte round-trip matches")

    # C7: Counter=1 produces different output than counter=0
    val ct_c0 = chacha20_encrypt(key, 0, nonce, plaintext)
    val ct_c1 = chacha20_encrypt(key, 1, nonce, plaintext)
    _assert(not _bytes_eq(ct_c0, ct_c1), "C7: Counter=1 differs from counter=0")

    # C8: 64-byte payload (one full ChaCha20 block)
    var pt64: [u8] = []
    i = 0
    while i < 64:
        pt64.push((i & 0xFF).to_u8())
        i = i + 1
    val ct64 = chacha20_encrypt(key, 0, nonce, pt64)
    _assert(ct64.len() == 64, "C8: 64-byte ciphertext same length")
    val rt64 = chacha20_encrypt(key, 0, nonce, ct64)
    _assert(_bytes_eq(rt64, pt64), "C8b: 64-byte round-trip matches")

# ============================================================================
# Poly1305 Tests
# ============================================================================

fn _test_poly1305():
    serial_println("--- Poly1305 ---")

    # P1: Poly1305 produces 16-byte tag
    var key: [u8] = []
    var i: u64 = 0
    while i < 32:
        key.push(i.to_u8())
        i = i + 1
    var msg: [u8] = [0x48, 0x65, 0x6c, 0x6c, 0x6f]
    val tag = poly1305_mac(key, msg)
    _assert(tag.len() == 16, "P1: Poly1305 produces 16-byte tag")

    # P2: Different messages produce different tags
    var msg2: [u8] = [0x57, 0x6f, 0x72, 0x6c, 0x64]
    val tag2 = poly1305_mac(key, msg2)
    _assert(not _bytes_eq(tag, tag2), "P2: Different messages produce different tags")

    # P3: Deterministic
    val tag_dup = poly1305_mac(key, msg)
    _assert(_bytes_eq(tag, tag_dup), "P3: Poly1305 is deterministic")

    # P4: Empty message
    var empty_msg: [u8] = []
    val tag_empty = poly1305_mac(key, empty_msg)
    _assert(tag_empty.len() == 16, "P4: Poly1305 of empty message is 16 bytes")

    # P5: Different keys produce different tags
    var key2: [u8] = []
    i = 0
    while i < 32:
        key2.push((i + 32).to_u8())
        i = i + 1
    val tag_k2 = poly1305_mac(key2, msg)
    _assert(not _bytes_eq(tag, tag_k2), "P5: Different keys produce different tags")

    # P6: 16-byte message (one block exactly)
    var msg16: [u8] = []
    i = 0
    while i < 16:
        msg16.push((0x10 + i).to_u8())
        i = i + 1
    val tag16 = poly1305_mac(key, msg16)
    _assert(tag16.len() == 16, "P6: Poly1305(16 bytes) produces 16-byte tag")

    # P7: 17-byte message (crosses block boundary)
    var msg17: [u8] = []
    i = 0
    while i < 17:
        msg17.push((0x20 + i).to_u8())
        i = i + 1
    val tag17 = poly1305_mac(key, msg17)
    _assert(tag17.len() == 16, "P7: Poly1305(17 bytes) produces 16-byte tag")
    _assert(not _bytes_eq(tag16, tag17), "P7b: 17-byte tag differs from 16-byte tag")

    # P8: 32-byte message (two blocks)
    var msg32: [u8] = []
    i = 0
    while i < 32:
        msg32.push((0x30 + i).to_u8())
        i = i + 1
    val tag32 = poly1305_mac(key, msg32)
    _assert(tag32.len() == 16, "P8: Poly1305(32 bytes) produces 16-byte tag")

    # P9: 15-byte message (partial block)
    var msg15: [u8] = []
    i = 0
    while i < 15:
        msg15.push((0x40 + i).to_u8())
        i = i + 1
    val tag15 = poly1305_mac(key, msg15)
    _assert(tag15.len() == 16, "P9: Poly1305(15 bytes) produces 16-byte tag")
    _assert(not _bytes_eq(tag15, tag16), "P9b: 15-byte tag differs from 16-byte tag")

    # P10: 1-byte message
    var msg1b: [u8] = [0x42]
    val tag1b = poly1305_mac(key, msg1b)
    _assert(tag1b.len() == 16, "P10: Poly1305(1 byte) produces 16-byte tag")
    _assert(not _bytes_eq(tag1b, tag_empty), "P10b: 1-byte tag differs from empty tag")

# ============================================================================
# ChaCha20-Poly1305 AEAD Tests
# ============================================================================

fn _test_chacha20_poly1305():
    serial_println("--- ChaCha20-Poly1305 ---")

    # CP1: Encrypt/decrypt round-trip
    var key: [u8] = []
    var i: u64 = 0
    while i < 32:
        key.push(i.to_u8())
        i = i + 1
    var nonce: [u8] = []
    i = 0
    while i < 12:
        nonce.push(0)
        i = i + 1
    var plaintext: [u8] = [0x48, 0x65, 0x6c, 0x6c, 0x6f]
    var aad: [u8] = [0x01, 0x02, 0x03]

    val encrypted = chacha20_poly1305_encrypt(key, nonce, plaintext, aad)
    _assert(encrypted.len() == plaintext.len() + 16, "CP1: Encrypted = plaintext + 16 byte tag")

    # CP2: Decrypt
    var ct: [u8] = []
    i = 0
    while i < plaintext.len():
        ct.push(encrypted[i])
        i = i + 1
    var tag: [u8] = []
    while i < encrypted.len():
        tag.push(encrypted[i])
        i = i + 1

    val decrypted = chacha20_poly1305_decrypt(key, nonce, ct, aad, tag)
    match decrypted:
        Chacha20Poly1305Result.Ok(pt):
            _assert(_bytes_eq(pt, plaintext), "CP2: Decrypted matches plaintext")
        Chacha20Poly1305Result.Err(msg):
            _assert(false, "CP2: Decryption should succeed")

    # CP3: Tampered ciphertext rejected
    var bad_ct: [u8] = []
    i = 0
    while i < ct.len():
        bad_ct.push(ct[i] ^ 0x01)
        i = i + 1
    val bad_result = chacha20_poly1305_decrypt(key, nonce, bad_ct, aad, tag)
    match bad_result:
        Chacha20Poly1305Result.Ok(pt):
            _assert(false, "CP3: Tampered ciphertext should be rejected")
        Chacha20Poly1305Result.Err(msg):
            _assert(true, "CP3: Tampered ciphertext rejected")

    # CP4: Tampered AAD rejected
    var bad_aad: [u8] = [0xFF, 0xFE, 0xFD]
    val bad_aad_result = chacha20_poly1305_decrypt(key, nonce, ct, bad_aad, tag)
    match bad_aad_result:
        Chacha20Poly1305Result.Ok(pt):
            _assert(false, "CP4: Tampered AAD should be rejected")
        Chacha20Poly1305Result.Err(msg):
            _assert(true, "CP4: Tampered AAD rejected")

    # CP5: Empty plaintext
    var empty_pt: [u8] = []
    val enc_empty = chacha20_poly1305_encrypt(key, nonce, empty_pt, aad)
    _assert(enc_empty.len() == 16, "CP5: Empty plaintext produces tag-only output")

    # CP6: Empty AAD
    var empty_aad: [u8] = []
    val enc_no_aad = chacha20_poly1305_encrypt(key, nonce, plaintext, empty_aad)
    _assert(enc_no_aad.len() == plaintext.len() + 16, "CP6: Empty AAD works")

    # CP7: 128-byte payload round-trip
    var big_pt: [u8] = []
    i = 0
    while i < 128:
        big_pt.push((i & 0xFF).to_u8())
        i = i + 1
    val big_enc = chacha20_poly1305_encrypt(key, nonce, big_pt, aad)
    _assert(big_enc.len() == 128 + 16, "CP7: 128-byte encrypted = 144 bytes")
    var big_ct: [u8] = []
    i = 0
    while i < 128:
        big_ct.push(big_enc[i])
        i = i + 1
    var big_tag: [u8] = []
    while i < big_enc.len():
        big_tag.push(big_enc[i])
        i = i + 1
    val big_dec = chacha20_poly1305_decrypt(key, nonce, big_ct, aad, big_tag)
    match big_dec:
        Chacha20Poly1305Result.Ok(pt):
            _assert(_bytes_eq(pt, big_pt), "CP7b: 128-byte round-trip matches")
        Chacha20Poly1305Result.Err(msg):
            _assert(false, "CP7b: 128-byte decrypt should succeed")

    # CP8: Wrong key -> decrypt error
    var wrong_key: [u8] = []
    i = 0
    while i < 32:
        wrong_key.push((i.to_u8()) ^ 0xFF)
        i = i + 1
    val cp8_result = chacha20_poly1305_decrypt(wrong_key, nonce, ct, aad, tag)
    match cp8_result:
        Chacha20Poly1305Result.Ok(pt):
            _assert(false, "CP8: Wrong key should be rejected")
        Chacha20Poly1305Result.Err(msg):
            _assert(true, "CP8: Wrong key rejected")

    # CP9: Wrong nonce -> decrypt error
    var wrong_nonce: [u8] = []
    i = 0
    while i < 12:
        wrong_nonce.push(0xFF)
        i = i + 1
    val cp9_result = chacha20_poly1305_decrypt(key, wrong_nonce, ct, aad, tag)
    match cp9_result:
        Chacha20Poly1305Result.Ok(pt):
            _assert(false, "CP9: Wrong nonce should be rejected")
        Chacha20Poly1305Result.Err(msg):
            _assert(true, "CP9: Wrong nonce rejected")

    # CP10: Different nonces -> different ciphertext
    var nonce_a: [u8] = []
    i = 0
    while i < 12:
        nonce_a.push(0x01)
        i = i + 1
    var nonce_b: [u8] = []
    i = 0
    while i < 12:
        nonce_b.push(0x02)
        i = i + 1
    val enc_a = chacha20_poly1305_encrypt(key, nonce_a, plaintext, aad)
    val enc_b = chacha20_poly1305_encrypt(key, nonce_b, plaintext, aad)
    _assert(not _bytes_eq(enc_a, enc_b), "CP10: Different nonces produce different ciphertext")

# ============================================================================
# X25519 Tests
# ============================================================================

fn _test_x25519():
    serial_println("--- X25519 ---")

    # X1: Base point multiplication produces 32-byte public key
    var scalar: [u8] = []
    var i: u64 = 0
    while i < 32:
        scalar.push((i + 1).to_u8())
        i = i + 1
    val pub_key = x25519_base(scalar)
    _assert(pub_key.len() == 32, "X1: x25519_base produces 32 bytes")

    # X2: DH key agreement — both sides compute same shared secret
    var alice_private: [u8] = []
    var bob_private: [u8] = []
    i = 0
    while i < 32:
        alice_private.push((i + 1).to_u8())
        bob_private.push((i + 33).to_u8())
        i = i + 1
    val alice_public = x25519_base(alice_private)
    val bob_public = x25519_base(bob_private)
    val alice_shared = x25519(alice_private, bob_public)
    val bob_shared = x25519(bob_private, alice_public)
    _assert(_bytes_eq(alice_shared, bob_shared), "X2: DH shared secrets match")

    # X3: Different scalars produce different public keys
    _assert(not _bytes_eq(alice_public, bob_public), "X3: Different scalars produce different keys")

    # X4: Deterministic
    val alice_pub2 = x25519_base(alice_private)
    _assert(_bytes_eq(alice_public, alice_pub2), "X4: x25519_base is deterministic")

# ============================================================================
# Ed25519 Tests
# ============================================================================

fn _test_ed25519():
    serial_println("--- Ed25519 ---")

    # E1: Keypair from seed produces 32-byte public key
    var seed: [u8] = [
        0x9d, 0x61, 0xb1, 0x9d, 0xef, 0xfd, 0x5a, 0x60,
        0xba, 0x84, 0x4a, 0xf4, 0x92, 0xec, 0x2c, 0xc4,
        0x44, 0x49, 0xc5, 0x69, 0x7b, 0x32, 0x69, 0x19,
        0x70, 0x3b, 0xac, 0x03, 0x1c, 0xae, 0x7f, 0x60
    ]
    val kp = ed25519_keypair_from_seed(seed)
    _assert(kp.1.len() == 32, "E1: Ed25519 public key is 32 bytes")

    # E2: Sign produces 64-byte signature
    var msg: [u8] = []
    val sig = ed25519_sign(seed, kp.1, msg)
    _assert(sig.len() == 64, "E2: Ed25519 signature is 64 bytes")

    # E3: Verify valid signature
    val valid = ed25519_verify(kp.1, msg, sig)
    _assert(valid, "E3: Valid signature verifies")

    # E4: Reject tampered message
    var bad_msg: [u8] = [0x42]
    val invalid = ed25519_verify(kp.1, bad_msg, sig)
    _assert(not invalid, "E4: Tampered message rejected")

    # E5: Reject tampered signature
    var bad_sig: [u8] = []
    var i: u64 = 0
    while i < 64:
        bad_sig.push(sig[i] ^ 0x01)
        i = i + 1
    val invalid2 = ed25519_verify(kp.1, msg, bad_sig)
    _assert(not invalid2, "E5: Tampered signature rejected")

    # E6: Sign non-empty message
    var msg2: [u8] = [0x72, 0x61, 0x66]  # "raf"
    val sig2 = ed25519_sign(seed, kp.1, msg2)
    val valid2 = ed25519_verify(kp.1, msg2, sig2)
    _assert(valid2, "E6: Non-empty message sign+verify")

    # E7: Different seeds produce different keypairs
    var seed2: [u8] = []
    i = 0
    while i < 32:
        seed2.push(((i + 1) & 0xFF).to_u8())
        i = i + 1
    val kp2 = ed25519_keypair_from_seed(seed2)
    _assert(not _bytes_eq(kp.1, kp2.1), "E7: Different seeds produce different keys")

    # E8: Wrong public key rejects signature
    val invalid3 = ed25519_verify(kp2.1, msg, sig)
    _assert(not invalid3, "E8: Wrong public key rejects signature")
