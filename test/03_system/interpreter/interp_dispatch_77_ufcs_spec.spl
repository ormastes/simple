## Task #77 repro/regression: UFCS free-function method calls from spec
## it-block test code. `value.free_fn(args)` where `free_fn` is a module-level
## fn must resolve as `free_fn(value, args)` in the interpreter's
## MethodResolution.FreeFunction dispatch (see interpreter.spl eval_expr
## HirExprKind.MethodCall case and interpreter_calls.spl call_function_by_id).
##
## Structs are named uniquely per the interp global-registry same-name
## collision hazard (two modules defining the same struct name corrupt each
## other's runtime type registry).

use test.fixtures.interp_dispatch_78.ufcs_mod77.{triple_it_77}

fn ufcs_double_77(x: i32) -> i32:
    return x * 2

struct Pt77Ufcs:
    x: i32
    y: i32

fn sum_pt77_ufcs(p: Pt77Ufcs) -> i32:
    return p.x + p.y

fn scale_pt77_ufcs(p: Pt77Ufcs, k: i32) -> i32:
    return (p.x + p.y) * k

describe "Interp dispatch repro (task 77) - UFCS free-function calls":
    it "resolves a module-local free function via UFCS from an it-block":
        val v = 5
        val r = v.ufcs_double_77()
        expect r == 10

    it "resolves UFCS on a struct receiver":
        val p = Pt77Ufcs(x: 3, y: 4)
        val s = p.sum_pt77_ufcs()
        expect s == 7

    it "resolves UFCS with extra positional args":
        val p = Pt77Ufcs(x: 3, y: 4)
        val s = p.scale_pt77_ufcs(2)
        expect s == 14

    it "resolves UFCS on a free function imported from another module":
        val v: i64 = 5
        val r = v.triple_it_77()
        expect r == 15
