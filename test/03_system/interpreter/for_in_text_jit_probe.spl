# Plain (non-SSpec) probe for the for-loop-over-text JIT regression guarded
# by for_in_text_jit_system_spec.spl. Deliberately NOT a `_spec.spl` file:
# SSpec `describe`/`it` block bodies always execute via the tree-walking
# interpreter (even when the enclosing process is launched with plain
# `bin/simple run`), so an SSpec-only test can never exercise the
# Cranelift-JIT for-loop-over-text path this guards. See
# doc/08_tracking/bug/for_loop_over_text_char_code_at_zero_len_crash_2026-07-19.md.
#
# Run directly: `bin/simple run test/03_system/interpreter/for_in_text_jit_probe.spl`
# Prints "ok" on success, or "fail:<detail>" describing the mismatch.

fn char_code_sum(s: text) -> i64:
    var total: i64 = 0
    for ch in s:
        total = total + ch.char_code_at(0)
    return total

fn joined_chars(s: text) -> text:
    var out = ""
    for ch in s:
        out = out + ch
    return out

fn main():
    val sample = "a" + "é🙂"
    val expected_sum: i64 = 97 + 233 + 128578
    val actual_sum = char_code_sum(sample)
    if actual_sum != expected_sum:
        print("fail:sum expected={expected_sum} actual={actual_sum}")
        return
    val joined = joined_chars(sample)
    if joined != sample:
        print("fail:join expected={sample} actual={joined}")
        return
    print("ok")
