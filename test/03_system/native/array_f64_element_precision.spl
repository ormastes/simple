struct FBox:
    v: f64

fn main() -> i64:
    val a = [0.1, 0.2, 0.3]
    val x = a[0]
    val d = {"k": 0.1}
    val y = d["k"]
    val s = FBox(v: 0.1)
    # Empty-container element-type erasure guard: `{}`/`[]` fix the declared
    # element type at the i64 default; a later f64 store heap-boxes but an
    # i64-typed read shredded the box pointer via `>>3` (leaked as a raw int).
    # Reads must pick up the store-observed type (runtime_elem_value_type).
    var ed = {}
    ed["k"] = 0.1
    # 0.1 is MASK-SENSITIVE (low 3 mantissa bits nonzero): these two lines
    # gate the JIT push/element-store float-boxing fix (MirInst::BoxFloat in
    # lowering_expr_method.rs / lowering_expr_call.rs). They used mask-immune
    # 0.25/0.5 while the interp/JIT store-mask bug was open — do not regress
    # them back. See seed_f64_array_element_precision_mask_2026-07-19.md.
    var ea = []
    ea.push(0.1)
    var eb = [0.0]
    eb[0] = 0.1
    # Typed [f64] push through a function boundary (the original rc-40 repro).
    var ep: [f64] = []
    ep.push(0.1)
    var ei = {}
    ei["n"] = 7
    if x == 0.1 and y == 0.1 and s.v == 0.1 and ed["k"] == 0.1 and ea[0] == 0.1 and eb[0] == 0.1 and ep[0] == 0.1 and ei["n"] == 7: return 30
    return 40
