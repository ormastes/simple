# Guards layoutglyph_struct_array_i64_field_tag_shift_readback_2026-07-20:
# a struct pushed into an array declared via an EMPTY `[]` literal (element
# type fixed at the erased i64 default, e.g. `var glyphs: [LayoutGlyph] = []`
# then `.push(...)`) never went through lower_array_lit's per-element
# struct-name capture, so array_element_struct_syms was never populated for
# the container. Re-reading `arr[i]` then fell through
# decode_runtime_value's is_integer default (`raw >> 3`), shredding the
# struct's heap pointer into a wild address -- SIGSEGV on the next field
# access. An array LITERAL with elements (class_array.spl) was unaffected;
# only empty-literal + push was.
#
# Fix: note_container_elem_type (called at every push/index-assign site)
# now also mirrors lower_array_lit's struct_value_syms ->
# array_element_struct_syms capture, so the read side learns the real
# element type regardless of how the container was declared.
#
# Expected rc: 30. Regression looks like: a non-zero SIGSEGV/crash exit
# (139), or rc matching one of the specific failure codes below.

class Rec:
    codepoint: i64
    x: i64
    y: i64
    width: i64
    height: i64
    byte_offset: i64

fn main() -> i64:
    var arr: [Rec] = []
    arr.push(Rec(codepoint: 83, x: 5, y: 12, width: 6, height: 12, byte_offset: 0))
    arr.push(Rec(codepoint: 0, x: 0, y: 0, width: 0, height: 0, byte_offset: 0))
    arr.push(Rec(codepoint: 7, x: -7, y: 7, width: -7, height: 7, byte_offset: -7))
    # 2^60 - 1: near the 3-bit tag boundary used by the scalar box/unbox scheme.
    arr.push(Rec(codepoint: 1152921504606846975, x: 1, y: 1, width: 1, height: 1, byte_offset: 1))

    if arr[0].codepoint != 83: return 111
    if arr[0].width != 6: return 112
    if arr[0].height != 12: return 113
    if arr[1].codepoint != 0: return 114
    if arr[2].x != -7: return 115
    if arr[2].codepoint != 7: return 116
    if arr[3].codepoint != 1152921504606846975: return 117

    # for-in over a push-built array is a SEPARATE decode_runtime_value call
    # site (mir_lowering_stmts.spl's counted-index desugar) from the Index
    # read case above -- both key off array_element_struct_syms, but must be
    # exercised independently since the font renderer iterates as well as
    # indexes.
    var sum_cp = 0
    for r in arr:
        sum_cp = sum_cp + r.codepoint
    if sum_cp != 1152921504606847065: return 118

    return 30
