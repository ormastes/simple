fn main() -> i64:
    val s = "Hello"
    val upper = s.to_upper()
    var upper_ok = 0
    if upper == "HELLO":
        upper_ok = 20
    val f = "3.14".parse_f64()
    val zero = "0".parse_f64()
    val invalid = "bad".parse_f64()
    val trailing = "12junk".parse_f64()
    var parse_ok = 0
    if f != nil and zero != nil:
        if invalid == nil and trailing == nil:
            if f.unwrap_or(0.0) == 3.14 and zero.unwrap_or(1.0) == 0.0:
                parse_ok = 22
    return upper_ok + parse_ok
