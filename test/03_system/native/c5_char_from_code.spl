fn chr(code: i64) -> text:
    "wrong-chr"

fn to_char(code: i64) -> text:
    "wrong-to-char"

struct CharOwner:
    marker: i64

impl CharOwner:
    fn chr(self) -> text:
        "owned-chr"

    fn to_char(self) -> text:
        "owned-to-char"

fn main() -> i64:
    val cp: i64 = 65
    val negative: i64 = -1
    val nul = 0.chr()
    val owner: CharOwner = CharOwner(marker: 1)
    if cp.chr() != "A": return 1
    if 90.to_char() != "Z": return 2
    if 233.chr() != "é": return 3
    if 128578.to_char() != "🙂": return 4
    if nul.len() != 1: return 5
    if nul.char_code_at(0) != 0: return 6
    if negative.chr().len() != 0: return 7
    if 55296.chr().len() != 0: return 8
    if 1114112.to_char().len() != 0: return 9
    if owner.chr() != "owned-chr": return 10
    if owner.to_char() != "owned-to-char": return 11
    return 42
