fn chr(code: i64) -> text:
    "wrong-chr"

fn to_char(code: i64) -> text:
    "wrong-to-char"

struct CharOwner:
    marker: i64

impl CharOwner:
    fn chr(self) -> text:
        "owned-chr"

    fn to_char(self) -> text:
        "owned-to-char"

fn main() -> i64:
    val cp: i64 = 65
    val negative: i64 = -1
    val nul = 0.chr()
    val owner: CharOwner = CharOwner(marker: 1)
    if (cp.chr() == "A" and 90.to_char() == "Z" and 233.chr() == "é" and 128578.to_char() == "🙂" and
        nul.len() == 1 and nul.char_code_at(0) == 0 and
        negative.chr().len() == 0 and 55296.chr().len() == 0 and 1114112.to_char().len() == 0 and
        owner.chr() == "owned-chr" and owner.to_char() == "owned-to-char"):
        return 42
    return 0
