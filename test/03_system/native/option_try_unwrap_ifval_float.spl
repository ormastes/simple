fn main() -> i64:
    val x64: f64? = 3.5
    if val v64 = x64.?:
        if v64 != 3.5:
            return 1
    else:
        return 2

    val none64: f64? = nil
    if val unexpected64 = none64.?:
        return 5

    val x32: f32? = 1.25
    if val v32 = x32.?:
        if v32 == 1.25:
            return 42
        return 3
    return 4
