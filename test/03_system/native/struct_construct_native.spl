struct P:
    x: i64
    y: i64

fn main() -> i64:
    # Regression guard for native_build_entry_struct_construction_buildfail:
    # `native-build --entry` on any local struct construction used to BUILDFAIL
    # with `method has not found on nil` because the driver's hand-duplicated
    # MirLowering(...) constructor omitted 8 fields that the seed then nil-filled.
    val p = P(x: 12, y: 18)
    if p.x + p.y == 30:
        return 30
    return 40
