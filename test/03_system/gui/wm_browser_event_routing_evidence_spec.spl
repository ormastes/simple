# @tag: sys, gui, wm, browser, events

use std.spec.*
use std.io_runtime.{getpid, time_now_unix_micros}
use app.io.mod.{process_run_timeout, file_read_text}

fn _run_id() -> text:
    getpid().to_text() + "_" + time_now_unix_micros().to_text()

fn _run_checker(run_id: text) -> (text, text, i32):
    val build_dir = "build/tmp/wm_browser_event_routing_evidence_spec_" + run_id
    val report_path = build_dir + "/report.md"
    val receipt_path = build_dir + "/missing-receipt.env"
    val cmd = "BUILD_DIR=" + build_dir + " REPORT_PATH=" + report_path +
        " SIMPLE_WEB_FONT_RUN_ID=" + run_id +
        " SIMPLE_WEB_FONT_COMPOSITION_RECEIPT=" + receipt_path +
        " sh scripts/check/check-wm-browser-event-routing-evidence.shs"
    process_run_timeout("/bin/sh", ["-c", cmd], 5000)

fn _report_path(run_id: text) -> text:
    "build/tmp/wm_browser_event_routing_evidence_spec_" + run_id + "/report.md"

describe "WM browser event routing evidence":

    it "fails closed when a valid Simple run ID has no composition receipt":
        step("Provide a valid caller-supplied Simple run ID")
        val run_id = _run_id()
        val result = _run_checker(run_id)

        step("Reject the missing authoritative composition receipt before Electron")
        expect(result[2]).to_be_greater_than(0)
        expect(result[0]).to_contain("wm_browser_event_routing_status=fail")
        expect(result[0]).to_contain("wm_browser_event_routing_reason=missing-simple-web-font-composition-receipt")

        val report = file_read_text(_report_path(run_id)) ?? ""
        expect(report).to_contain("- status: fail")
        expect(report).to_contain("- reason: missing-simple-web-font-composition-receipt")
