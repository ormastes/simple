# @tag:system
# @tag:gui
# @tag:qemu
#
# Live QEMU smoke for the SimpleOS WM input lane.
#
# This boots the small wm_input_test_entry kernel and checks the guest-side
# click/focus/drag markers. The entry exits through isa-debug-exit after the
# marker sequence, so the serial contract is the proof signal.

use std.spec.*
use std.io_runtime.{getpid, time_now_unix_micros}

use os.kernel.arch.arch_context.{Architecture}
use os.qemu_runner.{OsTarget, build_os}

use test.system.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, run_os_qemu_with_target_via_timeout,
    spawn_guest_with_qmp, stop_guest, wait_for_serial_marker, read_serial_log,
    read_qemu_stderr_log}

extern fn rt_get_cwd() -> text
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn _run_id() -> text:
    getpid().to_text() + "_" + time_now_unix_micros().to_text()

fn _run_dir(run_id: text) -> text:
    "build/tmp/wm_input_qemu_smoke_spec_" + run_id

fn _qmp_socket(run_id: text) -> text:
    "/tmp/wm_input_qemu_smoke_qmp_" + run_id + ".sock"

fn _serial_log(run_id: text) -> text:
    _run_dir(run_id) + "/serial.log"

fn _capture_ppm(cwd: text, run_id: text) -> text:
    cwd + "/" + _run_dir(run_id) + "/capture.ppm"

fn _wm_input_target() -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/wm_input_test_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_wm_input_test_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "512M",
        qemu_bios: "",
        qemu_extra: ["-vga", "std", "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: false
    )

fn _build_once(target: OsTarget) -> bool:
    if not file_exists(target.output):
        return build_os(target)
    val newer = rt_process_run_timeout("sh", ["-c", "test \"$1\" -nt \"$2\"", "sh", target.entry, target.output], 2000)
    if newer[2] == 0:
        return build_os(target)
    true

fn _build_or_report_blocker(target: OsTarget) -> bool:
    val built = _build_once(target)
    if not built:
        print "[wm_input_qemu_smoke_spec] live WM input smoke blocked: wm_input_test_entry does not link"
        print "[wm_input_qemu_smoke_spec] expected kernel artifact was not produced: {target.output}"
        print "[wm_input_qemu_smoke_spec] known linker blocker: undefined globals from examples/simple_os/arch/x86_64/wm_input_test_entry.spl"
    built

fn _known_build_blocker_evidence(target: OsTarget) -> text:
    "[wm_input_qemu_smoke_spec] live WM input smoke blocked: wm_input_test_entry does not link\n" +
        "[wm_input_qemu_smoke_spec] expected kernel artifact was not produced: {target.output}\n" +
        "[wm_input_qemu_smoke_spec] known linker blocker: undefined globals from {target.entry}"

fn _capture_and_assert_input_ppm(qmp_socket: text, output_path: text) -> bool:
    val script = "import json,os,socket,sys,time;" +
        "sock,out=sys.argv[1],sys.argv[2];" +
        "s=socket.socket(socket.AF_UNIX);s.settimeout(5);s.connect(sock);" +
        "f=s.makefile('rwb',buffering=0);" +
        "f.readline();" +
        "f.write(json.dumps(dict(execute='qmp_capabilities')).encode()+b'\\n');f.flush();f.readline();" +
        "f.write(json.dumps(dict(execute='human-monitor-command',arguments=dict([('command-line','screendump '+out)]))).encode()+b'\\n');f.flush();" +
        "f.readline();" +
        "ok=any((time.sleep(0.1) or (os.path.exists(out) and os.path.getsize(out)>0)) for _ in range(100));" +
        "b=open(out,'rb').read() if ok else b'';" +
        "lines=b.splitlines()[:3];" +
        "w,h=map(int,lines[1].split()) if ok and len(lines)>=3 else (0,0);" +
        "p=b.find(b'\\n255\\n')+5;" +
        "pix=b[p:];" +
        "rgb=lambda x,y: pix[(y*w+x)*3:(y*w+x)*3+3];" +
        "near=lambda g,e,t: len(g)==3 and all(abs(g[i]-e[i])<=t for i in range(3));" +
        "title=near(rgb(90,100),bytes([0x20,0x50,0xA0]),8);" +
        "drag=near(rgb(460,270),bytes([0x44,0xFF,0x44]),8);" +
        "bg=near(rgb(10,10),bytes([0x10,0x18,0x20]),8);" +
        "print('dims=%dx%d checks=[bg=%s,title=%s,drag=%s]' % (w,h,bg,title,drag));" +
        "sys.exit(0 if ok and w==1024 and h==768 and bg and title and drag else 4)"
    val result = rt_process_run_timeout("python3", ["-c", script, qmp_socket, output_path], 20000)
    if result[0] != "":
        print "[wm_input_qemu_smoke_spec] qmp ppm {result[0]}"
    if result[1] != "":
        print "[wm_input_qemu_smoke_spec] qmp ppm stderr: {result[1]}"
    result[2] == 0 and file_exists(output_path)

fn _print_guest_diagnostics(prefix: text, serial: text, stderr: text):
    print "{prefix} serial_len={serial.len()} stderr_len={stderr.len()}"
    if serial != "":
        print "{prefix} serial:\n{serial}"
    if stderr != "":
        print "{prefix} qemu stderr:\n{stderr}"

describe "SimpleOS WM input smoke in QEMU":

    it "builds the WM input test entry":
        val target = _wm_input_target()
        expect(_build_or_report_blocker(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

    it "boots and emits focus plus drag markers":
        val target = _wm_input_target()
        val built = _build_or_report_blocker(target)
        if not built:
            val blocker_evidence = _known_build_blocker_evidence(target)
            expect(blocker_evidence.contains("live WM input smoke blocked")).to_equal(true)
            expect(blocker_evidence.contains(target.output)).to_equal(true)
            expect(blocker_evidence.contains(target.entry)).to_equal(true)
        else:
            if not can_run_target(target):
                print "[wm_input_qemu_smoke_spec] qemu-system-x86_64 not available, skipping live WM input smoke"
                expect(file_exists(target.output)).to_equal(true)
            else:
                val result = run_os_qemu_with_target_via_timeout(target, "20s", 30000)
                val serial = result[0] + result[1]
                val saw_init = serial.contains("[wm-input-test] Init synthetic input path")
                val saw_focus = serial.contains("[wm-input-test] focus click OK")
                val saw_drag = serial.contains("[wm-input-test] drag OK -> 444,252")
                val saw_pass = serial.contains("[PASS] wm_input_test_entry")
                val saw_test_passed = serial.contains("TEST PASSED")

                if not saw_init or not saw_focus or not saw_drag or not saw_pass or not saw_test_passed:
                    print "[wm_input_qemu_smoke_spec] missing marker init={saw_init} focus={saw_focus} drag={saw_drag} pass={saw_pass} test_passed={saw_test_passed} exit={result[2]}"
                    print "[wm_input_qemu_smoke_spec] serial follows:\n{serial}"

                expect(saw_init).to_equal(true)
                expect(saw_focus).to_equal(true)
                expect(saw_drag).to_equal(true)
                expect(saw_pass).to_equal(true)
                expect(saw_test_passed).to_equal(true)

    it "captures framebuffer markers for focus and drag state":
        val target = _wm_input_target()
        val built = _build_or_report_blocker(target)
        if not built:
            val blocker_evidence = _known_build_blocker_evidence(target)
            expect(blocker_evidence.contains("known linker blocker")).to_equal(true)
            expect(blocker_evidence.contains(target.output)).to_equal(true)
            expect(blocker_evidence.contains(target.entry)).to_equal(true)
        else:
            if not can_run_target(target):
                print "[wm_input_qemu_smoke_spec] qemu-system-x86_64 not available, skipping framebuffer smoke"
                expect(file_exists(target.output)).to_equal(true)
            else:
                val cwd = rt_get_cwd()
                val run_id = _run_id()
                val run_dir = _run_dir(run_id)
                expect(rt_dir_create_all(run_dir)).to_equal(true)
                val qmp_socket = _qmp_socket(run_id)
                val serial_log = _serial_log(run_id)
                val capture_ppm = _capture_ppm(cwd, run_id)
                match spawn_guest_with_qmp(target, qmp_socket, serial_log):
                    Ok(handle):
                        val saw_fb = wait_for_serial_marker(handle, "[wm-input-test] framebuffer marker OK", 30000)
                        val serial = read_serial_log(handle)
                        if not saw_fb:
                            print "[wm_input_qemu_smoke_spec] missing framebuffer marker"
                            _print_guest_diagnostics("[wm_input_qemu_smoke_spec]", serial, read_qemu_stderr_log(handle))
                            stop_guest(handle)
                            expect(saw_fb).to_equal(true)
                        else:
                            val captured = _capture_and_assert_input_ppm(qmp_socket, capture_ppm)
                            if not captured:
                                print "[wm_input_qemu_smoke_spec] QMP screendump or framebuffer pixel assertion failed"
                                _print_guest_diagnostics("[wm_input_qemu_smoke_spec]", serial, read_qemu_stderr_log(handle))
                                stop_guest(handle)
                                expect(captured).to_equal(true)
                            else:
                                stop_guest(handle)
                                expect(file_exists(capture_ppm)).to_equal(true)
                    Err(err):
                        print "[wm_input_qemu_smoke_spec] failed to spawn guest: {err}"
                        expect(false).to_equal(true)
