fn resume_authorized_oversized_request(port: i32, token: text) -> text:
    val body = "x".repeat(UI_WEB_MAX_AUTH_JSON_BYTES + 1)
    return resume_authorized_request(port, token, body)

fn websocket_unauthorized_request(port: i32) -> text:
    var request = "GET /ui/ws HTTP/1.1\r\n"
    request = "{request}Host: 127.0.0.1:{port}\r\n"
    request = "{request}Origin: http://127.0.0.1:{port}\r\n"
    request = "{request}Upgrade: websocket\r\n"
    request = "{request}Connection: Upgrade\r\n"
    request = "{request}Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
    request = "{request}Sec-WebSocket-Version: 13\r\n"
    request = "{request}\r\n"
    return request

