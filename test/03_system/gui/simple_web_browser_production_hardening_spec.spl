    return "POST /ui/login HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nOrigin: http://127.0.0.1:{port}\r\nContent-Type: application/json\r\nContent-Length: {body.len()}\r\nContent-Length: {body.len()}\r\nConnection: close\r\n\r\n{body}"

fn oversized_head_request(port: i32) -> text:
    val pad = "x".repeat(UI_WEB_MAX_REQUEST_HEAD_BYTES + 1)
    return "GET / HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nX-Pad: {pad}\r\nConnection: close\r\n\r\n"

fn oversized_request_line_request(port: i32) -> text:
    val pad = "x".repeat(UI_WEB_MAX_REQUEST_LINE_BYTES + 1)
    return "GET /{pad} HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nConnection: close\r\n\r\n"

fn oversized_header_line_request(port: i32) -> text:
    val pad = "x".repeat(UI_WEB_MAX_HEADER_LINE_BYTES + 1)
