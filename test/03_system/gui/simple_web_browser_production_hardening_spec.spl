# @cover src/app/ui.web/server.spl 80%
# @cover src/app/ui.web/auth_params.spl 80%
# @gui: headless
# @tag:system, slow

use std.spec.*
use std.nogc_sync_mut.io.tcp.{TcpStream}

extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_thread_sleep(ms: i64)
extern fn rt_getpid() -> i64
extern fn rt_bytes_to_text(data: [u8]) -> text

fn hardening_free_port(extra: i32) -> i32:
    val base = 21000
    val pid_offset = rt_getpid() % 10000
    return base + pid_offset as i32 + extra

fn hardening_start_web_server(port: i32) -> i64:
    val cmd = "exec env SIMPLE_LIB=src SIMPLE_UI_WEB_TOKEN_SECRET=simple-web-hardening-test-secret SIMPLE_WEB_HARDENING_PORT={port} src/compiler_rust/target/release/simple run test/03_system/gui/ui_browser/simple_web_hardening_server.spl --mode=interpreter >/tmp/simple_web_hardening_{port}.log 2>&1"
    val pid = rt_process_spawn_async("sh", ["-c", cmd])
    hardening_wait_for_server(port)
    return pid

fn hardening_wait_for_server(port: i32):
    rt_thread_sleep(3500)

fn hardening_stop_web_server(pid: i64):
    if pid > 0:
        rt_process_kill(pid)

fn raw_http_request(port: i32, request: text) -> text:
    val addr = "127.0.0.1:{port}"
    match TcpStream.connect_timeout(addr, 2000):
        Err(e):
            return "CONNECT_FAILED: {e}"
        Ok(stream):
            stream.set_read_timeout(2000)
            match stream.write_text(request):
                Err(e):
                    stream.close()
                    return "WRITE_FAILED: {e}"
                Ok(()):
                    stream.flush()
                    match stream.read(4096):
                        Err(e):
                            stream.close()
                            return "READ_FAILED: {e}"
                        Ok(bytes):
                            stream.close()
                            return rt_bytes_to_text(bytes)

fn http_status_line(response: text) -> text:
    if response.starts_with("HTTP/1.1 403 Forbidden"):
        return "HTTP/1.1 403 Forbidden"
    if response.starts_with("HTTP/1.1 413 Payload Too Large"):
        return "HTTP/1.1 413 Payload Too Large"
    if response.starts_with("HTTP/1.1 101 Switching Protocols"):
        return "HTTP/1.1 101 Switching Protocols"
    if response.starts_with("HTTP/1.1 200 OK"):
        return "HTTP/1.1 200 OK"
    "unexpected"

fn http_marker(response: text, marker: text) -> text:
    if response.contains(marker):
        return "present"
    "missing"

fn http_json_string_field(response: text, field: text) -> text:
    val key = "\"{field}\""
    val key_pos = response.find(key)
    if key_pos < 0:
        return ""
    var pos = key_pos + key.len()
    while pos < response.len() and response.slice(pos, pos + 1) != ":":
        pos = pos + 1
    if pos >= response.len():
        return ""
    pos = pos + 1
    while pos < response.len() and (response.slice(pos, pos + 1) == " " or response.slice(pos, pos + 1) == "\r" or response.slice(pos, pos + 1) == "\n"):
        pos = pos + 1
    if pos >= response.len() or response.slice(pos, pos + 1) != "\"":
        return ""
    pos = pos + 1
    val start = pos
    while pos < response.len():
        if response.slice(pos, pos + 1) == "\"":
            return response.slice(start, pos)
        pos = pos + 1
    return ""

fn raw_http_summary(port: i32, request: text, marker: text) -> text:
    val response = raw_http_request(port, request)
    return "{http_status_line(response)}|{http_marker(response, marker)}"

fn login_missing_origin_request(port: i32) -> text:
    val body = "{\"capability_grant\":\"legacy\"}"
    return "POST /ui/login HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nContent-Type: application/json\r\nContent-Length: {body.len()}\r\nConnection: close\r\n\r\n{body}"

fn login_oversized_request(port: i32) -> text:
    return "POST /ui/login HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nOrigin: http://localhost:{port}\r\nContent-Type: application/json\r\nContent-Length: 8193\r\nConnection: close\r\n\r\n"

fn login_allowed_request(port: i32) -> text:
    val body = "{\"capability_grant\":\"legacy\"}"
    return "POST /ui/login HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nOrigin: http://localhost:{port}\r\nContent-Type: application/json\r\nContent-Length: {body.len()}\r\nConnection: close\r\n\r\n{body}"

fn api_state_unauthorized_request(port: i32) -> text:
    return "GET /api/state HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nOrigin: http://localhost:{port}\r\nConnection: close\r\n\r\n"

fn websocket_unauthorized_request(port: i32) -> text:
    var request = "GET /ui/ws HTTP/1.1\r\n"
    request = "{request}Host: 127.0.0.1:{port}\r\n"
    request = "{request}Origin: http://localhost:{port}\r\n"
    request = "{request}Upgrade: websocket\r\n"
    request = "{request}Connection: Upgrade\r\n"
    request = "{request}Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
    request = "{request}Sec-WebSocket-Version: 13\r\n"
    request = "{request}\r\n"
    return request

fn websocket_authorized_request(port: i32, token: text) -> text:
    var request = "GET /ui/ws HTTP/1.1\r\n"
    request = "{request}Host: 127.0.0.1:{port}\r\n"
    request = "{request}Origin: http://localhost:{port}\r\n"
    request = "{request}Upgrade: websocket\r\n"
    request = "{request}Connection: Upgrade\r\n"
    request = "{request}Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
    request = "{request}Sec-WebSocket-Version: 13\r\n"
    request = "{request}Sec-WebSocket-Protocol: simple-ui, bearer.{token}\r\n"
    request = "{request}\r\n"
    return request

describe "Simple web browser production hardening live endpoints":
    slow_it "fails closed on unauthenticated browser HTTP and WebSocket routes":
        """A production server must reject unauthenticated browser entrypoints before exposing state or upgrading sockets."""
        val port = hardening_free_port(0)
        step("Start a production-configured Simple Web server with a real token secret")
        val pid = hardening_start_web_server(port)

        step("Send unauthenticated requests to login, API, and WebSocket routes")
        val missing_origin = raw_http_summary(port, login_missing_origin_request(port), "forbidden_origin")
        val oversized_login = raw_http_summary(port, login_oversized_request(port), "request_body_too_large")
        val api_state = raw_http_summary(port, api_state_unauthorized_request(port), "\"error\": \"forbidden\"")
        val websocket = raw_http_summary(port, websocket_unauthorized_request(port), "\"error\": \"forbidden\"")

        hardening_stop_web_server(pid)

        step("Verify every unauthenticated route fails closed with a concrete status and marker")
        expect(missing_origin).to_equal("HTTP/1.1 403 Forbidden|present")
        expect(oversized_login).to_equal("HTTP/1.1 413 Payload Too Large|present")
        expect(api_state).to_equal("HTTP/1.1 403 Forbidden|present")
        expect(websocket).to_equal("HTTP/1.1 403 Forbidden|present")

    slow_it "mints an origin-bound token and redeems it for a websocket upgrade":
        """The positive production path must mint a token for the request origin and accept that token during WebSocket upgrade."""
        val port = hardening_free_port(100)
        step("Start a fresh production-configured Simple Web server")
        val pid = hardening_start_web_server(port)

        step("Request a login token from an allowed loopback origin")
        val login_response = raw_http_request(port, login_allowed_request(port))
        val token = http_json_string_field(login_response, "token")

        step("Redeem the minted bearer token through the WebSocket subprotocol list")
        val websocket_response = raw_http_request(port, websocket_authorized_request(port, token))
        val websocket = "{http_status_line(websocket_response)}|{http_marker(websocket_response, "Sec-WebSocket-Protocol: simple-ui")}"

        hardening_stop_web_server(pid)

        step("Verify login succeeds and the WebSocket upgrade echoes only the safe simple-ui protocol")
        expect(http_status_line(login_response)).to_equal("HTTP/1.1 200 OK")
        expect(token.len()).to_be_greater_than(20)
        expect(websocket).to_equal("HTTP/1.1 101 Switching Protocols|present")
