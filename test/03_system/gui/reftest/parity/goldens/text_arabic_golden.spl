# Golden fixture: text_arabic — fabricated glyph-like SkPath (no shaper dependency)
# Draws a simple abstract glyph shape that stands in for Arabic text rendering.

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_path}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_black}
use std.skia.entity.enums.{SkPathFillType}

fn _glyph_path() -> SkPath:
    # Fabricated glyph: a rounded hook shape approximating an Arabic letter body
    # Built from straight lines to avoid shaper dependency
    val base = sk_path_new()
    # Outer contour — a simple closed shape
    val p1  = base.move_to(80.0, 60.0)
    val p2  = p1.line_to(176.0, 60.0)
    val p3  = p2.line_to(176.0, 100.0)
    val p4  = p3.line_to(140.0, 100.0)
    val p5  = p4.line_to(140.0, 160.0)
    val p6  = p5.line_to(160.0, 180.0)
    val p7  = p6.line_to(140.0, 200.0)
    val p8  = p7.line_to(100.0, 200.0)
    val p9  = p8.line_to(80.0, 180.0)
    val p10 = p9.line_to(80.0, 60.0)
    val p11 = p10.close()
    # Inner cutout (counter) for the glyph
    val p12 = p11.move_to(100.0, 80.0)
    val p13 = p12.line_to(156.0, 80.0)
    val p14 = p13.line_to(156.0, 100.0)
    val p15 = p14.line_to(100.0, 100.0)
    val p16 = p15.close()
    p16.with_fill_type(SkPathFillType.EvenOdd)

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    val path = _glyph_path()
    val paint = sk_paint_fill(sk_color_black())
    val op = sk_picture_op_draw_path(path, paint)
    val ops = [op]
    val picture = SkPicture(cull_rect: cull, op_count: 1, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
