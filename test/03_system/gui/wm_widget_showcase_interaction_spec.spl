"""
# WM Widget Showcase Interaction System Spec

Pins the live hosted-widget-showcase contract: Winit events are routed into the
shared HostCompositor state, the taskbar uses the compositor's hit geometry, and
the app fails closed when launched outside a GUI environment.
"""

# @tag: system, gui, wm, event, taskbar, environment

use std.spec.*
use std.io_runtime.{file_read}
use app.io.mod.{process_spawn_async, process_kill, file_exists, file_read_text, file_write, file_read_bytes, dir_create_all, getpid, time_now_unix_micros, thread_sleep}
use common.window_protocol.geometry.{Size}
use common.ui.wm_app_process_contract.{
    WM_CLIENT_HOLD_ENV,
    WM_EVENT_FILE_ENV,
    WM_FRAME_SEQ_FILE_ENV,
    WIDGET_SHOWCASE_APP_SOURCE,
    wm_fs_app_event,
    wm_fs_app_event_encode,
    wm_fs_bridge_decode,
    wm_widget_showcase_client_env,
    wm_widget_showcase_event_path,
    wm_widget_showcase_frame_seq_path,
}
use os.compositor.host_compositor_entry.{
    HostCompositor,
    HeadlessHostCompositorBackend,
    host_compositor_pointer_move,
    host_compositor_left_button_at,
    host_compositor_focused_window_id,
    host_compositor_minimize_focused,
    host_taskbar_item_x,
    host_taskbar_item_width,
}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW}

val W: i32 = 820
val H: i32 = 620
val ENTRY: text = "examples/06_io/ui/wm_widget_showcase_gui.spl"
val SHOWCASE_SOURCE: text = "examples/06_io/ui/widget_showcase_gui.spl"

fn src() -> text:
    file_read(ENTRY)

fn showcase_src() -> text:
    file_read(SHOWCASE_SOURCE)

fn _comp() -> HostCompositor:
    val backend = HeadlessHostCompositorBackend.new(W, H)
    val comp = HostCompositor.new(backend, Size.wh(W, H))
    comp.apply_bridge_request(1, 701, COMP_CREATE_WINDOW.to_i64(), 0, "Widget Showcase", 54, 70, 708, 456, "showcase", 9201, "/examples/widget-showcase")
    comp

fn _two_window_comp() -> HostCompositor:
    val backend = HeadlessHostCompositorBackend.new(W, H)
    val comp = HostCompositor.new(backend, Size.wh(W, H))
    comp.apply_bridge_request(1, 701, COMP_CREATE_WINDOW.to_i64(), 0, "Widget Showcase", 54, 70, 708, 456, "showcase", 9201, "/examples/widget-showcase")
    comp.apply_bridge_request(2, 702, COMP_CREATE_WINDOW.to_i64(), 0, "Inspector", 120, 140, 360, 220, "inspect", 9202, "/examples/inspector")
    comp

fn _index_of(comp: HostCompositor, id: i64) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].id == id:
            return i
        i = i + 1
    -1

fn _taskbar_click_x(comp: HostCompositor, id: i64) -> i32:
    val count = comp.windows.len().to_i32()
    val item_w = host_taskbar_item_width(W, count)
    host_taskbar_item_x(W, count, _index_of(comp, id)) + item_w / 2

describe "WM showcase live wrapper source contract":

    it "routes real Winit mouse events into the shared host compositor":
        val s = src()
        expect(s).to_contain("fn apply_wm_input")
        expect(s).to_contain("winit_wait_input(lp, wait_ms)")
        expect(s).to_contain("host_compositor_pointer_move")
        expect(s).to_contain("host_compositor_left_button_at")
        expect(s).to_contain("input.click_buttons")
        expect(s).to_contain("input.click_pressed")
        expect(s).to_contain("[wm-showcase] input left_button")

    it "does not discard events inside render_and_present":
        val s = src()
        val render_pos = s.index_of("fn render_and_present")
        val input_pos = s.index_of("fn apply_wm_input")
        expect(render_pos >= 0).to_equal(true)
        expect(input_pos > render_pos).to_equal(true)
        val render_body = s.substring(render_pos, input_pos)
        expect(render_body.contains("winit_poll_input")).to_equal(false)

    it "draws the taskbar from the shared theme and host taskbar geometry":
        val s = src()
        expect(s).to_contain("wm_chrome_theme()")
        expect(s).to_contain("theme.taskbar")
        expect(s).to_contain("theme.command_lane")
        expect(s).to_contain("theme.accent")
        expect(s).to_contain("theme.host_window_body")
        expect(s).to_contain("theme.close_button")
        expect(s).to_contain("host_taskbar_dock_width")
        expect(s).to_contain("host_taskbar_item_width")
        expect(s).to_contain("host_taskbar_item_x")

    it "creates the child process window through COMP_CREATE_WINDOW":
        val s = src()
        expect(s).to_contain("HostCompositor.new")
        expect(s).to_contain("COMP_CREATE_WINDOW.to_i64()")
        expect(s).to_contain("req.title")
        expect(s).to_contain("req.pid")
        expect(s).to_contain("[wm-showcase] launched source=")

    it "launches the same showcase source from the filesystem as a child process":
        val s = src()
        expect(s).to_contain("process_spawn_async")
        expect(s).to_contain("bin/simple")
        expect(s).to_contain("WIDGET_SHOWCASE_APP_SOURCE")
        expect(s).to_contain("showcase_source_path")
        expect(s).to_contain("[\"run\", showcase_source_path]")
        expect(s).to_contain("wm_widget_showcase_client_env")
        expect(s).to_contain("SHOWCASE_PPM_SCALE")
        expect(s).to_contain("process_kill(child_pid)")

    # codex-system-test
    it "forwards child-content pointer events through the shared filesystem bridge":
        val s = src()
        expect(s).to_contain("WM_EVENT_FILE_ENV")
        expect(s).to_contain("wm_fs_app_event_encode")
        expect(s).to_contain("write_child_pointer_event")
        expect(s).to_contain("child_event_seq")
        expect(s).to_contain("child_local_at")
        expect(s).to_contain("win.x + 4")
        expect(s).to_contain("win.y + 28")
        expect(s).to_contain("file_write")
        expect(s).to_contain("child_pointer_down")
        expect(s).to_contain("child_drag_forwarding")
        expect(s).to_contain("child_needs_press_stream")
        expect(s).to_contain("x >= 134 and x < 199")
        expect(s).to_contain("elif not pressed")

    # codex-system-test
    it "keeps taskbar and window chrome events on the host compositor path":
        val s = src()
        expect(s).to_contain("host_compositor_pointer_move")
        expect(s).to_contain("host_compositor_left_button_at")
        expect(s).to_contain("win.x + win.w - 24")
        expect(s).to_contain("draw_taskbar_engine")
