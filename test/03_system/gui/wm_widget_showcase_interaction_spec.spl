    # codex-system-test
    it "refreshes child frames when bridge sequence or progress animation advances":
        val wm = src()
        expect(wm).to_contain("last_frame_seq")
        expect(wm).to_contain("req.frame_seq_path")
        expect(wm).to_contain("load_child_frame")
