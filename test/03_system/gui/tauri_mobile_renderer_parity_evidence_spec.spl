"""
# Tauri mobile renderer parity evidence

## Overview

Checks the aggregate evidence wrapper for Tauri v2 mobile renderer parity.
Positive evidence must include the desktop production backend contract, real
mobile PNG screenshots, MDI render/event/capture/performance/interaction/
animation proof rows, iOS Metal markers, and Android Vulkan markers.

**Plan:** doc/03_plan/agent_tasks/gui_web_mobile_renderer_hardening_resume_2026-06-28.md
**Requirements:** doc/02_requirements/feature/production_gui_web_renderer_parity_hardening.md
**Research:** doc/01_research/platform/mobile_android_ios_app_support_2026-04-24.md
**Design:** doc/05_design/ui/misc/production_gui_web_renderer_parity_hardening.md

## Syntax

```sh
SIMPLE_LIB=src bin/simple test test/03_system/gui/tauri_mobile_renderer_parity_evidence_spec.spl --mode=interpreter --clean --fail-fast
```

## Acceptance

- Passing evidence requires production GUI/Web backend parity evidence.
- iOS evidence must include WKWebView/Tauri2 proof plus Metal markers.
- Android evidence must include Android WebView/Tauri2 proof plus Vulkan
  markers.
- Event, capture, performance, interaction latency, and animation proof rows
  are surfaced in the report.
"""

# @tag: system, gui, tauri, mobile, ios, android, metal, vulkan

use std.io_runtime.{file_read, process_run}
use std.spec.*

fn _write_script(path: text, body: text) -> text:
    "cat > " + path + " <<'EOF'\n#!/bin/sh\n" + body + "\nEOF\nchmod +x " + path

fn _png(path: text) -> text:
    "node - " + path + " <<'NODE'\n" +
    "const fs=require('fs'),zlib=require('zlib');const p=process.argv[2],w=390,h=844,c=3;\n" +
    "function chunk(t,d){const b=Buffer.alloc(12+d.length);b.writeUInt32BE(d.length,0);b.write(t,4,4,'ascii');d.copy(b,8);return b;}\n" +
    "const sig=Buffer.from('89504e470d0a1a0a','hex');const ihdr=Buffer.alloc(13);ihdr.writeUInt32BE(w,0);ihdr.writeUInt32BE(h,4);ihdr[8]=8;ihdr[9]=2;\n" +
    "const raw=Buffer.alloc((w*c+1)*h);let o=0;for(let y=0;y<h;y++){raw[o++]=0;for(let x=0;x<w;x++){raw[o++]=(x%16)*16;raw[o++]=(y%16)*16;raw[o++]=((x+y)%16)*16;}}\n" +
    "fs.writeFileSync(p,Buffer.concat([sig,chunk('IHDR',ihdr),chunk('IDAT',zlib.deflateSync(raw)),chunk('IEND',Buffer.alloc(0))]));\n" +
    "NODE\n"

fn _production_env(path: text) -> text:
    "printf 'production_gui_web_renderer_parity_status=pass\\n" +
    "production_gui_web_renderer_parity_layout_manifest_status=pass\\n" +
    "production_gui_web_renderer_parity_surface_manifest_status=pass\\n" +
    "production_gui_web_renderer_parity_surface_manifest_no_fake_capture=true\\n" +
    "production_gui_web_renderer_parity_backend_status=pass\\n" +
    "production_gui_web_renderer_parity_backend_exact=true\\n" +
    "production_gui_web_renderer_parity_backend_cpu_simd_different_pixels=0\\n" +
    "production_gui_web_renderer_parity_backend_metal_resolved=metal\\n" +
    "production_gui_web_renderer_parity_backend_metal_different_pixels=0\\n" +
    "production_gui_web_renderer_parity_backend_metal_gpu_frame_complete=true\\n" +
    "production_gui_web_renderer_parity_backend_metal_command_queue_handle=42\\n" +
    "production_gui_web_renderer_parity_backend_software_checksum=900\\n" +
    "production_gui_web_renderer_parity_backend_cpu_simd_checksum=900\\n" +
    "production_gui_web_renderer_parity_backend_metal_checksum=900\\n" +
    "production_gui_web_renderer_parity_backend_metal_gpu_readback_checksum=900\\n" +
    "production_gui_web_renderer_parity_backend_checksum_match=true\\n" +
    "production_gui_web_renderer_parity_backend_same_frame_readback=true\\n" +
    "production_gui_web_renderer_parity_backend_blur_or_tolerance_used=false\\n" +
    "production_gui_web_renderer_parity_backend_sample_count=3\\n" +
    "production_gui_web_renderer_parity_backend_total_elapsed_us_min=90\\n" +
    "production_gui_web_renderer_parity_backend_total_elapsed_us_avg=100\\n" +
    "production_gui_web_renderer_parity_backend_total_elapsed_us_max=120\\n" +
    "production_gui_web_renderer_parity_backend_total_pixels_per_second_min=2000000\\n" +
    "production_gui_web_renderer_parity_backend_total_pixels_per_second_avg=2400000\\n" +
    "production_gui_web_renderer_parity_backend_total_pixels_per_second_max=2800000\\n" +
    "production_gui_web_renderer_parity_backend_timing_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_required_api=metal\\n" +
    "production_gui_web_renderer_parity_metal_render_log_generated_readback_gate_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_framebuffer_readback_gate_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_browser_backing_gate_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_pairwise_gate_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_argb_source_gate_status=pass\\n" +
    "production_gui_web_renderer_parity_metal_render_log_gpu_capture_gate_status=not-required\\n" +
    "production_gui_web_renderer_parity_metal_render_log_blocked_gate_count=0\\n' > " + path

fn _lane_script(path: text, root: text, platform: text, gpu_marker: text) -> text:
    val prefix = if platform == "ios": "ios" else: "android"
    val log_name = if platform == "ios": "log_stream" else: "logcat"
    val screenshot = root + "/" + platform + "/screenshot.png"
    val proof = root + "/" + platform + "/proof.json"
    val log = root + "/" + platform + "/" + log_name + ".txt"
    val log_line = "[tauri-shell] render, html_len=347702 " + gpu_marker + " openWindow id=terminal openWindow id=files openWindow id=tasks openWindow id=settings"
    val body = "mkdir -p " + root + "/" + platform + "\n" +
        _png(screenshot) +
        "printf '" + log_line + "\\n' > " + log + "\n" +
        "printf '{\"windowCount\":4,\"renderImageCount\":1,\"htmlRenderable\":true,\"taskbarItemCount\":4,\"taskbarIconCount\":4,\"hasDesktop\":true,\"dragRuntimeAvailable\":true,\"dragEventsAvailable\":true,\"dragMoved\":true,\"windowEventRuntimeAvailable\":true,\"appActionControlFound\":true,\"appInputControlFound\":true,\"bodyClickRouted\":true,\"bodyInputRouted\":true,\"bodyKeyRouted\":true,\"eventSequence\":[\"window_drag:move\",\"app_action:body_click\",\"app_input:body_input\",\"app_key:body_key\"],\"taskbarIconsVisible\":true,\"taskbarLabelsVisible\":true,\"captureViewportWidth\":390,\"captureViewportHeight\":844,\"captureDevicePixelRatio\":3,\"captureScreenOrientation\":\"portrait\",\"performanceNowAvailable\":true,\"performanceNowDeltaMs\":1.25,\"inputToPaintMs\":2.5,\"animationFrameAvailable\":true,\"animationFrameCount\":2,\"cssAnimationProbe\":true}\\n' > " + proof + "\n" +
        "echo " + prefix + "_screenshot=" + screenshot + "\n" +
        "echo " + prefix + "_" + log_name + "=" + log + "\n" +
        "echo " + prefix + "_mdi_proof_json=" + proof + "\n" +
        "echo " + prefix + "_mdi_proof_status=pass\n" +
        "echo " + prefix + "_mdi_proof_requested_source_count=1\n" +
        "echo " + prefix + "_mdi_proof_source_count=1\n" +
        "echo " + prefix + "_mdi_proof_marker_source_count=1\n" +
        "echo " + prefix + "_mdi_proof_missing_source_count=0\n" +
        "echo " + prefix + "_mdi_proof_empty_source_count=0\n" +
        "echo " + prefix + "_mdi_proof_symlink_source_count=0\n" +
        "echo " + prefix + "_mdi_proof_duplicate_source_count=0\n" +
        "echo " + prefix + "_mdi_proof_marker_source_path=" + log + "\n" +
        "echo " + prefix + "_mdi_proof_marker_source_size_bytes=$(wc -c < " + log + " | tr -d ' ')\n" +
        "echo " + prefix + "_mdi_render_status=pass\n" +
        "echo " + prefix + "_mdi_event_status=pass\n" +
        "echo " + prefix + "_mdi_capture_status=pass\n" +
        "echo " + prefix + "_mdi_performance_status=pass\n" +
        "echo " + prefix + "_mdi_interaction_latency_status=pass\n" +
        "echo " + prefix + "_mdi_animation_status=pass\n" +
        "echo " + prefix + "_mdi_proof_window_count=4\n" +
        "echo " + prefix + "_mdi_render_image_count=1\n" +
        "echo " + prefix + "_mdi_render_html_renderable=true\n" +
        "echo " + prefix + "_mdi_event_taskbar_item_count=4\n" +
        "echo " + prefix + "_mdi_event_taskbar_icon_count=4\n" +
        "echo " + prefix + "_mdi_event_has_desktop=true\n" +
        "echo " + prefix + "_mdi_event_drag_runtime_available=true\n" +
        "echo " + prefix + "_mdi_event_drag_events_available=true\n" +
        "echo " + prefix + "_mdi_event_drag_moved=true\n" +
        "echo " + prefix + "_mdi_event_window_event_runtime_available=true\n" +
        "echo " + prefix + "_mdi_event_app_action_control_found=true\n" +
        "echo " + prefix + "_mdi_event_app_input_control_found=true\n" +
        "echo " + prefix + "_mdi_event_body_click_routed=true\n" +
        "echo " + prefix + "_mdi_event_body_input_routed=true\n" +
        "echo " + prefix + "_mdi_event_body_key_routed=true\n" +
        "echo " + prefix + "_mdi_event_sequence=window_drag:move,app_action:body_click,app_input:body_input,app_key:body_key\n" +
        "echo " + prefix + "_mdi_event_taskbar_icons_visible=true\n" +
        "echo " + prefix + "_mdi_event_taskbar_labels_visible=true\n" +
        "echo " + prefix + "_mdi_capture_viewport_width=390\n" +
        "echo " + prefix + "_mdi_capture_viewport_height=844\n" +
        "echo " + prefix + "_mdi_capture_device_pixel_ratio=3\n" +
        "echo " + prefix + "_mdi_capture_screen_orientation=portrait\n" +
        "echo " + prefix + "_mdi_performance_now_available=true\n" +
        "echo " + prefix + "_mdi_performance_now_delta_ms=1.25\n" +
        "echo " + prefix + "_mdi_input_to_paint_ms=2.5\n" +
        "echo " + prefix + "_mdi_animation_frame_available=true\n" +
        "echo " + prefix + "_mdi_animation_frame_count=2\n" +
        "echo " + prefix + "_mdi_css_animation_probe=true\n" +
        "echo status=pass"
    _write_script(path, body)

fn _run(root: text, ios_marker: text, android_marker: text) -> text:
    "rm -rf " + root + " && mkdir -p " + root + "/source && " +
        _production_env(root + "/source/production.env") + " && " +
        _lane_script(root + "/ios.sh", root, "ios", ios_marker) + " && " +
        _lane_script(root + "/android.sh", root, "android", android_marker) + " && " +
        "PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV=" + root + "/source/production.env TAURI_MOBILE_RENDERER_IOS_SCRIPT=" + root + "/ios.sh TAURI_MOBILE_RENDERER_ANDROID_SCRIPT=" + root + "/android.sh BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md sh scripts/check/check-tauri-mobile-renderer-parity-evidence.shs"

describe "Tauri mobile renderer parity evidence":

    it "passes with controlled mobile render, event, capture, perf, interaction, and animation evidence":
        val root = "build/test-tauri-mobile-renderer-parity-pass"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", _run(root, "CAMetalLayer Metal renderer ready", "Vulkan renderer ready")])
        expect(code).to_equal(0)

        val evidence = file_read(root + "/out/evidence.env")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_status=pass")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_ios_metal_log_status=pass")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_android_vulkan_log_status=pass")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_ios_mdi_interaction_latency_status=pass")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_android_mdi_interaction_latency_status=pass")
        val report = file_read(root + "/report.md")
        expect(report).to_contain("- iOS MDI render/event/capture/perf/interaction/animation: pass / pass / pass / pass / pass / pass")
        expect(report).to_contain("- Android MDI render/event/capture/perf/interaction/animation: pass / pass / pass / pass / pass / pass")

    it "fails closed when iOS evidence has no Metal render marker":
        val root = "build/test-tauri-mobile-renderer-parity-ios-no-metal"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", _run(root, "plain webkit log", "Vulkan renderer ready") + " || true"])
        expect(code).to_equal(0)

        val evidence = file_read(root + "/out/evidence.env")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_status=fail")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_reason=ios-metal-log-marker-missing")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_ios_metal_log_status=fail")

    it "fails closed when Android evidence has no Vulkan render marker":
        val root = "build/test-tauri-mobile-renderer-parity-android-no-vulkan"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", _run(root, "CAMetalLayer Metal renderer ready", "plain android webview log") + " || true"])
        expect(code).to_equal(0)

        val evidence = file_read(root + "/out/evidence.env")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_status=fail")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_reason=android-vulkan-log-marker-missing")
        expect(evidence).to_contain("tauri_mobile_renderer_parity_android_vulkan_log_status=fail")
