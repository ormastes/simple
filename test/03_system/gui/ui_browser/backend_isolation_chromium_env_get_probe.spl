# Probe for backend_isolation_chromium_facade_gap_b_spec.spl (system tier).
#
# Not a spec — a standalone program spawned as a subprocess so the spec can
# observe the WebRenderBackend chromium lane's real exit code/stderr under
# `SIMPLE_EXECUTION_MODE=interpret` without crashing the test runner's own
# process (see doc/08_tracking/bug/web_backend_env_get_alias_unresolved_interpret_2026-07-07.md
# — the failure this probes for is an uncaught interpreter error, not a
# catchable Result).

use std.gc_async_mut.gpu.browser_engine.web_render_backend.{web_render_backend}

fn main():
    val backend = web_render_backend("chromium", 4, 4)
    print "constructed"
    val pixels = backend.render_html_to_pixels("<html><body>gap-b-probe</body></html>")
    print "rendered pixels_len={pixels.len()}"
