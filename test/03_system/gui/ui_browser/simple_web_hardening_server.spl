use app.ui.web.server.{run_web}

extern fn rt_env_get(key: text) -> text

fn hardening_server_port() -> i32:
    val raw = rt_env_get("SIMPLE_WEB_HARDENING_PORT") ?? "3000"
    raw.to_int()

fn main() -> i64:
    run_web("test/03_system/gui/ui_browser/fixtures/hello.ui.sdn", hardening_server_port())
