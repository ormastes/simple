# @cover src/app/ui.render/widgets.spl 80%
# @gui: headless

# @tag:system

use std.spec.*

use nogc_sync_mut.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.widget.{UIState}
use common.ui.state.{init_state}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.browser.backend.{BrowserBackend}

# ============================================================================
# Test Group 1: Demo UI Widget Rendering
# ============================================================================

describe "Widget HTML Rendering — Demo UI":

    slow_it "renders demo.ui.sdn to HTML":
        val tree_result = parse_ui_to_tree("examples/06_io/ui/demo.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                expect(html.len()).to_be_greater_than(50)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "contains widget CSS classes":
        val tree_result = parse_ui_to_tree("examples/06_io/ui/demo.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                # HTML should contain widget type classes
                expect(html).to_contain("widget-")
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# Test Group 2: Minimal UI Widget Rendering
# ============================================================================

describe "Widget HTML Rendering — Minimal UI":

    slow_it "renders minimal.ui.sdn to HTML":
        val tree_result = parse_ui_to_tree("examples/06_io/ui/minimal.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                expect(html.len()).to_be_greater_than(0)
            Err(e) :
                expect(false).to_equal(true)

describe "Browser Backend Rendering — Hello GUI":

    slow_it "paints parsed SDN content into the framebuffer":
        val tree_result = parse_ui_to_tree("examples/06_io/ui/hello_gui.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = UIState.new(tree)
                val backend_result = BrowserBackend.create(96, 64, "software")
                match backend_result:
                    Ok(backend) :
                        backend.render_frame(tree, state)
                        expect(backend.framebuffer.pixel_at(1, 1)).to_equal(0xE0E0E0)
                        backend.shutdown()
                    Err(e) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# Test Group 3: Layout Containers
# ============================================================================

describe "Widget HTML Rendering — Layout Containers":

    slow_it "produces layout classes":
        val tree_result = parse_ui_to_tree("examples/06_io/ui/demo.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                # Layout types should produce CSS classes
                expect(html).to_contain("layout-")
            Err(e) :
                expect(false).to_equal(true)
