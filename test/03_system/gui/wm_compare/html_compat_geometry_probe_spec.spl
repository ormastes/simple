# @tag: sys, wm_compare, html_compat, geometry

use std.spec.{describe, it, expect}
use app.wm_compare.html_compat_geometry_probe.{html_compat_fixture_simple_boxes}
use app.wm_compare.electron_geometry_compare.{compare_electron_geometry_json}

fn _check_block_and_controls():
    val boxes_02 = html_compat_fixture_simple_boxes("02_block_boxes", 320, 240)
    expect(boxes_02.len()).to_equal(6)
    expect(boxes_02[0].label).to_equal("outer")
    expect(boxes_02[0].x).to_equal(8)
    expect(boxes_02[0].width).to_equal(304)
    expect(boxes_02[0].height).to_equal(80)
    expect(boxes_02[2].label).to_equal("middle")
    expect(boxes_02[2].width).to_equal(304)
    expect(boxes_02[5].label).to_equal("footer")
    expect(boxes_02[5].y).to_equal(68)

    expect(html_compat_fixture_simple_boxes("99_missing", 320, 240).len()).to_equal(0)

    val report = compare_electron_geometry_json(
        "electron_geometry", "simple_renderer_geometry",
        320, 240,
        "{\"items\":[{\"label\":\"outer\",\"x\":8,\"y\":8,\"width\":304,\"height\":80,\"text\":\"\"},{\"label\":\"header\",\"x\":8,\"y\":8,\"width\":120,\"height\":20,\"text\":\"\"},{\"label\":\"middle\",\"x\":8,\"y\":28,\"width\":304,\"height\":40,\"text\":\"\"},{\"label\":\"left\",\"x\":8,\"y\":28,\"width\":80,\"height\":20,\"text\":\"\"},{\"label\":\"right\",\"x\":8,\"y\":48,\"width\":80,\"height\":20,\"text\":\"\"},{\"label\":\"footer\",\"x\":8,\"y\":68,\"width\":120,\"height\":20,\"text\":\"\"}]}",
        boxes_02,
        "simple_renderer:02_block_boxes",
        "build/test/electron_geometry.json"
    )
    expect(report.status).to_equal("layout_match")
    expect(report.mismatch_count).to_equal(0)

    val boxes_03 = html_compat_fixture_simple_boxes("03_list", 320, 240)
    expect(boxes_03.len()).to_equal(4)
    expect(boxes_03[0].label).to_equal("list_root")
    expect(boxes_03[0].x).to_equal(8)
    expect(boxes_03[0].width).to_equal(304)
    expect(boxes_03[1].label).to_equal("list_item_0")
    expect(boxes_03[1].width).to_equal(80)
    expect(boxes_03[1].height).to_equal(12)
    expect(boxes_03[3].label).to_equal("list_item_2")
    expect(boxes_03[3].y).to_equal(32)

    val boxes_04 = html_compat_fixture_simple_boxes("04_button", 320, 240)
    expect(boxes_04.len()).to_equal(2)
    expect(boxes_04[0].label).to_equal("button_panel")
    expect(boxes_04[0].x).to_equal(18)
    expect(boxes_04[0].width).to_equal(204)
    expect(boxes_04[0].height).to_equal(63)
    expect(boxes_04[1].label).to_equal("primary_button")
    expect(boxes_04[1].x).to_equal(30)
    expect(boxes_04[1].width).to_equal(120)
    expect(boxes_04[1].height).to_equal(36)

    val boxes_05 = html_compat_fixture_simple_boxes("05_text_input", 320, 240)
    expect(boxes_05.len()).to_equal(2)
    expect(boxes_05[0].label).to_equal("panel")
    expect(boxes_05[0].x).to_equal(18)
    expect(boxes_05[0].width).to_equal(234)
    expect(boxes_05[0].height).to_equal(56)
    expect(boxes_05[1].label).to_equal("search_input")
    expect(boxes_05[1].x).to_equal(30)
    expect(boxes_05[1].width).to_equal(166)
    expect(boxes_05[1].height).to_equal(32)

    val boxes_06 = html_compat_fixture_simple_boxes("06_card_panel", 320, 240)
    expect(boxes_06.len()).to_equal(3)
    if boxes_06.len() != 3:
        return
    expect(boxes_06[0].label).to_equal("card_panel")
    expect(boxes_06[0].x).to_equal(16)
    expect(boxes_06[0].width).to_equal(240)
    expect(boxes_06[0].height).to_equal(90)
    expect(boxes_06[0].text).to_equal("Panel Status ready")
    expect(boxes_06[1].label).to_equal("card_title")
    expect(boxes_06[1].text).to_equal("Panel")
    expect(boxes_06[2].label).to_equal("card_body")
    expect(boxes_06[2].text).to_equal("Status ready")

    val boxes_07 = html_compat_fixture_simple_boxes("07_scrollable_list", 320, 240)
    expect(boxes_07.len()).to_equal(5)
    expect(boxes_07[0].label).to_equal("scroll_shell")
    expect(boxes_07[0].x).to_equal(12)
    expect(boxes_07[0].width).to_equal(68)
    expect(boxes_07[0].height).to_equal(38)
    expect(boxes_07[0].padding_left).to_equal(4)
    expect(boxes_07[0].padding_top).to_equal(4)
    expect(boxes_07[0].border_left).to_equal(0)
    expect(boxes_07[0].background_color).to_equal("rgb(248, 250, 252)")
    expect(boxes_07[1].label).to_equal("scroll_list")
    expect(boxes_07[1].width).to_equal(45)
    expect(boxes_07[2].label).to_equal("scroll_item_0")
    expect(boxes_07[2].width).to_equal(42)
    expect(boxes_07[2].background_color).to_equal("rgb(219, 234, 254)")
    expect(boxes_07[4].label).to_equal("scroll_item_2")
    expect(boxes_07[4].y).to_equal(32)

