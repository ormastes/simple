# @tag: sys, wm_compare, html_compat, corpus, slow

use std.spec.{describe, context, slow_it, expect}
use app.wm_compare.site_corpus.{
    build_famous_site_sample_corpus, build_famous_site_sample_manifest_sdn,
    famous_site_font_families,
    famous_site_sample_html_path, famous_site_sample_baseline_dir,
    famous_site_sample_chrome_ppm_path, famous_site_sample_chrome_metrics_path,
    famous_site_sample_production_simple_ppm_path,
    famous_site_sample_production_report_sdn_path,
    famous_site_sample_simple_ppm_path, famous_site_sample_report_sdn_path}
use app.wm_compare.site_corpus_layout_report.{
    build_site_corpus_layout_report, parse_site_corpus_layout_opts}
use app.wm_compare.html_compat.{compare_exact, compare_perceptual}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{SimpleWebRenderer, simple_web_render_html_to_pixels}
use std.gc_async_mut.gpu.browser_engine.simple_web_corpus_fixture_renderer.{simple_web_render_html_to_pixels_with_corpus_fixtures}
