# @tag: sys, wm, ui, theme, chrome
# @cover src/lib/common/ui/wm_chrome_theme.spl 90%
# @cover src/lib/common/ui/window_scene_draw_ir.spl 0%
#
# WM chrome theming contract.
#
# Proves that window-manager chrome colors (desktop, titlebars, taskbar,
# command lane) are resolved from the single wm_chrome_theme() accessor rather
# than hardcoded literals scattered across the render pipelines, and that
# installing a theme flows through to both the Draw IR projection and the
# direct-rect pixel fallback. The default palette must stay byte-identical to
# the historical literals so the existing WM bitmap-evidence gates are
# unaffected.
#
use std.spec.{describe, context, it, expect}
use common.ui.wm_chrome_theme.{wm_chrome_theme, wm_chrome_theme_defaults, register_wm_chrome_theme, reset_wm_chrome_theme, WmChromeColors}
use common.ui.window_scene_draw_ir.{shared_wm_scene_draw_ir_composition}
use common.ui.window_scene.{shared_wm_scene_from_window_manager}
use common.ui.window.{WindowManager}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry, UI_SURFACE_KIND_SIMPLE_WEB}
use common.ui.taskbar_model.{AppRef, TaskbarModel, WindowRef}
use common.ui.builder.{column, label, build_tree_with_title}
use common.ui.draw_ir.{DRAW_IR_BACKEND_GPU}
use os.compositor.wm_scene.{standard_wm_scene, render_scene_to_backend, WmSceneSpec}

fn _tree(title: text):
    build_tree_with_title(column("{title}_root", [label("{title}_label", title)]), title, "glass_dark")

fn _taskbar() -> TaskbarModel:
    TaskbarModel(
        pinned: [AppRef(app_id: "terminal", display_name: "Terminal", icon: "term")],
        running: [WindowRef(window_id: "win1", app_id: "demo.app", title: "One", minimized: false)],
        tray: []
    )

fn _scene():
    var manager = WindowManager.new()
    val _one = manager.open_window("surf1", "One", 10, 40, 300, 200, _tree("one"))
    var registry = UiWindowSurfaceRegistry.new()
    registry.bind_with_kind("win1", "surf1", 42u64, "demo.app", "One", UI_SURFACE_KIND_SIMPLE_WEB)
    shared_wm_scene_from_window_manager(manager, registry, 800, 600)

fn _custom_theme() -> WmChromeColors:
    WmChromeColors(
        desktop_bg: 0xff010203u32,
        compositor_bg: 0xff040506u32,
        command_lane: 0xff070809u32,
        taskbar: 0xff0a0b0cu32,
        text_primary: 0xff0d0e0fu32,
        title_focused: 0xff101112u32,
        title_unfocused: 0xff131415u32,
        window_shadow: 0x22000000u32,
        window_body: 0xff161718u32,
        host_window_body: 0xff191a1bu32,
        accent: 0xff1c1d1eu32,
        close_button: 0xff1f2021u32,
        background_hex: "#010203"
    )

describe "WM chrome theme accessor":

    it "defaults reproduce the historical chrome literals byte-for-byte":
        reset_wm_chrome_theme()
        val d = wm_chrome_theme_defaults()
        expect(d.desktop_bg).to_equal(0xff101418u32)
        expect(d.compositor_bg).to_equal(0xff0f172au32)
        expect(d.command_lane).to_equal(0xff182027u32)
        expect(d.taskbar).to_equal(0xff151a20u32)
        expect(d.text_primary).to_equal(0xffffffffu32)
        expect(d.title_focused).to_equal(0xff2f80edu32)
        expect(d.title_unfocused).to_equal(0xff25313au32)
        expect(d.window_shadow).to_equal(0x33000000u32)
        expect(d.window_body).to_equal(0xff20262du32)
        expect(d.host_window_body).to_equal(0xff1e293bu32)
        expect(d.accent).to_equal(0xff2563ebu32)
        expect(d.close_button).to_equal(0xffcc3333u32)
        expect(d.background_hex).to_equal("#101418")

    it "returns defaults when no theme is installed and honors a registered theme":
        reset_wm_chrome_theme()
        expect(wm_chrome_theme().desktop_bg).to_equal(0xff101418u32)
        register_wm_chrome_theme(_custom_theme())
        expect(wm_chrome_theme().desktop_bg).to_equal(0xff010203u32)
        expect(wm_chrome_theme().accent).to_equal(0xff1c1d1eu32)
        reset_wm_chrome_theme()
        expect(wm_chrome_theme().desktop_bg).to_equal(0xff101418u32)

describe "WM chrome theme drives the Draw IR projection":

    it "chrome batch colors come from the accessor (default palette)":
        reset_wm_chrome_theme()
        val theme = wm_chrome_theme()
        val comp = shared_wm_scene_draw_ir_composition(_scene(), _taskbar(), DRAW_IR_BACKEND_GPU, 1000, "09:41", 1)
        expect(comp.batches[0].commands[0].color).to_equal(theme.desktop_bg)
        expect(comp.batches[1].commands[0].color).to_equal(theme.command_lane)
        expect(comp.batches[1].commands[1].color).to_equal(theme.taskbar)
        expect(comp.batches[2].commands[1].color).to_equal(theme.window_body)

    it "installing a theme changes the projected chrome colors":
        register_wm_chrome_theme(_custom_theme())
        val comp = shared_wm_scene_draw_ir_composition(_scene(), _taskbar(), DRAW_IR_BACKEND_GPU, 1000, "09:41", 1)
        expect(comp.batches[0].commands[0].color).to_equal(0xff010203u32)
        expect(comp.batches[1].commands[0].color).to_equal(0xff070809u32)
        expect(comp.batches[1].commands[1].color).to_equal(0xff0a0b0cu32)
        expect(comp.batches[2].commands[1].color).to_equal(0xff161718u32)
        reset_wm_chrome_theme()
        val restored = shared_wm_scene_draw_ir_composition(_scene(), _taskbar(), DRAW_IR_BACKEND_GPU, 1000, "09:41", 1)
        expect(restored.batches[0].commands[0].color).to_equal(0xff101418u32)

describe "WM chrome theme drives the desktop-resolution pixel fallback":

    it "paints the themed desktop background and real scene elements at 1024x768":
        reset_wm_chrome_theme()
        val scene = standard_wm_scene(1024, 768)
        val pixels = render_scene_to_backend(scene, nil)
        expect(pixels.len().to_i32()).to_equal(1024 * 768)
        # desktop backdrop pixel = desktop_chrome element color
        expect(pixels[5 * 1024 + 5]).to_equal(0xFF0F172Au32)
        # decoration bar element (y 42..76) is a real rect, not near-blank
        expect(pixels[50 * 1024 + 100]).to_equal(0xFF334155u32)

    it "themed compositor background is the fallback base fill":
        reset_wm_chrome_theme()
        val empty = WmSceneSpec(name: "empty", width: 1024, height: 768, elements: [])
        val base_default = render_scene_to_backend(empty, nil)
        expect(base_default[767 * 1024 + 1023]).to_equal(0xff0f172au32)
        register_wm_chrome_theme(_custom_theme())
        val base_themed = render_scene_to_backend(empty, nil)
        expect(base_themed[767 * 1024 + 1023]).to_equal(0xff040506u32)
        reset_wm_chrome_theme()
