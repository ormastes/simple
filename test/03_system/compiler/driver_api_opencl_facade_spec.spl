# @cover src/compiler/80.driver/driver_api.spl 80%
# Driver API OpenCL Backend Helper - End-to-End Tests
#
# Verifies that the in-process driver API helper emits an OpenCL AOT artifact.

use std.spec

use compiler.driver.driver_api_codegen_backends.{aot_opencl_file}

val NL = "\n"

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool

describe "Driver API OpenCL Backend Helper":

    it "OpenCL AOT helper imports cleanly for a direct external caller":
        val src_path = "/tmp/sml_driver_api_opencl_kernel.spl"
        val opencl_out_path = "/tmp/sml_driver_api_opencl_kernel.cl"
        val source =
            "kernel add_kernel(a: i32, b: i32) -> i32:" + NL +
            "    return a + b" + NL
        rt_file_write_text(src_path, source)
        rt_file_delete(opencl_out_path)

        val opencl_result = aot_opencl_file(src_path, opencl_out_path)

        expect(opencl_result.is_success()).to_equal(true)
        expect(rt_file_exists(opencl_out_path)).to_equal(true)

        rt_file_delete(src_path)
        rt_file_delete(opencl_out_path)
        expect(rt_file_exists(opencl_out_path)).to_equal(false)
