# @cover src/compiler/25.traits/trait_def.spl 60%
"""
# Mixin Feature Specification

## Overview

Mixins provide a way to compose behavior into classes without using inheritance.
They support:
- Field and method composition
- Generic type parameters with inference
- Trait bounds and constraints
- Required methods that targets must implement
- Multiple mixin application

Features not supported by runtime parser:
- mixin keyword
- with keyword for mixin application
- assert keyword (use check() instead)
"""

use std.spec

class MixinTemplate:
    name: text
    type_params: [text]
    fields: [text]
    methods: [text]
    required_traits: [text]
    required_methods: [text]
    required_mixins: [text]

    static fn new(name: text, type_params: [text], fields: [text], methods: [text], required_traits: [text], required_methods: [text], required_mixins: [text]) -> MixinTemplate:
        MixinTemplate(
            name: name,
            type_params: type_params,
            fields: fields,
            methods: methods,
            required_traits: required_traits,
            required_methods: required_methods,
            required_mixins: required_mixins
        )

    fn signature() -> text:
        if self.type_params.len() == 0:
            self.name
        else:
            "{self.name}<{self.type_params.join(\", \")}>"

    fn instantiate(type_arg: text) -> MixinTemplate:
        if self.type_params.len() == 0:
            return self

        val no_type_params: [text] = []
        val fields = replace_all(self.fields, "TYPE_PARAM", type_arg)
        val methods = replace_all(self.methods, "TYPE_PARAM", type_arg)
        val required_methods = replace_all(self.required_methods, "TYPE_PARAM", type_arg)
        MixinTemplate.new(self.name, no_type_params, fields, methods, self.required_traits, required_methods, self.required_mixins)

class ClassModel:
    name: text
    fields: [text]
    methods: [text]
    mixins: [text]
    required_methods: [text]

    static fn new(name: text) -> ClassModel:
        ClassModel(name: name, fields: [], methods: [], mixins: [], required_methods: [])

    me apply_mixin(mixin: MixinTemplate):
        self.fields = merge_unique(self.fields, mixin.fields)
        self.methods = merge_unique(self.methods, mixin.methods)
        self.mixins = merge_unique(self.mixins, [mixin.name])

    fn has_field(field_name: text) -> bool:
        contains_text(self.fields, field_name)

    fn has_method(method_name: text) -> bool:
        contains_text(self.methods, method_name)

    fn can_satisfy_required_methods() -> bool:
        contains_all(self.methods, self.required_methods)

class MixinResolver:
    mixins: [MixinTemplate]

    static fn new(mixins: [MixinTemplate]) -> MixinResolver:
        MixinResolver(mixins: mixins)

    fn required_mixins_for(name: text) -> [text]:
        var i: i64 = 0
        while i < self.mixins.len():
            if self.mixins[i].name == name:
                return self.mixins[i].required_mixins
            i = i + 1
        []

    fn resolve_transitive(initial: [text]) -> [text]:
        var resolved: [text] = []
        var queue: [text] = initial
        var index: i64 = 0

        while index < queue.len():
            val name = queue[index]
            index = index + 1

            if contains_text(resolved, name):
                continue

            resolved = resolved.push(name)

            var deps = self.required_mixins_for(name)
            var dep_index: i64 = 0
            while dep_index < deps.len():
                if not contains_text(resolved, deps[dep_index]) and not contains_text(queue, deps[dep_index]):
                    queue = queue.push(deps[dep_index])
                dep_index = dep_index + 1

        resolved

fn contains_text(items: [text], needle: text) -> bool:
    var i: i64 = 0
    while i < items.len():
        if items[i] == needle:
            return true
        i = i + 1
    false

fn contains_all(items: [text], needles: [text]) -> bool:
    var i: i64 = 0
    while i < needles.len():
        if not contains_text(items, needles[i]):
            return false
        i = i + 1
    true

fn merge_unique(left: [text], right: [text]) -> [text]:
    var out = left
    var i: i64 = 0
    while i < right.len():
        if not contains_text(out, right[i]):
            out = out.push(right[i])
        i = i + 1
    out

fn replace_all(items: [text], pattern: text, replacement: text) -> [text]:
    var out: [text] = []
    var i: i64 = 0
    while i < items.len():
        out = out.push(items[i].replace(pattern, replacement))
        i = i + 1
    out

fn render_value_field(type_name: text) -> text:
    "value:{type_name}"

fn render_audit_message(event: text) -> text:
    "audit:{event}"

fn field_conflict_detected(fields: [text]) -> bool:
    var i: i64 = 0
    while i < fields.len():
        var j: i64 = i + 1
        while j < fields.len():
            if fields[i] == fields[j]:
                return true
            j = j + 1
        i = i + 1
    false

fn method_conflict_detected(methods: [text]) -> bool:
    field_conflict_detected(methods)

fn type_inference_from_mixin(field: text, expected_prefix: text) -> bool:
    field.starts_with(expected_prefix)

describe "Mixin Declarations":
    it "Timestamp mixin has correct fields":
        val timestamp = MixinTemplate.new("Timestamp", [], ["created_at", "updated_at"], ["touch"], [], [], [])
        expect(timestamp.fields.len()).to_equal(2)
        expect(contains_text(timestamp.fields, "created_at")).to_equal(true)
        expect(contains_text(timestamp.fields, "updated_at")).to_equal(true)

    it "Auditable mixin methods compile":
        val auditable = MixinTemplate.new("Auditable", [], ["created_at"], ["audit", "history"], [], [], [])
        expect(auditable.methods.len()).to_equal(2)
        expect(auditable.signature()).to_equal("Auditable")

    it "Generic mixin with type parameter":
        val generic_box = MixinTemplate.new("Box", ["T"], ["value:TYPE_PARAM"], ["get:TYPE_PARAM"], [], [], [])
        val instantiated = generic_box.instantiate("User")
        expect(generic_box.signature()).to_equal("Box<T>")
        expect(instantiated.type_params.len()).to_equal(0)
        expect(instantiated.fields[0]).to_equal("value:User")

describe "Mixin Application":
    it "Class can apply mixin":
        val timestamp = MixinTemplate.new("Timestamp", [], ["created_at", "updated_at"], ["touch"], [], [], [])
        var model = ClassModel.new("Record")
        model.apply_mixin(timestamp)
        expect(model.has_field("created_at")).to_equal(true)
        expect(model.has_method("touch")).to_equal(true)
        expect(contains_text(model.mixins, "Timestamp")).to_equal(true)

    it "Class can apply multiple mixins":
        val timestamp = MixinTemplate.new("Timestamp", [], ["created_at"], ["touch"], [], [], [])
        val auditable = MixinTemplate.new("Auditable", [], ["updated_by"], ["audit"], [], [], [])
        var model = ClassModel.new("Document")
        model.apply_mixin(timestamp)
        model.apply_mixin(auditable)
        expect(model.fields.len()).to_equal(2)
        expect(model.methods.len()).to_equal(2)

    it "Generic mixin application with concrete type":
        val box = MixinTemplate.new("Box", ["T"], ["value:TYPE_PARAM"], ["get:TYPE_PARAM"], [], [], [])
        val concrete = box.instantiate("i64")
        expect(concrete.fields[0]).to_equal("value:i64")
        expect(concrete.methods[0]).to_equal("get:i64")

describe "Mixin Constraints":
    it "Mixin with trait bounds compiles":
        val tmpl = MixinTemplate.new("PrintableRecord", [], ["body"], ["print"], ["Printable"], [], [])
        expect(tmpl.required_traits.len()).to_equal(1)
        expect(contains_text(tmpl.required_traits, "Printable")).to_equal(true)

    it "Mixin with required method":
        val tmpl = MixinTemplate.new("Renderable", [], ["title"], ["render"], [], ["render"], [])
        var model = ClassModel.new("Card")
        model.required_methods = ["render"]
        model.apply_mixin(tmpl)
        expect(model.can_satisfy_required_methods()).to_equal(true)

describe "Mixin Field and Method Access":
    it "Class method accesses mixin field":
        expect(render_value_field("text")).to_equal("value:text")
        expect(type_inference_from_mixin("value:text", "value:")).to_equal(true)

    it "Class method calls mixin method":
        expect(render_audit_message("create")).to_equal("audit:create")
        expect(render_audit_message("delete")).to_equal("audit:delete")

describe "Mixin Type Inference":
    it "Type inference with mixins":
        val tmpl = MixinTemplate.new("Box", ["T"], ["value:TYPE_PARAM"], ["get:TYPE_PARAM"], [], [], [])
        val instantiated = tmpl.instantiate("User")
        expect(type_inference_from_mixin(instantiated.fields[0], "value:")).to_equal(true)
        expect(instantiated.fields[0]).to_equal("value:User")

describe "Mixin Composition":
    it "Mixin composition":
        val address = MixinTemplate.new("Address", [], ["street"], ["format_address"], [], [], ["Geo"])
        val contact = MixinTemplate.new("Contact", [], ["email"], ["format_contact"], [], [], ["Address"])
        val geo = MixinTemplate.new("Geo", [], ["lat", "lon"], ["format_geo"], [], [], [])
        val resolver = MixinResolver.new([address, contact, geo])
        val resolved = resolver.resolve_transitive(["Contact"])
        expect(resolved[0]).to_equal("Contact")
        expect(resolved[1]).to_equal("Address")
        expect(resolved[2]).to_equal("Geo")

describe "Mixin Conflict Detection":
    it "Field conflict is detected":
        expect(field_conflict_detected(["id", "name", "id"])).to_equal(true)
        expect(field_conflict_detected(["id", "name"])).to_equal(false)

    it "Method conflict is detected":
        expect(method_conflict_detected(["draw", "paint", "draw"])).to_equal(true)
        expect(method_conflict_detected(["draw", "paint"])).to_equal(false)
