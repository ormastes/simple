struct CustomPrefixOwner:
    marker: i64

impl CustomPrefixOwner:
    fn starts_with(prefix: text) -> bool:
        self.marker == 41 and prefix == "@"

fn exercise_custom_owner() -> bool:
    val owner = CustomPrefixOwner(marker: 41)
    owner.starts_with("@")

fn exercise_css_text_owner() -> bool:
    val css: text = "@media (min-width: 1px) { .panel { color: red; } }"
    val parts = css.split("{")
    val opener: text = parts[0].trim()
    opener.starts_with("@")

fn main():
    if not exercise_custom_owner():
        print "TEXT_PREDICATE_OWNER_COLLISION_FAIL custom-owner"
        return
    if not exercise_css_text_owner():
        print "TEXT_PREDICATE_OWNER_COLLISION_FAIL text-owner"
        return
    print "TEXT_PREDICATE_OWNER_COLLISION_PASS"
