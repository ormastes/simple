use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_result
}

fn fallback_valid(label: text, html: text) -> bool:
    print "WEB_MATERIAL_FALLBACK_CSS_STATE_STAGE {label} software-start"
    val software = simple_web_layout_render_html_software_result(html, 24, 16)
    print "WEB_MATERIAL_FALLBACK_CSS_STATE_STAGE {label} software-done"
    software.material_fallback.kind == "solid-material" and software.material_fallback.material_sha256.len() == 64

fn main():
    val plain = "<div data-wm-theme-fallback='solid-material' data-wm-theme-bg='#123456' data-wm-theme-fg='#FEDCBA' style='width:24px;height:16px;background:rgba(255,0,0,0.2);backdrop-filter:blur(12px)'>plain</div>"
    val multilayer = "<div data-wm-theme-fallback='solid-material' data-wm-theme-bg='#123456' data-wm-theme-fg='#FEDCBA' style='width:24px;height:16px;background:radial-gradient(circle,#FF0000,#0000FF),rgba(255,0,0,0.2);backdrop-filter:blur(12px)'>multilayer</div>"
    if fallback_valid("plain", plain) and fallback_valid("multilayer", multilayer):
        print "WEB_MATERIAL_FALLBACK_CSS_STATE_PASS"
    else:
        print "WEB_MATERIAL_FALLBACK_CSS_STATE_FAIL"
