# @cover src/compiler_rust/compiler/src/pipeline/codegen.rs 80%
# HIP Backend CLI Smoke Tests
#
# Verifies that the compile command emits HIP C++ source for the HIP backend.

use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn delete_if_exists(path: text):
    if rt_file_exists(path):
        rt_file_delete(path)

describe "HIP backend CLI smoke":

    it "bin/simple compile --backend=hip writes HIP C++ output":
        val src_path = "/tmp/sml_driver_api_hip_kernel.spl"
        val hip_out_path = "/tmp/sml_driver_api_hip_kernel.hip.cpp"
        val source =
            "kernel add_kernel(a: i32, b: i32) -> i32:\n" +
            "    return a + b\n"
        delete_if_exists(src_path)
        delete_if_exists(hip_out_path)
        rt_file_write_text(src_path, source)

        val (_stdout, _stderr, code) = rt_process_run("bin/simple", ["compile", "--backend=hip", src_path, "-o", hip_out_path])

        expect(code).to_equal(0)
        expect(rt_file_exists(hip_out_path)).to_equal(true)
        val output = rt_file_read_text(hip_out_path)
        expect(output).to_contain("Generated by Simple compiler (HIP backend)")
        expect(output).to_contain("extern \"C\" __global__ void add_kernel(long p0, long p1)")
        expect(output).to_contain("return;")

        delete_if_exists(src_path)
        delete_if_exists(hip_out_path)
        expect(rt_file_exists(hip_out_path)).to_equal(false)
