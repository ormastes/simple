"""
# Vector font compute evidence

## Overview

Validates that the vector font compute evidence script forces its generated
Simple probes through the interpreter path and emits real CPU glyph/readback
context even when CUDA/OpenCL glyph kernels are unavailable on the host.

**Plan:** doc/03_plan/sys_test/html_css_spec_traceability.md
**Requirements:** N/A
**Research:** N/A
**Design:** doc/07_guide/tooling/renderdoc_capture_infra.md

## Syntax

```sh
SIMPLE_LIB=src bin/simple test/03_system/check/vector_font_compute_evidence_spec.spl
```

## Acceptance

- The script does not misclassify JIT symbol failures as vector font evidence
  failure.
- CPU glyph metrics are emitted in the unavailable-accelerator path.
"""

# @tag: system, gui, font, evidence

use std.io_runtime.{file_read, process_run}
use std.spec.*

describe "Vector font compute evidence":

    it "forces interpreter execution for generated Simple probes":
        val script = file_read("scripts/check/check-vector-font-compute-evidence.shs")
        expect(script).to_contain("SIMPLE_EXECUTION_MODE=\"${SIMPLE_EXECUTION_MODE:-interpret}\"")

        val font_script = file_read("scripts/check/check-production-gui-font-offload-evidence.shs")
        expect(font_script).to_contain("SIMPLE_EXECUTION_MODE=\"${SIMPLE_EXECUTION_MODE:-interpret}\"")

    it "emits CPU glyph evidence instead of JIT symbol-failure unavailable evidence":
        val command = "rm -rf build/test-vector-font-compute-evidence && VECTOR_FONT_TEXT_RUN=GUIWM VECTOR_FONT_SIZE=24 VECTOR_FONT_ITERATIONS=1 BUILD_DIR=build/test-vector-font-compute-evidence REPORT_PATH=build/test-vector-font-compute-evidence/report.md sh scripts/check/check-vector-font-compute-evidence.shs"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
        expect(code).to_equal(0)

        val evidence = file_read("build/test-vector-font-compute-evidence/evidence.env")
        expect(evidence).to_contain("vector_font_compute_status=pass")
        expect(evidence).to_contain("vector_font_compute_offload_status=accelerator-unavailable")
        expect(evidence).to_contain("vector_font_compute_gpu_glyph_returned=false")
        expect(evidence).to_contain("vector_font_compute_production_offload_ready=false")
        expect(evidence).to_contain("vector_font_compute_cpu_checksum=6140562")
        expect(evidence).to_contain("vector_font_compute_cpu_ink_pixels=105")
        expect(evidence).to_contain("vector_font_compute_production_vector_raster_hits=5")
        expect(evidence).to_contain("vector_font_compute_production_cpu_fallback_hits=5")
        expect(evidence).to_contain("vector_font_compute_production_gpu_returned_glyphs=0")
        expect(evidence).to_contain("vector_font_compute_production_accelerator_unavailable_reason=production-gpu-dispatch-not-wired")

        val simple_out = file_read("build/test-vector-font-compute-evidence/simple.out")
        expect(simple_out.contains("can't resolve symbol spl_dlopen")).to_equal(false)
        expect(simple_out.contains("simple-vector-font-evidence-failed")).to_equal(false)
