        expect(script).to_contain("production_gui_web_renderer_parity_metal_readback_simple_bin_status=$simple_bin_status")

    it "prints production parity blocker summary rows for operator triage":
        val script = file_read("scripts/check/check-production-gui-web-renderer-parity-evidence.shs")
        expect(script).to_contain("emit_summary_env()")
        expect(script).to_contain("production_gui_web_renderer_parity_surface_manifest_tauri_live_capture")
        expect(script).to_contain("production_gui_web_renderer_parity_surface_manifest_chrome_live_capture")
