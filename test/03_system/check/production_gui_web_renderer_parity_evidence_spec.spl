        expect(script).to_contain("production_gui_web_renderer_parity_event_routing_status")

    it "rejects Rust seed Simple binary in Metal framebuffer readback evidence":
        val script = file_read("scripts/check/check-metal-engine2d-framebuffer-readback-evidence.shs")
        expect(script).to_contain("SIMPLE_BIN_SOURCE=")
        expect(script).to_contain("SIMPLE_BIN_STATUS=pass")
        expect(script).to_contain("\"bin/simple\"")
        expect(script).to_contain("\"bin/release\"/*/simple")
        expect(script).to_contain("is_rust_seed_simple")
        expect(script).to_contain("SIMPLE_BIN_STATUS=forbidden")
        expect(script).to_contain("export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS")
        expect(script).to_contain("metal_engine2d_framebuffer_readback_simple_bin=$SIMPLE_BIN")
        expect(script).to_contain("metal_engine2d_framebuffer_readback_simple_bin_source=$SIMPLE_BIN_SOURCE")
        expect(script).to_contain("metal_engine2d_framebuffer_readback_simple_bin_status=$SIMPLE_BIN_STATUS")

        val root = "build/test-metal-engine2d-framebuffer-readback-seed-forbidden"
        val command = "rm -rf " + root + " && SIMPLE_BIN=src/compiler_rust/target/release/simple BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md sh scripts/check/check-metal-engine2d-framebuffer-readback-evidence.shs || true"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
        expect(code).to_equal(0)

        val evidence = file_read(root + "/out/evidence.env")
        expect(evidence).to_contain("metal_engine2d_framebuffer_readback_status=unavailable")
        expect(evidence).to_contain("metal_engine2d_framebuffer_readback_reason=simple-bin-forbidden")
        expect(evidence).to_contain("metal_engine2d_framebuffer_readback_simple_bin=src/compiler_rust/target/release/simple")
        expect(evidence).to_contain("metal_engine2d_framebuffer_readback_simple_bin_status=forbidden")

    it "selects only self hosted backend simple candidates by default":
        val script = file_read("scripts/check/check-production-gui-web-backend-executed-evidence.shs")
        expect(script).to_contain("SIMPLE_BIN_EXPLICIT=")
        expect(script).to_contain("repo-self-hosted-fallback")
        expect(script).to_contain("\"bin/simple\"")
        expect(script).to_contain("\"bin/release\"/*/simple")
