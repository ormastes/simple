"""
# WM GUI Window Drawing Evidence Gate Contract

## Overview

Pins the structural contract of the WM GUI window-drawing capture gate
(`scripts/check/check-wm-gui-window-drawing-evidence.shs` driving
`src/os/compositor/wm_gui_window_drawing_evidence.spl`), which proves both WM
lanes — the compositor scene/CSS lane (`os.compositor.wm_scene`) and the
hosted-compositor chrome lane (`os.compositor.host_compositor_entry`) —
actually draw desktop chrome, windows/titlebars/taskbar, and correctly-sized
text at 1024x768, and fails closed on a blank frame, missing text/titlebar
ink, or the giant-text "font:" shorthand regression (CSS weight parsed as
font size).

This spec exercises the script's Simple-binary selection, its fail-closed
metric classification, and the driver's metric definitions deterministically
so the structural contract is pinned without paying for the multi-minute
capture pipeline (see the layer expert handoff: `wm_scene.scene_to_html()`
embeds one large WM chrome stylesheet on every call, so a single
`render_scene_to_backend()` call is stylesheet-bound, not pixel-bound, and
routinely takes minutes under the interpreter).

**Plan:** N/A
**Requirements:** N/A
**Design:** doc/00_llm_process/feature_expert/wm_gui_window_drawing/skill.md

## Syntax

```sh
SIMPLE_LIB=src bin/simple test test/03_system/check/wm_gui_window_drawing_spec.spl --mode=interpreter --clean --fail-fast
```

## Acceptance

- The check script selects a self-hosted Simple binary by default and rejects
  an explicit Rust seed override with `simple-bin-forbidden` before launching
  the driver.
- The check script's per-scene classification checks all three scenes
  (`wm_scene_css`, `wm_scene_windows`, `host_compositor`) and fails closed on
  a missing/non-numeric metric, a near-blank frame, missing text ink, a
  missing titlebar/accent band, or a giant-glyph pathology
  (`max_glyph_run_px >= GIANT_GLYPH_RUN_PX`).
- The driver emits the same metric key names the check script parses, and its
  background-literal / bright / accent-spread definitions mirror the existing
  `validate_hosted_wm_capture_ppm.spl` precedent.
- The driver's per-pixel measurement pass is inlined (no per-pixel helper
  function calls) — a documented interpreter-performance requirement, not a
  style preference.
"""

# @tag: system, gui, wm, compositor, capture

use std.io_runtime.{file_read, process_run}
use std.spec.*

describe "WM GUI window drawing check script contract":

    it "selects self-hosted Simple and rejects the Rust seed before rendering":
        val script = file_read("scripts/check/check-wm-gui-window-drawing-evidence.shs")
        expect(script).to_contain("is_rust_seed_simple")
        expect(script).to_contain("rust-seed-simple-bin-forbidden")
        expect(script).to_contain("\"release\"/*/simple")
        expect(script).to_contain("\"bin/release\"/*/simple")
        expect(script).to_contain("\"build/bootstrap/stage3/simple\"")
        expect(script).to_contain("\"bin/simple\"")
        expect(script).to_contain("missing-command:sips")

    it "classifies all three scenes and fails closed on each pathology class":
        val script = file_read("scripts/check/check-wm-gui-window-drawing-evidence.shs")
        expect(script).to_contain("wm_scene_css wm_scene_windows host_compositor")
        expect(script).to_contain("ppm-write-failed")
        expect(script).to_contain("png-conversion-failed")
        expect(script).to_contain("blank-or-near-blank-frame")
        expect(script).to_contain("missing-text-ink")
        expect(script).to_contain("missing-titlebar-accent")
        expect(script).to_contain("giant-glyph-pathology")
        expect(script).to_contain("GIANT_GLYPH_RUN_PX")
        # Text presence and the glyph detector key off exact-white INK pixels,
        # not the near-white "bright" class: the WM glass panels rasterize
        # large near-white gradients (a correct standard_wm_scene render
        # measured a 425px bright vertical run — panel body, not text). Slow
        # render is reported, not failed (documented interpreter stylesheet
        # cost, ~243s measured at 1024x768).
        expect(script).to_contain("MIN_INK_PIXELS")
        expect(script).to_contain("SCENE_SLOW=")
        # One driver process per scene: a renderer crash in one lane (e.g.
        # the chromed scene's "cannot assign to const 'child_styles'" abort)
        # must not erase the other lanes' captures.
        expect(script).to_contain("WM_GUI_WINDOW_DRAWING_SCENE=")
        expect(script).to_contain("driver-crashed")

    it "writes the fail-closed report with per-scene PPM/PNG paths and metrics":
        val script = file_read("scripts/check/check-wm-gui-window-drawing-evidence.shs")
        expect(script).to_contain("build/wm_gui_window_drawing")
        expect(script).to_contain("report.md")
        expect(script).to_contain("max_glyph_run_px")
        expect(script).to_contain("non_bg_pixels")
        expect(script).to_contain("ink_pixels (exact-white text)")
        expect(script).to_contain("bright_pixels (near-white, incl. glass panels)")
        expect(script).to_contain("accent_pixels (saturated / titlebar band)")

    it "rejects explicit Rust seed before the driver or sips conversion run":
        val root = "build/test-wm-gui-window-drawing-seed-forbidden"
        val command = "rm -rf " + root + " && mkdir -p " + root + " && SIMPLE_BIN=src/compiler_rust/target/debug/simple BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md sh scripts/check/check-wm-gui-window-drawing-evidence.shs > " + root + "/stdout.txt 2> " + root + "/stderr.txt || true"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
        expect(code).to_equal(0)

        val output = file_read(root + "/stdout.txt")
        expect(output).to_contain("wm_gui_window_drawing_status=unavailable")
        expect(output).to_contain("wm_gui_window_drawing_reason=rust-seed-simple-bin-forbidden")

        val report = file_read(root + "/report.md")
        expect(report).to_contain("- reason: rust-seed-simple-bin-forbidden")
        val (_out, _err, capture_code) = process_run("/bin/sh", ["-c", "test ! -f " + root + "/out/simple.log"])
        expect(capture_code).to_equal(0)

describe "WM GUI window drawing driver contract":

    it "renders all three scenes through both WM lanes with matching metric keys":
        val driver = file_read("src/os/compositor/wm_gui_window_drawing_evidence.spl")
        expect(driver).to_contain("standard_wm_scene")
        expect(driver).to_contain("shared_wm_scene_to_chromed_wm_scene")
        expect(driver).to_contain("render_scene_to_backend")
        expect(driver).to_contain("HostCompositor")
        expect(driver).to_contain("HeadlessHostCompositorBackend")
        expect(driver).to_contain("apply_bridge_request")
        expect(driver).to_contain("comp.render_frame()")
        expect(driver).to_contain("backend.pixels")
        expect(driver).to_contain("_render_ms=")
        expect(driver).to_contain("_non_bg_pixels=")
        expect(driver).to_contain("_bright_pixels=")
        expect(driver).to_contain("_ink_pixels=")
        expect(driver).to_contain("_accent_pixels=")
        expect(driver).to_contain("_max_glyph_run_px=")

    it "mirrors the hosted-WM-capture metric definitions (background / bright / accent)":
        val driver = file_read("src/os/compositor/wm_gui_window_drawing_evidence.spl")
        expect(driver).to_contain("r != BG_R or g != BG_G or b != BG_B")
        expect(driver).to_contain("r > 210 and g > 210 and b > 210")
        expect(driver).to_contain("r == 255 and g == 255 and b == 255")
        expect(driver).to_contain("mx - mn > 65")
        val validator = file_read("scripts/check/validate_hosted_wm_capture_ppm.spl")
        expect(validator).to_contain("r != 15 or g != 23 or b != 42")
        expect(validator).to_contain("r > 210 and g > 210 and b > 210")
        expect(validator).to_contain("max3(r, g, b) - min3(r, g, b) > 65")

    it "keeps the per-pixel measurement pass inlined (no per-pixel helper calls)":
        # Interpreter-performance requirement, not a style preference: an
        # earlier version with per-pixel _channel_r/_channel_g/_channel_b +
        # _max3/_min3/_is_bright helper calls did not finish measuring even
        # one 1024x768 (786432px) scene inside a 300s budget. See the
        # feature-expert handoff notes.
        val driver = file_read("src/os/compositor/wm_gui_window_drawing_evidence.spl")
        expect_not(driver.contains("fn _channel_r"))
        expect_not(driver.contains("fn _is_bright"))
        expect(driver).to_contain("col_run")
