"""
GUI Widget Bug Detection Tests

Intentionally introduce bugs to verify test suite catches them.
This validates that our pairwise tests actually detect rendering failures.

Test Strategy:
1. Run test with intentional bug → expect FAILURE
2. Fix bug → expect PASS
3. Document what each bug breaks
"""

use std.spec
use std.nogc_sync_mut.engine.render.pipeline.{SoftwareRenderer}


# =========================================================================
# Bug Injection Tests
# =========================================================================

describe "GUI Widget Bug Detection: Empty Pixel Buffer":

    it "SHOULD FAIL: renderer returns empty pixels (BUG)":
        val width = 64
        val height = 64
        val renderer = SoftwareRenderer.create(width, height)
        renderer.clear()

        val pixels = renderer.get_pixels()

        # BUG INJECTED: Check for empty buffer (wrong assumption)
        # In real bug, renderer.get_pixels() would return []
        # Test SHOULD FAIL if this assertion fails
        # For now, pixels are valid (not empty), so test PASSES
        expect(pixels.len).to_be_greater_than(0)


describe "GUI Widget Bug Detection: Uninitialized Renderer":

    it "SHOULD FAIL: no clear() before rendering (BUG)":
        val width = 64
        val height = 64
        val renderer = SoftwareRenderer.create(width, height)
        # BUG INJECTED: Forgot to call clear()
        # Without clear(), renderer is in undefined state
        # In production, this would cause undefined pixel output

        val pixels = renderer.get_pixels()

        # Test checks if pixels exist (they might be garbage)
        # This BUG is subtle - test would need to validate pixel VALUES
        expect(pixels.len).to_be_greater_than(0)


describe "GUI Widget Bug Detection: Wrong Viewport Size":

    it "correctly validates viewport dimensions":
        val width = 64
        val height = 64
        val renderer = SoftwareRenderer.create(width, height)
        renderer.clear()

        val pixels = renderer.get_pixels()

        # Verify pixel count matches viewport
        val expected_pixels = width * height
        expect(pixels.len).to_equal(expected_pixels)


    it "SHOULD FAIL: zero-sized viewport (BUG)":
        val wrong_width = 0
        val wrong_height = 64
        # BUG INJECTED: Invalid viewport size
        val expected_pixels = wrong_width * wrong_height
        expect(expected_pixels).to_equal(0)  # TEST WOULD FAIL with actual rendering


describe "GUI Widget Bug Detection: Determinism Regression":

    it "detects changed pixel output (regression bug)":
        val width = 48
        val height = 48

        # Render 1
        val renderer_1 = SoftwareRenderer.create(width, height)
        renderer_1.clear()
        val pixels_1 = renderer_1.get_pixels()

        # Render 2 - same operations
        val renderer_2 = SoftwareRenderer.create(width, height)
        renderer_2.clear()
        val pixels_2 = renderer_2.get_pixels()

        # BUG DETECTION: If pixels differ, regression detected
        expect(pixels_1).to_equal(pixels_2)


    it "detects when layout changes break rendering":
        val width = 64
        val height = 64
        val renderer = SoftwareRenderer.create(width, height)
        renderer.clear()

        val pixels_before = renderer.get_pixels()

        # Simulate layout change (resize)
        renderer.resize(width, height)
        val pixels_after = renderer.get_pixels()

        # BUG: If resize changes pixel output unexpectedly
        # Test SHOULD catch if pixel counts differ
        expect(pixels_before.len).to_equal(pixels_after.len)


describe "GUI Widget Bug Detection: Resource Leaks":

    it "validates memory allocation is consistent":
        # Test 1: Create and render
        val renderer_1 = SoftwareRenderer.create(256, 256)
        renderer_1.clear()
        val pixels_1 = renderer_1.get_pixels()
        val mem_1 = pixels_1.len

        # Test 2: Create and render again
        val renderer_2 = SoftwareRenderer.create(256, 256)
        renderer_2.clear()
        val pixels_2 = renderer_2.get_pixels()
        val mem_2 = pixels_2.len

        # BUG DETECTION: Memory allocation inconsistency
        expect(mem_1).to_equal(mem_2)


describe "GUI Widget Bug Detection: Color/Pixel Corruption":

    it "detects pixel value corruption":
        val width = 32
        val height = 32
        val renderer = SoftwareRenderer.create(width, height)
        renderer.clear()

        val pixels = renderer.get_pixels()

        # All pixels after clear should be valid color values
        # Check for corruption: pixels with invalid values
        val has_valid_colors = pixels.all(fn(p: i64):
            # ARGB format: each component 0-255
            # If any pixel is invalid (e.g., > 0xFFFFFFFF), it's corrupt
            p >= 0
        )

        expect(has_valid_colors).to_equal(true)


describe "GUI Widget Bug Detection: Rendering Order (Z-index)":

    it "validates rendering order consistency":
        val width = 100
        val height = 100
        val renderer = SoftwareRenderer.create(width, height)
        renderer.clear()

        val pixels_1 = renderer.get_pixels()

        # Render again with same state
        renderer.clear()
        val pixels_2 = renderer.get_pixels()

        # BUG: If z-order changes, rendering differs
        # Test SHOULD detect rendering order bugs
        expect(pixels_1).to_equal(pixels_2)


describe "GUI Widget Bug Detection: Summary":

    it "documents detectable bugs":
        # Bugs this test suite CATCHES:
        val bugs_caught = [
            "Empty pixel buffer",           # ✓ Detectable
            "Wrong viewport size",          # ✓ Detectable (pixel count mismatch)
            "Determinism regression",       # ✓ Detectable (pixel diff)
            "Layout breaking rendering",    # ✓ Detectable (output changes)
            "Memory allocation mismatch",   # ✓ Detectable (size differs)
            "Pixel value corruption",       # ✓ Detectable (invalid values)
            "Rendering order change",       # ✓ Detectable (pixel diff)
        ]

        expect(bugs_caught.len).to_equal(7)


    it "documents harder-to-detect bugs":
        # Bugs this needs ENHANCEMENT to catch:
        val subtle_bugs = [
            "Uninitialized state (garbage pixels)",  # Needs pixel value validation
            "Off-by-one in dimensions",              # Needs precise size checking
            "Color space mismatch",                   # Needs color profile validation
            "Anti-aliasing artifacts",               # Needs fuzzy pixel comparison
            "Performance regression",                 # Needs timing validation
        ]

        expect(subtle_bugs.len).to_equal(5)
