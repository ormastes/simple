"""
# RenderDoc Chrome target-control probe contract

## Overview

Locks the Linux Chrome target-control diagnostic contract. The probe is
diagnostic evidence for the GUI/web/2D Vulkan RenderDoc blocker lane; it must
not claim a browser `.rdc` pass unless the capture file has `RDOC` magic, and it
must record enough GPU-process state to distinguish "RenderDoc not injected"
from "RenderDoc injected but no capturable frame."

**Plan:** doc/03_plan/agent_tasks/vulkan_backed_web_gui_renderdoc_parallel_plan.md
**Requirements:** N/A
**Research:** N/A
**Design:** doc/07_guide/tooling/renderdoc_capture_infra.md
**Bug:** doc/08_tracking/bug/gui_web_2d_vulkan_renderdoc_blockers_2026-06-23.md

## Syntax

```sh
SIMPLE_LIB=src bin/simple test test/03_system/check/renderdoc_chrome_target_control_spec.spl --native
```

## Operator Flow

1. Run the real target-control probe only on a prepared Linux GUI host with
   Chrome, RenderDoc, X11, and Vulkan available.
2. Read `build/renderdoc/chrome-target-control/evidence.env`.
3. Treat `rdoc_chrome_target_control_status=pass` as valid only when
   `rdoc_chrome_target_control_capture_magic=RDOC`.
4. If the status is non-pass, use the GPU-process fields to classify the
   failure:
   - `rdoc_chrome_target_control_gpu_env_has_layer=0` means the Vulkan layer did
     not reach the GPU process.
   - `rdoc_chrome_target_control_gpu_maps_has_renderdoc=0` means RenderDoc was
     not mapped in the GPU process.
   - `rdoc_chrome_target_control_gpu_maps_has_vulkan=0` means Chrome did not
     expose a Vulkan GPU-process path for this probe.
   - `rdoc_chrome_target_control_reason=no-gpu-process` means qrenderdoc target
     control was deliberately skipped so another process cannot be captured by
     accident.

## Acceptance

- Missing Chrome writes deterministic non-pass evidence with the target-control
  schema.
- The script emits GPU-process environment and map fields:
  `gpu_env_has_layer`, `gpu_maps_has_renderdoc`, and `gpu_maps_has_vulkan`.
- The script fails closed with `no-gpu-process` before invoking qrenderdoc
  target-control when no Chromium GPU process exists.

## Evidence Contract

The probe writes `evidence.env` under `BUILD_DIR`, defaulting to
`build/renderdoc/chrome-target-control/evidence.env`. Required top-level keys:

- `rdoc_chrome_target_control_status`
- `rdoc_chrome_target_control_reason`
- `rdoc_chrome_target_control_html_path`
- `rdoc_chrome_target_control_chrome`
- `rdoc_chrome_target_control_renderdoc_home`
- `rdoc_chrome_target_control_gpu_pid`
- `rdoc_chrome_target_control_gpu_env_has_layer`
- `rdoc_chrome_target_control_gpu_maps_has_renderdoc`
- `rdoc_chrome_target_control_gpu_maps_has_vulkan`
- `rdoc_chrome_target_control_target_status`
- `rdoc_chrome_target_control_target_reason`
- `rdoc_chrome_target_control_target_pid`
- `rdoc_chrome_target_control_target_api`
- `rdoc_chrome_target_control_capture_file`
- `rdoc_chrome_target_control_capture_magic`

Passing evidence requires:

- `rdoc_chrome_target_control_status=pass`
- `rdoc_chrome_target_control_reason=pass`
- `rdoc_chrome_target_control_capture_magic=RDOC`
- `rdoc_chrome_target_control_target_api` identifying a Vulkan target

Any missing or non-`RDOC` capture magic is non-pass. The target-control probe is
not allowed to infer browser capture success from Chrome ARGB, browser backing,
Vulkan logs, or RenderDoc library mapping alone.

## Failure Matrix

| Reason | Meaning | Next evidence action |
|--------|---------|----------------------|
| `missing-chrome` | Chrome binary is unavailable | Install Chrome or set `RDOC_CHROME` |
| `missing-qrenderdoc` | RenderDoc target-control UI binary is unavailable | Install RenderDoc or set `RDOC_HOME` |
| `missing-renderdoc-vulkan-layer` | RenderDoc Vulkan layer manifest is unavailable | Register/fix RenderDoc layer |
| `no-gpu-process` | Chrome did not spawn a GPU process | Check display, Vulkan flags, and Chrome GPU logs |
| `target-control-no-evidence` | qrenderdoc did not write target-control env | Inspect `qrenderdoc.log` and UI Python availability |
| `no-new-capture-message` | target-control attached but no capture arrived | Inspect target API and frame/present activity |
| `missing-rdc` | target-control ran but no valid `.rdc` exists | Continue Chrome/RenderDoc capture debugging |

## Test Matrix

The executable spec covers:

1. Missing Chrome evidence remains deterministic and includes all target-control
   schema keys.
2. The shell script contains an explicit `no-gpu-process` fail-closed guard
   before qrenderdoc receives `RDOC_TARGET_CONTROL_PID`.
3. The shell script records GPU-process environment and map diagnostics for the
   RenderDoc Vulkan layer, `librenderdoc`, and `libvulkan`.

The spec deliberately does not launch real Chrome. Real capture attempts remain
host-dependent and belong in `doc/09_report` evidence rows plus the active
blocker document.
"""

# @tag: system, gpu, renderdoc, chrome, vulkan, evidence

use std.spec.*
use std.io_runtime.{file_read, process_run}

describe "RenderDoc Chrome target-control probe":

    it "writes typed non-pass evidence for missing Chrome":
        step("Run the target-control probe with a missing Chrome binary")
        val command = "rm -rf build/test-renderdoc-chrome-target-control-missing && RDOC_CHROME=/tmp/simple-missing-chrome BUILD_DIR=build/test-renderdoc-chrome-target-control-missing REPORT_PATH=build/test-renderdoc-chrome-target-control-missing/report.md sh scripts/check/check-renderdoc-chrome-target-control.shs || true"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
        expect(code).to_equal(0)

        step("Read deterministic missing-Chrome evidence")
        val evidence = file_read("build/test-renderdoc-chrome-target-control-missing/evidence.env")
        expect(evidence).to_contain("rdoc_chrome_target_control_status=fail")
        expect(evidence).to_contain("rdoc_chrome_target_control_reason=missing-chrome")
        expect(evidence).to_contain("rdoc_chrome_target_control_required_magic=RDOC")
        expect(evidence).to_contain("rdoc_chrome_target_control_required_api=vulkan")
        expect(evidence).to_contain("rdoc_chrome_target_control_required_angle=vulkan")
        expect(evidence).to_contain("rdoc_chrome_target_control_gpu_env_has_layer=")
        expect(evidence).to_contain("rdoc_chrome_target_control_gpu_maps_has_renderdoc=")
        expect(evidence).to_contain("rdoc_chrome_target_control_gpu_maps_has_vulkan=")
        expect(evidence).to_contain("rdoc_chrome_target_control_discovery_log=build/test-renderdoc-chrome-target-control-missing/discovery.log")
        expect(evidence).to_contain("rdoc_chrome_target_control_gpu_maps=build/test-renderdoc-chrome-target-control-missing/gpu.maps")

    it "fails closed before qrenderdoc when Chrome has no GPU process":
        step("Inspect target-control source for the no-GPU-process guard")
        val script = file_read("scripts/check/check-renderdoc-chrome-target-control.shs")
        expect(script).to_contain("reason=\"no-gpu-process\"")
        expect(script).to_contain("exit 1")
        expect(script).to_contain("RDOC_TARGET_CONTROL_PID=\"$gpu_pid\"")

    it "records RenderDoc layer and Vulkan map state for the Chromium GPU process":
        step("Inspect target-control source for GPU-process diagnostics")
        val script = file_read("scripts/check/check-renderdoc-chrome-target-control.shs")
        expect(script).to_contain("rdoc_chrome_target_control_gpu_env_has_layer=$gpu_env_has_layer")
        expect(script).to_contain("rdoc_chrome_target_control_gpu_maps_has_renderdoc=$gpu_maps_has_renderdoc")
        expect(script).to_contain("rdoc_chrome_target_control_gpu_maps_has_vulkan=$gpu_maps_has_vulkan")
        expect(script).to_contain("grep -q 'librenderdoc'")
        expect(script).to_contain("grep -q 'libvulkan'")
        expect(script).to_contain("cp \"/proc/$gpu_pid/maps\" \"$BUILD_DIR/gpu.maps\"")
