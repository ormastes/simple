    expect(value_of(evidence, prefix + "ready")).to_equal("true")
    expect(value_of(evidence, prefix + "wm_found")).to_equal("true")
    expect((value_of(evidence, prefix + "focus_count").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "move_count").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "maximize_count").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "title_command_count").to_i64() ?? 0)).to_be_greater_than(0)
