    val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
    expect(code).to_equal(0)

    val evidence = file_read(root + "/out/evidence.env")
    expect(value_of(evidence, "html_css_full_rendering_goal_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_ready_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_html_tag_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_all_html_elements_ready_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_implemented_css_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_all_implemented_css_ready_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_full_css_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_all_css_properties_ready_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_implemented_surface_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_css_completion_status")).to_equal("pass")
    assert_equal_count_fields(evidence, "html_css_full_rendering_goal_html_tag_total_count", "html_css_full_rendering_goal_html_tag_rendered_count")
    assert_equal_count_fields(evidence, "html_css_full_rendering_goal_implemented_css_total_count", "html_css_full_rendering_goal_implemented_css_rendered_count")
    assert_equal_count_fields(evidence, "html_css_full_rendering_goal_full_css_total_count", "html_css_full_rendering_goal_full_css_rendered_count")
    expect((value_of(evidence, "html_css_full_rendering_goal_full_css_total_count").to_i64() ?? 0)).to_be_greater_than(389)
    expect(value_of(evidence, "html_css_full_rendering_goal_full_css_unrendered_count")).to_equal("0")
    expect(value_of(evidence, "html_css_full_rendering_goal_full_css_unrendered_properties")).to_equal("")
    expect(value_of(evidence, "html_css_full_css_completion_unrendered_count")).to_equal("0")
    expect(value_of(evidence, "html_css_full_rendering_goal_animation_css_status")).to_equal("pass")
    expect(value_of(evidence, "html_css_full_rendering_goal_animation_css_unrendered_count")).to_equal("0")
    expect(value_of(evidence, "html_css_full_rendering_goal_animation_css_unrendered_properties")).to_equal("")
    "pass"

