    expect((value_of(evidence, prefix + "animation_frame_count").to_i64() ?? 0)).to_be_greater_than(1)
    expect(value_of(evidence, prefix + "css_animation_probe")).to_equal("true")
    expect(value_of(evidence, prefix + "blur_or_tolerance_used")).to_equal("false")
