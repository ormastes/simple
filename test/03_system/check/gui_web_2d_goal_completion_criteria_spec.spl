fn verify_retained_4k_8k_perf_completion():
    fail("TODO(gui-web-2d-completion): replace with assertions over current-source retained 4K and 8K 200 FPS rows with timing, RSS, checksum/readback, native binary provenance, retained mode, redraw count, and fallback_state=none")

