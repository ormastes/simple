fn verify_parallel_agent_review_completion() -> text:
    val plan = file_read("doc/03_plan/agent_tasks/gui_rendering_parallel_agent_plan_2026-06-27.md")
    expect(plan).to_contain("Spark was explicitly requested for this replan.")
    expect(plan).to_contain("GPT-5.3-Codex-Spark usage limit reached")
    expect(plan).to_contain("Do not mark Spark work as completed from that failed start.")
    expect(plan).to_contain("Russell")
    expect(plan).to_contain("Tesla")
    expect(plan).to_contain("Both failed at the same Spark quota gate.")
    expect(plan).to_contain("Fallback normal sidecars were started immediately")
    expect(plan).to_contain("Feynman")
    expect(plan).to_contain("Mill")
    expect(plan).to_contain("Poincare")
    expect(plan).to_contain("normal/high-capability review")
    expect(plan).to_contain("Fallback sidecar findings accepted for planning only")
    expect(plan).to_contain("Normal/high-capability review must accept ARGB equivalence")
    expect(plan).to_contain("Sidecar citations to older `2026-06-26` reports are advisory only.")
    expect(plan).to_contain("Review mini fallback outputs from `Erdos` and `Bohr`")
    expect(plan).to_contain("Main agent integrates only reviewed changes.")
    expect(plan).to_contain("| Parallel-agent review | Spark or fallback sidecar output plus normal/high-capability review before broad findings or done marks are accepted |")
    expect(plan).to_contain("Spark may be quota-blocked; fallback output remains advisory until reviewed")
    expect(plan).to_contain("WO-12 rule: do not spawn Spark against source-edit scopes until the read-only")

    val root = unique_build_root("parallel-agent-review")
    val command = "rm -rf " + root + " && " +
        "BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md " +
        "sh scripts/check/check-gui-web-2d-parallel-agent-review-evidence.shs >/dev/null"
    val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
    expect(code).to_equal(0)

    val evidence = file_read(root + "/out/evidence.env")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_status")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_reason")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_plan_file_status")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_spark_attempt_status")).to_equal("pass")
    expect((value_of(evidence, "gui_web_2d_parallel_agent_review_spark_attempt_count").to_i64() ?? 0)).to_be_greater_than(0)
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_fallback_sidecar_status")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_normal_review_status")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_accepted_split_status")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_anti_overclaim_status")).to_equal("pass")
    expect(value_of(evidence, "gui_web_2d_parallel_agent_review_reviewed_findings_status")).to_equal("pass")
    "pass"

fn value_of(lines: text, key: text) -> text:
    val prefix = key + "="
    val parts = lines.split("\n")
    var found = ""
    for line in parts:
        if line.starts_with(prefix):
            found = line.slice(prefix.len(), line.len())
    found

fn assert_retained_perf_row(evidence: text, prefix: text, resolution: text, width: text, height: text, pixels: text, rss_budget: text):
    expect(value_of(evidence, prefix + "_status")).to_equal("pass")
