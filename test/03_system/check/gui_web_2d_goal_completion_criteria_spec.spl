fn verify_retained_4k_8k_perf_completion() -> text:
    val root = unique_build_root("retained-perf")
    val command = "rm -rf " + root + " && " +
        "GUI_SHOWCASE_REQUIRE_CURRENT_SOURCE_REVISION=1 " +
        "GUI_RENDERDOC_AGGREGATE_STATIC_CACHE_DIR=build/test-gui-renderdoc-feature-coverage-static-cache " +
        "BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md " +
        "sh scripts/check/check-gui-renderdoc-feature-coverage-status.shs >/dev/null"
    val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
    expect(code).to_equal(0)

    val evidence = file_read(root + "/out/evidence.env")
    assert_retained_perf_row(evidence, "gui_showcase_4k_200fps", "4k", "3840", "2160", "8294400", "262144")
    assert_retained_perf_row(evidence, "gui_showcase_8k_perf", "8k", "7680", "4320", "33177600", "750000")
    "pass"

fn verify_full_html_css_completion() -> text:
    val root = unique_build_root("full-html-css")
    val command = "rm -rf " + root + " && " +
        "GUI_RENDERDOC_AGGREGATE_STATIC_CACHE_DIR=build/test-gui-renderdoc-feature-coverage-static-cache " +
