# codex-system-test
# @req REQ-009
# @evidence-display: links
"""# RenderDoc Capture Replay Inspection

Opens real captures through the canonical Simple helper and rejects magic-only,
synthetic, corrupt, or content-inconsistent artifacts.
"""
use std.spec.*
fn pending_renderdoc_replay_inspection(): fail("RenderDoc replay-open inspection is required")

describe "RenderDoc capture replay inspection":
    # @capture(artifact)
    # @capture(log)
    it "should open a real capture and agree on API device actions and frame":
        step("Capture the Simple Vulkan frame with the canonical helper")
        step("Open and replay the capture through the Simple inspector")
        step("Validate API device relevant actions and frame identity")
        pending_renderdoc_replay_inspection()
    # @manual: folded
    it "should reject a four-byte magic-only file":
        step("Inspect a file containing RDOC without capture contents")
        expect("capture-open-failed").to_equal("capture-open-failed")
        pending_renderdoc_replay_inspection()
    # @manual: folded
    it "should reject synthetic and corrupt capture artifacts":
        step("Inspect synthetic and truncated artifacts")
        expect(["synthetic-capture", "corrupt-capture"].len()).to_equal(2)
        pending_renderdoc_replay_inspection()
    # @manual: folded
    it "should reject capture and owner-record disagreement":
        step("Pair the capture with a different API or frame record")
        expect("capture-record-mismatch").to_equal("capture-record-mismatch")
        pending_renderdoc_replay_inspection()

