"""
# Doctest Lane Symmetry Contract

## Overview

Validates that the two doctest lanes of the pure-Simple test runner — sdoctest
(markdown code fences) and spl-doctest (same-file `///`/`##` fenced comment
doctests) — are symmetric: each has a scoped, explicit-target launch that
fail-closes on zero blocks, and each stays green/red in line with its fixture.

**Design:** doc/07_guide/tooling/pure_simple_tooling.md

## Acceptance

- An explicit green markdown target runs its sdoctest fence and exits 0.
- An explicit red markdown target exits nonzero.
- An explicit markdown target with zero fence blocks exits nonzero with
  `test-runner: no doctest blocks found`.
- `--spl-doctest <green.spl>` runs the file's comment doctest and exits 0.
- `--spl-doctest <red.spl>` exits nonzero.
- `--spl-doctest <empty.spl>` (zero comment doctests) exits nonzero with
  `test-runner: no doctest blocks found`.
"""

# @tag: system, test-runner, doctest, sdoctest, completion

use std.spec.*
use std.io_runtime.{process_run, env_get}

fn contract_binary() -> text:
    """Resolve which compiled binary to spawn for the fixture runs below.

    Mirrors the SIMPLE_RUNTIME / SIMPLE_BINARY override convention already
    used by find_simple_binary()/find_sdoctest_binary() elsewhere in the test
    runner: defaults to the deployed self-hosted bin/simple (normal usage),
    but honors an explicit override so this spec can also be verified against
    a bootstrap seed binary without editing the file."""
    val override = env_get("SIMPLE_TEST_BINARY")
    if override != "" and override != nil:
        return override
    "bin/simple"

describe "doctest lane symmetry contract":

    context "sdoctest lane (markdown fences)":
        it "runs an explicit green.md target and passes at least one block":
            val (stdout, stderr, code) = process_run(contract_binary(), [
                "test", "test/fixtures/doctest/green.md", "--no-db"
            ])
            val output = stdout + stderr

            expect(code).to_equal(0)
            expect(output).to_contain("1 passed")

        it "fails on an explicit red.md target":
            val (stdout, stderr, code) = process_run(contract_binary(), [
                "test", "test/fixtures/doctest/red.md", "--no-db"
            ])

            expect(code).to_equal(1)

        it "fail-closes on an explicit empty.md target with zero fence blocks":
            val (stdout, stderr, code) = process_run(contract_binary(), [
                "test", "test/fixtures/doctest/empty.md", "--no-db"
            ])
            val output = stdout + stderr

            expect(code).to_equal(1)
            expect(output).to_contain("test-runner: no doctest blocks found")

    context "spl-doctest lane (same-file fenced comment doctests)":
        it "runs an explicit --spl-doctest green.spl target and passes":
            val (stdout, stderr, code) = process_run(contract_binary(), [
                "test", "--spl-doctest", "test/fixtures/doctest/green.spl", "--no-db"
            ])
            val output = stdout + stderr

            expect(code).to_equal(0)
            expect(output).to_contain("1 passed")

        it "fails on an explicit --spl-doctest red.spl target":
            val (stdout, stderr, code) = process_run(contract_binary(), [
                "test", "--spl-doctest", "test/fixtures/doctest/red.spl", "--no-db"
            ])

            expect(code).to_equal(1)

        it "fail-closes on an explicit --spl-doctest empty.spl target with zero doctests":
            val (stdout, stderr, code) = process_run(contract_binary(), [
                "test", "--spl-doctest", "test/fixtures/doctest/empty.spl", "--no-db"
            ])
            val output = stdout + stderr

            expect(code).to_equal(1)
            expect(output).to_contain("test-runner: no doctest blocks found")
