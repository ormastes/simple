# @cover src/lib/nogc_sync_mut/game2d/loop/driver.spl 80%
# @cover src/lib/nogc_sync_mut/game2d/backend/headless.spl 60%
"""
# Game2D Event Replay & Animation (capture-backed)

**Feature IDs:** W8, G1.5, G1.6
**Category:** Testing | Runtime | GUI
**Status:** In Progress
**Requirements:** doc/03_plan/ui/production_readiness_master_plan_2026-07-02.md (W8)
**Design:** src/lib/nogc_sync_mut/game2d/loop/driver.spl (`run_frames`)

## Overview

Runtime (non-grep) capture spec for the game2d event/animation stack. Drives
real `App` implementations through `LoopDriver.run_frames` against a
`HeadlessBackend` software framebuffer with `ScriptedInput` snapshot lists:

1. **Event replay** — a scripted key press flips app state; the final
   `frame_hash` must differ from an identical replay without the press.
2. **Determinism** — the same scripted replay run twice produces byte-equal
   framebuffers (identical hashes).
3. **Animation** — an app that moves a rect one step per `fixed_update`;
   frame hashes sampled after each pumped frame must all differ from their
   predecessor (the rect visibly moved every fixed step).

Framebuffer is tiny (64x48) and frame counts small so the interpreter-mode
runner stays fast.

## Related Specifications

- [game2d_golden_spec.spl](../../system/game2d_golden_spec.spl) — golden hash pin
- [game2d_replay_spec.spl](../../system/game2d_replay_spec.spl) — replay contract (grep-level)
"""

use std.spec
use std.common.engine.math2d.{Vec2}
use std.common.engine.rect.{Rect2}
use std.common.engine.color.{EngineColor}
use std.common.engine.units.{KeyCode}
use std.nogc_sync_mut.game2d.render.canvas.{Canvas}
use std.nogc_sync_mut.game2d.math.{DrawMode}
use std.nogc_sync_mut.game2d.backend.headless.{HeadlessBackend, ScriptedInput}
use std.nogc_sync_mut.game2d.input.snapshot.{InputSnapshot}
use std.nogc_sync_mut.game2d.input.api.{key_pressed_this_frame}
use std.nogc_sync_mut.game2d.loop.driver.{LoopDriver, run_frames}

# 1e9 / 60 truncated — matches LoopDriver.new(60).fixed_step_ns exactly, so
# each pumped frame consumes exactly one fixed step.
val STEP_NS: i64 = 16_666_666
val SPACE: i64 = 32


# ============================================================================
# Test apps — mutable state lives in StateBox (composition; App callbacks
# take `fn self`, so mutation goes through the referenced holder's `me`).
# ============================================================================

class StateBox:
    on: bool
    x: i64

    static fn fresh() -> StateBox:
        StateBox(on: false, x: 0)

    me latch_on(self):
        self.on = true

    me bump(self):
        self.x = self.x + 1


# BlinkApp — draws a white rect only after a Space press was observed.
class BlinkApp:
    state: StateBox

    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        val _ = dt
        if key_pressed_this_frame(KeyCode(code: SPACE)):
            self.state.latch_on()

    fn fixed_update(self, step: f32):
        val _ = step

    fn draw(self, ctx: Canvas):
        ctx.clear(EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 1.0))
        if self.state.on:
            ctx.rect(DrawMode.Fill,
                     Rect2(x: 8.0, y: 8.0, width: 16.0, height: 12.0),
                     EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0))


# SlideApp — rect slides 4px right per fixed step (animation check).
class SlideApp:
    state: StateBox

    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        val _ = dt

    fn fixed_update(self, step: f32):
        val _ = step
        self.state.bump()

    fn draw(self, ctx: Canvas):
        ctx.clear(EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 1.0))
        val x0 = self.state.x.to_f64() * 4.0
        ctx.rect(DrawMode.Fill,
                 Rect2(x: x0, y: 10.0, width: 6.0, height: 6.0),
                 EngineColor(r: 1.0, g: 0.2, b: 0.2, a: 1.0))


# ============================================================================
# Step Helpers
# ============================================================================

# @step: Build an empty input snapshot (no keys)
fn empty_snap() -> InputSnapshot:
    InputSnapshot.create()

# @step: Build a snapshot with Space pressed this frame
fn press_snap() -> InputSnapshot:
    val k = KeyCode(code: SPACE)
    InputSnapshot.from_raw([k], [k], Vec2(x: 0.0, y: 0.0), [])

# @step: Replay a scripted input on a fresh BlinkApp, return final frame hash
fn replay_blink(script: ScriptedInput) -> i64:
    var backend = HeadlessBackend.create(64, 48)
    var app = BlinkApp(state: StateBox.fresh())
    var driver = LoopDriver.new(60)
    run_frames(driver, app, backend, script.frames, STEP_NS)
    backend.frame_hash()

# @step: Pump a SlideApp n frames, sampling the frame hash after each frame
fn sample_slide_hashes(n: i64) -> [i64]:
    var backend = HeadlessBackend.create(64, 48)
    var app = SlideApp(state: StateBox.fresh())
    var driver = LoopDriver.new(60)
    var hashes: [i64] = []
    var i: i64 = 0
    while i < n:
        run_frames(driver, app, backend, [empty_snap()], STEP_NS)
        hashes.push(backend.frame_hash())
        i = i + 1
    hashes


# ============================================================================
# Scenarios
# ============================================================================

describe "Game2D Event Replay (W8/G1.5)":

    it "scripted key press changes the captured frame hash":
        val base = replay_blink(
            ScriptedInput.new([empty_snap(), empty_snap(), empty_snap()]))
        val pressed = replay_blink(
            ScriptedInput.new([empty_snap(), press_snap(), empty_snap()]))
        assert_not_equal(base, pressed)

    it "identical replays are byte-equal (determinism)":
        val run_a = replay_blink(
            ScriptedInput.new([empty_snap(), press_snap(), empty_snap()]))
        val run_b = replay_blink(
            ScriptedInput.new([empty_snap(), press_snap(), empty_snap()]))
        assert_equal(run_a, run_b)

    it "no-input replay is also deterministic and distinct from pressed":
        val quiet_a = replay_blink(ScriptedInput.new([empty_snap()]))
        val quiet_b = replay_blink(ScriptedInput.new([empty_snap()]))
        val pressed = replay_blink(ScriptedInput.new([press_snap()]))
        assert_equal(quiet_a, quiet_b)
        assert_not_equal(quiet_a, pressed)


describe "Game2D Animation Capture (W8/G1.6)":

    it "rect animation: no two consecutive frame hashes are equal":
        val hashes = sample_slide_hashes(6)
        assert_equal(hashes.len(), 6)
        var i: i64 = 1
        while i < 6:
            assert_not_equal(hashes[i as i32], hashes[(i - 1) as i32])
            i = i + 1

    it "animation replay is deterministic frame-by-frame":
        val a = sample_slide_hashes(4)
        val b = sample_slide_hashes(4)
        var i: i64 = 0
        while i < 4:
            assert_equal(a[i as i32], b[i as i32])
            i = i + 1
