# Physics2 Asteroids — System Test
#
# Verifies: BVH with many bodies, raycasting, overlap queries,
# dynamic body addition, world-wrap positioning.

use std.io_runtime
use std.spec.{describe, it, expect}
use std.common.math.{math_sqrt, math_abs}
use std.common.engine.ids.{NodeId, RawHandle}
use std.common.engine.math2d.{Vec2}
use std.nogc_sync_mut.engine.physics.config.{default_physics_config_2d}
use std.nogc_sync_mut.engine.physics.world2d.{PhysicsWorld2D}
use std.nogc_sync_mut.engine.physics.simple.query.raycast2d.{raycast_2d}
use std.nogc_sync_mut.engine.physics.simple.query.overlap.{circle_overlap_2d}

fn make_node(idx: i64) -> NodeId:
    NodeId(raw: RawHandle.new(idx, 1))

fn make_asteroid_field(count: i64) -> PhysicsWorld2D:
    var config = default_physics_config_2d()
    config.gravity = Vec2(x: 0.0, y: 0.0)
    config.restitution = 0.8
    config.friction = 0.0
    var world = PhysicsWorld2D.create(config)
    var i = 0
    while i < count:
        val x = (i * 7 + 3) % 20 - 10
        val y = (i * 13 + 5) % 20 - 10
        world.add_dynamic_body(make_node(i), x.to_f64(), y.to_f64(), 1.0)
        world.add_circle_collider(make_node(i), 0.5)
        val vx = ((i * 3 + 1) % 5 - 2).to_f64()
        val vy = ((i * 7 + 2) % 5 - 2).to_f64()
        world.set_velocity(make_node(i), vx, vy)
        i = i + 1
    world

fn step_n(world: PhysicsWorld2D, n: i64):
    var i = 0
    while i < n:
        world.step(0.016)
        i = i + 1

describe "Physics2 Asteroids System":
    it "many bodies simulate without explosion":
        var world = make_asteroid_field(20)
        step_n(world, 30)
        var all_bounded = true
        var i = 0
        while i < 20:
            val pos = world.get_position(make_node(i))
            if pos.x < -50.0 or pos.x > 50.0:
                all_bounded = false
            if pos.y < -50.0 or pos.y > 50.0:
                all_bounded = false
            i = i + 1
        expect(all_bounded).to_equal(true)
        world.destroy()

    it "BVH used for many colliders":
        var world = make_asteroid_field(10)
        expect(world.colliders.count > 4).to_equal(true)
        expect(world.use_bvh).to_equal(true)
        world.destroy()

    it "raycast hits nearest body":
        var config = default_physics_config_2d()
        config.gravity = Vec2(x: 0.0, y: 0.0)
        var world = PhysicsWorld2D.create(config)
        world.add_static_body(make_node(0), 5.0, 0.0)
        world.add_circle_collider(make_node(0), 1.0)
        world.add_static_body(make_node(1), 10.0, 0.0)
        world.add_circle_collider(make_node(1), 1.0)
        val hit = raycast_2d(0.0, 0.0, 1.0, 0.0, 100.0, world.bodies, world.colliders)
        expect(hit.has_hit).to_equal(true)
        expect(hit.distance < 5.0).to_equal(true)
        world.destroy()

    it "overlap query finds bodies in radius":
        var config = default_physics_config_2d()
        config.gravity = Vec2(x: 0.0, y: 0.0)
        var world = PhysicsWorld2D.create(config)
        world.add_static_body(make_node(0), 2.0, 0.0)
        world.add_circle_collider(make_node(0), 0.5)
        world.add_static_body(make_node(1), 10.0, 0.0)
        world.add_circle_collider(make_node(1), 0.5)
        val results = circle_overlap_2d(0.0, 0.0, 3.0, world.bodies, world.colliders)
        expect(results.len() > 0).to_equal(true)
        world.destroy()

    it "body count tracks correctly":
        var world = make_asteroid_field(15)
        expect(world.body_count() == 15).to_equal(true)
        world.destroy()
