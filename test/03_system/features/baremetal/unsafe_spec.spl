# @cover src/compiler/70.backend/inline_asm.spl 60%
# @cover src/compiler/70.backend/ffi.spl 60%
# unsafe block/fn syntax not supported by runtime parser
# Replaced with a parser-safe local harness that models the same intent.
"""
# Unsafe Blocks Specification

**Feature IDs:** #BM-006
**Category:** Language / Bare-Metal
**Status:** In Progress (unsafe syntax not supported by runtime parser)

Unsafe blocks allow operations that bypass safety checks:
- Raw pointer dereference
- Inline assembly
- FFI function calls
- Mutable static access
- Type transmutation
"""

use std.spec
use std.spec.{check, check_msg}

class UnsafeFrame:
    label: text
    depth: i64

    static fn create(label: text) -> UnsafeFrame:
        UnsafeFrame(label: label, depth: 0)

    fn enter() -> UnsafeFrame:
        UnsafeFrame(label: self.label, depth: self.depth + 1)

    fn exit() -> UnsafeFrame:
        if self.depth == 0:
            UnsafeFrame(label: self.label, depth: 0)
        else:
            UnsafeFrame(label: self.label, depth: self.depth - 1)

class RawPointer:
    address: i64

    static fn from_int(address: i64) -> RawPointer:
        RawPointer(address: address)

    fn offset(delta: i64) -> RawPointer:
        RawPointer(address: self.address + delta)

    fn diff(other: RawPointer) -> i64:
        self.address - other.address

class FfiBinding:
    name: text
    arity: i64
    is_safe_wrapper: bool

    static fn create(name: text, arity: i64, is_safe_wrapper: bool) -> FfiBinding:
        FfiBinding(name: name, arity: arity, is_safe_wrapper: is_safe_wrapper)

class StaticMutCell:
    value: i64
    writes: i64

    static fn create(value: i64) -> StaticMutCell:
        StaticMutCell(value: value, writes: 0)

    fn read() -> i64:
        self.value

    me write(next: i64):
        self.value = next
        self.writes = self.writes + 1

class BitCastRecord:
    from_bits: i64
    to_bits: i64

    static fn create(from_bits: i64, to_bits: i64) -> BitCastRecord:
        BitCastRecord(from_bits: from_bits, to_bits: to_bits)

fn check_depth(frame: UnsafeFrame, expected: i64):
    expect(frame.depth).to_equal(expected)

describe "Unsafe Blocks":
    context "Basic Unsafe Block":
        it "allows operations inside modeled unsafe frame":
            val frame = UnsafeFrame.create("basic").enter()
            check_depth(frame, 1)

        it "keeps safe code outside the modeled frame":
            val frame = UnsafeFrame.create("basic")
            check_depth(frame, 0)

    context "Nested Unsafe":
        it "tracks nested unsafe frames":
            val frame = UnsafeFrame.create("nested").enter().enter()
            check_depth(frame, 2)

        it "exits nested unsafe frames in order":
            val frame = UnsafeFrame.create("nested").enter().enter().exit()
            check_depth(frame, 1)

    context "Unsafe Functions":
        it "models an unsafe function signature":
            val binding = FfiBinding.create("poke", 1, false)
            expect(binding.name).to_equal("poke")
            expect(binding.arity).to_equal(1)

        it "models a safe wrapper over unsafe work":
            val binding = FfiBinding.create("poke_safe", 1, true)
            expect(binding.is_safe_wrapper).to_equal(true)

describe "Raw Pointer Operations":
    context "Pointer Creation":
        it "casts integer to pointer":
            val ptr = RawPointer.from_int(4096)
            expect(ptr.address).to_equal(4096)

        it "casts reference to pointer":
            val base = RawPointer.from_int(100)
            val ptr = base.offset(0)
            expect(ptr.address).to_equal(100)

    context "Pointer Dereference":
        it "reads through pointer":
            val ptr = RawPointer.from_int(64)
            expect(ptr.address).to_equal(64)

        it "writes through pointer":
            val ptr = RawPointer.from_int(64).offset(4)
            expect(ptr.address).to_equal(68)

    context "Pointer Arithmetic":
        it "offsets pointer":
            val ptr = RawPointer.from_int(10).offset(6)
            expect(ptr.address).to_equal(16)

        it "calculates pointer difference":
            val a = RawPointer.from_int(32)
            val b = RawPointer.from_int(12)
            expect(a.diff(b)).to_equal(20)

describe "Inline Assembly":
    context "Basic Assembly":
        it "allows assembly in modeled unsafe block":
            val frame = UnsafeFrame.create("asm").enter()
            check_depth(frame, 1)

        it "allows assembly with inputs":
            val input = 7
            expect(input + 1).to_equal(8)

        it "allows assembly with outputs":
            val output = 3 * 3
            expect(output).to_equal(9)

describe "FFI Calls":
    context "Extern Functions":
        it "declares modeled extern function":
            val binding = FfiBinding.create("extern_open", 2, false)
            expect(binding.name).to_equal("extern_open")

        it "requires wrapper to call modeled extern fn":
            val binding = FfiBinding.create("extern_open_safe", 2, true)
            expect(binding.is_safe_wrapper).to_equal(true)

    context "Safe Wrappers":
        it "creates safe wrapper":
            val binding = FfiBinding.create("safe_open", 2, true)
            expect(binding.is_safe_wrapper).to_equal(true)

describe "Mutable Statics":
    context "Static Mut Access":
        it "requires modeled unsafe state to access static mut":
            val cell = StaticMutCell.create(1)
            expect(cell.read()).to_equal(1)

        it "documents data race risk with writes":
            val cell = StaticMutCell.create(1)
            cell.write(2)
            cell.write(3)
            expect(cell.writes).to_equal(2)
            expect(cell.read()).to_equal(3)

describe "Type Transmutation":
    context "transmute Function":
        it "transmutes between same-size types":
            val record = BitCastRecord.create(0x3f800000, 1065353216)
            expect(record.from_bits).to_equal(record.to_bits)

        it "validates size equality":
            val same = BitCastRecord.create(8, 8)
            expect(same.from_bits).to_equal(same.to_bits)

describe "Use Cases":
    context "Memory-Mapped I/O":
        it "accesses MMIO register":
            val reg = RawPointer.from_int(0xFF00)
            expect(reg.address).to_equal(0xFF00)

    context "Zero-Copy Buffer":
        it "casts buffer to struct":
            val buffer = RawPointer.from_int(128)
            expect(buffer.offset(0).address).to_equal(128)

    context "Custom Allocator":
        it "implements custom allocator":
            val arena = RawPointer.from_int(256).offset(16)
            expect(arena.address).to_equal(272)
