# @cover src/compiler/90.tools/duplicate_check/main.spl 60%
# @cover src/compiler/90.tools/duplicate_check/semantic.spl 80%
# @cover src/compiler/90.tools/duplicate_check/formatter.spl 80%

use std.spec.*

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool

fn run_spec(path: text) -> (text, text, i64):
    rt_process_run("bin/simple", ["test", path])

fn run_bootstrap(args: [text]) -> (text, text, i64):
    rt_process_run("src/compiler_rust/target/bootstrap/simple", args)

fn reset_fixture_dir(root: text):
    val (_, _, code) = rt_process_run("/bin/sh", ["-c", "rm -rf '" + root + "'"])
    expect(code).to_equal(0)

fn make_cli_fixture(root: text):
    reset_fixture_dir(root)
    expect(rt_dir_create(root, true)).to_equal(true)
    val file_a = root + "/alpha.spl"
    val file_b = root + "/beta.spl"
    val content_a = "## Adds a normalized value for downstream scoring.\nfn add_score(seed: i64) -> i64:\n    seed + 1\n"
    val content_b = "## Adds a normalized value for downstream scoring.\nfn merge_score(seed: i64) -> i64:\n    seed + 2\n"
    expect(rt_file_write_text(file_a, content_a)).to_equal(true)
    expect(rt_file_write_text(file_b, content_b)).to_equal(true)

fn make_token_fixture(root: text):
    reset_fixture_dir(root)
    expect(rt_dir_create(root, true)).to_equal(true)
    val file_a = root + "/token_a.spl"
    val file_b = root + "/token_b.spl"
    val content = "fn shared_logic(seed: i64) -> i64:\n    val base = seed + 1\n    val total = base * 2\n    if total > seed:\n        return total\n    return seed\n"
    expect(rt_file_write_text(file_a, content)).to_equal(true)
    expect(rt_file_write_text(file_b, content)).to_equal(true)

fn make_cosine_fixture(root: text):
    reset_fixture_dir(root)
    expect(rt_dir_create(root, true)).to_equal(true)
    val file_a = root + "/cosine_a.spl"
    val file_b = root + "/cosine_b.spl"
    val content_a = "fn alpha_logic(seed: i64) -> i64:\n    val alpha_base = seed + 1\n    val alpha_total = alpha_base * 2\n    if alpha_total > seed:\n        return alpha_total\n    return seed\n"
    val content_b = "fn beta_logic(seed: i64) -> i64:\n    val beta_base = seed + 2\n    val beta_total = beta_base * 2\n    if beta_total > seed:\n        return beta_total\n    return seed\n"
    expect(rt_file_write_text(file_a, content_a)).to_equal(true)
    expect(rt_file_write_text(file_b, content_b)).to_equal(true)

describe "duplicate-check system regressions":
    slow_it "executes the CLI regression unit spec end-to-end":
        val (stdout, _, code) = run_spec("test/unit/app/duplicate_check/duplicate_check_spec.spl")

        expect(code).to_equal(0)
        expect(stdout).to_contain("Passed:")
        expect(stdout).to_contain("All tests passed")

    slow_it "executes semantic fallback regressions end-to-end":
        val (stdout, _, code) = run_spec("test/system/duplicate_check/semantic_fallback_probe_spec.spl")

        expect(code).to_equal(0)
        expect(stdout).to_contain("Passed:")
        expect(stdout).to_contain("All tests passed")

    slow_it "runs semantic analysis by default for bare duplicate-check invocations":
        val root = "/tmp/simple_duplicate_check_system_default"
        make_cli_fixture(root)

        val (stdout, _, code) = rt_process_run("bin/simple", [
            "duplicate-check",
            root,
            "--semantic-threshold",
            "0.70",
            "--ollama-url",
            "http://127.0.0.1:9"
        ])

        expect(code).to_equal(1)
        expect(stdout).to_contain("Source: 2 items, 2 documented")
        expect(stdout).to_contain("Summary: 2 total, 2 documented")
        expect(stdout).to_contain("[text-based fallback]")

    slow_it "runs token mode for 5-line code duplication":
        val root = "/tmp/simple_duplicate_check_system_token"
        make_token_fixture(root)

        val (_, _, code) = rt_process_run("bin/simple", [
            "duplicate-check",
            root,
            "--mode",
            "token",
            "--min-lines",
            "5",
            "--min-tokens",
            "8"
        ])

        expect(code).to_equal(1)

    slow_it "runs cosine mode for fuzzy duplication":
        val root = "/tmp/simple_duplicate_check_system_cosine"
        make_cosine_fixture(root)

        val (_, _, code) = rt_process_run("bin/simple", [
            "duplicate-check",
            root,
            "--mode",
            "cosine",
            "--min-lines",
            "5",
            "--min-tokens",
            "8",
            "--similarity-threshold",
            "0.55"
        ])

        expect(code).to_equal(1)

    slow_it "falls back cleanly in bootstrap semantic mode without HTTP extern support":
        val (_, _, code) = run_bootstrap([
            "run",
            "src/compiler/90.tools/duplicate_check/main.spl",
            "src/compiler/90.tools/duplicate_check",
            "--semantic",
            "--semantic-threshold",
            "0.7",
            "--ollama-url",
            "http://127.0.0.1:9"
        ])

        expect(code).to_equal(0)
