# Semantic mode test data with proper docstrings

# ============================================================================
# Comment-based duplicates (similar docstrings, different implementations)
# ============================================================================

"""Validate user credentials and return session token"""
fn auth_login_v1(user: text, pass: text) -> text:
    """Authenticate user with username and password."""
    if user == "admin" and pass == "secret":
        return "token_v1"
    "error"

"""Validate user credentials and return session token"""
fn auth_login_v2(username: text, password: text) -> text:
    """Authenticate user with username and password."""
    if username == "admin" and password == "secret":
        return "token_v2"
    "error"

"""Check if email format is valid"""
fn is_valid_email_v1(email: text) -> bool:
    """Validate email format by checking for @ symbol."""
    email.contains("@") and email.contains(".")

"""Check if email format is valid"""
fn is_valid_email_v2(email: text) -> bool:
    """Validate email format by checking for @ symbol."""
    email.contains("@") and email.contains(".")

# ============================================================================
# Test-based duplicates (similar test docstrings)
# ============================================================================

"""Test authentication with valid credentials"""
fn test_auth_success():
    """Verify authentication returns valid token for correct credentials."""
    val result = auth_login_v1("admin", "secret")
    assert_true(result != "error")

"""Test authentication with valid credentials"""
fn test_auth_login():
    """Verify authentication returns valid token for correct credentials."""
    val result = auth_login_v2("admin", "secret")
    assert_true(result != "error")

"""Test email validation"""
fn test_email_check():
    """Verify email validation returns true for valid email."""
    val result = is_valid_email_v1("user@example.com")
    assert_true(result)

"""Test email validation"""
fn test_email_validate():
    """Verify email validation returns true for valid email."""
    val result = is_valid_email_v2("user@example.com")
    assert_true(result)

# ============================================================================
# Name-based duplicates (similar struct names and docstrings)
# ============================================================================

"""User authentication data structure"""
struct UserAuth:
    """Stores user authentication credentials and session token."""
    name: text
    token: text

"""User authentication data structure"""
struct UserAuthenticator:
    """Stores user authentication credentials and session token."""
    username: text
    session_token: text

"""Email validation configuration"""
struct EmailValidator:
    """Email validation pattern and configuration."""
    pattern: text

"""Email validation configuration"""
struct EmailChecker:
    """Email validation pattern and configuration."""
    regex_pattern: text
