# Semantic mode test data - comment-based duplicates

# Test helper for user authentication
# Validates credentials and returns session token
fn authenticate_user(username: text, password: text) -> text:
    """Authenticate user with credentials."""
    if username == "admin" and password == "secret":
        return "session_token_123"
    return "invalid"

# Test helper for user authentication
# Validates credentials and returns session token
fn authenticate_user_v2(username: text, password: text) -> text:
    """Authenticate user with credentials."""
    if username == "admin" and password == "secret":
        return "session_token_456"
    return "invalid"

# Data validator for email addresses
# Checks format and returns normalized result
fn validate_email(email: text) -> bool:
    """Validate email format."""
    if email.contains("@"):
        return true
    return false

# Data validator for email addresses
# Checks format and returns normalized result
fn validate_email_v2(email: text) -> bool:
    """Validate email format."""
    if email.contains("@"):
        return true
    return false
