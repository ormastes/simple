# fast_duplicate_check_audit_spec
#
# Verifies the fast duplicate gate runs as Simple code.

use std.spec

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "fast duplicate check audit":

    it "indexes windows directly instead of rescanning every bucket":
        val source = rt_file_read_text("scripts/audit/fast_duplicate_check.spl") ?? ""
        expect(source).to_contain("bucket_by_key: {text: i64}")
        expect(source.contains("fn bucket_index")).to_equal(false)
        expect(source).to_contain("parts.push(lines[idx])")
        expect(source).to_contain("collapse_shifted_duplicate_buckets")

    it "finds exact line-window duplicates and honors max allowed":
        val root = "/tmp/simple_fast_duplicate_check_spec"
        val (_clean_out, _clean_err, _clean_code) = rt_process_run("/bin/sh", ["-c", "rm -rf " + root + " && mkdir -p " + root])
        val body =
            "fn shared(value: i64) -> i64:\n" +
            "    val next = value + 1\n" +
            "    if next > 2:\n" +
            "        return next\n" +
            "    return value\n"
        expect(rt_file_write_text(root + "/a.spl", body)).to_equal(true)
        expect(rt_file_write_text(root + "/b.spl", body)).to_equal(true)

        val result = rt_process_run("bin/simple", ["run", "scripts/audit/fast_duplicate_check.spl", "--", root, "--min-lines", "3", "--max-allowed", "0"])
        expect(result.2).to_equal(1)
        expect(result.0).to_contain("Token Duplicate Report")
        expect(result.0).to_contain("Found 1 duplicate groups")

        val allowed = rt_process_run("bin/simple", ["run", "scripts/audit/fast_duplicate_check.spl", "--", root, "--min-lines", "3", "--max-allowed", "99"])
        expect(allowed.2).to_equal(0)

    it "keeps indentation-distinct windows separate":
        val root = "/tmp/simple_fast_duplicate_check_indentation"
        val (_clean_out, _clean_err, _clean_code) = rt_process_run("/bin/sh", ["-c", "rm -rf " + root + " && mkdir -p " + root])
        val left = "fn choose(flag: bool) -> i64:\n    if flag:\n        return 1\n    return 0"
        val right = "fn choose(flag: bool) -> i64:\n    if flag:\n    return 1\n    return 0"
        expect(rt_file_write_text(root + "/a.spl", left)).to_equal(true)
        expect(rt_file_write_text(root + "/b.spl", right)).to_equal(true)

        val result = rt_process_run("bin/simple", ["run", "scripts/audit/fast_duplicate_check.spl", "--", root, "--min-lines", "4", "--max-allowed", "0"])
        expect(result.2).to_equal(0)
        expect(result.0).to_contain("Found 0 duplicate groups")

    it "preserves newline and leading-dash paths without shell discovery":
        val root = "/tmp/simple_fast_duplicate_check_hostile_paths"
        val (_clean_out, _clean_err, _clean_code) = rt_process_run("/bin/sh", ["-c", "rm -rf " + root + " && mkdir -p " + root])
        val body =
            "fn shared(value: i64) -> i64:\n" +
            "    val next = value + 1\n" +
            "    return next\n"
        expect(rt_file_write_text(root + "/line\nbreak.spl", body)).to_equal(true)
        expect(rt_file_write_text(root + "/-leading.spl", body)).to_equal(true)

        val result = rt_process_run("bin/simple", ["run", "scripts/audit/fast_duplicate_check.spl", "--", root, "--min-lines", "3", "--max-allowed", "99", "--format", "json"])
        expect(result.2).to_equal(0)
        expect(result.0).to_contain("\"files\": 2")
        expect(result.0).to_contain("line\\nbreak.spl")
        expect(result.0).to_contain("-leading.spl")
