# doppler_spec
#
# Tests compute_doppler_pitch from std.nogc_sync_mut.engine.audio.doppler
# Verifies Doppler pitch calculation for stationary and moving sources.

use std.spec
use std.common.engine.math3d.{Vec3}
use std.nogc_sync_mut.engine.audio.doppler.{DopplerConfig, default_doppler_config, compute_doppler_pitch}

describe "Doppler — stationary":

    it "stationary listener and source gives pitch 1.0":
        val config = default_doppler_config()
        val zero = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val pos = Vec3(x: 10.0, y: 0.0, z: 0.0)
        val pitch = compute_doppler_pitch(zero, zero, pos, zero, config)
        expect(pitch > 0.99).to_equal(true)
        expect(pitch < 1.01).to_equal(true)

describe "Doppler — source moving toward listener":

    it "pitch is greater than 1.0":
        val config = default_doppler_config()
        val l_pos = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val l_vel = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val s_pos = Vec3(x: 100.0, y: 0.0, z: 0.0)
        val s_vel = Vec3(x: -50.0, y: 0.0, z: 0.0)
        val pitch = compute_doppler_pitch(l_pos, l_vel, s_pos, s_vel, config)
        expect(pitch > 1.0).to_equal(true)

describe "Doppler — source moving away from listener":

    it "pitch is less than 1.0":
        val config = default_doppler_config()
        val l_pos = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val l_vel = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val s_pos = Vec3(x: 100.0, y: 0.0, z: 0.0)
        val s_vel = Vec3(x: 50.0, y: 0.0, z: 0.0)
        val pitch = compute_doppler_pitch(l_pos, l_vel, s_pos, s_vel, config)
        expect(pitch < 1.0).to_equal(true)

describe "Doppler — disabled":

    it "disabled doppler returns 1.0 regardless of velocities":
        val config = DopplerConfig(enabled: false, speed_of_sound: 343.0, factor: 1.0)
        val l_pos = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val l_vel = Vec3(x: 0.0, y: 0.0, z: 0.0)
        val s_pos = Vec3(x: 100.0, y: 0.0, z: 0.0)
        val s_vel = Vec3(x: -50.0, y: 0.0, z: 0.0)
        val pitch = compute_doppler_pitch(l_pos, l_vel, s_pos, s_vel, config)
        expect(pitch > 0.99).to_equal(true)
        expect(pitch < 1.01).to_equal(true)
