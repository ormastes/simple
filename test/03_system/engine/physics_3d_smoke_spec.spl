# Physics2 3D Sphere Smoke Test — System Test
#
# Verifies: PhysicsWorld3D basic API, gravity integration,
# sphere body creation, position/velocity queries.

use std.io_runtime
use std.spec.{describe, it, expect}
use std.common.math.{math_sqrt, math_abs}
use std.common.engine.ids.{NodeId, RawHandle}
use std.nogc_sync_mut.engine.physics.config.{default_physics_config_3d, Vec3}
use std.nogc_sync_mut.engine.physics.world3d.{PhysicsWorld3D}

fn make_node(idx: i64) -> NodeId:
    NodeId(raw: RawHandle.new(idx, 1))

fn step_3d(world: PhysicsWorld3D, n: i64):
    var i = 0
    while i < n:
        world.step(0.016)
        i = i + 1

describe "Physics2 3D Smoke Test":
    it "sphere falls under gravity":
        var config = default_physics_config_3d()
        var world = PhysicsWorld3D.create(config)
        world.add_dynamic_body(make_node(0), 0.0, 10.0, 0.0, 1.0)
        world.add_sphere_collider(make_node(0), 0.5)
        step_3d(world, 30)
        val pos = world.get_position(make_node(0))
        expect(pos.y < 10.0).to_equal(true)
        expect(pos.y > -50.0).to_equal(true)
        world.destroy()

    it "x and z unchanged for vertical drop":
        var config = default_physics_config_3d()
        var world = PhysicsWorld3D.create(config)
        world.add_dynamic_body(make_node(0), 3.0, 10.0, -2.0, 1.0)
        world.add_sphere_collider(make_node(0), 0.5)
        step_3d(world, 20)
        val pos = world.get_position(make_node(0))
        expect(math_abs(pos.x - 3.0) < 0.01).to_equal(true)
        expect(math_abs(pos.z - (-2.0)) < 0.01).to_equal(true)
        world.destroy()

    it "body count correct":
        var config = default_physics_config_3d()
        var world = PhysicsWorld3D.create(config)
        world.add_dynamic_body(make_node(0), 0.0, 5.0, 0.0, 1.0)
        world.add_sphere_collider(make_node(0), 0.5)
        world.add_static_body(make_node(1), 0.0, 0.0, 0.0)
        world.add_box_collider(make_node(1), 5.0, 0.5, 5.0)
        expect(world.body_count() == 2).to_equal(true)
        world.destroy()

    it "velocity increases during fall":
        var config = default_physics_config_3d()
        var world = PhysicsWorld3D.create(config)
        world.add_dynamic_body(make_node(0), 0.0, 10.0, 0.0, 1.0)
        world.add_sphere_collider(make_node(0), 0.5)
        step_3d(world, 10)
        val vel = world.get_velocity(make_node(0))
        expect(vel.y < -0.1).to_equal(true)
        world.destroy()
