fn main() -> int:
    val line = "fn add_numbers(a: i32, b: i32) -> i32:"
    val params_start = line.index_of("(") ?? -1
    val params_end = line.index_of(")") ?? -1
    print line.substring(3, params_start).trim()
    print line.substring(params_start + 1, params_end).trim()
    val arrow_index = line.index_of("->") ?? -1
    var ret = line.substring(arrow_index + 2).trim()
    print ret
    val colon_index = ret.index_of(":") ?? -1
    print colon_index
    if colon_index >= 0:
        ret = ret.substring(0, colon_index).trim()
    print ret
    0
