fn main() -> int:
    val raw = "    mode: u8 @bits(4)"
    val trimmed = raw.trim()
    print raw.starts_with(" ")
    val field_parts = trimmed.split(":")
    print field_parts
    var type_part = field_parts[1].trim()
    print type_part
    val bits_start = type_part.index_of("@bits(") ?? -1
    print bits_start
    if bits_start >= 0:
        val bits_text = type_part.substring(bits_start + 6)
        print bits_text
        val bits_end = bits_text.index_of(")") ?? -1
        print bits_end
        if bits_end >= 0:
            print bits_text.substring(0, bits_end).trim()
            print type_part.substring(0, bits_start).trim()
    0
