use compiler.driver.driver_api.{generate_headers}
extern fn rt_file_exists(path: text) -> bool

fn main() -> int:
    val result = generate_headers("/tmp/sffi_driver_header_spec.spl", "/tmp/repo_child_hdr_out", "gpio_driver", true, true)
    print result
    print rt_file_exists("/tmp/repo_child_hdr_out/gpio_driver.h")
    print rt_file_exists("/tmp/repo_child_hdr_out/gpio_driver.hpp")
    0
