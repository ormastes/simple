use compiler.driver.driver_public_shared.{_sanitize_shared_source}
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

fn main() -> int:
    val source = rt_file_read_text("/tmp/sffi_driver_header_spec.spl") ?? ""
    val sanitized = _sanitize_shared_source(source)
    print rt_file_write_text("/tmp/sanitized_shared_input.spl", sanitized)
    0
