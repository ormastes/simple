# @cover src/compiler/60.mir_opt/mir_opt/pattern/rules_clib_parity.spl 40%
"""
# DB Optimization Patterns Specification

**Feature IDs:** #db-hardening-optimization
**Category:** Optimization Patterns
**Difficulty:** 2/5
**Status:** Draft
**Plan:** doc/03_plan/db_hardening_optimization_plan_2026-05-26.md

## Overview

Validates the 5 DB-domain optimization patterns registered in the
clib-parity rule engine. Each pattern has a CLibPatternKind variant,
a named rule with intrinsic/requires/required_proof, and specific
cost_delta and software_cost values calibrated to the DB workload.

## Behavior

- FtsMatch pattern: FTS via inverted index + BM25
- ContainsSearch pattern: substring/trigram contains search
- PageSummaryScan pattern: page-level min/max summary for range skip
- CacheInvalidation pattern: dirty-flag invalidation on mutation paths
- ReopenRecovery pattern: WAL replay + FTS rebuild on DB reopen
"""

use std.spec
use compiler.mir_opt.mir_opt.pattern.rules_clib_parity.{
    CLibPatternKind, clib_parity_rule_by_name,
    clib_parity_rule_rewrite_decision, clib_parity_domain_rule_count
}


# ============================================================================
# AC-7: DB optimization patterns in general-optimization-patterns
# ============================================================================

describe "DB Optimization Patterns (AC-7)":
    describe "FtsMatch pattern":
        it "AC-7: match_db_fts_match rule registered with FtsMatch kind":
            val maybe_rule = clib_parity_rule_by_name("match_db_fts_match")
            expect(maybe_rule.?).to_equal(true)
            if maybe_rule:
                val rule = maybe_rule.unwrap()
                val is_fts = rule.pattern_kind == CLibPatternKind.FtsMatch
                expect(is_fts).to_equal(true)
                expect(rule.domain).to_equal("database")
                expect(rule.intrinsic).to_equal("db_fts_match")
                expect(rule.cost_delta).to_equal(-6)
                expect(rule.software_cost).to_equal(1600)

        it "AC-7: FtsMatch proof gate rejects without fts_index_consistency":
            val maybe_rule = clib_parity_rule_by_name("match_db_fts_match")
            expect(maybe_rule.?).to_equal(true)
            if maybe_rule:
                val rule = maybe_rule.unwrap()
                val rejected = clib_parity_rule_rewrite_decision(rule, ["fts_index"], [])
                expect(rejected.eligible).to_equal(false)
                val accepted = clib_parity_rule_rewrite_decision(rule, ["fts_index"], ["fts_index_consistency"])
                expect(accepted.eligible).to_equal(true)

