# Verification decision evidence for SPipe LLM fine-tune attempts.

decisions:
  - attempt_id: "llm_backed_app_server_dry_run"
    status: "try-other-way"
    retry_target: "requirements-selection"
    next_attempt: "first-selected-production-attempt"
    notes: "Dry-run proves the SPipe record and verification loop. It does not train a model."
  - attempt_id: "llm_backed_app_server_dry_run"
    status: "retry-data-research"
    retry_target: "data-quality"
    next_attempt: "none"
    notes: "Best available trained MedGemma artifact is below target and below 57.78 percent English baseline; continue with fixed-format/data-quality retry rather than accept model."
  - attempt_id: "llm_backed_app_server_dry_run"
    status: "retry-data-research"
    retry_target: "data-quality"
    next_attempt: "llm_backed_app_server_dry_run_retry1"
    notes: "Create retry using fixed-format prompt/data-quality path because best existing MedGemma artifact reached 54.6 percent vs 90 percent target."
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    status: "retry-data-research"
    retry_target: "complete fixed-format data-quality retry and rerun target_accuracy>=90.0 eval before app/server acceptance"
    next_attempt: "llm_backed_app_server_dry_run_retry2"
    notes: "Normal LLM inspection found no pass evidence; structural handoff is complete but model quality is not accepted."
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    status: "retry-implementation"
    retry_target: "run licensed fixed-format KorMedMCQA data build, QLoRA training, and target_accuracy>=90.0 eval"
    next_attempt: "llm_backed_app_server_dry_run_retry3"
    notes: "Retry2 closes synthetic fixed-format gate only; do not accept model until real data/eval reaches target."
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    status: "retry-implementation"
    retry_target: "replace dry-run artifact with licensed real-data QLoRA training and target eval"
    next_attempt: "llm_backed_app_server_dry_run_retry4"
    notes: "Retry3 proves implementation artifact/eval handoff shape only; do not accept until real training reaches target."
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    status: "retry-data-research"
    retry_target: "obtain licensed fixed-format data access, checksum/cache evidence, and license approval before QLoRA"
    next_attempt: "llm_backed_app_server_dry_run_retry5"
    notes: "Retry4 is a license/data-access gate only; do not train or accept until data/license evidence exists."
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    status: "retry-data-research"
    retry_target: "obtain licensed fixed-format data access, write cache path and checksum evidence, then run QLoRA and target eval"
    next_attempt: "llm_backed_app_server_dry_run_retry6"
    notes: "Retry5 is a licensed data acquisition/cache gate only; do not train or accept until license, cache, checksum, and target eval evidence exist."
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    status: "retry-data-research"
    retry_target: "complete retry5 licensed cache/checksum review before real QLoRA, then write model artifact and target eval evidence"
    next_attempt: "llm_backed_app_server_dry_run_retry7"
    notes: "Retry6 is a real-training/eval gate shape only; do not accept until retry5 review passes and target eval evidence exists."
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
    status: "retry-implementation"
    retry_target: "complete retry6 real QLoRA artifact and target eval, then normal review may accept or choose another retry"
    next_attempt: "none"
    notes: "Retry7 is a normal acceptance gate shape only; do not accept until retry6 produces real artifacts and normal review records an accepted decision."
