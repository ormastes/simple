# New-model architecture evidence for SPipe LLM fine-tune attempts.

model_architecture:
  - attempt_id: "llm_backed_app_server_dry_run"
    architecture_doc: "doc/04_architecture/spipe_llm_finetune_process.md"
    model_family: "pending-user-selection"
    data_strategy: "pending-user-selection"
    training_strategy: "pending-user-selection"
    deployment_target: "pending-user-selection"
    fallback: "use existing base model or non-training approach after requirements selection"
  - attempt_id: "llm_backed_app_server_dry_run"
    architecture_doc: "doc/04_architecture/spipe_llm_finetune_model_architecture.md"
    model_family: "local-qlora-adapter"
    data_strategy: "recorded data downloads plus checksum/cache evidence feed instruction data preparation"
    training_strategy: "start with local QLoRA adapter; fallback to provider fine-tune; route eval failures to retrieval/tool/app changes when tuning is not the right fix"
    deployment_target: "local-or-provider"
    fallback: "provider-fine-tune"
