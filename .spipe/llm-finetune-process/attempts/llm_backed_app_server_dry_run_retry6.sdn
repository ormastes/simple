attempt:
  attempt_id: "llm_backed_app_server_dry_run_retry6"
  goal: "Run real QLoRA only after licensed cache review and require target eval before acceptance"
  app_or_server_target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"

research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process.md"
  data_sources:
    - name: "licensed-kormedmcqa-fixed-format"
      source: "retry5 verified cache manifest required before training"
      license: "pending retry5 license/data-access approval; do not train yet"
      download_command: ".spipe/llm-finetune-process/scripts/check_retry5_review_handoff.shs llm_backed_app_server_dry_run_retry5"
      checksum: "pending-retry5-cache-manifest"
      cache_path: "not-created"

requirements:
  feature_option: "local-qlora-medical-domain-retry"
  nfr_option: "accuracy-target-90-percent-with-604-sample-eval"
  selected_by: "retry5 decision handoff"
  selection_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"

process_docs:
  requirements_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"
  nfr_doc: "doc/02_requirements/nfr/spipe_llm_finetune_process.md"
  plan_doc: "doc/03_plan/ml/spipe_llm_finetune_process.md"
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_process.md"
  design_doc: "doc/05_design/app/spipe/spipe_llm_finetune_process.md"

model_research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
  candidate_model: "google/medgemma-4b-it"
  license: "Health AI community license plus dataset license review required before training"
  context_length: "deployment context window must be reverified before serving"
  fit: "medical-domain base model remains candidate, but retry6 cannot start before retry5 licensed cache review passes"
  constraints: "retry6 blocks real QLoRA until retry5 review is PASS and still blocks acceptance until target eval plus app handoff evidence exist"
  decision: "hold-training-behind-retry5-cache-review"

model_architecture:
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  model_family: "MedGemma"
  data_strategy: "consume only retry5-approved licensed fixed-format cache with matching checksum"
  training_strategy: "run local QLoRA only after retry5 review emits PASS; write model and eval artifacts before normal review"
  deployment_target: "local app/server only after target-reaching eval and accepted decision"
  fallback: "switch to retrieval/tool strategy or alternate dataset/model if license or target eval cannot pass"

model:
  base_model: "google/medgemma-4b-it"
  base_model_revision: "not-pinned-before-retry5-cache-review"
  base_model_reason: "Keep prior candidate while making retry6 enforce licensed cache, QLoRA artifact, and target eval gates."
  deployment_target: "local app/server after accepted eval"

tuning:
  method: "local-qlora"
  training_script: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs"
  training_command: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs llm_backed_app_server_dry_run_retry6"
  model_artifact: "not-created"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs llm_backed_app_server_dry_run_retry6"
  metrics: "upstream_retry5_review=warn; training_allowed=false; model_artifact=not-created; target_eval=not-run"
  target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
  result: "BLOCKED_UPSTREAM_LICENSED_DATA_NOT_READY"

decision:
  status: "retry-data-research"
  retry_target: "complete retry5 licensed cache/checksum review before real QLoRA, then write model artifact and target eval evidence"
  next_attempt: "llm_backed_app_server_dry_run_retry7"
  notes: "Retry6 is the real-training/eval gate shape only; do not train, accept, or deploy until retry5 review passes and target eval evidence exists."

app_handoff:
  app_target: "medgemma_korean"
  usage: "do not deploy; retry6 has no approved upstream cache, trained artifact, target eval, or accepted decision"
  handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  license_constraints: "Health AI community license plus dataset license review required; retry5 cache review not passed"
  safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
  deployment_evidence: "not-deployable; retry5 cache review, runtime, memory target, latency target, and fallback model pending"

retune:
  reason: "retry5 licensed cache review has not passed, so retry6 cannot run real QLoRA or target eval"
  source_eval: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs"
  next_attempt: "llm_backed_app_server_dry_run_retry7"
  retry_target: "retry5 PASS, real QLoRA artifact, target eval, safety review, and deployment handoff"
