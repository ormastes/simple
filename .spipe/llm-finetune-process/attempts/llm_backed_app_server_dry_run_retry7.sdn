attempt:
  attempt_id: "llm_backed_app_server_dry_run_retry7"
  goal: "Accept or reject retry6 only after normal review of target eval, license, safety, deployment, and app handoff evidence"
  app_or_server_target: "release handoff for target_accuracy>=90.0 only after retry6 artifacts exist and normal review accepts"

research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process.md"
  data_sources:
    - name: "retry6-trained-artifact-and-eval"
      source: "retry6 model_manifest.json and eval_result.json"
      license: "must be concrete and reviewed before acceptance"
      download_command: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs llm_backed_app_server_dry_run_retry6"
      checksum: "pending-retry6-target-eval-review"
      cache_path: "not-created"

requirements:
  feature_option: "normal-acceptance-review-after-real-training"
  nfr_option: "target-reaching-eval-plus-release-handoff"
  selected_by: "retry6 decision handoff"
  selection_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"

process_docs:
  requirements_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"
  nfr_doc: "doc/02_requirements/nfr/spipe_llm_finetune_process.md"
  plan_doc: "doc/03_plan/ml/spipe_llm_finetune_process.md"
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_process.md"
  design_doc: "doc/05_design/app/spipe/spipe_llm_finetune_process.md"

model_research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
  candidate_model: "google/medgemma-4b-it"
  license: "pending concrete retry6 artifact and license review"
  context_length: "deployment context window must be reverified before serving"
  fit: "review candidate only after retry6 produces a real artifact and target eval"
  constraints: "normal acceptance cannot proceed while retry6 has no model/eval artifacts"
  decision: "hold-acceptance-behind-retry6-training-eval"

model_architecture:
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  model_family: "MedGemma"
  data_strategy: "consume retry6-reviewed artifact/eval only"
  training_strategy: "no training in retry7; retry7 is normal review and release-handoff gate"
  deployment_target: "local app/server only after accepted decision"
  fallback: "retry data, model, tuning method, or retrieval/tool strategy if review fails"

model:
  base_model: "google/medgemma-4b-it"
  base_model_revision: "pending-retry6-artifact"
  base_model_reason: "Retry7 reviews the retry6 candidate; it does not select or train a new model."
  deployment_target: "local app/server after accepted eval"

tuning:
  method: "normal-acceptance-review"
  training_script: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs"
  training_command: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs llm_backed_app_server_dry_run_retry7"
  model_artifact: "not-created"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs llm_backed_app_server_dry_run_retry7"
  metrics: "retry6_training_eval_gate=warn; acceptance_allowed=false; accepted_decision=missing"
  target: "normal review accepts only after retry6 target_accuracy>=90.0 plus safety/deployment/app handoff evidence"
  result: "BLOCKED_RETRY6_NOT_READY"

decision:
  status: "retry-implementation"
  retry_target: "complete retry6 real QLoRA artifact and target eval, then normal review may accept or choose another retry"
  next_attempt: "none"
  notes: "Retry7 is a normal acceptance gate shape only. It must not accept until retry6 writes real model/eval artifacts and normal review records accepted decision."

app_handoff:
  app_target: "medgemma_korean"
  usage: "do not deploy; retry7 has no accepted retry6 model/eval/safety/deployment evidence"
  handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  license_constraints: "pending"
  safety_eval: "not-run"
  deployment_evidence: "not-deployable"

retune:
  reason: "retry6 target model artifact, target eval, and accepted decision are missing"
  source_eval: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs"
  next_attempt: "none"
  retry_target: "finish retry6 or choose another tuning/data/model strategy after normal review"
