attempt:
  attempt_id: "llm_backed_app_server_dry_run_retry3"
  goal: "Implementation retry: local artifact/eval dry-run after fixed-format data gate"
  app_or_server_target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"

research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process.md"
  data_sources:
    - name: "retry3-fixed-format-synthetic-mcq-fixture"
      source: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
      license: "synthetic repo-local format fixture; real medical data still requires license review"
      download_command: "reuse retry2 repo-local synthetic fixture; no external download"
      checksum: "not-recorded-synthetic-fixture"
      cache_path: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"

requirements:
  feature_option: "local-qlora-medical-domain-retry"
  nfr_option: "accuracy-target-90-percent-with-604-sample-eval"
  selected_by: "retry2 decision handoff"
  selection_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"

process_docs:
  requirements_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"
  nfr_doc: "doc/02_requirements/nfr/spipe_llm_finetune_process.md"
  plan_doc: "doc/03_plan/ml/spipe_llm_finetune_process.md"
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_process.md"
  design_doc: "doc/05_design/app/spipe/spipe_llm_finetune_process.md"

model_research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
  candidate_model: "google/medgemma-4b-it"
  license: "Health AI community license; production and clinical use require explicit review"
  context_length: "deployment context window must be reverified before serving"
  fit: "medical-domain base model with prior Korean MedGemma project evidence"
  constraints: "retry3 creates local artifact/eval evidence only; no accepted clinical model"
  decision: "continue-with-medgemma-for-implementation-dry-run"

model_architecture:
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  model_family: "MedGemma"
  data_strategy: "fixed-format synthetic gate plus local artifact manifest before real licensed data rerun"
  training_strategy: "local implementation dry-run writes artifact/eval manifest; real QLoRA remains required"
  deployment_target: "local app/server only after target-reaching eval"
  fallback: "switch to data/model/tool strategy if real rerun remains below target"

model:
  base_model: "google/medgemma-4b-it"
  base_model_revision: "not-pinned-in-existing-evidence"
  base_model_reason: "Keep prior candidate for retry3 while proving implementation artifact/eval handoff shape."
  deployment_target: "local app/server after accepted eval"

tuning:
  method: "local-qlora"
  training_script: ".spipe/llm-finetune-process/scripts/run_retry3_local_artifact_eval.shs"
  training_command: ".spipe/llm-finetune-process/scripts/run_retry3_local_artifact_eval.shs"
  model_artifact: ".spipe/llm-finetune-process/artifacts/llm_backed_app_server_dry_run_retry3/model_manifest.json"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/run_retry3_local_artifact_eval.shs"
  metrics: "format_gate=pass; artifact_manifest=created; model_accuracy=not-run; target_accuracy=90.0"
  target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
  result: "FAIL_IMPLEMENTATION_DRY_RUN_NO_REAL_TRAINING"

decision:
  status: "retry-implementation"
  retry_target: "replace dry-run artifact with licensed real-data QLoRA training and target eval"
  next_attempt: "llm_backed_app_server_dry_run_retry4"
  notes: "Retry3 proves implementation artifact/eval handoff shape only; do not accept until real training reaches target."

app_handoff:
  app_target: "medgemma_korean"
  usage: "do not deploy; retry3 artifact is a local dry-run manifest and no real model eval has run"
  handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  license_constraints: "Health AI community license plus dataset license review required before deployment"
  safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
  deployment_evidence: "not-deployable; dry-run artifact only and runtime/memory/latency/fallback evidence is pending"

retune:
  reason: "implementation dry-run artifact exists but no target-reaching trained model"
  source_eval: ".spipe/llm-finetune-process/artifacts/llm_backed_app_server_dry_run_retry3/eval_result.json"
  next_attempt: "llm_backed_app_server_dry_run_retry4"
  retry_target: "licensed real-data QLoRA rerun and target eval"
