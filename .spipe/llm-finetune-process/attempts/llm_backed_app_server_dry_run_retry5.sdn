attempt:
  attempt_id: "llm_backed_app_server_dry_run_retry5"
  goal: "Licensed fixed-format data acquisition and cache verification before QLoRA"
  app_or_server_target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"

research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process.md"
  data_sources:
    - name: "licensed-kormedmcqa-fixed-format"
      source: "external medical QA dataset pending access approval"
      license: "missing license approval; do not train"
      download_command: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs llm_backed_app_server_dry_run_retry5"
      checksum: "missing-before-cache"
      cache_path: "not-created"

requirements:
  feature_option: "local-qlora-medical-domain-retry"
  nfr_option: "accuracy-target-90-percent-with-604-sample-eval"
  selected_by: "retry4 decision handoff"
  selection_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"

process_docs:
  requirements_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"
  nfr_doc: "doc/02_requirements/nfr/spipe_llm_finetune_process.md"
  plan_doc: "doc/03_plan/ml/spipe_llm_finetune_process.md"
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_process.md"
  design_doc: "doc/05_design/app/spipe/spipe_llm_finetune_process.md"

model_research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
  candidate_model: "google/medgemma-4b-it"
  license: "Health AI community license plus dataset license review required before training"
  context_length: "deployment context window must be reverified before serving"
  fit: "medical-domain base model remains candidate after retry4 license gate"
  constraints: "retry5 blocks real QLoRA until licensed fixed-format data, checksum/cache evidence, and license approval exist"
  decision: "hold-medgemma-candidate-behind-data-access-gate"

model_architecture:
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  model_family: "MedGemma"
  data_strategy: "licensed fixed-format medical QA data with recorded cache path and checksum before training"
  training_strategy: "do not run QLoRA until license, cache, and checksum evidence are present"
  deployment_target: "local app/server only after target-reaching eval and accepted decision"
  fallback: "switch to retrieval/tool strategy or alternate dataset/model if license cannot be cleared"

model:
  base_model: "google/medgemma-4b-it"
  base_model_revision: "not-pinned-before-license-gate"
  base_model_reason: "Keep prior candidate while gating training on licensed data access and cache evidence."
  deployment_target: "local app/server after accepted eval"

tuning:
  method: "local-qlora"
  training_script: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs"
  training_command: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs llm_backed_app_server_dry_run_retry5"
  model_artifact: "not-created"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs llm_backed_app_server_dry_run_retry5"
  metrics: "license_review=missing; data_access=missing; cache_checksum=missing; training_allowed=false; model_accuracy=not-run"
  target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
  result: "BLOCKED_LICENSED_DATA_NOT_AVAILABLE"

decision:
  status: "retry-data-research"
  retry_target: "obtain licensed fixed-format data access, write cache path and checksum evidence, then run QLoRA and target eval"
  next_attempt: "llm_backed_app_server_dry_run_retry6"
  notes: "Retry5 is a licensed data acquisition/cache gate only; do not train or accept until license, cache, checksum, and target eval evidence exist."

app_handoff:
  app_target: "medgemma_korean"
  usage: "do not deploy; retry5 has no licensed data cache, trained artifact, or target eval"
  handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  license_constraints: "Health AI community license plus dataset license review required; distribution not approved"
  safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
  deployment_evidence: "not-deployable; runtime, memory target, latency target, and fallback model pending"

retune:
  reason: "licensed fixed-format data, cache path, checksum, and license approval are missing"
  source_eval: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs"
  next_attempt: "llm_backed_app_server_dry_run_retry6"
  retry_target: "licensed data acquisition, cache/checksum verification, QLoRA rerun, and target eval"
