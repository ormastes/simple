# Retune request evidence for SPipe LLM-backed app/server loops.

retune_requests:
  - attempt_id: "llm_backed_app_server_dry_run"
    reason: "requirements-selection-required-before-real-training"
    source_eval: ".spipe/llm-finetune-process/eval_results.sdn"
    next_attempt: "first-selected-production-attempt"
    retry_target: "requirements-selection"
  - attempt_id: "llm_backed_app_server_dry_run"
    reason: "retry-data-research"
    source_eval: "decisions.sdn:llm_backed_app_server_dry_run"
    next_attempt: "llm_backed_app_server_dry_run_retry1"
    retry_target: "data-quality"
