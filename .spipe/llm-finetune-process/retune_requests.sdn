# Retune request evidence for SPipe LLM-backed app/server loops.

retune_requests:
  - attempt_id: "llm_backed_app_server_dry_run"
    reason: "requirements-selection-required-before-real-training"
    source_eval: ".spipe/llm-finetune-process/eval_results.sdn"
    next_attempt: "first-selected-production-attempt"
    retry_target: "requirements-selection"
  - attempt_id: "llm_backed_app_server_dry_run"
    reason: "retry-data-research"
    source_eval: "decisions.sdn:llm_backed_app_server_dry_run"
    next_attempt: "llm_backed_app_server_dry_run_retry1"
    retry_target: "data-quality"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    reason: "existing MedGemma artifact is below the required accuracy target"
    source_eval: "train_03_medgemma-4b_20260225_230747.log and training_info.json"
    next_attempt: "llm_backed_app_server_dry_run_retry2"
    retry_target: "fixed-format data-quality pass plus target_accuracy>=90.0 eval"
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    reason: "fixed-format synthetic data-quality gate passed but real training/eval still required"
    source_eval: ".spipe/llm-finetune-process/scripts/check_fixed_format_data_quality.shs"
    next_attempt: "llm_backed_app_server_dry_run_retry3"
    retry_target: "licensed real-data fixed-format build plus QLoRA rerun and target eval"
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    reason: "retry-implementation"
    source_eval: "decisions.sdn:llm_backed_app_server_dry_run_retry2"
    next_attempt: "llm_backed_app_server_dry_run_retry3"
    retry_target: "run licensed fixed-format KorMedMCQA data build, QLoRA training, and target_accuracy>=90.0 eval"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    reason: "implementation dry-run artifact exists but no target-reaching trained model"
    source_eval: ".spipe/llm-finetune-process/artifacts/llm_backed_app_server_dry_run_retry3/eval_result.json"
    next_attempt: "llm_backed_app_server_dry_run_retry4"
    retry_target: "licensed real-data QLoRA rerun and target eval"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    reason: "retry-implementation"
    source_eval: "decisions.sdn:llm_backed_app_server_dry_run_retry3"
    next_attempt: "llm_backed_app_server_dry_run_retry4"
    retry_target: "replace dry-run artifact with licensed real-data QLoRA training and target eval"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    reason: "licensed fixed-format data and license approval are missing"
    source_eval: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs"
    next_attempt: "llm_backed_app_server_dry_run_retry5"
    retry_target: "licensed data acquisition and cache/checksum verification"
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    reason: "licensed fixed-format data, cache path, checksum, and license approval are missing"
    source_eval: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs"
    next_attempt: "llm_backed_app_server_dry_run_retry6"
    retry_target: "licensed data acquisition, cache/checksum verification, QLoRA rerun, and target eval"
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    reason: "retry5 licensed cache review has not passed, so retry6 cannot run real QLoRA or target eval"
    source_eval: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs"
    next_attempt: "llm_backed_app_server_dry_run_retry7"
    retry_target: "retry5 PASS, real QLoRA artifact, target eval, safety review, and deployment handoff"
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
    reason: "retry6 target model artifact, target eval, and accepted decision are missing"
    source_eval: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs"
    next_attempt: "none"
    retry_target: "finish retry6 or choose another tuning/data/model strategy after normal review"
