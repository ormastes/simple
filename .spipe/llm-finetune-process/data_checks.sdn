# Data cache/checksum verification evidence for SPipe LLM fine-tune attempts.

data_checks:
  - attempt_id: "llm_backed_app_server_dry_run"
    name: "dry-run-no-download"
    cache_path: ".spipe/llm-finetune-process/data/dry-run"
    result: "skipped-until-requirements-selected"
    checksum: "not-applicable"
    notes: "Dry run records planned data only; no data is downloaded before requirement selection."
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    name: "kormedmcqa-existing-medgemma-eval"
    cache_path: "/home/ormastes/dev/pub/medgemma_korean"
    result: "existing-evidence-reused"
    checksum: "not-recorded-for-existing-run"
    notes: "Existing run evidence is sufficient for structural SPipe handoff, but model quality remains below target."
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    name: "retry2-fixed-format-synthetic-mcq-fixture"
    cache_path: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    result: "format-pass"
    checksum: "not-recorded-synthetic-fixture"
    notes: "Fixed-format checker passes on synthetic repo fixture; real licensed data build and model eval remain required."
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    name: "retry3-fixed-format-synthetic-mcq-fixture"
    cache_path: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    result: "pass"
    checksum: "not-recorded-synthetic-fixture"
    notes: "fixed-format gate passed before artifact/eval dry-run"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    name: "licensed-data-access-gate"
    cache_path: "not-created"
    result: "blocked-license-missing"
    checksum: "not-available-before-license"
    notes: "No data cache or checksum may be claimed before license/access approval."
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    name: "licensed-data-cache-checksum-gate"
    cache_path: "not-created"
    result: "blocked-license-data-cache-missing"
    checksum: "missing-before-cache"
    checker: ".spipe/llm-finetune-process/scripts/check_retry5_cache_manifest.shs llm_backed_app_server_dry_run_retry5 .spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry5_cache_manifest.sdn"
    notes: "Retry5 is the current handoff for licensed data acquisition; the cache manifest checker only passes after license approval, data access, a real cache path, and a matching sha256 checksum are recorded."
