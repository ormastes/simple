# Data download evidence for SPipe LLM fine-tune attempts.

data_downloads:
  - attempt_id: "llm_backed_app_server_dry_run"
    name: "dry-run-no-download"
    source: "requirements-options"
    license: "not-applicable"
    download_command: "not-run-until-requirements-selected"
    cache_path: ".spipe/llm-finetune-process/data/dry-run"
    checksum: "not-applicable"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    name: "kormedmcqa-existing-medgemma-eval"
    source: "existing /home/ormastes/dev/pub/medgemma_korean run evidence"
    license: "requires medical dataset and Health AI community license review before production use"
    download_command: "not-rerun; reuse existing MedGemma Korean evidence for retry handoff"
    cache_path: "/home/ormastes/dev/pub/medgemma_korean"
    checksum: "not-recorded-for-existing-run"
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    name: "retry2-fixed-format-synthetic-mcq-fixture"
    source: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    license: "synthetic repo-local format fixture; real medical data still requires license review"
    download_command: "repo-local synthetic fixture; no external download"
    cache_path: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    checksum: "not-recorded-synthetic-fixture"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    name: "retry3-fixed-format-synthetic-mcq-fixture"
    source: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    license: "synthetic repo-local format fixture; real medical data still requires license review"
    download_command: "reuse retry2 repo-local synthetic fixture; no external download"
    cache_path: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    checksum: "not-recorded-synthetic-fixture"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    name: "licensed-kormedmcqa-fixed-format"
    source: "external medical QA dataset pending access approval"
    license: "missing license approval; do not train"
    download_command: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs llm_backed_app_server_dry_run_retry4"
    cache_path: "not-created"
    checksum: "not-available-before-license"
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    name: "licensed-kormedmcqa-fixed-format"
    source: "external medical QA dataset pending access approval"
    license: "missing license approval; do not train"
    download_command: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs llm_backed_app_server_dry_run_retry5"
    cache_path: "not-created"
    checksum: "missing-before-cache"
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    name: "licensed-kormedmcqa-fixed-format"
    source: "retry5 verified cache manifest required before training"
    license: "pending retry5 license/data-access approval; do not train"
    download_command: ".spipe/llm-finetune-process/scripts/check_retry5_review_handoff.shs llm_backed_app_server_dry_run_retry5"
    cache_path: "not-created"
    checksum: "pending-retry5-cache-manifest"
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
    name: "retry6-target-eval-review"
    source: "retry6 model manifest and target eval evidence required before acceptance"
    license: "pending retry6 license/safety/deployment review; do not deploy"
    download_command: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs llm_backed_app_server_dry_run_retry7"
    cache_path: "not-created"
    checksum: "pending-retry6-target-eval-review"
