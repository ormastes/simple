#!/bin/sh
set -eu

ATTEMPT_ID="${1:-llm_backed_app_server_dry_run_retry5}"
MANIFEST="${2:-.spipe/llm-finetune-process/data/${ATTEMPT_ID}_cache_manifest.sdn}"
CACHE_CHECK="$("$(dirname "$0")/check_retry5_cache_manifest.shs" "$ATTEMPT_ID" "$MANIFEST")"

value_for() {
  key="$1"
  printf '%s\n' "$CACHE_CHECK" | sed -n "s/^${key}=//p" | tail -1
}

license_review="$(value_for license_review)"
data_access="$(value_for data_access)"
cache_checksum="$(value_for cache_checksum)"
training_allowed="$(value_for training_allowed)"
cache_result="$(value_for result)"
status="WARN"
result="BLOCKED_LICENSED_DATA_NOT_AVAILABLE"
if [ "$training_allowed" = "true" ]; then
  status="PASS"
  result="LICENSED_DATA_CACHE_READY"
fi

cat <<EOF
attempt_id=${ATTEMPT_ID}
manifest=${MANIFEST}
license_review=${license_review:-missing}
data_access=${data_access:-missing}
cache_checksum=${cache_checksum:-missing}
training_allowed=${training_allowed:-false}
model_artifact=not-created
target_accuracy=90.0
cache_result=${cache_result:-missing}
result=${result}
STATUS: ${status} retry5-data-access-gate
EOF
