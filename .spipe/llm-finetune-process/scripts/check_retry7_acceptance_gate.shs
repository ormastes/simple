#!/bin/sh
set -eu

ATTEMPT_ID="${1:-llm_backed_app_server_dry_run_retry7}"
UPSTREAM_ATTEMPT="${2:-llm_backed_app_server_dry_run_retry6}"
BASE_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
ATTEMPT="${3:-${BASE_DIR}/attempts/${ATTEMPT_ID}.sdn}"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"

status_for() {
  sed -n 's/^STATUS: //p' | tail -1
}

value_for() {
  key="$1"
  sed -n "s/^${key}=//p" | tail -1
}

record_value() {
  key="$1"
  sed -n "s/^[[:space:]]*${key}: \"\\(.*\\)\"[[:space:]]*$/\\1/p" "$ATTEMPT" | tail -1
}

if [ "$#" -ge 8 ]; then
  UPSTREAM_CHECK="$("${SCRIPT_DIR}/check_retry6_training_eval_gate.shs" "$UPSTREAM_ATTEMPT" "$4" "$5" "$6" "$7" "$8")"
else
  UPSTREAM_CHECK="$("${SCRIPT_DIR}/check_retry6_training_eval_gate.shs" "$UPSTREAM_ATTEMPT")"
fi
upstream_status="$(printf '%s\n' "$UPSTREAM_CHECK" | status_for)"
upstream_result="$(printf '%s\n' "$UPSTREAM_CHECK" | value_for result)"
training_allowed="$(printf '%s\n' "$UPSTREAM_CHECK" | value_for training_allowed)"
model_manifest_exists="$(printf '%s\n' "$UPSTREAM_CHECK" | value_for model_manifest_exists)"
eval_result_exists="$(printf '%s\n' "$UPSTREAM_CHECK" | value_for eval_result_exists)"
target_accuracy="$(printf '%s\n' "$UPSTREAM_CHECK" | value_for target_accuracy)"
target_eval_reached="$(printf '%s\n' "$UPSTREAM_CHECK" | value_for target_eval_reached)"

attempt_status=missing
decision_status=missing
safety_eval=missing
deployment_evidence=missing
license_constraints=missing
handoff_doc=missing
handoff_doc_ready=false

if [ -f "$ATTEMPT" ]; then
  ATTEMPT_CHECK="$("${SCRIPT_DIR}/verify_attempt.shs" "$ATTEMPT" || true)"
  attempt_status="$(printf '%s\n' "$ATTEMPT_CHECK" | status_for)"
  decision_status="$(record_value status)"
  safety_eval="$(record_value safety_eval)"
  deployment_evidence="$(record_value deployment_evidence)"
  license_constraints="$(record_value license_constraints)"
  handoff_doc="$(record_value handoff_doc)"
fi

if [ -n "$handoff_doc" ] &&
   [ "$handoff_doc" != "missing" ] &&
   [ -f "$handoff_doc" ]; then
  handoff_doc_ready=true
fi

acceptance_allowed=false
result="BLOCKED_RETRY6_NOT_READY"
next_action="complete retry6 training/eval gate before normal acceptance review"
status="WARN"

if [ "$upstream_result" = "TARGET_EVAL_REVIEW_REQUIRED" ] &&
   [ "$training_allowed" = "true" ] &&
   [ "$model_manifest_exists" = "true" ] &&
   [ "$eval_result_exists" = "true" ] &&
   [ "$target_eval_reached" = "true" ]; then
  result="BLOCKED_NORMAL_ACCEPTANCE_REVIEW"
  next_action="normal LLM must accept only after license, safety, deployment, and app handoff evidence are concrete"
fi

if [ "$attempt_status" = "PASS llm-finetune-attempt-record" ] &&
   [ "$decision_status" = "accepted" ] &&
   [ "$upstream_result" = "TARGET_EVAL_REVIEW_REQUIRED" ] &&
   [ "$training_allowed" = "true" ] &&
   [ "$model_manifest_exists" = "true" ] &&
   [ "$eval_result_exists" = "true" ] &&
   [ "$target_eval_reached" = "true" ] &&
   [ "$safety_eval" != "not-run" ] &&
   [ "$deployment_evidence" != "not-deployable" ] &&
   [ "$license_constraints" != "pending" ] &&
   [ "$handoff_doc_ready" = "true" ]; then
  acceptance_allowed=true
  result="READY_FOR_RELEASE_HANDOFF_REVIEW"
  next_action="release handoff may cite accepted fine-tune evidence"
  status="PASS"
fi

cat <<EOF
attempt_id=${ATTEMPT_ID}
upstream_attempt=${UPSTREAM_ATTEMPT}
upstream_retry6_status=${upstream_status:-missing}
upstream_retry6_result=${upstream_result:-missing}
training_allowed=${training_allowed:-false}
model_manifest_exists=${model_manifest_exists:-false}
eval_result_exists=${eval_result_exists:-false}
target_accuracy=${target_accuracy:-missing}
target_eval_reached=${target_eval_reached:-false}
attempt_record_status=${attempt_status:-missing}
decision_status=${decision_status:-missing}
safety_eval=${safety_eval:-missing}
deployment_evidence=${deployment_evidence:-missing}
license_constraints=${license_constraints:-missing}
handoff_doc=${handoff_doc:-missing}
handoff_doc_ready=${handoff_doc_ready}
acceptance_allowed=${acceptance_allowed}
acceptance_reason=normal acceptance requires retry6 target eval, accepted decision, license, safety, deployment, and app handoff evidence
next_action=${next_action}
result=${result}
STATUS: ${status} retry7-acceptance-gate
EOF
