#!/bin/sh
set -eu

usage() {
  cat <<'USAGE'
Usage: check_fixed_format_data_quality.shs <jsonl>

Checks a fixed-format MCQ JSONL fixture for the retry2 fine-tune data-quality
gate. This is a format gate, not model training or model evaluation.
USAGE
}

case "${1:-}" in
  ""|--help|-h) usage; exit 2 ;;
esac

FILE="$1"
if [ ! -f "$FILE" ]; then
  echo "ERROR missing_data_file $FILE"
  echo "STATUS: FAIL fixed-format-data-quality"
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  echo "ERROR missing_node_runtime"
  echo "STATUS: FAIL fixed-format-data-quality"
  exit 1
fi

node - "$FILE" <<'JS'
const { readFileSync } = require("node:fs");

const file = process.argv[2];
const content = readFileSync(file, "utf8");
const lines = content.split(/\r?\n/).filter((line) => line.trim() !== "");
let invalid = 0;

function isText(value) {
  return typeof value === "string" && value.trim() !== "";
}

function fail(lineNumber, reason) {
  invalid += 1;
  console.log(`ERROR ${reason} line=${lineNumber}`);
}

if (lines.length === 0) {
  console.log(`ERROR empty_data_file ${file}`);
  console.log("STATUS: FAIL fixed-format-data-quality");
  process.exit(1);
}

lines.forEach((line, index) => {
  const lineNumber = index + 1;
  let record;
  try {
    record = JSON.parse(line);
  } catch {
    fail(lineNumber, "invalid_json");
    return;
  }
  if (!record || typeof record !== "object" || Array.isArray(record)) {
    fail(lineNumber, "record_not_object");
    return;
  }
  if (!isText(record.id)) fail(lineNumber, "missing_id");
  if (!isText(record.question)) fail(lineNumber, "missing_question");
  if (!record.choices || typeof record.choices !== "object" || Array.isArray(record.choices)) {
    fail(lineNumber, "missing_choices");
  } else {
    for (const key of ["A", "B", "C", "D"]) {
      if (!isText(record.choices[key])) fail(lineNumber, `missing_choice_${key}`);
    }
  }
  if (!["A", "B", "C", "D"].includes(record.answer)) fail(lineNumber, "invalid_answer");
  if (!isText(record.rationale)) fail(lineNumber, "missing_rationale");
});

console.log(`records=${lines.length}`);
console.log(`invalid_records=${invalid}`);
if (invalid === 0) {
  console.log("STATUS: PASS fixed-format-data-quality");
} else {
  console.log("STATUS: FAIL fixed-format-data-quality");
  process.exit(1);
}
JS
