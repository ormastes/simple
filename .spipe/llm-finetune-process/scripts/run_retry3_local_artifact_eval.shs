#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)"
cd "$ROOT_DIR"

ATTEMPT_ID="llm_backed_app_server_dry_run_retry3"
DATA_FILE=".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
ARTIFACT_DIR=".spipe/llm-finetune-process/artifacts/${ATTEMPT_ID}"
ARTIFACT_FILE="${ARTIFACT_DIR}/model_manifest.json"
EVAL_FILE="${ARTIFACT_DIR}/eval_result.json"

if [ ! -f "$DATA_FILE" ]; then
  echo "ERROR missing_data_file=$DATA_FILE" >&2
  exit 1
fi

quality_log="$(mktemp)"
trap 'rm -f "$quality_log"' EXIT INT TERM

.spipe/llm-finetune-process/scripts/check_fixed_format_data_quality.shs "$DATA_FILE" >"$quality_log"
quality_status="$(grep 'STATUS:' "$quality_log" | tail -1 || true)"

if [ "$quality_status" != "STATUS: PASS fixed-format-data-quality" ]; then
  echo "ERROR data_quality_failed" >&2
  exit 1
fi

mkdir -p "$ARTIFACT_DIR"

cat >"$ARTIFACT_FILE" <<EOF
{"attempt_id":"$ATTEMPT_ID","artifact_kind":"local-dry-run-adapter-manifest","base_model":"google/medgemma-4b-it","data_file":"$DATA_FILE","deployable":false}
EOF

cat >"$EVAL_FILE" <<EOF
{"attempt_id":"$ATTEMPT_ID","format_gate":"pass","model_accuracy":"not-run","target_accuracy":90.0,"result":"FAIL_IMPLEMENTATION_DRY_RUN_NO_REAL_TRAINING"}
EOF

printf 'attempt_id=%s\n' "$ATTEMPT_ID"
printf 'model_artifact=%s\n' "$ARTIFACT_FILE"
printf 'eval_artifact=%s\n' "$EVAL_FILE"
printf 'result=%s\n' "FAIL_IMPLEMENTATION_DRY_RUN_NO_REAL_TRAINING"
