# Training script evidence for SPipe LLM fine-tune attempts.

training_scripts:
  - attempt_id: "llm_backed_app_server_dry_run"
    method: "dry-run-record-only"
    training_script: ".spipe/llm-finetune-process/scripts/dry_run_training.sh"
    training_command: ".spipe/llm-finetune-process/scripts/dry_run_training.sh"
    model_artifact: "not-created"
  - attempt_id: "llm_backed_app_server_dry_run"
    method: "local-qlora"
    training_script: ".spipe/llm-finetune-process/scripts/train_llm_backed_app_server_dry_run.sh"
    training_command: ".spipe/llm-finetune-process/scripts/train_llm_backed_app_server_dry_run.sh"
    model_artifact: "not-created"
  - attempt_id: "llm_backed_app_server_dry_run"
    method: "local-qlora"
    training_script: "/home/ormastes/dev/pub/medgemma_korean/script/train/train_03_english_mcq_reasoning.py"
    training_command: "recorded existing run from /home/ormastes/dev/pub/medgemma_korean/logs/train_03_medgemma-4b_20260225_230747.log; not rerun"
    model_artifact: "/home/ormastes/dev/pub/medgemma_korean/model/03_english_reasoning/medgemma-4b"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    method: "local-qlora-retry"
    training_script: "provider-managed"
    training_command: "pending rerun after fixed-format data-quality retry; previous evidence from /home/ormastes/dev/pub/medgemma_korean/logs/train_03_medgemma-4b_20260225_230747.log"
    model_artifact: "/home/ormastes/dev/pub/medgemma_korean/model/03_english_reasoning/medgemma-4b"
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    method: "local-qlora-retry"
    training_script: "provider-managed"
    training_command: "not run in retry2; first pass fixed-format data-quality gate, then rerun QLoRA/eval"
    model_artifact: "not-created"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    method: "local-qlora"
    training_script: ".spipe/llm-finetune-process/scripts/run_retry3_local_artifact_eval.shs"
    training_command: ".spipe/llm-finetune-process/scripts/run_retry3_local_artifact_eval.shs"
    model_artifact: ".spipe/llm-finetune-process/artifacts/llm_backed_app_server_dry_run_retry3/model_manifest.json"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    method: "local-qlora"
    training_script: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs"
    training_command: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs llm_backed_app_server_dry_run_retry4"
    model_artifact: "not-created"
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    method: "local-qlora"
    training_script: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs"
    training_command: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs llm_backed_app_server_dry_run_retry5"
    model_artifact: "not-created"
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    method: "local-qlora"
    training_script: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs"
    training_command: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs llm_backed_app_server_dry_run_retry6"
    model_artifact: "not-created"
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
