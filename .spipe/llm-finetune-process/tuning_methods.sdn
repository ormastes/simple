  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    method: "local-qlora"
    reason: "QLoRA remains selected but is blocked until licensed fixed-format data exists."
    fallback: "retrieval/tool strategy or alternate data/model if license cannot be cleared"
