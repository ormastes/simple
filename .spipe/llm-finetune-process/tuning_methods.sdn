  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    method: "local-qlora"
    reason: "implementation dry-run for local QLoRA retry artifacts after fixed-format data gate"
    fallback: "real licensed data training/eval or retrieval/tool strategy if below target"
