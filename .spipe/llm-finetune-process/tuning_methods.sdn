  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    method: "local-qlora"
    reason: "QLoRA remains selected but is blocked until licensed data cache/checksum evidence exists."
    fallback: "retrieval/tool strategy or alternate data/model if license cannot be cleared"
