# Evaluation evidence for SPipe LLM fine-tune attempts.

eval_results:
  - attempt_id: "llm_backed_app_server_dry_run"
    eval_command: ".spipe/llm-finetune-process/scripts/verify_attempt.sh .spipe/llm-finetune-process/attempts/llm_backed_app_server_dry_run.sdn"
    metrics: "record completeness only"
    target: "attempt record has research, model, tuning, training script, evaluation, and retry fields"
    result: "structural-pass"
  - attempt_id: "llm_backed_app_server_dry_run"
    eval_command: "existing eval from train_03_medgemma-4b_20260225_230747.log and training_info.json"
    metrics: "final_accuracy=54.63576158940398; best_quick_accuracy=55.0; samples=604"
    target: "target_accuracy>=90.0 on 604 KorMedMCQA-derived samples"
    result: "FAIL_BELOW_TARGET_BEST_AVAILABLE"
  - attempt_id: "host_gpu_spark_small_task_2026_06_14"
    eval_command: "Spark sidecar read-only verification: host_gpu_lane_spec, host_gpu_event_path_spec, native/event probe"
    metrics: "host_gpu_lane_spec interpreter=pass; host_gpu_event_path_spec interpreter=pass; event_path native=pass; marker_probe events=6 begin=3 end=3"
    target: "Spark can verify a bounded host/GPU marker and event-flow task with exact commands and gaps"
    result: "PASS_WITH_NATIVE_SSPEC_GAP"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    eval_command: ".spipe/llm-finetune-process/scripts/verify_attempt.shs .spipe/llm-finetune-process/attempts/llm_backed_app_server_dry_run_retry1.sdn"
    metrics: "record completeness pass; model eval remains final_accuracy=54.63576158940398, best_quick_accuracy=55.0, samples=604"
    target: "normal LLM retry has complete attempt/eval/handoff evidence and target_accuracy>=90.0 before app/server acceptance"
    result: "STRUCTURAL_PASS_MODEL_RETRY_REQUIRED"
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    eval_command: ".spipe/llm-finetune-process/scripts/check_fixed_format_data_quality.shs .spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
    metrics: "records=3; invalid_records=0; format_gate=pass; model_accuracy=not-run"
    target: "fixed-format MCQ JSONL has id/question/choices A-D/answer/rationale before model rerun"
    result: "FORMAT_PASS_MODEL_EVAL_NOT_RUN"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    eval_command: ".spipe/llm-finetune-process/scripts/run_retry3_local_artifact_eval.shs"
    metrics: "format_gate=pass; artifact_manifest=created; model_accuracy=not-run; target_accuracy=90.0"
    target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
    result: "FAIL_IMPLEMENTATION_DRY_RUN_NO_REAL_TRAINING"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    eval_command: ".spipe/llm-finetune-process/scripts/check_retry4_license_gate.shs llm_backed_app_server_dry_run_retry4"
    metrics: "license_review=missing; data_access=missing; training_allowed=false; model_accuracy=not-run"
    target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
    result: "BLOCKED_LICENSED_DATA_NOT_AVAILABLE"
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    eval_command: ".spipe/llm-finetune-process/scripts/check_retry5_data_access_gate.shs llm_backed_app_server_dry_run_retry5"
    metrics: "license_review=missing; data_access=missing; cache_checksum=missing; training_allowed=false; model_accuracy=not-run"
    target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
    result: "BLOCKED_LICENSED_DATA_NOT_AVAILABLE"
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    eval_command: ".spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs llm_backed_app_server_dry_run_retry6"
    metrics: "upstream_retry5_review=warn; training_allowed=false; model_artifact=not-created; target_eval=not-run"
    target: "target_accuracy>=90.0 on licensed fixed-format KorMedMCQA rerun"
    result: "BLOCKED_UPSTREAM_LICENSED_DATA_NOT_READY"
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
    eval_command: ".spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs llm_backed_app_server_dry_run_retry7"
    metrics: "upstream_retry6_status=warn; training_allowed=false; model_artifact=not-created; target_eval=not-run; acceptance_allowed=false"
    target: "normal acceptance review after retry6 target eval, license/safety/deployment evidence, and accepted decision"
    result: "BLOCKED_RETRY6_NOT_READY"
