# Evaluation evidence for SPipe LLM fine-tune attempts.

eval_results:
  - attempt_id: "llm_backed_app_server_dry_run"
    eval_command: ".spipe/llm-finetune-process/scripts/verify_attempt.sh .spipe/llm-finetune-process/attempts/llm_backed_app_server_dry_run.sdn"
    metrics: "record completeness only"
    target: "attempt record has research, model, tuning, training script, evaluation, and retry fields"
    result: "structural-pass"
  - attempt_id: "llm_backed_app_server_dry_run"
    eval_command: "existing eval from train_03_medgemma-4b_20260225_230747.log and training_info.json"
    metrics: "final_accuracy=54.63576158940398; best_quick_accuracy=55.0; samples=604"
    target: "target_accuracy>=90.0 on 604 KorMedMCQA-derived samples"
    result: "FAIL_BELOW_TARGET_BEST_AVAILABLE"
  - attempt_id: "host_gpu_spark_small_task_2026_06_14"
    eval_command: "Spark sidecar read-only verification: host_gpu_lane_spec, host_gpu_event_path_spec, native/event probe"
    metrics: "host_gpu_lane_spec interpreter=pass; host_gpu_event_path_spec interpreter=pass; event_path native=pass; marker_probe events=6 begin=3 end=3"
    target: "Spark can verify a bounded host/GPU marker and event-flow task with exact commands and gaps"
    result: "PASS_WITH_NATIVE_SSPEC_GAP"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    eval_command: ".spipe/llm-finetune-process/scripts/verify_attempt.shs .spipe/llm-finetune-process/attempts/llm_backed_app_server_dry_run_retry1.sdn"
    metrics: "record completeness pass; model eval remains final_accuracy=54.63576158940398, best_quick_accuracy=55.0, samples=604"
    target: "normal LLM retry has complete attempt/eval/handoff evidence and target_accuracy>=90.0 before app/server acceptance"
    result: "STRUCTURAL_PASS_MODEL_RETRY_REQUIRED"
