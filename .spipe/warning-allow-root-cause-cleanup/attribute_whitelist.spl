"""
Attribute whitelist for the Simple strict-lint lane.

Tracks known attribute names that appear in @allow/@warn/@deny position.
"""

class AttributeWhitelist:
    names: [text]

static fn new_default() -> AttributeWhitelist:
    val base = [
        "allow", "warn", "deny", "default", "concurrency_mode", "layout",
        "pure", "snapshot", "deprecated", "bypass", "skip_todo", "generated",
        "inline", "ignore"
    ]
    AttributeWhitelist(names: base)

me add(name: text):
    self.names.push(name)

me is_known(name: text) -> bool:
    for n in self.names:
        if n == name:
            return true
    false

me size() -> i64:
    self.names.len()

me is_suppress_attr(name: text) -> bool:
    name == "allow" or name == "warn" or name == "deny"

me contains_suppress_attrs() -> bool:
    self.is_known("allow") and self.is_known("warn") and self.is_known("deny")
