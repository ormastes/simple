"""
Regression canary model for the warning/allow cleanup slice.

Asserts that the three enforcement wiring points remain intact:
  - Rust workflow targets src/compiler_rust
  - Simple strict lint lane exists and uses --deny-all
  - primitive-sort runtime retains NEON threshold constants
"""

class RegressionCanary:
    rust_workflow_path: text
    simple_lane_path: text
    primitive_sort_path: text

static fn new_default() -> RegressionCanary:
    RegressionCanary(
        rust_workflow_path: ".github/workflows/rust-tests.yml",
        simple_lane_path: ".github/workflows/simple-strict-lints.yml",
        primitive_sort_path: "src/compiler_rust/runtime/src/value/primitive_sort.rs"
    )

me check_rust_workflow_path(content: text) -> bool:
    content.contains("src/compiler_rust") and
    content.contains("working-directory: src/compiler_rust")

me check_simple_lane(content: text) -> bool:
    content.contains("Strict Simple Lints") and
    content.contains("--deny-all") and
    content.contains("warning_allow_root_cause_cleanup_spec.spl")

me check_neon_constants(content: text) -> bool:
    content.contains("const NEON_I64_RADIX_MIN_LEN") and
    content.contains("const NEON_F64_RADIX_MIN_LEN")

me all_checks_pass(rust_wf: text, simple_wf: text, primitive_sort: text) -> bool:
    self.check_rust_workflow_path(rust_wf) and
    self.check_simple_lane(simple_wf) and
    self.check_neon_constants(primitive_sort)
