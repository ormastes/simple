use std.spec.*

use std.gc_async_mut.web.browser_session_html.{html_to_text}

describe "BrowserSession HTML ruby tag text semantics":

    it "renders ruby annotations without leaking rp fallback markers twice":
        val html = "<ruby>漢<rp>(</rp><rt>kan</rt><rp>)</rp></ruby>"
        expect(html_to_text(html)).to_equal("漢(kan)")

    it "keeps adjacent ruby annotations readable without rp fallback tags":
        val html = "<ruby>東<rt>east</rt></ruby><ruby>京<rt>capital</rt></ruby>"
        expect(html_to_text(html)).to_equal("東(east)京(capital)")
