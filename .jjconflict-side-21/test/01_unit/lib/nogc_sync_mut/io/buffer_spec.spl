use std.spec
use std.io.traits.{Read}
use std.io.types.{IoError}
use std.nogc_sync_mut.io.buffer.{BufferedReader}

class MemoryReader with Read:
    data: [u8]
    pos: i64

    static fn new(data: [u8]) -> MemoryReader:
        MemoryReader(data: data, pos: 0)

    fn read(size: i64) -> Result<[u8], IoError>:
        val end = if self.pos + size > self.data.len(): self.data.len() else: self.pos + size
        val chunk = self.data.slice(self.pos, end)
        self.pos = end
        Ok(chunk)

    fn read_exact(size: i64) -> Result<[u8], IoError>:
        self.read(size)

    fn read_all() -> Result<[u8], IoError>:
        self.read(self.data.len() - self.pos)

    fn read_text() -> Result<text, IoError>:
        Ok("")

    fn read_line() -> Result<text, IoError>:
        Ok("")

describe "nogc_sync_mut io buffer":

    it "decodes buffered text without text.from_bytes":
        val raw = MemoryReader.new([111u8, 107u8, 255u8])
        val reader = BufferedReader.with_capacity(raw, 2)
        match reader.read_text():
            Ok(text_value):
                expect(text_value).to_equal("ok?")
            Err(err):
                expect(err.message).to_equal("")

    it "decodes buffered lines without text.from_bytes":
        val raw = MemoryReader.new([111u8, 107u8, 10u8])
        val reader = BufferedReader.with_capacity(raw, 2)
        match reader.read_line():
            Ok(text_value):
                expect(text_value).to_equal("ok\n")
            Err(err):
                expect(err.message).to_equal("")
