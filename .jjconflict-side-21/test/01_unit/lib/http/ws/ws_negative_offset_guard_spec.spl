use std.spec.{describe, it, assert_equal}
use std.http.ws.ws_parser.{ws_parse_frame, ws_parse_frame_header}

fn _minimal_text_frame() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x81)
    bytes.push(0x01)
    bytes.push(0x41)
    bytes

describe "WebSocket parser negative offset guard":
    it "rejects negative frame header offsets":
        assert_equal(ws_parse_frame_header(_minimal_text_frame(), -1) == nil, true)

    it "rejects negative frame offsets":
        assert_equal(ws_parse_frame(_minimal_text_frame(), -1) == nil, true)
