use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_wm_compare(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE=\"$REPO/bin/simple\"; [ -x \"$SIMPLE\" ] || SIMPLE=\"$REPO/bin/simple-interp\"; SIMPLE_LIB=\"$REPO/src\" \"$SIMPLE\" run \"$REPO/src/app/wm_compare/main.spl\" " + joined
    ])

describe "wm compare log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_wm_compare(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_wm_compare(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"wm-compare\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_wm_compare(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Unified pixel capture")

    it "rejects invalid log mode":
        val (out, err, code) = _run_wm_compare(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for missing scene":
        val (out, err, code) = _run_wm_compare(["--log-mode=json", "--source=A"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"wm-compare\"")
        expect(out).to_contain("\"error\":\"missing scene\"")

    it "rejects window mode on SimpleOS before capture":
        val (out, err, code) = _run_wm_compare(["--host-os=simpleos", "--wm-mode=window"])
        expect(code).to_equal(1)
        expect(out).to_contain("wm mode 'window' is not available on host 'simpleos'")
