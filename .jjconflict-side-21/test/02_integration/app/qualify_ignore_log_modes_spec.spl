use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_qualify_ignore_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/test && cat > " + FIXTURE_DIR + "/test/sample_spec.spl <<'EOF'\n#[ignore]\ndescribe \"sample\":\n    it \"works\":\n        assert true\nEOF"
    ])

fn _run_qualify_ignore(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/qualify_ignore/main.spl\" " + joined
    ])

describe "qualify-ignore log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_qualify_ignore(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports scan log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_qualify_ignore(["test", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"qualify-ignore\"")
        expect(out).to_contain("\"issues\":1")

    it "supports fix log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_qualify_ignore(["test", "--fix", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"mode\":\"fix\"")
        expect(out).to_contain("\"fixed\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_qualify_ignore(["test", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Found 1 unqualified ignore(s)")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_qualify_ignore(["test", "--log-mode=noisy"])
        expect(code).to_equal(1)
