# Unit: Lumen
# Kind: LuminousFlux
# Symbol: lm
# Canonical scale: 1.0 lm

class Lumen:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Lumen) -> Lumen: Lumen(value: self.value + other.value)
    fn sub(other: Lumen) -> Lumen: Lumen(value: self.value - other.value)

    static fn kind() -> text: "LuminousFlux"
    static fn symbol() -> text: "lm"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "lm"
    static fn zero() -> Lumen: Lumen(value: 0.0)

export Lumen
