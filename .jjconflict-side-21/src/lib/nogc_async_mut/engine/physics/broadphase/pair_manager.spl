# Physics2 — Pair Manager
#
# Tracks overlapping collider pairs across frames. Emits add/remove events
# for the narrow phase and contact cache.

struct OverlapPair:
    collider_a: i64
    collider_b: i64

struct PairManager:
    pairs: [OverlapPair]
    count: i64

impl PairManager:
    static fn create() -> PairManager:
        PairManager(pairs: [], count: 0)

    me update_from_bvh(new_pairs: [(i64, i64)]) -> ([(i64, i64)], [(i64, i64)]):
        var added: [(i64, i64)] = []
        var removed: [(i64, i64)] = []

        # Find newly added pairs
        var i = 0
        while i < new_pairs.len():
            val np = new_pairs[i]
            if not self.contains(np.0, np.1):
                added.push(np)
            i = i + 1

        # Find removed pairs
        i = 0
        while i < self.count:
            val op = self.pairs[i]
            if not self.in_new_list(new_pairs, op.collider_a, op.collider_b):
                removed.push((op.collider_a, op.collider_b))
            i = i + 1

        # Update stored pairs
        self.pairs = []
        self.count = 0
        i = 0
        while i < new_pairs.len():
            val p = new_pairs[i]
            self.pairs.push(OverlapPair(collider_a: p.0, collider_b: p.1))
            self.count = self.count + 1
            i = i + 1

        (added, removed)

    me contains(a: i64, b: i64) -> bool:
        var i = 0
        while i < self.count:
            val p = self.pairs[i]
            if (p.collider_a == a and p.collider_b == b) or (p.collider_a == b and p.collider_b == a):
                return true
            i = i + 1
        false

    me in_new_list(new_pairs: [(i64, i64)], a: i64, b: i64) -> bool:
        var i = 0
        while i < new_pairs.len():
            val p = new_pairs[i]
            if (p.0 == a and p.1 == b) or (p.0 == b and p.1 == a):
                return true
            i = i + 1
        false
