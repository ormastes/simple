# SIMD Vector Trait — Unified surface for FixedVec and ScalableVec
#
# C2 §1.1: Vector trait method catalog (39 core methods).
#
# Interpreter-mode note: Simple does not support associated types in trait
# method signatures at M0. The trait here is a structural marker; FixedVec
# and ScalableVec implement each method concretely with their own T.
# Self.Elem / Self.Mask from C2 §1.1 are documented in comments only.
# The M1+ type-checker will enforce associated-type constraints.
#
# @tag:stdlib
# @tag:simd
# @tag:api

# ============================================================================
# Marker traits for element-type constraints (C2 §1.0)
# ============================================================================

trait Numeric:
    pass_dn

trait Float:
    pass_dn

trait Integer:
    pass_dn

trait SignedInt:
    pass_dn

# Blanket implementations for primitive types are resolved by the compiler
# via its built-in numeric-type table; no explicit impl blocks needed here.

# ============================================================================
# SimdElementType — required bound on T for all SIMD generics
# ============================================================================

# Constraint alias for all supported SIMD element types:
# u8 u16 u32 u64 i8 i16 i32 i64 f32 f64
trait SimdElementType:
    pass_dn

# ============================================================================
# LaneIter — iteration over SIMD lanes (C2 §1.1)
# ============================================================================

class LaneIter<E>:
    data: [E]
    pos: usize

impl<E> LaneIter<E>:
    static fn new(data: [E]) -> LaneIter<E>:
        LaneIter(data: data, pos: 0)

    fn has_next(self) -> bool:
        self.pos < self.data.len()

    fn next(self) -> E:
        val v = self.data[self.pos]
        self.pos = self.pos + 1
        v

# ============================================================================
# Vector trait — C2 §1.1 structural marker
#
# Associated types (declared here as documentation only; enforced by M1+):
#   Elem — the scalar element type (e.g. f32, i32)
#   Mask — the per-lane boolean mask type (e.g. Mask<FixedVec<f32>>)
#
# At M0 the trait is a tag; FixedVec/ScalableVec provide all methods
# concretely via their generic T parameter.
# ============================================================================

trait Vector:
    """Unified contract for all SIMD vector types (structural marker at M0).

    C2 §1.1: full method catalog declared below.
    Associated types Elem and Mask are enforced by M1+ type-checker.
    """

    # — Lane count — (C2 §1.1)
    fn lanes(self) -> usize
    fn len(self) -> usize

    # — Arithmetic — (C2 §1.1; T: Numeric)
    fn add(self, rhs: Self) -> Self
    fn sub(self, rhs: Self) -> Self
    fn mul(self, rhs: Self) -> Self
    fn div(self, rhs: Self) -> Self
    fn neg(self) -> Self
    fn min(self, rhs: Self) -> Self
    fn max(self, rhs: Self) -> Self

    # — Float-only arithmetic — (C2 §1.1; T: Float; E_SIMD_FLOAT_ONLY on int)
    fn fma(self, b: Self, c: Self) -> Self
    fn fnmadd(self, b: Self, c: Self) -> Self
    fn abs(self) -> Self
    fn recip(self) -> Self
    fn sqrt(self) -> Self
    fn recip_sqrt(self) -> Self

    # — Integer-only bitwise — (C2 §1.1; T: Integer; E_SIMD_INT_ONLY on float)
    fn and(self, rhs: Self) -> Self
    fn or(self, rhs: Self) -> Self
    fn xor(self, rhs: Self) -> Self
    fn andnot(self, rhs: Self) -> Self
    fn shl(self, count: u32) -> Self
    fn shr_logical(self, count: u32) -> Self
    fn shr_arith(self, count: u32) -> Self

    # — Permutation / shuffle — (C2 §1.1)
    fn shuffle(self, indices: Self) -> Self
    fn permute(self, ctrl: Self) -> Self
    fn broadcast_lane(self, lane: u32) -> Self
    fn interleave_lo(self, rhs: Self) -> Self
    fn interleave_hi(self, rhs: Self) -> Self

    # — Debug — (C2 §1.1)
    fn fmt(self) -> text
    fn to_string(self) -> text
