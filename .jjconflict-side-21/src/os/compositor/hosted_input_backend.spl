# Hosted Input Backend — winit event-loop keyboard + mouse input
#
# Implements InputBackend trait by polling events from a winit event loop
# (used on macOS, Linux, Windows, FreeBSD host desktops). Converts winit
# keycodes and mouse events into the same KeyEvent/MouseEvent types used
# by the PS/2 drivers, so the compositor can switch input sources
# transparently.
#
# The winit event loop handle (event_loop_id) is an opaque i64 obtained
# from the Rust FFI layer during hosted window creation.

use os.compositor.input_backend.{InputBackend}
use os.drivers.input.ps2_keyboard.{KeyEvent, Key}
use os.drivers.input.ps2_mouse.{MouseEvent}

# ============================================================================
# Winit Event Loop FFI Declarations
# ============================================================================

extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool)
extern fn rt_winit_event_mouse_moved(ev: i64) -> (i64, i64)
extern fn rt_winit_event_mouse_button(ev: i64) -> (i64, bool)
extern fn rt_winit_event_free(ev: i64)

# ============================================================================
# Winit Event Type Constants
# ============================================================================

val EVENT_CLOSE: i64 = 3
val EVENT_KEYBOARD: i64 = 10
val EVENT_MOUSE_BUTTON: i64 = 20
val EVENT_MOUSE_MOVED: i64 = 21

# ============================================================================
# Winit Keycode Constants
# ============================================================================

val WINIT_KEY_ESCAPE: i64 = 27
val WINIT_KEY_ENTER: i64 = 13
val WINIT_KEY_SPACE: i64 = 32
val WINIT_KEY_BACKSPACE: i64 = 8
val WINIT_KEY_TAB: i64 = 9
val WINIT_KEY_LEFT: i64 = 37
val WINIT_KEY_UP: i64 = 38
val WINIT_KEY_RIGHT: i64 = 39
val WINIT_KEY_DOWN: i64 = 40

# Mouse button IDs from winit
val MOUSE_BUTTON_LEFT: i64 = 1
val MOUSE_BUTTON_RIGHT: i64 = 2

# ============================================================================
# Keycode Conversion
# ============================================================================

fn _winit_keycode_to_key(keycode: i64) -> Key?:
    """Convert a winit keycode (i64) to a Key enum value.

    Returns nil for unrecognised keycodes.
    """
    # Special keys
    if keycode == 27: return Key.Escape
    if keycode == 13: return Key.Enter
    if keycode == 32: return Key.Space
    if keycode == 8: return Key.Backspace
    if keycode == 9: return Key.Tab

    # Arrow keys
    if keycode == 37: return Key.Left
    if keycode == 38: return Key.Up
    if keycode == 39: return Key.Right
    if keycode == 40: return Key.Down

    # Function keys (F1=112 .. F12=123)
    if keycode == 112: return Key.F1
    if keycode == 113: return Key.F2
    if keycode == 114: return Key.F3
    if keycode == 115: return Key.F4
    if keycode == 116: return Key.F5
    if keycode == 117: return Key.F6
    if keycode == 118: return Key.F7
    if keycode == 119: return Key.F8
    if keycode == 120: return Key.F9
    if keycode == 121: return Key.F10
    if keycode == 122: return Key.F11
    if keycode == 123: return Key.F12

    # Letters A-Z (65-90)
    if keycode == 65: return Key.A
    if keycode == 66: return Key.B
    if keycode == 67: return Key.C
    if keycode == 68: return Key.D
    if keycode == 69: return Key.E
    if keycode == 70: return Key.F
    if keycode == 71: return Key.G
    if keycode == 72: return Key.H
    if keycode == 73: return Key.I
    if keycode == 74: return Key.J
    if keycode == 75: return Key.K
    if keycode == 76: return Key.L
    if keycode == 77: return Key.M
    if keycode == 78: return Key.N
    if keycode == 79: return Key.O
    if keycode == 80: return Key.P
    if keycode == 81: return Key.Q
    if keycode == 82: return Key.R
    if keycode == 83: return Key.S
    if keycode == 84: return Key.T
    if keycode == 85: return Key.U
    if keycode == 86: return Key.V
    if keycode == 87: return Key.W
    if keycode == 88: return Key.X
    if keycode == 89: return Key.Y
    if keycode == 90: return Key.Z

    # Digits 0-9 (48-57)
    if keycode == 48: return Key.Num0
    if keycode == 49: return Key.Num1
    if keycode == 50: return Key.Num2
    if keycode == 51: return Key.Num3
    if keycode == 52: return Key.Num4
    if keycode == 53: return Key.Num5
    if keycode == 54: return Key.Num6
    if keycode == 55: return Key.Num7
    if keycode == 56: return Key.Num8
    if keycode == 57: return Key.Num9

    # Home / End / Insert / Delete / PageUp / PageDown
    if keycode == 36: return Key.Home
    if keycode == 35: return Key.End
    if keycode == 45: return Key.Insert
    if keycode == 46: return Key.Delete
    if keycode == 33: return Key.PageUp
    if keycode == 34: return Key.PageDown

    # Modifiers — recognised but handled via modifier state tracking
    if keycode == 16: return Key.LeftShift
    if keycode == 17: return Key.LeftCtrl
    if keycode == 18: return Key.LeftAlt

    return nil

# ============================================================================
# HostedInputBackend
# ============================================================================

class HostedInputBackend:
    """InputBackend that reads keyboard and mouse events from a winit event loop.

    Used on host desktops (macOS, Linux, Windows, FreeBSD) where the SimpleOS
    window manager runs inside a native winit window. Converts winit events
    into the same KeyEvent/MouseEvent types the compositor uses for PS/2
    input, enabling transparent backend switching.

    Mouse events are buffered internally when poll_key() encounters them,
    so that poll_mouse() can return them without re-polling the event loop.
    """
    event_loop_id: i64
    _alt_held: bool
    _shift_held: bool
    _ctrl_held: bool
    mouse_x: i64
    mouse_y: i64
    _left_pressed: bool
    _right_pressed: bool
    _left_just_pressed: bool
    _left_just_released: bool
    _right_just_pressed: bool
    _has_buffered_mouse: bool

# ============================================================================
# InputBackend Trait Implementation
# ============================================================================

impl InputBackend for HostedInputBackend:

    me poll_key() -> KeyEvent?:
        """Poll the winit event loop for a keyboard event.

        Processes up to 16 events per call. Keyboard events are converted
        to KeyEvent and returned immediately. Mouse events are buffered
        for later retrieval via poll_mouse(). A window-close event is
        translated to KeyEvent.Press(Key.Escape) so the compositor treats
        it as a quit request.
        """
        var remaining: i64 = 16
        while remaining > 0:
            remaining = remaining - 1
            val ev = rt_winit_event_loop_poll_events(self.event_loop_id, 1)
            if ev == 0:
                return nil

            val ev_type = rt_winit_event_get_type(ev)

            if ev_type == EVENT_CLOSE:
                rt_winit_event_free(ev)
                return KeyEvent.Press(key: Key.Escape)

            if ev_type == EVENT_KEYBOARD:
                val input = rt_winit_event_keyboard_input(ev)
                val keycode = input.0
                val _scancode = input.1
                val pressed = input.2
                rt_winit_event_free(ev)

                if val key = _winit_keycode_to_key(keycode):
                    self._update_modifiers(key, pressed)
                    if pressed:
                        return KeyEvent.Press(key: key)
                    else:
                        return KeyEvent.Release(key: key)
                # Unrecognised keycode — skip and continue polling
                continue

            if ev_type == EVENT_MOUSE_MOVED:
                val pos = rt_winit_event_mouse_moved(ev)
                rt_winit_event_free(ev)
                self.mouse_x = pos.0
                self.mouse_y = pos.1
                self._has_buffered_mouse = true
                # Continue polling for keyboard events; mouse is buffered
                continue

            if ev_type == EVENT_MOUSE_BUTTON:
                val btn = rt_winit_event_mouse_button(ev)
                val button_id = btn.0
                val pressed = btn.1
                rt_winit_event_free(ev)

                val prev_left = self._left_pressed
                val prev_right = self._right_pressed
                if button_id == MOUSE_BUTTON_LEFT:
                    self._left_pressed = pressed
                    self._left_just_pressed = pressed and not prev_left
                    self._left_just_released = not pressed and prev_left
                elif button_id == MOUSE_BUTTON_RIGHT:
                    self._right_pressed = pressed
                    self._right_just_pressed = pressed and not prev_right
                self._has_buffered_mouse = true
                # Continue polling for keyboard events; mouse is buffered
                continue

            # Unknown event type — free and continue
            rt_winit_event_free(ev)

        return nil

    me poll_mouse() -> MouseEvent?:
        """Return a buffered mouse event, or poll the event loop for one.

        If poll_key() already buffered mouse state, returns it immediately
        and clears the buffer flag. Otherwise polls up to 16 events looking
        for mouse input, buffering any keyboard events encountered.
        """
        if self._has_buffered_mouse:
            self._has_buffered_mouse = false
            return self._build_mouse_event()

        # Poll specifically for mouse events
        var remaining: i64 = 16
        while remaining > 0:
            remaining = remaining - 1
            val ev = rt_winit_event_loop_poll_events(self.event_loop_id, 1)
            if ev == 0:
                return nil

            val ev_type = rt_winit_event_get_type(ev)

            if ev_type == EVENT_MOUSE_MOVED:
                val pos = rt_winit_event_mouse_moved(ev)
                rt_winit_event_free(ev)
                self.mouse_x = pos.0
                self.mouse_y = pos.1
                return self._build_mouse_event()

            if ev_type == EVENT_MOUSE_BUTTON:
                val btn = rt_winit_event_mouse_button(ev)
                val button_id = btn.0
                val pressed = btn.1
                rt_winit_event_free(ev)

                val prev_left = self._left_pressed
                val prev_right = self._right_pressed
                if button_id == MOUSE_BUTTON_LEFT:
                    self._left_pressed = pressed
                    self._left_just_pressed = pressed and not prev_left
                    self._left_just_released = not pressed and prev_left
                elif button_id == MOUSE_BUTTON_RIGHT:
                    self._right_pressed = pressed
                    self._right_just_pressed = pressed and not prev_right
                return self._build_mouse_event()

            # Non-mouse event — free and continue looking
            rt_winit_event_free(ev)

        return nil

    fn alt_held() -> bool:
        self._alt_held

    fn shift_held() -> bool:
        self._shift_held

    fn ctrl_held() -> bool:
        self._ctrl_held

    fn key_to_char(key: Key) -> text?:
        """Convert a Key to its character representation, respecting shift state.

        Mirrors the PS/2 keyboard's key_to_char behaviour so that text input
        works identically regardless of input backend.
        """
        if self._shift_held:
            match key:
                case Key.A: "A"
                case Key.B: "B"
                case Key.C: "C"
                case Key.D: "D"
                case Key.E: "E"
                case Key.F: "F"
                case Key.G: "G"
                case Key.H: "H"
                case Key.I: "I"
                case Key.J: "J"
                case Key.K: "K"
                case Key.L: "L"
                case Key.M: "M"
                case Key.N: "N"
                case Key.O: "O"
                case Key.P: "P"
                case Key.Q: "Q"
                case Key.R: "R"
                case Key.S: "S"
                case Key.T: "T"
                case Key.U: "U"
                case Key.V: "V"
                case Key.W: "W"
                case Key.X: "X"
                case Key.Y: "Y"
                case Key.Z: "Z"
                case Key.Num1: "!"
                case Key.Num2: "@"
                case Key.Num3: "#"
                case Key.Num4: "$"
                case Key.Num5: "%"
                case Key.Num6: "^"
                case Key.Num7: "&"
                case Key.Num8: "*"
                case Key.Num9: "("
                case Key.Num0: ")"
                case Key.Space: " "
                case Key.Enter: "\n"
                case Key.Minus: "_"
                case Key.Equals: "+"
                case Key.Semicolon: ":"
                case Key.Quote: "\""
                case Key.Comma: "<"
                case Key.Period: ">"
                case Key.Slash: "?"
                case Key.Backslash: "|"
                case Key.LeftBracket: "{"
                case Key.RightBracket: "}"
                case Key.Backtick: "~"
                case _: nil
        else:
            match key:
                case Key.A: "a"
                case Key.B: "b"
                case Key.C: "c"
                case Key.D: "d"
                case Key.E: "e"
                case Key.F: "f"
                case Key.G: "g"
                case Key.H: "h"
                case Key.I: "i"
                case Key.J: "j"
                case Key.K: "k"
                case Key.L: "l"
                case Key.M: "m"
                case Key.N: "n"
                case Key.O: "o"
                case Key.P: "p"
                case Key.Q: "q"
                case Key.R: "r"
                case Key.S: "s"
                case Key.T: "t"
                case Key.U: "u"
                case Key.V: "v"
                case Key.W: "w"
                case Key.X: "x"
                case Key.Y: "y"
                case Key.Z: "z"
                case Key.Num0: "0"
                case Key.Num1: "1"
                case Key.Num2: "2"
                case Key.Num3: "3"
                case Key.Num4: "4"
                case Key.Num5: "5"
                case Key.Num6: "6"
                case Key.Num7: "7"
                case Key.Num8: "8"
                case Key.Num9: "9"
                case Key.Space: " "
                case Key.Enter: "\n"
                case Key.Minus: "-"
                case Key.Equals: "="
                case Key.Semicolon: ";"
                case Key.Quote: "'"
                case Key.Comma: ","
                case Key.Period: "."
                case Key.Slash: "/"
                case Key.Backslash: "\\"
                case Key.LeftBracket: "["
                case Key.RightBracket: "]"
                case Key.Backtick: "`"
                case _: nil

# ============================================================================
# Internal Helpers
# ============================================================================

impl HostedInputBackend:

    me _update_modifiers(key: Key, pressed: bool):
        """Update modifier key state on press/release."""
        match key:
            case Key.LeftShift: self._shift_held = pressed
            case Key.RightShift: self._shift_held = pressed
            case Key.LeftCtrl: self._ctrl_held = pressed
            case Key.RightCtrl: self._ctrl_held = pressed
            case Key.LeftAlt: self._alt_held = pressed
            case Key.RightAlt: self._alt_held = pressed
            case _: pass_dn

    me _build_mouse_event() -> MouseEvent:
        """Construct a MouseEvent from current buffered mouse state."""
        val event = MouseEvent(
            x: self.mouse_x,
            y: self.mouse_y,
            dx: 0,
            dy: 0,
            left_pressed: self._left_pressed,
            right_pressed: self._right_pressed,
            middle_pressed: false,
            left_just_pressed: self._left_just_pressed,
            right_just_pressed: self._right_just_pressed,
            left_just_released: self._left_just_released
        )
        # Clear edge-triggered flags after building the event
        self._left_just_pressed = false
        self._left_just_released = false
        self._right_just_pressed = false
        event

# ============================================================================
# Static Constructor
# ============================================================================

    static fn create(event_loop_id: i64) -> HostedInputBackend:
        """Create a hosted input backend from a winit event loop handle.

        Args:
            event_loop_id: Opaque handle from the winit event loop
        """
        HostedInputBackend(
            event_loop_id: event_loop_id,
            _alt_held: false,
            _shift_held: false,
            _ctrl_held: false,
            mouse_x: 0,
            mouse_y: 0,
            _left_pressed: false,
            _right_pressed: false,
            _left_just_pressed: false,
            _left_just_released: false,
            _right_just_pressed: false,
            _has_buffered_mouse: false
        )
