# ARM32 (Thumb2 / Cortex-M/A) Cipher + BitManip Intrinsic Lowering Hooks
#
# Conservative feature tables for ARM32 scalar and NEON operations.
# Provides lowering decision points (should_lower, fallback predicates) and
# byte-count stubs for the future ARM32 encoder.
#
# Key constraints on ARM32 vs AArch64:
#   - No 64-bit registers in Thumb2 base ISA (dual-register pairs for 64-bit)
#   - No scalable vector; NEON is fixed 128-bit (D0-D31 / Q0-Q15)
#   - SHA-512 NOT available (64-bit arithmetic too expensive on 32-bit core)
#   - CLZ instruction available from ARMv5 (Cortex-M3+)
#   - RBIT instruction (bit reversal) from ARMv6T2 (Cortex-M3+)
#   - REV instruction (byte swap) from ARMv6
#   - CRC32 extension gated by ID_ISAR5.CRC32 CPUID bit

use compiler.backend.feature_caps.{ArmCaps, TargetIdiom, TargetFeatureClass}

# ============================================================================
# Lowering decision predicates
# ============================================================================

"""True when the ARM32 target can lower this idiom natively (no software emu)."""
fn arm32_can_lower_natively(caps: ArmCaps, idiom: TargetIdiom) -> bool:
    caps.supports(idiom)

"""True when the idiom must fall back to a software implementation on this ARM32 target."""
fn arm32_needs_software_fallback(caps: ArmCaps, idiom: TargetIdiom) -> bool:
    not caps.supports(idiom)

"""True when the idiom is permanently unavailable on ANY ARM32 target (architecture limit)."""
fn arm32_permanently_unavailable(idiom: TargetIdiom) -> bool:
    match idiom:
        case Sha512Rounds2: true   # 64-bit SHA-512 round function — no ARM32 encoding
        case Sha512Msg1:    true
        case Sha512Msg2:    true
        case SimdI32x8:     true   # No 256-bit NEON
        case SimdF32x8:     true
        case Crc32U64:      true   # CRC32Q uses 64-bit operands — unavailable
        case ClmulLo:       true   # VMULL.P64 is ARMv8 only (AArch64)
        case ClmulHi:       true
        case _:             false

"""True when NEON is needed but not present for this idiom."""
fn arm32_needs_neon(idiom: TargetIdiom) -> bool:
    match idiom:
        case SimdI32x4:      true
        case SimdF32x4:      true
        case MatrixDot:      true
        case MatrixOuterProduct: true
        case MatrixFmaKernel: true
        case _:              false

"""True when the AES extension is required for this idiom (Cortex-A with AESD/AESE)."""
fn arm32_needs_aes(idiom: TargetIdiom) -> bool:
    match idiom:
        case AesEnc:          true
        case AesEncLast:      true
        case AesDec:          true
        case AesDecLast:      true
        case AesImc:          true
        case AesKeygenAssist: true
        case _:               false

"""True when the SHA extension is required for this idiom (Cortex-A SHA2 optional)."""
fn arm32_needs_sha2(idiom: TargetIdiom) -> bool:
    match idiom:
        case Sha256Rounds2: true
        case Sha256Msg1:    true
        case Sha256Msg2:    true
        case _:             false

# ============================================================================
# Lowering result type for ARM32
# ============================================================================

"""Outcome of attempting to lower a TargetIdiom on ARM32.

lowered  — true iff a hardware path exists and caps permit it.
fallback — true iff caller must emit a software fallback sequence.
reason   — human-readable note; empty on success.
"""
struct Arm32LoweringDecision:
    lowered:  bool
    fallback: bool
    reason:   text

fn arm32_lowering_decision(caps: ArmCaps, idiom: TargetIdiom) -> Arm32LoweringDecision:
    """Return the lowering decision for a single idiom given this target's ArmCaps."""
    if arm32_permanently_unavailable(idiom):
        return Arm32LoweringDecision(lowered: false, fallback: true, reason: "permanently unavailable on ARM32")
    if arm32_needs_neon(idiom) and not caps.has_neon:
        return Arm32LoweringDecision(lowered: false, fallback: true, reason: "NEON required but not present")
    if arm32_needs_aes(idiom) and not caps.has_aes:
        return Arm32LoweringDecision(lowered: false, fallback: true, reason: "AES extension required but not present")
    if arm32_needs_sha2(idiom) and not caps.has_sha2:
        return Arm32LoweringDecision(lowered: false, fallback: true, reason: "SHA2 extension required but not present")
    if caps.supports(idiom):
        return Arm32LoweringDecision(lowered: true, fallback: false, reason: "")
    Arm32LoweringDecision(lowered: false, fallback: true, reason: "feature not present in ArmCaps")

# ============================================================================
# Scalar narrow-form hooks for ARM32
# ============================================================================

"""True when the ARM32 CLZ (Count Leading Zeros) instruction is available.

CLZ is a base instruction from ARMv5T; always true for Cortex-M3+ and
any Cortex-A that supports Thumb2.
"""
fn arm32_clz_available() -> bool:
    true

"""True when RBIT (bit reversal) is available — ARMv6T2 and later."""
fn arm32_rbit_available() -> bool:
    true  # All Cortex-M3+, Cortex-M4+, Cortex-A series with Thumb2 support RBIT

"""True when REV (byte swap) is available — ARMv6 and later."""
fn arm32_rev_available() -> bool:
    true  # All Cortex-M and modern Cortex-A

"""Preferred lowering path for RotateLeft on ARM32: use ROR (rotate-right) with 32-n."""
fn arm32_rotate_left_via_ror(count: i64) -> i64:
    (32 - (count % 32)) % 32  # ROR amount equivalent to ROL count; outer %32 keeps a full-width rotate (count%32==0) an identity (0), not 32

# ============================================================================
# RV32 scalar narrow-form and lowering hooks (Task 5 — RISC-V family)
# ============================================================================

use compiler.backend.feature_caps.{Rv32Caps}

"""True when the RV32 Zbb extension supplies a native CPOP (popcount) instruction."""
fn rv32_popcount_native(caps: Rv32Caps) -> bool:
    caps.has_zbb

"""True when RV32 Zbb provides CTZ (count trailing zeros)."""
fn rv32_ctz_native(caps: Rv32Caps) -> bool:
    caps.has_zbb

"""True when RV32 Zbb provides CLZ (count leading zeros)."""
fn rv32_clz_native(caps: Rv32Caps) -> bool:
    caps.has_zbb

"""True when RV32 Zbb provides REV8 (byte swap for 32-bit values)."""
fn rv32_bswap_native(caps: Rv32Caps) -> bool:
    caps.has_zbb

"""True when RV32 Zbkb provides BREV8 (bit reversal within bytes)."""
fn rv32_bitrev_native(caps: Rv32Caps) -> bool:
    caps.has_zbb and caps.has_zbkb

"""True when RV32 Zbb provides ROL/ROR (rotate-left / rotate-right)."""
fn rv32_rotate_native(caps: Rv32Caps) -> bool:
    caps.has_zbb or caps.has_zbkb

"""True when RV32 scalar AES encrypt is available via Zkne."""
fn rv32_aes_enc_native(caps: Rv32Caps) -> bool:
    caps.has_zkne

"""True when RV32 scalar AES decrypt is available via Zknd."""
fn rv32_aes_dec_native(caps: Rv32Caps) -> bool:
    caps.has_zknd

"""True when RV32 SHA-256 round function is available via Zknh."""
fn rv32_sha256_native(caps: Rv32Caps) -> bool:
    caps.has_zknh

"""RV32 lowering decision — parallel to arm32_lowering_decision."""
struct Rv32LoweringDecision:
    lowered:  bool
    fallback: bool
    reason:   text

fn rv32_lowering_decision(caps: Rv32Caps, idiom: TargetIdiom) -> Rv32LoweringDecision:
    """Return the lowering decision for a single idiom given this target's Rv32Caps."""
    match idiom:
        case Sha512Rounds2:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "SHA-512 needs 64-bit ops — not possible on RV32")
        case Sha512Msg1:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "SHA-512 needs 64-bit ops — not possible on RV32")
        case Sha512Msg2:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "SHA-512 needs 64-bit ops — not possible on RV32")
        case Crc32U8:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "no CRC32 in RISC-V base ISA or standard extensions")
        case Crc32U32:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "no CRC32 in RISC-V base ISA or standard extensions")
        case Crc32U64:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "no CRC32 in RISC-V; 64-bit operand also impossible on RV32")
        case ClmulLo:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "Zbc carry-less multiply not guaranteed on bare-metal RV32")
        case ClmulHi:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "Zbc carry-less multiply not guaranteed on bare-metal RV32")
        case SimdI32x8:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "no 256-bit SIMD on RV32")
        case SimdF32x8:
            Rv32LoweringDecision(lowered: false, fallback: true, reason: "no 256-bit SIMD on RV32")
        case _:
            if caps.supports(idiom):
                Rv32LoweringDecision(lowered: true, fallback: false, reason: "")
            else:
                Rv32LoweringDecision(lowered: false, fallback: true, reason: "feature not present in Rv32Caps")
