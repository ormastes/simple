use std.spec.{describe, it, expect, assert_true, assert_false, assert_equal, assert_not_equal, assert_contains, assert_nil}

describe "standalone assert functions":
    it "assert_true passes for true":
        assert_true(true)

    it "assert_false passes for false":
        assert_false(false)

    it "assert_equal passes for equal integers":
        assert_equal(42, 42)

    it "assert_equal passes for equal strings":
        assert_equal("hello", "hello")

    it "assert_not_equal passes for different values":
        assert_not_equal(1, 2)

    it "assert_contains passes when substring is present":
        assert_contains("hello world", "world")

    it "assert_nil passes for nil":
        assert_nil(nil)
