# duplicate-typed-args suppression was removed from this coverage spec
# primitive-api suppression was removed from this coverage spec
use std.common.cbor.major_types.*
use std.common.cbor.types.*
use std.common.cbor.encode.*
use std.common.cbor.decode.*

describe "quick test":
    it "text_to_bytes single char":
        val result = text_to_bytes("a")
        expect(result.len()).to_equal(1)
    it "text_to_bytes multi char":
        val result = text_to_bytes("ab")
        expect(result.len()).to_equal(2)
    it "var name test my_bytes":
        val my_bytes: [i64] = []
        expect(cbor_validate(my_bytes)).to_equal(false)
    it "var name test bytes":
        val bytes: [i64] = []
        expect(cbor_validate(bytes)).to_equal(false)
