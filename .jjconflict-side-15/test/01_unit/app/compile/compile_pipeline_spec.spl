# # Compile Pipeline Unit Tests
#
# **Feature ID:** #APP-COMPILE-001
# **Category:** App | Compile
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Compilation Stages":
    it "lex stage":
        val stage = "lex"
        check(stage == "lex")

    it "parse stage":
        val stage = "parse"
        check(stage == "parse")

    it "typecheck stage":
        val stage = "typecheck"
        check(stage == "typecheck")

    it "lower to hir stage":
        val stage = "hir_lower"
        check(stage == "hir_lower")

    it "lower to mir stage":
        val stage = "mir_lower"
        check(stage == "mir_lower")

    it "optimize stage":
        val stage = "optimize"
        check(stage == "optimize")

    it "codegen stage":
        val stage = "codegen"
        check(stage == "codegen")

    it "link stage":
        val stage = "link"
        check(stage == "link")

describe "Compilation Targets":
    it "compile to native":
        val target = "native"
        check(target == "native")

    it "compile to c":
        val target = "c"
        check(target == "c")

    it "compile to llvm-ir":
        val target = "llvm-ir"
        check(target == "llvm-ir")

    it "compile to wasm":
        val target = "wasm"
        check(target == "wasm")

    it "compile to cuda":
        val target = "cuda"
        check(target == "cuda")

    it "compile to vhdl":
        val target = "vhdl"
        check(target == "vhdl")

describe "Compilation Options":
    it "entry point specification":
        val entry = "src/app/cli/main.spl"
        check(entry.ends_with(".spl"))

    it "output path specification":
        val output = "build/output"
        check(output.starts_with("build"))

    it "debug info inclusion":
        val debug = true
        check(debug)

    it "optimization level":
        val opt_level = 2
        check(opt_level >= 0 and opt_level <= 3)

    it "self-contained format":
        val format = "self-contained"
        check(format == "self-contained")

describe "Compilation Errors":
    it "file not found error":
        val error = "file_not_found"
        check(error == "file_not_found")

    it "syntax error":
        val error = "syntax_error"
        check(error == "syntax_error")

    it "type error":
        val error = "type_error"
        check(error == "type_error")

    it "linker error":
        val error = "linker_error"
        check(error == "linker_error")

    it "multiple errors collected":
        val errors = ["e1", "e2", "e3"]
        check(errors.len() == 3)
