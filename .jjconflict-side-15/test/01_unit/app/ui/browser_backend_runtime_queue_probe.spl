use common.ui.builder.{button, panel, text_widget, build_tree_with_title}
use common.ui.widget.{UIEvent, WidgetKind, WidgetNode}
use common.ui.draw_ir.{draw_ir_event_target_context}
use common.ui.draw_ir_sdn.{sdn_to_draw_ir}
use common.ui.state.{init_state}
use app.ui.browser.backend.{BrowserBackend}

extern fn rt_host_gpu_queue_reset()
extern fn rt_time_now_unix_micros() -> i64

fn browser_frame_checksum(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = (checksum + pixels[i].to_i64() * (i.to_i64() + 1)) % 2147483647
        i = i + 1
    checksum

fn browser_frame_nonuniform_count(pixels: [u32]) -> i64:
    if pixels.len() == 0:
        return 0
    val first = pixels[0]
    var count: i64 = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] != first:
            count = count + 1
        i = i + 1
    count

fn text_occurrence_count(value: text, needle: text) -> i64:
    if needle == "":
        return 0
    val parts = value.split(needle)
    if parts.len() <= 1:
        return 0
    (parts.len() - 1).to_i64()

fn text_has(value: text, needle: text) -> text:
    if value.contains(needle):
        return "true"
    "false"

fn browser_queue_image_widget() -> WidgetNode:
    var node = WidgetNode.new("browser_queue_logo", WidgetKind.Image.to_wire())
    node = node.set_prop("src", "asset://browser-queue/logo")
    node = node.set_prop("alt", "Browser Queue Logo")
    node

val root = panel("browser_queue_root", "Browser Queue", [
    text_widget("browser_queue_copy", "Queued frame"),
    button("browser_queue_action", "Run", "run"),
    browser_queue_image_widget()
])
val tree = build_tree_with_title(root, "Browser Queue", "dark")
val state = init_state(tree)

rt_host_gpu_queue_reset()
val backend = BrowserBackend.create(64, 48, "vulkan").unwrap()
val input_event = UIEvent.Action("run")
backend.push_event(input_event)
val queued_events = backend.poll_events()
if queued_events.len() > 0:
    backend.record_event_dispatch(queued_events[0])
val first_start_us = rt_time_now_unix_micros()
backend.render_frame(state.tree, state)
val first_render_us = rt_time_now_unix_micros() - first_start_us
val first_pixels = backend.pixels_argb_u32()
print("backend=" + backend.gpu_backend())
print("first_render_us=" + str(first_render_us))
print("first_render_under_budget=" + if first_render_us > 0 and first_render_us < 5000000: "true" else: "false")
print("first_render_dom_layout_us=" + str(backend.last_render_dom_layout_us))
print("first_render_html_us=" + str(backend.last_render_html_us))
print("first_render_pixel_artifact_us=" + str(backend.last_render_pixel_artifact_us))
print("first_render_draw_ir_dispatch_us=" + str(backend.last_render_draw_ir_dispatch_us))
print("first_render_framebuffer_copy_us=" + str(backend.last_render_framebuffer_copy_us))
