val first_dispatch_composition = sdn_to_draw_ir(backend.last_artifact_queue_dispatch_payload_text)
val first_dispatch_context = draw_ir_event_target_context(first_dispatch_composition, first_dispatch_composition.scene_key, "browser-queue-click", "click", "browser_queue_action:text", "button", 7, 33, "gpu")
print("first_dispatch_target_context_resolved=" + if first_dispatch_context.resolved: "true" else: "false")
print("first_dispatch_target_context_batch_id=" + first_dispatch_context.batch_id)
print("first_dispatch_target_context_surface_id=" + first_dispatch_context.surface_id)
print("first_dispatch_target_context_component_id=" + first_dispatch_context.component_id)
print("first_dispatch_target_context_source_kind=" + first_dispatch_context.source_kind)
print("first_reason=" + backend.last_artifact_queue_reason)
print("first_readback_status=" + backend.last_artifact_readback_status)
