print("event_roundtrip_status=" + backend.last_input_event_roundtrip_status)
print("event_enqueued_count=" + str(backend.input_event_enqueued_count))
print("event_polled_count=" + str(backend.input_event_polled_count))
print("event_dispatched_count=" + str(backend.input_event_dispatched_count))
print("event_host_gpu_target_lane=" + backend.last_input_event_host_gpu_target_lane)
print("event_host_gpu_forwarded=" + if backend.last_input_event_host_gpu_forwarded: "true" else: "false")
