print("first_dispatch_text_command_count=" + str(text_occurrence_count(backend.last_artifact_queue_dispatch_payload_text, "command kind=text")))
print("first_dispatch_image_command_count=" + str(text_occurrence_count(backend.last_artifact_queue_dispatch_payload_text, "command kind=image")))
