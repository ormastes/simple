#!/bin/sh
set -eu
mkdir -p "$BUILD_DIR"
{
  echo "tauri_chrome_simple_web_layout_manifest_status=pass"
  echo "tauri_chrome_simple_web_layout_manifest_reason=pass"
  echo "tauri_chrome_simple_web_layout_manifest_electron_capture_status=pass"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_capture_status=pass"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_live_capture=true"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_mismatch_count=0"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_case_count=1"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_pass_count=1"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_tracked_count=0"
  echo "tauri_chrome_simple_web_layout_manifest_tauri_fail_count=0"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_capture_status=pass"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_live_capture=true"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_mismatch_count=0"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_case_count=1"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_pass_count=1"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_tracked_count=0"
  echo "tauri_chrome_simple_web_layout_manifest_chrome_fail_count=0"
  echo "tauri_chrome_simple_web_layout_manifest_no_fake_capture=true"
  echo "tauri_chrome_simple_web_layout_manifest_blur_or_tolerance_used=false"
} >"$BUILD_DIR/evidence.env"
