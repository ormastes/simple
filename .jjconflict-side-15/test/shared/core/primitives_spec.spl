# @platform: all
# Tests for primitive types in the Simple language.
#
# Covers basic operations on integers and booleans including
# arithmetic, comparisons, and logical operations.

describe "Primitives":
    # Tests for primitive data types: integers and booleans.
    # Verifies basic operations and edge cases.

    describe "integers":
        it "handles positive integers":
            expect(40 + 2).to_equal(42)
        it "handles zero":
            expect(7 - 7).to_equal(0)
        it "handles negative with parens":
            expect(0 - 1).to_equal(-1)

    describe "booleans":
        it "handles true":
            if not true:
                fail("true should be truthy")
        it "handles false":
            if false:
                fail("false should not be truthy")
        it "negates correctly":
            if not (not false):
                fail("not false should be truthy")
