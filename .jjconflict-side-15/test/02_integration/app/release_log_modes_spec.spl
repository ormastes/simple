use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_release(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/release/main.spl\" " + joined
    ])

describe "release log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_release(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports plan log-mode json":
        val (out, err, code) = _run_release(["plan", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"release plan\"")
        expect(out).to_contain("\"steps\":5")

    it "supports dot progress":
        val (out, err, code) = _run_release(["plan", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Release/Deploy Migration Plan")

    it "rejects invalid log mode":
        val (out, err, code) = _run_release(["plan", "--log-mode=noisy"])
        expect(code).to_equal(1)
