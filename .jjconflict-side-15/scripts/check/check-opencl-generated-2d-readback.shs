#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

. "$ROOT_DIR/scripts/deps/generated-2d-readback-lib.shs"

BUILD_DIR="${BUILD_DIR:-build/opencl_generated_2d_readback}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/opencl_generated_2d_readback_$(date -u +%F).md}"
TOOLCHAIN_BUILD_DIR="${TOOLCHAIN_BUILD_DIR:-$BUILD_DIR/toolchains}"
SPIRV_PATH="${SPIRV_PATH:-$TOOLCHAIN_BUILD_DIR/simple_2d_optimization.spirv}"
OPENCL_SPIRV_TOOL="${OPENCL_SPIRV_TOOL:-opencl-c-to-spirv}"
OPENCL_RUNTIME_PROBE="${OPENCL_RUNTIME_PROBE:-clinfo}"
CC_TOOL="${CC_TOOL:-cc}"
OPENCL_ELEMENT_COUNT="${OPENCL_ELEMENT_COUNT:-64}"
OPENCL_FILL_VALUE="${OPENCL_FILL_VALUE:-16909060}"
EXPECTED_PIXELS_PATH="$BUILD_DIR/expected-u32.json"
ACTUAL_PIXELS_PATH="$BUILD_DIR/actual-u32.json"

mkdir -p "$BUILD_DIR" "$TOOLCHAIN_BUILD_DIR" "$(dirname "$REPORT_PATH")"

has_opencl_loader() {
    generated_2d_loader_present "libOpenCL.so" /usr/lib/libOpenCL.so /usr/lib64/libOpenCL.so /lib/x86_64-linux-gnu/libOpenCL.so /usr/local/cuda/lib64/libOpenCL.so
}

emit_env() {
    status="$1"
    reason="$2"
    readback="$3"
    submit="$4"
    bytes="$(generated_2d_bytes_of "$SPIRV_PATH")"
    {
        echo "opencl_generated_2d_readback_status=$status"
        echo "opencl_generated_2d_readback_reason=$reason"
        echo "opencl_generated_2d_readback_spirv=$SPIRV_PATH"
        echo "opencl_generated_2d_readback_spirv_bytes=$bytes"
        echo "opencl_generated_2d_readback_loader_present=$loader_present"
        echo "opencl_generated_2d_readback_probe_tool_present=$probe_tool_present"
        echo "opencl_generated_2d_readback_module_verified=$module_verified"
        echo "opencl_generated_2d_readback_submit_attempted=$submit"
        echo "opencl_generated_2d_readback_readback_available=$readback"
        echo "opencl_generated_2d_readback_expected_checksum=0"
        echo "opencl_generated_2d_readback_actual_checksum=0"
        echo "opencl_generated_2d_readback_ops=fill,copy,alpha,scroll"
    } >"$BUILD_DIR/evidence.env"
}

emit_unavailable() {
    reason="$1"
    emit_env "unavailable" "$reason" "false" "false"
}

loader_present=false
if has_opencl_loader; then
    loader_present=true
fi

probe_tool_present=false
if generated_2d_have "$OPENCL_RUNTIME_PROBE"; then
    probe_tool_present=true
fi

module_verified=false
if ! generated_2d_module_verified "$SPIRV_PATH"; then
    REPORT_PATH="$BUILD_DIR/toolchains.md" BUILD_DIR="$TOOLCHAIN_BUILD_DIR" OPENCL_SPIRV_TOOL="$OPENCL_SPIRV_TOOL" sh scripts/check/check-portable-compute-toolchains.shs >/dev/null
fi

if generated_2d_module_verified "$SPIRV_PATH"; then
    module_verified=true
fi

if [ "$loader_present" != "true" ]; then
    emit_unavailable "missing-opencl-runtime-loader"
elif [ "$probe_tool_present" != "true" ]; then
    emit_unavailable "missing-opencl-runtime-probe-tool"
elif ! generated_2d_have "$CC_TOOL"; then
    emit_unavailable "missing-c-compiler"
else
    if "$OPENCL_RUNTIME_PROBE" >"$BUILD_DIR/opencl_probe.out" 2>"$BUILD_DIR/opencl_probe.err"; then
        cat >"$BUILD_DIR/opencl_generated_2d_readback.c" <<'C_EOF'
#include <CL/cl.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>

static const char *kernel_source =
"__kernel void simple_2d_fill_u32(__global uint* dst, uint value, uint count) {"
"  uint i = get_global_id(0); if (i >= count) return; dst[i] = value;"
"}"
"__kernel void simple_2d_copy_u32(__global const uint* src, __global uint* dst, uint count) {"
"  uint i = get_global_id(0); if (i >= count) return; dst[i] = src[i];"
"}"
"__kernel void simple_2d_alpha_u32(__global const uint* src, __global uint* dst, uint alpha, uint count) {"
"  uint i = get_global_id(0); if (i >= count) return;"
"  uint s = src[i]; uint d = dst[i]; uint inv = 255u - alpha;"
"  uint rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;"
"  uint g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;"
"  dst[i] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);"
"}"
"__kernel void simple_2d_scroll_u32(__global const uint* src, __global uint* dst, uint width, uint height, int delta_y) {"
"  uint i = get_global_id(0); uint count = width * height; if (i >= count) return;"
"  uint x = i % width; uint y = i / width; int sy = (int)y - delta_y;"
"  if (sy < 0 || sy >= (int)height) { dst[i] = 0u; return; }"
"  dst[i] = src[(uint)sy * width + x];"
"}";

static uint64_t checksum_u32(const uint32_t *data, unsigned int count) {
    uint64_t sum = 0;
    for (unsigned int i = 0; i < count; ++i) sum += data[i];
    return sum;
}

static uint64_t mismatch_u32(const uint32_t *actual, const uint32_t *expected, unsigned int count) {
    uint64_t mismatches = 0;
    for (unsigned int i = 0; i < count; ++i) {
        if (actual[i] != expected[i]) mismatches++;
    }
    return mismatches;
}

static uint64_t mismatch_fill_u32(const uint32_t *actual, uint32_t expected, unsigned int count) {
    uint64_t mismatches = 0;
    for (unsigned int i = 0; i < count; ++i) {
        if (actual[i] != expected) mismatches++;
    }
    return mismatches;
}

static int write_json_u32(const char *path, const uint32_t *data, unsigned int count, const char *producer) {
    FILE *f = fopen(path, "w");
    if (!f) return 0;
    fprintf(f, "{\"count\":%u,\"format\":\"u32\",\"producer\":\"%s\",\"pixels\":[", count, producer);
    for (unsigned int i = 0; i < count; ++i) {
        if (i > 0) fputc(',', f);
        fprintf(f, "%u", data[i]);
    }
    fprintf(f, "]}");
    fclose(f);
    return 1;
}

static uint32_t alpha_pixel(uint32_t s, uint32_t d, uint32_t alpha) {
    uint32_t inv = 255u - alpha;
    uint32_t rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;
    uint32_t g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;
    return 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);
}

static void fail(const char *reason, cl_int code, uint64_t expected, uint64_t actual) {
    printf("opencl_generated_2d_readback_status=fail\n");
    printf("opencl_generated_2d_readback_reason=%s\n", reason);
    printf("opencl_generated_2d_readback_opencl_code=%d\n", (int)code);
    printf("opencl_generated_2d_readback_expected_checksum=%llu\n", (unsigned long long)expected);
    printf("opencl_generated_2d_readback_actual_checksum=%llu\n", (unsigned long long)actual);
}

static int set3(cl_kernel k, cl_mem a, cl_mem b, cl_uint c) {
    cl_int err = CL_SUCCESS;
    err |= clSetKernelArg(k, 0, sizeof(cl_mem), &a);
    err |= clSetKernelArg(k, 1, sizeof(cl_mem), &b);
    err |= clSetKernelArg(k, 2, sizeof(cl_uint), &c);
    return err == CL_SUCCESS;
}

int main(int argc, char **argv) {
    unsigned int count = argc > 1 ? (unsigned int)strtoul(argv[1], NULL, 10) : 64u;
    unsigned int value = argc > 2 ? (unsigned int)strtoul(argv[2], NULL, 10) : 16909060u;
    const char *expected_pixels_path = argc > 3 ? argv[3] : "expected-u32.json";
    const char *actual_pixels_path = argc > 4 ? argv[4] : "actual-u32.json";
    if (count == 0 || count % 8u != 0u) { fail("invalid-count", -1, 0, 0); return 2; }
    size_t bytes = (size_t)count * sizeof(uint32_t);

    cl_int err = CL_SUCCESS;
    cl_uint platform_count = 0;
    err = clGetPlatformIDs(0, NULL, &platform_count);
    if (err != CL_SUCCESS || platform_count == 0) { fail("opencl-no-platform", err, 0, 0); return 3; }
    cl_platform_id platform = NULL;
    err = clGetPlatformIDs(1, &platform, NULL);
    if (err != CL_SUCCESS) { fail("opencl-get-platform", err, 0, 0); return 3; }
    cl_device_id device = NULL;
    err = clGetDeviceIDs(platform, CL_DEVICE_TYPE_GPU, 1, &device, NULL);
    if (err != CL_SUCCESS) err = clGetDeviceIDs(platform, CL_DEVICE_TYPE_DEFAULT, 1, &device, NULL);
    if (err != CL_SUCCESS) { fail("opencl-no-device", err, 0, 0); return 3; }
    cl_context context = clCreateContext(NULL, 1, &device, NULL, NULL, &err);
    if (err != CL_SUCCESS) { fail("opencl-create-context", err, 0, 0); return 3; }
    cl_command_queue queue = clCreateCommandQueueWithProperties(context, device, NULL, &err);
    if (err != CL_SUCCESS) { fail("opencl-create-queue", err, 0, 0); return 3; }
    cl_program program = clCreateProgramWithSource(context, 1, &kernel_source, NULL, &err);
    if (err != CL_SUCCESS) { fail("opencl-create-program", err, 0, 0); return 3; }
    err = clBuildProgram(program, 1, &device, "", NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-build-program", err, 0, 0); return 3; }
    cl_kernel k_fill = clCreateKernel(program, "simple_2d_fill_u32", &err);
    if (err != CL_SUCCESS) { fail("opencl-create-fill-kernel", err, 0, 0); return 3; }
    cl_kernel k_copy = clCreateKernel(program, "simple_2d_copy_u32", &err);
    if (err != CL_SUCCESS) { fail("opencl-create-copy-kernel", err, 0, 0); return 3; }
    cl_kernel k_alpha = clCreateKernel(program, "simple_2d_alpha_u32", &err);
    if (err != CL_SUCCESS) { fail("opencl-create-alpha-kernel", err, 0, 0); return 3; }
    cl_kernel k_scroll = clCreateKernel(program, "simple_2d_scroll_u32", &err);
    if (err != CL_SUCCESS) { fail("opencl-create-scroll-kernel", err, 0, 0); return 3; }

    uint32_t *host = (uint32_t *)calloc(count, sizeof(uint32_t));
    uint32_t *expected_buf = (uint32_t *)calloc(count, sizeof(uint32_t));
    uint32_t *expected_all = (uint32_t *)calloc((size_t)count * 4u, sizeof(uint32_t));
    uint32_t *actual_all = (uint32_t *)calloc((size_t)count * 4u, sizeof(uint32_t));
    if (!host || !expected_buf || !expected_all || !actual_all) { fail("host-alloc-failed", -1, 0, 0); return 3; }
    cl_mem src = clCreateBuffer(context, CL_MEM_READ_WRITE, bytes, NULL, &err);
    if (err != CL_SUCCESS) { fail("opencl-buffer-src", err, 0, 0); return 3; }
    cl_mem dst = clCreateBuffer(context, CL_MEM_READ_WRITE, bytes, NULL, &err);
    if (err != CL_SUCCESS) { fail("opencl-buffer-dst", err, 0, 0); return 3; }
    size_t global = count;

    cl_uint count_arg = count;
    cl_uint value_arg = value;
    err = clSetKernelArg(k_fill, 0, sizeof(cl_mem), &dst);
    err |= clSetKernelArg(k_fill, 1, sizeof(cl_uint), &value_arg);
    err |= clSetKernelArg(k_fill, 2, sizeof(cl_uint), &count_arg);
    if (err != CL_SUCCESS) { fail("opencl-fill-args", err, 0, 0); return 3; }
    err = clEnqueueNDRangeKernel(queue, k_fill, 1, NULL, &global, NULL, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-fill-enqueue", err, 0, 0); return 3; }
    err = clFinish(queue);
    if (err != CL_SUCCESS) { fail("opencl-fill-finish", err, 0, 0); return 3; }
    err = clEnqueueReadBuffer(queue, dst, CL_TRUE, 0, bytes, host, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-fill-readback", err, 0, 0); return 3; }
    uint64_t fill_actual = checksum_u32(host, count);
    uint64_t fill_expected = (uint64_t)value * (uint64_t)count;
    uint64_t fill_mismatches = mismatch_fill_u32(host, value, count);
    for (unsigned int i = 0; i < count; ++i) { expected_all[i] = value; actual_all[i] = host[i]; }

    for (unsigned int i = 0; i < count; ++i) expected_buf[i] = 1000u + i;
    err = clEnqueueWriteBuffer(queue, src, CL_TRUE, 0, bytes, expected_buf, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-copy-write", err, 0, 0); return 3; }
    if (!set3(k_copy, src, dst, count_arg)) { fail("opencl-copy-args", -1, 0, 0); return 3; }
    err = clEnqueueNDRangeKernel(queue, k_copy, 1, NULL, &global, NULL, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-copy-enqueue", err, 0, 0); return 3; }
    err = clFinish(queue);
    if (err != CL_SUCCESS) { fail("opencl-copy-finish", err, 0, 0); return 3; }
    err = clEnqueueReadBuffer(queue, dst, CL_TRUE, 0, bytes, host, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-copy-readback", err, 0, 0); return 3; }
    uint64_t copy_actual = checksum_u32(host, count);
    uint64_t copy_expected = checksum_u32(expected_buf, count);
    uint64_t copy_mismatches = mismatch_u32(host, expected_buf, count);
    for (unsigned int i = 0; i < count; ++i) { expected_all[count + i] = expected_buf[i]; actual_all[count + i] = host[i]; }

    for (unsigned int i = 0; i < count; ++i) expected_buf[i] = 0xff204060u + i;
    for (unsigned int i = 0; i < count; ++i) host[i] = 0xff102030u + i;
    err = clEnqueueWriteBuffer(queue, src, CL_TRUE, 0, bytes, expected_buf, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-alpha-src-write", err, 0, 0); return 3; }
    err = clEnqueueWriteBuffer(queue, dst, CL_TRUE, 0, bytes, host, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-alpha-dst-write", err, 0, 0); return 3; }
    cl_uint alpha = 128u;
    for (unsigned int i = 0; i < count; ++i) expected_buf[i] = alpha_pixel(expected_buf[i], host[i], alpha);
    err = clSetKernelArg(k_alpha, 0, sizeof(cl_mem), &src);
    err |= clSetKernelArg(k_alpha, 1, sizeof(cl_mem), &dst);
    err |= clSetKernelArg(k_alpha, 2, sizeof(cl_uint), &alpha);
    err |= clSetKernelArg(k_alpha, 3, sizeof(cl_uint), &count_arg);
    if (err != CL_SUCCESS) { fail("opencl-alpha-args", err, 0, 0); return 3; }
    err = clEnqueueNDRangeKernel(queue, k_alpha, 1, NULL, &global, NULL, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-alpha-enqueue", err, 0, 0); return 3; }
    err = clFinish(queue);
    if (err != CL_SUCCESS) { fail("opencl-alpha-finish", err, 0, 0); return 3; }
    err = clEnqueueReadBuffer(queue, dst, CL_TRUE, 0, bytes, host, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-alpha-readback", err, 0, 0); return 3; }
    uint64_t alpha_actual = checksum_u32(host, count);
    uint64_t alpha_expected = checksum_u32(expected_buf, count);
    uint64_t alpha_mismatches = mismatch_u32(host, expected_buf, count);
    for (unsigned int i = 0; i < count; ++i) { expected_all[count * 2u + i] = expected_buf[i]; actual_all[count * 2u + i] = host[i]; }

    cl_uint width = 8u;
    cl_uint height = count / width;
    cl_int delta_y = 1;
    for (unsigned int i = 0; i < count; ++i) host[i] = 2000u + i;
    for (unsigned int i = 0; i < count; ++i) {
        unsigned int x = i % width;
        unsigned int y = i / width;
        int sy = (int)y - delta_y;
        expected_buf[i] = (sy < 0 || sy >= (int)height) ? 0u : host[(unsigned int)sy * width + x];
    }
    err = clEnqueueWriteBuffer(queue, src, CL_TRUE, 0, bytes, host, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-scroll-write", err, 0, 0); return 3; }
    err = clSetKernelArg(k_scroll, 0, sizeof(cl_mem), &src);
    err |= clSetKernelArg(k_scroll, 1, sizeof(cl_mem), &dst);
    err |= clSetKernelArg(k_scroll, 2, sizeof(cl_uint), &width);
    err |= clSetKernelArg(k_scroll, 3, sizeof(cl_uint), &height);
    err |= clSetKernelArg(k_scroll, 4, sizeof(cl_int), &delta_y);
    if (err != CL_SUCCESS) { fail("opencl-scroll-args", err, 0, 0); return 3; }
    err = clEnqueueNDRangeKernel(queue, k_scroll, 1, NULL, &global, NULL, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-scroll-enqueue", err, 0, 0); return 3; }
    err = clFinish(queue);
    if (err != CL_SUCCESS) { fail("opencl-scroll-finish", err, 0, 0); return 3; }
    err = clEnqueueReadBuffer(queue, dst, CL_TRUE, 0, bytes, host, 0, NULL, NULL);
    if (err != CL_SUCCESS) { fail("opencl-scroll-readback", err, 0, 0); return 3; }
    uint64_t scroll_actual = checksum_u32(host, count);
    uint64_t scroll_expected = checksum_u32(expected_buf, count);
    uint64_t scroll_mismatches = mismatch_u32(host, expected_buf, count);
    for (unsigned int i = 0; i < count; ++i) { expected_all[count * 3u + i] = expected_buf[i]; actual_all[count * 3u + i] = host[i]; }

    uint64_t actual = fill_actual + copy_actual + alpha_actual + scroll_actual;
    uint64_t expected = fill_expected + copy_expected + alpha_expected + scroll_expected;
    uint64_t mismatches = fill_mismatches + copy_mismatches + alpha_mismatches + scroll_mismatches;
    int wrote_expected = write_json_u32(expected_pixels_path, expected_all, count * 4u, "opencl-generated-2d-expected");
    int wrote_actual = write_json_u32(actual_pixels_path, actual_all, count * 4u, "opencl-generated-2d-readback");
    if (actual == expected && mismatches == 0 && wrote_expected && wrote_actual) {
        printf("opencl_generated_2d_readback_status=pass\n");
        printf("opencl_generated_2d_readback_reason=readback-pixels-matched\n");
        printf("opencl_generated_2d_readback_opencl_code=0\n");
        printf("opencl_generated_2d_readback_submit_attempted=true\n");
        printf("opencl_generated_2d_readback_readback_available=true\n");
        printf("opencl_generated_2d_readback_expected_checksum=%llu\n", (unsigned long long)expected);
        printf("opencl_generated_2d_readback_actual_checksum=%llu\n", (unsigned long long)actual);
        printf("opencl_generated_2d_readback_mismatch_count=%llu\n", (unsigned long long)mismatches);
        printf("opencl_generated_2d_readback_fill_expected_checksum=%llu\n", (unsigned long long)fill_expected);
        printf("opencl_generated_2d_readback_fill_actual_checksum=%llu\n", (unsigned long long)fill_actual);
        printf("opencl_generated_2d_readback_fill_mismatch_count=%llu\n", (unsigned long long)fill_mismatches);
        printf("opencl_generated_2d_readback_copy_expected_checksum=%llu\n", (unsigned long long)copy_expected);
        printf("opencl_generated_2d_readback_copy_actual_checksum=%llu\n", (unsigned long long)copy_actual);
        printf("opencl_generated_2d_readback_copy_mismatch_count=%llu\n", (unsigned long long)copy_mismatches);
        printf("opencl_generated_2d_readback_alpha_expected_checksum=%llu\n", (unsigned long long)alpha_expected);
        printf("opencl_generated_2d_readback_alpha_actual_checksum=%llu\n", (unsigned long long)alpha_actual);
        printf("opencl_generated_2d_readback_alpha_mismatch_count=%llu\n", (unsigned long long)alpha_mismatches);
        printf("opencl_generated_2d_readback_scroll_expected_checksum=%llu\n", (unsigned long long)scroll_expected);
        printf("opencl_generated_2d_readback_scroll_actual_checksum=%llu\n", (unsigned long long)scroll_actual);
        printf("opencl_generated_2d_readback_scroll_mismatch_count=%llu\n", (unsigned long long)scroll_mismatches);
        printf("opencl_generated_2d_readback_blur_or_tolerance_used=false\n");
        printf("opencl_generated_2d_readback_ops=fill,copy,alpha,scroll\n");
        printf("opencl_generated_2d_readback_count=%u\n", count);
        printf("opencl_generated_2d_readback_value=%u\n", value);
        printf("opencl_generated_2d_readback_expected_pixels_path=%s\n", expected_pixels_path);
        printf("opencl_generated_2d_readback_actual_pixels_path=%s\n", actual_pixels_path);
        return 0;
    }
    fail(wrote_expected && wrote_actual ? "readback-pixel-mismatch" : "readback-artifact-write-failed", 0, expected, actual);
    return 4;
}
C_EOF
        if ! "$CC_TOOL" -O2 -o "$BUILD_DIR/opencl_generated_2d_readback" "$BUILD_DIR/opencl_generated_2d_readback.c" -lOpenCL >"$BUILD_DIR/cc.out" 2>"$BUILD_DIR/cc.err"; then
            emit_unavailable "opencl-readback-harness-build-failed"
        elif "$BUILD_DIR/opencl_generated_2d_readback" "$OPENCL_ELEMENT_COUNT" "$OPENCL_FILL_VALUE" "$EXPECTED_PIXELS_PATH" "$ACTUAL_PIXELS_PATH" >"$BUILD_DIR/evidence.env" 2>"$BUILD_DIR/run.err"; then
            {
                echo "opencl_generated_2d_readback_spirv=$SPIRV_PATH"
                echo "opencl_generated_2d_readback_spirv_bytes=$(generated_2d_bytes_of "$SPIRV_PATH")"
                echo "opencl_generated_2d_readback_loader_present=$loader_present"
                echo "opencl_generated_2d_readback_probe_tool_present=$probe_tool_present"
                echo "opencl_generated_2d_readback_module_verified=$module_verified"
            } >>"$BUILD_DIR/evidence.env"
        else
            if [ ! -s "$BUILD_DIR/evidence.env" ]; then
                emit_unavailable "opencl-readback-run-failed"
            fi
        fi
    else
        emit_unavailable "opencl-runtime-probe-failed"
    fi
fi

. "$BUILD_DIR/evidence.env"
generated_2d_report_from_env "$REPORT_PATH" "OpenCL Generated 2D Readback Evidence" "$BUILD_DIR/evidence.env" "Generated OpenCL evidence is fail-closed until the OpenCL loader, runtime probe, compiled kernel harness, device/queue/kernel handles, submit, synchronization, and readback checksum are all present. The SPIR-V fields are retained as portable-toolchain diagnostics; this gate passes only from direct OpenCL C runtime execution and readback checksum parity."

cat "$BUILD_DIR/evidence.env"
echo "report_path=$REPORT_PATH"

if [ "$opencl_generated_2d_readback_status" = "pass" ]; then
    exit 0
fi
exit 1
