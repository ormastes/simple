# Game Console — command-dispatching console with history
#
# Provides an in-game console that registers commands, stores
# input/output history, and dispatches text input.

# ============================================================================
# ConsoleCommand — registered command descriptor
# ============================================================================

struct ConsoleCommand:
    name: text
    description: text

# ============================================================================
# ConsoleEntry — single line in the console history
# ============================================================================

struct ConsoleEntry:
    content: text
    is_input: bool

# ============================================================================
# GameConsole — command registry + history buffer
# ============================================================================

class GameConsole:
    commands: [ConsoleCommand]
    history: [ConsoleEntry]
    visible: bool
    max_history: i64
    input_buffer: text

impl GameConsole:
    static fn new(max_history: i64) -> GameConsole:
        """Create a new game console with the given history limit."""
        GameConsole(
            commands: [],
            history: [],
            visible: false,
            max_history: max_history,
            input_buffer: ""
        )

    me register_command(name: text, description: text):
        """Register a command with its description."""
        val cmd = ConsoleCommand(name: name, description: description)
        self.commands = self.commands.push(cmd)

    me execute(input: text) -> text:
        """Parse and dispatch a command. Returns the output text.
        Stores both the input and output in history."""
        # Record input
        val input_entry = ConsoleEntry(content: input, is_input: true)
        self.history = self.history.push(input_entry)

        # Check if command is registered
        var found = false
        var cmd_desc = ""
        var i = 0
        while i < self.commands.len():
            if self.commands[i].name == input:
                found = true
                cmd_desc = self.commands[i].description
            i = i + 1

        var output = ""
        if found:
            output = "> " + input + ": " + cmd_desc
        else:
            output = "> unknown command: " + input

        # Record output
        val output_entry = ConsoleEntry(content: output, is_input: false)
        self.history = self.history.push(output_entry)

        # Trim history if over limit
        self._trim_history()

        output

    me toggle():
        """Toggle console visibility."""
        self.visible = not self.visible

    me add_output(content: text):
        """Add a line to the output history."""
        val entry = ConsoleEntry(content: content, is_input: false)
        self.history = self.history.push(entry)
        self._trim_history()

    fn is_visible(self) -> bool:
        """Check if the console is visible."""
        self.visible

    fn get_history(self) -> [ConsoleEntry]:
        """Get the full history."""
        self.history

    fn command_count(self) -> i64:
        """Return the number of registered commands."""
        self.commands.len()

    fn has_command(self, name: text) -> bool:
        """Check if a command is registered."""
        var i = 0
        while i < self.commands.len():
            if self.commands[i].name == name:
                return true
            i = i + 1
        false

    me clear_history():
        """Clear all history entries."""
        self.history = []

    # --- internal helper ---
    me _trim_history():
        """Remove oldest entries if history exceeds max_history."""
        while self.history.len() > self.max_history:
            # Rebuild without the first element
            var trimmed: [ConsoleEntry] = []
            var i = 1
            while i < self.history.len():
                trimmed = trimmed.push(self.history[i])
                i = i + 1
            self.history = trimmed
