pub fn wine_nt_api_kernel32_atom_table_import_gate(dll: text, symbols: [text]) -> text:
    if dll.lower() != "kernel32.dll":
        return "unsupported-dll:" + dll
    if symbols.len() == 0:
        return "missing-symbol:kernel32-atom-table"
    for symbol in symbols:
        val entry = _k32_lookup(symbol)
        if entry.state == "unsupported":
            return "unsupported-symbol:" + symbol
        if entry.state == "catalogued":
            return "catalogued-symbol:" + symbol
        if entry.category != "atom-table":
            return "wrong-category:" + symbol
    "ready"

pub fn wine_nt_api_kernel32_atom_table_dispatch_gate(symbols: [text]) -> text:
    if symbols.len() == 0:
        return "bridge-missing:kernel32-atom-table"
    for symbol in symbols:
        val entry = _k32_lookup(symbol)
        if entry.state != "implemented":
            return "bridge-unsupported:" + symbol
        if entry.category != "atom-table":
            return "bridge-wrong-category:" + symbol
    "ready"

