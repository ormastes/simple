"""3D Engine — Bind Group and Uniform System

@tag:stdlib
@tag:api
@tag:gpu

Defines bind group layout, entries, and bind group types mirroring
the Chrome WebGPU descriptor set / bind group API.

Usage:
    use std.gpu.engine3d.bind_group3d.{BindGroupLayout3D, BindGroup3D, BindGroupEntry3D}
"""

# ============================================================================
# Binding Type Constants
# ============================================================================

val BINDING_UNIFORM_BUFFER: i32 = 0
val BINDING_STORAGE_BUFFER: i32 = 1
val BINDING_READONLY_STORAGE_BUFFER: i32 = 2
val BINDING_TEXTURE: i32 = 3
val BINDING_STORAGE_TEXTURE: i32 = 4
val BINDING_SAMPLER: i32 = 5
val BINDING_COMPARISON_SAMPLER: i32 = 6

# ============================================================================
# Shader Visibility Flags
# ============================================================================

val VISIBILITY_VERTEX: i32 = 1
val VISIBILITY_FRAGMENT: i32 = 2
val VISIBILITY_COMPUTE: i32 = 4
val VISIBILITY_ALL: i32 = 7

# ============================================================================
# Bind Group Layout Entry
# ============================================================================

class BindGroupLayoutEntry3D:
    binding: i32
    visibility: i32
    binding_type: i32
    buffer_size: i32

    static fn uniform(binding: i32, visibility: i32, size: i32) -> BindGroupLayoutEntry3D:
        BindGroupLayoutEntry3D(binding: binding, visibility: visibility, binding_type: BINDING_UNIFORM_BUFFER, buffer_size: size)

    static fn texture(binding: i32, visibility: i32) -> BindGroupLayoutEntry3D:
        BindGroupLayoutEntry3D(binding: binding, visibility: visibility, binding_type: BINDING_TEXTURE, buffer_size: 0)

    static fn sampler(binding: i32, visibility: i32) -> BindGroupLayoutEntry3D:
        BindGroupLayoutEntry3D(binding: binding, visibility: visibility, binding_type: BINDING_SAMPLER, buffer_size: 0)

    static fn storage(binding: i32, visibility: i32, size: i32) -> BindGroupLayoutEntry3D:
        BindGroupLayoutEntry3D(binding: binding, visibility: visibility, binding_type: BINDING_STORAGE_BUFFER, buffer_size: size)

# ============================================================================
# Bind Group Layout
# ============================================================================

class BindGroupLayout3D:
    id: i32
    entries: [BindGroupLayoutEntry3D]

    static fn create(entries: [BindGroupLayoutEntry3D]) -> BindGroupLayout3D:
        BindGroupLayout3D(id: -1, entries: entries)

# ============================================================================
# Bind Group Entry (resource binding)
# ============================================================================

class BindGroupEntry3D:
    binding: i32
    buffer_id: i32
    texture_id: i32
    sampler_id: i32
    offset: i32
    size: i32

    static fn buffer(binding: i32, buffer_id: i32, offset: i32, size: i32) -> BindGroupEntry3D:
        BindGroupEntry3D(binding: binding, buffer_id: buffer_id, texture_id: -1, sampler_id: -1, offset: offset, size: size)

    static fn texture(binding: i32, texture_id: i32) -> BindGroupEntry3D:
        BindGroupEntry3D(binding: binding, buffer_id: -1, texture_id: texture_id, sampler_id: -1, offset: 0, size: 0)

    static fn sampler(binding: i32, sampler_id: i32) -> BindGroupEntry3D:
        BindGroupEntry3D(binding: binding, buffer_id: -1, texture_id: -1, sampler_id: sampler_id, offset: 0, size: 0)

# ============================================================================
# Bind Group
# ============================================================================

class BindGroup3D:
    id: i32
    layout_id: i32
    entries: [BindGroupEntry3D]

    static fn create(layout_id: i32, entries: [BindGroupEntry3D]) -> BindGroup3D:
        BindGroup3D(id: -1, layout_id: layout_id, entries: entries)

    fn entry_count() -> i32:
        self.entries.len()

# ============================================================================
# Standard Layout Presets
# ============================================================================

fn standard_mvp_layout() -> BindGroupLayout3D:
    BindGroupLayout3D.create([
        BindGroupLayoutEntry3D.uniform(0, VISIBILITY_VERTEX, 64)
    ])

fn standard_material_layout() -> BindGroupLayout3D:
    BindGroupLayout3D.create([
        BindGroupLayoutEntry3D.uniform(0, VISIBILITY_FRAGMENT, 32),
        BindGroupLayoutEntry3D.texture(1, VISIBILITY_FRAGMENT),
        BindGroupLayoutEntry3D.sampler(2, VISIBILITY_FRAGMENT)
    ])

fn standard_lighting_layout() -> BindGroupLayout3D:
    BindGroupLayout3D.create([
        BindGroupLayoutEntry3D.uniform(0, VISIBILITY_FRAGMENT, 512)
    ])
