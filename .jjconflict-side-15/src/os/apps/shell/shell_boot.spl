# Lightweight shell boot state for architecture bring-up entries.

struct ShellBootState:
    prompt: text
    cwd: text
    interactive: bool

impl ShellBootState:
    static fn new() -> ShellBootState:
        ShellBootState(prompt: "$ ", cwd: "/", interactive: true)

fn shell_boot_init() -> ShellBootState:
    """Initialize the shell state used by boot smoke and architecture bring-up."""
    ShellBootState.new()
