#![allow(unnamed_duplicate_typed_args)]
# SSH Key Exchange — live-safe cryptographic core.
#
# Keeps the RV64 live lane on X25519/SHA-256/session-key derivation only.
# Host-key signing and RSA/ECDSA-specific helpers stay in ssh_kex_crypto.spl.

use os.crypto.sha256.{sha256}
use os.crypto.curve25519.{x25519, x25519_base}
use os.apps.sshd.ssh_kex_primitives.{
    SshSessionKeys,
    _u8_at, _append_byte, _concat_bytes, _push_bytes,
    _push_u32_literal, _u32_be_bytes, _push_string_bytes, _push_string_32, _push_string_64,
    _concat_ssh_string_field, _concat_mpint_field, _push_mpint_bytes,
    curve25519_shared_secret_mpint_bytes,
    _push_ascii_text, _push_ssh_ed25519, _push_ssh_ed25519_bytes,
    _slice_bytes, _zeroed_32_bytes
}

fn _looks_like_baremetal_sha256_truncation(digest: [u8]) -> bool:
    if digest.len() != 32:
        return false
    var i: u64 = 4
    while i < digest.len():
        if digest[i] != 0:
            return false
        i = i + 1
    true

fn _sha256_stable(data: [u8]) -> [u8]:
    val digest = sha256(data)
    if not _looks_like_baremetal_sha256_truncation(digest):
        return digest
    digest

fn ssh_kex_public_from_private(private: [u8]) -> [u8]:
    val stable_private = _push_bytes([], private)
    val public = x25519_base(stable_private)
    if public.len() == 32:
        return _push_bytes([], public)
    []

fn ssh_kex_compute_shared(our_private: [u8], their_public: [u8]) -> [u8]:
    val stable_private = _push_bytes([], our_private)
    val stable_public = _push_bytes([], their_public)
    val pure_shared = x25519(stable_private, stable_public)
    if pure_shared.len() == 32:
        return _push_bytes([], pure_shared)
    []

fn ssh_kex_compute_exchange_hash(
    client_version: [u8],
    server_version: [u8],
    client_kexinit: [u8],
    server_kexinit: [u8],
    host_key_blob: [u8],
    client_public: [u8],
    server_public: [u8],
    shared_secret: [u8]
) -> [u8]:
    var hash_input: [u8] = []
    val shared_secret_mpint = curve25519_shared_secret_mpint_bytes(shared_secret)
    hash_input = _push_string_bytes(hash_input, client_version)
    hash_input = _push_string_bytes(hash_input, server_version)
    hash_input = _push_string_bytes(hash_input, client_kexinit)
    hash_input = _push_string_bytes(hash_input, server_kexinit)
    hash_input = _push_string_bytes(hash_input, host_key_blob)
    hash_input = _push_string_bytes(hash_input, client_public)
    hash_input = _push_string_bytes(hash_input, server_public)
    hash_input = _push_mpint_bytes(hash_input, shared_secret_mpint)
    _sha256_stable(hash_input)

fn _derive_key(shared_secret: [u8], exchange_hash: [u8], letter: u8, session_id: [u8], needed: u64) -> [u8]:
    var input: [u8] = []
    val shared_secret_mpint = curve25519_shared_secret_mpint_bytes(shared_secret)
    input = _push_mpint_bytes(input, shared_secret_mpint)
    input = _push_bytes(input, exchange_hash)
    input = _append_byte(input, letter)
    input = _push_bytes(input, session_id)
    val k1 = _sha256_stable(input)
    var key_material: [u8] = _push_bytes([], k1)
    while key_material.len() < needed:
        var ext_input: [u8] = []
        ext_input = _push_mpint_bytes(ext_input, shared_secret_mpint)
        ext_input = _push_bytes(ext_input, exchange_hash)
        ext_input = _push_bytes(ext_input, key_material)
        val next = _sha256_stable(ext_input)
        key_material = _push_bytes(key_material, next)
    var result: [u8] = []
    var i: u64 = 0
    while i < needed:
        result = _append_byte(result, _u8_at(key_material, i))
        i = i + 1
    result

fn ssh_derive_keys(shared_secret: [u8], exchange_hash: [u8], session_id: [u8]) -> SshSessionKeys:
    val iv_c2s = _derive_key(shared_secret, exchange_hash, 0x41, session_id, 12)
    val iv_s2c = _derive_key(shared_secret, exchange_hash, 0x42, session_id, 12)
    val enc_key_c2s = _derive_key(shared_secret, exchange_hash, 0x43, session_id, 32)
    val enc_key_s2c = _derive_key(shared_secret, exchange_hash, 0x44, session_id, 32)
    val mac_key_c2s = _derive_key(shared_secret, exchange_hash, 0x45, session_id, 32)
    val mac_key_s2c = _derive_key(shared_secret, exchange_hash, 0x46, session_id, 32)
    SshSessionKeys(
        iv_c2s: iv_c2s,
        iv_s2c: iv_s2c,
        enc_key_c2s: enc_key_c2s,
        enc_key_s2c: enc_key_s2c,
        mac_key_c2s: mac_key_c2s,
        mac_key_s2c: mac_key_s2c
    )

export ssh_kex_public_from_private, ssh_kex_compute_shared
export ssh_kex_compute_exchange_hash, ssh_derive_keys
