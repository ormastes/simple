class BackendTestEntry:
    arch: text
    test_name: text
    category: text
    expected_result: text
    actual_result: text
    shared_truth_ref: text

    me is_passing():
        return actual_result == expected_result

    me is_compile_test():
        return category == "compile"

    me is_simulate_test():
        return category == "simulate"

    me is_aligned():
        return shared_truth_ref != ""

    static fn compile_test(arch: text, name: text, truth: text) -> BackendTestEntry:
        var e = BackendTestEntry {
            arch: arch,
            test_name: name,
            category: "compile",
            expected_result: "pass",
            actual_result: "",
            shared_truth_ref: truth
        }
        return e

    static fn sim_test(arch: text, name: text, truth: text) -> BackendTestEntry:
        var e = BackendTestEntry {
            arch: arch,
            test_name: name,
            category: "simulate",
            expected_result: "pass",
            actual_result: "",
            shared_truth_ref: truth
        }
        return e


class VerificationStage:
    stage_name: text
    is_generated_only: bool
    is_external_rtl: bool
    is_optional: bool
    passed: bool
    test_count: i32
    pass_count: i32

    me is_gate():
        return is_generated_only and is_optional == false

    me is_diagnostic():
        return is_external_rtl and is_optional

    me pass_rate():
        if test_count > 0:
            return (pass_count * 100) / test_count
        return 0

    me all_pass():
        return pass_count == test_count and test_count > 0

    static fn generated_gate(name: text, tests: i32) -> VerificationStage:
        var s = VerificationStage {
            stage_name: name,
            is_generated_only: true,
            is_external_rtl: false,
            is_optional: false,
            passed: false,
            test_count: tests,
            pass_count: 0
        }
        return s

    static fn external_diag(name: text, tests: i32) -> VerificationStage:
        var s = VerificationStage {
            stage_name: name,
            is_generated_only: false,
            is_external_rtl: true,
            is_optional: true,
            passed: false,
            test_count: tests,
            pass_count: 0
        }
        return s


class AcceptanceMatrix:
    rv32_compile: bool
    rv32_sim: bool
    rv32_synth: bool
    rv32_boot: bool
    rv64_compile: bool
    rv64_sim: bool
    rv64_synth: bool
    rv64_boot: bool

    me rv32_all_pass():
        return rv32_compile and rv32_sim and rv32_synth and rv32_boot

    me rv64_all_pass():
        return rv64_compile and rv64_sim and rv64_synth and rv64_boot

    me all_pass():
        return rv32_compile and rv32_sim and rv32_synth and rv32_boot and rv64_compile and rv64_sim and rv64_synth and rv64_boot

    me total_pass():
        var count = 0
        if rv32_compile:
            count = count + 1
        if rv32_sim:
            count = count + 1
        if rv32_synth:
            count = count + 1
        if rv32_boot:
            count = count + 1
        if rv64_compile:
            count = count + 1
        if rv64_sim:
            count = count + 1
        if rv64_synth:
            count = count + 1
        if rv64_boot:
            count = count + 1
        return count

    static fn empty() -> AcceptanceMatrix:
        var m = AcceptanceMatrix {
            rv32_compile: false,
            rv32_sim: false,
            rv32_synth: false,
            rv32_boot: false,
            rv64_compile: false,
            rv64_sim: false,
            rv64_synth: false,
            rv64_boot: false
        }
        return m

    static fn rv64_only() -> AcceptanceMatrix:
        var m = AcceptanceMatrix {
            rv32_compile: false,
            rv32_sim: false,
            rv32_synth: false,
            rv32_boot: false,
            rv64_compile: true,
            rv64_sim: true,
            rv64_synth: true,
            rv64_boot: true
        }
        return m

    static fn full_pass() -> AcceptanceMatrix:
        var m = AcceptanceMatrix {
            rv32_compile: true,
            rv32_sim: true,
            rv32_synth: true,
            rv32_boot: true,
            rv64_compile: true,
            rv64_sim: true,
            rv64_synth: true,
            rv64_boot: true
        }
        return m


class PromotionGate:
    matrix_pass: bool
    generated_pass: bool
    external_pass: bool
    blocker_count: i32
    blocker_0: text
    blocker_1: text

    me can_promote():
        return matrix_pass and generated_pass

    me has_blockers():
        return blocker_count > 0

    me first_blocker():
        if blocker_count > 0:
            return blocker_0
        return "none"

    static fn ready() -> PromotionGate:
        var g = PromotionGate {
            matrix_pass: true,
            generated_pass: true,
            external_pass: true,
            blocker_count: 0,
            blocker_0: "",
            blocker_1: ""
        }
        return g

    static fn blocked(reason: text) -> PromotionGate:
        var g = PromotionGate {
            matrix_pass: false,
            generated_pass: false,
            external_pass: false,
            blocker_count: 1,
            blocker_0: reason,
            blocker_1: ""
        }
        return g


fn main():
    print("backend_test_verify loaded")
