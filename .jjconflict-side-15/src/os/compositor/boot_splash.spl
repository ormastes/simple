#![allow(unnamed_duplicate_typed_args)]
# Boot Splash — Shared boot splash screen
#
# Renders a glassmorphism boot splash with logo, version, and progress bar.
# Shared between hosted (winit) and QEMU window managers.
# Uses only CompositorBackend + GlassPortConfig — no extra module imports
# to avoid interpreter module loading order issues.

use os.compositor.display_backend.{CompositorBackend}
use os.compositor.glass_port.{GlassPortConfig}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Boot Splash Screen
# ============================================================================

fn draw_boot_splash(backend: CompositorBackend, config: GlassPortConfig, platform_tag: text):
    """Draw a glassmorphism boot splash screen.

    Shows: gradient wallpaper, centered glass pill, "SimpleOS" heading,
    version string, progress bar, "Starting..." text, and platform tag.

    Uses only backend methods to avoid interpreter import issues.
    """
    val sw = backend.width()
    val sh = backend.height()

    # 1. Gradient wallpaper background
    cap_gradient_v(backend, 0, 0, sw, sh, 0xFF060508, 0xFF200840)
    # Vignette corners
    cap_blend_rect(backend, 0, 0, 100, 80, 0x00000000, 20)
    cap_blend_rect(backend, sw - 100, 0, 100, 80, 0x00000000, 20)
    cap_blend_rect(backend, 0, sh - 80, 100, 80, 0x00000000, 20)
    cap_blend_rect(backend, sw - 100, sh - 80, 100, 80, 0x00000000, 20)
    # Stars
    cap_blend_rect(backend, 150, 120, 4, 4, 0x00FFFFFF, 160)
    cap_blend_rect(backend, 700, 200, 4, 4, 0x00FFFFFF, 140)
    cap_blend_rect(backend, 850, 350, 4, 4, 0x00FFFFFF, 120)
    cap_blend_rect(backend, 400, 500, 4, 4, 0x00FFFFFF, 100)
    cap_blend_rect(backend, 950, 100, 4, 4, 0x00FFFFFF, 150)

    # 2. Centered glass pill container
    val pill_w: i32 = 320
    val pill_h: i32 = 160
    val pill_x = (sw - pill_w) / 2
    val pill_y = (sh - pill_h) / 2 - 20

    # Blur background behind pill
    cap_blur_region(backend, pill_x, pill_y, pill_w, pill_h, 16)
    cap_blur_region(backend, pill_x, pill_y, pill_w, pill_h, 8)

    # Glass surface with rounded corners (radius=28, matches QEMU)
    _splash_rrect(backend, pill_x, pill_y, pill_w, pill_h, config.surface_color, 28, config.surface_alpha)

    # Rounded border
    _splash_rrect(backend, pill_x, pill_y, pill_w, pill_h, config.border_color, 28, config.border_alpha)

    # Highlight lines
    cap_blend_rect(backend, pill_x + 4, pill_y + 1, pill_w - 8, 1, 0x00FFFFFF, 35)
    cap_blend_rect(backend, pill_x + 8, pill_y + 2, pill_w - 16, 1, 0x00FFFFFF, 15)

    # 3. "SimpleOS" heading (8x16 font, centered, with accent underline)
    val title_w: i32 = 64
    val title_x: i32 = pill_x + (pill_w - title_w) / 2
    val title_y = pill_y + 28
    # Shadow (offset +2, +2)
    backend.draw_text(title_x + 2, title_y + 2, "SimpleOS", 0x20000000, 0x00000000)
    # Bold effect (render at x and x+1)
    backend.draw_text(title_x, title_y, "SimpleOS", 0xFFFFFFFF, 0x00000000)
    backend.draw_text(title_x + 1, title_y, "SimpleOS", 0xFFFFFFFF, 0x00000000)
    cap_blend_rect(backend, title_x, title_y + 18, title_w, 2, config.accent_color, 200)

    # 4. Version string
    val ver_x: i32 = pill_x + (pill_w - 32) / 2
    val ver_y = title_y + 28
    backend.draw_text(ver_x, ver_y, "v1.0", 0xFFA0A0B0, 0x00000000)

    # 5. Progress bar
    val bar_w: i32 = pill_w - 60
    val bar_h: i32 = 8
    val bar_x = pill_x + 30
    val bar_y = ver_y + 28

    # Bar background (rounded)
    _splash_rrect(backend, bar_x, bar_y, bar_w, bar_h, 0x00FFFFFF, 4, 30)

    # Bar fill with gradient effect (left half accent, right half accent2)
    val fill_w = bar_w * 2 / 3
    val half_fill = fill_w / 2
    _splash_rrect(backend, bar_x + 2, bar_y + 2, half_fill, bar_h - 4, config.accent_color, 3, 200)
    cap_blend_rect(backend, bar_x + 2 + half_fill, bar_y + 2, fill_w - half_fill, bar_h - 4, config.accent2_color, 200)
    # Fill border
    _splash_rrect(backend, bar_x + 2, bar_y + 2, fill_w, bar_h - 4, 0x00FFFFFF, 3, 20)

    # 6. "Starting..." text
    val start_x: i32 = pill_x + (pill_w - 88) / 2
    val start_y = bar_y + 18
    backend.draw_text(start_x, start_y, "Starting...", 0xFF808890, 0x00000000)

    # 7. Platform tag (centered in pill)
    val tag_x: i32 = pill_x + 80
    val tag_y = pill_y + pill_h - 22
    backend.draw_text(tag_x, tag_y, platform_tag, 0xFF606070, 0x00000000)

    # 8. Bottom accent line
    cap_blend_rect(backend, pill_x + 20, pill_y + pill_h - 4, pill_w - 40, 1, config.accent_color, 60)

    # "Powered" tagline (below splash pill)
    val powered_x: i32 = pill_x + (pill_w - 56) / 2
    val powered_y = pill_y + pill_h + 40
    backend.draw_text(powered_x, powered_y, "Powered", 0xFFEBEBF5, 0x00000000)

    # Present the splash frame
    backend.present()

fn _splash_rrect(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32, color: u32, radius: i32, alpha: u8):
    """Inline rounded rect for boot splash (avoids import issues)."""
    val r = if radius > w / 2: w / 2 else: if radius > h / 2: h / 2 else: radius
    if r <= 0:
        cap_blend_rect(backend, x, y, w, h, color, alpha)
        return
    var row: i32 = 0
    while row < h:
        var inset: i32 = 0
        if row < r:
            val dy = r - row
            inset = r - _splash_isqrt(r * r - dy * dy)
        else if row >= h - r:
            val dy = row - (h - r - 1)
            inset = r - _splash_isqrt(r * r - dy * dy)
        val rx = x + inset
        val rw = w - inset * 2
        if rw > 0:
            cap_blend_rect(backend, rx, y + row, rw, 1, color, alpha)
        row = row + 1

fn _splash_isqrt(n: i32) -> i32:
    """Integer square root for boot splash."""
    if n <= 0: return 0
    if n == 1: return 1
    var x = n
    var y = (x + 1) / 2
    while y < x:
        x = y
        y = (x + n / x) / 2
    x
