extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]?

fn main() -> i64:
    val path = "/tmp/simple_gui_write_literal_probe.bin"
    val data: [u8] = [1u8, 2u8, 3u8, 255u8]
    print "WRITE_LITERAL before_len=" + data.len().to_text()
    if not rt_file_write_bytes(path, data):
        print "WRITE_LITERAL ok=false"
        return 1
    val reread = rt_file_read_bytes(path) ?? []
    print "WRITE_LITERAL ok=true len=" + reread.len().to_text()
    if reread.len() != 4:
        return 1
    0
