use std.spec


# ============================================================================
# Modern SSpec: capture helpers (planned, see FR-1..FR-6 in
# doc/02_requirements/feature/sspec_scenario_manual.md; glossary entry
# "SSpec (Modern SSpec)" in doc/glossary.md)
# ============================================================================
# - tui_grid          : FR-1 rendered terminal cell-grid golden capture
# - gui_image         : screenshot capture + image compare (exists today)
# - protocol_json     : FR-3 pretty-printed, golden-compared JSON traffic
# - protocol_binary   : FR-3 offset/hex/field table, golden-compared bytes
# - bit_table(8|16|32): FR-3 bit-aligned field table over a captured frame
# - statistics         : numeric/aggregate capture, golden-compared
# - user-registered kinds also supported via the same capture mechanism
#
# Example (planned):
# it "renders the login screen":
#     capture(tui_grid, "login_screen")


# ============================================================================
# Step Helpers
# ============================================================================
# Name helpers so underscores read as manual sentences.
# Docgen renders `user.open_editor()` as "User open editor".
# Use @step when the derived label is not clear enough.

@step "Open the application"
fn open_app():
    nil

@step "Configure with valid settings"
fn configure_with_valid_settings(config: text):
    nil

@step "Perform the main action"
fn perform_main_action() -> text:
    return ""

# Checker helpers start with Then_ so the manual reads naturally.

@step "Then the result is correct"
fn Then_result_is_correct(result: text, expected: text):
    expect(result).to_equal(expected)

@step "Then no errors are reported"
fn Then_no_errors():
    nil


# ============================================================================
# Primary Scenarios
# ============================================================================
# @manual_section: Getting Started
# (planned, FR-4 — groups scenarios into user-manual sections; today a comment
# convention, parsed by grep until the annotation is first-class)

describe "Feature Name":
    # @inline
    it "app is ready":
        open_app()
        configure_with_valid_settings("default")

    # @prev("app is ready")
    # @capture
    it "completes the primary workflow":
        val result = perform_main_action()
        Then_result_is_correct(result, "expected")

    # @prev("app is ready")
    it "handles the alternate path":
        val result = perform_main_action()
        Then_no_errors()


# ============================================================================
# Edge Cases
# ============================================================================

# @manual-file: folded
describe "Feature Name Edge Cases":
    # @manual: folded
    it "handles empty input gracefully":
        val result = perform_main_action()
        expect(result).to_equal("")

    # @manual: skip
    it "internal helper plumbing check":
        expect(1 + 1).to_equal(2)


