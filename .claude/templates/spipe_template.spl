use std.spipe.*


# ============================================================================
# Test Group 1: Basic Functionality
# ============================================================================

describe "FeatureName Basic Functionality":
    """
    ## Basic Usage

    Describe what this test group validates.
    Include expected behavior and key scenarios.
    """

    context "when condition X":
        """
        ### Scenario: Condition X Description

        Explain this specific scenario and what it tests.
        """

        it "does expected behavior":
            # Arrange
            val input = setup_input()

            # Act
            val result = perform_action(input)

            # Assert
            expect(result).to_equal(expected)

    context "when condition Y":
        """
        ### Scenario: Condition Y Description

        Explain this scenario.
        """

        it "handles edge case":
            val result = perform_edge_case()
            expect(result).to_equal(expected_edge_case)


# ============================================================================
# Test Group 2: Advanced Features
# ============================================================================

describe "FeatureName Advanced Features":
    """
    ## Advanced Usage

    Cover complex scenarios, error handling, integration with other features.
    """

    before_each:
        # Setup code that runs before each test
        @fixture = setup_fixture()

    after_each:
        # Cleanup code
        cleanup(@fixture)

    it "integrates with other features":
        val result = integrate_feature()
        expect(result).to_equal(expected_integration)

    it "returns an error result for invalid input":
        val result = risky_operation()
        expect(result.error?).to_equal(true)


