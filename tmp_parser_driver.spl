use compiler.core.parser.{parse_module, parser_error_count}

fn count_errors(src: text, label: text) -> i64:
    parse_module(src, "driver_snippet.spl")
    val n = parser_error_count()
    print("{label}: errors={n}")
    n

fn main():
    val plain = "fn f(o: Option<i64>) -> i64:\n    if val x = o:\n        return 1\n    else:\n        return 0\n"
    val ctor = "fn g(o: Option<i64>) -> i64:\n    if val Some(v) = o:\n        return v\n    else:\n        return -1\n"
    val ctor_no_else = "fn h(o: Option<i64>) -> i64:\n    var r = -9\n    if val Some(v) = o:\n        r = v\n    r\n"
    val bad = "fn b():\n    if val = :\n"

    val expr_plain = "fn p(o: Option<i64>) -> i64:\n    val r = if val x = o:\n        1\n    else:\n        0\n    r\n"
    val expr_ctor = "fn q(o: Option<i64>) -> i64:\n    val r = if val Some(v) = o:\n        v\n    else:\n        -1\n    r\n"

    count_errors(plain, "plain-ident if val")
    count_errors(ctor, "ctor-pattern if val Some(v)")
    count_errors(ctor_no_else, "ctor-pattern no-else")
    count_errors(expr_plain, "EXPR-position plain if val")
    count_errors(expr_ctor, "EXPR-position ctor if val Some(v)")
    count_errors(bad, "malformed (should error)")
    print("PARSER_DRIVER_DONE")
