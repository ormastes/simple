# Editor Settings GUI Spec
#
# Phase C: HTML-based settings panel in GUI shell.
# Text-grep verification — no compilation required.

use std.spec
use app.io.mod.{file_read_text}

fn read_text(path: text) -> text:
    file_read_text(path) ?? ""

describe "gui_render_settings_html — html output":

    it "function exists in gui_backend.spl":
        val src = read_text("src/lib/editor/70.backend/gui_backend.spl")
        expect(src.contains("fn gui_render_settings_html(view: SettingsViewState, config: EditorConfig) -> text")).to_equal(true)

    it "wraps output in settings-panel div":
        val src = read_text("src/lib/editor/70.backend/gui_backend.spl")
        expect(src.contains("settings-panel")).to_equal(true)

    it "includes search bar with settings-search class":
        val src = read_text("src/lib/editor/70.backend/gui_backend.spl")
        expect(src.contains("settings-search")).to_equal(true)

    it "renders checkbox for bool settings":
        val src = read_text("src/lib/editor/70.backend/gui_backend.spl")
        expect(src.contains("type=\\\"checkbox\\\"")).to_equal(true)

    it "renders number input for i64 settings":
        val src = read_text("src/lib/editor/70.backend/gui_backend.spl")
        expect(src.contains("type=\\\"number\\\"")).to_equal(true)

    it "renders select element for enum settings":
        val src = read_text("src/lib/editor/70.backend/gui_backend.spl")
        expect(src.contains("<select")).to_equal(true)

describe "gui_shell — settings integration":

    it "calls gui_render_settings_html when settings_view is active":
        val src = read_text("src/app/editor/gui_shell_render.spl")
        expect(src.contains("gui_render_settings_html")).to_equal(true)

    it "handles settings-change event":
        val src = read_text("src/app/editor/gui_shell_core.spl")
        expect(src.contains("settings-change")).to_equal(true)

    it "parses key and value from settings-change event data":
        val src = read_text("src/app/editor/gui_shell_core.spl")
        expect(src.contains("editor_config_set_by_key")).to_equal(true)
