use std.spec.{describe, it, assert_equal}
use std.common.encoding.protobuf_wire.{pb_text_to_bytes}

describe "Protobuf wire text encode guards":
    it "rejects characters outside byte range":
        val text_value = 256.chr()
        val result = pb_text_to_bytes(text_value)
        assert_equal(result.len(), 0)

    it "keeps empty text encoding":
        val result = pb_text_to_bytes("")
        assert_equal(result.len(), 0)
