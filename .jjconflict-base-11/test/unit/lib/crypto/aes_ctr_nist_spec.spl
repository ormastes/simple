# AES-CTR NIST SP 800-38A Appendix F.5 Test Vectors
#
# Tests aes_ctr_encrypt / aes_ctr_decrypt against the authoritative NIST
# SP 800-38A Appendix F.5 vectors for AES-128-CTR (F.5.1/F.5.2) and
# AES-256-CTR (F.5.5/F.5.6).
#
# Purpose: green baseline confirming CTR mode correctness for SSH
# aes128-ctr / aes256-ctr (RFC 4344) cipher support.
#
# Source: NIST SP 800-38A, Appendix F.5
#   https://csrc.nist.gov/publications/detail/sp/800-38a/final

use std.spec.*
use std.common.aes.modes.{aes_ctr_encrypt, aes_ctr_decrypt}

# ============================================================================
# Test data — module-level helpers to avoid it-block var-mutation footgun
# (see memory: feedback_it_block_var_mutation.md)
# ============================================================================

# AES-128-CTR key (16 bytes): 2b7e151628aed2a6abf7158809cf4f3c
fn _key_aes128() -> list:
    [0x2b, 0x7e, 0x15, 0x16, 0x28, 0xae, 0xd2, 0xa6,
     0xab, 0xf7, 0x15, 0x88, 0x09, 0xcf, 0x4f, 0x3c]

# AES-256-CTR key (32 bytes): 603deb1015ca71be2b73aef0857d7781...
fn _key_aes256() -> list:
    [0x60, 0x3d, 0xeb, 0x10, 0x15, 0xca, 0x71, 0xbe,
     0x2b, 0x73, 0xae, 0xf0, 0x85, 0x7d, 0x77, 0x81,
     0x1f, 0x35, 0x2c, 0x07, 0x3b, 0x61, 0x08, 0xd7,
     0x2d, 0x98, 0x10, 0xa3, 0x09, 0x14, 0xdf, 0xf4]

# Initial counter / IV (16 bytes): f0f1f2f3f4f5f6f7f8f9fafbfcfdfeff
fn _iv_f5() -> list:
    [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7,
     0xf8, 0xf9, 0xfa, 0xfb, 0xfc, 0xfd, 0xfe, 0xff]

# 64-byte plaintext (blocks 1-4 concatenated)
# Block 1: 6bc1bee22e409f96e93d7e117393172a
# Block 2: ae2d8a571e03ac9c9eb76fac45af8e51
# Block 3: 30c81c46a35ce411e5fbc1191a0a52ef
# Block 4: f69f2445df4f9b17ad2b417be66c3710
fn _plaintext_f5() -> list:
    [0x6b, 0xc1, 0xbe, 0xe2, 0x2e, 0x40, 0x9f, 0x96,
     0xe9, 0x3d, 0x7e, 0x11, 0x73, 0x93, 0x17, 0x2a,
     0xae, 0x2d, 0x8a, 0x57, 0x1e, 0x03, 0xac, 0x9c,
     0x9e, 0xb7, 0x6f, 0xac, 0x45, 0xaf, 0x8e, 0x51,
     0x30, 0xc8, 0x1c, 0x46, 0xa3, 0x5c, 0xe4, 0x11,
     0xe5, 0xfb, 0xc1, 0x19, 0x1a, 0x0a, 0x52, 0xef,
     0xf6, 0x9f, 0x24, 0x45, 0xdf, 0x4f, 0x9b, 0x17,
     0xad, 0x2b, 0x41, 0x7b, 0xe6, 0x6c, 0x37, 0x10]

# AES-128-CTR expected ciphertext (64 bytes)
# Block 1: 874d6191b620e3261bef6864990db6ce
# Block 2: 9806f66b7970fdff8617187bb9fffdff
# Block 3: 5ae4df3edbd5d35e5b4f09020db03eab
# Block 4: 1e031dda2fbe03d1792170a0f3009cee
fn _expected_ct_aes128() -> list:
    [0x87, 0x4d, 0x61, 0x91, 0xb6, 0x20, 0xe3, 0x26,
     0x1b, 0xef, 0x68, 0x64, 0x99, 0x0d, 0xb6, 0xce,
     0x98, 0x06, 0xf6, 0x6b, 0x79, 0x70, 0xfd, 0xff,
     0x86, 0x17, 0x18, 0x7b, 0xb9, 0xff, 0xfd, 0xff,
     0x5a, 0xe4, 0xdf, 0x3e, 0xdb, 0xd5, 0xd3, 0x5e,
     0x5b, 0x4f, 0x09, 0x02, 0x0d, 0xb0, 0x3e, 0xab,
     0x1e, 0x03, 0x1d, 0xda, 0x2f, 0xbe, 0x03, 0xd1,
     0x79, 0x21, 0x70, 0xa0, 0xf3, 0x00, 0x9c, 0xee]

# AES-256-CTR expected ciphertext (64 bytes)
# Block 1: 601ec313775789a5b7a7f504bbf3d228
# Block 2: f443e3ca4d62b59aca84e990cabf3622
# Block 3: e89c399ff0f198c6d40a31db156cabfe
# Block 4: ca84e9935a647eafad94da3a3df8a4b5 (note: NIST Appendix F.5.6)
fn _expected_ct_aes256() -> list:
    [0x60, 0x1e, 0xc3, 0x13, 0x77, 0x57, 0x89, 0xa5,
     0xb7, 0xa7, 0xf5, 0x04, 0xbb, 0xf3, 0xd2, 0x28,
     0xf4, 0x43, 0xe3, 0xca, 0x4d, 0x62, 0xb5, 0x9a,
     0xca, 0x84, 0xe9, 0x90, 0xca, 0xbf, 0x36, 0x22,
     0xe8, 0x9c, 0x39, 0x9f, 0xf0, 0xf1, 0x98, 0xc6,
     0xd4, 0x0a, 0x31, 0xdb, 0x15, 0x6c, 0xab, 0xfe,
     0xca, 0x84, 0xe9, 0x93, 0x5a, 0x64, 0x7e, 0xaf,
     0xad, 0x94, 0xda, 0x3a, 0x3d, 0xf8, 0xa4, 0xb5]

# ============================================================================
# Specs
# ============================================================================

describe "AES-CTR NIST SP 800-38A Appendix F.5 vectors":

    it "F.5.1 AES-128-CTR encrypts 4-block plaintext correctly":
        val ct = aes_ctr_encrypt(_plaintext_f5(), _key_aes128(), _iv_f5())
        expect(ct).to_equal(_expected_ct_aes128())

    it "F.5.2 AES-128-CTR decrypts back to plaintext":
        val pt = aes_ctr_decrypt(_expected_ct_aes128(), _key_aes128(), _iv_f5())
        expect(pt).to_equal(_plaintext_f5())

    it "F.5.5 AES-256-CTR encrypts 4-block plaintext correctly":
        val ct = aes_ctr_encrypt(_plaintext_f5(), _key_aes256(), _iv_f5())
        expect(ct).to_equal(_expected_ct_aes256())

    it "F.5.6 AES-256-CTR decrypts back to plaintext":
        val pt = aes_ctr_decrypt(_expected_ct_aes256(), _key_aes256(), _iv_f5())
        expect(pt).to_equal(_plaintext_f5())
