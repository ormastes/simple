use std.spipe.*
use os.crypto.curve25519_smalllimb.{
    x25519_smalllimb_roundtrip_probe,
    x25519_smalllimb_mask_probe
}

val U_TV1_PROBE: [u8] = [
    0xe6u8, 0xdbu8, 0x68u8, 0x67u8, 0x58u8, 0x30u8, 0x30u8, 0xdbu8,
    0x35u8, 0x94u8, 0xc1u8, 0xa4u8, 0x24u8, 0xb1u8, 0x5fu8, 0x7cu8,
    0x72u8, 0x66u8, 0x24u8, 0xecu8, 0x26u8, 0xb3u8, 0x35u8, 0x3bu8,
    0x10u8, 0xa9u8, 0x03u8, 0xa6u8, 0xd0u8, 0xabu8, 0x1cu8, 0x4cu8
]

describe "Curve25519 small-limb probes":
    it "round-trips a masked arbitrary u-coordinate":
        expect(x25519_smalllimb_roundtrip_probe(U_TV1_PROBE)).to_equal(x25519_smalllimb_mask_probe(U_TV1_PROBE))
