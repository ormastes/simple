use std.common.encoding.protobuf.{pb_encode_varint, pb_decode_field, pb_encode_fixed64, pb_encode_tag}

describe "impl smoke":
    it "encode varint 1":
        val enc = pb_encode_varint(1)
        expect(enc.len()).to_equal(1)
    it "decode field fixed64":
        var tb = pb_encode_tag(4, 1)
        var vb = pb_encode_fixed64(1000000000000)
        var out: [u8] = []
        var i = 0
        while i < tb.len():
            var bv: u8 = tb[i].to_i64().to_u8()
            out.push(bv)
            i = i + 1
        i = 0
        while i < vb.len():
            var bv: u8 = vb[i].to_i64().to_u8()
            out.push(bv)
            i = i + 1
        val r = pb_decode_field(out, 0)
        expect(r[2]).to_equal(1000000000000)
