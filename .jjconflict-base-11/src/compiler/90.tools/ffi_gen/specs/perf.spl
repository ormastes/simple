# Performance Measurement Module - FFI Spec
#
# Performance tracking operations for the Simple runtime.
# Generates build/rust/ffi_gen/src/perf.rs
#
# Usage: simple ffi-gen --gen-intern src/app/ffi_gen/specs/perf.spl

use app.ffi_gen.intern_codegen (InternFnSpec, InternParamSpec)

fn perf_specs() -> [InternFnSpec]:
    var specs: [InternFnSpec] = []

    # =========================================================================
    # Clock Primitives
    # =========================================================================

    specs.push(InternFnSpec(
        name: "rt_perf_clock_ns", category: "perf",
        params: [],
        return_type: "i64", runtime_fn: "rt_perf_clock_ns",
        doc: "Get monotonic nanoseconds since arbitrary baseline (~20ns overhead)"
    ))

    specs.push(InternFnSpec(
        name: "rt_perf_rdtsc", category: "perf",
        params: [],
        return_type: "i64", runtime_fn: "rt_perf_rdtsc",
        doc: "Get CPU cycle counter via rdtsc on x86 (~5ns), falls back to clock_ns"
    ))

    specs.push(InternFnSpec(
        name: "rt_perf_cycles_to_ns", category: "perf",
        params: [
            InternParamSpec(name: "cycles", value_type: "i64"),
            InternParamSpec(name: "freq_mhz", value_type: "i64")
        ],
        return_type: "i64", runtime_fn: "rt_perf_cycles_to_ns",
        doc: "Convert rdtsc cycles to nanoseconds given CPU frequency in MHz"
    ))

    # =========================================================================
    # Perf Control
    # =========================================================================

    specs.push(InternFnSpec(
        name: "rt_perf_enable", category: "perf",
        params: [],
        return_type: "void", runtime_fn: "rt_perf_enable",
        doc: "Enable performance tracking at runtime"
    ))

    specs.push(InternFnSpec(
        name: "rt_perf_enabled", category: "perf",
        params: [],
        return_type: "bool", runtime_fn: "rt_perf_enabled",
        doc: "Check if performance tracking is enabled"
    ))

    specs.push(InternFnSpec(
        name: "rt_perf_clear", category: "perf",
        params: [],
        return_type: "void", runtime_fn: "rt_perf_clear",
        doc: "Clear all performance data"
    ))

    # =========================================================================
    # Region Probes
    # =========================================================================

    specs.push(InternFnSpec(
        name: "rt_perf_region_enter", category: "perf",
        params: [
            InternParamSpec(name: "region_id", value_type: "i64"),
            InternParamSpec(name: "file", value_type: "String"),
            InternParamSpec(name: "line", value_type: "i64")
        ],
        return_type: "void", runtime_fn: "rt_perf_region_enter",
        doc: "Record entry into a performance region"
    ))

    specs.push(InternFnSpec(
        name: "rt_perf_region_exit", category: "perf",
        params: [
            InternParamSpec(name: "region_id", value_type: "i64"),
            InternParamSpec(name: "file", value_type: "String"),
            InternParamSpec(name: "line", value_type: "i64")
        ],
        return_type: "void", runtime_fn: "rt_perf_region_exit",
        doc: "Record exit from a performance region"
    ))

    # =========================================================================
    # Perf Output
    # =========================================================================

    specs.push(InternFnSpec(
        name: "rt_perf_dump_sdn", category: "perf",
        params: [],
        return_type: "String", runtime_fn: "rt_perf_dump_sdn",
        doc: "Dump perf data as SDN format string"
    ))

    specs.push(InternFnSpec(
        name: "rt_perf_free_sdn", category: "perf",
        params: [InternParamSpec(name: "ptr", value_type: "i64")],
        return_type: "void", runtime_fn: "rt_perf_free_sdn",
        doc: "Free SDN string returned by rt_perf_dump_sdn"
    ))

    specs
