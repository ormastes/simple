# brotli/decoder_tables.spl — Insert/copy length code tables and ICP decomposition.
# RFC 7932 §5 tables and _decompose_icp helper.

use std.common.compress.types.{CompressionError}

# Insert-length code base/extra tables (24 entries).
fn _insert_length_base(code: i64) -> i64:
    if code == 0: return 0
    if code == 1: return 1
    if code == 2: return 2
    if code == 3: return 3
    if code == 4: return 4
    if code == 5: return 5
    if code == 6: return 6
    if code == 7: return 8
    if code == 8: return 10
    if code == 9: return 14
    if code == 10: return 18
    if code == 11: return 26
    if code == 12: return 34
    if code == 13: return 50
    if code == 14: return 66
    if code == 15: return 98
    if code == 16: return 130
    if code == 17: return 194
    if code == 18: return 322
    if code == 19: return 578
    if code == 20: return 1090
    if code == 21: return 2114
    if code == 22: return 6210
    return 22594

fn _insert_length_extra(code: i64) -> i64:
    if code <= 5: return 0
    if code <= 7: return 1
    if code <= 9: return 2
    if code <= 11: return 3
    if code <= 13: return 4
    if code <= 15: return 5
    if code == 16: return 6
    if code == 17: return 7
    if code == 18: return 8
    if code == 19: return 9
    if code == 20: return 10
    if code == 21: return 12
    if code == 22: return 14
    return 24

# Copy-length code base/extra (RFC 7932 §5).
fn _copy_length_base(code: i64) -> i64:
    if code == 0: return 2
    if code == 1: return 3
    if code == 2: return 4
    if code == 3: return 5
    if code == 4: return 6
    if code == 5: return 7
    if code == 6: return 8
    if code == 7: return 9
    if code == 8: return 10
    if code == 9: return 12
    if code == 10: return 14
    if code == 11: return 18
    if code == 12: return 22
    if code == 13: return 30
    if code == 14: return 38
    if code == 15: return 54
    if code == 16: return 70
    if code == 17: return 102
    if code == 18: return 134
    if code == 19: return 198
    if code == 20: return 326
    if code == 21: return 582
    if code == 22: return 1094
    return 2118

fn _copy_length_extra(code: i64) -> i64:
    if code <= 7: return 0
    if code <= 8: return 1
    if code <= 9: return 1
    if code <= 11: return 2
    if code <= 13: return 3
    if code == 14: return 4
    if code == 15: return 4
    if code <= 17: return 5
    if code == 18: return 5
    if code == 19: return 6
    if code == 20: return 7
    if code == 21: return 8
    if code == 22: return 9
    return 10

# Decompose an ICP symbol into (insert_length_code, copy_length_code,
# has_distance_context).  RFC 7932 §5 / Table 4.
struct _IcpDecomp:
    ins_code: i64
    cop_code: i64
    has_distance: bool

fn _decompose_icp(sym: i64) -> _IcpDecomp:
    val kind = sym >> 6
    val low6 = sym & 0x3f
    val ilc6 = low6 & 0x07
    val clc6 = low6 >> 3
    var ins_kind = 0
    var cop_kind = 0
    var has_dist = false
    if kind == 0:
        ins_kind = 0
        cop_kind = 0
    elif kind == 1:
        ins_kind = 0
        cop_kind = 1
    elif kind == 2:
        ins_kind = 1
        cop_kind = 0
    elif kind == 3:
        ins_kind = 1
        cop_kind = 1
    elif kind == 4:
        ins_kind = 0
        cop_kind = 0
        has_dist = true
    elif kind == 5:
        ins_kind = 0
        cop_kind = 1
        has_dist = true
    elif kind == 6:
        ins_kind = 1
        cop_kind = 0
        has_dist = true
    elif kind == 7:
        ins_kind = 1
        cop_kind = 1
        has_dist = true
    elif kind == 8:
        ins_kind = 2
        cop_kind = 0
        has_dist = true
    elif kind == 9:
        ins_kind = 2
        cop_kind = 1
        has_dist = true
    else:
        # kind == 10
        ins_kind = 2
        cop_kind = 2
        has_dist = true
    val ins_code = (ins_kind * 8) + ilc6
    val cop_code = (cop_kind * 8) + clc6
    _IcpDecomp(ins_code: ins_code, cop_code: cop_code, has_distance: has_dist)
