#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.feature.gdb_pretty_printers.GdbPrettyPrinterManager
use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}

fn main():
    describe("GdbPrettyPrinterManager command builders"):
        it("builds enable pretty printing command"):
            val cmd = GdbPrettyPrinterManager.build_enable_pretty_printing_cmd()
            expect(cmd).to_equal("enable-pretty-printing")

        it("builds set pretty on command"):
            val cmd = GdbPrettyPrinterManager.build_set_pretty_on_cmd()
            expect(cmd).to_equal("set print pretty on")

        it("builds set pretty off command"):
            val cmd = GdbPrettyPrinterManager.build_set_pretty_off_cmd()
            expect(cmd).to_equal("set print pretty off")

        it("builds var evaluate command"):
            val cmd = GdbPrettyPrinterManager.build_var_eval_cmd("my_var")
            expect(cmd).to_equal("var-evaluate-expression my_var")

        it("builds var evaluate command with different name"):
            val cmd = GdbPrettyPrinterManager.build_var_eval_cmd("obj.field")
            expect(cmd).to_equal("var-evaluate-expression obj.field")

        it("enable command does not contain dash prefix"):
            val cmd = GdbPrettyPrinterManager.build_enable_pretty_printing_cmd()
            expect(cmd).to_start_with("enable")

    describe("FeatureId PrettyPrint variant"):
        it("has PrettyPrint"):
            expect(FeatureId.PrettyPrint.to_string()).to_equal("PrettyPrint")

        it("PrettyPrint is distinct from other features"):
            val pp = FeatureId.PrettyPrint.to_string()
            val rs = FeatureId.ReverseStep.to_string()
            expect(pp == rs).to_equal(false)

    describe("FeatureRank constants"):
        it("NATIVE rank is 0"):
            expect(FeatureRank.NATIVE()).to_equal(0)

        it("BRIDGE rank is 1"):
            expect(FeatureRank.BRIDGE()).to_equal(1)
