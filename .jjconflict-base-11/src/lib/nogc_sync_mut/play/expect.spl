# std.play.expect — Playwright-style expect() DSL with auto-retry
#
# Usage:
#   expect(win).to_have_title("My App")
#   expect(win.locator("#out")).to_have_text("clicked")
#
# Semantics: each matcher polls with DEFAULT_POLL_INTERVAL_MS until the
# assertion passes or DEFAULT_EXPECT_TIMEOUT_MS elapses. Throws (via
# PlayError) on failure.

use std.play.page.{Page}
use std.play.locator.{Locator}
use std.play.types.{
    PlayError, play_error, play_error_with_detail,
    ERR_ASSERTION, DEFAULT_EXPECT_TIMEOUT_MS, DEFAULT_POLL_INTERVAL_MS
}

extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# PageExpect — matchers that operate on a whole Page
# ============================================================================

class PageExpect:
    page: Page
    timeout_ms: i64

    me _deadline() -> i64:
        rt_time_now_unix_micros() + (self.timeout_ms * 1000)

    me to_have_title(expected: text) -> Result<(), PlayError>:
        val deadline = self._deadline()
        var last = ""
        while rt_time_now_unix_micros() < deadline:
            val t = self.page.title()?
            last = t
            if t == expected: return Ok(())
            if t.contains(expected): return Ok(())
        Err(play_error_with_detail(ERR_ASSERTION, "to_have_title failed: expected '" + expected + "', got '" + last + "'", ""))

    me to_have_url(expected: text) -> Result<(), PlayError>:
        val deadline = self._deadline()
        var last = ""
        while rt_time_now_unix_micros() < deadline:
            val u = self.page.url()?
            last = u
            if u.contains(expected): return Ok(())
        Err(play_error_with_detail(ERR_ASSERTION, "to_have_url failed: expected '" + expected + "', got '" + last + "'", ""))

# ============================================================================
# LocatorExpect — matchers that operate on a Locator
# ============================================================================

class LocatorExpect:
    locator: Locator
    timeout_ms: i64

    me _deadline() -> i64:
        rt_time_now_unix_micros() + (self.timeout_ms * 1000)

    me to_be_visible() -> Result<(), PlayError>:
        val deadline = self._deadline()
        while rt_time_now_unix_micros() < deadline:
            val v = self.locator.is_visible()?
            if v: return Ok(())
        Err(play_error(ERR_ASSERTION, "to_be_visible failed"))

    me to_be_hidden() -> Result<(), PlayError>:
        val deadline = self._deadline()
        while rt_time_now_unix_micros() < deadline:
            val v = self.locator.is_visible()?
            if not v: return Ok(())
        Err(play_error(ERR_ASSERTION, "to_be_hidden failed"))

    me to_have_text(expected: text) -> Result<(), PlayError>:
        val deadline = self._deadline()
        var last = ""
        while rt_time_now_unix_micros() < deadline:
            val tc = self.locator.text_content()?
            last = tc
            if tc == expected or tc.contains(expected):
                return Ok(())
        Err(play_error_with_detail(ERR_ASSERTION, "to_have_text failed: expected '" + expected + "', got '" + last + "'", ""))

    me to_contain_text(expected: text) -> Result<(), PlayError>:
        val deadline = self._deadline()
        var last = ""
        while rt_time_now_unix_micros() < deadline:
            val tc = self.locator.text_content()?
            last = tc
            if tc.contains(expected): return Ok(())
        Err(play_error_with_detail(ERR_ASSERTION, "to_contain_text failed: expected substring '" + expected + "', got '" + last + "'", ""))

    me to_have_count(expected: i64) -> Result<(), PlayError>:
        val deadline = self._deadline()
        var last: i64 = -1
        while rt_time_now_unix_micros() < deadline:
            val c = self.locator.count()?
            last = c
            if c == expected: return Ok(())
        Err(play_error(ERR_ASSERTION, "to_have_count failed: expected {expected}, got {last}"))

# ============================================================================
# Factory functions — these become `expect(...)` when re-exported from mod.spl
# ============================================================================

fn expect_page(page: Page) -> PageExpect:
    PageExpect(page: page, timeout_ms: DEFAULT_EXPECT_TIMEOUT_MS)

fn expect_locator(locator: Locator) -> LocatorExpect:
    LocatorExpect(locator: locator, timeout_ms: DEFAULT_EXPECT_TIMEOUT_MS)

fn expect_page_with(page: Page, timeout_ms: i64) -> PageExpect:
    PageExpect(page: page, timeout_ms: timeout_ms)

fn expect_locator_with(locator: Locator, timeout_ms: i64) -> LocatorExpect:
    LocatorExpect(locator: locator, timeout_ms: timeout_ms)
