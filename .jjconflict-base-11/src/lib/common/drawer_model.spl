# Drawer Model
#
# Keyboard-first launcher state for primary GUI applications.

struct DrawerItem:
    name: text
    category: text
    icon: text
    launch_path: text

struct DrawerModel:
    query: text
    selected_index: u64
    items: [DrawerItem]

fn drawer_item(name: text, category: text, icon: text, launch_path: text) -> DrawerItem:
    DrawerItem(name: name, category: category, icon: icon, launch_path: launch_path)

fn primary_drawer_items() -> [DrawerItem]:
    [
        drawer_item("Terminal", "System", "term", "/sys/apps/terminal"),
        drawer_item("Shell", "System", "shell", "/sys/apps/shell"),
        drawer_item("Markdown Editor", "Utilities", "edit", "/sys/apps/editor"),
        drawer_item("File Explorer", "Utilities", "folder", "/sys/apps/file_explorer"),
        drawer_item("Settings", "Settings", "settings", "/sys/apps/settings"),
        drawer_item("Drawer", "System", "drawer", "/sys/apps/drawer"),
        drawer_item("Minesweeper", "Games", "mine", "/sys/apps/minesweeper"),
        drawer_item("Web Browser", "Utilities", "browser", "/sys/apps/simple_browser"),
        drawer_item("PDF Viewer", "Utilities", "pdf", "/sys/apps/pdf_viewer")
    ]

fn drawer_model(items: [DrawerItem]) -> DrawerModel:
    DrawerModel(query: "", selected_index: 0, items: items)

fn primary_drawer_model() -> DrawerModel:
    drawer_model(primary_drawer_items())

fn drawer_set_query(model: DrawerModel, query: text) -> DrawerModel:
    DrawerModel(query: query, selected_index: 0, items: model.items)

fn drawer_visible_items(model: DrawerModel) -> [DrawerItem]:
    if model.query == "":
        return model.items
    var visible: [DrawerItem] = []
    val q = model.query.lower()
    for item in model.items:
        if item.name.lower().contains(q) or item.category.lower().contains(q):
            visible = visible.push(item)
    visible

fn drawer_select_next(model: DrawerModel) -> DrawerModel:
    val visible = drawer_visible_items(model)
    if visible.len() == 0:
        return DrawerModel(query: model.query, selected_index: 0, items: model.items)
    val next = if model.selected_index + 1 >= visible.len(): visible.len() - 1 else: model.selected_index + 1
    DrawerModel(query: model.query, selected_index: next, items: model.items)

fn drawer_select_prev(model: DrawerModel) -> DrawerModel:
    val next = if model.selected_index == 0: 0 else: model.selected_index - 1
    DrawerModel(query: model.query, selected_index: next, items: model.items)

fn drawer_selected_launch_path(model: DrawerModel) -> text:
    val visible = drawer_visible_items(model)
    if visible.len() == 0:
        return ""
    val index = if model.selected_index >= visible.len(): visible.len() - 1 else: model.selected_index
    visible[index].launch_path
