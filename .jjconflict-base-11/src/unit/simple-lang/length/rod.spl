# Unit: Rod
# Kind: Length
# Symbol: rod
# Canonical scale: 5.0292 m

class Rod:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Rod) -> Rod: Rod(value: self.value + other.value)
    fn sub(other: Rod) -> Rod: Rod(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "rod"
    static fn scale_to_base() -> f64: 5.0292
    static fn base_unit() -> text: "m"
    static fn zero() -> Rod: Rod(value: 0.0)

export Rod
