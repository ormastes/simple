# Unit: Jin
# Kind: Mass
# Symbol: jin
# Canonical scale: 0.5 kg

class Jin:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Jin) -> Jin: Jin(value: self.value + other.value)
    fn sub(other: Jin) -> Jin: Jin(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "jin"
    static fn scale_to_base() -> f64: 0.5
    static fn base_unit() -> text: "kg"
    static fn zero() -> Jin: Jin(value: 0.0)

export Jin
