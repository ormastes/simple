# SimpleOS serial-marker registry
#
# Canonical list of `[namespace] event` markers emitted via serial_println.
# Consumed by test harnesses (src/os/qemu_runner.spl) to verify boot progress.
#
# Each marker has a namespace (prefix) + event id + optional kv attributes.
# This module provides:
#   - constants for each marker (so kernel code does not stringly-type)
#   - a validator: validate(raw: text) -> Result<(), text>
#   - find_spec: find_spec(raw: text) -> MarkerSpec?

use std.text

enum MarkerNamespace:
    Boot          # [BOOT]
    DesktopE2E    # [desktop-e2e]
    Vfs           # [vfs]
    Pack          # [pack]
    NativeVerify  # [native-verify]
    Launcher      # [launcher]

struct MarkerSpec:
    namespace: MarkerNamespace
    event: text
    attrs_schema: [text]   # expected kv keys, or [] for unstructured
    description: text

# ---------------------------------------------------------------------------
# Namespace prefix constants
# ---------------------------------------------------------------------------

val NS_BOOT: text          = "[BOOT]"
val NS_DESKTOP_E2E: text   = "[desktop-e2e]"
val NS_VFS: text           = "[vfs]"
val NS_PACK: text          = "[pack]"
val NS_NATIVE_VERIFY: text = "[native-verify]"
val NS_LAUNCHER: text      = "[launcher]"

# ---------------------------------------------------------------------------
# Event constants — use these in kernel/app code instead of raw strings
# ---------------------------------------------------------------------------

val EVT_BOOT_ENTRY: text              = "entry"

val EVT_DE2E_SPL_START: text          = "spl_start"
val EVT_DE2E_BOOT: text               = "boot"
val EVT_DE2E_SHELL_READY: text        = "shell-ready"
val EVT_DE2E_LAUNCHER_READY: text     = "launcher-ready"
val EVT_DE2E_DESKTOP_READY: text      = "desktop-ready"
val EVT_DE2E_SHORTCUT_OK: text        = "shortcut:ok"
val EVT_DE2E_SHORTCUT_FAIL: text      = "shortcut:fail"
val EVT_DE2E_WM_OK: text              = "wm:ok"
val EVT_DE2E_WM_FAIL: text            = "wm:fail"
val EVT_DE2E_HELLO_SHORTCUT_OK: text  = "hello:shortcut:ok"
val EVT_DE2E_HELLO_SHORTCUT_FAIL: text = "hello:shortcut:fail"
val EVT_DE2E_LAUNCHER_READY2: text    = "launcher:ready"
val EVT_DE2E_LAUNCHER_FAIL: text      = "launcher:fail"
val EVT_DE2E_REMOTE_GROUPING_OK: text = "remote-grouping:ok"
val EVT_DE2E_PAINT_SETTLE_DONE: text  = "paint-settle:done"

val EVT_VFS_MOUNTED: text             = "mounted"
val EVT_VFS_MOUNT_FAILED: text        = "mount_failed"

val EVT_LAUNCHER_SPAWNED: text        = "spawned"

# ---------------------------------------------------------------------------
# Canonical registry — add entries here when adding new markers.
# ---------------------------------------------------------------------------

fn registry() -> [MarkerSpec]:
    [
        MarkerSpec(
            namespace: MarkerNamespace.Boot,
            event: EVT_BOOT_ENTRY,
            attrs_schema: [],
            description: "baremetal entry reached"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_SPL_START,
            attrs_schema: [],
            description: "desktop_e2e_entry::spl_start entered"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_BOOT,
            attrs_schema: [],
            description: "SYS-GUI-001 boot marker"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_SHELL_READY,
            attrs_schema: [],
            description: "SYS-GUI-001 shell ready"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_LAUNCHER_READY,
            attrs_schema: ["apps"],
            description: "SYS-GUI-001 launcher ready"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_DESKTOP_READY,
            attrs_schema: [],
            description: "SYS-GUI-001 desktop ready"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_SHORTCUT_OK,
            attrs_schema: ["key", "app"],
            description: "SYS-GUI-002 launcher shortcut dispatched"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_SHORTCUT_FAIL,
            attrs_schema: ["key"],
            description: "SYS-GUI-002 launcher shortcut failed"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_WM_OK,
            attrs_schema: ["pid", "app"],
            description: "SYS-GUI-002 wm saw the launch"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_WM_FAIL,
            attrs_schema: ["reason"],
            description: "SYS-GUI-002 wm launch failed"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_HELLO_SHORTCUT_OK,
            attrs_schema: [],
            description: "SYS-GUI-003 hello app shortcut ok"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_HELLO_SHORTCUT_FAIL,
            attrs_schema: [],
            description: "SYS-GUI-003 hello app shortcut failed"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_LAUNCHER_READY2,
            attrs_schema: [],
            description: "SYS-GUI-003 launcher ready (alt form)"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_LAUNCHER_FAIL,
            attrs_schema: [],
            description: "SYS-GUI-003 launcher failed"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_REMOTE_GROUPING_OK,
            attrs_schema: ["pid", "windows", "mode"],
            description: "SYS-GUI-004 multi-window join"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.DesktopE2E,
            event: EVT_DE2E_PAINT_SETTLE_DONE,
            attrs_schema: [],
            description: "SYS-GUI-005 paint settle complete"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.Vfs,
            event: EVT_VFS_MOUNTED,
            attrs_schema: ["device", "volume"],
            description: "SYS-GUI-007 FAT32 mounted"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.Vfs,
            event: EVT_VFS_MOUNT_FAILED,
            attrs_schema: ["reason"],
            description: "SYS-GUI-007 mount skipped/failed"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.Pack,
            event: "done",
            attrs_schema: [],
            description: "pack step complete"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.NativeVerify,
            event: "done",
            attrs_schema: [],
            description: "native-verify step complete"
        ),
        MarkerSpec(
            namespace: MarkerNamespace.Launcher,
            event: EVT_LAUNCHER_SPAWNED,
            attrs_schema: ["app_id"],
            description: "launcher spawned app"
        ),
        # Add new markers here...
    ]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn namespace_prefix(ns: MarkerNamespace) -> text:
    if ns == MarkerNamespace.Boot:
        "[BOOT]"
    else if ns == MarkerNamespace.DesktopE2E:
        "[desktop-e2e]"
    else if ns == MarkerNamespace.Vfs:
        "[vfs]"
    else if ns == MarkerNamespace.Pack:
        "[pack]"
    else if ns == MarkerNamespace.NativeVerify:
        "[native-verify]"
    else:
        "[launcher]"

fn marker_string(ns: MarkerNamespace, event: text) -> text:
    namespace_prefix(ns) + " " + event

# ---------------------------------------------------------------------------
# find_spec — parse `[namespace] event ...` from raw, lookup registry entry.
# Returns nil if the raw line does not match any registered marker.
# ---------------------------------------------------------------------------

fn find_spec(raw: text) -> MarkerSpec?:
    val specs = registry()
    var i: u64 = 0
    while i < specs.len():
        val spec = specs[i]
        val prefix = namespace_prefix(spec.namespace) + " " + spec.event
        if raw.starts_with(prefix):
            return spec
        i = i + 1
    nil

# ---------------------------------------------------------------------------
# validate — check a raw marker against registry + attrs_schema.
# Used by test harness to assert no unknown markers slip through.
# ---------------------------------------------------------------------------

fn validate(raw: text) -> Result<(), text>:
    val spec = find_spec(raw)
    if spec.is_nil():
        return Result.err("unknown marker: " + raw)
    Result.ok(())

# trailing newline
