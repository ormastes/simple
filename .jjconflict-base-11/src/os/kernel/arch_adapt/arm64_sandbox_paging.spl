# ARM64 sandbox paging adapter.
#
# Keeps arch-neutral boot hardening code from importing os.kernel.arch.arm64
# directly. Imports the CPU-intrinsic-free policy module (NOT
# os.kernel.arch.arm64.paging) so arch-neutral boot code does not drag
# os.kernel.arch.arm64.cpu (rt_arm64_*) into the riscv64 boot reachable set.
# See doc/08_tracking/bug/rv64_web_gate_arm64_import_leak_and_storage_2026-06-15.md.

use os.kernel.arch.arm64.sandbox_pte_bits.{arm64_sandbox_pte_bits_from_lowering as arch_arm64_sandbox_pte_bits_from_lowering}

fn arm64_sandbox_pte_bits_from_lowering(sandbox_lowering_sdn: text) -> [u64]:
    arch_arm64_sandbox_pte_bits_from_lowering(sandbox_lowering_sdn)
