# @feature simplebox.dispatch
# simplebox_dispatch — MDSOC+ busybox-style multi-call applet router.
# Self-contained: applet table is inline; no cross-module imports (avoids
# interpreter merge bugs).  Lane: .spipe/simpleos-alpine-harden-musl-busybox.

fn _applet_echo(args: [text]) -> i32:
    return 0

fn _applet_true(args: [text]) -> i32:
    return 0

fn _applet_false(args: [text]) -> i32:
    return 1

fn _applet_pwd(args: [text]) -> i32:
    return 0

fn _basename(path: text) -> text:
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash >= 0:
        path.slice(last_slash + 1, path.len())
    else:
        path

fn _run_applet(name: text, args: [text]) -> i32:
    if name == "echo":
        return _applet_echo(args)
    elif name == "true":
        return _applet_true(args)
    elif name == "false":
        return _applet_false(args)
    elif name == "pwd":
        return _applet_pwd(args)
    127

fn simplebox_applet_names() -> [text]:
    var names: [text] = []
    names.push("echo")
    names.push("true")
    names.push("false")
    names.push("pwd")
    names

fn simplebox_has_applet(name: text) -> bool:
    if name == "echo":
        return true
    elif name == "true":
        return true
    elif name == "false":
        return true
    elif name == "pwd":
        return true
    false

fn simplebox_dispatch(argv: [text]) -> i32:
    if argv.len() == 0:
        return 127
    val base = _basename(argv[0])
    var applet = base
    var arg_start = 1
    if base == "simplebox" or base == "busybox":
        if argv.len() < 2:
            return 127
        applet = argv[1]
        arg_start = 2
    if applet == "--list":
        return 0
    val applet_args = argv.slice(arg_start, argv.len())
    _run_applet(applet, applet_args)
