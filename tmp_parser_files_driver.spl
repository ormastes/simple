use compiler.core.parser.{parse_module}
use std.fs.{read_file}

fn check_file(path: text):
    val src = read_file(path)
    print("=== {path} len={src.len()}")
    parse_module(src, path)
    print("=== done {path}")

fn main():
    check_file("src/compiler/00.common/effects.spl")
    check_file("src/compiler/70.backend/backend/codegen_errors.spl")
    check_file("src/lib/nogc_async_mut_noalloc/replay/bm_checkpoint.spl")
    print("FILES_DRIVER_DONE")
