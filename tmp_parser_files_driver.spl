use compiler.core.parser.{parse_module}
use std.fs.{read_file}

fn check_file(path: text):
    val src = read_file(path)
    print("=== parsing {path}")
    parse_module(src, path)
    print("=== done {path}")

fn main():
    val sp = "/tmp/claude-1000/-home-ormastes-dev-pub-simple/33c947ae-e017-48b7-b5a6-08020378379a/scratchpad"
    check_file("{sp}/mini_effects.spl")
    check_file("{sp}/mini_codegen.spl")
    check_file("{sp}/mini_checkpoint.spl")
    print("FILES_DRIVER_DONE")
