use app.mcp_t32.json_helpers

fn main():
    val body = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"}"
    val search = "\"" + "method" + "\"" + ":"
    if body.len() == 46:
        print "len-ok"
    else:
        print "len-bad"
    if body.substring(24, 32) == "\"method\"":
        print "sub-ok"
    else:
        print "sub-bad"
    if t32_find_text(body, search) == 24:
        print "find-ok"
    else:
        print "find-bad"
    if t32_extract_field(body, "method") == "initialize":
        print "field-ok"
    else:
        print "field-bad"
        print t32_extract_field_raw(body, "method")
    if t32_extract_id(body) == "1":
        print "id-ok"
    else:
        print "id-bad"
