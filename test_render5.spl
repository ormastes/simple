use common.ui.parse.sdn.{parse_to_flat, render_entries, read_file}

fn main():
    val source = read_file("examples/ui/demo.ui.sdn")
    val entries = parse_to_flat(source)
    val result = render_entries(entries)
    match result:
        case Ok(html):
            print html
        case Err(e):
            print "Error: {e}"
