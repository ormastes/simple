fn s_starts(s: text, p: text) -> bool:
    s.starts_with(p)

fn s_find(s: text, n: text) -> i64:
    val idx = s.index_of(n)
    match idx:
        case Some(i):
            return i
        case _:
            return -1

fn s_len(s: text) -> i64:
    s.len()

fn tlist_len(l: [text]) -> i64:
    l.len()

fn flat_child_keys2(d: Dict<text, text>, prefix: text) -> [text]:
    var seen: Dict<text, bool> = {}
    var keys: [text] = []
    val plen = s_len(prefix)
    val dot_prefix = prefix + "."
    val all_keys = d.keys()
    var ki = 0
    val kcount = tlist_len(all_keys)

    while ki < kcount:
        val key = all_keys[ki]
        ki = ki + 1
        if s_starts(key, dot_prefix):
            val rest = key[plen + 1:]
            val dot_pos = s_find(rest, ".")
            var child_key = rest
            if dot_pos >= 0:
                child_key = rest[0:dot_pos]
            val already = seen.get(child_key)
            if already == nil:
                seen[child_key] = true
                keys = keys + [child_key]
    return keys

fn main():
    var d: Dict<text, text> = {}
    d["layout.children.menu.type"] = "menubar"
    d["layout.children.main.type"] = "hbox"
    d["layout.children.status.type"] = "statusbar"
    val result = flat_child_keys2(d, "layout.children")
    print "Result: {result}"
