#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
MODULE_DIR="${ROOT_DIR}/.spipe/spipe"

usage() {
  cat <<'USAGE'
Usage: sh scripts/setup-spipe-submodule.shs [--force] [--dry-run]

Initializes the .spipe/spipe submodule if needed, then delegates to the
platform-specific SPipe link setup script.

Unix/macOS:
  sh scripts/setup-spipe-submodule.shs

Windows PowerShell:
  powershell -ExecutionPolicy Bypass -File .spipe\spipe\scripts\setup-spipe-links.ps1
USAGE
}

case "${1:-}" in
  --help|-h)
    usage
    exit 0
    ;;
esac

if [ ! -d "${MODULE_DIR}/.git" ] && [ ! -f "${MODULE_DIR}/.git" ]; then
  git submodule update --init --recursive -- .spipe/spipe
fi

if [ -n "${OS:-}" ] && [ "${OS}" = "Windows_NT" ]; then
  if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -ExecutionPolicy Bypass -File "${MODULE_DIR}\\scripts\\setup-spipe-links.ps1" "$@"
  fi
  if command -v powershell >/dev/null 2>&1; then
    exec powershell -ExecutionPolicy Bypass -File "${MODULE_DIR}\\scripts\\setup-spipe-links.ps1" "$@"
  fi
  echo "setup-spipe-submodule: Windows detected but PowerShell was not found" >&2
  exit 127
fi

exec sh "${MODULE_DIR}/scripts/setup-spipe-links.sh" "$@"
