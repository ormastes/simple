# Magic numbers and resource limits for the Simple Browser Platform.
# Centralizes all tunable constants so they are easy to find and adjust.

# Tab and navigation limits
val MAX_TABS: i64 = 64
val MAX_HISTORY_ENTRIES: i64 = 1000

# Network limits
val MAX_CONNECTIONS_PER_HOST: i64 = 6
val MAX_TOTAL_CONNECTIONS: i64 = 64
val DEFAULT_TIMEOUT_MS: i64 = 30000

# GPU and rendering limits
val MAX_TEXTURE_SIZE: i64 = 4096
val TILE_SIZE: i64 = 256
val TARGET_FPS: i64 = 60
val FRAME_BUDGET_MS: f64 = 16.67

# Process limits
val MAX_RENDERER_PROCESSES: i64 = 32
val MAX_UTILITY_PROCESSES: i64 = 8

# Cache sizes
val DNS_CACHE_TTL_SECS: i64 = 300
val HTTP_CACHE_SIZE_MB: i64 = 256

# IPC limits
val MAX_IPC_MSG_SIZE: i64 = 65536
val IPC_QUEUE_DEPTH: i64 = 256
