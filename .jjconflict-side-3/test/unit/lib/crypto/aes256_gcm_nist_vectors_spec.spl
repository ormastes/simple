# --- TC16: same key/nonce as TC15, 60-byte PT (TC15 PT minus last 4), 20-byte AAD ---
# Tag:   76fc6ece0f4e1768cddf8853bb2d551b

fn _tc16_key() -> [u8]:
    [0xfeu8, 0xffu8, 0xe9u8, 0x92u8, 0x86u8, 0x65u8, 0x73u8, 0x1cu8,
     0x6du8, 0x6au8, 0x8fu8, 0x94u8, 0x67u8, 0x30u8, 0x83u8, 0x08u8,
     0xfeu8, 0xffu8, 0xe9u8, 0x92u8, 0x86u8, 0x65u8, 0x73u8, 0x1cu8,
     0x6du8, 0x6au8, 0x8fu8, 0x94u8, 0x67u8, 0x30u8, 0x83u8, 0x08u8]

fn _tc16_nonce() -> [u8]:
    [0xcau8, 0xfeu8, 0xbau8, 0xbeu8, 0xfau8, 0xceu8,
     0xdbu8, 0xadu8, 0xdeu8, 0xcau8, 0xf8u8, 0x88u8]

fn _tc16_plaintext() -> [u8]:
    [0xd9u8, 0x31u8, 0x32u8, 0x25u8, 0xf8u8, 0x84u8, 0x06u8, 0xe5u8,
     0xa5u8, 0x59u8, 0x09u8, 0xc5u8, 0xafu8, 0xf5u8, 0x26u8, 0x9au8,
     0x86u8, 0xa7u8, 0xa9u8, 0x53u8, 0x15u8, 0x34u8, 0xf7u8, 0xdau8,
