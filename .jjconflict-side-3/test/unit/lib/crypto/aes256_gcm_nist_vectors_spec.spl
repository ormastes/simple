     0xfeu8, 0xedu8, 0xfau8, 0xceu8, 0xdeu8, 0xadu8, 0xbeu8, 0xefu8,
     0xabu8, 0xadu8, 0xdau8, 0xd2u8]

fn _tc16_expected_ct() -> [u8]:
    [0x52u8, 0x2du8, 0xc1u8, 0xf0u8, 0x99u8, 0x56u8, 0x7du8, 0x07u8,
     0xf4u8, 0x7fu8, 0x37u8, 0xa3u8, 0x2au8, 0x84u8, 0x42u8, 0x7du8,
