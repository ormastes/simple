# AES-256-GCM NIST SP 800-38D Appendix B Test Vectors
#
# Tests aes256_gcm_encrypt / aes256_gcm_decrypt against the four AES-256
# test cases from NIST SP 800-38D Appendix B (TC13-TC16).
#
# TC13: all-zero 32-byte key, all-zero 12-byte IV, empty PT, empty AAD
# TC14: all-zero 32-byte key, all-zero 12-byte IV, 16-byte zero PT, empty AAD
# TC15: non-trivial key/IV, 64-byte PT, empty AAD
# TC16: same key/IV as TC15, 60-byte PT, 20-byte AAD
#
# Source: NIST SP 800-38D (Nov 2007), Appendix B
# Used by TLS_AES_256_GCM_SHA384 cipher suite (RFC 8446 0x1302).

use os.crypto.aes256_gcm.{aes256_gcm_encrypt, aes256_gcm_decrypt, Aes256GcmResult}

# ============================================================================
# Vector helpers — built at module level to avoid it-block var-mutation footgun
# (see memory: feedback_it_block_var_mutation.md)
# ============================================================================

# --- TC13: all-zero 32-byte key, all-zero IV, empty PT, empty AAD ---
# Key:   0000...0000 (32 bytes)
# Nonce: 000000000000000000000000
# PT:    (empty)
# AAD:   (empty)
# CT:    (empty)
# Tag:   530f8afbc74536b9a963b4f1c4cb738b

fn _tc13_key() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _tc13_nonce() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
     0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn _tc13_expected_tag() -> [u8]:
    [0x53u8, 0x0fu8, 0x8au8, 0xfbu8, 0xc7u8, 0x45u8, 0x36u8, 0xb9u8,
     0xa9u8, 0x63u8, 0xb4u8, 0xf1u8, 0xc4u8, 0xcbu8, 0x73u8, 0x8bu8]

