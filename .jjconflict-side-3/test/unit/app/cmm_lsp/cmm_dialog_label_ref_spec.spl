# CMM Dialog Label Reference spec — tests analyzer Pass 6 dialog label checking

# --- Helpers ---

fn dlr_find_pos(haystack: text, needle: text) -> i64:
    var i = 0
    while i < haystack.len():
        if i + needle.len() <= haystack.len():
            if haystack.substring(i, i + needle.len()) == needle:
                return i
        i = i + 1
    -1

fn dlr_find_pos_from(haystack: text, needle: text, start: i64) -> i64:
    var i = start
    while i < haystack.len():
        if i + needle.len() <= haystack.len():
            if haystack.substring(i, i + needle.len()) == needle:
                return i
        i = i + 1
    -1

fn dlr_find_colon(s: text) -> i64:
    var i = 0
    while i < s.len():
        if s.substring(i, i + 1) == ":":
            return i
        i = i + 1
    -1

fn dlr_dlr_list_has(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false

class DialogLabelDiag:
    message: text
    line_num: i64

fn dlr_collect_duplicate_labels(source: text) -> [text]:
    val labels = dlr_collect_labels(source)
    val lines = source.split("\n")
    var duplicates: [text] = []
    var in_dialog = false
    for line in lines:
        val trimmed = line.trim()
        val upper = trimmed.upper()
        if upper.starts_with("DIALOG"):
            in_dialog = true
            continue
        if trimmed == "(":
            continue
        if trimmed == ")":
            in_dialog = false
            continue
        if not in_dialog:
            continue
        val colon_pos = dlr_find_colon(trimmed)
        if colon_pos > 0:
            val maybe_label = trimmed.substring(0, colon_pos).trim()
            var seen = 0
            for label in labels:
                if label == maybe_label:
                    seen = seen + 1
            if seen > 0 and not dlr_list_has(duplicates, maybe_label):
                var count = 0
                for scan in lines:
                    if scan.trim().starts_with(maybe_label + ":"):
                        count = count + 1
                if count > 1:
                    duplicates.push(maybe_label)
    duplicates

fn dlr_collect_labels(source: text) -> [text]:
    val lines = source.split("\n")
    var labels: [text] = []
    var in_dialog = false
    for line in lines:
        val trimmed = line.trim()
        val upper = trimmed.upper()
        if upper.starts_with("DIALOG"):
            in_dialog = true
            continue
        if trimmed == "(":
            continue
        if trimmed == ")":
            in_dialog = false
            continue
        if not in_dialog:
            continue
        val colon_pos = dlr_find_colon(trimmed)
        if colon_pos > 0:
            val maybe_label = trimmed.substring(0, colon_pos).trim()
            val after = colon_pos + 1
            if after < trimmed.len():
                val rest = trimmed.substring(after, trimmed.len()).trim().upper()
                if rest.starts_with("EDIT"):
                    if not dlr_list_has(labels, maybe_label):
                        labels.push(maybe_label)
                if rest.starts_with("BUTTON"):
                    if not dlr_list_has(labels, maybe_label):
                        labels.push(maybe_label)
                if rest.starts_with("DEFBUTTON"):
                    if not dlr_list_has(labels, maybe_label):
                        labels.push(maybe_label)
                if rest.starts_with("CHECKBOX"):
                    if not dlr_list_has(labels, maybe_label):
                        labels.push(maybe_label)
                if rest.starts_with("CHOOSEBOX"):
                    if not dlr_list_has(labels, maybe_label):
                        labels.push(maybe_label)
                if rest.starts_with("PULLDOWN"):
                    if not dlr_list_has(labels, maybe_label):
                        labels.push(maybe_label)
    labels

fn dlr_check_refs(source: text, labels: [text]) -> [DialogLabelDiag]:
    val lines = source.split("\n")
    var diags: [DialogLabelDiag] = []
    var line_num: i64 = 1
    for line in lines:
        val trimmed = line.trim()
        val upper = trimmed.upper()
        var ref_label = ""
        # Check DIALOG.Set/Disable/Enable/EXECUTE <label>
        if upper.starts_with("DIALOG.SET "):
            ref_label = trimmed.substring(11, trimmed.len()).trim()
        elif upper.starts_with("DIALOG.DISABLE "):
            ref_label = trimmed.substring(15, trimmed.len()).trim()
        elif upper.starts_with("DIALOG.ENABLE "):
            ref_label = trimmed.substring(14, trimmed.len()).trim()
        elif upper.starts_with("DIALOG.EXECUTE "):
            ref_label = trimmed.substring(15, trimmed.len()).trim()
        # Check EVAL DIALOG.BOOLEAN(label) etc.
        if ref_label == "":
            val bool_pos = dlr_find_pos(upper, "DIALOG.BOOLEAN(")
            if bool_pos >= 0:
                val after = bool_pos + 15
                val end = dlr_find_pos_from(trimmed, ")", after)
                if end > after:
                    ref_label = trimmed.substring(after, end).trim()
            val str_pos = dlr_find_pos(upper, "DIALOG.STRING(")
            if ref_label == "" and str_pos >= 0:
                val after = str_pos + 14
                val end = dlr_find_pos_from(trimmed, ")", after)
                if end > after:
                    ref_label = trimmed.substring(after, end).trim()
            val exist_pos = dlr_find_pos(upper, "DIALOG.EXIST(")
            if ref_label == "" and exist_pos >= 0:
                val after = exist_pos + 13
                val end = dlr_find_pos_from(trimmed, ")", after)
                if end > after:
                    ref_label = trimmed.substring(after, end).trim()
            val val_pos = dlr_find_pos(upper, "DIALOG.VALUE(")
            if ref_label == "" and val_pos >= 0:
                val after = val_pos + 13
                val end = dlr_find_pos_from(trimmed, ")", after)
                if end > after:
                    ref_label = trimmed.substring(after, end).trim()
        if ref_label != "":
            if not ref_label.starts_with("&"):
                if not dlr_list_has(labels, ref_label):
                    diags.push(DialogLabelDiag(
                        message: "Dialog label '" + ref_label + "' not found in any DIALOG block",
                        line_num: line_num
                    ))
        line_num = line_num + 1
    diags

fn dlr_analyze_refs(source: text) -> [DialogLabelDiag]:
    val labels = dlr_collect_labels(source)
    dlr_check_refs(source, labels)

# --- Sample CMM sources ---

fn cmm_valid_refs() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  mycheck: CHECKBOX \"Enable\" \"\"\n"
    s = s + "  ok_btn: DEFBUTTON \"OK\" \"gosub ok\"\n"
    s = s + ")\n"
    s = s + "DIALOG.Set mycheck\n"
    s = s + "DIALOG.EXECUTE ok_btn"
    s

fn cmm_invalid_ref() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  mycheck: CHECKBOX \"Enable\" \"\"\n"
    s = s + ")\n"
    s = s + "DIALOG.Set nonexistent"
    s

fn cmm_macro_ref() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  mycheck: CHECKBOX \"Enable\" \"\"\n"
    s = s + ")\n"
    s = s + "DIALOG.Set &varname"
    s

fn cmm_no_dialog() -> text:
    "PRINT \"Hello\"\nENDDO"

fn cmm_multi_dialog() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  label_a: EDIT \"\" \"\"\n"
    s = s + ")\n"
    s = s + "DIALOG\n(\n"
    s = s + "  label_b: CHECKBOX \"B\" \"\"\n"
    s = s + ")\n"
    s = s + "DIALOG.Set label_a\n"
    s = s + "DIALOG.Set label_b"
    s

fn cmm_eval_invalid() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  mycheck: CHECKBOX \"Enable\" \"\"\n"
    s = s + ")\n"
    s = s + "EVAL DIALOG.BOOLEAN(missing_label)"
    s

fn cmm_duplicate_labels() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  same: EDIT \"\" \"\"\n"
    s = s + "  same: CHECKBOX \"A\" \"\"\n"
    s = s + ")"
    s

# --- SPipe tests ---

describe "CMM Dialog Label Reference Checking":
    context "valid references":
        it "produces no warnings for valid label refs":
            val diags = dlr_analyze_refs(cmm_valid_refs())
            expect(diags.len()).to_equal(0)

        it "accepts DIALOG.Set with declared label":
            val labels = dlr_collect_labels(cmm_valid_refs())
            val diags = dlr_check_refs("DIALOG.Set mycheck", labels)
            expect(diags.len()).to_equal(0)

        it "accepts DIALOG.EXECUTE with declared label":
            val labels = dlr_collect_labels(cmm_valid_refs())
            val diags = dlr_check_refs("DIALOG.EXECUTE ok_btn", labels)
            expect(diags.len()).to_equal(0)

    context "invalid references":
        it "warns on undeclared label in DIALOG.Set":
            val diags = dlr_analyze_refs(cmm_invalid_ref())
            expect(diags.len()).to_equal(1)
            expect(diags[0].message).to_contain("nonexistent")

        it "warns on undeclared label in EVAL DIALOG.BOOLEAN":
            val diags = dlr_analyze_refs(cmm_eval_invalid())
            expect(diags.len()).to_equal(1)
            expect(diags[0].message).to_contain("missing_label")

    context "macro references skipped":
        it "does not warn on macro reference":
            val diags = dlr_analyze_refs(cmm_macro_ref())
            expect(diags.len()).to_equal(0)

    context "no dialog blocks":
        it "produces no warnings when no DIALOG blocks exist":
            val diags = dlr_analyze_refs(cmm_no_dialog())
            expect(diags.len()).to_equal(0)

    context "multiple dialog blocks":
        it "collects labels from both blocks":
            val labels = dlr_collect_labels(cmm_multi_dialog())
            expect(labels.len()).to_equal(2)

        it "validates refs against labels from all blocks":
            val diags = dlr_analyze_refs(cmm_multi_dialog())
            expect(diags.len()).to_equal(0)

    context "label collection":
        it "collects edit labels":
            val labels = dlr_collect_labels("DIALOG\n(\n  myedit: EDIT \"\" \"\"\n)")
            expect(labels.len()).to_equal(1)

        it "collects checkbox labels":
            val labels = dlr_collect_labels("DIALOG\n(\n  mycb: CHECKBOX \"C\" \"\"\n)")
            expect(labels.len()).to_equal(1)

        it "does not collect HEADER as label":
            val labels = dlr_collect_labels("DIALOG\n(\n  HEADER \"Title\"\n)")
            expect(labels.len()).to_equal(0)

        it "does not collect TEXT as label":
            val labels = dlr_collect_labels("DIALOG\n(\n  TEXT \"Info\"\n)")
            expect(labels.len()).to_equal(0)

    context "duplicate labels":
        it "detects duplicate labels in a dialog block":
            val duplicates = dlr_collect_duplicate_labels(cmm_duplicate_labels())
            expect(duplicates).to_contain("same")
