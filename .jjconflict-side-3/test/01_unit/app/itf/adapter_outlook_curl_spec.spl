# Microsoft Graph (Outlook) curl-shellout Adapter Unit Tests
#
# Feature: Outlook curl adapter for SPipe Infra (#10 follow-up to #11)
# Category: ITF, Adapter, Outlook, Curl
# Status: Implemented
#
# Covers:
#   - client construction from a token
#   - URL builders (mailFolders collection / messages with filter+top)
#   - token-cache freshness window and render/parse roundtrip
#   - argv builders for the OAuth2 token POST and Graph GET
#   - error-label mapping for 401/403/404/429/500/0 and 2xx success window
#   - response status-tail parsing (curl -w newline + http_code output)
#
# All tests target pure helpers — NO subprocess execution.

use app.itf.adapter_outlook_curl.{
    OutlookCurlClient,
    outlook_curl_client_from_token,
    outlook_curl_token_cache_is_fresh,
    outlook_curl_render_token_cache,
    outlook_curl_parse_token_cache,
    _build_curl_argv_token,
    _build_curl_argv_get,
    _status_message,
    _status_ok,
    _split_response,
    _parse_status
}


fn _mk_client() -> OutlookCurlClient:
    outlook_curl_client_from_token("tk_abc", "ops@acme.com")


fn _list_contains(xs: [text], needle: text) -> bool:
    for x in xs:
        if x == needle:
            return true
    false


# ============================================================================
# Client construction
# ============================================================================

describe "outlook curl client":
    it "carries token and mailbox":
        val c = _mk_client()
        expect(c.access_token).to_equal("tk_abc")
        expect(c.mailbox_upn).to_equal("ops@acme.com")

    it "defaults to the v1.0 Graph base and curl binary":
        val c = _mk_client()
        expect(c.base_url).to_equal("https://graph.microsoft.com/v1.0")
        expect(c.curl_path).to_equal("curl")


# NOTE: URL builders (outlook_curl_folder_list_url / outlook_curl_messages_url)
# are not unit-tested here. They call `url_encode`
# (std.nogc_sync_mut.http_client.types -> nogc_sync_mut.http.url), whose module
# chain fails to load in the interpreter test runner with
# "Cannot resolve module: utilities", so any spec exercising them fails to
# execute. Tracked in
# doc/08_tracking/bug/interp_http_url_encode_utilities_unresolved_2026-06-14.md.


# ============================================================================
# Token cache freshness + roundtrip
# ============================================================================

describe "outlook token cache":
    it "is fresh only when expiry clears the safety margin":
        expect(outlook_curl_token_cache_is_fresh(1000, 900)).to_equal(true)
        expect(outlook_curl_token_cache_is_fresh(1000, 950)).to_equal(false)

    it "treats the exact margin boundary as not fresh":
        expect(outlook_curl_token_cache_is_fresh(1000, 940)).to_equal(false)

    it "renders and parses a token cache roundtrip":
        val rendered = outlook_curl_render_token_cache("tok_xyz", 1700000000)
        val (tok, exp) = outlook_curl_parse_token_cache(rendered)
        expect(tok).to_equal("tok_xyz")
        expect(exp).to_equal(1700000000)

    it "parses an empty cache to empty token":
        val (tok, exp) = outlook_curl_parse_token_cache("")
        expect(tok).to_equal("")
        expect(exp).to_equal(0)


# ============================================================================
# argv builders
# ============================================================================

describe "outlook argv builders":
    it "token POST uses POST verb and form content type":
        val args = _build_curl_argv_token("https://login/token", "grant_type=client_credentials")
        expect(_list_contains(args, "-X")).to_equal(true)
        expect(_list_contains(args, "POST")).to_equal(true)
        expect(_list_contains(args, "Content-Type: application/x-www-form-urlencoded")).to_equal(true)
        expect(_list_contains(args, "grant_type=client_credentials")).to_equal(true)
        expect(_list_contains(args, "https://login/token")).to_equal(true)

    it "Graph GET carries a Bearer authorization header and url":
        val args = _build_curl_argv_get("tok_abc", "https://graph/x")
        expect(_list_contains(args, "Authorization: Bearer tok_abc")).to_equal(true)
        expect(_list_contains(args, "https://graph/x")).to_equal(true)


# ============================================================================
# status helpers + error mapping
# ============================================================================

describe "outlook status mapping":
    it "treats 2xx as ok and others as not ok":
        expect(_status_ok(200)).to_equal(true)
        expect(_status_ok(299)).to_equal(true)
        expect(_status_ok(300)).to_equal(false)
        expect(_status_ok(401)).to_equal(false)

    it "maps auth, not-found, rate-limit, server, and transport errors":
        expect(_status_message(401, "")).to_equal("authentication required (HTTP 401)")
        expect(_status_message(403, "")).to_equal("authentication required (HTTP 403)")
        expect(_status_message(404, "")).to_equal("not found (HTTP 404)")
        expect(_status_message(429, "")).to_equal("rate limited (HTTP 429)")
        expect(_status_message(500, "boom")).to_equal("server error (HTTP 500): boom")
        expect(_status_message(0, "no route")).to_equal("transport error: no route")

    it "parses a numeric status tail and rejects non-numeric":
        expect(_parse_status("200")).to_equal(200)
        expect(_parse_status("  404 ")).to_equal(404)
        expect(_parse_status("abc")).to_equal(0)

    it "splits curl body from the trailing status line":
        val (body, code) = _split_response("hello world\n200")
        expect(body).to_equal("hello world")
        expect(code).to_equal(200)
