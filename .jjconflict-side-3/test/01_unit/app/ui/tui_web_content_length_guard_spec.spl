extern fn rt_file_read_text(path: text) -> text

describe "tui web content length guard":
    it "guards malformed content length parsing":
        val source = rt_file_read_text("src/app/ui.tui_web/server.spl") ?? ""

        expect(source).to_contain("content_length = trimmed_len.to_int() ?? 0")
        expect(source.contains("content_length = trimmed_len.to_int()\n")).to_equal(false)
