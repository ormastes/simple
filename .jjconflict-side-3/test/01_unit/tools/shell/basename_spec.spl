# Test: basename tool
# Feature: TOOL-BASENAME - Strip directory from path
# @cover tools/shell/basename/basename_tool.spl

describe "basename tool":
    context "path stripping":
        it "strips directory from path":
            val path = "/usr/local/bin/simple"
            # basename should return "simple"
            var last_slash = -1
            var i = 0
            for ch in path:
                if ch == "/":
                    last_slash = i
                i = i + 1
            val name = path.slice(last_slash + 1, path.len())
            expect(name).to_equal("simple")

        it "handles root path":
            val path = "/"
            expect(path).to_equal("/")

        it "handles no directory":
            val path = "file.txt"
            var last_slash = -1
            var i = 0
            for ch in path:
                if ch == "/":
                    last_slash = i
                i = i + 1
            val name = if last_slash >= 0: path.slice(last_slash + 1, path.len()) else: path
            expect(name).to_equal("file.txt")

    context "suffix stripping":
        it "strips suffix from filename":
            val name = "file.spl"
            val suffix = ".spl"
            val result = name.slice(0, name.len() - suffix.len())
            expect(result).to_equal("file")
