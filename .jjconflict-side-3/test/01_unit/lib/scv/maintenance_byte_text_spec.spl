use std.spec
use std.scv.maintenance.{scv_pack_bytes_line_m}

describe "scv maintenance byte text conversion":
    it "decodes pack lines without text.from_bytes":
        val payload = [101u8, 110u8, 116u8, 114u8, 121u8, 45u8, 100u8, 101u8, 108u8, 116u8, 97u8, 32u8, 99u8, 104u8, 117u8, 110u8, 107u8, 115u8, 13u8, 9u8, 255u8, 10u8]
        val (line, end) = scv_pack_bytes_line_m(payload, 0)
        expect(line).to_equal("entry-delta chunks\r\t?")
        expect(end).to_equal(21)
