use std.spec
use std.common.compress.types.{CompressionCodec, CompressionError}
use std.common.compress.utilities.{decompress_bytes}

fn check(condition: bool):
    expect condition == true

describe "Compression utility validation":
    it "rejects empty explicit gzip payloads":
        var data: [u8] = []
        val decoded = decompress_bytes(data, Some(CompressionCodec.gzip))
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.TruncatedInput(message):
                check(message.contains("gzip"))
            _:
                check(false)

    it "rejects empty explicit brotli payloads":
        var data: [u8] = []
        val decoded = decompress_bytes(data, Some(CompressionCodec.brotli))
        check(decoded.is_err())
        val err = decoded.unwrap_err()
        match err:
            CompressionError.TruncatedInput(message):
                check(message.contains("brotli"))
            _:
                check(false)
