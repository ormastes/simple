use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism}

extern fn rt_thread_sleep(ms: i64)
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_exit(code: i32)

fn blocker(delay_ms: i64, value: i64) -> i64:
    rt_thread_sleep(delay_ms)
    value

fn main() -> i64:
    multicore_green_set_parallelism(2)

    val h0 = multicore_green_spawn(\: blocker(150, 1))
    val h1 = multicore_green_spawn(\: blocker(150, 2))
    rt_thread_sleep(10)

    val start = rt_time_now_unix_micros()
    val quick = multicore_green_spawn(\: 7)
    rt_thread_sleep(30)

    val quick_done_while_blocked = quick.is_done()
    val waited_us = rt_time_now_unix_micros() - start
    println("quick_done_while_blocked={quick_done_while_blocked}")
    println("waited_us={waited_us}")

    val total = h0.join() + h1.join() + quick.join()
    println("total={total}")

    if total != 10:
        rt_exit(71)
    if !quick_done_while_blocked:
        rt_exit(72)
    0
