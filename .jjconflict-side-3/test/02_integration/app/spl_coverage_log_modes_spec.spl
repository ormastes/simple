use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_spl_coverage(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" SIMPLE_COVERAGE= \"$REPO/bin/simple\" run \"$REPO/src/app/spl_coverage/main.spl\" " + joined
    ])

describe "spl-coverage log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_spl_coverage(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for disabled status":
        val (out, err, code) = _run_spl_coverage(["--log-mode=json"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"spl-coverage\"")
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("\"enabled\":false")

    it "supports dot progress for missing command":
        val (out, err, code) = _run_spl_coverage(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Usage: simple spl-coverage")

    it "rejects invalid log mode":
        val (out, err, code) = _run_spl_coverage(["--log-mode=noisy", "status"])
        expect(code).to_equal(1)
