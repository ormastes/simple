# Editor TUI launcher entry.
#
# Dedicated native entry that builds an EditSession from file args and enters
# the terminal UI render loop (editor_tui_run). Kept narrow on purpose: it reads
# argv via the runtime extern instead of std.cli.cli_util so the linked surface
# stays small.

use std.editor.core.session.{EditSession}
use app.editor.editor_controller.{EditorController}
use app.editor.tui_shell.{editor_tui_run}

extern fn rt_cli_get_args() -> [text]

fn _editor_tui_file_args() -> [text]:
    var files: [text] = []
    val raw = rt_cli_get_args()
    var seen_editor = false
    for arg in raw:
        if not seen_editor:
            if arg == "editor" or arg == "tui":
                seen_editor = true
            continue
        if arg == "--gui" or arg == "--gui-sdl":
            continue
        if not arg.starts_with("-"):
            files.push(arg)
    files

fn main() -> i64:
    var session = EditSession.new()
    val files = _editor_tui_file_args()
    for path in files:
        session.open_file(path)
    if session.documents.len() == 0:
        session.open_empty()
    editor_tui_run(session)
    0
