# AC-10: native entry driving the SFM version-control layer.
#
# Reports status and records a commit through the VCS layer, printing OK/FAIL.
# Run: bin/simple run src/app/sfm_samples/vcs/main.spl

use app.sfm_samples.vcs.vcs_layer.{vcs_status, vcs_commit}

fn ok(cond: bool, label: text):
    if cond:
        print("OK " + label)
    else:
        print("FAIL " + label)

fn main():
    val status: text = vcs_status(".")
    ok(status.contains("branch"), "status -> " + status)
    val hash: text = vcs_commit(".", "initial commit")
    ok(hash.len() > 0, "commit -> " + hash)
