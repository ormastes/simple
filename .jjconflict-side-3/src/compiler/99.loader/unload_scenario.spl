use std.io_runtime

class UnloadScenario:
    path: text
    is_loaded: bool
    metadata_symbol_count: i32
    heuristic_symbol_count: i32
    global_symbol_count: i32

    static fn unknown_path(path: text) -> UnloadScenario:
        return UnloadScenario(
            path: path,
            is_loaded: false,
            metadata_symbol_count: 0,
            heuristic_symbol_count: 0,
            global_symbol_count: 0
        )

    static fn loaded_with_metadata(path: text, meta_count: i32, global_count: i32) -> UnloadScenario:
        return UnloadScenario(
            path: path,
            is_loaded: true,
            metadata_symbol_count: meta_count,
            heuristic_symbol_count: 0,
            global_symbol_count: global_count
        )

    static fn loaded_with_heuristic(path: text, heur_count: i32, global_count: i32) -> UnloadScenario:
        return UnloadScenario(
            path: path,
            is_loaded: true,
            metadata_symbol_count: 0,
            heuristic_symbol_count: heur_count,
            global_symbol_count: global_count
        )

    static fn loaded_with_both(path: text, meta_count: i32, heur_count: i32, global_count: i32) -> UnloadScenario:
        return UnloadScenario(
            path: path,
            is_loaded: true,
            metadata_symbol_count: meta_count,
            heuristic_symbol_count: heur_count,
            global_symbol_count: global_count
        )


class UnloadResult:
    path: text
    jit_removed: i32
    globals_removed: i32
    total_removed: i32
    used_metadata_path: bool
    used_heuristic_path: bool

    static fn noop(path: text) -> UnloadResult:
        return UnloadResult(
            path: path,
            jit_removed: 0,
            globals_removed: 0,
            total_removed: 0,
            used_metadata_path: false,
            used_heuristic_path: false
        )

    static fn from_metadata(path: text, jit: i32, globals: i32) -> UnloadResult:
        return UnloadResult(
            path: path,
            jit_removed: jit,
            globals_removed: globals,
            total_removed: jit + globals,
            used_metadata_path: true,
            used_heuristic_path: false
        )

    static fn from_heuristic(path: text, jit: i32, globals: i32) -> UnloadResult:
        return UnloadResult(
            path: path,
            jit_removed: jit,
            globals_removed: globals,
            total_removed: jit + globals,
            used_metadata_path: false,
            used_heuristic_path: true
        )

    static fn from_both(path: text, meta_jit: i32, heur_jit: i32, globals: i32) -> UnloadResult:
        return UnloadResult(
            path: path,
            jit_removed: meta_jit,
            globals_removed: globals,
            total_removed: meta_jit + globals,
            used_metadata_path: true,
            used_heuristic_path: true
        )

    me is_noop() -> bool:
        return self.total_removed == 0

    me metadata_was_primary() -> bool:
        return self.used_metadata_path


class ReloadScenario:
    path: text
    pre_unload_jit_count: i32
    post_unload_jit_count: i32
    post_reload_jit_count: i32
    persisted_count: i32

    static fn create(path: text, pre: i32, post_unload: i32, post_reload: i32, persisted: i32) -> ReloadScenario:
        return ReloadScenario(
            path: path,
            pre_unload_jit_count: pre,
            post_unload_jit_count: post_unload,
            post_reload_jit_count: post_reload,
            persisted_count: persisted
        )

    me reload_preserved_all() -> bool:
        return self.post_reload_jit_count >= self.pre_unload_jit_count

    me some_persisted() -> bool:
        return self.persisted_count > 0


class ScenarioVerdict:
    scenario_name: text
    passed: bool
    reason: text

    static fn pass_verdict(name: text, reason: text) -> ScenarioVerdict:
        return ScenarioVerdict(
            scenario_name: name,
            passed: true,
            reason: reason
        )

    static fn fail_verdict(name: text, reason: text) -> ScenarioVerdict:
        return ScenarioVerdict(
            scenario_name: name,
            passed: false,
            reason: reason
        )
