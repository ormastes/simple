# buffer.spl — Bounded scrollback ring buffer for smux pane capture.
#
# Holds up to 8 lines in a fixed-size ring. Older lines are evicted when full.
# No imports needed — pure value-type module.

class ScrollLine:
    text: text
    seq: int

    static fn create(t: text, s: int) -> ScrollLine:
        return ScrollLine(text: t, seq: s)


class ScrollbackBuffer:
    l0: ScrollLine
    l1: ScrollLine
    l2: ScrollLine
    l3: ScrollLine
    l4: ScrollLine
    l5: ScrollLine
    l6: ScrollLine
    l7: ScrollLine
    used: int
    head: int
    next_seq: int
    capacity: int

    me append(line: text) -> ScrollbackBuffer:
        val s = ScrollLine.create(line, me.next_seq)
        val slot = me.head
        var l0 = me.l0
        var l1 = me.l1
        var l2 = me.l2
        var l3 = me.l3
        var l4 = me.l4
        var l5 = me.l5
        var l6 = me.l6
        var l7 = me.l7
        if slot == 0:
            l0 = s
        if slot == 1:
            l1 = s
        if slot == 2:
            l2 = s
        if slot == 3:
            l3 = s
        if slot == 4:
            l4 = s
        if slot == 5:
            l5 = s
        if slot == 6:
            l6 = s
        if slot == 7:
            l7 = s
        val new_head = (me.head + 1) % me.capacity
        val new_used = if me.used < me.capacity: me.used + 1 else: me.used
        return ScrollbackBuffer(
            l0: l0, l1: l1, l2: l2, l3: l3,
            l4: l4, l5: l5, l6: l6, l7: l7,
            used: new_used,
            head: new_head,
            next_seq: me.next_seq + 1,
            capacity: me.capacity
        )

    me get(idx: int) -> text:
        # idx=0 is oldest retained line
        val start = if me.used < me.capacity: 0 else: me.head
        val slot = (start + idx) % me.capacity
        if slot == 0:
            return me.l0.text
        if slot == 1:
            return me.l1.text
        if slot == 2:
            return me.l2.text
        if slot == 3:
            return me.l3.text
        if slot == 4:
            return me.l4.text
        if slot == 5:
            return me.l5.text
        if slot == 6:
            return me.l6.text
        if slot == 7:
            return me.l7.text
        return ""

    me capture(max_lines: int) -> text:
        var result = ""
        var i = 0
        val limit = if max_lines < me.used: max_lines else: me.used
        while i < limit:
            val line = me.get(i)
            if line != "":
                if result == "":
                    result = line
                else:
                    result = result + "\n" + line
            i = i + 1
        return result

    me line_count() -> int:
        return me.used

    me clear() -> ScrollbackBuffer:
        val empty = ScrollLine.create("", 0)
        return ScrollbackBuffer(
            l0: empty, l1: empty, l2: empty, l3: empty,
            l4: empty, l5: empty, l6: empty, l7: empty,
            used: 0, head: 0, next_seq: 0, capacity: me.capacity
        )

    static fn create() -> ScrollbackBuffer:
        val empty = ScrollLine.create("", 0)
        return ScrollbackBuffer(
            l0: empty, l1: empty, l2: empty, l3: empty,
            l4: empty, l5: empty, l6: empty, l7: empty,
            used: 0, head: 0, next_seq: 0, capacity: 8
        )
