"""
SOSIX queue notification stubs — scheduler-aware wakeup placeholders.

When the scheduler gains blocking-wait support, these stubs will issue the
corresponding kernel syscalls (IDs 120-131) to wake waiters on send/recv
readiness rather than busy-polling.
"""

# Syscall IDs 120-131 for dataset/queue kernel managers (Follow-Up Slice).
val SOSIX_SYS_DATASET_CREATE: u64 = 120
val SOSIX_SYS_DATASET_WRITE: u64 = 121
val SOSIX_SYS_DATASET_SEAL: u64 = 122
val SOSIX_SYS_DATASET_READ: u64 = 123
val SOSIX_SYS_DATASET_CLOSE: u64 = 124
val SOSIX_SYS_QUEUE_CREATE: u64 = 125
val SOSIX_SYS_QUEUE_SEND: u64 = 126
val SOSIX_SYS_QUEUE_RECV: u64 = 127
val SOSIX_SYS_QUEUE_POLL: u64 = 128
val SOSIX_SYS_QUEUE_CLOSE: u64 = 129
val SOSIX_SYS_QUEUE_WAIT_RECV: u64 = 130
val SOSIX_SYS_QUEUE_WAIT_SEND: u64 = 131

fn sosix_queue_notify_recv(queue_id: u64):
    """Stub: notify the scheduler that queue_id has a message ready for receive."""
    val _ignored = queue_id

fn sosix_queue_notify_send(queue_id: u64):
    """Stub: notify the scheduler that queue_id has a free slot ready for send."""
    val _ignored = queue_id

fn sosix_queue_wait_recv(queue_id: u64) -> i64:
    """Stub: block caller until queue_id becomes readable (returns 0 on success)."""
    val _ignored = queue_id
    0

fn sosix_queue_wait_send(queue_id: u64) -> i64:
    """Stub: block caller until queue_id has a free slot (returns 0 on success)."""
    val _ignored = queue_id
    0
