# AArch64 CPU Primitives — TPIDR System Register Access
#
# Provides low-level CPU operations for AArch64 (Cortex-A) only.
# Cortex-M has no TPIDR convention — do not use this file for Cortex-M targets.
#
# TPIDR registers:
#   TPIDR_EL1 — kernel per-CPU base pointer (EL1/supervisor, analogous to RISC-V tp)
#   TPIDR_EL0 — userspace thread pointer (EL0/user; NOT the per-CPU base in EL1)
#
# AArch64 system registers are NOT part of the x0-x30 GPR file.
# They survive exception entry by design and do NOT need trap-frame save/restore.
#
# Asm conventions:
#   mrs {out}, <sysreg>   — read system register into GPR
#   msr <sysreg>, {in}    — write GPR into system register

# ============================================================================
# TPIDR_EL1 — Kernel Per-CPU Base Register
# ============================================================================

fn read_tpidr_el1() -> u64:
    """Read TPIDR_EL1 — kernel per-CPU base pointer (EL1 software thread ID register)."""
    var value: u64 = 0u64
    unsafe:
        asm volatile:
            "mrs {out}, tpidr_el1"
            out(reg) value
    value

fn write_tpidr_el1(val: u64):
    """Write TPIDR_EL1 — set the kernel per-CPU base pointer."""
    unsafe:
        asm volatile:
            "msr tpidr_el1, {in}"
            in(reg) val

# ============================================================================
# TPIDR_EL0 — Userspace Thread Pointer Register
# ============================================================================

fn read_tpidr_el0() -> u64:
    """Read TPIDR_EL0 — userspace thread pointer (EL0 software thread ID register).
    Note: this is the userspace TLS/thread-local base, NOT the kernel per-CPU pointer."""
    var value: u64 = 0u64
    unsafe:
        asm volatile:
            "mrs {out}, tpidr_el0"
            out(reg) value
    value

fn write_tpidr_el0(val: u64):
    """Write TPIDR_EL0 — set the userspace thread pointer."""
    unsafe:
        asm volatile:
            "msr tpidr_el0, {in}"
            in(reg) val
