# Bare-Metal Console Facade
#
# Shared stdout surface for examples and SimpleOS boot code. Policy is pure
# Simple; platform code remains behind semihost/UART primitives in syscall.spl.

use std.nogc_async_mut_noalloc.baremetal.console_policy.{
    BaremetalConsoleConfig,
    BAREMETAL_CONSOLE_NONE,
    BAREMETAL_CONSOLE_SEMIHOST,
    BAREMETAL_CONSOLE_UART,
    baremetal_console_choose
}
use std.nogc_async_mut_noalloc.baremetal.syscall.{semi_write_string, uart_write_string}

fn baremetal_console_default_qemu(prefer_semihost: bool) -> BaremetalConsoleConfig:
    baremetal_console_choose(prefer_semihost, true, 0x10000000u32)

fn baremetal_console_write(config: BaremetalConsoleConfig, message: text):
    if config.mode == BAREMETAL_CONSOLE_SEMIHOST:
        semi_write_string(message)
        return
    if config.mode == BAREMETAL_CONSOLE_UART:
        uart_write_string(config.uart_base, message)
        return
    pass

fn baremetal_console_writeln(config: BaremetalConsoleConfig, message: text):
    baremetal_console_write(config, message)
    if config.newline_crlf:
        baremetal_console_write(config, "\r\n")
    else:
        baremetal_console_write(config, "\n")
