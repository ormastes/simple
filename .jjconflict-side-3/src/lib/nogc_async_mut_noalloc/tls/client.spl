# TLS 1.3 Client — No-Alloc Baremetal Orchestrator
#
# Top-level TlsClient struct. Orchestrates the full TLS 1.3 handshake
# (ClientHello → ServerHello → EncryptedExtensions → Certificate →
#  CertificateVerify → server Finished → client Finished → App data)
# using only the no-alloc primitives in this package.
#
# Constraints:
#   - Single cipher suite: TLS_AES_128_GCM_SHA256
#   - Single key exchange: X25519
#   - No client certificates, no PSK, no 0-RTT, no HRR
#   - Certificate validation: compare SHA-256(DER) against embedded root CA hash
#   - Transport: pluggable BaremetalTransport trait
#
# Usage:
#   val cfg = TlsConfig(hostname: "example.com", root_ca_hash: my_hash)
#   var client = TlsClient.new(cfg, transport)
#   client.do_handshake()?
#   client.tls_send(data)?
#   val plain = client.tls_recv(buf)?

use src.lib.nogc_async_mut_noalloc.tls.types.{
    TlsState, TlsError, ContentType, content_type_from_byte,
    HASH_SIZE_SHA256, X25519_KEY_SIZE, TLS_RECORD_BUFFER_SIZE
}
use src.lib.nogc_async_mut_noalloc.tls.transport.{BaremetalTransport}
use src.lib.nogc_async_mut_noalloc.tls.transcript.{Transcript, transcript_new, transcript_add, transcript_hash}
use src.lib.nogc_async_mut_noalloc.tls.hkdf.{hkdf_expand_label}
use src.lib.nogc_async_mut_noalloc.tls.key_schedule.{
    Tls13Secrets, TrafficKeys,
    tls13_compute_handshake_secrets, tls13_compute_app_secrets,
    tls13_traffic_keys, tls13_finished_key, tls13_verify_data
}
use src.lib.nogc_async_mut_noalloc.tls.x25519.{x25519, x25519_pubkey}
use src.lib.nogc_async_mut_noalloc.tls.record.{RecordKey, RecordResult, record_encrypt, record_decrypt}
use src.lib.nogc_async_mut_noalloc.tls.handshake.{
    ParsedHandshake, ServerHello13,
    build_client_hello, parse_handshake_header, parse_server_hello,
    parse_finished_verify_data, build_finished,
    HS_SERVER_HELLO, HS_ENCRYPTED_EXTENSIONS,
    HS_CERTIFICATE, HS_CERTIFICATE_VERIFY, HS_FINISHED
}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_tls13_sha256(data: [u8]) -> [u8]

fn _cli_u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _cli_bytes_equal(a: [u8], b: [u8]) -> bool:
    """Constant-time byte array equality (same length required)."""
    if a.len() != b.len():
        return false
    var diff: u8 = 0x00
    var i: u64 = 0
    while i < a.len().to_u64():
        diff = diff | (_cli_u8_at(a, i) ^ _cli_u8_at(b, i))
        i = i + 1
    diff == 0

# ============================================================================
# TLS Client Configuration
# ============================================================================

class TlsConfig:
    """Configuration for no-alloc TLS 1.3 client.

    root_ca_hash: SHA-256 of the trusted root CA DER certificate.
    Set to 32 zero bytes to skip certificate validation (development only).
    """
    hostname: text
    root_ca_hash: [u8]   # 32 bytes — SHA-256 of expected root CA DER

fn tls_config_skip_verify(hostname: text) -> TlsConfig:
    """Create a config that skips certificate validation. FOR DEVELOPMENT ONLY."""
    var zero_hash: [u8] = []
    var i: u64 = 0
    while i < 32:
        zero_hash.push(0x00u8)
        i = i + 1
    TlsConfig(hostname: hostname, root_ca_hash: zero_hash)

# ============================================================================
# TLS Client State
# ============================================================================

class TlsClient:
    """No-alloc TLS 1.3 client. Holds all handshake and application state."""
    config: TlsConfig
    transport: BaremetalTransport
    state: TlsState

    # Ephemeral key pair for X25519
    privkey: [u8]    # 32 bytes — ephemeral private key
    pubkey: [u8]     # 32 bytes — ephemeral public key

    # Handshake transcript
    transcript: Transcript

    # Derived secrets
    secrets: Tls13Secrets

    # Application traffic keys (after handshake completes)
    client_write: RecordKey
    server_write: RecordKey

    # Sequence counters (per-direction)
    send_seq: u64
    recv_seq: u64

    # Receive buffer (fixed size: TLS_RECORD_BUFFER_SIZE bytes)
    recv_buf: [u8]
    recv_buf_len: u64

    static fn new(config: TlsConfig, transport: BaremetalTransport, privkey: [u8]) -> TlsClient:
        """Create a new TLS client with the given ephemeral private key.

        privkey: 32-byte random private key (caller supplies entropy).
        """
        val pubkey = x25519_pubkey(privkey)
        # Pre-allocate receive buffer
        var rb: [u8] = []
        var i: u64 = 0
        while i < TLS_RECORD_BUFFER_SIZE:
            rb.push(0x00u8)
            i = i + 1
        val empty: [u8] = []
        val empty_key = RecordKey(key: empty, iv: empty)
        val empty_secrets = Tls13Secrets(
            early_secret:       empty,
            handshake_secret:   empty,
            master_secret:      empty,
            client_hs_traffic:  empty,
            server_hs_traffic:  empty,
            client_app_traffic: empty,
            server_app_traffic: empty,
        )
        TlsClient(
            config: config,
            transport: transport,
            state: TlsState.Idle,
            privkey: privkey,
            pubkey: pubkey,
            transcript: transcript_new(),
            secrets: empty_secrets,
            client_write: empty_key,
            server_write: empty_key,
            send_seq: 0,
            recv_seq: 0,
            recv_buf: rb,
            recv_buf_len: 0,
        )

# ============================================================================
# Handshake Orchestrator
# ============================================================================

fn tls_do_handshake(client: TlsClient, client_random: [u8]) -> Result<TlsClient, TlsError>:
    """Perform the full TLS 1.3 client handshake.

    client_random: 32 bytes of random data (caller supplies entropy).
    Returns updated TlsClient on success, TlsError on failure.
    """
    # Step 1: Send ClientHello
    val ch_msg = build_client_hello(client.pubkey, client_random, client.config.hostname)
    val ch_record = _wrap_handshake_record(ch_msg)
    val send_result = client.transport.send(ch_record)
    match send_result:
        Result.Err(msg): return Result.Err(TlsError.TransportError(msg))
        Result.Ok(_): pass_dn

    # Add ClientHello to transcript
    var c = client
    c.transcript = transcript_add(c.transcript, ch_msg)
    c.state = TlsState.WaitServerHello

    # Step 2: Receive ServerHello (plaintext handshake record)
    val sh_raw = _recv_handshake_record(c.transport)
    match sh_raw:
        Result.Err(msg): return Result.Err(TlsError.TransportError(msg))
        Result.Ok(data: sh_record):
            # Parse the handshake header inside the record body
            val payload = _record_payload(sh_record)
            val sh_hs = parse_handshake_header(payload)
            if sh_hs.msg_type != HS_SERVER_HELLO:
                return Result.Err(TlsError.UnexpectedMessage)
            val sh = parse_server_hello(sh_hs.body)
            if sh.x25519_pub.len() != 32:
                return Result.Err(TlsError.HandshakeFailure("no x25519 key share in ServerHello"))
            if sh.cipher_suite != 0x1301:
                return Result.Err(TlsError.HandshakeFailure("unsupported cipher suite"))

            # Add ServerHello to transcript
            c.transcript = transcript_add(c.transcript, payload)
            c.state = TlsState.WaitEncryptedExtensions

            # Derive X25519 shared secret
            val shared = x25519(c.privkey, sh.x25519_pub)

            # Derive handshake secrets
            c.secrets = tls13_compute_handshake_secrets(shared, c.transcript)
            val c_hs_keys = tls13_traffic_keys(c.secrets.client_hs_traffic)
            val s_hs_keys = tls13_traffic_keys(c.secrets.server_hs_traffic)

            # Handshake read key = server_hs_traffic keys
            val hs_read_key = RecordKey(key: s_hs_keys.key, iv: s_hs_keys.iv)
            var hs_recv_seq: u64 = 0

            # Step 3: Receive EncryptedExtensions
            val ee_result = _recv_encrypted_record(c.transport, hs_read_key, hs_recv_seq)
            hs_recv_seq = hs_recv_seq + 1
            match ee_result:
                RecordResult.Err(msg): return Result.Err(TlsError.TransportError(msg))
                RecordResult.Ok(content_type: ee_ct, data: ee_plain, data_len: _):
                    if ee_ct != 0x16:
                        return Result.Err(TlsError.UnexpectedMessage)
                    val ee_hs = parse_handshake_header(ee_plain)
                    if ee_hs.msg_type != HS_ENCRYPTED_EXTENSIONS:
                        return Result.Err(TlsError.UnexpectedMessage)
                    c.transcript = transcript_add(c.transcript, ee_plain)

            # Step 4: Receive Certificate
            val cert_result = _recv_encrypted_record(c.transport, hs_read_key, hs_recv_seq)
            hs_recv_seq = hs_recv_seq + 1
            match cert_result:
                RecordResult.Err(msg): return Result.Err(TlsError.TransportError(msg))
                RecordResult.Ok(content_type: cert_ct, data: cert_plain, data_len: _):
                    if cert_ct != 0x16:
                        return Result.Err(TlsError.UnexpectedMessage)
                    val cert_hs = parse_handshake_header(cert_plain)
                    if cert_hs.msg_type != HS_CERTIFICATE:
                        return Result.Err(TlsError.UnexpectedMessage)
                    c.transcript = transcript_add(c.transcript, cert_plain)
                    # Certificate validation: check SHA-256 of DER against config
                    val cert_valid = _validate_certificate(cert_hs.body, c.config.root_ca_hash)
                    if not cert_valid:
                        return Result.Err(TlsError.CertificateRejected)

            # Step 5: Receive CertificateVerify
            val cv_result = _recv_encrypted_record(c.transport, hs_read_key, hs_recv_seq)
            hs_recv_seq = hs_recv_seq + 1
            match cv_result:
                RecordResult.Err(msg): return Result.Err(TlsError.TransportError(msg))
                RecordResult.Ok(content_type: cv_ct, data: cv_plain, data_len: _):
                    if cv_ct != 0x16:
                        return Result.Err(TlsError.UnexpectedMessage)
                    val cv_hs = parse_handshake_header(cv_plain)
                    if cv_hs.msg_type != HS_CERTIFICATE_VERIFY:
                        return Result.Err(TlsError.UnexpectedMessage)
                    c.transcript = transcript_add(c.transcript, cv_plain)

            # Step 6: Receive server Finished
            val sf_result = _recv_encrypted_record(c.transport, hs_read_key, hs_recv_seq)
            hs_recv_seq = hs_recv_seq + 1
            match sf_result:
                RecordResult.Err(msg): return Result.Err(TlsError.TransportError(msg))
                RecordResult.Ok(content_type: sf_ct, data: sf_plain, data_len: _):
                    if sf_ct != 0x16:
                        return Result.Err(TlsError.UnexpectedMessage)
                    val sf_hs = parse_handshake_header(sf_plain)
                    if sf_hs.msg_type != HS_FINISHED:
                        return Result.Err(TlsError.UnexpectedMessage)
                    # Verify server Finished MAC
                    val s_finished_key = tls13_finished_key(c.secrets.server_hs_traffic)
                    val expected_vd = tls13_verify_data(s_finished_key, transcript_hash(c.transcript))
                    val server_vd = parse_finished_verify_data(sf_hs.body)
                    if not _cli_bytes_equal(expected_vd, server_vd):
                        return Result.Err(TlsError.BadMac)
                    c.transcript = transcript_add(c.transcript, sf_plain)

            # Step 7: Derive application secrets (uses transcript through server Finished)
            c.secrets = tls13_compute_app_secrets(c.secrets, c.transcript)

            # Step 8: Send client Finished
            val c_finished_key = tls13_finished_key(c.secrets.client_hs_traffic)
            val c_verify_data = tls13_verify_data(c_finished_key, transcript_hash(c.transcript))
            val finished_msg = build_finished(c_verify_data)
            c.transcript = transcript_add(c.transcript, finished_msg)

            val c_hs_write = RecordKey(key: c_hs_keys.key, iv: c_hs_keys.iv)
            val finished_record = record_encrypt(c_hs_write, 0, 0x16u8, finished_msg)
            val f_send = client.transport.send(finished_record)
            match f_send:
                Result.Err(msg): return Result.Err(TlsError.TransportError(msg))
                Result.Ok(_): pass_dn

            # Step 9: Switch to application traffic keys
            val c_app_keys = tls13_traffic_keys(c.secrets.client_app_traffic)
            val s_app_keys = tls13_traffic_keys(c.secrets.server_app_traffic)
            c.client_write = RecordKey(key: c_app_keys.key, iv: c_app_keys.iv)
            c.server_write = RecordKey(key: s_app_keys.key, iv: s_app_keys.iv)
            c.send_seq = 0
            c.recv_seq = 0
            c.state = TlsState.Connected
            return Result.Ok(c)

    Result.Err(TlsError.Internal("unreachable"))

# ============================================================================
# Application Data Send / Recv
# ============================================================================

fn tls_send(client: TlsClient, data: [u8]) -> Result<TlsClient, TlsError>:
    """Encrypt and send application data over TLS."""
    if client.state != TlsState.Connected:
        return Result.Err(TlsError.Internal("not connected"))
    val record = record_encrypt(client.client_write, client.send_seq, 0x17u8, data)
    val result = client.transport.send(record)
    match result:
        Result.Err(msg): return Result.Err(TlsError.TransportError(msg))
        Result.Ok(_): pass_dn
    var c = client
    c.send_seq = c.send_seq + 1
    Result.Ok(c)

fn tls_recv(client: TlsClient) -> Result<(TlsClient, [u8]), TlsError>:
    """Receive and decrypt the next TLS application data record."""
    if client.state != TlsState.Connected:
        return Result.Err(TlsError.Internal("not connected"))
    val result = _recv_encrypted_record(client.transport, client.server_write, client.recv_seq)
    match result:
        RecordResult.Err(msg): return Result.Err(TlsError.TransportError(msg))
        RecordResult.Ok(content_type: ct, data: plain, data_len: _):
            if ct != 0x17:
                return Result.Err(TlsError.UnexpectedMessage)
            var c = client
            c.recv_seq = c.recv_seq + 1
            Result.Ok((c, plain))

# ============================================================================
# Internal Transport Helpers
# ============================================================================

fn _wrap_handshake_record(payload: [u8]) -> [u8]:
    """Wrap a plaintext handshake message in a TLS record (no encryption)."""
    val payload_len = payload.len().to_u64()
    var out: [u8] = []
    out.push(0x16u8)  # ContentType = Handshake
    out.push(0x03u8)  # legacy_version hi
    out.push(0x01u8)  # legacy_version lo (TLS 1.0 for compatibility)
    out.push(((payload_len >> 8) & 0xFF).to_u8())
    out.push((payload_len & 0xFF).to_u8())
    var i: u64 = 0
    while i < payload_len:
        out.push(_cli_u8_at(payload, i))
        i = i + 1
    out

fn _recv_handshake_record(transport: BaremetalTransport) -> Result<[u8], text>:
    """Receive a single plaintext TLS record from the transport."""
    # Read 5-byte header
    var header: [u8] = []
    var i: u64 = 0
    while i < 5:
        header.push(0x00u8)
        i = i + 1
    val hr = transport.recv(header, 5)
    match hr:
        Result.Err(msg): return Result.Err(msg)
        Result.Ok(n):
            if n < 5:
                return Result.Err("transport: short read on record header")

    val payload_len = (_cli_u8_at(header, 3).to_u64() << 8) | _cli_u8_at(header, 4).to_u64()
    var payload: [u8] = []
    i = 0
    while i < payload_len:
        payload.push(0x00u8)
        i = i + 1
    val pr = transport.recv(payload, payload_len.to_i64())
    match pr:
        Result.Err(msg): return Result.Err(msg)
        Result.Ok(n):
            if n.to_u64() < payload_len:
                return Result.Err("transport: short read on record payload")

    # Return header || payload
    var full: [u8] = []
    i = 0
    while i < 5:
        full.push(_cli_u8_at(header, i))
        i = i + 1
    i = 0
    while i < payload_len:
        full.push(_cli_u8_at(payload, i))
        i = i + 1
    Result.Ok(full)

fn _recv_encrypted_record(transport: BaremetalTransport, rk: RecordKey, seq: u64) -> RecordResult:
    """Receive and decrypt a TLS 1.3 encrypted record."""
    val raw = _recv_handshake_record(transport)
    match raw:
        Result.Err(msg): return RecordResult.Err(msg)
        Result.Ok(data: record_bytes):
            record_decrypt(rk, seq, record_bytes)

fn _record_payload(raw_record: [u8]) -> [u8]:
    """Extract payload bytes from a raw plaintext TLS record (skip 5-byte header)."""
    val raw_len = raw_record.len().to_u64()
    if raw_len < 5:
        return []
    val payload_len = (_cli_u8_at(raw_record, 3).to_u64() << 8) | _cli_u8_at(raw_record, 4).to_u64()
    var out: [u8] = []
    var i: u64 = 5
    while i < 5 + payload_len and i < raw_len:
        out.push(_cli_u8_at(raw_record, i))
        i = i + 1
    out

# ============================================================================
# Certificate Validation
# ============================================================================

fn _validate_certificate(cert_body: [u8], expected_root_hash: [u8]) -> bool:
    """Minimal certificate validation.

    Checks that the SHA-256 fingerprint of the leaf certificate DER matches
    the expected root CA hash configured in TlsConfig.

    If expected_root_hash is all zeros, skip validation (dev mode).
    Returns true if valid or validation skipped.
    """
    # Check for skip-verify (all zeros)
    var all_zero = true
    var i: u64 = 0
    while i < 32:
        if _cli_u8_at(expected_root_hash, i) != 0x00:
            all_zero = false
            break
        i = i + 1
    if all_zero:
        return true

    # Parse Certificate message body:
    # request_context_len(1) + request_context + cert_list_len(3) +
    #   [cert_data_len(3) + cert_data + extensions_len(2) + extensions]
    val body_len = cert_body.len().to_u64()
    if body_len < 4:
        return false

    val ctx_len = _cli_u8_at(cert_body, 0).to_u64()
    var offset: u64 = 1 + ctx_len
    if offset + 3 > body_len:
        return false

    # cert_list_len
    offset = offset + 3

    if offset + 3 > body_len:
        return false
    val cert_data_len = (_cli_u8_at(cert_body, offset).to_u64() << 16) |
                        (_cli_u8_at(cert_body, offset + 1).to_u64() << 8) |
                        _cli_u8_at(cert_body, offset + 2).to_u64()
    offset = offset + 3

    if offset + cert_data_len > body_len:
        return false

    # Hash the leaf certificate DER bytes
    var der: [u8] = []
    i = 0
    while i < cert_data_len:
        der.push(_cli_u8_at(cert_body, offset + i))
        i = i + 1

    val actual_hash = rt_tls13_sha256(der)
    _cli_bytes_equal(actual_hash, expected_root_hash)
