# TLS 1.3 Handshake Message Builders and Parsers — No-Alloc Baremetal
#
# Ported from src/os/tls13/handshake13.spl and handshake13_ext_builders.spl.
# Scope: minimal client-only, single cipher suite (AES-128-GCM-SHA256),
# single key exchange (X25519). No PSK, HRR, client certificates.
#
# Public functions:
#   build_client_hello(pubkey, random, hostname)       -> [u8]
#   parse_handshake_header(data)                       -> ParsedHandshake
#   parse_server_hello(body)                           -> ServerHello13
#   extract_x25519_server_pubkey(sh)                   -> [u8]  (32 bytes)
#   parse_finished(body)                               -> [u8]  (verify_data)
#
# Reference: RFC 8446

use src.lib.nogc_async_mut_noalloc.tls.types.{
    TLS_VERSION_1_2, TLS_VERSION_1_3,
    CIPHER_AES_128_GCM_SHA256, GROUP_X25519,
    EXT_SERVER_NAME, EXT_SUPPORTED_GROUPS, EXT_SIG_ALGS,
    EXT_KEY_SHARE, EXT_SUPPORTED_VERSIONS
}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_text_to_bytes(s: text) -> [u8]

fn _hs_u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _hs_u16_be(buf: [u8], offset: u64) -> u64:
    (_hs_u8_at(buf, offset).to_u64() << 8) | _hs_u8_at(buf, offset + 1).to_u64()

fn _hs_u24_be(buf: [u8], offset: u64) -> u64:
    (_hs_u8_at(buf, offset).to_u64() << 16) |
    (_hs_u8_at(buf, offset + 1).to_u64() << 8) |
    _hs_u8_at(buf, offset + 2).to_u64()

fn _hs_u32_be(buf: [u8], offset: u64) -> u64:
    (_hs_u8_at(buf, offset).to_u64() << 24) |
    (_hs_u8_at(buf, offset + 1).to_u64() << 16) |
    (_hs_u8_at(buf, offset + 2).to_u64() << 8) |
    _hs_u8_at(buf, offset + 3).to_u64()

fn _hs_append(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    var i: u64 = 0
    while i < src.len().to_u64():
        out.push(_hs_u8_at(src, i))
        i = i + 1
    out

fn _hs_push_u16_be(buf: [u8], v: u64) -> [u8]:
    buf.push(((v >> 8) & 0xFF).to_u8())
    buf.push((v & 0xFF).to_u8())
    buf

fn _hs_push_u24_be(buf: [u8], v: u64) -> [u8]:
    buf.push(((v >> 16) & 0xFF).to_u8())
    buf.push(((v >> 8) & 0xFF).to_u8())
    buf.push((v & 0xFF).to_u8())
    buf

fn _hs_copy_range(src: [u8], start: u64, count: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < count:
        out.push(_hs_u8_at(src, start + i))
        i = i + 1
    out

# ============================================================================
# Data Classes
# ============================================================================

class ParsedHandshake:
    """Raw parsed handshake envelope: type byte + body bytes."""
    msg_type: u8
    body: [u8]
    body_len: u64

class ServerHello13:
    """Decoded ServerHello fields for TLS 1.3 client."""
    random: [u8]
    cipher_suite: u16
    x25519_pub: [u8]   # 32 bytes or empty if not present

# ============================================================================
# Handshake Message Type Constants
# ============================================================================

val HS_CLIENT_HELLO: u8         = 1
val HS_SERVER_HELLO: u8         = 2
val HS_ENCRYPTED_EXTENSIONS: u8 = 8
val HS_CERTIFICATE: u8          = 11
val HS_CERTIFICATE_VERIFY: u8   = 15
val HS_FINISHED: u8             = 20

# ============================================================================
# Parser Helpers
# ============================================================================

fn parse_handshake_header(data: [u8]) -> ParsedHandshake:
    """Parse the 4-byte handshake envelope and return msg_type + body."""
    val data_len = data.len().to_u64()
    if data_len < 4:
        return ParsedHandshake(msg_type: 0u8, body: [], body_len: 0)
    val msg_type = _hs_u8_at(data, 0)
    val raw_body_len = _hs_u24_be(data, 1)
    val available = if data_len >= 4 { data_len - 4 } else { 0u64 }
    val body_len = if raw_body_len < available { raw_body_len } else { available }
    val body = _hs_copy_range(data, 4, body_len)
    ParsedHandshake(msg_type: msg_type, body: body, body_len: body_len)

fn parse_server_hello(data: [u8]) -> ServerHello13:
    """Parse a ServerHello body (after the 4-byte handshake header).

    Returns ServerHello13 with x25519_pub populated from key_share extension,
    or empty x25519_pub if not found.
    """
    val empty: [u8] = []
    val data_len = data.len().to_u64()
    if data_len < 38:
        return ServerHello13(random: empty, cipher_suite: 0u16, x25519_pub: empty)

    # Skip: legacy_version(2) + random(32) + session_id_len(1) + session_id(N)
    val random = _hs_copy_range(data, 2, 32)
    val session_id_len = _hs_u8_at(data, 34).to_u64()
    var offset: u64 = 35 + session_id_len

    if offset + 2 > data_len:
        return ServerHello13(random: random, cipher_suite: 0u16, x25519_pub: empty)
    val cipher_suite = _hs_u16_be(data, offset).to_u16()
    offset = offset + 2

    # Skip compression method (1 byte)
    offset = offset + 1

    if offset + 2 > data_len:
        return ServerHello13(random: random, cipher_suite: cipher_suite, x25519_pub: empty)
    val extensions_total_len = _hs_u16_be(data, offset)
    offset = offset + 2

    val extensions_end = offset + extensions_total_len
    var x25519_pub: [u8] = empty

    while offset + 4 <= extensions_end and offset + 4 <= data_len:
        val ext_type = _hs_u16_be(data, offset)
        offset = offset + 2
        val ext_len = _hs_u16_be(data, offset)
        offset = offset + 2
        if offset + ext_len > data_len:
            break
        if ext_type == EXT_KEY_SHARE.to_u64() and ext_len >= 4:
            val group = _hs_u16_be(data, offset)
            val key_len = _hs_u16_be(data, offset + 2)
            val key_start = offset + 4
            if group == GROUP_X25519.to_u64() and key_len == 32:
                x25519_pub = _hs_copy_range(data, key_start, 32)
        offset = offset + ext_len

    ServerHello13(random: random, cipher_suite: cipher_suite, x25519_pub: x25519_pub)

fn parse_finished_verify_data(body: [u8]) -> [u8]:
    """Extract verify_data from Finished message body (RFC 8446 §4.4.4)."""
    body

# ============================================================================
# ClientHello Builder (RFC 8446 §4.1.2)
# ============================================================================

fn build_client_hello(pubkey: [u8], client_random: [u8], hostname: text) -> [u8]:
    """Build a complete ClientHello handshake message (without record header).

    Single cipher suite: TLS_AES_128_GCM_SHA256 (0x1301)
    Single key share: X25519
    """
    var body: [u8] = []

    # legacy_version: TLS 1.2 (0x0303) — required by RFC 8446
    body.push(0x03u8)
    body.push(0x03u8)

    # random: 32 bytes
    var i: u64 = 0
    while i < 32:
        if i < client_random.len().to_u64():
            body.push(_hs_u8_at(client_random, i))
        else:
            body.push(0x00u8)
        i = i + 1

    # legacy_session_id: empty (length = 0)
    body.push(0x00u8)

    # cipher_suites: [TLS_AES_128_GCM_SHA256]
    body.push(0x00u8)  # length hi
    body.push(0x02u8)  # length lo (2 bytes = 1 suite)
    body.push(0x13u8)  # TLS_AES_128_GCM_SHA256 hi
    body.push(0x01u8)  # TLS_AES_128_GCM_SHA256 lo

    # compression_methods: [null]
    body.push(0x01u8)  # length
    body.push(0x00u8)  # null compression

    # Extensions
    val exts = _build_extensions(pubkey, hostname)
    val exts_len = exts.len().to_u64()
    body.push(((exts_len >> 8) & 0xFF).to_u8())
    body.push((exts_len & 0xFF).to_u8())
    body = _hs_append(body, exts)

    # Wrap in handshake header: type(1) || length(3)
    val body_len = body.len().to_u64()
    var msg: [u8] = []
    msg.push(HS_CLIENT_HELLO)
    msg = _hs_push_u24_be(msg, body_len)
    msg = _hs_append(msg, body)
    msg

fn _build_extensions(pubkey: [u8], hostname: text) -> [u8]:
    """Build the extensions block for ClientHello."""
    var exts: [u8] = []

    # supported_versions: TLS 1.3 (0x0304) only
    exts = _hs_push_u16_be(exts, EXT_SUPPORTED_VERSIONS.to_u64())  # type
    exts = _hs_push_u16_be(exts, 3)  # ext length
    exts.push(0x02u8)                 # list length
    exts.push(0x03u8)                 # TLS 1.3 hi
    exts.push(0x04u8)                 # TLS 1.3 lo

    # server_name (SNI)
    if hostname.len() > 0:
        val sni_data = _build_sni(hostname)
        exts = _hs_push_u16_be(exts, EXT_SERVER_NAME.to_u64())
        exts = _hs_push_u16_be(exts, sni_data.len().to_u64())
        exts = _hs_append(exts, sni_data)

    # supported_groups: x25519
    exts = _hs_push_u16_be(exts, EXT_SUPPORTED_GROUPS.to_u64())
    exts = _hs_push_u16_be(exts, 4)   # ext length
    exts = _hs_push_u16_be(exts, 2)   # list length
    exts = _hs_push_u16_be(exts, GROUP_X25519.to_u64())

    # signature_algorithms: ed25519 + ecdsa_secp256r1_sha256 + rsa_pss_rsae_sha256
    exts = _hs_push_u16_be(exts, EXT_SIG_ALGS.to_u64())
    exts = _hs_push_u16_be(exts, 8)    # ext length
    exts = _hs_push_u16_be(exts, 6)    # list length
    exts = _hs_push_u16_be(exts, 0x0807)  # ed25519
    exts = _hs_push_u16_be(exts, 0x0403)  # ecdsa_secp256r1_sha256
    exts = _hs_push_u16_be(exts, 0x0804)  # rsa_pss_rsae_sha256

    # key_share: x25519
    val ks_data = _build_key_share(pubkey)
    exts = _hs_push_u16_be(exts, EXT_KEY_SHARE.to_u64())
    exts = _hs_push_u16_be(exts, ks_data.len().to_u64())
    exts = _hs_append(exts, ks_data)

    exts

fn _build_sni(hostname: text) -> [u8]:
    """Build ServerNameList for the SNI extension."""
    val name_bytes = rt_text_to_bytes(hostname)
    val name_len = name_bytes.len().to_u64()
    # ServerNameList: list_len(2) + name_type(1) + name_len(2) + name
    var out: [u8] = []
    out = _hs_push_u16_be(out, name_len + 3)  # list length
    out.push(0x00u8)                            # name_type = host_name
    out = _hs_push_u16_be(out, name_len)
    out = _hs_append(out, name_bytes)
    out

fn _build_key_share(pubkey: [u8]) -> [u8]:
    """Build the key_share extension body for X25519."""
    # client_shares: list_len(2) + [group(2) + key_len(2) + key(32)]
    var out: [u8] = []
    out = _hs_push_u16_be(out, 36)    # list length: 2+2+32
    out = _hs_push_u16_be(out, GROUP_X25519.to_u64())
    out = _hs_push_u16_be(out, 32)    # key length
    var i: u64 = 0
    while i < 32:
        if i < pubkey.len().to_u64():
            out.push(_hs_u8_at(pubkey, i))
        else:
            out.push(0x00u8)
        i = i + 1
    out

# ============================================================================
# Finished Message Builder
# ============================================================================

fn build_finished(verify_data: [u8]) -> [u8]:
    """Build a Finished handshake message wrapping verify_data."""
    val vd_len = verify_data.len().to_u64()
    var msg: [u8] = []
    msg.push(HS_FINISHED)
    msg = _hs_push_u24_be(msg, vd_len)
    msg = _hs_append(msg, verify_data)
    msg
