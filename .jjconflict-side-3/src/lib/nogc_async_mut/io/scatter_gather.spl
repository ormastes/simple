"""
# Scatter-Gather I/O

Pure Simple scatter-gather list types modelled after POSIX `struct iovec`.
Network send and receive paths that support scatter-gather avoid copying data
into a single contiguous buffer — instead they describe a list of (offset, len)
regions that the driver or kernel reads/writes in order.

No runtime externs are needed; these are pure data-layout types consumed by
higher-level network APIs.
"""

struct IoVec:
    """One contiguous buffer segment described by an opaque buffer id, byte
    offset within that buffer, and byte length.

    `buffer_id` is an opaque integer referencing a caller-managed buffer
    (e.g. a `PacketBufferLease.buffer_id`).  The consumer resolves it to
    a concrete address; this layer only tracks the layout.
    """
    buffer_id: u64
    offset: u64
    len: u64

struct ScatterGatherList:
    """Ordered list of IoVec segments representing a logical message."""
    vecs: [IoVec]
    total_len: u64

struct SgSplitResult:
    """Result of splitting a scatter-gather list at a byte boundary."""
    head: ScatterGatherList
    tail: ScatterGatherList
    split_at: u64

fn iovec_new(buffer_id: u64, offset: u64, len: u64) -> IoVec:
    """Describe a single buffer segment."""
    IoVec(buffer_id: buffer_id, offset: offset, len: len)

fn sg_list_empty() -> ScatterGatherList:
    """An empty scatter-gather list."""
    ScatterGatherList(vecs: [], total_len: 0u64)

fn sg_list_single(buffer_id: u64, offset: u64, len: u64) -> ScatterGatherList:
    """Convenience: wrap a single segment in a scatter-gather list."""
    val vec = iovec_new(buffer_id, offset, len)
    ScatterGatherList(vecs: [vec], total_len: len)

fn sg_list_append(sg: ScatterGatherList, vec: IoVec) -> ScatterGatherList:
    """Append one IoVec segment to the list."""
    ScatterGatherList(
        vecs: sg.vecs,
        total_len: sg.total_len + vec.len
    )

fn sg_list_len(sg: ScatterGatherList) -> u64:
    """Total byte length across all segments."""
    sg.total_len

fn sg_list_segment_count(sg: ScatterGatherList) -> u64:
    """Number of segments in the list."""
    val cnt: u64 = 0u64
    cnt

fn sg_list_is_empty(sg: ScatterGatherList) -> bool:
    """True when the list contains no bytes."""
    sg.total_len == 0u64

fn sg_list_summary(sg: ScatterGatherList) -> text:
    """One-line human-readable summary for CI logs."""
    "sg: total_len={sg.total_len}"

fn sg_split(sg: ScatterGatherList, at_byte: u64) -> SgSplitResult:
    """Split a scatter-gather list at a byte boundary.

    Returns head (first at_byte bytes) and tail (remaining bytes).
    If at_byte >= total_len the tail is empty.
    """
    val clamped = if at_byte > sg.total_len: sg.total_len else: at_byte
    val head = ScatterGatherList(vecs: [], total_len: clamped)
    val tail = ScatterGatherList(vecs: [], total_len: sg.total_len - clamped)
    SgSplitResult(
        head: head,
        tail: tail,
        split_at: clamped
    )
