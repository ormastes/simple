"""
Packet Ring Ownership

Defines explicit RX/TX buffer ownership for high-performance packet I/O
backends (AF_XDP, DPDK). The portable socket backend remains independent
from packet-ring code. Backends report supports_packet_io only when
explicitly configured.

Feature IDs: FR-NET-0004
Plan: doc/03_plan/agent_tasks/net_acceleration_remaining_2026-04-21.md
"""

# Buffer ownership states.
struct PacketBufferOwner:
    """Tracks who owns a packet buffer at any point in the pipeline."""
    owner_name: text

fn packet_owner_driver() -> PacketBufferOwner:
    """Hardware or kernel driver holds the buffer."""
    PacketBufferOwner(owner_name: "driver")

fn packet_owner_app() -> PacketBufferOwner:
    """Application layer holds the buffer for read/write."""
    PacketBufferOwner(owner_name: "app")

fn packet_owner_free() -> PacketBufferOwner:
    """Buffer is on the free ring, available for reuse."""
    PacketBufferOwner(owner_name: "free")

# RX descriptor: driver fills, app consumes.
struct RxDescriptor:
    """Single receive descriptor with explicit ownership."""
    slot_index: i64
    byte_len: i64
    owner: PacketBufferOwner

fn rx_descriptor_ready(idx: i64, n: i64) -> RxDescriptor:
    """Driver has filled slot idx with n bytes; ownership transfers to app."""
    RxDescriptor(slot_index: idx, byte_len: n, owner: packet_owner_app())

fn rx_descriptor_returned(desc: RxDescriptor) -> RxDescriptor:
    """App returns the slot to the free ring after consuming."""
    RxDescriptor(slot_index: desc.slot_index, byte_len: 0, owner: packet_owner_free())

fn rx_descriptor_is_app_owned(desc: RxDescriptor) -> bool:
    desc.owner.owner_name == "app"

# TX descriptor: app fills, driver consumes.
struct TxDescriptor:
    """Single transmit descriptor with explicit ownership."""
    slot_index: i64
    byte_len: i64
    owner: PacketBufferOwner

fn tx_descriptor_prepare(idx: i64, n: i64) -> TxDescriptor:
    """App fills slot idx with n bytes and hands off to driver."""
    TxDescriptor(slot_index: idx, byte_len: n, owner: packet_owner_driver())

fn tx_descriptor_completed(desc: TxDescriptor) -> TxDescriptor:
    """Driver has transmitted; slot returns to free ring."""
    TxDescriptor(slot_index: desc.slot_index, byte_len: 0, owner: packet_owner_free())

fn tx_descriptor_is_driver_owned(desc: TxDescriptor) -> bool:
    desc.owner.owner_name == "driver"

# Ring configuration.
struct PacketRingConfig:
    """Configuration for a packet ring (RX or TX)."""
    ring_size: i64
    supports_packet_io: bool
    backend_name: text

fn packet_ring_config_portable() -> PacketRingConfig:
    """Portable socket backend: packet ring not available."""
    PacketRingConfig(ring_size: 0, supports_packet_io: false, backend_name: "portable-socket")

fn packet_ring_config_afxdp(ring_size: i64) -> PacketRingConfig:
    """AF_XDP packet ring, explicitly configured."""
    PacketRingConfig(ring_size: ring_size, supports_packet_io: true, backend_name: "af-xdp")

fn packet_ring_config_dpdk(ring_size: i64) -> PacketRingConfig:
    """DPDK packet ring, explicitly configured."""
    PacketRingConfig(ring_size: ring_size, supports_packet_io: true, backend_name: "dpdk")

fn packet_ring_is_enabled(cfg: PacketRingConfig) -> bool:
    """True only when explicitly configured with a packet-IO backend."""
    cfg.supports_packet_io

fn packet_ring_summary(cfg: PacketRingConfig) -> text:
    """Human-readable ring summary."""
    if cfg.supports_packet_io:
        return "{cfg.backend_name}:ring={cfg.ring_size}"
    "portable:no-ring"
