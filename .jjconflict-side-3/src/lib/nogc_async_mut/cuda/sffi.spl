"""
# No-GC Async CUDA SFFI

Compatibility facade over the no-GC sync CUDA SFFI backend. CUDA runtime calls
are synchronous backend operations; async-family CUDA layers reuse the shared
no-GC declaration owner instead of redeclaring hooks.
"""

export use std.nogc_sync_mut.cuda.sffi.{
    rt_cuda_available,
    rt_cuda_init, rt_cuda_device_count, rt_cuda_device_get,
    rt_cuda_device_name, rt_cuda_device_compute_capability,
    rt_cuda_ctx_create, rt_cuda_ctx_destroy, rt_cuda_ctx_synchronize,
    rt_cuda_mem_alloc, rt_cuda_mem_free,
    rt_cuda_memcpy_htod, rt_cuda_memcpy_dtoh, rt_cuda_memcpy_dtod,
    rt_cuda_memset, rt_cuda_f64_binary_op, rt_cuda_f64_sum,
    rt_cuda_f64_minmax, rt_cuda_f64_sum_axis, rt_cuda_f64_scalar_div,
    rt_cuda_f64_slice_1d, rt_cuda_f64_slice_2d,
    rt_cuda_module_load, rt_cuda_module_load_data, rt_cuda_module_unload,
    rt_cuda_module_get_function, rt_cuda_launch_kernel, rt_cuda_sync,
    rt_cuda_get_error_string
}
