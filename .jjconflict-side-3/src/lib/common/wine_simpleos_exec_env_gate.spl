# Wine SimpleOS Exec Env Gate - execution environment evidence for Wine on SimpleOS.

pub fn wine_simpleos_exec_env_required_evidence() -> [text]:
    [
        "simpleos-qemu-vm",
        "simpleos-full-os-boot",
        "simpleos-kernel-syscall-abi",
        "simpleos-kernel-scheduler",
        "simpleos-kernel-vfs-service",
        "simpleos-user-process",
        "simpleos-vmspace",
        "simpleos-window-server",
        "simpleos-vfs-mounted",
        "simpleos-network-smoke",
        "simpleos-container-namespace",
        "simpleos-container-pid-namespace",
        "simpleos-container-fs-namespace",
        "simpleos-container-ipc-namespace",
        "simpleos-container-net-namespace",
        "simpleos-container-capability-boundary",
        "simpleos-container-rootfs",
        "simpleos-container-rootfs-nvfs",
        "simpleos-mdsoc-capsule",
        "simpleos-mdsoc-public-port",
        "simpleos-mdsoc-resident-state-owner"
    ]

pub fn wine_simpleos_exec_env_gate(evidence: text) -> text:
    for required in wine_simpleos_exec_env_required_evidence():
        if not evidence.contains(required):
            return "missing-" + required
    "ready"

pub fn wine_simpleos_exec_env_fixture_evidence() -> text:
    wine_simpleos_exec_env_required_evidence().join(" ")

pub fn wine_simpleos_exec_env_fixture_serial_log() -> text:
    "QEMU x86_64 desktop lane\n" +
        "[phase-3-mount] fat32 ok\n" +
        "[kernel] syscall-abi:ok arch=x86_64\n" +
        "[kernel] scheduler:ok runqueue=user\n" +
        "[kernel] vfs-service:ok root=/\n" +
        "[vfs] mounted fat32 device=nvme0 volume=simpleos\n" +
        "[fs-exec] spawn:image path=/sys/apps/wine_hello entry=0 segments=1 stub_bytes=128 argv_count=1 env_count=0\n" +
        "[desktop-e2e] process-backed:ok app=wine_hello pid=42\n" +
        "[desktop-e2e] wm:ok pid=42 wid=1001\n" +
        "[desktop-e2e] network-smoke:bounded ok packets=1\n" +
        "[desktop-e2e] container-namespace:ok pid fs ipc net capability\n" +
        "[desktop-e2e] container-rootfs:ok rootfs=/containers/wine rootfs_backend=nvfs\n" +
        "[desktop-e2e] mdsoc-capsule:ok owner=process-container-wm\n" +
        "[desktop-e2e] mdsoc-public-port:ok facade=exec-env\n" +
        "[desktop-e2e] mdsoc-resident-state-owner:ok ecs=wm,process,container\n" +
        "TEST PASSED"

pub fn wine_simpleos_exec_env_evidence_from_serial_log(serial_log: text) -> text:
    var evidence: [text] = []
    if serial_log.contains("QEMU x86_64 desktop lane"):
        evidence.push("simpleos-qemu-vm")
    if serial_log.contains("[phase-3-mount] fat32 ok"):
        evidence.push("simpleos-full-os-boot")
    if serial_log.contains("[kernel] syscall-abi:ok"):
        evidence.push("simpleos-kernel-syscall-abi")
    if serial_log.contains("[kernel] scheduler:ok"):
        evidence.push("simpleos-kernel-scheduler")
    if serial_log.contains("[kernel] vfs-service:ok"):
        evidence.push("simpleos-kernel-vfs-service")
    if serial_log.contains("[fs-exec] spawn:image path=/sys/apps/wine_hello"):
        evidence.push("simpleos-user-process")
        evidence.push("simpleos-vmspace")
    if serial_log.contains("[desktop-e2e] wm:ok"):
        evidence.push("simpleos-window-server")
    if serial_log.contains("[vfs] mounted"):
        evidence.push("simpleos-vfs-mounted")
    if serial_log.contains("[desktop-e2e] network-smoke:bounded ok packets="):
        evidence.push("simpleos-network-smoke")
    if serial_log.contains("[desktop-e2e] container-namespace:ok"):
        evidence.push("simpleos-container-namespace")
        if serial_log.contains("[desktop-e2e] container-namespace:ok pid"):
            evidence.push("simpleos-container-pid-namespace")
        if serial_log.contains("[desktop-e2e] container-namespace:ok pid fs") or serial_log.contains("[desktop-e2e] container-namespace:ok fs"):
            evidence.push("simpleos-container-fs-namespace")
        if serial_log.contains("[desktop-e2e] container-namespace:ok pid fs ipc") or serial_log.contains("[desktop-e2e] container-namespace:ok ipc"):
            evidence.push("simpleos-container-ipc-namespace")
        if serial_log.contains("[desktop-e2e] container-namespace:ok pid fs ipc net") or serial_log.contains("[desktop-e2e] container-namespace:ok net"):
            evidence.push("simpleos-container-net-namespace")
        if serial_log.contains("[desktop-e2e] container-namespace:ok pid fs ipc net capability") or serial_log.contains("[desktop-e2e] container-namespace:ok capability"):
            evidence.push("simpleos-container-capability-boundary")
    if serial_log.contains("[desktop-e2e] container-rootfs:ok"):
        evidence.push("simpleos-container-rootfs")
        if serial_log.contains("rootfs_backend=nvfs"):
            evidence.push("simpleos-container-rootfs-nvfs")
    if serial_log.contains("[desktop-e2e] mdsoc-capsule:ok"):
        evidence.push("simpleos-mdsoc-capsule")
    if serial_log.contains("[desktop-e2e] mdsoc-public-port:ok"):
        evidence.push("simpleos-mdsoc-public-port")
    if serial_log.contains("[desktop-e2e] mdsoc-resident-state-owner:ok"):
        evidence.push("simpleos-mdsoc-resident-state-owner")
    evidence.join(" ")

pub fn wine_simpleos_exec_env_gate_from_serial_log(serial_log: text) -> text:
    wine_simpleos_exec_env_gate(wine_simpleos_exec_env_evidence_from_serial_log(serial_log))
