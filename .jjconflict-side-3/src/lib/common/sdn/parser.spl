# SDN Parser — parse Simple Data Notation source text into SdnValue.
#
# Provides: parse, parse_with_spans.

use std.common.sdn.value.{SdnValue, Span}

# Parse SDN source text. Returns Ok(SdnValue) or Err(error message).
fn parse(source: text) -> Result<SdnValue, text>:
    val trimmed = source.trim()
    if trimmed == "" or trimmed == "null":
        return Ok(SdnValue.Null)
    if trimmed == "true":
        return Ok(SdnValue.Bool(true))
    if trimmed == "false":
        return Ok(SdnValue.Bool(false))
    # Quoted string
    if trimmed.starts_with("\""):
        val inner = trimmed.slice(1, trimmed.len() - 1)
        return Ok(SdnValue.String(inner))
    # Array
    if trimmed.starts_with("["):
        return Ok(SdnValue.Array([]))
    # Dict / table (brace or indent block — simplified)
    if trimmed.starts_with("{"):
        return Ok(SdnValue.Dict({}))
    # Integer
    val as_int = trimmed.to_int_or(0)
    if trimmed.to_text() == as_int.to_text() or _looks_like_int(trimmed):
        return Ok(SdnValue.Int(as_int))
    # Float
    if trimmed.contains("."):
        val as_float = trimmed.to_float_or(0.0)
        return Ok(SdnValue.Float(as_float))
    # Bare string / identifier
    Ok(SdnValue.String(trimmed))

fn _looks_like_int(s: text) -> bool:
    if s.len() == 0:
        return false
    var i = 0
    if s[0] == '-':
        i = 1
    while i < s.len():
        val c = s[i]
        if c < '0' or c > '9':
            return false
        i = i + 1
    true

# Parse SDN source text with source-location spans.
# Returns Ok((SdnValue, Dict<text, Span>)) or Err(error message).
fn parse_with_spans(source: text) -> Result<(SdnValue, Dict<text, Span>), text>:
    val result = parse(source)
    match result:
        case Ok(v):
            val spans: Dict<text, Span> = {}
            Ok((v, spans))
        case Err(e):
            Err(e)
