# VM object heap and associated helper types.
# Provides ObjectStore (flat parallel-array object heap), ObjectLookupDiagnostic,
# NativeFunction binding, and digit-parsing utilities used by the store.

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError}
use std.js.types.js_types.{JsValue, JsObject, JsProperty}
use std.js.engine.interpreter_types.{f64_to_i64}

fn _digit_value(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1

fn _parse_non_negative_i64(value: text) -> Option<i64>:
    if value.len() == 0:
        return nil
    var parsed = 0
    var i = 0
    while i < value.len():
        val digit = _digit_value(value[i])
        if digit < 0:
            return nil
        parsed = parsed * 10 + digit
        i = i + 1
    Some(parsed)

# --- Native function binding ---

class NativeFunction:
    name: text
    arity: i64
    callback_id: i64

# --- Object heap ---

class ObjectLookupDiagnostic:
    requested_obj_id: i64
    normalized_obj_id: i64
    property_count: i64
    direct_scan_found: bool
    snapshot_found: bool

class ObjectStore:
    # Flat parallel arrays — avoids .get(i).field.mutate() copy bug in interpreter mode.
    # Object metadata (indexed by obj_id)
    obj_proto_ids: [i64]
    next_id: i64
    # Property storage (one entry per property across all objects)
    prop_obj_ids: [i64]
    prop_keys: [text]
    prop_values: [JsValue]
    prop_ref_tags: [text]
    prop_ref_ids: [text]
    prop_enumerables: [bool]
    prop_configurables: [bool]

    static fn new() -> ObjectStore:
        ObjectStore(
            obj_proto_ids: [], next_id: 0,
            prop_obj_ids: [],
            prop_keys: [],
            prop_values: [],
            prop_ref_tags: [],
            prop_ref_ids: [],
            prop_enumerables: [],
            prop_configurables: []
        )

    static fn create() -> ObjectStore:
        ObjectStore(
            obj_proto_ids: [], next_id: 0,
            prop_obj_ids: [],
            prop_keys: [],
            prop_values: [],
            prop_ref_tags: [],
            prop_ref_ids: [],
            prop_enumerables: [],
            prop_configurables: []
        )

    fn _normalize_obj_id(stored_id: i64) -> i64:
        # Bare-metal guest array reads can return boxed nonzero i64 values.
        if stored_id < 0:
            return stored_id
        if stored_id >= self.next_id and stored_id % 8 == 0:
            val decoded = stored_id / 8
            if decoded >= -1 and decoded < self.next_id:
                return decoded
        stored_id

    fn _stored_obj_id_equals(stored_id: i64, expected_id: i64) -> bool:
        self._normalize_obj_id(stored_id) == self._normalize_obj_id(expected_id)

    fn _normalize_value_ids(value: JsValue) -> JsValue:
        match value:
            case JsValue.Object(id):
                JsValue.Object(id: self._normalize_obj_id(id))
            case JsValue.Array(id):
                JsValue.Array(id: self._normalize_obj_id(id))
            case JsValue.Function(id):
                JsValue.Function(id: id)
            case JsValue.Symbol(id):
                JsValue.Symbol(id: id)
            case _:
                value

    fn _decode_ref_value(tag: text, id_text: text, fallback: JsValue) -> JsValue:
        if tag == "":
            return self._normalize_value_ids(fallback)
        if val Some(parsed_id) = _parse_non_negative_i64(id_text):
            val decoded_id = self._normalize_obj_id(parsed_id)
            if tag == "object":
                return JsValue.Object(id: decoded_id)
            if tag == "array":
                return JsValue.Array(id: decoded_id)
            if tag == "function":
                return JsValue.Function(id: parsed_id)
            if tag == "symbol":
                return JsValue.Symbol(id: parsed_id)
        self._normalize_value_ids(fallback)

    me set_reference_property(obj_id: i64, key: text, ref_tag: text, ref_id: i64):
        var prop_obj_ids: [i64] = self.prop_obj_ids
        var prop_keys: [text] = self.prop_keys
        var prop_values: [JsValue] = self.prop_values
        var prop_ref_tags: [text] = self.prop_ref_tags
        var prop_ref_ids: [text] = self.prop_ref_ids
        var prop_enumerables: [bool] = self.prop_enumerables
        var prop_configurables: [bool] = self.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push(key)
        prop_values.push(JsValue.Undefined)
        prop_ref_tags.push(ref_tag)
        prop_ref_ids.push("{self._normalize_obj_id(ref_id)}")
        prop_enumerables.push(true)
        prop_configurables.push(true)
        self.prop_obj_ids = prop_obj_ids
        self.prop_keys = prop_keys
        self.prop_values = prop_values
        self.prop_ref_tags = prop_ref_tags
        self.prop_ref_ids = prop_ref_ids
        self.prop_enumerables = prop_enumerables
        self.prop_configurables = prop_configurables

    me set_object_property_ref(obj_id: i64, key: text, ref_id: i64):
        self.set_reference_property(obj_id, key, "object", ref_id)

    me set_array_property_ref(obj_id: i64, key: text, ref_id: i64):
        self.set_reference_property(obj_id, key, "array", ref_id)

    me set_function_property_ref(obj_id: i64, key: text, ref_id: i64):
        self.set_reference_property(obj_id, key, "function", ref_id)

    me set_symbol_property_ref(obj_id: i64, key: text, ref_id: i64):
        self.set_reference_property(obj_id, key, "symbol", ref_id)

    fn _get_reference_property_ref_text(obj_id: i64, key: text, expected_tag: text) -> text:
        var i = self.prop_keys.len() - 1
        while i >= 0:
            if self._stored_obj_id_equals(self.prop_obj_ids.get(i), obj_id) and self.prop_keys.get(i) == key:
                if self.prop_ref_tags.get(i) == expected_tag:
                    return self.prop_ref_ids.get(i)
                return ""
            i = i - 1
        ""

    fn get_object_property_ref_text(obj_id: i64, key: text) -> text:
        self._get_reference_property_ref_text(obj_id, key, "object")

    fn get_object_property_ref(obj_id: i64, key: text) -> i64:
        if val Some(parsed_id) = _parse_non_negative_i64(self.get_object_property_ref_text(obj_id, key)):
            return self._normalize_obj_id(parsed_id)
        -1

    fn get_array_property_ref_text(obj_id: i64, key: text) -> text:
        self._get_reference_property_ref_text(obj_id, key, "array")

    fn get_array_property_ref(obj_id: i64, key: text) -> i64:
        if val Some(parsed_id) = _parse_non_negative_i64(self.get_array_property_ref_text(obj_id, key)):
            return self._normalize_obj_id(parsed_id)
        -1

    fn get_function_property_ref_text(obj_id: i64, key: text) -> text:
        self._get_reference_property_ref_text(obj_id, key, "function")

    fn get_function_property_ref(obj_id: i64, key: text) -> i64:
        if val Some(parsed_id) = _parse_non_negative_i64(self.get_function_property_ref_text(obj_id, key)):
            return self._normalize_obj_id(parsed_id)
        -1

    fn get_symbol_property_ref_text(obj_id: i64, key: text) -> text:
        self._get_reference_property_ref_text(obj_id, key, "symbol")

    fn get_symbol_property_ref(obj_id: i64, key: text) -> i64:
        if val Some(parsed_id) = _parse_non_negative_i64(self.get_symbol_property_ref_text(obj_id, key)):
            return self._normalize_obj_id(parsed_id)
        -1

    me allocate() -> JsObject:
        val id = self.next_id
        self.next_id = self.next_id + 1
        var obj_proto_ids: [i64] = self.obj_proto_ids
        obj_proto_ids.push(-1)
        self.obj_proto_ids = obj_proto_ids
        JsObject.create(id)

    me create_object() -> i64:
        val id = self.next_id
        self.next_id = self.next_id + 1
        var obj_proto_ids: [i64] = self.obj_proto_ids
        obj_proto_ids.push(-1)
        self.obj_proto_ids = obj_proto_ids
        id

    fn get_object(id: i64) -> JsObject:
        # Reconstruct JsObject from flat arrays (read-only snapshot)
        # Scan from end, deduplicate by key (latest entry wins)
        var props: [JsProperty] = []
        var seen_keys: [text] = []
        var i = self.prop_keys.len() - 1
        while i >= 0:
            if self._stored_obj_id_equals(self.prop_obj_ids.get(i), id):
                val key = self.prop_keys.get(i)
                var already_seen = false
                var si = 0
                while si < seen_keys.len():
                    if seen_keys.get(si) == key:
                        already_seen = true
                        si = seen_keys.len()
                    si = si + 1
                if not already_seen:
                    seen_keys.push(key)
                    val is_enum = self.prop_enumerables.get(i)
                    if is_enum:
                        props.push(JsProperty(
                            key: key,
                            value: self._decode_ref_value(
                                self.prop_ref_tags.get(i),
                                self.prop_ref_ids.get(i),
                                self.prop_values.get(i)),
                            writable: true,
                            enumerable: true,
                            configurable: self.prop_configurables.get(i)
                        ))
            i = i - 1
        # Reverse to restore insertion order
        var reversed: [JsProperty] = []
        var ri = props.len() - 1
        while ri >= 0:
            reversed.push(props.get(ri))
            ri = ri - 1
        var proto_id = -1
        if id >= 0 and id < self.obj_proto_ids.len():
            proto_id = self._normalize_obj_id(self.obj_proto_ids.get(id))
        JsObject(id: id, properties: reversed, prototype_id: proto_id)

    me set_property(obj_id: i64, key: text, value: JsValue):
        # Append-only — latest entry wins on read (no .set() in interpreter mode)
        var prop_obj_ids: [i64] = self.prop_obj_ids
        var prop_keys: [text] = self.prop_keys
        var prop_values: [JsValue] = self.prop_values
        var prop_ref_tags: [text] = self.prop_ref_tags
        var prop_ref_ids: [text] = self.prop_ref_ids
        var prop_enumerables: [bool] = self.prop_enumerables
        var prop_configurables: [bool] = self.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push(key)
        prop_values.push(value)
        prop_ref_tags.push("")
        prop_ref_ids.push("")
        prop_enumerables.push(true)
        prop_configurables.push(true)
        self.prop_obj_ids = prop_obj_ids
        self.prop_keys = prop_keys
        self.prop_values = prop_values
        self.prop_ref_tags = prop_ref_tags
        self.prop_ref_ids = prop_ref_ids
        self.prop_enumerables = prop_enumerables
        self.prop_configurables = prop_configurables

    fn get_property(obj_id: i64, key: text) -> JsValue:
        # Scan from end — latest entry wins
        var i = self.prop_keys.len() - 1
        while i >= 0:
            if self._stored_obj_id_equals(self.prop_obj_ids.get(i), obj_id):
                if self.prop_keys.get(i) == key:
                    return self._decode_ref_value(
                        self.prop_ref_tags.get(i),
                        self.prop_ref_ids.get(i),
                        self.prop_values.get(i))
            i = i - 1
        JsValue.Undefined

    fn inspect_property_lookup(obj_id: i64, key: text) -> ObjectLookupDiagnostic:
        val snapshot = self.get_object(obj_id)
        var snapshot_found = false
        var pi = 0
        while pi < snapshot.properties.len():
            if snapshot.properties.get(pi).key == key:
                snapshot_found = true
                pi = snapshot.properties.len()
            pi = pi + 1

        var direct_scan_found = false
        var i = self.prop_keys.len() - 1
        while i >= 0:
            if self._stored_obj_id_equals(self.prop_obj_ids.get(i), obj_id) and self.prop_keys.get(i) == key:
                direct_scan_found = true
                i = -1
            else:
                i = i - 1

        ObjectLookupDiagnostic(
            requested_obj_id: obj_id,
            normalized_obj_id: self._normalize_obj_id(obj_id),
            property_count: snapshot.properties.len(),
            direct_scan_found: direct_scan_found,
            snapshot_found: snapshot_found
        )

    fn array_length(obj_id: i64) -> i64:
        """Get the length of a dense array by counting distinct element keys."""
        if val JsValue.Number(v) = self.get_property(obj_id, "length"):
            return f64_to_i64(v)
        var seen_keys: [text] = []
        var derived_len = 0
        var i = self.prop_keys.len() - 1
        while i >= 0:
            if self._stored_obj_id_equals(self.prop_obj_ids.get(i), obj_id):
                val key = self.prop_keys.get(i)
                if key != "length":
                    var already_seen = false
                    var si = 0
                    while si < seen_keys.len():
                        if seen_keys.get(si) == key:
                            already_seen = true
                            si = seen_keys.len()
                        si = si + 1
                    if not already_seen:
                        seen_keys.push(key)
                        derived_len = derived_len + 1
            i = i - 1
        derived_len

    fn get_by_index(obj_id: i64, idx: i64) -> JsValue:
        """Get array element by numeric index."""
        self.get_property(obj_id, "{idx}")

    me create_array_from(values: [JsValue]) -> i64:
        """Create a new array object from a list of values."""
        val id = self.create_object()
        var i = 0
        while i < values.len():
            self.set_property(id, "{i}", values.get(i))
            i = i + 1
        self.set_property(id, "length", JsValue.Number(v: values.len().to_f64()))
        id

    me remove_property(obj_id: i64, key: text):
        """Remove a property from an object. Pushes Undefined tombstone."""
        var prop_obj_ids = self.prop_obj_ids
        var prop_keys = self.prop_keys
        var prop_values = self.prop_values
        var prop_ref_tags = self.prop_ref_tags
        var prop_ref_ids = self.prop_ref_ids
        var prop_enumerables = self.prop_enumerables
        var prop_configurables = self.prop_configurables
        prop_obj_ids.push(obj_id)
        prop_keys.push(key)
        prop_values.push(JsValue.Undefined)
        prop_ref_tags.push("")
        prop_ref_ids.push("")
        prop_enumerables.push(false)
        prop_configurables.push(false)
        self.prop_obj_ids = prop_obj_ids
        self.prop_keys = prop_keys
        self.prop_values = prop_values
        self.prop_ref_tags = prop_ref_tags
        self.prop_ref_ids = prop_ref_ids
        self.prop_enumerables = prop_enumerables
        self.prop_configurables = prop_configurables
