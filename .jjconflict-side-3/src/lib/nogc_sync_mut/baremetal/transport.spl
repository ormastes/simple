# Baremetal Host Communication - Transport Backend Trait
#
# Unified interface for all communication transports.
# Modeled after DebugAdapter in dap/adapter/mod.spl.

# Common transport backend interface
# All transport implementations (SSH, Serial, TRACE32, etc.) implement this trait
trait TransportBackend:
    # Get transport name/type
    fn name() -> text

    # Check if currently connected
    fn is_connected() -> bool

    # Connect to target device
    fn connect() -> Result<text, text>

    # Disconnect from target device
    fn disconnect() -> Result<text, text>

    # Send data to target
    fn send(data: text) -> Result<i32, text>

    # Receive data from target (blocking)
    fn receive() -> Result<text, text>

    # Receive data with timeout in milliseconds
    fn receive_timeout(timeout_ms: i64) -> Result<text, text>

    # Send command and receive response (send + receive)
    fn send_command(cmd: text) -> Result<text, text>

    # Flush any buffered data
    fn flush() -> Result<text, text>

    # Check how many bytes are available to read
    fn available() -> Result<i32, text>
