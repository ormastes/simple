"""SIMD Provider — trait, hit-count accumulator, and provider registration.

@tag:stdlib
@tag:gpu

Defines the SimdProvider trait and SimdHitCounts accumulator consumed by
simd_kernels.spl and the optimization plugin metadata hook.

Usage:
    use std.nogc_sync_mut.gpu.engine2d.simd_provider.{SimdProvider, SimdHitCounts, reset_simd_hits}
"""

# ============================================================================
# Hit-count accumulator (module-level singleton)
# ============================================================================

class SimdHitCounts:
    """Per-frame SIMD kernel invocation counters.

    Each span/rect kernel call increments the corresponding counter.
    vectorize_changes is incremented by the optimization plugin hook
    whenever a loop is reported as newly vectorized (changed == true).
    """
    fill_hits:         i64
    copy_hits:         i64
    alpha_hits:        i64
    blit_hits:         i64
    scroll_hits:       i64
    vectorize_changes: i64

fn make_simd_hit_counts_zero() -> SimdHitCounts:
    SimdHitCounts(
        fill_hits:         0,
        copy_hits:         0,
        alpha_hits:        0,
        blit_hits:         0,
        scroll_hits:       0,
        vectorize_changes: 0
    )

var _simd_fill_hits: i64 = 0
var _simd_copy_hits: i64 = 0
var _simd_alpha_hits: i64 = 0
var _simd_blit_hits: i64 = 0
var _simd_scroll_hits: i64 = 0
var _simd_vectorize_changes: i64 = 0

pub fn reset_simd_hits():
    """Reset all counters — call at frame boundary before rendering."""
    _simd_fill_hits = 0
    _simd_copy_hits = 0
    _simd_alpha_hits = 0
    _simd_blit_hits = 0
    _simd_scroll_hits = 0
    _simd_vectorize_changes = 0

pub fn simd_hit_counts() -> SimdHitCounts:
    SimdHitCounts(
        fill_hits: _simd_fill_hits,
        copy_hits: _simd_copy_hits,
        alpha_hits: _simd_alpha_hits,
        blit_hits: _simd_blit_hits,
        scroll_hits: _simd_scroll_hits,
        vectorize_changes: _simd_vectorize_changes
    )

pub fn record_simd_fill_hit():
    _simd_fill_hits = _simd_fill_hits + 1

pub fn record_simd_copy_hit():
    _simd_copy_hits = _simd_copy_hits + 1

pub fn record_simd_alpha_hit():
    _simd_alpha_hits = _simd_alpha_hits + 1

pub fn record_simd_blit_hit():
    _simd_blit_hits = _simd_blit_hits + 1

pub fn record_simd_scroll_hit():
    _simd_scroll_hits = _simd_scroll_hits + 1

# ============================================================================
# SimdProvider trait
# ============================================================================

trait SimdProvider:
    """Abstraction over a SIMD kernel set.

    Implementations provide the five span/rect kernels and expose the
    accumulated hit counts for the current frame. The optimization plugin
    metadata hook (plugin_hook_vectorize_event) updates vectorize_changes.
    """

    # Return snapshot of hit counts for this frame
    fn hit_counts() -> SimdHitCounts

    # Return target feature list
    fn target_features() -> [text]

# ============================================================================
# Provider registration — module-level singleton registry
# ============================================================================

var _registered_provider_name: text = ""
var _provider_registered: bool = false

pub fn register_simd_provider(name: text):
    """Register a named SIMD provider. Call once at engine init."""
    _registered_provider_name = name
    _provider_registered = true

pub fn registered_provider_name() -> text:
    _registered_provider_name

pub fn has_registered_provider() -> bool:
    _provider_registered
