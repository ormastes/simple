# UI Widgets — Helper constructors for common UI elements
#
# Convenience functions that create pre-configured UIElement instances
# with appropriate types, positions, and anchors.
#
# Usage:
#   val label = create_label("title", "Hello", 10.0, 10.0, 200.0, 30.0)
#   val btn = create_button("ok", "OK", 10.0, 50.0, 100.0, 40.0)

use std.nogc_sync_mut.engine.ui.canvas.{UIElement, Anchor}

fn create_label(name: text, txt: text, x: f64, y: f64, width: f64, height: f64) -> UIElement:
    var elem = UIElement.new(name, "label", width, height)
    elem.offset_x = x
    elem.offset_y = y
    elem.content = txt
    elem

fn create_button(name: text, txt: text, x: f64, y: f64, width: f64, height: f64) -> UIElement:
    var elem = UIElement.new(name, "button", width, height)
    elem.offset_x = x
    elem.offset_y = y
    elem.content = txt
    elem

fn create_panel(name: text, x: f64, y: f64, width: f64, height: f64) -> UIElement:
    var elem = UIElement.new(name, "panel", width, height)
    elem.offset_x = x
    elem.offset_y = y
    elem

fn create_progress_bar(name: text, x: f64, y: f64, width: f64, height: f64) -> UIElement:
    var elem = UIElement.new(name, "progress_bar", width, height)
    elem.offset_x = x
    elem.offset_y = y
    elem.content = "0"
    elem

fn create_image(name: text, path: text, x: f64, y: f64, width: f64, height: f64) -> UIElement:
    var elem = UIElement.new(name, "image", width, height)
    elem.offset_x = x
    elem.offset_y = y
    elem.content = path
    elem
