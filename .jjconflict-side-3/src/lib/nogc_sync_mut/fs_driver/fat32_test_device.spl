# FAT32 — Test device registry and per-device operation wrappers.
#
# Provides a global Fat32Core registry keyed by DeviceId for use in tests.

use std.driver.types.{DeviceId, DriverClass}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.types.{FileHandle, DirEntry}
use std.fs_driver.fat32_core.{Fat32Core}

var __fat32_test_devices: [Fat32Core] = []

fn fat32_register_test_device(device: BlockDevice) -> DeviceId:
    val slot = __fat32_test_devices.len() as i64
    __fat32_test_devices.push(Fat32Core.new(device))
    DeviceId(value: slot, dclass: DriverClass.Block)

fn fat32_test_device_probe(dev: DeviceId) -> Result<bool, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Ok(false)
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Ok(false)
    var core = __fat32_test_devices[idx]
    val rc = core.probe_boot_sector()
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_mount(dev: DeviceId) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.mount()
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_unmount(dev: DeviceId) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.unmount()
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_is_mounted(dev: DeviceId) -> Result<bool, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Ok(false)
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Ok(false)
    Ok(__fat32_test_devices[idx].mounted)

fn fat32_test_device_open(dev: DeviceId, path: text) -> Result<FileHandle, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.open(path)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_close(dev: DeviceId, handle: FileHandle) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.close(handle)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_read_bytes(dev: DeviceId, handle: FileHandle, len: i64) -> Result<[u8], text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.read_bytes(handle, len)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_read(dev: DeviceId, handle: FileHandle, buf: [u8], len: i64) -> Result<i64, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.read(handle, buf, len)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_write(dev: DeviceId, handle: FileHandle, buf: [u8], len: i64) -> Result<i64, text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.write(handle, buf, len)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_readdir(dev: DeviceId, path: text) -> Result<[DirEntry], text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.readdir(path)
    __fat32_test_devices[idx] = core
    rc

fn fat32_test_device_truncate(dev: DeviceId, handle: FileHandle, size: i64) -> Result<(), text>:
    if dev.dclass != DriverClass.Block or dev.value < 0:
        return Err("invalid FAT32 device")
    val idx = dev.value.to_i32()
    if idx < 0 or idx >= __fat32_test_devices.len():
        return Err("unknown FAT32 device")
    var core = __fat32_test_devices[idx]
    val rc = core.truncate(handle, size)
    __fat32_test_devices[idx] = core
    rc
