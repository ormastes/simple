# Terminal & Power SDN Config Parser
#
# Parses config/t32/t32_terminal.sdn into typed TerminalConfig and PowerConfig
# structs. SDN format uses indentation-based hierarchy:
#   0-indent = section header (terminals, power)
#   2-indent = entry name
#   4-indent = key: value pairs
#
# Used by: CLI terminal/power commands, MCP tools, test daemon adapters

use std.terminal.types.{
    TerminalConfig, PowerConfig,
    TERM_KIND_SSH, TERM_KIND_TELNET, TERM_KIND_T32_SWD, TERM_KIND_RELAY,
    make_ssh_config, make_ssh_pubkey_config, make_telnet_config,
    make_t32_swd_config, make_relay_config,
    make_power_config_t32, make_power_config_relay, make_power_config_host
}
use std.terminal.credential.store.{credential_resolve}

extern fn rt_file_read_text(path: text) -> text

# ============================================================================
# Public API
# ============================================================================

fn parse_terminal_config(path: text) -> [TerminalConfig]:
    """Parse the terminals section of an SDN config file.

    Reads the file, finds the 'terminals' section, and parses each
    entry into a TerminalConfig struct based on its 'kind' field.

    Args:
        path: Path to the SDN config file

    Returns:
        List of TerminalConfig structs parsed from the file

    Example:
        val configs = parse_terminal_config("config/t32/t32_terminal.sdn")
        var i = 0
        while i < configs.len():
            print "Terminal: {configs[i].name}"
            i = i + 1
    """
    val content = rt_file_read_text(path)
    val lines = content.split("\n")
    val entries = parse_section_entries(lines, "terminals")
    var result: [TerminalConfig] = []

    var i = 0
    while i < entries.len():
        val entry = entries[i]
        val config = build_terminal_config(entry)
        if config.?:
            result.push(config)
        i = i + 1
    result

fn parse_power_config(path: text) -> [PowerConfig]:
    """Parse the power section of an SDN config file.

    Reads the file, finds the 'power' section, and parses each
    entry into a PowerConfig struct based on its 'kind' field.

    Args:
        path: Path to the SDN config file

    Returns:
        List of PowerConfig structs parsed from the file

    Example:
        val configs = parse_power_config("config/t32/t32_terminal.sdn")
        var i = 0
        while i < configs.len():
            print "Power target: {configs[i].name}"
            i = i + 1
    """
    val content = rt_file_read_text(path)
    val lines = content.split("\n")
    val entries = parse_section_entries(lines, "power")
    var result: [PowerConfig] = []

    var i = 0
    while i < entries.len():
        val entry = entries[i]
        val config = build_power_config(entry)
        if config.?:
            result.push(config)
        i = i + 1
    result

fn find_terminal_by_name(configs: [TerminalConfig], name: text) -> TerminalConfig?:
    """Find a terminal config by its name.

    Args:
        configs: List of terminal configurations to search
        name: Name to match against config.name

    Returns:
        Matching TerminalConfig, or nil if not found
    """
    var i = 0
    while i < configs.len():
        if configs[i].name == name:
            return configs[i]
        i = i + 1
    nil

fn find_power_by_name(configs: [PowerConfig], name: text) -> PowerConfig?:
    """Find a power config by its name.

    Args:
        configs: List of power configurations to search
        name: Name to match against config.name

    Returns:
        Matching PowerConfig, or nil if not found
    """
    var i = 0
    while i < configs.len():
        if configs[i].name == name:
            return configs[i]
        i = i + 1
    nil

# ============================================================================
# Internal: SDN Section Parser
# ============================================================================

struct SdnEntry:
    """A parsed SDN entry with name and key-value pairs."""
    name: text
    fields: {text: text}

fn parse_section_entries(lines: [text], section_name: text) -> [SdnEntry]:
    """Parse all entries within a named section.

    Walks through lines looking for the section header at 0-indent,
    then collects entries (2-indent names) with their key-value pairs
    (4-indent key: value) until the next 0-indent section or EOF.

    Args:
        lines: All lines from the SDN file
        section_name: Section to extract (e.g., "terminals", "power")

    Returns:
        List of SdnEntry structs with name and fields
    """
    var result: [SdnEntry] = []
    var in_section = false
    var current_name = ""
    var current_fields: {text: text} = {}
    var i = 0

    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()

        # Skip empty lines and comments
        if trimmed == "" or trimmed.starts_with("#"):
            i = i + 1
            continue

        val indent = count_leading_spaces(line)

        if indent == 0:
            # Section header
            if in_section:
                # Save last entry before leaving section
                if current_name != "":
                    result.push(SdnEntry(name: current_name, fields: current_fields))
                in_section = false
                current_name = ""
                current_fields = {}

            if trimmed == section_name:
                in_section = true

        elif in_section and indent == 2:
            # Entry name at 2-indent
            if current_name != "":
                result.push(SdnEntry(name: current_name, fields: current_fields))
            current_name = trimmed
            current_fields = {}

        elif in_section and indent >= 4:
            # Key: value pair at 4-indent
            val colon_pos = trimmed.index_of(":")
            if colon_pos > 0:
                val key = trimmed.substring(0, colon_pos).trim()
                val value = trimmed.substring(colon_pos + 1, trimmed.len()).trim()
                current_fields[key] = value

        i = i + 1

    # Save last entry if we were still in section
    if in_section and current_name != "":
        result.push(SdnEntry(name: current_name, fields: current_fields))

    result

fn count_leading_spaces(line: text) -> i64:
    """Count the number of leading space characters in a line.

    Args:
        line: Input text line

    Returns:
        Number of leading spaces (stops at first non-space character)
    """
    var count: i64 = 0
    var i = 0
    while i < line.len():
        if line.char_at(i) == " ":
            count = count + 1
        else:
            return count
        i = i + 1
    count

# ============================================================================
# Internal: Config Builders
# ============================================================================

fn build_terminal_config(entry: SdnEntry) -> TerminalConfig?:
    """Build a TerminalConfig from a parsed SDN entry.

    Dispatches by the 'kind' field to create the appropriate config type.

    Args:
        entry: Parsed SDN entry with name and fields

    Returns:
        TerminalConfig, or nil if kind is unknown
    """
    val kind = entry.fields["kind"] ?? ""

    if kind == "ssh":
        return build_ssh_terminal(entry)
    if kind == "telnet":
        return build_telnet_terminal(entry)
    if kind == "t32_swd":
        return build_t32_swd_terminal(entry)
    if kind == "relay":
        return build_relay_terminal(entry)
    nil

fn build_ssh_terminal(entry: SdnEntry) -> TerminalConfig:
    """Build an SSH TerminalConfig from a parsed SDN entry.

    Handles both password and pubkey auth methods. Passwords prefixed
    with 'encrypted:' are resolved via credential_resolve().

    Args:
        entry: Parsed SDN entry with SSH fields

    Returns:
        TerminalConfig with SSH kind
    """
    val host = entry.fields["host"] ?? ""
    val port_str = entry.fields["port"] ?? "22"
    val port = port_str.to_i64() ?? 22
    val username = entry.fields["username"] ?? ""
    val auth = entry.fields["auth"] ?? "password"
    val key_path = entry.fields["key_path"] ?? ""

    if auth == "pubkey":
        return make_ssh_pubkey_config(entry.name, host, port, username, key_path)

    # Password auth — resolve encrypted credentials
    val raw_password = entry.fields["password"] ?? ""
    val credential = credential_resolve(raw_password)
    make_ssh_config(entry.name, host, port, username, auth, credential)

fn build_telnet_terminal(entry: SdnEntry) -> TerminalConfig:
    """Build a Telnet TerminalConfig from a parsed SDN entry.

    Args:
        entry: Parsed SDN entry with telnet fields

    Returns:
        TerminalConfig with Telnet kind
    """
    val host = entry.fields["host"] ?? ""
    val port_str = entry.fields["port"] ?? "23"
    val port = port_str.to_i64() ?? 23
    make_telnet_config(entry.name, host, port)

fn build_t32_swd_terminal(entry: SdnEntry) -> TerminalConfig:
    """Build a T32 SWD TerminalConfig from a parsed SDN entry.

    Args:
        entry: Parsed SDN entry with T32 SWD fields

    Returns:
        TerminalConfig with T32 SWD kind
    """
    val t32_host = entry.fields["t32_host"] ?? "localhost"
    val t32_port_str = entry.fields["t32_port"] ?? "20000"
    val t32_port = t32_port_str.to_i64() ?? 20000
    val channel = entry.fields["channel"] ?? "TERM.A"
    make_t32_swd_config(entry.name, t32_host, t32_port, channel)

fn build_relay_terminal(entry: SdnEntry) -> TerminalConfig:
    """Build a Relay TerminalConfig from a parsed SDN entry.

    Args:
        entry: Parsed SDN entry with relay fields

    Returns:
        TerminalConfig with Relay kind
    """
    val script_path = entry.fields["script_path"] ?? ""
    make_relay_config(entry.name, script_path)

fn build_power_config(entry: SdnEntry) -> PowerConfig?:
    """Build a PowerConfig from a parsed SDN entry.

    Dispatches by the 'kind' field to create the appropriate power config.

    Args:
        entry: Parsed SDN entry with name and fields

    Returns:
        PowerConfig, or nil if kind is unknown
    """
    val kind = entry.fields["kind"] ?? ""

    if kind == "t32":
        return build_t32_power(entry)
    if kind == "relay":
        return build_relay_power(entry)
    if kind == "host":
        return build_host_power(entry)
    nil

fn build_t32_power(entry: SdnEntry) -> PowerConfig:
    """Build a T32 PowerConfig from a parsed SDN entry.

    Args:
        entry: Parsed SDN entry with T32 power fields

    Returns:
        PowerConfig with T32 kind
    """
    val t32_host = entry.fields["t32_host"] ?? "localhost"
    val t32_port_str = entry.fields["t32_port"] ?? "20000"
    val t32_port = t32_port_str.to_i64() ?? 20000
    make_power_config_t32(entry.name, t32_host, t32_port)

fn build_relay_power(entry: SdnEntry) -> PowerConfig:
    """Build a relay PowerConfig from a parsed SDN entry.

    Reads script paths and optional relay hardware parameters (device,
    baud, USB VID/PID, custom commands).  Empty strings use script defaults.

    Args:
        entry: Parsed SDN entry with relay script paths and hardware config

    Returns:
        PowerConfig with relay kind
    """
    val on_script = entry.fields["on_script"] ?? ""
    val off_script = entry.fields["off_script"] ?? ""
    val toggle_script = entry.fields["toggle_script"] ?? ""
    val reset_script = entry.fields["reset_script"] ?? ""
    val state_script = entry.fields["state_script"] ?? ""
    val relay_device = entry.fields["relay_device"] ?? ""
    val relay_baud = entry.fields["relay_baud"] ?? ""
    val relay_usb_vid = entry.fields["relay_usb_vid"] ?? ""
    val relay_usb_pid = entry.fields["relay_usb_pid"] ?? ""
    val relay_cmd_on = entry.fields["relay_cmd_on"] ?? ""
    val relay_cmd_off = entry.fields["relay_cmd_off"] ?? ""
    val relay_cmd_state = entry.fields["relay_cmd_state"] ?? ""
    val relay_cmd_toggle = entry.fields["relay_cmd_toggle"] ?? ""
    val relay_reset_delay = entry.fields["relay_reset_delay"] ?? ""
    make_power_config_relay(entry.name, on_script, off_script, toggle_script, reset_script, state_script, relay_device, relay_baud, relay_usb_vid, relay_usb_pid, relay_cmd_on, relay_cmd_off, relay_cmd_state, relay_cmd_toggle, relay_reset_delay)

fn build_host_power(entry: SdnEntry) -> PowerConfig:
    """Build a host PowerConfig from a parsed SDN entry.

    Handles SSH credentials and Wake-on-LAN MAC address for host power control.

    Args:
        entry: Parsed SDN entry with host power fields

    Returns:
        PowerConfig with host kind
    """
    val host = entry.fields["host"] ?? ""
    val port_str = entry.fields["ssh_port"] ?? "22"
    val port = port_str.to_i64() ?? 22
    val username = entry.fields["username"] ?? ""
    val auth = entry.fields["auth"] ?? "pubkey"
    val key_path = entry.fields["key_path"] ?? ""
    val mac = entry.fields["mac"] ?? ""

    # Resolve credential if password auth
    val raw_credential = entry.fields["password"] ?? ""
    val credential = credential_resolve(raw_credential)

    make_power_config_host(entry.name, host, port, username, auth, credential, key_path, mac)
