# DBFS database layer.
#
# Submodules:
#   accel.spl        — Phase 1: shared scan/bitmap/text acceleration primitives
#   prefix_index.spl — Phase 2: prefix/radix index for namespace and key-span scans
#   text_index.spl   — Phase 2: in-memory prefix+text index for simple_db
#   filter_in.spl    — Phase 2: OR-semantics batch filter_in with RowBitmap output
#   page_summary.spl — Phase 2: page-header summary scan helpers (BRIN-style)
#   query_planner.spl — Phase 3: cost-based plan selection (FullScan, IndexLookup, etc.)
#   db_persistence.spl — DbTable with integrated index maintenance
#   db_query.spl     — indexed + planner-aware query API
#   dbfs_engine/     — embedded pager+B-tree+WAL engine
#   dbfs_driver/     — FsDriver seam (DbFsDriver implementing FsDriver trait)

use std.io_runtime
