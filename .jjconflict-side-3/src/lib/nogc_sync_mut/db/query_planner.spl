"""Query Planner — maps a predicate tree + available indexes to an execution plan.

Phase 3 of the DB acceleration plan.  Enumerates plan candidates (FullScan,
IndexLookup, IndexRange, IndexPrefix, Join) and selects the lowest-cost
candidate via the ML cost model.

See also: ml_cost_model.spl
"""

use std.db.ml_cost_model.{
    CostModel,
    PlanCost,
    cost_model_new,
    estimate_cost,
    plan_cost_total,
    plan_cost_rows
}

# ── Predicate tree ────────────────────────────────────────────────────────────

enum PredicateKind:
    Eq
    Range
    Prefix
    And
    Or

struct Predicate:
    kind: PredicateKind
    column: text
    value: text
    range_lo: text
    range_hi: text
    children: [Predicate]

fn predicate_eq(column: text, value: text) -> Predicate:
    Predicate(
        kind: PredicateKind.Eq,
        column: column,
        value: value,
        range_lo: "",
        range_hi: "",
        children: []
    )

fn predicate_range(column: text, lo: text, hi: text) -> Predicate:
    Predicate(
        kind: PredicateKind.Range,
        column: column,
        value: "",
        range_lo: lo,
        range_hi: hi,
        children: []
    )

fn predicate_prefix(column: text, prefix: text) -> Predicate:
    Predicate(
        kind: PredicateKind.Prefix,
        column: column,
        value: prefix,
        range_lo: "",
        range_hi: "",
        children: []
    )

fn predicate_and(children: [Predicate]) -> Predicate:
    Predicate(
        kind: PredicateKind.And,
        column: "",
        value: "",
        range_lo: "",
        range_hi: "",
        children: children
    )

fn predicate_or(children: [Predicate]) -> Predicate:
    Predicate(
        kind: PredicateKind.Or,
        column: "",
        value: "",
        range_lo: "",
        range_hi: "",
        children: children
    )

# ── Index descriptor ──────────────────────────────────────────────────────────

enum IndexKind:
    BTree
    Hash
    Prefix

struct IndexDescriptor:
    name: text
    column: text
    kind: IndexKind

fn index_descriptor_new(name: text, column: text, kind: IndexKind) -> IndexDescriptor:
    IndexDescriptor(name: name, column: column, kind: kind)

fn index_covers_column(idx: IndexDescriptor, column: text) -> bool:
    idx.column == column

# ── Plan nodes ────────────────────────────────────────────────────────────────

enum PlanNodeKind:
    FullScan
    IndexLookup
    IndexRange
    IndexPrefix
    Join
    IndexFts
    PageSummaryScan

struct PlanNode:
    kind: PlanNodeKind
    index_name: text
    predicate_column: text
    left_node: text
    right_node: text

fn plan_node_full_scan() -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.FullScan,
        index_name: "",
        predicate_column: "",
        left_node: "",
        right_node: ""
    )

fn plan_node_index_lookup(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexLookup,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_index_range(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexRange,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_index_prefix(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexPrefix,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_join(left: text, right: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.Join,
        index_name: "",
        predicate_column: "",
        left_node: left,
        right_node: right
    )

fn plan_node_index_fts(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexFts,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_page_summary(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.PageSummaryScan,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_kind_name(node: PlanNode) -> text:
    match node.kind:
        case PlanNodeKind.FullScan:
            "FullScan"
        case PlanNodeKind.IndexLookup:
            "IndexLookup"
        case PlanNodeKind.IndexRange:
            "IndexRange"
        case PlanNodeKind.IndexPrefix:
            "IndexPrefix"
        case PlanNodeKind.Join:
            "Join"
        case PlanNodeKind.IndexFts:
            "IndexFts"
        case PlanNodeKind.PageSummaryScan:
            "PageSummaryScan"

# ── Plan candidate (node + cost) ──────────────────────────────────────────────

struct PlanCandidate:
    node: PlanNode
    cost: PlanCost

fn plan_candidate_new(node: PlanNode, cost: PlanCost) -> PlanCandidate:
    PlanCandidate(node: node, cost: cost)

# ── Candidate enumeration ─────────────────────────────────────────────────────

fn find_index_for_predicate(pred: Predicate, indexes: [IndexDescriptor]) -> [IndexDescriptor]:
    var result: [IndexDescriptor] = []
    var i = 0
    while i < indexes.len():
        if index_covers_column(indexes[i as i32], pred.column):
            result.push(indexes[i as i32])
        i = i + 1
    result

fn candidates_for_predicate(pred: Predicate, indexes: [IndexDescriptor], model: CostModel) -> [PlanCandidate]:
    var candidates: [PlanCandidate] = []

    # Always include full-scan as fallback
    val full_scan_node = plan_node_full_scan()
    val full_scan_cost = estimate_cost("FullScan", model)
    candidates.push(PlanCandidate(node: full_scan_node, cost: full_scan_cost))

    val covering = find_index_for_predicate(pred, indexes)
    var ci = 0
    while ci < covering.len():
        val idx = covering[ci as i32]
        match pred.kind:
            case PredicateKind.Eq:
                if idx.kind == IndexKind.Hash or idx.kind == IndexKind.BTree:
                    val node = plan_node_index_lookup(idx.name, pred.column)
                    val cost = estimate_cost("IndexLookup", model)
                    candidates.push(PlanCandidate(node: node, cost: cost))
            case PredicateKind.Range:
                if idx.kind == IndexKind.BTree:
                    val node = plan_node_index_range(idx.name, pred.column)
                    val cost = estimate_cost("IndexRange", model)
                    candidates.push(PlanCandidate(node: node, cost: cost))
            case PredicateKind.Prefix:
                if idx.kind == IndexKind.Prefix or idx.kind == IndexKind.BTree:
                    val node = plan_node_index_prefix(idx.name, pred.column)
                    val cost = estimate_cost("IndexPrefix", model)
                    candidates.push(PlanCandidate(node: node, cost: cost))
            case PredicateKind.And:
                pass_do_nothing
            case PredicateKind.Or:
                pass_do_nothing
        ci = ci + 1

    candidates

fn plan_query(pred: Predicate, indexes: [IndexDescriptor], model: CostModel) -> [PlanCandidate]:
    match pred.kind:
        case PredicateKind.And:
            # For AND: plan each child, include a join candidate
            var all: [PlanCandidate] = []
            var ci = 0
            while ci < pred.children.len():
                val child_candidates = candidates_for_predicate(pred.children[ci as i32], indexes, model)
                var ki = 0
                while ki < child_candidates.len():
                    all.push(child_candidates[ki as i32])
                    ki = ki + 1
                ci = ci + 1
            # Add join candidate across first two children if multiple
            if pred.children.len() >= 2:
                val join_node = plan_node_join("child_0", "child_1")
                val join_cost = estimate_cost("Join", model)
                all.push(PlanCandidate(node: join_node, cost: join_cost))
            all
        case PredicateKind.Or:
            # For OR: full scan is simplest safe choice
            var all: [PlanCandidate] = []
            val full_scan_node = plan_node_full_scan()
            val full_scan_cost = estimate_cost("FullScan", model)
            all.push(PlanCandidate(node: full_scan_node, cost: full_scan_cost))
            all
        case PredicateKind.Eq:
            candidates_for_predicate(pred, indexes, model)
        case PredicateKind.Range:
            candidates_for_predicate(pred, indexes, model)
        case PredicateKind.Prefix:
            candidates_for_predicate(pred, indexes, model)

# ── Best plan selection ───────────────────────────────────────────────────────

fn pick_best(candidates: [PlanCandidate]) -> PlanNode:
    if candidates.len() == 0:
        return plan_node_full_scan()
    var best_idx = 0
    var best_cost = plan_cost_total(candidates[0].cost)
    var i = 1
    while i < candidates.len():
        val c = plan_cost_total(candidates[i as i32].cost)
        if c < best_cost:
            best_cost = c
            best_idx = i
        i = i + 1
    candidates[best_idx as i32].node

# ── Top-level convenience ─────────────────────────────────────────────────────

fn choose_plan(pred: Predicate, indexes: [IndexDescriptor], row_count: i64) -> PlanNode:
    val model = cost_model_new(row_count)
    val candidates = plan_query(pred, indexes, model)
    pick_best(candidates)
