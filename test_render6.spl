use common.ui.parse.sdn.{parse_to_flat, flat_get, flat_child_keys, read_file}

fn main():
    val source = read_file("examples/ui/demo.ui.sdn")
    val entries = parse_to_flat(source)
    print "Title: {flat_get(entries, "app.title")}"
    print "Getting child keys..."
    val kids = flat_child_keys(entries, "layout.children")
    print "Children: {kids}"
