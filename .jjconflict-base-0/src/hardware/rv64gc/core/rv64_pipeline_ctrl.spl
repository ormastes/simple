"""
# RV64 Pipeline Hazard Detection and Forwarding

Detects load-use hazards and resolves data forwarding for a classic
5-stage pipeline (IF/ID/EX/MEM/WB).
"""

use hardware.riscv_common.pkg.riscv_types_pkg.{ForwardSrc, PipelineControl}

# ---------------------------------------------------------------------------
# Load-use hazard detection
# ---------------------------------------------------------------------------

fn detect_load_use_hazard(ex_mem_is_load: bool, ex_mem_rd: i64, id_rs1: i64, id_rs2: i64) -> bool:
    """Detect if a load in EX/MEM stage feeds directly into the next instruction's source.
    Requires a 1-cycle stall (load-use penalty)."""
    if ex_mem_is_load and ex_mem_rd != 0:
        (ex_mem_rd == id_rs1) or (ex_mem_rd == id_rs2)
    else:
        false

# ---------------------------------------------------------------------------
# Data forwarding resolution
# ---------------------------------------------------------------------------

fn resolve_forward_rs1(id_rs1: i64, ex_mem_rd: i64, ex_mem_writes_rd: bool,
                       mem_wb_rd: i64, mem_wb_writes_rd: bool) -> ForwardSrc:
    """Determine forwarding source for rs1."""
    if ex_mem_writes_rd and ex_mem_rd != 0 and ex_mem_rd == id_rs1:
        ForwardSrc.FromEx
    elif mem_wb_writes_rd and mem_wb_rd != 0 and mem_wb_rd == id_rs1:
        ForwardSrc.FromMem
    else:
        ForwardSrc.RegFile

fn resolve_forward_rs2(id_rs2: i64, ex_mem_rd: i64, ex_mem_writes_rd: bool,
                       mem_wb_rd: i64, mem_wb_writes_rd: bool) -> ForwardSrc:
    """Determine forwarding source for rs2."""
    if ex_mem_writes_rd and ex_mem_rd != 0 and ex_mem_rd == id_rs2:
        ForwardSrc.FromEx
    elif mem_wb_writes_rd and mem_wb_rd != 0 and mem_wb_rd == id_rs2:
        ForwardSrc.FromMem
    else:
        ForwardSrc.RegFile

# ---------------------------------------------------------------------------
# Combined pipeline control
# ---------------------------------------------------------------------------

fn compute_pipeline_control(load_use: bool, branch_taken: bool) -> PipelineControl:
    """Compute stall and flush signals for the pipeline.
    - load_use: stall IF and ID, insert bubble in EX
    - branch_taken: flush IF and ID stages"""
    if load_use:
        PipelineControl(stall: true, flush: false)
    elif branch_taken:
        PipelineControl(stall: false, flush: true)
    else:
        PipelineControl(stall: false, flush: false)
