/**
Simple Concurrency Module

Provides primitives for concurrent and asynchronous programming:
- Promise<T>: Type-safe async values for async-by-default semantics
- Generators: Lazy sequences with yield/next
- Futures: Async values with future/await
- Actors: Message-passing concurrency with spawn/send/recv
- Async Functions: Effect-safe async/await

```sdoctest
>>> val gen = generator(\: yield 42)
>>> next(gen)
42
```

```sdoctest
>>> val f = future(1 + 2)
>>> await f
3
```

```sdoctest
>>> val p = Promise.resolved(42)
>>> await p
42
```
*/

# Export submodules
export promise
export generators
export futures
export actors
export channels
export threads
export resource_limits

