# Unit: MilliWatt
# Kind: Power
# Symbol: mW
# Canonical scale: 0.001 W

class MilliWatt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MilliWatt) -> MilliWatt: MilliWatt(value: self.value + other.value)
    fn sub(other: MilliWatt) -> MilliWatt: MilliWatt(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "mW"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "W"
    static fn zero() -> MilliWatt: MilliWatt(value: 0.0)

export MilliWatt
