# Composite Unit: DB
# Kind: Log
# Symbol: dB
# Scale to SI base: 1.0 dB

class DB:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: DB) -> DB: DB(value: self.value + other.value)
    fn sub(other: DB) -> DB: DB(value: self.value - other.value)

    static fn kind() -> text: "Log"
    static fn symbol() -> text: "dB"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "dB"
    static fn numerator() -> [text]: ["dB"]
    static fn denominator() -> [text]: []
    static fn zero() -> DB: DB(value: 0.0)

export DB
