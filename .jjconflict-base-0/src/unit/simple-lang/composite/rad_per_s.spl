# Composite Unit: RadPerS
# Kind: AngularVelocity
# Symbol: rad_per_s
# Scale to SI base: 1.0 rad/s

class RadPerS:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: RadPerS) -> RadPerS: RadPerS(value: self.value + other.value)
    fn sub(other: RadPerS) -> RadPerS: RadPerS(value: self.value - other.value)

    static fn kind() -> text: "AngularVelocity"
    static fn symbol() -> text: "rad_per_s"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "rad/s"
    static fn numerator() -> [text]: ["rad"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> RadPerS: RadPerS(value: 0.0)

export RadPerS
