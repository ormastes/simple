# Composite Unit: KgMperS
# Kind: Momentum
# Symbol: kg_m_per_s
# Scale to SI base: 1.0 kg*m/s

class KgMperS:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KgMperS) -> KgMperS: KgMperS(value: self.value + other.value)
    fn sub(other: KgMperS) -> KgMperS: KgMperS(value: self.value - other.value)

    static fn kind() -> text: "Momentum"
    static fn symbol() -> text: "kg_m_per_s"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "kg*m/s"
    static fn numerator() -> [text]: ["kg", "m"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> KgMperS: KgMperS(value: 0.0)

export KgMperS
