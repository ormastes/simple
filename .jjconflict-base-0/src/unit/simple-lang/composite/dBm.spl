# Composite Unit: DBm
# Kind: PowerLog
# Symbol: dBm
# Scale to SI base: 1.0 dBm

class DBm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: DBm) -> DBm: DBm(value: self.value + other.value)
    fn sub(other: DBm) -> DBm: DBm(value: self.value - other.value)

    static fn kind() -> text: "PowerLog"
    static fn symbol() -> text: "dBm"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "dBm"
    static fn numerator() -> [text]: ["dBm"]
    static fn denominator() -> [text]: []
    static fn zero() -> DBm: DBm(value: 0.0)

export DBm
