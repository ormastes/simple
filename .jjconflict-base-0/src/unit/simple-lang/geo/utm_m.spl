# Unit: UtmM
# Kind: GeoProjection
# Symbol: utm_m
# Canonical scale: 1.0 m

class UtmM:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: UtmM) -> UtmM: UtmM(value: self.value + other.value)
    fn sub(other: UtmM) -> UtmM: UtmM(value: self.value - other.value)

    static fn kind() -> text: "GeoProjection"
    static fn symbol() -> text: "utm_m"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m"
    static fn zero() -> UtmM: UtmM(value: 0.0)

export UtmM
