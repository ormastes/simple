# Unit: MegaHertz
# Kind: Frequency
# Symbol: MHz
# Canonical scale: 1000000.0 Hz

class MegaHertz:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaHertz) -> MegaHertz: MegaHertz(value: self.value + other.value)
    fn sub(other: MegaHertz) -> MegaHertz: MegaHertz(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "MHz"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "Hz"
    static fn zero() -> MegaHertz: MegaHertz(value: 0.0)

export MegaHertz
