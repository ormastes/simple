# Unit: Molar
# Kind: Concentration
# Symbol: M
# Canonical scale: 1.0 mol/L

class Molar:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Molar) -> Molar: Molar(value: self.value + other.value)
    fn sub(other: Molar) -> Molar: Molar(value: self.value - other.value)

    static fn kind() -> text: "Concentration"
    static fn symbol() -> text: "M"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "mol/L"
    static fn zero() -> Molar: Molar(value: 0.0)

export Molar
