# Unit: Ppm
# Kind: MassFraction
# Symbol: ppm
# Canonical scale: 1e-06 ratio

class Ppm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ppm) -> Ppm: Ppm(value: self.value + other.value)
    fn sub(other: Ppm) -> Ppm: Ppm(value: self.value - other.value)

    static fn kind() -> text: "MassFraction"
    static fn symbol() -> text: "ppm"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "ratio"
    static fn zero() -> Ppm: Ppm(value: 0.0)

export Ppm
