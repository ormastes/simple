# Unit: Ps
# Kind: Time
# Symbol: ps
# Canonical scale: 1e-12 s

class Ps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ps) -> Ps: Ps(value: self.value + other.value)
    fn sub(other: Ps) -> Ps: Ps(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "ps"
    static fn scale_to_base() -> f64: 1e-12
    static fn base_unit() -> text: "s"
    static fn zero() -> Ps: Ps(value: 0.0)

export Ps
