# Unit: Kati
# Kind: Mass
# Symbol: kati
# Canonical scale: 0.604 kg

class Kati:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Kati) -> Kati: Kati(value: self.value + other.value)
    fn sub(other: Kati) -> Kati: Kati(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "kati"
    static fn scale_to_base() -> f64: 0.604
