# Unit: Mi
# Kind: Length
# Symbol: mi
# Canonical scale: 1609.344 m

class Mi:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mi) -> Mi: Mi(value: self.value + other.value)
    fn sub(other: Mi) -> Mi: Mi(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "mi"
    static fn scale_to_base() -> f64: 1609.344
    static fn base_unit() -> text: "m"
    static fn zero() -> Mi: Mi(value: 0.0)

export Mi
