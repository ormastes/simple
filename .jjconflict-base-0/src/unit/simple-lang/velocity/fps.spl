# Unit: Fps
# Kind: Velocity
# Symbol: fps
# Canonical scale: 0.3048 m/s

class Fps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Fps) -> Fps: Fps(value: self.value + other.value)
    fn sub(other: Fps) -> Fps: Fps(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "fps"
    static fn scale_to_base() -> f64: 0.3048
    static fn base_unit() -> text: "m/s"
    static fn zero() -> Fps: Fps(value: 0.0)

export Fps
