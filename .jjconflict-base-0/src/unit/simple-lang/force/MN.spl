# Unit: MegaNewton
# Kind: Force
# Symbol: MN
# Canonical scale: 1000000.0 N

class MegaNewton:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaNewton) -> MegaNewton: MegaNewton(value: self.value + other.value)
    fn sub(other: MegaNewton) -> MegaNewton: MegaNewton(value: self.value - other.value)

    static fn kind() -> text: "Force"
    static fn symbol() -> text: "MN"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "N"
    static fn zero() -> MegaNewton: MegaNewton(value: 0.0)

export MegaNewton
