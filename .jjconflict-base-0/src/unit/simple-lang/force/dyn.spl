# Unit: Dyne
# Kind: Force
# Symbol: dyn
# Canonical scale: 1e-05 N

class Dyne:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dyne) -> Dyne: Dyne(value: self.value + other.value)
    fn sub(other: Dyne) -> Dyne: Dyne(value: self.value - other.value)

    static fn kind() -> text: "Force"
    static fn symbol() -> text: "dyn"
    static fn scale_to_base() -> f64: 1e-05
    static fn base_unit() -> text: "N"
    static fn zero() -> Dyne: Dyne(value: 0.0)

export Dyne
