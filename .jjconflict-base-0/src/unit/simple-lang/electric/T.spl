# Unit: Tesla
# Kind: MagneticFlux
# Symbol: T
# Canonical scale: 1.0 T

class Tesla:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Tesla) -> Tesla: Tesla(value: self.value + other.value)
    fn sub(other: Tesla) -> Tesla: Tesla(value: self.value - other.value)

    static fn kind() -> text: "MagneticFlux"
    static fn symbol() -> text: "T"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "T"
    static fn zero() -> Tesla: Tesla(value: 0.0)

export Tesla
