# Unit: MilliVolt
# Kind: ElectricPotential
# Symbol: mV
# Canonical scale: 0.001 V

class MilliVolt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MilliVolt) -> MilliVolt: MilliVolt(value: self.value + other.value)
    fn sub(other: MilliVolt) -> MilliVolt: MilliVolt(value: self.value - other.value)

    static fn kind() -> text: "ElectricPotential"
    static fn symbol() -> text: "mV"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "V"
    static fn zero() -> MilliVolt: MilliVolt(value: 0.0)

export MilliVolt
