# Unit: Mmol
# Kind: Amount
# Symbol: mmol
# Canonical scale: 0.001 mol

class Mmol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mmol) -> Mmol: Mmol(value: self.value + other.value)
    fn sub(other: Mmol) -> Mmol: Mmol(value: self.value - other.value)

    static fn kind() -> text: "Amount"
    static fn symbol() -> text: "mmol"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "mol"
    static fn zero() -> Mmol: Mmol(value: 0.0)

export Mmol
