# Unit: Megagram
# Kind: Mass
# Symbol: Mg
# Canonical scale: 1000.0 kg

class Megagram:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Megagram) -> Megagram: Megagram(value: self.value + other.value)
    fn sub(other: Megagram) -> Megagram: Megagram(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "Mg"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "kg"
    static fn zero() -> Megagram: Megagram(value: 0.0)

export Megagram
