# Unit: Nok
# Kind: Currency
# Symbol: NOK
# Canonical scale: 1.0 USD

class Nok:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Nok) -> Nok: Nok(value: self.value + other.value)
    fn sub(other: Nok) -> Nok: Nok(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "NOK"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Nok: Nok(value: 0.0)

export Nok
