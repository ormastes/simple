# Unit: Krw
# Kind: Currency
# Symbol: KRW
# Canonical scale: 1.0 USD

class Krw:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Krw) -> Krw: Krw(value: self.value + other.value)
    fn sub(other: Krw) -> Krw: Krw(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "KRW"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Krw: Krw(value: 0.0)

export Krw
