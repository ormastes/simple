# Unit: Zar
# Kind: Currency
# Symbol: ZAR
# Canonical scale: 1.0 USD

class Zar:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Zar) -> Zar: Zar(value: self.value + other.value)
    fn sub(other: Zar) -> Zar: Zar(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "ZAR"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Zar: Zar(value: 0.0)

export Zar
