# Unit: TurkishLira
# Kind: Currency
# Symbol: TRY
# Canonical scale: 1.0 USD

class TurkishLira:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: TurkishLira) -> TurkishLira: TurkishLira(value: self.value + other.value)
    fn sub(other: TurkishLira) -> TurkishLira: TurkishLira(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "TRY"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> TurkishLira: TurkishLira(value: 0.0)

export TurkishLira
