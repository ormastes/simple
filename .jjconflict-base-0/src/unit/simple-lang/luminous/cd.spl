# Unit: Candela
# Kind: LuminousIntensity
# Symbol: cd
# Canonical scale: 1.0 cd

class Candela:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Candela) -> Candela: Candela(value: self.value + other.value)
    fn sub(other: Candela) -> Candela: Candela(value: self.value - other.value)

    static fn kind() -> text: "LuminousIntensity"
    static fn symbol() -> text: "cd"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "cd"
    static fn zero() -> Candela: Candela(value: 0.0)

export Candela
