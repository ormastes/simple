# Unit: Serving
# Kind: Culinary
# Symbol: serving
# Canonical scale: 1.0 serving

class Serving:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Serving) -> Serving: Serving(value: self.value + other.value)
    fn sub(other: Serving) -> Serving: Serving(value: self.value - other.value)

    static fn kind() -> text: "Culinary"
    static fn symbol() -> text: "serving"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "serving"
    static fn zero() -> Serving: Serving(value: 0.0)

export Serving
