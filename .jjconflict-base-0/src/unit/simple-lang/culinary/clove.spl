# Unit: Clove
# Kind: Culinary
# Symbol: clove
# Canonical scale: 1.0 clove

class Clove:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Clove) -> Clove: Clove(value: self.value + other.value)
    fn sub(other: Clove) -> Clove: Clove(value: self.value - other.value)

    static fn kind() -> text: "Culinary"
    static fn symbol() -> text: "clove"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "clove"
    static fn zero() -> Clove: Clove(value: 0.0)

export Clove
