# Unit: Cup
# Kind: Volume
# Symbol: cup
# Canonical scale: 0.000236588 m3

class Cup:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Cup) -> Cup: Cup(value: self.value + other.value)
    fn sub(other: Cup) -> Cup: Cup(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "cup"
    static fn scale_to_base() -> f64: 0.000236588
    static fn base_unit() -> text: "m3"
    static fn zero() -> Cup: Cup(value: 0.0)

export Cup
