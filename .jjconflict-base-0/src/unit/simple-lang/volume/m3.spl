# Unit: M3
# Kind: Volume
# Symbol: m3
# Canonical scale: 1.0 m3

class M3:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: M3) -> M3: M3(value: self.value + other.value)
    fn sub(other: M3) -> M3: M3(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "m3"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m3"
    static fn zero() -> M3: M3(value: 0.0)

export M3
