#![allow(unnamed_duplicate_typed_args)]
## simple_make — Minimal make-like build tool for SimpleOS
##
## Replaces make/ninja for on-SimpleOS compilation.
## Parses a simplified Makefile format and executes rules.
##
## Usage:
##   bin/simple run src/os/port/build_tools/simple_make.spl
##   bin/simple run src/os/port/build_tools/simple_make.spl -- -f build.mk
##   bin/simple run src/os/port/build_tools/simple_make.spl -- clean
##   bin/simple run src/os/port/build_tools/simple_make.spl -- -j 4 all

use std.fs
use std.process
use std.text
use std.cli

# --- Data structures ---

struct MakeVar:
    name: text
    value: text

struct MakeRule:
    target: text
    deps: [text]
    commands: [text]
    is_pattern: bool      # true for %.o: %.c rules

struct MakeFile:
    vars: [MakeVar]
    rules: [MakeRule]
    default_target: text

# --- Parser ---

fn parse_makefile(content: text) -> MakeFile:
    """Parse a Makefile-like build description.

    Supports:
    - Variable assignment: VAR = value
    - Rules: target: dep1 dep2
    - Tab-indented commands under rules
    - Pattern rules: %.o: %.c
    - Comments starting with #
    """
    var vars: [MakeVar] = []
    var rules: [MakeRule] = []
    var default_target = ""
    var current_rule: MakeRule? = nil

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()

        # Skip empty lines and comments
        if trimmed.len() == 0 or trimmed.starts_with("#"):
            # Save current rule before a blank separator
            if trimmed.len() == 0 and current_rule != nil:
                rules.push(current_rule)
                current_rule = nil
            continue

        # Command line (starts with tab) belongs to current rule
        if line.starts_with("\t") and current_rule != nil:
            current_rule.commands.push(trimmed)
            continue

        # Variable assignment: VAR = value (but not lines with ':' which are rules)
        if trimmed.contains("=") and not trimmed.contains(":"):
            val eq_pos = trimmed.index_of("=")
            if eq_pos > 0:
                val name = trimmed.slice(0, eq_pos).trim()
                val value = trimmed.slice(eq_pos + 1, trimmed.len()).trim()
                vars.push(MakeVar(name: name, value: value))
            continue

        # Rule: target: dep1 dep2 ...
        if trimmed.contains(":"):
            # Save previous rule if any
            if current_rule != nil:
                rules.push(current_rule)

            val colon_pos = trimmed.index_of(":")
            val target = trimmed.slice(0, colon_pos).trim()
            val deps_str = trimmed.slice(colon_pos + 1, trimmed.len()).trim()
            val deps = if deps_str.len() > 0:
                deps_str.split(" ").filter(\x: x.len() > 0)
            else:
                []

            val is_pattern = target.contains("%")

            current_rule = MakeRule(
                target: target,
                deps: deps,
                commands: [],
                is_pattern: is_pattern,
            )

            # First non-pattern rule is the default target
            if default_target.len() == 0 and not is_pattern:
                default_target = target

    # Save last rule
    if current_rule != nil:
        rules.push(current_rule)

    MakeFile(vars: vars, rules: rules, default_target: default_target)

# --- Variable expansion ---

fn expand_vars(input: text, vars: [MakeVar]) -> text:
    """Expand $(VAR) references in a string."""
    var result = input
    for v in vars:
        result = result.replace_all("$({v.name})", v.value)
    result

fn expand_automatic_vars(cmd: text, target: text, deps: [text]) -> text:
    """Expand automatic variables: $@ $< $^"""
    var result = cmd
    result = result.replace_all("$@", target)
    if deps.len() > 0:
        result = result.replace_all("$<", deps[0])
    result = result.replace_all("$^", deps.join(" "))
    result

# --- Pattern matching ---

fn match_pattern(pattern: text, target: text) -> text?:
    """Match target against a pattern rule (e.g. %.o matches foo.o).
    Returns the stem (the part matching %) or nil if no match.
    """
    val pct_pos = pattern.index_of("%")
    if pct_pos < 0:
        return nil

    val prefix = pattern.slice(0, pct_pos)
    val suffix = pattern.slice(pct_pos + 1, pattern.len())

    if target.starts_with(prefix) and target.ends_with(suffix):
        val stem_end = target.len() - suffix.len()
        if stem_end >= prefix.len():
            return target.slice(prefix.len(), stem_end)
    nil

fn apply_pattern(pattern: text, stem: text) -> text:
    """Apply a stem to a pattern, replacing % with stem."""
    pattern.replace_all("%", stem)

# --- Build execution ---

fn needs_rebuild(target: text, deps: [text]) -> bool:
    """Check if target needs rebuilding based on file modification times."""
    if not fs.exists(target):
        return true
    val target_stat = fs.stat(target)
    if target_stat.is_err():
        return true
    val target_mtime = target_stat.unwrap().mtime
    for dep in deps:
        if not fs.exists(dep):
            print "[make] Missing dependency: {dep}"
            return true
        val dep_stat = fs.stat(dep)
        if dep_stat.is_ok():
            if dep_stat.unwrap().mtime > target_mtime:
                return true
    false

fn find_rule(makefile: MakeFile, target: text) -> MakeRule?:
    """Find a rule for the given target.

    Tries exact match first, then pattern rules.
    """
    # Exact match first
    for rule in makefile.rules:
        if rule.target == target:
            return rule

    # Pattern match (e.g. %.o: %.c)
    for rule in makefile.rules:
        if rule.is_pattern:
            val stem = match_pattern(rule.target, target)
            if stem != nil:
                # Instantiate pattern rule for this target
                val concrete_deps = rule.deps.map(\d: apply_pattern(d, stem))
                return MakeRule(
                    target: target,
                    deps: concrete_deps,
                    commands: rule.commands,
                    is_pattern: false,
                )
    nil

var _in_progress: [text] = []

fn build_target(makefile: MakeFile, target: text, built: [text]) -> bool:
    """Build a target and its dependencies recursively.

    Returns true on success, false on failure.
    Detects dependency cycles via _in_progress tracking.
    """
    # Already built this session
    if built.contains(target):
        return true

    # Cycle detection: if target is already being built, we have a loop
    if _in_progress.contains(target):
        print "[make] Error: dependency cycle detected at '{target}'"
        return false

    val rule = find_rule(makefile, target)
    if rule == nil:
        # No rule — check if file exists (source file)
        if fs.exists(target):
            return true
        print "[make] No rule to make '{target}'"
        return false

    # Mark in-progress before descending into dependencies
    _in_progress.push(target)

    # Expand variables in dependency list
    val expanded_deps = rule.deps.map(\d: expand_vars(d, makefile.vars))

    # Build dependencies first (depth-first)
    for dep in expanded_deps:
        if not build_target(makefile, dep, built):
            _in_progress = _in_progress.filter(\t: t != target)
            return false

    # Check if rebuild needed
    if not needs_rebuild(target, expanded_deps):
        print "[make] '{target}' is up to date"
        built.push(target)
        return true

    # Execute commands
    for cmd in rule.commands:
        var expanded = expand_vars(cmd, makefile.vars)
        expanded = expand_automatic_vars(expanded, target, expanded_deps)

        print "[make] {expanded}"
        val result = process.run("sh", ["-c", expanded])
        if result.exit_code != 0:
            if result.stderr.len() > 0:
                print result.stderr
            print "[make] Error: command failed with exit code {result.exit_code}"
            return false

    # Done building — mark complete, remove from in-progress
    _in_progress = _in_progress.filter(\t: t != target)
    built.push(target)
    true

# --- Main ---

fn main():
    val args = cli.args()
    var build_file = "Makefile"
    var target = ""
    var jobs = 1

    # Parse arguments
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "-f":
            i = i + 1
            if i < args.len():
                build_file = args[i]
        else if arg == "-j":
            i = i + 1
            if i < args.len():
                jobs = args[i].parse_int()
        else if arg == "--help" or arg == "-h":
            print_usage()
            return
        else if not arg.starts_with("-"):
            target = arg
        i = i + 1

    # Read build file
    if not fs.exists(build_file):
        print "[make] No '{build_file}' found"
        process.exit(1)

    val content = fs.read_text(build_file)
    val makefile = parse_makefile(content)

    if target.len() == 0:
        target = makefile.default_target

    if target.len() == 0:
        print "[make] No target specified and no default target"
        process.exit(1)

    if jobs > 1:
        print "[make] Parallel builds (-j {jobs}) not yet implemented, using serial"

    print "[make] Building '{target}' from '{build_file}'..."
    var built: [text] = []
    val ok = build_target(makefile, target, built)
    if ok:
        print "[make] Done."
    else:
        print "[make] Build failed."
        process.exit(1)

fn print_usage():
    print "simple_make — Minimal make-like build tool for SimpleOS"
    print ""
    print "Usage:"
    print "  simple_make                  Build default target from Makefile"
    print "  simple_make -f build.mk      Use specific build file"
    print "  simple_make clean            Build specific target"
    print "  simple_make -j 4 all         Parallel jobs (not yet implemented)"
    print ""
    print "Build file format (subset of Make):"
    print "  # Variables"
    print "  CC = clang"
    print "  CFLAGS = -ffreestanding"
    print ""
    print "  # Pattern rules"
    print "  %.o: %.c"
    print "  \t$(CC) $(CFLAGS) -c $< -o $@"
    print ""
    print "  # Explicit rules"
    print "  libfoo.a: foo.o bar.o"
    print "  \tar rcs $@ $^"
    print ""
    print "Supported:"
    print "  $(VAR)  Variable expansion"
    print "  $@      Target name"
    print "  $<      First dependency"
    print "  $^      All dependencies"
    print "  %.ext   Pattern rules"
