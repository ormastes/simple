//! Target: `library/std/src/sys/pal/simpleos/thread.rs`
//!
//! SimpleOS is single-threaded until the kernel grows real threads.
//! `Thread::new` returns `ErrorKind::Unsupported`. Thread-local storage
//! degrades to a single-slot `UnsafeCell` keyed by address — safe because
//! there is only ever one thread of execution.

use crate::ffi::CStr;
use crate::io;
use crate::num::NonZero;
use crate::time::Duration;

pub struct Thread(!);

pub const DEFAULT_MIN_STACK_SIZE: usize = 64 * 1024;

impl Thread {
    /// # Safety
    /// Matches the libstd signature; never actually called successfully
    /// because we always return `Unsupported` below.
    pub unsafe fn new(_stack: usize, _p: Box<dyn FnOnce()>) -> io::Result<Thread> {
        Err(io::Error::from(io::ErrorKind::Unsupported))
    }

    pub fn yield_now() {
        // Single-threaded — nothing to yield to. A cooperative hint could
        // call `sched_yield` once libsimpleos_c exposes it (TODO).
    }

    pub fn set_name(_name: &CStr) {}

    pub fn sleep(dur: Duration) {
        // TODO: libsimpleos_c nanosleep. For now busy-wait on
        // `time::Instant::now()`.
        let deadline = crate::sys::time::Instant::now()
            .checked_add_duration(&dur)
            .unwrap_or_else(crate::sys::time::Instant::now);
        while crate::sys::time::Instant::now() < deadline {
            core::hint::spin_loop();
        }
    }

    pub fn join(self) { self.0 }
}

pub fn available_parallelism() -> io::Result<NonZero<usize>> {
    // Single hart in SimpleOS userspace.
    Ok(NonZero::new(1).unwrap())
}

// ---- Single-threaded TLS via UnsafeCell -----------------------------------
//
// Because we have exactly one thread, thread-locals may live in a plain
// per-address `UnsafeCell`. Concurrency is structurally impossible.

pub mod guard {
    pub type Guard = !;
    pub unsafe fn current() -> Option<Guard> { None }
    pub unsafe fn init() -> Option<Guard>    { None }
}

pub mod local {
    use core::cell::UnsafeCell;

    /// Opaque key handle — stored as the address of the `UnsafeCell` we
    /// expose through `get`.
    pub struct Key<T: 'static> {
        slot: UnsafeCell<Option<T>>,
    }

    // SAFETY: single-threaded — no cross-thread aliasing is possible.
    unsafe impl<T: 'static> Sync for Key<T> {}

    impl<T: 'static> Key<T> {
        pub const fn new() -> Self { Key { slot: UnsafeCell::new(None) } }

        /// # Safety
        /// Caller must not hold another reference into the same slot.
        pub unsafe fn get(&self) -> *mut Option<T> { self.slot.get() }
    }
}
