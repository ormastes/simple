# env / printenv — Print environment variables
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line, write_error}

fn tool_env(env_vars: [(text, text)], terminal: Terminal) -> i32:
    """Print all environment variables."""
    for pair in env_vars:
        write_line(terminal, "{pair.0}={pair.1}")
    return 0

fn tool_printenv(env_vars: [(text, text)], args: [text], terminal: Terminal) -> i32:
    """Print specific environment variable(s)."""
    if args.len() == 0:
        return tool_env(env_vars, terminal)
    val name = args[0]
    for pair in env_vars:
        if pair.0 == name:
            write_line(terminal, pair.1)
            return 0
    return 1
