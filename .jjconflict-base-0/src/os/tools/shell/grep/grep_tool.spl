# grep — Search for pattern in files
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines}

fn tool_grep(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Search for pattern in files."""
    if args.len() < 2:
        write_error(terminal, "grep: usage: grep PATTERN FILE...")
        return 1
    val pattern = args[0]
    var found = false
    var i = 1
    while i < args.len():
        val path = resolve_path(cwd, args[i])
        if vfs != nil:
            val result = vfs.read_text(path)
            match result:
                case Ok(content):
                    var line_num = 1
                    for line in split_lines(content):
                        if line.contains(pattern):
                            write_line(terminal, "{args[i]}:{line_num}:{line}")
                            found = true
                        line_num = line_num + 1
                case Err(err):
                    write_error(terminal, "grep: {path}: {err}")
        i = i + 1
    return 0
