# Package Manifest — SDN Format
# MDSOC: feature dimension, apps layer

struct PackageVersion:
    major: i32
    minor: i32
    patch: i32

impl PackageVersion:
    fn to_text() -> text:
        "{self.major}.{self.minor}.{self.patch}"

    static fn parse(s: text) -> Result<PackageVersion, text>:
        """Parse a version string like '1.2.3'."""
        val parts = s.split(".")
        if parts.len() != 3:
            return Result.Err("Invalid version format: '{s}' (expected X.Y.Z)")

        val major = parts[0].to_i32()
        val minor = parts[1].to_i32()
        val patch = parts[2].to_i32()
        return Result.Ok(PackageVersion(major: major, minor: minor, patch: patch))

    fn compare(other: PackageVersion) -> i32:
        """Compare two versions. Returns -1, 0, or 1."""
        if self.major != other.major:
            if self.major < other.major:
                return -1
            return 1
        if self.minor != other.minor:
            if self.minor < other.minor:
                return -1
            return 1
        if self.patch != other.patch:
            if self.patch < other.patch:
                return -1
            return 1
        return 0

struct PackageManifest:
    name: text
    version: PackageVersion
    description: text
    dependencies: [text]            # "name>=version" format
    files: [text]                   # installed file paths
    checksum: text

fn parse_manifest(content: text) -> Result<PackageManifest, text>:
    """Parse a package manifest from SDN format.

    Format:
    [package]
    name = "foo"
    version = "1.2.3"
    description = "A useful package"
    dependencies = ["bar>=1.0.0", "baz"]
    files = ["/usr/bin/foo", "/usr/lib/libfoo.so"]
    checksum = "sha256:abc..."
    """
    var name = ""
    var version_str = ""
    var description = ""
    var dependencies: [text] = []
    var files: [text] = []
    var checksum = ""

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("["):
            pass_dn

        else if trimmed.starts_with("name"):
            name = _extract_string_value(trimmed)
        else if trimmed.starts_with("version"):
            version_str = _extract_string_value(trimmed)
        else if trimmed.starts_with("description"):
            description = _extract_string_value(trimmed)
        else if trimmed.starts_with("checksum"):
            checksum = _extract_string_value(trimmed)
        else if trimmed.starts_with("dependencies"):
            dependencies = _extract_list_value(trimmed)
        else if trimmed.starts_with("files"):
            files = _extract_list_value(trimmed)

    if name == "":
        return Result.Err("Missing required field: name")
    if version_str == "":
        return Result.Err("Missing required field: version")

    val version_result = PackageVersion.parse(version_str)
    if val Err(e) = version_result:
        return Result.Err(e)
    val version = version_result.unwrap()

    return Result.Ok(PackageManifest(
        name: name,
        version: version,
        description: description,
        dependencies: dependencies,
        files: files,
        checksum: checksum
    ))

fn serialize_manifest(m: PackageManifest) -> text:
    """Serialize a package manifest to SDN format."""
    var out = "[package]\n"
    out = out + "name = \"{m.name}\"\n"
    out = out + "version = \"{m.version.to_text()}\"\n"
    out = out + "description = \"{m.description}\"\n"

    var deps_str = "["
    var i = 0
    for dep in m.dependencies:
        if i > 0:
            deps_str = deps_str + ", "
        deps_str = deps_str + "\"{dep}\""
        i = i + 1
    deps_str = deps_str + "]"
    out = out + "dependencies = {deps_str}\n"

    var files_str = "["
    i = 0
    for f in m.files:
        if i > 0:
            files_str = files_str + ", "
        files_str = files_str + "\"{f}\""
        i = i + 1
    files_str = files_str + "]"
    out = out + "files = {files_str}\n"

    out = out + "checksum = \"{m.checksum}\"\n"
    return out

fn _extract_string_value(line: text) -> text:
    """Extract quoted string value from 'key = "value"' line."""
    val eq_idx = line.index_of("=")
    if eq_idx < 0:
        return ""
    var value = line.slice(eq_idx + 1, line.len()).trim()
    # Remove surrounding quotes
    if value.starts_with("\""):
        value = value.slice(1, value.len())
    if value.ends_with("\""):
        value = value.slice(0, value.len() - 1)
    return value

fn _extract_list_value(line: text) -> [text]:
    """Extract list value from 'key = ["a", "b"]' line."""
    val eq_idx = line.index_of("=")
    if eq_idx < 0:
        return []
    var value = line.slice(eq_idx + 1, line.len()).trim()
    # Remove [ and ]
    if value.starts_with("["):
        value = value.slice(1, value.len())
    if value.ends_with("]"):
        value = value.slice(0, value.len() - 1)

    var items: [text] = []
    val parts = value.split(",")
    for part in parts:
        var item = part.trim()
        # Remove quotes
        if item.starts_with("\""):
            item = item.slice(1, item.len())
        if item.ends_with("\""):
            item = item.slice(0, item.len() - 1)
        if item != "":
            items.push(item)
    return items
