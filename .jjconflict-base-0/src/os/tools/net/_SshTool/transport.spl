# SSH client transport: ClientSocket framing, plain/encrypted packet send & recv, version-line exchange, argument parsing, ECDH-reply parsing, and userauth/channel message builders.
use os.tools.net.ssh_tool.*
# ssh — SSH client
# MDSOC: feature dimension, apps layer
#
# Complete client state machine: version exchange → KEXINIT → KEX ECDH →
# key derivation → NEWKEYS → service request → userauth (password) →
# channel open → pty-req + shell → bidirectional I/O loop.

use os.apps.sshd.ssh_transport.{
    ssh_build_version_string,
    ssh_parse_version_string,
    ssh_build_kexinit,
    ssh_parse_kexinit,
    SSH_MSG_DEBUG,
    SSH_MSG_EXT_INFO,
    SSH_MSG_IGNORE,
    SSH_MSG_KEXINIT,
    SSH_MSG_NEWKEYS,
    SSH_MSG_SERVICE_REQUEST,
    SSH_MSG_SERVICE_ACCEPT,
    SSH_VERSION_STRING
}
use os.apps.sshd.ssh_packet.{
    ssh_packet_build,
    ssh_packet_read,
    ssh_get_u32,
    ssh_get_string,
    ssh_get_text,
    ssh_ascii_text_to_bytes,
    ssh_put_u32,
    ssh_put_text,
    ssh_put_string,
    ssh_put_bool,
    SshPacket,
    SshPacketResult,
    SshStringResult,
    SshTextResult
}
use os.apps.sshd.ssh_kex.{
    ssh_kex_generate_keypair,
    ssh_kex_compute_shared,
    ssh_kex_compute_exchange_hash,
    ssh_derive_keys,
    SshSessionKeys,
    SSH_MSG_KEX_ECDH_INIT,
    SSH_MSG_KEX_ECDH_REPLY
}
use os.apps.sshd.ssh_cipher.{SshCipher}
use os.apps.sshd.ssh_auth.{
    SSH_MSG_USERAUTH_REQUEST,
    SSH_MSG_USERAUTH_SUCCESS,
    SSH_MSG_USERAUTH_FAILURE
}
use os.apps.sshd.ssh_channel.{
    ssh_build_channel_data,
    ssh_build_channel_window_adjust,
    ssh_build_channel_eof,
    ssh_build_channel_close,
    SSH_MSG_CHANNEL_OPEN,
    SSH_MSG_CHANNEL_OPEN_CONFIRMATION,
    SSH_MSG_CHANNEL_OPEN_FAILURE,
    SSH_MSG_CHANNEL_WINDOW_ADJUST,
    SSH_MSG_CHANNEL_DATA,
    SSH_MSG_CHANNEL_EXTENDED_DATA,
    SSH_MSG_CHANNEL_EOF,
    SSH_MSG_CHANNEL_CLOSE,
    SSH_MSG_CHANNEL_REQUEST,
    DEFAULT_WINDOW_SIZE,
    DEFAULT_MAX_PACKET
}
use std.io.signature_sffi.{verify_host_key}

extern fn rt_stdin_read_line() -> text?
extern fn rt_string_to_byte_array(s: text) -> [u8]
extern fn rt_io_tcp_connect(addr: text) -> i64
extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_write(fd: i64, data: [u8]) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

class ClientSocket:
    fd: i64

# ============================================================================
# Plaintext packet helpers
# ============================================================================

fn _build_packet(payload: [u8]) -> [u8]:
    """Wrap payload in SSH binary packet format (plaintext)."""
    ssh_packet_build(payload, 0)

fn _socket_send(sock: ClientSocket, data: [u8]) -> Result<u64, text>:
    var written: i64 = rt_io_tcp_write(sock.fd, data)
    if written < 0:
        return Err("write failed: {written}")
    if written == 0 and data.len() > 0:
        return Err("write returned 0")
    Ok(written.to_u64())

fn _socket_send_all(sock: ClientSocket, data: [u8]) -> Result<bool, text>:
    var sent: u64 = 0
    while sent < data.len():
        val chunk = data.slice(sent, data.len())
        val r = _socket_send(sock, chunk)
        if r.is_err():
            return Err(r.unwrap_err())
        var wrote: u64 = 0
        match r:
            Err(_e):
                pass_dn
            Ok(n):
                wrote = n
        sent = sent + wrote
    Ok(true)

fn _socket_recv_some(sock: ClientSocket, max_len: u64) -> Result<[u8], text>:
    if max_len == 0:
        return Ok([])
    Ok(rt_io_tcp_read(sock.fd, max_len.to_i64()))

fn _socket_recv_exact(sock: ClientSocket, size: u64) -> Result<[u8], text>:
    var out: [u8] = []
    while out.len() < size:
        val need = size - out.len()
        val r = _socket_recv_some(sock, need)
        if r.is_err():
            return Err(r.unwrap_err())
        var chunk: [u8] = []
        match r:
            Err(_e):
                pass_dn
            Ok(bytes):
                chunk = bytes
        if chunk.len() == 0:
            return Err("EOF while reading {size} bytes")
        var i: u64 = 0
        while i < chunk.len():
            out.push(chunk[i])
            i = i + 1
    Ok(out)

fn _send_plain(sock: ClientSocket, payload: [u8]) -> Result<bool, text>:
    """Build and send a plaintext SSH packet."""
    var pkt: [u8] = _build_packet(payload)
    var r = _socket_send_all(sock, pkt)
    if r.is_err():
        var e: text = r.unwrap_err()
        return Err(e)
    Ok(true)

fn _recv_plain(sock: ClientSocket) -> Result<[u8], text>:
    """Receive one plaintext SSH packet and return its payload.

    Reads one complete SSH binary packet frame before parsing.
    """
    val header_result = _socket_recv_exact(sock, 5)
    if header_result.is_err():
        return Err(header_result.unwrap_err())
    var raw: [u8] = []
    match header_result:
        Err(_e):
            pass_dn
        Ok(header):
            raw = header
    val packet_length = ssh_get_u32(raw, 0).to_u64()
    if packet_length < 2:
        return Err("ssh: invalid plaintext packet length {packet_length}")
    val rest_result = _socket_recv_exact(sock, packet_length - 1)
    if rest_result.is_err():
        return Err(rest_result.unwrap_err())
    var rest: [u8] = []
    match rest_result:
        Err(_e):
            pass_dn
        Ok(bytes):
            rest = bytes
    var i: u64 = 0
    while i < rest.len():
        raw.push(rest[i])
        i = i + 1
    var pr = ssh_packet_read(raw, 0)
    if pr.is_err():
        var e: text = pr.unwrap_err()
        return Err(e)
    var parsed_packet = SshPacketResult(packet: SshPacket(payload: [], sequence: 0), consumed: 0)
    match pr:
        Err(_e):
            pass_dn
        Ok(packet_result):
            parsed_packet = packet_result
    Ok(parsed_packet.packet.payload)

fn _recv_version_line(sock: ClientSocket) -> Result<[u8], text>:
    """Read SSH identification bytes until CRLF."""
    var buf: [u8] = []
    while buf.len() < 256:
        var r = _socket_recv_some(sock, 1)
        if r.is_err():
            var e: text = r.unwrap_err()
            return Err(e)
        var chunk: [u8] = []
        match r:
            Err(_e):
                pass_dn
            Ok(bytes):
                chunk = bytes
        if chunk.len() == 0:
            return Err("EOF while reading version string")
        buf.push(chunk[0])
        var n = buf.len()
        if n >= 2 and buf[n - 2] == 0x0D and buf[n - 1] == 0x0A:
            return Ok(buf)
    Err("version string exceeded 256 bytes")

# ============================================================================
# Encrypted packet helpers
# ============================================================================

fn send_encrypted(sock: ClientSocket, cipher: SshCipher, enc_key: [u8], iv: [u8], payload: [u8]) -> Result<bool, text>:
    """Encrypt payload with C2S keys and send.

    SshCipher.encrypt_packet uses the s2c direction internally (server side).
    For client use we activate with swapped keys so that encrypt_packet
    actually applies the c2s key material.  See activate call below.
    """
    var enc: [u8] = cipher.encrypt_packet(payload, enc_key, iv)
    var r = _socket_send_all(sock, enc)
    if r.is_err():
        var e: text = r.unwrap_err()
        return Err(e)
    cipher.seq_s2c = (cipher.seq_s2c + 1) & 0xFFFFFFFF
    Ok(true)

fn recv_encrypted(sock: ClientSocket, cipher: SshCipher, enc_key: [u8], iv: [u8]) -> Result<[u8], text>:
    """Receive one AES-256-GCM encrypted SSH packet and return plaintext payload.

    Wire format (AES-256-GCM):
      4-byte packet_length (AAD, plaintext) || encrypted_body || 16-byte tag
    Total bytes to read: 4 + packet_length + 16
    """
    # Read the 4-byte length header first
    var r_len = _socket_recv_exact(sock, 4)
    if r_len.is_err():
        var e: text = r_len.unwrap_err()
        return Err(e)
    var len_bytes: [u8] = []
    match r_len:
        Err(_e):
            pass_dn
        Ok(bytes):
            len_bytes = bytes
    if len_bytes.len() < 4:
        return Err("recv_encrypted: short length read")

    var pkt_len: u64 = ssh_get_u32(len_bytes, 0).to_u64()

    # Read body + tag
    var body_len: u64 = pkt_len + 16
    var r_body = _socket_recv_exact(sock, body_len)
    if r_body.is_err():
        var e: text = r_body.unwrap_err()
        return Err(e)
    var body: [u8] = []
    match r_body:
        Err(_e):
            pass_dn
        Ok(bytes):
            body = bytes

    # Reassemble the full wire frame so decrypt_packet can see the AAD
    var frame: [u8] = []
    var i: u64 = 0
    while i < 4:
        frame.push(len_bytes[i])
        i = i + 1
    i = 0
    while i < body.len():
        frame.push(body[i])
        i = i + 1

    # decrypt_packet uses c2s direction internally; we activated with swapped
    # keys so that "c2s" in the cipher state holds the real s2c key material.
    var dr = cipher.decrypt_packet(frame, enc_key, iv)
    if dr.is_err():
        var e: text = dr.unwrap_err()
        return Err(e)
    cipher.seq_c2s = (cipher.seq_c2s + 1) & 0xFFFFFFFF
    var decrypted: [u8] = []
    match dr:
        Err(_e):
            pass_dn
        Ok(payload):
            decrypted = payload
    Ok(decrypted)

fn _recv_encrypted_skip_post_kex_metadata(sock: ClientSocket, cipher: SshCipher, enc_key: [u8], iv: [u8]) -> Result<[u8], text>:
    """Read one encrypted packet, skipping benign metadata/control messages.

    OpenSSH may send SSH_MSG_EXT_INFO immediately after NEWKEYS.  Accepting
    that keeps the client aligned with both OpenSSH and the in-tree server.
    """
    while true:
        val rr = recv_encrypted(sock, cipher, enc_key, iv)
        if rr.is_err():
            return Err(rr.unwrap_err())
        var payload: [u8] = []
        match rr:
            Err(_e):
                pass_dn
            Ok(bytes):
                payload = bytes
        if payload.len() == 0:
            return Ok(payload)
        val msg_type = payload[0]
        if msg_type == SSH_MSG_EXT_INFO or msg_type == SSH_MSG_IGNORE or msg_type == SSH_MSG_DEBUG:
            pass
        else:
            return Ok(payload)

# ============================================================================
# Argument parsing
# ============================================================================

fn _parse_decimal_port(raw: text) -> u64:
    """Parse a decimal TCP port. Returns 0 for invalid input."""
    if raw == "":
        return 0
    var out: u64 = 0
    for ch in raw:
        if ch < "0" or ch > "9":
            return 0
        out = out * 10 + (ch.to_i32() - "0".to_i32()).to_u64()
    if out == 0 or out > 65535:
        return 0
    out

fn _parse_args(args: [text]) -> Result<(text, text, u64), text>:
    """Parse [user@]host [-p port] args. Returns (user, host, port)."""
    var user = "root"
    var host = ""
    var port: u64 = 22

    var i: u64 = 0
    while i < args.len():
        var arg: text = args[i]
        if arg == "-p":
            i = i + 1
            if i >= args.len():
                return Err("ssh: -p requires a port number")
            var p_val: u64 = _parse_decimal_port(args[i])
            if p_val == 0:
                return Err("ssh: invalid port: {args[i]}")
            port = p_val
        else:
            if host == "":
                var at_idx = arg.find("@")
                if at_idx >= 0:
                    user = arg.slice(0, at_idx)
                    host = arg.slice(at_idx + 1, arg.len())
                else:
                    host = arg
        i = i + 1

    if host == "":
        return Err("ssh: missing host\nUsage: ssh [user@]host [-p port]")
    Ok((user, host, port))

# ============================================================================
# Phase 1 helpers: parse KEX_ECDH_REPLY fields
# ============================================================================

fn _parse_ecdh_reply(payload: [u8]) -> Result<([u8], [u8], text, [u8], [u8]), text>:
    """Parse SSH_MSG_KEX_ECDH_REPLY payload.

    Returns (host_key_blob, q_s, key_type, raw_pubkey, signature_bytes).
    host_key_blob is the raw blob for the exchange hash.
    key_type and raw_pubkey are extracted from inside the blob for verification.
    signature_bytes is the raw signature blob.
    """
    if payload.len() < 1:
        return Err("KEX_ECDH_REPLY: empty")
    if payload[0] != SSH_MSG_KEX_ECDH_REPLY:
        return Err("KEX_ECDH_REPLY: wrong msg type {payload[0]}")

    var off: u64 = 1

    # K_S: host key blob (string)
    var r_ks = ssh_get_string(payload, off)
    if r_ks.is_err():
        return Err("KEX_ECDH_REPLY: bad K_S")
    var ks_pair = SshStringResult(data: [], next_offset: 0)
    match r_ks:
        Err(_e):
            pass_dn
        Ok(pair):
            ks_pair = pair
    var host_key_blob: [u8] = ks_pair.data
    off = ks_pair.next_offset

    # Q_S: server ephemeral public key (string, 32 bytes)
    var r_qs = ssh_get_string(payload, off)
    if r_qs.is_err():
        return Err("KEX_ECDH_REPLY: bad Q_S")
    var qs_pair = SshStringResult(data: [], next_offset: 0)
    match r_qs:
        Err(_e):
            pass_dn
        Ok(pair):
            qs_pair = pair
    var q_s: [u8] = qs_pair.data
    off = qs_pair.next_offset

    # Signature blob (string)
    var r_sig = ssh_get_string(payload, off)
    if r_sig.is_err():
        return Err("KEX_ECDH_REPLY: bad signature blob")
    var sig_pair = SshStringResult(data: [], next_offset: 0)
    match r_sig:
        Err(_e):
            pass_dn
        Ok(pair):
            sig_pair = pair
    var sig_blob: [u8] = sig_pair.data

    # Extract key_type from inside host_key_blob
    var r_kt = ssh_get_text(host_key_blob, 0)
    if r_kt.is_err():
        return Err("KEX_ECDH_REPLY: bad key_type in K_S")
    var kt_pair = SshTextResult(value: "", next_offset: 0)
    match r_kt:
        Err(_e):
            pass_dn
        Ok(pair):
            kt_pair = pair
    var key_type: text = kt_pair.value
    var kt_off: u64 = kt_pair.next_offset

    # Raw public key bytes follow the key_type string
    var r_pk = ssh_get_string(host_key_blob, kt_off)
    if r_pk.is_err():
        return Err("KEX_ECDH_REPLY: bad pubkey in K_S")
    var pk_pair = SshStringResult(data: [], next_offset: 0)
    match r_pk:
        Err(_e):
            pass_dn
        Ok(pair):
            pk_pair = pair
    var raw_pubkey: [u8] = pk_pair.data

    # Extract raw signature bytes from inside sig_blob
    # sig_blob format: string sig_algo + string sig_bytes
    var r_sa = ssh_get_text(sig_blob, 0)
    if r_sa.is_err():
        return Err("KEX_ECDH_REPLY: bad sig algo")
    var sa_pair = SshTextResult(value: "", next_offset: 0)
    match r_sa:
        Err(_e):
            pass_dn
        Ok(pair):
            sa_pair = pair
    var sa_off: u64 = sa_pair.next_offset

    var r_sb = ssh_get_string(sig_blob, sa_off)
    if r_sb.is_err():
        return Err("KEX_ECDH_REPLY: bad sig bytes")
    var sb_pair = SshStringResult(data: [], next_offset: 0)
    match r_sb:
        Err(_e):
            pass_dn
        Ok(pair):
            sb_pair = pair
    var signature_bytes: [u8] = sb_pair.data

    Ok((host_key_blob, q_s, key_type, raw_pubkey, signature_bytes))

# ============================================================================
# Phase 4: build client-side USERAUTH_REQUEST (password)
# ============================================================================

fn _build_userauth_password(username: text, service: text, password: text) -> [u8]:
    """Build SSH_MSG_USERAUTH_REQUEST for password method.

    Format (RFC 4252):
      byte    SSH_MSG_USERAUTH_REQUEST (50)
      string  user name
      string  service name ("ssh-connection")
      string  method name ("password")
      bool    FALSE
      string  plaintext password
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_REQUEST)
    ssh_put_text(buf, username)
    ssh_put_text(buf, service)
    ssh_put_text(buf, "password")
    ssh_put_bool(buf, false)
    ssh_put_text(buf, password)
    buf

# ============================================================================
# Phase 4: build SSH_MSG_SERVICE_REQUEST
# ============================================================================

fn _build_service_request(service: text) -> [u8]:
    """Build SSH_MSG_SERVICE_REQUEST payload."""
    var buf: [u8] = []
    buf.push(SSH_MSG_SERVICE_REQUEST)
    ssh_put_text(buf, service)
    buf

# ============================================================================
# Phase 5: build CHANNEL_OPEN (session, client side)
# ============================================================================

fn _build_channel_open_session(local_id: u32) -> [u8]:
    """Build SSH_MSG_CHANNEL_OPEN for "session" type.

    Format (RFC 4254 section 5.1):
      byte    SSH_MSG_CHANNEL_OPEN (90)
      string  channel type ("session")
      uint32  sender channel (our local ID)
      uint32  initial window size
      uint32  maximum packet size
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_CHANNEL_OPEN)
    ssh_put_text(buf, "session")
    ssh_put_u32(buf, local_id)
    ssh_put_u32(buf, DEFAULT_WINDOW_SIZE)
    ssh_put_u32(buf, DEFAULT_MAX_PACKET)
    buf

# ============================================================================
# Phase 5: build CHANNEL_REQUEST helpers
# ============================================================================

fn _build_channel_request_pty(remote_id: u32) -> [u8]:
    """Build SSH_MSG_CHANNEL_REQUEST "pty-req" (RFC 4254 section 6.2).

    Requests an xterm pseudo-terminal with 80 columns x 24 rows.
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_CHANNEL_REQUEST)
    ssh_put_u32(buf, remote_id)
    ssh_put_text(buf, "pty-req")
    ssh_put_bool(buf, false)        # want reply = false (keep it simple)
    ssh_put_text(buf, "xterm")      # TERM environment variable value
    ssh_put_u32(buf, 80)            # terminal width (columns)
    ssh_put_u32(buf, 24)            # terminal height (rows)
    ssh_put_u32(buf, 0)             # terminal width (pixels)
    ssh_put_u32(buf, 0)             # terminal height (pixels)
    ssh_put_string(buf, [])         # encoded terminal modes (empty)
    buf

fn _build_channel_request_shell(remote_id: u32) -> [u8]:
    """Build SSH_MSG_CHANNEL_REQUEST "shell" (RFC 4254 section 6.5)."""
    var buf: [u8] = []
    buf.push(SSH_MSG_CHANNEL_REQUEST)
    ssh_put_u32(buf, remote_id)
    ssh_put_text(buf, "shell")
    ssh_put_bool(buf, false)        # want reply = false
    buf

# ============================================================================
# Main entry point
# ============================================================================
