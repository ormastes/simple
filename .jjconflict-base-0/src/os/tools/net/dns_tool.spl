use os.userlib.net.{SockAddr, Socket, socket, send, recv}

## DNS lookup tool.
## Usage: dns HOSTNAME [A|AAAA|MX|TXT]

val DNS_PORT = 53
val DEFAULT_NAMESERVER = "10.0.2.3"

fn _record_type_to_code(rtype: text) -> i32:
    if rtype == "A": 1
    else if rtype == "AAAA": 28
    else if rtype == "MX": 15
    else if rtype == "TXT": 16
    else: 1

fn _build_dns_query(hostname: text, rtype: i32) -> [u8]:
    ## Build minimal DNS query packet
    var packet: [u8] = []

    ## Header: ID=0xABCD, flags=0x0100 (standard query, recursion desired)
    packet = packet + [0xAB, 0xCD, 0x01, 0x00]
    ## QDCOUNT=1, ANCOUNT=0, NSCOUNT=0, ARCOUNT=0
    packet = packet + [0x00, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]

    ## Question: encode hostname as labels
    val parts = hostname.split(".")
    for part in parts:
        packet.push(part.len())
        for ch in part.bytes():
            packet.push(ch)
    packet.push(0)

    ## Type
    packet.push((rtype >> 8) & 0xFF)
    packet.push(rtype & 0xFF)
    ## Class IN
    packet.push(0x00)
    packet.push(0x01)

    packet

fn _parse_dns_response(data: [u8], rtype: text) -> [text]:
    ## Simplified DNS response parser
    var results: [text] = []

    if data.len() < 12:
        return results

    val ancount = (data[6] << 8) | data[7]
    if ancount == 0:
        return results

    ## Skip header (12 bytes) and question section
    var offset = 12
    ## Skip question QNAME
    while offset < data.len() and data[offset] != 0:
        offset = offset + data[offset] + 1
    offset = offset + 5  ## null byte + QTYPE(2) + QCLASS(2)

    ## Parse answer records
    var i = 0
    while i < ancount and offset < data.len():
        ## Skip name (may be pointer)
        if (data[offset] & 0xC0) == 0xC0:
            offset = offset + 2
        else:
            while offset < data.len() and data[offset] != 0:
                offset = offset + data[offset] + 1
            offset = offset + 1

        if offset + 10 > data.len():
            break

        val rdlength = (data[offset + 8] << 8) | data[offset + 9]
        offset = offset + 10

        if rtype == "A" and rdlength == 4 and offset + 4 <= data.len():
            val a = data[offset]
            val b = data[offset + 1]
            val c = data[offset + 2]
            val d = data[offset + 3]
            results.push("{a}.{b}.{c}.{d}")

        offset = offset + rdlength
        i = i + 1

    results

fn _print_usage():
    print "Usage: dns HOSTNAME [A|AAAA|MX|TXT]"
    print ""
    print "Perform DNS lookup. Default record type: A"

fn run_dns(args: [text]) -> i32:
    if args.len() == 0:
        _print_usage()
        return 1

    if args[0] == "-h":
        _print_usage()
        return 0

    val hostname = args[0]
    val rtype = if args.len() >= 2: args[1].upper() else: "A"
    val rcode = _record_type_to_code(rtype)

    val query = _build_dns_query(hostname, rcode)
    val sock = socket("udp")
    val addr = SockAddr(host: DEFAULT_NAMESERVER, port: DNS_PORT)

    send(sock, addr, query)
    val response = recv(sock, 512, 5000)

    if response.len() == 0:
        print "dns: no response from {DEFAULT_NAMESERVER}"
        return 1

    val results = _parse_dns_response(response, rtype)

    if results.len() == 0:
        print "dns: no {rtype} records found for {hostname}"
        return 1

    print "DNS lookup: {hostname} (type {rtype})"
    for record in results:
        print "  {record}"

    0
