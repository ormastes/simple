# traceroute — Trace packet route
# MDSOC: feature dimension, apps layer

use os.userlib.net.{SockAddr, Socket, socket, send, recv}

fn run_traceroute(args: [text]) -> i32:
    """Trace the route to a host.

    Usage: traceroute HOST
    Sends ICMP packets with increasing TTL.
    """
    if args.len() == 0:
        print "traceroute: missing host"
        return 1

    val host = args[0]
    val max_hops: i32 = 30
    print "traceroute to {host}, {max_hops} hops max"

    var ttl: i32 = 1
    while ttl <= max_hops:
        # Build ICMP echo with TTL
        val sock = socket("icmp")
        val addr = SockAddr(host: host, port: 0)

        # Send probe
        val probe: [u8] = [8, 0, 0, 0, 0, 0, 0, 0]
        send(sock, addr, probe)

        val reply = recv(sock, 64, 3000)
        if reply.len() > 0:
            print " {ttl}  {host}  *"
            if ttl > 1:
                return 0
        else:
            print " {ttl}  * * *"

        ttl = ttl + 1

    return 0
