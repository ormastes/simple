# Kill Tool — Send Signals
# MDSOC: feature dimension, apps layer

use os.userlib.process.{signal, kill}
use os.kernel.types.syscall_types.{SignalKind}

fn run_kill(args: [text]) -> i32:
    """Entry point for kill command.

    Usage: kill [-TERM|-KILL|-STOP|-CONT|-INT] PID
    Default signal is TERM.
    """
    if args.len() > 0 and (args[0] == "-h" or args[0] == "--help"):
        print "usage: kill [-TERM|-KILL|-STOP|-CONT|-INT] PID"
        return 0

    var sig = SignalKind.Term
    var pid_str: text? = nil
    var i = 0

    while i < args.len():
        val arg = args[i]
        if arg.starts_with("-"):
            sig = _parse_signal(arg)
        else:
            pid_str = Some(arg)
        i = i + 1

    if pid_str.? == false:
        print "usage: kill [-TERM|-KILL|-STOP|-CONT|-INT] PID"
        return 1

    val pid_result = _parse_pid(pid_str.unwrap())
    if val Err(e) = pid_result:
        print "error: {e}"
        return 1

    val pid = pid_result.unwrap()
    val result = signal(pid, sig)
    if val Err(e) = result:
        print "error: failed to send signal to PID {pid}: {e}"
        return 1

    0

fn _parse_signal(flag: text) -> SignalKind:
    val upper = flag.to_upper()
    match upper:
        "-TERM": SignalKind.Term
        "-KILL": SignalKind.Kill
        "-STOP": SignalKind.Stop
        "-CONT": SignalKind.Cont
        "-INT": SignalKind.Int
        _:
            print "warning: unknown signal '{flag}', using TERM"
            SignalKind.Term

fn _parse_pid(s: text) -> Result<u64, text>:
    val n = s.parse_u64()
    if val Some(pid) = n:
        Ok(pid)
    else:
        Err("invalid PID: {s}")
