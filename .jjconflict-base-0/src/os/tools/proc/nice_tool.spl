# Nice Tool — Priority Adjustment
# MDSOC: feature dimension, apps layer

use os.userlib.process.{set_priority, get_task_info}

fn run_nice(args: [text]) -> i32:
    """Entry point for nice command.

    Usage: nice -p PID -n PRIORITY
    PRIORITY: 0=Realtime, 1=High, 2=Normal, 3=Low, 4=Idle
    """
    if args.len() > 0 and (args[0] == "-h" or args[0] == "--help"):
        print "usage: nice -p PID -n PRIORITY"
        print "  PRIORITY: 0=Realtime, 1=High, 2=Normal, 3=Low, 4=Idle"
        return 0

    var pid: u64? = nil
    var priority: u8? = nil
    var i = 0

    while i < args.len():
        val arg = args[i]
        if arg == "-p":
            i = i + 1
            if i >= args.len():
                print "error: -p requires a PID"
                return 1
            val parsed = args[i].parse_u64()
            if val Some(v) = parsed:
                pid = Some(v)
            else:
                print "error: invalid PID '{args[i]}'"
                return 1
        else if arg == "-n":
            i = i + 1
            if i >= args.len():
                print "error: -n requires a priority value"
                return 1
            val parsed = args[i].parse_u8()
            if val Some(v) = parsed:
                if v > 4:
                    print "error: priority must be 0-4 (0=Realtime, 1=High, 2=Normal, 3=Low, 4=Idle)"
                    return 1
                priority = Some(v)
            else:
                print "error: invalid priority '{args[i]}'"
                return 1
        i = i + 1

    if pid.? == false or priority.? == false:
        print "usage: nice -p PID -n PRIORITY"
        print "  PRIORITY: 0=Realtime, 1=High, 2=Normal, 3=Low, 4=Idle"
        return 1

    val target_pid = pid.unwrap()
    val target_priority = priority.unwrap()

    # Show current priority before change
    val info_result = get_task_info(target_pid)
    if val Ok(info) = info_result:
        print "PID {target_pid} ({info.name}): current priority = {_format_priority(info.priority)}"

    val result = set_priority(target_pid, target_priority)
    if val Err(e) = result:
        print "error: failed to set priority for PID {target_pid}: {e}"
        return 1

    print "PID {target_pid}: priority set to {_format_priority(target_priority)}"
    0

fn _format_priority(priority: u8) -> text:
    match priority:
        0: "Realtime"
        1: "High"
        2: "Normal"
        3: "Low"
        4: "Idle"
        _: "?"
