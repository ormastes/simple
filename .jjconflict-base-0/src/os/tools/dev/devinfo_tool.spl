use os.userlib.device.{DeviceEntry, enumerate_devices, device_class_name}
use os.userlib.fs.{mount_list}
use os.userlib.net.{ifconfig}
use os.userlib.system.{sysinfo, mem_info, hostname}

## Display combined system and device information.

fn _format_memory(bytes: u64) -> text:
    if bytes >= 1073741824:
        val gb = bytes / 1073741824
        "{gb} GB"
    else if bytes >= 1048576:
        val mb = bytes / 1048576
        "{mb} MB"
    else:
        val kb = bytes / 1024
        "{kb} KB"

fn _print_system_info():
    val host = hostname()
    val info = sysinfo()
    val mem = mem_info()

    print "=== System Information ==="
    print "Hostname:    {host}"
    print "CPUs:        {info.cpu_count}"
    print "Memory:      {_format_memory(mem.total)} total, {_format_memory(mem.used)} used, {_format_memory(mem.free)} free"
    print "Uptime:      {info.uptime_seconds}s"
    print ""

fn _print_pci_summary():
    val devices = enumerate_devices()
    print "=== PCI Devices ({devices.len()}) ==="
    for entry in devices:
        val class_name = device_class_name(entry.class_code)
        val vendor = entry.vendor_id
        val dev_id = entry.device_id
        print "  {class_name}: {vendor:04x}:{dev_id:04x}"
    print ""

fn _print_block_devices():
    val devices = enumerate_devices()
    val mounts = mount_list()
    var count = 0

    print "=== Block Devices ==="
    for entry in devices:
        if entry.class_code == 0x01:
            val name = entry.name
            print "  {name}"
            count = count + 1

    if count == 0:
        print "  (none)"
    print ""

fn _print_network_interfaces():
    val ifaces = ifconfig()
    print "=== Network Interfaces ({ifaces.len()}) ==="
    for iface in ifaces:
        val name = iface.name
        val addr = iface.address
        val status = iface.status
        print "  {name}: {addr} ({status})"
    print ""

fn _print_usage():
    print "Usage: devinfo [-h]"
    print ""
    print "Display combined system and device information."

fn run_devinfo(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_usage()
            return 0

    _print_system_info()
    _print_pci_summary()
    _print_block_devices()
    _print_network_interfaces()

    0
