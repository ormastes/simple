# VMM user copy-in and pointer verification — split from vmm.spl.
# Contains user pointer verification structs and all vmm_copyin_* / vmm_verify_*
# functions for safe kernel reads from user-space virtual addresses.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, PageFrame, VmFlags, phys_addr_value, virt_addr_value}
use os.kernel.types.vmspace_types.{VmArea, ProcessVmSpace}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read64, mmio_write64}
use os.kernel.memory.vmm_core.{
    PAGE_SIZE, VMM_KERNEL_SPACE_START, VMM_U64_MAX,
    PTE_PRESENT, PTE_USER, PTE_WRITABLE, PTE_HUGE_PAGE, PTE_ADDR_MASK,
    g_vmm, vmm_kernel_pml4_phys, _phys_to_virt, _read_pte, _pte_is_present, _pte_phys_addr,
    _pml4_index, _pdpt_index, _pd_index, _pt_index,
    vmm_translate, vmm_read_pte
}
use os.kernel.memory.vmm_vma.{vma_find}

# ============================================================================
# User Pointer Verification (copy_to_user guard)
# ============================================================================

struct VmmUserCopyStatus:
    """Status returned by VMM user copy-in helpers."""
    ok: bool
    errno: i32
    bytes_read: u64

struct VmmCopyBytesResult:
    status: VmmUserCopyStatus
    bytes: [u8]

struct VmmCopyU64Result:
    status: VmmUserCopyStatus
    value: u64

struct VmmCopyCstrResult:
    status: VmmUserCopyStatus
    value: text

struct VmmCopyStringVectorResult:
    status: VmmUserCopyStatus
    values: [text]

struct VmmPtWalkResult:
    """Result of translating one user virtual address through a ProcessVmSpace."""
    ok: bool
    kernel_ptr: u64
    bytes_until_page_end: u64

struct VmmCopyTestWord:
    addr: u64
    value: u64

var g_vmm_copy_test_words: [VmmCopyTestWord] = []

fn vmm_copy_clear_test_words():
    """Test hook: clear synthetic RAM words used by hosted copy-in specs."""
    g_vmm_copy_test_words = []

fn vmm_copy_set_test_word(addr: u64, value: u64):
    """Test hook: install one synthetic RAM/page-table word for hosted specs."""
    var i = 0
    while i < g_vmm_copy_test_words.len():
        if g_vmm_copy_test_words[i].addr == addr:
            g_vmm_copy_test_words[i] = VmmCopyTestWord(addr: addr, value: value)
            return
        i = i + 1
    g_vmm_copy_test_words.push(VmmCopyTestWord(addr: addr, value: value))

fn _vmm_copy_test_word(addr: u64) -> u64?:
    var i = 0
    while i < g_vmm_copy_test_words.len():
        if g_vmm_copy_test_words[i].addr == addr:
            return Some(g_vmm_copy_test_words[i].value)
        i = i + 1
    nil

fn _vmm_copy_test_words_active() -> bool:
    g_vmm_copy_test_words.len() > 0

fn vmm_copy_bytes_result_ok(result: VmmCopyBytesResult) -> bool:
    result.status.ok

fn vmm_copy_string_vector_result_ok(result: VmmCopyStringVectorResult) -> bool:
    result.status.ok

fn vmm_copy_string_vector_result_errno(result: VmmCopyStringVectorResult) -> i32:
    result.status.errno

fn vmm_copy_string_vector_result_values(result: VmmCopyStringVectorResult) -> [text]:
    result.values

fn _vmm_copy_ok(bytes_read: u64) -> VmmUserCopyStatus:
    VmmUserCopyStatus(ok: true, errno: 0, bytes_read: bytes_read)

fn _vmm_copy_err(errno: i32, bytes_read: u64) -> VmmUserCopyStatus:
    VmmUserCopyStatus(ok: false, errno: errno, bytes_read: bytes_read)

fn _vmm_copy_bytes_err(errno: i32) -> VmmCopyBytesResult:
    VmmCopyBytesResult(status: _vmm_copy_err(errno, 0), bytes: [])

fn _vmm_copy_u64_err(errno: i32) -> VmmCopyU64Result:
    VmmCopyU64Result(status: _vmm_copy_err(errno, 0), value: 0)

fn _vmm_copy_cstr_err(errno: i32, bytes_read: u64) -> VmmCopyCstrResult:
    VmmCopyCstrResult(status: _vmm_copy_err(errno, bytes_read), value: "")

fn _vmm_copy_vector_err(errno: i32, bytes_read: u64) -> VmmCopyStringVectorResult:
    VmmCopyStringVectorResult(status: _vmm_copy_err(errno, bytes_read), values: [])

fn _vmm_is_userspace_ptr(ptr: u64) -> bool:
    ptr != 0 and ptr < VMM_KERNEL_SPACE_START

fn _vmm_is_userspace_range(ptr: u64, size: u64) -> bool:
    if ptr == 0 or size == 0:
        return false
    if size > VMM_U64_MAX - ptr:
        return false
    val end = ptr + size - 1
    if end < ptr:
        return false
    _vmm_is_userspace_ptr(ptr) and _vmm_is_userspace_ptr(end)

fn _vmm_read_physmap_byte(addr: u64) -> u8:
    """Read a byte from RAM-backed physmap memory using available word MMIO."""
    val aligned = addr - (addr % 8)
    val shift = (addr % 8) * 8
    val synthetic = _vmm_copy_test_word(aligned)
    if val Some(word) = synthetic:
        return ((word >> shift) & 0xFF).to_u8()
    if _vmm_copy_test_words_active():
        return 0u8
    val word = mmio_read64(aligned)
    ((word >> shift) & 0xFF).to_u8()

fn _vmm_read_pte_word(table_virt: u64, index: u64) -> u64:
    val addr = table_virt + (index * 8)
    val synthetic = _vmm_copy_test_word(addr)
    if val Some(word) = synthetic:
        return word
    if _vmm_copy_test_words_active():
        return 0
    _read_pte(table_virt, index)

fn _vmm_verify_user_access(addr: u64, size: u64, required_bits: u64) -> bool:
    if not _vmm_is_userspace_range(addr, size):
        return false
    val last = addr + size - 1
    var page = addr - (addr % PAGE_SIZE)
    val last_page = last - (last % PAGE_SIZE)
    while page <= last_page:
        if not _vmm_check_pte_flags(page, required_bits):
            return false
        if page == last_page:
            return true
        page = page + PAGE_SIZE
    true

fn vmm_verify_user_read(addr: u64, size: u64) -> bool:
    """Verify that [addr, addr+size) is mapped as user-readable."""
    _vmm_verify_user_access(addr, size, PTE_PRESENT | PTE_USER)

fn _vmm_pt_walk(space: ProcessVmSpace, vaddr: u64, required_bits: u64) -> VmmPtWalkResult:
    """Translate one user VA in `space` to a kernel-readable physmap pointer."""
    if space.pml4 == 0:
        return VmmPtWalkResult(ok: false, kernel_ptr: 0, bytes_until_page_end: 0)
    if not _vmm_is_userspace_ptr(vaddr):
        return VmmPtWalkResult(ok: false, kernel_ptr: 0, bytes_until_page_end: 0)

    val pml4_virt = _phys_to_virt(space.pml4)
    val pml4_entry = _vmm_read_pte_word(pml4_virt, _pml4_index(vaddr))
    if (pml4_entry & required_bits) != required_bits:
        return VmmPtWalkResult(ok: false, kernel_ptr: 0, bytes_until_page_end: 0)

    val pdpt_virt = _phys_to_virt(_pte_phys_addr(pml4_entry))
    val pdpt_entry = _vmm_read_pte_word(pdpt_virt, _pdpt_index(vaddr))
    if (pdpt_entry & required_bits) != required_bits:
        return VmmPtWalkResult(ok: false, kernel_ptr: 0, bytes_until_page_end: 0)

    val pd_virt = _phys_to_virt(_pte_phys_addr(pdpt_entry))
    val pd_entry = _vmm_read_pte_word(pd_virt, _pd_index(vaddr))
    if (pd_entry & required_bits) != required_bits:
        return VmmPtWalkResult(ok: false, kernel_ptr: 0, bytes_until_page_end: 0)

    if (pd_entry & PTE_HUGE_PAGE) != 0:
        val offset = vaddr & 0x1FFFFF
        return VmmPtWalkResult(
            ok: true,
            kernel_ptr: _phys_to_virt(_pte_phys_addr(pd_entry) + offset),
            bytes_until_page_end: 0x200000 - offset
        )

    val pt_virt = _phys_to_virt(_pte_phys_addr(pd_entry))
    val pt_entry = _vmm_read_pte_word(pt_virt, _pt_index(vaddr))
    if (pt_entry & required_bits) != required_bits:
        return VmmPtWalkResult(ok: false, kernel_ptr: 0, bytes_until_page_end: 0)

    val page_offset = vaddr & 0xFFF
    VmmPtWalkResult(
        ok: true,
        kernel_ptr: _phys_to_virt(_pte_phys_addr(pt_entry) + page_offset),
        bytes_until_page_end: PAGE_SIZE - page_offset
    )

fn vmm_pt_walk_user_read(space: ProcessVmSpace, vaddr: u64) -> u64?:
    """Translate one readable user VA in an explicit address space."""
    if space.vma_count > 0:
        val area = vma_find(space, vaddr)
        if area == nil:
            return nil
        if (area.flags & 1) == 0:
            return nil
    val walked = _vmm_pt_walk(space, vaddr, PTE_PRESENT | PTE_USER)
    if not walked.ok:
        return nil
    walked.kernel_ptr

fn vmm_pt_range_user_readable(space: ProcessVmSpace, ptr: u64, len: u64) -> bool:
    """Return true when every page in [ptr, ptr+len) translates for read."""
    if ptr == 0 or len == 0 or ptr + len < ptr:
        return false
    var copied: u64 = 0
    while copied < len:
        val current = ptr + copied
        if space.vma_count > 0:
            val area = vma_find(space, current)
            if area == nil:
                return false
            if (area.flags & 1) == 0:
                return false
        val walked = _vmm_pt_walk(space, current, PTE_PRESENT | PTE_USER)
        if not walked.ok:
            return false
        copied = copied + walked.bytes_until_page_end
    true

fn vmm_pt_range_user_writable(space: ProcessVmSpace, ptr: u64, len: u64) -> bool:
    """Return true when every page in [ptr, ptr+len) translates for write."""
    if ptr == 0 or len == 0 or ptr + len < ptr:
        return false
    var copied: u64 = 0
    while copied < len:
        val current = ptr + copied
        if space.vma_count > 0:
            val area = vma_find(space, current)
            if area == nil:
                return false
            if (area.flags & 2) == 0:
                return false
        val walked = _vmm_pt_walk(space, current, PTE_PRESENT | PTE_USER | PTE_WRITABLE)
        if not walked.ok:
            return false
        copied = copied + walked.bytes_until_page_end
    true

fn vmm_copyin_bytes_from_space(space: ProcessVmSpace, ptr: u64, len: u64) -> VmmCopyBytesResult:
    """Copy an exact byte range through an explicit address-space page walk."""
    if ptr == 0:
        return _vmm_copy_bytes_err(14)
    if len == 0:
        return VmmCopyBytesResult(status: _vmm_copy_ok(0), bytes: [])
    if ptr + len < ptr:
        return _vmm_copy_bytes_err(14)
    if not vmm_pt_range_user_readable(space, ptr, len):
        return _vmm_copy_bytes_err(14)

    var bytes: [u8] = []
    var copied: u64 = 0
    while copied < len:
        val current = ptr + copied
        if space.vma_count > 0:
            val area = vma_find(space, current)
            if area == nil:
                return _vmm_copy_bytes_err(14)
            if (area.flags & 1) == 0:
                return _vmm_copy_bytes_err(14)
        val walked = _vmm_pt_walk(space, current, PTE_PRESENT | PTE_USER)
        if not walked.ok:
            return _vmm_copy_bytes_err(14)
        var chunk = walked.bytes_until_page_end
        val remaining = len - copied
        if chunk > remaining:
            chunk = remaining
        var i: u64 = 0
        while i < chunk:
            bytes.push(_vmm_read_physmap_byte(walked.kernel_ptr + i))
            i = i + 1
        copied = copied + chunk

    VmmCopyBytesResult(status: _vmm_copy_ok(len), bytes: bytes)

fn _vmm_bytes_to_text(bytes: [u8]) -> text:
    var chars: [text] = []
    for b in bytes:
        chars.push((b.to_i64()).to_char())
    chars.join("")

fn _vmm_copyin_current_byte(ptr: u64) -> u8?:
    """Read one byte from the current userspace mapping through page tables."""
    val translated = vmm_translate(VirtAddr(addr: ptr))
    if val Some(phys) = translated:
        return _vmm_read_physmap_byte(_phys_to_virt(phys_addr_value(phys)))
    nil

fn vmm_copyin_bytes(ptr: u64, len: u64) -> VmmCopyBytesResult:
    """Copy an exact byte range from userspace into kernel-owned memory."""
    if ptr == 0:
        return _vmm_copy_bytes_err(14)
    if len == 0:
        return VmmCopyBytesResult(status: _vmm_copy_ok(0), bytes: [])
    if not vmm_verify_user_read(ptr, len):
        return _vmm_copy_bytes_err(14)

    var bytes: [u8] = []
    var i: u64 = 0
    while i < len:
        val current = ptr + i
        if current < ptr:
            return _vmm_copy_bytes_err(14)
        val read = _vmm_copyin_current_byte(current)
        if val Some(byte) = read:
            bytes.push(byte)
        else:
            return _vmm_copy_bytes_err(14)
        i = i + 1

    VmmCopyBytesResult(status: _vmm_copy_ok(len), bytes: bytes)

fn vmm_copyin_u64(ptr: u64) -> VmmCopyU64Result:
    """Copy a little-endian u64 from userspace."""
    if ptr == 0:
        return _vmm_copy_u64_err(14)
    if not vmm_verify_user_read(ptr, 8):
        return _vmm_copy_u64_err(14)

    var value: u64 = 0
    var i: u64 = 0
    while i < 8:
        val current = ptr + i
        if current < ptr:
            return _vmm_copy_u64_err(14)
        val read = _vmm_copyin_current_byte(current)
        if val Some(byte) = read:
            value = value | (byte.to_u64() << (i * 8))
        else:
            return _vmm_copy_u64_err(14)
        i = i + 1

    VmmCopyU64Result(status: _vmm_copy_ok(8), value: value)

fn vmm_copyin_cstr(ptr: u64, max_len: u64) -> VmmCopyCstrResult:
    """Copy a NUL-terminated userspace string, bounded by max_len bytes."""
    if ptr == 0:
        return _vmm_copy_cstr_err(14, 0)

    var bytes: [u8] = []
    var i: u64 = 0
    while i < max_len:
        val current = ptr + i
        if current < ptr:
            return _vmm_copy_cstr_err(14, i)
        if not vmm_verify_user_read(current, 1):
            return _vmm_copy_cstr_err(14, i)
        val read = _vmm_copyin_current_byte(current)
        if val Some(b) = read:
            if b == 0u8:
                return VmmCopyCstrResult(
                    status: _vmm_copy_ok(i + 1),
                    value: _vmm_bytes_to_text(bytes)
                )
            bytes.push(b)
        else:
            return _vmm_copy_cstr_err(14, i)
        i = i + 1

    _vmm_copy_cstr_err(7, i)

fn vmm_copyin_string_vector(
    vec_ptr: u64,
    max_count: u64,
    max_string_len: u64,
    max_total_bytes: u64
) -> VmmCopyStringVectorResult:
    """Copy a NUL-terminated userspace char** vector into kernel text values."""
    if vec_ptr == 0:
        return VmmCopyStringVectorResult(status: _vmm_copy_ok(0), values: [])

    var out: [text] = []
    var total_bytes: u64 = 0
    var bytes_read: u64 = 0
    var i: u64 = 0
    while i < max_count:
        if i > (VMM_U64_MAX / 8):
            return _vmm_copy_vector_err(14, bytes_read)
        val offset = i * 8
        val slot = vec_ptr + offset
        if slot < vec_ptr:
            return _vmm_copy_vector_err(14, bytes_read)

        val item_ptr_result = vmm_copyin_u64(slot)
        if not item_ptr_result.status.ok:
            return _vmm_copy_vector_err(item_ptr_result.status.errno, bytes_read)
        if bytes_read > VMM_U64_MAX - 8:
            return _vmm_copy_vector_err(7, bytes_read)
        bytes_read = bytes_read + 8

        val item_ptr = item_ptr_result.value
        if item_ptr == 0:
            return VmmCopyStringVectorResult(status: _vmm_copy_ok(bytes_read), values: out)

        val item_result = vmm_copyin_cstr(item_ptr, max_string_len)
        if not item_result.status.ok:
            if bytes_read > VMM_U64_MAX - item_result.status.bytes_read:
                return _vmm_copy_vector_err(7, bytes_read)
            return _vmm_copy_vector_err(item_result.status.errno, bytes_read + item_result.status.bytes_read)

        val item_bytes = item_result.status.bytes_read
        if total_bytes + item_bytes < total_bytes:
            return _vmm_copy_vector_err(7, bytes_read)
        total_bytes = total_bytes + item_bytes
        if total_bytes > max_total_bytes:
            if bytes_read > VMM_U64_MAX - item_bytes:
                return _vmm_copy_vector_err(7, bytes_read)
            return _vmm_copy_vector_err(7, bytes_read + item_bytes)

        if bytes_read > VMM_U64_MAX - item_bytes:
            return _vmm_copy_vector_err(7, bytes_read)
        bytes_read = bytes_read + item_bytes
        out.push(item_result.value)
        i = i + 1

    _vmm_copy_vector_err(7, bytes_read)

fn vmm_copyin_packed_string_vector(
    base_ptr: u64,
    table_offset: u64,
    max_count: u64,
    max_string_len: u64,
    max_total_bytes: u64
) -> VmmCopyStringVectorResult:
    """Copy Simple's packed [strings...][offset table] vector from userspace."""
    if base_ptr == 0:
        return VmmCopyStringVectorResult(status: _vmm_copy_ok(0), values: [])
    if table_offset > VMM_U64_MAX - base_ptr:
        return _vmm_copy_vector_err(14, 0)

    val table_ptr = base_ptr + table_offset
    var out: [text] = []
    var total_bytes: u64 = 0
    var bytes_read: u64 = 0
    var i: u64 = 0
    while i < max_count:
        if i > (VMM_U64_MAX / 8):
            return _vmm_copy_vector_err(14, bytes_read)
        val slot = table_ptr + i * 8
        if slot < table_ptr:
            return _vmm_copy_vector_err(14, bytes_read)
        val off_result = vmm_copyin_u64(slot)
        if not off_result.status.ok:
            return _vmm_copy_vector_err(off_result.status.errno, bytes_read)
        bytes_read = bytes_read + 8

        val off = off_result.value
        if off == 0 and i > 0:
            return VmmCopyStringVectorResult(status: _vmm_copy_ok(bytes_read), values: out)
        if off > VMM_U64_MAX - base_ptr:
            return _vmm_copy_vector_err(14, bytes_read)
        val item_result = vmm_copyin_cstr(base_ptr + off, max_string_len)
        if not item_result.status.ok:
            return _vmm_copy_vector_err(item_result.status.errno, bytes_read + item_result.status.bytes_read)
        val item_bytes = item_result.status.bytes_read
        total_bytes = total_bytes + item_bytes
        if total_bytes > max_total_bytes:
            return _vmm_copy_vector_err(7, bytes_read + item_bytes)
        bytes_read = bytes_read + item_bytes
        out.push(item_result.value)
        i = i + 1

    _vmm_copy_vector_err(7, bytes_read)

fn vmm_verify_user_write(addr: u64, size: u64) -> bool:
    """Verify that [addr, addr+size) is mapped as user-writable."""
    if size == 0:
        return false
    val required_bits = PTE_PRESENT | PTE_USER | PTE_WRITABLE
    var offset: u64 = 0
    val end = addr + size
    while addr + offset < end:
        val vaddr = addr + offset
        if not _vmm_check_pte_flags(vaddr, required_bits):
            return false
        offset = offset + PAGE_SIZE
    true

fn _vmm_check_pte_flags(vaddr: u64, required_bits: u64) -> bool:
    """Walk page tables and verify the leaf PTE has all required_bits set."""
    val pml4_virt = _phys_to_virt(vmm_kernel_pml4_phys())

    val pml4_entry = _read_pte(pml4_virt, _pml4_index(vaddr))
    if not _pte_is_present(pml4_entry):
        return false

    val pdpt_virt = _phys_to_virt(_pte_phys_addr(pml4_entry))
    val pdpt_entry = _read_pte(pdpt_virt, _pdpt_index(vaddr))
    if not _pte_is_present(pdpt_entry):
        return false

    val pd_virt = _phys_to_virt(_pte_phys_addr(pdpt_entry))
    val pd_entry = _read_pte(pd_virt, _pd_index(vaddr))
    if not _pte_is_present(pd_entry):
        return false

    if (pd_entry & PTE_HUGE_PAGE) != 0:
        return (pd_entry & required_bits) == required_bits

    val pt_virt = _phys_to_virt(_pte_phys_addr(pd_entry))
    val pt_entry = _read_pte(pt_virt, _pt_index(vaddr))
    if not _pte_is_present(pt_entry):
        return false

    (pt_entry & required_bits) == required_bits
