use os.drivers.pci.pci.{pci_read_config, pci_read_vendor, pci_read_device_id, pci_read_class, pci_read_header_type, pci_read_bar, pci_write_config}
use os.drivers.pci.pci_bar64.{pci_bar64_decode, pci_function_is_qemu_ivshmem}

@cfg(x86_64)
fn _direct_boot_ivshmem_window_base(device: u8) -> u64:
    0xC000000000u64 + device.to_u64() * 0x01000000u64

@cfg(arm64)
fn _direct_boot_ivshmem_window_base(device: u8) -> u64:
    0x3E000000u64

@cfg(riscv64)
fn _direct_boot_ivshmem_window_base(device: u8) -> u64:
    0x60000000u64 + device.to_u64() * 0x01000000u64

@cfg(x86_64)
fn _direct_boot_ivshmem_window_valid(base: u64, size: u64) -> bool:
    base >= 0xC000000000u64 and base + size <= 0xC040000000u64

@cfg(arm64)
fn _direct_boot_ivshmem_window_valid(base: u64, size: u64) -> bool:
    base == 0x3E000000u64 and size == 0x00800000u64

@cfg(riscv64)
fn _direct_boot_ivshmem_window_valid(base: u64, size: u64) -> bool:
    base >= 0x60000000u64 and base + size <= 0x80000000u64

fn _map_qemu_ivshmem_bar64(bus: u8, dev: u8, func: u8, bar_index: u8) -> i64:
    val low_offset = (0x10u32 + bar_index.to_u32() * 4u32).to_u8()
    val high_offset = (low_offset.to_u32() + 4u32).to_u8()
    val raw_low = pci_read_bar(bus, dev, func, bar_index)
    val raw_high = pci_read_bar(bus, dev, func, bar_index + 1u8)
    val command_status = pci_read_config(bus, dev, func, 0x04u8)
    pci_write_config(bus, dev, func, 0x04u8, command_status & 0xFFFFFFFDu32)
    pci_write_config(bus, dev, func, low_offset, 0xFFFFFFFFu32)
    pci_write_config(bus, dev, func, high_offset, 0xFFFFFFFFu32)
    val probe_low = pci_read_bar(bus, dev, func, bar_index)
    val probe_high = pci_read_bar(bus, dev, func, bar_index + 1u8)
    pci_write_config(bus, dev, func, high_offset, raw_high)
    pci_write_config(bus, dev, func, low_offset, raw_low)
    pci_write_config(bus, dev, func, 0x04u8, command_status)
    var info = pci_bar64_decode(raw_low, raw_high, probe_low, probe_high)
    if not info.implemented:
        return -19
    if info.size != 0x00800000u64:
        return -28
    val window_base = _direct_boot_ivshmem_window_base(dev)
    val programmed_low = ((window_base & 0xFFFFFFF0u64).to_u32()) | (info.raw_low & 0xFu32)
    val programmed_high = (window_base >> 32).to_u32()
    pci_write_config(bus, dev, func, high_offset, programmed_high)
    pci_write_config(bus, dev, func, low_offset, programmed_low)
    pci_write_config(bus, dev, func, 0x04u8, command_status | 0x2u32)
    info = pci_bar64_decode(programmed_low, programmed_high, probe_low, probe_high)
    if not _direct_boot_ivshmem_window_valid(info.base, info.size):
        return -12
    0

fn map_qemu_host_gpu_ivshmem_bar2() -> i64:
    var saw_qemu_vendor = false
    var saw_qemu_device = false
    var dev: u8 = 0u8
    while dev < 32u8:
        val vendor0 = pci_read_vendor(0u8, dev, 0u8)
        if vendor0 != 0xFFFFu16:
            val header_type = pci_read_header_type(0u8, dev, 0u8)
            val function_count: u8 = if (header_type & 0x80u8) != 0u8: 8u8 else: 1u8
            var func: u8 = 0u8
            while func < function_count:
                val vendor = pci_read_vendor(0u8, dev, func)
                if vendor != 0xFFFFu16:
                    val device_id = pci_read_device_id(0u8, dev, func)
                    if vendor == 0x1AF4u16:
                        saw_qemu_vendor = true
                        if device_id == 0x1110u16:
                            saw_qemu_device = true
                    val class_info = pci_read_class(0u8, dev, func)
                    val class_code = ((class_info >> 24u32) & 0xFFu32).to_u8()
                    val subclass = ((class_info >> 16u32) & 0xFFu32).to_u8()
                    if pci_function_is_qemu_ivshmem(vendor, device_id, class_code, subclass):
                        val mapped = _map_qemu_ivshmem_bar64(0u8, dev, func, 2u8)
                        if mapped < 0:
                            return mapped
                        return dev.to_i64() + 1
                func = func + 1u8
        dev = dev + 1u8
    if saw_qemu_device:
        return -71  # EPROTO: ivshmem identity visible but class shape rejected
    if saw_qemu_vendor:
        return -6  # ENXIO: QEMU vendor visible without ivshmem device 1110
    -2  # ENOENT: no matching ivshmem function on bus 0

fn qemu_host_gpu_ivshmem_window_base(mapped_slot: i64) -> u64:
    if mapped_slot <= 0:
        return 0u64
    _direct_boot_ivshmem_window_base((mapped_slot - 1).to_u8())

export map_qemu_host_gpu_ivshmem_bar2, qemu_host_gpu_ivshmem_window_base
