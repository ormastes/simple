# Loopback Socket Backend -- pure in-memory socket-pair transport for 127.0.0.1
#
# MDSOC: feature dimension, network layer
#
# Provides a host-testable, extern-free path for socket()/bind()/connect()/
# send()/recv() traffic addressed to 127.0.0.1, so loopback traffic never
# depends on the netstack IPC service (os.services.netstack) or a NIC driver
# being wired up. Two locally-registered POSIX fds rendezvous by port: one
# binds the port, the other connects to it; each direction gets its own FIFO
# byte queue.
#
# Scope: bind + connect + send + recv only (matches the current caller in
# socket_compat.spl). listen()/accept() semantics (a real backlog queue with
# per-connection fds) are NOT implemented here.
#
# ponytail: no NIC driver / x86_64 net path exists yet, so non-loopback
# traffic still goes through the netstack IPC path in socket_compat.spl,
# which requires a live os.services.netstack.netstack_service responder.
# That wiring gap is unchanged by this module -- see doc fragment in the
# task report for details.

use os.kernel.errno.{EADDRINUSE, ECONNREFUSED, ENOTCONN, EINVAL}

struct LoopbackEntry:
    """Loopback-registered socket state for one local POSIX fd."""
    fd: i32
    port: u16          # bound/listening port, 0 = unbound
    bound: bool
    peer_fd: i32        # -1 until connected to a peer fd
    connected: bool
    recv_buf: [u8]       # bytes queued for this fd's recv()

var g_loopback_entries: [LoopbackEntry] = []

fn loopback_is_loopback_addr(addr: u32) -> bool:
    """True when the packed IPv4 addr's first octet is 127 (127.0.0.0/8).

    SockaddrIn.addr packs octets as a | b<<8 | c<<16 | d<<24, so the first
    octet is the low byte.
    """
    (addr & 0xFFu32) == 127u32

fn _loopback_index(fd: i32) -> i64:
    var i: i64 = 0
    while i < g_loopback_entries.len().to_i64():
        if g_loopback_entries[i.to_u64()].fd == fd:
            return i
        i = i + 1
    -1

fn loopback_register(fd: i32):
    """Register fd as loopback-eligible with empty/unbound state."""
    val entry = LoopbackEntry(fd: fd, port: 0u16, bound: false, peer_fd: -1, connected: false, recv_buf: [])
    val idx = _loopback_index(fd)
    if idx >= 0:
        g_loopback_entries[idx.to_u64()] = entry
    else:
        g_loopback_entries.push(entry)

fn loopback_is_registered(fd: i32) -> bool:
    """True when fd has a loopback registry entry (bound and/or connected)."""
    _loopback_index(fd) >= 0

fn loopback_is_connected(fd: i32) -> bool:
    """True when fd's loopback entry is rendezvoused with a peer."""
    val idx = _loopback_index(fd)
    if idx < 0:
        return false
    g_loopback_entries[idx.to_u64()].connected

fn _find_listener_index(port: u16) -> i64:
    var i: i64 = 0
    while i < g_loopback_entries.len().to_i64():
        val e = g_loopback_entries[i.to_u64()]
        if e.bound and e.port == port and not e.connected:
            return i
        i = i + 1
    -1

fn loopback_bind(fd: i32, port: u16) -> i32:
    """Bind fd to `port` in the loopback registry. Returns 0 or -errno."""
    if _loopback_index(fd) < 0:
        loopback_register(fd)
    val listener_idx = _find_listener_index(port)
    if listener_idx >= 0 and g_loopback_entries[listener_idx.to_u64()].fd != fd:
        return 0 - EADDRINUSE

    val idx = _loopback_index(fd)
    val cur = g_loopback_entries[idx.to_u64()]
    g_loopback_entries[idx.to_u64()] = LoopbackEntry(
        fd: cur.fd, port: port, bound: true, peer_fd: cur.peer_fd,
        connected: cur.connected, recv_buf: cur.recv_buf
    )
    0

fn loopback_connect(fd: i32, port: u16) -> i32:
    """Connect fd to the loopback listener bound on `port`.

    Simplified 1:1 rendezvous: connecting links directly to the bound
    listener fd itself (no separate accept()-spawned fd or backlog queue).
    """
    val listener_idx = _find_listener_index(port)
    if listener_idx < 0:
        return 0 - ECONNREFUSED
    val listener_fd = g_loopback_entries[listener_idx.to_u64()].fd
    if listener_fd == fd:
        return 0 - EINVAL

    if _loopback_index(fd) < 0:
        loopback_register(fd)
    val idx = _loopback_index(fd)

    val client = g_loopback_entries[idx.to_u64()]
    g_loopback_entries[idx.to_u64()] = LoopbackEntry(
        fd: client.fd, port: port, bound: client.bound, peer_fd: listener_fd,
        connected: true, recv_buf: client.recv_buf
    )

    val server = g_loopback_entries[listener_idx.to_u64()]
    g_loopback_entries[listener_idx.to_u64()] = LoopbackEntry(
        fd: server.fd, port: server.port, bound: server.bound, peer_fd: fd,
        connected: true, recv_buf: server.recv_buf
    )
    0

fn loopback_send(fd: i32, data: [u8]) -> i64:
    """Deliver `data` to the connected peer's recv queue.

    Returns bytes sent, or -errno if fd is not loopback-connected.
    """
    val idx = _loopback_index(fd)
    if idx < 0 or not g_loopback_entries[idx.to_u64()].connected:
        return (0 - ENOTCONN) as i64
    val peer_fd = g_loopback_entries[idx.to_u64()].peer_fd
    val peer_idx = _loopback_index(peer_fd)
    if peer_idx < 0:
        return (0 - ENOTCONN) as i64

    val peer = g_loopback_entries[peer_idx.to_u64()]
    var buf = peer.recv_buf
    var i: u64 = 0
    while i < data.len():
        buf.push(data[i])
        i = i + 1
    g_loopback_entries[peer_idx.to_u64()] = LoopbackEntry(
        fd: peer.fd, port: peer.port, bound: peer.bound, peer_fd: peer.peer_fd,
        connected: peer.connected, recv_buf: buf
    )
    data.len() as i64

fn loopback_recv(fd: i32, max_len: u64) -> [u8]:
    """Pop up to `max_len` bytes FIFO from fd's own recv queue."""
    val idx = _loopback_index(fd)
    if idx < 0:
        return []

    val entry = g_loopback_entries[idx.to_u64()]
    var take = max_len
    if entry.recv_buf.len() < take:
        take = entry.recv_buf.len()

    var out: [u8] = []
    var i: u64 = 0
    while i < take:
        out.push(entry.recv_buf[i])
        i = i + 1

    var remaining: [u8] = []
    var j: u64 = take
    while j < entry.recv_buf.len():
        remaining.push(entry.recv_buf[j])
        j = j + 1

    g_loopback_entries[idx.to_u64()] = LoopbackEntry(
        fd: entry.fd, port: entry.port, bound: entry.bound, peer_fd: entry.peer_fd,
        connected: entry.connected, recv_buf: remaining
    )
    out

fn loopback_close(fd: i32):
    """Remove fd's loopback registry entry, if any. Safe to call on a
    non-loopback or never-registered fd (no-op)."""
    var next: [LoopbackEntry] = []
    var i: u64 = 0
    while i < g_loopback_entries.len():
        if g_loopback_entries[i].fd != fd:
            next.push(g_loopback_entries[i])
        i = i + 1
    g_loopback_entries = next

fn clear_loopback_sockets_for_test():
    """Test hook: reset the loopback registry between spec cases."""
    g_loopback_entries = []
