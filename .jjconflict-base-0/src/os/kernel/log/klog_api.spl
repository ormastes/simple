# SimpleOS kernel log facade.
#
# Keep this facade self-contained: SimpleOS kernel, services, drivers, and
# hosted tests import these names directly. The noalloc log package layout has
# changed over time, so this module owns the stable API surface.

val LOG_TRACE: i32 = 0
val LOG_DEBUG: i32 = 1
val LOG_INFO: i32 = 2
val LOG_WARN: i32 = 3
val LOG_ERROR: i32 = 4
val LOG_FATAL: i32 = 5
val LOG_OFF: i32 = 6

val TARGET_DEVICE: i32 = 1
val TARGET_SEMIHOST: i32 = 2
val TARGET_HOST_FILE: i32 = 4

val LOG_DEV_KIND_COM1: i32 = 1
val LOG_DEV_KIND_PL011: i32 = 2
val LOG_DEV_KIND_NS16550: i32 = 3

var _klog_level: i32 = LOG_INFO
var _klog_targets: i32 = TARGET_DEVICE
var _klog_device_kind: i32 = LOG_DEV_KIND_COM1
var _klog_device_base: u64 = 0

fn log_init(level: i32, targets: i32):
    _klog_level = level
    _klog_targets = targets

fn log_init_serial(level: i32):
    log_init(level, TARGET_DEVICE)

fn log_init_from_config(config: text):
    _klog_level = log_parse_level(config)

fn _ascii_lower_code(code: i64) -> i64:
    if code >= 65 and code <= 90:
        return code + 32
    code

fn _ascii_contains_folded(haystack: text, needle: text) -> bool:
    if needle.len() == 0:
        return true
    if haystack.len() < needle.len():
        return false
    var start: u64 = 0
    val last = haystack.len() - needle.len()
    while start <= last:
        var matched = true
        var i: u64 = 0
        while i < needle.len():
            if _ascii_lower_code(haystack.char_code_at(start + i)) != _ascii_lower_code(needle.char_code_at(i)):
                matched = false
                break
            i = i + 1
        if matched:
            return true
        start = start + 1
    false

fn log_parse_level(level: text) -> i32:
    if _ascii_contains_folded(level, "trace"):
        return LOG_TRACE
    if _ascii_contains_folded(level, "debug"):
        return LOG_DEBUG
    if _ascii_contains_folded(level, "warn"):
        return LOG_WARN
    if _ascii_contains_folded(level, "error"):
        return LOG_ERROR
    if _ascii_contains_folded(level, "fatal"):
        return LOG_FATAL
    if _ascii_contains_folded(level, "off"):
        return LOG_OFF
    LOG_INFO

fn log_parse_targets(targets: text) -> i32:
    var flags = 0
    if _ascii_contains_folded(targets, "device") or _ascii_contains_folded(targets, "serial"):
        flags = flags | TARGET_DEVICE
    if _ascii_contains_folded(targets, "semihost"):
        flags = flags | TARGET_SEMIHOST
    if _ascii_contains_folded(targets, "file"):
        flags = flags | TARGET_HOST_FILE
    if flags == 0:
        return 0
    flags

fn log_set_level(level: i32):
    _klog_level = level

fn log_set_targets(targets: i32):
    _klog_targets = targets

fn log_set_device(kind: i32, base: u64):
    _klog_device_kind = kind
    _klog_device_base = base

fn log_level_name(level: i32) -> text:
    if level == LOG_TRACE:
        return "TRACE"
    if level == LOG_DEBUG:
        return "DEBUG"
    if level == LOG_INFO:
        return "INFO"
    if level == LOG_WARN:
        return "WARN"
    if level == LOG_ERROR:
        return "ERROR"
    if level == LOG_FATAL:
        return "FATAL"
    "OFF"

fn _klog_should_emit(level: i32) -> bool:
    level >= _klog_level and _klog_level < LOG_OFF and _klog_targets != 0

fn _klog_emit(level: i32, msg: text):
    if _klog_should_emit(level):
        serial_println("[" + log_level_name(level) + "] " + msg)

fn log_trace(msg: text):
    _klog_emit(LOG_TRACE, msg)

fn log_debug(msg: text):
    _klog_emit(LOG_DEBUG, msg)

fn log_info(msg: text):
    _klog_emit(LOG_INFO, msg)

fn log_warn(msg: text):
    _klog_emit(LOG_WARN, msg)

fn log_error(msg: text):
    _klog_emit(LOG_ERROR, msg)

fn log_fatal(msg: text):
    _klog_emit(LOG_FATAL, msg)

fn log_raw(msg: text):
    if _klog_targets != 0 and _klog_level < LOG_OFF:
        serial_println(msg)

fn log_raw_println(msg: text):
    log_raw(msg)

extern fn serial_println(msg: text)

export LOG_TRACE, LOG_DEBUG, LOG_INFO, LOG_WARN, LOG_ERROR, LOG_FATAL, LOG_OFF
export TARGET_DEVICE, TARGET_SEMIHOST, TARGET_HOST_FILE
export LOG_DEV_KIND_COM1, LOG_DEV_KIND_PL011, LOG_DEV_KIND_NS16550

export log_init, log_init_serial, log_init_from_config
export log_parse_level, log_parse_targets
export log_set_level, log_set_targets, log_set_device
export log_trace, log_debug, log_info, log_warn, log_error, log_fatal
export log_raw, log_raw_println
export log_level_name
