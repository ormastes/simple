use std.io_runtime

class VerifyClaim:
    claim_id: text
    statement: text
    lane: text
    has_evidence: bool
    evidence_kind: text

    static fn create(cid: text, stmt: text, lane: text) -> VerifyClaim:
        return VerifyClaim(claim_id: cid, statement: stmt, lane: lane, has_evidence: false, evidence_kind: "")

    me with_evidence(kind: text) -> VerifyClaim:
        return VerifyClaim(claim_id: self.claim_id, statement: self.statement, lane: self.lane, has_evidence: true, evidence_kind: kind)

    me claim_needs_evidence() -> bool:
        return self.has_evidence == false

    me is_proven() -> bool:
        return self.evidence_kind == "proof"


class AssumptionLedger:
    a0_id: text
    a0_documented: bool
    a0_text: text
    a1_id: text
    a1_documented: bool
    a1_text: text
    a2_id: text
    a2_documented: bool
    a2_text: text
    a3_id: text
    a3_documented: bool
    a3_text: text
    total: i32
    documented_count: i32

    static fn from_four(id0: text, doc0: bool, t0: text, id1: text, doc1: bool, t1: text, id2: text, doc2: bool, t2: text, id3: text, doc3: bool, t3: text) -> AssumptionLedger:
        var count = 0
        if doc0:
            count = count + 1
        if doc1:
            count = count + 1
        if doc2:
            count = count + 1
        if doc3:
            count = count + 1
        return AssumptionLedger(a0_id: id0, a0_documented: doc0, a0_text: t0, a1_id: id1, a1_documented: doc1, a1_text: t1, a2_id: id2, a2_documented: doc2, a2_text: t2, a3_id: id3, a3_documented: doc3, a3_text: t3, total: 4, documented_count: count)

    me all_documented() -> bool:
        return self.documented_count == self.total

    me undocumented_count() -> i32:
        return self.total - self.documented_count


class EvidenceEntry:
    evidence_id: text
    claim_id: text
    kind: text
    strength: i32

    static fn proof(eid: text, cid: text) -> EvidenceEntry:
        return EvidenceEntry(evidence_id: eid, claim_id: cid, kind: "proof", strength: 4)

    static fn test_evidence(eid: text, cid: text) -> EvidenceEntry:
        return EvidenceEntry(evidence_id: eid, claim_id: cid, kind: "test", strength: 3)

    static fn review(eid: text, cid: text) -> EvidenceEntry:
        return EvidenceEntry(evidence_id: eid, claim_id: cid, kind: "review", strength: 2)

    static fn assertion(eid: text, cid: text) -> EvidenceEntry:
        return EvidenceEntry(evidence_id: eid, claim_id: cid, kind: "assertion", strength: 1)

    me is_strong() -> bool:
        return self.strength >= 3


class EvidenceClassification:
    proof_count: i32
    test_count: i32
    review_count: i32
    assertion_count: i32
    total: i32

    static fn create(proofs: i32, tests: i32, reviews: i32, assertions: i32) -> EvidenceClassification:
        return EvidenceClassification(proof_count: proofs, test_count: tests, review_count: reviews, assertion_count: assertions, total: proofs + tests + reviews + assertions)

    me strong_count() -> i32:
        return self.proof_count + self.test_count

    me weak_count() -> i32:
        return self.review_count + self.assertion_count

    me strong_ratio_pct() -> i32:
        if self.total > 0:
            return (self.strong_count() * 100) / self.total
        return 0


class TaxonomyReport:
    lane: text
    total_claims: i32
    evidenced_claims: i32
    strong_evidence_count: i32
    weak_evidence_count: i32

    static fn create(lane: text, claims: i32, evidenced: i32, strong: i32, weak: i32) -> TaxonomyReport:
        return TaxonomyReport(lane: lane, total_claims: claims, evidenced_claims: evidenced, strong_evidence_count: strong, weak_evidence_count: weak)

    me coverage_pct() -> i32:
        if self.total_claims > 0:
            return (self.evidenced_claims * 100) / self.total_claims
        return 0

    me is_adequate() -> bool:
        return self.coverage_pct() >= 80
