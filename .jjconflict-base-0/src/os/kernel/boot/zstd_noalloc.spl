"""
Zstd noalloc streaming decompressor — boot/initramfs stage.

Supports Zstd frame format (RFC 8878) with Raw and RLE block types.
Compressed (FSE/Huffman) blocks are flagged as unsupported; the caller
must supply a frame compressed without them (e.g. --no-compress-literals
zstd option, or a pre-decompressed image).

Constraints (same as riscv_noalloc_heap / riscv_noalloc_pmm):
  - No heap, no arrays, no Option, no Result, no text, no log facade.
  - All state in module-level var globals.
  - Input/output via caller-supplied raw u64 address + length pairs.
  - UART output uses literal byte pushes for diagnostics.

MDSOC: feature dimension, kernel boot layer.
"""

# ============================================================================
# ZSTD CONSTANTS (RFC 8878)
# ============================================================================

val ZSTD_MAGIC:       u64 = 0xFD2FB528
val ZSTD_SKIPPABLE_MAGIC_BASE: u64 = 0x184D2A50
val ZSTD_SKIPPABLE_MAGIC_MASK: u64 = 0xFFFFFFF0

# Block types (2-bit field in Block_Header)
val ZSTD_BLOCK_RAW:        u64 = 0  # Raw (uncompressed) block
val ZSTD_BLOCK_RLE:        u64 = 1  # Single-byte RLE block
val ZSTD_BLOCK_COMPRESSED: u64 = 2  # Compressed (FSE/Huffman) — unsupported
val ZSTD_BLOCK_RESERVED:   u64 = 3  # Reserved — error

# State codes
val ZSTD_S_INIT:            u64 = 0
val ZSTD_S_FRAME_HEADER:    u64 = 1
val ZSTD_S_BLOCK:           u64 = 2
val ZSTD_S_DONE:            u64 = 3
val ZSTD_S_ERROR:           u64 = 4

# Error codes (stored in g_zstd_error_code)
val ZSTD_OK:                u64 = 0
val ZSTD_ERR_BAD_MAGIC:     u64 = 1
val ZSTD_ERR_TRUNCATED:     u64 = 2
val ZSTD_ERR_OUTPUT_FULL:   u64 = 3
val ZSTD_ERR_BLOCK_TYPE:    u64 = 4
val ZSTD_ERR_RESERVED:      u64 = 5
val ZSTD_ERR_NOT_READY:     u64 = 6

# ============================================================================
# MODULE STATE
# ============================================================================

var g_zstd_ready:       bool  = false
var g_zstd_state:       u64   = ZSTD_S_INIT

# Input window
var g_zstd_in_ptr:      u64   = 0
var g_zstd_in_len:      u64   = 0
var g_zstd_in_pos:      u64   = 0

# Output window
var g_zstd_out_ptr:     u64   = 0
var g_zstd_out_cap:     u64   = 0
var g_zstd_out_pos:     u64   = 0

# Frame metadata
var g_zstd_has_checksum: bool = false
var g_zstd_fcs:          u64  = 0   # expected frame content size (0 = unknown)

# Diagnostics
var g_zstd_error_code:  u64   = ZSTD_OK
var g_zstd_blocks_done: u64   = 0

extern fn rt_riscv_uart_put(byte: u64)
extern fn rt_mem_read_u8(addr: u64) -> u64
extern fn rt_mem_write_u8(addr: u64, byte: u64)

# ============================================================================
# UART HELPERS  (byte-literal only — no text)
# ============================================================================

fn _uart_put(b: u64):
    rt_riscv_uart_put(b)

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_zstd_ok():
    # "ZSTD OK\r\n"
    _uart_put(90)   # Z
    _uart_put(83)   # S
    _uart_put(84)   # T
    _uart_put(68)   # D
    _uart_put(32)   # space
    _uart_put(79)   # O
    _uart_put(75)   # K
    _crlf()

fn _line_zstd_fail():
    # "ZSTD ERR\r\n"
    _uart_put(90)   # Z
    _uart_put(83)   # S
    _uart_put(84)   # T
    _uart_put(68)   # D
    _uart_put(32)   # space
    _uart_put(69)   # E
    _uart_put(82)   # R
    _uart_put(82)   # R
    _crlf()

fn _line_zstd_unsupported():
    # "ZSTD COMP\r\n"  (compressed block not supported)
    _uart_put(90)   # Z
    _uart_put(83)   # S
    _uart_put(84)   # T
    _uart_put(68)   # D
    _uart_put(32)   # space
    _uart_put(67)   # C
    _uart_put(79)   # O
    _uart_put(77)   # M
    _uart_put(80)   # P
    _crlf()

# ============================================================================
# LOW-LEVEL MEMORY READ HELPERS
# ============================================================================

fn _read8(base: u64, offset: u64) -> u64:
    rt_mem_read_u8(base + offset)

fn _read16_le(base: u64, offset: u64) -> u64:
    val lo = rt_mem_read_u8(base + offset)
    val hi = rt_mem_read_u8(base + offset + 1)
    lo | (hi << 8)

fn _read24_le(base: u64, offset: u64) -> u64:
    val b0 = rt_mem_read_u8(base + offset)
    val b1 = rt_mem_read_u8(base + offset + 1)
    val b2 = rt_mem_read_u8(base + offset + 2)
    b0 | (b1 << 8) | (b2 << 16)

fn _read32_le(base: u64, offset: u64) -> u64:
    val b0 = rt_mem_read_u8(base + offset)
    val b1 = rt_mem_read_u8(base + offset + 1)
    val b2 = rt_mem_read_u8(base + offset + 2)
    val b3 = rt_mem_read_u8(base + offset + 3)
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn _read64_le(base: u64, offset: u64) -> u64:
    val lo = _read32_le(base, offset)
    val hi = _read32_le(base, offset + 4)
    lo | (hi << 32)

fn _write8(base: u64, offset: u64, byte: u64):
    rt_mem_write_u8(base + offset, byte)

# ============================================================================
# OUTPUT HELPER
# ============================================================================

fn _emit_byte(b: u64) -> bool:
    """Write one byte to the output buffer. Returns false if full."""
    if g_zstd_out_pos >= g_zstd_out_cap:
        g_zstd_error_code = ZSTD_ERR_OUTPUT_FULL
        g_zstd_state = ZSTD_S_ERROR
        _line_zstd_fail()
        return false
    _write8(g_zstd_out_ptr, g_zstd_out_pos, b)
    g_zstd_out_pos = g_zstd_out_pos + 1
    true

# ============================================================================
# FRAME HEADER PARSE
# ============================================================================

fn _parse_frame_header(pos: u64) -> u64:
    """
    Parse Zstd Frame_Header starting at input[pos].
    Returns new pos after header, or 0 on error.

    Frame_Header_Descriptor (FHD) layout (1 byte):
      [7:6] FCS_Flag      — Frame_Content_Size field size
      [5]   Single_Segment — if set, no Window_Descriptor
      [4]   Unused
      [3]   Reserved      — must be 0
      [2]   Content_Checksum_Flag
      [1:0] Dictionary_ID_Flag
    """
    if pos >= g_zstd_in_len:
        g_zstd_error_code = ZSTD_ERR_TRUNCATED
        g_zstd_state = ZSTD_S_ERROR
        return 0

    val fhd = _read8(g_zstd_in_ptr, pos)
    var cur = pos + 1

    val fcs_flag       = (fhd >> 6) & 3
    val single_segment = (fhd >> 5) & 1
    val checksum_flag  = (fhd >> 2) & 1
    val did_flag       = fhd & 3

    g_zstd_has_checksum = checksum_flag == 1

    # Window_Descriptor (1 byte) if not single_segment
    if single_segment == 0:
        if cur >= g_zstd_in_len:
            g_zstd_error_code = ZSTD_ERR_TRUNCATED
            g_zstd_state = ZSTD_S_ERROR
            return 0
        cur = cur + 1  # skip window descriptor

    # Dictionary_ID (0 / 1 / 2 / 4 bytes)
    if did_flag == 1:
        cur = cur + 1
    if did_flag == 2:
        cur = cur + 2
    if did_flag == 3:
        cur = cur + 4

    # Frame_Content_Size
    if fcs_flag == 0:
        if single_segment == 1:
            # 1-byte FCS
            if cur >= g_zstd_in_len:
                g_zstd_error_code = ZSTD_ERR_TRUNCATED
                g_zstd_state = ZSTD_S_ERROR
                return 0
            g_zstd_fcs = _read8(g_zstd_in_ptr, cur)
            cur = cur + 1
        # else: FCS not present (0 = unknown)
    if fcs_flag == 1:
        if cur + 1 >= g_zstd_in_len:
            g_zstd_error_code = ZSTD_ERR_TRUNCATED
            g_zstd_state = ZSTD_S_ERROR
            return 0
        g_zstd_fcs = _read16_le(g_zstd_in_ptr, cur) + 256
        cur = cur + 2
    if fcs_flag == 2:
        if cur + 3 >= g_zstd_in_len:
            g_zstd_error_code = ZSTD_ERR_TRUNCATED
            g_zstd_state = ZSTD_S_ERROR
            return 0
        g_zstd_fcs = _read32_le(g_zstd_in_ptr, cur)
        cur = cur + 4
    if fcs_flag == 3:
        if cur + 7 >= g_zstd_in_len:
            g_zstd_error_code = ZSTD_ERR_TRUNCATED
            g_zstd_state = ZSTD_S_ERROR
            return 0
        g_zstd_fcs = _read64_le(g_zstd_in_ptr, cur)
        cur = cur + 8

    cur

# ============================================================================
# BLOCK PROCESSING
# ============================================================================

fn _process_raw_block(pos: u64, block_size: u64) -> u64:
    """Copy raw (uncompressed) block bytes to output. Returns new pos or 0."""
    if pos + block_size > g_zstd_in_len:
        g_zstd_error_code = ZSTD_ERR_TRUNCATED
        g_zstd_state = ZSTD_S_ERROR
        return 0
    var i: u64 = 0
    while i < block_size:
        val b = _read8(g_zstd_in_ptr, pos + i)
        if not _emit_byte(b):
            return 0
        i = i + 1
    pos + block_size

fn _process_rle_block(pos: u64, block_size: u64) -> u64:
    """
    RLE block: one byte content repeated block_size times.
    Returns new pos or 0.
    """
    if pos >= g_zstd_in_len:
        g_zstd_error_code = ZSTD_ERR_TRUNCATED
        g_zstd_state = ZSTD_S_ERROR
        return 0
    val rle_byte = _read8(g_zstd_in_ptr, pos)
    var i: u64 = 0
    while i < block_size:
        if not _emit_byte(rle_byte):
            return 0
        i = i + 1
    pos + 1

# ============================================================================
# PUBLIC API
# ============================================================================

fn zstd_noalloc_init(in_ptr: u64, in_len: u64, out_ptr: u64, out_cap: u64) -> bool:
    """
    Initialise the decompressor for one Zstd frame.

    in_ptr  — physical address of the compressed input buffer
    in_len  — byte length of input
    out_ptr — physical address of the output buffer
    out_cap — capacity of output buffer in bytes

    Returns true on success, false if parameters are invalid.
    Call zstd_noalloc_decompress() after this to run the decompressor.
    """
    if in_len < 4:
        g_zstd_error_code = ZSTD_ERR_TRUNCATED
        g_zstd_state = ZSTD_S_ERROR
        _line_zstd_fail()
        return false
    if out_cap < 1:
        g_zstd_error_code = ZSTD_ERR_OUTPUT_FULL
        g_zstd_state = ZSTD_S_ERROR
        _line_zstd_fail()
        return false

    g_zstd_in_ptr      = in_ptr
    g_zstd_in_len      = in_len
    g_zstd_in_pos      = 0
    g_zstd_out_ptr     = out_ptr
    g_zstd_out_cap     = out_cap
    g_zstd_out_pos     = 0
    g_zstd_state       = ZSTD_S_INIT
    g_zstd_error_code  = ZSTD_OK
    g_zstd_blocks_done = 0
    g_zstd_has_checksum= false
    g_zstd_fcs         = 0
    g_zstd_ready       = true
    true

fn zstd_noalloc_decompress() -> bool:
    """
    Run the decompressor to completion.

    Returns true if the entire frame was successfully decompressed.
    On return, call zstd_noalloc_out_len() for decompressed byte count.

    Supports Raw (00) and RLE (01) block types.
    Compressed (10) blocks set ZSTD_ERR_BLOCK_TYPE and return false.
    """
    if not g_zstd_ready:
        g_zstd_error_code = ZSTD_ERR_NOT_READY
        _line_zstd_fail()
        return false

    var pos = g_zstd_in_pos

    # --- Verify magic number ---
    if pos + 4 > g_zstd_in_len:
        g_zstd_error_code = ZSTD_ERR_TRUNCATED
        g_zstd_state = ZSTD_S_ERROR
        _line_zstd_fail()
        return false

    val magic = _read32_le(g_zstd_in_ptr, pos)
    if magic != ZSTD_MAGIC:
        g_zstd_error_code = ZSTD_ERR_BAD_MAGIC
        g_zstd_state = ZSTD_S_ERROR
        _line_zstd_fail()
        return false
    pos = pos + 4

    # --- Parse frame header ---
    g_zstd_state = ZSTD_S_FRAME_HEADER
    val after_hdr = _parse_frame_header(pos)
    if after_hdr == 0:
        _line_zstd_fail()
        return false
    pos = after_hdr

    # --- Process blocks ---
    g_zstd_state = ZSTD_S_BLOCK
    var done = false
    while not done:
        # Block_Header: 3 bytes, little-endian
        if pos + 3 > g_zstd_in_len:
            g_zstd_error_code = ZSTD_ERR_TRUNCATED
            g_zstd_state = ZSTD_S_ERROR
            _line_zstd_fail()
            return false

        val bh = _read24_le(g_zstd_in_ptr, pos)
        pos = pos + 3

        val last_block  = bh & 1
        val block_type  = (bh >> 1) & 3
        val block_size  = bh >> 3

        if block_type == ZSTD_BLOCK_RAW:
            val new_pos = _process_raw_block(pos, block_size)
            if new_pos == 0:
                return false
            pos = new_pos

        if block_type == ZSTD_BLOCK_RLE:
            val new_pos = _process_rle_block(pos, block_size)
            if new_pos == 0:
                return false
            pos = new_pos

        if block_type == ZSTD_BLOCK_COMPRESSED:
            g_zstd_error_code = ZSTD_ERR_BLOCK_TYPE
            g_zstd_state = ZSTD_S_ERROR
            _line_zstd_unsupported()
            return false

        if block_type == ZSTD_BLOCK_RESERVED:
            g_zstd_error_code = ZSTD_ERR_RESERVED
            g_zstd_state = ZSTD_S_ERROR
            _line_zstd_fail()
            return false

        g_zstd_blocks_done = g_zstd_blocks_done + 1

        if last_block == 1:
            done = true

    # Skip optional content checksum (4 bytes) — not verified at boot
    if g_zstd_has_checksum:
        pos = pos + 4

    g_zstd_in_pos = pos
    g_zstd_state = ZSTD_S_DONE
    _line_zstd_ok()
    true

fn zstd_noalloc_out_len() -> u64:
    """Return number of bytes written to the output buffer."""
    g_zstd_out_pos

fn zstd_noalloc_error_code() -> u64:
    """Return the last error code (ZSTD_OK = 0 means no error)."""
    g_zstd_error_code

fn zstd_noalloc_blocks_done() -> u64:
    """Return number of blocks successfully processed."""
    g_zstd_blocks_done

fn zstd_noalloc_is_done() -> bool:
    """True if the frame was fully decompressed without error."""
    g_zstd_state == ZSTD_S_DONE

fn zstd_noalloc_is_error() -> bool:
    """True if the decompressor is in an error state."""
    g_zstd_state == ZSTD_S_ERROR

fn zstd_noalloc_expected_size() -> u64:
    """Return Frame_Content_Size from the frame header (0 if unknown)."""
    g_zstd_fcs
