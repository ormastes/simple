# Pure-Simple NVMe production boot handoff.
#
# This module is intentionally narrow: the real NVMe driver provisions a
# lease-backed BlockDevice plus transfer evidence here, and the freestanding boot
# filesystem mount consumes it. It avoids coupling VFS initialization back to the
# broader boot filesystem probing module.

use os.services.block_device.{BlockDevice}
use os.drivers.nvme.nvme_storage_model.{NvmeTransferEvidence, NvmeFilesystemLease}

var _boot_nvme_devices: [BlockDevice] = []
var _boot_nvme_evidence: [NvmeTransferEvidence] = []
var _boot_nvme_leases: [NvmeFilesystemLease] = []

fn boot_nvme_production_handoff_provision(dev: BlockDevice, evidence: NvmeTransferEvidence, lease: NvmeFilesystemLease):
    _boot_nvme_devices = [dev]
    _boot_nvme_evidence = [evidence]
    _boot_nvme_leases = [lease]

fn boot_nvme_production_handoff_clear():
    _boot_nvme_devices = []
    _boot_nvme_evidence = []
    _boot_nvme_leases = []

fn boot_nvme_production_handoff_ready() -> bool:
    _boot_nvme_devices.len() > 0 and _boot_nvme_evidence.len() > 0 and _boot_nvme_leases.len() > 0

fn boot_nvme_production_handoff_device() -> BlockDevice:
    _boot_nvme_devices[0]

fn boot_nvme_production_handoff_evidence() -> NvmeTransferEvidence:
    _boot_nvme_evidence[0]

fn boot_nvme_production_handoff_lease() -> NvmeFilesystemLease:
    _boot_nvme_leases[0]
