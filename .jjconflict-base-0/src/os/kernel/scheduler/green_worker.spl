# SimpleOS Green Worker Scheduler Contract
#
# Pure scheduler-facing helpers for future green-task carrier workers. This
# module does not execute green tasks; it defines CPU placement and balancing
# rules that the SimpleOS carrier bridge must preserve.

pub struct GreenWorkerPlacement:
    """CPU placement decision for a logical green worker."""
    cpu: i64
    reason: text

pub struct GreenWorkerRebalanceDecision:
    """One-step rebalance or steal decision between SimpleOS CPU run queues."""
    should_move: bool
    from_cpu: i64
    to_cpu: i64
    moved_workers: i64
    reason: text

pub fn green_worker_cpu_allowed(affinity_mask: i64, cpu: i64) -> bool:
    if cpu < 0:
        false
    else:
        affinity_mask == 0 or (affinity_mask & (1 << cpu)) != 0

fn green_worker_load_for_cpu(cpu: i64, load0: i64, load1: i64, load2: i64, load3: i64) -> i64:
    if cpu == 0:
        load0
    elif cpu == 1:
        load1
    elif cpu == 2:
        load2
    elif cpu == 3:
        load3
    else:
        0

fn green_worker_first_allowed_cpu(cpu_count: i64, affinity_mask: i64) -> i64:
    if cpu_count > 0 and green_worker_cpu_allowed(affinity_mask, 0):
        0
    elif cpu_count > 1 and green_worker_cpu_allowed(affinity_mask, 1):
        1
    elif cpu_count > 2 and green_worker_cpu_allowed(affinity_mask, 2):
        2
    elif cpu_count > 3 and green_worker_cpu_allowed(affinity_mask, 3):
        3
    else:
        0

fn green_worker_consider_cpu(candidate_cpu: i64, candidate_load: i64, best_cpu: i64, best_load: i64, cpu_count: i64, affinity_mask: i64) -> GreenWorkerPlacement:
    if candidate_cpu < cpu_count and green_worker_cpu_allowed(affinity_mask, candidate_cpu) and candidate_load < best_load:
        GreenWorkerPlacement(cpu: candidate_cpu, reason: "least_loaded_allowed_cpu")
    else:
        GreenWorkerPlacement(cpu: best_cpu, reason: "least_loaded_allowed_cpu")

pub fn green_worker_pick_spawn_cpu(cpu_count: i64, affinity_mask: i64, load0: i64, load1: i64, load2: i64, load3: i64) -> GreenWorkerPlacement:
    """Pick the least-loaded CPU allowed by the green worker affinity mask."""
    val normalized_cpu_count = if cpu_count < 1: 1 elif cpu_count > 4: 4 else: cpu_count
    var best_cpu = green_worker_first_allowed_cpu(normalized_cpu_count, affinity_mask)
    var best_load = green_worker_load_for_cpu(best_cpu, load0, load1, load2, load3)
    val c1 = green_worker_consider_cpu(1, load1, best_cpu, best_load, normalized_cpu_count, affinity_mask)
    best_cpu = c1.cpu
    best_load = green_worker_load_for_cpu(best_cpu, load0, load1, load2, load3)
    val c2 = green_worker_consider_cpu(2, load2, best_cpu, best_load, normalized_cpu_count, affinity_mask)
    best_cpu = c2.cpu
    best_load = green_worker_load_for_cpu(best_cpu, load0, load1, load2, load3)
    val c3 = green_worker_consider_cpu(3, load3, best_cpu, best_load, normalized_cpu_count, affinity_mask)
    best_cpu = c3.cpu
    GreenWorkerPlacement(cpu: best_cpu, reason: "least_loaded_allowed_cpu")

pub fn green_worker_choose_wake_cpu(home_cpu: i64, waker_cpu: i64, affinity_mask: i64, home_load: i64, waker_load: i64, wake_affine_threshold: i64) -> GreenWorkerPlacement:
    """Prefer the waker CPU only when affinity allows it and load is close."""
    if green_worker_cpu_allowed(affinity_mask, waker_cpu) and waker_load - home_load <= wake_affine_threshold:
        GreenWorkerPlacement(cpu: waker_cpu, reason: "wake_affine_waker_cpu")
    elif green_worker_cpu_allowed(affinity_mask, home_cpu):
        GreenWorkerPlacement(cpu: home_cpu, reason: "home_cpu")
    else:
        GreenWorkerPlacement(cpu: green_worker_first_allowed_cpu(4, affinity_mask), reason: "first_allowed_cpu")

pub fn green_worker_should_steal(local_load: i64, remote_load: i64, steal_threshold: i64) -> bool:
    remote_load - local_load >= steal_threshold

pub fn green_worker_rebalance_decision(cpu_count: i64, load0: i64, load1: i64, load2: i64, load3: i64, rebalance_threshold: i64) -> GreenWorkerRebalanceDecision:
    """Move one logical green worker from the busiest CPU to the idlest CPU."""
    val normalized_cpu_count = if cpu_count < 1: 1 elif cpu_count > 4: 4 else: cpu_count
    var busiest_cpu = 0
    var busiest_load = load0
    var idlest_cpu = 0
    var idlest_load = load0
    if normalized_cpu_count > 1:
        if load1 > busiest_load:
            busiest_load = load1
            busiest_cpu = 1
        if load1 < idlest_load:
            idlest_load = load1
            idlest_cpu = 1
    if normalized_cpu_count > 2:
        if load2 > busiest_load:
            busiest_load = load2
            busiest_cpu = 2
        if load2 < idlest_load:
            idlest_load = load2
            idlest_cpu = 2
    if normalized_cpu_count > 3:
        if load3 > busiest_load:
            busiest_load = load3
            busiest_cpu = 3
        if load3 < idlest_load:
            idlest_load = load3
            idlest_cpu = 3
    if busiest_load - idlest_load < rebalance_threshold:
        GreenWorkerRebalanceDecision(
            should_move: false,
            from_cpu: busiest_cpu,
            to_cpu: idlest_cpu,
            moved_workers: 0,
            reason: "below_threshold"
        )
    else:
        GreenWorkerRebalanceDecision(
            should_move: true,
            from_cpu: busiest_cpu,
            to_cpu: idlest_cpu,
            moved_workers: 1,
            reason: "busiest_to_idlest"
        )
