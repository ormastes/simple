# Device Memory Types — Exokernel-style device resource grants
#
# All fields use primitive types for baremetal ABI safety.
# The kernel exposes raw device resources to user-space drivers.

# DMA direction constants
val DMA_TO_DEVICE: u8 = 0
val DMA_FROM_DEVICE: u8 = 1
val DMA_BIDIRECTIONAL: u8 = 2

val DMA_CACHE_COHERENT: u8 = 0
val DMA_CACHE_FLUSH_REQUIRED: u8 = 1
val DMA_CACHE_UNCACHED: u8 = 2
val DMA_CACHE_WRITE_COMBINING: u8 = 3

struct PciBdf:
    bus: u8
    device: u8
    func: u8

fn pci_bdf_pack(bus: u8, device: u8, func: u8) -> u64:
    (bus as u64) << 16 | (device as u64) << 8 | (func as u64)

fn pci_bdf_bus(packed: u64) -> u8:
    ((packed >> 16) & 0xFF).to_u8()

fn pci_bdf_device(packed: u64) -> u8:
    ((packed >> 8) & 0xFF).to_u8()

fn pci_bdf_function(packed: u64) -> u8:
    (packed & 0xFF).to_u8()

struct PciBar:
    index: u8
    phys_addr: u64
    size: u64
    is_mmio: bool
    is_prefetchable: bool
    cap_token: u64   # capability token ID

struct IrqObject:
    vector: u32
    notification_id: u64
    notification_bit: u64
    cap_token: u64

struct DmaWindow:
    device_addr: u64
    host_addr: u64
    size: u64
    direction: u8
    cap_token: u64

struct DmaDescriptor:
    """Canonical kernel DMA allocation descriptor."""
    cpu_virt_addr: u64
    host_phys_addr: u64
    device_addr: u64
    byte_len: u64
    cache_policy: u8
    owner_task: u64
    owner_bdf_bus: u8
    owner_bdf_device: u8
    owner_bdf_function: u8
    allocation_id: u64

struct IommuDomain:
    domain_id: u32
    cap_token: u64

struct PciFunction:
    bdf_bus: u8
    bdf_device: u8
    bdf_function: u8
    vendor_id: u16
    device_id: u16
    class_code: u8
    subclass: u8
    prog_if: u8
    revision: u8

# Device Grant — everything a user-space driver needs
# Kernel grants this to a driver capsule via capability transfer.
struct DeviceGrant:
    pci_vendor: u16
    pci_device: u16
    pci_bus: u8
    pci_dev: u8
    pci_func: u8
    pci_class: u8
    pci_subclass: u8
    # BAR 0 mapping (primary — most drivers only need BAR0)
    bar0_phys: u64
    bar0_size: u64
    bar0_cap: u64
    # IRQ
    irq_vector: u32
    irq_notification_id: u64
    irq_notification_bit: u64
    irq_cap: u64
    # DMA (0 if not applicable)
    dma_device_addr: u64
    dma_host_addr: u64
    dma_size: u64
    dma_cap: u64
    # IOMMU (0 if not applicable)
    iommu_domain_id: u32
    iommu_cap: u64

fn new_device_grant() -> DeviceGrant:
    """Factory for cross-module construction."""
    DeviceGrant(pci_vendor: 0, pci_device: 0, pci_bus: 0, pci_dev: 0, pci_func: 0, pci_class: 0, pci_subclass: 0, bar0_phys: 0, bar0_size: 0, bar0_cap: 0, irq_vector: 0, irq_notification_id: 0, irq_notification_bit: 0, irq_cap: 0, dma_device_addr: 0, dma_host_addr: 0, dma_size: 0, dma_cap: 0, iommu_domain_id: 0, iommu_cap: 0)

fn device_grant_is_isolated(grant: DeviceGrant) -> bool:
    """True when a grant carries an IOMMU-capable isolation domain."""
    grant.iommu_domain_id != 0u32 and grant.iommu_cap != 0u64

fn device_grant_is_no_isolation(grant: DeviceGrant) -> bool:
    """Explicit no-isolation marker used by trusted no-IOMMU lanes."""
    not device_grant_is_isolated(grant)

fn device_grant_token_base(bus: u8, dev: u8, func: u8, owner_task: u64) -> u64:
    """Deterministic nonzero token seed for BAR/IRQ/DMA/IOMMU grant metadata."""
    0xD000000000000000u64 |
        (owner_task & 0xFFFFu64) << 24 |
        (bus.to_u64() << 16) |
        (dev.to_u64() << 8) |
        func.to_u64()

fn device_grant_bar_token(base: u64) -> u64:
    base | 0x1u64

fn device_grant_irq_token(base: u64) -> u64:
    base | 0x2u64

fn device_grant_dma_token(base: u64) -> u64:
    base | 0x4u64

fn device_grant_iommu_token(base: u64) -> u64:
    base | 0x8u64

fn device_grant_iommu_domain_id(bus: u8, dev: u8, func: u8) -> u32:
    1u32 + (bus.to_u32() << 16) + (dev.to_u32() << 8) + func.to_u32()

fn device_grant_has_resource_tokens(grant: DeviceGrant) -> bool:
    grant.bar0_cap != 0u64 and grant.irq_cap != 0u64 and
        grant.dma_cap != 0u64 and grant.iommu_cap != 0u64

fn device_grant_matches_owner_task(grant: DeviceGrant, owner_task: u64) -> bool:
    val base = device_grant_token_base(grant.pci_bus, grant.pci_dev, grant.pci_func, owner_task)
    grant.bar0_cap == device_grant_bar_token(base) and
        grant.irq_cap == device_grant_irq_token(base) and
        grant.dma_cap == device_grant_dma_token(base) and
        grant.iommu_cap == device_grant_iommu_token(base) and
        grant.iommu_domain_id == device_grant_iommu_domain_id(grant.pci_bus, grant.pci_dev, grant.pci_func)

fn device_grant_resource_set_label(grant: DeviceGrant) -> text:
    if not device_grant_has_resource_tokens(grant):
        return "resource-grant-set:missing"
    "resource-grant-set:tok=" + grant.bar0_cap.to_text()

fn dma_descriptor_matches_owner(desc: DmaDescriptor,
                                task_id: u64,
                                bdf_bus: u8,
                                bdf_device: u8,
                                bdf_function: u8) -> bool:
    """Validate DMA descriptor ownership before cross-driver reuse."""
    desc.owner_task == task_id and
        desc.owner_bdf_bus == bdf_bus and
        desc.owner_bdf_device == bdf_device and
        desc.owner_bdf_function == bdf_function
