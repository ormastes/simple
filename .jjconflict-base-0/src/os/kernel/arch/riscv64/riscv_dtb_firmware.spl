class DtbNode:
    name: text
    compatible: text
    reg_base: i32
    reg_size: i32
    child_count: i32
    c0_name: text
    c1_name: text

    me is_cpu():
        return name == "cpu" or compatible.starts_with("riscv")

    me is_memory():
        return name == "memory" or compatible == "memory"

    me has_children():
        return child_count > 0

    static fn cpu_node(hart_id: i32) -> DtbNode:
        return DtbNode { name: "cpu", compatible: "riscv", reg_base: hart_id, reg_size: 0, child_count: 0, c0_name: "", c1_name: "" }

    static fn memory_node(base: i32, size: i32) -> DtbNode:
        return DtbNode { name: "memory", compatible: "memory", reg_base: base, reg_size: size, child_count: 0, c0_name: "", c1_name: "" }

    static fn root() -> DtbNode:
        return DtbNode { name: "", compatible: "", reg_base: 0, reg_size: 0, child_count: 2, c0_name: "cpu", c1_name: "memory" }


class DtbBlob:
    total_size: i32
    node_count: i32
    boot_cpu_id: i32
    bootargs: text
    stdout_path: text
    initrd_start: i32
    initrd_end: i32

    me has_bootargs():
        return bootargs != ""

    me has_initrd():
        return initrd_end > initrd_start

    static fn minimal(nodes: i32, cpu: i32) -> DtbBlob:
        return DtbBlob { total_size: 0, node_count: nodes, boot_cpu_id: cpu, bootargs: "", stdout_path: "", initrd_start: 0, initrd_end: 0 }

    static fn linux_boot(nodes: i32, cpu: i32, args: text, console: text) -> DtbBlob:
        return DtbBlob { total_size: 0, node_count: nodes, boot_cpu_id: cpu, bootargs: args, stdout_path: console, initrd_start: 0, initrd_end: 0 }


class FirmwareStage:
    stage_name: text
    entry_addr: i32
    load_addr: i32
    size_bytes: i32
    next_stage: text
    is_final: bool

    me is_opensbi():
        return stage_name == "opensbi"

    me is_linux():
        return stage_name == "linux"

    me has_next():
        return is_final == false

    static fn rom(entry: i32) -> FirmwareStage:
        return FirmwareStage { stage_name: "rom", entry_addr: entry, load_addr: entry, size_bytes: 0, next_stage: "opensbi", is_final: false }

    static fn opensbi(entry: i32, size: i32) -> FirmwareStage:
        return FirmwareStage { stage_name: "opensbi", entry_addr: entry, load_addr: entry, size_bytes: size, next_stage: "uboot", is_final: false }

    static fn linux_kernel(entry: i32, size: i32) -> FirmwareStage:
        return FirmwareStage { stage_name: "linux", entry_addr: entry, load_addr: entry, size_bytes: size, next_stage: "", is_final: true }


class SbiCall:
    extension_id: i32
    function_id: i32
    extension_name: text
    arg0: i32
    arg1: i32
    ret_value: i32
    ret_error: i32

    me is_timer():
        return extension_id == 84

    me is_console():
        return extension_id == 1

    me succeeded():
        return ret_error == 0

    static fn set_timer(val: i32) -> SbiCall:
        return SbiCall { extension_id: 84, function_id: 0, extension_name: "timer", arg0: val, arg1: 0, ret_value: 0, ret_error: 0 }

    static fn console_putchar(ch: i32) -> SbiCall:
        return SbiCall { extension_id: 1, function_id: 0, extension_name: "console", arg0: ch, arg1: 0, ret_value: 0, ret_error: 0 }

    static fn send_ipi(hart_mask: i32) -> SbiCall:
        return SbiCall { extension_id: 115, function_id: 0, extension_name: "ipi", arg0: hart_mask, arg1: 0, ret_value: 0, ret_error: 0 }


fn main():
    print("riscv_dtb_firmware loaded")
