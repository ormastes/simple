"""SimpleOS RV64 Lite Shell — minimal serial-UART command dispatch.

This is the management fallback used when the FPGA/board has no working
network: an operator connects over UART (directly, or through the host-side
telnet-over-serial bridge in src/lib/nogc_sync_mut/io/telnet_serial_bridge.spl)
and drives the box with these commands.

The dispatch logic here is pure text-in/text-out so it is unit-testable in the
interpreter without UART hardware. The interactive read/echo loop that wires it
to the 16550 UART lives in os.kernel.arch.riscv64.console (serial_shell_main),
which already owns the MMIO I/O.

Commands: help, info, net, echo <text>, reboot
"""

fn rv64_shell_banner() -> text:
    "SimpleOS RV64 serial console - network unavailable, UART management active.\r\nType 'help' for commands."

fn rv64_shell_prompt() -> text:
    "simpleos-rv64> "

fn rv64_shell_help() -> text:
    "commands: help, info, net, echo <text>, reboot"

fn rv64_shell_dispatch(line: text, network_ok: i64) -> text:
    """Map one command line to its response text. Pure: no UART, no I/O."""
    if line == "help":
        return rv64_shell_help()
    if line == "info":
        return "SimpleOS RV64 (riscv64) - serial console fallback"
    if line == "net":
        if network_ok == 1:
            return "network: ready"
        return "network: unavailable - UART telnet/ssh fallback in use"
    if line == "reboot":
        # ponytail: stub response only — wire SBI system_reset in the console
        # loop when an operator actually needs remote reset.
        return "rebooting..."
    if line.starts_with("echo "):
        return line.slice(5, line.len())
    if line == "":
        return ""
    return "unknown command: {line}\r\nType 'help' for commands."

export rv64_shell_banner, rv64_shell_prompt, rv64_shell_dispatch, rv64_shell_help
