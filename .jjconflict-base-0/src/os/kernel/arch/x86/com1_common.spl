# Shared x86 COM1 serial helpers.

extern fn rt_port_outb(port: u16, value: u8)
extern fn rt_port_inb(port: u16) -> u8

val X86_COM1_BASE: u16 = 0x3F8
val X86_COM1_DATA: u16 = 0x3F8
val X86_COM1_IER: u16 = 0x3F9
val X86_COM1_FCR: u16 = 0x3FA
val X86_COM1_LCR: u16 = 0x3FB
val X86_COM1_MCR: u16 = 0x3FC
val X86_COM1_LSR: u16 = 0x3FD

fn x86_com1_init(ready: bool) -> bool:
    """Initialize COM1 once and return the ready state."""
    if ready:
        return true

    rt_port_outb(X86_COM1_IER, 0x00)
    rt_port_outb(X86_COM1_LCR, 0x80)
    rt_port_outb(X86_COM1_DATA, 0x01)
    rt_port_outb(X86_COM1_IER, 0x00)
    rt_port_outb(X86_COM1_LCR, 0x03)
    rt_port_outb(X86_COM1_FCR, 0xC7)
    rt_port_outb(X86_COM1_MCR, 0x0B)
    rt_port_outb(X86_COM1_MCR, 0x1E)
    rt_port_outb(X86_COM1_DATA, 0xAE)
    rt_port_outb(X86_COM1_MCR, 0x0F)
    true

fn x86_com1_write_byte(byte: u8):
    """Write one byte to COM1, blocking until transmit ready."""
    while (rt_port_inb(X86_COM1_LSR) & 0x20) == 0:
        pass_do_nothing
    rt_port_outb(X86_COM1_DATA, byte)

fn x86_com1_write(msg: text):
    """Write text to COM1."""
    for i in 0..msg.len():
        val ch = msg.char_at(i)
        x86_com1_write_byte(ch as u8)

fn x86_com1_writeln(msg: text):
    """Write text plus CRLF to COM1."""
    x86_com1_write(msg)
    x86_com1_write_byte(0x0D)
    x86_com1_write_byte(0x0A)
