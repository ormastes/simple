# x86_64 Interrupt HAL — IDT, APIC, PIC
#
# HAL-compatible wrapper for the x86_64 interrupt subsystem.
# Delegates to the existing fully-implemented modules:
#   - os.kernel.interrupts.idt   (IDT setup, handler table, dispatch)
#   - os.kernel.interrupts.apic  (Local APIC init, EOI)
#   - os.kernel.interrupts.pic   (legacy 8259 PIC disable/masking)
#   - os.kernel.arch.x86_64.cpu  (CLI/STI/HLT wrappers)

use os.kernel.interrupts.idt.{idt_init, idt_set_handler, idt_register_handler,
    VEC_IRQ_BASE, VEC_SPURIOUS}
use os.kernel.interrupts.apic.{apic_init, apic_eoi, apic_write, apic_read,
    APIC_BASE, APIC_REG_EOI}
use os.kernel.interrupts.pic.{pic_disable}
use os.kernel.arch.x86_64.cpu.{x86_cli, x86_sti, x86_start_registered_aps_once}
use os.kernel.arch.x86_64.trap_runtime.{X86TrapRuntime}
use os.kernel.types.task_types.{TaskContext}
use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult, KLogEntry}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}
use os.kernel.ipc.syscall.{syscall_handler, syscall_handler_ipc_state, dispatch_spawn_binary_direct_state}
use os.kernel.arch.x86_64.user_entry.{dispatch_enter_user_blocking}
use std.baremetal.x86.io.{outb, inb}

# ============================================================================
# PIC Port Constants (for IRQ mask control when PIC is in use)
# ============================================================================

val PIC1_CMD_PORT: i32  = 0x20
val PIC1_DATA_PORT: i32 = 0x21
val PIC2_CMD_PORT: i32  = 0xA0
val PIC2_DATA_PORT: i32 = 0xA1

val PIC_EOI: i32 = 0x20    # End-of-interrupt command byte

# ============================================================================
# X86Interrupt
# ============================================================================

struct X86Interrupt:
    """x86_64 interrupt management (IDT + APIC/PIC).

    Thin HAL wrapper that delegates to the existing interrupt subsystem
    modules in os.kernel.interrupts/.
    """
    pass_dn

# ============================================================================
# Runtime Ownership
# ============================================================================

var g_trap_runtime_installed: bool = false
var g_trap_scheduler: Scheduler = Scheduler.new_bootstrap()
var g_trap_ipc: IpcManager = IpcManager.new()
var g_trap_klog: KernelLog = KernelLog.new(256)

impl X86Interrupt:
    static fn init():
        """Initialize IDT with 256 entries, remap and disable legacy PIC,
        then initialize the Local APIC.

        After this call, interrupts are NOT enabled — caller must call
        enable() (STI) when ready.
        """
        # Set up the 256-entry IDT with exception handlers
        idt_init()

        # APIC init handles: PIC disable, APIC enable via MSR, SVR setup,
        # TPR=0, ESR clear, initial EOI, mask all LVT, calibrate timer
        apic_init()

        # FR-SOS-017: once the BSP has a live IDT and Local APIC, send the
        # low-memory trampoline INIT/SIPI sequence to firmware-registered APs.
        x86_start_registered_aps_once()

    static fn install_runtime(scheduler: Scheduler, ipc: IpcManager, klog: KernelLog):
        """Install the runtime objects used by trap/syscall dispatch."""
        x86_install_runtime(scheduler, ipc, klog)

    static fn install_runtime_bundle(runtime: X86TrapRuntime):
        """Install a precomposed runtime bundle for trap dispatch."""
        x86_install_runtime_bundle(runtime)

    static fn install_bootstrap_runtime(log_capacity: u64):
        """Install the minimal early-boot runtime bundle."""
        x86_install_bootstrap_runtime(log_capacity)

    static fn runtime_installed() -> bool:
        """Report whether the x86_64 trap runtime has been installed."""
        x86_runtime_installed()

    static fn installed_scheduler() -> Scheduler:
        """Return the scheduler currently installed in the trap bridge."""
        x86_installed_scheduler()

    static fn enable():
        """Enable maskable interrupts (STI instruction)."""
        x86_sti()

    static fn disable():
        """Disable maskable interrupts (CLI instruction)."""
        x86_cli()

    static fn register_handler(vector: u64, handler_addr: u64):
        """Register an interrupt handler for a given vector number.

        Sets the IDT entry so the CPU dispatches to handler_addr when
        this vector fires. The handler_addr must point to a valid ISR
        stub that saves context and calls the handler table.
        """
        idt_set_handler(vector as u32, handler_addr, 0)

    static fn unregister_handler(vector: u64):
        """Remove interrupt handler for a given vector.

        Restores the vector to a default no-op handler by installing
        _default_unhandled as the high-level handler.
        """
        idt_register_handler(vector as u32, _default_unhandled)

    static fn send_eoi(vector: u64):
        """Send End-Of-Interrupt for the given vector.

        For vectors in the PIC range (32-47), sends EOI to the legacy
        PIC(s) as well. For all vectors, sends EOI to the Local APIC.

        PIC EOI protocol:
        - Master PIC (IRQ 0-7, vectors 32-39): outb 0x20, 0x20
        - Slave PIC (IRQ 8-15, vectors 40-47): outb 0xA0, 0x20 then outb 0x20, 0x20
        """
        val vec = vector as u32

        # If this is a slave PIC IRQ (vectors 40-47), EOI the slave first
        if vec >= 40 and vec < 48:
            outb(PIC2_CMD_PORT, PIC_EOI)

        # If this is any PIC IRQ (vectors 32-47), EOI the master
        if vec >= 32 and vec < 48:
            outb(PIC1_CMD_PORT, PIC_EOI)

        # Always send LAPIC EOI (write 0 to EOI register)
        apic_eoi()

    static fn set_irq_mask(irq: u64, masked: bool):
        """Mask or unmask a hardware IRQ line on the legacy PIC.

        irq: IRQ number 0-15
        masked: true = disable IRQ, false = enable IRQ

        IRQ 0-7 are on the master PIC (data port 0x21).
        IRQ 8-15 are on the slave PIC (data port 0xA1).
        Each bit in the mask register corresponds to one IRQ line.
        """
        if irq > 15:
            return

        var port = PIC1_DATA_PORT
        var bit = irq
        if irq >= 8:
            port = PIC2_DATA_PORT
            bit = irq - 8

        val current_mask = inb(port)
        val bit_mask = 1 << (bit as i32)

        if masked:
            # Set the bit to mask (disable) the IRQ
            outb(port, current_mask | bit_mask)
        else:
            # Clear the bit to unmask (enable) the IRQ
            outb(port, current_mask & (bit_mask ^ 0xFF))

    static fn acknowledge():
        """Acknowledge the current interrupt by sending EOI to the Local APIC.

        This is the generic EOI path used when the specific vector is not
        known (e.g., from a timer or IPI handler). For PIC-routed IRQs,
        use send_eoi(vector) instead to also acknowledge the PIC.
        """
        apic_eoi()

# ============================================================================
# Default Handler
# ============================================================================

fn _default_unhandled(ctx: TaskContext):
    """Default handler installed when a vector is unregistered.
    Silently ignores the interrupt.
    """
    pass_dn

fn _log_bridge_failure(message: text):
    """Record x86 bridge/runtime failures in the installed kernel log."""
    if g_trap_runtime_installed:
        g_trap_klog.write(3, 0, 0, message)

fn x86_install_runtime(scheduler: Scheduler, ipc: IpcManager, klog: KernelLog):
    """Install the kernel runtime objects used by the x86_64 trap bridge."""
    g_trap_scheduler = scheduler
    g_trap_ipc = ipc
    g_trap_klog = klog
    g_trap_runtime_installed = true

fn x86_install_runtime_bundle(runtime: X86TrapRuntime):
    """Install a precomposed runtime bundle for x86_64 trap dispatch."""
    g_trap_scheduler = runtime.scheduler
    g_trap_ipc = runtime.ipc
    g_trap_klog = runtime.klog
    g_trap_runtime_installed = true

fn x86_install_bootstrap_runtime(log_capacity: u64):
    """Install the minimal early-boot runtime bundle."""
    val scheduler = Scheduler.new_bootstrap()
    val ipc = IpcManager.new()
    val klog = KernelLog.new(log_capacity)
    g_trap_scheduler = scheduler
    g_trap_ipc = ipc
    g_trap_klog = klog
    g_trap_runtime_installed = true

fn x86_runtime_installed() -> bool:
    """Report whether the x86_64 trap bridge has runtime objects installed."""
    g_trap_runtime_installed

fn x86_installed_scheduler() -> Scheduler:
    """Return the scheduler currently installed in the x86_64 trap bridge."""
    g_trap_scheduler

fn x86_read_trap_log(min_level: u8, offset: u64, max_count: u64) -> [KLogEntry]:
    """Read entries from the installed x86_64 trap runtime log buffer."""
    if not g_trap_runtime_installed:
        return []
    g_trap_klog.read(min_level, offset, max_count)

fn x86_dispatch_installed_syscall(args: SyscallArgs) -> Result<SyscallResult, text>:
    """Dispatch syscall arguments through the installed x86_64 runtime."""
    if not x86_runtime_installed():
        val message = "x86 trap runtime is not installed"
        _log_bridge_failure(message)
        return Err(message)

    if args.id >= 20 and args.id <= 23:
        val ipc_state = syscall_handler_ipc_state(args, g_trap_scheduler, g_trap_ipc, g_trap_klog)
        g_trap_scheduler = ipc_state.scheduler
        g_trap_ipc = ipc_state.ipc
        return Ok(ipc_state.result)

    val result = syscall_handler(args, g_trap_scheduler, g_trap_ipc, g_trap_klog)
    Ok(result)

fn x86_dispatch_installed_syscall_abi(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64, arg5: u64) -> i64:
    """C-callable primitive ABI for the installed x86_64 syscall bridge."""
    if id == 13:
        # Scheduler has value semantics across call boundaries: adopt the
        # returned scheduler so the spawned task survives in the trap globals.
        val spawn_state = dispatch_spawn_binary_direct_state(arg0, arg1, arg2, g_trap_scheduler, g_trap_klog)
        g_trap_scheduler = spawn_state.scheduler
        return spawn_state.pid

    if id == 14:
        # EnterUserBlocking — noreturn: hands off to ring-3 via iretq.
        # Returns -22 (EINVAL) only if the TCB lookup fails or has no user_context.
        return dispatch_enter_user_blocking(arg0, g_trap_scheduler)

    val result = x86_dispatch_installed_syscall(SyscallArgs(
        id: id,
        arg0: arg0,
        arg1: arg1,
        arg2: arg2,
        arg3: arg3,
        arg4: arg4,
        arg5: arg5
    ))
    if result.is_err():
        return -38
    val value = result.unwrap().value
    value

@export("C", name: "spl_x86_dispatch_installed_syscall_abi")
fn spl_x86_dispatch_installed_syscall_abi(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64, arg5: u64) -> i64:
    """Raw C ABI wrapper for baremetal syscall_entry.s and C stubs."""
    x86_dispatch_installed_syscall_abi(id, arg0, arg1, arg2, arg3, arg4, arg5)

# ============================================================================
# Ring-3 fault termination
# ============================================================================
# The x86_64 rich-fault ISR stub (`_rich_fault_entry`, baremetal_stubs.c) used
# to recover from EVERY fault the same way: advance the faulting RIP by 2 bytes,
# set RAX=nil, and `iretq`. That is only valid for the narrow ring-0 use case of
# skipping a stubbed no-op call during boot. On a ring-3 (CPL=3) unrecoverable
# fault (page fault with no mapping / protection violation, or #GP), iretq-ing
# back to the faulting user instruction re-faults immediately, and the stub then
# advances 2 bytes and iretqs again — an unbounded kernel re-fault runaway
# (observed: clang_static NULL deref looped ~107k frames, rip symbolising near
# kernel::arch::x86_64::boot::parse_hhdm).
#
# The stub now guards on CS: a ring-3 fault calls `spl_x86_on_user_fault` and
# then parks the CPU instead of returning into the doomed user context. This
# function is the pure-Simple decision + fatal-signal marker. It must never
# itself fault, so it uses only port I/O (no heap, no allocation, no scheduler
# traversal — the same COM1 primitive the IDT exception handlers already use).

fn _pf_serial_putc(ch: u8):
    """Write one byte to COM1 (0x3F8), waiting for the TX holding register."""
    var lsr: i32 = 0
    while (lsr & 0x20) == 0:
        lsr = inb(0x3FD)
    outb(0x3F8, ch as i32)

fn _pf_serial_puts(msg: text):
    """Write a static string to COM1. Heap-free: indexes the literal in place."""
    var i = 0
    while i < msg.len():
        _pf_serial_putc(msg[i] as u8)
        i = i + 1

fn _pf_serial_hex(value: u64):
    """Print a 64-bit value as 0x-prefixed hex to COM1."""
    _pf_serial_puts("0x")
    var shift = 60
    while shift >= 0:
        val nibble = ((value >> shift) & 0x0F) as u8
        val ch = if nibble < 10: (0x30 + nibble) as u8 else: (0x57 + nibble) as u8
        _pf_serial_putc(ch)
        shift = shift - 4

@export("C", name: "spl_x86_on_user_fault")
fn spl_x86_on_user_fault(rip: u64, cs: u64, cr2: u64):
    """Terminate a ring-3 process that took an unrecoverable fault.

    Called from the x86_64 rich-fault ISR stub (`_rich_fault_entry`) when the
    interrupt frame's CS indicates CPL=3. Emits a fatal-signal marker; the ISR
    stub parks the CPU afterwards so the fault never re-enters the faulting user
    instruction (the historical kernel re-fault runaway).

    Heap-free and self-contained by contract: the whole point is that the fault
    handler must not itself fault, so this path allocates nothing.
    """
    _pf_serial_puts("\n[fault] ring-3 process killed: SIGSEGV rip=")
    _pf_serial_hex(rip)
    _pf_serial_puts(" cr2=")
    _pf_serial_hex(cr2)
    _pf_serial_puts(" cs=")
    _pf_serial_hex(cs)
    _pf_serial_puts("\n")

# ============================================================================
# Kernel-mode #UD (ud2) fatal termination — C8 ud2-recovery fix
# ============================================================================
# `_rich_fault_entry`'s kernel-mode (CPL=0), no-error-code recovery path used
# to advance-RIP-by-2-and-iretq blindly for ANY vector that pushes no error
# code — including #UD (vector 6, invalid opcode). A `ud2` (opcode 0x0F 0x0B)
# is never a random invalid opcode to skip past: it is an INTENTIONAL trap
# instruction, e.g. the compiler's duck-dispatch-sentinel guard emitted by
# `compile_method_call_virtual`
# (src/compiler_rust/compiler/src/codegen/instr/closures_structs.rs) when a
# MIR vtable slot equals the `DUCK_DISPATCH_UNSUPPORTED_SLOT` sentinel.
# "Recovering" it turned an honest, deliberate abort into a silent wild-jump
# fault storm — the real root cause behind the C8 defect chain (see
# doc/08_tracking/bug/simpleos_native_build_entry_closure_codegen_defects_2026-07-17.md,
# C8-FIX lane item 3). The ISR stub now detects the `ud2` opcode at the
# faulting RIP before recovering and calls this function instead of
# iretq-ing back into the trap; the stub parks the CPU (cli/hlt loop)
# afterwards, so this must never return control to the faulting code.

@export("C", name: "spl_x86_on_kernel_ud2_fault")
fn spl_x86_on_kernel_ud2_fault(rip: u64):
    """Fatal-diagnostic marker for an unrecovered kernel-mode `ud2` (#UD) trap.

    Called from `_rich_fault_entry` only after it has confirmed the two bytes
    at the faulting RIP are the `ud2` opcode (0x0F 0x0B). Prints the vector
    and RIP, then the ISR stub halts — it never advances past the trap or
    iretqs back into it, unlike the old blind recovery.

    Heap-free and self-contained by contract: the whole point is that the
    fault handler must not itself fault, so this path allocates nothing and
    does not attempt to read/disassemble further than the two already-
    confirmed-readable opcode bytes at RIP (the stub already fetched them).
    """
    _pf_serial_puts("\n[fault] FATAL: kernel #UD (ud2) trap at rip=")
    _pf_serial_hex(rip)
    _pf_serial_puts(" vector=6 (#UD)\n")
    _pf_serial_puts("[fault] ud2 is an intentional trap (e.g. compiler duck-dispatch")
    _pf_serial_puts(" sentinel guard) — halting instead of resuming past it\n")
