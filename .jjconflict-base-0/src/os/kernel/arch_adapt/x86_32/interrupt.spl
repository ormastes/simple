# x86_32 Interrupt Adapter Scaffold
#
# Thin wrapper layer over the concrete x86_32 interrupt module.

use os.kernel.arch.x86_32.interrupt.{X86_32Interrupt}

fn interrupt_init():
    """Initialize the x86_32 interrupt subsystem."""
    var interrupt = X86_32Interrupt()
    interrupt.init()

fn interrupt_enable():
    """Enable interrupts globally on x86_32."""
    var interrupt = X86_32Interrupt()
    interrupt.enable()

fn interrupt_disable():
    """Disable interrupts globally on x86_32."""
    var interrupt = X86_32Interrupt()
    interrupt.disable()

fn interrupt_register_handler(vector: u32, handler_addr: u32):
    """Install an x86_32 IDT entry for the provided vector."""
    var interrupt = X86_32Interrupt()
    interrupt.register_handler(vector, handler_addr)

fn interrupt_unregister_handler(vector: u32):
    """Clear an x86_32 IDT entry for the provided vector."""
    var interrupt = X86_32Interrupt()
    interrupt.unregister_handler(vector)

fn interrupt_send_eoi(irq: u32):
    """Send PIC end-of-interrupt for the provided IRQ."""
    var interrupt = X86_32Interrupt()
    interrupt.send_eoi(irq)

fn interrupt_acknowledge(irq: u32):
    """Acknowledge the provided x86_32 IRQ."""
    var interrupt = X86_32Interrupt()
    interrupt.acknowledge(irq)

fn interrupt_enable_irq(irq: u32):
    """Unmask one x86_32 PIC IRQ line."""
    var interrupt = X86_32Interrupt()
    interrupt.enable_irq(irq)

fn interrupt_disable_irq(irq: u32):
    """Mask one x86_32 PIC IRQ line."""
    var interrupt = X86_32Interrupt()
    interrupt.disable_irq(irq)
