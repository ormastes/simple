#![allow(unnamed_duplicate_typed_args)]
# Render Extras — Pure Simple implementations of missing C FFI rendering functions
#
# Provides gradient_rect (gradient + rounded corners) and wallpaper rendering
# via the CompositorBackend trait. Works on all backends.

use os.compositor.display_backend.{CompositorBackend}
use os.compositor.rendering_primitives.{draw_line, filled_circle, gradient_radial, draw_vignette}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Gradient Rectangle with Rounded Corners
# ============================================================================

fn gradient_rect(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32,
                 color1: u32, color2: u32, radius: i32, alpha: u8):
    """Fill a rectangle with a vertical gradient and rounded corners.

    Combines gradient_v with corner masking for rounded rectangle appearance.
    Uses alpha blending for smooth edges.
    """
    if radius <= 0:
        # No rounding — simple gradient
        cap_gradient_v(backend, x, y, w, h, color1, color2)
        return

    val r = if radius > w / 2: w / 2 else: if radius > h / 2: h / 2 else: radius

    # Draw gradient row-by-row with corner masking
    # Uses segment-based blending to avoid .to_i32()/.to_u32() interpreter issues
    val segs: i32 = if h < 32: h else: 32
    val seg_h = if h / segs > 0: h / segs else: 1
    val max_seg = segs - 1

    var seg: i32 = 0
    while seg < segs:
        val seg_start = seg_h * seg
        val seg_end = if seg == max_seg: h else: seg_h * (seg + 1)
        val t: u8 = if max_seg > 0: 255 * seg / max_seg else: 0

        var row: i32 = seg_start
        while row < seg_end:
            # Calculate horizontal inset for rounded corners
            var inset: i32 = 0
            if row < r:
                val dy = r - row
                inset = r - isqrt(r * r - dy * dy)
            else if row >= h - r:
                val dy = row - (h - r - 1)
                inset = r - isqrt(r * r - dy * dy)

            val rx = x + inset
            val rw = w - inset * 2
            if rw > 0:
                # Base color1 then overlay color2 with increasing opacity
                cap_blend_rect(backend, rx, y + row, rw, 1, color1, alpha)
                if t > 0:
                    cap_blend_rect(backend, rx, y + row, rw, 1, color2, t)
            row = row + 1
        seg = seg + 1

# ============================================================================
# Desktop Wallpaper
# ============================================================================

fn draw_wallpaper(backend: CompositorBackend, style: i32):
    """Draw a decorative desktop wallpaper.

    Styles:
      0 — Midnight gradient (dark purple → black)
      1 — Ocean gradient (dark blue → teal)
      2 — Sunset gradient (dark orange → purple)
      3 — Forest gradient (dark green → black)
    """
    val sw = backend.width()
    val sh = backend.height()

    if style == 0:
        # Midnight: dark purple to black with subtle noise
        cap_gradient_v(backend, 0, 0, sw, sh, 0xFF100820, 0xFF020208)
    else if style == 1:
        # Ocean: dark blue to teal
        cap_gradient_v(backend, 0, 0, sw, sh, 0xFF0A1628, 0xFF082018)
    else if style == 2:
        # Sunset: dark orange to purple
        cap_gradient_v(backend, 0, 0, sw, sh, 0xFF281008, 0xFF180828)
    else:
        # Forest: dark green to black
        cap_gradient_v(backend, 0, 0, sw, sh, 0xFF082010, 0xFF040408)

    # Add subtle horizontal accent stripe at 30% height
    val stripe_y = sh * 3 / 10
    cap_blend_rect(backend, 0, stripe_y, sw, 2, 0x00FFFFFF, 15)

fn draw_wallpaper_enhanced(backend: CompositorBackend, dark: bool, accent: u32, accent2: u32, frame: i32):
    """Draw enhanced desktop wallpaper with stars, vignette, and tech grid.

    Ported from QEMU ARM64 wm_entry.spl draw_desktop wallpaper section.
    Shared between hosted and QEMU window managers.
    """
    val sw = backend.width()
    val sh = backend.height()

    # Base gradient
    if dark:
        cap_gradient_v(backend, 0, 0, sw, sh, 0xFF060508, 0xFF200840)
    else:
        cap_gradient_v(backend, 0, 0, sw, sh, 0xFFE8E0F0, 0xFFF5F0FF)

    # Accent gradient line at top
    cap_blend_rect(backend, 0, 0, sw, 1, accent, 60)
    cap_blend_rect(backend, sw / 2, 0, sw / 2, 1, accent2, 60)

    # Vignette (smooth edge darkening)
    draw_vignette(backend, 0, 0, sw, sh, 20)

    # Tech grid (dark theme only)
    if dark:
        var gy: i32 = 100
        while gy < sh - 100:
            cap_blend_rect(backend, 0, gy, sw, 1, 0x00FFFFFF, 2)
            gy = gy + 80
        var gx: i32 = 100
        while gx < sw - 100:
            cap_blend_rect(backend, gx, 100, 1, sh - 200, 0x00FFFFFF, 2)
            gx = gx + 80

    # Procedural wallpaper effects (stars, nebula, galaxy, moon, etc.)
    draw_wallpaper_procedural(backend, dark, accent, accent2)

    # Stars (dark theme only)
    if dark:
        # Animated shooting star 1 (120-frame cycle)
        val phase1 = frame % 120
        if phase1 < 40:
            val t1 = phase1
            val sx1 = 180 + t1 * 3
            val sy1 = 80 + t1
            val alpha1: u8 = if t1 < 10: t1 * 20 else: if t1 > 30: (40 - t1) * 20 else: 200
            _draw_star_line(backend, sx1, sy1, sx1 + 30, sy1 + 10, alpha1)

        # Animated shooting star 2 (180-frame cycle, offset)
        val phase2 = (frame + 60) % 180
        if phase2 < 50:
            val t2 = phase2
            val sx2 = 600 + t2 * 3
            val sy2 = 150 + t2
            val alpha2: u8 = if t2 < 10: t2 * 18 else: if t2 > 40: (50 - t2) * 18 else: 170
            _draw_star_line(backend, sx2, sy2, sx2 + 40, sy2 + 15, alpha2)

        # Static stars
        cap_blend_rect(backend, 150, 120, 4, 4, 0x00FFFFFF, 160)
        cap_blend_rect(backend, 700, 200, 4, 4, 0x00FFFFFF, 140)
        cap_blend_rect(backend, 850, 350, 4, 4, 0x00FFFFFF, 120)
        cap_blend_rect(backend, 400, 500, 4, 4, 0x00FFFFFF, 100)
        cap_blend_rect(backend, 950, 100, 4, 4, 0x00FFFFFF, 150)

    if not dark:
        # Light theme: subtle pastel overlay on lower half
        cap_blend_rect(backend, 0, sh / 2, sw, sh / 2, 0x00E8D0F0, 6)

    # Bottom warm tint
    cap_blend_rect(backend, 0, sh * 2 / 3, sw, sh / 3, 0x00201008, 6)

    # Ambient backlight bleed (top center)
    cap_blend_rect(backend, sw / 2 - 200, 0, 400, 20, 0x00FFFFFF, 3)
    # Global accent wash
    cap_blend_rect(backend, 0, 0, sw, sh, accent, 2)
    # Bottom gradient fade
    cap_blend_rect(backend, 0, sh - 2, sw, 2, 0x00000000, 20)

# ============================================================================
# Procedural Wallpaper Effects
# ============================================================================

fn draw_wallpaper_procedural(backend: CompositorBackend, dark: bool, accent: u32, accent2: u32):
    """Draw procedural wallpaper effects: stars, nebula, galaxy, moon, constellations, aurora.

    Called from draw_wallpaper_enhanced after base gradient/grid, before shooting stars.
    Shared between hosted (Mac/winit) and QEMU (ARM64/x86_64) window managers.
    """
    val sw = backend.width()
    val sh = backend.height()

    # ------------------------------------------------------------------
    # K12: 600 pseudo-random stars (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        var i: i32 = 0
        while i < 600:
            val hash = (i * 2654435761) & 0x7FFFFFFF
            val sx = hash % sw
            val sy = (hash / sw) % sh
            # Color variety: white 70%, cool blue 20%, warm amber 10%
            val color_sel = hash % 100
            var star_color: u32 = 0x00FFFFFF
            if color_sel >= 90:
                star_color = 0x00FFE8D0   # warm amber (10%)
            else if color_sel >= 70:
                star_color = 0x00C0D0FF   # cool blue (20%)
            # Alpha: 80-200 range based on hash
            val star_alpha: u8 = 80 + (hash % 121)
            # Size: every 5th star is 3x3, rest 2x2
            val star_size: i32 = if i % 5 == 0: 3 else: 2
            cap_blend_rect(backend, sx, sy, star_size, star_size, star_color, star_alpha)
            i = i + 1

    # ------------------------------------------------------------------
    # K13: 12 super-bright stars (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        _draw_bright_star(backend, sw / 8, sh / 6)
        _draw_bright_star(backend, sw * 3 / 8, sh / 8)
        _draw_bright_star(backend, sw * 5 / 8, sh / 5)
        _draw_bright_star(backend, sw * 7 / 8, sh / 7)
        _draw_bright_star(backend, sw / 5, sh * 2 / 5)
        _draw_bright_star(backend, sw * 2 / 5, sh * 3 / 8)
        _draw_bright_star(backend, sw * 3 / 5, sh / 3)
        _draw_bright_star(backend, sw * 4 / 5, sh * 2 / 7)
        _draw_bright_star(backend, sw / 4, sh * 3 / 5)
        _draw_bright_star(backend, sw / 2, sh * 4 / 7)
        _draw_bright_star(backend, sw * 3 / 4, sh * 3 / 7)
        _draw_bright_star(backend, sw * 7 / 10, sh * 5 / 8)

    # ------------------------------------------------------------------
    # K14: 11 nebula radial blobs (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        _draw_nebula_blob(backend, sw / 3, sh / 3, 165, 0x000A84FF, 44)
        _draw_nebula_blob(backend, sw * 2 / 3, sh * 2 / 3, 150, 0x00BB86FC, 37)
        _draw_nebula_blob(backend, sw / 2, sh * 3 / 4, 135, 0x0000D4AA, 27)
        _draw_nebula_blob(backend, sw * 3 / 4, sh / 4, 120, 0x00FF6B9D, 30)
        _draw_nebula_blob(backend, sw / 4, sh * 2 / 3, 105, 0x00FFD700, 24)
        _draw_nebula_blob(backend, sw / 2, sh / 4, 90, 0x004ECDC4, 20)
        _draw_nebula_blob(backend, sw * 3 / 4, sh / 2, 112, 0x00E040FB, 25)
        _draw_nebula_blob(backend, sw / 4, sh / 2, 97, 0x00FF7043, 22)
        _draw_nebula_blob(backend, sw / 2, sh / 2, 82, accent, 18)
        _draw_nebula_blob(backend, sw / 3, sh * 3 / 4, 75, accent2, 15)
        _draw_nebula_blob(backend, sw * 2 / 3, sh / 4, 68, 0x00FFFFFF, 12)

    # ------------------------------------------------------------------
    # K15: Galaxy spiral (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        val gcx = sw / 2
        val gcy = sh * 2 / 5
        # Core glow
        filled_circle(backend, gcx, gcy, 40, 0x00FFFFFF, 30)
        # Sin lookup table (scaled by 43): 0..15 for 0..337.5 degrees in 22.5-degree steps
        # sin_table[i] = round(43 * sin(i * 22.5 degrees))
        # [0, 17, 31, 40, 43, 40, 31, 17, 0, -17, -31, -40, -43, -40, -31, -17]
        # Spiral: 2 arms, 8 segments each
        # Arm 0 offset = 0 degrees, Arm 1 offset = 180 degrees (= 8 steps in table)
        var arm: i32 = 0
        while arm < 2:
            val arm_offset = arm * 8   # 0 or 8 steps (0 or 180 degrees)
            var seg: i32 = 0
            while seg < 8:
                val r = 60 + seg * 25
                # angle in table steps: each step = 22.5 degrees
                # We want arm_offset + seg*40 degrees = arm_offset + seg*40/22.5 steps
                # 40/22.5 ~ 1.78, approximate as seg*2 (= 45 degrees per segment)
                val angle_step = (arm_offset + seg * 2) % 16
                val cos_val = _sin_lookup((angle_step + 4) % 16)  # cos = sin(x + 90) = sin(x + 4 steps)
                val sin_val = _sin_lookup(angle_step)
                val px = gcx + r * cos_val / 43
                val py = gcy + r * sin_val / 43
                val sr = 8 - seg
                val sa: u8 = if 20 - seg * 2 > 0: 20 - seg * 2 else: 2
                if sr > 0:
                    filled_circle(backend, px, py, sr, 0x00FFFFFF, sa)
                seg = seg + 1
            arm = arm + 1

    # ------------------------------------------------------------------
    # K16: Crescent moon (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        val mx = sw * 4 / 5
        val my = sh / 5
        # Halo glow
        filled_circle(backend, mx, my, 50, 0x00FFFFFF, 18)
        # Moon body
        filled_circle(backend, mx, my, 30, 0x00FFFFFF, 85)
        # Shadow crescent (offset to darken one side)
        filled_circle(backend, mx - 12, my - 8, 28, 0x00060508, 200)

    # ------------------------------------------------------------------
    # K17: 7 constellation points (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        _draw_constellation_point(backend, 200, 180)
        _draw_constellation_point(backend, 280, 220)
        _draw_constellation_point(backend, 350, 190)
        _draw_constellation_point(backend, 420, 250)
        _draw_constellation_point(backend, 500, 210)
        _draw_constellation_point(backend, 560, 270)
        _draw_constellation_point(backend, 620, 230)

    # ------------------------------------------------------------------
    # K18: Aurora horizon glow (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        val aurora_y = sh * 2 / 3
        var ay: i32 = 0
        while ay < 60:
            val aurora_alpha: u8 = 40 - ay * 40 / 60
            if aurora_alpha > 0:
                cap_blend_rect(backend, 0, aurora_y + ay, sw, 1, 0x00200840, aurora_alpha)
            ay = ay + 1

    # ------------------------------------------------------------------
    # K19: Pastel clouds (light theme only)
    # ------------------------------------------------------------------
    if not dark:
        filled_circle(backend, sw / 4, sh / 3, 80, 0x00FFB5C5, 12)
        filled_circle(backend, sw * 3 / 4, sh / 2, 70, 0x0099CCFF, 10)
        filled_circle(backend, sw / 2, sh * 2 / 3, 75, 0x00E8C5FF, 8)

    # ------------------------------------------------------------------
    # K20, K21: Sun glow + lens flare (light theme only)
    # ------------------------------------------------------------------
    if not dark:
        val sun_x = sw / 2
        val sun_y: i32 = 80
        # Outer glow
        filled_circle(backend, sun_x, sun_y, 100, 0x00FFFFFF, 15)
        # Sun core
        filled_circle(backend, sun_x, sun_y, 40, 0x00FFFFFF, 25)
        # Sun center
        filled_circle(backend, sun_x, sun_y, 20, 0x00FFFDE0, 40)
        # Lens flare horizontal band
        cap_blend_rect(backend, sun_x - 75, 78, 150, 4, 0x00FFFFFF, 6)

    # ------------------------------------------------------------------
    # K22: Atmospheric haze (dark theme only)
    # ------------------------------------------------------------------
    if dark:
        cap_blend_rect(backend, 0, sh * 2 / 3, sw, 40, 0x000A84FF, 15)

    # ------------------------------------------------------------------
    # K24: 1% noise overlay (both themes)
    # ------------------------------------------------------------------
    var ny: i32 = 0
    while ny < sh:
        var nx: i32 = 0
        while nx < sw:
            if (ny * 7 + nx * 13) % 100 < 1:
                cap_blend_rect(backend, nx, ny, 1, 1, 0x00FFFFFF, 4)
            nx = nx + 10
        ny = ny + 10

fn _sin_lookup(idx: i32) -> i32:
    """Integer sine lookup table. 16 entries for 0..360 degrees in 22.5-degree steps.

    Values scaled by 43 (~100%). Returns sin(idx * 22.5 degrees) * 43.
    """
    val i = idx % 16
    if i == 0: return 0
    if i == 1: return 17
    if i == 2: return 31
    if i == 3: return 40
    if i == 4: return 43
    if i == 5: return 40
    if i == 6: return 31
    if i == 7: return 17
    if i == 8: return 0
    if i == 9: return -17
    if i == 10: return -31
    if i == 11: return -40
    if i == 12: return -43
    if i == 13: return -40
    if i == 14: return -31
    if i == 15: return -17
    0

fn _draw_bright_star(backend: CompositorBackend, x: i32, y: i32):
    """Draw a super-bright star with core, cross arms, and diagonal softening."""
    # Core: 4x4px, alpha 250
    cap_blend_rect(backend, x - 2, y - 2, 4, 4, 0x00FFFFFF, 250)
    # Cross arms: horizontal +-1px
    cap_blend_rect(backend, x - 3, y - 1, 1, 2, 0x00FFFFFF, 200)
    cap_blend_rect(backend, x + 2, y - 1, 1, 2, 0x00FFFFFF, 200)
    # Cross arms: vertical +-1px
    cap_blend_rect(backend, x - 1, y - 3, 2, 1, 0x00FFFFFF, 200)
    cap_blend_rect(backend, x - 1, y + 2, 2, 1, 0x00FFFFFF, 200)
    # Diagonal softening: 4 corner pixels
    cap_blend_rect(backend, x - 3, y - 3, 1, 1, 0x00FFFFFF, 100)
    cap_blend_rect(backend, x + 2, y - 3, 1, 1, 0x00FFFFFF, 100)
    cap_blend_rect(backend, x - 3, y + 2, 1, 1, 0x00FFFFFF, 100)
    cap_blend_rect(backend, x + 2, y + 2, 1, 1, 0x00FFFFFF, 100)

fn _draw_nebula_blob(backend: CompositorBackend, cx: i32, cy: i32, r: i32, color: u32, max_alpha: u8):
    """Draw a radial nebula blob using gradient_radial for smooth falloff."""
    gradient_radial(backend, cx, cy, r, color, max_alpha)

fn _draw_constellation_point(backend: CompositorBackend, x: i32, y: i32):
    """Draw a constellation point with 2x2 core and 4 adjacent glow pixels."""
    # Core: 2x2 at alpha 220
    cap_blend_rect(backend, x, y, 2, 2, 0x00FFFFFF, 220)
    # 4 adjacent pixels at alpha 120
    cap_blend_rect(backend, x - 1, y, 1, 2, 0x00FFFFFF, 120)
    cap_blend_rect(backend, x + 2, y, 1, 2, 0x00FFFFFF, 120)
    cap_blend_rect(backend, x, y - 1, 2, 1, 0x00FFFFFF, 120)
    cap_blend_rect(backend, x, y + 2, 2, 1, 0x00FFFFFF, 120)

fn _draw_star_line(backend: CompositorBackend, x1: i32, y1: i32, x2: i32, y2: i32, alpha: u8):
    """Draw a shooting star trail with head glow and fade tail."""
    # Head glow (bright point at start)
    cap_blend_rect(backend, x1 - 1, y1 - 1, 5, 5, 0x00FFFFFF, alpha)
    # Main trail (2px wide line)
    draw_line(backend, x1, y1, x2, y2, 0x00FFFFFF, 2, alpha)
    # Fade tail (extend line further at lower alpha)
    val tail_x = x2 + (x2 - x1) / 4
    val tail_y = y2 + (y2 - y1) / 4
    draw_line(backend, x2, y2, tail_x, tail_y, 0x00FFFFFF, 1, alpha / 2)

# ============================================================================
# Integer Square Root (for rounded corner calculation)
# ============================================================================

fn isqrt(n: i32) -> i32:
    """Integer square root via Newton's method."""
    if n <= 0: return 0
    if n == 1: return 1
    var x = n
    var y = (x + 1) / 2
    while y < x:
        x = y
        y = (x + n / x) / 2
    x
