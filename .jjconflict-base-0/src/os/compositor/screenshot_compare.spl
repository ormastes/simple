
use os.compositor.tolerance_profile.{ToleranceProfile, tolerance_profile_allows_acceptance}

class ComparisonResult:
    exact_match: bool
    match_percentage: i32
    different_pixels: i32
    max_channel_diff: i32
    total_channel_diff: i64
    passed: bool

type ChannelDiffResult = ComparisonResult

class DiffRegion:
    x: i32
    y: i32
    width: i32
    height: i32

fn _abs_i32(v: i32) -> i32:
    if v < 0: -v else: v

fn _channel_diff(a: u32, b: u32, shift: i32) -> i32:
    _abs_i32(((a >> shift) & 0xFF).to_i32() - ((b >> shift) & 0xFF).to_i32())

fn compare_pixel_buffers(a: [u32], b: [u32], width: i32, height: i32, threshold: i32) -> ComparisonResult:
    if width <= 0 or height <= 0:
        return ComparisonResult(exact_match: false, match_percentage: 0, different_pixels: 1, max_channel_diff: 255, total_channel_diff: 0, passed: false)
    val expected = if width > 0 and height > 0: width * height else: 0
    if a.len() != b.len() or a.len() != expected:
        return ComparisonResult(exact_match: false, match_percentage: 0, different_pixels: expected, max_channel_diff: 255, total_channel_diff: 0, passed: false)
    var diff_count = 0
    var exact_diff_count = 0
    var max_diff = 0
    var total: i64 = 0
    var idx = 0
    while idx < a.len():
        if a[idx] != b[idx]:
            exact_diff_count = exact_diff_count + 1
        val ar = _channel_diff(a[idx], b[idx], 16)
        val ag = _channel_diff(a[idx], b[idx], 8)
        val ab = _channel_diff(a[idx], b[idx], 0)
        val aa = _channel_diff(a[idx], b[idx], 24)
        val pixel_max = if ar > ag and ar > ab and ar > aa: ar elif ag > ab and ag > aa: ag elif ab > aa: ab else: aa
        total = total + ar.to_i64() + ag.to_i64() + ab.to_i64() + aa.to_i64()
        if pixel_max > max_diff:
            max_diff = pixel_max
        if pixel_max > threshold:
            diff_count = diff_count + 1
        idx = idx + 1
    val match_pct = if expected > 0: ((expected - diff_count) * 10000) / expected else: 10000
    ComparisonResult(exact_match: exact_diff_count == 0, match_percentage: match_pct, different_pixels: diff_count, max_channel_diff: max_diff, total_channel_diff: total, passed: diff_count == 0)

fn compare_exact(a: [u32], b: [u32], width: i32, height: i32) -> ComparisonResult:
    compare_pixel_buffers(a, b, width, height, 0)

fn compare_with_profile(a: [u32], b: [u32], width: i32, height: i32, profile: ToleranceProfile) -> ComparisonResult:
    val result = compare_pixel_buffers(a, b, width, height, profile.default_threshold)
    val profile_passed = result.match_percentage >= profile.min_match_pct
    val accepted = if tolerance_profile_allows_acceptance(profile): profile_passed else: result.exact_match
    ComparisonResult(
        exact_match: result.exact_match,
        match_percentage: result.match_percentage,
        different_pixels: result.different_pixels,
        max_channel_diff: result.max_channel_diff,
        total_channel_diff: result.total_channel_diff,
        passed: accepted
    )

fn compare_per_channel(a: [u32], b: [u32], width: i32, height: i32, threshold: i32) -> ComparisonResult:
    compare_pixel_buffers(a, b, width, height, threshold)

fn find_diff_regions(a: [u32], b: [u32], width: i32, height: i32, threshold: i32) -> [DiffRegion]:
    []

fn print_comparison_report(result: ComparisonResult):
    ()

fn print_channel_report(result: ComparisonResult):
    ()

fn format_percentage(value: i32) -> text:
    value.to_text()

fn generate_diff_image(a: [u32], b: [u32], width: i32, height: i32) -> [u32]:
    if width <= 0 or height <= 0:
        return []
    val expected = width * height
    var out: [u32] = []
    var idx = 0
    while idx < expected:
        if idx < a.len() and idx < b.len() and a[idx] == b[idx]:
            out.push(0xFF00FF00u32)
        else:
            out.push(0xFFFF00FFu32)
        idx = idx + 1
    out

export ChannelDiffResult
export compare_per_channel
export DiffRegion
export find_diff_regions
export print_comparison_report
export print_channel_report
export format_percentage
