# Shared WM action application helpers.
#
# Host and SimpleOS adapters should translate platform/wire requests into
# WmAction, then apply the common compositor mutations here.

use common.ui.builder.{column, panel, statusbar, text_widget, build_tree_with_title}
use common.ui.widget.{UITree}
use common.ui.web_render_api.{WebRenderRequest, WEB_RENDER_TARGET_SIMPLE_WEB}
use os.compositor.compositor.{Compositor}
use os.compositor.web_render_surface.{compositor_default_web_page_html}
use os.services.wm.wm_world.{WmAction, wm_action_none}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW, COMP_CREATE_WEB_WINDOW, COMP_DESTROY_WINDOW, COMP_UPDATE_TREE, COMP_FOCUS, COMP_RESIZE, COMP_MOVE, COMP_SET_TITLE, COMP_MINIMIZE, COMP_MAXIMIZE, COMP_RESTORE}

class WmActionApplyResult:
    compositor: Compositor
    window_id: u64
    applied: bool

class WmLifecycleWindowState:
    id: i64
    owner_port: i64
    title: text
    x: i32
    y: i32
    w: i32
    h: i32
    content: text
    process_id: i64
    app_id: text
    minimized: bool
    focused: bool

class WmLifecycleApplyResult:
    windows: [WmLifecycleWindowState]
    next_window_id: i64
    window_id: i64
    applied: bool

class WmPointerInteractionState:
    dragging: bool
    drag_window_id: i64
    drag_offset_x: i32
    drag_offset_y: i32
    resizing: bool
    resize_window_id: i64
    resize_start_x: i32
    resize_start_y: i32
    resize_start_w: i32
    resize_start_h: i32

class WmLifecyclePointerResult:
    windows: [WmLifecycleWindowState]
    next_window_id: i64
    interaction: WmPointerInteractionState

fn wm_action_remote_tree(window_id: u64, content: text) -> UITree:
    val wid_str = "{window_id}"
    val root = column("remote_{wid_str}", [
        panel("remote_content_{wid_str}", "", [
            text_widget("remote_text_{wid_str}", content)
        ]),
        statusbar("remote_status_{wid_str}", "Remote window {wid_str}", "Updated")
    ])
    build_tree_with_title(root, "Window {wid_str}", "dark")

fn wm_action_web_window_request(window_id: u64, title: text, url: text, width: i32, height: i32) -> WebRenderRequest:
    val surface_id = "web_window_{window_id}"
    val body = compositor_default_web_page_html(url)
    WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, title, body, "", "", width, height).with_surface(surface_id).with_pixel_output()

fn apply_wm_action_to_compositor(compositor: Compositor, action: WmAction) -> WmActionApplyResult:
    var next = compositor
    match action.kind:
        "create_window":
            val wid = next.create_remote_window(action.title, action.x, action.y, action.width, action.height, action.owner_port)
            next.set_window_identity(wid.value.to_i32(), action.process_id.to_i64(), action.app_id)
            return WmActionApplyResult(compositor: next, window_id: wid.value, applied: true)
        "create_web_window":
            val web_wid = next.create_remote_window(action.title, action.x, action.y, action.width, action.height, action.owner_port)
            next.update_window_tree(web_wid.value, wm_action_web_window_request(web_wid.value, action.title, action.content, action.width, action.height))
            next.set_window_identity(web_wid.value.to_i32(), action.process_id.to_i64(), action.app_id)
            return WmActionApplyResult(compositor: next, window_id: web_wid.value, applied: true)
        "destroy_window":
            next.destroy_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "focus":
            next.focus_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "resize":
            next.resize_window(action.window_id, action.width, action.height)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "move":
            next.move_window(action.window_id, action.x, action.y)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "set_title":
            next.set_window_title(action.window_id, action.title)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "minimize":
            next.minimize_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "maximize":
            next.maximize_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "restore":
            next.restore_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "update_tree":
            next.update_window_tree(action.window_id, wm_action_remote_tree(action.window_id, action.content))
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        _:
            return WmActionApplyResult(compositor: next, window_id: 0, applied: false)

fn wm_action_is_shared_lifecycle(kind: text) -> bool:
    kind == "create_window" or kind == "create_web_window" or kind == "destroy_window" or kind == "focus" or kind == "resize" or kind == "move" or kind == "set_title" or kind == "minimize" or kind == "maximize" or kind == "restore" or kind == "update_tree"

fn wm_action_with_app_id(action: WmAction, app_id: text) -> WmAction:
    WmAction(kind: action.kind, window_id: action.window_id, title: action.title, x: action.x, y: action.y, width: action.width, height: action.height, content: action.content, process_id: action.process_id, app_id: app_id, owner_port: action.owner_port, src_port: action.src_port)

fn wm_lifecycle_find_window_index(windows: [WmLifecycleWindowState], window_id: i64) -> i32:
    var i = 0
    while i < windows.len():
        if windows[i].id == window_id:
            return i
        i = i + 1
    -1

fn wm_lifecycle_focus_window(windows: [WmLifecycleWindowState], window_id: i64) -> [WmLifecycleWindowState]:
    val idx = wm_lifecycle_find_window_index(windows, window_id)
    if idx < 0:
        return windows
    var selected = windows[idx]
    selected.minimized = false
    selected.focused = true
    var out: [WmLifecycleWindowState] = []
    var i = 0
    while i < windows.len():
        if i != idx:
            var other = windows[i]
            other.focused = false
            out.push(other)
        i = i + 1
    out.push(selected)
    out

fn wm_lifecycle_destroy_window(windows: [WmLifecycleWindowState], window_id: i64) -> [WmLifecycleWindowState]:
    var out: [WmLifecycleWindowState] = []
    var i = 0
    while i < windows.len():
        if windows[i].id != window_id:
            out.push(windows[i])
        i = i + 1
    out

fn wm_taskbar_item_width(screen_width: i32, count: i32) -> i32:
    if count <= 0:
        return 0
    val available = screen_width - 80
    val fit = available / count
    if fit < 104: fit else: 104

fn wm_taskbar_dock_width(screen_width: i32, count: i32) -> i32:
    if count <= 0:
        return 0
    wm_taskbar_item_width(screen_width, count) * count + 20

fn wm_taskbar_item_x(screen_width: i32, count: i32, index: i32) -> i32:
    val dock_w = wm_taskbar_dock_width(screen_width, count)
    val start = (screen_width - dock_w) / 2 + 10
    start + index * wm_taskbar_item_width(screen_width, count)

fn wm_lifecycle_hit_taskbar(windows: [WmLifecycleWindowState], screen_width: i32, screen_height: i32, x: i32, y: i32) -> i64:
    val count = windows.len()
    if count == 0:
        return 0
    val dock_y = screen_height - 62
    if y < dock_y or y >= dock_y + 44:
        return 0
    var i = 0
    val item_w = wm_taskbar_item_width(screen_width, count)
    while i < count:
        val ix = wm_taskbar_item_x(screen_width, count, i)
        if x >= ix and x < ix + item_w:
            return windows[i].id
        i = i + 1
    0

fn wm_lifecycle_pointer_move(windows: [WmLifecycleWindowState], next_window_id: i64, desktop_width: i32, desktop_height: i32, interaction: WmPointerInteractionState, x: i32, y: i32) -> WmLifecyclePointerResult:
    var out_windows = windows
    var out_interaction = interaction
    if out_interaction.resize_window_id != 0:
        val idx = wm_lifecycle_find_window_index(out_windows, out_interaction.resize_window_id)
        if idx >= 0:
            var nw = out_interaction.resize_start_w + (x - out_interaction.resize_start_x)
            var nh = out_interaction.resize_start_h + (y - out_interaction.resize_start_y)
            if nw < 160:
                nw = 160
            if nh < 120:
                nh = 120
            val resized = apply_wm_action_to_lifecycle_windows(out_windows, next_window_id, desktop_width, desktop_height, wm_resize_action(out_interaction.resize_window_id, nw, nh))
            out_windows = resized.windows
        return WmLifecyclePointerResult(windows: out_windows, next_window_id: next_window_id, interaction: out_interaction)
    if out_interaction.drag_window_id != 0:
        val idx = wm_lifecycle_find_window_index(out_windows, out_interaction.drag_window_id)
        if idx >= 0:
            var nx = x - out_interaction.drag_offset_x
            var ny = y - out_interaction.drag_offset_y
            if nx < 0:
                nx = 0
            if ny < 48:
                ny = 48
            val moved = apply_wm_action_to_lifecycle_windows(out_windows, next_window_id, desktop_width, desktop_height, wm_move_action(out_interaction.drag_window_id, nx, ny))
            out_windows = moved.windows
        return WmLifecyclePointerResult(windows: out_windows, next_window_id: next_window_id, interaction: out_interaction)
    var i = 0
    while i < out_windows.len():
        val win = out_windows[i]
        if x >= win.x + win.w - 8 and x <= win.x + win.w and y >= win.y + win.h - 8 and y <= win.y + win.h:
            out_interaction.resize_window_id = win.id
            out_interaction.resize_start_x = x
            out_interaction.resize_start_y = y
            out_interaction.resize_start_w = win.w
            out_interaction.resize_start_h = win.h
        i = i + 1
    WmLifecyclePointerResult(windows: out_windows, next_window_id: next_window_id, interaction: out_interaction)

fn wm_lifecycle_left_button(interaction: WmPointerInteractionState, down: bool) -> WmPointerInteractionState:
    var out = interaction
    if down:
        if out.resize_window_id != 0:
            out.resizing = true
    else:
        out.resizing = false
        out.resize_window_id = 0
    out

fn apply_wm_action_to_lifecycle_windows(windows: [WmLifecycleWindowState], next_window_id: i64, desktop_width: i32, desktop_height: i32, action: WmAction) -> WmLifecycleApplyResult:
    var out_windows = windows
    var next_id = next_window_id
    if not wm_action_is_shared_lifecycle(action.kind):
        return WmLifecycleApplyResult(windows: out_windows, next_window_id: next_id, window_id: 0, applied: false)
    if action.kind == "create_window" or action.kind == "create_web_window":
        val id = next_id
        next_id = next_id + 1
        out_windows.push(WmLifecycleWindowState(id: id, owner_port: action.owner_port.to_i64(), title: action.title, x: action.x, y: action.y, w: action.width, h: action.height, content: action.content, process_id: action.process_id.to_i64(), app_id: action.app_id, minimized: false, focused: true))
        out_windows = wm_lifecycle_focus_window(out_windows, id)
        return WmLifecycleApplyResult(windows: out_windows, next_window_id: next_id, window_id: id, applied: true)
    if action.kind == "destroy_window":
        return WmLifecycleApplyResult(windows: wm_lifecycle_destroy_window(out_windows, action.window_id.to_i64()), next_window_id: next_id, window_id: action.window_id.to_i64(), applied: true)
    if action.kind == "focus":
        return WmLifecycleApplyResult(windows: wm_lifecycle_focus_window(out_windows, action.window_id.to_i64()), next_window_id: next_id, window_id: action.window_id.to_i64(), applied: true)
    val i = wm_lifecycle_find_window_index(out_windows, action.window_id.to_i64())
    if i < 0:
        return WmLifecycleApplyResult(windows: out_windows, next_window_id: next_id, window_id: action.window_id.to_i64(), applied: false)
    var win = out_windows[i]
    if action.kind == "update_tree":
        win.content = action.content
    elif action.kind == "resize":
        win.w = action.width
        win.h = action.height
    elif action.kind == "move":
        win.x = action.x
        win.y = action.y
    elif action.kind == "set_title":
        win.title = action.title
    elif action.kind == "minimize":
        win.minimized = true
        win.focused = false
    elif action.kind == "maximize":
        win.minimized = false
        win.focused = true
        win.x = 0
        win.y = 48
        win.w = desktop_width
        win.h = desktop_height - 96
    elif action.kind == "restore":
        win.minimized = false
        win.focused = true
    out_windows[i] = win
    WmLifecycleApplyResult(windows: out_windows, next_window_id: next_id, window_id: action.window_id.to_i64(), applied: true)

fn wm_action_from_bridge_request(owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text) -> WmAction:
    var src_port: u64 = 0
    if owner_port > 0:
        src_port = owner_port.to_u64()
    var pid: u64 = src_port
    if process_id > 0:
        pid = process_id.to_u64()
    val wid = if window_id > 0: window_id.to_u64() else: 0
    if method == COMP_CREATE_WEB_WINDOW.to_i64():
        return WmAction(kind: "create_web_window", window_id: 0, title: title, x: x, y: y, width: w, height: h, content: content, process_id: pid, app_id: app_id, owner_port: src_port, src_port: src_port)
    if method == COMP_CREATE_WINDOW.to_i64() or (window_id == 0 and title.len() > 0 and w > 0 and h > 0):
        return WmAction(kind: "create_window", window_id: 0, title: title, x: x, y: y, width: w, height: h, content: content, process_id: pid, app_id: app_id, owner_port: src_port, src_port: src_port)
    if method == COMP_DESTROY_WINDOW.to_i64():
        return WmAction(kind: "destroy_window", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_UPDATE_TREE.to_i64():
        return WmAction(kind: "update_tree", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: content, process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_FOCUS.to_i64():
        return WmAction(kind: "focus", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_RESIZE.to_i64():
        return WmAction(kind: "resize", window_id: wid, title: "", x: 0, y: 0, width: w, height: h, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_MOVE.to_i64():
        return WmAction(kind: "move", window_id: wid, title: "", x: x, y: y, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_SET_TITLE.to_i64():
        return WmAction(kind: "set_title", window_id: wid, title: title, x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_MINIMIZE.to_i64():
        return WmAction(kind: "minimize", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_MAXIMIZE.to_i64():
        return WmAction(kind: "maximize", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_RESTORE.to_i64():
        return WmAction(kind: "restore", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    wm_action_none()

fn wm_move_action(window_id: i64, x: i32, y: i32) -> WmAction:
    WmAction(kind: "move", window_id: window_id.to_u64(), title: "", x: x, y: y, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: 0)

fn wm_resize_action(window_id: i64, width: i32, height: i32) -> WmAction:
    WmAction(kind: "resize", window_id: window_id.to_u64(), title: "", x: 0, y: 0, width: width, height: height, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: 0)

fn wm_focus_action(window_id: i64) -> WmAction:
    WmAction(kind: "focus", window_id: window_id.to_u64(), title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: 0)

fn wm_destroy_action(window_id: i64) -> WmAction:
    WmAction(kind: "destroy_window", window_id: window_id.to_u64(), title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: 0)
