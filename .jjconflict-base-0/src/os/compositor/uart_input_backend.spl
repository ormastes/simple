# UART Input Backend — PL011 serial input for ARM64
#
# Implements InputBackend trait by polling the PL011 UART Data Register.
# Maps ASCII character codes to KeyEvent/Key values for the compositor.
#
# ARM64 QEMU virt PL011 UART at 0x09000000.
# No mouse support (UART is character-based).

use os.compositor.input_backend.{InputBackend}
use os.drivers.input.ps2_keyboard.{KeyEvent, Key}
use os.drivers.input.ps2_mouse.{MouseEvent}

extern fn rt_mmio_read_u8(addr: u64) -> u64

# ============================================================================
# PL011 Constants
# ============================================================================

val UART_DR: u64 = 0x000       # Data Register offset
val UART_FR: u64 = 0x018       # Flag Register offset
val UART_FR_RXFE: u64 = 0x10   # Receive FIFO empty (bit 4)

# ============================================================================
# UartInputBackend
# ============================================================================

class UartInputBackend:
    """InputBackend wrapping PL011 UART serial input.

    Polls the UART data register for ASCII characters and maps them
    to KeyEvent/Key values. No mouse support -- poll_mouse always
    returns nil.
    """
    base_addr: u64
    alt_state: bool
    shift_state: bool
    ctrl_state: bool

# ============================================================================
# InputBackend Trait Implementation
# ============================================================================

impl InputBackend for UartInputBackend:

    me poll_key() -> KeyEvent?:
        """Poll UART for a character and convert to KeyEvent."""
        val fr = rt_mmio_read_u8(self.base_addr + UART_FR)
        if (fr & UART_FR_RXFE) != 0:
            return nil

        val ch = rt_mmio_read_u8(self.base_addr + UART_DR) & 0xFF

        # Update modifier state from Ctrl codes (Ctrl+A = 0x01, etc.)
        if ch >= 0x01 and ch <= 0x1A and ch != 0x09 and ch != 0x0D and ch != 0x0A:
            self.ctrl_state = true
        else:
            self.ctrl_state = false

        # Track shift state from uppercase letters
        if ch >= 0x41 and ch <= 0x5A:
            self.shift_state = true
        else:
            self.shift_state = false

        # Map ASCII to Key enum
        val key = uart_char_to_key(ch)
        if key == nil:
            return nil

        KeyEvent.Press(key: key.unwrap())

    me poll_mouse() -> MouseEvent?:
        """No mouse support on UART."""
        nil

    fn alt_held() -> bool:
        self.alt_state

    fn shift_held() -> bool:
        self.shift_state

    fn ctrl_held() -> bool:
        self.ctrl_state

    fn key_to_char(key: Key) -> text?:
        """Convert Key to character string."""
        if self.shift_state:
            match key:
                case Key.A: "A"
                case Key.B: "B"
                case Key.C: "C"
                case Key.D: "D"
                case Key.E: "E"
                case Key.F: "F"
                case Key.G: "G"
                case Key.H: "H"
                case Key.I: "I"
                case Key.J: "J"
                case Key.K: "K"
                case Key.L: "L"
                case Key.M: "M"
                case Key.N: "N"
                case Key.O: "O"
                case Key.P: "P"
                case Key.Q: "Q"
                case Key.R: "R"
                case Key.S: "S"
                case Key.T: "T"
                case Key.U: "U"
                case Key.V: "V"
                case Key.W: "W"
                case Key.X: "X"
                case Key.Y: "Y"
                case Key.Z: "Z"
                case Key.Space: " "
                case Key.Enter: "\n"
                case _: nil
        else:
            match key:
                case Key.A: "a"
                case Key.B: "b"
                case Key.C: "c"
                case Key.D: "d"
                case Key.E: "e"
                case Key.F: "f"
                case Key.G: "g"
                case Key.H: "h"
                case Key.I: "i"
                case Key.J: "j"
                case Key.K: "k"
                case Key.L: "l"
                case Key.M: "m"
                case Key.N: "n"
                case Key.O: "o"
                case Key.P: "p"
                case Key.Q: "q"
                case Key.R: "r"
                case Key.S: "s"
                case Key.T: "t"
                case Key.U: "u"
                case Key.V: "v"
                case Key.W: "w"
                case Key.X: "x"
                case Key.Y: "y"
                case Key.Z: "z"
                case Key.Space: " "
                case Key.Enter: "\n"
                case Key.Tab: "\t"
                case Key.Num0: "0"
                case Key.Num1: "1"
                case Key.Num2: "2"
                case Key.Num3: "3"
                case Key.Num4: "4"
                case Key.Num5: "5"
                case Key.Num6: "6"
                case Key.Num7: "7"
                case Key.Num8: "8"
                case Key.Num9: "9"
                case _: nil

# ============================================================================
# Constructor
# ============================================================================

impl UartInputBackend:

    static fn create(base_addr: u64) -> UartInputBackend:
        """Create a UART input backend from PL011 base address."""
        UartInputBackend(
            base_addr: base_addr,
            alt_state: false,
            shift_state: false,
            ctrl_state: false
        )

    static fn default_arm64() -> UartInputBackend:
        """Create with default ARM64 QEMU virt PL011 address (0x09000000)."""
        UartInputBackend.create(0x09000000)

# ============================================================================
# UART Character to Key Mapping
# ============================================================================

fn uart_char_to_key(ch: u64) -> Key?:
    """Map ASCII character code to Key enum value."""
    if ch == 0x1B: return Key.Escape        # ESC
    if ch == 0x0D: return Key.Enter          # CR
    if ch == 0x0A: return Key.Enter          # LF
    if ch == 0x09: return Key.Tab            # Tab
    if ch == 0x20: return Key.Space          # Space
    if ch == 0x7F: return Key.Backspace      # DEL
    if ch == 0x08: return Key.Backspace      # BS

    # Lowercase letters (a=0x61 .. z=0x7A)
    if ch == 0x61: return Key.A
    if ch == 0x62: return Key.B
    if ch == 0x63: return Key.C
    if ch == 0x64: return Key.D
    if ch == 0x65: return Key.E
    if ch == 0x66: return Key.F
    if ch == 0x67: return Key.G
    if ch == 0x68: return Key.H
    if ch == 0x69: return Key.I
    if ch == 0x6A: return Key.J
    if ch == 0x6B: return Key.K
    if ch == 0x6C: return Key.L
    if ch == 0x6D: return Key.M
    if ch == 0x6E: return Key.N
    if ch == 0x6F: return Key.O
    if ch == 0x70: return Key.P
    if ch == 0x71: return Key.Q
    if ch == 0x72: return Key.R
    if ch == 0x73: return Key.S
    if ch == 0x74: return Key.T
    if ch == 0x75: return Key.U
    if ch == 0x76: return Key.V
    if ch == 0x77: return Key.W
    if ch == 0x78: return Key.X
    if ch == 0x79: return Key.Y
    if ch == 0x7A: return Key.Z

    # Uppercase letters (A=0x41 .. Z=0x5A) -> same Key variants
    if ch == 0x41: return Key.A
    if ch == 0x42: return Key.B
    if ch == 0x43: return Key.C
    if ch == 0x44: return Key.D
    if ch == 0x45: return Key.E
    if ch == 0x46: return Key.F
    if ch == 0x47: return Key.G
    if ch == 0x48: return Key.H
    if ch == 0x49: return Key.I
    if ch == 0x4A: return Key.J
    if ch == 0x4B: return Key.K
    if ch == 0x4C: return Key.L
    if ch == 0x4D: return Key.M
    if ch == 0x4E: return Key.N
    if ch == 0x4F: return Key.O
    if ch == 0x50: return Key.P
    if ch == 0x51: return Key.Q
    if ch == 0x52: return Key.R
    if ch == 0x53: return Key.S
    if ch == 0x54: return Key.T
    if ch == 0x55: return Key.U
    if ch == 0x56: return Key.V
    if ch == 0x57: return Key.W
    if ch == 0x58: return Key.X
    if ch == 0x59: return Key.Y
    if ch == 0x5A: return Key.Z

    # Digits (0=0x30 .. 9=0x39)
    if ch == 0x30: return Key.Num0
    if ch == 0x31: return Key.Num1
    if ch == 0x32: return Key.Num2
    if ch == 0x33: return Key.Num3
    if ch == 0x34: return Key.Num4
    if ch == 0x35: return Key.Num5
    if ch == 0x36: return Key.Num6
    if ch == 0x37: return Key.Num7
    if ch == 0x38: return Key.Num8
    if ch == 0x39: return Key.Num9

    # Ctrl+letter codes (0x01..0x1A -> Key.A..Key.Z)
    if ch == 0x01: return Key.A
    if ch == 0x02: return Key.B
    if ch == 0x03: return Key.C
    if ch == 0x04: return Key.D
    if ch == 0x05: return Key.E
    if ch == 0x06: return Key.F
    if ch == 0x07: return Key.G
    if ch == 0x0B: return Key.K
    if ch == 0x0C: return Key.L
    if ch == 0x0E: return Key.N
    if ch == 0x0F: return Key.O
    if ch == 0x10: return Key.P
    if ch == 0x11: return Key.Q
    if ch == 0x12: return Key.R
    if ch == 0x13: return Key.S
    if ch == 0x14: return Key.T
    if ch == 0x15: return Key.U
    if ch == 0x16: return Key.V
    if ch == 0x17: return Key.W
    if ch == 0x18: return Key.X
    if ch == 0x19: return Key.Y
    if ch == 0x1A: return Key.Z

    nil
