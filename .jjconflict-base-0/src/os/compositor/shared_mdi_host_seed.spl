# HostCompositor seeding for the shared Simple Web MDI surface set.

use os.compositor.host_compositor_entry.{HostCompositor}
use os.compositor.shared_mdi_setup.{shared_mdi_surfaces}
use os.userlib.ipc_protocol.{COMP_CREATE_WEB_WINDOW}

fn seed_host_compositor_shared_mdi(comp: HostCompositor):
    for surface in shared_mdi_surfaces():
        comp.apply_bridge_request(
            surface.process_id,
            surface.process_id,
            COMP_CREATE_WEB_WINDOW.to_i64(),
            0,
            surface.title,
            surface.x,
            surface.y,
            surface.w,
            surface.h,
            surface.content,
            surface.process_id,
            surface.app_id
        )
