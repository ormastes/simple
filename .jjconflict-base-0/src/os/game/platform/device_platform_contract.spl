"""Game device platform contracts for SimpleOS.

Readiness markers for graphics, audio, input, network, filesystem, and CPU fallback.
"""

class DeviceReadinessMarker:
    device_type: text
    backend: text
    status: text
    notes: text

    static fn ready(dtype: text, backend: text) -> DeviceReadinessMarker:
        DeviceReadinessMarker(device_type: dtype, backend: backend, status: "ready", notes: "")

    static fn partial(dtype: text, backend: text, note: text) -> DeviceReadinessMarker:
        DeviceReadinessMarker(device_type: dtype, backend: backend, status: "partial", notes: note)

    static fn not_ready(dtype: text, backend: text, note: text) -> DeviceReadinessMarker:
        DeviceReadinessMarker(device_type: dtype, backend: backend, status: "not_ready", notes: note)

    me is_ready() -> bool:
        self.status == "ready"

    me is_partial() -> bool:
        self.status == "partial"

    me summary() -> text:
        self.device_type + "/" + self.backend + "=" + self.status +
            if self.notes == "" { "" } else { "(" + self.notes + ")" }


class GameDevicePlatform:
    graphics_status: text
    graphics_backend: text
    audio_status: text
    audio_backend: text
    input_status: text
    input_backend: text
    network_status: text
    network_backend: text
    filesystem_status: text
    filesystem_backend: text
    cpu_fallback_status: text
    cpu_fallback_backend: text

    static fn create(
        gfx_status: text, gfx_backend: text,
        aud_status: text, aud_backend: text,
        inp_status: text, inp_backend: text,
        net_status: text, net_backend: text,
        fs_status: text, fs_backend: text,
        cpu_status: text, cpu_backend: text
    ) -> GameDevicePlatform:
        GameDevicePlatform(
            graphics_status: gfx_status,
            graphics_backend: gfx_backend,
            audio_status: aud_status,
            audio_backend: aud_backend,
            input_status: inp_status,
            input_backend: inp_backend,
            network_status: net_status,
            network_backend: net_backend,
            filesystem_status: fs_status,
            filesystem_backend: fs_backend,
            cpu_fallback_status: cpu_status,
            cpu_fallback_backend: cpu_backend
        )

    me graphics_ready() -> bool:
        self.graphics_status == "ready"

    me audio_ready() -> bool:
        self.audio_status == "ready"

    me input_ready() -> bool:
        self.input_status == "ready"

    me network_ready() -> bool:
        self.network_status == "ready"

    me filesystem_ready() -> bool:
        self.filesystem_status == "ready"

    me cpu_fallback_ready() -> bool:
        self.cpu_fallback_status == "ready"

    me all_core_ready() -> bool:
        self.graphics_ready() and self.audio_ready() and self.input_ready() and self.filesystem_ready()

    me ready_count() -> i64:
        var n = 0
        if self.graphics_ready(): n = n + 1
        if self.audio_ready(): n = n + 1
        if self.input_ready(): n = n + 1
        if self.network_ready(): n = n + 1
        if self.filesystem_ready(): n = n + 1
        if self.cpu_fallback_ready(): n = n + 1
        n

    me report() -> text:
        "device_platform: gfx=" + self.graphics_status +
            " audio=" + self.audio_status +
            " input=" + self.input_status +
            " net=" + self.network_status +
            " fs=" + self.filesystem_status +
            " cpu_fallback=" + self.cpu_fallback_status +
            " ready=" + self.ready_count().to_text() + "/6"


fn build_simpleos_game_device_platform() -> GameDevicePlatform:
    GameDevicePlatform.create(
        "partial", "virtio-gpu",
        "partial", "miniaudio",
        "ready", "evdev",
        "partial", "virtio-net",
        "ready", "fat32",
        "not_ready", "none"
    )
