class SteamSupportApiSurface:
    app_id: i64
    app_name: text
    compatdata_path: text
    cloud_quota_bytes: i64
    overlay_enabled: bool
    input_enabled: bool
    achievements_enabled: bool
    stats_enabled: bool
    cloud_enabled: bool
    lobby_enabled: bool
    drm_enabled: bool
    sffi_abi: text

class SteamApiState:
    initialized: bool
    app_id: i64
    app_name: text
    compatdata_path: text
    cloud_quota_bytes: i64
    overlay_enabled: bool
    input_enabled: bool
    achievements_enabled: bool
    stats_enabled: bool
    cloud_enabled: bool
    lobby_enabled: bool
    drm_enabled: bool
    sffi_abi: text
    session_started: bool
    achievement_name: text
    achievement_unlocked: bool
    stat_name: text
    stat_value: i64
    cloud_file: text
    cloud_bytes_written: i64
    lobby_id: text
    lobby_member_count: i64
    drm_ticket: text
    crash_log_path: text
    launch_options: text
    runtime_env: text
    friend_id: text
    friend_persona: text
    network_peer: text
    network_channel: text
    network_message: text
    auth_session_ticket: text
    install_dir: text
    overlay_dialog: text
    input_action: text
    input_action_value: i64
    screenshot_path: text
    ugc_item_id: text
    ugc_title: text
    microtxn_order_id: text
    microtxn_authorized: bool
    persona_state: text
    p2p_packet_peer: text
    p2p_packet_bytes: i64

class SteamApiFacade:
    surface: SteamSupportApiSurface
    state: SteamApiState

class SteamBackendProbe:
    client_present: bool
    required_symbol_count: i64
    matched_symbol_count: i64
    required_os_capability_count: i64
    matched_os_capability_count: i64
    ready: bool
    blocker: text

pub fn steam_support_api_surface(app_id: i64, app_name: text, compatdata_path: text) -> SteamSupportApiSurface:
    SteamSupportApiSurface(
        app_id: app_id,
        app_name: app_name,
        compatdata_path: compatdata_path,
        cloud_quota_bytes: 104857600,
        overlay_enabled: true,
        input_enabled: true,
        achievements_enabled: true,
        stats_enabled: true,
        cloud_enabled: true,
        lobby_enabled: true,
        drm_enabled: true,
        sffi_abi: "simple-steam-sffi-v1"
    )

pub fn steam_api_facade(surface: SteamSupportApiSurface) -> SteamApiFacade:
    val state = SteamApiState(
        initialized: false,
        app_id: surface.app_id,
        app_name: surface.app_name,
        compatdata_path: surface.compatdata_path,
        cloud_quota_bytes: surface.cloud_quota_bytes,
        overlay_enabled: surface.overlay_enabled,
        input_enabled: surface.input_enabled,
        achievements_enabled: surface.achievements_enabled,
        stats_enabled: surface.stats_enabled,
        cloud_enabled: surface.cloud_enabled,
        lobby_enabled: surface.lobby_enabled,
        drm_enabled: surface.drm_enabled,
        sffi_abi: surface.sffi_abi,
        session_started: false,
        achievement_name: "",
        achievement_unlocked: false,
        stat_name: "",
        stat_value: 0,
        cloud_file: "",
        cloud_bytes_written: 0,
        lobby_id: "",
        lobby_member_count: 0,
        drm_ticket: "",
        crash_log_path: "",
        launch_options: "",
        runtime_env: "",
        friend_id: "",
        friend_persona: "",
        network_peer: "",
        network_channel: "",
        network_message: "",
        auth_session_ticket: "",
        install_dir: "",
        overlay_dialog: "",
        input_action: "",
        input_action_value: 0,
        screenshot_path: "",
        ugc_item_id: "",
        ugc_title: "",
        microtxn_order_id: "",
        microtxn_authorized: false,
        persona_state: "",
        p2p_packet_peer: "",
        p2p_packet_bytes: 0
    )
    SteamApiFacade(surface: surface, state: state)

pub fn steam_api_init(facade: SteamApiFacade) -> SteamApiFacade:
    var next = facade
    next.state.initialized = true
    next

pub fn steam_api_ready(facade: SteamApiFacade) -> bool:
    facade.state.initialized and facade.state.app_id > 0 and facade.state.compatdata_path != ""

pub fn steam_api_readiness_blocker(facade: SteamApiFacade) -> text:
    if facade.state.initialized == false:
        return "SteamAPI_Init not called"
    if facade.state.app_id <= 0:
        return "missing app id"
    if facade.state.compatdata_path == "":
        return "missing compatdata path"
    ""

pub fn steam_api_begin_session(facade: SteamApiFacade) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade):
        next.state.session_started = true
    next

pub fn steam_api_unlock_achievement(facade: SteamApiFacade, name: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.achievements_enabled and name != "":
        next.state.achievement_name = name
        next.state.achievement_unlocked = true
    next

pub fn steam_api_write_stat(facade: SteamApiFacade, name: text, value: i64) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.stats_enabled and name != "":
        next.state.stat_name = name
        next.state.stat_value = value
    next

pub fn steam_api_cloud_write(facade: SteamApiFacade, file: text, bytes: i64) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.cloud_enabled and file != "" and bytes >= 0 and bytes <= facade.state.cloud_quota_bytes:
        next.state.cloud_file = file
        next.state.cloud_bytes_written = bytes
    next

pub fn steam_api_join_lobby(facade: SteamApiFacade, lobby_id: text, member_count: i64) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.lobby_enabled and lobby_id != "" and member_count > 0:
        next.state.lobby_id = lobby_id
        next.state.lobby_member_count = member_count
    next

pub fn steam_api_request_drm_ticket(facade: SteamApiFacade, ticket: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.drm_enabled and ticket != "":
        next.state.drm_ticket = ticket
    next

pub fn steam_api_crash_log(facade: SteamApiFacade, path: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and path != "":
        next.state.crash_log_path = path
    next

pub fn steam_api_launch_options(facade: SteamApiFacade, options: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade):
        next.state.launch_options = options
    next

pub fn steam_api_runtime_env(facade: SteamApiFacade, runtime: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and runtime != "":
        next.state.runtime_env = runtime
    next

pub fn steam_api_friend_identity(facade: SteamApiFacade, friend_id: text, persona: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and friend_id != "" and persona != "":
        next.state.friend_id = friend_id
        next.state.friend_persona = persona
    next

pub fn steam_api_network_message(facade: SteamApiFacade, peer: text, channel: text, message: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and peer != "" and channel != "" and message != "":
        next.state.network_peer = peer
        next.state.network_channel = channel
        next.state.network_message = message
    next

pub fn steam_api_auth_session_ticket(facade: SteamApiFacade, ticket: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and ticket != "":
        next.state.auth_session_ticket = ticket
    next

pub fn steam_api_app_install_dir(facade: SteamApiFacade, install_dir: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and install_dir != "":
        next.state.install_dir = install_dir
    next

pub fn steam_api_activate_overlay(facade: SteamApiFacade, dialog: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.overlay_enabled and dialog != "":
        next.state.overlay_dialog = dialog
    next

pub fn steam_api_input_action(facade: SteamApiFacade, action: text, value: i64) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and facade.state.input_enabled and action != "":
        next.state.input_action = action
        next.state.input_action_value = value
    next

pub fn steam_api_write_screenshot(facade: SteamApiFacade, path: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and path != "":
        next.state.screenshot_path = path
    next

pub fn steam_api_publish_ugc(facade: SteamApiFacade, item_id: text, title: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and item_id != "" and title != "":
        next.state.ugc_item_id = item_id
        next.state.ugc_title = title
    next

pub fn steam_api_authorize_microtxn(facade: SteamApiFacade, order_id: text, authorized: bool) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and order_id != "":
        next.state.microtxn_order_id = order_id
        next.state.microtxn_authorized = authorized
    next

pub fn steam_api_persona_state(facade: SteamApiFacade, persona_state: text) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and persona_state != "":
        next.state.persona_state = persona_state
    next

pub fn steam_api_p2p_packet(facade: SteamApiFacade, peer: text, bytes: i64) -> SteamApiFacade:
    var next = facade
    if steam_api_ready(facade) and peer != "" and bytes >= 0:
        next.state.p2p_packet_peer = peer
        next.state.p2p_packet_bytes = bytes
    next

pub fn steam_api_interfaces() -> [text]:
    [
        "ISteamApps",
        "ISteamAppTicket",
        "ISteamClient",
        "ISteamController",
        "ISteamFriends",
        "ISteamGameCoordinator",
        "ISteamGameServer",
        "ISteamGameServerStats",
        "ISteamHTMLSurface",
        "ISteamHTTP",
        "ISteamInput",
        "ISteamInventory",
        "ISteamMatchmaking",
        "ISteamMatchmakingServers",
        "ISteamMusic",
        "ISteamNetworking",
        "ISteamNetworkingMessages",
        "ISteamNetworkingSockets",
        "ISteamNetworkingUtils",
        "ISteamParties",
        "ISteamRemotePlay",
        "ISteamRemoteStorage",
        "ISteamScreenshots",
        "ISteamTimeline",
        "ISteamUGC",
        "ISteamUser",
        "ISteamUserStats",
        "ISteamUtils",
        "ISteamVideo",
        "SteamEncryptedAppTicket",
        "steam_api",
        "steam_gameserver"
    ]

pub fn steam_api_interface_count() -> i64:
    steam_api_interfaces().len()

pub fn steam_api_interface_supported(name: text) -> bool:
    for interface_name in steam_api_interfaces():
        if interface_name == name:
            return true
    false

pub fn steam_api_backend_required_symbols() -> [text]:
    [
        "SteamAPI_Init",
        "SteamAPI_Shutdown",
        "SteamAPI_RestartAppIfNecessary",
        "SteamAPI_RunCallbacks",
        "SteamAPI_GetHSteamUser",
        "SteamAPI_GetHSteamPipe",
        "SteamAPI_ISteamApps",
        "SteamAPI_ISteamFriends",
        "SteamAPI_ISteamInput",
        "SteamAPI_ISteamMatchmaking",
        "SteamAPI_ISteamNetworkingSockets",
        "SteamAPI_ISteamRemoteStorage",
        "SteamAPI_ISteamScreenshots",
        "SteamAPI_ISteamUGC",
        "SteamAPI_ISteamUser",
        "SteamAPI_ISteamUserStats",
        "SteamAPI_ISteamUtils",
        "SteamGameServer_Init",
        "SteamGameServer_Shutdown",
        "SteamInternal_CreateInterface"
    ]

pub fn steam_api_backend_required_os_capabilities() -> [text]:
    [
        "elf64_dynamic_loader",
        "dlopen_shared_objects",
        "linux_glibc_abi",
        "pthread_futex_threads",
        "bsd_sockets_tls_dns",
        "posix_filesystem_locks",
        "steam_client_process_ipc",
        "callback_pump",
        "secure_ticket_crypto",
        "steam_runtime_container",
        "proton_wine_host"
    ]

fn _steam_api_contains(items: [text], expected: text) -> bool:
    for item in items:
        if item == expected:
            return true
    false

fn _steam_api_count_matches(required: [text], available: [text]) -> i64:
    var count: i64 = 0
    for item in required:
        if _steam_api_contains(available, item):
            count = count + 1
    count

pub fn steam_api_probe_backend(client_present: bool, available_symbols: [text], available_os_capabilities: [text]) -> SteamBackendProbe:
    val required_symbols = steam_api_backend_required_symbols()
    val required_os = steam_api_backend_required_os_capabilities()
    val matched_symbols = _steam_api_count_matches(required_symbols, available_symbols)
    val matched_os = _steam_api_count_matches(required_os, available_os_capabilities)
    val ready = client_present and matched_symbols == required_symbols.len() and matched_os == required_os.len()
    var blocker = ""
    if client_present == false:
        blocker = "missing authenticated Steam client"
    else if matched_symbols != required_symbols.len():
        blocker = "missing Steamworks SFFI symbols"
    else if matched_os != required_os.len():
        blocker = "missing SimpleOS Linux/Steam Runtime capabilities"
    SteamBackendProbe(
        client_present: client_present,
        required_symbol_count: required_symbols.len(),
        matched_symbol_count: matched_symbols,
        required_os_capability_count: required_os.len(),
        matched_os_capability_count: matched_os,
        ready: ready,
        blocker: blocker
    )

pub fn steam_api_real_backend_ready() -> bool:
    steam_api_probe_backend(false, [], []).ready

pub fn steam_api_real_backend_blocker() -> text:
    steam_api_probe_backend(false, [], []).blocker + ", upstream Steamworks SDK bridge, Linux ABI, Steam Runtime, and Proton/Wine host"

pub fn steam_api_sffi_bridge_name(facade: SteamApiFacade) -> text:
    facade.state.sffi_abi

pub fn steam_api_summary(facade: SteamApiFacade) -> text:
    "app=" + facade.state.app_id.to_text() +
        " ready=" + steam_api_ready(facade).to_text() +
        " sffi=" + facade.state.sffi_abi +
        " overlay=" + facade.state.overlay_enabled.to_text() +
        " input=" + facade.state.input_enabled.to_text() +
        " interfaces=" + steam_api_interface_count().to_text() +
        " real_backend=" + steam_api_real_backend_ready().to_text()
