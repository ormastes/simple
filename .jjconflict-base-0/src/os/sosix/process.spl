# SOSIX Process API — Simple-native async process-control facade.

use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}
use os.posix.errno.{EINVAL, EIO}
use os.userlib.syscall_raw.{syscall}

extern fn rt_copy_user_byte(ptr_addr: u64) -> u8
extern fn rt_string_from_byte_array(arr: [u8]) -> text
extern fn rt_string_data(s: text) -> i64

val SOSIX_PROCESS_MAX_REQUESTS: u64 = 64

val SOSIX_PROCESS_REQ_FREE: u8 = 0
val SOSIX_PROCESS_REQ_PENDING: u8 = 1
val SOSIX_PROCESS_REQ_COMPLETE: u8 = 2
val SOSIX_PROCESS_REQ_ERROR: u8 = 3

val SOSIX_PROCESS_OP_NONE: u8 = 0
val SOSIX_PROCESS_OP_FORK: u8 = 1
val SOSIX_PROCESS_OP_EXECVE: u8 = 2
val SOSIX_PROCESS_OP_SPAWN: u8 = 3
val SOSIX_PROCESS_OP_WAITPID: u8 = 4
val SOSIX_PROCESS_OP_EXIT: u8 = 5
val SOSIX_PROCESS_OP_GETPID: u8 = 6
val SOSIX_PROCESS_OP_SIGNAL: u8 = 7

val SOSIX_PROCESS_WNOHANG: u32 = 1

val _SOSIX_SYS_EXIT: u64 = 0
val _SOSIX_SYS_GETPID: u64 = 4
val _SOSIX_SYS_SIGNAL: u64 = 7
val _SOSIX_SYS_SPAWN_BINARY: u64 = 13
val _SOSIX_SYS_FORK: u64 = 57
val _SOSIX_SYS_EXECVE: u64 = 59
val _SOSIX_SYS_WAITPID: u64 = 61

var sosix_process_req_states: [u8; 64] = [0; 64]
var sosix_process_req_ops: [u8; 64] = [0; 64]
var sosix_process_req_results: [i64; 64] = [0; 64]
# Baremetal Cranelift currently fails to read back writes to the fixed request
# tables on the desktop lane; keep the latest immediate request in scalars so
# the async-first API still has a reliable synchronous compatibility boundary.
var sosix_process_last_req: u64 = SOSIX_PROCESS_MAX_REQUESTS
var sosix_process_last_result: i64 = 0
var sosix_process_last_complete: bool = false

fn sosix_process_init():
    """Initialize SOSIX async process request slots."""
    var i: u64 = 0
    while i < SOSIX_PROCESS_MAX_REQUESTS:
        sosix_process_req_states[i] = SOSIX_PROCESS_REQ_FREE
        sosix_process_req_ops[i] = SOSIX_PROCESS_OP_NONE
        sosix_process_req_results[i] = 0
        i = i + 1

fn sosix_process_alloc_request() -> u64:
    var i: u64 = 0
    while i < SOSIX_PROCESS_MAX_REQUESTS:
        if sosix_process_req_states[i] == SOSIX_PROCESS_REQ_FREE:
            sosix_process_req_states[i] = SOSIX_PROCESS_REQ_PENDING
            sosix_process_req_ops[i] = SOSIX_PROCESS_OP_NONE
            sosix_process_req_results[i] = 0
            sosix_process_last_req = i
            sosix_process_last_result = 0
            sosix_process_last_complete = false
            return i
        i = i + 1
    SOSIX_PROCESS_MAX_REQUESTS

fn sosix_process_free_request(req: u64):
    if req < SOSIX_PROCESS_MAX_REQUESTS:
        sosix_process_req_states[req] = SOSIX_PROCESS_REQ_FREE
        sosix_process_req_ops[req] = SOSIX_PROCESS_OP_NONE
        sosix_process_req_results[req] = 0
        if sosix_process_last_req == req:
            sosix_process_last_complete = false
            sosix_process_last_req = SOSIX_PROCESS_MAX_REQUESTS

fn sosix_process_is_complete(req: u64) -> bool:
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return true
    if sosix_process_last_req == req and sosix_process_last_complete:
        return true
    sosix_process_req_states[req] == SOSIX_PROCESS_REQ_COMPLETE or sosix_process_req_states[req] == SOSIX_PROCESS_REQ_ERROR

fn sosix_process_result(req: u64) -> i64:
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return 0 - EIO as i64
    if sosix_process_last_req == req and sosix_process_last_complete:
        return sosix_process_last_result
    sosix_process_req_results[req]

fn _sosix_process_complete(req: u64, op: u8, result: i64) -> u64:
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    sosix_process_req_ops[req] = op
    sosix_process_req_results[req] = result
    sosix_process_last_req = req
    sosix_process_last_result = result
    sosix_process_last_complete = true
    if result < 0:
        sosix_process_req_states[req] = SOSIX_PROCESS_REQ_ERROR
    else:
        sosix_process_req_states[req] = SOSIX_PROCESS_REQ_COMPLETE
    req

fn sosix_process_fork() -> u64:
    """Start a fork request."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    _sosix_process_complete(req, SOSIX_PROCESS_OP_FORK, syscall(_SOSIX_SYS_FORK, 0, 0, 0, 0, 0))

fn sosix_process_execve(path: text, args: [text], envp: [text]) -> u64:
    """Start an execve request."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    val _ignored_args = args
    val _ignored_envp = envp
    if path.len() == 0:
        return _sosix_process_complete(req, SOSIX_PROCESS_OP_EXECVE, 0 - EINVAL as i64)
    val path_ptr = rt_string_data(path) as u64
    _sosix_process_complete(req, SOSIX_PROCESS_OP_EXECVE, syscall(_SOSIX_SYS_EXECVE, path_ptr, path.len().to_u64(), 0, 0, 0))

fn sosix_process_spawn(path: text, args: [text], priority: u8) -> u64:
    """Start a spawn-binary request."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    val _ignored_args = args
    if path.len() == 0:
        return _sosix_process_complete(req, SOSIX_PROCESS_OP_SPAWN, 0 - EINVAL as i64)
    val path_ptr = rt_string_data(path) as u64
    var copied: [u8] = []
    var i: u64 = 0
    while i < path.len().to_u64():
        copied.push(rt_copy_user_byte(path_ptr + i))
        i = i + 1
    val copied_text = rt_string_from_byte_array(copied)
    log_info("[sosix] " + "[sosix-spawn] path={path} len={path.len()} ptr=0x{path_ptr} copied={copied_text}")
    val spawn_result = syscall(_SOSIX_SYS_SPAWN_BINARY, path_ptr, path.len().to_u64(), priority as u64, 0, 0)
    val done_req = _sosix_process_complete(req, SOSIX_PROCESS_OP_SPAWN, spawn_result)
    done_req

fn sosix_process_waitpid(pid: i64, options: u32) -> u64:
    """Start a waitpid request."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    val pid_u64 = if pid < 0: 0xFFFFFFFFFFFFFFFF as u64 else: pid as u64
    _sosix_process_complete(req, SOSIX_PROCESS_OP_WAITPID, syscall(_SOSIX_SYS_WAITPID, pid_u64, 0, options as u64, 0, 0))

fn sosix_process_getpid() -> u64:
    """Start a getpid request."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    _sosix_process_complete(req, SOSIX_PROCESS_OP_GETPID, syscall(_SOSIX_SYS_GETPID, 0, 0, 0, 0, 0))

fn sosix_process_signal(pid: u64, kern_sig: i32) -> u64:
    """Start a kernel signal request."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    if kern_sig < 0:
        return _sosix_process_complete(req, SOSIX_PROCESS_OP_SIGNAL, 0 - EINVAL as i64)
    _sosix_process_complete(req, SOSIX_PROCESS_OP_SIGNAL, syscall(_SOSIX_SYS_SIGNAL, pid, kern_sig as u64, 0, 0, 0))

fn sosix_process_exit(code: i32) -> u64:
    """Start process exit. The syscall should not return on a live kernel."""
    val req = sosix_process_alloc_request()
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return req
    _sosix_process_complete(req, SOSIX_PROCESS_OP_EXIT, syscall(_SOSIX_SYS_EXIT, code as u64, 0, 0, 0, 0))

fn sosix_process_wait_request(req: u64) -> i64:
    """Block the caller until a SOSIX process request completes."""
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return 0 - EIO as i64
    while not sosix_process_is_complete(req):
        # Blocking is isolated to compatibility or explicit wait boundaries.
        continue
    val result = sosix_process_result(req)
    sosix_process_free_request(req)
    result

# ============================================================================
# Argv / envp marshaling helpers
# ============================================================================

fn sosix_marshal_string_vector(strings: [text]) -> [u8]:
    """Pack an array of text strings into a contiguous byte buffer for kernel consumption.

    Layout:
      [string_0 bytes, NUL, string_1 bytes, NUL, ..., string_N bytes, NUL,
       offset_0 (8 bytes LE), offset_1 (8 bytes LE), ..., offset_N (8 bytes LE),
       NULL_terminator (8 bytes of zeroes)]

    Each offset entry records the byte position of the corresponding string
    within the buffer. The kernel adds the buffer base address to recover
    absolute pointers suitable for a C-style char** array.

    This variant uses char_at() for interpreter compatibility. The kernel-
    side sosix_marshal_string_vector_kern() uses rt_copy_user_byte for
    baremetal contexts where char_at may not be available.

    Returns an empty buffer when the input is empty.
    """
    if strings.len() == 0:
        return []

    # Phase 1: concatenate null-terminated strings, recording offsets
    var buf: [u8] = []
    var offsets: [u64] = []
    var si: u64 = 0
    while si < strings.len().to_u64():
        offsets.push(buf.len().to_u64())
        val s = strings[si]
        for ci in 0..s.len():
            buf.push(s.char_at(ci) as u8)
        buf.push(0)  # NUL terminator
        si = si + 1

    # Phase 2: append pointer/offset table (little-endian u64 entries)
    var oi: u64 = 0
    while oi < offsets.len().to_u64():
        val offset = offsets[oi]
        buf.push((offset & 0xFF) as u8)
        buf.push(((offset >> 8) & 0xFF) as u8)
        buf.push(((offset >> 16) & 0xFF) as u8)
        buf.push(((offset >> 24) & 0xFF) as u8)
        buf.push(((offset >> 32) & 0xFF) as u8)
        buf.push(((offset >> 40) & 0xFF) as u8)
        buf.push(((offset >> 48) & 0xFF) as u8)
        buf.push(((offset >> 56) & 0xFF) as u8)
        oi = oi + 1

    # NULL terminator pointer entry
    var ni: u64 = 0
    while ni < 8:
        buf.push(0)
        ni = ni + 1

    buf

fn sosix_marshal_string_vector_kern(strings: [text]) -> [u8]:
    """Kernel-side variant using rt_copy_user_byte for baremetal byte access."""
    if strings.len() == 0:
        return []

    var buf: [u8] = []
    var offsets: [u64] = []
    var si: u64 = 0
    while si < strings.len().to_u64():
        offsets.push(buf.len().to_u64())
        val s = strings[si]
        val s_ptr = rt_string_data(s) as u64
        var ci: u64 = 0
        while ci < s.len().to_u64():
            buf.push(rt_copy_user_byte(s_ptr + ci))
            ci = ci + 1
        buf.push(0)
        si = si + 1

    var oi: u64 = 0
    while oi < offsets.len().to_u64():
        val offset = offsets[oi]
        buf.push((offset & 0xFF) as u8)
        buf.push(((offset >> 8) & 0xFF) as u8)
        buf.push(((offset >> 16) & 0xFF) as u8)
        buf.push(((offset >> 24) & 0xFF) as u8)
        buf.push(((offset >> 32) & 0xFF) as u8)
        buf.push(((offset >> 40) & 0xFF) as u8)
        buf.push(((offset >> 48) & 0xFF) as u8)
        buf.push(((offset >> 56) & 0xFF) as u8)
        oi = oi + 1

    var ni: u64 = 0
    while ni < 8:
        buf.push(0)
        ni = ni + 1

    buf

fn sosix_marshal_string_vector_size(count: u64, total_string_bytes: u64) -> u64:
    """Compute the expected buffer size for a given number of strings.

    total_string_bytes is the sum of all string lengths (without NULs).
    Result = total_string_bytes + count (NULs) + (count + 1) * 8 (offset table).
    """
    total_string_bytes + count + (count + 1) * 8
