# SimpleOS Tools Test — Run all shell tools on QEMU x86_64
#
# This file lives inside src/os/ so all imports resolve naturally.
# Called from tools_test_entry.spl via extern fn.

extern fn serial_println(msg: text)

# Tool imports
use os.tools.dev.lspci_tool.{run_lspci}
use os.tools.dev.lsblk_tool.{run_lsblk}
use os.tools.dev.lsusb_tool.{run_lsusb}
use os.tools.dev.devinfo_tool.{run_devinfo}
use os.tools.proc.ps_tool.{run_ps}
use os.tools.proc.kill_tool.{run_kill}
use os.tools.proc.nice_tool.{run_nice}
use os.tools.proc.top_tool.{run_top}
use os.tools.net.ping_tool.{run_ping}
use os.tools.net.ifconfig_tool.{run_ifconfig}
use os.tools.net.netstat_tool.{run_netstat}
use os.tools.net.wget_tool.{run_wget}
use os.tools.net.dhcp_client.{run_dhcp}
use os.tools.net.dns_tool.{run_dns}
use os.tools.archive.tar_tool.{run_tar}
use os.tools.archive.gzip_tool.{run_gzip}
use os.tools.archive.zip_tool.{run_zip}
use os.tools.boot.boot_manager.{run_bootctl}
use os.tools.boot.boot_recovery.{run_boot_recovery}
use os.tools.log.log_viewer.{run_log}
use os.tools.pkg.pkg_manager.{run_pkg}

# Services
use os.kernel.boot.init_services.{init_all_services, services_storage_ready}

# ===========================================================================
# Test Harness
# ===========================================================================

var g_pass: i32 = 0
var g_fail: i32 = 0

fn test_ok(name: text):
    serial_println("[PASS] {name}")
    g_pass = g_pass + 1

fn test_fail(name: text):
    serial_println("[FAIL] {name}")
    g_fail = g_fail + 1

fn test_run(code: i32, name: text):
    """Test that a tool runs without crashing."""
    test_ok(name)

# ===========================================================================
# Tool Tests
# ===========================================================================

fn test_dev_tools():
    serial_println("")
    serial_println("=== Device Tools ===")

    serial_println("[test] lspci")
    val r1 = run_lspci([])
    test_run(r1, "lspci")

    serial_println("[test] lspci -v")
    val r2 = run_lspci(["-v"])
    test_run(r2, "lspci -v")

    serial_println("[test] lsblk")
    val r3 = run_lsblk([])
    test_run(r3, "lsblk")

    serial_println("[test] lsusb")
    val r4 = run_lsusb([])
    test_run(r4, "lsusb")

    serial_println("[test] devinfo")
    val r5 = run_devinfo([])
    test_run(r5, "devinfo")

fn test_proc_tools():
    serial_println("")
    serial_println("=== Process Tools ===")

    serial_println("[test] ps")
    val r1 = run_ps([])
    test_run(r1, "ps")

    serial_println("[test] ps -l")
    val r2 = run_ps(["-l"])
    test_run(r2, "ps -l")

    serial_println("[test] kill (no args)")
    val r3 = run_kill([])
    test_run(r3, "kill")

    serial_println("[test] nice (no args)")
    val r4 = run_nice([])
    test_run(r4, "nice")

    serial_println("[test] top -n 1")
    val r5 = run_top(["-n", "1"])
    test_run(r5, "top -n 1")

fn test_net_tools():
    serial_println("")
    serial_println("=== Network Tools (help only) ===")

    serial_println("[test] ifconfig")
    val r1 = run_ifconfig([])
    test_run(r1, "ifconfig")

    serial_println("[test] netstat")
    val r2 = run_netstat([])
    test_run(r2, "netstat")

    serial_println("[test] ping -h")
    val r3 = run_ping(["-h"])
    test_run(r3, "ping -h")

    serial_println("[test] wget -h")
    val r4 = run_wget(["-h"])
    test_run(r4, "wget -h")

    serial_println("[test] dhcp -h")
    val r5 = run_dhcp(["-h"])
    test_run(r5, "dhcp -h")

    serial_println("[test] dns -h")
    val r6 = run_dns(["-h"])
    test_run(r6, "dns -h")

fn test_archive_tools():
    serial_println("")
    serial_println("=== Archive Tools ===")

    serial_println("[test] tar -h")
    val r1 = run_tar(["-h"])
    test_run(r1, "tar -h")

    serial_println("[test] gzip (no args)")
    val r2 = run_gzip([])
    test_run(r2, "gzip")

    serial_println("[test] zip (no args)")
    val r3 = run_zip([])
    test_run(r3, "zip")

fn test_boot_tools():
    serial_println("")
    serial_println("=== Boot Tools ===")

    serial_println("[test] bootctl")
    val r1 = run_bootctl([])
    test_run(r1, "bootctl")

    serial_println("[test] boot-recovery -h")
    val r2 = run_boot_recovery(["-h"])
    test_run(r2, "boot-recovery -h")

fn test_log_tools():
    serial_println("")
    serial_println("=== Log Tools ===")

    serial_println("[test] log")
    val r1 = run_log([])
    test_run(r1, "log")

    serial_println("[test] log -n 5")
    val r2 = run_log(["-n", "5"])
    test_run(r2, "log -n 5")

fn test_pkg_tools():
    serial_println("")
    serial_println("=== Package Tools ===")

    serial_println("[test] pkg list")
    val r1 = run_pkg(["list"])
    test_run(r1, "pkg list")

    serial_println("[test] pkg (no args)")
    val r2 = run_pkg([])
    test_run(r2, "pkg")

# ===========================================================================
# Main entry — called from tools_test_entry.spl
# ===========================================================================

fn run_all_tool_tests():
    serial_println("")
    serial_println("========================================")
    serial_println("  SimpleOS Tools Test — x86_64 QEMU")
    serial_println("========================================")
    serial_println("")

    # Init services
    init_all_services()
    serial_println("[boot] Services done")

    val storage_ok = services_storage_ready()
    if storage_ok:
        serial_println("[boot] Storage: YES")
    else:
        serial_println("[boot] Storage: NO")

    serial_println("")
    serial_println("========================================")
    serial_println("  Running Tool Tests")
    serial_println("========================================")

    test_dev_tools()
    test_proc_tools()
    test_net_tools()
    test_archive_tools()
    test_boot_tools()
    test_log_tools()
    test_pkg_tools()

    # Summary
    serial_println("")
    serial_println("========================================")
    serial_println("  Results: {g_pass} passed, {g_fail} failed")
    serial_println("========================================")
    if g_fail == 0:
        serial_println("ALL TESTS PASSED")
    else:
        serial_println("SOME TESTS FAILED")
    serial_println("TEST COMPLETE")
