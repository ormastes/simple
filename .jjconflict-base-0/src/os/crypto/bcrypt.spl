# bcrypt — Password Hashing (Provos/Mazières 1999, OpenBSD)
#
# Canonical pure-Simple bcrypt with [u8]-typed API.
# NOTE: src/lib/common/bcrypt/ is a legacy text-API variant — not for new use.
#
# Implements Eksblowfish key setup and the $2a$ hash format per:
#   Provos & Mazières, "A Future-Adaptable Password Scheme", USENIX 1999.
#   https://www.usenix.org/legacy/events/usenix99/provos/provos.pdf
#
# Public API:
#   bcrypt_hash(password: [u8], cost: i64, salt: [u8] /* 16 bytes */) -> [u8]
#     Returns 60-byte ASCII string: $2a$NN$<22-char salt><31-char hash>
#   bcrypt_verify(password: [u8], hash_string: [u8]) -> bool
#     Constant-time compare via byte-XOR accumulator.
#
# Custom Base64 alphabet (NOT standard base64):
#   ./ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789
#   Alphabet index: . → 0, / → 1, A-Z → 2..27, a-z → 28..53, 0-9 → 54..63
#
# KAT vectors: test/01_unit/lib/crypto/bcrypt_kat_spec.spl
#
# INTERPRETER PERFORMANCE
# cost=4 requires 2^4=16 EksBlowfish ExpandKey iterations, each touching the
# 18-entry P-array and 4×256 S-boxes through ~512 Blowfish encryptions.
# Total: ~33k Blowfish encryptions per hash.  One cost=4 vector is tractable in
# interpreter mode; additional cost=4 vectors may exceed the 60s watchdog.
# Filed: doc/02_requirements/feature/bcrypt_native_runtime_helpers_2026-05-02.md
#
# Sub-files:
#   bcrypt_tables.spl — BCRYPT_MAGIC constants + BF_P_INIT + BF_S0/S1/S2/S3

use os.crypto.bcrypt_tables.{BCRYPT_MAGIC_0, BCRYPT_MAGIC_1, BCRYPT_MAGIC_2, BCRYPT_MAGIC_3, BCRYPT_MAGIC_4, BCRYPT_MAGIC_5, BF_P_INIT, BF_S0, BF_S1, BF_S2, BF_S3}

# ============================================================================
# 32-BIT ARITHMETIC HELPERS
# ============================================================================

# Mask to 32-bit unsigned
fn _w32(x: i64) -> i64:
    """Mask value to 32-bit unsigned range [0, 2^32)."""
    x & 0xFFFFFFFF

# 32-bit wrapping add
fn _add32(a: i64, b: i64) -> i64:
    """Add with 32-bit wrap."""
    (a + b) & 0xFFFFFFFF

# 32-bit XOR
fn _xor32(a: i64, b: i64) -> i64:
    """XOR, masked to 32 bits."""
    (a ^ b) & 0xFFFFFFFF

# ============================================================================
# BLOWFISH F-FUNCTION
# ============================================================================

fn _bf_f(x: i64, s0: [i64], s1: [i64], s2: [i64], s3: [i64]) -> i64:
    """Blowfish Feistel function: ((S0[a] + S1[b]) XOR S2[c]) + S3[d]."""
    val a = (x >> 24) & 0xFF
    val b = (x >> 16) & 0xFF
    val c = (x >> 8) & 0xFF
    val d = x & 0xFF
    val h = _add32(s0[a], s1[b])
    val h2 = _xor32(h, s2[c])
    _add32(h2, s3[d])

# ============================================================================
# BLOWFISH ENCRYPT ONE 64-BIT BLOCK (16 Feistel rounds)
# ============================================================================

fn _bf_encrypt(xl: i64, xr: i64, p: [i64], s0: [i64], s1: [i64], s2: [i64], s3: [i64]) -> [i64]:
    """Encrypt one 64-bit block
    returns [new_xl, new_xr]."""
    var l = xl
    var r = xr
    var round = 0
    while round < 16:
        l = _xor32(l, p[round])
        r = _xor32(r, _bf_f(l, s0, s1, s2, s3))
        # swap l and r
        var tmp = l
        l = r
        r = tmp
        round = round + 1
    # undo last swap then apply final subkeys
    var final_r = _xor32(l, p[17])
    var final_l = _xor32(r, p[16])
    [final_l, final_r]

# ============================================================================
# BLOWFISH KEY SCHEDULE (ExpandKey)
# ============================================================================

fn _bf_expand_key(p: [i64], s0: [i64], s1: [i64], s2: [i64], s3: [i64],
                  key: [i64], key_len: i64,
                  data: [i64], data_len: i64) -> [[i64]]:
    """
    Perform one ExpandKey step (Provos paper §4, Step 2).
    key: password bytes as i64 values, cycled
    data: salt bytes as i64 values, cycled (pass zeros for password-only step)
    Returns [[p0..p17], [s0..], [s1..], [s2..], [s3..]].
    """
    # XOR P-array with key (cycling through key bytes)
    var new_p: [i64] = []
    var ki = 0
    var pi = 0
    while pi < 18:
        # build a 32-bit word from 4 consecutive key bytes (big-endian)
        var word: i64 = 0
        var bi = 0
        while bi < 4:
            if key_len > 0:
                word = (word << 8) | key[ki % key_len]
            bi = bi + 1
            ki = ki + 1
        new_p.push(_xor32(p[pi], word))
        pi = pi + 1

    # Encrypt state using data as the "plaintext source" stream (cycling salt)
    var cur_p = new_p
    var cur_s0 = s0
    var cur_s1 = s1
    var cur_s2 = s2
    var cur_s3 = s3

    # Re-encrypt P-array and S-boxes in pairs using the data stream (cycling).
    # Hoist all loop-local vars to function scope to avoid interpreter issues.
    var di = 0
    var i = 0
    var lw: i64 = 0
    var rw: i64 = 0
    var b = 0
    var enc: [i64] = []

    # P-array (18 entries = 9 pairs)
    i = 0
    while i < 18:
        lw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                lw = (lw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        rw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                rw = (rw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        enc = _bf_encrypt(lw, rw, cur_p, cur_s0, cur_s1, cur_s2, cur_s3)
        cur_p[i] = enc[0]
        cur_p[i + 1] = enc[1]
        i = i + 2

    # S-box 0
    i = 0
    while i < 256:
        lw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                lw = (lw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        rw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                rw = (rw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        enc = _bf_encrypt(lw, rw, cur_p, cur_s0, cur_s1, cur_s2, cur_s3)
        cur_s0[i] = enc[0]
        cur_s0[i + 1] = enc[1]
        i = i + 2

    # S-box 1
    i = 0
    while i < 256:
        lw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                lw = (lw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        rw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                rw = (rw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        enc = _bf_encrypt(lw, rw, cur_p, cur_s0, cur_s1, cur_s2, cur_s3)
        cur_s1[i] = enc[0]
        cur_s1[i + 1] = enc[1]
        i = i + 2

    # S-box 2
    i = 0
    while i < 256:
        lw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                lw = (lw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        rw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                rw = (rw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        enc = _bf_encrypt(lw, rw, cur_p, cur_s0, cur_s1, cur_s2, cur_s3)
        cur_s2[i] = enc[0]
        cur_s2[i + 1] = enc[1]
        i = i + 2

    # S-box 3
    i = 0
    while i < 256:
        lw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                lw = (lw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        rw = 0
        b = 0
        while b < 4:
            if data_len > 0:
                rw = (rw << 8) | data[di % data_len]
            b = b + 1
            di = di + 1
        enc = _bf_encrypt(lw, rw, cur_p, cur_s0, cur_s1, cur_s2, cur_s3)
        cur_s3[i] = enc[0]
        cur_s3[i + 1] = enc[1]
        i = i + 2

    [cur_p, cur_s0, cur_s1, cur_s2, cur_s3]

# ============================================================================
# EKSBLOWFISH SETUP (Provos paper §4, EksBlowfishSetup)
# ============================================================================

fn _eksblowfish_setup(cost: i64, salt: [i64], salt_len: i64,
                      key: [i64], key_len: i64) -> [[i64]]:
    """
    EksBlowfishSetup per Provos §4:
      state = InitState()
      state = ExpandKey(state, salt, key)
      repeat(2^cost):
        state = ExpandKey(state, 0, key)
        state = ExpandKey(state, 0, salt)
    Returns [[p], [s0], [s1], [s2], [s3]].
    """
    # Copy initial Blowfish state from constants
    var p: [i64] = []
    var i = 0
    while i < 18:
        p.push(BF_P_INIT[i])
        i = i + 1

    var s0: [i64] = []
    var s1: [i64] = []
    var s2: [i64] = []
    var s3: [i64] = []
    i = 0
    while i < 256:
        s0.push(BF_S0[i])
        s1.push(BF_S1[i])
        s2.push(BF_S2[i])
        s3.push(BF_S3[i])
        i = i + 1

    # Step 1: ExpandKey(state, salt, key)
    val zeros: [i64] = []
    var st = _bf_expand_key(p, s0, s1, s2, s3, key, key_len, salt, salt_len)

    # Step 2: 2^cost iterations of ExpandKey with zeros then salt
    val iters = _pow2(cost)
    var iter = 0
    while iter < iters:
        # ExpandKey(state, 0, key)  — data = empty (treated as all zeros)
        st = _bf_expand_key(st[0], st[1], st[2], st[3], st[4],
                            key, key_len, zeros, 0)
        # ExpandKey(state, 0, salt)
        st = _bf_expand_key(st[0], st[1], st[2], st[3], st[4],
                            salt, salt_len, zeros, 0)
        iter = iter + 1

    st

fn _pow2(n: i64) -> i64:
    """Compute 2^n for small n."""
    var result = 1
    var i = 0
    while i < n:
        result = result * 2
        i = i + 1
    result

# ============================================================================
# BCRYPT CORE: encrypt magic string 64 times
# ============================================================================

fn _bcrypt_hash_raw(cost: i64, salt: [i64], salt_len: i64,
                    key: [i64], key_len: i64) -> [i64]:
    """
    Run EksBlowfishSetup then encrypt the magic string 64 times.
    Returns 24 bytes (6 x 32-bit words) as i64 list.
    """
    val st = _eksblowfish_setup(cost, salt, salt_len, key, key_len)
    val p = st[0]
    val s0 = st[1]
    val s1 = st[2]
    val s2 = st[3]
    val s3 = st[4]

    # Encrypt "OrpheanBeholderScryDoubt" (6 words = 3 pairs) 64 times
    var c0 = BCRYPT_MAGIC_0
    var c1 = BCRYPT_MAGIC_1
    var c2 = BCRYPT_MAGIC_2
    var c3 = BCRYPT_MAGIC_3
    var c4 = BCRYPT_MAGIC_4
    var c5 = BCRYPT_MAGIC_5

    var round = 0
    var enc: [i64] = []
    while round < 64:
        enc = _bf_encrypt(c0, c1, p, s0, s1, s2, s3)
        c0 = enc[0]
        c1 = enc[1]
        enc = _bf_encrypt(c2, c3, p, s0, s1, s2, s3)
        c2 = enc[0]
        c3 = enc[1]
        enc = _bf_encrypt(c4, c5, p, s0, s1, s2, s3)
        c4 = enc[0]
        c5 = enc[1]
        round = round + 1

    # Convert 6 words to 24 bytes (big-endian)
    var out: [i64] = []
    out.push((c0 >> 24) & 0xFF)
    out.push((c0 >> 16) & 0xFF)
    out.push((c0 >> 8) & 0xFF)
    out.push(c0 & 0xFF)
    out.push((c1 >> 24) & 0xFF)
    out.push((c1 >> 16) & 0xFF)
    out.push((c1 >> 8) & 0xFF)
    out.push(c1 & 0xFF)
    out.push((c2 >> 24) & 0xFF)
    out.push((c2 >> 16) & 0xFF)
    out.push((c2 >> 8) & 0xFF)
    out.push(c2 & 0xFF)
    out.push((c3 >> 24) & 0xFF)
    out.push((c3 >> 16) & 0xFF)
    out.push((c3 >> 8) & 0xFF)
    out.push(c3 & 0xFF)
    out.push((c4 >> 24) & 0xFF)
    out.push((c4 >> 16) & 0xFF)
    out.push((c4 >> 8) & 0xFF)
    out.push(c4 & 0xFF)
    out.push((c5 >> 24) & 0xFF)
    out.push((c5 >> 16) & 0xFF)
    out.push((c5 >> 8) & 0xFF)
    out.push(c5 & 0xFF)
    out

# ============================================================================
# BCRYPT BASE64 ENCODE / DECODE
#
# bcrypt uses its own alphabet but the SAME MSB-first bit packing as RFC 4648.
# Alphabet: ./ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789
#
# Encode 3 bytes → 4 sextets (MSB-first):
#   c0 = b0 >> 2
#   c1 = ((b0 & 0x03) << 4) | (b1 >> 4)
#   c2 = ((b1 & 0x0F) << 2) | (b2 >> 6)
#   c3 = b2 & 0x3F
#
# Decode 4 sextets → 3 bytes (MSB-first):
#   b0 = (c0 << 2) | (c1 >> 4)
#   b1 = ((c1 & 0x0F) << 4) | (c2 >> 2)
#   b2 = ((c2 & 0x03) << 6) | c3
#
# Verified against base64ct crate test vector:
#   raw [0x01,0x02,0x03,0x04] → ".OGB/." (bytes 46,79,71,66,47,46)
# ============================================================================

fn _b64_char(idx: i64) -> i64:
    """
    Return ASCII byte for bcrypt base64 index 0..63.
    Alphabet: ./ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789
    Pure arithmetic — no text indexing.
      0       → '.' (46)
      1       → '/' (47)
      2..27   → 'A'..'Z' (65..90)  : byte = idx + 63
      28..53  → 'a'..'z' (97..122) : byte = idx + 69
      54..63  → '0'..'9' (48..57)  : byte = idx - 6
    """
    if idx == 0: return 46
    if idx == 1: return 47
    if idx >= 2:
        if idx <= 27:
            return idx + 63
    if idx >= 28:
        if idx <= 53:
            return idx + 69
    if idx >= 54:
        if idx <= 63:
            return idx - 6
    46

fn _b64_idx_from_byte(b: i64) -> i64:
    """Return bcrypt base64 index for ASCII byte b."""
    # . = 0
    if b == 46: return 0
    # / = 1
    if b == 47: return 1
    # A-Z = 2..27
    if b >= 65:
        if b <= 90:
            return b - 63
    # a-z = 28..53
    if b >= 97:
        if b <= 122:
            return b - 69
    # 0-9 = 54..63
    if b >= 48:
        if b <= 57:
            return b + 6
    0

fn _bcrypt_encode_bytes(src: [i64], nbytes: i64) -> [i64]:
    """
    Encode exactly nbytes from src into bcrypt base64 bytes (ASCII).
    Uses MSB-first bit packing (same as RFC 4648, different alphabet).
    Returns ASCII bytes (not text).
    """
    var out: [i64] = []
    var i = 0
    while i < nbytes:
        val b0 = src[i]
        var b1 = 0
        var b2 = 0
        if i + 1 < nbytes: b1 = src[i + 1]
        if i + 2 < nbytes: b2 = src[i + 2]

        # MSB-first: same packing order as RFC 4648, bcrypt alphabet only
        val c0 = (b0 >> 2) & 0x3F
        val c1 = ((b0 & 0x03) << 4) | ((b1 >> 4) & 0x0F)
        val c2 = ((b1 & 0x0F) << 2) | ((b2 >> 6) & 0x03)
        val c3 = b2 & 0x3F

        out.push(_b64_char(c0))
        out.push(_b64_char(c1))
        if i + 1 < nbytes: out.push(_b64_char(c2))
        if i + 2 < nbytes: out.push(_b64_char(c3))

        i = i + 3

    out

fn _bcrypt_decode_b64(src: [u8], offset: i64, nbytes: i64) -> [i64]:
    """
    Decode nbytes of output from bcrypt base64 encoded in src starting at offset.
    Uses MSB-first bit packing (same as RFC 4648, bcrypt alphabet).
    Returns list of decoded bytes.
    """
    var out: [i64] = []
    var si = offset
    var remaining = nbytes
    var c0 = 0
    var c1 = 0
    var c2 = 0
    var c3 = 0
    var b0 = 0
    var b1 = 0
    var b2 = 0
    while remaining > 0:
        c0 = _b64_idx_from_byte(src[si].to_i64())
        c1 = _b64_idx_from_byte(src[si + 1].to_i64())
        # MSB-first decode: b0 = (c0 << 2) | (c1 >> 4)
        b0 = ((c0 << 2) | ((c1 >> 4) & 0x03)) & 0xFF
        out.push(b0)
        remaining = remaining - 1
        if remaining == 0: return out
        c2 = _b64_idx_from_byte(src[si + 2].to_i64())
        b1 = (((c1 & 0x0F) << 4) | ((c2 >> 2) & 0x0F)) & 0xFF
        out.push(b1)
        remaining = remaining - 1
        if remaining == 0: return out
        c3 = _b64_idx_from_byte(src[si + 3].to_i64())
        b2 = (((c2 & 0x03) << 6) | (c3 & 0x3F)) & 0xFF
        out.push(b2)
        remaining = remaining - 1
        si = si + 4

    out

# ============================================================================
# PUBLIC API: bcrypt_hash
# ============================================================================

fn bcrypt_hash(password: [u8], cost: i64, salt: [u8]) -> [u8]:
    """
    Hash password with bcrypt using the given 16-byte salt and cost factor.
    Returns 60 ASCII bytes: $2a$NN$<22-char-salt><31-char-hash>
    Source: jBCrypt (Damien Miller, ISC license) cross-checked test vectors.
    """
    # Build key: password bytes + NUL terminator, max 72 bytes per OpenBSD
    var key: [i64] = []
    var pi = 0
    val pw_len = password.len()
    val max_pw = if pw_len < 72: pw_len else: 72
    while pi < max_pw:
        key.push(password[pi].to_i64())
        pi = pi + 1
    key.push(0)  # NUL terminator

    # Build salt as i64 list (16 bytes)
    var salt_i: [i64] = []
    var si = 0
    while si < 16:
        salt_i.push(salt[si].to_i64())
        si = si + 1

    # Run core hash
    val raw = _bcrypt_hash_raw(cost, salt_i, 16, key, key.len())

    # Encode output: $2a$ + 2-digit cost + $ + 22-char salt + 31-char hash
    # Header: $2a$
    var out: [i64] = [36, 50, 97, 36]  # '$', '2', 'a', '$'

    # Cost: two ASCII digits
    val cost_tens = cost / 10
    val cost_ones = cost % 10
    out.push(48 + cost_tens)
    out.push(48 + cost_ones)
    out.push(36)  # '$'

    # Salt: 16 bytes → 22 bcrypt-base64 chars (22 sextets = 132 bits; last char uses only 2 bits)
    val salt_enc = _bcrypt_encode_bytes(salt_i, 16)
    # salt_enc has 22 chars (floor(16*4/3) = 21 full + partial = 22)
    var sei = 0
    while sei < 22:
        out.push(salt_enc[sei])
        sei = sei + 1

    # Hash: first 23 of 24 raw bytes → 31 bcrypt-base64 chars
    val hash_enc = _bcrypt_encode_bytes(raw, 23)
    var hei = 0
    while hei < 31:
        out.push(hash_enc[hei])
        hei = hei + 1

    # Convert i64 list to [u8]
    var result: [u8] = []
    var ri = 0
    while ri < out.len():
        result.push(out[ri] as u8)
        ri = ri + 1
    result

# ============================================================================
# PUBLIC API: bcrypt_verify (constant-time)
# ============================================================================

fn bcrypt_verify(password: [u8], hash_string: [u8]) -> bool:
    """
    Verify password against a bcrypt hash string.
    Constant-time: uses byte-XOR accumulator — does NOT short-circuit.
    hash_string must be 60 bytes: $2a$NN$<22><31>
    """
    if hash_string.len() != 60: return false

    # Parse cost from positions 4-5
    var tens = hash_string[4].to_i64() - 48
    var ones = hash_string[5].to_i64() - 48
    var cost = tens * 10 + ones
    if cost < 4: return false
    if cost > 31: return false

    # Extract and decode the 16-byte salt (positions 7..28, 22 chars)
    var salt_bytes = _bcrypt_decode_b64(hash_string, 7, 16)

    # Convert salt to [u8]
    var salt_u8: [u8] = []
    var si = 0
    while si < 16:
        salt_u8.push(salt_bytes[si].to_u8())
        si = si + 1

    # Compute hash of candidate password
    var candidate = bcrypt_hash(password, cost, salt_u8)

    # Constant-time comparison: accumulate XOR differences (no short-circuit)
    var diff: i64 = 0
    var i = 0
    while i < 60:
        diff = diff | (hash_string[i].to_i64() ^ candidate[i].to_i64())
        i = i + 1

    diff == 0
