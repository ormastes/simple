# MGF1 — Mask Generation Function 1 (RFC 8017 §B.2.1)
#
# Reusable MGF1 primitive, factored out from rsa_pss.spl so RSA-OAEP,
# RSA-PSS, and other schemes can share a single implementation.
#
# Algorithm (RFC 8017 §B.2.1):
#   T = ""
#   For counter = 0, 1, ..., ceil(maskLen / hLen) - 1:
#     C = I2OSP(counter, 4)          # 4-byte big-endian counter
#     T = T || Hash(mgfSeed || C)
#   Output = T[0..maskLen]
#
# Supported hash variants: SHA-256, SHA-384, SHA-512, SHA-1.
# SHA-1 is included for legacy RSA-OAEP / PKCS#1 v1.5 interop only.
#
# tag: crypto, mgf1, rsa, oaep, pss

use os.crypto.sha256.{sha256}
use os.crypto.sha384.{sha384}
use os.crypto.sha512.{sha512}
use std.crypto.sha1.{sha1_bytes}
# sha1.spl declares `mod crypto.types`; importing a sibling from that module
# brings rotl32 into scope so sha1_bytes resolves correctly.
use std.crypto.types.{rotl32}

# ============================================================================
# Internal helpers
# ============================================================================

# Append bytes from src into dst (in-place push loop).
fn _mgf1_append_bytes(dst: [u8], src: [u8]) -> [u8]:
    var i: u64 = 0
    while i < src.len():
        dst.push(src[i])
        i = i + 1
    dst

# Convert a [u8] array to a plain list (for SHA-1 which takes list).
fn _mgf1_u8_to_list(b: [u8]) -> list:
    var out: list = []
    var i: u64 = 0
    while i < b.len():
        out.push(b[i])
        i = i + 1
    out

# Convert a plain list (SHA-1 output, elements are i64 byte values) to [u8].
fn _mgf1_list_to_u8(b: list) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < b.len().to_i64():
        out.push(b[i].to_u8())
        i = i + 1
    out

# Append I2OSP(counter, 4) big-endian bytes to buf.
fn _mgf1_append_counter(buf: [u8], counter: i64) -> [u8]:
    buf.push(((counter / 16777216) % 256).to_u8())
    buf.push(((counter / 65536) % 256).to_u8())
    buf.push(((counter / 256) % 256).to_u8())
    buf.push((counter % 256).to_u8())
    buf

# Build the per-iteration input: mgfSeed || I2OSP(counter, 4).
fn _mgf1_seed_with_counter(seed: [u8], counter: i64) -> [u8]:
    var buf: [u8] = []
    buf = _mgf1_append_bytes(buf, seed)
    buf = _mgf1_append_counter(buf, counter)
    buf

# ============================================================================
# Public API — one concrete function per hash variant.
# Simple closures cannot mutate captured vars, so we inline four variants
# rather than using a function-pointer parameter.
# ============================================================================

# MGF1-SHA-256 (RFC 8017 §B.2.1, hLen = 32).
fn mgf1_sha256(seed: [u8], mask_len: i64) -> [u8]:
    var out: [u8] = []
    var counter: i64 = 0
    while out.len().to_i64() < mask_len:
        val input = _mgf1_seed_with_counter(seed, counter)
        val block = sha256(input)
        var b: u64 = 0
        while b < block.len() and out.len().to_i64() < mask_len:
            out.push(block[b])
            b = b + 1
        counter = counter + 1
    out

# MGF1-SHA-384 (RFC 8017 §B.2.1, hLen = 48).
fn mgf1_sha384(seed: [u8], mask_len: i64) -> [u8]:
    var out: [u8] = []
    var counter: i64 = 0
    while out.len().to_i64() < mask_len:
        val input = _mgf1_seed_with_counter(seed, counter)
        val block = sha384(input)
        var b: u64 = 0
        while b < block.len() and out.len().to_i64() < mask_len:
            out.push(block[b])
            b = b + 1
        counter = counter + 1
    out

# MGF1-SHA-512 (RFC 8017 §B.2.1, hLen = 64).
fn mgf1_sha512(seed: [u8], mask_len: i64) -> [u8]:
    var out: [u8] = []
    var counter: i64 = 0
    while out.len().to_i64() < mask_len:
        val input = _mgf1_seed_with_counter(seed, counter)
        val block = sha512(input)
        var b: u64 = 0
        while b < block.len() and out.len().to_i64() < mask_len:
            out.push(block[b])
            b = b + 1
        counter = counter + 1
    out

# MGF1-SHA-1 (RFC 8017 §B.2.1, hLen = 20).
# WARNING: SHA-1 is cryptographically broken. Use only for legacy PKCS#1 v1.5
# / RSA-OAEP with SHA-1 interop (e.g., NIST PKCS#1 test vectors).
# sha1_bytes takes a plain list; we convert [u8] <-> list at the boundary.
fn mgf1_sha1(seed: [u8], mask_len: i64) -> [u8]:
    var out: [u8] = []
    var counter: i64 = 0
    while out.len().to_i64() < mask_len:
        val input = _mgf1_seed_with_counter(seed, counter)
        val input_list = _mgf1_u8_to_list(input)
        val block_list = sha1_bytes(input_list)
        val block = _mgf1_list_to_u8(block_list)
        var b: u64 = 0
        while b < block.len() and out.len().to_i64() < mask_len:
            out.push(block[b])
            b = b + 1
        counter = counter + 1
    out
