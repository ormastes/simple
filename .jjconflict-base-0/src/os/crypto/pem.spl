# PEM Encoder/Decoder — RFC 7468
#
# Textual encoding of DER-encoded cryptographic objects using
# Base64 + -----BEGIN <LABEL>----- / -----END <LABEL>----- markers.
#
# Public API:
#   pem_encode(label, der_bytes)         -> [u8]
#   pem_decode(pem_bytes)                -> Result<PemBlock, text>
#   pem_decode_all(pem_bytes)            -> Result<list, text>
#
# DER bodies are [u8] throughout — never text — per RFC 7468 §2 which
# states PEM encodes arbitrary opaque octets.  Labels are ASCII; they
# arrive/leave as [u8] and are checked to be printable ASCII.
#
# Base64 dependency: std.base_encoding (RFC 4648 §4, with padding).
# Line wrapping: exactly 64 Base64 characters per line per RFC 7468 §2.
#
# tag: crypto, pem, rfc7468
# =============================================================================

use base_encoding.base64.{base64_encode, base64_decode}
use base_encoding.utilities.{line_wrap, line_unwrap}

# =============================================================================
# Internal helpers
# =============================================================================

# Convert [u8] to a Simple list of i64 for base_encoding APIs.
fn _u8_to_list(src: [u8]) -> list:
    var out: list = []
    var i: u64 = 0
    while i < src.len():
        out.push(src[i].to_i64())
        i = i + 1
    out

# Convert a base_encoding list-of-i64 back to [u8].
fn _list_to_u8(src: list) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < src.len().to_i64():
        out.push(src.get(i).to_u8())
        i = i + 1
    out

# Convert a text to [u8] (ASCII / UTF-8 byte sequence).
fn _text_to_u8(s: text) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < s.len():
        out.push(s.char_code_at(i).to_u8())
        i = i + 1
    out

# Convert [u8] label bytes to text for string operations.
fn _u8_to_text(src: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < src.len():
        out = out + src[i].to_i64().chr()
        i = i + 1
    out

# Build a single PEM line as text: "-----<prefix> <label>-----\n"
fn _pem_marker(prefix: text, label: text) -> text:
    "-----" + prefix + " " + label + "-----\n"

# =============================================================================
# pem_encode
# =============================================================================

# Encode DER bytes into a PEM block.
#
# Produces:
#   -----BEGIN <LABEL>-----\n
#   <base64, 64 chars per line>\n
#   -----END <LABEL>-----\n
#
# label must be printable ASCII with no newlines (e.g. "CERTIFICATE",
# "RSA PRIVATE KEY", "PUBLIC KEY").
# reason: positional pem encode API
fn pem_encode(label: [u8], der_bytes: [u8]) -> [u8]:
    val label_text = _u8_to_text(label)
    val body_list = _u8_to_list(der_bytes)
    val b64_flat = base64_encode(body_list)
    val b64_wrapped = line_wrap(b64_flat, 64)
    val begin = _pem_marker("BEGIN", label_text)
    # line_wrap may or may not append a trailing newline; ensure body ends with \n
    val body = if b64_wrapped.len() > 0 and b64_wrapped.char_at(b64_wrapped.len() - 1) != "\n":
        b64_wrapped + "\n"
    else:
        b64_wrapped
    val end = _pem_marker("END", label_text)
    _text_to_u8(begin + body + end)

# =============================================================================
# pem_decode — single block
# =============================================================================

# Parsed PEM block — label + DER bytes.
# reason: pem block result type
struct PemBlock:
    label: [u8]
    der: [u8]

# Find the first occurrence of needle in haystack starting at pos.
# Returns -1 if not found.
fn _find_str(haystack: text, needle: text, start: i64) -> i64:
    val hlen = haystack.len()
    val nlen = needle.len()
    if nlen == 0:
        return start
    var i = start
    while i <= hlen - nlen:
        val candidate = haystack.substring(i, i + nlen)
        if candidate == needle:
            return i
        i = i + 1
    -1

# Strip whitespace (spaces, tabs, CR, LF) from both ends of a text.
fn _trim_text(s: text) -> text:
    val len = s.len()
    var ls = 0
    var found_start = false
    while ls < len and not found_start:
        val c = s.char_at(ls)
        if c != " " and c != "\t" and c != "\r" and c != "\n":
            found_start = true
        else:
            ls = ls + 1
    if not found_start:
        return ""
    var le = len - 1
    var found_end = false
    while le >= 0 and not found_end:
        val c = s.char_at(le)
        if c != " " and c != "\t" and c != "\r" and c != "\n":
            found_end = true
        else:
            le = le - 1
    s.substring(ls, le + 1)

# Parse one PEM block.  Accepts LF or CRLF line endings.
# Returns Err if no valid block found, BEGIN/END label mismatch,
# or Base64 body is empty/invalid.
# reason: positional pem decode API
fn pem_decode(pem_bytes: [u8]) -> Result<PemBlock, text>:
    val src = _u8_to_text(pem_bytes)
    val begin_prefix = "-----BEGIN "
    val marker_suffix = "-----"

    val begin_pos = _find_str(src, begin_prefix, 0)
    if begin_pos < 0:
        return Err("pem: no BEGIN marker found")

    val begin_label_start = begin_pos + begin_prefix.len()
    val begin_end = _find_str(src, marker_suffix, begin_label_start)
    if begin_end < 0:
        return Err("pem: malformed BEGIN marker (no closing dashes)")

    val begin_label = src.substring(begin_label_start, begin_end)

    # Body starts after the closing dashes + optional CRLF/LF
    var body_start = begin_end + marker_suffix.len()
    # Skip one CRLF or LF
    if body_start < src.len() and src.char_at(body_start) == "\r":
        body_start = body_start + 1
    if body_start < src.len() and src.char_at(body_start) == "\n":
        body_start = body_start + 1

    # Find matching END marker
    val end_search = "-----END " + begin_label + "-----"
    val end_pos = _find_str(src, end_search, body_start)
    if end_pos < 0:
        return Err("pem: no matching END marker for label '" + begin_label + "'")

    # Extract body text and strip whitespace
    val body_raw = src.substring(body_start, end_pos)
    val body_clean = line_unwrap(body_raw)
    val body_trimmed = _trim_text(body_clean)

    if body_trimmed.len() == 0:
        return Err("pem: empty Base64 body")

    val decoded_list = base64_decode(body_trimmed)
    if decoded_list.len() == 0:
        return Err("pem: Base64 decode produced empty result — body may be malformed")

    val der = _list_to_u8(decoded_list)
    val label_bytes = _text_to_u8(begin_label)
    Ok(PemBlock(label: label_bytes, der: der))

# =============================================================================
# pem_decode_all — multi-block
# =============================================================================

# Decode all PEM blocks in a file (e.g. a certificate chain).
# Explanatory text between blocks is silently ignored per RFC 7468 §2.
# Returns a list of PemBlock values.
# Returns Err only on hard parse errors (malformed marker, label mismatch,
# or bad Base64).  An empty file returns Ok([]).
# reason: positional pem decode_all API
fn pem_decode_all(pem_bytes: [u8]) -> Result<list, text>:
    val src = _u8_to_text(pem_bytes)
    val begin_prefix = "-----BEGIN "
    val marker_suffix = "-----"

    var blocks: list = []
    var search_pos: i64 = 0
    val src_len = src.len()

    while search_pos < src_len:
        val begin_pos = _find_str(src, begin_prefix, search_pos)
        if begin_pos < 0:
            # No more BEGIN markers — done.
            search_pos = src_len
        else:
            val begin_label_start = begin_pos + begin_prefix.len()
            val begin_end = _find_str(src, marker_suffix, begin_label_start)
            if begin_end < 0:
                return Err("pem: malformed BEGIN marker at offset " + begin_pos.to_text())

            val begin_label = src.substring(begin_label_start, begin_end)

            var body_start = begin_end + marker_suffix.len()
            if body_start < src_len and src.char_at(body_start) == "\r":
                body_start = body_start + 1
            if body_start < src_len and src.char_at(body_start) == "\n":
                body_start = body_start + 1

            val end_search = "-----END " + begin_label + "-----"
            val end_pos = _find_str(src, end_search, body_start)
            if end_pos < 0:
                return Err("pem: no matching END for label '" + begin_label + "'")

            val body_raw = src.substring(body_start, end_pos)
            val body_clean = line_unwrap(body_raw)
            val body_trimmed = _trim_text(body_clean)

            if body_trimmed.len() == 0:
                return Err("pem: empty Base64 body for label '" + begin_label + "'")

            val decoded_list = base64_decode(body_trimmed)
            if decoded_list.len() == 0:
                return Err("pem: Base64 decode failed for label '" + begin_label + "'")

            val der = _list_to_u8(decoded_list)
            val label_bytes = _text_to_u8(begin_label)
            val block = PemBlock(label: label_bytes, der: der)
            blocks.push(block)

            # Advance past END marker
            search_pos = end_pos + end_search.len()

    Ok(blocks)
