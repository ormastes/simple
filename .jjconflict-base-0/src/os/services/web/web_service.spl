# SimpleOS web service entry — starts the real Simple web server stack
# (std.http_server, the nogc_async_mut default tier) on a configured port.
#
# Before this module, no os/services or os/apps entry constructed the full
# HttpServer stack, so its routers / handler registry / middleware pipeline
# were unreachable on SimpleOS (only the kernel-native plaintext boot server
# in os.kernel.boot.http_baremetal existed). WebService is a thin bridge:
#
#   - It builds a ServerConfig bound to `port` and an HttpServer over it, so
#     `start()` runs the same worker/supervisor stack every hosted consumer
#     uses — nothing here reimplements the server.
#   - It registers ONE demo route ("web_demo") whose page is escaped through
#     the canonical std.common.web.html_escape, so untrusted request data
#     cannot break out of the returned markup.
#   - Route classification reuses os.kernel.net.http_route.http_classify_request
#     (the same pure, spec-tested classifier the boot server uses): GET / is
#     served by the demo handler, everything else is a 404.
#
# dispatch() resolves and runs a request through the registered handler
# in-process (no socket), which is what the spec exercises; start() is the
# production entry that binds the port and serves for real.

use std.http_server.{
    HttpServer, ServerConfig, LocationConfig,
    HttpRequestData, HttpResponseData, HandlerRegistry,
    create_default_registry, default_server_config,
    default_location_config, default_response_data
}
use std.http_server.error.{HttpServerError}
use os.kernel.net.http_route.{http_classify_request, HttpRouteKind}
use std.common.web.html_escape.{html_escape_core}

# Handler-type name the demo LocationConfig maps to, and under which the demo
# handler is registered in the HandlerRegistry.
val WEB_DEMO_HANDLER_TYPE: text = "web_demo"

pub fn web_demo_handler(request: HttpRequestData, location: LocationConfig) -> HttpResponseData:
    """Demo route handler: returns a small HTML page. The request path is
    escaped through the canonical html_escape so reflected request data cannot
    inject markup into the response."""
    val safe_path = html_escape_core(request.path)
    val page = "<!doctype html><html><head><title>SimpleOS</title></head><body><h1>SimpleOS Web</h1><p>You requested: " + safe_path + "</p></body></html>"
    default_response_data(200, "OK", page)

fn _web_demo_location() -> LocationConfig:
    var loc = default_location_config()
    loc.pattern = "/"
    loc.match_type = "exact"
    loc.handler_type = WEB_DEMO_HANDLER_TYPE
    loc

fn _request_line(request: HttpRequestData) -> text:
    """Reconstruct a raw request line the pure classifier can consume from
    already-parsed request data."""
    request.method + " " + request.path + " " + request.version + "\r\n\r\n"

pub struct WebService:
    """A minimal SimpleOS web service over the real std.http_server stack."""
    config: ServerConfig
    registry: HandlerRegistry
    location: LocationConfig
    port: i64

pub fn web_service_new(port: i64) -> WebService:
    """Construct the service: a ServerConfig bound to `port`, a HandlerRegistry
    with the demo route registered, and the demo LocationConfig. Does NOT bind
    a socket or spawn workers — call start() for that."""
    var config = default_server_config()
    config.listen_addr = "0.0.0.0:" + port.to_text()
    val loc = _web_demo_location()
    config.locations = [loc]
    var registry = create_default_registry(".")
    registry.register(WEB_DEMO_HANDLER_TYPE, web_demo_handler)
    WebService(config: config, registry: registry, location: loc, port: port)

fn _handler_type_for(service: WebService, path: text) -> text:
    """Look up which registered handler_type serves `path` by scanning the
    service's LocationConfigs (the same list start()'s workers route against).
    Returns "" when no location matches."""
    if service.location.pattern == path:
        return service.location.handler_type
    ""

pub fn web_service_dispatch(service: WebService, request: HttpRequestData) -> HttpResponseData:
    """Resolve a request to a handler and run it in-process (no socket).

    Route decision reuses the boot classifier (GET / -> Status, else NotFound);
    the matched path is then resolved against the service's registered
    LocationConfig to pick the handler_type, and the demo handler runs.

    NOTE: the handler is invoked directly rather than via
    HandlerRegistry.dispatch() because the pure-Simple interpreter returns nil
    when calling a fn-pointer stored in a Dict (HandlerRegistry.custom_handlers)
    -- verified with a standalone probe. The registry is still installed on the
    HttpServer in web_service_start(), where the threaded worker path (compiled,
    not interpreted) dispatches through it normally."""
    val route = http_classify_request(_request_line(request))
    match route.kind:
        case HttpRouteKind.Status:
            val handler_type = _handler_type_for(service, request.path)
            if handler_type == WEB_DEMO_HANDLER_TYPE:
                web_demo_handler(request, service.location)
            else:
                default_response_data(404, "Not Found", "<!doctype html><html><body><h1>404 Not Found</h1></body></html>")
        case _:
            default_response_data(404, "Not Found", "<!doctype html><html><body><h1>404 Not Found</h1></body></html>")

pub fn web_service_start(service: WebService) -> Result<(), HttpServerError>:
    """Production entry: build the real HttpServer over the service config,
    install the demo handler registry, and start serving (binds the port and
    spawns the worker/supervisor stack)."""
    var server = HttpServer.new(service.config)
    server.set_handler_registry(service.registry)
    server.start()
