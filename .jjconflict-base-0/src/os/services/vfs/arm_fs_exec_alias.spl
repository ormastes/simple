# ARM filesystem-exec VFS — path alias tables
#
# Maps logical paths to canonical FAT32 8.3 uppercase paths and extracts
# the short filename component for directory scan use.

fn _arm_exec_alias(path: text) -> text:
    match path:
        case "/sys/apps/hello_world":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/sys/apps/hello_world.smf":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/sys/apps/simple_compiler":
            "/SYS/APPS/SCOMPSMF.SMF"
        case "/sys/apps/simple_compiler.smf":
            "/SYS/APPS/SCOMPSMF.SMF"
        case "/sys/apps/simple_interpreter":
            "/SYS/APPS/SINTSMF.SMF"
        case "/sys/apps/simple_interpreter.smf":
            "/SYS/APPS/SINTSMF.SMF"
        case "/sys/apps/simple_loader":
            "/SYS/APPS/SLOADSMF.SMF"
        case "/sys/apps/simple_loader.smf":
            "/SYS/APPS/SLOADSMF.SMF"
        case "/sys/apps/simple":
            "/SYS/APPS/SIMPLSTC.SMF"
        case "/sys/apps/simple.smf":
            "/SYS/APPS/SIMPLSTC.SMF"
        case "/usr/bin/simple":
            "/SYS/APPS/SIMPLSTC.SMF"
        case "/bin/simple":
            "/SYS/APPS/SIMPLSTC.SMF"
        case "/sys/apps/llvm":
            "/SYS/APPS/LLVMSMF.SMF"
        case "/sys/apps/llvm.smf":
            "/SYS/APPS/LLVMSMF.SMF"
        case "/sys/apps/clang":
            "/SYS/APPS/CLANGSMF.SMF"
        case "/sys/apps/clang.smf":
            "/SYS/APPS/CLANGSMF.SMF"
        case "/sys/apps/rust":
            "/SYS/APPS/RUSTSMF.SMF"
        case "/sys/apps/rust.smf":
            "/SYS/APPS/RUSTSMF.SMF"
        case "/SYS/APPS/HELLOSMF.SMF":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/SYS/APPS/SCOMPSMF.SMF":
            "/SYS/APPS/SCOMPSMF.SMF"
        case "/SYS/APPS/SINTSMF.SMF":
            "/SYS/APPS/SINTSMF.SMF"
        case "/SYS/APPS/SLOADSMF.SMF":
            "/SYS/APPS/SLOADSMF.SMF"
        case "/SYS/APPS/SIMPLSTC.SMF":
            "/SYS/APPS/SIMPLSTC.SMF"
        case "/SYS/APPS/LLVMSMF.SMF":
            "/SYS/APPS/LLVMSMF.SMF"
        case "/SYS/APPS/CLANGSMF.SMF":
            "/SYS/APPS/CLANGSMF.SMF"
        case "/SYS/APPS/RUSTSMF.SMF":
            "/SYS/APPS/RUSTSMF.SMF"
        case "/HELLOSMF.SMF":
            "/HELLOSMF.SMF"
        case "/SCOMPSMF.SMF":
            "/SCOMPSMF.SMF"
        case "/SINTSMF.SMF":
            "/SINTSMF.SMF"
        case "/SLOADSMF.SMF":
            "/SLOADSMF.SMF"
        case "/SIMPLSTC.SMF":
            "/SIMPLSTC.SMF"
        case "/LLVMSMF.SMF":
            "/LLVMSMF.SMF"
        case "/CLANGSMF.SMF":
            "/CLANGSMF.SMF"
        case "/RUSTSMF.SMF":
            "/RUSTSMF.SMF"
        case "/SYS/VERSION.TXT":
            "/SYS/VERSION.TXT"
        case "/sys/version.txt":
            "/SYS/VERSION.TXT"
        case "/SYS/LLVMMAN.TXT":
            "/SYS/LLVMMAN.TXT"
        case "/sys/llvmman.txt":
            "/SYS/LLVMMAN.TXT"
        case "/SYS/CLANGMAN.TXT":
            "/SYS/CLANGMAN.TXT"
        case "/sys/clangman.txt":
            "/SYS/CLANGMAN.TXT"
        case "/SYS/RUSTMAN.TXT":
            "/SYS/RUSTMAN.TXT"
        case "/sys/rustman.txt":
            "/SYS/RUSTMAN.TXT"
        case "/SYS/TOOLSET.SDN":
            "/SYS/TOOLSET.SDN"
        case "/sys/toolset.sdn":
            "/SYS/TOOLSET.SDN"
        case "/hello.spl":
            "/HELLO.SPL"
        case "/HELLO.SPL":
            "/HELLO.SPL"
        case "/simple.elf":
            "/SIMPLE.ELF"
        case "/SIMPLE.ELF":
            "/SIMPLE.ELF"
        case _:
            path

pub fn arm_fs_exec_disk_alias(path: text) -> text:
    _arm_exec_alias(path)

fn _arm_short_name_for_mapped_path(path: text) -> text:
    match path:
        case "/HELLO.SPL":
            "HELLO.SPL"
        case "/SIMPLE.ELF":
            "SIMPLE.ELF"
        case "/HELLOSMF.SMF":
            "HELLOSMF.SMF"
        case "/SCOMPSMF.SMF":
            "SCOMPSMF.SMF"
        case "/SINTSMF.SMF":
            "SINTSMF.SMF"
        case "/SLOADSMF.SMF":
            "SLOADSMF.SMF"
        case "/SIMPLSTC.SMF":
            "SIMPLSTC.SMF"
        case "/LLVMSMF.SMF":
            "LLVMSMF.SMF"
        case "/CLANGSMF.SMF":
            "CLANGSMF.SMF"
        case "/RUSTSMF.SMF":
            "RUSTSMF.SMF"
        case "/SYS/APPS/HELLOSMF.SMF":
            "HELLOSMF.SMF"
        case "/SYS/APPS/SCOMPSMF.SMF":
            "SCOMPSMF.SMF"
        case "/SYS/APPS/SINTSMF.SMF":
            "SINTSMF.SMF"
        case "/SYS/APPS/SLOADSMF.SMF":
            "SLOADSMF.SMF"
        case "/SYS/APPS/SIMPLSTC.SMF":
            "SIMPLSTC.SMF"
        case "/SYS/APPS/LLVMSMF.SMF":
            "LLVMSMF.SMF"
        case "/SYS/APPS/CLANGSMF.SMF":
            "CLANGSMF.SMF"
        case "/SYS/APPS/RUSTSMF.SMF":
            "RUSTSMF.SMF"
        case "/SYS/VERSION.TXT":
            "VERSION.TXT"
        case "/SYS/LLVMMAN.TXT":
            "LLVMMAN.TXT"
        case "/SYS/CLANGMAN.TXT":
            "CLANGMAN.TXT"
        case "/SYS/RUSTMAN.TXT":
            "RUSTMAN.TXT"
        case "/SYS/TOOLSET.SDN":
            "TOOLSET.SDN"
        case _:
            ""
