# TCP -- Transmission Control Protocol
#
# MDSOC: feature dimension, network layer
# Full TCP state machine per RFC 793 with:
#   - Connection establishment (3-way handshake)
#   - Data transfer with flow control
#   - Connection teardown (4-way FIN)
#   - Retransmission timer support
#
# Header format (20 bytes minimum, no options):
#   src_port(2) dst_port(2) seq_num(4) ack_num(4)
#   data_offset(4b) reserved(3b) flags(9b -- only low 6 used) window(2)
#   checksum(2) urgent_ptr(2)

use os.services.netstack.ipv4.{Ipv4Address}

val TCP_FLAG_FIN: u8 = 0x01
val TCP_FLAG_SYN: u8 = 0x02
val TCP_FLAG_RST: u8 = 0x04
val TCP_FLAG_PSH: u8 = 0x08
val TCP_FLAG_ACK: u8 = 0x10
val TCP_FLAG_URG: u8 = 0x20

val TCP_HEADER_MIN: u64 = 20
val TCP_DEFAULT_WINDOW: u16 = 65535
val TCP_MSS: u16 = 1460         # Max segment size: 1500 - 20 IP - 20 TCP
val TCP_MAX_RETRIES: u32 = 8
val TCP_INITIAL_RTO: u64 = 1000  # Initial retransmission timeout (ms)
val TCP_TIME_WAIT_MS: u64 = 60000  # 2MSL = 60 seconds

# ============================================================================
# TCP State Machine (RFC 793)
# ============================================================================

enum TcpState:
    """TCP connection states per RFC 793."""
    Closed
    Listen
    SynSent
    SynReceived
    Established
    FinWait1
    FinWait2
    CloseWait
    Closing
    LastAck
    TimeWait

fn tcp_state_name(state: TcpState) -> text:
    """Return human-readable name of a TCP state."""
    match state:
        TcpState.Closed: "CLOSED"
        TcpState.Listen: "LISTEN"
        TcpState.SynSent: "SYN_SENT"
        TcpState.SynReceived: "SYN_RECEIVED"
        TcpState.Established: "ESTABLISHED"
        TcpState.FinWait1: "FIN_WAIT_1"
        TcpState.FinWait2: "FIN_WAIT_2"
        TcpState.CloseWait: "CLOSE_WAIT"
        TcpState.Closing: "CLOSING"
        TcpState.LastAck: "LAST_ACK"
        TcpState.TimeWait: "TIME_WAIT"

# ============================================================================
# TCP Header
# ============================================================================

struct TcpHeader:
    """Parsed TCP header fields."""
    src_port: u16
    dst_port: u16
    seq_num: u32
    ack_num: u32
    data_offset: u8    # Header length in 32-bit words (min 5)
    flags: u8          # 6-bit flags: URG ACK PSH RST SYN FIN
    window: u16
    checksum: u16
    urgent_ptr: u16

# ============================================================================
# TCP Segment
# ============================================================================

struct TcpSegment:
    """Complete TCP segment: header + data."""
    header: TcpHeader
    data: [u8]

# ============================================================================
# Parse
# ============================================================================

fn tcp_parse(data: [u8]) -> Result<TcpSegment, text>:
    """Parse a TCP segment from raw bytes.

    Validates minimum length and data offset. Checksum verification
    requires the pseudo-header and is done separately via tcp_checksum.
    """
    if data.len() < TCP_HEADER_MIN:
        return Err("TCP segment too short: {data.len()} < {TCP_HEADER_MIN}")

    val src_port: u16 = (data[0].to_u16() << 8) | data[1].to_u16()
    val dst_port: u16 = (data[2].to_u16() << 8) | data[3].to_u16()

    val seq_num: u32 = (data[4].to_u32() << 24) | (data[5].to_u32() << 16) |
                       (data[6].to_u32() << 8) | data[7].to_u32()
    val ack_num: u32 = (data[8].to_u32() << 24) | (data[9].to_u32() << 16) |
                       (data[10].to_u32() << 8) | data[11].to_u32()

    # Byte 12: data offset (high nibble) in 32-bit words
    val data_offset = (data[12] >> 4) & 0x0F
    if data_offset < 5:
        return Err("TCP data offset too small: {data_offset}")

    val header_len: u64 = data_offset.to_u64() * 4
    if data.len() < header_len:
        return Err("TCP segment shorter than header")

    # Byte 13: flags (low 6 bits are the standard flags)
    val flags = data[13] & 0x3F

    val window: u16 = (data[14].to_u16() << 8) | data[15].to_u16()
    val checksum: u16 = (data[16].to_u16() << 8) | data[17].to_u16()
    val urgent_ptr: u16 = (data[18].to_u16() << 8) | data[19].to_u16()

    # Extract payload (data after header)
    var payload: [u8] = []
    var i: u64 = header_len
    while i < data.len():
        payload.push(data[i])
        i = i + 1

    Ok(TcpSegment(
        header: TcpHeader(
            src_port: src_port, dst_port: dst_port,
            seq_num: seq_num, ack_num: ack_num,
            data_offset: data_offset, flags: flags,
            window: window, checksum: checksum,
            urgent_ptr: urgent_ptr
        ),
        data: payload
    ))

# ============================================================================
# Build
# ============================================================================

fn tcp_build(src_port: u16, dst_port: u16, seq: u32, ack: u32, flags: u8, window: u16, data: [u8]) -> [u8]:
    """Build a TCP segment as raw bytes.

    Creates a minimal 20-byte header (no options, data_offset=5).
    Checksum is set to 0; the caller must compute it via tcp_checksum
    using the pseudo-header and then patch bytes 16-17.
    """
    var pkt: [u8] = []

    # Source port (big-endian)
    pkt.push(((src_port >> 8) & 0xFF).to_u8())
    pkt.push((src_port & 0xFF).to_u8())
    # Destination port (big-endian)
    pkt.push(((dst_port >> 8) & 0xFF).to_u8())
    pkt.push((dst_port & 0xFF).to_u8())

    # Sequence number (big-endian)
    pkt.push(((seq >> 24) & 0xFF).to_u8())
    pkt.push(((seq >> 16) & 0xFF).to_u8())
    pkt.push(((seq >> 8) & 0xFF).to_u8())
    pkt.push((seq & 0xFF).to_u8())

    # Acknowledgment number (big-endian)
    pkt.push(((ack >> 24) & 0xFF).to_u8())
    pkt.push(((ack >> 16) & 0xFF).to_u8())
    pkt.push(((ack >> 8) & 0xFF).to_u8())
    pkt.push((ack & 0xFF).to_u8())

    # Data offset (5 = 20 bytes, no options) in high nibble + reserved
    pkt.push(0x50)  # data_offset=5, reserved=0
    # Flags
    pkt.push(flags)
    # Window (big-endian)
    pkt.push(((window >> 8) & 0xFF).to_u8())
    pkt.push((window & 0xFF).to_u8())
    # Checksum placeholder
    pkt.push(0)
    pkt.push(0)
    # Urgent pointer
    pkt.push(0)
    pkt.push(0)

    # Data payload
    var i: u64 = 0
    while i < data.len():
        pkt.push(data[i])
        i = i + 1

    pkt

fn tcp_build_with_checksum(src_port: u16, dst_port: u16, seq: u32, ack: u32, flags: u8, window: u16, data: [u8], src_ip: Ipv4Address, dst_ip: Ipv4Address) -> [u8]:
    """Build a TCP segment with computed pseudo-header checksum."""
    var pkt = tcp_build(src_port, dst_port, seq, ack, flags, window, data)

    val cksum = tcp_checksum(src_ip, dst_ip, pkt)
    pkt[16] = ((cksum >> 8) & 0xFF).to_u8()
    pkt[17] = (cksum & 0xFF).to_u8()

    pkt

# ============================================================================
# Checksum
# ============================================================================

fn tcp_checksum(src_ip: Ipv4Address, dst_ip: Ipv4Address, tcp_data: [u8]) -> u16:
    """Compute TCP checksum including IPv4 pseudo-header.

    Pseudo-header: src_ip(4) + dst_ip(4) + zero(1) + proto=6(1) + tcp_length(2)
    """
    var sum: u32 = 0

    # Pseudo-header: source IP (two 16-bit words)
    sum = sum + ((src_ip.value >> 16) & 0xFFFF)
    sum = sum + (src_ip.value & 0xFFFF)
    # Pseudo-header: destination IP (two 16-bit words)
    sum = sum + ((dst_ip.value >> 16) & 0xFFFF)
    sum = sum + (dst_ip.value & 0xFFFF)
    # Pseudo-header: zero + protocol (6 = TCP)
    sum = sum + 6
    # Pseudo-header: TCP length
    sum = sum + tcp_data.len().to_u32()

    # Sum over TCP header + data
    var i: u64 = 0
    while i + 1 < tcp_data.len():
        val word: u32 = (tcp_data[i].to_u32() << 8) | tcp_data[i + 1].to_u32()
        sum = sum + word
        i = i + 2

    # Handle odd byte
    if i < tcp_data.len():
        sum = sum + (tcp_data[i].to_u32() << 8)

    # Fold carries
    while (sum >> 16) > 0:
        sum = (sum & 0xFFFF) + (sum >> 16)

    val result: u16 = (~sum & 0xFFFF).to_u16()
    result

# ============================================================================
# Helpers
# ============================================================================

fn tcp_has_flag(flags: u8, flag: u8) -> bool:
    """Check if a specific TCP flag is set."""
    (flags & flag) != 0

fn tcp_flags_text(flags: u8) -> text:
    """Format TCP flags as a human-readable string."""
    var result = ""
    if tcp_has_flag(flags, TCP_FLAG_SYN): result = result + "SYN "
    if tcp_has_flag(flags, TCP_FLAG_ACK): result = result + "ACK "
    if tcp_has_flag(flags, TCP_FLAG_FIN): result = result + "FIN "
    if tcp_has_flag(flags, TCP_FLAG_RST): result = result + "RST "
    if tcp_has_flag(flags, TCP_FLAG_PSH): result = result + "PSH "
    if tcp_has_flag(flags, TCP_FLAG_URG): result = result + "URG "
    result

fn seq_lt(a: u32, b: u32) -> bool:
    """Sequence number comparison: a < b (handles wraparound).

    Uses signed comparison on the difference, per RFC 1323.
    If (a - b) interpreted as signed is negative, then a < b.
    """
    val diff = a - b
    # If high bit is set, the signed interpretation is negative
    (diff & 0x80000000) != 0

fn seq_lte(a: u32, b: u32) -> bool:
    """Sequence number comparison: a <= b (handles wraparound)."""
    a == b or seq_lt(a, b)

fn seq_gt(a: u32, b: u32) -> bool:
    """Sequence number comparison: a > b (handles wraparound)."""
    seq_lt(b, a)

fn seq_gte(a: u32, b: u32) -> bool:
    """Sequence number comparison: a >= b (handles wraparound)."""
    a == b or seq_gt(a, b)

fn seq_between(seq: u32, start: u32, end: u32) -> bool:
    """Check if seq is in the range [start, end) with wraparound."""
    if start == end:
        return false
    if seq_lt(start, end):
        return seq_gte(seq, start) and seq_lt(seq, end)
    # Wraps around
    seq_gte(seq, start) or seq_lt(seq, end)
