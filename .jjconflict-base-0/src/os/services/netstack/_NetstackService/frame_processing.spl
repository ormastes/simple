# NetstackService run loop and inbound frame/protocol processing (ARP, IPv4, ICMP, TCP, UDP).
use os.services.netstack.netstack_service.*
# Network Stack Service -- User-Space TCP/IP on IPC Port 2
#
# MDSOC: feature dimension, network layer
# Owns the VirtIO-net driver in-process (exokernel/libOS pattern).
# Receives raw Ethernet frames, processes through protocol layers
# (ARP, IPv4, ICMP, TCP, UDP), and delivers to application sockets.
# Receives IPC requests from applications for socket operations.
#
# Wire protocol (IPC):
#   Request:  method(u32) | payload(bytes)
#   Response: status(i32) | payload(bytes)

use os.drivers.virtio.virtio_net.{VirtioNetDriver}
use os.services.netstack.ethernet.{
    EthAddress, EthFrame, eth_parse, eth_build,
    ETHERTYPE_IPV4, ETHERTYPE_ARP, ETH_MAX_FRAME
}
use os.services.netstack.arp.{
    ArpTable, ArpPacket, arp_parse, arp_build_request, arp_build_reply,
    ARP_REQUEST, ARP_REPLY
}
use os.services.netstack.ipv4.{
    Ipv4Address, Ipv4Packet, Ipv4Header, ipv4_parse, ipv4_build, RoutingTable,
    IP_PROTO_ICMP, IP_PROTO_TCP, IP_PROTO_UDP
}
use os.services.netstack.icmp.{
    IcmpPacket, icmp_parse, icmp_build_echo_reply,
    ICMP_ECHO_REQUEST
}
use os.services.netstack.udp.{
    UdpDatagram, UdpTable, udp_parse, udp_build
}
use os.services.netstack.tcp.{
    TcpState, TcpSegment, TcpHeader, tcp_parse, tcp_build_with_checksum, tcp_checksum,
    TCP_FLAG_SYN, TCP_FLAG_ACK, tcp_has_flag
}
use os.services.netstack.tcp_connection.{TcpConnection}
use os.services.netstack.socket.{
    OsSocket, SocketTable, SockAddr, SocketProtocol, SocketState
}
use os.userlib.syscall_raw.{syscall}

use os.kernel.log.klog_api.{log_raw_println}
extern fn unsafe_addr_of(ref: any) -> u64

# IPC method constants for network syscalls
impl NetstackService:
    static fn new(driver: VirtioNetDriver) -> NetstackService:
        NetstackService(
            driver: driver,
            arp_table: ArpTable.new(ARP_TABLE_CAPACITY),
            routing: RoutingTable.new(),
            tcp_connections: [],
            udp_table: UdpTable.new(),
            sockets: SocketTable.new(),
            local_ip: Ipv4Address.from_bytes(DEFAULT_IP_A, DEFAULT_IP_B, DEFAULT_IP_C, DEFAULT_IP_D),
            local_mac: EthAddress.zero(),
            subnet_mask: Ipv4Address.from_bytes(DEFAULT_MASK_A, DEFAULT_MASK_B, DEFAULT_MASK_C, DEFAULT_MASK_D),
            port_id: 2,
            running: false,
            next_conn_id: NEXT_CONN_ID_START,
            next_ephemeral: EPHEMERAL_PORT_START,
            tick_count: 0
        )

    # ========================================================================
    # Initialization
    # ========================================================================

    me start():
        """Initialize the network stack and start the service loop.

        Reads MAC from VirtIO driver, sets default IP configuration,
        creates IPC port 2, and enters the main event loop.
        """
        # Read MAC from driver
        val mac_bytes = self.driver.mac_address()
        self.local_mac = EthAddress.from_driver_mac(mac_bytes)
        log_raw_println("[netstack] MAC={self.local_mac.to_text()}")
        log_raw_println("[netstack] IP={self.local_ip.to_text()}")

        # Set up default route
        val gw = Ipv4Address.from_bytes(DEFAULT_GW_A, DEFAULT_GW_B, DEFAULT_GW_C, DEFAULT_GW_D)
        self.routing.set_default(gw)
        self.routing.add_route(
            Ipv4Address.from_bytes(DEFAULT_IP_A, DEFAULT_IP_B, DEFAULT_IP_C, 0),
            self.subnet_mask, gw, self.local_ip
        )
        log_raw_println("[netstack] Default gateway={gw.to_text()}")

        # Create IPC port
        val port = syscall(SYS_IPC_CREATE_PORT, 0, 0, 0, 0, 0)
        if port < 0:
            log_raw_println("[netstack] Failed to create IPC port: {port}")
            return
        self.port_id = port.to_u64()
        self.running = true
        log_raw_println("[netstack] Service started on IPC port {self.port_id}")

        self.run_loop()

    # ========================================================================
    # Main Event Loop
    # ========================================================================

    me run_loop():
        """Main event loop: process incoming frames and IPC requests.

        Busy-polls frames and IPC in a tight loop. For dedicated task mode.
        For cooperative scheduling, use init_port() + poll_once() instead.

        Note: This is a polling loop, not a blocking-wait loop, because
        the netstack must continuously poll for incoming Ethernet frames
        (there's no IRQ-driven notification in the cooperative path).
        """
        while self.running:
            self.poll_once()

    me init_port():
        """Initialize IPC port without entering the blocking loop.

        Call this instead of start() when using cooperative scheduling
        (os_main calls poll_once() in a shared main loop).
        """
        val mac_bytes = self.driver.mac_address()
        self.local_mac = EthAddress.from_driver_mac(mac_bytes)
        log_raw_println("[netstack] MAC={self.local_mac.to_text()}")
        log_raw_println("[netstack] IP={self.local_ip.to_text()}")

        val gw = Ipv4Address.from_bytes(DEFAULT_GW_A, DEFAULT_GW_B, DEFAULT_GW_C, DEFAULT_GW_D)
        self.routing.set_default(gw)
        self.routing.add_route(
            Ipv4Address.from_bytes(DEFAULT_IP_A, DEFAULT_IP_B, DEFAULT_IP_C, 0),
            self.subnet_mask, gw, self.local_ip
        )
        log_raw_println("[netstack] Default gateway={gw.to_text()}")

        val port = syscall(SYS_IPC_CREATE_PORT, 0, 0, 0, 0, 0)
        if port < 0:
            log_raw_println("[netstack] Failed to create IPC port: {port}")
            return
        self.port_id = port.to_u64()
        self.running = true
        log_raw_println("[netstack] Service ready on IPC port {self.port_id}")

    me poll_once():
        """Run one iteration of the event loop (non-blocking).

        Call this from a cooperative main loop. Processes:
          1. Incoming Ethernet frames (non-blocking poll)
          2. IPC requests from applications (non-blocking)
          3. TCP send buffer flush
          4. TCP retransmission timers
          5. TIME_WAIT expiry cleanup
          6. ARP table aging (every 100 ticks)
        """
        if not self.running:
            return
        self.tick_count = self.tick_count + 1

        # 1. Process incoming Ethernet frames
        self.process_incoming_frames()

        # 2. Process IPC requests from applications
        self.process_ipc_requests()

        # 3. Flush pending TCP data
        self.flush_tcp_connections()

        # 4. Check TCP retransmission timers
        self.check_tcp_timers()

        # 5. Check TIME_WAIT expiry and clean up closed connections
        self.cleanup_connections()

        # 6. Age ARP entries periodically (every 100 ticks)
        if self.tick_count % 100 == 0:
            self.arp_table.age_entries(1)

    # ========================================================================
    # Frame Processing
    # ========================================================================

    me process_incoming_frames():
        """Poll for and process incoming Ethernet frames.

        Uses the non-blocking recv_frame_poll() from the VirtIO driver.
        Dispatches by EtherType: ARP (0x0806) or IPv4 (0x0800).
        """
        # Use a stack buffer for the raw frame
        var buf: [u8] = []
        var bi: u64 = 0
        while bi < RECV_BUF_SIZE:
            buf.push(0)
            bi = bi + 1

        # Non-blocking poll
        val buf_addr = unsafe_addr_of(buf)
        val result = self.driver.recv_frame_poll(buf_addr, RECV_BUF_SIZE)

        match result:
            Ok(frame_len):
                # Extract frame bytes
                var frame_data: [u8] = []
                var fi: u64 = 0
                while fi < frame_len:
                    frame_data.push(buf[fi])
                    fi = fi + 1
                self._dispatch_frame(frame_data)
            Err(_):
                pass_dn  # No frame available, that's normal

    me _dispatch_frame(data: [u8]):
        """Parse Ethernet frame and dispatch by EtherType."""
        val frame_result = eth_parse(data)
        match frame_result:
            Err(msg):
                log_raw_println("[netstack] frame parse error: {msg}")
            Ok(frame):
                match frame.ethertype:
                    ETHERTYPE_ARP:
                        self.handle_arp(frame)
                    ETHERTYPE_IPV4:
                        self.handle_ipv4(frame)
                    _:
                        pass_dn  # Ignore unknown EtherTypes

    # ========================================================================
    # ARP Handling
    # ========================================================================

    me handle_arp(frame: EthFrame):
        """Process an ARP request or reply.

        - ARP Request for our IP: send ARP Reply with our MAC
        - ARP Reply: update our ARP cache
        """
        val arp_result = arp_parse(frame.payload)
        match arp_result:
            Err(msg):
                log_raw_println("[netstack] ARP parse error: {msg}")
            Ok(arp):
                # Always learn the sender's mapping
                self.arp_table.insert(arp.sender_ip, arp.sender_mac)

                if arp.operation == ARP_REQUEST:
                    # Is this request for our IP?
                    if arp.target_ip == self.local_ip.value:
                        log_raw_println("[netstack] ARP request for our IP from {arp.sender_mac.to_text()}")
                        val reply_payload = arp_build_reply(
                            self.local_mac, self.local_ip.value,
                            arp.sender_mac, arp.sender_ip
                        )
                        val eth_frame = eth_build(
                            arp.sender_mac, self.local_mac,
                            ETHERTYPE_ARP, reply_payload
                        )
                        self._send_raw_frame(eth_frame)

                else if arp.operation == ARP_REPLY:
                    log_raw_println("[netstack] ARP reply: {Ipv4Address.from_u32(arp.sender_ip).to_text()} -> {arp.sender_mac.to_text()}")

    # ========================================================================
    # IPv4 Handling
    # ========================================================================

    me handle_ipv4(frame: EthFrame):
        """Process an IPv4 packet.

        Validates the header and dispatches by protocol:
          ICMP (1), TCP (6), UDP (17)
        """
        val ip_result = ipv4_parse(frame.payload)
        match ip_result:
            Err(msg):
                log_raw_println("[netstack] IPv4 parse error: {msg}")
            Ok(packet):
                # Check if this packet is for us (or broadcast)
                if (packet.header.dst.equals(self.local_ip) or
                    packet.header.dst.is_broadcast()):
                    match packet.header.protocol:
                        IP_PROTO_ICMP: self.handle_icmp(packet)
                        IP_PROTO_TCP: self.handle_tcp(packet)
                        IP_PROTO_UDP: self.handle_udp(packet)
                        _: pass_dn  # Unsupported protocol

    # ========================================================================
    # ICMP Handling
    # ========================================================================

    me handle_icmp(packet: Ipv4Packet):
        """Process an ICMP packet.

        Echo Request (type 8): send Echo Reply (type 0).
        """
        val icmp_result = icmp_parse(packet.payload)
        match icmp_result:
            Err(msg):
                log_raw_println("[netstack] ICMP parse error: {msg}")
            Ok(icmp):
                if icmp.type_ == ICMP_ECHO_REQUEST:
                    log_raw_println("[netstack] ICMP echo request from {packet.header.src.to_text()}")
                    val reply = icmp_build_echo_reply(icmp)
                    self.send_ipv4(packet.header.src, IP_PROTO_ICMP, reply)

    # ========================================================================
    # TCP Handling
    # ========================================================================

    me handle_tcp(packet: Ipv4Packet):
        """Process an incoming TCP segment.

        Looks up the connection by (src_ip, src_port, dst_port).
        If no connection exists and it's a SYN to a listening socket,
        creates a new connection via the listener.
        """
        val tcp_result = tcp_parse(packet.payload)
        match tcp_result:
            Err(msg):
                log_raw_println("[netstack] TCP parse error: {msg}")
            Ok(segment):
                val src_ip = packet.header.src
                val src_port = segment.header.src_port
                val dst_port = segment.header.dst_port

                # Find existing connection
                var conn_idx: i64 = -1
                var ci: u64 = 0
                while ci < self.tcp_connections.len():
                    if self.tcp_connections[ci].matches_tuple(src_ip, src_port, dst_port):
                        conn_idx = ci.to_i64()
                        break
                    ci = ci + 1

                if conn_idx >= 0:
                    # Existing connection: process segment
                    val was_established = self.tcp_connections[conn_idx.to_u64()].is_established()
                    val reply_segments = self.tcp_connections[conn_idx.to_u64()].process_segment(segment, src_ip)
                    if not was_established and self.tcp_connections[conn_idx.to_u64()].is_established():
                        self._tcp_connection_established(conn_idx.to_u64())
                    elif not was_established and self.tcp_connections[conn_idx.to_u64()].is_closed():
                        self.sockets.mark_connect_failed_by_conn(
                            self.tcp_connections[conn_idx.to_u64()].conn_id,
                            "refused"
                        )
                    self._send_tcp_segments(conn_idx.to_u64(), reply_segments)
                else:
                    # No existing connection: check for SYN to a listener
                    if tcp_has_flag(segment.header.flags, TCP_FLAG_SYN) and
                       not tcp_has_flag(segment.header.flags, TCP_FLAG_ACK):
                        self._handle_incoming_syn(segment, src_ip, dst_port)
                    # else: send RST for unsolicited segments
                    # (omitted for simplicity -- a real stack would RST)

    me _handle_incoming_syn(segment: TcpSegment, src_ip: Ipv4Address, dst_port: u16):
        """Handle a SYN to a listening socket: create new connection."""
        val listener = self.sockets.find_listener(dst_port)
        if listener.?:
            # Create a new TcpConnection in LISTEN state, then process the SYN
            var conn = TcpConnection.new_listener(self.local_ip, dst_port)
            conn.conn_id = self.next_conn_id
            self.next_conn_id = self.next_conn_id + 1

            val reply_segments = conn.process_segment(segment, src_ip)

            self.tcp_connections.push(conn)
            val conn_idx = self.tcp_connections.len() - 1

            self._send_tcp_segments(conn_idx, reply_segments)
            log_raw_println("[netstack] New TCP connection from {src_ip.to_text()}:{segment.header.src_port} -> :{dst_port}")
        # else: no listener, ignore (real stack sends RST)

    me _tcp_connection_established(conn_idx: u64):
        """Publish a TCP connection only after the handshake reaches ESTABLISHED."""
        val conn = self.tcp_connections[conn_idx]
        if self.sockets.mark_connected_by_conn(conn.conn_id):
            return

        val listener = self.sockets.find_listener(conn.local_port)
        if listener.?:
            self.sockets.queue_accepted(listener.unwrap().fd, conn.conn_id)

    me _send_tcp_segments(conn_idx: u64, segments: [TcpSegment]):
        """Send TCP segments for a connection, computing checksums."""
        val conn = self.tcp_connections[conn_idx]
        var i: u64 = 0
        while i < segments.len():
            val seg = segments[i]
            val tcp_bytes = tcp_build_with_checksum(
                seg.header.src_port, seg.header.dst_port,
                seg.header.seq_num, seg.header.ack_num,
                seg.header.flags, seg.header.window,
                seg.data,
                self.local_ip, conn.remote_addr
            )
            self.send_ipv4(conn.remote_addr, IP_PROTO_TCP, tcp_bytes)
            i = i + 1

    # ========================================================================
    # UDP Handling
    # ========================================================================

    me handle_udp(packet: Ipv4Packet):
        """Process an incoming UDP datagram.

        Parses the UDP header and delivers the payload to the bound port.
        """
        val udp_result = udp_parse(packet.payload)
        match udp_result:
            Err(msg):
                log_raw_println("[netstack] UDP parse error: {msg}")
            Ok(datagram):
                val delivered = self.udp_table.deliver(
                    datagram.header.dst_port,
                    datagram.data,
                    packet.header.src,
                    datagram.header.src_port
                )
                if not delivered:
                    log_raw_println("[netstack] UDP: no binding for port {datagram.header.dst_port}")

    # ========================================================================
    # TCP Connection Management
    # ========================================================================

    me flush_tcp_connections():
        """Flush send buffers for all established TCP connections."""
        var i: u64 = 0
        while i < self.tcp_connections.len():
            if self.tcp_connections[i].has_send_data():
                val segments = self.tcp_connections[i].flush_send_buf()
                self._send_tcp_segments(i, segments)
            i = i + 1

    me check_tcp_timers():
        """Check retransmission timers for all TCP connections."""
        var i: u64 = 0
        while i < self.tcp_connections.len():
            val segments = self.tcp_connections[i].check_retransmit(self.tick_count)
            if segments.len() > 0:
                self._send_tcp_segments(i, segments)
            i = i + 1

    me cleanup_connections():
        """Check TIME_WAIT expiry and remove fully closed connections."""
        var i: u64 = 0
        while i < self.tcp_connections.len():
            self.tcp_connections[i].check_time_wait(self.tick_count)
            i = i + 1

        # Remove closed connections (compact the list)
        var active: [TcpConnection] = []
        i = 0
        while i < self.tcp_connections.len():
            if not self.tcp_connections[i].is_closed():
                active.push(self.tcp_connections[i])
            i = i + 1
        self.tcp_connections = active

    # ========================================================================
    # IPv4 Sending
    # ========================================================================

    me send_ipv4(dst_ip: Ipv4Address, protocol: u8, payload: [u8]):
        """Send an IPv4 packet to a destination IP.

        1. Build the IPv4 packet (header + payload)
        2. Resolve destination MAC via ARP lookup
        3. Wrap in Ethernet frame
        4. Transmit via VirtIO driver
        """
        val ip_pkt = ipv4_build(self.local_ip, dst_ip, protocol, payload)

        # Determine next-hop IP (gateway or direct)
        var next_hop = dst_ip
        if not dst_ip.in_subnet(self.local_ip, self.subnet_mask):
            val gw = self.routing.lookup(dst_ip)
            if gw.?:
                next_hop = gw.unwrap()

        # Resolve MAC for next hop
        var dst_mac = self.arp_table.lookup(next_hop.value)
        if dst_mac.?:
            val mac = dst_mac.unwrap()
            val eth_frame = eth_build(mac, self.local_mac, ETHERTYPE_IPV4, ip_pkt)
            self._send_raw_frame(eth_frame)
        else:
            # Need ARP resolution: send ARP request
            # Queue the packet for later (simplified: just send ARP and drop this packet)
            log_raw_println("[netstack] ARP miss for {next_hop.to_text()}, sending request")
            val arp_req = arp_build_request(self.local_mac, self.local_ip.value, next_hop.value)
            val arp_frame = eth_build(EthAddress.broadcast(), self.local_mac, ETHERTYPE_ARP, arp_req)
            self._send_raw_frame(arp_frame)
            # Drop current packet (TCP retransmit will resend; UDP is best-effort)

    me _send_raw_frame(frame: [u8]):
        """Send a raw Ethernet frame via the VirtIO driver."""
        val data_addr = unsafe_addr_of(frame)
        val result = self.driver.send_frame(data_addr, 0, frame.len())
        match result:
            Err(msg): log_raw_println("[netstack] send_frame error: {msg}")
            Ok(_): pass_dn

    # ========================================================================
    # IPC Request Processing
    # ========================================================================
