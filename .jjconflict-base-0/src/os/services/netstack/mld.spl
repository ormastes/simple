# mld.spl
# MLDv1/v2 -- Multicast Listener Discovery (RFC 3810)
# MDSOC: feature dimension, network layer.
#
# MLD is "IGMP for IPv6" -- rides on ICMPv6 (types 130/131/132/143).
#
# Wire formats:
#   MLDv1 (130/131/132):
#       max_resp_delay(2) reserved(2) multicast(16)     = 20 bytes
#   MLDv2 Query (130):
#       max_resp_code(2) reserved(2) multicast(16)
#       flags(1) qqic(1) num_sources(2) sources(16*N)
#   MLDv2 Report (143):
#       reserved(2) num_records(2) records...
#
# GroupRecord reuses the shared type from igmp.spl with IpAddr::V6 sources.
# Records parsed inline (not via sub-function) to avoid ByteReader copy-semantics trap.
#
# Integer constants for type dispatch -- NOT enums (JIT-safe).

use std.common.net.byte_cursor.{ByteReader, ByteWriter}
use std.common.net.addr.{Ipv6Addr, IpAddr, ip_addr_v6, ip_addr_to_bytes}
use os.services.netstack.igmp.{GroupRecord, igmp_group_record_build,
                                GROUP_RECORD_MODE_IS_INCLUDE,
                                GROUP_RECORD_MODE_IS_EXCLUDE,
                                GROUP_RECORD_CHANGE_TO_INCLUDE,
                                GROUP_RECORD_CHANGE_TO_EXCLUDE,
                                GROUP_RECORD_ALLOW_NEW_SOURCES,
                                GROUP_RECORD_BLOCK_OLD_SOURCES}

# ============================================================================
# MLD ICMPv6 type constants
# ============================================================================

val MLD_LISTENER_QUERY: u8 = 130
val MLD_V1_REPORT:      u8 = 131
val MLD_V1_DONE:        u8 = 132
val MLD_V2_REPORT:      u8 = 143

# ============================================================================
# MLDv1 message body (after ICMPv6 type+code+checksum stripped)
# ============================================================================

struct MldV1Message:
    """MLDv1 body: max_resp_delay(2) reserved(2) multicast(16) = 20 bytes."""
    max_resp_delay: u16
    reserved:       u16
    multicast:      Ipv6Addr

fn mldv1_parse(data: [u8]) -> Result<MldV1Message, text>:
    """Parse MLDv1 message body from raw bytes (20 bytes minimum)."""
    if data.len() < 20:
        return Err("MLDv1 truncated: need 20 bytes, got {data.len()}")
    var r = ByteReader.new(data)
    val mrd_r = r.read_u16()
    if mrd_r.is_err():
        return Err("MLDv1: read max_resp_delay")
    val res_r = r.read_u16()
    if res_r.is_err():
        return Err("MLDv1: read reserved")
    val hi_r = r.read_u64()
    if hi_r.is_err():
        return Err("MLDv1: read multicast hi")
    val lo_r = r.read_u64()
    if lo_r.is_err():
        return Err("MLDv1: read multicast lo")
    Ok(MldV1Message(
        max_resp_delay: mrd_r.unwrap(),
        reserved: res_r.unwrap(),
        multicast: Ipv6Addr.from_halves(hi_r.unwrap(), lo_r.unwrap())
    ))

fn mldv1_build(msg: MldV1Message) -> [u8]:
    """Serialize an MLDv1 message body."""
    var w = ByteWriter.new()
    w.write_u16(msg.max_resp_delay)
    w.write_u16(msg.reserved)
    w.write_bytes(msg.multicast.to_bytes())
    w.to_bytes()

# ============================================================================
# MLDv2 Query body
# ============================================================================

struct MldV2Query:
    """MLDv2 Membership Query body (RFC 3810 §5.1)."""
    max_resp_code: u16
    reserved:      u16
    multicast:     Ipv6Addr
    flags:         u8      # resv(4) S(1) QRV(3)
    qqic:          u8
    num_sources:   u16
    sources:       [Ipv6Addr]

fn mldv2_query_parse(data: [u8]) -> Result<MldV2Query, text>:
    """Parse an MLDv2 Query body (28 bytes min before sources)."""
    if data.len() < 28:
        return Err("MLDv2 query truncated: need 28 bytes, got {data.len()}")
    var r = ByteReader.new(data)
    val mrc_r = r.read_u16()
    if mrc_r.is_err():
        return Err("MLDv2q: read max_resp_code")
    val res_r = r.read_u16()
    if res_r.is_err():
        return Err("MLDv2q: read reserved")
    val mhi_r = r.read_u64()
    if mhi_r.is_err():
        return Err("MLDv2q: read multicast hi")
    val mlo_r = r.read_u64()
    if mlo_r.is_err():
        return Err("MLDv2q: read multicast lo")
    val fl_r = r.read_u8()
    if fl_r.is_err():
        return Err("MLDv2q: read flags")
    val qq_r = r.read_u8()
    if qq_r.is_err():
        return Err("MLDv2q: read qqic")
    val ns_r = r.read_u16()
    if ns_r.is_err():
        return Err("MLDv2q: read num_sources")
    val nsrc = ns_r.unwrap().to_u64()
    if r.remaining() < nsrc * 16:
        return Err("MLDv2q: truncated sources")
    var sources: [Ipv6Addr] = []
    var i: u64 = 0
    while i < nsrc:
        val shi_r = r.read_u64()
        if shi_r.is_err():
            return Err("MLDv2q: read source hi")
        val slo_r = r.read_u64()
        if slo_r.is_err():
            return Err("MLDv2q: read source lo")
        sources.push(Ipv6Addr.from_halves(shi_r.unwrap(), slo_r.unwrap()))
        i = i + 1
    Ok(MldV2Query(
        max_resp_code: mrc_r.unwrap(),
        reserved: res_r.unwrap(),
        multicast: Ipv6Addr.from_halves(mhi_r.unwrap(), mlo_r.unwrap()),
        flags: fl_r.unwrap(),
        qqic: qq_r.unwrap(),
        num_sources: ns_r.unwrap(),
        sources: sources
    ))

fn mldv2_query_build(q: MldV2Query) -> [u8]:
    """Serialize an MLDv2 Query body."""
    var w = ByteWriter.new()
    w.write_u16(q.max_resp_code)
    w.write_u16(q.reserved)
    w.write_bytes(q.multicast.to_bytes())
    w.write_u8(q.flags)
    w.write_u8(q.qqic)
    w.write_u16(q.num_sources)
    var i: u64 = 0
    while i < q.sources.len():
        w.write_bytes(q.sources[i].to_bytes())
        i = i + 1
    w.to_bytes()

# ============================================================================
# MLDv2 Report body
# MLDv2 GroupRecord: record_type(1) aux_data_len(1) num_sources(2)
#                    multicast_v6(16) sources(16*N) aux(4*aux_data_len)
# Parsed inline (not via sub-function) to avoid ByteReader copy-semantics trap.
# ============================================================================

struct MldV2Report:
    """MLDv2 Membership Report body (type=143, RFC 3810 §5.2)."""
    reserved:    u16
    num_records: u16
    records:     [GroupRecord]

fn mldv2_report_parse(data: [u8]) -> Result<MldV2Report, text>:
    """Parse an MLDv2 Report body (4 bytes min)."""
    if data.len() < 4:
        return Err("MLDv2 report truncated: need 4 bytes, got {data.len()}")
    var r = ByteReader.new(data)
    val res_r = r.read_u16()
    if res_r.is_err():
        return Err("MLDv2r: read reserved")
    val nr_r = r.read_u16()
    if nr_r.is_err():
        return Err("MLDv2r: read num_records")
    val nrec = nr_r.unwrap().to_u64()
    var records: [GroupRecord] = []
    var i: u64 = 0
    # Parse records inline to keep ByteReader cursor advances in scope.
    while i < nrec:
        val rt_r = r.read_u8()
        if rt_r.is_err():
            return Err("MLDv2r record{i}: read record_type")
        val adl_r = r.read_u8()
        if adl_r.is_err():
            return Err("MLDv2r record{i}: read aux_data_len")
        val ns_r = r.read_u16()
        if ns_r.is_err():
            return Err("MLDv2r record{i}: read num_sources")
        val mhi_r = r.read_u64()
        if mhi_r.is_err():
            return Err("MLDv2r record{i}: read multicast hi")
        val mlo_r = r.read_u64()
        if mlo_r.is_err():
            return Err("MLDv2r record{i}: read multicast lo")
        val nsrc = ns_r.unwrap().to_u64()
        var sources: [IpAddr] = []
        var j: u64 = 0
        while j < nsrc:
            val shi_r = r.read_u64()
            if shi_r.is_err():
                return Err("MLDv2r record{i} source{j}: hi truncated")
            val slo_r = r.read_u64()
            if slo_r.is_err():
                return Err("MLDv2r record{i} source{j}: lo truncated")
            sources.push(ip_addr_v6(Ipv6Addr.from_halves(shi_r.unwrap(), slo_r.unwrap())))
            j = j + 1
        val adl = adl_r.unwrap().to_u64()
        val aux_bytes = adl * 4
        var aux_data: [u8] = []
        if aux_bytes > 0:
            val ax_r = r.read_bytes(aux_bytes)
            if ax_r.is_err():
                return Err("MLDv2r record{i}: read aux_data")
            aux_data = ax_r.unwrap()
        records.push(GroupRecord(
            record_type: rt_r.unwrap(),
            aux_data_len: adl_r.unwrap(),
            num_sources: ns_r.unwrap(),
            multicast: ip_addr_v6(Ipv6Addr.from_halves(mhi_r.unwrap(), mlo_r.unwrap())),
            sources: sources,
            aux_data: aux_data
        ))
        i = i + 1
    Ok(MldV2Report(
        reserved: res_r.unwrap(),
        num_records: nr_r.unwrap(),
        records: records
    ))

fn mldv2_report_build(rep: MldV2Report) -> [u8]:
    """Serialize an MLDv2 Report body."""
    var w = ByteWriter.new()
    w.write_u16(rep.reserved)
    w.write_u16(rep.num_records)
    var i: u64 = 0
    while i < rep.records.len():
        val rb = igmp_group_record_build(rep.records[i])
        w.write_bytes(rb)
        i = i + 1
    w.to_bytes()
