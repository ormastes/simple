# Display Service — GPU/Framebuffer owner and surface manager
#
# The display service owns either a VirtIO-GPU driver or a FramebufferDriver
# and exposes a surface-based API via IPC. Clients (compositor, apps) create
# surfaces, write pixels, and present damage regions.
#
# GPU path: Uses VirtioGpuDriver to create 2D resources, attach backing
#   memory, bind scanouts, and flush damage regions.
# FB path: Uses FramebufferDriver's double-buffered software rendering
#   with copy-based present.

use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use os.drivers.gpu.gpu_accel.{set_gpu_accel_supported_from_driver}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color}
use common.display_protocol.display_protocol.{DisplayMode, DamageRect, SurfaceDesc, PIXEL_FORMAT_BGRA8, display_mode, surface_desc}
use os.kernel.types.device_mem_types.{DeviceGrant}
use os.kernel.boot.mmio.{mmio_write32, mmio_read32}

use os.kernel.log.klog_api.{log_raw_println}

# ============================================================================
# Display Service
# ============================================================================

class DisplayService:
    """Owns the display hardware (GPU or framebuffer) and manages surfaces.

    Only one of gpu/fb is active at a time. The use_gpu flag determines
    which path is used for surface creation and presentation.
    """
    gpu: VirtioGpuDriver?
    fb: FramebufferDriver?
    mode: DisplayMode
    surfaces: [SurfaceDesc]
    surface_count: i32
    active_scanout: u32
    use_gpu: bool
    next_surface_id: u32

impl DisplayService:

    static fn new() -> DisplayService:
        """Create an uninitialized display service."""
        DisplayService(
            gpu: nil,
            fb: nil,
            mode: DisplayMode(width: 0, height: 0, format: 0, refresh_hz: 0),
            surfaces: [],
            surface_count: 0,
            active_scanout: 0,
            use_gpu: false,
            next_surface_id: 1
        )

    # ========================================================================
    # Initialization
    # ========================================================================

    me init_gpu(grant: DeviceGrant) -> bool:
        """Try to initialize VirtIO-GPU driver from a device grant.

        Returns true on success, false if GPU initialization fails.
        On success, the display mode is populated from the GPU's display info.
        """
        var driver = VirtioGpuDriver.new()
        val result = driver.init_from_grant(grant)
        match result:
            Ok(ok):
                self.gpu = driver
                self.use_gpu = true
                self.mode = display_mode(driver.width, driver.height, PIXEL_FORMAT_BGRA8)
                log_raw_println("[display] GPU initialized: {driver.width}x{driver.height}")
                # Wire feature flag + C-side mirror so glass_render.c's
                # rt_gui_present() takes the pending-flush handoff path
                # instead of the MMIO memcpy fallback.
                set_gpu_accel_supported_from_driver(driver)
                log_raw_println("[display] gpu_accel feature flag ON (rid={driver.resource_id})")
                return true
            Err(msg):
                log_raw_println("[display] GPU init failed: {msg}")
                return false

    me init_framebuffer(fb: FramebufferDriver) -> bool:
        """Initialize with framebuffer fallback.

        Returns true on success. The framebuffer driver must already be
        initialized (via from_boot_info).
        """
        self.fb = fb
        self.use_gpu = false
        self.mode = display_mode(fb.width, fb.height, PIXEL_FORMAT_BGRA8)
        log_raw_println("[display] Framebuffer initialized: {fb.width}x{fb.height}")
        return true

    # ========================================================================
    # Queries
    # ========================================================================

    fn get_mode() -> DisplayMode:
        """Return the current display mode."""
        self.mode

    fn is_gpu_active() -> bool:
        """Returns true if the GPU driver is active."""
        self.use_gpu

    # ========================================================================
    # Surface Management
    # ========================================================================

    me create_surface(width: u32, height: u32, format: u32) -> SurfaceDesc:
        """Allocate a new surface.

        For GPU: creates a 2D resource + backing via VirtIO-GPU commands.
        For FB: allocates a pixel buffer in the back_buffer array.

        Returns a SurfaceDesc with an assigned ID. buffer_virt/buffer_phys
        point to the pixel data.
        """
        val sid = self.next_surface_id
        self.next_surface_id = self.next_surface_id + 1

        if self.use_gpu and self.gpu != nil:
            val gpu_ref = self.gpu
            # Create a GPU 2D resource for this surface
            val res_result = gpu_ref.cmd_resource_create_2d(sid, width, height)
            match res_result:
                Ok(ok):
                    # Allocate DMA backing for the surface pixels
                    val buf_size = (width as u64) * (height as u64) * 4
                    val dma = gpu_ref.alloc_dma(buf_size)
                    if dma.ok:
                        val attach = gpu_ref.cmd_resource_attach_backing(sid, dma.phys, buf_size)
                        val desc = surface_desc(sid, width, height, format, dma.virt, dma.phys, buf_size)
                        self.surfaces.push(desc)
                        self.surface_count = self.surface_count + 1
                        log_raw_println("[display] GPU surface {sid}: {width}x{height}")
                        return desc
                    else:
                        log_raw_println("[display] DMA alloc failed for surface {sid}")
                Err(msg):
                    log_raw_println("[display] Resource create failed for surface {sid}: {msg}")

        # FB path: no actual separate allocation, track the surface descriptor
        # with virt/phys = 0 (pixels go through the shared back_buffer)
        val buf_size = (width as u64) * (height as u64) * 4
        val desc = surface_desc(sid, width, height, format, 0, 0, buf_size)
        self.surfaces.push(desc)
        self.surface_count = self.surface_count + 1
        log_raw_println("[display] FB surface {sid}: {width}x{height}")
        return desc

    me destroy_surface(surface_id: u32):
        """Free surface resources.

        For GPU: detaches backing and unreferences the resource.
        Removes the surface from the internal list.
        """
        # Remove from surface list
        var updated: [SurfaceDesc] = []
        for s in self.surfaces:
            if s.id != surface_id:
                updated.push(s)
        self.surfaces = updated
        self.surface_count = self.surface_count - 1
        if self.surface_count < 0:
            self.surface_count = 0

        # GPU cleanup: detach backing memory then unreference the resource
        if self.use_gpu and self.gpu != nil:
            val gpu_ref = self.gpu
            val detach_result = gpu_ref.cmd_resource_detach_backing(surface_id)
            match detach_result:
                Ok(ok):
                    pass_do_nothing
                Err(msg):
                    log_raw_println("[display] DETACH_BACKING warning for surface {surface_id}: {msg}")
            val unref_result = gpu_ref.cmd_resource_unref(surface_id)
            match unref_result:
                Ok(ok):
                    pass_do_nothing
                Err(msg):
                    log_raw_println("[display] RESOURCE_UNREF warning for surface {surface_id}: {msg}")

        log_raw_println("[display] Surface {surface_id} destroyed")

    # ========================================================================
    # Presentation
    # ========================================================================

    me present(surface_id: u32, damage: DamageRect):
        """Present a damage region of a surface to the display.

        For GPU: TRANSFER_TO_HOST_2D + RESOURCE_FLUSH for the damage region.
        For FB: copy damage region from surface buffer to framebuffer and
                call swap_buffers().
        """
        if self.use_gpu and self.gpu != nil:
            val gpu_ref = self.gpu
            # Transfer the dirty region to the host-side resource
            gpu_ref.flush_rect(damage.x, damage.y, damage.width, damage.height)
            return

        # FB path: swap_buffers to present back buffer to front
        if self.fb != nil:
            val fb_ref = self.fb
            fb_ref.swap_buffers()

    me set_scanout(surface_id: u32):
        """Bind a surface to scanout 0 (the primary display output).

        For GPU: sends SET_SCANOUT command.
        For FB: just records the active scanout ID (FB has only one output).
        """
        self.active_scanout = surface_id

        if self.use_gpu and self.gpu != nil:
            val gpu_ref = self.gpu
            # Find the surface dimensions
            for s in self.surfaces:
                if s.id == surface_id:
                    val result = gpu_ref.cmd_set_scanout(0, surface_id, s.width, s.height)
                    match result:
                        Ok(ok):
                            log_raw_println("[display] Scanout 0 bound to surface {surface_id}")
                        Err(msg):
                            log_raw_println("[display] SET_SCANOUT failed: {msg}")
                    return

        log_raw_println("[display] Scanout set to surface {surface_id} (FB mode)")

    # ========================================================================
    # Internal Helpers
    # ========================================================================

    fn _find_surface(surface_id: u32) -> SurfaceDesc?:
        """Find a surface by ID."""
        for s in self.surfaces:
            if s.id == surface_id:
                return s
        nil
