# SimpleOS libc — pure-Simple, musl-shaped string search / span / compare / tokenize core.
#
# Syscall-free subset of musl libc, written in pure Simple (replaces C implementations).
# Buffers are modeled as exact-length `[u8]` (no implicit NUL); search functions return
# indices (or -1 for not found) to model C pointer returns.
#
# Shared interface: libc_<fn> per .spipe/simpleos-alpine-harden-musl-busybox.
# Self-contained: no cross-module imports (interp merge traps avoided).

# ---- search / span / pbrk ---------------------------------------------------

fn libc_strstr(haystack: [u8], needle: [u8]) -> i64:
    """Index of first occurrence of needle in haystack, or -1.
    Empty needle returns 0 (matches at position 0)."""
    val hlen = haystack.len()
    val nlen = needle.len()
    if nlen == 0:
        return 0
    if nlen > hlen:
        return -1
    var i = 0
    while i <= hlen - nlen:
        var match = true
        var j = 0
        while j < nlen:
            if haystack[i + j] != needle[j]:
                match = false
                break
            j = j + 1
        if match:
            return i
        i = i + 1
    -1

fn libc_strspn(s: [u8], accept: [u8]) -> i64:
    """Length of initial run of s whose bytes are ALL in accept."""
    val slen = s.len()
    val alen = accept.len()
    var i = 0
    while i < slen:
        val b = s[i]
        var found = false
        var j = 0
        while j < alen:
            if accept[j] == b:
                found = true
                break
            j = j + 1
        if not found:
            return i
        i = i + 1
    slen

fn libc_strcspn(s: [u8], reject: [u8]) -> i64:
    """Length of initial run of s containing NO byte from reject."""
    val slen = s.len()
    val rlen = reject.len()
    var i = 0
    while i < slen:
        val b = s[i]
        var found = false
        var j = 0
        while j < rlen:
            if reject[j] == b:
                found = true
                break
            j = j + 1
        if found:
            return i
        i = i + 1
    slen

fn libc_strpbrk(s: [u8], accept: [u8]) -> i64:
    """Index of first byte of s that is in accept, or -1."""
    val slen = s.len()
    val alen = accept.len()
    var i = 0
    while i < slen:
        val b = s[i]
        var j = 0
        while j < alen:
            if accept[j] == b:
                return i
            j = j + 1
        i = i + 1
    -1

fn libc_memchr(s: [u8], c: i64, n: i64) -> i64:
    """Index of first byte == c within first n bytes, or -1."""
    val slen = s.len()
    val lim = if n < slen: n else: slen
    var i = 0
    while i < lim:
        if s[i] == c:
            return i
        i = i + 1
    -1

fn libc_memrchr(s: [u8], c: i64, n: i64) -> i64:
    """Index of last byte == c within first n bytes, or -1."""
    val slen = s.len()
    val lim = if n < slen: n else: slen
    var i = lim - 1
    while i >= 0:
        if s[i] == c:
            return i
        i = i - 1
    -1

# ---- case-insensitive compare -----------------------------------------------

fn _libc_tolower_ascii(ch: i64) -> i64:
    """Convert ASCII uppercase to lowercase; leave others unchanged."""
    if ch >= 65 and ch <= 90:
        ch + 32
    else:
        ch

fn libc_strcasecmp(a: [u8], b: [u8]) -> i64:
    """ASCII case-insensitive compare: 0 if equal, -1 or 1 by sign of first diff."""
    val alen = a.len()
    val blen = b.len()
    var i = 0
    while i < alen and i < blen:
        val ca = _libc_tolower_ascii(a[i])
        val cb = _libc_tolower_ascii(b[i])
        if ca != cb:
            return if ca < cb: -1 else: 1
        i = i + 1
    if alen == blen:
        return 0
    if alen < blen:
        return -1
    1

fn libc_strncasecmp(a: [u8], b: [u8], n: i64) -> i64:
    """Case-insensitive compare of first n bytes: 0 if equal, -1 or 1 by sign."""
    val alen = a.len()
    val blen = b.len()
    var i = 0
    while i < n and i < alen and i < blen:
        val ca = _libc_tolower_ascii(a[i])
        val cb = _libc_tolower_ascii(b[i])
        if ca != cb:
            return if ca < cb: -1 else: 1
        i = i + 1
    if i >= n:
        return 0
    if alen < blen:
        return -1
    if alen > blen:
        return 1
    0

# ---- error strings ----------------------------------------------------------

fn libc_strerror(errnum: i64) -> text:
    """Return error message string for errno value.
    Mirrors musl strerror / C library standard messages."""
    if errnum == 0:
        return "Success"
    elif errnum == 1:
        return "Operation not permitted"
    elif errnum == 2:
        return "No such file or directory"
    elif errnum == 3:
        return "No such process"
    elif errnum == 4:
        return "Interrupted system call"
    elif errnum == 5:
        return "Input/output error"
    elif errnum == 6:
        return "No such device or address"
    elif errnum == 7:
        return "Argument list too long"
    elif errnum == 8:
        return "Exec format error"
    elif errnum == 9:
        return "Bad file descriptor"
    elif errnum == 10:
        return "No child processes"
    elif errnum == 11:
        return "Resource temporarily unavailable"
    elif errnum == 12:
        return "Out of memory"
    elif errnum == 13:
        return "Permission denied"
    elif errnum == 14:
        return "Bad address"
    elif errnum == 15:
        return "Block device required"
    elif errnum == 16:
        return "Device or resource busy"
    elif errnum == 17:
        return "File exists"
    elif errnum == 18:
        return "Invalid cross-device link"
    elif errnum == 19:
        return "No such device"
    elif errnum == 20:
        return "Not a directory"
    elif errnum == 21:
        return "Is a directory"
    elif errnum == 22:
        return "Invalid argument"
    elif errnum == 23:
        return "Too many open files in system"
    elif errnum == 24:
        return "Too many open files"
    elif errnum == 25:
        return "Inappropriate ioctl for device"
    elif errnum == 26:
        return "Text file busy"
    elif errnum == 27:
        return "File too large"
    elif errnum == 28:
        return "No space left on device"
    elif errnum == 29:
        return "Illegal seek"
    elif errnum == 30:
        return "Read-only file system"
    elif errnum == 32:
        return "Broken pipe"
    elif errnum == 33:
        return "Numerical argument out of domain"
    elif errnum == 34:
        return "Numerical result out of range"
    elif errnum == 35:
        return "Resource deadlock avoided"
    elif errnum == 36:
        return "File name too long"
    elif errnum == 37:
        return "No locks available"
    elif errnum == 38:
        return "Function not implemented"
    elif errnum == 39:
        return "Directory not empty"
    elif errnum == 40:
        return "Too many levels of symbolic links"
    elif errnum == 42:
        return "No message of desired type"
    elif errnum == 43:
        return "Identifier removed"
    elif errnum == 44:
        return "Channel number out of range"
    elif errnum == 45:
        return "Level 2 not synchronized"
    elif errnum == 46:
        return "Level 3 halted"
    elif errnum == 47:
        return "Level 3 reset"
    elif errnum == 48:
        return "Link number out of range"
    elif errnum == 49:
        return "Protocol driver not attached"
    elif errnum == 50:
        return "No CSI structure available"
    elif errnum == 51:
        return "Level 2 halted"
    elif errnum == 52:
        return "Invalid exchange"
    elif errnum == 53:
        return "Invalid request descriptor"
    elif errnum == 54:
        return "Exchange full"
    elif errnum == 55:
        return "No anode"
    elif errnum == 56:
        return "Invalid request code"
    elif errnum == 57:
        return "Invalid slot"
    elif errnum == 59:
        return "Bad font file format"
    elif errnum == 60:
        return "Device not a stream"
    elif errnum == 61:
        return "No data available"
    elif errnum == 62:
        return "Timer expired"
    elif errnum == 63:
        return "Out of streams resources"
    elif errnum == 64:
        return "Machine is not on the network"
    elif errnum == 65:
        return "Package not installed"
    elif errnum == 66:
        return "Object is remote"
    elif errnum == 67:
        return "Link has been severed"
    elif errnum == 68:
        return "Advertise error"
    elif errnum == 69:
        return "Srmount error"
    elif errnum == 70:
        return "Communication error on send"
    elif errnum == 71:
        return "Protocol error"
    elif errnum == 72:
        return "Multihop attempted"
    elif errnum == 73:
        return "RFS specific error"
    elif errnum == 74:
        return "Bad message"
    elif errnum == 75:
        return "Value too large for defined data type"
    elif errnum == 76:
        return "File name too long"
    elif errnum == 77:
        return "Remote address changed"
    elif errnum == 78:
        return "Illegal byte sequence"
    else:
        return "Unknown error"

# ---- tokenizer (reentrant, stateless) ----------------------------------------

struct TokResult:
    tok_start: i64
    tok_end: i64
    nextpos: i64
    found: bool

fn libc_strtok_r(s: [u8], delims: [u8], from: i64) -> TokResult:
    """Reentrant tokenizer: return next token and continuation position.
    Starting at `from`, skip leading delimiter bytes, then find the token
    (runs until next delimiter or end). found=false when no token remains."""
    val slen = s.len()
    val dlen = delims.len()
    var pos = from
    # Skip leading delimiters
    while pos < slen:
        val b = s[pos]
        var is_delim = false
        var j = 0
        while j < dlen:
            if delims[j] == b:
                is_delim = true
                break
            j = j + 1
        if not is_delim:
            break
        pos = pos + 1
    # Check if we've exhausted the string
    if pos >= slen:
        return TokResult(tok_start: -1, tok_end: -1, nextpos: pos, found: false)
    # Token starts here
    val tok_start = pos
    # Find the end (next delimiter or end of string)
    while pos < slen:
        val b = s[pos]
        var is_delim = false
        var j = 0
        while j < dlen:
            if delims[j] == b:
                is_delim = true
                break
            j = j + 1
        if is_delim:
            break
        pos = pos + 1
    val tok_end = pos
    # Position for next call
    var nextpos = pos
    if nextpos < slen:
        nextpos = nextpos + 1
    TokResult(tok_start: tok_start, tok_end: tok_end, nextpos: nextpos, found: true)
