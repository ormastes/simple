# Release Pipeline — End-to-End OS Build + Package + Artifact
# MDSOC: feature dimension, apps layer

use os.tools.pkg.pkg_format.{PkgArch, pkg_arch_from_text, pkg_arch_to_text}
use os.packages.os_packages.{list_all_packages, os_version}
use os.tools.pkg.pkg_builder.{build_meta_package}
use os.installer.image_builder.{build_usb_installer_image, build_install_image}
use os.userlib.fs.{mkdir, write_text}

struct ReleaseConfig:
    arch: PkgArch
    output_dir: text
    kernel_path: text
    image_size_mb: u64

fn default_release_config(arch: PkgArch) -> ReleaseConfig:
    ReleaseConfig(arch: arch, output_dir: "release", kernel_path: "", image_size_mb: 512)

fn release_all(config: ReleaseConfig) -> Result<bool, text>:
    val arch_name = pkg_arch_to_text(config.arch)
    val ver_str = os_version().to_text()
    val release_dir = "{config.output_dir}/{arch_name}"
    val pkg_dir = "{release_dir}/packages"
    val img_dir = "{release_dir}/images"

    mkdir(config.output_dir)
    mkdir(release_dir)
    mkdir(pkg_dir)
    mkdir(img_dir)

    print "[1/5] Kernel..."
    var kernel = config.kernel_path
    if kernel == "":
        kernel = _locate_kernel(config.arch)
        if kernel == "":
            kernel = "{release_dir}/kernel.elf"
            write_text(kernel, "# Placeholder kernel — build with: bin/simple os build --arch={arch_name}\n")
        else:
            print "  Using kernel: {kernel}"

    print "\n[2/5] Building packages..."
    val packages = list_all_packages(config.arch)
    var pkg_count = 0
    for pkg in packages:
        val result = build_meta_package(pkg, pkg_dir)
        if val Ok(_) = result:
            pkg_count = pkg_count + 1
        else if val Err(e) = result:
            print "  FAILED: {pkg.base.name} — {e}"
    print "  Built {pkg_count} packages"

    print "\n[3/5] Creating installer ISO..."
    val iso_path = "{img_dir}/simpleos-{ver_str}-{arch_name}-installer.iso"
    val iso_result = build_usb_installer_image(config.arch, kernel, pkg_dir, iso_path, config.image_size_mb)
    if val Err(e) = iso_result:
        return Result.Err("Installer ISO failed: {e}")

    print "\n[4/5] Creating disk image..."
    val disk_path = "{img_dir}/simpleos-{ver_str}-{arch_name}.img"
    val disk_result = build_install_image(config.arch, kernel, pkg_dir, disk_path, config.image_size_mb)
    if val Err(e) = disk_result:
        return Result.Err("Disk image failed: {e}")

    print "\n[5/5] Writing release manifest..."
    val manifest = _write_release_manifest(release_dir, config, pkg_count)
    print "  Release manifest: {manifest}"
    print "  Installer ISO: {iso_path}"
    print "  Disk image: {disk_path}"
    print "  Deploy manifest: {disk_path}.manifest.sdn"
    Result.Ok(true)

fn release_packages(config: ReleaseConfig) -> Result<i32, text>:
    val pkg_dir = "{config.output_dir}/packages"
    mkdir(config.output_dir)
    mkdir(pkg_dir)
    val packages = list_all_packages(config.arch)
    var count = 0
    for pkg in packages:
        val result = build_meta_package(pkg, pkg_dir)
        if val Ok(_) = result:
            count = count + 1
        else if val Err(e) = result:
            print "FAILED: {pkg.base.name} — {e}"
    Result.Ok(count)

fn release_usb(config: ReleaseConfig) -> Result<text, text>:
    val pkg_dir = "{config.output_dir}/packages"
    mkdir(config.output_dir)
    mkdir(pkg_dir)
    val pkg_result = release_packages(config)
    if val Err(e) = pkg_result:
        return Result.Err(e)

    var kernel = config.kernel_path
    if kernel == "":
        kernel = _locate_kernel(config.arch)

    val arch_name = pkg_arch_to_text(config.arch)
    val ver_str = os_version().to_text()
    val iso_path = "{config.output_dir}/simpleos-{ver_str}-{arch_name}-installer.iso"
    build_usb_installer_image(config.arch, kernel, pkg_dir, iso_path, config.image_size_mb)

fn _print_release_usage():
    print "Usage: release <command> [OPTIONS]"
    print ""
    print "Commands:"
    print "  all              Full release (kernel + packages + disk + iso)"
    print "  packages         Build .spk packages only"
    print "  usb              Build installer ISO artifact"
    print "  disk             Build ready-to-boot disk image"
    print ""
    print "Options:"
    print "  --arch=ARCH      Target architecture (default: x86_64)"
    print "  --output=DIR     Output directory (default: release/)"
    print "  --kernel=PATH    Pre-built kernel ELF path"
    print "  --size=MB        Disk image size in MB (default: 512)"
    print "  -h               Show this help"

fn run_release(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_release_usage()
            return 0
    if args.len() < 1:
        _print_release_usage()
        return 1

    var arch_str = "x86_64"
    var output = "release"
    var kernel = ""
    var size_mb: u64 = 512
    for arg in args:
        if arg.starts_with("--arch="):
            arch_str = arg.slice(7, arg.len())
        else if arg.starts_with("--output="):
            output = arg.slice(9, arg.len())
        else if arg.starts_with("--kernel="):
            kernel = arg.slice(9, arg.len())
        else if arg.starts_with("--size="):
            size_mb = arg.slice(7, arg.len()).to_u64()

    val arch_result = pkg_arch_from_text(arch_str)
    if val Err(e) = arch_result:
        print "Error: {e}"
        return 1
    val config = ReleaseConfig(
        arch: arch_result.unwrap(),
        output_dir: output,
        kernel_path: kernel,
        image_size_mb: size_mb
    )

    val command = args[0]
    if command == "all":
        val result = release_all(config)
        if val Err(e) = result:
            print "Release failed: {e}"
            return 1
        return 0
    else if command == "packages":
        val result = release_packages(config)
        if val Ok(count) = result:
            print "Built {count} packages in {output}/"
            return 0
        else if val Err(e) = result:
            print "Error: {e}"
            return 1
    else if command == "usb":
        val result = release_usb(config)
        if val Ok(path) = result:
            print "Installer ISO: {path}"
            return 0
        else if val Err(e) = result:
            print "Error: {e}"
            return 1
    else if command == "disk":
        val pkg_dir = "{output}/packages"
        val ver_str = os_version().to_text()
        val disk_path = "{output}/simpleos-{ver_str}-{arch_str}.img"
        val result = build_install_image(config.arch, kernel, pkg_dir, disk_path, size_mb)
        if val Ok(path) = result:
            print "Disk image: {path}"
            return 0
        else if val Err(e) = result:
            print "Error: {e}"
            return 1
    print "Unknown command: {command}"
    _print_release_usage()
    1

fn _locate_kernel(arch: PkgArch) -> text:
    val arch_name = pkg_arch_to_text(arch)
    val candidates = [
        "build/os/simpleos_{arch_name}.elf",
        "build/os/{arch_name}/kernel.elf",
        "examples/simple_os/build/{arch_name}/kernel.elf"
    ]
    for path in candidates:
        val content = os.userlib.fs.read_text(path)
        if content != "":
            return path
    ""

fn _write_release_manifest(release_dir: text, config: ReleaseConfig, pkg_count: i32) -> text:
    val arch_name = pkg_arch_to_text(config.arch)
    val ver = os_version().to_text()
    val path = "{release_dir}/release.sdn"
    var content = "[release]\n"
    content = content + "version = \"{ver}\"\n"
    content = content + "arch = \"{arch_name}\"\n"
    content = content + "packages = {pkg_count}\n"
    content = content + "image_size_mb = {config.image_size_mb}\n"
    content = content + "kernel = \"{config.kernel_path}\"\n"
    content = content + "disk_image = \"{release_dir}/images/simpleos-{ver}-{arch_name}.img\"\n"
    content = content + "installer_iso = \"{release_dir}/images/simpleos-{ver}-{arch_name}-installer.iso\"\n"
    content = content + "deploy_manifest = \"{release_dir}/images/simpleos-{ver}-{arch_name}.img.manifest.sdn\"\n"
    write_text(path, content)
    path
