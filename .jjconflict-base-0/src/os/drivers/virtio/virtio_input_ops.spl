# VirtIO-Input Event Translation — pure evdev -> internal input event mapping
#
# MDSOC: feature dimension, drivers layer
#
# Translates raw `virtio_input_event { type, code, value }` fields (the
# Linux evdev wire format virtio-input devices use) into the SAME internal
# event types the PS/2 drivers already produce:
#   - os.drivers.input.ps2_keyboard.{Key, KeyEvent}   (keyboard)
#   - os.drivers.input.ps2_mouse.{MouseEvent}         (mouse/pointer)
#
# so everything downstream of PS/2 (WM input routing, InputBackend
# implementations) works unchanged regardless of which driver produced the
# event. Every function/method here is pure host-side logic — no MMIO, no
# hardware I/O — so it is unit-testable without QEMU.

use os.drivers.input.ps2_keyboard.{Key, KeyEvent}
use os.drivers.input.ps2_mouse.{MouseEvent}

# ============================================================================
# evdev wire-format constants (Linux input-event-codes.h / input.h)
# ============================================================================

val EV_SYN: u16 = 0x00
val EV_KEY: u16 = 0x01
val EV_REL: u16 = 0x02
val EV_ABS: u16 = 0x03

val SYN_REPORT: u16 = 0x00

val REL_X: u16 = 0x00
val REL_Y: u16 = 0x01
val REL_WHEEL: u16 = 0x08

val BTN_LEFT: u16 = 0x110
val BTN_RIGHT: u16 = 0x111
val BTN_MIDDLE: u16 = 0x112

# Key-value semantics on the EV_KEY event: 0 = release, 1 = press, 2 = repeat.
val KEY_VALUE_RELEASE: u32 = 0
val KEY_VALUE_PRESS: u32 = 1
val KEY_VALUE_REPEAT: u32 = 2

# ============================================================================
# evdev KEY_* codes (Linux input-event-codes.h) used by the keyboard table
# ============================================================================

val KEY_ESC: u16 = 1
val KEY_1: u16 = 2
val KEY_2: u16 = 3
val KEY_3: u16 = 4
val KEY_4: u16 = 5
val KEY_5: u16 = 6
val KEY_6: u16 = 7
val KEY_7: u16 = 8
val KEY_8: u16 = 9
val KEY_9: u16 = 10
val KEY_0: u16 = 11
val KEY_MINUS: u16 = 12
val KEY_EQUAL: u16 = 13
val KEY_BACKSPACE: u16 = 14
val KEY_TAB: u16 = 15
val KEY_Q: u16 = 16
val KEY_W: u16 = 17
val KEY_E: u16 = 18
val KEY_R: u16 = 19
val KEY_T: u16 = 20
val KEY_Y: u16 = 21
val KEY_U: u16 = 22
val KEY_I: u16 = 23
val KEY_O: u16 = 24
val KEY_P: u16 = 25
val KEY_LEFTBRACE: u16 = 26
val KEY_RIGHTBRACE: u16 = 27
val KEY_ENTER: u16 = 28
val KEY_LEFTCTRL: u16 = 29
val KEY_A: u16 = 30
val KEY_S: u16 = 31
val KEY_D: u16 = 32
val KEY_F: u16 = 33
val KEY_G: u16 = 34
val KEY_H: u16 = 35
val KEY_J: u16 = 36
val KEY_K: u16 = 37
val KEY_L: u16 = 38
val KEY_SEMICOLON: u16 = 39
val KEY_APOSTROPHE: u16 = 40
val KEY_GRAVE: u16 = 41
val KEY_LEFTSHIFT: u16 = 42
val KEY_BACKSLASH: u16 = 43
val KEY_Z: u16 = 44
val KEY_X: u16 = 45
val KEY_C: u16 = 46
val KEY_V: u16 = 47
val KEY_B: u16 = 48
val KEY_N: u16 = 49
val KEY_M: u16 = 50
val KEY_COMMA: u16 = 51
val KEY_DOT: u16 = 52
val KEY_SLASH: u16 = 53
val KEY_RIGHTSHIFT: u16 = 54
val KEY_LEFTALT: u16 = 56
val KEY_SPACE: u16 = 57
val KEY_CAPSLOCK: u16 = 58
val KEY_F1: u16 = 59
val KEY_F2: u16 = 60
val KEY_F3: u16 = 61
val KEY_F4: u16 = 62
val KEY_F5: u16 = 63
val KEY_F6: u16 = 64
val KEY_F7: u16 = 65
val KEY_F8: u16 = 66
val KEY_F9: u16 = 67
val KEY_F10: u16 = 68
val KEY_F11: u16 = 87
val KEY_F12: u16 = 88
val KEY_RIGHTCTRL: u16 = 97
val KEY_RIGHTALT: u16 = 100
val KEY_HOME: u16 = 102
val KEY_UP: u16 = 103
val KEY_PAGEUP: u16 = 104
val KEY_LEFT: u16 = 105
val KEY_RIGHT: u16 = 106
val KEY_END: u16 = 107
val KEY_DOWN: u16 = 108
val KEY_PAGEDOWN: u16 = 109
val KEY_INSERT: u16 = 110
val KEY_DELETE: u16 = 111

# ============================================================================
# evdev KEY_* code -> internal Key enum (mirrors ps2_keyboard.scancode_to_key)
# ============================================================================

fn evdev_key_to_key(code: u16) -> Key:
    """Translate a Linux evdev KEY_* code into the same `Key` enum PS/2 uses.

    Uses an if/elif chain of `==` comparisons against the named KEY_* vals
    rather than a `match` — a bare identifier in a `case` pattern is a
    capture binding, not a value comparison against an existing `val` (and
    even literal-int case patterns mis-match on u16 scrutinees under this
    toolchain), so `match` here would silently fall through to `_` for
    every code. ps2_keyboard.spl's own `scancode_to_key` sidesteps the same
    trap by matching on `u8` with literal hex patterns instead.
    """
    if code == KEY_ESC: Key.Escape
    elif code == KEY_F1: Key.F1
    elif code == KEY_F2: Key.F2
    elif code == KEY_F3: Key.F3
    elif code == KEY_F4: Key.F4
    elif code == KEY_F5: Key.F5
    elif code == KEY_F6: Key.F6
    elif code == KEY_F7: Key.F7
    elif code == KEY_F8: Key.F8
    elif code == KEY_F9: Key.F9
    elif code == KEY_F10: Key.F10
    elif code == KEY_F11: Key.F11
    elif code == KEY_F12: Key.F12
    elif code == KEY_GRAVE: Key.Backtick
    elif code == KEY_1: Key.Num1
    elif code == KEY_2: Key.Num2
    elif code == KEY_3: Key.Num3
    elif code == KEY_4: Key.Num4
    elif code == KEY_5: Key.Num5
    elif code == KEY_6: Key.Num6
    elif code == KEY_7: Key.Num7
    elif code == KEY_8: Key.Num8
    elif code == KEY_9: Key.Num9
    elif code == KEY_0: Key.Num0
    elif code == KEY_MINUS: Key.Minus
    elif code == KEY_EQUAL: Key.Equals
    elif code == KEY_BACKSPACE: Key.Backspace
    elif code == KEY_TAB: Key.Tab
    elif code == KEY_Q: Key.Q
    elif code == KEY_W: Key.W
    elif code == KEY_E: Key.E
    elif code == KEY_R: Key.R
    elif code == KEY_T: Key.T
    elif code == KEY_Y: Key.Y
    elif code == KEY_U: Key.U
    elif code == KEY_I: Key.I
    elif code == KEY_O: Key.O
    elif code == KEY_P: Key.P
    elif code == KEY_LEFTBRACE: Key.LeftBracket
    elif code == KEY_RIGHTBRACE: Key.RightBracket
    elif code == KEY_BACKSLASH: Key.Backslash
    elif code == KEY_CAPSLOCK: Key.CapsLock
    elif code == KEY_A: Key.A
    elif code == KEY_S: Key.S
    elif code == KEY_D: Key.D
    elif code == KEY_F: Key.F
    elif code == KEY_G: Key.G
    elif code == KEY_H: Key.H
    elif code == KEY_J: Key.J
    elif code == KEY_K: Key.K
    elif code == KEY_L: Key.L
    elif code == KEY_SEMICOLON: Key.Semicolon
    elif code == KEY_APOSTROPHE: Key.Quote
    elif code == KEY_ENTER: Key.Enter
    elif code == KEY_LEFTSHIFT: Key.LeftShift
    elif code == KEY_Z: Key.Z
    elif code == KEY_X: Key.X
    elif code == KEY_C: Key.C
    elif code == KEY_V: Key.V
    elif code == KEY_B: Key.B
    elif code == KEY_N: Key.N
    elif code == KEY_M: Key.M
    elif code == KEY_COMMA: Key.Comma
    elif code == KEY_DOT: Key.Period
    elif code == KEY_SLASH: Key.Slash
    elif code == KEY_RIGHTSHIFT: Key.RightShift
    elif code == KEY_LEFTCTRL: Key.LeftCtrl
    elif code == KEY_LEFTALT: Key.LeftAlt
    elif code == KEY_SPACE: Key.Space
    elif code == KEY_RIGHTALT: Key.RightAlt
    elif code == KEY_RIGHTCTRL: Key.RightCtrl
    elif code == KEY_UP: Key.Up
    elif code == KEY_DOWN: Key.Down
    elif code == KEY_LEFT: Key.Left
    elif code == KEY_RIGHT: Key.Right
    elif code == KEY_INSERT: Key.Insert
    elif code == KEY_DELETE: Key.Delete
    elif code == KEY_HOME: Key.Home
    elif code == KEY_END: Key.End
    elif code == KEY_PAGEUP: Key.PageUp
    elif code == KEY_PAGEDOWN: Key.PageDown
    else: Key.Unknown

fn virtio_input_key_event(code: u16, value: u32) -> KeyEvent:
    """Translate one EV_KEY (code, value) pair into a PS/2-compatible KeyEvent.

    value: 0 = release, 1 = press, 2 = repeat (Linux evdev convention).
    A repeat is reported as another Press, matching the PS/2 driver's own
    behavior of re-emitting Press while a key is held (scancode auto-repeat).
    """
    val key = evdev_key_to_key(code)
    if value == KEY_VALUE_RELEASE:
        KeyEvent.Release(key: key)
    else:
        KeyEvent.Press(key: key)

fn virtio_input_key_is_modifier_code(code: u16) -> bool:
    """True if `code` is one of the modifier KEY_* codes (shift/ctrl/alt)."""
    code == KEY_LEFTSHIFT or code == KEY_RIGHTSHIFT or
        code == KEY_LEFTCTRL or code == KEY_RIGHTCTRL or
        code == KEY_LEFTALT or code == KEY_RIGHTALT

# ============================================================================
# Mouse/pointer accumulator — buffers EV_REL/EV_KEY(BTN_*) until EV_SYN,
# mirroring Ps2Mouse's 3-byte-packet accumulation + edge-triggered buttons.
# ============================================================================

class VirtioMouseAccum:
    """Accumulates virtio-input pointer events between SYN_REPORT frames.

    Feed EV_REL (REL_X/REL_Y/REL_WHEEL) and EV_KEY (BTN_LEFT/RIGHT/MIDDLE)
    events via `feed_rel`/`feed_key` as they arrive off the event virtqueue;
    call `feed_syn()` on SYN_REPORT to flush the accumulated frame into a
    single PS/2-compatible `MouseEvent` with edge-triggered button state.
    """
    x: i64
    y: i64
    screen_width: i64
    screen_height: i64
    left: bool
    right: bool
    middle: bool
    prev_left: bool
    prev_right: bool
    pending_dx: i64
    pending_dy: i64
    pending_scroll: i64

impl VirtioMouseAccum:
    static fn create(screen_width: i64, screen_height: i64) -> VirtioMouseAccum:
        VirtioMouseAccum(
            x: screen_width / 2,
            y: screen_height / 2,
            screen_width: screen_width,
            screen_height: screen_height,
            left: false,
            right: false,
            middle: false,
            prev_left: false,
            prev_right: false,
            pending_dx: 0,
            pending_dy: 0,
            pending_scroll: 0
        )

    me feed_rel(code: u16, value: i64):
        """Accumulate one EV_REL sample (REL_X/REL_Y/REL_WHEEL); ignores others.

        Uses `==` comparisons against the named REL_* vals rather than a
        `match` with bare-identifier patterns, which bind rather than
        compare (see evdev_key_to_key's docstring for why).
        """
        if code == REL_X:
            self.pending_dx = self.pending_dx + value
        elif code == REL_Y:
            self.pending_dy = self.pending_dy + value
        elif code == REL_WHEEL:
            self.pending_scroll = self.pending_scroll + value

    me feed_key(code: u16, pressed: bool):
        """Update button state from one EV_KEY(BTN_*) sample; ignores others."""
        if code == BTN_LEFT:
            self.left = pressed
        elif code == BTN_RIGHT:
            self.right = pressed
        elif code == BTN_MIDDLE:
            self.middle = pressed

    me feed_syn() -> MouseEvent:
        """Flush the accumulated frame (SYN_REPORT) into one MouseEvent.

        Applies the pending relative deltas to the tracked absolute position
        (clamped to screen bounds, matching Ps2Mouse), computes edge-triggered
        button transitions, then resets the per-frame accumulators.
        """
        var new_x = self.x + self.pending_dx
        var new_y = self.y + self.pending_dy
        if new_x < 0:
            new_x = 0
        if new_x >= self.screen_width:
            new_x = self.screen_width - 1
        if new_y < 0:
            new_y = 0
        if new_y >= self.screen_height:
            new_y = self.screen_height - 1
        self.x = new_x
        self.y = new_y

        val event = MouseEvent(
            x: self.x,
            y: self.y,
            dx: self.pending_dx,
            dy: self.pending_dy,
            left_pressed: self.left,
            right_pressed: self.right,
            middle_pressed: self.middle,
            left_just_pressed: self.left and not self.prev_left,
            right_just_pressed: self.right and not self.prev_right,
            left_just_released: (not self.left) and self.prev_left
        )

        self.prev_left = self.left
        self.prev_right = self.right
        self.pending_dx = 0
        self.pending_dy = 0
        self.pending_scroll = 0
        event
