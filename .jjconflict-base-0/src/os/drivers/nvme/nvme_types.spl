# NVMe Types -- command and completion entry structures
#
# NVMe Submission Queue Entry (SQE): 64 bytes
# NVMe Completion Queue Entry (CQE): 16 bytes
#
# MDSOC: feature dimension, drivers layer
# All constants use primitive types for baremetal ABI safety.

# ============================================================================
# Admin Command Opcodes
# ============================================================================

val NVME_ADMIN_DELETE_IOSQ: u8 = 0x00
val NVME_ADMIN_CREATE_IOSQ: u8 = 0x01
val NVME_ADMIN_DELETE_IOCQ: u8 = 0x04
val NVME_ADMIN_CREATE_IOCQ: u8 = 0x05
val NVME_ADMIN_IDENTIFY: u8 = 0x06
val NVME_ADMIN_SET_FEATURES: u8 = 0x09
val NVME_ADMIN_GET_FEATURES: u8 = 0x0A

# ============================================================================
# I/O Command Opcodes
# ============================================================================

val NVME_IO_FLUSH: u8 = 0x00
val NVME_IO_WRITE: u8 = 0x01
val NVME_IO_READ: u8 = 0x02

# ============================================================================
# Register Offsets (from BAR0)
# ============================================================================

val NVME_REG_CAP: u64 = 0x00       # Controller Capabilities (64-bit)
val NVME_REG_VS: u64 = 0x08        # Version
val NVME_REG_INTMS: u64 = 0x0C     # Interrupt Mask Set
val NVME_REG_INTMC: u64 = 0x10     # Interrupt Mask Clear
val NVME_REG_CC: u64 = 0x14        # Controller Configuration
val NVME_REG_CSTS: u64 = 0x1C      # Controller Status
val NVME_REG_AQA: u64 = 0x24       # Admin Queue Attributes
val NVME_REG_ASQ: u64 = 0x28       # Admin Submission Queue Base (64-bit)
val NVME_REG_ACQ: u64 = 0x30       # Admin Completion Queue Base (64-bit)

# ============================================================================
# Controller Configuration (CC) Register Bits
# ============================================================================
# Bit 0:     EN   - Enable
# Bits 4-6:  CSS  - I/O Command Set Selected (0 = NVM)
# Bits 7-10: MPS  - Memory Page Size (0 = 4KB)
# Bits 11-13: AMS - Arbitration Mechanism Selected
# Bits 16-19: IOSQES - I/O SQ Entry Size (log2, 6 = 64 bytes)
# Bits 20-23: IOCQES - I/O CQ Entry Size (log2, 4 = 16 bytes)

val CC_EN: u32 = 1              # Bit 0
val CC_CSS_NVM: u32 = 0         # Bits 4-6: NVM command set
val CC_MPS_4K: u32 = 0          # Bits 7-10: 4KB pages
val CC_IOSQES_64: u32 = 393216  # 6 << 16 (log2(64) = 6)
val CC_IOCQES_16: u32 = 4194304 # 4 << 20 (log2(16) = 4)

# ============================================================================
# Controller Status (CSTS) Register Bits
# ============================================================================

val CSTS_RDY: u32 = 1           # Bit 0: Ready
val CSTS_CFS: u32 = 2           # Bit 1: Controller Fatal Status

# ============================================================================
# Queue Sizes
# ============================================================================

val ADMIN_QUEUE_DEPTH: u16 = 32
val IO_QUEUE_DEPTH: u16 = 64

# ============================================================================
# Submission Queue Entry Size / Completion Queue Entry Size (bytes)
# ============================================================================

val SQE_SIZE: u64 = 64
val CQE_SIZE: u64 = 16

# ============================================================================
# Identify CNS Values
# ============================================================================

val IDENTIFY_CNS_NAMESPACE: u32 = 0x00    # Identify Namespace
val IDENTIFY_CNS_CONTROLLER: u32 = 0x01   # Identify Controller

# ============================================================================
# Identify Namespace Data Offsets (bytes from start of 4KB response)
# ============================================================================

val IDNS_NSZE_OFFSET: u64 = 0      # Namespace Size (u64, in LBAs)
val IDNS_NCAP_OFFSET: u64 = 8      # Namespace Capacity (u64, in LBAs)
val IDNS_FLBAS_OFFSET: u64 = 26    # Formatted LBA Size (u8)
val IDNS_LBAF0_OFFSET: u64 = 128   # LBA Format 0 (u32): bits 16-23 = data size (log2)
