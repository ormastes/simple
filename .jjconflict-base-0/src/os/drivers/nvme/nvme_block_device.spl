# NVMe Block Device Trait Implementations
#
# MDSOC: entity dimension, drivers layer
#
# Implements BlockDevice (sync) and AsyncBlockDevice (async) for NvmeDriver.
#
# The sync implementation delegates to the existing read_sectors/write_sectors
# methods which use spin-polling wait_completion().
#
# The async implementation uses the notification-based read_sectors_notify /
# write_sectors_notify / flush_notify methods which sleep on IRQ notifications
# instead of spinning.

use os.drivers.nvme.block_device.{BlockDevice, AsyncBlockDevice}
use os.drivers.nvme.nvme_driver.{NvmeDriver}
use os.drivers.nvme.nvme_async.{NvmeAsyncCompletion}
use os.async.os_future.{OsFuture, ReadyFuture}
use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}

# ============================================================================
# Synchronous BlockDevice implementation
# ============================================================================

impl BlockDevice for NvmeDriver:
    fn read_sector(lba: u64, buf_phys: u64) -> Result<bool, text>:
        """Read a single sector via the synchronous spin-poll path."""
        var driver = self
        driver.read_sectors(lba, 1, buf_phys)

    fn write_sector(lba: u64, buf_phys: u64) -> Result<bool, text>:
        """Write a single sector via the synchronous spin-poll path."""
        var driver = self
        driver.write_sectors(lba, 1, buf_phys)

    fn sector_size() -> u32:
        """Sector size in bytes."""
        self.sector_size

    fn sector_count() -> u64:
        """Total sectors on namespace 1."""
        self.sector_count

# ============================================================================
# Async BlockDevice implementation
# ============================================================================

impl AsyncBlockDevice for NvmeDriver:
    fn read_sectors_async(lba: u64, count: u32, buf_phys: u64) -> OsFuture<Result<bool, text>>:
        """Submit async read and return a future for the result.

        Uses read_sectors_notify internally which waits on IRQ notification
        instead of spin-polling.
        """
        # Validate before submitting
        if not self.initialized:
            return ReadyFuture.new(Result.Err("NVMe: driver not initialized"))
        val count_u64 = count.to_u64()
        if lba + count_u64 > self.sector_count:
            return ReadyFuture.new(Result.Err("NVMe: read beyond namespace capacity"))

        # Submit the read command to the I/O queue
        var driver = self
        val result = driver.read_sectors_notify(lba, count, buf_phys)
        ReadyFuture.new(result)

    fn write_sectors_async(lba: u64, count: u32, buf_phys: u64) -> OsFuture<Result<bool, text>>:
        """Submit async write and return a future for the result.

        Uses write_sectors_notify internally which waits on IRQ notification
        instead of spin-polling.
        """
        if not self.initialized:
            return ReadyFuture.new(Result.Err("NVMe: driver not initialized"))
        val count_u64 = count.to_u64()
        if lba + count_u64 > self.sector_count:
            return ReadyFuture.new(Result.Err("NVMe: write beyond namespace capacity"))

        var driver = self
        val result = driver.write_sectors_notify(lba, count, buf_phys)
        ReadyFuture.new(result)

    fn flush_async() -> OsFuture<Result<bool, text>>:
        """Submit async flush and return a future for the result."""
        if not self.initialized:
            return ReadyFuture.new(Result.Err("NVMe: driver not initialized"))

        var driver = self
        val result = driver.flush_notify()
        ReadyFuture.new(result)

    fn sector_size() -> u32:
        """Sector size in bytes."""
        self.sector_size

    fn sector_count() -> u64:
        """Total sectors on namespace 1."""
        self.sector_count
