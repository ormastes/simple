use std.io_runtime

class StorageDmaResult:
    backend: text
    operation: text
    byte_count: i32
    uses_shared_dma: bool
    completed: bool
    timed_out: bool

    static fn success(backend: text, op: text, bytes: i32) -> StorageDmaResult:
        return StorageDmaResult(
            backend: backend,
            operation: op,
            byte_count: bytes,
            uses_shared_dma: true,
            completed: true,
            timed_out: false
        )

    static fn timeout(backend: text, op: text) -> StorageDmaResult:
        return StorageDmaResult(
            backend: backend,
            operation: op,
            byte_count: 0,
            uses_shared_dma: false,
            completed: false,
            timed_out: true
        )

    me is_ok() -> bool:
        return self.completed and self.timed_out == false

    me uses_unified_dma() -> bool:
        return self.uses_shared_dma

class DisplayReport:
    mode: text
    accelerated: bool
    gpu_cmd_complete: bool
    width: i32
    height: i32

    static fn framebuffer(w: i32, h: i32) -> DisplayReport:
        return DisplayReport(
            mode: "framebuffer",
            accelerated: false,
            gpu_cmd_complete: false,
            width: w,
            height: h
        )

    static fn bga(w: i32, h: i32) -> DisplayReport:
        return DisplayReport(
            mode: "bga",
            accelerated: false,
            gpu_cmd_complete: false,
            width: w,
            height: h
        )

    static fn virtio_gpu(w: i32, h: i32, cmd_complete: bool) -> DisplayReport:
        return DisplayReport(
            mode: "virtio-gpu",
            accelerated: cmd_complete,
            gpu_cmd_complete: cmd_complete,
            width: w,
            height: h
        )

    me is_accelerated() -> bool:
        return self.accelerated

    me false_acceleration() -> bool:
        return self.accelerated and self.gpu_cmd_complete == false

class InputDevice:
    device_type: text
    bus: text
    is_functional: bool
    is_blocking: bool

    static fn ps2_keyboard() -> InputDevice:
        return InputDevice(
            device_type: "keyboard",
            bus: "ps2",
            is_functional: true,
            is_blocking: true
        )

    static fn ps2_mouse() -> InputDevice:
        return InputDevice(
            device_type: "mouse",
            bus: "ps2",
            is_functional: true,
            is_blocking: true
        )

    static fn xhci_diagnostic(dev_type: text) -> InputDevice:
        return InputDevice(
            device_type: dev_type,
            bus: "xhci",
            is_functional: false,
            is_blocking: false
        )

    me is_accepted() -> bool:
        return self.is_functional and self.bus == "ps2"

class FalseClaimCheck:
    claim_type: text
    detected: bool
    detail: text

    static fn resident_fallback(detected: bool) -> FalseClaimCheck:
        return FalseClaimCheck(
            claim_type: "resident_fallback",
            detected: detected,
            detail: ""
        )

    static fn hidden_dma(detected: bool) -> FalseClaimCheck:
        return FalseClaimCheck(
            claim_type: "hidden_dma",
            detected: detected,
            detail: ""
        )

    static fn false_accel(detected: bool) -> FalseClaimCheck:
        return FalseClaimCheck(
            claim_type: "false_accel",
            detected: detected,
            detail: ""
        )

    me fails_acceptance() -> bool:
        return self.detected
