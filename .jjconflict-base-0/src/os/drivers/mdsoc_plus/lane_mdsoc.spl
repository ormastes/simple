# MDSOC lane platform contract helpers — layer visibility audit and release-gate mapping.

fn mdsoc_lane_required_layers() -> text:
    "os-kernel,driver-supervisor,pcimgr,ipc"

fn mdsoc_lane_visibility_allowed(from_layer: text, to_layer: text) -> bool:
    if from_layer == "driver-supervisor" and to_layer == "os-kernel":
        return true
    if from_layer == "pcimgr" and to_layer == "driver-supervisor":
        return true
    if from_layer == "ipc" and to_layer == "driver-supervisor":
        return true
    false

fn mdsoc_lane_visibility_forbidden(from_layer: text, to_layer: text) -> bool:
    if from_layer == "os-kernel" and to_layer == "driver-supervisor":
        return true
    if from_layer == "pcimgr" and to_layer == "ipc":
        return true
    false

fn mdsoc_lane_release_gate_label(owner: bool, contract: bool, tests: bool, docs: bool, reviewer: bool) -> text:
    if owner and contract and tests and docs and reviewer:
        return "mdsoc-lane:ready"
    if not owner:
        return "mdsoc-lane:missing-owner"
    if not contract:
        return "mdsoc-lane:missing-contract"
    if not tests:
        return "mdsoc-lane:missing-tests"
    if not docs:
        return "mdsoc-lane:missing-docs"
    "mdsoc-lane:missing-reviewer"

fn mdsoc_lane_plan_complete(gpu_ready: bool, audio_ready: bool, input_ready: bool, exokernel_ready: bool, mdsoc_ready: bool) -> bool:
    gpu_ready and audio_ready and input_ready and exokernel_ready and mdsoc_ready

fn mdsoc_lane_plan_blocker(gpu_ready: bool, audio_ready: bool, input_ready: bool, exokernel_ready: bool, mdsoc_ready: bool) -> text:
    if not gpu_ready:
        return "blocking-lane:gpu"
    if not audio_ready:
        return "blocking-lane:audio"
    if not input_ready:
        return "blocking-lane:input"
    if not exokernel_ready:
        return "blocking-lane:exokernel"
    if not mdsoc_ready:
        return "blocking-lane:mdsoc"
    "all-lanes:ready"
