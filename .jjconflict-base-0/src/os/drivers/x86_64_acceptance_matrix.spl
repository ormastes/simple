# x86_64 Desktop Driver Acceptance Matrix + Boot Capability Summary.
#
# Tracks per-device-class acceptance status, boot capability snapshot,
# and false-claim detection for the SimpleOS x86_64 desktop QEMU lane.

# ---------------------------------------------------------------------------
# DeviceClassEntry — one device class in the matrix
# ---------------------------------------------------------------------------

struct DeviceClassEntry:
    device_class: text
    driver_name: text
    driver_status: text
    is_mandatory: bool
    is_accelerated: bool
    fallback_reason: text

static fn DeviceClassEntry_pass(cls: text, driver: text) -> DeviceClassEntry:
    DeviceClassEntry(device_class: cls, driver_name: driver, driver_status: "pass",
        is_mandatory: true, is_accelerated: false, fallback_reason: "")

static fn DeviceClassEntry_fail(cls: text, driver: text, reason: text) -> DeviceClassEntry:
    DeviceClassEntry(device_class: cls, driver_name: driver, driver_status: "fail",
        is_mandatory: true, is_accelerated: false, fallback_reason: reason)

static fn DeviceClassEntry_fallback(cls: text, driver: text, reason: text) -> DeviceClassEntry:
    DeviceClassEntry(device_class: cls, driver_name: driver, driver_status: "fallback",
        is_mandatory: false, is_accelerated: false, fallback_reason: reason)

fn DeviceClassEntry_passes_acceptance(self: DeviceClassEntry) -> bool:
    self.driver_status == "pass"

fn DeviceClassEntry_summary(self: DeviceClassEntry) -> text:
    "[" + self.driver_status + "] " + self.device_class + " / " + self.driver_name +
    " | mandatory=" + self.is_mandatory.to_text() +
    " accel=" + self.is_accelerated.to_text() +
    " fallback=" + self.fallback_reason

# ---------------------------------------------------------------------------
# AcceptanceMatrix — flat matrix (max 8 device classes)
# ---------------------------------------------------------------------------

struct AcceptanceMatrix:
    count: i64
    d0_class: text  d1_class: text  d2_class: text  d3_class: text
    d4_class: text  d5_class: text  d6_class: text  d7_class: text
    d0_driver: text d1_driver: text d2_driver: text d3_driver: text
    d4_driver: text d5_driver: text d6_driver: text d7_driver: text
    d0_status: text d1_status: text d2_status: text d3_status: text
    d4_status: text d5_status: text d6_status: text d7_status: text
    d0_mandatory: bool d1_mandatory: bool d2_mandatory: bool d3_mandatory: bool
    d4_mandatory: bool d5_mandatory: bool d6_mandatory: bool d7_mandatory: bool
    d0_accelerated: bool d1_accelerated: bool d2_accelerated: bool d3_accelerated: bool
    d4_accelerated: bool d5_accelerated: bool d6_accelerated: bool d7_accelerated: bool
    d0_fallback: text d1_fallback: text d2_fallback: text d3_fallback: text
    d4_fallback: text d5_fallback: text d6_fallback: text d7_fallback: text

static fn AcceptanceMatrix_create() -> AcceptanceMatrix:
    AcceptanceMatrix(
        count: 0,
        d0_class: "", d1_class: "", d2_class: "", d3_class: "",
        d4_class: "", d5_class: "", d6_class: "", d7_class: "",
        d0_driver: "", d1_driver: "", d2_driver: "", d3_driver: "",
        d4_driver: "", d5_driver: "", d6_driver: "", d7_driver: "",
        d0_status: "", d1_status: "", d2_status: "", d3_status: "",
        d4_status: "", d5_status: "", d6_status: "", d7_status: "",
        d0_mandatory: false, d1_mandatory: false, d2_mandatory: false, d3_mandatory: false,
        d4_mandatory: false, d5_mandatory: false, d6_mandatory: false, d7_mandatory: false,
        d0_accelerated: false, d1_accelerated: false, d2_accelerated: false, d3_accelerated: false,
        d4_accelerated: false, d5_accelerated: false, d6_accelerated: false, d7_accelerated: false,
        d0_fallback: "", d1_fallback: "", d2_fallback: "", d3_fallback: "",
        d4_fallback: "", d5_fallback: "", d6_fallback: "", d7_fallback: ""
    )

static fn AcceptanceMatrix_x86_64_qemu_desktop() -> AcceptanceMatrix:
    AcceptanceMatrix(
        count: 7,
        d0_class: "platform",  d1_class: "storage",   d2_class: "display",
        d3_class: "input",     d4_class: "network",   d5_class: "dma",
        d6_class: "interrupt", d7_class: "",
        d0_driver: "UEFI/OVMF",                  d1_driver: "NVMe/VirtIO-BLK",
        d2_driver: "framebuffer/BGA/VirtIO-GPU", d3_driver: "PS/2",
        d4_driver: "virtio-net",                 d5_driver: "PCI-DMA",
        d6_driver: "APIC/polling",               d7_driver: "",
        d0_status: "pass", d1_status: "pass", d2_status: "pass", d3_status: "pass",
        d4_status: "pass", d5_status: "pass", d6_status: "pass", d7_status: "",
        d0_mandatory: true,  d1_mandatory: true,  d2_mandatory: true,  d3_mandatory: true,
        d4_mandatory: true,  d5_mandatory: true,  d6_mandatory: true,  d7_mandatory: false,
        d0_accelerated: false, d1_accelerated: false, d2_accelerated: false, d3_accelerated: false,
        d4_accelerated: false, d5_accelerated: false, d6_accelerated: false, d7_accelerated: false,
        d0_fallback: "", d1_fallback: "", d2_fallback: "", d3_fallback: "",
        d4_fallback: "", d5_fallback: "", d6_fallback: "", d7_fallback: ""
    )

fn AcceptanceMatrix_add(self: AcceptanceMatrix, cls: text, driver: text, status: text, mandatory: bool, accel: bool, fallback: text) -> text:
    val idx = self.count
    if idx >= 8: return "ERROR: matrix full (max 8)"
    self.count = self.count + 1
    if idx == 0: self.d0_class = cls  self.d0_driver = driver  self.d0_status = status  self.d0_mandatory = mandatory  self.d0_accelerated = accel  self.d0_fallback = fallback
    if idx == 1: self.d1_class = cls  self.d1_driver = driver  self.d1_status = status  self.d1_mandatory = mandatory  self.d1_accelerated = accel  self.d1_fallback = fallback
    if idx == 2: self.d2_class = cls  self.d2_driver = driver  self.d2_status = status  self.d2_mandatory = mandatory  self.d2_accelerated = accel  self.d2_fallback = fallback
    if idx == 3: self.d3_class = cls  self.d3_driver = driver  self.d3_status = status  self.d3_mandatory = mandatory  self.d3_accelerated = accel  self.d3_fallback = fallback
    if idx == 4: self.d4_class = cls  self.d4_driver = driver  self.d4_status = status  self.d4_mandatory = mandatory  self.d4_accelerated = accel  self.d4_fallback = fallback
    if idx == 5: self.d5_class = cls  self.d5_driver = driver  self.d5_status = status  self.d5_mandatory = mandatory  self.d5_accelerated = accel  self.d5_fallback = fallback
    if idx == 6: self.d6_class = cls  self.d6_driver = driver  self.d6_status = status  self.d6_mandatory = mandatory  self.d6_accelerated = accel  self.d6_fallback = fallback
    if idx == 7: self.d7_class = cls  self.d7_driver = driver  self.d7_status = status  self.d7_mandatory = mandatory  self.d7_accelerated = accel  self.d7_fallback = fallback
    "OK"

fn AcceptanceMatrix_pass_count(self: AcceptanceMatrix) -> i64:
    var n = 0
    if self.d0_status == "pass": n = n + 1
    if self.d1_status == "pass": n = n + 1
    if self.d2_status == "pass": n = n + 1
    if self.d3_status == "pass": n = n + 1
    if self.d4_status == "pass": n = n + 1
    if self.d5_status == "pass": n = n + 1
    if self.d6_status == "pass": n = n + 1
    if self.d7_status == "pass": n = n + 1
    n

fn AcceptanceMatrix_fail_count(self: AcceptanceMatrix) -> i64:
    var n = 0
    if self.d0_status == "fail": n = n + 1
    if self.d1_status == "fail": n = n + 1
    if self.d2_status == "fail": n = n + 1
    if self.d3_status == "fail": n = n + 1
    if self.d4_status == "fail": n = n + 1
    if self.d5_status == "fail": n = n + 1
    if self.d6_status == "fail": n = n + 1
    if self.d7_status == "fail": n = n + 1
    n

fn AcceptanceMatrix_all_mandatory_pass(self: AcceptanceMatrix) -> bool:
    var ok = true
    if (self.d0_mandatory) and (self.d0_status == "pass" == false): ok = false
    if (self.d1_mandatory) and (self.d1_status == "pass" == false): ok = false
    if (self.d2_mandatory) and (self.d2_status == "pass" == false): ok = false
    if (self.d3_mandatory) and (self.d3_status == "pass" == false): ok = false
    if (self.d4_mandatory) and (self.d4_status == "pass" == false): ok = false
    if (self.d5_mandatory) and (self.d5_status == "pass" == false): ok = false
    if (self.d6_mandatory) and (self.d6_status == "pass" == false): ok = false
    if (self.d7_mandatory) and (self.d7_status == "pass" == false): ok = false
    ok

fn AcceptanceMatrix_fmt_row(cls: text, driver: text, status: text, mandatory: bool, accel: bool, fallback: text) -> text:
    if cls == "": return ""
    var s = "  " + cls + " | " + driver + " | " + status
    if mandatory: s = s + " [mandatory]"
    if accel: s = s + " [accel]"
    if fallback != "": s = s + " fallback=" + fallback
    s + "\n"

fn AcceptanceMatrix_report(self: AcceptanceMatrix) -> text:
    "ACCEPTANCE MATRIX (count=" + self.count.to_text() +
    " pass=" + AcceptanceMatrix_pass_count(self).to_text() +
    " fail=" + AcceptanceMatrix_fail_count(self).to_text() + ")\n" +
    AcceptanceMatrix_fmt_row(self.d0_class, self.d0_driver, self.d0_status, self.d0_mandatory, self.d0_accelerated, self.d0_fallback) +
    AcceptanceMatrix_fmt_row(self.d1_class, self.d1_driver, self.d1_status, self.d1_mandatory, self.d1_accelerated, self.d1_fallback) +
    AcceptanceMatrix_fmt_row(self.d2_class, self.d2_driver, self.d2_status, self.d2_mandatory, self.d2_accelerated, self.d2_fallback) +
    AcceptanceMatrix_fmt_row(self.d3_class, self.d3_driver, self.d3_status, self.d3_mandatory, self.d3_accelerated, self.d3_fallback) +
    AcceptanceMatrix_fmt_row(self.d4_class, self.d4_driver, self.d4_status, self.d4_mandatory, self.d4_accelerated, self.d4_fallback) +
    AcceptanceMatrix_fmt_row(self.d5_class, self.d5_driver, self.d5_status, self.d5_mandatory, self.d5_accelerated, self.d5_fallback) +
    AcceptanceMatrix_fmt_row(self.d6_class, self.d6_driver, self.d6_status, self.d6_mandatory, self.d6_accelerated, self.d6_fallback) +
    AcceptanceMatrix_fmt_row(self.d7_class, self.d7_driver, self.d7_status, self.d7_mandatory, self.d7_accelerated, self.d7_fallback)

# ---------------------------------------------------------------------------
# BootCapabilitySummary — single serial-emitted record
# ---------------------------------------------------------------------------

struct BootCapabilitySummary:
    platform: text
    storage: text
    display: text
    input: text
    network: text
    dma_mode: text
    interrupt_mode: text
    boot_timestamp_ms: i64
    boot_success: bool

static fn BootCapabilitySummary_create() -> BootCapabilitySummary:
    BootCapabilitySummary(platform: "", storage: "", display: "", input: "",
        network: "", dma_mode: "", interrupt_mode: "",
        boot_timestamp_ms: 0, boot_success: false)

fn BootCapabilitySummary_set_platform(self: BootCapabilitySummary, val: text) -> text:
    self.platform = val
    "OK"

fn BootCapabilitySummary_set_storage(self: BootCapabilitySummary, val: text) -> text:
    self.storage = val
    "OK"

fn BootCapabilitySummary_set_display(self: BootCapabilitySummary, val: text) -> text:
    self.display = val
    "OK"

fn BootCapabilitySummary_set_input(self: BootCapabilitySummary, val: text) -> text:
    self.input = val
    "OK"

fn BootCapabilitySummary_set_network(self: BootCapabilitySummary, val: text) -> text:
    self.network = val
    "OK"

fn BootCapabilitySummary_set_dma(self: BootCapabilitySummary, val: text) -> text:
    self.dma_mode = val
    "OK"

fn BootCapabilitySummary_set_interrupt(self: BootCapabilitySummary, val: text) -> text:
    self.interrupt_mode = val
    "OK"

fn BootCapabilitySummary_emit_serial(self: BootCapabilitySummary) -> text:
    "CAPABILITY: platform=" + self.platform + " storage=" + self.storage +
    " display=" + self.display + " input=" + self.input +
    " network=" + self.network + " dma=" + self.dma_mode +
    " interrupt=" + self.interrupt_mode +
    " ts=" + self.boot_timestamp_ms.to_text() +
    " ok=" + self.boot_success.to_text()

fn BootCapabilitySummary_is_complete(self: BootCapabilitySummary) -> bool:
    if self.platform == "": return false
    if self.storage == "": return false
    if self.display == "": return false
    if self.input == "": return false
    if self.network == "": return false
    if self.dma_mode == "": return false
    if self.interrupt_mode == "": return false
    true

# ---------------------------------------------------------------------------
# FalseClaimDetector — detects false acceptance claims
# ---------------------------------------------------------------------------

struct FalseClaimDetector:
    resident_launch_detected: bool
    heap_copy_dma_detected: bool
    false_accel_detected: bool
    violation_count: i64
    last_violation: text

static fn FalseClaimDetector_create() -> FalseClaimDetector:
    FalseClaimDetector(resident_launch_detected: false, heap_copy_dma_detected: false,
        false_accel_detected: false, violation_count: 0, last_violation: "")

fn FalseClaimDetector_record(self: FalseClaimDetector, msg: text) -> text:
    self.violation_count = self.violation_count + 1
    self.last_violation = msg
    msg

fn FalseClaimDetector_check_resident_launch(self: FalseClaimDetector, is_resident: bool) -> text:
    if is_resident == false: return ""
    self.resident_launch_detected = true
    FalseClaimDetector_record(self, "REJECT: resident launch fallback")

fn FalseClaimDetector_check_dma_heap_copy(self: FalseClaimDetector, is_heap_copy: bool) -> text:
    if is_heap_copy == false: return ""
    self.heap_copy_dma_detected = true
    FalseClaimDetector_record(self, "REJECT: heap-copy DMA fallback")

fn FalseClaimDetector_check_acceleration(self: FalseClaimDetector, claimed: bool, verified: bool) -> text:
    if claimed == verified: return ""
    self.false_accel_detected = true
    FalseClaimDetector_record(self, "REJECT: false acceleration claim")

fn FalseClaimDetector_has_violations(self: FalseClaimDetector) -> bool:
    self.violation_count > 0

fn FalseClaimDetector_report(self: FalseClaimDetector) -> text:
    if self.violation_count == 0: return "FALSE-CLAIM-DETECTOR: clean (0 violations)"
    "FALSE-CLAIM-DETECTOR: violations=" + self.violation_count.to_text() + " last=" + self.last_violation
