# USB HID Input Backend — bridges USB HID boot-protocol reports into the
# compositor input multiplexer.
#
# MDSOC: feature dimension, drivers layer
#
# Implements the same os.compositor.input_backend.InputBackend trait the
# PS/2 backend implements, so a USB keyboard/mouse drives the compositor
# (window focus, shortcuts, cursor) through the exact same
# Compositor._handle_input_backend path — no compositor changes per input
# source.
#
# Report ingestion: the transport (xHCI interrupt-endpoint polling, or a
# test/gate injector) pushes raw boot-protocol reports via
# push_keyboard_report / push_mouse_report; the compositor drains translated
# events via poll_key / poll_mouse. Malformed reports are dropped
# (fail-closed), never partially applied.

use os.drivers.input.ps2_keyboard.{Key, KeyEvent}
use os.drivers.input.ps2_mouse.{MouseEvent}
use os.compositor.input_backend.{InputBackend}

# HID keyboard boot-protocol modifier bits (byte 0 of the 8-byte report)
val HID_MOD_LEFT_CTRL: i64   = 0x01
val HID_MOD_LEFT_SHIFT: i64  = 0x02
val HID_MOD_LEFT_ALT: i64    = 0x04
val HID_MOD_RIGHT_CTRL: i64  = 0x10
val HID_MOD_RIGHT_SHIFT: i64 = 0x20
val HID_MOD_RIGHT_ALT: i64   = 0x40

fn hid_usage_to_key(usage: i64) -> Key:
    """Map a HID keyboard usage ID (page 0x07) to the shared Key enum.

    Boot-protocol usage IDs: 0x04-0x1D = A-Z, 0x1E-0x27 = 1-0, then
    Enter/Escape/Backspace/Tab/Space, punctuation, F-keys, arrows.
    Unmapped usages return Key.Unknown.
    """
    if usage >= 0x04 and usage <= 0x1D:
        # A..Z in enum order
        return match usage:
            case 0x04: Key.A
            case 0x05: Key.B
            case 0x06: Key.C
            case 0x07: Key.D
            case 0x08: Key.E
            case 0x09: Key.F
            case 0x0A: Key.G
            case 0x0B: Key.H
            case 0x0C: Key.I
            case 0x0D: Key.J
            case 0x0E: Key.K
            case 0x0F: Key.L
            case 0x10: Key.M
            case 0x11: Key.N
            case 0x12: Key.O
            case 0x13: Key.P
            case 0x14: Key.Q
            case 0x15: Key.R
            case 0x16: Key.S
            case 0x17: Key.T
            case 0x18: Key.U
            case 0x19: Key.V
            case 0x1A: Key.W
            case 0x1B: Key.X
            case 0x1C: Key.Y
            case _: Key.Z
    match usage:
        case 0x1E: Key.Num1
        case 0x1F: Key.Num2
        case 0x20: Key.Num3
        case 0x21: Key.Num4
        case 0x22: Key.Num5
        case 0x23: Key.Num6
        case 0x24: Key.Num7
        case 0x25: Key.Num8
        case 0x26: Key.Num9
        case 0x27: Key.Num0
        case 0x28: Key.Enter
        case 0x29: Key.Escape
        case 0x2A: Key.Backspace
        case 0x2B: Key.Tab
        case 0x2C: Key.Space
        case 0x2D: Key.Minus
        case 0x2E: Key.Equals
        case 0x2F: Key.LeftBracket
        case 0x30: Key.RightBracket
        case 0x31: Key.Backslash
        case 0x33: Key.Semicolon
        case 0x34: Key.Quote
        case 0x35: Key.Backtick
        case 0x36: Key.Comma
        case 0x37: Key.Period
        case 0x38: Key.Slash
        case 0x39: Key.CapsLock
        case 0x3A: Key.F1
        case 0x3B: Key.F2
        case 0x3C: Key.F3
        case 0x3D: Key.F4
        case 0x3E: Key.F5
        case 0x3F: Key.F6
        case 0x40: Key.F7
        case 0x41: Key.F8
        case 0x42: Key.F9
        case 0x43: Key.F10
        case 0x44: Key.F11
        case 0x45: Key.F12
        case 0x4F: Key.Right
        case 0x50: Key.Left
        case 0x51: Key.Down
        case 0x52: Key.Up
        case _: Key.Unknown

fn _key_to_char_base(key: Key) -> text?:
    """Lowercase/unshifted character for a Key, nil for non-printable."""
    match key:
        case Key.A: "a"
        case Key.B: "b"
        case Key.C: "c"
        case Key.D: "d"
        case Key.E: "e"
        case Key.F: "f"
        case Key.G: "g"
        case Key.H: "h"
        case Key.I: "i"
        case Key.J: "j"
        case Key.K: "k"
        case Key.L: "l"
        case Key.M: "m"
        case Key.N: "n"
        case Key.O: "o"
        case Key.P: "p"
        case Key.Q: "q"
        case Key.R: "r"
        case Key.S: "s"
        case Key.T: "t"
        case Key.U: "u"
        case Key.V: "v"
        case Key.W: "w"
        case Key.X: "x"
        case Key.Y: "y"
        case Key.Z: "z"
        case Key.Num1: "1"
        case Key.Num2: "2"
        case Key.Num3: "3"
        case Key.Num4: "4"
        case Key.Num5: "5"
        case Key.Num6: "6"
        case Key.Num7: "7"
        case Key.Num8: "8"
        case Key.Num9: "9"
        case Key.Num0: "0"
        case Key.Space: " "
        case _: nil

fn _key_to_char_shifted(key: Key) -> text?:
    """Uppercase/shifted character for a Key, nil for non-printable."""
    match key:
        case Key.A: "A"
        case Key.B: "B"
        case Key.C: "C"
        case Key.D: "D"
        case Key.E: "E"
        case Key.F: "F"
        case Key.G: "G"
        case Key.H: "H"
        case Key.I: "I"
        case Key.J: "J"
        case Key.K: "K"
        case Key.L: "L"
        case Key.M: "M"
        case Key.N: "N"
        case Key.O: "O"
        case Key.P: "P"
        case Key.Q: "Q"
        case Key.R: "R"
        case Key.S: "S"
        case Key.T: "T"
        case Key.U: "U"
        case Key.V: "V"
        case Key.W: "W"
        case Key.X: "X"
        case Key.Y: "Y"
        case Key.Z: "Z"
        case Key.Space: " "
        case _: nil

# ---------------------------------------------------------------------------
# Module-level backing store (keyed by inst_id)
#
# Works around interpreter value-semantics: the compositor stores a COPY of
# the backend, so struct-field mutation from push_*_report would be invisible
# to poll_* through the compositor's copy. Module-level arrays survive across
# call boundaries and copies (same pattern as std.fs_driver.mem_block_device).
# Pending events are stored as flat integers and reconstructed at poll time.
# ---------------------------------------------------------------------------

var _hid_next_id: i64        = 1
var _hid_ids: [i64]          = []
var _hid_prev_keys: [[i64]]  = []   # usage IDs held in the previous report
var _hid_modifiers: [i64]    = []   # current modifier byte
var _hid_caps: [i64]         = []   # caps lock state (0/1)
var _hid_pend_key: [[i64]]   = []   # pending key events, pairs: usage, press(1)/release(0)
var _hid_mouse_x: [i64]      = []
var _hid_mouse_y: [i64]      = []
var _hid_prev_buttons: [i64] = []
var _hid_pend_mouse: [[i64]] = []   # pending mouse events, groups of 6: x, y, dx, dy, buttons, edges

fn _hid_alloc_id() -> i64:
    val id = _hid_next_id
    _hid_next_id = _hid_next_id + 1
    id

fn _hid_find(inst_id: i64) -> i64:
    var i: i64 = 0
    while i < _hid_ids.len():
        if _hid_ids[i] == inst_id:
            return i
        i = i + 1
    -1

fn _hid_register(inst_id: i64, screen_width: i64, screen_height: i64):
    _hid_ids.push(inst_id)
    _hid_prev_keys.push([])
    _hid_modifiers.push(0)
    _hid_caps.push(0)
    _hid_pend_key.push([])
    _hid_mouse_x.push(screen_width / 2)
    _hid_mouse_y.push(screen_height / 2)
    _hid_prev_buttons.push(0)
    _hid_pend_mouse.push([])

class UsbHidInputBackend:
    """InputBackend over USB HID boot-protocol reports.

    Keyboard: 8-byte boot reports (modifiers, reserved, keycode[6]).
    Press/Release edges are derived by diffing consecutive reports.
    Mouse: 3-byte boot reports (buttons, dx, dy signed) integrated into an
    absolute cursor position clamped to the screen.
    """
    inst_id: i64
    screen_width: i64
    screen_height: i64

impl UsbHidInputBackend:
    static fn create(screen_width: i64, screen_height: i64) -> UsbHidInputBackend:
        val id = _hid_alloc_id()
        _hid_register(id, screen_width, screen_height)
        UsbHidInputBackend(
            inst_id: id,
            screen_width: screen_width,
            screen_height: screen_height
        )

    fn push_keyboard_report(report: [u8]) -> bool:
        """Ingest one 8-byte HID keyboard boot report.

        Returns false (and changes nothing) for malformed reports —
        fail-closed, no partial modifier/key state is applied.
        """
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return false
        if report.len() < 8:
            return false

        # Collect currently-held usage IDs (bytes 2..7, 0 = no key)
        var now_keys: [i64] = []
        var i = 2
        while i < 8:
            val usage = report[i].to_i64()
            # 0x01-0x03 are error rollover codes: drop the report entirely
            if usage >= 0x01 and usage <= 0x03:
                return false
            if usage != 0:
                now_keys.push(usage)
            i = i + 1

        _hid_modifiers[idx] = report[0].to_i64()
        val prev_keys = _hid_prev_keys[idx]
        var pending = _hid_pend_key[idx]

        # Press edges: in now, not in prev
        for usage in now_keys:
            var was_held = false
            for prev in prev_keys:
                if prev == usage:
                    was_held = true
            if not was_held:
                if usage == 0x39:
                    _hid_caps[idx] = 1 - _hid_caps[idx]
                pending.push(usage)
                pending.push(1)

        # Release edges: in prev, not in now
        for prev in prev_keys:
            var still_held = false
            for usage in now_keys:
                if usage == prev:
                    still_held = true
            if not still_held:
                pending.push(prev)
                pending.push(0)

        _hid_pend_key[idx] = pending
        _hid_prev_keys[idx] = now_keys
        true

    fn push_mouse_report(report: [u8]) -> bool:
        """Ingest one HID mouse boot report (buttons, dx, dy signed bytes).

        Returns false (and changes nothing) for malformed reports.
        """
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return false
        if report.len() < 3:
            return false
        val buttons = report[0].to_i64()

        # Sign-extend the 8-bit deltas
        var dx = report[1].to_i64()
        if dx > 127:
            dx = dx - 256
        var dy = report[2].to_i64()
        if dy > 127:
            dy = dy - 256

        var nx = _hid_mouse_x[idx] + dx
        var ny = _hid_mouse_y[idx] + dy
        if nx < 0:
            nx = 0
        if nx >= self.screen_width:
            nx = self.screen_width - 1
        if ny < 0:
            ny = 0
        if ny >= self.screen_height:
            ny = self.screen_height - 1
        _hid_mouse_x[idx] = nx
        _hid_mouse_y[idx] = ny

        val prev = _hid_prev_buttons[idx]
        val prev_left = (prev & 0x01) != 0
        val prev_right = (prev & 0x02) != 0
        val left = (buttons & 0x01) != 0
        val right = (buttons & 0x02) != 0
        var edges: i64 = 0
        if left and not prev_left:
            edges = edges | 0x1     # left_just_pressed
        if right and not prev_right:
            edges = edges | 0x2     # right_just_pressed
        if (not left) and prev_left:
            edges = edges | 0x4     # left_just_released

        var pending = _hid_pend_mouse[idx]
        pending.push(nx)
        pending.push(ny)
        pending.push(dx)
        pending.push(dy)
        pending.push(buttons)
        pending.push(edges)
        _hid_pend_mouse[idx] = pending
        _hid_prev_buttons[idx] = buttons
        true

impl InputBackend for UsbHidInputBackend:
    me poll_key() -> KeyEvent?:
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return nil
        var pending = _hid_pend_key[idx]
        if pending.len() < 2:
            return nil
        val usage = pending[0]
        val is_press = pending[1]
        _hid_pend_key[idx] = pending.slice(2, pending.len())
        val key = hid_usage_to_key(usage)
        if is_press == 1:
            return KeyEvent.Press(key: key)
        KeyEvent.Release(key: key)

    me poll_mouse() -> MouseEvent?:
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return nil
        var pending = _hid_pend_mouse[idx]
        if pending.len() < 6:
            return nil
        val x = pending[0]
        val y = pending[1]
        val dx = pending[2]
        val dy = pending[3]
        val buttons = pending[4]
        val edges = pending[5]
        _hid_pend_mouse[idx] = pending.slice(6, pending.len())
        MouseEvent(
            x: x,
            y: y,
            dx: dx,
            dy: dy,
            left_pressed: (buttons & 0x01) != 0,
            right_pressed: (buttons & 0x02) != 0,
            middle_pressed: (buttons & 0x04) != 0,
            left_just_pressed: (edges & 0x1) != 0,
            right_just_pressed: (edges & 0x2) != 0,
            left_just_released: (edges & 0x4) != 0
        )

    fn alt_held() -> bool:
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return false
        (_hid_modifiers[idx] & (HID_MOD_LEFT_ALT | HID_MOD_RIGHT_ALT)) != 0

    fn shift_held() -> bool:
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return false
        (_hid_modifiers[idx] & (HID_MOD_LEFT_SHIFT | HID_MOD_RIGHT_SHIFT)) != 0

    fn ctrl_held() -> bool:
        val idx = _hid_find(self.inst_id)
        if idx < 0:
            return false
        (_hid_modifiers[idx] & (HID_MOD_LEFT_CTRL | HID_MOD_RIGHT_CTRL)) != 0

    fn key_to_char(key: Key) -> text?:
        val idx = _hid_find(self.inst_id)
        var caps = false
        if idx >= 0:
            caps = _hid_caps[idx] == 1
        if self.shift_held() or caps:
            return _key_to_char_shifted(key)
        _key_to_char_base(key)
