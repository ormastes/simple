# VirtIO-GPU Standalone Test Entry Point
#
# MDSOC: feature dimension, drivers layer
# Boots into QEMU with virtio-gpu in legacy PCI mode, scans PCI for the
# GPU device, initialises the VirtIO-GPU 2D driver, draws a red-blue
# gradient with a centred white rectangle, and flushes to the display.
#
# Usage (via QEMU scenario x64-gpu-2d):
#   bin/simple os run --scenario=x64-gpu-2d --entry=src/os/drivers/gpu/virtio_gpu_entry.spl

use os.drivers.pci.pci.{PciBus, PciDevice, pci_read_bar}
use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use os.drivers.virtio.virtio_gpu_types.{VIRTIO_GPU_FORMAT_B8G8R8A8_UNORM}
use os.drivers.gpu.gpu_accel.{set_gpu_accel_supported_from_driver}
use os.kernel.types.device_mem_types.{DeviceGrant}
use os.kernel.boot.mmio.{mmio_write32}
use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}


# ============================================================================
# Helper — build a DeviceGrant from a discovered PciDevice
# ============================================================================

fn grant_from_pci(dev: PciDevice) -> DeviceGrant:
    """Construct a DeviceGrant for VirtIO PCI transport.
    Uses BAR0 if assigned, falls back to BAR1 (modern VirtIO MMIO).
    """
    var bar0_phys: u64 = dev.bar0.to_u64()
    # If BAR0 is unassigned (0), try BAR1 (modern VirtIO on q35)
    if bar0_phys == 0:
        bar0_phys = (dev.bar1 & 0xFFFFFFF0).to_u64()
    log_info("[gpu] " + "[grant] bar0={dev.bar0} bar1={dev.bar1} using=0x{bar0_phys}")

    # BAR size: write all-ones, read back, mask, complement + 1
    # For simplicity, assume 4KB for legacy PCI I/O BAR
    val bar0_size: u64 = 4096

    DeviceGrant(
        pci_vendor: dev.vendor_id,
        pci_device: dev.device_id,
        pci_bus: dev.bus,
        pci_dev: dev.device,
        pci_func: dev.func,
        pci_class: dev.class_code,
        pci_subclass: dev.subclass,
        bar0_phys: bar0_phys,
        bar0_size: bar0_size,
        bar0_cap: 0,
        irq_vector: dev.irq_line.to_u32(),
        irq_notification_id: 0,
        irq_notification_bit: 0,
        irq_cap: 0,
        dma_device_addr: 0,
        dma_host_addr: 0,
        dma_size: 0,
        dma_cap: 0,
        iommu_domain_id: 0,
        iommu_cap: 0
    )

# ============================================================================
# Test Pattern Drawing
# ============================================================================

fn draw_test_pattern(gpu: VirtioGpuDriver):
    """Draw a red-blue gradient with a centred white rectangle.

    Gradient: top-left is red (0xFFFF0000), bottom-right is blue (0xFF0000FF).
    White rectangle: 200x100, centred on the framebuffer.
    """
    val w = gpu.get_width()
    val h = gpu.get_height()
    val fb = gpu.get_fb_virt()

    # Pass 1: red-blue gradient
    var py: u32 = 0
    while py < h:
        var px: u32 = 0
        while px < w:
            # Red component scales with x, blue scales with y
            val r = ((px.to_u64() * 255) / w.to_u64()).to_u32()
            val b = ((py.to_u64() * 255) / h.to_u64()).to_u32()
            # BGRA pixel: B in low byte, then G, R, A
            val pixel = (0xFF << 24) | (r << 16) | b
            val offset = ((py.to_u64()) * (w.to_u64()) + (px.to_u64())) * 4
            mmio_write32(fb + offset, pixel)
            px = px + 1
        py = py + 1

    # Pass 2: white rectangle at centre (200x100)
    val rect_w: u32 = 200
    val rect_h: u32 = 100
    val rx = (w - rect_w) / 2
    val ry = (h - rect_h) / 2
    val white: u32 = 0xFFFFFFFF

    var ry_i: u32 = ry
    while ry_i < ry + rect_h and ry_i < h:
        var rx_i: u32 = rx
        while rx_i < rx + rect_w and rx_i < w:
            val offset = ((ry_i.to_u64()) * (w.to_u64()) + (rx_i.to_u64())) * 4
            mmio_write32(fb + offset, white)
            rx_i = rx_i + 1
        ry_i = ry_i + 1

# ============================================================================
# GPU Test Entry Point
# ============================================================================

fn gpu_test_main():
    """Standalone GPU test: scan PCI, init driver, draw pattern, flush."""
    log_info("[gpu] " + "[gpu-test] VirtIO-GPU test entry starting")

    # Step 1: Scan PCI bus
    var pci = PciBus.new()
    pci.scan()
    log_info("[gpu] " + "[gpu-test] PCI scan complete: {pci.device_count()} devices found")

    # Step 2: Find VirtIO-GPU device
    #   VirtIO vendor = 0x1AF4
    #   Display controller class = 0x03, subclass 0x00 or 0x80
    var gpu_dev: PciDevice? = nil

    # Search by class (display controller)
    val display_devs = pci.find_by_class(0x03, 0x80)
    if display_devs.len() > 0:
        gpu_dev = display_devs[0]
    else:
        val disp00 = pci.find_by_class(0x03, 0x00)
        if disp00.len() > 0:
            gpu_dev = disp00[0]

    if val Some(found_dev) = gpu_dev:
        log_info("[gpu] " + "[gpu-test] Found GPU: {found_dev.description()}")

        # Step 3: Build DeviceGrant and init driver
        val grant = grant_from_pci(found_dev)
        var gpu = VirtioGpuDriver.new()
        if val Ok(_ok) = gpu.init_from_grant(grant):
            log_info("[gpu] " + "[gpu-test] GPU driver initialized: {gpu.get_width()}x{gpu.get_height()}")

            # Wire the gpu_accel feature flag + glass_render.c mirror.
            # Safe in the standalone test too — glass_render's C globals
            # live in the same boot image and any subsequent rt_gui_*
            # calls will see the flag set.
            set_gpu_accel_supported_from_driver(gpu)
            log_info("[gpu] " + "[gpu-test] gpu_accel feature flag ON")

            # Step 4: Draw test pattern
            log_info("[gpu] " + "[gpu-test] Drawing test pattern...")
            draw_test_pattern(gpu)

            # Step 5: Transfer to host and flush
            gpu.flush()

            log_info("[gpu] " + "GPU TEST PATTERN VISIBLE")
        else:
            log_info("[gpu] " + "[gpu-test] GPU init failed")
    else:
        log_info("[gpu] " + "NO VIRTIO-GPU FOUND")

    log_info("[gpu] " + "[gpu-test] Test entry complete")
