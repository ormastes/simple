# GPU Model Abstraction and Serialization
#
# Neural network module trait, layer implementations, and
# weight persistence (text-based serialization format).
#
# Usage:
#   use os.ml.model.{Module, GpuLinear, GpuReLU, GpuSequential}
#   use os.ml.model.{save_model, load_weights}

use os.ml.gpu_tensor.{GpuTensor}
use os.ml.autograd.{GradTensor, ComputeGraph}

extern fn rt_file_write(path: text, content: text) -> i64
extern fn rt_file_read_text(path: text) -> text

# ============================================================================
# Module Trait
# ============================================================================

trait Module:
    """Abstract neural network module.

    All layers and models implement this trait to provide
    forward propagation and parameter enumeration.
    """
    fn forward(input: GpuTensor, graph: ComputeGraph) -> i64
    fn parameters() -> [GradTensor]

# ============================================================================
# GpuLinear — Fully Connected Layer
# ============================================================================

class GpuLinear:
    """Dense (fully connected) linear layer: y = xW^T + b.

    Weight shape: [out_features, in_features]
    Bias shape: [out_features] (optional)
    """

    weight: GradTensor
    bias: GradTensor?
    in_features: i64
    out_features: i64

    static fn new(graph: ComputeGraph, in_features: i64, out_features: i64, use_bias: bool) -> GpuLinear:
        """Create a new linear layer with Xavier-uniform initialization.

        Args:
            graph: ComputeGraph for autograd registration
            in_features: Input dimension
            out_features: Output dimension
            use_bias: Whether to include a bias term

        Returns:
            Initialized GpuLinear layer
        """
        # Xavier-uniform init: scale = sqrt(6 / (fan_in + fan_out))
        val fan_sum = in_features + out_features
        val scale = 2.449  # approx sqrt(6) for Xavier

        # Initialize weight data on host
        var weight_data: [f64] = []
        val weight_numel = out_features * in_features
        var i = 0
        # Deterministic pseudo-random init via LCG
        val a: i64 = 1103515245
        val c: i64 = 12345
        val m: i64 = 2147483648
        var seed: i64 = in_features * out_features + 17

        while i < weight_numel:
            seed = (a * seed + c) % m
            # Map to [-scale/fan_sum, +scale/fan_sum]
            val normalized = (seed % 10000) / 10000.0
            val value = (normalized * 2.0 - 1.0) * scale / fan_sum
            weight_data.push(value)
            i = i + 1

        val weight_shape: [i64] = [out_features, in_features]
        val weight_tensor = GpuTensor.from_host(weight_data, weight_shape)
        val weight_grad = graph.variable(weight_tensor)

        var bias_grad: GradTensor? = none

        if use_bias:
            # Initialize bias to zeros
            var bias_data: [f64] = []
            i = 0
            while i < out_features:
                bias_data.push(0.0)
                i = i + 1

            val bias_shape: [i64] = [out_features]
            val bias_tensor = GpuTensor.from_host(bias_data, bias_shape)
            bias_grad = graph.variable(bias_tensor)

        GpuLinear(
            weight: weight_grad,
            bias: bias_grad,
            in_features: in_features,
            out_features: out_features
        )

    fn forward(input: GpuTensor, graph: ComputeGraph) -> i64:
        """Forward pass: y = xW^T + b.

        Registers input as a variable on the graph, performs
        matmul with weight, and optionally adds bias.

        Args:
            input: Input tensor [batch, in_features]
            graph: Active compute graph for recording ops

        Returns:
            Tape index of the output node
        """
        val input_idx = graph.variable(input).idx
        val weight_idx = self.weight.idx

        # matmul: input @ weight^T -> [batch, out_features]
        var out_idx = graph.matmul(input_idx, weight_idx)

        # Add bias if present
        if val b = self.bias:
            out_idx = graph.add(out_idx, b.idx)

        out_idx

    fn parameters() -> [GradTensor]:
        """Return all trainable parameters."""
        var params: [GradTensor] = [self.weight]
        if val b = self.bias:
            params.push(b)
        params

# ============================================================================
# GpuReLU — Rectified Linear Unit
# ============================================================================

class GpuReLU:
    """Stateless ReLU activation: max(0, x)."""

    _dummy: i64

    static fn new() -> GpuReLU:
        """Create a ReLU activation module."""
        GpuReLU(_dummy: 0)

    fn forward(input: GpuTensor, graph: ComputeGraph) -> i64:
        """Apply ReLU element-wise.

        Args:
            input: Input tensor
            graph: Active compute graph

        Returns:
            Tape index of the ReLU output node
        """
        val input_idx = graph.variable(input).idx
        graph.relu(input_idx)

    fn parameters() -> [GradTensor]:
        """ReLU has no trainable parameters."""
        []

# ============================================================================
# GpuSequential — Layer Container
# ============================================================================

class GpuSequential:
    """Sequential container that chains modules in order.

    Forward pass feeds output of each layer as input to the next.

    Example:
        val model = GpuSequential.new([
            GpuLinear.new(graph, 784, 128, true),
            GpuReLU.new(),
            GpuLinear.new(graph, 128, 10, true)
        ])
    """

    layers: [Module]

    static fn new(layers: [Module]) -> GpuSequential:
        """Create a sequential model from ordered layer list.

        Args:
            layers: Modules to chain in forward order

        Returns:
            GpuSequential container
        """
        GpuSequential(layers: layers)

    fn forward(input: GpuTensor, graph: ComputeGraph) -> i64:
        """Chain forward through all layers.

        The first layer receives the raw input tensor.
        Subsequent layers receive the output tensor of the
        previous layer (retrieved from the graph tape).

        Args:
            input: Input tensor to the first layer
            graph: Active compute graph

        Returns:
            Tape index of the final layer's output
        """
        var current_tensor = input
        var current_idx: i64 = -1

        for layer in self.layers:
            current_idx = layer.forward(current_tensor, graph)
            current_tensor = graph.get_tensor(current_idx)

        current_idx

    fn parameters() -> [GradTensor]:
        """Collect all trainable parameters from all layers."""
        var params: [GradTensor] = []
        for layer in self.layers:
            val layer_params = layer.parameters()
            for p in layer_params:
                params.push(p)
        params

# ============================================================================
# Serialization
# ============================================================================

fn save_model(path: text, params: [GradTensor]):
    """Save model parameters to a text file.

    Format: one tensor per section.
    Each section has a shape header line (comma-separated dims)
    followed by space-separated f64 values.
    Sections are separated by blank lines.

    Args:
        path: File path to write
        params: List of GradTensors to save
    """
    var content = ""

    for param in params:
        val tensor = param.tensor()
        val host_data = tensor.to_host()
        val shape = tensor.shape

        # Write shape line
        var shape_line = ""
        var i = 0
        while i < shape.len():
            if i > 0:
                shape_line = shape_line + ","
            shape_line = shape_line + shape[i].to_text()
            i = i + 1

        content = content + shape_line + "\n"

        # Write values line (space-separated)
        var values_line = ""
        i = 0
        while i < host_data.len():
            if i > 0:
                values_line = values_line + " "
            values_line = values_line + host_data[i].to_text()
            i = i + 1

        content = content + values_line + "\n\n"

    rt_file_write(path, content)

fn load_weights(path: text, params: [GradTensor]):
    """Load model parameters from a text file.

    Reads the format produced by save_model and uploads
    values into existing GradTensor GPU memory.

    Args:
        path: File path to read
        params: List of GradTensors to populate (must match saved order/shapes)
    """
    val content = rt_file_read_text(path)
    val lines = content.split("\n")

    var line_idx = 0
    var param_idx = 0

    while param_idx < params.len():
        # Skip blank lines
        while line_idx < lines.len() and lines[line_idx].trim() == "":
            line_idx = line_idx + 1

        if line_idx >= lines.len():
            # No more data
            param_idx = params.len()
        else:
            # Parse shape line
            val shape_line = lines[line_idx]
            line_idx = line_idx + 1

            # Parse values line
            val values_line = lines[line_idx]
            line_idx = line_idx + 1

            val value_tokens = values_line.split(" ")
            var values: [f64] = []
            for token in value_tokens:
                val trimmed = token.trim()
                if trimmed != "":
                    values.push(trimmed.parse_f64())

            # Parse shape for upload
            val shape_tokens = shape_line.split(",")
            var shape: [i64] = []
            for s in shape_tokens:
                val trimmed = s.trim()
                if trimmed != "":
                    shape.push(trimmed.parse_i64())

            # Upload to existing param tensor
            val new_tensor = GpuTensor.from_host(values, shape)
            val param = params[param_idx]
            # Replace device data via graph
            param.tensor().free()
            param.set_tensor(new_tensor)

            param_idx = param_idx + 1
