# SPSC Ring Buffer — Lock-free single-producer single-consumer queue
#
# Designed for shared-memory data paths between driver and service processes.
# Uses a contiguous memory region (typically DMA-mapped or shared via VMM).
#
# Producer writes at tail, consumer reads at head. Both indices advance
# monotonically modulo capacity. The one-slot-empty convention distinguishes
# full from empty without a separate count variable.
#
# Memory access uses volatile MMIO reads/writes to prevent compiler
# reordering, which is critical for correctness in shared-memory scenarios.
#
# Notification-based signaling: after producing data, the producer can
# call signal() to wake a consumer blocked on NotificationWait.

use os.userlib.syscall_raw.{syscall}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read32, mmio_write32}

struct SpscRing:
    """Lock-free single-producer single-consumer ring buffer.

    Uses a contiguous memory region with volatile access for correctness.
    Producer writes at tail, consumer reads at head.
    Capacity must be a power of 2 for efficient modular arithmetic.

    Signaling is done via kernel notification objects — the producer
    calls signal() after writing to wake a sleeping consumer.
    """
    buffer_virt: u64    # Virtual address of data buffer
    capacity: u32       # Number of entries (must be power of 2)
    entry_size: u32     # Bytes per entry
    head: u32           # Consumer read index (consumer updates)
    tail: u32           # Producer write index (producer updates)
    notif_id: u64       # Notification ID for signaling
    notif_bit: u64      # Bit to signal

impl SpscRing:
    static fn new(buf_virt: u64, capacity: u32, entry_size: u32, notif_id: u64, notif_bit: u64) -> SpscRing:
        """Create a new ring buffer over the given memory region.

        The caller must ensure:
        - buf_virt points to at least (capacity * entry_size) bytes of valid memory
        - capacity is a power of 2
        - The memory region is shared between producer and consumer processes
        """
        SpscRing(
            buffer_virt: buf_virt,
            capacity: capacity,
            entry_size: entry_size,
            head: 0,
            tail: 0,
            notif_id: notif_id,
            notif_bit: notif_bit
        )

    fn is_empty() -> bool:
        """Check if the ring buffer has no entries to consume."""
        self.head == self.tail

    fn is_full() -> bool:
        """Check if the ring buffer has no room for new entries.

        Uses the one-slot-empty convention: the buffer is full when
        advancing tail by one would make it equal to head.
        """
        ((self.tail + 1) % self.capacity) == self.head

    fn count() -> u32:
        """Return the number of entries currently in the buffer."""
        if self.tail >= self.head:
            self.tail - self.head
        else:
            self.capacity - self.head + self.tail

    fn available_space() -> u32:
        """Return the number of entries that can be written before full."""
        # capacity - 1 because one slot is always empty (full detection)
        (self.capacity - 1) - self.count()

    fn entry_offset(index: u32) -> u64:
        """Compute the byte offset for a given ring index."""
        (index as u64) * (self.entry_size as u64)

    me produce(data_virt: u64, len: u32) -> bool:
        """Write one entry to the ring buffer.

        Copies len bytes from data_virt into the tail slot. If len exceeds
        entry_size, only entry_size bytes are copied. Returns false if the
        buffer is full.

        Uses volatile byte-by-byte copy to prevent compiler reordering.
        After a successful produce, call signal() to wake the consumer.
        """
        if self.is_full():
            return false

        # Compute destination address
        val offset = self.entry_offset(self.tail)
        val dest = self.buffer_virt + offset

        # Copy data byte-by-byte using volatile writes
        val copy_len = if len < self.entry_size: len else: self.entry_size
        var byte_idx: u32 = 0
        while byte_idx < copy_len:
            val src_addr = data_virt + (byte_idx as u64)
            val dst_addr = dest + (byte_idx as u64)
            val byte_val = mmio_read8(src_addr)
            mmio_write8(dst_addr, byte_val)
            byte_idx = byte_idx + 1

        # Zero remaining bytes if data is shorter than entry
        while byte_idx < self.entry_size:
            val dst_addr = dest + (byte_idx as u64)
            mmio_write8(dst_addr, 0)
            byte_idx = byte_idx + 1

        # Advance tail (this must happen AFTER the data write)
        self.tail = (self.tail + 1) % self.capacity
        true

    me consume(dest_virt: u64, max_len: u32) -> u32:
        """Read one entry from the ring buffer.

        Copies up to max_len bytes from the head slot into dest_virt.
        Returns the number of bytes actually copied, or 0 if the buffer
        is empty.

        Uses volatile byte-by-byte copy to prevent compiler reordering.
        """
        if self.is_empty():
            return 0

        # Compute source address
        val offset = self.entry_offset(self.head)
        val src = self.buffer_virt + offset

        # Copy data byte-by-byte using volatile reads
        val copy_len = if max_len < self.entry_size: max_len else: self.entry_size
        var byte_idx: u32 = 0
        while byte_idx < copy_len:
            val src_addr = src + (byte_idx as u64)
            val dst_addr = dest_virt + (byte_idx as u64)
            val byte_val = mmio_read8(src_addr)
            mmio_write8(dst_addr, byte_val)
            byte_idx = byte_idx + 1

        # Advance head (this must happen AFTER the data read)
        self.head = (self.head + 1) % self.capacity
        copy_len

    me signal():
        """Signal the consumer via notification.

        Calls syscall 25 (NotificationSignal) to wake any thread
        blocked on this ring's notification object.
        """
        syscall(25, self.notif_id, self.notif_bit, 0, 0, 0)

    me produce_and_signal(data_virt: u64, len: u32) -> bool:
        """Write one entry and signal the consumer if successful.

        Convenience method that combines produce() + signal().
        Returns false if the buffer was full (no signal sent).
        """
        val ok = self.produce(data_virt, len)
        if ok:
            self.signal()
        ok

    me reset():
        """Reset the ring buffer to empty state.

        Only safe to call when both producer and consumer are stopped.
        """
        self.head = 0
        self.tail = 0
