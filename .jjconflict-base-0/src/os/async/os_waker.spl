# SimpleOS async waker token.

class OsWaker:
    notif_id: u64
    task_id: u64

    static fn new(notif_id: u64, task_id: u64) -> OsWaker:
        OsWaker(notif_id: notif_id, task_id: task_id)

    me notification_id() -> u64:
        self.notif_id

    me owner_task_id() -> u64:
        self.task_id

    me wake() -> bool:
        true
