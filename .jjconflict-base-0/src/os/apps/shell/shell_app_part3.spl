# =========================================================================
# Shell Application
# =========================================================================

fn _find_char(s: text, target: text) -> i32:
    """Find first occurrence of a character in a string. Returns -1 if not found."""
    var i = 0
    for ch in s:
        if ch == target:
            return i
        i = i + 1
    return -1

fn _normalize_path(path: text) -> text:
    """Normalize a path by resolving . and .. components."""
    var parts: [text] = []
    var current = ""
    for ch in path:
        if ch == "/":
            if current == "..":
                if parts.len() > 0:
                    var new_parts: [text] = []
                    var j = 0
                    while j < parts.len() - 1:
                        new_parts = new_parts.push(parts[j])
                        j = j + 1
                    parts = new_parts
            elif current != "." and current != "":
                parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
    # Handle trailing component
    if current == "..":
        if parts.len() > 0:
            var new_parts: [text] = []
            var j = 0
            while j < parts.len() - 1:
                new_parts = new_parts.push(parts[j])
                j = j + 1
            parts = new_parts
    elif current != "." and current != "":
        parts = parts.push(current)

    if parts.len() == 0:
        return "/"
    var result = ""
    for part in parts:
        result = "{result}/{part}"
    return result

fn _parse_u64(s: text) -> u64:
    """Parse a u64 from text, returning 0 on failure."""
    var result: u64 = 0
    for ch in s:
        if ch >= "0" and ch <= "9":
            val digit = ch.to_i32() - "0".to_i32()
            result = result * 10 + digit.to_u64()
        else:
            return 0
    return result

fn _parent_path(path: text) -> text:
    """Get the parent directory of a path."""
    if path == "/":
        return "/"
    var last_slash = 0
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash == 0:
        return "/"
    return path.slice(0, last_slash)

fn _join_lines(lines: [text]) -> text:
    """Join a list of lines into a single text with newlines."""
    var result = ""
    for line in lines:
        result = "{result}{line}\n"
    return result

fn _find_chain_op(s: text, op: text) -> i32:
    """Find op in s outside of quotes. Returns position or -1."""
    var in_quote = false
    var quote_char = ""
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if in_quote:
            if ch == quote_char:
                in_quote = false
        else:
            if ch == "\"" or ch == "'":
                in_quote = true
                quote_char = ch
            elif i + op.len() <= s.len():
                if s.slice(i, i + op.len()) == op:
                    return i
        i = i + 1
    return -1

fn _basename_of(path: text) -> text:
    """Return the last component of a path."""
    if path == "/" or path == "":
        return path
    val normalized = if path.ends_with("/"): path.slice(0, path.len() - 1) else: path
    var last_slash = -1
    var i = 0
    for ch in normalized:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash < 0:
        return normalized
    return normalized.slice(last_slash + 1, normalized.len())

fn _unquote_simple(s: text) -> text:
    """Strip surrounding single or double quotes from a string."""
    if s.len() >= 2:
        val first = s.slice(0, 1)
        val last = s.slice(s.len() - 1, s.len())
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return s.slice(1, s.len() - 1)
    return s

fn _find_char_pos(s: text, ch: text) -> i32:
    """Find position of first occurrence of ch in s. Returns -1 if not found."""
    var pos = 0
    for c in s:
        if c == ch:
            return pos
        pos = pos + 1
    return -1

# =========================================================================
# Remote Window Entry
# =========================================================================

fn shell_remote_main():
    """Launch Shell (Terminal) as a remote WM window."""
    log_info("[app.shell] " + "[shell] start app_id=/sys/apps/shell")
    var client = WindowClient.new()
    client.set_app_identity("/sys/apps/shell")
    if not client.connect():
        log_info("[app.shell] " + "[shell] connect_failed app_id=/sys/apps/shell")
        exit_(1)
        return

    val wid = client.create_window("Terminal", 80, 80, 600, 360)
    if wid == 0:
        log_info("[app.shell] " + "[shell] create_window_failed app_id=/sys/apps/shell")
        client.disconnect()
        exit_(1)
        return
    log_info("[app.shell] " + "[shell] window_created app_id=/sys/apps/shell wid={wid}")

    client.update_content("SimpleOS Shell\n\n$ ")

    var running = true
    while running:
        val event = client.wait_event()
        if event.event_type == WM_EVENT_CLOSE:
            running = false

    client.destroy_window()
    client.disconnect()
    log_info("[app.shell] " + "[shell] exit app_id=/sys/apps/shell code=0")
    exit_(0)

fn shell_remote_launch_once(process_id: u64) -> bool:
    """Create the packaged Shell window and return immediately."""
    log_info("[app.shell] " + "[shell] start app_id=/sys/apps/shell mode=filesystem-process pid={process_id}")
    var client = WindowClient.new()
    client.set_app_identity("/sys/apps/shell")
    if not client.connect():
        log_info("[app.shell] " + "[shell] connect_failed app_id=/sys/apps/shell mode=filesystem-process pid={process_id}")
        return false

    val wid = client.create_window_with_process_id("Terminal", 80, 80, 600, 360, process_id)
    if wid == 0:
        log_info("[app.shell] " + "[shell] create_window_failed app_id=/sys/apps/shell mode=filesystem-process pid={process_id}")
        client.disconnect()
        return false
    log_info("[app.shell] " + "[shell] window_created app_id=/sys/apps/shell wid={wid} mode=filesystem-process pid={process_id}")

    client.update_content("SimpleOS Shell\n\n$ ")
    true
