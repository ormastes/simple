use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title
}

class DiskManager:
    static fn new() -> DiskManager:
        DiskManager()

    me build_ui() -> UISession:
        val disk_header = row("dm_header", [
            label("dm_h_dev", "Device"),
            label("dm_h_mount", "Mount"),
            label("dm_h_fs", "Type"),
            label("dm_h_size", "Size"),
            label("dm_h_used", "Used"),
            label("dm_h_free", "Free")
        ])

        val disk_list = panel("dm_disks", "Partitions", [
            disk_header,
            text_widget("dm_d1", "/dev/sda1    /boot   ext4    512 MB    128 MB    384 MB"),
            text_widget("dm_d2", "/dev/sda2    /       ext4    20 GB     8.2 GB    11.8 GB"),
            text_widget("dm_d3", "/dev/sda3    /home   ext4    40 GB     12.5 GB   27.5 GB"),
            text_widget("dm_d4", "/dev/sda4    swap    swap    4 GB      1.2 GB    2.8 GB")
        ])

        val usage_panel = panel("dm_usage", "Disk Usage", [
            text_widget("dm_u1", "/boot  [=====                         ] 25%"),
            text_widget("dm_u2", "/      [==============                ] 41%"),
            text_widget("dm_u3", "/home  [=========                     ] 31%"),
            text_widget("dm_u4", "swap   [=========                     ] 30%")
        ])

        val actions = row("dm_actions", [
            button("dm_mount", "Mount", "mount"),
            button("dm_unmount", "Unmount", "unmount"),
            button("dm_format", "Format", "format"),
            button("dm_check", "Check Filesystem", "fsck"),
            button("dm_refresh", "Refresh", "refresh")
        ])

        val status = statusbar("dm_status", "4 partitions  |  64.5 GB total", "SimpleOS Disk Manager")

        val root = column("dm_root", [
            disk_list,
            usage_panel,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "Disk Manager", "dark")
        UISession.new(tree)
