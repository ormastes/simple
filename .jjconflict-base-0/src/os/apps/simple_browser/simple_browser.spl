# Simple Browser — deterministic Simple Web launcher-owned browser app for SimpleOS.
#
# Provides the filesystem-backed `/sys/apps/simple_browser` process used by
# the desktop/QEMU launcher acceptance lane. In the freestanding desktop lane
# the shell materializes the launcher-owned window and the compositor's
# canonical Simple Web renderer provides the visible `about:network` page proof.

use os.userlib.process.{getpid, yield_}
use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}


val SIMPLE_BROWSER_APP_ID: text = "/sys/apps/simple_browser"
val SIMPLE_BROWSER_WINDOW_TITLE: text = "Simple Browser"
val SIMPLE_BROWSER_START_PAGE: text = "about:network"

pub fn simple_browser_app_id() -> text:
    SIMPLE_BROWSER_APP_ID

pub fn simple_browser_window_title() -> text:
    SIMPLE_BROWSER_WINDOW_TITLE

pub fn simple_browser_start_page() -> text:
    SIMPLE_BROWSER_START_PAGE

pub fn simple_browser_ready_marker(process_id: u64) -> text:
    val app_id = simple_browser_app_id()
    val page = simple_browser_start_page()
    "[simple_browser] started app_id={app_id} mode=filesystem-process pid={process_id} page={page}"

pub fn simple_browser_window_marker(process_id: u64, window_id: u64) -> text:
    val app_id = simple_browser_app_id()
    val title = simple_browser_window_title()
    "[simple_browser] window_created app_id={app_id} wid={window_id} title={title} mode=filesystem-process pid={process_id}"

pub fn simple_browser_render_marker(process_id: u64, window_id: u64) -> text:
    val app_id = simple_browser_app_id()
    val page = simple_browser_start_page()
    "[simple_browser] page_rendered app_id={app_id} wid={window_id} page={page} renderer=simple_web mode=filesystem-process pid={process_id}"

pub fn simple_browser_remote_launch_once(process_id: u64) -> bool:
    log_info("[app.simple_browser] " + simple_browser_ready_marker(process_id))
    true

pub fn simple_browser_remote_main():
    val pid = getpid()
    log_info("[app.simple_browser] " + simple_browser_ready_marker(pid))
    while true:
        yield_()
