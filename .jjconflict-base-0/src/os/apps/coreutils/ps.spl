# coreutils/ps — list processes
#
# Tiny wrapper around PM externs. No flags yet beyond --help.
#
# MDSOC: feature dimension, coreutils layer

extern fn pm_list_pids(buf_ptr: u64, max: i32) -> i32
extern fn pm_process_name(pid: u32) -> text
extern fn println(msg: text)
extern fn unsafe_addr_of(ref: any) -> u64

val _MAX_PIDS: i32 = 256

fn main_ps(args: [text]) -> i32:
    """List running processes.

    Usage: ps [--help]
    """
    var i: u64 = 0
    while i < args.len():
        if args[i] == "--help":
            println("usage: ps")
            return 0i32
        i = i + 1

    var buf: [u32] = []
    var k: i32 = 0
    while k < _MAX_PIDS:
        buf.push(0u32)
        k = k + 1
    val n = pm_list_pids(unsafe_addr_of(buf), _MAX_PIDS)
    if n < 0:
        println("ps: pm_list_pids failed")
        return 1i32
    println("  PID  NAME")
    var j: i32 = 0
    while j < n:
        val pid = buf[j as u64]
        val name = pm_process_name(pid)
        println("{pid} {name}")
        j = j + 1
    0i32
