# Network Monitor — Network Connections and Traffic Monitor
#
# Displays active TCP/UDP connections, network interfaces,
# bandwidth traffic graphs, and DNS lookup history.
# Renders as a widget tree using the existing UI builder DSL.
#
# MDSOC: feature dimension, apps layer

use common.ui.builder.{
    column, row, panel, button, text_widget, label,
    statusbar, menubar, build_tree_with_title,
    with_flex, with_width, tabs, table_widget
}
use common.ui.widget.{WidgetNode, UITree, UIEvent}
use common.ui.session.{UISession}

# =========================================================================
# Data Models
# =========================================================================

struct Connection:
    """An active network connection."""
    protocol: text
    local_addr: text
    remote_addr: text
    state: text
    pid: i32

struct NetInterface:
    """A network interface with traffic counters."""
    name: text
    ip: text
    mac: text
    status: text
    rx_bytes: i64
    tx_bytes: i64

struct TrafficSample:
    """A single traffic measurement at a point in time."""
    timestamp: text
    rx_bps: i64
    tx_bps: i64

struct DnsEntry:
    """A cached DNS lookup result."""
    domain: text
    ip: text
    ttl: i32

# =========================================================================
# Network Monitor App
# =========================================================================

class NetworkMonitorApp:
    """Network connections and traffic monitor.

    Provides four views: active connections, interface status,
    bandwidth traffic graph, and DNS cache. Supports keyboard
    navigation, tab switching, sorting, and manual refresh.
    """
    connections: [Connection]
    interfaces: [NetInterface]
    traffic: [TrafficSample]
    dns_cache: [DnsEntry]
    current_tab: text
    sort_column: text
    selected_index: i32
    status_message: text

impl NetworkMonitorApp:

    static fn new() -> NetworkMonitorApp:
        """Create a network monitor with sample data."""
        var app = NetworkMonitorApp(
            connections: [],
            interfaces: [],
            traffic: [],
            dns_cache: [],
            current_tab: "connections",
            sort_column: "local_addr",
            selected_index: 0,
            status_message: "Ready"
        )
        app._load_sample_data()
        return app

    # -- Sample Data ---------------------------------------------------------

    me _load_sample_data():
        """Populate with simulated network data."""
        self._load_connections()
        self._load_interfaces()
        self._load_traffic()
        self._load_dns()
        self.status_message = "Refreshed — {self.connections.len()} connections"

    me _load_connections():
        """Load sample TCP/UDP connections."""
        self.connections = []
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:22", remote_addr: "192.168.1.50:49821", state: "ESTABLISHED", pid: 1024))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:80", remote_addr: "10.0.0.5:52340", state: "ESTABLISHED", pid: 2048))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:443", remote_addr: "10.0.0.5:52341", state: "ESTABLISHED", pid: 2048))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "127.0.0.1:5432", remote_addr: "127.0.0.1:49900", state: "ESTABLISHED", pid: 3100))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:8080", remote_addr: "192.168.1.100:61234", state: "ESTABLISHED", pid: 4200))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:3000", remote_addr: "0.0.0.0:0", state: "LISTEN", pid: 5010))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:22", remote_addr: "0.0.0.0:0", state: "LISTEN", pid: 1024))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:80", remote_addr: "0.0.0.0:0", state: "LISTEN", pid: 2048))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "0.0.0.0:443", remote_addr: "0.0.0.0:0", state: "LISTEN", pid: 2048))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "10.0.0.1:55012", remote_addr: "93.184.216.34:443", state: "TIME_WAIT", pid: 6100))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "10.0.0.1:55013", remote_addr: "151.101.1.140:443", state: "TIME_WAIT", pid: 6100))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "10.0.0.1:55020", remote_addr: "172.217.14.99:443", state: "CLOSE_WAIT", pid: 6200))
        self.connections = self.connections.push(Connection(protocol: "UDP", local_addr: "0.0.0.0:53", remote_addr: "*:*", state: "LISTENING", pid: 800))
        self.connections = self.connections.push(Connection(protocol: "UDP", local_addr: "0.0.0.0:68", remote_addr: "*:*", state: "LISTENING", pid: 900))
        self.connections = self.connections.push(Connection(protocol: "UDP", local_addr: "0.0.0.0:5353", remote_addr: "*:*", state: "LISTENING", pid: 950))
        self.connections = self.connections.push(Connection(protocol: "TCP", local_addr: "10.0.0.1:43210", remote_addr: "140.82.121.4:443", state: "ESTABLISHED", pid: 7000))

    me _load_interfaces():
        """Load sample network interface data."""
        self.interfaces = []
        self.interfaces = self.interfaces.push(NetInterface(
            name: "eth0",
            ip: "10.0.0.1",
            mac: "52:54:00:ab:cd:01",
            status: "UP",
            rx_bytes: 1073741824,
            tx_bytes: 536870912
        ))
        self.interfaces = self.interfaces.push(NetInterface(
            name: "lo",
            ip: "127.0.0.1",
            mac: "00:00:00:00:00:00",
            status: "UP",
            rx_bytes: 8388608,
            tx_bytes: 8388608
        ))
        self.interfaces = self.interfaces.push(NetInterface(
            name: "wlan0",
            ip: "192.168.1.10",
            mac: "52:54:00:ab:cd:02",
            status: "DOWN",
            rx_bytes: 0,
            tx_bytes: 0
        ))

    me _load_traffic():
        """Load sample traffic history (bytes per second)."""
        self.traffic = []
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:00", rx_bps: 120000, tx_bps: 45000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:05", rx_bps: 250000, tx_bps: 80000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:10", rx_bps: 510000, tx_bps: 120000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:15", rx_bps: 980000, tx_bps: 310000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:20", rx_bps: 1200000, tx_bps: 450000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:25", rx_bps: 870000, tx_bps: 280000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:30", rx_bps: 640000, tx_bps: 190000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:35", rx_bps: 1500000, tx_bps: 620000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:40", rx_bps: 2100000, tx_bps: 890000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:45", rx_bps: 1800000, tx_bps: 740000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:50", rx_bps: 950000, tx_bps: 350000))
        self.traffic = self.traffic.push(TrafficSample(timestamp: "00:55", rx_bps: 430000, tx_bps: 160000))

    me _load_dns():
        """Load sample DNS cache entries."""
        self.dns_cache = []
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "simpleos.org", ip: "93.184.216.34", ttl: 3600))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "pkg.simpleos.org", ip: "93.184.216.35", ttl: 1800))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "github.com", ip: "140.82.121.4", ttl: 60))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "google.com", ip: "172.217.14.99", ttl: 300))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "dns.google", ip: "8.8.8.8", ttl: 7200))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "reddit.com", ip: "151.101.1.140", ttl: 120))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "api.simpleos.org", ip: "93.184.216.36", ttl: 900))
        self.dns_cache = self.dns_cache.push(DnsEntry(domain: "ntp.simpleos.org", ip: "93.184.216.37", ttl: 43200))

    # -- Display Helpers -----------------------------------------------------

    me _format_bytes(bytes: i64) -> text:
        """Format byte count in human-readable form (B/KB/MB/GB)."""
        if bytes < 1024:
            return "{bytes} B"
        val kb = bytes / 1024
        if kb < 1024:
            return "{kb} KB"
        val mb = kb / 1024
        if mb < 1024:
            return "{mb} MB"
        val gb = mb / 1024
        return "{gb} GB"

    me _format_bps(bps: i64) -> text:
        """Format bytes per second in human-readable form."""
        if bps < 1024:
            return "{bps} B/s"
        val kbps = bps / 1024
        if kbps < 1024:
            return "{kbps} KB/s"
        val mbps = kbps / 1024
        return "{mbps} MB/s"

    me _traffic_bar(value: i64, max_val: i64) -> text:
        """Build a text bar chart for bandwidth visualization."""
        if max_val <= 0:
            return "[                    ] 0 B/s"
        val width = 20
        val filled = if max_val > 0: ((value * width) / max_val).to_i32() else: 0
        val clamped = if filled > width: width elif filled < 0: 0 else: filled
        val empty = width - clamped
        var bar = "["
        bar = bar + _repeat_char("#", clamped)
        bar = bar + _repeat_char(".", empty)
        bar = bar + "] " + self._format_bps(value)
        return bar

    me _state_indicator(state: text) -> text:
        """Format connection state with visual prefix."""
        match state:
            "ESTABLISHED": "[*] ESTABLISHED"
            "LISTEN": "[~] LISTEN"
            "LISTENING": "[~] LISTENING"
            "TIME_WAIT": "[.] TIME_WAIT"
            "CLOSE_WAIT": "[!] CLOSE_WAIT"
            "SYN_SENT": "[>] SYN_SENT"
            _: "[-] {state}"

    me _status_indicator(status: text) -> text:
        """Format interface status with visual prefix."""
        match status:
            "UP": "[UP] Active"
            "DOWN": "[--] Down"
            _: "[??] {status}"

    # -- Tab Content Builders ------------------------------------------------

    me _build_connections_panel() -> WidgetNode:
        """Build the connections table panel."""
        val headers = ["Proto", "Local Address", "Remote Address", "State", "PID"]
        var rows = []
        var idx = 0
        for conn in self.connections:
            val prefix = if idx == self.selected_index: "> " else: "  "
            rows = rows.push([
                "{prefix}{conn.protocol}",
                conn.local_addr,
                conn.remote_addr,
                self._state_indicator(conn.state),
                "{conn.pid}"
            ])
            idx = idx + 1
        val conn_table = table_widget("nm_conn_table", headers, rows)

        # Summary row
        var established = 0
        var listening = 0
        for conn in self.connections:
            if conn.state == "ESTABLISHED":
                established = established + 1
            if conn.state == "LISTEN" or conn.state == "LISTENING":
                listening = listening + 1

        panel("nm_conn_panel", "Active Connections", [
            text_widget("nm_conn_summary", "Established: {established}  |  Listening: {listening}  |  Total: {self.connections.len()}"),
            with_flex(conn_table, 1)
        ])

    me _build_interfaces_panel() -> WidgetNode:
        """Build the network interfaces panel."""
        val headers = ["Name", "IP Address", "MAC Address", "Status", "RX", "TX"]
        var rows = []
        for iface in self.interfaces:
            rows = rows.push([
                iface.name,
                iface.ip,
                iface.mac,
                self._status_indicator(iface.status),
                self._format_bytes(iface.rx_bytes),
                self._format_bytes(iface.tx_bytes)
            ])
        val iface_table = table_widget("nm_iface_table", headers, rows)

        var active_count = 0
        for iface in self.interfaces:
            if iface.status == "UP":
                active_count = active_count + 1

        panel("nm_iface_panel", "Network Interfaces", [
            text_widget("nm_iface_summary", "Active: {active_count} / {self.interfaces.len()} interfaces"),
            with_flex(iface_table, 1)
        ])

    me _build_traffic_panel() -> WidgetNode:
        """Build the traffic bandwidth graph panel."""
        # Find max for scaling bars
        var max_bps: i64 = 1
        for sample in self.traffic:
            if sample.rx_bps > max_bps:
                max_bps = sample.rx_bps
            if sample.tx_bps > max_bps:
                max_bps = sample.tx_bps

        var traffic_widgets = []
        traffic_widgets = traffic_widgets.push(
            text_widget("nm_traffic_header", "Time      RX Bandwidth                          TX Bandwidth")
        )

        for sample in self.traffic:
            val rx_bar = self._traffic_bar(sample.rx_bps, max_bps)
            val tx_bar = self._traffic_bar(sample.tx_bps, max_bps)
            traffic_widgets = traffic_widgets.push(
                text_widget("nm_traffic_{sample.timestamp}",
                    "{sample.timestamp}  RX {rx_bar}")
            )
            traffic_widgets = traffic_widgets.push(
                text_widget("nm_traffic_{sample.timestamp}_tx",
                    "        TX {tx_bar}")
            )

        # Aggregate stats
        var total_rx: i64 = 0
        var total_tx: i64 = 0
        for sample in self.traffic:
            total_rx = total_rx + sample.rx_bps
            total_tx = total_tx + sample.tx_bps
        val avg_rx = if self.traffic.len() > 0: total_rx / self.traffic.len() else: 0
        val avg_tx = if self.traffic.len() > 0: total_tx / self.traffic.len() else: 0

        traffic_widgets = traffic_widgets.push(
            text_widget("nm_traffic_stats",
                "Peak: {self._format_bps(max_bps)}  |  Avg RX: {self._format_bps(avg_rx)}  |  Avg TX: {self._format_bps(avg_tx)}")
        )

        panel("nm_traffic_panel", "Bandwidth Monitor", traffic_widgets)

    me _build_dns_panel() -> WidgetNode:
        """Build the DNS cache panel."""
        val headers = ["Domain", "IP Address", "TTL (sec)"]
        var rows = []
        for entry in self.dns_cache:
            rows = rows.push([
                entry.domain,
                entry.ip,
                "{entry.ttl}"
            ])
        val dns_table = table_widget("nm_dns_table", headers, rows)

        panel("nm_dns_panel", "DNS Cache", [
            text_widget("nm_dns_summary", "{self.dns_cache.len()} cached entries"),
            with_flex(dns_table, 1)
        ])

    # -- Input Handling ------------------------------------------------------

    me handle_key(key: text):
        """Handle keyboard input.

        Keys: Tab = cycle tabs, 1-4 = jump to tab,
              R = refresh, Up/Down = scroll selection,
              S = cycle sort column (connections tab)
        """
        match key:
            "tab":
                self._cycle_tab()
            "1":
                self.current_tab = "connections"
                self.selected_index = 0
                self.status_message = "Connections"
            "2":
                self.current_tab = "interfaces"
                self.selected_index = 0
                self.status_message = "Interfaces"
            "3":
                self.current_tab = "traffic"
                self.selected_index = 0
                self.status_message = "Traffic"
            "4":
                self.current_tab = "dns"
                self.selected_index = 0
                self.status_message = "DNS Cache"
            "r":
                self._load_sample_data()
            "up":
                if self.selected_index > 0:
                    self.selected_index = self.selected_index - 1
            "down":
                self._select_next()
            "s":
                if self.current_tab == "connections":
                    self._cycle_sort_column()
            _:
                pass_dn

    me handle_action(action: text):
        """Handle button actions dispatched from the UI."""
        match action:
            "tab_connections":
                self.current_tab = "connections"
                self.selected_index = 0
                self.status_message = "Connections"
            "tab_interfaces":
                self.current_tab = "interfaces"
                self.selected_index = 0
                self.status_message = "Interfaces"
            "tab_traffic":
                self.current_tab = "traffic"
                self.selected_index = 0
                self.status_message = "Traffic"
            "tab_dns":
                self.current_tab = "dns"
                self.selected_index = 0
                self.status_message = "DNS Cache"
            "refresh":
                self._load_sample_data()
            "sort_proto":
                self.sort_column = "protocol"
                self.status_message = "Sort: Protocol"
            "sort_local":
                self.sort_column = "local_addr"
                self.status_message = "Sort: Local Address"
            "sort_remote":
                self.sort_column = "remote_addr"
                self.status_message = "Sort: Remote Address"
            "sort_state":
                self.sort_column = "state"
                self.status_message = "Sort: State"
            "sort_pid":
                self.sort_column = "pid"
                self.status_message = "Sort: PID"
            _ => pass_dn

    # -- Internal Helpers ----------------------------------------------------

    me _cycle_tab():
        """Cycle to the next tab."""
        val next = match self.current_tab:
            "connections": "interfaces"
            "interfaces": "traffic"
            "traffic": "dns"
            _: "connections"
        self.current_tab = next
        self.selected_index = 0
        self.status_message = match next:
            "connections": "Connections"
            "interfaces": "Interfaces"
            "traffic": "Traffic"
            "dns": "DNS Cache"
            _: "Ready"

    me _select_next():
        """Move selection down, clamped to list size."""
        val max_idx = match self.current_tab:
            "connections": self.connections.len() - 1
            "interfaces": self.interfaces.len() - 1
            "dns": self.dns_cache.len() - 1
            _: 0
        if self.selected_index < max_idx:
            self.selected_index = self.selected_index + 1

    me _cycle_sort_column():
        """Cycle through sort columns for connections."""
        val next = match self.sort_column:
            "protocol": "local_addr"
            "local_addr": "remote_addr"
            "remote_addr": "state"
            "state": "pid"
            _: "protocol"
        self.sort_column = next
        self.status_message = "Sort: {next}"

    # -- UI Construction -----------------------------------------------------

    me build_ui() -> UISession:
        """Build the network monitor UI.

        Layout:
          Menubar: File | View | Tools
          Tab bar (Connections / Interfaces / Traffic / DNS)
          Content panel (varies by active tab)
          Action buttons
          Statusbar: connection count | active interfaces
        """
        val tab_index = match self.current_tab:
            "connections": 0
            "interfaces": 1
            "traffic": 2
            "dns": 3
            _: 0

        val tab_names = ["Connections", "Interfaces", "Traffic", "DNS"]

        val content = match self.current_tab:
            "connections": self._build_connections_panel()
            "interfaces": self._build_interfaces_panel()
            "traffic": self._build_traffic_panel()
            "dns": self._build_dns_panel()
            _: self._build_connections_panel()

        # Action buttons
        val actions = row("nm_actions", [
            button("nm_btn_refresh", "Refresh", "refresh"),
            button("nm_btn_sort_proto", "Sort: Proto", "sort_proto"),
            button("nm_btn_sort_state", "Sort: State", "sort_state"),
            button("nm_btn_sort_pid", "Sort: PID", "sort_pid")
        ])

        # Status bar info
        var active_ifaces = 0
        for iface in self.interfaces:
            if iface.status == "UP":
                active_ifaces = active_ifaces + 1

        val root = column("nm_root", [
            menubar("nm_menu", ["File", "View", "Tools"]),
            tabs("nm_tabs", tab_names, tab_index),
            with_flex(content, 1),
            actions,
            statusbar("nm_status",
                "{self.connections.len()} connections",
                "{active_ifaces} active interfaces"
            )
        ])

        val tree = build_tree_with_title(root, "Network Monitor", "dark")
        return UISession.new(tree)

# =========================================================================
# Helpers
# =========================================================================

fn _repeat_char(ch: text, count: i32) -> text:
    """Repeat a character count times."""
    var result = ""
    var i = 0
    while i < count:
        result = "{result}{ch}"
        i = i + 1
    return result
