class PtyConfig:
    shell_path: text
    working_dir: text
    rows: int
    cols: int
    env_term: text

    me terminal_size() -> int:
        return self.rows * self.cols

    me with_size(r: int, c: int) -> PtyConfig:
        return PtyConfig(
            shell_path: self.shell_path,
            working_dir: self.working_dir,
            rows: r,
            cols: c,
            env_term: self.env_term
        )

    me to_text() -> text:
        return "pty " + self.rows.to_text() + "x" + self.cols.to_text() + " shell=" + self.shell_path

    static fn default_config() -> PtyConfig:
        return PtyConfig(
            shell_path: "/bin/sh",
            working_dir: ".",
            rows: 24,
            cols: 80,
            env_term: "xterm-256color"
        )


class OutputBuffer:
    f0_line: text
    f1_line: text
    f2_line: text
    f3_line: text
    line_count: int
    max_lines: int

    me append_line(line: text) -> OutputBuffer:
        if self.line_count >= self.max_lines:
            return self
        var next = self.line_count
        if next == 0:
            return OutputBuffer(
                f0_line: line,
                f1_line: self.f1_line,
                f2_line: self.f2_line,
                f3_line: self.f3_line,
                line_count: self.line_count + 1,
                max_lines: self.max_lines
            )
        if next == 1:
            return OutputBuffer(
                f0_line: self.f0_line,
                f1_line: line,
                f2_line: self.f2_line,
                f3_line: self.f3_line,
                line_count: self.line_count + 1,
                max_lines: self.max_lines
            )
        if next == 2:
            return OutputBuffer(
                f0_line: self.f0_line,
                f1_line: self.f1_line,
                f2_line: line,
                f3_line: self.f3_line,
                line_count: self.line_count + 1,
                max_lines: self.max_lines
            )
        if next == 3:
            return OutputBuffer(
                f0_line: self.f0_line,
                f1_line: self.f1_line,
                f2_line: self.f2_line,
                f3_line: line,
                line_count: self.line_count + 1,
                max_lines: self.max_lines
            )
        return self

    me get_line(idx: int) -> text:
        if idx == 0:
            return self.f0_line
        if idx == 1:
            return self.f1_line
        if idx == 2:
            return self.f2_line
        if idx == 3:
            return self.f3_line
        return ""

    me is_full() -> bool:
        return self.line_count >= self.max_lines

    me clear() -> OutputBuffer:
        return OutputBuffer(
            f0_line: "",
            f1_line: "",
            f2_line: "",
            f3_line: "",
            line_count: 0,
            max_lines: self.max_lines
        )

    static fn create(max: int) -> OutputBuffer:
        return OutputBuffer(
            f0_line: "",
            f1_line: "",
            f2_line: "",
            f3_line: "",
            line_count: 0,
            max_lines: max
        )


class PaneBackend:
    pane_id: int
    config: PtyConfig
    buffer: OutputBuffer
    is_running: bool
    exit_code: int

    me capture() -> text:
        var result = ""
        var i = 0
        while i < self.buffer.line_count:
            val line = self.buffer.get_line(i)
            if line == "" == false:
                if result == "":
                    result = line
                else:
                    result = result + "\n" + line
            i = i + 1
        return result

    me stop(code: int) -> PaneBackend:
        return PaneBackend(
            pane_id: self.pane_id,
            config: self.config,
            buffer: self.buffer,
            is_running: false,
            exit_code: code
        )

    me feed_output(line: text) -> PaneBackend:
        return PaneBackend(
            pane_id: self.pane_id,
            config: self.config,
            buffer: self.buffer.append_line(line),
            is_running: self.is_running,
            exit_code: self.exit_code
        )

    me to_text() -> text:
        return "backend pane[" + self.pane_id.to_text() + "] running=" + self.is_running.to_text()

    static fn create(pid: int, cfg: PtyConfig) -> PaneBackend:
        return PaneBackend(
            pane_id: pid,
            config: cfg,
            buffer: OutputBuffer.create(4),
            is_running: true,
            exit_code: 0
        )


class ShellBinding:
    binding_name: text
    shell_cmd: text
    is_active: bool
    pane_ref: int

    me activate() -> ShellBinding:
        return ShellBinding(
            binding_name: self.binding_name,
            shell_cmd: self.shell_cmd,
            is_active: true,
            pane_ref: self.pane_ref
        )

    me deactivate() -> ShellBinding:
        return ShellBinding(
            binding_name: self.binding_name,
            shell_cmd: self.shell_cmd,
            is_active: false,
            pane_ref: self.pane_ref
        )

    me to_text() -> text:
        return "binding:" + self.binding_name + " -> pane[" + self.pane_ref.to_text() + "]"

    static fn create(name: text, cmd: text, pane: int) -> ShellBinding:
        return ShellBinding(
            binding_name: name,
            shell_cmd: cmd,
            is_active: false,
            pane_ref: pane
        )
