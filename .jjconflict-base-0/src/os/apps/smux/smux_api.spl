class SmuxCommand:
    command: text
    target_name: text
    arg_width: int
    arg_height: int
    arg_direction: text

    me is_session_cmd() -> bool:
        if self.command.starts_with("new"):
            return true
        if self.command.starts_with("attach"):
            return true
        if self.command.starts_with("detach"):
            return true
        if self.command.starts_with("list"):
            return true
        if self.command.starts_with("kill"):
            return true
        return false

    me is_pane_cmd() -> bool:
        if self.command.starts_with("split"):
            return true
        if self.command.starts_with("resize"):
            return true
        if self.command.starts_with("capture"):
            return true
        return false

    me to_text() -> text:
        return "smux " + self.command + " target=" + self.target_name

    static fn new_session(name: text) -> SmuxCommand:
        SmuxCommand(
            command: "new-session",
            target_name: name,
            arg_width: 0,
            arg_height: 0,
            arg_direction: "",
        )

    static fn attach(name: text) -> SmuxCommand:
        SmuxCommand(
            command: "attach",
            target_name: name,
            arg_width: 0,
            arg_height: 0,
            arg_direction: "",
        )

    static fn detach() -> SmuxCommand:
        SmuxCommand(
            command: "detach",
            target_name: "",
            arg_width: 0,
            arg_height: 0,
            arg_direction: "",
        )

    static fn split(dir: text) -> SmuxCommand:
        SmuxCommand(
            command: "split-window",
            target_name: "",
            arg_width: 0,
            arg_height: 0,
            arg_direction: dir,
        )

    static fn capture(target: text) -> SmuxCommand:
        SmuxCommand(
            command: "capture-pane",
            target_name: target,
            arg_width: 0,
            arg_height: 0,
            arg_direction: "",
        )


class SmuxResponse:
    success: bool
    message: text
    result_data: text
    error_code: int

    me is_error() -> bool:
        return self.success == false

    me to_text() -> text:
        if self.success:
            return "OK: " + self.message
        return "ERR[" + self.error_code.to_text() + "]: " + self.message

    static fn ok(msg: text) -> SmuxResponse:
        SmuxResponse(
            success: true,
            message: msg,
            result_data: "",
            error_code: 0,
        )

    static fn ok_with_data(msg: text, data: text) -> SmuxResponse:
        SmuxResponse(
            success: true,
            message: msg,
            result_data: data,
            error_code: 0,
        )

    static fn error(msg: text, code: int) -> SmuxResponse:
        SmuxResponse(
            success: false,
            message: msg,
            result_data: "",
            error_code: code,
        )


class ApiDispatch:
    f0_cmd: text
    f1_cmd: text
    f2_cmd: text
    f3_cmd: text
    registered_count: int

    me is_registered(cmd: text) -> bool:
        if self.registered_count > 0:
            if self.f0_cmd == cmd:
                return true
        if self.registered_count > 1:
            if self.f1_cmd == cmd:
                return true
        if self.registered_count > 2:
            if self.f2_cmd == cmd:
                return true
        if self.registered_count > 3:
            if self.f3_cmd == cmd:
                return true
        return false

    me register(cmd: text) -> ApiDispatch:
        if self.registered_count == 0:
            return ApiDispatch(
                f0_cmd: cmd,
                f1_cmd: self.f1_cmd,
                f2_cmd: self.f2_cmd,
                f3_cmd: self.f3_cmd,
                registered_count: 1,
            )
        if self.registered_count == 1:
            return ApiDispatch(
                f0_cmd: self.f0_cmd,
                f1_cmd: cmd,
                f2_cmd: self.f2_cmd,
                f3_cmd: self.f3_cmd,
                registered_count: 2,
            )
        if self.registered_count == 2:
            return ApiDispatch(
                f0_cmd: self.f0_cmd,
                f1_cmd: self.f1_cmd,
                f2_cmd: cmd,
                f3_cmd: self.f3_cmd,
                registered_count: 3,
            )
        if self.registered_count == 3:
            return ApiDispatch(
                f0_cmd: self.f0_cmd,
                f1_cmd: self.f1_cmd,
                f2_cmd: self.f2_cmd,
                f3_cmd: cmd,
                registered_count: 4,
            )
        return ApiDispatch(
            f0_cmd: self.f0_cmd,
            f1_cmd: self.f1_cmd,
            f2_cmd: self.f2_cmd,
            f3_cmd: self.f3_cmd,
            registered_count: self.registered_count,
        )

    me to_text() -> text:
        return "dispatch(" + self.registered_count.to_text() + " commands)"

    static fn create() -> ApiDispatch:
        ApiDispatch(
            f0_cmd: "",
            f1_cmd: "",
            f2_cmd: "",
            f3_cmd: "",
            registered_count: 0,
        )


class CompatAdapter:
    adapter_name: text
    target_service: text
    is_connected: bool
    protocol_version: int

    me connect() -> CompatAdapter:
        CompatAdapter(
            adapter_name: self.adapter_name,
            target_service: self.target_service,
            is_connected: true,
            protocol_version: self.protocol_version,
        )

    me disconnect() -> CompatAdapter:
        CompatAdapter(
            adapter_name: self.adapter_name,
            target_service: self.target_service,
            is_connected: false,
            protocol_version: self.protocol_version,
        )

    me to_text() -> text:
        return "adapter:" + self.adapter_name + " -> " + self.target_service + " v" + self.protocol_version.to_text()

    static fn create(name: text, svc: text) -> CompatAdapter:
        CompatAdapter(
            adapter_name: name,
            target_service: svc,
            is_connected: false,
            protocol_version: 1,
        )
