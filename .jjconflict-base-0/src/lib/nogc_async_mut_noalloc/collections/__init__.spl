# Collections Module - Fixed-Size, Heap-Free Data Structures
#
# All collections use bounded capacity with no dynamic allocation.
# Suitable for bare-metal and embedded environments.
#
# Public API:
#   - use std.collections.{FixedArray, fixed_array_8, fixed_array_16, ...}
#   - use std.collections.{PoolLinkedList, ListNode}
#   - use std.collections.{RingBuffer, ring_buffer_16, ring_buffer_32, ...}
#   - use std.collections.{FixedStack}
#   - use std.collections.{FixedMap, FixedMapEntry}

# All submodules are automatically available.

# Re-exported from fixed_array.spl
export FixedArray
export fixed_array_8, fixed_array_16, fixed_array_32, fixed_array_64
export fixed_array_128, fixed_array_256

# Re-exported from fixed_map.spl
export FixedMapEntry, FixedMap

# Re-exported from fixed_set.spl
export FixedSet

# Re-exported from fixed_stack.spl
export FixedStack

# Re-exported from linked_list.spl
export ListNode, PoolLinkedList

# Re-exported from ring_buffer.spl
export RingBuffer
export ring_buffer_16, ring_buffer_32, ring_buffer_64, ring_buffer_128
