# Re-exported from baremetal_io.spl
export SemihostReader, SemihostWriter, UartWriter

# Re-export host I/O helpers so noalloc modules can use `std.io.{shell, file_read, ...}`
# even though this module shadows std.io within the nogc_async_mut_noalloc namespace.
export use std.nogc_sync_mut.io.{shell, shell_output, shell_bool, shell_lines, shell_int, shell_output_trimmed, ProcessResult, file_read, file_read_lines, file_read_bytes, file_read_text, file_write, file_write_bytes, file_exists, file_delete, file_copy, file_size, file_append, file_modified_time, file_remove, file_hash_sha256, file_stat, file_lock}
