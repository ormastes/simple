use std.nogc_async_mut_noalloc.baremetal.console_policy.{
    BAREMETAL_CONSOLE_NONE,
    BAREMETAL_CONSOLE_SEMIHOST,
    BAREMETAL_CONSOLE_UART,
    BAREMETAL_UART_QEMU_VIRT,
    BaremetalConsoleConfig,
    baremetal_console_choose,
    baremetal_console_is_enabled,
    baremetal_console_uses_semihost,
    baremetal_console_uses_uart
}

describe "Baremetal console policy":
    it "prefers semihost when requested and available":
        val config = baremetal_console_choose(true, true, BAREMETAL_UART_QEMU_VIRT)
        expect config.mode == BAREMETAL_CONSOLE_SEMIHOST
        expect baremetal_console_uses_semihost(config) == true
        expect baremetal_console_uses_uart(config) == false

    it "falls back to UART when semihost is not available":
        val config = baremetal_console_choose(true, false, BAREMETAL_UART_QEMU_VIRT)
        expect config.mode == BAREMETAL_CONSOLE_UART
        expect config.uart_base == BAREMETAL_UART_QEMU_VIRT
        expect baremetal_console_is_enabled(config) == true

    it "uses semihost when UART is unavailable":
        val config = baremetal_console_choose(false, true, 0u32)
        expect config.mode == BAREMETAL_CONSOLE_SEMIHOST

    it "can explicitly disable console output":
        val config = BaremetalConsoleConfig.none()
        expect config.mode == BAREMETAL_CONSOLE_NONE
        expect baremetal_console_is_enabled(config) == false
