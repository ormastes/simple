val BAREMETAL_INTERRUPT_NONE: i32 = 0
val BAREMETAL_INTERRUPT_NVIC: i32 = 1
val BAREMETAL_INTERRUPT_PLIC: i32 = 2
val BAREMETAL_INTERRUPT_APIC: i32 = 3

val BAREMETAL_VECTOR_EXCEPTION: i32 = 1
val BAREMETAL_VECTOR_EXTERNAL_IRQ: i32 = 2
val BAREMETAL_VECTOR_SOFTWARE: i32 = 3
val BAREMETAL_VECTOR_UNKNOWN: i32 = 4

class BaremetalInterruptConfig:
    controller: i32
    base_addr: u32
    vector_base: i32
    max_vectors: i32

impl BaremetalInterruptConfig:
    static fn none() -> BaremetalInterruptConfig:
        BaremetalInterruptConfig(controller: BAREMETAL_INTERRUPT_NONE, base_addr: 0u32, vector_base: 0, max_vectors: 0)

    static fn nvic(base_addr: u32) -> BaremetalInterruptConfig:
        BaremetalInterruptConfig(controller: BAREMETAL_INTERRUPT_NVIC, base_addr: base_addr, vector_base: 16, max_vectors: 240)

    static fn plic(base_addr: u32) -> BaremetalInterruptConfig:
        BaremetalInterruptConfig(controller: BAREMETAL_INTERRUPT_PLIC, base_addr: base_addr, vector_base: 1, max_vectors: 1023)

    static fn apic(base_addr: u32) -> BaremetalInterruptConfig:
        BaremetalInterruptConfig(controller: BAREMETAL_INTERRUPT_APIC, base_addr: base_addr, vector_base: 32, max_vectors: 224)

fn baremetal_interrupt_choose(arch_name: text, base_addr: u32) -> BaremetalInterruptConfig:
    if arch_name == "arm" or arch_name == "arm32" or arch_name == "cortex-m":
        return BaremetalInterruptConfig.nvic(base_addr)
    if arch_name == "riscv" or arch_name == "riscv32" or arch_name == "riscv64":
        return BaremetalInterruptConfig.plic(base_addr)
    if arch_name == "x86" or arch_name == "x86_64":
        return BaremetalInterruptConfig.apic(base_addr)
    BaremetalInterruptConfig.none()

fn baremetal_interrupt_is_enabled(config: BaremetalInterruptConfig) -> bool:
    config.controller != BAREMETAL_INTERRUPT_NONE

fn baremetal_interrupt_vector_in_range(config: BaremetalInterruptConfig, vector: i32) -> bool:
    if not baremetal_interrupt_is_enabled(config):
        return false
    vector >= config.vector_base and vector < config.vector_base + config.max_vectors

fn baremetal_interrupt_external_or_unknown(config: BaremetalInterruptConfig, vector: i32) -> i32:
    if baremetal_interrupt_vector_in_range(config, vector):
        return BAREMETAL_VECTOR_EXTERNAL_IRQ
    BAREMETAL_VECTOR_UNKNOWN

fn baremetal_interrupt_vector_kind(config: BaremetalInterruptConfig, vector: i32) -> i32:
    if config.controller == BAREMETAL_INTERRUPT_NVIC:
        if vector >= 1 and vector < 16:
            return BAREMETAL_VECTOR_EXCEPTION
        return baremetal_interrupt_external_or_unknown(config, vector)
    if config.controller == BAREMETAL_INTERRUPT_PLIC:
        if vector == 3 or vector == 7:
            return BAREMETAL_VECTOR_SOFTWARE
        return baremetal_interrupt_external_or_unknown(config, vector)
    if config.controller == BAREMETAL_INTERRUPT_APIC:
        if vector >= 0 and vector < 32:
            return BAREMETAL_VECTOR_EXCEPTION
        return baremetal_interrupt_external_or_unknown(config, vector)
    BAREMETAL_VECTOR_UNKNOWN

export BAREMETAL_INTERRUPT_APIC, BAREMETAL_INTERRUPT_NONE, BAREMETAL_INTERRUPT_NVIC, BAREMETAL_INTERRUPT_PLIC, BAREMETAL_VECTOR_EXCEPTION, BAREMETAL_VECTOR_EXTERNAL_IRQ, BAREMETAL_VECTOR_SOFTWARE, BAREMETAL_VECTOR_UNKNOWN
