#!/bin/bash
# GHDL semihost runner for the repo-native generated RV32 core.
#
# Usage:
#   ./ghdl_generated_rv32_semihost_runner.shs <binary.elf> [--timeout=30]

set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
GEN_SCRIPT="$PROJECT_ROOT/src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl"
TIMEOUT=30
BINARY=""

for arg in "$@"; do
    case "$arg" in
        --timeout=*) TIMEOUT="${arg#--timeout=}" ;;
        *) [ -z "$BINARY" ] && BINARY="$arg" ;;
    esac
done

if [ -z "$BINARY" ]; then
    echo "Usage: $0 <binary.elf> [--timeout=N]"
    exit 1
fi

if [ ! -f "$BINARY" ]; then
    echo "Error: Binary not found: $BINARY"
    exit 1
fi

if ! file "$BINARY" | grep -q "RISC-V"; then
    echo "Error: Not a RISC-V binary: $BINARY"
    exit 1
fi

TMP_DIR=$(mktemp -d /tmp/ghdl_generated_rv32_semihost_XXXXXX)
trap "rm -rf $TMP_DIR" EXIT

GEN_DIR="$TMP_DIR/generated"
TEST_BIN="$TMP_DIR/test.bin"
TEST_PKG="$TMP_DIR/test_program.vhd"

bin/simple run "$GEN_SCRIPT" -- "$GEN_DIR" >/dev/null
RTL_DIR="$GEN_DIR/rv32/rtl"
riscv64-linux-gnu-objcopy -O binary "$BINARY" "$TEST_BIN"

python3 -c "
import struct
data = open('$TEST_BIN', 'rb').read()
while len(data) % 4 != 0: data += b'\x00'
words = [struct.unpack('<I', data[i:i+4])[0] for i in range(0, len(data), 4)]
print('library ieee;')
print('use ieee.std_logic_1164.all;')
print('package test_program is')
print('    type word_array_t is array (natural range <>) of std_logic_vector(31 downto 0);')
print('    constant PROGRAM_SIZE : integer := %d;' % len(words))
print('    constant PROGRAM_DATA : word_array_t(0 to %d) := (' % (len(words)-1))
for i, w in enumerate(words):
    comma = ',' if i < len(words)-1 else ''
    print('        x\"%08x\"%s' % (w, comma))
print('    );')
print('end package test_program;')
" > "$TEST_PKG"

cd "$TMP_DIR"
ghdl -a --std=08 \
    "$RTL_DIR/rv32i_pkg.vhd" \
    "$GEN_DIR/rv32/rtl/simple_rv32i_core_pkg.vhd" \
    "$GEN_DIR/rv32/rtl/simple_rv32gc_core.vhd" \
    "$RTL_DIR/rv32i_generated_wrapper.vhd" \
    "$TEST_PKG" \
    "$RTL_DIR/tb_semi_run.vhd"
ghdl -e --std=08 tb_semi_run

STOP_MS=$((TIMEOUT * 1000))
OUTPUT=$(timeout "$TIMEOUT" ghdl -r --std=08 tb_semi_run --stop-time="${STOP_MS}ms" 2>&1) || EXIT_STATUS=$?
EXIT_STATUS=${EXIT_STATUS:-0}

SEMI_OUTPUT=$(echo "$OUTPUT" | grep "OUTPUT:" | sed 's/.*OUTPUT: //' || true)
EXIT_CODE=$(echo "$OUTPUT" | grep "EXIT_CODE:" | grep -oP 'EXIT_CODE: \K[0-9-]+' || echo "-1")
CYCLES=$(echo "$OUTPUT" | grep "CYCLES:" | grep -oP 'CYCLES: \K[0-9]+' || echo "0")

if [ -n "$SEMI_OUTPUT" ]; then
    echo "$SEMI_OUTPUT"
fi

echo ""
echo "----------------------------------------"
echo "[GHDL-GEN-SEMI] Cycles: $CYCLES"

if [ "$EXIT_STATUS" = "124" ]; then
    echo "[GHDL-GEN-SEMI] TIMEOUT after ${TIMEOUT}s"
    exit 124
elif [ "$EXIT_CODE" = "0" ]; then
    echo "[GHDL-GEN-SEMI] Test PASSED (exit code 0)"
    exit 0
elif [ "$EXIT_CODE" -gt "0" ] 2>/dev/null; then
    echo "[GHDL-GEN-SEMI] Test FAILED (exit code $EXIT_CODE)"
    exit 1
else
    echo "[GHDL-GEN-SEMI] Test completed (no SYS_EXIT detected)"
    exit 0
fi
