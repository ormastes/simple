# @platform: baremetal
#
# Bare-Metal String Extraction
#
# Freestanding string utilities for fixed-size byte buffers.
# No heap allocation — all operations work on [i64] buffers in-place.
#
# Bytes are represented as i64 values (matching the baremetal memory model).
#
# Functions:
# - bytes_equal:        compare two byte slices for equality
# - bytes_find:         find first occurrence of a pattern in a buffer
# - bytes_copy_slice:   copy a slice into an output buffer (extract substring)
# - parse_dec:          parse unsigned decimal integer from byte slice
# - parse_hex:          parse unsigned hex integer from byte slice


# Compare two byte slices for equality.
# Returns true iff buf_a[a_off..a_off+len] == buf_b[b_off..b_off+len].
fn bytes_equal(buf_a: [i64], a_off: i64, buf_b: [i64], b_off: i64, len: i64) -> bool:
    """Return true if the two byte slices of length len are equal."""
    if len <= 0:
        return true
    val a_end = a_off + len
    val b_size = buf_b.len()
    val a_size = buf_a.len()
    if a_end > a_size:
        return false
    if b_off + len > b_size:
        return false
    var i: i64 = 0
    var matched = true
    while i < len and matched:
        if (buf_a[a_off + i] & 0xFF) != (buf_b[b_off + i] & 0xFF):
            matched = false
        i = i + 1
    matched


# Find the first occurrence of pattern in buf starting at start.
# Returns the byte offset of the match, or -1 if not found.
# Searches buf[start..buf_len) for pattern[0..pat_len).
fn bytes_find(buf: [i64], buf_start: i64, buf_len: i64, pat: [i64], pat_len: i64) -> i64:
    """Return offset of first match of pat in buf[buf_start..buf_len), or -1."""
    if pat_len <= 0:
        return buf_start
    if pat_len > buf_len - buf_start:
        return -1
    val limit = buf_len - pat_len
    var i = buf_start
    var found: i64 = -1
    while i <= limit and found == -1:
        if bytes_equal(buf, i, pat, 0, pat_len):
            found = i
        i = i + 1
    found


# Copy a slice of src into dst, writing at most dst_cap bytes.
# src_off and src_len define the source region.
# Returns the number of bytes actually written (min of src_len and dst_cap).
fn bytes_copy_slice(src: [i64], src_off: i64, src_len: i64, dst: [i64], dst_cap: i64) -> i64:
    """Copy src[src_off..src_off+src_len] into dst[0..], return bytes written."""
    var count: i64 = src_len
    if dst_cap < count:
        count = dst_cap
    val src_size = src.len()
    if src_off + count > src_size:
        count = src_size - src_off
    if count <= 0:
        return 0
    var i: i64 = 0
    while i < count:
        dst[i] = src[src_off + i] & 0xFF
        i = i + 1
    count


# Parse an unsigned decimal integer from buf[off..off+len).
# Stops at the first non-digit byte.
# Returns the parsed value (0 if no digits found).
fn parse_dec(buf: [i64], off: i64, len: i64) -> i64:
    """Parse unsigned decimal integer from byte slice; stop at non-digit."""
    var result: i64 = 0
    var i: i64 = 0
    var running = true
    while i < len and running:
        val b = buf[off + i] & 0xFF
        # ASCII '0' = 0x30, '9' = 0x39
        if b >= 0x30 and b <= 0x39:
            result = result * 10 + (b - 0x30)
        else:
            running = false
        i = i + 1
    result


# Parse an unsigned hex integer from buf[off..off+len).
# Accepts digits 0-9, a-f, A-F. Optional leading "0x" or "0X" is skipped.
# Stops at the first non-hex byte.
# Returns the parsed value (0 if no hex digits found).
fn parse_hex(buf: [i64], off: i64, len: i64) -> i64:
    """Parse unsigned hex integer from byte slice; skip optional 0x prefix."""
    var result: i64 = 0
    var i: i64 = 0
    var running = true

    # Skip optional "0x" / "0X" prefix
    if len >= 2:
        val b0 = buf[off] & 0xFF
        val b1 = buf[off + 1] & 0xFF
        if b0 == 0x30 and (b1 == 0x78 or b1 == 0x58):
            i = 2

    while i < len and running:
        val b = buf[off + i] & 0xFF
        var digit: i64 = -1
        if b >= 0x30 and b <= 0x39:
            digit = b - 0x30
        else if b >= 0x41 and b <= 0x46:
            # 'A'..'F'
            digit = b - 0x41 + 10
        else if b >= 0x61 and b <= 0x66:
            # 'a'..'f'
            digit = b - 0x61 + 10
        if digit >= 0:
            result = (result << 4) | digit
        else:
            running = false
        i = i + 1
    result
