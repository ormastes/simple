# SCV network remote transport.
#
# Wraps the filesystem public-remote layer with:
#   - SSRF / origin validation on pack_url fields in refs.sdn
#   - public_ready gate enforcement before push
#   - CAS (compare-and-swap) refs update with conflict detection
#   - Auth header injection (Token / OAuth2 / SigV4 stubs)
#   - Resumable upload/download stubs (chunk_bytes path)
#
# The "network" commands accept a base_url parameter for SSRF checking.
# For loopback http:// URLs the filesystem remote_dir is used directly
# (tests run without a real HTTP server).  HTTPS targets would route
# through http_client in a future network-layer extension.

use app.io.mod (file_exists, file_read, file_write, file_delete, dir_create)
use std.scv.store.{scv_repo_exists, scv_read_workspace_commit, scv_commit_state, scv_write_text, scv_restore_op}
use std.scv.core.{scv_state_public_ready, scv_metadata_path_safe}
use std.scv.integrity.{scv_fsck}
use std.scv.fast_import.{scv_import_git_fast_import}
use std.scv.public_remote.{scv_public_export, scv_public_export_verify, scv_public_push_verify, scv_remote_refs_update, scv_public_push_ref_line, scv_public_manifest_matches_imported_tree, scv_public_branch_safe, scv_public_result_token_value}

# ---------------------------------------------------------------------------
# SSRF guard
# ---------------------------------------------------------------------------

fn scv_net_url_scheme(url: text) -> text:
    val colon = url.index_of(":")
    if colon < 0:
        return ""
    url[0:colon].lower()

fn scv_net_url_host(url: text) -> text:
    # strip scheme://
    var s = url
    val scheme_end = url.index_of("://")
    if scheme_end >= 0:
        s = url[scheme_end + 3:]
    # strip path/query/fragment
    var host_end = s.len()
    var i = 0
    while i < s.len():
        val c = s[i:i+1]
        if c == "/" or c == "?" or c == "#":
            host_end = i
            break
        i = i + 1
    # strip port
    val host_part = s[0:host_end]
    val port_colon = host_part.index_of(":")
    if port_colon >= 0:
        return host_part[0:port_colon].lower()
    host_part.lower()

fn scv_net_url_port(url: text) -> text:
    var s = url
    val scheme_end = url.index_of("://")
    if scheme_end >= 0:
        s = url[scheme_end + 3:]
    var host_end = s.len()
    var i = 0
    while i < s.len():
        val c = s[i:i+1]
        if c == "/" or c == "?" or c == "#":
            host_end = i
            break
        i = i + 1
    val host_part = s[0:host_end]
    val port_colon = host_part.index_of(":")
    if port_colon >= 0:
        return host_part[port_colon + 1:]
    ""

fn scv_net_is_rfc1918_or_loopback(host: text) -> bool:
    if host == "localhost":
        return true
    if host == "::1":
        return true
    if host.starts_with("127."):
        return true
    if host.starts_with("10."):
        return true
    if host.starts_with("192.168."):
        return true
    # 172.16.0.0/12 — 172.16.x.x through 172.31.x.x
    if host.starts_with("172."):
        val rest = host[4:]
        val dot = rest.index_of(".")
        if dot >= 0:
            val octet = rest[0:dot].to_i64() ?? -1
            if octet >= 16 and octet <= 31:
                return true
    if host.starts_with("fc") or host.starts_with("fd"):
        return true
    false

# Returns "" on success, or an error message starting with "ERROR ssrf".
fn scv_ssrf_origin_check(base_url: text, target_url: text) -> text:
    val base_scheme = scv_net_url_scheme(base_url)
    val target_scheme = scv_net_url_scheme(target_url)
    if base_scheme != target_scheme:
        return "ERROR ssrf scheme mismatch: {target_url}\n"
    val base_host = scv_net_url_host(base_url)
    val target_host = scv_net_url_host(target_url)
    if base_host != target_host:
        return "ERROR ssrf host mismatch: {target_url}\n"
    val base_port = scv_net_url_port(base_url)
    val target_port = scv_net_url_port(target_url)
    if base_port != "" and target_port != "" and base_port != target_port:
        return "ERROR ssrf port mismatch: {target_url}\n"
    # Reject RFC1918/loopback hosts unless base_url itself is loopback
    if scv_net_is_rfc1918_or_loopback(target_host):
        if not scv_net_is_rfc1918_or_loopback(base_host):
            return "ERROR ssrf rfc1918 target rejected: {target_url}\n"
    ""

# Parse a refs.sdn branch line and SSRF-check its pack_url field.
# Format: branch|commit|pack_url_or_artifact_dir
# Returns "" on success or "ERROR ssrf ..." message.
fn scv_validate_refs_response(base_url: text, refs_body: text) -> text:
    for line in refs_body.split("\n"):
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("format:") or trimmed.starts_with("#"):
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 3:
            val pack_url = parts[2]
            # Only SSRF-check entries that look like URLs
            if pack_url.starts_with("http://") or pack_url.starts_with("https://"):
                val check = scv_ssrf_origin_check(base_url, pack_url)
                if check.starts_with("ERROR"):
                    return check
    ""

# ---------------------------------------------------------------------------
# Auth helpers (stubs — real OAuth2/SigV4 wiring is an extension point)
# ---------------------------------------------------------------------------

fn scv_auth_token(header_name: text, token: text) -> text:
    "auth:token header={header_name} token={token}"

fn scv_auth_oauth2(client_id: text, client_secret: text, token_url: text) -> text:
    "auth:oauth2 client_id={client_id} token_url={token_url}"

fn scv_auth_sigv4(access_key: text, secret_key: text, region: text) -> text:
    "auth:sigv4 key={access_key} region={region}"

# Parse an auth config string into an Authorization-style header value.
# Used by push to annotate the output (actual header injection is a stub here).
fn scv_net_auth_header_value(auth_config: text) -> text:
    if auth_config.starts_with("auth:token"):
        for part in auth_config.split(" "):
            val trimmed = part.trim()
            if trimmed.starts_with("token="):
                return "Bearer {trimmed[6:]}"
    ""

# ---------------------------------------------------------------------------
# Loopback URL validation for test / CI use
# ---------------------------------------------------------------------------

fn scv_net_is_loopback_url(url: text) -> bool:
    val host = scv_net_url_host(url)
    host == "127.0.0.1" or host == "::1" or host == "localhost"

fn scv_net_validate_base_url(base_url: text) -> text:
    val scheme = scv_net_url_scheme(base_url)
    if scheme == "https":
        return ""
    if scheme == "http":
        if scv_net_is_loopback_url(base_url):
            return ""
        return "ERROR https required for non-loopback remote\n"
    "ERROR network remote requires http:// or https:// URL\n"

# ---------------------------------------------------------------------------
# CAS refs update (compare-and-swap)
# ---------------------------------------------------------------------------

# Read the current commit for a branch from refs.sdn.
fn scv_net_refs_current_commit(remote_dir: text, branch: text) -> text:
    val refs_path = "{remote_dir}/refs.sdn"
    if not file_exists(refs_path):
        return ""
    val refs = file_read(refs_path)
    for line in refs.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("{branch}|"):
            val parts = trimmed.split("|")
            if parts.len() >= 2:
                return parts[1]
    ""

# CAS update: only advance if current commit matches old_etag (or old_etag is "").
# Returns "" on success, "ERROR cas-conflict ..." on mismatch.
fn scv_net_cas_refs_update(remote_dir: text, branch: text, old_etag: text, new_commit: text, artifact_dir: text) -> text:
    val current = scv_net_refs_current_commit(remote_dir, branch)
    if old_etag != "" and current != old_etag:
        return "ERROR conflict: remote advanced, pull first (branch={branch} expected={old_etag} got={current})\n"
    val next_refs = scv_remote_refs_update(remote_dir, branch, new_commit, artifact_dir)
    scv_write_text("{remote_dir}/refs.sdn", next_refs)
    ""

# ---------------------------------------------------------------------------
# Network push
# ---------------------------------------------------------------------------

fn scv_network_push(base_url: text, remote_dir: text, branch: text) -> text:
    val url_check = scv_net_validate_base_url(base_url)
    if url_check.starts_with("ERROR"):
        return url_check
    if not scv_repo_exists("."):
        return "ERROR repository not initialized\n"
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe network branch name\n"
    val commit = scv_read_workspace_commit(".")
    if commit == "":
        return "ERROR no current commit\n"
    val state = scv_commit_state(".", commit)
    if state != scv_state_public_ready():
        return "ERROR public_ready gate not set\n"
    val fsck = scv_fsck(".")
    if not fsck.starts_with("OK"):
        return fsck
    dir_create(remote_dir, true)
    val artifact_dir = "{remote_dir}/branches/{branch}"
    val export_result = scv_public_export(".", artifact_dir, branch)
    if export_result.starts_with("ERROR"):
        return export_result
    val verify_result = scv_public_export_verify(artifact_dir)
    if verify_result.starts_with("ERROR"):
        return verify_result
    val refs_result = scv_net_cas_refs_update(remote_dir, branch, "", commit, artifact_dir)
    if refs_result.starts_with("ERROR"):
        return refs_result
    "network-push {base_url} {remote_dir} branch={branch} commit={commit}\n{fsck}"

# ---------------------------------------------------------------------------
# Network push CAS (explicit old_etag)
# ---------------------------------------------------------------------------

fn scv_network_push_cas(base_url: text, remote_dir: text, branch: text, old_etag: text) -> text:
    val url_check = scv_net_validate_base_url(base_url)
    if url_check.starts_with("ERROR"):
        return url_check
    if not scv_repo_exists("."):
        return "ERROR repository not initialized\n"
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe network branch name\n"
    val commit = scv_read_workspace_commit(".")
    if commit == "":
        return "ERROR no current commit\n"
    val state = scv_commit_state(".", commit)
    if state != scv_state_public_ready():
        return "ERROR public_ready gate not set\n"
    val fsck = scv_fsck(".")
    if not fsck.starts_with("OK"):
        return fsck
    dir_create(remote_dir, true)
    val artifact_dir = "{remote_dir}/branches/{branch}"
    val export_result = scv_public_export(".", artifact_dir, branch)
    if export_result.starts_with("ERROR"):
        return export_result
    val verify_result = scv_public_export_verify(artifact_dir)
    if verify_result.starts_with("ERROR"):
        return verify_result
    val refs_result = scv_net_cas_refs_update(remote_dir, branch, old_etag, commit, artifact_dir)
    if refs_result.starts_with("ERROR"):
        return refs_result
    "network-push-cas {base_url} {remote_dir} branch={branch} commit={commit}\n{fsck}"

# ---------------------------------------------------------------------------
# Network push verify
# ---------------------------------------------------------------------------

fn scv_network_push_verify(remote_dir: text, branch: text) -> text:
    val verify = scv_public_push_verify(remote_dir, branch)
    if verify.starts_with("ERROR"):
        return verify
    "network-push-verify {remote_dir} branch={branch} fsck ok\n"

# ---------------------------------------------------------------------------
# Network pull
# ---------------------------------------------------------------------------

fn scv_network_pull(base_url: text, remote_dir: text, branch: text) -> text:
    val url_check = scv_net_validate_base_url(base_url)
    if url_check.starts_with("ERROR"):
        return url_check
    if not scv_repo_exists("."):
        return "ERROR repository not initialized\n"
    if not scv_public_branch_safe(branch):
        return "ERROR unsafe network branch name\n"
    # Validate refs.sdn for SSRF before using it
    val refs_path = "{remote_dir}/refs.sdn"
    if not file_exists(refs_path):
        return "ERROR network-pull refs.sdn not found at {remote_dir}\n"
    val refs_body = file_read(refs_path)
    val ssrf_check = scv_validate_refs_response(base_url, refs_body)
    if ssrf_check.starts_with("ERROR"):
        return ssrf_check
    # Use public_push_verify to validate the remote artifact integrity
    val verify = scv_public_push_verify(remote_dir, branch)
    if verify.starts_with("ERROR"):
        return verify
    val ref_line = scv_public_push_ref_line(remote_dir, branch)
    val parts = ref_line.split("|")
    if parts.len() != 3:
        return "ERROR corrupt network remote ref\n"
    val remote_commit = parts[1]
    val artifact_dir = parts[2]
    val import_result = scv_import_git_fast_import(".", "{artifact_dir}/export.fi")
    if import_result.starts_with("ERROR"):
        return import_result
    val imported_commit = scv_public_result_token_value(import_result, "commit=")
    if imported_commit == "":
        return "ERROR network-pull missing imported commit\n"
    if not scv_public_manifest_matches_imported_tree(".", artifact_dir, imported_commit):
        return "ERROR network-pull manifest does not match imported commit\n"
    val op = scv_public_result_token_value(import_result, "op=")
    if op == "":
        return "ERROR network-pull missing imported operation\n"
    val restore = scv_restore_op(".", op)
    if restore.starts_with("ERROR"):
        return restore
    val fsck = scv_fsck(".")
    if not fsck.starts_with("OK"):
        return fsck
    "network-pull {base_url} {remote_dir} branch={branch} remote_commit={remote_commit}\n{import_result}{fsck}"

# ---------------------------------------------------------------------------
# Resumable upload stub
# ---------------------------------------------------------------------------

fn scv_resumable_upload(remote_dir: text, pack_path: text) -> text:
    if not file_exists(pack_path):
        return "ERROR resumable-upload pack not found: {pack_path}\n"
    "resumable-upload pack={pack_path} remote={remote_dir}\n"

# ---------------------------------------------------------------------------
# Resumable download stub
# ---------------------------------------------------------------------------

fn scv_resumable_download(base_url: text, pack_url: text, out_path: text) -> text:
    val ssrf = scv_ssrf_origin_check(base_url, pack_url)
    if ssrf.starts_with("ERROR"):
        return ssrf
    "resumable-download pack_url={pack_url} out={out_path}\n"

# ---------------------------------------------------------------------------
# Auth config set-auth (CLI helper — stores auth config as text)
# ---------------------------------------------------------------------------

fn scv_network_config_set_auth(kind: text, header_name: text, token_val: text) -> text:
    if kind == "token":
        val cfg = scv_auth_token(header_name, token_val)
        return "network-config set-auth {cfg}\n"
    "ERROR network-config unknown auth kind: {kind}\n"

# ---------------------------------------------------------------------------
# TLS config
# ---------------------------------------------------------------------------

fn scv_network_config_set_tls_no_verify(base_url: text) -> text:
    val host = scv_net_url_host(base_url)
    if scv_net_is_rfc1918_or_loopback(host):
        return "network-config set-tls-no-verify base_url={base_url}\n"
    "ERROR tls_verify=false only permitted for loopback\n"

# ---------------------------------------------------------------------------
# Partial download simulation and discard (for resumable-download support)
# ---------------------------------------------------------------------------

fn scv_network_pull_simulate_interrupt(base_url: text, remote_dir: text, branch: text) -> text:
    val url_check = scv_net_validate_base_url(base_url)
    if url_check.starts_with("ERROR"):
        return url_check
    val tmp_dir = ".scv/tmp"
    dir_create(tmp_dir, true)
    val partial_path = "{tmp_dir}/{branch}.partial"
    scv_write_text(partial_path, "partial\n")
    "network-pull-simulate-interrupt branch={branch} partial={partial_path}\n"

fn scv_network_pull_discard(remote_dir: text, branch: text) -> text:
    val tmp_dir = ".scv/tmp"
    val partial_path = "{tmp_dir}/{branch}.partial"
    if file_exists(partial_path):
        file_delete(partial_path)
    "network-pull-discard branch={branch}\n"

# ---------------------------------------------------------------------------
# Chunked network push (chunk_bytes variant — same result, flag accepted)
# ---------------------------------------------------------------------------

fn scv_network_push_chunked(base_url: text, remote_dir: text, branch: text, chunk_bytes: i64) -> text:
    # chunk_bytes is accepted but the filesystem transport writes whole artifacts;
    # the resumable-upload path is a stub.  Delegate to whole-pack push.
    scv_network_push(base_url, remote_dir, branch)
