# SCV commit gates.

use app.io.mod (process_run)
use std.scv.core.{scv_state_compile_ok, scv_state_test_ok, scv_state_public_ready}
use std.scv.store.{scv_mark_current_state, scv_read_workspace_commit, scv_commit_state}

fn scv_compile_gate(root: text, cmd: text) -> text:
    val (_out, _err, code) = process_run("/bin/sh", ["-c", cmd])
    if code == 0:
        scv_mark_current_state(root, scv_state_compile_ok())
    else:
        "compile_failed\n"

fn scv_test_gate(root: text, cmd: text) -> text:
    val (_out, _err, code) = process_run("/bin/sh", ["-c", cmd])
    if code == 0:
        scv_mark_current_state(root, scv_state_test_ok())
    else:
        "test_failed\n"

fn scv_public_ready(root: text) -> text:
    val commit = scv_read_workspace_commit(root)
    val state = scv_commit_state(root, commit)
    if state == scv_state_test_ok() or state == scv_state_public_ready():
        scv_mark_current_state(root, scv_state_public_ready())
    else:
        "ERROR current commit is not test_ok\n"
