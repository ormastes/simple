# PaintChunk — grouped drawing unit sharing transform/clip/effect state.
#
# Mirrors Blink's PaintChunk: consecutive display-list items that share the
# same PropertyTreeState (transform id + clip id + effect id). Chunks batch
# items to minimize property-tree switches during paint.

use std.lib.skia.entity.geometry.{SkRect, sk_rect}

# ============================================================================
# PropertyTreeState
# ============================================================================
#
# Identifies a chunk's position in the four property trees. All ids = -1
# means the root of each tree (no transform, no clip, no effect, no scroll).

class PropertyTreeState:
    transform_id: i64
    clip_id: i64
    effect_id: i64
    scroll_id: i64

fn property_tree_state_root() -> PropertyTreeState:
    PropertyTreeState(
        transform_id: -1,
        clip_id: -1,
        effect_id: -1,
        scroll_id: -1
    )

# ============================================================================
# PaintChunkId
# ============================================================================
#
# Stable identifier for a chunk, combining the owning DOM node and a
# display-item index within that node's paint output.

class PaintChunkId:
    owner_node_id: i64
    display_item_index: i64

# ============================================================================
# PaintChunk
# ============================================================================
#
# A half-open [begin_index, end_index) range of DisplayItems in the parent
# PaintArtifact, all sharing the same PropertyTreeState.

class PaintChunk:
    begin_index: i64
    end_index: i64
    id: PaintChunkId
    property_state: PropertyTreeState
    bounds: SkRect
    is_cacheable: bool
    outset_for_raster_effects: f64

fn paint_chunk_new(
    begin: i64,
    end: i64,
    id: PaintChunkId,
    state: PropertyTreeState,
    bounds: SkRect
) -> PaintChunk:
    PaintChunk(
        begin_index: begin,
        end_index: end,
        id: id,
        property_state: state,
        bounds: bounds,
        is_cacheable: true,
        outset_for_raster_effects: 0.0
    )

impl PaintChunk:
    me size() -> i64:
        self.end_index - self.begin_index

    me is_empty() -> bool:
        self.size() == 0

    me overlaps(other: PaintChunk) -> bool:
        self.bounds.left < other.bounds.right and
        self.bounds.right > other.bounds.left and
        self.bounds.top < other.bounds.bottom and
        self.bounds.bottom > other.bounds.top

    me has_same_property_state(other: PaintChunk) -> bool:
        self.property_state.transform_id == other.property_state.transform_id and
        self.property_state.clip_id == other.property_state.clip_id and
        self.property_state.effect_id == other.property_state.effect_id and
        self.property_state.scroll_id == other.property_state.scroll_id
