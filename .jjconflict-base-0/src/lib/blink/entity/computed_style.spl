# ComputedStyle — resolved CSS properties for a DOM element after cascade.
#
# Mirrors Blink's ComputedStyle. Stores the fully-resolved final values of
# every CSS property that matters for layout + paint. This is a stub — just
# the most important 15-20 properties; full ComputedStyle has 300+.

use std.lib.skia.entity.color.{SkColor4f, sk_color4f}

# ============================================================================
# Enums — CSS property value keywords
# ============================================================================

enum Display:
    None
    Block
    Inline
    Flex
    Grid
    InlineBlock
    Table

enum Position:
    Static
    Relative
    Absolute
    Fixed
    Sticky

enum Overflow:
    Visible
    Hidden
    Scroll
    Auto

enum Visibility:
    Visible
    Hidden
    Collapse

enum TextAlign:
    Start
    End
    Left
    Right
    Center
    Justify

# ============================================================================
# Length — a CSS length value (value + unit)
# ============================================================================

class Length:
    value: f64
    unit: String

# ============================================================================
# ComputedStyle — resolved style for a DOM element
# ============================================================================

class ComputedStyle:
    display: Display
    position: Position
    overflow_x: Overflow
    overflow_y: Overflow
    visibility: Visibility
    text_align: TextAlign
    color: SkColor4f
    background_color: SkColor4f
    width: Length
    height: Length
    margin_top: Length
    margin_right: Length
    margin_bottom: Length
    margin_left: Length
    padding_top: Length
    padding_right: Length
    padding_bottom: Length
    padding_left: Length
    font_size: f64
    font_weight: i64
    opacity: f64
    z_index: i64

# ============================================================================
# Default factory — the initial value of every CSS property
# ============================================================================

fn computed_style_default() -> ComputedStyle:
    val zero_px = Length(value: 0.0, unit: "px")
    val black = sk_color4f(0.0, 0.0, 0.0, 1.0)
    val transparent = sk_color4f(0.0, 0.0, 0.0, 0.0)
    ComputedStyle(
        display: Display.Inline,
        position: Position.Static,
        overflow_x: Overflow.Visible,
        overflow_y: Overflow.Visible,
        visibility: Visibility.Visible,
        text_align: TextAlign.Start,
        color: black,
        background_color: transparent,
        width: zero_px,
        height: zero_px,
        margin_top: zero_px,
        margin_right: zero_px,
        margin_bottom: zero_px,
        margin_left: zero_px,
        padding_top: zero_px,
        padding_right: zero_px,
        padding_bottom: zero_px,
        padding_left: zero_px,
        font_size: 16.0,
        font_weight: 400,
        opacity: 1.0,
        z_index: 0
    )

# ============================================================================
# Methods on ComputedStyle
# ============================================================================

impl ComputedStyle:
    fn is_visible() -> bool:
        val visible_keyword = self.visibility == Visibility.Visible
        val not_display_none = self.display != Display.None
        val has_opacity = self.opacity > 0.0
        visible_keyword && not_display_none && has_opacity

    fn is_positioned() -> bool:
        self.position != Position.Static

    fn total_margin_horizontal() -> f64:
        self.margin_left.value + self.margin_right.value

    fn is_block_level() -> bool:
        val d = self.display
        d == Display.Block || d == Display.Flex || d == Display.Grid || d == Display.Table
