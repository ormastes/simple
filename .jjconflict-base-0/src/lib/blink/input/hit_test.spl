# Hit testing — maps a 2D point to the topmost LayoutBox containing it.
#
# Mirrors Blink's EventHandler::HitTestResultAtLocation. Walks the layout
# tree depth-first from root, returning the deepest (innermost) box whose
# computed_rect contains the hit point.
#
# Scope: opaque hit testing — no pointer-events:none, no CSS transforms,
# no stacking context z-order. Transform-aware / z-order hit testing is a
# future extension.

use std.lib.skia.entity.geometry.{SkRect}
use std.lib.blink.layout.block_flow.{LayoutBox, LayoutContext}
use std.lib.blink.input.event.{InputEvent, EventType}

# ============================================================================
# HitTestResult — outcome of a hit test query
# ============================================================================

class HitTestResult:
    hit_box_id: i64
    local_x: f64
    local_y: f64

# ============================================================================
# Free constructors
# ============================================================================

fn hit_test_empty() -> HitTestResult:
    HitTestResult(hit_box_id: -1, local_x: 0.0, local_y: 0.0)

# ============================================================================
# point_in_rect — primitive containment test
#
# Returns true iff (x, y) lies within rect using half-open intervals:
#   left <= x < right  and  top <= y < bottom
# ============================================================================

fn point_in_rect(rect: SkRect, x: f64, y: f64) -> bool:
    x >= rect.left and x < rect.right and y >= rect.top and y < rect.bottom

# ============================================================================
# _hit_test_node — recursive depth-first walk
#
# Checks box `id` and its descendants. Returns the id of the deepest box
# that contains (x, y), or -1 if none does.
# ============================================================================

fn _hit_test_node(ctx: LayoutContext, id: i64, x: f64, y: f64) -> i64:
    val opt = ctx.get_box(id)
    if opt is None:
        -1
    else:
        val box = opt.unwrap()
        if not point_in_rect(box.computed_rect, x, y):
            -1
        else:
            # This box contains the point. Now check children depth-first.
            # The last child that contains the point is the innermost winner
            # (children drawn later sit on top).
            val deepest = id
            val c = 0
            val child_count = box.children_ids.len()
            while c < child_count:
                val child_id = box.children_ids[c]
                val child_hit = _hit_test_node(ctx, child_id, x, y)
                if child_hit != -1:
                    deepest = child_hit
                c = c + 1
            deepest

# ============================================================================
# hit_test — main entry point
#
# Walks the layout tree rooted at ctx.root_id, returning the deepest
# LayoutBox whose computed_rect contains (x, y).  If the root_id is -1 or
# no box contains the point, returns hit_test_empty().
# ============================================================================

fn hit_test(ctx: LayoutContext, x: f64, y: f64) -> HitTestResult:
    if ctx.root_id == -1:
        hit_test_empty()
    else:
        val hit_id = _hit_test_node(ctx, ctx.root_id, x, y)
        if hit_id == -1:
            hit_test_empty()
        else:
            val opt = ctx.get_box(hit_id)
            if opt is None:
                hit_test_empty()
            else:
                val box = opt.unwrap()
                val lx = x - box.computed_rect.left
                val ly = y - box.computed_rect.top
                HitTestResult(hit_box_id: hit_id, local_x: lx, local_y: ly)

# ============================================================================
# hit_test_event — convenience wrapper for InputEvent
#
# For pointer events (mouse / touch / wheel) extracts the position and
# delegates to hit_test.  For non-position events (keyboard, focus/blur)
# returns hit_test_empty() because there is no meaningful 2D coordinate.
# ============================================================================

fn hit_test_event(ctx: LayoutContext, event: InputEvent) -> HitTestResult:
    val is_pointer = event.is_mouse() or event.is_touch()
        or event.event_type == EventType.MouseWheel
    if not is_pointer:
        hit_test_empty()
    else:
        hit_test(ctx, event.position.x, event.position.y)

# ============================================================================
# hit_test_ancestors — ancestor chain for event bubbling
#
# Returns [parent_id, grandparent_id, ..., root_id] of box_id.
# Useful for dispatching bubbling events from the hit target up to the root.
# If box_id is the root or is not found, returns an empty list.
# ============================================================================

fn hit_test_ancestors(ctx: LayoutContext, box_id: i64) -> [i64]:
    val result: [i64] = []
    val current = box_id
    val found = true
    while found:
        val parent_id = -1
        val i = 0
        val len = ctx.boxes.len()
        while i < len:
            val c2 = 0
            val child_count = ctx.boxes[i].children_ids.len()
            while c2 < child_count:
                if ctx.boxes[i].children_ids[c2] == current:
                    parent_id = ctx.boxes[i].id
                c2 = c2 + 1
            i = i + 1
        if parent_id == -1:
            found = false
        else:
            result.push(parent_id)
            current = parent_id
    result
