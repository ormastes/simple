# Interaction state — tracks which DOM node is currently hovered / focused.
#
# Used by the style cascade to resolve pseudo-class selectors (`:hover`,
# `:focus`). The browser's input pipeline updates this state in response to
# pointer and keyboard events; the renderer re-runs the cascade with the new
# state to restyle affected elements.
#
# Sentinel `-1` means "no node in this interaction state".

# ============================================================================
# InteractionState — pair of node ids for the two tracked pseudo-classes
# ============================================================================

class InteractionState:
    hovered_id: i64    # -1 = no hover
    focused_id: i64    # -1 = no focus

# ============================================================================
# Constructors
# ============================================================================

fn interaction_state_empty() -> InteractionState:
    InteractionState(hovered_id: -1, focused_id: -1)

fn interaction_state_with_hover(id: i64) -> InteractionState:
    InteractionState(hovered_id: id, focused_id: -1)

fn interaction_state_with_focus(id: i64) -> InteractionState:
    InteractionState(hovered_id: -1, focused_id: id)
