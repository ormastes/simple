# HTML tokenizer — subset of the WHATWG HTML tokenization state machine.
#
# Produces a token stream for the HTML tree builder. Supports:
#   - Character/text data
#   - Start tag with attributes (no quoting escapes beyond basic " and ')
#   - End tag
#   - Comment <!-- ... -->
#   - DOCTYPE
#
# Out of scope: CDATA, script/style special tokenization, &nbsp-style entities,
# malformed markup recovery beyond simple skip.

# ============================================================================
# HtmlTokenKind — variant tag for each HTML token class.
# ============================================================================

enum HtmlTokenKind:
    Character
    StartTag
    EndTag
    Comment
    Doctype
    Eof

# ============================================================================
# HtmlAttribute — one attribute on a start tag.
# ============================================================================

class HtmlAttribute:
    name: String
    value: String

# ============================================================================
# HtmlToken — one emitted token. Fields are populated per kind:
#   - Character:  `data` holds the run of text
#   - StartTag:   `name`, `attributes`, `self_closing`
#   - EndTag:     `name`
#   - Comment:    `data` holds the comment body
#   - Doctype:    `name` holds the DOCTYPE name (e.g. "html")
#   - Eof:        all fields empty
# ============================================================================

class HtmlToken:
    kind: HtmlTokenKind
    name: String
    data: String
    attributes: [HtmlAttribute]
    self_closing: bool

# ============================================================================
# Character classification helpers.
#
# WHY ASCII-only: tag/attribute names in the HTML spec are ASCII. Character
# data and attribute values may contain UTF-8 but we treat them as opaque
# byte runs — no decoding needed at the tokenizer layer.
# ============================================================================

fn _is_alpha(c: i64) -> bool:
    # a-z, A-Z
    val lower = c >= 97 and c <= 122
    val upper = c >= 65 and c <= 90
    lower or upper

fn _is_whitespace(c: i64) -> bool:
    # space, tab, CR, LF, form-feed
    c == 32 or c == 9 or c == 13 or c == 10 or c == 12

# ============================================================================
# _peek — safe byte fetch, returns -1 on out-of-range.
#
# WHY -1 sentinel: keeps callers free of Option<u8> match-nesting at every
# lookahead site. -1 is outside u8 range so it cannot collide with any real
# byte, and classification helpers treat it as "not a match".
# ============================================================================

fn _peek(source: String, pos: i64) -> i64:
    val bytes = source.bytes()
    if pos < 0 or pos >= bytes.length():
        return -1
    val opt = bytes.at(pos)
    match opt:
        Some(v):
            v as i64
        None:
            -1

# ============================================================================
# _slice — substring helper. Thin wrapper so we can swap storage later.
# ============================================================================

fn _slice(source: String, start: i64, end: i64) -> String:
    source[start:end]

# ============================================================================
# tokenize_html — main entry point.
#
# Produces a token list terminated by a single HtmlToken(kind: Eof, ...).
# Walks the WHATWG state machine for the happy path: Data, TagOpen,
# EndTagOpen, TagName, BeforeAttributeName, AttributeName, BeforeAttributeValue,
# AttributeValue (quoted/unquoted), SelfClosingStartTag, MarkupDeclarationOpen,
# CommentStart/Comment/CommentEnd, and Doctype.
#
# Malformed input (stray `<` with no valid follower, unterminated quote at EOF,
# etc.) is skipped by advancing one byte so the scanner always makes progress.
# ============================================================================

fn tokenize_html(source: String) -> [HtmlToken]:
    var tokens: [HtmlToken] = []
    val n = source.bytes().length()
    var i = 0

    while i < n:
        val c = _peek(source, i)

        # --- Data state: accumulate characters until `<` ---
        if c != 60:
            val start = i
            while i < n and _peek(source, i) != 60:
                i = i + 1
            val text = _slice(source, start, i)
            tokens.push(HtmlToken(
                kind: HtmlTokenKind.Character,
                name: "",
                data: text,
                attributes: [],
                self_closing: false
            ))
            continue

        # --- TagOpen state: saw `<` ---
        val c1 = _peek(source, i + 1)

        # Comment or DOCTYPE: `<!`
        if c1 == 33:
            # `<!--` → Comment
            if _peek(source, i + 2) == 45 and _peek(source, i + 3) == 45:
                i = i + 4
                val cstart = i
                # scan until `-->`
                while i < n:
                    if _peek(source, i) == 45 and _peek(source, i + 1) == 45 and _peek(source, i + 2) == 62:
                        break
                    i = i + 1
                val body = _slice(source, cstart, i)
                # consume closing `-->` if present
                if i + 2 < n:
                    i = i + 3
                else:
                    i = n
                tokens.push(HtmlToken(
                    kind: HtmlTokenKind.Comment,
                    name: "",
                    data: body,
                    attributes: [],
                    self_closing: false
                ))
                continue

            # `<!DOCTYPE` (case-insensitive per spec; accept upper/lower)
            val d0 = _peek(source, i + 2)
            val d1 = _peek(source, i + 3)
            val d2 = _peek(source, i + 4)
            val d3 = _peek(source, i + 5)
            val d4 = _peek(source, i + 6)
            val d5 = _peek(source, i + 7)
            val d6 = _peek(source, i + 8)
            val is_doctype_upper = d0 == 68 and d1 == 79 and d2 == 67 and d3 == 84 and d4 == 89 and d5 == 80 and d6 == 69
            val is_doctype_lower = d0 == 100 and d1 == 111 and d2 == 99 and d3 == 116 and d4 == 121 and d5 == 112 and d6 == 101
            if is_doctype_upper or is_doctype_lower:
                i = i + 9
                # skip whitespace before name
                while i < n and _is_whitespace(_peek(source, i)):
                    i = i + 1
                val dstart = i
                while i < n and _peek(source, i) != 62 and not _is_whitespace(_peek(source, i)):
                    i = i + 1
                val dname = _slice(source, dstart, i)
                # skip to closing `>`
                while i < n and _peek(source, i) != 62:
                    i = i + 1
                if i < n:
                    i = i + 1
                tokens.push(HtmlToken(
                    kind: HtmlTokenKind.Doctype,
                    name: dname,
                    data: "",
                    attributes: [],
                    self_closing: false
                ))
                continue

            # unknown `<!...>` — skip the `<` and resume
            i = i + 1
            continue

        # EndTag: `</`
        if c1 == 47:
            i = i + 2
            val estart = i
            while i < n and _is_alpha(_peek(source, i)):
                i = i + 1
            val ename = _slice(source, estart, i)
            # skip to `>`
            while i < n and _peek(source, i) != 62:
                i = i + 1
            if i < n:
                i = i + 1
            tokens.push(HtmlToken(
                kind: HtmlTokenKind.EndTag,
                name: ename,
                data: "",
                attributes: [],
                self_closing: false
            ))
            continue

        # StartTag: `<` followed by a letter
        if _is_alpha(c1):
            i = i + 1
            val tstart = i
            while i < n and _is_alpha(_peek(source, i)):
                i = i + 1
            val tname = _slice(source, tstart, i)
            var attrs: [HtmlAttribute] = []
            var self_closing = false

            # BeforeAttributeName / AttributeName / AttributeValue loop
            while i < n:
                # skip whitespace
                while i < n and _is_whitespace(_peek(source, i)):
                    i = i + 1
                val cc = _peek(source, i)
                if cc == 62:
                    # `>` closes the tag
                    i = i + 1
                    break
                if cc == 47:
                    # `/` — if followed by `>` this is a self-closing tag
                    if _peek(source, i + 1) == 62:
                        self_closing = true
                        i = i + 2
                        break
                    # stray `/`, skip
                    i = i + 1
                    continue
                if cc < 0:
                    break

                # AttributeName — read until `=`, whitespace, `/`, or `>`
                val nstart = i
                while i < n:
                    val nc = _peek(source, i)
                    if nc == 61 or nc == 62 or nc == 47 or _is_whitespace(nc) or nc < 0:
                        break
                    i = i + 1
                val aname = _slice(source, nstart, i)

                # skip whitespace after name
                while i < n and _is_whitespace(_peek(source, i)):
                    i = i + 1

                var avalue = ""
                if _peek(source, i) == 61:
                    # `=` → BeforeAttributeValue
                    i = i + 1
                    while i < n and _is_whitespace(_peek(source, i)):
                        i = i + 1
                    val q = _peek(source, i)
                    if q == 34 or q == 39:
                        # quoted value
                        i = i + 1
                        val vstart = i
                        while i < n and _peek(source, i) != q:
                            i = i + 1
                        avalue = _slice(source, vstart, i)
                        if i < n:
                            # consume closing quote
                            i = i + 1
                    else:
                        # unquoted value
                        val vstart = i
                        while i < n:
                            val vc = _peek(source, i)
                            if vc == 62 or _is_whitespace(vc) or vc < 0:
                                break
                            i = i + 1
                        avalue = _slice(source, vstart, i)

                if aname.len() > 0:
                    attrs.push(HtmlAttribute(name: aname, value: avalue))

            tokens.push(HtmlToken(
                kind: HtmlTokenKind.StartTag,
                name: tname,
                data: "",
                attributes: attrs,
                self_closing: self_closing
            ))
            continue

        # stray `<` with no valid follower — emit as Character and advance
        tokens.push(HtmlToken(
            kind: HtmlTokenKind.Character,
            name: "",
            data: _slice(source, i, i + 1),
            attributes: [],
            self_closing: false
        ))
        i = i + 1

    tokens.push(HtmlToken(
        kind: HtmlTokenKind.Eof,
        name: "",
        data: "",
        attributes: [],
        self_closing: false
    ))
    tokens
