# JS Parser
# Parses JavaScript source code into an AST.

use std.js.types.ast_types.{JsStatement, JsExpression}
use std.js.engine.js_error.{JsError, Logger}
use std.js.engine.lexer.{JsLexer}

class JsParser:
    source: text
    lexer: JsLexer
    logger: Logger
    pos: i64

impl JsParser:
    static fn create(source: text, logger: Logger) -> JsParser:
        JsParser(source: source, lexer: JsLexer.create(source), logger: logger, pos: 0)

    static fn new(source: text, logger: Logger) -> JsParser:
        JsParser.create(source, logger)

    fn parse_program() -> [JsStatement]:
        []

    fn parse_assignment() -> Result<JsExpression, JsError>:
        Err(JsError(message: "parser not implemented", name: "SyntaxError", stack: ""))
