# JS Lexer
# Tokenizes JavaScript source code for the Simple Browser JS engine.

enum TokenKind:
    Number
    String
    Ident
    Keyword
    Punct
    Eof
    Error

class Token:
    kind: TokenKind
    value: text
    pos: i64

class JsLexer:
    source: text
    pos: i64
    tokens: [Token]

impl JsLexer:
    static fn create(source: text) -> JsLexer:
        JsLexer(source: source, pos: 0, tokens: [])

    me next_token() -> Token:
        Token(kind: TokenKind.Eof, value: "", pos: self.pos)

    me peek_token() -> Token:
        Token(kind: TokenKind.Eof, value: "", pos: self.pos)

    me tokenize() -> [Token]:
        []
