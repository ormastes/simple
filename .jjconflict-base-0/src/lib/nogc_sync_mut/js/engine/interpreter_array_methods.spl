# JsInterpreter — array method dispatch (_dispatch_array_method).

use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel, BrowserResult, BrowserError, js_nan, js_infinity, js_neg_infinity, is_nan}
use std.js.types.js_types.JsValue
use std.js.types.ast_types.JsExpression
use std.js.engine.interpreter_types.{Environment, EnvironmentStack, CallFrame, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}
use std.js.engine.vm_object_store.{ObjectStore}
use std.nogc_sync_mut.js.engine.interpreter.{JsInterpreter}
use std.nogc_sync_mut.js.engine.interpreter_object.{JsInterpreter}

impl JsInterpreter:
    # ── Array method dispatch ────────────────────────────────────────────
    me _dispatch_array_method(arr_id: i64, method: text, args: [JsExpression], env: i64) -> BrowserResult<JsValue>:
        val arr_len = self.object_store.array_length(arr_id)

        # --- Higher-order methods that need a callback ---
        if method == "map":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    val result_id = self.create_object()
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val mapped = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        self.set_object_property(result_id, "{i}", mapped)
                        i = i + 1
                    self.set_object_property(result_id, "length", JsValue.Number(v: arr_len.to_f64()))
                    return Ok(JsValue.Array(id: result_id))
                _:
                    return Ok(JsValue.Undefined)

        if method == "filter":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    val result_id = self.create_object()
                    var i = 0
                    var out_idx = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val keep = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(keep):
                            self.set_object_property(result_id, "{out_idx}", elem)
                            out_idx = out_idx + 1
                        i = i + 1
                    self.set_object_property(result_id, "length", JsValue.Number(v: out_idx.to_f64()))
                    return Ok(JsValue.Array(id: result_id))
                _:
                    return Ok(JsValue.Undefined)

        if method == "forEach":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        i = i + 1
                _: pass_dn
            return Ok(JsValue.Undefined)

        if method == "find":
            val cb_val = self.eval_expression(args.get(0), env)?
            var final_result = JsValue.Undefined
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    var found = false
                    var found_value = JsValue.Undefined
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(result):
                            found = true
                            found_value = elem
                            break
                        i = i + 1
                    if found:
                        final_result = found_value
                _: pass_dn
            return Ok(final_result)

        if method == "findIndex":
            val cb_val = self.eval_expression(args.get(0), env)?
            var final_index = -1
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    var found = false
                    var found_index = -1
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(result):
                            found = true
                            found_index = i
                            break
                        i = i + 1
                    if found:
                        final_index = found_index
                _: pass_dn
            return Ok(JsValue.Number(v: final_index.to_f64()))

        if method == "some":
            val cb_val = self.eval_expression(args.get(0), env)?
            var matched = false
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if is_truthy(result):
                            matched = true
                            break
                        i = i + 1
                _: pass_dn
            return Ok(JsValue.Boolean(v: matched))

        if method == "every":
            val cb_val = self.eval_expression(args.get(0), env)?
            var all_match = true
            match cb_val:
                JsValue.Function(fn_id):
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val result = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        if not is_truthy(result):
                            all_match = false
                            break
                        i = i + 1
                _: pass_dn
            return Ok(JsValue.Boolean(v: all_match))

        if method == "reduce":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    var acc = JsValue.Undefined
                    var start = 0
                    if args.len() > 1:
                        acc = self.eval_expression(args.get(1), env)?
                    else:
                        if arr_len > 0:
                            acc = self.object_store.get_by_index(arr_id, 0)
                            start = 1
                    var i = start
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        acc = self._invoke_function(fn_id, [acc, elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        i = i + 1
                    return Ok(acc)
                _:
                    return Ok(JsValue.Undefined)

        # --- Mutating / non-callback methods ---
        if method == "push":
            var i = 0
            while i < args.len():
                val arg_val = self.eval_expression(args.get(i), env)?
                self.set_object_property(arr_id, "{arr_len + i}", arg_val)
                i = i + 1
            val new_len = arr_len + args.len()
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(JsValue.Number(v: new_len.to_f64()))

        if method == "pop":
            if arr_len == 0:
                return Ok(JsValue.Undefined)
            val last = self.object_store.get_by_index(arr_id, arr_len - 1)
            val new_len = arr_len - 1
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(last)

        if method == "indexOf":
            val search_val = self.eval_expression(args.get(0), env)?
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                if strict_equals(elem, search_val):
                    return Ok(JsValue.Number(v: i.to_f64()))
                i = i + 1
            return Ok(JsValue.Number(v: -1.0))

        if method == "includes":
            val search_val = self.eval_expression(args.get(0), env)?
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                if strict_equals(elem, search_val):
                    return Ok(JsValue.Boolean(v: true))
                i = i + 1
            return Ok(JsValue.Boolean(v: false))

        if method == "join":
            var sep = ","
            if args.len() > 0:
                val sep_val = self.eval_expression(args.get(0), env)?
                sep = js_to_string(sep_val)
            var result = ""
            var i = 0
            while i < arr_len:
                if i > 0:
                    result = result + sep
                val elem = self.object_store.get_by_index(arr_id, i)
                result = result + js_to_string(elem)
                i = i + 1
            return Ok(JsValue.String(v: result))

        if method == "reverse":
            var i = 0
            var j = arr_len - 1
            while i < j:
                val a = self.object_store.get_by_index(arr_id, i)
                val b = self.object_store.get_by_index(arr_id, j)
                self.set_object_property(arr_id, "{i}", b)
                self.set_object_property(arr_id, "{j}", a)
                i = i + 1
                j = j - 1
            return Ok(JsValue.Array(id: arr_id))

        if method == "slice":
            var start = 0
            var end = arr_len
            if args.len() > 0:
                val s = self.eval_expression(args.get(0), env)?
                start = f64_to_i64(to_number(s))
                if start < 0:
                    start = arr_len + start
                    if start < 0:
                        start = 0
            if args.len() > 1:
                val e = self.eval_expression(args.get(1), env)?
                end = f64_to_i64(to_number(e))
                if end < 0:
                    end = arr_len + end
                if end > arr_len:
                    end = arr_len
            val result_id = self.create_object()
            var i = start
            var out = 0
            while i < end:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(result_id, "{out}", elem)
                out = out + 1
                i = i + 1
            self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "concat":
            val result_id = self.create_object()
            var out = 0
            # Copy current array
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(result_id, "{out}", elem)
                out = out + 1
                i = i + 1
            # Append each argument (expand arrays)
            var ai = 0
            while ai < args.len():
                val arg_val = self.eval_expression(args.get(ai), env)?
                match arg_val:
                    JsValue.Array(src_id):
                        val src_len = self.object_store.array_length(src_id)
                        var si = 0
                        while si < src_len:
                            val sv = self.object_store.get_by_index(src_id, si)
                            self.set_object_property(result_id, "{out}", sv)
                            out = out + 1
                            si = si + 1
                    _:
                        self.set_object_property(result_id, "{out}", arg_val)
                        out = out + 1
                ai = ai + 1
            self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "sort":
            if args.len() > 0:
                val cb_val = self.eval_expression(args.get(0), env)?
                match cb_val:
                    JsValue.Function(fn_id):
                        # Simple bubble sort with comparator
                        var swapped = true
                        while swapped:
                            swapped = false
                            var i = 0
                            while i < arr_len - 1:
                                val a = self.object_store.get_by_index(arr_id, i)
                                val b = self.object_store.get_by_index(arr_id, i + 1)
                                val cmp = self._invoke_function(fn_id, [a, b], env)?
                                val cmp_num = to_number(cmp)
                                if cmp_num > 0.0:
                                    self.set_object_property(arr_id, "{i}", b)
                                    self.set_object_property(arr_id, "{i + 1}", a)
                                    swapped = true
                                i = i + 1
                    _: pass_dn
            return Ok(JsValue.Array(id: arr_id))

        # shift — remove first element
        if method == "shift":
            if arr_len == 0:
                return Ok(JsValue.Undefined)
            val first = self.object_store.get_by_index(arr_id, 0)
            var i = 1
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(arr_id, "{i - 1}", elem)
                i = i + 1
            val new_len = arr_len - 1
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(first)

        # unshift — prepend elements
        if method == "unshift":
            val count = args.len()
            # Shift existing elements right
            var i = arr_len - 1
            while i >= 0:
                val elem = self.object_store.get_by_index(arr_id, i)
                self.set_object_property(arr_id, "{i + count}", elem)
                i = i - 1
            # Insert new elements at front
            var j = 0
            while j < count:
                val arg_val = self.eval_expression(args.get(j), env)?
                self.set_object_property(arr_id, "{j}", arg_val)
                j = j + 1
            val new_len = arr_len + count
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(JsValue.Number(v: new_len.to_f64()))

        # splice — remove/insert elements
        if method == "splice":
            var start = 0
            if args.len() > 0:
                val s = self.eval_expression(args.get(0), env)?
                start = f64_to_i64(to_number(s))
                if start < 0:
                    start = arr_len + start
                    if start < 0:
                        start = 0
            var delete_count = arr_len - start
            if args.len() > 1:
                val dc = self.eval_expression(args.get(1), env)?
                delete_count = f64_to_i64(to_number(dc))
            # Collect removed elements
            val removed_id = self.create_object()
            var ri = 0
            while ri < delete_count and (start + ri) < arr_len:
                val elem = self.object_store.get_by_index(arr_id, start + ri)
                self.set_object_property(removed_id, "{ri}", elem)
                ri = ri + 1
            self.set_object_property(removed_id, "length", JsValue.Number(v: ri.to_f64()))
            # Collect insert items (args from index 2 onward)
            var inserts: [JsValue] = []
            var ii = 2
            while ii < args.len():
                val iv = self.eval_expression(args.get(ii), env)?
                inserts.push(iv)
                ii = ii + 1
            # Shift tail elements
            val tail_start = start + delete_count
            val shift_amount = inserts.len() - delete_count
            if shift_amount > 0:
                var ti = arr_len - 1
                while ti >= tail_start:
                    val elem = self.object_store.get_by_index(arr_id, ti)
                    self.set_object_property(arr_id, "{ti + shift_amount}", elem)
                    ti = ti - 1
            else:
                if shift_amount < 0:
                    var ti = tail_start
                    while ti < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, ti)
                        self.set_object_property(arr_id, "{ti + shift_amount}", elem)
                        ti = ti + 1
            # Insert new elements
            var ki = 0
            while ki < inserts.len():
                self.set_object_property(arr_id, "{start + ki}", inserts.get(ki))
                ki = ki + 1
            val new_len = arr_len + shift_amount
            self.set_object_property(arr_id, "length", JsValue.Number(v: new_len.to_f64()))
            return Ok(JsValue.Array(id: removed_id))

        if method == "at":
            if args.len() > 0:
                val idx_val = self.eval_expression(args.get(0), env)?
                var idx = f64_to_i64(to_number(idx_val))
                if idx < 0:
                    idx = arr_len + idx
                if idx >= 0 and idx < arr_len:
                    return Ok(self.object_store.get_by_index(arr_id, idx))
            return Ok(JsValue.Undefined)

        if method == "flat":
            val result_id = self.create_object()
            var out = 0
            var i = 0
            while i < arr_len:
                val elem = self.object_store.get_by_index(arr_id, i)
                val elem_arr_id = _get_obj_id(elem)
                var is_inner_array = false
                match elem:
                    JsValue.Array(id):
                        is_inner_array = true
                    _: pass_dn
                if is_inner_array and elem_arr_id >= 0:
                    val inner_len = self.object_store.array_length(elem_arr_id)
                    var j = 0
                    while j < inner_len:
                        val inner_elem = self.object_store.get_by_index(elem_arr_id, j)
                        self.set_object_property(result_id, "{out}", inner_elem)
                        out = out + 1
                        j = j + 1
                else:
                    self.set_object_property(result_id, "{out}", elem)
                    out = out + 1
                i = i + 1
            self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
            return Ok(JsValue.Array(id: result_id))

        if method == "flatMap":
            val cb_val = self.eval_expression(args.get(0), env)?
            match cb_val:
                JsValue.Function(fn_id):
                    val result_id = self.create_object()
                    var out = 0
                    var i = 0
                    while i < arr_len:
                        val elem = self.object_store.get_by_index(arr_id, i)
                        val mapped = self._invoke_function(fn_id, [elem, JsValue.Number(v: i.to_f64()), JsValue.Array(id: arr_id)], env)?
                        val mapped_arr_id = _get_obj_id(mapped)
                        var is_array = false
                        match mapped:
                            JsValue.Array(id):
                                is_array = true
                            _: pass_dn
                        if is_array and mapped_arr_id >= 0:
                            val inner_len = self.object_store.array_length(mapped_arr_id)
                            var j = 0
                            while j < inner_len:
                                val inner = self.object_store.get_by_index(mapped_arr_id, j)
                                self.set_object_property(result_id, "{out}", inner)
                                out = out + 1
                                j = j + 1
                        else:
                            self.set_object_property(result_id, "{out}", mapped)
                            out = out + 1
                        i = i + 1
                    self.set_object_property(result_id, "length", JsValue.Number(v: out.to_f64()))
                    return Ok(JsValue.Array(id: result_id))
                _:
                    return Ok(JsValue.Undefined)

        self.logger.warn("Unknown array method: {method}")
        Ok(JsValue.Undefined)
