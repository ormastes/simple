# SFM dependency-injection bridge — data-driven layer wiring (AC-3).
#
# `register_layers` loops the manifest and binds each layer to its role (no
# hard-coded wiring). `resolve_layer` resolves by role and applies the
# authorization gate (authz.spl) before returning the layer as `Any`. DI stays
# `Any`-keyed — the typed `resolve<T>` path is dead (di.spl:179).

use std.sfm.manifest.{FeatureManifest, LayerDescriptor, SfmSecurityLevel}
use std.sfm.authz.{AuthzContext, authorize}

# A lightweight SFM-scoped container: carries the module's security level (the
# gate input) plus the role -> layer bindings registered from the manifest.
struct SfmContainer:
    security_level: SfmSecurityLevel
    roles: [text]
    layers: [LayerDescriptor]

# Create a fresh container bound to a manifest's security level. Layers are
# wired here (data-driven from the manifest) into constructor locals so the
# bindings live in the returned value — Simple `fn`-arg mutation does not
# persist to the caller, so post-construction field appends would be lost.
fn new_sfm_container(m: FeatureManifest) -> SfmContainer:
    var roles: [text] = []
    var layers: [LayerDescriptor] = []
    var i: i32 = 0
    val n: i32 = m.layers.len() as i32
    while i < n:
        val layer = m.layers[i]
        roles = roles.push(layer.role)
        layers = layers.push(layer)
        i = i + 1
    return SfmContainer(
        security_level: m.security_level,
        roles: roles,
        layers: layers
    )

# AC-3: confirm the manifest layers are bound (data-driven, no hard-coding).
# Wiring is performed in `new_sfm_container`; this is the documented register
# entry the app calls. It re-derives the same bindings to stay idempotent.
fn register_layers(c: SfmContainer, m: FeatureManifest):
    var i: i32 = 0
    val n: i32 = m.layers.len() as i32
    while i < n:
        val layer = m.layers[i]
        var found: bool = false
        var j: i32 = 0
        while j < (c.roles.len() as i32):
            if c.roles[j] == layer.role:
                found = true
            j = j + 1
        if not found:
            c.roles = c.roles.push(layer.role)
            c.layers = c.layers.push(layer)
        i = i + 1

# AC-3/4: resolve a layer by role, applying the authorization aspect. Unknown
# roles fail; gated privileged layers are denied for untrusted callers.
fn resolve_layer(c: SfmContainer, role: text, ctx: AuthzContext) -> Result<Any, text>:
    var i: i32 = 0
    val n: i32 = c.roles.len() as i32
    while i < n:
        if c.roles[i] == role:
            val layer = c.layers[i]
            match authorize(c.security_level, layer, ctx):
                Err(e): return Err(e)
                Ok(_): return Ok(layer)
        i = i + 1
    return Err("sfm di: no layer registered for role '" + role + "'")
