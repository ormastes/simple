# SFM loader & target profiles (AC-6).
#
# Loads a `.sfm` across five profiles (native / loader / script / web / mobile).
# The caller picks a preferred profile; the loader reports which one handled the
# module via `handled_profile`. Mobile is a thin load-and-report shim (app-store
# packaging is out of scope). The embedded SMF blob is opaque here and is handed
# to the existing SMF loader path by callers that need to execute code.

use std.sfm.manifest.{FeatureManifest}
use std.sfm.container.{read_sfm_file}

enum SfmProfile:
    Native
    Loader
    Script
    Web
    Mobile

struct SfmModule:
    manifest: FeatureManifest
    smf_bytes: [u8]
    profile: SfmProfile

fn profile_name(p: SfmProfile) -> text:
    match p:
        case Native: return "native"
        case Loader: return "loader"
        case Script: return "script"
        case Web:    return "web"
        case Mobile: return "mobile"

# AC-6: load a `.sfm`, decoding the manifest + embedded SMF, recording the
# profile that handled it (the preferred one — every profile can load the
# container; the difference is downstream execution, out of Wave-1 scope).
fn load_sfm(path: text, prefer: SfmProfile) -> Result<SfmModule, text>:
    match read_sfm_file(path):
        Err(e): return Err(e)
        Ok((manifest, smf)):
            return Ok(SfmModule(manifest: manifest, smf_bytes: smf, profile: prefer))

# AC-6: report which profile the loader used.
fn handled_profile(m: SfmModule) -> SfmProfile:
    return m.profile
