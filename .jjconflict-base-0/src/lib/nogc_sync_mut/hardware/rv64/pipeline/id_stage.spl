@allow(unnamed_duplicate_typed_args) # reason: pipeline stage APIs use positional i64 params
# RV64 Instruction Decode (ID) Stage
#
# Reads the IF/ID latch, extracts register operands from the register file,
# decodes the instruction via the Rv64Decoder, and produces the ID/EX latch.
#
# Feature IDs: #HW-RV64-PIPE-ID
# Category: Hardware / RTL Simulation
# Status: Implemented

use std.hardware.rv64.pipeline.types.{
    Rv64RegisterFile, Rv64IfIdLatch, Rv64IdExLatch, create_id_ex_latch
}
use std.hardware.rv64.pipeline.decoder.{
    Rv64Decoder, rv64_rs1, rv64_rs2
}

# ============================================================================
# Instruction Decode Stage
# ============================================================================

struct Rv64IdStage:
    """Instruction Decode stage.

    Uses the decoder to produce control signals and reads register operands.
    """
    dec: Rv64Decoder

fn create_rv64_id_stage() -> Rv64IdStage:
    """Create an ID stage with a fresh decoder."""
    Rv64IdStage(dec: Rv64Decoder(placeholder: 0))

impl Rv64IdStage:
    fn tick(if_id: Rv64IfIdLatch, reg_file: Rv64RegisterFile) -> Rv64IdExLatch:
        """Execute one clock cycle of the ID stage.

        Args:
            if_id: Latch data from the IF stage.
            reg_file: Register file to read operands from.

        Returns:
            ID/EX latch with decoded control signals and operand values.
        """
        if not if_id.valid:
            return create_id_ex_latch()

        val inst = if_id.instruction
        val rs1_idx = rv64_rs1(inst)
        val rs2_idx = rv64_rs2(inst)
        val rs1_val = reg_file.read(rs1_idx)
        val rs2_val = reg_file.read(rs2_idx)

        self.dec.decode(inst, if_id.pc, rs1_val, rs2_val)
