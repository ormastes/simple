"""
Hardware Abstraction Layer — typed capsules for MMIO, physical addresses,
DMA ownership, and IRQ registration.

@tag:stdlib
@tag:api

Wraps std.io.volatile_ops and std.io.dma with typed address capsules.
Composition-only design (D-7), function-local val only (D-6).

Submodules:
  - types:        MmioAddress, PhysAddress, DmaAddress, IrqLine, RegisterWidth,
                  IrqTrigger, IrqConfig + constructors/accessors.
  - volatile:     Typed volatile read/write wrapping std.io.volatile_ops.
  - irq:          IRQ enable/disable/pending/clear.
  - dma_contract: DMA ownership/alignment contracts wrapping std.io.dma.
  - qemu_mock:    QEMU mock backend for tests (in-memory register map).
"""

# Re-exported from types.spl
export RegisterWidth, MmioAddress, mmio_address
export PhysAddress, phys_address, phys_to_u64, phys_is_aligned, phys_offset
export DmaAddress, dma_address
export IrqTrigger, IrqLine, irq_line, IrqConfig, irq_config

# Re-exported from volatile.spl
export mmio_read_u8, mmio_read_u16, mmio_read_u32, mmio_read_u64
export mmio_write_u8, mmio_write_u16, mmio_write_u32, mmio_write_u64
export mmio_read_with_barrier, mmio_write_with_barrier

# Re-exported from irq.spl
export irq_enable, irq_disable, irq_is_pending, irq_clear_pending

# Re-exported from dma_contract.spl
export dma_address_alloc, dma_address_free
export dma_address_sync_for_device, dma_address_sync_for_cpu

# Re-exported from qemu_mock.spl
export MmioRegEntry, QemuMockHal, qemu_mock_hal_new
export qemu_mock_read, qemu_mock_write
export MockIrqEntry, qemu_mock_irq_pending, qemu_mock_inject_irq
