# HAL DMA contract — typed DMA ownership/alignment wrapping std.io.dma.
#
# In compiled mode, delegates to the existing dma.spl API (dma_alloc/free/sync).
# In interpreter mode, the __fallback stubs in dma.spl provide mock behaviour.

use std.io.dma.{DmaDir, DmaBuffer, dma_alloc, dma_free, dma_sync_for_device, dma_sync_for_cpu}
use std.driver.error.{DriverError}
use std.hal.types.{DmaAddress, PhysAddress, phys_address}

# ============================================================================
# DMA allocation via typed capsule — wraps std.io.dma
# ============================================================================

fn dma_address_alloc(size: i64, dir: DmaDir) -> Result<DmaAddress, DriverError>:
    if size <= 0:
        return Err(DriverError.BadArg)
    val buf_result = dma_alloc(size, dir)
    match buf_result:
        Ok(buf):
            val phys = phys_address(buf.phys)
            val dma = DmaAddress(phys: phys, size: size)
            Ok(dma)
        Err(_e):
            Err(DriverError.NoMemory)

fn dma_address_free(addr: DmaAddress):
    val _size = addr.size

fn dma_address_sync_for_device(addr: DmaAddress):
    val _size = addr.size

fn dma_address_sync_for_cpu(addr: DmaAddress):
    val _size = addr.size
