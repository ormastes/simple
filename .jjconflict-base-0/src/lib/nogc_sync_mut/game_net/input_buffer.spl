# ============================================================================
# game_net/input_buffer.spl — client-side ring of unacknowledged InputFrames
#
# Netcode plan P2. Keyed by seq (monotonic per client); `ack_trim` drops every
# frame the server has confirmed processing so the reconciler only replays
# what the server hasn't seen yet. `class` (not `struct`) so mutation through
# `me` methods is visible to every caller, including across module
# boundaries (see wire.spl's ByteReader/ByteWriter note for the struct-value
# pitfall this sidesteps).
# ============================================================================

use std.nogc_sync_mut.game_net.wire.{InputFrame}

class InputBuffer:
    frames: [InputFrame]

impl InputBuffer:
    static fn new() -> InputBuffer:
        InputBuffer(frames: [])

    me push(f: InputFrame):
        self.frames.push(f)

    me ack_trim(acked_seq: u32):
        """Drop every buffered frame with seq <= acked_seq."""
        var kept: [InputFrame] = []
        var i: u64 = 0
        while i < self.frames.len().to_u64():
            if self.frames[i].seq > acked_seq:
                kept.push(self.frames[i])
            i = i + 1
        self.frames = kept

    fn unacked() -> [InputFrame]:
        """Buffered frames in ascending seq order (replay order)."""
        self.frames

    fn len() -> u64:
        self.frames.len().to_u64()

export InputBuffer
