# SelectionState — multi-select for scene nodes

# ============================================================================
# NodeId — lightweight entity reference for the editor
# ============================================================================

struct NodeId:
    id: i32

    static fn null() -> NodeId:
        NodeId(id: -1)

    fn is_null(self) -> bool:
        self.id < 0

    fn eq(self, other: NodeId) -> bool:
        self.id == other.id

# ============================================================================
# SelectionState
# ============================================================================

class SelectionState:
    selected_nodes: [NodeId]
    primary_node: NodeId

    static fn empty() -> SelectionState:
        SelectionState(
            selected_nodes: [],
            primary_node: NodeId.null()
        )

    me select(node: NodeId):
        self.selected_nodes = [node]
        self.primary_node = node

    me add_to_selection(node: NodeId):
        for n in self.selected_nodes:
            if n.eq(node):
                return
        self.selected_nodes = self.selected_nodes.push(node)
        if self.primary_node.is_null():
            self.primary_node = node

    me deselect(node: NodeId):
        var kept: [NodeId] = []
        for n in self.selected_nodes:
            if not n.eq(node):
                kept = kept.push(n)
        self.selected_nodes = kept
        if self.primary_node.eq(node):
            if self.selected_nodes.len() > 0:
                self.primary_node = self.selected_nodes[0]
            else:
                self.primary_node = NodeId.null()

    me clear():
        self.selected_nodes = []
        self.primary_node = NodeId.null()

    fn contains(self, node: NodeId) -> bool:
        for n in self.selected_nodes:
            if n.eq(node):
                return true
        false

    fn count(self) -> i32:
        self.selected_nodes.len()

    fn is_empty(self) -> bool:
        self.selected_nodes.len() == 0
