# Static driver table — the compile-time driver list for static-mode builds.
#
# Drivers declared with @driver(...) in static mode lower to a call to
# `register_static_driver(manifest, ops)` in their module init. The
# static table is the process-wide DriverRegistry the kernel consults.
#
# For dynamic-mode builds the same `DriverRegistry` is populated by
# `loader.spl` after parsing the `.drv_manifest` SMF section.
#
# Usage (driver module):
#
#   use std.driver.static_table.{register_static_driver}
#   use std.driver.manifest.{DriverManifest}
#   use std.driver.registry.{DriverOps}
#
#   fn register_ahci_driver():
#       val m = DriverManifest.for_driver("ahci", "1.0", DriverClass.Block,
#                                          0x8086, [0x2922, 0x2829])
#       val ops = DriverOps(
#           self_ptr: 0,
#           manifest_abi: ahci_abi_rev,
#           init_fn: ahci_init, probe_fn: ahci_probe,
#           attach_fn: ahci_attach, detach_fn: ahci_detach,
#           suspend_fn: ahci_suspend, resume_fn: ahci_resume,
#           ioctl_fn: ahci_ioctl,
#       )
#       register_static_driver(m, ops)
#
# The kernel boot path later calls `static_registry().init_all(ctx)`.

use std.driver.error.{DriverError}
use std.driver.manifest.{DriverManifest}
use std.driver.registry.{DriverRegistry, DriverOps}

var __STATIC_REGISTRY: DriverRegistry = DriverRegistry.empty()

fn register_static_driver(manifest: DriverManifest, ops: DriverOps) -> Result<i32, DriverError>:
    return __STATIC_REGISTRY.register(ops, manifest)

fn static_registry() -> DriverRegistry:
    return __STATIC_REGISTRY

fn static_driver_count() -> i32:
    return __STATIC_REGISTRY.count()
