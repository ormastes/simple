# UI SDN File Parser — file I/O wrapper
#
# Reads .ui.sdn files from disk and delegates to the pure parser
# in common.ui.parse.sdn for HTML rendering.

use common.ui.parse.sdn.{render_source}
use std.io_runtime.{file_exists, read_file}

fn parse_ui_file(path: text) -> Result<text, text>:
    if not file_exists(path):
        return Err("File not found: {path}")
    val source = read_file(path) ?? ""
    return render_source(source)
