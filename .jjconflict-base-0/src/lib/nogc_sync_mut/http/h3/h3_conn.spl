# HTTP/3 Connection State Machine — RFC 9114 §5
#
# Models the lifecycle of an HTTP/3 connection over QUIC.
# States follow RFC 9114 §5 (Idle → Open → Closing → Draining → Closed).
#
# This module provides:
#   - H3ConnState enum (five states)
#   - H3ConnEvent enum (events that trigger transitions)
#   - h3_conn_transition(state, event) → H3ConnState
#   - H3ConnStateResult for error reporting
#
# Out of scope (deferred):
#   - Flow control accounting (RFC 9000 §4)
#   - QUIC transport integration (RFC 9000)
#   - Settings negotiation bookkeeping
#   - Stream limit enforcement
#
# Reference: RFC 9114 §5, RFC 9000 §10

# ============================================================================
# Connection state enum — RFC 9114 §5
# ============================================================================

enum H3ConnState:
    """HTTP/3 connection lifecycle state."""
    # No QUIC connection established yet.
    Idle
    # QUIC handshake complete; SETTINGS exchanged; requests may be sent.
    Open
    # GOAWAY sent or received; no new requests accepted; existing streams draining.
    Closing
    # Peer acknowledged GOAWAY; waiting for in-flight streams to finish.
    Draining
    # QUIC connection closed; no further activity.
    Closed

# ============================================================================
# Connection events
# ============================================================================

enum H3ConnEvent:
    """Events that drive H3ConnState transitions."""
    # QUIC handshake complete and SETTINGS frames exchanged.
    Connected
    # Local endpoint sent GOAWAY to peer.
    SentGoaway
    # Received GOAWAY from peer.
    ReceivedGoaway
    # Peer acknowledged GOAWAY; all streams at zero.
    DrainComplete
    # QUIC connection closed (error or graceful).
    ConnectionClosed

# ============================================================================
# Result type
# ============================================================================

class H3ConnTransitionOk:
    """Successful transition: new state."""
    next: H3ConnState

enum H3ConnTransitionResult:
    """Result of a state transition attempt."""
    Ok(H3ConnTransitionOk)
    Err(msg: text)

# ============================================================================
# State transition — RFC 9114 §5
#
# Transitions:
#   Idle      + Connected       → Open
#   Open      + SentGoaway      → Closing
#   Open      + ReceivedGoaway  → Draining
#   Closing   + ReceivedGoaway  → Draining
#   Closing   + DrainComplete   → Closed
#   Draining  + DrainComplete   → Closed
#   any       + ConnectionClosed → Closed
# ============================================================================

pub fn h3_conn_transition(state: H3ConnState, event: H3ConnEvent) -> H3ConnTransitionResult:
    """Apply event to state and return the next connection state.

    Returns Err if the event is not valid in the current state.
    ConnectionClosed is accepted from any state (QUIC can close at any time).
    """
    match event:
        case ConnectionClosed:
            return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Closed))
        case Connected:
            match state:
                case Idle:
                    return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Open))
                case _:
                    return H3ConnTransitionResult.Err("Connected event only valid from Idle")
        case SentGoaway:
            match state:
                case Open:
                    return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Closing))
                case _:
                    return H3ConnTransitionResult.Err("SentGoaway only valid from Open")
        case ReceivedGoaway:
            match state:
                case Open:
                    return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Draining))
                case Closing:
                    return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Draining))
                case _:
                    return H3ConnTransitionResult.Err("ReceivedGoaway only valid from Open or Closing")
        case DrainComplete:
            match state:
                case Closing:
                    return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Closed))
                case Draining:
                    return H3ConnTransitionResult.Ok(H3ConnTransitionOk(next: H3ConnState.Closed))
                case _:
                    return H3ConnTransitionResult.Err("DrainComplete only valid from Closing or Draining")
    return H3ConnTransitionResult.Err("unreachable")

# ============================================================================
# Predicate helpers
# ============================================================================

pub fn h3_conn_can_send_request(state: H3ConnState) -> bool:
    """True if the connection accepts new client-initiated requests."""
    match state:
        case Open:
            return true
        case _:
            return false

pub fn h3_conn_is_closed(state: H3ConnState) -> bool:
    """True if the connection is fully closed."""
    match state:
        case Closed:
            return true
        case _:
            return false
