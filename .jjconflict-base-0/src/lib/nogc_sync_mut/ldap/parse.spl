# LDAP BER decoders (RFC 4511 §5.1).
#
# ALL decoding is OFFSET-BASED over a [u8] slice.  We never pass a ByteReader
# by value to a free fn — that copies the cursor and the advance is invisible
# to the caller (bytereader_by_value_param_no_cursor_propagation).  Helpers
# that need to report how many bytes they consumed return a small struct
# carrying (ok, value, next_offset); compound/filter decode recurses on the
# slice with explicit offsets.
#
# BUG(cross_module_struct_literal_push_array_nil): result structs are built via
# Type.new(...) positional constructors, never Type(field: pushed_array).
# BUG(interp_text_bytes_corrupts_across_frame) / i64.chr-not-found: byte->text
# uses string_core.char_from_code (ASCII table), not the `.chr()` method which
# is unresolved in the interpreter.

use std.nogc_sync_mut.ldap.types.*

fn _ldap_char_from_code(code: i64) -> text:
    if code >= 32 and code <= 126:
        val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        val index = code - 32
        if index >= 0 and index < chars.len().to_i64():
            return chars[index]
    "?"

# =============================================================================
# TLV header decode — offset based
# =============================================================================

# Result of reading one TLV header at a given offset.
struct LdapTlvHeader:
    ok: bool
    tag: u8
    content_start: u64
    content_len: u64
    next_offset: u64       # offset just past this TLV's content

impl LdapTlvHeader:
    static fn err() -> LdapTlvHeader:
        LdapTlvHeader(ok: false, tag: 0, content_start: 0, content_len: 0, next_offset: 0)

    static fn make(tag: u8, content_start: u64, content_len: u64, next_offset: u64) -> LdapTlvHeader:
        LdapTlvHeader(ok: true, tag: tag, content_start: content_start, content_len: content_len, next_offset: next_offset)

# Read a TLV header starting at `pos` within `data`.
fn ldap_read_tlv_header(data: [u8], pos: u64) -> LdapTlvHeader:
    if pos + 2 > data.len():
        return LdapTlvHeader.err()
    val tag = data[pos]
    var p: u64 = pos + 1
    val first = data[p]
    p = p + 1
    var length: u64 = 0
    if (first & 0x80) == 0:
        length = first.to_u64()
    else:
        val count = (first & 0x7F).to_u64()
        if count == 0:
            return LdapTlvHeader.err()
        var acc: u64 = 0
        var li: u64 = 0
        while li < count:
            if p >= data.len():
                return LdapTlvHeader.err()
            acc = (acc << 8) | data[p].to_u64()
            p = p + 1
            li = li + 1
        length = acc
    if p + length > data.len():
        return LdapTlvHeader.err()
    LdapTlvHeader.make(tag, p, length, p + length)

# Extract content bytes [start, start+len) from data.
fn ldap_slice(data: [u8], start: u64, length: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < length:
        out.push(data[start + i])
        i = i + 1
    out

# Decode a minimal-length two's-complement integer/enumerated content slice.
fn ldap_decode_int_content(bytes: [u8]) -> i64:
    if bytes.len() == 0:
        return 0
    val negative = (bytes[0] & 0x80) != 0
    var acc: u64 = 0
    var i: u64 = 0
    while i < bytes.len():
        acc = (acc << 8) | bytes[i].to_u64()
        i = i + 1
    if negative:
        val bits = bytes.len() * 8
        if bits < 64:
            val ones: u64 = 0xFFFFFFFFFFFFFFFF
            val mask = ones << bits.to_u64()
            acc = acc | mask
        return acc.to_i64()
    acc.to_i64()

# Decode text content as UTF-8 (ASCII fast path + minimal multibyte).
# Uses string_core.char_from_code (ASCII table) because the `.chr()` method on
# i64 is not resolvable in the interpreter ("Function 'i64.chr' not found").
# LDAP DNs / attribute descriptions are ASCII, so this covers the protocol.
fn ldap_bytes_to_text(bytes: [u8]) -> text:
    var result = ""
    var i: u64 = 0
    val n = bytes.len()
    while i < n:
        val b = bytes[i] as i64
        if b < 0x80:
            result = result + _ldap_char_from_code(b)
            i = i + 1
        elif b < 0xE0:
            if i + 1 < n:
                val b2 = bytes[i + 1] as i64
                val cp = ((b & 0x1F) << 6) | (b2 & 0x3F)
                result = result + _ldap_char_from_code(cp)
                i = i + 2
            else:
                result = result + "?"
                i = i + 1
        elif b < 0xF0:
            if i + 2 < n:
                val b2 = bytes[i + 1] as i64
                val b3 = bytes[i + 2] as i64
                val cp = ((b & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
                result = result + _ldap_char_from_code(cp)
                i = i + 3
            else:
                result = result + "?"
                i = i + 1
        else:
            result = result + "?"
            i = i + 1
    result

# =============================================================================
# Message envelope decode
# =============================================================================

# Decoded LDAP message envelope: message_id + op kind + raw op TLV bytes.
struct LdapDecodedMessage:
    ok: bool
    error: text
    message_id: i64
    op_kind: i64
    op_tag: u8
    op_bytes: [u8]        # full TLV bytes of the operation
    op_content: [u8]      # just the operation's content bytes

impl LdapDecodedMessage:
    static fn err(msg: text) -> LdapDecodedMessage:
        LdapDecodedMessage(ok: false, error: msg, message_id: 0, op_kind: LDAP_OP_UNKNOWN, op_tag: 0, op_bytes: [], op_content: [])

    static fn make(message_id: i64, op_kind: i64, op_tag: u8, op_bytes: [u8], op_content: [u8]) -> LdapDecodedMessage:
        LdapDecodedMessage(ok: true, error: "", message_id: message_id, op_kind: op_kind, op_tag: op_tag, op_bytes: op_bytes, op_content: op_content)

# Parse a top-level LDAPMessage from raw bytes.
fn ldap_parse_message(data: [u8]) -> LdapDecodedMessage:
    val hdr = ldap_read_tlv_header(data, 0)
    if not hdr.ok:
        return LdapDecodedMessage.err("ldap_parse_message: truncated envelope")
    if hdr.tag != 0x30:
        return LdapDecodedMessage.err("ldap_parse_message: envelope not a SEQUENCE")
    # messageID INTEGER
    val id_hdr = ldap_read_tlv_header(data, hdr.content_start)
    if not id_hdr.ok:
        return LdapDecodedMessage.err("ldap_parse_message: truncated messageID")
    if id_hdr.tag != 0x02:
        return LdapDecodedMessage.err("ldap_parse_message: messageID not INTEGER")
    val id_bytes = ldap_slice(data, id_hdr.content_start, id_hdr.content_len)
    val message_id = ldap_decode_int_content(id_bytes)
    # protocolOp
    val op_hdr = ldap_read_tlv_header(data, id_hdr.next_offset)
    if not op_hdr.ok:
        return LdapDecodedMessage.err("ldap_parse_message: truncated protocolOp")
    val op_kind = ldap_op_kind_of_tag(op_hdr.tag)
    # full op TLV bytes span [id_hdr.next_offset, op_hdr.next_offset)
    val op_total_len = op_hdr.next_offset - id_hdr.next_offset
    val op_bytes = ldap_slice(data, id_hdr.next_offset, op_total_len)
    val op_content = ldap_slice(data, op_hdr.content_start, op_hdr.content_len)
    LdapDecodedMessage.make(message_id, op_kind, op_hdr.tag, op_bytes, op_content)

# =============================================================================
# Operation decoders (input = the op's content bytes)
# =============================================================================

# Decode an LDAPResult from result content bytes.
fn ldap_decode_result(content: [u8]) -> LdapResult:
    var pos: u64 = 0
    var code: i64 = LDAP_RESULT_OTHER
    var matched = ""
    var diag = ""
    # resultCode ENUMERATED
    val code_hdr = ldap_read_tlv_header(content, pos)
    if code_hdr.ok:
        val cb = ldap_slice(content, code_hdr.content_start, code_hdr.content_len)
        code = ldap_decode_int_content(cb)
        pos = code_hdr.next_offset
        # matchedDN OCTET STRING
        val md_hdr = ldap_read_tlv_header(content, pos)
        if md_hdr.ok:
            val mb = ldap_slice(content, md_hdr.content_start, md_hdr.content_len)
            matched = ldap_bytes_to_text(mb)
            pos = md_hdr.next_offset
            # diagnosticMessage OCTET STRING
            val dg_hdr = ldap_read_tlv_header(content, pos)
            if dg_hdr.ok:
                val db = ldap_slice(content, dg_hdr.content_start, dg_hdr.content_len)
                diag = ldap_bytes_to_text(db)
    LdapResult.new(code, LdapDn.new(matched), diag)

# Decode a BindRequest from its content bytes.
fn ldap_decode_bind_request(content: [u8]) -> LdapBindRequest:
    var pos: u64 = 0
    var version: i64 = 3
    var name = ""
    var password: [u8] = []
    val v_hdr = ldap_read_tlv_header(content, pos)
    if v_hdr.ok:
        version = ldap_decode_int_content(ldap_slice(content, v_hdr.content_start, v_hdr.content_len))
        pos = v_hdr.next_offset
        val n_hdr = ldap_read_tlv_header(content, pos)
        if n_hdr.ok:
            name = ldap_bytes_to_text(ldap_slice(content, n_hdr.content_start, n_hdr.content_len))
            pos = n_hdr.next_offset
            val a_hdr = ldap_read_tlv_header(content, pos)
            if a_hdr.ok and a_hdr.tag == LDAP_TAG_AUTH_SIMPLE:
                password = ldap_slice(content, a_hdr.content_start, a_hdr.content_len)
    LdapBindRequest.new(version, LdapDn.new(name), LDAP_AUTH_SIMPLE, password)

# Decode a filter from its full TLV bytes (recursive, offset-based).
fn ldap_decode_filter(data: [u8]) -> LdapFilter:
    val no_children: [LdapFilter] = []
    val no_value: [u8] = []
    val hdr = ldap_read_tlv_header(data, 0)
    if not hdr.ok:
        return LdapFilter.new(LDAP_FILTER_PRESENT, "", no_value, no_children)
    if hdr.tag == LDAP_FILTER_TAG_PRESENT:
        val attr = ldap_bytes_to_text(ldap_slice(data, hdr.content_start, hdr.content_len))
        return LdapFilter.new(LDAP_FILTER_PRESENT, attr, no_value, no_children)
    elif hdr.tag == LDAP_FILTER_TAG_EQUALITY:
        # AVA SEQUENCE: desc OCTET STRING, value OCTET STRING
        val inner = ldap_slice(data, hdr.content_start, hdr.content_len)
        val d_hdr = ldap_read_tlv_header(inner, 0)
        var attr = ""
        var value: [u8] = []
        if d_hdr.ok:
            attr = ldap_bytes_to_text(ldap_slice(inner, d_hdr.content_start, d_hdr.content_len))
            val v_hdr = ldap_read_tlv_header(inner, d_hdr.next_offset)
            if v_hdr.ok:
                value = ldap_slice(inner, v_hdr.content_start, v_hdr.content_len)
        return LdapFilter.new(LDAP_FILTER_EQUALITY, attr, value, no_children)
    elif hdr.tag == LDAP_FILTER_TAG_AND or hdr.tag == LDAP_FILTER_TAG_OR:
        val inner = ldap_slice(data, hdr.content_start, hdr.content_len)
        var children: [LdapFilter] = []
        var pos: u64 = 0
        while pos < inner.len():
            val ch = ldap_read_tlv_header(inner, pos)
            if not ch.ok:
                break
            val child_bytes = ldap_slice(inner, pos, ch.next_offset - pos)
            children.push(ldap_decode_filter(child_bytes))
            pos = ch.next_offset
        if hdr.tag == LDAP_FILTER_TAG_AND:
            return LdapFilter.new(LDAP_FILTER_AND, "", no_value, children)
        else:
            return LdapFilter.new(LDAP_FILTER_OR, "", no_value, children)
    elif hdr.tag == LDAP_FILTER_TAG_NOT:
        val inner = ldap_slice(data, hdr.content_start, hdr.content_len)
        val child = ldap_decode_filter(inner)
        var notch: [LdapFilter] = []
        notch.push(child)
        return LdapFilter.new(LDAP_FILTER_NOT, "", no_value, notch)
    else:
        return LdapFilter.new(LDAP_FILTER_PRESENT, "", no_value, no_children)

# Decode a SearchRequest from its content bytes.
fn ldap_decode_search_request(content: [u8]) -> LdapSearchRequest:
    var pos: u64 = 0
    var base = ""
    var scope: i64 = LDAP_SCOPE_BASE_OBJECT
    var deref: i64 = LDAP_DEREF_NEVER
    var size_limit: i64 = 0
    var time_limit: i64 = 0
    var types_only = false
    val _fv: [u8] = []
    val _fc: [LdapFilter] = []
    var filter = LdapFilter.new(LDAP_FILTER_PRESENT, "", _fv, _fc)
    var attributes: [text] = []
    val b_hdr = ldap_read_tlv_header(content, pos)
    if b_hdr.ok:
        base = ldap_bytes_to_text(ldap_slice(content, b_hdr.content_start, b_hdr.content_len))
        pos = b_hdr.next_offset
        val s_hdr = ldap_read_tlv_header(content, pos)
        if s_hdr.ok:
            scope = ldap_decode_int_content(ldap_slice(content, s_hdr.content_start, s_hdr.content_len))
            pos = s_hdr.next_offset
            val dr_hdr = ldap_read_tlv_header(content, pos)
            if dr_hdr.ok:
                deref = ldap_decode_int_content(ldap_slice(content, dr_hdr.content_start, dr_hdr.content_len))
                pos = dr_hdr.next_offset
                val sl_hdr = ldap_read_tlv_header(content, pos)
                if sl_hdr.ok:
                    size_limit = ldap_decode_int_content(ldap_slice(content, sl_hdr.content_start, sl_hdr.content_len))
                    pos = sl_hdr.next_offset
                    val tl_hdr = ldap_read_tlv_header(content, pos)
                    if tl_hdr.ok:
                        time_limit = ldap_decode_int_content(ldap_slice(content, tl_hdr.content_start, tl_hdr.content_len))
                        pos = tl_hdr.next_offset
                        val to_hdr = ldap_read_tlv_header(content, pos)
                        if to_hdr.ok:
                            val tob = ldap_slice(content, to_hdr.content_start, to_hdr.content_len)
                            if tob.len() > 0:
                                types_only = tob[0] != 0x00
                            pos = to_hdr.next_offset
                            # filter (one full TLV)
                            val f_hdr = ldap_read_tlv_header(content, pos)
                            if f_hdr.ok:
                                val fb = ldap_slice(content, pos, f_hdr.next_offset - pos)
                                filter = ldap_decode_filter(fb)
                                pos = f_hdr.next_offset
                                # attributes SEQUENCE OF OCTET STRING
                                val at_hdr = ldap_read_tlv_header(content, pos)
                                if at_hdr.ok and at_hdr.tag == 0x30:
                                    val inner = ldap_slice(content, at_hdr.content_start, at_hdr.content_len)
                                    var ap: u64 = 0
                                    while ap < inner.len():
                                        val a1 = ldap_read_tlv_header(inner, ap)
                                        if not a1.ok:
                                            break
                                        attributes.push(ldap_bytes_to_text(ldap_slice(inner, a1.content_start, a1.content_len)))
                                        ap = a1.next_offset
    LdapSearchRequest.new(LdapDn.new(base), scope, deref, size_limit, time_limit, types_only, filter, attributes)

# Decode a SearchResultEntry from its content bytes.
fn ldap_decode_search_entry(content: [u8]) -> LdapEntry:
    var pos: u64 = 0
    var dn = ""
    var attributes: [LdapAttribute] = []
    val dn_hdr = ldap_read_tlv_header(content, pos)
    if dn_hdr.ok:
        dn = ldap_bytes_to_text(ldap_slice(content, dn_hdr.content_start, dn_hdr.content_len))
        pos = dn_hdr.next_offset
        val pal_hdr = ldap_read_tlv_header(content, pos)
        if pal_hdr.ok and pal_hdr.tag == 0x30:
            val pal = ldap_slice(content, pal_hdr.content_start, pal_hdr.content_len)
            var pp: u64 = 0
            while pp < pal.len():
                val attr_hdr = ldap_read_tlv_header(pal, pp)
                if not attr_hdr.ok:
                    break
                val attr_inner = ldap_slice(pal, attr_hdr.content_start, attr_hdr.content_len)
                # type OCTET STRING
                val t_hdr = ldap_read_tlv_header(attr_inner, 0)
                var atype = ""
                var avals: [[u8]] = []
                if t_hdr.ok:
                    atype = ldap_bytes_to_text(ldap_slice(attr_inner, t_hdr.content_start, t_hdr.content_len))
                    # SET OF value
                    val set_hdr = ldap_read_tlv_header(attr_inner, t_hdr.next_offset)
                    if set_hdr.ok:
                        val setb = ldap_slice(attr_inner, set_hdr.content_start, set_hdr.content_len)
                        var sp: u64 = 0
                        while sp < setb.len():
                            val v_hdr = ldap_read_tlv_header(setb, sp)
                            if not v_hdr.ok:
                                break
                            avals.push(ldap_slice(setb, v_hdr.content_start, v_hdr.content_len))
                            sp = v_hdr.next_offset
                attributes.push(LdapAttribute.new(atype, avals))
                pp = attr_hdr.next_offset
    LdapEntry.new(LdapDn.new(dn), attributes)
