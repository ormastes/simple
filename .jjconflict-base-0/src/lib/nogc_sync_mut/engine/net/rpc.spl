# RPC Dispatcher — remote procedure call registration and dispatch

struct RPCCall:
    method: text
    sender_id: i32
    args: [text]
    timestamp: f64

struct RPCRegistration:
    method: text
    target: text
    reliable: bool

class RPCDispatcher:
    registrations: [RPCRegistration]
    call_log: [RPCCall]
    max_log_size: i32

impl RPCDispatcher:
    static fn new(max_log: i32) -> RPCDispatcher:
        RPCDispatcher(registrations: [], call_log: [], max_log_size: max_log)

    me register(method: text, target: text, reliable: bool) -> bool:
        var i = 0
        while i < self.registrations.len():
            if self.registrations[i].method == method:
                return false
            i = i + 1
        val reg = RPCRegistration(method: method, target: target, reliable: reliable)
        self.registrations.push(reg)
        true

    me unregister(method: text) -> bool:
        var new_regs: [RPCRegistration] = []
        var removed = false
        var i = 0
        while i < self.registrations.len():
            if self.registrations[i].method == method:
                removed = true
            else:
                new_regs.push(self.registrations[i])
            i = i + 1
        self.registrations = new_regs
        removed

    me dispatch(method: text, sender_id: i32, args: [text], timestamp: f64) -> bool:
        var found = false
        var i = 0
        while i < self.registrations.len():
            if self.registrations[i].method == method:
                found = true
            i = i + 1
        if not found:
            return false
        val call = RPCCall(method: method, sender_id: sender_id, args: args, timestamp: timestamp)
        self.call_log.push(call)
        if self.call_log.len() > self.max_log_size:
            var trimmed: [RPCCall] = []
            var j = self.call_log.len() - self.max_log_size
            while j < self.call_log.len():
                trimmed.push(self.call_log[j])
                j = j + 1
            self.call_log = trimmed
        true

    fn is_registered(method: text) -> bool:
        var i = 0
        while i < self.registrations.len():
            if self.registrations[i].method == method:
                return true
            i = i + 1
        false

    fn registration_count() -> i32:
        self.registrations.len().to_i32()

    fn call_count() -> i32:
        self.call_log.len().to_i32()

    fn get_last_call() -> RPCCall?:
        if self.call_log.len() == 0:
            return nil
        self.call_log[self.call_log.len() - 1]
