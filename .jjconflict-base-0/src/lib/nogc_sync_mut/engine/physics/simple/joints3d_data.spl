# Physics System — 3D Joint Data (Joint3D / JointStorage3D)
#
# Shared joint data types. Split out of simple/world3d.spl so that
# physics/world3d.spl can re-export Joint3D/JointStorage3D without pulling
# simple/world3d.spl's PhysicsWorld3D class into the same compile unit —
# that duplicate class name collides in the flattened type registry and
# mis-types `self.bodies` (Array.add_dynamic dispatch bug, see
# doc/08_tracking/bug/cranelift_f32_trig_wrapper_codegen_2026-07-02.md).

use std.common.engine.ids.{NodeId}
use std.common.engine.math3d.{Vec3}

# ============================================================================
# Joint3D — Internal joint representation
# ============================================================================

class Joint3D:
    joint_type: i64        # 0=ball_socket, 1=fixed, 2=spring
    node_a: NodeId
    node_b: NodeId
    anchor: Vec3           # World-space anchor for ball socket
    rest_length: f64       # For spring joints
    stiffness: f64         # For spring joints
    damping: f64           # For spring joints
    offset: Vec3           # Initial offset for fixed joints

# ============================================================================
# JointStorage3D — manages all joints in the world
# ============================================================================

class JointStorage3D:
    joints: [Joint3D]
    next_id: i64

impl JointStorage3D:
    static fn create() -> JointStorage3D:
        JointStorage3D(joints: [], next_id: 0)

    me add(joint: Joint3D) -> i64:
        val id = self.next_id
        self.joints.push(joint)
        self.next_id = self.next_id + 1
        id

    me remove(idx: i64) -> bool:
        if idx < 0 or idx >= self.joints.len():
            return false
        var new_joints: [Joint3D] = []
        var i = 0
        while i < self.joints.len():
            if i != idx:
                new_joints.push(self.joints[i])
            i = i + 1
        self.joints = new_joints
        true

export Joint3D, JointStorage3D
