# Tilemap — grid-based tile rendering for 2D games
#
# Supports tile sets with margin/spacing, multiple named layers,
# world-to-tile and tile-to-world coordinate conversion.
#
# Usage:
#   val ts = TileSet.new("tiles.png", 16, 16, 10)
#   var map = TileMap.new(ts, 20, 15)
#   val layer_idx = map.add_layer("ground")
#   map.get_layer(layer_idx).set_tile(5, 3, 42)

# ============================================================================
# TileRect — source rectangle within a tile sheet
# ============================================================================

struct TileRect:
    x: i32
    y: i32
    width: i32
    height: i32

# ============================================================================
# TileCoord — grid coordinate (column, row)
# ============================================================================

struct TileCoord:
    col: i32
    row: i32

# ============================================================================
# TileWorldPos — world-space position for a tile origin
# ============================================================================

struct TileWorldPos:
    x: f64
    y: f64

# ============================================================================
# TileSet — texture atlas of same-sized tiles
# ============================================================================

struct TileSet:
    texture_path: text
    tile_width: i32
    tile_height: i32
    columns: i32
    margin: i32
    spacing: i32

impl TileSet:
    static fn new(texture_path: text, tile_w: i32, tile_h: i32, columns: i32) -> TileSet:
        """Create a tile set with no margin or spacing."""
        TileSet(
            texture_path: texture_path,
            tile_width: tile_w,
            tile_height: tile_h,
            columns: columns,
            margin: 0,
            spacing: 0
        )

    fn tile_src_rect(self, tile_id: i32) -> TileRect:
        """Convert a tile_id to the source rectangle in the texture.
        Tiles are indexed left-to-right, top-to-bottom."""
        if tile_id < 0:
            return TileRect(x: 0, y: 0, width: 0, height: 0)
        val col = tile_id % self.columns
        val row = tile_id / self.columns
        val x = self.margin + col * (self.tile_width + self.spacing)
        val y = self.margin + row * (self.tile_height + self.spacing)
        TileRect(x: x, y: y, width: self.tile_width, height: self.tile_height)

# ============================================================================
# TileLayer — single grid of tile IDs
# ============================================================================

class TileLayer:
    name: text
    width: i32
    height: i32
    tiles: [i32]
    visible: bool
    opacity: f64
    offset_x: f64
    offset_y: f64

impl TileLayer:
    static fn new(name: text, width: i32, height: i32) -> TileLayer:
        """Create a tile layer initialized with all empty tiles (-1)."""
        var tiles: [i32] = []
        val total = width * height
        var i = 0
        while i < total:
            tiles = tiles.push(-1)
            i = i + 1
        TileLayer(
            name: name,
            width: width,
            height: height,
            tiles: tiles,
            visible: true,
            opacity: 1.0,
            offset_x: 0.0,
            offset_y: 0.0
        )

    me set_tile(col: i32, row: i32, tile_id: i32):
        """Set the tile ID at (col, row). Out-of-bounds writes are ignored."""
        if col >= 0:
            if col < self.width:
                if row >= 0:
                    if row < self.height:
                        val idx = row * self.width + col
                        self.tiles[idx] = tile_id

    fn get_tile(self, col: i32, row: i32) -> i32:
        """Get the tile ID at (col, row). Returns -1 for out-of-bounds."""
        if col < 0:
            return -1
        if col >= self.width:
            return -1
        if row < 0:
            return -1
        if row >= self.height:
            return -1
        val idx = row * self.width + col
        self.tiles[idx]

    me fill(tile_id: i32):
        """Fill the entire layer with a single tile ID."""
        var i = 0
        while i < self.tiles.len():
            self.tiles[i] = tile_id
            i = i + 1

    me clear_all():
        """Clear the entire layer to empty (-1)."""
        var i = 0
        while i < self.tiles.len():
            self.tiles[i] = -1
            i = i + 1

    fn cell_count(self) -> i32:
        """Return the total number of cells in this layer."""
        self.width * self.height

# ============================================================================
# TileMap — collection of layers sharing a single tile set
# ============================================================================

class TileMap:
    tile_set: TileSet
    layers: [TileLayer]
    map_width: i32
    map_height: i32

impl TileMap:
    static fn new(tile_set: TileSet, width: i32, height: i32) -> TileMap:
        """Create a tile map with no layers."""
        TileMap(
            tile_set: tile_set,
            layers: [],
            map_width: width,
            map_height: height
        )

    me add_layer(name: text) -> i32:
        """Add a new layer and return its index."""
        val layer = TileLayer.new(name, self.map_width, self.map_height)
        val idx = self.layers.len()
        self.layers = self.layers.push(layer)
        idx

    me remove_layer(index: i32):
        """Remove a layer by index. Out-of-bounds is ignored."""
        if index < 0:
            return
        if index >= self.layers.len():
            return
        var new_layers: [TileLayer] = []
        var i = 0
        while i < self.layers.len():
            if i != index:
                new_layers = new_layers.push(self.layers[i])
            i = i + 1
        self.layers = new_layers

    fn layer_count(self) -> i32:
        """Return the number of layers."""
        self.layers.len()

    fn get_layer(self, index: i32) -> TileLayer?:
        """Return the layer at the given index, or nil if out of bounds."""
        if index < 0:
            return nil
        if index >= self.layers.len():
            return nil
        self.layers[index]

    fn world_width(self) -> f64:
        """Total world width in pixels."""
        (self.map_width * self.tile_set.tile_width) as f64

    fn world_height(self) -> f64:
        """Total world height in pixels."""
        (self.map_height * self.tile_set.tile_height) as f64

    fn world_to_tile(self, world_x: f64, world_y: f64) -> TileCoord:
        """Convert world-space position to tile grid coordinate."""
        val col = (world_x / self.tile_set.tile_width as f64) as i32
        val row = (world_y / self.tile_set.tile_height as f64) as i32
        TileCoord(col: col, row: row)

    fn tile_to_world(self, col: i32, row: i32) -> TileWorldPos:
        """Convert tile grid coordinate to world-space position (top-left corner)."""
        val x = (col * self.tile_set.tile_width) as f64
        val y = (row * self.tile_set.tile_height) as f64
        TileWorldPos(x: x, y: y)
