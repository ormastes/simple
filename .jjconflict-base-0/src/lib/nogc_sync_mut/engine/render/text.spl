#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# Text Renderer — Glyph-by-glyph text rendering into pixel buffer
#
# Renders text strings using font glyph bitmaps, blitting alpha-weighted
# pixels into a target pixel buffer. Supports basic line wrapping and color.

use std.common.engine.color.{EngineColor}
use std.common.engine.rect.{Rect2}
use std.nogc_sync_mut.io.font_ffi.{FontHandle, GlyphBitmap, GlyphMetrics, get_glyph, get_line_height}

# Text alignment options
enum TextAlign:
    Left
    Center
    Right

impl TextAlign:
    fn to_text() -> text:
        match self:
            case Left: "Left"
            case Center: "Center"
            case Right: "Right"

# Text rendering configuration
class TextStyle:
    font: FontHandle
    size_px: i64
    color: EngineColor
    align: TextAlign
    line_spacing: f64    # Multiplier on line height (1.0 = normal)

impl TextStyle:
    static fn default_style(font: FontHandle) -> TextStyle:
        TextStyle(
            font: font,
            size_px: 16,
            color: EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0),
            align: TextAlign.Left,
            line_spacing: 1.2
        )

# Measured text dimensions
class TextMetrics:
    width: i64
    height: i64
    line_count: i64

# Measure text dimensions without rendering
fn measure_text(content: text, style: TextStyle) -> TextMetrics:
    var max_width = 0
    var current_width = 0
    var lines = 1
    val line_h = get_line_height(style.font, style.size_px)
    var i = 0
    val chars = content.chars()
    while i < chars.len():
        val ch = chars[i]
        if ch == "\n":
            if current_width > max_width:
                max_width = current_width
            current_width = 0
            lines = lines + 1
        else:
            val cp = ch.codepoint()
            val glyph_opt = get_glyph(style.font, cp, style.size_px)
            if val Some(g) = glyph_opt:
                current_width = current_width + g.metrics.advance
        i = i + 1
    if current_width > max_width:
        max_width = current_width
    val total_height_f = line_h * 1.0 * style.line_spacing * lines * 1.0
    val total_height: i64 = total_height_f
    TextMetrics(width: max_width, height: total_height, line_count: lines)

# Render text into a pixel buffer
# pixels: mutable pixel array (RGBA packed), buf_width/buf_height: buffer dims
# x, y: top-left position to start rendering
fn render_text_to_buffer(
    content: text,
    style: TextStyle,
    pixels: [i64],
    buf_width: i64,
    buf_height: i64,
    start_x: i64,
    start_y: i64
) -> [i64]:
    var result = pixels
    val line_h = get_line_height(style.font, style.size_px)
    val line_step_f = line_h * 1.0 * style.line_spacing
    val line_step: i64 = line_step_f
    var cursor_x = start_x
    var cursor_y = start_y
    val chars = content.chars()
    var i = 0
    while i < chars.len():
        val ch = chars[i]
        if ch == "\n":
            cursor_x = start_x
            cursor_y = cursor_y + line_step
        else:
            val cp = ch.codepoint()
            val glyph_opt = get_glyph(style.font, cp, style.size_px)
            if val Some(g) = glyph_opt:
                result = _blit_glyph(result, buf_width, buf_height, cursor_x, cursor_y, g, style.color)
                cursor_x = cursor_x + g.metrics.advance
        i = i + 1
    result

# Blit a single glyph bitmap into the pixel buffer with color tinting
fn _blit_glyph(
    pixels: [i64],
    buf_width: i64,
    buf_height: i64,
    gx: i64,
    gy: i64,
    glyph: GlyphBitmap,
    color: EngineColor
) -> [i64]:
    var result = pixels
    var row = 0
    while row < glyph.height:
        val py = gy + row
        if py >= 0 and py < buf_height:
            var col = 0
            while col < glyph.width:
                val px = gx + col
                if px >= 0 and px < buf_width:
                    val glyph_idx = row * glyph.width + col
                    val alpha_i = glyph.pixels[glyph_idx]
                    if alpha_i > 0:
                        val alpha = alpha_i * 1.0 / 255.0
                        val final_a = alpha * color.a
                        val buf_idx = py * buf_width + px
                        val dst_packed = result[buf_idx]
                        # Unpack destination
                        val dr = (dst_packed / 16777216) % 256
                        val dg_val = (dst_packed / 65536) % 256
                        val db = (dst_packed / 256) % 256
                        val da = dst_packed % 256
                        # Alpha blend
                        val inv_a = 1.0 - final_a
                        val out_r_f = color.r * final_a * 255.0 + dr * 1.0 * inv_a
                        val out_g_f = color.g * final_a * 255.0 + dg_val * 1.0 * inv_a
                        val out_b_f = color.b * final_a * 255.0 + db * 1.0 * inv_a
                        val out_a_f = final_a * 255.0 + da * 1.0 * inv_a
                        val or_i: i64 = out_r_f
                        val og_i: i64 = out_g_f
                        val ob_i: i64 = out_b_f
                        val oa_i: i64 = out_a_f
                        result[buf_idx] = or_i * 16777216 + og_i * 65536 + ob_i * 256 + oa_i
                col = col + 1
        row = row + 1
    result
