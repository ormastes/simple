# Camera Render Order Helpers
#
# Provides pure functions for sorting camera render orders
# and comparing camera draw precedence.

fn sort_camera_orders(orders: [i64]) -> [i64]:
    """Sort camera render orders in ascending order (stable).

    Args:
        orders: Array of render order values

    Returns:
        New sorted array in ascending order
    """
    # Insertion sort - simpler and stabler for small arrays
    var result: [i64] = []
    var i = 0
    while i < orders.length():
        val val_to_insert = orders.at(i)
        var j = 0
        var inserted = false
        while j < result.length():
            if not inserted and result.at(j) >= val_to_insert:
                # Insert here
                val left = result.slice(0, j)
                val right = result.slice(j, result.length())
                result = left + [val_to_insert] + right
                inserted = true
            j = j + 1
        if not inserted:
            result = result + [val_to_insert]
        i = i + 1
    result

fn camera_draws_after(a: i64, b: i64) -> bool:
    """Return true if camera a should draw after camera b.

    Camera a draws after b if a's render_order is greater than b's.

    Args:
        a: Render order of first camera
        b: Render order of second camera

    Returns:
        true if a > b, false otherwise
    """
    a > b

export sort_camera_orders
export camera_draws_after
