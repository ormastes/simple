# Camera2D Helpers — world/screen coordinate transformations
#
# Provides camera projection, unprojection, visible bounds, and zoom control.
#
# Usage:
#   val cam = CameraData.create(800.0, 600.0)
#   val screen_pos = cam.world_to_screen(world_pos, camera_pos)
#   val bounds = cam.visible_bounds(camera_pos)
#   val zoomed = cam.with_zoom(ZoomLevel(value: 2.0))

use std.common.engine.math2d.{Vec2}
use std.common.engine.rect.{Rect2}
use std.common.engine.units.{ZoomLevel}
use std.nogc_sync_mut.engine.component.registry.{CameraData}

# ============================================================================
# CameraData helpers
# ============================================================================

impl CameraData:
    static fn create(viewport_width: f64, viewport_height: f64) -> CameraData:
        """Create a camera with default zoom (1.0) and active state.

        Args:
            viewport_width: Width of the viewport in pixels
            viewport_height: Height of the viewport in pixels
        """
        CameraData(
            zoom: ZoomLevel(value: 1.0),
            viewport_width: viewport_width,
            viewport_height: viewport_height,
            is_active: true
        )

    fn world_to_screen(world_pos: Vec2, camera_pos: Vec2) -> Vec2:
        """Convert a world position to screen coordinates.

        Centers the camera on camera_pos.
        Applies zoom: further zoom = larger on screen.
        Screen origin is top-left of viewport.

        Args:
            world_pos: Position in world space
            camera_pos: Camera center in world space

        Returns:
            Position in screen space (pixels from top-left)
        """
        val half_w = self.viewport_width / 2.0
        val half_h = self.viewport_height / 2.0
        val dx = world_pos.x - camera_pos.x
        val dy = world_pos.y - camera_pos.y
        val sx = half_w + dx * self.zoom.value
        val sy = half_h + dy * self.zoom.value
        Vec2(x: sx, y: sy)

    fn screen_to_world(screen_pos: Vec2, camera_pos: Vec2) -> Vec2:
        """Convert screen coordinates to world position (inverse of world_to_screen).

        Args:
            screen_pos: Position in screen space (pixels from top-left)
            camera_pos: Camera center in world space

        Returns:
            Position in world space
        """
        val half_w = self.viewport_width / 2.0
        val half_h = self.viewport_height / 2.0
        val dx = (screen_pos.x - half_w) / self.zoom.value
        val dy = (screen_pos.y - half_h) / self.zoom.value
        val wx = camera_pos.x + dx
        val wy = camera_pos.y + dy
        Vec2(x: wx, y: wy)

    fn visible_bounds(camera_pos: Vec2) -> Rect2:
        """Compute the world-space AABB of the visible area.

        The visible area is centered on camera_pos, sized by viewport / zoom.

        Args:
            camera_pos: Camera center in world space

        Returns:
            Axis-aligned bounding rect in world space
        """
        val world_w = self.viewport_width / self.zoom.value
        val world_h = self.viewport_height / self.zoom.value
        val half_w = world_w / 2.0
        val half_h = world_h / 2.0
        Rect2(
            x: camera_pos.x - half_w,
            y: camera_pos.y - half_h,
            width: world_w,
            height: world_h
        )

    fn with_zoom(zoom: ZoomLevel) -> CameraData:
        """Return a copy with the given zoom level.

        Args:
            zoom: New zoom level (ZoomLevel(value: 1.0) = normal, 2.0 = 2x magnification)
        """
        CameraData(
            zoom: zoom,
            viewport_width: self.viewport_width,
            viewport_height: self.viewport_height,
            is_active: self.is_active
        )
