# Skeletal Animation — Skinning Data
#
# Per-vertex bone influences for mesh skinning. Each vertex can be
# influenced by up to 4 bones with corresponding weights.

# --------------------------------------------------------------------------
# SkinWeight — bone influences for a single vertex
# --------------------------------------------------------------------------

struct SkinWeight:
    bone_indices: [i32]
    weights: [f64]

impl SkinWeight:
    static fn new() -> SkinWeight:
        SkinWeight(
            bone_indices: [],
            weights: []
        )

    me add_influence(bone_index: i32, weight: f64):
        if self.bone_indices.len() >= 4:
            return
        self.bone_indices.push(bone_index)
        self.weights.push(weight)

    fn influence_count() -> i32:
        self.bone_indices.len()

# --------------------------------------------------------------------------
# SkinData — per-mesh skinning weights
# --------------------------------------------------------------------------

struct SkinData:
    vertex_weights: [SkinWeight]

impl SkinData:
    static fn new() -> SkinData:
        SkinData(
            vertex_weights: []
        )

    me add_vertex_weight(sw: SkinWeight):
        self.vertex_weights.push(sw)

    fn vertex_count() -> i32:
        self.vertex_weights.len()
