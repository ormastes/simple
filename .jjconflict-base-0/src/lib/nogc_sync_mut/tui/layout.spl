"""TUI Layout Module - Spatial arrangement of widgets.

@tag:stdlib
@tag:tui

Provides layout primitives for dividing terminal screen areas into
sub-regions: vertical stacking (VBox), horizontal stacking (HBox),
and proportional splitting.

# Usage

```simple
use std.tui.layout.*
use std.tui.widget.{make_rect}

val area = make_rect(0, 0, 80, 24)

# Split vertically into 3 parts: 20%, 60%, 20%
val parts = split_vertical(area, [20, 60, 20])
val header = parts[0]
val body = parts[1]
val footer = parts[2]

# Split horizontally into 2 equal halves
val cols = split_horizontal(area, [50, 50])
```
"""

use std.tui.widget.{Rect, make_rect}

# ============================================================================
# Direction
# ============================================================================

val DIRECTION_VERTICAL: i64 = 0
val DIRECTION_HORIZONTAL: i64 = 1

# ============================================================================
# Proportional Split
# ============================================================================

fn split_vertical(area: Rect, ratios: [i64]) -> [Rect]:
    """Divide an area into vertically stacked sub-areas by ratio.

    Each ratio value is relative to the sum of all ratios. For example,
    [1, 2, 1] divides the height into 25%, 50%, 25%.

    Args:
        area: The area to divide
        ratios: List of integer ratios

    Returns:
        List of Rects stacked top to bottom
    """
    if len(ratios) == 0:
        return []

    var total_ratio: i64 = 0
    var i = 0
    while i < len(ratios):
        total_ratio = total_ratio + ratios[i]
        i = i + 1

    if total_ratio <= 0:
        return []

    var results: [Rect] = []
    var current_y = area.y
    var remaining_height = area.height
    var j = 0
    while j < len(ratios):
        var h: i64 = 0
        if j == len(ratios) - 1:
            # Last item gets all remaining height to avoid rounding gaps
            h = remaining_height
        else:
            h = area.height * ratios[j] / total_ratio
            if h > remaining_height:
                h = remaining_height
        results = results + [make_rect(area.x, current_y, area.width, h)]
        current_y = current_y + h
        remaining_height = remaining_height - h
        j = j + 1

    results

fn split_horizontal(area: Rect, ratios: [i64]) -> [Rect]:
    """Divide an area into horizontally arranged sub-areas by ratio.

    Each ratio value is relative to the sum of all ratios.

    Args:
        area: The area to divide
        ratios: List of integer ratios

    Returns:
        List of Rects arranged left to right
    """
    if len(ratios) == 0:
        return []

    var total_ratio: i64 = 0
    var i = 0
    while i < len(ratios):
        total_ratio = total_ratio + ratios[i]
        i = i + 1

    if total_ratio <= 0:
        return []

    var results: [Rect] = []
    var current_x = area.x
    var remaining_width = area.width
    var j = 0
    while j < len(ratios):
        var w: i64 = 0
        if j == len(ratios) - 1:
            w = remaining_width
        else:
            w = area.width * ratios[j] / total_ratio
            if w > remaining_width:
                w = remaining_width
        results = results + [make_rect(current_x, area.y, w, area.height)]
        current_x = current_x + w
        remaining_width = remaining_width - w
        j = j + 1

    results

# ============================================================================
# Fixed-size Split
# ============================================================================

fn split_vertical_fixed(area: Rect, sizes: [i64]) -> [Rect]:
    """Divide an area vertically with fixed pixel heights.

    A size of -1 means "take remaining space". Only one -1 is supported.

    Args:
        area: The area to divide
        sizes: List of fixed heights (-1 for flex)

    Returns:
        List of Rects stacked top to bottom
    """
    # Calculate total fixed and find flex index
    var total_fixed: i64 = 0
    var flex_idx: i64 = -1
    var i = 0
    while i < len(sizes):
        if sizes[i] == -1:
            flex_idx = i
        else:
            total_fixed = total_fixed + sizes[i]
        i = i + 1

    var flex_size: i64 = 0
    if flex_idx >= 0:
        flex_size = area.height - total_fixed
        if flex_size < 0:
            flex_size = 0

    var results: [Rect] = []
    var current_y = area.y
    var j = 0
    while j < len(sizes):
        var h = sizes[j]
        if h == -1:
            h = flex_size
        results = results + [make_rect(area.x, current_y, area.width, h)]
        current_y = current_y + h
        j = j + 1

    results

fn split_horizontal_fixed(area: Rect, sizes: [i64]) -> [Rect]:
    """Divide an area horizontally with fixed pixel widths.

    A size of -1 means "take remaining space". Only one -1 is supported.

    Args:
        area: The area to divide
        sizes: List of fixed widths (-1 for flex)

    Returns:
        List of Rects arranged left to right
    """
    var total_fixed: i64 = 0
    var flex_idx: i64 = -1
    var i = 0
    while i < len(sizes):
        if sizes[i] == -1:
            flex_idx = i
        else:
            total_fixed = total_fixed + sizes[i]
        i = i + 1

    var flex_size: i64 = 0
    if flex_idx >= 0:
        flex_size = area.width - total_fixed
        if flex_size < 0:
            flex_size = 0

    var results: [Rect] = []
    var current_x = area.x
    var j = 0
    while j < len(sizes):
        var w = sizes[j]
        if w == -1:
            w = flex_size
        results = results + [make_rect(current_x, area.y, w, area.height)]
        current_x = current_x + w
        j = j + 1

    results

# ============================================================================
# Margin / Padding
# ============================================================================

struct Margin:
    """Margin around a widget area.

    Fields:
        top: Top margin in rows
        right: Right margin in columns
        bottom: Bottom margin in rows
        left: Left margin in columns
    """
    top: i64
    right: i64
    bottom: i64
    left: i64

fn make_margin(top: i64, right: i64, bottom: i64, left: i64) -> Margin:
    """Create a Margin."""
    Margin(top: top, right: right, bottom: bottom, left: left)

fn make_uniform_margin(size: i64) -> Margin:
    """Create a uniform margin with equal spacing on all sides."""
    Margin(top: size, right: size, bottom: size, left: size)

fn apply_margin(area: Rect, m: Margin) -> Rect:
    """Apply margin to shrink an area.

    Args:
        area: Original area
        m: Margin to apply

    Returns:
        Shrunk Rect, clamped to non-negative dimensions
    """
    var w = area.width - m.left - m.right
    var h = area.height - m.top - m.bottom
    if w < 0:
        w = 0
    if h < 0:
        h = 0
    make_rect(area.x + m.left, area.y + m.top, w, h)

# ============================================================================
# Centering
# ============================================================================

fn center_rect(outer: Rect, inner_width: i64, inner_height: i64) -> Rect:
    """Center a rectangle of given size within an outer rectangle.

    Args:
        outer: The outer area
        inner_width: Desired inner width
        inner_height: Desired inner height

    Returns:
        Centered Rect clamped to outer bounds
    """
    var w = inner_width
    var h = inner_height
    if w > outer.width:
        w = outer.width
    if h > outer.height:
        h = outer.height
    val x = outer.x + (outer.width - w) / 2
    val y = outer.y + (outer.height - h) / 2
    make_rect(x, y, w, h)
