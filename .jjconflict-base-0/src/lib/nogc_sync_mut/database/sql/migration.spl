# Typed SQL Database Library - Schema Migration System
#
# Tracks applied migrations in a `_migrations` table.
# Supports forward (up) and backward (down) migration with ordering.

use std.database.sql.types.{DbValue, DbError}
use std.database.sql.connection.{Database}

# ============================================================================
# Migration — a single schema change with up/down SQL
# ============================================================================

struct Migration:
    id: text               # e.g. "001_create_users"
    description: text      # human-readable description
    up_sql: text           # SQL to apply
    down_sql: text         # SQL to reverse

# ============================================================================
# MigrationStatus — status of a single migration
# ============================================================================

struct MigrationStatus:
    id: text
    description: text
    applied: bool
    applied_at: text?      # ISO timestamp or nil

# ============================================================================
# MigrationRunner — applies and rolls back migrations
# ============================================================================

class MigrationRunner:
    db: Database
    migrations: [Migration]

    # ------------------------------------------------------------------
    # Create a new MigrationRunner with empty migration list.
    # ------------------------------------------------------------------
    static fn new(db: Database) -> MigrationRunner:
        MigrationRunner(db: db, migrations: [])

    # ------------------------------------------------------------------
    # Add a migration to the runner. Returns self for chaining.
    # ------------------------------------------------------------------
    me add(m: Migration) -> MigrationRunner:
        self.migrations.push(m)
        self

    # ------------------------------------------------------------------
    # Ensure the _migrations tracking table exists.
    # ------------------------------------------------------------------
    me ensure_table() -> Result<(), DbError>:
        val sql = "CREATE TABLE IF NOT EXISTS _migrations (id TEXT PRIMARY KEY, description TEXT NOT NULL, applied_at TEXT NOT NULL)"
        self.db.exec(sql, [])?
        Ok(())

    # ------------------------------------------------------------------
    # Run all pending migrations.
    # Returns the count of newly applied migrations.
    # ------------------------------------------------------------------
    me run() -> Result<i64, DbError>:
        self.ensure_table()?

        val applied_ids = self.applied()?

        var count: i64 = 0
        for m in self.migrations:
            val already_applied = _list_contains(applied_ids, m.id)
            if not already_applied:
                self.db.exec(m.up_sql, [])?

                val insert_sql = "INSERT INTO _migrations (id, description, applied_at) VALUES (?, ?, datetime('now'))"
                var params: [DbValue] = []
                params.push(DbValue.Text(value: m.id))
                params.push(DbValue.Text(value: m.description))
                self.db.exec(insert_sql, params)?

                count = count + 1

        Ok(count)

    # ------------------------------------------------------------------
    # Rollback the last `count` applied migrations.
    # Returns the count actually rolled back.
    # ------------------------------------------------------------------
    me rollback(count: i64) -> Result<i64, DbError>:
        self.ensure_table()?

        # Get applied migration IDs in reverse order (most recent first)
        val query_sql = "SELECT id FROM _migrations ORDER BY applied_at DESC"
        val rows = self.db.query(query_sql, [])?

        var rolled_back: i64 = 0
        for row in rows:
            if rolled_back >= count:
                break

            val id_opt = row.get_text("id")
            if val Some(mid) = id_opt:
                # Find matching migration definition
                val migration_opt = _find_migration(self.migrations, mid)
                if val Some(migration) = migration_opt:
                    self.db.exec(migration.down_sql, [])?

                    val delete_sql = "DELETE FROM _migrations WHERE id = ?"
                    var params: [DbValue] = []
                    params.push(DbValue.Text(value: mid))
                    self.db.exec(delete_sql, params)?

                    rolled_back = rolled_back + 1

        Ok(rolled_back)

    # ------------------------------------------------------------------
    # Get list of applied migration IDs ordered by applied_at.
    # ------------------------------------------------------------------
    fn applied() -> Result<[text], DbError>:
        self.ensure_table()?

        val query_sql = "SELECT id FROM _migrations ORDER BY applied_at"
        val rows = self.db.query(query_sql, [])?

        var ids: [text] = []
        for row in rows:
            val id_opt = row.get_text("id")
            if val Some(id) = id_opt:
                ids.push(id)
        Ok(ids)

    # ------------------------------------------------------------------
    # Get list of migrations not yet applied.
    # ------------------------------------------------------------------
    fn pending() -> Result<[Migration], DbError>:
        val applied_ids = self.applied()?

        var result: [Migration] = []
        for m in self.migrations:
            val already_applied = _list_contains(applied_ids, m.id)
            if not already_applied:
                result.push(m)
        Ok(result)

    # ------------------------------------------------------------------
    # Get status of all registered migrations.
    # ------------------------------------------------------------------
    fn status() -> Result<[MigrationStatus], DbError>:
        self.ensure_table()?

        val query_sql = "SELECT id, applied_at FROM _migrations"
        val rows = self.db.query(query_sql, [])?

        # Build a lookup of applied migration timestamps
        var applied_map: [text] = []
        var applied_times: [text] = []
        for row in rows:
            val id_opt = row.get_text("id")
            val time_opt = row.get_text("applied_at")
            if val Some(id) = id_opt:
                applied_map.push(id)
                if val Some(t) = time_opt:
                    applied_times.push(t)
                else:
                    applied_times.push("")

        var result: [MigrationStatus] = []
        for m in self.migrations:
            val idx = _list_index_of(applied_map, m.id)
            if idx >= 0:
                val ts = applied_times[idx]
                val status = MigrationStatus(
                    id: m.id,
                    description: m.description,
                    applied: true,
                    applied_at: Some(ts)
                )
                result.push(status)
            else:
                val status = MigrationStatus(
                    id: m.id,
                    description: m.description,
                    applied: false,
                    applied_at: nil
                )
                result.push(status)

        Ok(result)

# ============================================================================
# Internal helpers
# ============================================================================

fn _list_contains(list: [text], item: text) -> bool:
    for entry in list:
        if entry == item:
            return true
    false

fn _list_index_of(list: [text], item: text) -> i64:
    for i in 0..list.len():
        if list[i] == item:
            return i
    -1

fn _find_migration(migrations: [Migration], id: text) -> Migration?:
    for m in migrations:
        if m.id == id:
            return Some(m)
    nil
