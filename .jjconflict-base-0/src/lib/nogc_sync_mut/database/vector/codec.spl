fn encode_vector(v: [f64]) -> text:
    var parts: [text] = []
    var i = 0
    while i < v.len():
        parts.push(v[i].to_text())
        i = i + 1
    parts.join(",")

fn decode_vector(s: text) -> [f64]?:
    if s.len() == 0:
        return nil
    val parts = s.split(",")
    var out: [f64] = []
    var i = 0
    while i < parts.len():
        val raw_part = parts[i]
        val trimmed = raw_part.trim()
        if val Some(parsed) = _parse_vector_f64(trimmed):
            out.push(parsed)
        else:
            return nil
        i = i + 1
    Some(out)

fn _digit_value(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1

fn _parse_vector_f64(s: text) -> f64?:
    if s.len() == 0:
        return nil
    var sign = 1.0
    var pos = 0
    if s.substring(0, 1) == "-":
        sign = -1.0
        pos = 1
    elif s.substring(0, 1) == "+":
        pos = 1

    var int_value: i64 = 0
    var saw_digit = false
    while pos < s.len() and s.substring(pos, pos + 1) != ".":
        val digit = _digit_value(s.substring(pos, pos + 1))
        if digit < 0:
            return nil
        int_value = int_value * 10 + digit
        saw_digit = true
        pos = pos + 1

    var frac_value = 0.0
    var scale = 1.0
    if pos < s.len() and s.substring(pos, pos + 1) == ".":
        pos = pos + 1
        while pos < s.len():
            val digit = _digit_value(s.substring(pos, pos + 1))
            if digit < 0:
                return nil
            scale = scale * 10.0
            frac_value = frac_value + digit.to_f64() / scale
            saw_digit = true
            pos = pos + 1

    if not saw_digit:
        return nil
    Some(sign * (int_value.to_f64() + frac_value))

fn encode_metadata(meta: Dict<text, text>) -> text:
    var parts: [text] = []
    val keys = meta.keys()
    var i = 0
    while i < keys.len():
        val k = keys[i]
        val v = meta.get(k)
        if v.?:
            parts.push(k + "=" + v)
        i = i + 1
    parts.join(";")

fn decode_metadata(s: text) -> Dict<text, text>:
    var out: Dict<text, text> = {}
    if s.len() == 0:
        return out
    val pairs = s.split(";")
    var i = 0
    while i < pairs.len():
        val pair = pairs[i]
        val eq = pair.find("=")
        if eq >= 0:
            val k = pair.slice(0, eq).trim()
            val v = pair.slice(eq + 1, pair.len()).trim()
            out.set(k, v)
        i = i + 1
    out
