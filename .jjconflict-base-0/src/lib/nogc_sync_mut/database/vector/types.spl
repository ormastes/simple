enum DistanceMetric:
    Cosine
    Euclidean
    DotProduct

struct VectorEntry:
    id: text
    vector: [f64]
    metadata: Dict<text, text>
    norm: f64

struct SearchResult:
    id: text
    distance: f64
    metadata: Dict<text, text>

struct VectorDbConfig:
    dimensions: i64
    metric: DistanceMetric
    max_entries: i64

fn default_vector_config(dimensions: i64) -> VectorDbConfig:
    VectorDbConfig(
        dimensions: dimensions,
        metric: DistanceMetric.Cosine,
        max_entries: 0
    )

enum VectorDbError:
    DimensionMismatch(expected: i64, got: i64)
    EntryNotFound(id: text)
    StorageError(message: text)
    IndexError(message: text)
