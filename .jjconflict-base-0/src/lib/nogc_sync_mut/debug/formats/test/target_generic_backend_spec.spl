"""RemoteGenericBackend + DebugTargetInfo integration tests."""

use std.debug.remote.target.target_info.DebugTargetInfo
use std.debug.remote.target.x86_64.X86_64Target
use std.debug.remote.target.riscv64.RiscV64Target
use std.debug.remote.target.aarch64.Aarch64Target
use std.debug.remote.target.avr.AvrTarget
use std.debug.remote.target.i8086.I8086Target
use std.debug.remote.target.simpleos.SimpleOsTarget
use std.debug.remote.connection_matrix.{ConnectionMatrix, DebugTarget, DebuggerKind}

describe "DebugTargetInfo structural conformance":
    it "X86_64Target conforms to trait":
        val t = X86_64Target.create()
        expect(t.name()).to_equal("x86_64")
        expect(t.register_count()).to_equal(24)
        expect(t.pc_register_index()).to_equal(16)

    it "RiscV64Target conforms to trait":
        val t = RiscV64Target.create()
        expect(t.name()).to_equal("RISC-V64 (RV64GC)")
        expect(t.register_count()).to_equal(33)
        expect(t.pc_register_index()).to_equal(32)

    it "Aarch64Target conforms to trait":
        val t = Aarch64Target.create()
        expect(t.name()).to_equal("AArch64")
        expect(t.register_count()).to_equal(34)
        expect(t.pc_register_index()).to_equal(32)

    it "AvrTarget conforms to trait":
        val t = AvrTarget.create()
        expect(t.name()).to_equal("AVR (ATmega328P)")
        expect(t.register_count()).to_equal(36)
        expect(t.pc_register_index()).to_equal(35)

    it "I8086Target conforms to trait":
        val t = I8086Target.create()
        expect(t.name()).to_equal("Intel 8086")
        expect(t.register_count()).to_equal(14)
        expect(t.pc_register_index()).to_equal(8)

    it "SimpleOsTarget delegates correctly":
        val t = SimpleOsTarget.create()
        expect(t.register_count()).to_equal(24)
        expect(t.arch().to_string()).to_equal("x86_64")

describe "ConnectionMatrix new targets":
    it "has 15 connection specs":
        val matrix = ConnectionMatrix.default()
        expect(matrix.count()).to_equal(15)

    it "finds QemuX86_64 target":
        val matrix = ConnectionMatrix.default()
        val specs = matrix.find_by_target(DebugTarget.QemuX86_64)
        expect(specs.len()).to_equal(1)
        expect(specs[0].index).to_equal(9)

    it "QemuX86_64 is not hardware":
        val matrix = ConnectionMatrix.default()
        val spec = matrix.get(9)
        expect(spec != nil).to_equal(true)
        expect(spec!.is_hardware()).to_equal(false)

    it "finds QemuRiscV64 target":
        val matrix = ConnectionMatrix.default()
        val specs = matrix.find_by_target(DebugTarget.QemuRiscV64)
        expect(specs.len()).to_equal(1)
        expect(specs[0].index).to_equal(10)

    it "finds QemuAarch64 target":
        val matrix = ConnectionMatrix.default()
        val specs = matrix.find_by_target(DebugTarget.QemuAarch64)
        expect(specs.len()).to_equal(1)

    it "finds NativeLinux target":
        val matrix = ConnectionMatrix.default()
        val specs = matrix.find_by_target(DebugTarget.NativeLinux)
        expect(specs.len()).to_equal(1)
        expect(specs[0].debugger.to_string()).to_equal("ptrace Native")

    it "finds WasmBrowser target":
        val matrix = ConnectionMatrix.default()
        val specs = matrix.find_by_target(DebugTarget.WasmBrowser)
        expect(specs.len()).to_equal(1)
        expect(specs[0].debugger.to_string()).to_equal("Chrome DevTools")

    it "QEMU specs include new targets":
        val matrix = ConnectionMatrix.default()
        val qemu = matrix.qemu_specs()
        expect(qemu.len() >= 7).to_equal(true)

    it "hardware specs unchanged":
        val matrix = ConnectionMatrix.default()
        val hw = matrix.hardware_specs()
        expect(hw.len()).to_equal(6)

    it "finds QemuAvr and QemuI8086":
        val matrix = ConnectionMatrix.default()
        val avr = matrix.find_by_target(DebugTarget.QemuAvr)
        expect(avr.len()).to_equal(1)
        val i86 = matrix.find_by_target(DebugTarget.QemuI8086)
        expect(i86.len()).to_equal(1)
