# T32 FDX (Fast Data Exchange) API FFI — channel open/close, send/receive, poll

use std.ffi.dynamic.{spl_dlsym, spl_wffi_call_i64}
use std.ffi.dynamic_versioned.{VersionedDynLib}
use std.debug.remote.t32_ffi.t32_types.{T32_OK, T32Error, make_t32_error}

extern fn spl_str_to_cstr(s: text) -> i64
extern fn spl_alloc_buffer(size: i64) -> i64
extern fn spl_free_buffer(ptr: i64)
extern fn spl_read_bytes(ptr: i64, len: i64) -> [i64]
extern fn spl_write_bytes(ptr: i64, data: [i64], len: i64)

var _fp_FdxOpen: i64 = 0
var _fp_FdxClose: i64 = 0
var _fp_FdxResolve: i64 = 0
var _fp_FdxReceive: i64 = 0
var _fp_FdxReceivePoll: i64 = 0
var _fp_FdxSend: i64 = 0
var _fp_FdxSendPoll: i64 = 0

fn t32_fdx_bind(lib: VersionedDynLib) -> [text]:
    var missing: [text] = []
    _fp_FdxOpen = lib.lib.sym("T32_Fdx_Open")
    _fp_FdxClose = lib.lib.sym("T32_Fdx_Close")
    _fp_FdxResolve = lib.lib.sym("T32_Fdx_Resolve")
    _fp_FdxReceive = lib.lib.sym("T32_Fdx_Receive")
    _fp_FdxReceivePoll = lib.lib.sym("T32_Fdx_ReceivePoll")
    _fp_FdxSend = lib.lib.sym("T32_Fdx_Send")
    _fp_FdxSendPoll = lib.lib.sym("T32_Fdx_SendPoll")
    missing

fn t32_fdx_function_names() -> [text]:
    ["T32_Fdx_Open", "T32_Fdx_Close", "T32_Fdx_Resolve",
     "T32_Fdx_Receive", "T32_Fdx_ReceivePoll",
     "T32_Fdx_Send", "T32_Fdx_SendPoll"]

# int T32_Fdx_Open(const char* name, int mode) -> channel handle
fn t32_fdx_open(name: text, mode: i64) -> Result<i64, T32Error>:
    if _fp_FdxOpen == 0: return Err(make_t32_error(-999))
    val n = spl_str_to_cstr(name)
    var args: [i64] = [n, mode]
    val rc = spl_wffi_call_i64(_fp_FdxOpen, args, 2)
    # Returns channel handle (>=0) or negative error
    if rc >= 0: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Fdx_Close(int channel)
fn t32_fdx_close(channel: i64) -> Result<i64, T32Error>:
    if _fp_FdxClose == 0: return Err(make_t32_error(-999))
    var args: [i64] = [channel]
    val rc = spl_wffi_call_i64(_fp_FdxClose, args, 1)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Fdx_Resolve(const char* name) -> channel handle
fn t32_fdx_resolve(name: text) -> Result<i64, T32Error>:
    if _fp_FdxResolve == 0: return Err(make_t32_error(-999))
    val n = spl_str_to_cstr(name)
    var args: [i64] = [n]
    val rc = spl_wffi_call_i64(_fp_FdxResolve, args, 1)
    # Returns channel handle (>=0) or negative error
    if rc >= 0: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Fdx_Receive(int channel, uint8_t* buf, int maxsize)
fn t32_fdx_receive(channel: i64, maxsize: i64) -> Result<[i64], T32Error>:
    if _fp_FdxReceive == 0: return Err(make_t32_error(-999))
    val buf = spl_alloc_buffer(maxsize)
    var args: [i64] = [channel, buf, maxsize]
    val rc = spl_wffi_call_i64(_fp_FdxReceive, args, 3)
    # Returns number of bytes received (>=0) or negative error
    if rc >= 0:
        val data = spl_read_bytes(buf, rc)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_Fdx_ReceivePoll(int channel, uint8_t* buf, int maxsize, int timeout)
fn t32_fdx_receive_poll(channel: i64, maxsize: i64, timeout: i64) -> Result<[i64], T32Error>:
    if _fp_FdxReceivePoll == 0: return Err(make_t32_error(-999))
    val buf = spl_alloc_buffer(maxsize)
    var args: [i64] = [channel, buf, maxsize, timeout]
    val rc = spl_wffi_call_i64(_fp_FdxReceivePoll, args, 4)
    # Returns number of bytes received (>=0) or negative error
    if rc >= 0:
        val data = spl_read_bytes(buf, rc)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_Fdx_Send(int channel, const uint8_t* buf, int size)
fn t32_fdx_send(channel: i64, data: [i64]) -> Result<i64, T32Error>:
    if _fp_FdxSend == 0: return Err(make_t32_error(-999))
    val size = data.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, data, size)
    var args: [i64] = [channel, buf, size]
    val rc = spl_wffi_call_i64(_fp_FdxSend, args, 3)
    spl_free_buffer(buf)
    # Returns bytes sent (>=0) or negative error
    if rc >= 0: Ok(rc) else: Err(make_t32_error(rc))

# int T32_Fdx_SendPoll(int channel, const uint8_t* buf, int size, int timeout)
fn t32_fdx_send_poll(channel: i64, data: [i64], timeout: i64) -> Result<i64, T32Error>:
    if _fp_FdxSendPoll == 0: return Err(make_t32_error(-999))
    val size = data.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, data, size)
    var args: [i64] = [channel, buf, size, timeout]
    val rc = spl_wffi_call_i64(_fp_FdxSendPoll, args, 4)
    spl_free_buffer(buf)
    # Returns bytes sent (>=0) or negative error
    if rc >= 0: Ok(rc) else: Err(make_t32_error(rc))
