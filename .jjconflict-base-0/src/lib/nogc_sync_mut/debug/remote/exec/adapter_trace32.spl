# TRACE32 Adapter
#
# ExecTarget implementation for TRACE32 debugger via T32GdbBridgeClient.
# Uses GDB-MI channel for standard ops (memory, registers, execution)
# and t32rem channel for T32-unique ops (flash, trace, coverage).
#
# Supports STM32H7 and STM32WB targets through TRACE32 PowerView.

use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.exec.types.{
    MemoryMap, Architecture, arm_reg_name
}
use std.nogc_sync_mut.debug.remote.exec.manager.{RemoteExecutionManager}
use std.nogc_sync_mut.debug.remote.types.{DebugConfig}
use std.nogc_sync_mut.debug.remote.protocol.trace32.{Trace32Client}
use std.nogc_sync_mut.debug.remote.protocol.t32_gdb_bridge.{T32GdbBridgeClient}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{CapabilityReport, probe_trace32}

fn default_t32_port() -> i32:
    20000

fn default_t32_gdb_port() -> i32:
    2331

class Trace32Adapter:
    """TRACE32 adapter using T32GdbBridgeClient for JIT execution."""
    bridge: Option<T32GdbBridgeClient>
    t32_port: i32
    gdb_port: i32
    memory_map: MemoryMap
    connected: bool

    static fn new() -> Trace32Adapter:
        Trace32Adapter.for_stm32h7()

    static fn for_stm32h7() -> Trace32Adapter:
        Trace32Adapter(
            bridge: nil,
            t32_port: default_t32_port(),
            gdb_port: default_t32_gdb_port(),
            memory_map: MemoryMap.stm32h7(),
            connected: false
        )

    static fn for_stm32wb() -> Trace32Adapter:
        Trace32Adapter(
            bridge: nil,
            t32_port: default_t32_port(),
            gdb_port: default_t32_gdb_port(),
            memory_map: MemoryMap.stm32wb(),
            connected: false
        )

    static fn with_ports(t32_port: i32, gdb_port: i32, memory_map: MemoryMap) -> Trace32Adapter:
        Trace32Adapter(
            bridge: nil,
            t32_port: t32_port,
            gdb_port: gdb_port,
            memory_map: memory_map,
            connected: false
        )

    fn is_available() -> bool:
        val t32rem = Trace32Client.find_t32rem()
        t32rem != ""

    fn capability_report() -> CapabilityReport:
        probe_trace32()

    me connect() -> Result<text, text>:
        if not self.is_available():
            return Err("t32rem not available")

        val config = DebugConfig(
            host: "localhost",
            port: self.t32_port as i64,
            target: Architecture.Arm32,
            program: "",
            options: {}
        )
        val bridge_result = T32GdbBridgeClient.connect(config, self.gdb_port)
        if bridge_result.is_err():
            return Err("T32 bridge connect failed: {bridge_result.err().unwrap()}")

        self.bridge = Some(bridge_result.ok.unwrap())
        val halt_result = self.bridge.unwrap().halt()
        if halt_result.is_err():
            return Err("T32 halt failed: {halt_result.err().unwrap()}")

        self.connected = true
        Ok("connected to TRACE32 on port {self.t32_port}, GDB on port {self.gdb_port}")

    me disconnect():
        if self.bridge.?:
            self.bridge.unwrap().disconnect()
        self.bridge = nil
        self.connected = false

    fn write_code(addr: i64, bytes: [i32]) -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        self.bridge.unwrap().write_memory(addr, bytes)

    fn read_code(addr: i64, size: i64) -> Result<[i32], text>:
        if not self.connected:
            return Err("not connected")
        self.bridge.unwrap().read_memory(addr, size as i32)

    fn write_register(reg: i64, value: i64) -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        val name = arm_reg_name(reg)
        self.bridge.unwrap().write_register(name, value)

    fn read_register(reg: i64) -> Result<i64, text>:
        if not self.connected:
            return Err("not connected")
        val name = arm_reg_name(reg)
        self.bridge.unwrap().read_register(name)

    fn resume() -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        self.bridge.unwrap().resume()

    fn wait_halt(timeout_ms: i64) -> Result<text, text>:
        if not self.connected:
            return Err("not connected")
        self.bridge.unwrap().t32.wait_for_stop(timeout_ms as i32)

    fn create_manager() -> Result<RemoteExecutionManager, text>:
        if not self.connected:
            return Err("not connected — call connect() first")

        Ok(RemoteExecutionManager.new(
            arch: Architecture.Arm32,
            memory_map: self.memory_map,
            write_code_fn: \addr, bytes: self.write_code(addr, bytes),
            read_code_fn: \addr, size: self.read_code(addr, size),
            write_register_fn: \reg, val_: self.write_register(reg, val_),
            read_register_fn: \reg: self.read_register(reg),
            resume_fn: \: self.resume(),
            wait_halt_fn: \timeout: self.wait_halt(timeout)
        ))
