# MCP SDK - Method Detection Helpers
#
# Fast method detection for MCP JSON-RPC messages.
# Checks known method names before falling back to field extraction.

use std.mcp_sdk.core.json.{extract_field}

# Check if a JSON message contains a specific method name
fn has_method(msg: text, name: text) -> bool:
    msg.contains("\"method\":\"" + name + "\"") or msg.contains("\"method\": \"" + name + "\"")

# Detect the method from a JSON-RPC message by checking known methods first
fn detect_method(msg: text, known_methods: [text]) -> text:
    var i = 0
    while i < known_methods.len():
        if has_method(msg, known_methods[i]):
            return known_methods[i]
        i = i + 1
    extract_field(msg, "method")
