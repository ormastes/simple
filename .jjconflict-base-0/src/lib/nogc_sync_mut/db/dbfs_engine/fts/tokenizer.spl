# FTS Tokenizer — converts text to lowercase tokens, filters stop words.
#
# Exports: FtsToken, fts_tokenize, fts_tokenize_raw

use std.io_runtime

# ── Stop words ─────────────────────────────────────────────────────────────────

val _STOP_WORDS: [text] = [
    "a", "an", "the", "is", "are", "was", "were",
    "in", "on", "at", "to", "for", "of",
    "and", "or", "not", "with", "by", "from", "as",
    "it", "this", "that", "be", "has", "have", "had",
    "do", "does", "did", "will", "can", "could", "would", "should"
]

fn _is_stop_word(word: text) -> bool:
    var i: i32 = 0
    while i < _STOP_WORDS.len() as i32:
        if _STOP_WORDS[i] == word:
            return true
        i = i + 1
    false

# ── Character helpers ──────────────────────────────────────────────────────────

fn _is_alnum(ch: text) -> bool:
    if ch == "a" or ch == "b" or ch == "c" or ch == "d" or ch == "e":
        return true
    if ch == "f" or ch == "g" or ch == "h" or ch == "i" or ch == "j":
        return true
    if ch == "k" or ch == "l" or ch == "m" or ch == "n" or ch == "o":
        return true
    if ch == "p" or ch == "q" or ch == "r" or ch == "s" or ch == "t":
        return true
    if ch == "u" or ch == "v" or ch == "w" or ch == "x" or ch == "y":
        return true
    if ch == "z":
        return true
    if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4":
        return true
    if ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
        return true
    false

# ── FtsToken ───────────────────────────────────────────────────────────────────

struct FtsToken:
    term: text
    position: i64

# ── Tokenize (raw — no stop-word filtering) ────────────────────────────────────

fn fts_tokenize_raw(input: text) -> [text]:
    val lowered = input.to_lower()
    var tokens: [text] = []
    var current: text = ""
    var idx: i32 = 0
    while idx < lowered.len() as i32:
        val ch = lowered.char_at(idx)
        if _is_alnum(ch):
            current = current + ch
        else:
            if current.len() > 0:
                tokens.push(current)
                current = ""
        idx = idx + 1
    if current.len() > 0:
        tokens.push(current)
    tokens

# ── Tokenize (with stop-word filtering + positions) ────────────────────────────

fn fts_tokenize(input: text) -> [FtsToken]:
    val raw = fts_tokenize_raw(input)
    var result: [FtsToken] = []
    var pos: i64 = 0
    var i: i32 = 0
    while i < raw.len() as i32:
        val term = raw[i]
        if not _is_stop_word(term):
            result.push(FtsToken(term: term, position: pos))
            pos = pos + 1
        i = i + 1
    result
