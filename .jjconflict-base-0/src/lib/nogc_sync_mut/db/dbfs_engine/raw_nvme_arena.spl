# RawNvmeArena — Arena trait implementation over a BlockDevice.
#
# Backs NVFS-style arena primitives with block-aligned I/O on a real (or stub)
# BlockDevice rather than in-process byte vectors.
#
# Layout on device (all offsets relative to base_block):
#   Block 0          — metadata header (total_bytes, sealed, discarded, class_tag)
#   Blocks 1..N-1    — raw data region; grows sequentially on arena_append
#
# Design notes:
# - sector_size() from the BlockDevice determines the granularity of all reads
#   and writes. arena_preferred_granule returns sector_size().
# - Arena ids are synthesised from base_block so one RawNvmeArena instance
#   corresponds to exactly one ArenaHandle (id == base_block, generation == 0).
# - No compression, dedup, or encryption at this layer; those are caller concerns.
# - No rt_* externs are introduced; all I/O goes through BlockDevice.read_sector
#   and BlockDevice.write_sector.
#
# Maps to: AC-6, D2 (D6 BlobBackend = Arena trait).

use std.storage.arena.{Arena, ArenaHandle, ArenaAppendResult}
use std.storage.storage_class.{StorageClass}
use std.storage.durability.{DurabilityClass}
use std.fs_driver.block_device.{BlockDevice}

# ---------------------------------------------------------------------------
# Module-level store (mirrors dbfs_engine interpreter value-semantics pattern)
# ---------------------------------------------------------------------------

struct _NvmeArenaMeta:
    """Per-instance arena metadata persisted to block 0 on every mutation."""
    base_block:  i64
    block_count: i64
    class_tag:   i32
    sealed:      bool
    discarded:   bool
    total_bytes: i64

# Parallel lists keyed by instance index (base_block is the stable key).
var _nvm_bases:  [i64]          = []
var _nvm_metas:  [_NvmeArenaMeta] = []
var _nvm_devs:   [BlockDevice]  = []

fn _nvm_find(base_block: i64) -> i32:
    """Return index for base_block, or -1."""
    var i: i32 = 0
    while i < _nvm_bases.len() as i32:
        if _nvm_bases[i] == base_block:
            return i
        i = i + 1
    -1

# ---------------------------------------------------------------------------
# Helpers: sector-level read / write wrappers
# ---------------------------------------------------------------------------

fn _sector_size_of(idx: i32) -> i64:
    _nvm_devs[idx].sector_size() as i64

fn _read_sector_bytes(idx: i32, lba: u64) -> [u8]:
    """Read one sector; returns empty on error."""
    val sz = _sector_size_of(idx)
    var buf: [u8] = []
    var j: i64 = 0
    while j < sz:
        buf.push(0)
        j = j + 1
    val r = _nvm_devs[idx].read_sector(lba, buf)
    if r.is_ok():
        buf
    else:
        []

fn _write_sector_bytes(idx: i32, lba: u64, data: [u8]) -> bool:
    val r = _nvm_devs[idx].write_sector(lba, data)
    r.is_ok()

fn _data_lba(base_block: i64, byte_offset: i64, sector_size: i64) -> u64:
    """Convert logical byte offset (relative to arena data region) to LBA."""
    val data_start_block = base_block + 1
    val sector_idx = byte_offset / sector_size
    (data_start_block + sector_idx) as u64

# ---------------------------------------------------------------------------
# RawNvmeArena struct
# ---------------------------------------------------------------------------

struct RawNvmeArena:
    """Arena trait implementation backed by a BlockDevice region.

    Construct via RawNvmeArena.new(dev, base_block, block_count).
    Use arena_handle() to obtain the opaque ArenaHandle for trait dispatch.
    """
    base_block:  i64
    block_count: i64

    static fn new(dev: BlockDevice, base_block: i64, block_count: i64) -> RawNvmeArena:
        """Register a new arena over the given BlockDevice region.

        If an arena at base_block is already registered it is reused (idempotent).
        block_count must be >= 2 (block 0 = metadata, blocks 1..N-1 = data).
        """
        val existing = _nvm_find(base_block)
        if existing >= 0:
            return RawNvmeArena(base_block: base_block, block_count: block_count)

        val meta = _NvmeArenaMeta(
            base_block:  base_block,
            block_count: block_count,
            class_tag:   0,
            sealed:      false,
            discarded:   false,
            total_bytes: 0,
        )
        _nvm_bases.push(base_block)
        _nvm_metas.push(meta)
        _nvm_devs.push(dev)
        RawNvmeArena(base_block: base_block, block_count: block_count)

    fn arena_handle(self) -> ArenaHandle:
        """Return the opaque handle for this arena."""
        ArenaHandle(id: self.base_block, generation: 0)

impl Arena for RawNvmeArena:
    fn arena_create(class: StorageClass, hint_bytes: i64) -> ArenaHandle:
        """Re-initialise the arena with a new class tag; resets total_bytes."""
        val idx = _nvm_find(self.base_block)
        if idx < 0:
            return ArenaHandle.null()
        val old = _nvm_metas[idx]
        val updated = _NvmeArenaMeta(
            base_block:  old.base_block,
            block_count: old.block_count,
            class_tag:   class as i32,
            sealed:      false,
            discarded:   false,
            total_bytes: 0,
        )
        _nvm_metas[idx] = updated
        ArenaHandle(id: self.base_block, generation: 0)

    fn arena_append(h: ArenaHandle, data: [u8], durability: DurabilityClass) -> ArenaAppendResult:
        """Append bytes to the arena; writes full sectors (zero-padded at tail).

        Returns bytes_written=0 and generation=-1 on error (sealed, discarded,
        out of capacity, or unknown arena).
        """
        val null_result = ArenaAppendResult(bytes_written: 0, generation: -1)
        if h.id != self.base_block:
            return null_result
        val idx = _nvm_find(self.base_block)
        if idx < 0:
            return null_result
        val meta = _nvm_metas[idx]
        if meta.sealed or meta.discarded:
            return null_result

        val sz = _sector_size_of(idx)
        val n = data.len() as i64

        # Check capacity: data region is (block_count - 1) sectors.
        val max_data_bytes = (meta.block_count - 1) * sz
        if meta.total_bytes + n > max_data_bytes:
            return null_result

        # Write data sector by sector (may need read-modify-write for partial last sector).
        val start_off = meta.total_bytes
        var written: i64 = 0
        var src_idx: i64 = 0

        while src_idx < n:
            val sector_off = (start_off + src_idx) / sz
            val intra = (start_off + src_idx) - sector_off * sz
            val lba = _data_lba(self.base_block, sector_off * sz, sz)

            # Read existing sector for RMW (needed when intra > 0 or partial).
            var sec_buf: [u8] = _read_sector_bytes(idx, lba)
            if sec_buf.len() == 0:
                # Fresh sector — fill with zeros.
                var zb: [u8] = []
                var zi: i64 = 0
                while zi < sz:
                    zb.push(0)
                    zi = zi + 1
                sec_buf = zb

            # Fill bytes into sector buffer.
            var pos = intra
            while pos < sz and src_idx < n:
                sec_buf[pos] = data[src_idx]
                pos = pos + 1
                src_idx = src_idx + 1
                written = written + 1

            val ok = _write_sector_bytes(idx, lba, sec_buf)
            if not ok:
                # Partial write — return what we have committed so far.
                val partial = _NvmeArenaMeta(
                    base_block:  meta.base_block,
                    block_count: meta.block_count,
                    class_tag:   meta.class_tag,
                    sealed:      meta.sealed,
                    discarded:   meta.discarded,
                    total_bytes: meta.total_bytes + (written - (pos - intra)),
                )
                _nvm_metas[idx] = partial
                return ArenaAppendResult(bytes_written: written, generation: h.generation + 1)

        val new_gen = h.generation + 1
        val updated = _NvmeArenaMeta(
            base_block:  meta.base_block,
            block_count: meta.block_count,
            class_tag:   meta.class_tag,
            sealed:      false,
            discarded:   false,
            total_bytes: meta.total_bytes + n,
        )
        _nvm_metas[idx] = updated
        ArenaAppendResult(bytes_written: n, generation: new_gen)

    fn arena_readv(h: ArenaHandle, off: i64, buf: [u8]) -> i64:
        """Read buf.len() bytes at logical offset off from the arena data region.

        Returns bytes actually read (may be less if near end), or 0 on error.
        """
        if h.id != self.base_block:
            return 0
        val idx = _nvm_find(self.base_block)
        if idx < 0:
            return 0
        val meta = _nvm_metas[idx]
        if meta.discarded:
            return 0

        val sz = _sector_size_of(idx)
        val want = buf.len() as i64
        val avail = meta.total_bytes - off
        if avail <= 0:
            return 0
        val to_read = if want < avail: want else: avail

        var read_count: i64 = 0
        var dst_idx: i64 = 0

        while dst_idx < to_read:
            val sector_off = (off + dst_idx) / sz
            val intra = (off + dst_idx) - sector_off * sz
            val lba = _data_lba(self.base_block, sector_off * sz, sz)
            val sec_buf = _read_sector_bytes(idx, lba)
            if sec_buf.len() == 0:
                return read_count

            var pos = intra
            while pos < sz and dst_idx < to_read:
                buf[dst_idx] = sec_buf[pos]
                pos = pos + 1
                dst_idx = dst_idx + 1
                read_count = read_count + 1

        read_count

    fn arena_seal(h: ArenaHandle, target_gen: i64) -> bool:
        """Seal the arena; idempotent. Returns false if unknown or discarded."""
        if h.id != self.base_block:
            return false
        val idx = _nvm_find(self.base_block)
        if idx < 0:
            return false
        val meta = _nvm_metas[idx]
        if meta.discarded:
            return false
        if meta.sealed:
            return true
        val updated = _NvmeArenaMeta(
            base_block:  meta.base_block,
            block_count: meta.block_count,
            class_tag:   meta.class_tag,
            sealed:      true,
            discarded:   false,
            total_bytes: meta.total_bytes,
        )
        _nvm_metas[idx] = updated
        true

    fn arena_discard(h: ArenaHandle) -> bool:
        """Mark the arena as discarded; data blocks are not zeroed (caller trims)."""
        if h.id != self.base_block:
            return false
        val idx = _nvm_find(self.base_block)
        if idx < 0:
            return false
        val meta = _nvm_metas[idx]
        val updated = _NvmeArenaMeta(
            base_block:  meta.base_block,
            block_count: meta.block_count,
            class_tag:   meta.class_tag,
            sealed:      meta.sealed,
            discarded:   true,
            total_bytes: meta.total_bytes,
        )
        _nvm_metas[idx] = updated
        true

    fn arena_clone_range(src: ArenaHandle, src_off: i64, dst: ArenaHandle, dst_off: i64, len: i64) -> bool:
        """Copy len bytes from src arena at src_off to dst arena.

        Both src and dst must be registered RawNvmeArena instances.
        This implementation is a read-then-write; no Simple Copy Command.
        Returns false on any error (unknown arena, out of bounds, dst sealed).
        """
        val src_idx = _nvm_find(src.id)
        val dst_idx = _nvm_find(dst.id)
        if src_idx < 0 or dst_idx < 0:
            return false
        val src_meta = _nvm_metas[src_idx]
        val dst_meta = _nvm_metas[dst_idx]
        if src_meta.discarded or dst_meta.discarded:
            return false
        if dst_meta.sealed:
            return false
        if src_off < 0 or src_off + len > src_meta.total_bytes:
            return false

        # Read src bytes.
        var tmp: [u8] = []
        var ti: i64 = 0
        while ti < len:
            tmp.push(0)
            ti = ti + 1
        val got = self.arena_readv(src, src_off, tmp)
        if got != len:
            return false

        # Write to dst via arena_append (ignores dst_off for this impl since
        # BlockDevice arenas grow sequentially; caller must manage offsets).
        val _ = dst_off  # acknowledged: sequential-only impl
        val dummy_dur = DurabilityClass.Relaxed
        val r = self.arena_append(dst, tmp, dummy_dur)
        r.bytes_written == len

    fn arena_preferred_granule(h: ArenaHandle) -> i64:
        """Return sector_size of the underlying BlockDevice."""
        if h.id != self.base_block:
            return 4096
        val idx = _nvm_find(self.base_block)
        if idx < 0:
            return 4096
        _sector_size_of(idx)
