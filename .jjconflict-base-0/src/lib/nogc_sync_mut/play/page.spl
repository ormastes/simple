# std.play.page — Page class (mirrors Playwright's Page)
#
# One Page per BrowserWindow. Wraps a CdpSession plus Keyboard, Mouse and
# Locator factories. Method names are snake_case to match Python Playwright
# and Simple's stdlib.

use std.play.cdp.client.{CdpClient}
use std.play.cdp.session.{CdpSession}
use std.play.cdp.domains.{cdp_page_capture_screenshot}
use std.play.keyboard.{Keyboard}
use std.play.mouse.{Mouse}
use std.play.locator.{Locator}
use std.play.types.*

extern fn rt_file_write_bytes_b64(path: text, b64: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

class Page:
    session: CdpSession
    keyboard: Keyboard
    mouse: Mouse
    artifacts_dir: text
    window_id: text

    static fn from_cdp(sess: CdpSession, window_id: text, artifacts_dir: text) -> Page:
        Page(
            session: sess,
            keyboard: Keyboard(client: sess.client, session_id: sess.session_id),
            mouse: Mouse(client: sess.client, session_id: sess.session_id, x: 0.0, y: 0.0),
            artifacts_dir: artifacts_dir,
            window_id: window_id
        )

    # ------------------------------------------------------------------
    # Navigation
    # ------------------------------------------------------------------

    me goto(url: text) -> Result<(), PlayError>:
        self.session.navigate(url)

    me reload() -> Result<(), PlayError>:
        val client = self.session.client
        client.send_on_session(self.session.session_id, "Page.reload", "{}", DEFAULT_NAVIGATION_TIMEOUT_MS)?
        Ok(())

    me url() -> Result<text, PlayError>:
        self.session.get_url()

    me title() -> Result<text, PlayError>:
        self.session.get_title()

    # ------------------------------------------------------------------
    # Locator / selector convenience
    # ------------------------------------------------------------------

    me locator(selector: text) -> Locator:
        Locator(session: self.session, spec: locator_css(selector))

    me get_by_role(role: text, name: text) -> Locator:
        Locator(
            session: self.session,
            spec: LocatorSpec(selector: role, strategy: "role", nth: -1, has_text: name, has_not_text: "")
        )

    me get_by_text(value: text) -> Locator:
        Locator(
            session: self.session,
            spec: LocatorSpec(selector: value, strategy: "text", nth: -1, has_text: "", has_not_text: "")
        )

    me get_by_test_id(tid: text) -> Locator:
        Locator(
            session: self.session,
            spec: LocatorSpec(selector: tid, strategy: "test-id", nth: -1, has_text: "", has_not_text: "")
        )

    me get_by_label(label: text) -> Locator:
        Locator(
            session: self.session,
            spec: locator_css("[aria-label=\"" + label + "\"]")
        )

    me get_by_placeholder(ph: text) -> Locator:
        Locator(
            session: self.session,
            spec: locator_css("[placeholder=\"" + ph + "\"]")
        )

    # ------------------------------------------------------------------
    # Shortcut actions (mirroring Playwright's page.click/fill/... helpers)
    # ------------------------------------------------------------------

    me click(selector: text) -> Result<(), PlayError>:
        self.session.click_selector(selector, "left", 1, 0)

    me click_with(selector: text, options: ClickOptions) -> Result<(), PlayError>:
        self.session.click_selector(selector, options.button, options.click_count, 0)

    me dblclick(selector: text) -> Result<(), PlayError>:
        self.session.click_selector(selector, "left", 2, 0)

    me fill(selector: text, value: text) -> Result<(), PlayError>:
        self.session.fill_selector(selector, value)

    me type_text(selector: text, value: text) -> Result<(), PlayError>:
        self.session.type_selector(selector, value, 0)

    me press(selector: text, key: text) -> Result<(), PlayError>:
        self.session.press_selector(selector, key, 0)

    me focus(selector: text) -> Result<(), PlayError>:
        self.session.focus_selector(selector)

    me text_content(selector: text) -> Result<text, PlayError>:
        self.session.text_content(selector)

    me inner_text(selector: text) -> Result<text, PlayError>:
        self.session.text_content(selector)

    # ------------------------------------------------------------------
    # Waiting
    # ------------------------------------------------------------------

    me wait_for_selector(selector: text) -> Result<(), PlayError>:
        self.session.wait_for_selector(selector, 30000)

    me wait_for_timeout(ms: i64):
        val deadline = rt_time_now_unix_micros() + (ms * 1000)
        while rt_time_now_unix_micros() < deadline:
            pass_do_nothing

    me wait_for_url(url: text, timeout_ms: i64) -> Result<(), PlayError>:
        val deadline = rt_time_now_unix_micros() + (timeout_ms * 1000)
        while rt_time_now_unix_micros() < deadline:
            val cur = self.session.get_url()?
            if cur.contains(url):
                return Ok(())
        Err(play_error(ERR_TIMEOUT, "wait_for_url: " + url))

    # ------------------------------------------------------------------
    # Screenshot
    # ------------------------------------------------------------------

    me screenshot(path: text) -> Result<text, PlayError>:
        val body = cdp_page_capture_screenshot(self.session.client, self.session.session_id, "png", 90, false)?
        val b64 = _extract_data_field(body)
        if b64 == "":
            return Err(play_error(ERR_CDP_PROTOCOL, "captureScreenshot: no data field"))

        val final_path = if path == "":
            val ts = rt_time_now_unix_micros()
            self.artifacts_dir + "/screenshot-{ts}.png"
        else:
            path
        rt_mkdir_p(self.artifacts_dir)
        rt_file_write_bytes_b64(final_path, b64)
        Ok(final_path)

    me screenshot_with(options: ScreenshotOptions) -> Result<text, PlayError>:
        val body = cdp_page_capture_screenshot(self.session.client, self.session.session_id, options.image_type, options.quality, options.full_page)?
        val b64 = _extract_data_field(body)
        if b64 == "":
            return Err(play_error(ERR_CDP_PROTOCOL, "captureScreenshot: no data field"))
        val final_path = if options.path == "":
            val ts = rt_time_now_unix_micros()
            self.artifacts_dir + "/screenshot-{ts}." + options.image_type
        else:
            options.path
        rt_mkdir_p(self.artifacts_dir)
        rt_file_write_bytes_b64(final_path, b64)
        Ok(final_path)

    # ------------------------------------------------------------------
    # Scripting
    # ------------------------------------------------------------------

    me evaluate(expression: text) -> Result<text, PlayError>:
        self.session.evaluate(expression)

    me evaluate_handle(expression: text) -> Result<text, PlayError>:
        self.session.client.send_on_session(self.session.session_id, "Runtime.evaluate",
            "{\"expression\": \"" + expression + "\", \"returnByValue\": false}", 30000)

fn _extract_data_field(body: text) -> text:
    """Extract the base64 data from a CDP screenshot response using .split()."""
    val marker = "\"data\":\""
    if not body.contains(marker): return ""
    val parts = body.split(marker)
    if parts.length() < 2: return ""
    val rest = parts[1]
    rest.split("\"")[0]
