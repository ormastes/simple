# IPsec facade (RFC 4303 ESP / RFC 4302 AH / RFC 7296 IKEv2 minimal).
#
# Entirely new framing/SA/IKE surface; reuses only the common.net crypto-channel
# primitives (SecurityParameterIndex, AntiReplayWindow). No TLS record/handshake
# reuse. Dispatch values are integer `val` constants, never payload-enums.

export use std.nogc_sync_mut.ipsec.types.{EspPacket, AhHeader, IkeHeader, IkePayloadHeader, IkeMessage}
export use std.nogc_sync_mut.ipsec.types.{IPSEC_NH_TCP, IPSEC_NH_UDP, IPSEC_NH_ESP, IPSEC_NH_AH, IPSEC_NH_IPV6_NO_NEXT}
export use std.nogc_sync_mut.ipsec.types.{IKE_EXCHANGE_SA_INIT, IKE_EXCHANGE_AUTH, IKE_EXCHANGE_CREATE_CHILD_SA, IKE_EXCHANGE_INFORMATIONAL}
export use std.nogc_sync_mut.ipsec.types.{IKE_PAYLOAD_NONE, IKE_PAYLOAD_SA, IKE_PAYLOAD_KE, IKE_PAYLOAD_ID_INITIATOR, IKE_PAYLOAD_AUTH, IKE_PAYLOAD_NONCE, IKE_PAYLOAD_NOTIFY, IKE_PAYLOAD_ENCRYPTED}
export use std.nogc_sync_mut.ipsec.types.{IKE_VERSION_2, IKE_FLAG_INITIATOR, IKE_FLAG_VERSION, IKE_FLAG_RESPONSE}
export use std.nogc_sync_mut.ipsec.build.{build_esp_packet, build_ah_header, build_ike_header, build_ike_payload, build_ike_message}
export use std.nogc_sync_mut.ipsec.parse.{parse_esp_packet, parse_ah_header, parse_ike_header, parse_ike_message}
