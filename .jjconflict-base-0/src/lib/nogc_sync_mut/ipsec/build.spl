# IPsec wire serialization (RFC 4303 / 4302 / 7296).

use std.common.net.byte_cursor.{ByteWriter}
use std.nogc_sync_mut.ipsec.types.{EspPacket, AhHeader, IkeHeader, IkePayloadHeader, IkeMessage}

# ESP (RFC 4303 §2): SPI | Seq | Payload | Pad | PadLen | NextHdr | ICV.
fn build_esp_packet(pkt: EspPacket) -> [u8]:
    var w = ByteWriter.new()
    w.write_u32(pkt.spi.value)
    w.write_u32(pkt.sequence_number)
    w.write_bytes(pkt.payload)
    w.write_bytes(pkt.pad)
    w.write_u8(pkt.pad.len().to_u8())
    w.write_u8(pkt.next_header)
    w.write_bytes(pkt.icv)
    w.to_bytes()

# AH (RFC 4302 §2): NextHdr | PayloadLen | Reserved | SPI | Seq | ICV.
fn build_ah_header(ah: AhHeader) -> [u8]:
    var w = ByteWriter.new()
    w.write_u8(ah.next_header)
    w.write_u8(ah.payload_length)
    w.write_u16(ah.reserved)
    w.write_u32(ah.spi.value)
    w.write_u32(ah.sequence_number)
    w.write_bytes(ah.icv)
    w.to_bytes()

# IKEv2 fixed header (RFC 7296 §3.1): 28 bytes.
fn build_ike_header(h: IkeHeader) -> [u8]:
    var w = ByteWriter.new()
    w.write_u64(h.initiator_spi)
    w.write_u64(h.responder_spi)
    w.write_u8(h.next_payload)
    w.write_u8(h.version)
    w.write_u8(h.exchange_type)
    w.write_u8(h.flags)
    w.write_u32(h.message_id)
    w.write_u32(h.length)
    w.to_bytes()

# Generic IKEv2 payload (RFC 7296 §3.2): NextPayload | C+Reserved | Length | body.
fn build_ike_payload(p: IkePayloadHeader) -> [u8]:
    var w = ByteWriter.new()
    w.write_u8(p.next_payload)
    var crit: u8 = 0
    if p.critical:
        crit = 0x80
    w.write_u8(crit)
    w.write_u16((p.body.len() + 4).to_u16())
    w.write_bytes(p.body)
    w.to_bytes()

# Full IKEv2 message: header (with recomputed total length) + payloads.
fn build_ike_message(msg: IkeMessage) -> [u8]:
    # First serialize payloads to learn the total length.
    var body = ByteWriter.new()
    var i: u64 = 0
    while i < msg.payloads.len():
        body.write_bytes(build_ike_payload(msg.payloads[i]))
        i = i + 1
    val payload_bytes = body.to_bytes()
    val total = (payload_bytes.len() + 28).to_u32()
    var hdr = msg.header
    hdr.length = total
    var w = ByteWriter.new()
    w.write_bytes(build_ike_header(hdr))
    w.write_bytes(payload_bytes)
    w.to_bytes()
