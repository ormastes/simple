@allow(star_import)
# Power Controller - Unified dispatch layer for power operations
#
# Routes power operations to the appropriate backend based on config.kind:
#   - "t32"   -> t32_power.spl (TRACE32 PRACTICE commands)
#   - "relay" -> relay_power.spl (.shs script execution)
#   - "host"  -> host_power.spl (SSH + Wake-on-LAN)
#
# Used by: MCP power tools, CLI power commands

use std.terminal.types.{PowerConfig, PowerState, POWER_STATE_UNKNOWN, make_power_state}
use std.terminal.power.t32_power.{t32_power_on, t32_power_off, t32_power_reset, t32_power_state}
use std.terminal.power.relay_power.{relay_power_on, relay_power_off, relay_power_toggle, relay_power_reset, relay_power_state}
use std.terminal.power.host_power.{host_power_on, host_power_off, host_power_toggle, host_power_reset, host_power_state}

extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Power Dispatch
# ============================================================================

fn power_on(config: PowerConfig) -> PowerState:
    """Power on a target by dispatching to the appropriate backend.

    Routes to t32_power_on, relay_power_on, or host_power_on based
    on config.kind.

    Args:
        config: PowerConfig with kind set to "t32", "relay", or "host"

    Returns:
        PowerState from the backend operation
    """
    if config.kind == "t32":
        return t32_power_on(config)
    if config.kind == "relay":
        return relay_power_on(config)
    if config.kind == "host":
        return host_power_on(config)
    val timestamp = rt_time_now_unix_micros()
    make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn power_off(config: PowerConfig) -> PowerState:
    """Power off a target by dispatching to the appropriate backend.

    Routes to t32_power_off, relay_power_off, or host_power_off based
    on config.kind.

    Args:
        config: PowerConfig with kind set to "t32", "relay", or "host"

    Returns:
        PowerState from the backend operation
    """
    if config.kind == "t32":
        return t32_power_off(config)
    if config.kind == "relay":
        return relay_power_off(config)
    if config.kind == "host":
        return host_power_off(config)
    val timestamp = rt_time_now_unix_micros()
    make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn power_toggle(config: PowerConfig) -> PowerState:
    """Toggle power state by dispatching to the appropriate backend.

    T32 does NOT support toggle (returns POWER_STATE_UNKNOWN).
    Relay uses toggle_script. Host checks state then powers on or off.

    Args:
        config: PowerConfig with kind set to "t32", "relay", or "host"

    Returns:
        PowerState from the backend operation, POWER_STATE_UNKNOWN for unsupported
    """
    if config.kind == "t32":
        # T32 does not support toggle - discrete only
        val timestamp = rt_time_now_unix_micros()
        return make_power_state(POWER_STATE_UNKNOWN, timestamp)
    if config.kind == "relay":
        return relay_power_toggle(config)
    if config.kind == "host":
        return host_power_toggle(config)
    val timestamp = rt_time_now_unix_micros()
    make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn power_reset(config: PowerConfig) -> PowerState:
    """Reset a target by dispatching to the appropriate backend.

    Routes to t32_power_reset, relay_power_reset, or host_power_reset
    based on config.kind.

    Args:
        config: PowerConfig with kind set to "t32", "relay", or "host"

    Returns:
        PowerState from the backend operation
    """
    if config.kind == "t32":
        return t32_power_reset(config)
    if config.kind == "relay":
        return relay_power_reset(config)
    if config.kind == "host":
        return host_power_reset(config)
    val timestamp = rt_time_now_unix_micros()
    make_power_state(POWER_STATE_UNKNOWN, timestamp)

fn power_state(config: PowerConfig) -> PowerState:
    """Query current power state by dispatching to the appropriate backend.

    Routes to t32_power_state, relay_power_state, or host_power_state
    based on config.kind.

    Args:
        config: PowerConfig with kind set to "t32", "relay", or "host"

    Returns:
        PowerState from the backend query
    """
    if config.kind == "t32":
        return t32_power_state(config)
    if config.kind == "relay":
        return relay_power_state(config)
    if config.kind == "host":
        return host_power_state(config)
    val timestamp = rt_time_now_unix_micros()
    make_power_state(POWER_STATE_UNKNOWN, timestamp)

# ============================================================================
# Capability Queries
# ============================================================================

fn power_supports_toggle(config: PowerConfig) -> bool:
    """Check if the power backend supports toggle operation.

    Toggle is supported by relay (toggle_script) and host (state check + on/off).
    T32 uses discrete SYStem.Up/Down commands only.

    Args:
        config: PowerConfig to check

    Returns:
        true for relay and host kinds, false for t32
    """
    if config.kind == "relay":
        return true
    if config.kind == "host":
        return true
    false

fn power_supports_discrete(config: PowerConfig) -> bool:
    """Check if the power backend supports discrete on/off operations.

    All three backends support discrete power_on and power_off.

    Args:
        config: PowerConfig to check

    Returns:
        true for all known kinds (t32, relay, host)
    """
    if config.kind == "t32":
        return true
    if config.kind == "relay":
        return true
    if config.kind == "host":
        return true
    false
