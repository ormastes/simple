# AOP Module - Aspect-Oriented Programming
#
# Around advice with real proceed: register via AspectRegistry.register_around().
# Limitation: only one AroundAdvice per join point is supported in interpreter mode;
# if multiple match, wrap returns Err("multiple around advices not yet supported")
# and records a denial. This is an honest runtime limitation pending closure-chain
# support in the interpreter.

use config.AopConfig
use std.io.{time_now_unix_micros}

enum AdviceKind:
    Before
    After
    AfterError
    Around

enum JoinPoint:
    FunctionCall(name: text)
    MethodCall(class_name: text, method_name: text)
    ModuleLoad(module_name: text)
    All

struct Pointcut:
    kind: JoinPoint
    pattern: text?

struct Advice:
    kind: AdviceKind
    handler: fn(AdviceContext) -> Result<(), text>

struct Aspect:
    name: text
    pointcut: Pointcut
    advice: Advice
    enabled: bool
    priority: i64

struct AdviceContext:
    function_name: text
    class_name: text?
    module_name: text?
    args: [Any]
    result: Any?
    error: text?
    start_time: i64
    end_time: i64?

# ----------------------------------------------------------------------------
# ProceedCell — tracks whether proceed() was called inside an Around handler.
# Fields are mutated only through me-methods, which work even when the object
# is captured read-only by a closure (interpreter constraint).
# ----------------------------------------------------------------------------
class ProceedCell:
    called: i64
    ok: bool
    error: text

impl ProceedCell:
    static fn fresh() -> ProceedCell:
        ProceedCell(called: 0, ok: false, error: "")

    me mark_called():
        self.called = self.called + 1

    me set_ok():
        self.ok = true

    me set_err(e: text):
        self.error = e

# ----------------------------------------------------------------------------
# AopResultSlot<T> — typed result slot written by the proceed thunk inside
# wrap<T>. Generic class so wrap<T> can instantiate it without type erasure.
# ----------------------------------------------------------------------------
class AopResultSlot<T>:
    value: T?
    filled: bool

impl AopResultSlot<T>:
    static fn empty() -> AopResultSlot<T>:
        AopResultSlot(value: nil, filled: false)

    me set(v: T):
        self.value = Some(v)
        self.filled = true

# ----------------------------------------------------------------------------
# AroundAdvice — separate struct for Around advice with real proceed contract.
# Registered via AspectRegistry.register_around(); matched independently of
# the legacy Advice/Aspect path so old pre-hook Around registrations are
# byte-compatible.
# ----------------------------------------------------------------------------
struct AroundAdvice:
    name: text
    pointcut: Pointcut
    priority: i64
    enabled: bool
    handler: fn(AdviceContext, fn() -> Result<(), text>) -> Result<(), text>

# Reserved priority band for security aspects.
# Aspects with priority >= RESERVED_SECURITY_MIN are reserved for security use.
# Non-security registrations that claim this band are clamped below it.
val RESERVED_SECURITY_MIN: i64 = 1000000

struct AspectRegistry:
    aspects: [Aspect]
    around_advices: [AroundAdvice]
    enabled: bool
    # Once sealed (after init_aop registers security aspects), disable_unsafe and
    # unregister_unsafe become no-ops. New aspect registrations are still permitted.
    sealed: bool

impl AspectRegistry:
    static fn empty() -> AspectRegistry:
        AspectRegistry(aspects: [], around_advices: [], enabled: true, sealed: false)

    me register(aspect: Aspect):
        # Clamp any aspect that attempts to claim the reserved security priority band.
        # The reserved band (>= RESERVED_SECURITY_MIN) is for security aspects woven at
        # compile time via weaving_config. Runtime-registered aspects must stay below it.
        val safe_priority = if aspect.priority >= RESERVED_SECURITY_MIN:
            RESERVED_SECURITY_MIN - 1
        else:
            aspect.priority
        val clamped = Aspect(
            name: aspect.name,
            pointcut: aspect.pointcut,
            advice: aspect.advice,
            enabled: aspect.enabled,
            priority: safe_priority
        )
        self.aspects = self.aspects.push(clamped)

    me register_around(adv: AroundAdvice):
        """Register an AroundAdvice with real proceed contract (E1)."""
        val safe_priority = if adv.priority >= RESERVED_SECURITY_MIN:
            RESERVED_SECURITY_MIN - 1
        else:
            adv.priority
        val clamped = AroundAdvice(
            name: adv.name,
            pointcut: adv.pointcut,
            priority: safe_priority,
            enabled: adv.enabled,
            handler: adv.handler
        )
        self.around_advices = self.around_advices.push(clamped)

    fn find_around_advices(join_point: JoinPoint) -> [AroundAdvice]:
        if not self.enabled:
            return []
        var matched: [AroundAdvice] = []
        var i = 0
        while i < self.around_advices.len():
            val adv = self.around_advices[i]
            i = i + 1
            if not adv.enabled:
                continue
            val pattern = adv.pointcut.pattern
            val effective_pattern = if pattern.is_some(): pattern.unwrap() else: "*"
            val matches = _match_join_point(adv.pointcut.kind, effective_pattern, join_point)
            if matches:
                matched = matched.push(adv)
        # Sort by priority, highest first (stable selection sort).
        var sorted: [AroundAdvice] = []
        var remaining = matched
        while remaining.len() > 0:
            var best = 0
            var ri = 1
            while ri < remaining.len():
                if remaining[ri].priority > remaining[best].priority:
                    best = ri
                ri = ri + 1
            sorted = sorted.push(remaining[best])
            var next_rem: [AroundAdvice] = []
            var rj = 0
            while rj < remaining.len():
                if rj != best:
                    next_rem = next_rem.push(remaining[rj])
                rj = rj + 1
            remaining = next_rem
        return sorted

    me unregister_unsafe(name: text):
        # SECURITY: only call from trusted initialization code.
        # Removing a registered aspect at runtime can silently disable security enforcement.
        # No-op when registry is sealed — security aspects cannot be removed.
        if self.sealed:
            return
        self.aspects = self.aspects.filter(_.name != name)
        self.around_advices = self.around_advices.filter(_.name != name)

    fn find_aspects(join_point: JoinPoint) -> [Aspect]:
        if not self.enabled:
            return []
        var matched: [Aspect] = []
        var i = 0
        while i < self.aspects.len():
            val aspect = self.aspects[i]
            i = i + 1
            if not aspect.enabled:
                continue
            val pattern = aspect.pointcut.pattern
            val effective_pattern = if pattern.is_some(): pattern.unwrap() else: "*"
            val matches = _match_join_point(aspect.pointcut.kind, effective_pattern, join_point)
            if matches:
                matched = matched.push(aspect)
        # Sort by priority, highest first. Hand-rolled stable selection sort:
        # array.sort_by is unavailable in interpreter mode, which left the
        # weaver broken for any matching aspect when interpreted. Avoids
        # subtraction so large priorities cannot overflow i64.
        var sorted: [Aspect] = []
        var remaining = matched
        while remaining.len() > 0:
            var best = 0
            var ri = 1
            while ri < remaining.len():
                if remaining[ri].priority > remaining[best].priority:
                    best = ri
                ri = ri + 1
            sorted = sorted.push(remaining[best])
            var next_rem: [Aspect] = []
            var rj = 0
            while rj < remaining.len():
                if rj != best:
                    next_rem = next_rem.push(remaining[rj])
                rj = rj + 1
            remaining = next_rem
        return sorted

fn time_now_ms() -> i64:
    time_now_unix_micros() / 1000

impl AspectRegistry:
    me enable():
        self.enabled = true

    me disable_unsafe():
        # SECURITY: disabling the registry suppresses ALL advice including security enforcement.
        # No-op when registry is sealed — security enforcement cannot be bypassed at runtime.
        if self.sealed:
            return
        self.enabled = false

struct LogAspects:
    config: AopConfig
    log_level: i64

impl LogAspects:
    static fn from_config(config: AopConfig) -> LogAspects:
        LogAspects(config: config, log_level: config.log_level)

    fn register_all(registry: AspectRegistry):
        pass

# ============================================================================
# Advice-denial visibility (H10 hardening)
#
# When Before/Around advice returns Err, the join-point function is skipped.
# Callers that ignore the Result would otherwise silently drop the operation,
# so every denial is recorded here. Written only on the denial path — zero
# overhead when advice succeeds.
# ============================================================================

var _aop_denial_count = 0
var _aop_last_denial = ""

# ---------------------------------------------------------------------------
# Proceed-slot state for AroundAdvice (E1).
# Module-level vars are writable from closures; class instances captured in
# closures are copied (interpreter limitation), so we use module-level state.
# These are always reset before each around-advice invocation and are NOT
# thread-safe — single-threaded interpreter only.
# ---------------------------------------------------------------------------
var _aop_proceed_called: i64 = 0
var _aop_proceed_target_ran: bool = false
var _aop_proceed_result_i64: i64 = 0
var _aop_proceed_result_text: text = ""
var _aop_proceed_result_bool: bool = false
var _aop_proceed_err: text = ""
var _aop_proceed_had_err: bool = false

fn _aop_proceed_reset():
    _aop_proceed_called = 0
    _aop_proceed_target_ran = false
    _aop_proceed_result_i64 = 0
    _aop_proceed_result_text = ""
    _aop_proceed_result_bool = false
    _aop_proceed_err = ""
    _aop_proceed_had_err = false

pub fn aop_last_proceed_err() -> text:
    """Last error returned by a duplicate proceed() call (test support)."""
    _aop_proceed_err

pub fn aop_proceed_double_called() -> bool:
    """True if proceed() was called more than once in the last around invocation."""
    _aop_proceed_had_err

pub fn aop_denial_count() -> i64:
    """Number of join points skipped because advice returned Err."""
    _aop_denial_count

pub fn aop_last_denial() -> text:
    """Description of the most recent advice denial ("" if none)."""
    _aop_last_denial

pub fn aop_clear_denials():
    """Reset denial bookkeeping (test support)."""
    _aop_denial_count = 0
    _aop_last_denial = ""

fn _record_denial(fn_name: text, kind: text, err: text):
    _aop_denial_count = _aop_denial_count + 1
    _aop_last_denial = "{kind} advice denied {fn_name}: {err}"

struct AspectWeaver:
    registry: AspectRegistry

impl AspectWeaver:
    static fn with_registry(registry: AspectRegistry) -> AspectWeaver:
        AspectWeaver(registry: registry)

    fn wrap<T>(join_point: JoinPoint, func: fn() -> T) -> Result<T, text>:
        val aspects = self.registry.find_aspects(join_point)
        val around_advices = self.registry.find_around_advices(join_point)
        if aspects.len() == 0 and around_advices.len() == 0:
            val result = func()
            return Ok(result)
        val fn_name = _join_point_name(join_point)
        val start = time_now_ms()
        val before_ctx = AdviceContext(
            function_name: fn_name,
            class_name: nil,
            module_name: nil,
            args: [],
            result: nil,
            error: nil,
            start_time: start,
            end_time: nil
        )
        # Execute Before and legacy Around (pre-hook) advice
        var j = 0
        while j < aspects.len():
            val aspect = aspects[j]
            j = j + 1
            match aspect.advice.kind:
                case Before:
                    val res = aspect.advice.handler(before_ctx)
                    if res.is_err():
                        val e = res.unwrap_err()
                        _record_denial(fn_name, "before", e)
                        return Err(e)
                case Around:
                    # Legacy Around handler runs as a pre-hook; proceed callback
                    # not available because handler signature lacks it.
                    val res = aspect.advice.handler(before_ctx)
                    if res.is_err():
                        val e = res.unwrap_err()
                        _record_denial(fn_name, "around", e)
                        return Err(e)
                case After:
                    pass_do_nothing
                case AfterError:
                    pass_do_nothing
        # Execute AroundAdvice with real proceed contract (E1).
        # Limitation: only one AroundAdvice per join point in interpreter mode.
        # Interpreter constraint: closures capture class instances by value, so
        # me-method mutations inside a closure do not propagate back to outer vars.
        # We use module-level vars (_aop_proceed_*) as the proceed state store —
        # module-level vars ARE writable from closures in the interpreter.
        # func() is NOT called inside the proceed closure (can't store generic T
        # in a module-level var); instead the closure sets _aop_proceed_called and
        # wrap<T> calls func() after the handler returns if called == 1.
        if around_advices.len() > 1:
            _record_denial(fn_name, "around", "multiple around advices not yet supported")
            return Err("multiple around advices not yet supported")
        if around_advices.len() == 1:
            val adv = around_advices[0]
            _aop_proceed_reset()
            val proceed = \:
                if _aop_proceed_called >= 1:
                    _aop_proceed_had_err = true
                    _aop_proceed_err = "proceed called more than once"
                    return Err("proceed called more than once")
                _aop_proceed_called = _aop_proceed_called + 1
                Ok(())
            val handler_res = adv.handler(before_ctx, proceed)
            if handler_res.is_err():
                val e = handler_res.unwrap_err()
                val ran_note = if _aop_proceed_called > 0: " (target ran)" else: " (target did not run)"
                _record_denial(fn_name, "around", e + ran_note)
                return Err(e)
            if _aop_proceed_called == 0:
                val no_proceed_msg = "around advice did not call proceed"
                _record_denial(fn_name, "around", no_proceed_msg)
                return Err(no_proceed_msg)
            # proceed was called exactly once — now call func() to get T
            val around_result = func()
            return Ok(around_result)
        # Call the actual function (no AroundAdvice matched)
        val result = func()
        val end = time_now_ms()
        val after_ctx = AdviceContext(
            function_name: fn_name,
            class_name: nil,
            module_name: nil,
            args: [],
            result: result,
            error: nil,
            start_time: start,
            end_time: end
        )
        # Execute After advice
        var k = 0
        while k < aspects.len():
            val aspect = aspects[k]
            k = k + 1
            match aspect.advice.kind:
                case After:
                    val res = aspect.advice.handler(after_ctx)
                    if res.is_err():
                        # Join point already ran; the denial here masks its result.
                        val e = res.unwrap_err()
                        _record_denial(fn_name, "after(target-executed)", e)
                        return Err(e)
                case Before:
                    pass_do_nothing
                case Around:
                    pass_do_nothing
                case AfterError:
                    # AfterError unreachable here: Simple has no try/catch,
                    # so func() cannot throw. Kept for future Result-returning wrappers.
                    pass_do_nothing
        Ok(result)

# ============================================================================
# Internal helpers
# ============================================================================

fn _join_point_name(jp: JoinPoint) -> text:
    match jp:
        case FunctionCall(name):
            return name
        case MethodCall(class_name, method_name):
            return class_name + "." + method_name
        case ModuleLoad(module_name):
            return module_name
        case All:
            return "*"

fn _match_join_point(pointcut_kind: JoinPoint, pattern: text, join_point: JoinPoint) -> bool:
    """Check whether a pointcut kind + pattern matches a given join point."""
    match pointcut_kind:
        case All:
            # All pointcut matches every join point
            return _glob_match(pattern, _join_point_name(join_point))
        case FunctionCall(pc_name):
            match join_point:
                case FunctionCall(name):
                    return _glob_match(pattern, name)
                case _:
                    return false
        case MethodCall(pc_class, pc_method):
            match join_point:
                case MethodCall(class_name, method_name):
                    val full = class_name + "." + method_name
                    return _glob_match(pattern, full)
                case _:
                    return false
        case ModuleLoad(pc_module):
            match join_point:
                case ModuleLoad(module_name):
                    return _glob_match(pattern, module_name)
                case _:
                    return false

fn _glob_match(pattern: text, value: text) -> bool:
    """Match a glob pattern against a value. Supports '*' as wildcard."""
    if pattern == "*":
        return true
    if pattern == value:
        return true
    # Split pattern on '*' and check segments appear in order
    val parts = pattern.split("*")
    if parts.len() == 1:
        # No wildcard, exact match only (already checked above)
        return false
    var pos = 0
    var idx = 0
    while idx < parts.len():
        val seg = parts[idx]
        if seg.len() == 0:
            # Empty segment from leading/trailing/consecutive '*'
            idx = idx + 1
            continue
        if idx == 0:
            # First segment must anchor at start
            if not value.starts_with(seg):
                return false
            pos = seg.len()
        elif idx == parts.len() - 1:
            # Last segment must anchor at end and must not overlap already-consumed position.
            if not value.ends_with(seg):
                return false
            val end_start = value.len() - seg.len()
            if end_start < pos:
                # The suffix overlaps the already-consumed prefix — reject to avoid false match.
                return false
            pos = value.len()
        else:
            # Middle segment: find next occurrence after pos
            val remaining = value.slice(pos, value.len())
            val found = remaining.index_of(seg)
            if found < 0:
                return false
            pos = pos + found + seg.len()
        idx = idx + 1
    return true

var global_registry: AspectRegistry? = nil
var global_weaver: AspectWeaver? = nil

# Seal the global registry so that disable_unsafe and unregister_unsafe become no-ops.
# Called by init_aop after security aspects have been registered.
# Not pub — only the init path may seal the registry.
fn _seal_registry():
    if global_registry.is_some():
        var reg = global_registry.unwrap()
        reg.sealed = true
        global_registry = Some(reg)

pub fn init_aop(config: AopConfig):
    # SECURITY: only initialize once. Re-initialization would wipe all registered security aspects.
    if global_registry.is_some():
        return
    global_registry = Some(AspectRegistry.empty())
    global_weaver = Some(AspectWeaver.with_registry(global_registry.unwrap()))
    # Seal after creation so security aspects registered immediately after cannot be removed.
    _seal_registry()

pub fn get_registry() -> AspectRegistry:
    if global_registry.is_none():
        global_registry = Some(AspectRegistry.empty())
    global_registry.unwrap()

pub fn get_weaver() -> AspectWeaver:
    if global_weaver.is_none():
        global_weaver = Some(AspectWeaver.with_registry(get_registry()))
    global_weaver.unwrap()

pub fn register_aspect(aspect: Aspect):
    get_registry().register(aspect)

pub fn register_around_advice(adv: AroundAdvice):
    get_registry().register_around(adv)

pub fn wrap_call<T>(name: text, func: fn() -> T) -> Result<T, text>:
    get_weaver().wrap(JoinPoint.FunctionCall(name), func)

# @tag(class_name=class_name, method_name=method_name)
pub fn wrap_method<T>(class_name: text, method_name: text, func: fn() -> T) -> Result<T, text>:
    get_weaver().wrap(JoinPoint.MethodCall(class_name, method_name), func)
