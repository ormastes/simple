# SReplay VM — Core Types

use std.nogc_sync_mut.replay.types.{Arch}

# ============================================================================
# VM Replay Mode
# ============================================================================

enum VmReplayMode:
    Live       # Normal execution, no recording
    Record     # Execute and record all device I/O
    Replay     # Replay from recorded device I/O log
    Snapshot   # Use QEMU snapshots (hybrid mode)

impl VmReplayMode:
    fn to_text() -> text:
        match self:
            case VmReplayMode.Live: "live"
            case VmReplayMode.Record: "record"
            case VmReplayMode.Replay: "replay"
            case VmReplayMode.Snapshot: "snapshot"

# ============================================================================
# VM State
# ============================================================================

enum VmState:
    Stopped
    Running
    Paused
    Replaying

# ============================================================================
# Device Configuration
# ============================================================================

struct DeviceConfig:
    name: text
    base_addr: i64
    size: i64
    irq: i32

# ============================================================================
# VM Configuration
# ============================================================================

struct VmConfig:
    arch: Arch
    num_cpus: i32
    memory_mb: i64
    devices: [DeviceConfig]
    replay_mode: VmReplayMode

impl VmConfig:
    static fn default_rv32(memory_mb: i64) -> VmConfig:
        VmConfig(
            arch: Arch.RISCV32,
            num_cpus: 1,
            memory_mb: memory_mb,
            devices: [
                DeviceConfig(name: "uart0", base_addr: 0x10000000, size: 0x100, irq: 10),
                DeviceConfig(name: "timer0", base_addr: 0x02000000, size: 0x10000, irq: 7)
            ],
            replay_mode: VmReplayMode.Live
        )

# ============================================================================
# Device I/O Event (for replay log)
# ============================================================================

enum DeviceIoKind:
    MmioRead
    MmioWrite
    Interrupt
    DmaTransfer
    TimerFired

impl DeviceIoKind:
    fn to_i32() -> i32:
        match self:
            case DeviceIoKind.MmioRead: 0
            case DeviceIoKind.MmioWrite: 1
            case DeviceIoKind.Interrupt: 2
            case DeviceIoKind.DmaTransfer: 3
            case DeviceIoKind.TimerFired: 4

struct DeviceIoEvent:
    seq: i64
    device_name: text
    kind: DeviceIoKind
    timestamp_cycles: i64
    offset: i64
    size: i32
    value: i64
