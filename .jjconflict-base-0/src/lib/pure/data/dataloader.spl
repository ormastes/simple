# Stubs for pure dataloader primitives

struct LabeledBatch:
    features: [[f64]]
    labels: [f64]

class DataLoader:
    data: [[f64]]
    batch_size: i64
    pos: i64

    me reset():
        self.pos = 0

    me next_batch() -> [[f64]]:
        val end = self.pos + self.batch_size
        val slice = self.data
        self.pos = end
        slice

class LabeledDataLoader:
    data: [any]
    batch_size: i64
    pos: i64

    me reset():
        self.pos = 0

    me next_batch() -> LabeledBatch:
        LabeledBatch(features: [], labels: [])

fn create_dataloader(data: [[f64]], batch_size: i64) -> DataLoader:
    DataLoader(data: data, batch_size: batch_size, pos: 0)

fn create_dataloader_labeled(data: [any], batch_size: i64) -> LabeledDataLoader:
    LabeledDataLoader(data: data, batch_size: batch_size, pos: 0)

export DataLoader, LabeledDataLoader, LabeledBatch, create_dataloader, create_dataloader_labeled
