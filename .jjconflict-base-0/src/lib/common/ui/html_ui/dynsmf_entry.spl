# dynsmf_entry.spl — background-lane entry module for the html_ui library.
#
# Re-exports the catalog and payload decode API so background-built SMF
# bundles can import a single module and access both.
#
# Module id: ui_html

export use std.common.ui.html_ui.catalog.{
    UiCatalogEntry,
    catalog_elements,
    catalog_supports,
    catalog_tags
}

export use std.common.ui.html_ui.payload.{
    UiPartMap,
    payload_encode,
    payload_decode,
    payload_split,
    gen_std_module_source,
    gen_dyn_main_source,
    gen_dyn_part_source
}

fn ui_html_lib_ready() -> bool:
    true

export ui_html_lib_ready
