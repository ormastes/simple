# Motion Tokens
#
# Animation duration and easing tokens for the layered surface system.
# Covers hover, panel, modal, sidebar, notification, and page transitions.
# Provides a reduced-motion path (prefers-reduced-motion).
# Supersedes IOSAnimationTokens for glass themes.

class MotionTokens:
    hover_ms: i32          # 120-160
    panel_ms: i32          # 180-240
    modal_ms: i32          # 220-300
    sidebar_ms: i32        # 200-280
    notification_ms: i32   # 180-240
    page_ms: i32           # 200-280
    easing: text           # cubic-bezier
    reduced_motion: bool   # prefers-reduced-motion

    static fn default_motion() -> MotionTokens:
        MotionTokens(
            hover_ms: 140,
            panel_ms: 200,
            modal_ms: 260,
            sidebar_ms: 240,
            notification_ms: 200,
            page_ms: 240,
            easing: "cubic-bezier(0.4, 0.0, 0.2, 1.0)",
            reduced_motion: false
        )

    static fn reduced() -> MotionTokens:
        MotionTokens(
            hover_ms: 0,
            panel_ms: 0,
            modal_ms: 0,
            sidebar_ms: 0,
            notification_ms: 0,
            page_ms: 0,
            easing: "linear",
            reduced_motion: true
        )

fn motion_tokens_to_css(tokens: MotionTokens) -> text:
    """Generate CSS custom properties from MotionTokens.

    Output:
        --motion-hover: 140ms;
        --motion-panel: 200ms;
        --motion-modal: 260ms;
        --motion-sidebar: 240ms;
        --motion-notification: 200ms;
        --motion-page: 240ms;
        --motion-easing: cubic-bezier(0.4, 0.0, 0.2, 1.0);
    """
    var css = ""
    css = css + "--motion-hover: " + tokens.hover_ms.to_text() + "ms;\n"
    css = css + "--motion-panel: " + tokens.panel_ms.to_text() + "ms;\n"
    css = css + "--motion-modal: " + tokens.modal_ms.to_text() + "ms;\n"
    css = css + "--motion-sidebar: " + tokens.sidebar_ms.to_text() + "ms;\n"
    css = css + "--motion-notification: " + tokens.notification_ms.to_text() + "ms;\n"
    css = css + "--motion-page: " + tokens.page_ms.to_text() + "ms;\n"
    css = css + "--motion-easing: " + tokens.easing + ";\n"
    css
