# Scroll Surface — persistent packed framebuffer + scroll model for partial redraw.
#
# This is the shared render core used by examples/06_io/ui/showcase_8k_scroll_gui.spl
# and its spec. It owns a packed [i64] pixel buffer (low 24 bits = 0x00RRGGBB, the
# same masking the showcase pack() uses) and mutates it in place via me-methods.
# Arrays are value types in Simple, so the buffer MUST live as a class field and
# never be passed by value to a helper — that would copy the whole 8K surface.
#
# Two render strategies, producing the SAME image:
#   paint_full        : clear + repaint the whole viewport (the OFF baseline).
#   step_on (blit)    : translate retained rows by the scroll delta (scroll-blit),
#                       raster only the newly-exposed band, repaint the thumb.
#
# Present note: no sub-rect present extern exists (rt_winit/rt_sdl2 present take a
# full pixels+w+h upload only), so on a real window the full upload is the ceiling;
# the ON win is in the raster stage that this module controls.

use common.ui.dirty_region.{DirtyTracker}

# ---- Palette (packed 0x00RRGGBB) ----
val BG: i64 = 0x14141C
val ROW_A: i64 = 0x1A1A24
val ROW_B: i64 = 0x20202C
val ACCENT: i64 = 0x4080FF
val TRACK: i64 = 0x101018
val THUMB: i64 = 0x6070A0

# ---- Geometry ----
val ROW_H: i32 = 48          # height of one list row
val SCROLLBAR_W: i32 = 24    # scrollbar track width on the right edge

# ============================================================================
# FrameBuffer — persistent packed [i64] surface, mutated in place via me-methods.
# ============================================================================
class FrameBuffer:
    buf: [i64]
    w: i32
    h: i32

    static fn create(w: i32, h: i32) -> FrameBuffer:
        return FrameBuffer(buf: [0; w * h], w: w, h: h)

    # Fill a clamped rectangle with a solid packed color. Returns pixels written.
    me fill_rect(x: i32, y: i32, rw: i32, rh: i32, color: i64) -> i64:
        var x0 = x
        var y0 = y
        var x1 = x + rw
        var y1 = y + rh
        if x0 < 0:
            x0 = 0
        if y0 < 0:
            y0 = 0
        if x1 > self.w:
            x1 = self.w
        if y1 > self.h:
            y1 = self.h
        if x1 <= x0 or y1 <= y0:
            return 0
        var written: i64 = 0
        var py = y0
        while py < y1:
            val row_base = py * self.w
            var px = x0
            while px < x1:
                self.buf[row_base + px] = color
                px = px + 1
            written = written + (x1 - x0).to_i64()
            py = py + 1
        return written

    # Vertical scroll-blit: shift columns [0, cols) up/down by `delta` rows so the
    # retained content moves with the scroll. delta>0 = scroll down (content moves
    # up). Returns pixels copied. This is the cost the ON path must pay to keep the
    # retained region correct.
    me blit_vertical(cols: i32, delta: i32) -> i64:
        if delta == 0 or cols <= 0:
            return 0
        var copied: i64 = 0
        if delta > 0:
            # content moves up: dst row y <- src row y+delta, top-to-bottom
            var y = 0
            val limit = self.h - delta
            while y < limit:
                val dst_base = y * self.w
                val src_base = (y + delta) * self.w
                var x = 0
                while x < cols:
                    self.buf[dst_base + x] = self.buf[src_base + x]
                    x = x + 1
                copied = copied + cols.to_i64()
                y = y + 1
        else:
            # content moves down: dst row y <- src row y+delta, bottom-to-top
            val d = 0 - delta
            var y = self.h - 1
            while y >= d:
                val dst_base = y * self.w
                val src_base = (y - d) * self.w
                var x = 0
                while x < cols:
                    self.buf[dst_base + x] = self.buf[src_base + x]
                    x = x + 1
                copied = copied + cols.to_i64()
                y = y - 1
        return copied

# ============================================================================
# Scroll model
# ============================================================================
struct ScrollModel:
    total_rows: i32
    view_w: i32
    view_h: i32

fn content_height(m: ScrollModel) -> i32:
    return m.total_rows * ROW_H

fn max_scroll(m: ScrollModel) -> i32:
    val ch = content_height(m)
    if ch <= m.view_h:
        return 0
    return ch - m.view_h

# Color for an absolute content row (alternating bands + an accent every 16th).
fn row_color(content_row: i32) -> i64:
    if content_row % 16 == 0:
        return ACCENT
    if content_row % 2 == 0:
        return ROW_A
    return ROW_B

# ============================================================================
# Virtualization
# ============================================================================
# The persistent FrameBuffer is viewport-sized (not content-sized), but
# `total_rows * ROW_H` (content_height) can be far larger than the viewport —
# that's the whole scrollable-list point. `visible_range` is the primitive
# that answers "which absolute content rows does a [scroll_offset,
# scroll_offset + viewport_h) pixel window cover?" so painting code (and any
# future caller — e.g. a data-fetching virtualized list) walks only that row
# window instead of the full row count. Returns `count: 0` for a degenerate
# (non-positive) viewport_h or row_h.
#
# Returns a VisibleRange struct rather than an anonymous labeled tuple
# (`-> (first: i32, count: i32)`): the interpreter has a confirmed bug where
# reading `.first`/`.count` back off a labeled-tuple return can yield a STALE
# value left over from an unrelated earlier call elsewhere in the same loaded
# program (reproduced with a minimal probe — two different calls with the
# same field names on a fresh tuple type read back garbage instead of the
# values just returned). A dedicated struct type does not hit this.
struct VisibleRange:
    first: i32
    count: i32

fn visible_range(scroll_offset: i32, viewport_h: i32, row_h: i32) -> VisibleRange:
    if viewport_h <= 0 or row_h <= 0:
        return VisibleRange(first: 0, count: 0)
    var so = scroll_offset
    if so < 0:
        so = 0
    val first = so / row_h
    val last_pixel = so + viewport_h - 1
    val last_row = last_pixel / row_h
    return VisibleRange(first: first, count: last_row - first + 1)

struct ThumbGeom:
    y: i32
    h: i32

fn thumb_geom(m: ScrollModel, scroll: i32) -> ThumbGeom:
    val ch = content_height(m)
    if ch <= m.view_h:
        return ThumbGeom(y: 0, h: m.view_h)
    var th = (m.view_h * m.view_h) / ch
    if th < 24:
        th = 24
    val ms = max_scroll(m)
    var ty = 0
    if ms > 0:
        ty = (scroll * (m.view_h - th)) / ms
    return ThumbGeom(y: ty, h: th)

# ============================================================================
# Painting
# ============================================================================
# Paint content rows overlapping the viewport band [band_y0, band_y1) at `scroll`.
# Virtualized via visible_range(): only the rows the band actually covers are
# walked, never the full total_rows list.
fn paint_content_band(fb: FrameBuffer, m: ScrollModel, scroll: i32, band_y0: i32, band_y1: i32) -> i64:
    var y0 = band_y0
    var y1 = band_y1
    if y0 < 0:
        y0 = 0
    if y1 > m.view_h:
        y1 = m.view_h
    if y1 <= y0:
        return 0
    val content_w = m.view_w - SCROLLBAR_W
    var written: i64 = 0
    val range = visible_range(scroll + y0, y1 - y0, ROW_H)
    var count = range.count
    if range.first + count > m.total_rows:
        count = m.total_rows - range.first
    if count < 0:
        count = 0
    var i = 0
    while i < count:
        val content_row = range.first + i
        val content_y = content_row * ROW_H
        val screen_y = content_y - scroll
        var draw_y0 = screen_y
        if draw_y0 < y0:
            draw_y0 = y0
        var draw_y1 = screen_y + ROW_H
        if draw_y1 > y1:
            draw_y1 = y1
        if draw_y1 > draw_y0:
            val n = fb.fill_rect(0, draw_y0, content_w, draw_y1 - draw_y0, row_color(content_row))
            written = written + n
        i = i + 1
    return written

fn paint_scrollbar(fb: FrameBuffer, m: ScrollModel, scroll: i32) -> i64:
    val tx = m.view_w - SCROLLBAR_W
    var written: i64 = 0
    written = written + fb.fill_rect(tx, 0, SCROLLBAR_W, m.view_h, TRACK)
    val tg = thumb_geom(m, scroll)
    written = written + fb.fill_rect(tx + 4, tg.y, SCROLLBAR_W - 8, tg.h, THUMB)
    return written

# Full repaint of the viewport (the OFF baseline): clear + content + scrollbar.
fn paint_full(fb: FrameBuffer, m: ScrollModel, scroll: i32) -> i64:
    var written: i64 = 0
    written = written + fb.fill_rect(0, 0, m.view_w, m.view_h, BG)
    written = written + paint_content_band(fb, m, scroll, 0, m.view_h)
    written = written + paint_scrollbar(fb, m, scroll)
    return written

# ============================================================================
# Frame stepping
# ============================================================================
# OFF: repaint the whole viewport every frame. Marks the full viewport dirty.
fn step_off(fb: FrameBuffer, m: ScrollModel, scroll: i32, tracker: DirtyTracker) -> i64:
    tracker.reset()
    tracker.mark(0, 0, m.view_w, m.view_h)
    return paint_full(fb, m, scroll)

# ON: scroll-blit the retained region, raster only the newly-exposed band, then
# repaint the scrollbar thumb. Produces the SAME image as paint_full at new_scroll.
# delta == 0 (idle) ⇒ nothing dirty, nothing painted. Returns pixels touched
# (blit copies + band raster + thumb), which is the honest ON CPU cost.
fn step_on(fb: FrameBuffer, m: ScrollModel, old_scroll: i32, new_scroll: i32, tracker: DirtyTracker) -> i64:
    tracker.reset()
    var written: i64 = 0
    val delta = new_scroll - old_scroll
    if delta == 0:
        return 0
    val content_w = m.view_w - SCROLLBAR_W
    # 1. Shift retained content rows by delta (content columns only).
    written = written + fb.blit_vertical(content_w, delta)
    # 2. Raster the newly-exposed band at the new offset.
    var band_y0 = 0
    var band_y1 = 0
    if delta > 0:
        band_y0 = m.view_h - delta
        band_y1 = m.view_h
    else:
        band_y0 = 0
        band_y1 = 0 - delta
    if band_y0 < 0:
        band_y0 = 0
    if band_y1 > m.view_h:
        band_y1 = m.view_h
    written = written + fb.fill_rect(0, band_y0, content_w, band_y1 - band_y0, BG)
    written = written + paint_content_band(fb, m, new_scroll, band_y0, band_y1)
    tracker.mark(0, band_y0, content_w, band_y1 - band_y0)
    # 3. Thumb moved: clear old thumb span to track, draw new thumb.
    val tx = m.view_w - SCROLLBAR_W
    val og = thumb_geom(m, old_scroll)
    val ng = thumb_geom(m, new_scroll)
    written = written + fb.fill_rect(tx, og.y, SCROLLBAR_W, og.h, TRACK)
    written = written + fb.fill_rect(tx + 4, ng.y, SCROLLBAR_W - 8, ng.h, THUMB)
    tracker.mark(tx, og.y, SCROLLBAR_W, og.h)
    tracker.mark(tx, ng.y, SCROLLBAR_W, ng.h)
    return written
