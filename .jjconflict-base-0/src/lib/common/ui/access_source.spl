# UI Access Source + Envelope Contracts
#
# Additive provenance and adapter-target metadata around the canonical
# UiAccessSnapshot model.

use common.ui.access.{UiAccessSnapshot, ui_access_empty_snapshot, ui_access_snapshot_to_json}

struct UiAccessSourceMeta:
    source_kind: text
    source_id: text
    source_name: text
    source_uri: text
    source_version: text

struct UiAccessIssue:
    code: text
    severity: text
    message: text
    source_id: text
    subject: text
    detail: text

struct UiAccessAdapterTarget:
    source: UiAccessSourceMeta
    operation: text
    snapshot_mode: text
    active_surface: text
    surface_id: text
    window_id: text
    app_id: text
    title: text
    focused_only: bool
    limit: i32

struct UiAccessSnapshotEnvelope:
    source: UiAccessSourceMeta
    target: UiAccessAdapterTarget
    snapshot: UiAccessSnapshot
    issues: [UiAccessIssue]

fn ui_access_source_meta(source_kind: text, source_id: text, source_name: text, source_uri: text, source_version: text) -> UiAccessSourceMeta:
    return UiAccessSourceMeta(
        source_kind: source_kind,
        source_id: source_id,
        source_name: source_name,
        source_uri: source_uri,
        source_version: source_version
    )

fn ui_access_source_meta_empty(source_kind: text, source_id: text) -> UiAccessSourceMeta:
    return ui_access_source_meta(source_kind, source_id, source_id, "", "")

fn ui_access_issue(code: text, severity: text, message: text, source_id: text, subject: text, detail: text) -> UiAccessIssue:
    return UiAccessIssue(
        code: code,
        severity: severity,
        message: message,
        source_id: source_id,
        subject: subject,
        detail: detail
    )

fn ui_access_issue_error(code: text, message: text, source_id: text, subject: text, detail: text) -> UiAccessIssue:
    return ui_access_issue(code, "error", message, source_id, subject, detail)

fn ui_access_issue_warning(code: text, message: text, source_id: text, subject: text, detail: text) -> UiAccessIssue:
    return ui_access_issue(code, "warning", message, source_id, subject, detail)

fn ui_access_issue_is_error(issue: UiAccessIssue) -> bool:
    return issue.severity == "error"

fn ui_access_issue_is_warning(issue: UiAccessIssue) -> bool:
    return issue.severity == "warning"

fn ui_access_adapter_target(source: UiAccessSourceMeta, operation: text, snapshot_mode: text, active_surface: text, surface_id: text, window_id: text, app_id: text, title: text, focused_only: bool, limit: i32) -> UiAccessAdapterTarget:
    return UiAccessAdapterTarget(
        source: source,
        operation: operation,
        snapshot_mode: snapshot_mode,
        active_surface: active_surface,
        surface_id: surface_id,
        window_id: window_id,
        app_id: app_id,
        title: title,
        focused_only: focused_only,
        limit: limit
    )

fn ui_access_adapter_target_for_snapshot(source: UiAccessSourceMeta, snapshot_mode: text, active_surface: text) -> UiAccessAdapterTarget:
    return ui_access_adapter_target(source, "snapshot", snapshot_mode, active_surface, active_surface, "", "", "", false, 0)

fn ui_access_snapshot_envelope(source: UiAccessSourceMeta, target: UiAccessAdapterTarget, snapshot: UiAccessSnapshot, issues: [UiAccessIssue]) -> UiAccessSnapshotEnvelope:
    return UiAccessSnapshotEnvelope(
        source: source,
        target: target,
        snapshot: snapshot,
        issues: issues
    )

fn ui_access_snapshot_envelope_empty(target: UiAccessAdapterTarget) -> UiAccessSnapshotEnvelope:
    val snapshot = ui_access_empty_snapshot(target.snapshot_mode, target.active_surface, [])
    return ui_access_snapshot_envelope(target.source, target, snapshot, [])

fn ui_access_snapshot_envelope_to_json(envelope: UiAccessSnapshotEnvelope) -> text:
    return "{" +
        _json_pair("source", _source_to_json(envelope.source)) + "," +
        _json_pair("target", _target_to_json(envelope.target)) + "," +
        _json_pair("snapshot", ui_access_snapshot_to_json(envelope.snapshot)) + "," +
        _json_pair("issues", _issues_to_json(envelope.issues)) +
        "}"

fn _source_to_json(source: UiAccessSourceMeta) -> text:
    return "{" +
        _json_pair("source_kind", _json_str(source.source_kind)) + "," +
        _json_pair("source_id", _json_str(source.source_id)) + "," +
        _json_pair("source_name", _json_str(source.source_name)) + "," +
        _json_pair("source_uri", _json_str(source.source_uri)) + "," +
        _json_pair("source_version", _json_str(source.source_version)) +
        "}"

fn _target_to_json(target: UiAccessAdapterTarget) -> text:
    return "{" +
        _json_pair("source", _source_to_json(target.source)) + "," +
        _json_pair("operation", _json_str(target.operation)) + "," +
        _json_pair("snapshot_mode", _json_str(target.snapshot_mode)) + "," +
        _json_pair("active_surface", _json_str(target.active_surface)) + "," +
        _json_pair("surface_id", _json_str(target.surface_id)) + "," +
        _json_pair("window_id", _json_str(target.window_id)) + "," +
        _json_pair("app_id", _json_str(target.app_id)) + "," +
        _json_pair("title", _json_str(target.title)) + "," +
        _json_pair("focused_only", if target.focused_only: "true" else: "false") + "," +
        _json_pair("limit", "{target.limit}") +
        "}"

fn _issues_to_json(issues: [UiAccessIssue]) -> text:
    var out = "["
    var first = true
    for issue in issues:
        if not first:
            out = "{out},"
        out = "{out}{_issue_to_json(issue)}"
        first = false
    out = "{out}]"
    return out

fn _issue_to_json(issue: UiAccessIssue) -> text:
    return "{" +
        _json_pair("code", _json_str(issue.code)) + "," +
        _json_pair("severity", _json_str(issue.severity)) + "," +
        _json_pair("message", _json_str(issue.message)) + "," +
        _json_pair("source_id", _json_str(issue.source_id)) + "," +
        _json_pair("subject", _json_str(issue.subject)) + "," +
        _json_pair("detail", _json_str(issue.detail)) +
        "}"

fn _json_pair(key: text, value: text) -> text:
    return "{_json_str(key)}:{value}"

fn _json_str(value: text) -> text:
    return "\"{_escape_json(value)}\""

fn _escape_json(value: text) -> text:
    var result = ""
    var idx = 0
    while idx < value.len():
        val ch = value[idx]
        if ch == "\"":
            result = "{result}\\\""
        elif ch == "\\":
            result = "{result}\\\\"
        elif ch == "\n":
            result = "{result}\\n"
        elif ch == "\r":
            result = "{result}\\r"
        elif ch == "\t":
            result = "{result}\\t"
        else:
            result = "{result}{ch}"
        idx = idx + 1
    return result
