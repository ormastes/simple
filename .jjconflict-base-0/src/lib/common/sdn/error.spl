# SDN Error — structured parse/validation errors.
#
# Provides: SdnError.

use std.common.sdn.value.{Span}

pub class SdnError:
    kind: text
    msg: text

    static fn syntax_error(message: text, line: i64, column: i64) -> SdnError:
        SdnError(kind: "syntax", msg: message)

    static fn syntax_error_with_span(message: text, span: Span) -> SdnError:
        SdnError(kind: "syntax", msg: message)

    static fn unexpected_token(found: text, expected: text, span: Span) -> SdnError:
        SdnError(kind: "unexpected", msg: "unexpected token {found}, expected {expected}")

    static fn security_error(message: text, span: Span) -> SdnError:
        SdnError(kind: "security", msg: message)

    fn message(self) -> text:
        self.msg

    fn is_security_error(self) -> bool:
        self.kind == "security"
