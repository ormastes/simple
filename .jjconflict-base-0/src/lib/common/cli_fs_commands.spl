# CLI Filesystem Commands
#
# Pure state transitions for mkdir/chmod behavior.

struct CliFsNode:
    path: text
    is_dir: bool
    mode: i64

struct CliFsState:
    nodes: [CliFsNode]

fn cli_fs_node(path: text, is_dir: bool, mode: i64) -> CliFsNode:
    CliFsNode(path: _cli_fs_normalize(path), is_dir: is_dir, mode: mode)

fn cli_fs_state(nodes: [CliFsNode]) -> CliFsState:
    var out: [CliFsNode] = [cli_fs_node("/", true, 0o755)]
    for node in nodes:
        out = _cli_fs_put(out, cli_fs_node(node.path, node.is_dir, node.mode))
    CliFsState(nodes: out)

fn cli_fs_exists(state: CliFsState, path: text) -> bool:
    match cli_fs_find(state, path):
        case Some(_): true
        case _: false

fn cli_fs_find(state: CliFsState, path: text) -> CliFsNode?:
    val normalized = _cli_fs_normalize(path)
    for node in state.nodes:
        if node.path == normalized:
            return Some(node)
    nil

fn cli_fs_apply_mkdir(state: CliFsState, path: text, parents: bool) -> Result<CliFsState, text>:
    val normalized = _cli_fs_normalize(path)
    if cli_fs_exists(state, normalized):
        if parents:
            return Ok(state)
        return Err("mkdir: file exists")
    val parent = _cli_fs_parent(normalized)
    if not parents and not cli_fs_exists(state, parent):
        return Err("mkdir: parent missing")
    var nodes = state.nodes
    if parents:
        var current = ""
        for part in _cli_fs_parts(normalized):
            current = if current == "": "/" + part else: current + "/" + part
            if not _cli_fs_contains(nodes, current):
                nodes = nodes.push(cli_fs_node(current, true, 0o755))
    else:
        nodes = nodes.push(cli_fs_node(normalized, true, 0o755))
    Ok(CliFsState(nodes: nodes))

fn cli_fs_apply_chmod(state: CliFsState, path: text, mode: i64) -> Result<CliFsState, text>:
    val normalized = _cli_fs_normalize(path)
    var nodes: [CliFsNode] = []
    var changed = false
    for node in state.nodes:
        if node.path == normalized:
            nodes = nodes.push(cli_fs_node(node.path, node.is_dir, mode))
            changed = true
        else:
            nodes = nodes.push(node)
    if not changed:
        return Err("chmod: missing path")
    Ok(CliFsState(nodes: nodes))

fn cli_fs_parse_octal_mode(mode: text) -> Result<i64, text>:
    if mode.len() < 3 or mode.len() > 4:
        return Err("chmod: unsupported mode")
    var bits: i64 = 0
    for ch in mode:
        if ch < "0" or ch > "7":
            return Err("chmod: unsupported mode")
        bits = bits * 8 + (ch.to_i64() - "0".to_i64())
    Ok(bits)

fn _cli_fs_put(nodes: [CliFsNode], next: CliFsNode) -> [CliFsNode]:
    var out: [CliFsNode] = []
    var replaced = false
    for node in nodes:
        if node.path == next.path:
            out = out.push(next)
            replaced = true
        else:
            out = out.push(node)
    if not replaced:
        out = out.push(next)
    out

fn _cli_fs_contains(nodes: [CliFsNode], path: text) -> bool:
    val normalized = _cli_fs_normalize(path)
    for node in nodes:
        if node.path == normalized:
            return true
    false

fn _cli_fs_parent(path: text) -> text:
    val normalized = _cli_fs_normalize(path)
    if normalized == "/":
        return "/"
    var last_slash = 0
    var i = 0
    for ch in normalized:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash == 0:
        return "/"
    normalized.slice(0, last_slash)

fn _cli_fs_normalize(path: text) -> text:
    if path == "":
        return "/"
    if path.starts_with("/"):
        return path
    "/" + path

fn _cli_fs_parts(path: text) -> [text]:
    var parts: [text] = []
    var current = ""
    for ch in _cli_fs_normalize(path) + "/":
        if ch == "/":
            if current != "":
                parts = parts.push(current)
            current = ""
        else:
            current = current + ch
    parts
