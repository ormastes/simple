"""Minimal portable processing IR shared by CPU oracles and device backends."""

val PROCESSING_IR_OP_FILL_U32: i64 = 1

struct ProcessingIr:
    op: i64
    element_count: i64
    value: u32

struct ProcessingIrValidation:
    valid: bool
    reason: text

fn processing_ir_fill_u32(element_count: i64, value: u32) -> ProcessingIr:
    ProcessingIr(op: PROCESSING_IR_OP_FILL_U32, element_count: element_count, value: value)

fn processing_ir_validate(ir: ProcessingIr) -> ProcessingIrValidation:
    if ir.op != PROCESSING_IR_OP_FILL_U32:
        return ProcessingIrValidation(valid: false, reason: "unsupported-op")
    if ir.element_count <= 0:
        return ProcessingIrValidation(valid: false, reason: "invalid-element-count")
    if ir.element_count > 536870911:
        return ProcessingIrValidation(valid: false, reason: "output-size-overflow")
    ProcessingIrValidation(valid: true, reason: "ok")

fn processing_ir_cpu_execute(ir: ProcessingIr) -> [u32]:
    if not processing_ir_validate(ir).valid:
        return []
    var output: [u32] = []
    var i: i64 = 0
    while i < ir.element_count:
        output.push(ir.value)
        i = i + 1
    output

fn processing_ir_outputs_equal(actual: [u32], expected: [u32]) -> bool:
    if actual.len() != expected.len():
        return false
    var i: i64 = 0
    while i < actual.len().to_i64():
        if actual[i] != expected[i]:
            return false
        i = i + 1
    true

export PROCESSING_IR_OP_FILL_U32, ProcessingIr, ProcessingIrValidation
export processing_ir_fill_u32, processing_ir_validate, processing_ir_cpu_execute
export processing_ir_outputs_equal
