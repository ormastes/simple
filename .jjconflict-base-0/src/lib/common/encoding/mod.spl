@allow(primitive_api, star_import)
# Encoding Module
#
# Unified text encoding system for Simple.
#
# Two character modes:
#   CharMode.Utf8        — byte-oriented (default), O(1) length
#   CharMode.FullUnicode — codepoint-oriented, O(n) length
#
# Encoding codecs: UTF-8, UTF-16, UTF-32, ASCII, Latin-1
#
# Usage:
#     use std.common.encoding.{CharMode, set_char_mode, text_len_mode, Encoding, encode, decode}

use std.common.encoding.char_mode.*
use std.common.encoding.utf8.*
use std.common.encoding.utf16.*
use std.common.encoding.utf32.*
use std.common.encoding.codec.*
use std.common.encoding.text_ops.*
use std.common.encoding.unicode_text.*
use std.common.encoding.font_registry.*
