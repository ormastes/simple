# WAV Encode — f32 samples to RIFF/WAVE bytes, pure Simple
#
# Two variants:
#   encode_wav_pcm16(samples, channels, sample_rate) — 16-bit PCM (format 1)
#   encode_wav_f32(samples, channels, sample_rate)   — 32-bit IEEE float (format 3)
#
# Input samples are f32 in [-1.0, 1.0], interleaved when channels > 1.
#
# PCM16 quantization (documented choice, asserted by wav_encode_spec):
#   v = trunc(clamp(s, -1.0, 1.0) * 32768), then clamp to [-32768, 32767].
#   So 0.0 -> 0, 0.5 -> 16384, -0.5 -> -16384, 1.0 -> 32767 (clamped).
#
# ponytail: fmt chunk is always the 16-byte PCM shape, even for format 3
# (canonical float WAV adds cbSize + a fact chunk); every common decoder
# accepts this — add the fact chunk only if a real consumer rejects it.

use std.common.binary_io.{f32_to_bits}

# ============================================================================
# Public API
# ============================================================================

pub fn encode_wav_pcm16(samples: [f32], channels: i32, sample_rate: i32) -> [u8]:
    """Encode interleaved f32 samples [-1,1] as a 16-bit PCM WAV file."""
    val data_len = samples.len() * 2
    var out = _wav_header(1, channels.to_i64(), sample_rate.to_i64(), 16, data_len)
    for s in samples:
        val v = _pcm16_of(s)
        val u = if v < 0: v + 65536 else: v
        out.push((u & 0xFF).to_u8())
        out.push(((u >> 8) & 0xFF).to_u8())
    out

pub fn encode_wav_f32(samples: [f32], channels: i32, sample_rate: i32) -> [u8]:
    """Encode interleaved f32 samples as a 32-bit IEEE-float WAV file (format 3).

    Sample bytes are the exact IEEE-754 bit pattern, little-endian — bit-exact,
    no clamping or scaling.
    """
    val data_len = samples.len() * 4
    var out = _wav_header(3, channels.to_i64(), sample_rate.to_i64(), 32, data_len)
    for s in samples:
        val bits = f32_to_bits(s).to_i64()
        out.push((bits & 0xFF).to_u8())
        out.push(((bits >> 8) & 0xFF).to_u8())
        out.push(((bits >> 16) & 0xFF).to_u8())
        out.push(((bits >> 24) & 0xFF).to_u8())
    out

# ============================================================================
# Internals
# ============================================================================

fn _pcm16_of(sample: f32) -> i64:
    """Quantize one f32 sample to signed 16-bit: trunc(s * 32768), clamped."""
    var s = sample as f64
    if s > 1.0:
        s = 1.0
    if s < -1.0:
        s = -1.0
    var v = (s * 32768.0) as i64
    if v > 32767:
        v = 32767
    if v < -32768:
        v = -32768
    v

fn _wav_header(audio_format: i64, channels: i64, sample_rate: i64, bits: i64, data_len: i64) -> [u8]:
    """RIFF header + 16-byte fmt chunk + data chunk header."""
    val bytes_per_sample = bits / 8
    val block_align = channels * bytes_per_sample
    val byte_rate = sample_rate * block_align

    var out: [u8] = []
    out = _extend(out, "RIFF".bytes())
    out = _extend(out, _u32_le(36 + data_len))     # RIFF chunk size
    out = _extend(out, "WAVE".bytes())
    out = _extend(out, "fmt ".bytes())
    out = _extend(out, _u32_le(16))                # fmt chunk size
    out = _extend(out, _u16_le(audio_format))      # 1 = PCM, 3 = IEEE float
    out = _extend(out, _u16_le(channels))
    out = _extend(out, _u32_le(sample_rate))
    out = _extend(out, _u32_le(byte_rate))
    out = _extend(out, _u16_le(block_align))
    out = _extend(out, _u16_le(bits))
    out = _extend(out, "data".bytes())
    out = _extend(out, _u32_le(data_len))
    out

fn _u16_le(v: i64) -> [u8]:
    [(v & 0xFF).to_u8(), ((v >> 8) & 0xFF).to_u8()]

fn _u32_le(v: i64) -> [u8]:
    [
        (v & 0xFF).to_u8(),
        ((v >> 8) & 0xFF).to_u8(),
        ((v >> 16) & 0xFF).to_u8(),
        ((v >> 24) & 0xFF).to_u8()
    ]

fn _extend(dst: [u8], src: [u8]) -> [u8]:
    var out = dst
    for b in src:
        out.push(b)
    out
