# Web event types and listener registration.
# Platform-independent event handling for DOM elements.

use std.common.web.dom.{WebElement}

# Event types that can be listened for.
enum WebEventType:
    Click
    DblClick
    Input
    Change
    Submit
    KeyDown
    KeyUp
    KeyPress
    MouseDown
    MouseUp
    MouseMove
    MouseOver
    MouseOut
    MouseEnter
    MouseLeave
    Focus
    Blur
    Scroll
    Resize
    Load
    Unload
    Custom(name: text)

# Event data passed to handlers.
class WebEvent:
    event_type: WebEventType
    target_id: i64
    value: text
    key: text
    x: i64
    y: i64
    button: i64
    prevent_default: bool

    static fn empty() -> WebEvent:
        WebEvent(
            event_type: WebEventType.Click,
            target_id: -1,
            value: "",
            key: "",
            x: 0,
            y: 0,
            button: 0,
            prevent_default: false
        )

    static fn click(target_id: i64, x: i64, y: i64) -> WebEvent:
        WebEvent(
            event_type: WebEventType.Click,
            target_id: target_id,
            value: "",
            key: "",
            x: x,
            y: y,
            button: 0,
            prevent_default: false
        )

    static fn input_event(target_id: i64, value: text) -> WebEvent:
        WebEvent(
            event_type: WebEventType.Input,
            target_id: target_id,
            value: value,
            key: "",
            x: 0,
            y: 0,
            button: 0,
            prevent_default: false
        )

    static fn key_event(event_type: WebEventType, target_id: i64, key: text) -> WebEvent:
        WebEvent(
            event_type: event_type,
            target_id: target_id,
            value: "",
            key: key,
            x: 0,
            y: 0,
            button: 0,
            prevent_default: false
        )

# Event listener registration trait.
trait EventBackend:
    # Generic event listener.
    me on(element: WebElement, event_type: WebEventType, handler: fn(WebEvent))

    # Remove event listener.
    me off(element: WebElement, event_type: WebEventType)

    # Convenience: click handler.
    me on_click(element: WebElement, handler: fn(WebEvent))

    # Convenience: input handler (for text fields).
    me on_input(element: WebElement, handler: fn(WebEvent))

    # Convenience: change handler (for selects, checkboxes).
    me on_change(element: WebElement, handler: fn(WebEvent))

    # Convenience: submit handler (for forms).
    me on_submit(element: WebElement, handler: fn(WebEvent))

    # Convenience: key handlers.
    me on_keydown(element: WebElement, handler: fn(WebEvent))
    me on_keyup(element: WebElement, handler: fn(WebEvent))

# Convert WebEventType to its DOM event name string.
fn event_type_name(event_type: WebEventType) -> text:
    match event_type:
        WebEventType.Click: "click"
        WebEventType.DblClick: "dblclick"
        WebEventType.Input: "input"
        WebEventType.Change: "change"
        WebEventType.Submit: "submit"
        WebEventType.KeyDown: "keydown"
        WebEventType.KeyUp: "keyup"
        WebEventType.KeyPress: "keypress"
        WebEventType.MouseDown: "mousedown"
        WebEventType.MouseUp: "mouseup"
        WebEventType.MouseMove: "mousemove"
        WebEventType.MouseOver: "mouseover"
        WebEventType.MouseOut: "mouseout"
        WebEventType.MouseEnter: "mouseenter"
        WebEventType.MouseLeave: "mouseleave"
        WebEventType.Focus: "focus"
        WebEventType.Blur: "blur"
        WebEventType.Scroll: "scroll"
        WebEventType.Resize: "resize"
        WebEventType.Load: "load"
        WebEventType.Unload: "unload"
        WebEventType.Custom(name): name
