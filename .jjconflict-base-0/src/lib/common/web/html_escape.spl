# Canonical HTML escaping.
#
# Consolidates the previously duplicated, inconsistent html_escape copies
# scattered across src/app/ui.render/html.spl, src/lib/common/ui/html_window.spl,
# src/lib/common/ui/mobile_html_gen.spl, and src/lib/gc_async_mut/web/browser_session_html.spl
# (several of which missed escaping `'`, letting a crafted single-quoted
# attribute break out of markup). One implementation, one entity table.
#
# `html_escape_core` is the implementation callers should import when their
# own public wrapper is itself named `html_escape` — a same-named import
# would collide with the local function definition (this interpreter has no
# working `use X.{a as b}` aliasing across a 2+-level module import chain,
# so renaming at the source is the workaround). `html_escape` /
# `html_attr_escape` are for direct callers with no naming collision.

fn html_escape_core(s: text) -> text:
    """Escape HTML special characters: `&`, `<`, `>`, `"`, `'`.

    `&` is escaped first so the other entities' own `&` is not re-escaped.
    """
    var out = s
    out = out.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out = out.replace("'", "&#39;")
    return out

fn html_escape(s: text) -> text:
    """Escape HTML special characters for safe use in text content or attribute values."""
    html_escape_core(s)

fn html_attr_escape(s: text) -> text:
    """Escape HTML special characters for safe use inside a quoted attribute value.

    Attribute values in this codebase are always double-quoted, so the
    coverage is identical to `html_escape` (all 5 special characters).
    """
    html_escape_core(s)
