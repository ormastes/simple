# DOM query convenience functions.
# Wraps DomBackend query methods with shorter names.

use std.common.web.dom.{DomBackend, WebElement}

# Find first element matching a CSS selector, or nil.
fn find(backend: DomBackend, selector: text) -> Option<WebElement>:
    backend.query_selector(selector)

# Find all elements matching a CSS selector.
fn find_all(backend: DomBackend, selector: text) -> List<WebElement>:
    backend.query_selector_all(selector)

# Find element by ID (without # prefix).
fn by_id(backend: DomBackend, id: text) -> Option<WebElement>:
    backend.get_element_by_id(id)

# Check if an element matching selector exists.
fn element_exists(backend: DomBackend, selector: text) -> bool:
    val el = backend.query_selector(selector)
    el.?

# Get the document body element.
fn get_body(backend: DomBackend) -> WebElement:
    backend.body()

# Get the root <html> element.
fn get_root(backend: DomBackend) -> WebElement:
    backend.document_element()
