# Fluent CSS style builder for WebElement.
# Collects CSS properties, then applies them via a DomBackend.

use std.common.web.dom.{DomBackend, WebElement}

class WebStyle:
    properties: List<Pair<text, text>>

    static fn new() -> WebStyle:
        WebStyle(properties: List<Pair<text, text>>())

    # --- Layout ---

    me display(value: text) -> WebStyle:
        self.properties.push(Pair(first: "display", second: value))
        self

    me position(value: text) -> WebStyle:
        self.properties.push(Pair(first: "position", second: value))
        self

    me width(value: text) -> WebStyle:
        self.properties.push(Pair(first: "width", second: value))
        self

    me height(value: text) -> WebStyle:
        self.properties.push(Pair(first: "height", second: value))
        self

    me min_width(value: text) -> WebStyle:
        self.properties.push(Pair(first: "min-width", second: value))
        self

    me min_height(value: text) -> WebStyle:
        self.properties.push(Pair(first: "min-height", second: value))
        self

    me max_width(value: text) -> WebStyle:
        self.properties.push(Pair(first: "max-width", second: value))
        self

    me max_height(value: text) -> WebStyle:
        self.properties.push(Pair(first: "max-height", second: value))
        self

    # --- Spacing ---

    me margin(value: text) -> WebStyle:
        self.properties.push(Pair(first: "margin", second: value))
        self

    me padding(value: text) -> WebStyle:
        self.properties.push(Pair(first: "padding", second: value))
        self

    # --- Flex ---

    me flex(value: text) -> WebStyle:
        self.properties.push(Pair(first: "flex", second: value))
        self

    me flex_direction(value: text) -> WebStyle:
        self.properties.push(Pair(first: "flex-direction", second: value))
        self

    me justify_content(value: text) -> WebStyle:
        self.properties.push(Pair(first: "justify-content", second: value))
        self

    me align_items(value: text) -> WebStyle:
        self.properties.push(Pair(first: "align-items", second: value))
        self

    me gap(value: text) -> WebStyle:
        self.properties.push(Pair(first: "gap", second: value))
        self

    # --- Typography ---

    me color(value: text) -> WebStyle:
        self.properties.push(Pair(first: "color", second: value))
        self

    me font_size(value: text) -> WebStyle:
        self.properties.push(Pair(first: "font-size", second: value))
        self

    me font_weight(value: text) -> WebStyle:
        self.properties.push(Pair(first: "font-weight", second: value))
        self

    me text_align(value: text) -> WebStyle:
        self.properties.push(Pair(first: "text-align", second: value))
        self

    # --- Visual ---

    me background(value: text) -> WebStyle:
        self.properties.push(Pair(first: "background", second: value))
        self

    me border(value: text) -> WebStyle:
        self.properties.push(Pair(first: "border", second: value))
        self

    me border_radius(value: text) -> WebStyle:
        self.properties.push(Pair(first: "border-radius", second: value))
        self

    me opacity(value: text) -> WebStyle:
        self.properties.push(Pair(first: "opacity", second: value))
        self

    me overflow(value: text) -> WebStyle:
        self.properties.push(Pair(first: "overflow", second: value))
        self

    me cursor(value: text) -> WebStyle:
        self.properties.push(Pair(first: "cursor", second: value))
        self

    # --- Generic ---

    me set(property: text, value: text) -> WebStyle:
        self.properties.push(Pair(first: property, second: value))
        self

    # Apply all styles to an element via a DomBackend.
    fn apply(backend: DomBackend, element: WebElement):
        for prop in self.properties:
            backend.set_style(element, prop.first, prop.second)

    # Convert to inline CSS string.
    fn to_css() -> text:
        var parts = List<text>()
        for prop in self.properties:
            parts.push("{prop.first}: {prop.second}")
        parts.join("; ")

    # Get number of properties set.
    fn len() -> i64:
        self.properties.len()
