enum TargetArch:
    X86_64
    X86
    Aarch64
    Arm
    ARM
    Riscv64
    Riscv32
    RiscV64
    RiscV32
    Wasm64
    Wasm32
    AVR
    Avr
    MCS51
    I8086
    MSP430
    Host

impl TargetArch:
    static fn host() -> TargetArch:
        TargetArch.X86_64

enum TargetOS:
    Linux
    Windows
    MacOS
    FreeBSD
    Unknown

impl TargetOS:
    static fn host() -> TargetOS:
        TargetOS.Linux

enum Endian:
    Little
    Big

impl Endian:
    static fn host() -> Endian:
        Endian.Little
