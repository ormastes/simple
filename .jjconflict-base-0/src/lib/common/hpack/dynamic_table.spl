# HPACK dynamic header table (RFC 7541 §2.3.2, §4).
#
# The dynamic table is a LIFO structure where the most recently inserted entry
# is at index 0 (relative HPACK dynamic index 1). When the table exceeds
# `max_size` bytes, the oldest entries (at the back) are evicted one-by-one
# until the constraint holds.
#
# Entry size formula per RFC §4.1:
#   name_octets + value_octets + 32
#
# Combined HPACK index space (§2.3.3):
#   1..61    — static table (not handled here)
#   62..     — dynamic table, 62 = entries[0] (most recent)
#
# This module implements only the dynamic table data structure. The encoder
# and decoder are responsible for combining static + dynamic addressing.

class DynamicEntry:
    name: text
    value: text

class DynamicTable:
    entries: [DynamicEntry]   # newest at index 0 per RFC §2.3.2
    max_size: i64             # current SETTINGS_HEADER_TABLE_SIZE cap in bytes
    current_size: i64         # sum of (name.len() + value.len() + 32) for all entries

# Compute the RFC §4.1 size of a single entry.
fn _entry_size(name: text, value: text) -> i64:
    name.len() + value.len() + 32

# Evict oldest entries (from the back of entries[], i.e. highest index) until
# total size fits within max_size. Returns the trimmed (entries, size) pair.
#
# entries[0] is newest; entries[entries.len()-1] is oldest. We keep as many
# entries from the front as fit within max_size, evicting the rest.
fn _evict_to_fit(entries: [DynamicEntry], max_size: i64) -> ([DynamicEntry], i64):
    var result: [DynamicEntry] = []
    var final_size: i64 = 0
    var i: i64 = 0
    while i < entries.len():
        val e = entries[i]
        val esize = _entry_size(e.name, e.value)
        if final_size + esize <= max_size:
            result = result + [e]
            final_size = final_size + esize
            i = i + 1
        else:
            i = entries.len()  # stop: evict this and all older entries
    (result, final_size)

# Create a new empty dynamic table with the given maximum size (bytes).
fn dynamic_table_new(max_size: i64) -> DynamicTable:
    DynamicTable(entries: [], max_size: max_size, current_size: 0)

# Insert a header field into the dynamic table (RFC §4.4).
#
# If the new entry's size alone exceeds max_size, the table is emptied and
# the entry is NOT inserted (RFC §4.4). Otherwise, old entries are evicted
# from the back (oldest-first) until the new entry fits, then the entry is
# prepended at index 0.
fn dynamic_table_insert(t: DynamicTable, name: text, value: text) -> DynamicTable:
    val esize = _entry_size(name, value)
    if esize > t.max_size:
        # Entry larger than cap: empty the table, do not insert (RFC §4.4)
        return DynamicTable(entries: [], max_size: t.max_size, current_size: 0)
    # Prepend new entry at front (index 0), then append existing entries
    var new_entries: [DynamicEntry] = [DynamicEntry(name: name, value: value)]
    var i: i64 = 0
    while i < t.entries.len():
        new_entries = new_entries + [t.entries[i]]
        i = i + 1
    # Evict oldest entries from the back until total fits in max_size
    val evicted = _evict_to_fit(new_entries, t.max_size)
    DynamicTable(entries: evicted.0, max_size: t.max_size, current_size: evicted.1)

# Look up an entry by relative dynamic index (1 = most recent, 2 = second most recent).
# Returns nil for out-of-range indices.
fn dynamic_table_lookup(t: DynamicTable, hpack_index: i64) -> DynamicEntry?:
    if hpack_index < 1 or hpack_index > t.entries.len():
        return nil
    t.entries[hpack_index - 1]

# Find the relative dynamic index for a (name, value) pair.
#
# Returns:
#   - (relative_index, true)  if both name and value match
#   - (relative_index, false) if only name matches (value differs)
#   - (-1, false)             if no name match exists
#
# Mirrors the contract of hpack_static_find in static_table.spl. The caller
# adds 61 to convert the relative dynamic index to a combined HPACK index.
fn dynamic_table_find(t: DynamicTable, name: text, value: text) -> (i64, bool):
    var name_only_index: i64 = -1
    var i: i64 = 0
    while i < t.entries.len():
        val entry = t.entries[i]
        if entry.name == name:
            if entry.value == value:
                return (i + 1, true)
            if name_only_index < 0:
                name_only_index = i + 1
        i = i + 1
    (name_only_index, false)

# Resize the dynamic table (RFC §4.3).
#
# When new_max_size < current_size, oldest entries are evicted to fit.
# When new_max_size >= current_size, no entries are changed (only the cap is raised).
fn dynamic_table_resize(t: DynamicTable, new_max_size: i64) -> DynamicTable:
    if new_max_size >= t.current_size:
        DynamicTable(entries: t.entries, max_size: new_max_size, current_size: t.current_size)
    else:
        val evicted = _evict_to_fit(t.entries, new_max_size)
        DynamicTable(entries: evicted.0, max_size: new_max_size, current_size: evicted.1)
