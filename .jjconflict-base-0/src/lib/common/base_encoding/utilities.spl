# ============================================================================
# Base-encoding utilities — byte / text conversion
# ============================================================================
#
# Exported functions:
#   bytes_to_text(data: [u8]) -> text   — interpret raw bytes as UTF-8
#   text_to_bytes(data: text) -> [u8]   — encode text to UTF-8 bytes

pub fn bytes_to_text(data: [u8]) -> text:
    """Interpret a raw byte slice as UTF-8 text.
    Non-UTF-8 bytes are replaced with '?'.
    """
    var result = ""
    var i = 0
    val n = data.len()
    while i < n:
        val b = data[i] as i64
        if b < 0x80:
            result = result + b.chr()
            i = i + 1
        else if b < 0xC0:
            result = result + "?"
            i = i + 1
        else if b < 0xE0:
            if i + 1 < n:
                val b2 = data[i + 1] as i64
                val cp = ((b & 0x1F) << 6) | (b2 & 0x3F)
                if (b2 & 0xC0) == 0x80 and cp >= 0x80:
                    result = result + cp.chr()
                    i = i + 2
                else:
                    result = result + "?"
                    i = i + 1
            else:
                result = result + "?"
                i = i + 1
        else if b < 0xF0:
            if i + 2 < n:
                val b2 = data[i + 1] as i64
                val b3 = data[i + 2] as i64
                val cp = ((b & 0x0F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
                if (b2 & 0xC0) == 0x80 and (b3 & 0xC0) == 0x80 and cp >= 0x800 and not (cp >= 0xD800 and cp <= 0xDFFF):
                    result = result + cp.chr()
                    i = i + 3
                else:
                    result = result + "?"
                    i = i + 1
            else:
                result = result + "?"
                i = i + 1
        else:
            if i + 3 < n:
                val b2 = data[i + 1] as i64
                val b3 = data[i + 2] as i64
                val b4 = data[i + 3] as i64
                val cp = ((b & 0x07) << 18) | ((b2 & 0x3F) << 12) | ((b3 & 0x3F) << 6) | (b4 & 0x3F)
                if b < 0xF8 and (b2 & 0xC0) == 0x80 and (b3 & 0xC0) == 0x80 and (b4 & 0xC0) == 0x80 and cp >= 0x10000 and cp <= 0x10FFFF:
                    result = result + cp.chr()
                    i = i + 4
                else:
                    result = result + "?"
                    i = i + 1
            else:
                result = result + "?"
                i = i + 1
    result

pub fn text_to_bytes(data: text) -> [u8]:
    """Encode text as UTF-8 bytes."""
    var result: [u8] = []
    val raw = data.bytes()
    val n = raw.len()
    var i = 0
    while i < n:
        result = result.push(raw[i] as u8)
        i = i + 1
    result
