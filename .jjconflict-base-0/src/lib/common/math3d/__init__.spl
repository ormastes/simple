# math3d — Pure 3D math types
#
# Standalone 3D math library with no engine dependencies.
# Vec2, Vec3, Vec4, Mat4, Quaternion, Transform.

# Vectors
export Vec2, Vec3, Vec4

# Matrix
export Mat4

# Quaternion
export Quaternion

# Transform
export Transform

# Utilities
export sqrt3d, sin3d, cos3d, acos3d, atan2_3d
