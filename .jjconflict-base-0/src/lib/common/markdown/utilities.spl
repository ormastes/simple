# HTML Escaping and Utilities (5 functions)
# =============================================================================

fn escape_html_char(c: text) -> text:
    if c == "&":
        return "&amp;"
    if c == "<":
        return "&lt;"
    if c == ">":
        return "&gt;"
    if c == "\"":
        return "&quot;"
    if c == "'":
        return "&#39;"
    c

fn escape_html(s: text) -> text:
    var parts: [text] = []
    var i = 0
    var len = s.length()
    while i < len:
        val c = s.char_at(i)
        val escaped = escape_html_char(c)
        parts.push(escaped)
        i = i + 1
    parts.join("")

fn escape_attr(s: text) -> text:
    escape_html(s)

fn unescape_text(s: text) -> text:
    var parts: [text] = []
    var i = 0
    var len = s.length()
    while i < len:
        val c = s.char_at(i)
        if c == "\\":
            if i + 1 < len:
                val next = s.char_at(i + 1)
                val escapable = next == "*" or next == "_" or next == "`"
                val more = next == "[" or next == "]" or next == "\\" or next == "!"
                if escapable or more:
                    parts.push(next)
                    i = i + 2
                else:
                    parts.push(c)
                    i = i + 1
            else:
                parts.push(c)
                i = i + 1
        else:
            parts.push(c)
            i = i + 1
    parts.join("")

fn is_escaped(s: text, pos: i64) -> bool:
    if pos == 0:
        return false
    val prev = s.char_at(pos - 1)
    prev == "\\"

# =============================================================================
# Slugification for Heading Anchors (1 function)
# =============================================================================

fn slugify(s: text) -> text:
    var parts: [text] = []
    var i = 0
    var len = s.length()
    var last_was_dash = false
    while i < len:
        val c = s.char_at(i)
        if is_alphanumeric(c):
            val lower = char_to_lower(c)
            parts.push(lower)
            last_was_dash = false
        else:
            if not last_was_dash and parts.len() > 0:
                parts.push("-")
                last_was_dash = true
        i = i + 1
    val result = parts.join("")
    if ends_with(result, "-"):
        return result.substring(0, result.length() - 1)
    result

# =============================================================================
# Line Processing (5 functions)
# =============================================================================

fn split_lines(s: text) -> array:
    var lines = []
    var current_parts: [text] = []
    var i = 0
    var len = s.length()
    while i < len:
        val c = s.char_at(i)
        if c == "\n":
            lines.push(current_parts.join(""))
            current_parts = []
        else:
            if c != "\r":
                current_parts.push(c)
        i = i + 1
    if current_parts.len() > 0 or len > 0:
        lines.push(current_parts.join(""))
    lines

fn join_lines(lines: array, sep: text) -> text:
    var parts: [text] = []
    var i = 0
    var len = lines.length()
    while i < len:
        val line = lines.get(i)
        parts.push(line)
        i = i + 1
    parts.join(sep)

fn is_blank_line(line: text) -> bool:
    val trimmed = trim(line)
    trimmed.length() == 0

fn count_leading_spaces(line: text) -> i64:
    count_leading_chars(line, " ")

fn count_line_indent(line: text) -> i64:
    var spaces = 0
    var i = 0
    var len = line.length()
    while i < len and line.char_at(i) == " ":
        spaces = spaces + 1
        i = i + 1
    spaces

