# Markdown AST Adapter
#
# Bridges tuple-based AST from parse_blocks_with_ranges()
# to typed RenderBlock structs used by the editor.

fn md_ast_to_render_blocks(ranged_ast: array, lines: [text]) -> [RenderBlock]:
    var blocks: [RenderBlock] = []
    var i = 0
    var len = ranged_ast.length()
    var block_id = 1
    while i < len:
        val entry = ranged_ast.get(i)
        val block = entry.0
        val from_line = entry.1
        val to_line = entry.2
        val kind = block.0
        if kind == "heading":
            val rb = _adapt_heading(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        elif kind == "code_block":
            val rb = _adapt_code_block(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        elif kind == "blockquote":
            val rb = _adapt_blockquote(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        elif kind == "unordered_list":
            val rb = _adapt_list(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        elif kind == "ordered_list":
            val rb = _adapt_list(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        elif kind == "table":
            val rb = _adapt_table(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        elif kind == "horizontal_rule":
            val rb = _adapt_horizontal_rule(from_line, lines, block_id)
            blocks.push(rb)
        elif kind == "paragraph":
            val rb = _adapt_paragraph(block, from_line, to_line, lines, block_id)
            blocks.push(rb)
        block_id = block_id + 1
        i = i + 1
    blocks


fn _adapt_heading(block: tuple, from_line: i64, to_line: i64, lines: [text], id: i64) -> RenderBlock:
    val level = block.1
    val content = _adapt_join_lines(lines, from_line, to_line)
    var prefix = ""
    var h = 0
    while h < level:
        prefix = prefix + "#"
        h = h + 1
    val tokens = block.2
    val heading_text = _adapt_extract_text(tokens)
    var rendered: [text] = []
    rendered.push(prefix + " " + heading_text)
    RenderBlock(id: id, kind: "heading", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_code_block(block: tuple, from_line: i64, to_line: i64, lines: [text], id: i64) -> RenderBlock:
    val content = _adapt_join_lines(lines, from_line, to_line)
    val rendered = _adapt_slice_lines(lines, from_line, to_line)
    if _adapt_is_sdn_graph_fence(rendered):
        return RenderBlock(id: id, kind: "sdn_graph", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")
    if _adapt_is_css_fence(rendered):
        return RenderBlock(id: id, kind: "md_css", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")
    RenderBlock(id: id, kind: "code", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_blockquote(block: tuple, from_line: i64, to_line: i64, lines: [text], id: i64) -> RenderBlock:
    val content = _adapt_join_lines(lines, from_line, to_line)
    val rendered = _adapt_slice_lines(lines, from_line, to_line)
    if _adapt_is_callout_content(content):
        return RenderBlock(id: id, kind: "callout", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")
    RenderBlock(id: id, kind: "blockquote", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_list(block: tuple, from_line: i64, to_line: i64, lines: [text], id: i64) -> RenderBlock:
    val content = _adapt_join_lines(lines, from_line, to_line)
    val rendered = _adapt_slice_lines(lines, from_line, to_line)
    RenderBlock(id: id, kind: "list", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_table(block: tuple, from_line: i64, to_line: i64, lines: [text], id: i64) -> RenderBlock:
    val content = _adapt_join_lines(lines, from_line, to_line)
    val rendered = _adapt_slice_lines(lines, from_line, to_line)
    RenderBlock(id: id, kind: "table", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_horizontal_rule(from_line: i64, lines: [text], id: i64) -> RenderBlock:
    val content = if from_line < lines.len() then lines[from_line] else: "---"
    var rendered: [text] = []
    rendered.push(content)
    RenderBlock(id: id, kind: "horizontal_rule", from_line: from_line, to_line: from_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_paragraph(block: tuple, from_line: i64, to_line: i64, lines: [text], id: i64) -> RenderBlock:
    val content = _adapt_join_lines(lines, from_line, to_line)
    val rendered = _adapt_slice_lines(lines, from_line, to_line)
    if _adapt_is_embed_content(content):
        return RenderBlock(id: id, kind: "embed", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")
    RenderBlock(id: id, kind: "paragraph", from_line: from_line, to_line: to_line, content: content, rendered_lines: rendered, status: "ok")


fn _adapt_join_lines(lines: [text], from: i64, to: i64) -> text:
    var result = ""
    var i = from
    while i <= to and i < lines.len():
        if i > from:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result


fn _adapt_slice_lines(lines: [text], from: i64, to: i64) -> [text]:
    var result: [text] = []
    var i = from
    while i <= to and i < lines.len():
        result.push(lines[i])
        i = i + 1
    result


fn _adapt_extract_text(tokens: array) -> text:
    var parts: [text] = []
    var i = 0
    var len = tokens.length()
    while i < len:
        val token = tokens.get(i)
        val kind = token.0
        if kind == "text":
            val content = token.1
            parts.push(content)
        elif kind == "bold" or kind == "italic" or kind == "strikethrough":
            val inner = token.1
            val inner_text = _adapt_extract_text(inner)
            parts.push(inner_text)
        elif kind == "code":
            val content = token.1
            parts.push(content)
        elif kind == "link":
            val text_tokens = token.1
            val inner_text = _adapt_extract_text(text_tokens)
            parts.push(inner_text)
        elif kind == "image":
            val alt = token.1
            parts.push(alt)
        i = i + 1
    parts.join("")

fn _adapt_is_callout_content(content: text) -> bool:
    val lines = content.split("\n")
    if lines.len() == 0:
        return false
    val first = _adapt_trim(lines[0])
    first.starts_with("> [!")

fn _adapt_is_embed_content(content: text) -> bool:
    val lines = content.split("\n")
    if lines.len() != 1:
        return false
    val first = _adapt_trim(lines[0])
    first.starts_with("![[") or first.starts_with("![")

fn _adapt_is_sdn_graph_fence(lines: [text]) -> bool:
    if lines.len() == 0:
        return false
    val first = _adapt_trim(lines[0])
    first == "```sdn-graph" or first == "```graph"

fn _adapt_is_css_fence(lines: [text]) -> bool:
    if lines.len() == 0:
        return false
    val first = _adapt_trim(lines[0])
    first == "```css" or first == "```style"

fn _adapt_trim(value: text) -> text:
    var start = 0
    var end = value.len()
    while start < end and _adapt_is_space(value.char_at(start)):
        start = start + 1
    while end > start and _adapt_is_space(value.char_at(end - 1)):
        end = end - 1
    value.slice(start, end)

fn _adapt_is_space(ch: text) -> bool:
    ch == " " or ch == "\t" or ch == "\r" or ch == "\n"
