# Node.js path module — path manipulation utilities

use std.js.types.pair.{Pair}
use std.js.types.js_types.{JsValue}

fn path_join(args: [JsValue]) -> JsValue:
    """Join path segments with /."""
    var result = ""
    var i = 0
    while i < args.len():
        val part = _val_to_text(args[i])
        if part == "":
            i = i + 1
            continue
        if result == "":
            result = part
        elif result.ends_with("/"):
            result = result + part
        else:
            result = result + "/" + part
        i = i + 1
    JsValue.String(v: _normalize_path(result))

fn path_dirname(args: [JsValue]) -> JsValue:
    """Get directory name from path."""
    if args.len() == 0:
        return JsValue.String(v: ".")
    val path = _val_to_text(args[0])
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash < 0:
        return JsValue.String(v: ".")
    if last_slash == 0:
        return JsValue.String(v: "/")
    JsValue.String(v: path.slice(0, last_slash))

fn path_basename(args: [JsValue]) -> JsValue:
    """Get base name from path, optionally stripping extension."""
    if args.len() == 0:
        return JsValue.String(v: "")
    val path = _val_to_text(args[0])
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    var name = path
    if last_slash >= 0:
        name = path.slice(last_slash + 1, path.len())
    if args.len() > 1:
        val ext = _val_to_text(args[1])
        if name.ends_with(ext):
            name = name.slice(0, name.len() - ext.len())
    JsValue.String(v: name)

fn path_extname(args: [JsValue]) -> JsValue:
    """Get file extension."""
    if args.len() == 0:
        return JsValue.String(v: "")
    val path = _val_to_text(args[0])
    var last_dot = -1
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == ".":
            last_dot = i
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_dot < 0 or last_dot <= last_slash + 1:
        return JsValue.String(v: "")
    JsValue.String(v: path.slice(last_dot, path.len()))

fn path_resolve(args: [JsValue]) -> JsValue:
    """Resolve path segments to absolute path."""
    var resolved = ""
    var i = args.len() - 1
    while i >= 0:
        val segment = _val_to_text(args[i])
        if segment.starts_with("/"):
            resolved = segment
            break
        if resolved == "":
            resolved = segment
        else:
            resolved = segment + "/" + resolved
        i = i - 1
    if not resolved.starts_with("/"):
        resolved = "/" + resolved
    JsValue.String(v: _normalize_path(resolved))

fn path_normalize(args: [JsValue]) -> JsValue:
    """Normalize path separators."""
    if args.len() == 0:
        return JsValue.String(v: ".")
    JsValue.String(v: _normalize_path(_val_to_text(args[0])))

fn path_isAbsolute(args: [JsValue]) -> JsValue:
    """Check if path is absolute."""
    if args.len() == 0:
        return JsValue.Boolean(v: false)
    JsValue.Boolean(v: _val_to_text(args[0]).starts_with("/"))

fn create_path_module() -> [Pair<text, JsValue>]:
    """Create path module method pairs."""
    var methods: [Pair<text, JsValue>] = []
    methods

fn _val_to_text(val: JsValue) -> text:
    match val:
        JsValue.String(v): v
        JsValue.Number(v): "{v}"
        _: ""

fn _normalize_path(path: text) -> text:
    # Basic normalization: remove consecutive slashes, resolve . and ..
    var parts = path.split("/")
    var result: [text] = []
    var i = 0
    while i < parts.len():
        val part = parts[i]
        if part == "" or part == ".":
            i = i + 1
            continue
        if part == "..":
            if result.len() > 0:
                result.pop()
        else:
            result.push(part)
        i = i + 1
    var normalized = ""
    if path.starts_with("/"):
        normalized = "/"
    var j = 0
    while j < result.len():
        if j > 0:
            normalized = normalized + "/"
        normalized = normalized + result[j]
        j = j + 1
    if normalized == "":
        return "."
    normalized
