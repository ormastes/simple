# Promoted from examples/browser/ to std library
# JavaScript AST types for the JS parser output.
# Models statements and expressions as recursive enum trees.

use std.js.types.pair.{Pair}
use std.js.types.js_types.{JsValue}

enum Expression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: Expression, right: Expression)
    Unary(op: text, operand: Expression)
    Call(callee: Expression, args: [Expression])
    Member(object: Expression, property: text)
    Assignment(target: Expression, value: Expression)
    Array(elements: [Expression])
    ObjectExpr(properties: [Pair<text, Expression>])
    Ternary(condition: Expression, consequent: Expression, alternate: Expression)
    ArrowFunction(params: [text], body: [Statement])
    SpreadElement(argument: Expression)
    TemplateLiteral(quasis: [text], expressions: [Expression])
    Delete(expr: Expression)
    InstanceOf(left: Expression, right: Expression)
    InExpr(left: Expression, right: Expression)
    # ES2015+ additions
    ObjectPattern(props: [DestructProp])
    ArrayPattern(elements: [Expression])
    ComputedMember(object: Expression, property: Expression)
    TaggedTemplate(tag: Expression, quasis: [text], expressions: [Expression])
    YieldExpr(argument: Expression, delegate: bool)
    AwaitExpr(argument: Expression)
    ClassExpr(name: text, parent_name: text, constructor: Statement, methods: [Statement])
    NewExpr(callee: Expression, args: [Expression])

enum Statement:
    VarDecl(name: text, init: Expression)
    ExprStmt(expr: Expression)
    Return(value: Expression)
    If(cond: Expression, then_body: [Statement], else_body: [Statement])
    While(cond: Expression, body: [Statement])
    For(init: Statement, cond: Expression, update: Expression, body: [Statement])
    Block(stmts: [Statement])
    FnDecl(name: text, params: [text], body: [Statement])
    TryCatch(try_body: [Statement], catch_param: text, catch_body: [Statement], finally_body: [Statement])
    Switch(discriminant: Expression, cases: [SwitchCase])
    ForIn(binding: text, object: Expression, body: [Statement])
    ForOf(binding: text, iterable: Expression, body: [Statement])
    ThrowStmt(expr: Expression)
    BreakStmt
    ContinueStmt
    ClassDecl(name: text, parent_name: text, constructor: Statement, methods: [Statement])
    # ES2015+ additions
    LetDecl(name: text, init: Expression)
    ConstDecl(name: text, init: Expression)
    DestructVarDecl(pattern: Expression, init: Expression, kind: text)
    ImportDecl(specifiers: [ImportSpec], source: text)
    ExportDecl(declaration: Statement)
    ExportDefault(expression: Expression)
    ExportNamed(specifiers: [ExportSpec], source: text)
    AsyncFnDecl(name: text, params: [FnParam], body: [Statement])
    LabeledStmt(label: text, body: Statement)
    DoWhile(cond: Expression, body: [Statement])

class SwitchCase:
    test: Option<Expression>
    consequent: [Statement]

    static fn case_clause(test: Expression, body: [Statement]) -> SwitchCase:
        SwitchCase(test: Some(test), consequent: body)

    static fn default_clause(body: [Statement]) -> SwitchCase:
        SwitchCase(test: nil, consequent: body)

class JsAstNode:
    kind: text
    children: [JsAstNode]
    token_start: i64
    token_end: i64

    static fn create(kind: text, token_start: i64, token_end: i64) -> JsAstNode:
        JsAstNode(kind: kind, children: [], token_start: token_start, token_end: token_end)

class FnParam:
    name: text
    default_value: Expression?
    is_rest: bool

    static fn simple(name: text) -> FnParam:
        FnParam(name: name, default_value: nil, is_rest: false)

    static fn with_default(name: text, default_val: Expression) -> FnParam:
        FnParam(name: name, default_value: Some(default_val), is_rest: false)

    static fn rest(name: text) -> FnParam:
        FnParam(name: name, default_value: nil, is_rest: true)

class DestructProp:
    key: text
    value: Expression
    default_value: Expression?
    is_computed: bool

    static fn simple(key: text) -> DestructProp:
        DestructProp(key: key, value: Expression.Identifier(name: key), default_value: nil, is_computed: false)

class ImportSpec:
    imported: text
    local: text

    static fn named(imported: text, local: text) -> ImportSpec:
        ImportSpec(imported: imported, local: local)

    static fn default_import(local: text) -> ImportSpec:
        ImportSpec(imported: "default", local: local)

class ExportSpec:
    local: text
    exported: text

    static fn named(local: text, exported: text) -> ExportSpec:
        ExportSpec(local: local, exported: exported)

class ObjProp:
    key: Expression
    value: Expression?
    is_computed: bool
    is_shorthand: bool

    static fn simple(key: text, value: Expression) -> ObjProp:
        ObjProp(key: Expression.Literal(value: JsValue.String(v: key)), value: Some(value), is_computed: false, is_shorthand: false)

    static fn shorthand(name: text) -> ObjProp:
        ObjProp(key: Expression.Identifier(name: name), value: nil, is_computed: false, is_shorthand: true)

    static fn computed(key_expr: Expression, value: Expression) -> ObjProp:
        ObjProp(key: key_expr, value: Some(value), is_computed: true, is_shorthand: false)
