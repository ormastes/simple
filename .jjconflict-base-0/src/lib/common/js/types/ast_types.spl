# Promoted from examples/browser/ to std library
# JavaScript AST types for the JS parser output.
# Models statements and expressions as recursive enum trees.

use std.js.types.pair.{Pair}
use std.js.types.js_types.{JsValue}

enum JsExpression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: JsExpression, right: JsExpression)
    Unary(op: text, operand: JsExpression)
    Call(callee: JsExpression, args: [JsExpression])
    Member(object: JsExpression, property: text)
    Assignment(target: JsExpression, value: JsExpression)
    Array(elements: [JsExpression])
    ObjectExpr(properties: [Pair<text, JsExpression>])
    Ternary(condition: JsExpression, consequent: JsExpression, alternate: JsExpression)
    ArrowFunction(params: [text], body: [JsStatement])
    SpreadElement(argument: JsExpression)
    TemplateLiteral(quasis: [text], expressions: [JsExpression])
    Delete(expr: JsExpression)
    InstanceOf(left: JsExpression, right: JsExpression)
    InExpr(left: JsExpression, right: JsExpression)
    # ES2015+ additions
    ObjectPattern(props: [DestructProp])
    ArrayPattern(elements: [JsExpression])
    ComputedMember(object: JsExpression, property: JsExpression)
    TaggedTemplate(tag: JsExpression, quasis: [text], expressions: [JsExpression])
    YieldExpr(argument: JsExpression, delegate: bool)
    AwaitExpr(argument: JsExpression)
    ClassExpr(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement])
    NewExpr(callee: JsExpression, args: [JsExpression])

enum JsStatement:
    VarDecl(name: text, init: JsExpression)
    ExprStmt(expr: JsExpression)
    Return(value: JsExpression)
    If(cond: JsExpression, then_body: [JsStatement], else_body: [JsStatement])
    While(cond: JsExpression, body: [JsStatement])
    For(init: JsStatement, cond: JsExpression, update: JsExpression, body: [JsStatement])
    Block(stmts: [JsStatement])
    FnDecl(name: text, params: [text], body: [JsStatement])
    TryCatch(try_body: [JsStatement], catch_param: text, catch_body: [JsStatement], finally_body: [JsStatement])
    Switch(discriminant: JsExpression, cases: [SwitchCase])
    ForIn(binding: text, object: JsExpression, body: [JsStatement])
    ForOf(binding: text, iterable: JsExpression, body: [JsStatement])
    ThrowStmt(expr: JsExpression)
    BreakStmt
    ContinueStmt
    ClassDecl(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement])
    # ES2015+ additions
    LetDecl(name: text, init: JsExpression)
    ConstDecl(name: text, init: JsExpression)
    DestructVarDecl(pattern: JsExpression, init: JsExpression, kind: text)
    ImportDecl(specifiers: [ImportSpec], source: text)
    ExportDecl(declaration: JsStatement)
    ExportDefault(expression: JsExpression)
    ExportNamed(specifiers: [ExportSpec], source: text)
    AsyncFnDecl(name: text, params: [FnParam], body: [JsStatement])
    LabeledStmt(label: text, body: JsStatement)
    DoWhile(cond: JsExpression, body: [JsStatement])

class SwitchCase:
    test: Option<JsExpression>
    consequent: [JsStatement]

    static fn case_clause(test: JsExpression, body: [JsStatement]) -> SwitchCase:
        SwitchCase(test: Some(test), consequent: body)

    static fn default_clause(body: [JsStatement]) -> SwitchCase:
        SwitchCase(test: nil, consequent: body)

class JsAstNode:
    kind: text
    children: [JsAstNode]
    token_start: i64
    token_end: i64

    static fn create(kind: text, token_start: i64, token_end: i64) -> JsAstNode:
        JsAstNode(kind: kind, children: [], token_start: token_start, token_end: token_end)

class FnParam:
    name: text
    default_value: JsExpression?
    is_rest: bool

    static fn simple(name: text) -> FnParam:
        FnParam(name: name, default_value: nil, is_rest: false)

    static fn with_default(name: text, default_val: JsExpression) -> FnParam:
        FnParam(name: name, default_value: Some(default_val), is_rest: false)

    static fn rest(name: text) -> FnParam:
        FnParam(name: name, default_value: nil, is_rest: true)

class DestructProp:
    key: text
    value: JsExpression
    default_value: JsExpression?
    is_computed: bool

    static fn simple(key: text) -> DestructProp:
        DestructProp(key: key, value: JsExpression.Identifier(name: key), default_value: nil, is_computed: false)

class ImportSpec:
    imported: text
    local: text

    static fn named(imported: text, local: text) -> ImportSpec:
        ImportSpec(imported: imported, local: local)

    static fn default_import(local: text) -> ImportSpec:
        ImportSpec(imported: "default", local: local)

class ExportSpec:
    local: text
    exported: text

    static fn named(local: text, exported: text) -> ExportSpec:
        ExportSpec(local: local, exported: exported)

class JsAstFactory:
    static fn literal(value: JsValue) -> JsExpression:
        JsExpression.Literal(value: value)

    static fn identifier(name: text) -> JsExpression:
        JsExpression.Identifier(name: name)

    static fn binary(op: text, left: JsExpression, right: JsExpression) -> JsExpression:
        JsExpression.Binary(op: op, left: left, right: right)

    static fn unary(op: text, operand: JsExpression) -> JsExpression:
        JsExpression.Unary(op: op, operand: operand)

    static fn call(callee: JsExpression, args: [JsExpression]) -> JsExpression:
        JsExpression.Call(callee: callee, args: args)

    static fn member(object: JsExpression, property: text) -> JsExpression:
        JsExpression.Member(object: object, property: property)

    static fn assignment(target: JsExpression, value: JsExpression) -> JsExpression:
        JsExpression.Assignment(target: target, value: value)

    static fn array(elements: [JsExpression]) -> JsExpression:
        JsExpression.Array(elements: elements)

    static fn object_expr(properties: [Pair<text, JsExpression>]) -> JsExpression:
        JsExpression.ObjectExpr(properties: properties)

    static fn ternary(condition: JsExpression, consequent: JsExpression, alternate: JsExpression) -> JsExpression:
        JsExpression.Ternary(condition: condition, consequent: consequent, alternate: alternate)

    static fn arrow_function(params: [text], body: [JsStatement]) -> JsExpression:
        JsExpression.ArrowFunction(params: params, body: body)

    static fn spread_element(argument: JsExpression) -> JsExpression:
        JsExpression.SpreadElement(argument: argument)

    static fn template_literal(quasis: [text], expressions: [JsExpression]) -> JsExpression:
        JsExpression.TemplateLiteral(quasis: quasis, expressions: expressions)

    static fn delete_expr(expr: JsExpression) -> JsExpression:
        JsExpression.Delete(expr: expr)

    static fn instance_of(left: JsExpression, right: JsExpression) -> JsExpression:
        JsExpression.InstanceOf(left: left, right: right)

    static fn in_expr(left: JsExpression, right: JsExpression) -> JsExpression:
        JsExpression.InExpr(left: left, right: right)

    static fn object_pattern(props: [DestructProp]) -> JsExpression:
        JsExpression.ObjectPattern(props: props)

    static fn array_pattern(elements: [JsExpression]) -> JsExpression:
        JsExpression.ArrayPattern(elements: elements)

    static fn var_decl(name: text, init: JsExpression) -> JsStatement:
        JsStatement.VarDecl(name: name, init: init)

    static fn expr_stmt(expr: JsExpression) -> JsStatement:
        JsStatement.ExprStmt(expr: expr)

    static fn return_stmt(value: JsExpression) -> JsStatement:
        JsStatement.Return(value: value)

    static fn if_stmt(cond: JsExpression, then_body: [JsStatement], else_body: [JsStatement]) -> JsStatement:
        JsStatement.If(cond: cond, then_body: then_body, else_body: else_body)

    static fn while_stmt(cond: JsExpression, body: [JsStatement]) -> JsStatement:
        JsStatement.While(cond: cond, body: body)

    static fn for_stmt(init: JsStatement, cond: JsExpression, update: JsExpression, body: [JsStatement]) -> JsStatement:
        JsStatement.For(init: init, cond: cond, update: update, body: body)

    static fn block(stmts: [JsStatement]) -> JsStatement:
        JsStatement.Block(stmts: stmts)

    static fn fn_decl(name: text, params: [text], body: [JsStatement]) -> JsStatement:
        JsStatement.FnDecl(name: name, params: params, body: body)

    static fn try_catch(try_body: [JsStatement], catch_param: text, catch_body: [JsStatement], finally_body: [JsStatement]) -> JsStatement:
        JsStatement.TryCatch(try_body: try_body, catch_param: catch_param, catch_body: catch_body, finally_body: finally_body)

    static fn switch_stmt(discriminant: JsExpression, cases: [SwitchCase]) -> JsStatement:
        JsStatement.Switch(discriminant: discriminant, cases: cases)

    static fn for_in(binding: text, object: JsExpression, body: [JsStatement]) -> JsStatement:
        JsStatement.ForIn(binding: binding, object: object, body: body)

    static fn for_of(binding: text, iterable: JsExpression, body: [JsStatement]) -> JsStatement:
        JsStatement.ForOf(binding: binding, iterable: iterable, body: body)

    static fn throw_stmt(expr: JsExpression) -> JsStatement:
        JsStatement.ThrowStmt(expr: expr)

    static fn break_stmt() -> JsStatement:
        JsStatement.BreakStmt

    static fn continue_stmt() -> JsStatement:
        JsStatement.ContinueStmt

    static fn class_decl(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement]) -> JsStatement:
        JsStatement.ClassDecl(name: name, parent_name: parent_name, constructor: constructor, methods: methods)

    static fn let_decl(name: text, init: JsExpression) -> JsStatement:
        JsStatement.LetDecl(name: name, init: init)

    static fn const_decl(name: text, init: JsExpression) -> JsStatement:
        JsStatement.ConstDecl(name: name, init: init)

    static fn destruct_var_decl(pattern: JsExpression, init: JsExpression, kind: text) -> JsStatement:
        JsStatement.DestructVarDecl(pattern: pattern, init: init, kind: kind)

    static fn labeled_stmt(label: text, body: JsStatement) -> JsStatement:
        JsStatement.LabeledStmt(label: label, body: body)

    static fn do_while(cond: JsExpression, body: [JsStatement]) -> JsStatement:
        JsStatement.DoWhile(cond: cond, body: body)

class ObjProp:
    key: JsExpression
    value: JsExpression?
    is_computed: bool
    is_shorthand: bool

    static fn simple(key: text, value: JsExpression) -> ObjProp:
        ObjProp(key: JsExpression.Literal(value: JsValue.String(v: key)), value: Some(value), is_computed: false, is_shorthand: false)

    static fn shorthand(name: text) -> ObjProp:
        ObjProp(key: JsExpression.Identifier(name: name), value: nil, is_computed: false, is_shorthand: true)

    static fn computed(key_expr: JsExpression, value: JsExpression) -> ObjProp:
        ObjProp(key: key_expr, value: Some(value), is_computed: true, is_shorthand: false)
