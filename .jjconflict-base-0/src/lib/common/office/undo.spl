# Office Undo — undo/redo stack for office document editors.
#
# Provides: UndoEntry, UndoStack.

struct UndoEntry:
    id: text
    description: text
    before_snapshot: text
    after_snapshot: text

class UndoStack:
    entries: [UndoEntry]
    position: i64
    max_size: i64

    static fn new(max_size: i64) -> UndoStack:
        UndoStack(entries: [], position: 0, max_size: max_size)

    me push(entry: UndoEntry):
        # Trim any redo history ahead of current position
        var new_entries: [UndoEntry] = []
        var i = 0
        while i < me.position:
            new_entries.push(me.entries[i])
            i = i + 1
        new_entries.push(entry)
        # Trim to max_size
        if new_entries.len() > me.max_size:
            var trimmed: [UndoEntry] = []
            var j = new_entries.len() - me.max_size
            while j < new_entries.len():
                trimmed.push(new_entries[j])
                j = j + 1
            me.entries = trimmed
        else:
            me.entries = new_entries
        me.position = me.entries.len()

    me undo() -> Option<UndoEntry>:
        if me.position == 0:
            return Option.None
        me.position = me.position - 1
        Option.Some(me.entries[me.position])

    me redo() -> Option<UndoEntry>:
        if me.position >= me.entries.len():
            return Option.None
        val entry = me.entries[me.position]
        me.position = me.position + 1
        Option.Some(entry)

    fn can_undo() -> bool:
        me.position > 0

    fn can_redo() -> bool:
        me.position < me.entries.len()
