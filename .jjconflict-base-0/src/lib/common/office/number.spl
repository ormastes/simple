# Shared numeric helpers for Office apps.

fn office_parse_non_negative_i32(s: text) -> i32:
    """Parse a non-negative integer. Returns 0 for empty or invalid text."""
    if s.len() == 0:
        return 0
    var result: i32 = 0
    var i: i32 = 0
    while i < s.len():
        val c = s.char_at(i)
        val code = c.char_code_at(0)
        if code >= 48 and code <= 57:
            result = result * 10 + (code - 48)
        else:
            return 0
        i = i + 1
    result

fn office_pow10_f64(exp: i32) -> f64:
    """Calculate 10^exp for small non-negative exponents."""
    var result = 1.0
    var i = 0
    while i < exp:
        result = result * 10.0
        i = i + 1
    result

fn office_pow10_i64(exp: i32) -> i64:
    """Calculate integer 10^exp for small non-negative exponents."""
    var result = 1
    var i = 0
    while i < exp:
        result = result * 10
        i = i + 1
    result

fn office_parse_unsigned_decimal_f64(s: text) -> f64:
    """Parse a simple unsigned decimal, ignoring non-digit non-dot text."""
    office_parse_decimal_f64_from(s, 0)

fn office_parse_signed_decimal_f64(s: text) -> f64:
    """Parse a simple decimal with an optional leading minus sign."""
    if s.len() > 0 and s.char_at(0) == "-":
        return 0.0 - office_parse_decimal_f64_from(s, 1)
    office_parse_decimal_f64_from(s, 0)

fn office_parse_decimal_f64_from(s: text, start: i32) -> f64:
    var int_part = 0.0
    var frac_part = 0.0
    var frac_divisor = 1.0
    var in_frac = false
    var i = start
    while i < s.len():
        val c = s.char_at(i)
        if c == ".":
            in_frac = true
        else:
            val code = c.char_code_at(0)
            if code >= 48 and code <= 57:
                val d = code - 48
                if in_frac:
                    frac_divisor = frac_divisor * 10.0
                    frac_part = frac_part + d.to_f64() / frac_divisor
                else:
                    int_part = int_part * 10.0 + d.to_f64()
        i = i + 1
    int_part + frac_part
