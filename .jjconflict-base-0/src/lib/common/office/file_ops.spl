# Office File Ops — recent files store and file I/O helpers.
#
# Provides: RecentFile, RecentFileStore.

struct RecentFile:
    path: text
    title: text
    app_name: text
    last_opened_at: i64

class RecentFileStore:
    entries: [RecentFile]
    max_entries: i64

    static fn new(max_entries: i64) -> RecentFileStore:
        RecentFileStore(entries: [], max_entries: max_entries)

    static fn with_defaults() -> RecentFileStore:
        RecentFileStore(entries: [], max_entries: 20)

    me add(file: RecentFile):
        # Remove existing entry for same path
        var filtered: [RecentFile] = []
        for e in me.entries:
            if e.path != file.path:
                filtered.push(e)
        filtered.push(file)
        # Trim to max
        if filtered.len() > me.max_entries:
            var trimmed: [RecentFile] = []
            var i = filtered.len() - me.max_entries
            while i < filtered.len():
                trimmed.push(filtered[i])
                i = i + 1
            me.entries = trimmed
        else:
            me.entries = filtered

    fn get_recent(count: i64) -> [RecentFile]:
        val n = if count > me.entries.len(): me.entries.len() else: count
        var out: [RecentFile] = []
        var i = me.entries.len() - n
        while i < me.entries.len():
            out.push(me.entries[i])
            i = i + 1
        out

    me clear():
        me.entries = []
