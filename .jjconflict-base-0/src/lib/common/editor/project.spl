# Project — editor project metadata and file management
#
# EditorProject holds project-level settings (name, paths, window size).
# ProjectManager provides mutable operations and dirty-tracking.

# ============================================================================
# EditorProject — immutable project metadata
# ============================================================================

struct EditorProject:
    name: text
    root_path: text
    scene_paths: [text]
    asset_paths: [text]
    last_opened_scene: text
    window_width: f64
    window_height: f64

impl EditorProject:
    static fn new(name: text, root_path: text) -> EditorProject:
        """Create a new project with default window size and empty path lists."""
        EditorProject(
            name: name,
            root_path: root_path,
            scene_paths: [],
            asset_paths: [],
            last_opened_scene: "",
            window_width: 1280.0,
            window_height: 720.0
        )

    fn to_sdn(self) -> text:
        """Serialize project metadata to SDN text format."""
        val n = self.name
        val rp = self.root_path
        val ww = self.window_width
        val wh = self.window_height
        val los = self.last_opened_scene
        var out = "project {\n"
        out = out + "  name: \"" + n + "\"\n"
        out = out + "  root_path: \"" + rp + "\"\n"
        out = out + "  window_width: " + ww.to_text() + "\n"
        out = out + "  window_height: " + wh.to_text() + "\n"
        out = out + "  last_opened_scene: \"" + los + "\"\n"
        out = out + "  scenes {\n"
        for sp in self.scene_paths:
            out = out + "    path: \"" + sp + "\"\n"
        out = out + "  }\n"
        out = out + "  assets {\n"
        for ap in self.asset_paths:
            out = out + "    path: \"" + ap + "\"\n"
        out = out + "  }\n"
        out = out + "}"
        out

    fn asset_count(self) -> i32:
        """Return the number of registered asset paths."""
        self.asset_paths.len()

    fn scene_count(self) -> i32:
        """Return the number of registered scene paths."""
        self.scene_paths.len()

# ============================================================================
# ProjectManager — mutable project state with dirty tracking
# ============================================================================

class ProjectManager:
    project: EditorProject
    dirty: bool

impl ProjectManager:
    static fn new(project: EditorProject) -> ProjectManager:
        """Create a new manager wrapping the given project."""
        ProjectManager(
            project: project,
            dirty: false
        )

    me add_scene(path: text):
        """Register a scene file path in the project."""
        val sp = self.project.scene_paths
        val new_sp = sp.push(path)
        self.project = EditorProject(
            name: self.project.name,
            root_path: self.project.root_path,
            scene_paths: new_sp,
            asset_paths: self.project.asset_paths,
            last_opened_scene: self.project.last_opened_scene,
            window_width: self.project.window_width,
            window_height: self.project.window_height
        )
        self.dirty = true

    me remove_scene(path: text):
        """Remove a scene file path from the project."""
        var kept: [text] = []
        for sp in self.project.scene_paths:
            if sp != path:
                kept = kept.push(sp)
        self.project = EditorProject(
            name: self.project.name,
            root_path: self.project.root_path,
            scene_paths: kept,
            asset_paths: self.project.asset_paths,
            last_opened_scene: self.project.last_opened_scene,
            window_width: self.project.window_width,
            window_height: self.project.window_height
        )
        self.dirty = true

    me add_asset(path: text):
        """Register an asset path in the project."""
        val ap = self.project.asset_paths
        val new_ap = ap.push(path)
        self.project = EditorProject(
            name: self.project.name,
            root_path: self.project.root_path,
            scene_paths: self.project.scene_paths,
            asset_paths: new_ap,
            last_opened_scene: self.project.last_opened_scene,
            window_width: self.project.window_width,
            window_height: self.project.window_height
        )
        self.dirty = true

    me set_last_scene(path: text):
        """Update the last-opened scene path."""
        self.project = EditorProject(
            name: self.project.name,
            root_path: self.project.root_path,
            scene_paths: self.project.scene_paths,
            asset_paths: self.project.asset_paths,
            last_opened_scene: path,
            window_width: self.project.window_width,
            window_height: self.project.window_height
        )
        self.dirty = true

    me mark_dirty():
        """Mark the project as having unsaved changes."""
        self.dirty = true

    me mark_saved():
        """Clear the dirty flag after saving."""
        self.dirty = false

    fn is_dirty(self) -> bool:
        """Return whether the project has unsaved changes."""
        self.dirty

    fn project_name(self) -> text:
        """Return the project name."""
        self.project.name
