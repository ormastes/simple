# Source-backed color primitives used by browser paint and raster paths.

pub class Color:
    r: i64
    g: i64
    b: i64
    a: i64

    fn to_string(self) -> text:
        "rgba({self.r},{self.g},{self.b},{self.a})"

fn _clamp_byte(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 255:
        return 255
    value

pub fn from_rgba(r: i64, g: i64, b: i64, a: i64) -> Color:
    Color(r: _clamp_byte(r), g: _clamp_byte(g), b: _clamp_byte(b), a: _clamp_byte(a))

pub fn from_rgb(r: i64, g: i64, b: i64) -> Color:
    from_rgba(r, g, b, 255)

pub fn black() -> Color:
    from_rgb(0, 0, 0)

pub fn white() -> Color:
    from_rgb(255, 255, 255)

pub fn transparent() -> Color:
    from_rgba(0, 0, 0, 0)
