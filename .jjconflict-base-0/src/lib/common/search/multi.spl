# ============================================================================
# common/search/multi.spl — Aho-Corasick multi-pattern matcher (AC-3)
#
# Finds ALL occurrences of a set of `Pattern`s in a `Haystack` in a single
# left-to-right pass, returning a typed match per occurrence (which pattern,
# and its [start, end) MatchSpan).
#
# Standalone automaton (NOT built on common/trie/): the shared trie ships only
# as compiled `.smf` (no `.spl` source to reuse), and a plain trie carries no
# failure/output links — the two structures Aho-Corasick is *defined by*. The
# task brief permits building the automaton here when the trie API "doesn't fit
# cleanly"; it doesn't fit (no source, no link concept), so we build it here.
#
# Correctness note (the canonical trap): scanning "ushers" with {he,she,his,hers}
# lands on the trie node for "she" after s-h-e; the node for "he" is never
# reached by goto. "he" is emitted ONLY by following output/failure links from
# "she". So at every position we emit the goto node's terminal pattern PLUS every
# pattern reachable via the output-link chain (nearest terminal failure-ancestor).
#
# KNOWN BUG designed around: `for x in <custom struct>` iterates zero times; we
# use index/counter loops and `.to_bytes()` exclusively.
# ============================================================================

use std.common.search.types.{Haystack, Pattern, MatchSpan}

# ----------------------------------------------------------------------------
# AcMatch -- one occurrence: which pattern matched, and where ([start, end))
# ----------------------------------------------------------------------------
struct AcMatch:
    """A single Aho-Corasick hit. `pattern_id` indexes into the pattern set the
    automaton was built from; `span` is the typed [start, end) location."""
    pattern_id: i64
    span: MatchSpan

impl AcMatch:
    static fn of(pattern_id: i64, span: MatchSpan) -> AcMatch:
        AcMatch(pattern_id: pattern_id, span: span)

    fn pattern() -> i64:
        self.pattern_id

    fn start() -> i64:
        self.span.start()

    fn end() -> i64:
        self.span.end()

    fn length() -> i64:
        self.span.length()

    fn equals(other: AcMatch) -> bool:
        if self.pattern_id != other.pattern_id:
            return false
        self.span.equals(other.span)

# ----------------------------------------------------------------------------
# AhoCorasick -- the multi-pattern automaton over a fixed Pattern set
# ----------------------------------------------------------------------------
struct AhoCorasick:
    """Aho-Corasick automaton built from a list of patterns (their byte content
    + an id = their index in the build list). Behavior-carrying: `find_all`
    runs the single-pass scan; the goto/fail/output machinery is internal and
    built once in `build`. Parallel arrays are indexed by node id (i64); node 0
    is the root. Edges are flat (edge_byte/edge_to) with per-node child_off /
    child_cnt windows so no array-of-arrays is needed at scan time."""
    pat_len: [i64]
    edge_byte: [i64]
    edge_to: [i64]
    child_off: [i64]
    child_cnt: [i64]
    fail: [i64]
    out_pat: [i64]
    out_link: [i64]
    depth: [i64]
    node_count: i64

impl AhoCorasick:
    static fn build(patterns: [Pattern]) -> AhoCorasick:
        """Construct the automaton: build the trie, then failure + output links.
        Empty patterns are skipped (they would match everywhere); their slot in
        `pat_len` is preserved so non-empty pattern ids stay stable."""
        var pat_len: [i64] = []
        var p = 0
        while p < patterns.len():
            pat_len.push(patterns[p].len())
            p = p + 1

        # Mutable trie as nested child lists during construction, then flatten.
        var tchild_bytes: [[i64]] = []
        var tchild_nodes: [[i64]] = []
        var out_pat: [i64] = []
        var depth: [i64] = []
        var root_b: [i64] = []
        var root_n: [i64] = []
        tchild_bytes.push(root_b)
        tchild_nodes.push(root_n)
        out_pat.push(0 - 1)
        depth.push(0)
        var n_nodes = 1

        var pi = 0
        while pi < patterns.len():
            val pbytes = patterns[pi].to_bytes()
            val plen = pbytes.len()
            if plen > 0:
                var cur = 0
                var k = 0
                while k < plen:
                    val b = pbytes[k].to_i64()
                    var found = 0 - 1
                    val kids_b = tchild_bytes[cur]
                    var ci = 0
                    while ci < kids_b.len():
                        if kids_b[ci] == b:
                            found = tchild_nodes[cur][ci]
                            ci = kids_b.len()
                        else:
                            ci = ci + 1
                    if found < 0:
                        var nb: [i64] = []
                        var nn: [i64] = []
                        tchild_bytes.push(nb)
                        tchild_nodes.push(nn)
                        out_pat.push(0 - 1)
                        depth.push(depth[cur] + 1)
                        val new_id = n_nodes
                        n_nodes = n_nodes + 1
                        tchild_bytes[cur].push(b)
                        tchild_nodes[cur].push(new_id)
                        cur = new_id
                    else:
                        cur = found
                    k = k + 1
                out_pat[cur] = pi
            pi = pi + 1

        # Flatten children into edge_byte / edge_to with per-node offsets.
        var edge_byte: [i64] = []
        var edge_to: [i64] = []
        var child_off: [i64] = []
        var child_cnt: [i64] = []
        var ni = 0
        while ni < n_nodes:
            val kb = tchild_bytes[ni]
            val kn = tchild_nodes[ni]
            child_off.push(edge_byte.len())
            child_cnt.push(kb.len())
            var ei = 0
            while ei < kb.len():
                edge_byte.push(kb[ei])
                edge_to.push(kn[ei])
                ei = ei + 1
            ni = ni + 1

        # BFS to build failure links + output links.
        var fail: [i64] = []
        var out_link: [i64] = []
        var z = 0
        while z < n_nodes:
            fail.push(0)
            out_link.push(0 - 1)
            z = z + 1

        var queue: [i64] = []
        var qhead = 0
        val r_off = child_off[0]
        val r_cnt = child_cnt[0]
        var rci = 0
        while rci < r_cnt:
            val cnode = edge_to[r_off + rci]
            fail[cnode] = 0
            queue.push(cnode)
            rci = rci + 1

        while qhead < queue.len():
            val u = queue[qhead]
            qhead = qhead + 1
            val u_off = child_off[u]
            val u_cnt = child_cnt[u]
            var ui = 0
            while ui < u_cnt:
                val b = edge_byte[u_off + ui]
                val v = edge_to[u_off + ui]
                var f = fail[u]
                var target = 0 - 1
                var searching = true
                while searching:
                    val f_off = child_off[f]
                    val f_cnt = child_cnt[f]
                    var fi = 0
                    var hit = 0 - 1
                    while fi < f_cnt:
                        if edge_byte[f_off + fi] == b:
                            hit = edge_to[f_off + fi]
                            fi = f_cnt
                        else:
                            fi = fi + 1
                    if hit >= 0:
                        target = hit
                        searching = false
                    else:
                        if f == 0:
                            target = 0
                            searching = false
                        else:
                            f = fail[f]
                fail[v] = target
                if out_pat[target] >= 0:
                    out_link[v] = target
                else:
                    out_link[v] = out_link[target]
                queue.push(v)
                ui = ui + 1

        AhoCorasick(pat_len: pat_len, edge_byte: edge_byte, edge_to: edge_to, child_off: child_off, child_cnt: child_cnt, fail: fail, out_pat: out_pat, out_link: out_link, depth: depth, node_count: n_nodes)

    fn node_total() -> i64:
        self.node_count

    fn goto_edge(node: i64, b: i64) -> i64:
        """Child of `node` on byte `b`, or -1 if no such trie edge."""
        val off = self.child_off[node]
        val cnt = self.child_cnt[node]
        var i = 0
        while i < cnt:
            if self.edge_byte[off + i] == b:
                return self.edge_to[off + i]
            i = i + 1
        0 - 1

    fn next_state(state: i64, b: i64) -> i64:
        """Aho-Corasick goto-with-fallback: follow a real trie edge if present,
        else walk failure links until an edge exists or we reach the root."""
        var s = state
        var moved = false
        while not moved:
            val e = self.goto_edge(s, b)
            if e >= 0:
                s = e
                moved = true
            else:
                if s == 0:
                    moved = true
                else:
                    s = self.fail[s]
        s

    fn find_all(haystack: Haystack) -> [AcMatch]:
        """Single left-to-right pass. At each position emit the current node's
        terminal pattern (if any) and every pattern on its output-link chain,
        each as a typed AcMatch with an exact [start, end) span."""
        var out: [AcMatch] = []
        val data = haystack.to_bytes()
        val n = data.len()
        var state = 0
        var pos = 0
        while pos < n:
            val b = data[pos].to_i64()
            state = self.next_state(state, b)
            if self.out_pat[state] >= 0:
                val plen = self.pat_len[self.out_pat[state]]
                val end_i = pos + 1
                val start_i = end_i - plen
                out.push(AcMatch.of(self.out_pat[state], MatchSpan.of(start_i, end_i)))
            var link = self.out_link[state]
            while link >= 0:
                val lpid = self.out_pat[link]
                val lplen = self.pat_len[lpid]
                val lend = pos + 1
                val lstart = lend - lplen
                out.push(AcMatch.of(lpid, MatchSpan.of(lstart, lend)))
                link = self.out_link[link]
            pos = pos + 1
        out

# ----------------------------------------------------------------------------
# Convenience: build + scan in one call.
# ----------------------------------------------------------------------------
fn find_multi(haystack: Haystack, patterns: [Pattern]) -> [AcMatch]:
    """Build an Aho-Corasick automaton from `patterns` and return all matches
    in `haystack`. Pattern ids are indices into `patterns`."""
    val ac = AhoCorasick.build(patterns)
    ac.find_all(haystack)
