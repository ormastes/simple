# Vector drawing primitives — 2-D point and axis-aligned rectangle.
#
# Mirrors the Skia naming used throughout the drawing/editor subsystem.
# SkPoint and SkRect are pure value types; all methods return new values.

pub struct SkPoint:
    """A 2-D floating-point coordinate (Skia-style naming)."""
    x: f64
    y: f64

impl SkPoint:
    static fn zero() -> SkPoint:
        """Origin point (0, 0)."""
        SkPoint(x: 0.0, y: 0.0)

    static fn from_xy(x: f64, y: f64) -> SkPoint:
        """Construct from explicit coordinates."""
        SkPoint(x: x, y: y)

    fn translate(self, dx: f64, dy: f64) -> SkPoint:
        """Return point shifted by (dx, dy)."""
        SkPoint(x: self.x + dx, y: self.y + dy)

    fn distance_to(self, other: SkPoint) -> f64:
        """Euclidean distance to another point."""
        val dx = self.x - other.x
        val dy = self.y - other.y
        # Newton–Raphson sqrt approximation good to ~0.1 %
        val d2 = dx * dx + dy * dy
        if d2 == 0.0:
            return 0.0
        var s = d2
        var i = 0
        while i < 20:
            s = (s + d2 / s) * 0.5
            i = i + 1
        s

    fn equals(self, other: SkPoint) -> bool:
        self.x == other.x and self.y == other.y

pub struct SkRect:
    """An axis-aligned rectangle expressed as (left, top, right, bottom)."""
    left: f64
    top: f64
    right: f64
    bottom: f64

impl SkRect:
    static fn zero() -> SkRect:
        """Empty rectangle at origin."""
        SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)

    static fn from_ltrb(left: f64, top: f64, right: f64, bottom: f64) -> SkRect:
        """Construct from explicit left/top/right/bottom values."""
        SkRect(left: left, top: top, right: right, bottom: bottom)

    static fn from_xywh(x: f64, y: f64, w: f64, h: f64) -> SkRect:
        """Construct from (x, y, width, height)."""
        SkRect(left: x, top: y, right: x + w, bottom: y + h)

    fn width(self) -> f64:
        self.right - self.left

    fn height(self) -> f64:
        self.bottom - self.top

    fn center_x(self) -> f64:
        (self.left + self.right) * 0.5

    fn center_y(self) -> f64:
        (self.top + self.bottom) * 0.5

    fn contains_point(self, p: SkPoint) -> bool:
        p.x >= self.left and p.x < self.right and p.y >= self.top and p.y < self.bottom

    fn is_empty(self) -> bool:
        self.right <= self.left or self.bottom <= self.top

    fn translate(self, dx: f64, dy: f64) -> SkRect:
        SkRect(left: self.left + dx, top: self.top + dy,
               right: self.right + dx, bottom: self.bottom + dy)

    fn inset(self, dx: f64, dy: f64) -> SkRect:
        SkRect(left: self.left + dx, top: self.top + dy,
               right: self.right - dx, bottom: self.bottom - dy)

    fn union_rect(self, other: SkRect) -> SkRect:
        """Return the smallest rect enclosing both rects."""
        val l = if self.left < other.left: self.left else: other.left
        val t = if self.top < other.top: self.top else: other.top
        val r = if self.right > other.right: self.right else: other.right
        val b = if self.bottom > other.bottom: self.bottom else: other.bottom
        SkRect(left: l, top: t, right: r, bottom: b)
