# Geometry, identity, color, and input wrappers for the window manager stack.
#
# Named value-object wrappers for the primitives exposed by WM public APIs
# (window_protocol, display_protocol, CompositorBackend, InputBackend,
# wm_service, ui.*). Wrapping primitives in these single-field classes IS
# the fix for the `primitive_api` lint: callers only see the wrapper type
# on the pub surface and read/write `.value` or the `.to_*()` helpers
# inside the wrapper layer.

# ============================================================================
# Identity
# ============================================================================

class WindowId:
    """Stable id assigned by the window manager to each window."""
    value: u64

impl WindowId:
    fn to_u64() -> u64:
        self.value

class ProcessId:
    """Process that owns a window (matches kernel pid / host pid)."""
    value: u64

impl ProcessId:
    fn to_u64() -> u64:
        self.value

class AppId:
    """Application identifier string (e.g. `com.example.browser`)."""
    value: text

impl AppId:
    fn to_text() -> text:
        self.value

# ============================================================================
# Geometry
# ============================================================================

class Px:
    """Screen-space distance, signed pixels."""
    value: i32

impl Px:
    fn to_i32() -> i32:
        self.value

    fn to_i64() -> i64:
        self.value.to_i64()

    fn to_u64() -> u64:
        if self.value < 0:
            return 0
        self.value.to_u64()

class Point:
    """Screen-space point (x, y)."""
    x: Px
    y: Px

impl Point:
    static fn xy(x: i32, y: i32) -> Point:
        Point(x: Px(value: x), y: Px(value: y))

class Size:
    """Screen-space rectangle extent (width, height)."""
    width: Px
    height: Px

impl Size:
    static fn wh(w: i32, h: i32) -> Size:
        Size(width: Px(value: w), height: Px(value: h))

class Rect:
    """Axis-aligned rectangle: top-left origin + size.
    Right/bottom edges are EXCLUSIVE (matches CompositorBackend fill_rect)."""
    origin: Point
    size: Size

impl Rect:
    static fn xywh(x: i32, y: i32, w: i32, h: i32) -> Rect:
        Rect(
            origin: Point.xy(x, y),
            size: Size.wh(w, h)
        )

    fn contains(p: Point) -> bool:
        val px = p.x.to_i32()
        val py = p.y.to_i32()
        val ox = self.origin.x.to_i32()
        val oy = self.origin.y.to_i32()
        val ow = self.size.width.to_i32()
        val oh = self.size.height.to_i32()
        px >= ox and px < ox + ow and py >= oy and py < oy + oh

    fn inset(n: i32) -> Rect:
        Rect.xywh(
            self.origin.x.to_i32() + n,
            self.origin.y.to_i32() + n,
            self.size.width.to_i32() - n * 2,
            self.size.height.to_i32() - n * 2
        )

    fn intersects(other: Rect) -> bool:
        val ax = self.origin.x.to_i32()
        val ay = self.origin.y.to_i32()
        val aw = self.size.width.to_i32()
        val ah = self.size.height.to_i32()
        val bx = other.origin.x.to_i32()
        val by = other.origin.y.to_i32()
        val bw = other.size.width.to_i32()
        val bh = other.size.height.to_i32()
        ax < bx + bw and ax + aw > bx and ay < by + bh and ay + ah > by

# ============================================================================
# Color and Alpha
# ============================================================================

class Argb32:
    """Packed ARGB color (0xAARRGGBB)."""
    value: u32

impl Argb32:
    fn to_u32() -> u32:
        self.value

class Alpha:
    """8-bit alpha channel (0=transparent, 255=opaque)."""
    value: u8

impl Alpha:
    fn to_u8() -> u8:
        self.value

class BlurRadius:
    """Blur radius in pixels (0 = no blur)."""
    value: u32

# ============================================================================
# Input
# ============================================================================

class KeyCode:
    """Platform-independent key code."""
    value: u32

impl KeyCode:
    fn to_u32() -> u32:
        self.value

class Modifiers:
    """Keyboard modifier bitmask (Shift, Ctrl, Alt, Meta)."""
    value: u32

impl Modifiers:
    fn to_u32() -> u32:
        self.value

class WmEventType:
    """Window manager event type discriminant."""
    value: u32

impl WmEventType:
    fn to_u32() -> u32:
        self.value

class WmStatus:
    """Window manager status code."""
    value: i32

impl WmStatus:
    fn to_i32() -> i32:
        self.value
