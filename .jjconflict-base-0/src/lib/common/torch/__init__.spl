# Torch Convention Interface
#
# Defines the shared TorchBackend trait that both gc and nogc implementations satisfy.
# Import this module for backend-agnostic code.
#
# Public API:
#   use std.common.torch.interface.{TorchBackend, LayerForward, HasParameters}
#
# Backend implementations:
#   use std.nogc_sync_mut.torch.backend  # NogcTorchOps
#   use std.gc_async_mut.torch.backend   # GcTorchOps

