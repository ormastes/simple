# Package Command Model
#
# Minimal package command planning for the primary SimpleOS CLI.

struct PackageCommandPlan:
    action: text
    package_name: text
    assume_yes: bool
    dry_run: bool

fn package_command_plan(action: text, package_name: text, assume_yes: bool, dry_run: bool) -> PackageCommandPlan:
    PackageCommandPlan(action: action, package_name: package_name, assume_yes: assume_yes, dry_run: dry_run)

fn parse_package_command(args: [text]) -> Result<PackageCommandPlan, text>:
    if args.len() == 0:
        return Err("pkg: action required")
    val action = args[0]
    if not _package_action_supported(action):
        return Err("pkg: unsupported action: {action}")
    var assume_yes = false
    var dry_run = false
    var package_name = ""
    var i: u64 = 1
    while i < args.len():
        val arg = args[i]
        if arg == "-y" or arg == "--yes":
            assume_yes = true
        elif arg == "--dry-run":
            dry_run = true
        elif arg.starts_with("-"):
            return Err("pkg: unsupported option: {arg}")
        else:
            package_name = arg
        i = i + 1
    if _package_action_needs_name(action) and package_name == "":
        return Err("pkg: package name required")
    Ok(package_command_plan(action, package_name, assume_yes, dry_run))

fn package_command_summary(plan: PackageCommandPlan) -> text:
    if plan.package_name == "":
        return "pkg {plan.action}"
    "pkg {plan.action} {plan.package_name}"

fn _package_action_supported(action: text) -> bool:
    action == "install" or action == "remove" or action == "update" or action == "list" or action == "search" or action == "info"

fn _package_action_needs_name(action: text) -> bool:
    action == "install" or action == "remove" or action == "search" or action == "info"
