# Runtime contract-check helpers — pure Simple equivalents of runtime_contracts.c
#
# IMPORTANT: simple_contract_check and simple_contract_check_msg are hardcoded by
# name in the Cranelift and LLVM codegens (codegen/instr/contracts.rs).
# These pub fn declarations export those exact symbols in native builds.
#
# The abort/exit path (condition=0) cannot be unit-tested — it terminates the
# process. Tests only verify the happy-path (condition != 0 returns silently).

extern fn exit(code: i64)

fn contract_kind_name(kind: i64) -> text:
    if kind == 0:
        "Precondition"
    else:
        if kind == 1:
            "Postcondition"
        else:
            if kind == 2:
                "Error postcondition"
            else:
                if kind == 3:
                    "Entry invariant"
                else:
                    if kind == 4:
                        "Exit invariant"
                    else:
                        if kind == 5:
                            "Assertion"
                        else:
                            "Precondition"

pub fn simple_contract_check(
    condition: i64,
    kind: i64,
    func_name: text
):
    """Check a contract condition; exit(1) with a diagnostic message on failure.

    condition: non-zero means pass, 0 means violation.
    kind:      0=Precondition 1=Postcondition 2=Error-postcondition
               3=Entry-invariant 4=Exit-invariant 5=Assertion
    func_name: name of the enclosing function (may be empty).
    """
    if condition != 0:
        return
    val kind_str = contract_kind_name(kind)
    if func_name.len() > 0:
        print("{kind_str} violation in function '{func_name}': contract condition failed")
    else:
        print("{kind_str} violation in function '<unknown>': contract condition failed")
    exit(1)

pub fn simple_contract_check_msg(
    condition: i64,
    kind: i64,
    func_name: text,
    message: text
):
    """Like simple_contract_check but includes an extra diagnostic message."""
    if condition != 0:
        return
    val kind_str = contract_kind_name(kind)
    if func_name.len() > 0:
        print("{kind_str} violation in function '{func_name}': {message}")
    else:
        print("{kind_str} violation in function '<unknown>': {message}")
    exit(1)
