# layer_tree_host.spl — cc::LayerTreeHost + LayerTreeImpl (pending/active tree swap)

use std.cc.entity.layer.{Layer, LayerKind}
use std.cc.entity.property_tree.{PropertyTrees}
use std.skia.entity.geometry.{SkRect}

class LayerTreeImpl:
    layers: [Layer]
    property_trees: PropertyTrees
    device_viewport: SkRect
    root_layer_id: i32

    static fn empty() -> LayerTreeImpl:
        LayerTreeImpl(
            layers: [Layer](),
            property_trees: PropertyTrees.new(),
            device_viewport: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
            root_layer_id: -1
        )

    me add_layer(layer: Layer) -> i32:
        val id = me.layers.len() as i32
        var l = layer
        l.id = id
        me.layers.push(l)
        id

    me get_layer(id: i32) -> Layer:
        me.layers.get(id as i64)

    me layer_count() -> i32:
        me.layers.len() as i32

class LayerTreeHost:
    pending_tree: LayerTreeImpl
    active_tree: LayerTreeImpl
    source_frame_number: i64
    needs_commit: bool

    static fn new() -> LayerTreeHost:
        LayerTreeHost(
            pending_tree: LayerTreeImpl.empty(),
            active_tree: LayerTreeImpl.empty(),
            source_frame_number: 0,
            needs_commit: false
        )

    me set_needs_commit():
        me.needs_commit = true

    me commit():
        var copied = LayerTreeImpl.empty()
        copied.device_viewport = me.pending_tree.device_viewport
        copied.root_layer_id = me.pending_tree.root_layer_id
        var i = 0
        while i < me.pending_tree.layers.len():
            copied.layers.push(me.pending_tree.layers.get(i))
            i = i + 1
        me.active_tree = copied
        me.needs_commit = false

    me begin_main_frame():
        me.source_frame_number = me.source_frame_number + 1
