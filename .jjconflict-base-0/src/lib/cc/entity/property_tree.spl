# Property Tree — transform, clip, and effect trees for the compositor.
#
# Provides: TransformNode, TransformTree, ClipNode, ClipTree, EffectNode, EffectTree.

struct TransformNode:
    id: i32
    parent_id: i32
    local: [f32]

class TransformTree:
    nodes: [TransformNode]

    static fn new() -> TransformTree:
        TransformTree(nodes: [])

    me add_node(node: TransformNode):
        me.nodes.push(node)

    fn find(id: i32) -> Option<TransformNode>:
        for n in me.nodes:
            if n.id == id:
                return Option.Some(n)
        Option.None

    fn get(id: i32) -> TransformNode:
        for n in me.nodes:
            if n.id == id:
                return n
        TransformNode(id: -1, parent_id: -1, local: [])

struct ClipNode:
    id: i32
    parent_id: i32
    clip_x: f64
    clip_y: f64
    clip_w: f64
    clip_h: f64

class ClipTree:
    nodes: [ClipNode]

    static fn new() -> ClipTree:
        ClipTree(nodes: [])

    me add_node(node: ClipNode):
        me.nodes.push(node)

    fn find(id: i32) -> Option<ClipNode>:
        for n in me.nodes:
            if n.id == id:
                return Option.Some(n)
        Option.None

    fn get(id: i32) -> ClipNode:
        for n in me.nodes:
            if n.id == id:
                return n
        ClipNode(id: -1, parent_id: -1, clip_x: 0.0, clip_y: 0.0, clip_w: 0.0, clip_h: 0.0)

struct EffectNode:
    id: i32
    parent_id: i32
    opacity: f64
    blend_mode: i32
    has_render_surface: bool
    clip_id: i32
    transform_id: i32

class EffectTree:
    nodes: [EffectNode]

    static fn new() -> EffectTree:
        EffectTree(nodes: [])

    me add_node(node: EffectNode):
        me.nodes.push(node)

    fn find(id: i32) -> Option<EffectNode>:
        for n in me.nodes:
            if n.id == id:
                return Option.Some(n)
        Option.None

    fn get(id: i32) -> EffectNode:
        for n in me.nodes:
            if n.id == id:
                return n
        EffectNode(id: -1, parent_id: -1, opacity: 1.0, blend_mode: 0, has_render_surface: false, clip_id: 0, transform_id: 0)
