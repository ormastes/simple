# SoC VHDL — top-level SoC assembly + simulation testbench
use lib.hardware.fpga_linux.soc_vhdl_gen.*
# SoC VHDL Generation — Synthesizable VHDL for RISC-V SoC Peripherals
#
# Generates VHDL-2008 text for each SoC component matching the behavioral
# models in soc_rtl/*.spl. Output is suitable for GHDL simulation and
# Xilinx Vivado synthesis (BRAM inference, combinational ROM, etc.).

use std.hardware.fpga_linux.soc_boot_sim.{generate_simpleos_test_prog}

fn generate_soc_top_vhdl() -> text:
    var l: [text] = []
    l = l.push("library ieee;")
    l = l.push("use ieee.std_logic_1164.all;")
    l = l.push("use ieee.numeric_std.all;")
    l = l.push("")
    l = l.push("entity soc_top is")
    l = l.push("  generic (")
    l = l.push("    CLK_FREQ       : natural := 25000000;")
    l = l.push("    BAUD_RATE      : natural := 115200;")
    l = l.push("    RAM_ADDR_WIDTH : natural := 17")
    l = l.push("  );")
    l = l.push("  port (")
    l = l.push("    clk        : in  std_logic;")
    l = l.push("    rst_n      : in  std_logic;")
    l = l.push("    uart_tx    : out std_logic;")
    l = l.push("    uart_rx    : in  std_logic;")
    l = l.push("    -- Mailbox semihosting output")
    l = l.push("    char_out   : out std_logic_vector(7 downto 0);")
    l = l.push("    char_valid : out std_logic;")
    l = l.push("    halted     : out std_logic;")
    l = l.push("    -- RAM init (testbench loads program during reset)")
    l = l.push("    init_we    : in  std_logic;")
    l = l.push("    init_addr  : in  std_logic_vector(31 downto 0);")
    l = l.push("    init_wdata : in  std_logic_vector(31 downto 0)")
    l = l.push("  );")
    l = l.push("end entity soc_top;")
    l = l.push("")
    l = l.push("architecture structural of soc_top is")
    l = l.push("  -- CPU Harvard interface")
    l = l.push("  signal imem_addr   : std_logic_vector(31 downto 0);")
    l = l.push("  signal imem_data   : std_logic_vector(31 downto 0);")
    l = l.push("  signal dmem_addr   : std_logic_vector(31 downto 0);")
    l = l.push("  signal dmem_wdata  : std_logic_vector(31 downto 0);")
    l = l.push("  signal dmem_rdata  : std_logic_vector(31 downto 0);")
    l = l.push("  signal dmem_we     : std_logic;")
    l = l.push("  signal dmem_re     : std_logic;")
    l = l.push("  signal dmem_width  : std_logic_vector(1 downto 0);")
    l = l.push("  signal cpu_halted  : std_logic;")
    l = l.push("  signal semi_trigger: std_logic;")
    l = l.push("  signal semi_op     : std_logic_vector(31 downto 0);")
    l = l.push("  signal semi_param  : std_logic_vector(31 downto 0);")
    l = l.push("  -- Bus master signals (from CPU data port)")
    l = l.push("  signal bus_adr   : std_logic_vector(31 downto 0);")
    l = l.push("  signal bus_dat_o : std_logic_vector(31 downto 0);")
    l = l.push("  signal bus_dat_i : std_logic_vector(31 downto 0);")
    l = l.push("  signal bus_we    : std_logic;")
    l = l.push("  signal bus_sel   : std_logic_vector(3 downto 0);")
    l = l.push("  signal bus_stb   : std_logic;")
    l = l.push("  signal bus_cyc   : std_logic;")
    l = l.push("  signal bus_ack   : std_logic;")
    l = l.push("  -- ROM (two instances: instruction fetch + data bus)")
    l = l.push("  signal rom_imem_dat : std_logic_vector(31 downto 0);")
    l = l.push("  signal rom_dbus_dat : std_logic_vector(31 downto 0);")
    l = l.push("  signal rom_stb      : std_logic;")
    l = l.push("  -- CLINT")
    l = l.push("  signal clint_dat : std_logic_vector(31 downto 0);")
    l = l.push("  signal clint_stb : std_logic;")
    l = l.push("  signal clint_ack : std_logic;")
    l = l.push("  signal msip_irq  : std_logic;")
    l = l.push("  signal mtip_irq  : std_logic;")
    l = l.push("  -- UART")
    l = l.push("  signal uart_dat_o: std_logic_vector(7 downto 0);")
    l = l.push("  signal uart_stb  : std_logic;")
    l = l.push("  signal uart_ack  : std_logic;")
    l = l.push("  signal uart_irq  : std_logic;")
    l = l.push("  signal uart_dat32: std_logic_vector(31 downto 0);")
    l = l.push("  -- RAM")
    l = l.push("  signal ram_dat      : std_logic_vector(31 downto 0);")
    l = l.push("  signal ram_imem_dat : std_logic_vector(31 downto 0);")
    l = l.push("  signal ram_stb      : std_logic;")
    l = l.push("  signal ram_ack      : std_logic;")
    l = l.push("  signal ram_we       : std_logic;")
    l = l.push("  -- Mailbox")
    l = l.push("  signal mb_dat       : std_logic_vector(31 downto 0);")
    l = l.push("  signal mb_stb       : std_logic;")
    l = l.push("  signal mb_ack       : std_logic;")
    l = l.push("  signal mb_char_out  : std_logic_vector(7 downto 0);")
    l = l.push("  signal mb_char_valid: std_logic;")
    l = l.push("  signal mb_halt_req  : std_logic;")
    l = l.push("begin")
    l = l.push("  -- Widen UART data to 32 bits")
    l = l.push("  uart_dat32 <= x\"000000\" & uart_dat_o;")
    l = l.push("  -- Single-cycle ack for RAM, CLINT, mailbox")
    l = l.push("  ram_we    <= bus_we and ram_stb;")
    l = l.push("  ram_ack   <= ram_stb;")
    l = l.push("  clint_ack <= clint_stb;")
    l = l.push("  mb_ack    <= mb_stb;")
    l = l.push("  -- Outputs")
    l = l.push("  char_out   <= mb_char_out;")
    l = l.push("  char_valid <= mb_char_valid;")
    l = l.push("  halted     <= mb_halt_req or cpu_halted;")
    l = l.push("")
    l = l.push("  -- ============================================================")
    l = l.push("  -- CPU Harvard-to-bus bridge")
    l = l.push("  -- ============================================================")
    l = l.push("  -- Instruction fetch: combinational mux (ROM or RAM)")
    l = l.push("  imem_data <= rom_imem_dat when imem_addr(31 downto 12) = x\"00001\" else")
    l = l.push("               ram_imem_dat when imem_addr(31) = '1' else")
    l = l.push("               x\"00000013\";")
    l = l.push("  -- Data bus: dmem signals drive the Wishbone master")
    l = l.push("  bus_adr   <= dmem_addr;")
    l = l.push("  bus_dat_o <= dmem_wdata;")
    l = l.push("  bus_we    <= dmem_we;")
    l = l.push("  bus_stb   <= dmem_we or dmem_re;")
    l = l.push("  bus_cyc   <= bus_stb;")
    l = l.push("  dmem_rdata <= bus_dat_i;")
    l = l.push("  -- Byte-enable from width + address alignment")
    l = l.push("  process(dmem_width, dmem_addr)")
    l = l.push("  begin")
    l = l.push("    case dmem_width is")
    l = l.push("      when \"00\" =>")
    l = l.push("        case dmem_addr(1 downto 0) is")
    l = l.push("          when \"00\"   => bus_sel <= \"0001\";")
    l = l.push("          when \"01\"   => bus_sel <= \"0010\";")
    l = l.push("          when \"10\"   => bus_sel <= \"0100\";")
    l = l.push("          when others => bus_sel <= \"1000\";")
    l = l.push("        end case;")
    l = l.push("      when \"01\" =>")
    l = l.push("        if dmem_addr(1) = '0' then bus_sel <= \"0011\";")
    l = l.push("        else bus_sel <= \"1100\"; end if;")
    l = l.push("      when others =>")
    l = l.push("        bus_sel <= \"1111\";")
    l = l.push("    end case;")
    l = l.push("  end process;")
    l = l.push("")
    l = l.push("  -- ============================================================")
    l = l.push("  -- Component instances")
    l = l.push("  -- ============================================================")
    l = l.push("  u_cpu : entity work.rv32i_core")
    l = l.push("    generic map (RESET_ADDR => x\"00001000\")")
    l = l.push("    port map (")
    l = l.push("      clk => clk, reset_n => rst_n,")
    l = l.push("      imem_addr => imem_addr, imem_data => imem_data,")
    l = l.push("      dmem_addr => dmem_addr, dmem_wdata => dmem_wdata,")
    l = l.push("      dmem_rdata => dmem_rdata, dmem_we => dmem_we,")
    l = l.push("      dmem_re => dmem_re, dmem_width => dmem_width,")
    l = l.push("      halted => cpu_halted,")
    l = l.push("      semi_trigger => semi_trigger,")
    l = l.push("      semi_op => semi_op, semi_param => semi_param")
    l = l.push("    );")
    l = l.push("  u_rom_imem : entity work.bootrom")
    l = l.push("    port map (addr => imem_addr, rdata => rom_imem_dat);")
    l = l.push("  u_rom_dbus : entity work.bootrom")
    l = l.push("    port map (addr => bus_adr, rdata => rom_dbus_dat);")
    l = l.push("  u_clint : entity work.clint")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst_n => rst_n,")
    l = l.push("      addr => bus_adr(15 downto 0), wdata => bus_dat_o,")
    l = l.push("      rdata => clint_dat, we => bus_we, re => clint_stb,")
    l = l.push("      msip_out => msip_irq, mtip_out => mtip_irq")
    l = l.push("    );")
    l = l.push("  u_uart : entity work.uart16550")
    l = l.push("    generic map (CLK_FREQ => CLK_FREQ, BAUD_RATE => BAUD_RATE)")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst_n => rst_n,")
    l = l.push("      wb_adr => bus_adr(4 downto 2), wb_dat_i => bus_dat_o(7 downto 0),")
    l = l.push("      wb_dat_o => uart_dat_o, wb_we => bus_we,")
    l = l.push("      wb_stb => uart_stb, wb_ack => uart_ack,")
    l = l.push("      tx => uart_tx, rx => uart_rx, irq => uart_irq")
    l = l.push("    );")
    l = l.push("  u_ram : entity work.soc_ram")
    l = l.push("    generic map (ADDR_WIDTH => RAM_ADDR_WIDTH)")
    l = l.push("    port map (")
    l = l.push("      clk => clk,")
    l = l.push("      i_addr => imem_addr, i_rdata => ram_imem_dat,")
    l = l.push("      we => ram_we, be => bus_sel,")
    l = l.push("      addr => bus_adr, wdata => bus_dat_o, rdata => ram_dat,")
    l = l.push("      init_we => init_we, init_addr => init_addr,")
    l = l.push("      init_wdata => init_wdata")
    l = l.push("    );")
    l = l.push("  u_mailbox : entity work.soc_mailbox")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst_n => rst_n,")
    l = l.push("      addr => bus_adr(7 downto 0), wdata => bus_dat_o,")
    l = l.push("      rdata => mb_dat, we => bus_we, stb => mb_stb,")
    l = l.push("      char_out => mb_char_out, char_valid => mb_char_valid,")
    l = l.push("      halt_req => mb_halt_req")
    l = l.push("    );")
    l = l.push("  u_bus : entity work.wb_interconnect")
    l = l.push("    port map (")
    l = l.push("      m_adr => bus_adr, m_dat_o => bus_dat_o, m_dat_i => bus_dat_i,")
    l = l.push("      m_we => bus_we, m_sel => bus_sel, m_stb => bus_stb,")
    l = l.push("      m_cyc => bus_cyc, m_ack => bus_ack,")
    l = l.push("      s0_dat => rom_dbus_dat, s0_stb => rom_stb,")
    l = l.push("      s1_dat => clint_dat, s1_stb => clint_stb, s1_ack => clint_ack,")
    l = l.push("      s2_dat => uart_dat32, s2_stb => uart_stb, s2_ack => uart_ack,")
    l = l.push("      s3_dat => ram_dat, s3_stb => ram_stb, s3_ack => ram_ack,")
    l = l.push("      s4_dat => mb_dat, s4_stb => mb_stb, s4_ack => mb_ack")
    l = l.push("    );")
    l = l.push("end architecture structural;")
    l.join("\n")

# ============================================================================
# GHDL Testbench — Loads test kernel, runs SoC, checks mailbox output
# ============================================================================

# ============================================================================
# RV64GC SoC Top-Level VHDL Generator
# ============================================================================

pub fn generate_soc_top_vhdl_rv64() -> text:
    """Generates VHDL-2008 text for the RV64GC SoC top-level entity.
    Includes rv64gc_core, clint, plic, uart, ram, bootrom, and wb interconnect.
    64-bit Wishbone data bus (63 downto 0)."""
    var l: [text] = []
    l = l.push("library ieee;")
    l = l.push("use ieee.std_logic_1164.all;")
    l = l.push("use ieee.numeric_std.all;")
    l = l.push("")
    l = l.push("entity soc_top_rv64 is")
    l = l.push("  generic (")
    l = l.push("    CLK_FREQ       : natural := 100000000;")
    l = l.push("    BAUD_RATE      : natural := 115200;")
    l = l.push("    RAM_ADDR_WIDTH : natural := 19")
    l = l.push("  );")
    l = l.push("  port (")
    l = l.push("    clk      : in  std_logic;")
    l = l.push("    rst      : in  std_logic;")
    l = l.push("    uart_tx  : out std_logic;")
    l = l.push("    uart_rx  : in  std_logic;")
    l = l.push("    debug_uart_valid : out std_logic;")
    l = l.push("    debug_uart_byte  : out std_logic_vector(7 downto 0)")
    l = l.push("  );")
    l = l.push("end entity soc_top_rv64;")
    l = l.push("")
    l = l.push("architecture rtl of soc_top_rv64 is")
    l = l.push("  -- 64-bit Wishbone data bus")
    l = l.push("  signal wb_dat_o  : std_logic_vector(63 downto 0);")
    l = l.push("  signal wb_dat_i  : std_logic_vector(63 downto 0);")
    l = l.push("  signal wb_adr    : std_logic_vector(63 downto 0);")
    l = l.push("  signal wb_we     : std_logic;")
    l = l.push("  signal wb_sel    : std_logic_vector(7 downto 0);")
    l = l.push("  signal wb_stb    : std_logic;")
    l = l.push("  signal wb_cyc    : std_logic;")
    l = l.push("  signal wb_ack    : std_logic;")
    l = l.push("  -- Component data / strobe / ack")
    l = l.push("  signal clint_dat : std_logic_vector(63 downto 0);")
    l = l.push("  signal clint_stb : std_logic;")
    l = l.push("  signal clint_ack : std_logic;")
    l = l.push("  signal plic_dat  : std_logic_vector(63 downto 0);")
    l = l.push("  signal plic_stb  : std_logic;")
    l = l.push("  signal plic_ack  : std_logic;")
    l = l.push("  signal uart_dat  : std_logic_vector(63 downto 0);")
    l = l.push("  signal uart_stb  : std_logic;")
    l = l.push("  signal uart_ack  : std_logic;")
    l = l.push("  signal uart_tx_core : std_logic;")
    l = l.push("  signal debug_uart_valid_core : std_logic;")
    l = l.push("  signal debug_uart_byte_core  : std_logic_vector(7 downto 0);")
    l = l.push("  signal ram_dat   : std_logic_vector(63 downto 0);")
    l = l.push("  signal ram_stb   : std_logic;")
    l = l.push("  signal ram_ack   : std_logic;")
    l = l.push("  signal bootrom_dat : std_logic_vector(63 downto 0);")
    l = l.push("  signal bootrom_stb : std_logic;")
    l = l.push("  signal debug_live : std_logic;")
    l = l.push("  attribute dont_touch : string;")
    l = l.push("  attribute mark_debug : string;")
    l = l.push("  attribute dont_touch of debug_live : signal is \"true\";")
    l = l.push("  attribute mark_debug of debug_live : signal is \"true\";")
    l = l.push("  -- IRQ lines")
    l = l.push("  signal msip_irq  : std_logic;")
    l = l.push("  signal mtip_irq  : std_logic;")
    l = l.push("  signal uart_irq  : std_logic;")
    l = l.push("begin")
    l = l.push("")
    l = l.push("  uart_tx <= uart_tx_core;")
    l = l.push("  debug_uart_valid <= debug_uart_valid_core;")
    l = l.push("  debug_uart_byte <= debug_uart_byte_core;")
    l = l.push("  debug_live <= wb_adr(3) xor wb_dat_i(0) xor wb_ack;")
    l = l.push("")
    l = l.push("  u_rv64gc_core : entity work.rv64gc_core")
    l = l.push("    generic map (CLK_FREQ => CLK_FREQ)")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst => rst,")
    l = l.push("      wb_adr_o => wb_adr, wb_dat_o => wb_dat_o, wb_dat_i => wb_dat_i,")
    l = l.push("      wb_we_o => wb_we, wb_sel_o => wb_sel,")
    l = l.push("      wb_stb_o => wb_stb, wb_cyc_o => wb_cyc, wb_ack_i => wb_ack,")
    l = l.push("      msip_i => msip_irq, mtip_i => mtip_irq")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  u_clint : entity work.clint")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst => rst,")
    l = l.push("      wb_adr => wb_adr(15 downto 0), wb_dat_i => wb_dat_o,")
    l = l.push("      wb_dat_o => clint_dat, wb_we => wb_we, wb_stb => clint_stb,")
    l = l.push("      wb_ack => clint_ack,")
    l = l.push("      msip_o => msip_irq, mtip_o => mtip_irq")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  u_plic : entity work.plic")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst => rst,")
    l = l.push("      wb_adr => wb_adr(23 downto 0), wb_dat_i => wb_dat_o,")
    l = l.push("      wb_dat_o => plic_dat, wb_we => wb_we, wb_stb => plic_stb,")
    l = l.push("      wb_ack => plic_ack,")
    l = l.push("      irq_sources(0) => uart_irq")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  u_uart : entity work.uart")
    l = l.push("    generic map (CLK_FREQ => CLK_FREQ, BAUD_RATE => BAUD_RATE)")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst => rst,")
    l = l.push("      wb_adr => wb_adr(4 downto 0), wb_dat_i => wb_dat_o(7 downto 0),")
    l = l.push("      wb_dat_o => uart_dat(7 downto 0), wb_we => wb_we,")
    l = l.push("      wb_stb => uart_stb, wb_ack => uart_ack,")
    l = l.push("      tx => uart_tx_core, rx => uart_rx, irq => uart_irq,")
    l = l.push("      debug_uart_valid => debug_uart_valid_core,")
    l = l.push("      debug_uart_byte => debug_uart_byte_core")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  u_ram : entity work.ram")
    l = l.push("    generic map (ADDR_WIDTH => RAM_ADDR_WIDTH)")
    l = l.push("    port map (")
    l = l.push("      clk => clk,")
    l = l.push("      wb_adr => wb_adr(RAM_ADDR_WIDTH - 1 downto 0),")
    l = l.push("      wb_dat_i => wb_dat_o, wb_dat_o => ram_dat,")
    l = l.push("      wb_we => wb_we, wb_sel => wb_sel,")
    l = l.push("      wb_stb => ram_stb, wb_ack => ram_ack")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  u_bootrom : entity work.bootrom")
    l = l.push("    port map (")
    l = l.push("      clk => clk,")
    l = l.push("      wb_adr => wb_adr(11 downto 0),")
    l = l.push("      wb_dat_o => bootrom_dat,")
    l = l.push("      wb_stb => bootrom_stb")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  u_wb : entity work.wb_interconnect")
    l = l.push("    port map (")
    l = l.push("      m_adr => wb_adr, m_dat_o => wb_dat_o, m_dat_i => wb_dat_i,")
    l = l.push("      m_we => wb_we, m_sel => wb_sel,")
    l = l.push("      m_stb => wb_stb, m_cyc => wb_cyc, m_ack => wb_ack,")
    l = l.push("      s0_dat => bootrom_dat, s0_stb => bootrom_stb,")
    l = l.push("      s1_dat => clint_dat,   s1_stb => clint_stb,   s1_ack => clint_ack,")
    l = l.push("      s2_dat => plic_dat,    s2_stb => plic_stb,    s2_ack => plic_ack,")
    l = l.push("      s3_dat => uart_dat,    s3_stb => uart_stb,    s3_ack => uart_ack,")
    l = l.push("      s4_dat => ram_dat,     s4_stb => ram_stb,     s4_ack => ram_ack")
    l = l.push("    );")
    l = l.push("")
    l = l.push("end architecture rtl;")
    l.join("\n")

fn generate_testbench_vhdl(prog: [u32]) -> text:
    var l: [text] = []
    l = l.push("library ieee;")
    l = l.push("use ieee.std_logic_1164.all;")
    l = l.push("use ieee.numeric_std.all;")
    l = l.push("")
    l = l.push("entity tb_soc_boot is")
    l = l.push("end entity tb_soc_boot;")
    l = l.push("")
    l = l.push("architecture sim of tb_soc_boot is")
    l = l.push("  constant CLK_PERIOD : time := 40 ns;")
    l = l.push("  signal clk        : std_logic := '0';")
    l = l.push("  signal rst_n      : std_logic := '0';")
    l = l.push("  signal uart_tx    : std_logic;")
    l = l.push("  signal uart_rx    : std_logic := '1';")
    l = l.push("  signal char_out   : std_logic_vector(7 downto 0);")
    l = l.push("  signal char_valid : std_logic;")
    l = l.push("  signal halted     : std_logic;")
    l = l.push("  signal init_we    : std_logic := '0';")
    l = l.push("  signal init_addr  : std_logic_vector(31 downto 0) := (others => '0');")
    l = l.push("  signal init_wdata : std_logic_vector(31 downto 0) := (others => '0');")
    l = l.push("  signal done       : boolean := false;")
    l = l.push("")
    val prog_len = prog.len()
    l = l.push("  type prog_t is array(0 to {prog_len - 1}) of std_logic_vector(31 downto 0);")
    l = l.push("  constant PROG : prog_t := (")
    var pi = 0
    while pi < prog_len:
        val hex = u32_to_vhdl_hex(prog[pi])
        val comma = if pi < prog_len - 1: "," else: ""
        l = l.push("    {hex}{comma}")
        pi = pi + 1
    l = l.push("  );")
    l = l.push("begin")
    l = l.push("  clk <= not clk after CLK_PERIOD/2 when not done else '0';")
    l = l.push("")
    l = l.push("  u_soc : entity work.soc_top")
    l = l.push("    generic map (RAM_ADDR_WIDTH => 17)")
    l = l.push("    port map (")
    l = l.push("      clk => clk, rst_n => rst_n,")
    l = l.push("      uart_tx => uart_tx, uart_rx => uart_rx,")
    l = l.push("      char_out => char_out, char_valid => char_valid,")
    l = l.push("      halted => halted,")
    l = l.push("      init_we => init_we, init_addr => init_addr,")
    l = l.push("      init_wdata => init_wdata")
    l = l.push("    );")
    l = l.push("")
    l = l.push("  process")
    l = l.push("    variable collected : string(1 to 256) := (others => ' ');")
    l = l.push("    variable col_len   : natural := 0;")
    l = l.push("    variable cycle     : natural := 0;")
    l = l.push("  begin")
    l = l.push("    -- Phase 1: Hold reset and load program into RAM")
    l = l.push("    rst_n <= '0';")
    l = l.push("    wait for CLK_PERIOD * 2;")
    l = l.push("    for i in PROG'range loop")
    l = l.push("      init_we    <= '1';")
    l = l.push("      init_addr  <= std_logic_vector(to_unsigned(i * 4, 32));")
    l = l.push("      init_wdata <= PROG(i);")
    l = l.push("      wait for CLK_PERIOD;")
    l = l.push("    end loop;")
    l = l.push("    init_we <= '0';")
    l = l.push("    wait for CLK_PERIOD;")
    l = l.push("")
    l = l.push("    -- Phase 2: Release reset and run")
    l = l.push("    rst_n <= '1';")
    l = l.push("    while cycle < 500 and halted = '0' loop")
    l = l.push("      wait for CLK_PERIOD;")
    l = l.push("      if char_valid = '1' then")
    l = l.push("        col_len := col_len + 1;")
    l = l.push("        collected(col_len) := character'val(to_integer(unsigned(char_out)));")
    l = l.push("      end if;")
    l = l.push("      cycle := cycle + 1;")
    l = l.push("    end loop;")
    l = l.push("")
    l = l.push("    -- Phase 3: Check results")
    l = l.push("    report \"Cycles: \" & integer'image(cycle);")
    l = l.push("    report \"Output: [\" & collected(1 to col_len) & \"]\";")
    l = l.push("    if col_len >= 8 and collected(1 to 8) = \"SimpleOS\" then")
    l = l.push("      report \"PASS: SoC boot simulation produced SimpleOS\" severity note;")
    l = l.push("    else")
    l = l.push("      report \"FAIL: expected SimpleOS, got [\" & collected(1 to col_len) & \"]\" severity failure;")
    l = l.push("    end if;")
    l = l.push("    done <= true;")
    l = l.push("    wait;")
    l = l.push("  end process;")
    l = l.push("end architecture sim;")
    l.join("\n")

# ============================================================================
# Public API — Generate All SoC VHDL Files
# ============================================================================

pub struct SocVhdlBundle:
    bootrom: text
    ram: text
    uart: text
    clint: text
    wb_interconnect: text
    mailbox: text
    soc_top: text
    testbench: text

pub fn generate_soc_vhdl_bundle() -> SocVhdlBundle:
    val prog = generate_simpleos_test_prog()
    SocVhdlBundle(
        bootrom: generate_bootrom_vhdl(),
        ram: generate_ram_vhdl(),
        uart: generate_uart_vhdl(),
        clint: generate_clint_vhdl(),
        wb_interconnect: generate_wb_interconnect_vhdl(),
        mailbox: generate_mailbox_vhdl(),
        soc_top: generate_soc_top_vhdl(),
        testbench: generate_testbench_vhdl(prog)
    )
