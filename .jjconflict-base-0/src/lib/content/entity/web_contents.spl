# WebContents: top-level browser view abstraction owning one or more RenderFrameHosts

use std.viz.entity.surface_id.{SurfaceId, FrameSinkId, LocalSurfaceId}
use std.blink.entity.paint_artifact.{PaintArtifact}
use std.skia.entity.geometry.{SkRect}

class WebContents:
    id: i32
    title: text
    url: text
    viewport: SkRect
    main_frame_surface: SurfaceId
    last_paint: Option<PaintArtifact>
    is_loading: bool

    static fn new(id: i32, viewport: SkRect) -> WebContents:
        val fsi = FrameSinkId(client_id: id, sink_id: 1)
        val lsi = LocalSurfaceId(parent_sequence_number: 1, child_sequence_number: 1)
        val sid = SurfaceId(frame_sink_id: fsi, local_surface_id: lsi)
        WebContents(
            id: id,
            title: "",
            url: "",
            viewport: viewport,
            main_frame_surface: sid,
            last_paint: None,
            is_loading: false
        )

    me navigate(url: text):
        me.url = url

    me set_title(title: text):
        me.title = title

    me update_paint(artifact: PaintArtifact):
        me.last_paint = Some(artifact)

    me loading(v: bool):
        me.is_loading = v
