"""
HTTP Server — web.http.server

Provides HttpServer, HttpRequest, HttpResponse, and HttpHandler for
building HTTP/MCP servers. Consumed by app.lms.main.

Usage:
    val server = HttpServer.localhost(port)
        .handler(fn(req: HttpRequest) -> HttpResponse:
            HttpResponse.ok().json("{\"status\":\"ok\"}"))
    server.run()
"""

use std.json.{json_parse, json_is_object, json_object_keys, json_object_get,
              json_is_string, json_to_string, json_serialize}
use std.io.driver.{IoDriver}
use std.nogc_async_mut.io.tcp_backend.{
    tcp_backend_bind, tcp_backend_close,
    tcp_backend_set_nonblocking, tcp_backend_set_nodelay
}
use std.http_server.shared.{parse_http_request, serialize_http_response}
use std.http_server.types.{HttpRequestData}

# ============================================================================
# HttpRequest
# ============================================================================

class HttpRequest:
    """An incoming HTTP request."""
    method: text
    path: text
    headers: Dict<text, text>
    body: text
    query: text

impl HttpRequest:
    static fn create(method: text, path: text, headers: Dict<text, text>,
                     body: text, query: text) -> HttpRequest:
        HttpRequest(method: method, path: path, headers: headers, body: body, query: query)

    fn get_header(name: text) -> text:
        val lower = name.lower()
        for key in self.headers.keys():
            if key.lower() == lower:
                return self.headers.get(key) ?? ""
        ""

    fn body_json() -> Dict<text, text>:
        """Parse the request body as a simple flat JSON object.

        Returns a Dict of top-level string keys and their string values.
        For full JSON support, use std.json.
        """
        parse_flat_json(self.body)

    fn content_type() -> text:
        self.get_header("content-type")

    fn is_json() -> bool:
        self.content_type().contains("application/json")

# ============================================================================
# HttpResponse
# ============================================================================

class HttpResponse:
    """An HTTP response to be sent back to the client."""
    status_code: i64
    status_text: text
    headers: Dict<text, text>
    body: text

impl HttpResponse:
    static fn new(status_code: i64, status_text: text) -> HttpResponse:
        HttpResponse(status_code: status_code, status_text: status_text,
                     headers: {}, body: "")

    static fn ok() -> HttpResponse:
        """200 OK response."""
        HttpResponse.new(200, "OK")

    static fn created() -> HttpResponse:
        """201 Created response."""
        HttpResponse.new(201, "Created")

    static fn not_found() -> HttpResponse:
        """404 Not Found response."""
        HttpResponse.new(404, "Not Found")

    static fn bad_request() -> HttpResponse:
        """400 Bad Request response."""
        HttpResponse.new(400, "Bad Request")

    static fn internal_error() -> HttpResponse:
        """500 Internal Server Error response."""
        HttpResponse.new(500, "Internal Server Error")

    me json(json_body: text) -> HttpResponse:
        """Set body and Content-Type: application/json."""
        self.body = json_body
        self.headers["Content-Type"] = "application/json"
        self.headers["Content-Length"] = "{json_body.len()}"
        self

    me text_body(body: text) -> HttpResponse:
        """Set body and Content-Type: text/plain."""
        self.body = body
        self.headers["Content-Type"] = "text/plain; charset=utf-8"
        self.headers["Content-Length"] = "{body.len()}"
        self

    me html(body: text) -> HttpResponse:
        """Set body and Content-Type: text/html."""
        self.body = body
        self.headers["Content-Type"] = "text/html; charset=utf-8"
        self.headers["Content-Length"] = "{body.len()}"
        self

    me header(name: text, value: text) -> HttpResponse:
        """Add a response header."""
        self.headers[name] = value
        self

    fn to_text() -> text:
        """Serialize to HTTP/1.1 wire format."""
        var header_lines: [text] = []
        header_lines.push("HTTP/1.1 {self.status_code} {self.status_text}")
        for key in self.headers.keys():
            header_lines.push("{key}: {self.headers.get(key) ?? \"\"}")
        header_lines.push("")
        header_lines.push(self.body)
        header_lines.join("\r\n")

# ============================================================================
# HttpHandler
# ============================================================================

type HttpHandler = fn(HttpRequest) -> HttpResponse

# ============================================================================
# HttpServer
# ============================================================================

class HttpServer:
    """A simple blocking HTTP server."""
    host: text
    port: i64
    handler_fn: HttpHandler?

impl HttpServer:
    static fn localhost(port: i64) -> HttpServer:
        """Create a server bound to localhost."""
        HttpServer(host: "127.0.0.1", port: port, handler_fn: nil)

    static fn bind(host: text, port: i64) -> HttpServer:
        """Create a server bound to the given host and port."""
        HttpServer(host: host, port: port, handler_fn: nil)

    me handler(h: HttpHandler) -> HttpServer:
        """Register the request handler function."""
        self.handler_fn = Some(h)
        self

    fn dispatch_raw(raw_request: text) -> text:
        """Parse a raw HTTP/1.1 request, run it through the registered
        handler, and serialize the response back to wire format.

        Delegates parsing/serialization to std.http_server.shared (the
        same production request parser used by the full async server and
        by EmbeddedHttpServer), so it stays correct without duplicating
        HTTP framing logic here. Pure/socket-free, so it is directly
        unit-testable without binding a real port.
        """
        val parsed = parse_http_request(raw_request)
        if not parsed.?:
            return serialize_http_response(400, "Bad Request", [("Connection", "close")])
        val request_data = parsed as HttpRequestData
        var headers: Dict<text, text> = {}
        for pair in request_data.headers:
            headers[pair.0] = pair.1
        val request = HttpRequest.create(request_data.method, request_data.path,
                                          headers, request_data.body, request_data.query)
        val handler = self.handler_fn ?? default_handler
        val response = handler(request)
        var out_headers: [(text, text)] = []
        for key in response.headers.keys():
            out_headers.push((key, response.headers.get(key) ?? ""))
        out_headers.push(("Connection", "close"))
        serialize_http_response(response.status_code, response.body, out_headers)

    fn run():
        """Start the server event loop (blocking).

        Binds to host:port, accepts connections via std.io.driver's IoDriver
        (the same completion-based I/O backend the production async server
        and EmbeddedHttpServer use), and dispatches each request through
        `dispatch_raw` to the registered handler. Single-threaded,
        connection-close-after-response (no keepalive) -- matching this
        facade's "simple blocking HTTP server" contract. Runs until the
        process is terminated.
        """
        val listen_fd = tcp_backend_bind("{self.host}:{self.port}")
        if listen_fd < 0:
            print "HttpServer: failed to bind {self.host}:{self.port}"
            return
        tcp_backend_set_nonblocking(listen_fd, true)

        val driver = IoDriver.new()
        var accept_op = driver.submit_accept(listen_fd)
        driver.flush()

        var running = true
        print "HttpServer listening on {self.host}:{self.port}"

        var op_to_fd: Dict<i64, i64> = {}
        var op_is_recv: Dict<i64, bool> = {}

        while running:
            driver.flush()
            val count = driver.poll_count(64, 50)

            var idx = 0
            while idx < count:
                val op_id = driver.poll_id(idx)
                val result = driver.poll_result(idx)

                if op_id == accept_op:
                    accept_op = driver.submit_accept(listen_fd)
                    if result >= 0:
                        val client_fd = result
                        tcp_backend_set_nonblocking(client_fd, true)
                        tcp_backend_set_nodelay(client_fd, true)
                        val recv_op = driver.submit_recv(client_fd, 8192)
                        op_to_fd[recv_op] = client_fd
                        op_is_recv[recv_op] = true
                else:
                    val fd_opt = op_to_fd.get(op_id)
                    if fd_opt.?:
                        val fd = fd_opt as i64
                        val is_recv = op_is_recv.get(op_id) ?? false
                        op_to_fd.remove(op_id)
                        op_is_recv.remove(op_id)
                        if is_recv:
                            if result <= 0:
                                tcp_backend_close(fd)
                            else:
                                val data = driver.poll_data(idx)
                                val response_text = self.dispatch_raw(data)
                                val send_op = driver.submit_send(fd, response_text)
                                op_to_fd[send_op] = fd
                                op_is_recv[send_op] = false
                        else:
                            tcp_backend_close(fd)
                idx = idx + 1

        tcp_backend_close(listen_fd)
        driver.close()

# ============================================================================
# Internal helpers
# ============================================================================

fn default_handler(req: HttpRequest) -> HttpResponse:
    HttpResponse.not_found().json("{\"error\":\"No handler registered\"}")

fn parse_flat_json(json: text) -> Dict<text, text>:
    """Parse a flat JSON object {"k":"v",...} into Dict<text,text>.

    Delegates to the shared std.json parser instead of a naive comma-split
    (the old split-based version broke on commas inside string values, e.g.
    {"a":"x,y"}). Non-string values (numbers, booleans, null, nested
    objects/arrays) are converted to their JSON text form rather than
    dropped -- callers needing full nested JSON should use std.json directly.
    """
    var result: Dict<text, text> = {}
    val parsed = json_parse(json)
    if not json_is_object(parsed):
        return result
    for key in json_object_keys(parsed):
        val value = json_object_get(parsed, key)
        if json_is_string(value):
            result[key] = json_to_string(value) as text
        else:
            result[key] = json_serialize(value)
    result
