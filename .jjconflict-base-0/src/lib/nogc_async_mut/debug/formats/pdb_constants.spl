# PDB/CodeView Constants
# Stream indices, CodeView leaf types, and symbol kind constants from the PDB specification.

# ============================================================================
# MSF Magic
# ============================================================================

val MSF_MAGIC: text = "Microsoft C/C++ MSF 7.00\r\n\x1aDS\x00\x00\x00"
val MSF_MAGIC_LEN: i64 = 32

# ============================================================================
# PDB Stream Indices
# ============================================================================

val PDB_STREAM_OLD_DIRECTORY: i64 = 0
val PDB_STREAM_PDB: i64 = 1
val PDB_STREAM_TPI: i64 = 2
val PDB_STREAM_DBI: i64 = 3
val PDB_STREAM_IPI: i64 = 4

# ============================================================================
# DBI Stream Constants
# ============================================================================

val DBI_HEADER_SIZE: i64 = 64

# ============================================================================
# CodeView Leaf Types (common ones for type records)
# ============================================================================

val LF_MODIFIER: i64 = 0x1001
val LF_POINTER: i64 = 0x1002
val LF_PROCEDURE: i64 = 0x1008
val LF_ARGLIST: i64 = 0x1201
val LF_FIELDLIST: i64 = 0x1203
val LF_BITFIELD: i64 = 0x1205
val LF_ARRAY: i64 = 0x1503
val LF_CLASS: i64 = 0x1504
val LF_STRUCTURE: i64 = 0x1505
val LF_UNION: i64 = 0x1506
val LF_ENUM: i64 = 0x1507
val LF_MEMBER: i64 = 0x150d
val LF_STMEMBER: i64 = 0x150e
val LF_METHOD: i64 = 0x150f
val LF_ONEMETHOD: i64 = 0x1511
val LF_ENUMERATE: i64 = 0x1502
val LF_NESTTYPE: i64 = 0x1510
val LF_FUNC_ID: i64 = 0x1601
val LF_MFUNC_ID: i64 = 0x1602
val LF_BUILDINFO: i64 = 0x1603
val LF_SUBSTR_LIST: i64 = 0x1604
val LF_STRING_ID: i64 = 0x1605
val LF_UDT_SRC_LINE: i64 = 0x1606
val LF_UDT_MOD_SRC_LINE: i64 = 0x1607

