# Timer - Deadline-based async timer futures
#
# Uses current_time_ms (std.nogc_sync_mut.io.time_ops) — no new externs.
# timer_new(duration_ms) -> Future<()>: Ready when now >= deadline.
# timeout_with_deadline(future, ms) -> Future<Result<text, text>>:
#   Err("timed out") once deadline passes while inner is Pending.

use nogc_async_mut.async.poll.{Poll}
use nogc_async_mut.async.future.{Future}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}

# ============================================================
# TimerFuture
# ============================================================

class TimerFuture:
    """A future that becomes Ready(()) once the wall-clock deadline passes.

    deadline_ms: absolute epoch milliseconds (current_time_ms() + duration).

    Example:
        val f = timer_new(0)   # 0ms -- immediately ready on first poll
        val p = f.poll()       # Poll.Ready(())
    """
    deadline_ms: i64

fn timer_new(duration_ms: i64) -> TimerFuture:
    """Create a timer future that fires after duration_ms milliseconds.

    Args:
        duration_ms: How many ms from now until the timer fires.

    Returns:
        TimerFuture ready when now >= deadline.
    """
    TimerFuture(deadline_ms: current_time_ms() + duration_ms)

impl TimerFuture:
    fn poll() -> Poll<()>:
        """Poll the timer.

        Returns Ready(()) when now >= deadline, Pending otherwise.
        """
        if current_time_ms() >= self.deadline_ms:
            Poll.Ready(())
        else:
            Poll.Pending

    fn as_future() -> Future<()>:
        """Convert to a Future<()> using a single poll-point snapshot.

        If the deadline has already passed, returns an immediately-ready
        future; otherwise returns a pending future.
        """
        val p = self.poll()
        match p:
            case Poll.Ready(_): Future.from_value(())
            case Poll.Pending: Future.pending<()>()

# ============================================================
# timeout_with_deadline
# ============================================================

fn timeout_with_deadline(inner: Future<text>, duration_ms: i64) -> Future<text>:
    """Race inner future against a deadline.

    Returns a Future that resolves to:
    - the inner value (as text) if inner is Ready before deadline, or
    - "timed out" if the deadline passes while inner is Pending.

    Cooperative single-pass model: polls inner once, checks deadline once.

    Args:
        inner:       Future<text> to race against the deadline.
        duration_ms: Timeout in milliseconds from now.

    Returns:
        Future<text> — inner value or "timed out".
    """
    val deadline_ms = current_time_ms() + duration_ms
    val p = inner.poll()
    match p:
        case Poll.Ready(v):
            Future.from_value(v)
        case Poll.Pending:
            if current_time_ms() >= deadline_ms:
                Future.from_value("timed out")
            else:
                Future.pending<text>()
