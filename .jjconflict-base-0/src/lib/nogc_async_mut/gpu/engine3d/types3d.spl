"""
# No-GC Async 3D render types

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine3d.types3d.{
    Vertex3D, vertex3d, vertex3d_pos, vertex3d_pos_color, vertex3d_pos_normal,
    Material3DParams, material_unlit, material_phong, material_pbr, LightParams3D,
    light_directional, light_point, light_spot, RenderStats3D, render_stats3d_new, CULL_NONE,
    CULL_BACK, CULL_FRONT, BLEND_OPAQUE, BLEND_ALPHA, BLEND_ADDITIVE, MATERIAL_UNLIT,
    MATERIAL_PHONG, MATERIAL_PBR, LIGHT_DIRECTIONAL, LIGHT_POINT, LIGHT_SPOT, mat4_identity,
    mat4_translate, mat4_scale, mat4_rotate_x, mat4_rotate_y, mat4_rotate_z, mat4_mul,
    mat4_transform_point, mat4_transform_dir, mat4_perspective, mat4_ortho, mat4_look_at,
    vec3_dot, vec3_length, vec3_normalize, vec3_cross, color3d_r, color3d_g, color3d_b,
    color3d_a, color3d_pack, color3d_pack_rgb, _sin, _cos, _tan, _sqrt
}
