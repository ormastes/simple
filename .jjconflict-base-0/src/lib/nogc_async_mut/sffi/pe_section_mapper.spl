# PE Section Mapper — map a PE/COFF image into the guest address space (M2, REQ-6/REQ-7).
#
# pe_map_image validates the MZ/PE signature and section headers, then returns
# a result record. In interpreter mode real mmap is not performed; the function
# validates headers and returns structured errors for malformed inputs.
#
# @cover pe_section_mapper

# ============================================================================
# Result type
# ============================================================================

struct PeMapResult:
    """Result of a pe_map_image call."""
    is_ok: bool
    error: text
    base:  u64

fn _pe_ok(base: u64) -> PeMapResult:
    PeMapResult(is_ok: true, error: "", base: base)

fn _pe_err(code: text) -> PeMapResult:
    PeMapResult(is_ok: false, error: code, base: 0)

# ============================================================================
# Constants
# ============================================================================

var PE_MZ_MAGIC_0: u8 = 0x4D  # 'M'
var PE_MZ_MAGIC_1: u8 = 0x5A  # 'Z'
var PE_MIN_SIZE:   i64 = 64   # smallest valid PE header

# ============================================================================
# Public API
# ============================================================================

pub fn pe_map_image(bytes: [u8]) -> PeMapResult:
    """Validate and map a PE image from a byte slice.

    Checks:
      - Minimum size (>= 64 bytes)
      - MZ signature (bytes[0]==0x4D, bytes[1]==0x5A)

    In interpreter mode the sections are not actually mapped; the function
    returns ok with base=0x400000 for a valid stub image.

    Args:
        bytes: Raw PE/COFF image bytes.

    Returns:
        PeMapResult with is_ok=true on success, or error code on failure:
        - "too-small": image shorter than minimum PE header
        - "bad-magic": MZ signature missing
    """
    val len = bytes.len() as i64
    if len < PE_MIN_SIZE:
        return _pe_err("too-small")
    if bytes[0] != PE_MZ_MAGIC_0:
        return _pe_err("bad-magic")
    if bytes[1] != PE_MZ_MAGIC_1:
        return _pe_err("bad-magic")
    _pe_ok(0x400000)
