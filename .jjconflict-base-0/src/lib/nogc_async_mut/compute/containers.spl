@no_gc

# containers — generic CPU/GPU-usable container types for std.compute (libcu++ parity).
#   Span<T>          — non-owning view over an array slice
#   FixedArray<T>    — fixed-capacity buffer
#   InplaceVector<T> — bounded push vector (no heap growth)

class Span<T>:
    data: [T]
    start: i64
    count: i64

    static fn of(data: [T]) -> Span<T>:
        Span(data: data, start: 0, count: data.len())

    static fn slice(data: [T], start: i64, count: i64) -> Span<T>:
        Span(data: data, start: start, count: count)

    fn get(i: i64) -> T:
        self.data[self.start + i]

    fn len() -> i64:
        self.count

    fn is_empty() -> bool:
        self.count == 0

    fn first() -> T:
        self.data[self.start]

    fn last() -> T:
        self.data[self.start + self.count - 1]

class FixedArray<T>:
    items: [T]
    cap: i64

    static fn filled(value: T, n: i64) -> FixedArray<T>:
        FixedArray(items: [for i in 0..n: value], cap: n)

    fn get(i: i64) -> T:
        self.items[i]

    me set(i: i64, v: T):
        self.items[i] = v

    fn len() -> i64:
        self.cap

class InplaceVector<T>:
    items: [T]
    cap: i64
    count: i64

    # `seed` only types the backing array; count starts at 0.
    static fn with_cap(seed: T, cap: i64) -> InplaceVector<T>:
        InplaceVector(items: [for i in 0..cap: seed], cap: cap, count: 0)

    me push(v: T) -> bool:
        if self.count >= self.cap:
            return false
        self.items[self.count] = v
        self.count = self.count + 1
        return true

    fn get(i: i64) -> T:
        self.items[i]

    fn len() -> i64:
        self.count

    fn is_full() -> bool:
        self.count >= self.cap

    me clear():
        self.count = 0

export Span, FixedArray, InplaceVector
