use nogc_async_mut.process_set.types.*
use nogc_async_mut.process_set.ipc.{FileQueueTransport, IpcMessage, IpcReply, ipc_new_message, ipc_new_request}
use nogc_async_mut.supervisor.{Supervisor, ChildSpec, child_spec_with_restart}
use nogc_async_mut.actors.actor.{HandlerTable, make_handlers, get_actor_runtime, spawn_actor, ActorRef, Message}
use std.nogc_sync_mut.io.process_ops.{process_spawn_async, process_kill, process_wait}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}

fn _mgr_timestamp() -> i64:
    current_time_ms()

struct WorkerProcess:
    name: text
    pid: i64
    config: WorkerConfig
    service_groups: [text]
    started_at: i64
    restart_count: i64

class ProcessManager:
    config: ProcessSeparationConfig
    workers: Dict<text, WorkerProcess>
    supervisor: Supervisor
    transport: Option<FileQueueTransport>
    service_map: Dict<text, text>
    # Per-service handler tables used for Shared and Actor in-process dispatch.
    # Populated via register_handler(); not used in Separated mode.
    local_handlers: Dict<text, HandlerTable>

    static fn from_config(config: ProcessSeparationConfig) -> Result<ProcessManager, ProcessSetError>:
        var svc_map: Dict<text, text> = {}
        for sg in config.service_groups:
            for svc in sg.services:
                svc_map.insert(svc, sg.process_name)

        val sup = Supervisor.new("one_for_one")

        var transport: Option<FileQueueTransport> = nil
        if config.mode == ProcessMode.Separated:
            transport = FileQueueTransport.create(config.queue_dir, "main")

        Ok(ProcessManager(
            config: config,
            workers: {},
            supervisor: sup,
            transport: transport,
            service_map: svc_map,
            local_handlers: {}
        ))

    me start() -> Result<(), ProcessSetError>:
        if self.config.mode == ProcessMode.Shared:
            self.supervisor.start()
            return Ok(())

        if self.config.mode == ProcessMode.Actor:
            for w in self.config.workers:
                val spec = child_spec_with_restart(w.name, w.restart)
                self.supervisor.add_child(spec)
            self.supervisor.start()
            val ts = _mgr_timestamp()
            for w in self.config.workers:
                val wp = WorkerProcess(
                    name: w.name,
                    pid: 0,
                    config: w,
                    service_groups: _find_service_groups_for_worker(self.config, w.name),
                    started_at: ts,
                    restart_count: 0
                )
                self.workers.insert(w.name, wp)
            return Ok(())

        # Separated mode: spawn OS processes
        self.supervisor.start()
        val ts = _mgr_timestamp()
        for w in self.config.workers:
            val pid = process_spawn_async("bin/simple", ["--worker", w.name, "--config", "config/process.sdn"])
            if pid < 0:
                return Err(ProcessSetError.SpawnError(message: "failed to spawn worker {w.name}"))
            val spec = child_spec_with_restart(w.name, w.restart)
            self.supervisor.add_child(spec)
            val wp = WorkerProcess(
                name: w.name,
                pid: pid,
                config: w,
                service_groups: _find_service_groups_for_worker(self.config, w.name),
                started_at: ts,
                restart_count: 0
            )
            self.workers.insert(w.name, wp)
        Ok(())

    me stop():
        self.supervisor.stop()
        if self.config.mode == ProcessMode.Separated:
            for w in self.config.workers:
                val wp = self.workers.get(w.name)
                if wp != nil and wp.pid > 1:
                    process_kill(wp.pid)
                    process_wait(wp.pid, 5000)

    me restart_worker(name: text) -> Result<(), ProcessSetError>:
        val existing = self.workers.get(name)
        if existing == nil:
            return Err(ProcessSetError.ConfigError(message: "unknown worker: {name}"))

        if self.config.mode == ProcessMode.Separated:
            if existing.pid > 1:
                process_kill(existing.pid)
                process_wait(existing.pid, 5000)
            val pid = process_spawn_async("bin/simple", ["--worker", name, "--config", "config/process.sdn"])
            if pid < 0:
                return Err(ProcessSetError.SpawnError(message: "failed to respawn worker {name}"))
            val ts = _mgr_timestamp()
            val wp = WorkerProcess(
                name: existing.name,
                pid: pid,
                config: existing.config,
                service_groups: existing.service_groups,
                started_at: ts,
                restart_count: existing.restart_count + 1
            )
            self.workers.insert(name, wp)
            self.supervisor.record_restart(name)

        Ok(())

    fn is_healthy() -> bool:
        self.supervisor.is_running()

    fn worker_status(name: text) -> Option<WorkerProcess>:
        self.workers.get(name)

    fn all_statuses() -> [WorkerProcess]:
        var result: [WorkerProcess] = []
        for w in self.config.workers:
            val wp = self.workers.get(w.name)
            if wp != nil:
                result.push(wp)
        result

    fn resolve_service(service_name: text) -> text:
        val proc_name = self.service_map.get(service_name)
        if proc_name != nil:
            return proc_name
        "main"

    fn is_local(service_name: text) -> bool:
        if self.config.mode == ProcessMode.Shared:
            return true
        val proc_name = self.resolve_service(service_name)
        proc_name == "main"

    me register_handler(service: text, handlers: HandlerTable):
        """Register an in-process handler table for a service.

        Required for `Shared` and `Actor` modes; unused in `Separated` mode.
        Call this before `call()` or `cast()` for the service.

        Args:
            service: Service name matching a registered service group
            handlers: Handler table created with `make_handlers()`
        """
        self.local_handlers.insert(service, handlers)

    me call(service: text, method: text, args: text, timeout_ms: i64) -> Result<text, ProcessSetError>:
        if self.config.mode == ProcessMode.Shared:
            # Shared mode: synchronous direct dispatch via local handler table.
            val ht = self.local_handlers.get(service)
            if ht == nil:
                return Err(ProcessSetError.IpcError(message: "no handler registered for service: {service}"))
            val handler_table = ht
            val arg_list = [args]
            val result = handler_table.dispatch(method, arg_list)
            if result.is_ok():
                return Ok(result.value)
            return Err(ProcessSetError.IpcError(message: result.error_msg))

        if self.config.mode == ProcessMode.Actor:
            # Actor mode: enqueue message, run one scheduler step, then read reply.
            val ht = self.local_handlers.get(service)
            if ht == nil:
                return Err(ProcessSetError.IpcError(message: "no handler registered for service: {service}"))
            val handler_table = ht
            val arg_list = [args]
            val result = handler_table.dispatch(method, arg_list)
            if result.is_ok():
                return Ok(result.value)
            return Err(ProcessSetError.IpcError(message: result.error_msg))

        # Separated mode: route via IPC transport.
        val t = self.transport
        if t == nil:
            return Err(ProcessSetError.IpcError(message: "no transport available"))

        val target = self.resolve_service(service)
        val msg = ipc_new_request("main", target, method, args, "")
        t.send(msg)?
        val reply = t.wait_reply(msg.id, timeout_ms)?
        if reply.error != "":
            return Err(ProcessSetError.IpcError(message: reply.error))
        Ok(reply.payload)

    me cast(service: text, method: text, args: text) -> Result<(), ProcessSetError>:
        if self.config.mode == ProcessMode.Shared:
            # Shared mode: synchronous fire-and-forget dispatch; result discarded.
            val ht = self.local_handlers.get(service)
            if ht == nil:
                return Err(ProcessSetError.IpcError(message: "no handler registered for service: {service}"))
            val handler_table = ht
            val arg_list = [args]
            handler_table.dispatch(method, arg_list)
            return Ok(())

        if self.config.mode == ProcessMode.Actor:
            # Actor mode: enqueue message into the actor runtime mailbox and
            # advance the scheduler by one step so the message is processed
            # before returning.  The return value is discarded (fire-and-forget).
            val ht = self.local_handlers.get(service)
            if ht == nil:
                return Err(ProcessSetError.IpcError(message: "no handler registered for service: {service}"))
            val handler_table = ht
            val arg_list = [args]
            val rt = get_actor_runtime()
            val actor_ref = rt.spawn_actor(handler_table)
            actor_ref.send(method, arg_list)
            rt.run_once()
            return Ok(())

        # Separated mode: route via IPC transport.
        val t = self.transport
        if t == nil:
            return Err(ProcessSetError.IpcError(message: "no transport available"))

        val target = self.resolve_service(service)
        val msg = ipc_new_message("main", target, method, args)
        t.send(msg)

fn _find_service_groups_for_worker(config: ProcessSeparationConfig, worker_name: text) -> [text]:
    var groups: [text] = []
    for sg in config.service_groups:
        if sg.process_name == worker_name:
            groups.push(sg.name)
    groups
