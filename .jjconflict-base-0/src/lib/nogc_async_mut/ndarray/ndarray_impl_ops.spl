use std.common.science_math.ndarray.*
use std.ndarray.ndarray_simd.*

fn ndarray_flatten(arr: NDArray) -> NDArray:
    match arr.dtype:
        case DType.F32:
            var out: [Float32] = []
            var i = 0
            while i < arr.len().value:
                out.push(arr.flat_f32(i))
                i = i + 1
            make_f32_array(out, Shape.new([Index.new(out.len())]))
        case DType.F64:
            var out: [Float64] = []
            var i = 0
            while i < arr.len().value:
                out.push(arr.flat_f64(i))
                i = i + 1
            make_f64_array(out, Shape.new([Index.new(out.len())]))
        case DType.I64:
            var out: [Int64] = []
            var i = 0
            while i < arr.len().value:
                out.push(arr.flat_i64(i))
                i = i + 1
            make_i64_array(out, Shape.new([Index.new(out.len())]))
        case DType.Bool:
            var out: [Bool] = []
            var i = 0
            while i < arr.len().value:
                out.push(arr.flat_bool(i))
                i = i + 1
            make_bool_array(out, Shape.new([Index.new(out.len())]))

fn ndarray_to_contiguous(arr: NDArray) -> NDArray:
    match arr.dtype:
        case DType.F32:
            var out: [Float32] = []
            var i = 0
            while i < arr.len().value:
                out.push(arr.flat_f32(i))
                i = i + 1
            make_f32_array(out, arr.shape)
        case DType.F64:
            var out: [Float64] = []
            var i = 0
            while i < arr.len().value:
                out.push(arr.flat_f64(i))
                i = i + 1
            make_f64_array(out, arr.shape)
        case DType.I64:
            arr
        case DType.Bool:
            arr

fn ndarray_to_csv_text(arr: NDArray) -> Result<text, NdarrayError>:
    if arr.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if arr.shape.dims.len() == 1:
        var cells: [text] = []
        var i = 0
        while i < arr.len().value:
            cells.push("{arr.flat_f64(i).value}")
            i = i + 1
        return Ok(cells.join(","))
    if arr.shape.dims.len() != 2:
        return Err(NdarrayError.InvalidShape)
    var lines: [text] = []
    var row = 0
    while row < arr.rows().value:
        var cells: [text] = []
        var col = 0
        while col < arr.cols().value:
            cells.push("{arr.get_f64_at([Index.new(row), Index.new(col)]).value}")
            col = col + 1
        lines.push(cells.join(","))
        row = row + 1
    Ok(lines.join("\n"))

fn ndarray_try_gather(arr: NDArray, idx: NDArray) -> Result<NDArray, NdarrayError>:
    if idx.dtype != DType.I64:
        return Err(NdarrayError.UnsupportedDType)
    match arr.dtype:
        case DType.F32:
            var out: [Float32] = []
            var i = 0
            while i < idx.data_i64.len():
                val pos = idx.data_i64[i].value
                if pos < 0 or pos >= arr.len().value:
                    return Err(NdarrayError.IndexOutOfBounds)
                out.push(arr.flat_f32(pos))
                i = i + 1
            Ok(make_f32_array(out, Shape.new([Index.new(out.len())])))
        case DType.F64:
            var out: [Float64] = []
            var i = 0
            while i < idx.data_i64.len():
                val pos = idx.data_i64[i].value
                if pos < 0 or pos >= arr.len().value:
                    return Err(NdarrayError.IndexOutOfBounds)
                out.push(arr.flat_f64(pos))
                i = i + 1
            Ok(make_f64_array(out, Shape.new([Index.new(out.len())])))
        case DType.I64:
            var out: [Int64] = []
            var i = 0
            while i < idx.data_i64.len():
                val pos = idx.data_i64[i].value
                if pos < 0 or pos >= arr.len().value:
                    return Err(NdarrayError.IndexOutOfBounds)
                out.push(arr.flat_i64(pos))
                i = i + 1
            Ok(make_i64_array(out, Shape.new([Index.new(out.len())])))
        case DType.Bool:
            var out: [Bool] = []
            var i = 0
            while i < idx.data_i64.len():
                val pos = idx.data_i64[i].value
                if pos < 0 or pos >= arr.len().value:
                    return Err(NdarrayError.IndexOutOfBounds)
                out.push(arr.flat_bool(pos))
                i = i + 1
            Ok(make_bool_array(out, Shape.new([Index.new(out.len())])))

fn ndarray_try_mask(arr: NDArray, mask_values: NDArray) -> Result<NDArray, NdarrayError>:
    if mask_values.dtype != DType.Bool or mask_values.len().value != arr.len().value:
        return Err(NdarrayError.ShapeMismatch)
    match arr.dtype:
        case DType.F32:
            var out: [Float32] = []
            var i = 0
            while i < arr.len().value:
                if mask_values.flat_bool(i).value:
                    out.push(arr.flat_f32(i))
                i = i + 1
            Ok(make_f32_array(out, Shape.new([Index.new(out.len())])))
        case DType.F64:
            var out: [Float64] = []
            var i = 0
            while i < arr.len().value:
                if mask_values.flat_bool(i).value:
                    out.push(arr.flat_f64(i))
                i = i + 1
            Ok(make_f64_array(out, Shape.new([Index.new(out.len())])))
        case DType.I64:
            var out: [Int64] = []
            var i = 0
            while i < arr.len().value:
                if mask_values.flat_bool(i).value:
                    out.push(arr.flat_i64(i))
                i = i + 1
            Ok(make_i64_array(out, Shape.new([Index.new(out.len())])))
        case DType.Bool:
            var out: [Bool] = []
            var i = 0
            while i < arr.len().value:
                if mask_values.flat_bool(i).value:
                    out.push(arr.flat_bool(i))
                i = i + 1
            Ok(make_bool_array(out, Shape.new([Index.new(out.len())])))

fn ndarray_try_argsort(arr: NDArray) -> Result<NDArray, NdarrayError>:
    if arr.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if arr.dtype == DType.Bool:
        return Err(NdarrayError.UnsupportedDType)
    var indices: [Int64] = []
    var i = 0
    while i < arr.len().value:
        indices.push(Int64.new(i))
        i = i + 1
    i = 1
    while i < indices.len():
        val current = indices[i]
        var j = i
        while j > 0 and ndarray_sort_value_less(arr, current.value, indices[j - 1].value):
            indices[j] = indices[j - 1]
            j = j - 1
        indices[j] = current
        i = i + 1
    Ok(make_i64_array(indices, Shape.new([Index.new(indices.len())])))

fn ndarray_sort_value_less(arr: NDArray, left_index: i64, right_index: i64) -> bool:
    match arr.dtype:
        case DType.F32:
            arr.flat_f32(left_index).value < arr.flat_f32(right_index).value
        case DType.F64:
            arr.flat_f64(left_index).value < arr.flat_f64(right_index).value
        case DType.I64:
            arr.flat_i64(left_index).value < arr.flat_i64(right_index).value
        case DType.Bool:
            false

fn ndarray_try_clip(arr: NDArray, minimum: Float64, maximum: Float64) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if minimum.value > maximum.value:
        return Err(NdarrayError.InvalidShape)
    var out: [Float64] = []
    var i = 0
    while i < arr.len().value:
        var value = arr.flat_f64(i).value
        if value < minimum.value:
            value = minimum.value
        if value > maximum.value:
            value = maximum.value
        out.push(Float64.new(value))
        i = i + 1
    Ok(make_f64_array(out, arr.shape))

fn ndarray_scalar_f64(arr: NDArray, scalar: Float64, op: text) -> NDArray:
    if should_use_simd_scalar_f64x4(arr):
        return simd_scalar_f64x4(arr, scalar, op)
    var out: [Float64] = []
    var i = 0
    while i < arr.len().value:
        val value = arr.flat_f64(i).value
        val next = if op == "add":
            value + scalar.value
        elif op == "sub":
            value - scalar.value
        elif op == "mul":
            value * scalar.value
        else:
            value / scalar.value
        out.push(Float64.new(next))
        i = i + 1
    make_f64_array(out, arr.shape)

fn ndarray_try_scalar_f32(arr: NDArray, scalar: Float32, op: text) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F32:
        return Err(NdarrayError.UnsupportedDType)
    if should_use_simd_scalar_f32x4(arr, op):
        return Ok(simd_scalar_f32x4(arr, scalar, op))
    val scalar_value = scalar.value
    val is_add = op == "add"
    val is_sub = op == "sub"
    val is_mul = op == "mul"
    var out: [Float32] = []
    var i = 0
    while i < arr.len().value:
        val value = arr.flat_f32(i).value
        val widened = value as f64
        val widened_scalar = scalar_value as f64
        val next = if is_add:
            widened + widened_scalar
        elif is_sub:
            widened - widened_scalar
        elif is_mul:
            widened * widened_scalar
        else:
            widened / widened_scalar
        out.push(Float32.new(next as f32))
        i = i + 1
    Ok(make_f32_array(out, arr.shape))

fn ndarray_try_unary_f64(arr: NDArray, op: text) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if should_use_simd_unary_f64x4(arr, op):
        return Ok(simd_unary_f64x4(arr, op))
    var out: [Float64] = []
    var i = 0
    while i < arr.len().value:
        val value = arr.flat_f64(i).value
        val next = if op == "abs":
            if value < 0.0:
                -value
            else:
                value
        elif op == "square":
            value * value
        elif op == "sqrt":
            ndarray_sqrt_f64(value)
        elif op == "relu":
            if value < 0.0:
                0.0
            else:
                value
        else:
            -value
        out.push(Float64.new(next))
        i = i + 1
    Ok(make_f64_array(out, arr.shape))

fn ndarray_try_unary_f32(arr: NDArray, op: text) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F32:
        return Err(NdarrayError.UnsupportedDType)
    if should_use_simd_unary_f32x4(arr, op):
        return Ok(simd_unary_f32x4(arr, op))
    var out: [Float32] = []
    var i = 0
    while i < arr.len().value:
        val value = arr.flat_f32(i).value
        val next = if op == "abs":
            if value < 0.0:
                -value
            else:
                value
        elif op == "square":
            value * value
        else:
            -value
        out.push(Float32.new(next))
        i = i + 1
    Ok(make_f32_array(out, arr.shape))

fn ndarray_try_binary_f64(arr: NDArray, other: NDArray, op: text) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F64 or other.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if should_use_simd_binary_f64x4(arr, other):
        return Ok(simd_binary_f64x4(arr, other, op))
    val plan = make_broadcast_plan(arr.shape, arr.strides, other.shape, other.strides)?
    var out: [Float64] = []
    var i = 0
    while i < plan.shape.numel().value:
        val coords = unravel_index(i, plan.shape)
        val left_pos = resolve_offset(plan.shape, plan.left, arr.offset, coords)
        val right_pos = resolve_offset(plan.shape, plan.right, other.offset, coords)
        val left = arr.data_f64[left_pos.value].value
        val right = other.data_f64[right_pos.value].value
        val next = if op == "add":
            left + right
        elif op == "sub":
            left - right
        elif op == "mul":
            left * right
        else:
            left / right
        out.push(Float64.new(next))
        i = i + 1
    Ok(make_f64_array(out, plan.shape))

fn ndarray_try_binary_f32(arr: NDArray, other: NDArray, op: text) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F32 or other.dtype != DType.F32:
        return Err(NdarrayError.UnsupportedDType)
    if should_use_simd_binary_f32x4(arr, other):
        return Ok(simd_binary_f32x4(arr, other, op))
    val plan = make_broadcast_plan(arr.shape, arr.strides, other.shape, other.strides)?
    var out: [Float32] = []
    var i = 0
    while i < plan.shape.numel().value:
        val coords = unravel_index(i, plan.shape)
        val left_pos = resolve_offset(plan.shape, plan.left, arr.offset, coords)
        val right_pos = resolve_offset(plan.shape, plan.right, other.offset, coords)
        val left = arr.data_f32[left_pos.value].value
        val right = other.data_f32[right_pos.value].value
        val next = if op == "add":
            left + right
        elif op == "sub":
            left - right
        elif op == "mul":
            left * right
        else:
            left / right
        out.push(Float32.new(next))
        i = i + 1
    Ok(make_f32_array(out, plan.shape))

fn ndarray_try_sum_axis(arr: NDArray, axis: Axis) -> Result<NDArray, NdarrayError>:
    if arr.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if arr.shape.dims.len() != 2:
        return Err(NdarrayError.InvalidShape)
    val normalized = normalize_axis(axis, arr.shape.dims.len())?
    val rows = arr.rows().value
    val cols = arr.cols().value
    if normalized.value == 0:
        var out: [Float64] = []
        var col = 0
        while col < cols:
            var total = 0.0
            var row = 0
            while row < rows:
                total = total + arr.get_f64_at([Index.new(row), Index.new(col)]).value
                row = row + 1
            out.push(Float64.new(total))
            col = col + 1
        return Ok(make_f64_array(out, Shape.new([Index.new(cols)])))
    var out: [Float64] = []
    var row = 0
    while row < rows:
        var total = 0.0
        var col = 0
        while col < cols:
            total = total + arr.get_f64_at([Index.new(row), Index.new(col)]).value
            col = col + 1
        out.push(Float64.new(total))
        row = row + 1
    Ok(make_f64_array(out, Shape.new([Index.new(rows)])))
