# SPipe process harness shared types.

struct HarnessOptions:
    provider: text
    feature: text
    event: text
    model: text
    session_id: text
    raw_payload: text
    require_approval: bool

struct GateDecision:
    allowed: bool
    exit_code: i64
    reason: text

struct HudSnapshot:
    model: text
    jj_worktree: text
    commit_id: text
    hours_remaining: text
    week_remaining: text
    goal: text

struct HookDeploySnippet:
    provider: text
    path: text
    content: text

