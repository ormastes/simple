"""
# No-GC Async Platform Helpers

Compatibility facade over the no-GC sync platform backend. Host platform
detection and path helper operations are synchronous runtime calls, so the async
family reuses the shared no-GC declaration owner.
"""

export use std.nogc_sync_mut.platform.{
    shell_output_trim, is_windows_env,
    get_host_os, get_host_arch,
    is_windows, is_unix, is_macos, is_linux,
    dir_sep, path_sep, exe_ext, lib_ext,
    normalize_path, is_absolute, is_absolute_path, join_path, resolve_command,
    home_dir
}
