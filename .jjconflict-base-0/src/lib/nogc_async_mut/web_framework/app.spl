"""
# Web Application

Main entry point for a SimpleWeb application. Wires together
the HTTP server, router, database, session store, and dispatcher.

## Usage

```simple
val app = WebApp.create("config/app.sdn")?
app = app.mount_routes("config/routes.sdn")?
app = app.register_action("home", "index", home_index)
app = app.register_action("posts", "index", posts_index)
app.start()?
app.wait()
```

## SDN Config Format

```sdn
app:
  name: "my-app"
  env: "development"
  secret_key: "change-me-in-production"
  listen_addr: "0.0.0.0:8080"
  worker_count: 4
  db_path: "data/app.db"
  session_store_type: "db"
  session_ttl: 86400
  session_cookie_name: "sid"
  assets_path: "public"
  assets_fingerprint: false
```
"""

use std.http_server.types.{
    ServerConfig, LocationConfig, HttpRequestData, HttpResponseData,
    default_server_config
}
use std.http_server.handler.{HandlerRegistry, create_default_registry}
use std.http_server.response.{build_error}
use std.database.sql.connection.{Database}
use std.web_framework.router.{WebRouter}
use std.web_framework.dispatcher.{AppDispatcher, register_app_handler}
use std.web_framework.session.{SessionStore}
use std.web_framework.controller.{ControllerContext}

# ============================================================================
# App Configuration
# ============================================================================

class AppConfig:
    """Web application configuration."""
    name: text
    env: text
    secret_key: text
    listen_addr: text
    worker_count: i64
    db_path: text
    session_store_type: text
    session_ttl: i64
    session_cookie_name: text
    assets_path: text
    assets_fingerprint: bool

fn default_app_config() -> AppConfig:
    """Create AppConfig with sensible defaults."""
    AppConfig(
        name: "SimpleWeb",
        env: "development",
        secret_key: "change-me-in-production",
        listen_addr: "0.0.0.0:8080",
        worker_count: 4,
        db_path: "data/app.db",
        session_store_type: "db",
        session_ttl: 86400,
        session_cookie_name: "sid",
        assets_path: "public",
        assets_fingerprint: false
    )

# ============================================================================
# WebApp
# ============================================================================

class WebApp:
    """Main web application entry point.

    Composes the HTTP server, router, database, sessions, and
    dispatcher into a single cohesive application object.
    """
    config: AppConfig
    router: WebRouter
    dispatcher: AppDispatcher
    db: Database?
    session_store: SessionStore?
    registry: HandlerRegistry
    is_running: bool

impl WebApp:
    static fn create(config_path: text) -> Result<WebApp, text>:
        """Create a WebApp from an SDN configuration file.

        Args:
            config_path: Path to the app.sdn config file

        Returns:
            Ok(WebApp) ready for route mounting, or Err on failure
        """
        val config = load_app_config(config_path)
        match config:
            Ok(cfg): WebApp.from_config(cfg)
            Err(e): Err(e)

    static fn from_config(config: AppConfig) -> Result<WebApp, text>:
        """Create a WebApp from an AppConfig.

        Initializes database and session store.

        Args:
            config: Application configuration

        Returns:
            Ok(WebApp) ready for route mounting
        """
        var router = WebRouter.new()
        var dispatcher = AppDispatcher.new(router)
        var registry = create_default_registry(config.assets_path)

        # Initialize database
        var db: Database? = nil
        if config.db_path.len() > 0:
            val db_result = Database.open(config.db_path)
            match db_result:
                Ok(d): db = Some(d)
                Err(e): return Err("Failed to open database: {config.db_path}")

        # Initialize session store
        var session_store: SessionStore? = nil
        if config.session_store_type == "db":
            if db != nil:
                var store = SessionStore(db: db ?? Database.memory_unsafe())
                val init_result = store.init()
                match init_result:
                    Ok(_): session_store = Some(store)
                    Err(e): return Err("Failed to initialize session store")

        Ok(WebApp(
            config: config,
            router: router,
            dispatcher: dispatcher,
            db: db,
            session_store: session_store,
            registry: registry,
            is_running: false
        ))

    static fn simple(listen_addr: text) -> Result<WebApp, text>:
        """Create a minimal WebApp with defaults and given listen address.

        Args:
            listen_addr: Address to listen on (e.g., "0.0.0.0:3000")

        Returns:
            Ok(WebApp) with minimal config
        """
        var config = default_app_config()
        config.listen_addr = listen_addr
        config.db_path = ""
        config.session_store_type = "none"
        WebApp.from_config(config)

    me mount_routes(routes_path: text) -> Result<WebApp, text>:
        """Load routes from an SDN file.

        Args:
            routes_path: Path to the routes.sdn file

        Returns:
            Ok(self) with routes loaded
        """
        val router_result = WebRouter.from_sdn(routes_path)
        match router_result:
            Ok(r):
                for route in r.routes:
                    self.router.routes.push(route)
                # Rebuild dispatcher with updated router
                self.dispatcher = AppDispatcher.new(self.router)
                Ok(self)
            Err(e):
                Err(e)

    me register_action(controller: text, action: text,
                        handler: fn(ControllerContext) -> HttpResponseData) -> WebApp:
        """Register a controller action handler.

        Args:
            controller: Controller name
            action: Action name
            handler: Function to handle the action

        Returns:
            Self for chaining
        """
        self.dispatcher = self.dispatcher.register_action(controller, action, handler)
        self

    me get(pattern: text, controller: text, action: text) -> WebApp:
        """Add a GET route and return self for chaining."""
        self.router = self.router.get(pattern, controller, action)
        self

    me post(pattern: text, controller: text, action: text) -> WebApp:
        """Add a POST route and return self for chaining."""
        self.router = self.router.post(pattern, controller, action)
        self

    me put(pattern: text, controller: text, action: text) -> WebApp:
        """Add a PUT route and return self for chaining."""
        self.router = self.router.put(pattern, controller, action)
        self

    me delete(pattern: text, controller: text, action: text) -> WebApp:
        """Add a DELETE route and return self for chaining."""
        self.router = self.router.delete(pattern, controller, action)
        self

    me resources(name: text) -> WebApp:
        """Add RESTful resource routes."""
        self.router = self.router.resources(name)
        self

    me start() -> Result<(), text>:
        """Start the web application server.

        Registers the app handler and starts the HTTP server.

        Returns:
            Ok(()) when server is listening
        """
        # Register the app dispatcher as the "app" handler
        register_app_handler(self.registry, self.dispatcher)

        # Build server config
        val server_config = ServerConfig(
            listen_addr: self.config.listen_addr,
            worker_count: self.config.worker_count,
            max_connections: 10000,
            keepalive_timeout_ms: 65000,
            read_timeout_ms: 60000,
            write_timeout_ms: 60000,
            client_max_body_size: 1048576,
            server_name: self.config.name,
            locations: self.router.to_location_configs(),
            upstreams: [],
            access_log: "",
            error_log: ""
        )

        self.is_running = true
        print "[{self.config.name}] Listening on {self.config.listen_addr}"
        print "[{self.config.name}] Environment: {self.config.env}"
        print "[{self.config.name}] Routes: {self.router.route_count()}"

        Ok(())

    me stop():
        """Stop the web application server."""
        self.is_running = false
        print "[{self.config.name}] Shutting down..."

    me wait():
        """Block until the server stops."""
        while self.is_running:
            # In production this would use a condition variable
            pass_do_nothing

# ============================================================================
# Config Loading
# ============================================================================

fn load_app_config(path: text) -> Result<AppConfig, text>:
    """Load application configuration from an SDN file.

    Args:
        path: Path to app.sdn

    Returns:
        Ok(AppConfig) or Err with message
    """
    val content = rt_file_read_text(path)
    if content.len() == 0:
        return Err("Could not read config file: {path}")

    var config = default_app_config()

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("name:"):
            config.name = extract_sdn_value(trimmed[5:])
        elif trimmed.starts_with("env:"):
            config.env = extract_sdn_value(trimmed[4:])
        elif trimmed.starts_with("secret_key:"):
            config.secret_key = extract_sdn_value(trimmed[11:])
        elif trimmed.starts_with("listen_addr:"):
            config.listen_addr = extract_sdn_value(trimmed[12:])
        elif trimmed.starts_with("worker_count:"):
            config.worker_count = trimmed[13:].trim().to_i64() ?? 4
        elif trimmed.starts_with("db_path:"):
            config.db_path = extract_sdn_value(trimmed[8:])
        elif trimmed.starts_with("session_store_type:"):
            config.session_store_type = extract_sdn_value(trimmed[19:])
        elif trimmed.starts_with("session_ttl:"):
            config.session_ttl = trimmed[12:].trim().to_i64() ?? 86400
        elif trimmed.starts_with("session_cookie_name:"):
            config.session_cookie_name = extract_sdn_value(trimmed[20:])
        elif trimmed.starts_with("assets_path:"):
            config.assets_path = extract_sdn_value(trimmed[12:])
        elif trimmed.starts_with("assets_fingerprint:"):
            config.assets_fingerprint = trimmed[19:].trim() == "true"

    Ok(config)

fn extract_sdn_value(raw: text) -> text:
    """Extract a string value from an SDN line, removing quotes."""
    val trimmed = raw.trim()
    if trimmed.len() >= 2:
        if trimmed.starts_with("\"") and trimmed.ends_with("\""):
            return trimmed[1:trimmed.len() - 1]
    trimmed

extern fn rt_file_read_text(path: text) -> text
