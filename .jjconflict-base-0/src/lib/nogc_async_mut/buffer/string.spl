# String utility functions for buffer module

fn char_from_code(code: i64) -> text:
    """Convert a unicode code point to a single-character text string."""
    if code >= 32 and code <= 126:
        val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        val index = code - 32
        if index >= 0 and index < chars.length():
            return chars[index]
    "?"

export char_from_code
