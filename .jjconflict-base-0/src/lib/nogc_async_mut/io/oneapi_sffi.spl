"""
# No-GC Async oneAPI I/O SFFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.oneapi_sffi.{
    oneapi_available, oneapi_init, oneapi_device_count, oneapi_set_device, oneapi_get_device,
    OneApiDeviceType, parse_oneapi_device_type, OneApiDeviceInfo, oneapi_device_info,
    OneApiPtr, oneapi_alloc_device, oneapi_alloc_shared, oneapi_free, oneapi_copy_to_device,
    oneapi_copy_from_device, oneapi_memset, OneApiModule, oneapi_compile_spirv,
    oneapi_compile_opencl, oneapi_unload, OneApiFunc, oneapi_get_kernel, OneApiQueue,
    oneapi_create_queue, oneapi_destroy_queue, oneapi_queue_wait, oneapi_submit, oneapi_sync,
    oneapi_last_error, oneapi_alloc_from_host
}
