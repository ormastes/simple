"""
# Async TCP Socket Options

Pure Simple option record types and helper functions for configuring TCP
sockets in the async I/O path. The sync side (`nogc_sync_mut/tcp/socket.spl`)
already carries Nagle and keepalive helpers; this module mirrors and extends
those for async streams and adds cork, quickack, and buffer-size controls.

These structs carry intent — the actual `setsockopt` calls are delegated to
the IoDriver or platform SFFI layer, which may be a no-op on portable backends.
"""

struct KeepaliveOptions:
    """TCP keepalive parameters (SO_KEEPALIVE + TCP_KEEPIDLE/INTVL/CNT)."""
    enabled: bool
    idle_sec: u32
    interval_sec: u32
    probe_count: u32

struct LingerOptions:
    """SO_LINGER: hard close after timeout instead of FIN handshake."""
    enabled: bool
    timeout_sec: u32

struct TcpSocketOptions:
    """Complete option set for one TCP connection in the async path."""
    nodelay: bool
    cork: bool
    quickack: bool
    keepalive: KeepaliveOptions
    linger: LingerOptions
    sndbuf_bytes: u32
    rcvbuf_bytes: u32

struct SocketOptionResult:
    """Outcome of applying a socket option set to a file descriptor."""
    fd: i64
    applied: bool
    backend_name: text
    skipped_reason: text

fn keepalive_default() -> KeepaliveOptions:
    """Keepalive disabled (OS defaults)."""
    KeepaliveOptions(
        enabled: false,
        idle_sec: 0u32,
        interval_sec: 0u32,
        probe_count: 0u32
    )

fn keepalive_options(idle_sec: u32, interval_sec: u32, probe_count: u32) -> KeepaliveOptions:
    """Enable keepalive with explicit timers."""
    KeepaliveOptions(
        enabled: true,
        idle_sec: idle_sec,
        interval_sec: interval_sec,
        probe_count: probe_count
    )

fn linger_default() -> LingerOptions:
    """Linger disabled (graceful FIN close)."""
    LingerOptions(enabled: false, timeout_sec: 0u32)

fn linger_options(timeout_sec: u32) -> LingerOptions:
    """Enable hard close after timeout_sec seconds."""
    LingerOptions(enabled: true, timeout_sec: timeout_sec)

fn tcp_socket_options_default() -> TcpSocketOptions:
    """Sensible defaults: nodelay off, cork off, keepalive off, OS buffer sizes."""
    TcpSocketOptions(
        nodelay: false,
        cork: false,
        quickack: false,
        keepalive: keepalive_default(),
        linger: linger_default(),
        sndbuf_bytes: 0u32,
        rcvbuf_bytes: 0u32
    )

fn tcp_socket_options_low_latency() -> TcpSocketOptions:
    """Preset: minimise latency — nodelay + quickack, no cork."""
    TcpSocketOptions(
        nodelay: true,
        cork: false,
        quickack: true,
        keepalive: keepalive_default(),
        linger: linger_default(),
        sndbuf_bytes: 0u32,
        rcvbuf_bytes: 0u32
    )

fn tcp_socket_options_bulk_throughput(sndbuf_bytes: u32, rcvbuf_bytes: u32) -> TcpSocketOptions:
    """Preset: maximise bulk throughput — cork enabled, large socket buffers."""
    TcpSocketOptions(
        nodelay: false,
        cork: true,
        quickack: false,
        keepalive: keepalive_default(),
        linger: linger_default(),
        sndbuf_bytes: sndbuf_bytes,
        rcvbuf_bytes: rcvbuf_bytes
    )

fn tcp_socket_options_with_nodelay(opts: TcpSocketOptions, nodelay: bool) -> TcpSocketOptions:
    """Return a copy of opts with nodelay updated."""
    TcpSocketOptions(
        nodelay: nodelay,
        cork: opts.cork,
        quickack: opts.quickack,
        keepalive: opts.keepalive,
        linger: opts.linger,
        sndbuf_bytes: opts.sndbuf_bytes,
        rcvbuf_bytes: opts.rcvbuf_bytes
    )

fn tcp_socket_options_with_cork(opts: TcpSocketOptions, cork: bool) -> TcpSocketOptions:
    """Return a copy of opts with cork updated (disables nodelay when corked)."""
    val nodelay = if cork: false else: opts.nodelay
    TcpSocketOptions(
        nodelay: nodelay,
        cork: cork,
        quickack: opts.quickack,
        keepalive: opts.keepalive,
        linger: opts.linger,
        sndbuf_bytes: opts.sndbuf_bytes,
        rcvbuf_bytes: opts.rcvbuf_bytes
    )

fn tcp_socket_options_with_keepalive(opts: TcpSocketOptions,
                                     keepalive: KeepaliveOptions) -> TcpSocketOptions:
    """Return a copy of opts with keepalive updated."""
    TcpSocketOptions(
        nodelay: opts.nodelay,
        cork: opts.cork,
        quickack: opts.quickack,
        keepalive: keepalive,
        linger: opts.linger,
        sndbuf_bytes: opts.sndbuf_bytes,
        rcvbuf_bytes: opts.rcvbuf_bytes
    )

fn socket_option_result_ok(fd: i64, backend_name: text) -> SocketOptionResult:
    """Record that all options were successfully applied."""
    SocketOptionResult(
        fd: fd,
        applied: true,
        backend_name: backend_name,
        skipped_reason: ""
    )

fn socket_option_result_skipped(fd: i64, backend_name: text, reason: text) -> SocketOptionResult:
    """Record that option application was skipped (portable backend, etc.)."""
    SocketOptionResult(
        fd: fd,
        applied: false,
        backend_name: backend_name,
        skipped_reason: reason
    )

fn tcp_socket_options_summary(opts: TcpSocketOptions) -> text:
    """Compact one-line summary for CI logs and benchmark reports."""
    val ka = if opts.keepalive.enabled: "keepalive=on" else: "keepalive=off"
    val nd = if opts.nodelay: "nodelay=on" else: "nodelay=off"
    val ck = if opts.cork: "cork=on" else: "cork=off"
    "{nd},{ck},{ka},sndbuf={opts.sndbuf_bytes},rcvbuf={opts.rcvbuf_bytes}"
