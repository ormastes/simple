# QUIC UDP Socket — native_udp_* wrapper for interpreter-compatible UDP I/O
#
# Wraps the native_udp_* extern family (registered in the interpreter via
# interpreter_extern/network/udp.rs) with a simple struct interface for use
# by the QUIC transport layer.
#
# Verified interpreter ABIs (interpreter_native_net.rs):
#   native_udp_bind(addr:text) -> (handle:i64, err_code:i64)
#     err_code 0 = success, non-zero = errno-derived code
#   native_udp_send_to(fd:i64, data:[u8], data_len:i64, addr:text) -> (bytes_sent:i64, err_code:i64)
#     args[2] (data_len) is accepted but ignored; addr is args[3]
#   native_udp_recv_from(fd:i64, max_size:i64) -> Result<[i64], IoError>
#     Ok payload: array of 3 elements [recv_len:i64, from_addr:text, data:[i64]]
#   native_udp_set_read_timeout(fd:i64, ms:i64) -> Result<i64, text>
#   native_udp_close(fd:i64) -> i64
#
# NOTE: The data array type for send_to is [u8]; recv_from returns [i64] boxed
# bytes. Callers must coerce receive bytes to [u8] themselves.
#
# Reference: RFC 9000 §13 (UDP datagram layer)

# ============================================================================
# Extern declarations — native_udp_* family (interpreter-registered)
# ============================================================================

extern fn native_udp_bind(addr: text) -> (i64, i64)
extern fn native_udp_send_to(fd: i64, data: [u8], data_len: i64, addr: text) -> (i64, i64)
extern fn native_udp_recv_from(fd: i64, max_size: i64) -> Result<[i64], text>
extern fn native_udp_set_read_timeout(fd: i64, ms: i64) -> Result<i64, text>
extern fn native_udp_close(fd: i64) -> i64

# ============================================================================
# Result type
# ============================================================================

enum UdpResult:
    """Result of a UDP send/recv operation."""
    # Successful send: number of bytes sent
    Sent(n: i64)
    # Successful recv: data bytes and peer address
    Received(data: [u8], from_addr: text)
    # Operation failed: error code
    Err(code: i64)
    # Recv timed out or no data available
    Timeout

# ============================================================================
# QuicUdpSocket — QUIC-specific UDP socket backed by native_udp_*
# ============================================================================

class QuicUdpSocket:
    """UDP socket for QUIC packet I/O using the interpreter-registered native_udp_* externs.

    Binary-safe: send/recv operate on [u8] arrays without going through
    text conversion. recv_from returns raw bytes as [u8] (coerced from
    the [i64] array returned by native_udp_recv_from).
    """
    fd: i64
    local_addr: text
    is_open: bool

    static fn bind(addr: text) -> QuicUdpSocket?:
        """Bind a UDP socket to addr (e.g. "127.0.0.1:4433").

        Returns nil if bind fails.
        """
        val (hdl, err) = native_udp_bind(addr)
        if err != 0:
            return nil
        return QuicUdpSocket(
            fd: hdl,
            local_addr: addr,
            is_open: true
        )

    me set_read_timeout(ms: i64):
        """Set a read timeout in milliseconds (0 = blocking)."""
        if self.is_open:
            native_udp_set_read_timeout(self.fd, ms)

    me send_to(data: [u8], peer_addr: text) -> i64:
        """Send a datagram to peer_addr. Returns bytes sent, or -1 on error."""
        if not self.is_open:
            return -1
        val n: i64 = data.len()
        val (sent, err) = native_udp_send_to(self.fd, data, n, peer_addr)
        if err != 0:
            return -1
        return sent

    me recv_from(max_size: i64) -> UdpResult:
        """Receive one datagram. Returns Received(data, addr) or Timeout on timeout/error."""
        if not self.is_open:
            return UdpResult.Err(-1)
        val res = native_udp_recv_from(self.fd, max_size)
        match res:
            case Ok(arr):
                # arr = [recv_len:i64, from_addr:text, data:[i64]]
                # arr.len() should be 3 but we access by index
                if arr.len() < 3:
                    return UdpResult.Timeout
                # Coerce [i64] data to [u8]: mask each element to low byte
                var raw: [u8] = []
                val data_arr = arr[2]
                # data_arr is itself an array of i64 (byte values 0-255)
                var di = 0
                loop:
                    if di >= data_arr.len():
                        break
                    raw.push(data_arr[di] & 0xff)
                    di = di + 1
                # arr[1] is the from address text
                val from_txt = "{arr[1]}"
                return UdpResult.Received(data: raw, from_addr: from_txt)
            case Err(msg):
                return UdpResult.Timeout

    me close():
        """Close the socket."""
        if self.is_open:
            native_udp_close(self.fd)
            self.is_open = false

    fn is_valid() -> bool:
        """True if the socket is bound and open."""
        return self.is_open and self.fd >= 0

export QuicUdpSocket, UdpResult
