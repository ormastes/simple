# texture3d.spl — GPU texture upload + id-keyed cache
#
# Maps integer texture IDs to GPU TextureHandles. Textures are uploaded
# once via the RenderBackend3D trait and looked up by id for subsequent draws.
#
# Usage:
#   var cache = texture_cache_new()
#   val id = texture_cache_upload(cache, backend, 256, 256, TextureFormat3D.Rgba8Unorm, pixels)
#   val handle = texture_cache_get(cache, id)

use std.nogc_async_mut.engine.render.backend3d.{TextureHandle, TextureFormat3D, RenderBackend3D}

# ============================================================================
# TextureCache3D — parallel-array id-to-handle map
# ============================================================================

class TextureCache3D:
    ids: [i64]
    handles: [TextureHandle]
    widths: [i64]
    heights: [i64]
    next_id: i64

# ============================================================================
# Constructors
# ============================================================================

fn texture_cache_new() -> TextureCache3D:
    """Create an empty texture cache."""
    TextureCache3D(
        ids: [],
        handles: [],
        widths: [],
        heights: [],
        next_id: 0
    )

# ============================================================================
# Operations
# ============================================================================

fn texture_cache_upload(cache: TextureCache3D, backend: RenderBackend3D, width: i64, height: i64, format: TextureFormat3D, data: [u8]) -> i64:
    """Upload pixel data to the GPU and return a new cache id."""
    val handle = backend.create_texture(width, height, format)
    backend.upload_texture(handle, data)
    val id = cache.next_id
    cache.ids.push(id)
    cache.handles.push(handle)
    cache.widths.push(width)
    cache.heights.push(height)
    cache.next_id = cache.next_id + 1
    id

fn texture_cache_get(cache: TextureCache3D, id: i64) -> TextureHandle:
    """Look up a TextureHandle by cache id. Returns TextureHandle.invalid() if not found."""
    var idx = 0
    while idx < cache.ids.len():
        if cache.ids[idx] == id:
            return cache.handles[idx]
        idx = idx + 1
    TextureHandle.invalid()

fn texture_cache_evict(cache: TextureCache3D, id: i64):
    """Remove a cached texture entry by id (does not destroy GPU resource)."""
    var idx = 0
    while idx < cache.ids.len():
        if cache.ids[idx] == id:
            cache.ids.remove(idx)
            cache.handles.remove(idx)
            cache.widths.remove(idx)
            cache.heights.remove(idx)
            return
        idx = idx + 1
