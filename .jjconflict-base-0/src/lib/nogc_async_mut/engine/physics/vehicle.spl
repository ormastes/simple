# Vehicle Physics — simplified vehicle model with wheels and steering

fn _veh_sqrt(n: f64) -> f64:
    if n <= 0.0:
        return 0.0
    var x = n * 0.5
    if n < 1.0:
        x = 1.0
    var i = 0
    while i < 5:
        x = 0.5 * (x + n / x)
        i = i + 1
    x

struct Wheel:
    x_offset: f64
    y_offset: f64
    radius: f64
    suspension_length: f64
    suspension_stiffness: f64
    grip: f64
    steering: bool
    drive: bool
    angular_velocity: f64
    compression: f64

impl Wheel:
    static fn new(x_offset: f64, y_offset: f64, radius: f64, is_steering: bool, is_drive: bool) -> Wheel:
        Wheel(
            x_offset: x_offset, y_offset: y_offset, radius: radius,
            suspension_length: 0.3, suspension_stiffness: 5000.0, grip: 1.0,
            steering: is_steering, drive: is_drive,
            angular_velocity: 0.0, compression: 0.0
        )

struct VehicleConfig:
    mass: f64
    max_steer_angle: f64
    engine_force: f64
    brake_force: f64
    drag: f64

impl VehicleConfig:
    static fn default_config() -> VehicleConfig:
        VehicleConfig(
            mass: 1500.0, max_steer_angle: 35.0,
            engine_force: 5000.0, brake_force: 3000.0, drag: 0.3
        )

class Vehicle:
    position_x: f64
    position_y: f64
    rotation: f64
    velocity_x: f64
    velocity_y: f64
    angular_velocity: f64
    wheels: [Wheel]
    config: VehicleConfig
    throttle: f64
    brake_input: f64
    steer_input: f64

impl Vehicle:
    static fn new(x: f64, y: f64, config: VehicleConfig) -> Vehicle:
        Vehicle(
            position_x: x, position_y: y, rotation: 0.0,
            velocity_x: 0.0, velocity_y: 0.0, angular_velocity: 0.0,
            wheels: [], config: config,
            throttle: 0.0, brake_input: 0.0, steer_input: 0.0
        )

    me add_wheel(wheel: Wheel) -> i32:
        val idx: i32 = self.wheels.len()
        self.wheels.push(wheel)
        idx

    me set_throttle(value: f64):
        self.throttle = value

    me set_brake(value: f64):
        self.brake_input = value

    me set_steering(value: f64):
        self.steer_input = value

    me update(dt: f64):
        val force = self.throttle * self.config.engine_force / self.config.mass
        val brake_decel = self.brake_input * self.config.brake_force / self.config.mass

        # Simplified: forward is along rotation direction
        # Apply force along forward direction
        self.velocity_x = self.velocity_x + force * dt
        # Apply drag
        self.velocity_x = self.velocity_x * (1.0 - self.config.drag * dt)
        # Apply braking
        val speed = self.get_speed()
        if speed > 0.001:
            val brake_amount = brake_decel * dt
            if brake_amount >= speed:
                self.velocity_x = 0.0
                self.velocity_y = 0.0
            else:
                val ratio = 1.0 - brake_amount / speed
                self.velocity_x = self.velocity_x * ratio
                self.velocity_y = self.velocity_y * ratio

        # Steering affects rotation
        val steer_rate = self.steer_input * self.config.max_steer_angle * dt * 0.01
        self.rotation = self.rotation + steer_rate * self.get_speed() * 0.01

        # Update position
        self.position_x = self.position_x + self.velocity_x * dt
        self.position_y = self.position_y + self.velocity_y * dt

    fn get_speed() -> f64:
        _veh_sqrt(self.velocity_x * self.velocity_x + self.velocity_y * self.velocity_y)

    fn wheel_count() -> i32:
        self.wheels.len()

    fn get_wheel(index: i32) -> Wheel?:
        if index < 0 or index >= self.wheels.len():
            return nil
        self.wheels[index]

    me stop():
        self.velocity_x = 0.0
        self.velocity_y = 0.0
        self.angular_velocity = 0.0
