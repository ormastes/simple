# Physics2 — Render Synchronization
#
# Bridges physics simulation to the render engine via interpolated
# transform buffers. Decouples physics rate from render rate.

use std.common.engine.ids.{NodeId}
use std.common.math.{math_lerp}

struct PhysicsTransform2D:
    node_id: NodeId
    pos_x: f64
    pos_y: f64
    rotation: f64

struct PhysicsTransform3D:
    node_id: NodeId
    pos_x: f64
    pos_y: f64
    pos_z: f64
    rot_w: f64
    rot_x: f64
    rot_y: f64
    rot_z: f64

struct RenderSyncBuffer2D:
    prev_transforms: [PhysicsTransform2D]
    curr_transforms: [PhysicsTransform2D]
    count: i64

impl RenderSyncBuffer2D:
    static fn create(capacity: i64) -> RenderSyncBuffer2D:
        RenderSyncBuffer2D(
            prev_transforms: [],
            curr_transforms: [],
            count: 0
        )

    me push(t: PhysicsTransform2D):
        if self.count < self.curr_transforms.len():
            self.curr_transforms[self.count] = t
        else:
            self.curr_transforms.push(t)
            self.prev_transforms.push(t)
        self.count = self.count + 1

    me swap_buffers():
        var i = 0
        while i < self.count:
            self.prev_transforms[i] = self.curr_transforms[i]
            i = i + 1

    me clear():
        self.count = 0

    me get_interpolated(alpha: f64) -> [PhysicsTransform2D]:
        var result: [PhysicsTransform2D] = []
        var i = 0
        while i < self.count:
            val prev = self.prev_transforms[i]
            val curr = self.curr_transforms[i]
            result.push(PhysicsTransform2D(
                node_id: curr.node_id,
                pos_x: math_lerp(prev.pos_x, curr.pos_x, alpha),
                pos_y: math_lerp(prev.pos_y, curr.pos_y, alpha),
                rotation: math_lerp(prev.rotation, curr.rotation, alpha)
            ))
            i = i + 1
        result

struct RenderSyncBuffer3D:
    prev_transforms: [PhysicsTransform3D]
    curr_transforms: [PhysicsTransform3D]
    count: i64

impl RenderSyncBuffer3D:
    static fn create(capacity: i64) -> RenderSyncBuffer3D:
        RenderSyncBuffer3D(
            prev_transforms: [],
            curr_transforms: [],
            count: 0
        )

    me push(t: PhysicsTransform3D):
        if self.count < self.curr_transforms.len():
            self.curr_transforms[self.count] = t
        else:
            self.curr_transforms.push(t)
            self.prev_transforms.push(t)
        self.count = self.count + 1

    me swap_buffers():
        var i = 0
        while i < self.count:
            self.prev_transforms[i] = self.curr_transforms[i]
            i = i + 1

    me clear():
        self.count = 0

    me get_interpolated(alpha: f64) -> [PhysicsTransform3D]:
        var result: [PhysicsTransform3D] = []
        var i = 0
        while i < self.count:
            val prev = self.prev_transforms[i]
            val curr = self.curr_transforms[i]
            result.push(PhysicsTransform3D(
                node_id: curr.node_id,
                pos_x: math_lerp(prev.pos_x, curr.pos_x, alpha),
                pos_y: math_lerp(prev.pos_y, curr.pos_y, alpha),
                pos_z: math_lerp(prev.pos_z, curr.pos_z, alpha),
                rot_w: math_lerp(prev.rot_w, curr.rot_w, alpha),
                rot_x: math_lerp(prev.rot_x, curr.rot_x, alpha),
                rot_y: math_lerp(prev.rot_y, curr.rot_y, alpha),
                rot_z: math_lerp(prev.rot_z, curr.rot_z, alpha)
            ))
            i = i + 1
        result
