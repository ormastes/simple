# Character Controller — Capsule-Based 2D Character Movement
#
# Simple character movement with ground detection and slope handling.
# Pure math/geometry — no SFFI needed.
#
# Usage:
#   val cfg = CharacterConfig.default_config()
#   var ctrl = CharacterController.new(0.0, 0.0, cfg)
#   ctrl.move_by(1.0, 0.0)
#   ctrl.apply_gravity(0.016)
#   ctrl.update(0.016)

# ============================================================================
# GroundInfo — ground detection state
# ============================================================================

struct GroundInfo:
    """Describes the ground state beneath the character."""
    grounded: bool
    slope_angle: f64
    ground_normal_x: f64
    ground_normal_y: f64

# ============================================================================
# CharacterConfig — tuning parameters
# ============================================================================

struct CharacterConfig:
    """Configuration for character movement behavior."""
    step_height: f64
    slope_limit: f64
    skin_width: f64
    gravity: f64

impl CharacterConfig:
    static fn default_config() -> CharacterConfig:
        """Default character config: step=0.3, slope=45, skin=0.01, gravity=9.81."""
        CharacterConfig(
            step_height: 0.3,
            slope_limit: 45.0,
            skin_width: 0.01,
            gravity: 9.81
        )

# ============================================================================
# CharacterController — mutable character movement state
# ============================================================================

class CharacterController:
    """2D character controller with velocity, gravity, and ground info."""
    position_x: f64
    position_y: f64
    velocity_x: f64
    velocity_y: f64
    config: CharacterConfig
    ground: GroundInfo

impl CharacterController:
    static fn new(x: f64, y: f64, config: CharacterConfig) -> CharacterController:
        """Create a character controller at the given position."""
        CharacterController(
            position_x: x,
            position_y: y,
            velocity_x: 0.0,
            velocity_y: 0.0,
            config: config,
            ground: GroundInfo(
                grounded: false,
                slope_angle: 0.0,
                ground_normal_x: 0.0,
                ground_normal_y: 1.0
            )
        )

    me move_by(dx: f64, dy: f64):
        """Add displacement directly to position."""
        self.position_x = self.position_x + dx
        self.position_y = self.position_y + dy

    me apply_gravity(dt: f64):
        """Apply gravity to velocity_y if not grounded."""
        if not self.ground.grounded:
            self.velocity_y = self.velocity_y + self.config.gravity * dt

    me update(dt: f64):
        """Apply velocity to position, then apply gravity."""
        self.position_x = self.position_x + self.velocity_x * dt
        self.position_y = self.position_y + self.velocity_y * dt
        self.apply_gravity(dt)

    me set_grounded(grounded: bool, slope_angle: f64, nx: f64, ny: f64):
        """Update ground info. If grounded, zero out velocity_y."""
        self.ground = GroundInfo(
            grounded: grounded,
            slope_angle: slope_angle,
            ground_normal_x: nx,
            ground_normal_y: ny
        )
        if grounded:
            self.velocity_y = 0.0

    me jump(force: f64):
        """If grounded, set velocity_y = -force (upward)."""
        if self.ground.grounded:
            self.velocity_y = 0.0 - force

    fn is_grounded() -> bool:
        """Check whether the character is on the ground."""
        self.ground.grounded

    fn get_slope_angle() -> f64:
        """Get the current ground slope angle."""
        self.ground.slope_angle

    fn can_climb_slope() -> bool:
        """Check whether the current slope is within the climbable limit."""
        self.ground.slope_angle < self.config.slope_limit

    fn get_position_x() -> f64:
        """Get current X position."""
        self.position_x

    fn get_position_y() -> f64:
        """Get current Y position."""
        self.position_y

    me set_velocity(vx: f64, vy: f64):
        """Set velocity directly."""
        self.velocity_x = vx
        self.velocity_y = vy

    me stop():
        """Zero out all velocity."""
        self.velocity_x = 0.0
        self.velocity_y = 0.0
