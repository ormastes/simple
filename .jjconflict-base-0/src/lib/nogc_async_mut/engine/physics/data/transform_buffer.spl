# Physics2 — Transform Buffer for Render Sync
#
# Stores interpolated transforms for rendering. Physics and render can run
# at different rates; the buffer provides smooth interpolation.

use std.common.engine.ids.{NodeId}

struct PhysicsTransform2D:
    node_id: NodeId
    pos_x: f64
    pos_y: f64
    rotation: f64

struct TransformBuffer2D:
    transforms: [PhysicsTransform2D]
    count: i64
    alpha: f64

impl TransformBuffer2D:
    static fn create() -> TransformBuffer2D:
        TransformBuffer2D(transforms: [], count: 0, alpha: 1.0)

    me set_alpha(a: f64):
        self.alpha = a

    me clear():
        self.transforms = []
        self.count = 0

    me push(t: PhysicsTransform2D):
        self.transforms.push(t)
        self.count = self.count + 1
