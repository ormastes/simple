"""
# CSRF Protection Middleware

Double-submit cookie CSRF protection using HMAC-SHA256 tokens.
Runs in the Access phase to validate state-changing requests.

## Algorithm

1. Token = HMAC-SHA256(secret, session_id + "|" + timestamp)
2. Token is set as a cookie AND expected in a request header
3. On state-changing requests (POST, PUT, DELETE, PATCH), both the
   cookie and header must be present and match

## Usage

```simple
val config = CsrfConfig(
    secret_key: "your-secret-key-here",
    token_header: "X-CSRF-Token",
    cookie_name: "csrf_token",
    exempt_paths: ["/api/webhook"],
    exempt_methods: ["GET", "HEAD", "OPTIONS"]
)
pipeline.add(Phase.Access, 150, "csrf",
    \req, srv_cfg: csrf_handler(req, srv_cfg, config))
```
"""

use std.http_server.types.{
    Phase, PhaseResult, HttpRequestData, ServerConfig
}
use std.io.crypto_ffi.{hmac_sha256, random_hex}
use std.security.types.{SecurityEvent, AuditEntry, AuditConfig}
use std.security.audit_log.{log_security_event}

# Time FFI
extern fn rt_time_now_ms() -> i64

# ============================================================================
# Configuration
# ============================================================================

class CsrfConfig:
    """CSRF protection configuration."""
    secret_key: text
    token_header: text
    cookie_name: text
    exempt_paths: [text]
    exempt_methods: [text]

    static fn default() -> CsrfConfig:
        """Default CSRF config — requires setting secret_key before use."""
        CsrfConfig(
            secret_key: "",
            token_header: "X-CSRF-Token",
            cookie_name: "csrf_token",
            exempt_paths: [],
            exempt_methods: ["GET", "HEAD", "OPTIONS"]
        )

# ============================================================================
# Token Generation
# ============================================================================

fn generate_csrf_token(config: CsrfConfig, session_id: text) -> text:
    """Generate a new CSRF token for a session.

    Token = HMAC-SHA256(secret, session_id + "|" + timestamp)

    Args:
        config: CSRF configuration with secret_key
        session_id: Current session identifier

    Returns:
        Hex-encoded CSRF token
    """
    val timestamp = rt_time_now_ms()
    val payload = "{session_id}|{timestamp}"
    hmac_sha256(config.secret_key, payload)

fn generate_csrf_token_with_timestamp(config: CsrfConfig,
                                       session_id: text,
                                       timestamp: i64) -> text:
    """Generate a CSRF token with an explicit timestamp.

    Useful for validation: regenerate the expected token from the
    same timestamp to compare.

    Args:
        config: CSRF configuration with secret_key
        session_id: Session identifier
        timestamp: Timestamp used in token generation

    Returns:
        Hex-encoded CSRF token
    """
    val payload = "{session_id}|{timestamp}"
    hmac_sha256(config.secret_key, payload)

# ============================================================================
# Handler
# ============================================================================

fn csrf_handler(request: HttpRequestData,
                server_config: ServerConfig,
                config: CsrfConfig) -> PhaseResult:
    """Access phase handler: validate CSRF double-submit cookie.

    Exempt methods (default: GET, HEAD, OPTIONS) are passed through.
    For state-changing methods, both the cookie and header token must
    be present and match.

    Args:
        request: Incoming request
        server_config: Server configuration
        config: CSRF settings

    Returns:
        Continue if valid, Error(403) if CSRF validation fails
    """
    # Check exempt methods
    for method in config.exempt_methods:
        if request.method == method:
            return PhaseResult.Continue

    # Check exempt paths
    for path in config.exempt_paths:
        if request.path == path:
            return PhaseResult.Continue

    # Extract token from header
    val header_token = get_header_value(request.headers, config.token_header)
    if header_token == "":
        log_csrf_violation(request, "missing CSRF header")
        return PhaseResult.Error(403, "CSRF validation failed")

    # Extract token from cookie
    val cookie_token = get_cookie_value(request.headers, config.cookie_name)
    if cookie_token == "":
        log_csrf_violation(request, "missing CSRF cookie")
        return PhaseResult.Error(403, "CSRF validation failed")

    # Double-submit: header and cookie must match
    if header_token != cookie_token:
        log_csrf_violation(request, "token mismatch")
        return PhaseResult.Error(403, "CSRF validation failed")

    PhaseResult.Continue

# ============================================================================
# Header / Cookie Helpers
# ============================================================================

fn get_header_value(headers: [(text, text)], name: text) -> text:
    """Find a header value by name (case-insensitive).

    Returns empty string if not found.
    """
    val lower_name = name.lower()
    for header in headers:
        if header.0.lower() == lower_name:
            return header.1
    ""

fn get_cookie_value(headers: [(text, text)], cookie_name: text) -> text:
    """Extract a named cookie value from Cookie headers.

    Parses Cookie header format: "name1=value1; name2=value2"

    Returns empty string if not found.
    """
    for header in headers:
        if header.0.lower() == "cookie":
            val pairs = header.1.split("; ")
            for pair in pairs:
                val parts = pair.split("=")
                if parts.len() >= 2:
                    val name = parts[0].trim()
                    if name == cookie_name:
                        return parts[1].trim()
    ""

# ============================================================================
# Audit Logging
# ============================================================================

fn log_csrf_violation(request: HttpRequestData, reason: text):
    """Log a CSRF violation as a security event."""
    val event = SecurityEvent.CsrfViolation(
        peer: request.peer_addr,
        path: request.path
    )
    val entry = AuditEntry.new(
        event: event,
        correlation_id: "",
        module_path: "http_server.csrf"
    )
    log_security_event(entry, AuditConfig.default())
