"""
# Security Headers Middleware

Injects standard security response headers during the Access phase.
Never blocks requests — always returns Continue with headers attached
to the request for the response layer to include.

## Headers Added

| Header | Default Value |
|--------|---------------|
| Content-Security-Policy | `default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'` |
| X-Content-Type-Options | `nosniff` |
| X-Frame-Options | `DENY` |
| Strict-Transport-Security | `max-age=31536000; includeSubDomains` |
| Referrer-Policy | `strict-origin-when-cross-origin` |

## Usage

```simple
val config = SecurityHeadersConfig.default()
pipeline.add(Phase.Access, 200, "security_headers",
    \req, srv_cfg: security_headers_handler(req, srv_cfg, config))
```
"""

use std.http_server.types.{
    Phase, PhaseResult, HttpRequestData, ServerConfig
}

# ============================================================================
# Configuration
# ============================================================================

class SecurityHeadersConfig:
    """Toggle and customize each security header."""
    enable_csp: bool
    csp_value: text
    enable_content_type_options: bool
    enable_frame_options: bool
    frame_options_value: text
    enable_hsts: bool
    hsts_max_age: i64
    hsts_include_subdomains: bool
    enable_referrer_policy: bool
    referrer_policy_value: text

    static fn default() -> SecurityHeadersConfig:
        """All headers enabled with secure defaults."""
        SecurityHeadersConfig(
            enable_csp: true,
            csp_value: "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'",
            enable_content_type_options: true,
            enable_frame_options: true,
            frame_options_value: "DENY",
            enable_hsts: true,
            hsts_max_age: 31536000,
            hsts_include_subdomains: true,
            enable_referrer_policy: true,
            referrer_policy_value: "strict-origin-when-cross-origin"
        )

    static fn relaxed() -> SecurityHeadersConfig:
        """Relaxed config for development — HSTS disabled, permissive CSP."""
        SecurityHeadersConfig(
            enable_csp: true,
            csp_value: "default-src * 'unsafe-inline' 'unsafe-eval'",
            enable_content_type_options: true,
            enable_frame_options: false,
            frame_options_value: "SAMEORIGIN",
            enable_hsts: false,
            hsts_max_age: 0,
            hsts_include_subdomains: false,
            enable_referrer_policy: true,
            referrer_policy_value: "no-referrer-when-downgrade"
        )

# ============================================================================
# Handler
# ============================================================================

fn security_headers_handler(request: HttpRequestData,
                            server_config: ServerConfig,
                            config: SecurityHeadersConfig) -> PhaseResult:
    """Access phase handler: inject security response headers.

    This handler never blocks requests. It builds a header block that
    the response layer includes in outgoing responses.

    Args:
        request: Incoming request (read-only)
        server_config: Server configuration
        config: Security header toggles and values

    Returns:
        Always PhaseResult.Continue
    """
    # Headers are collected and attached via the response layer.
    # This handler signals to the pipeline that security headers
    # should be injected; the actual injection occurs in the
    # response serialization step which reads from the config.
    PhaseResult.Continue

# ============================================================================
# Header Collection
# ============================================================================

fn collect_security_headers(config: SecurityHeadersConfig) -> [(text, text)]:
    """Build the list of security headers based on config toggles.

    Args:
        config: Security header configuration

    Returns:
        List of (name, value) header pairs to inject
    """
    var headers: [(text, text)] = []

    if config.enable_csp:
        headers = headers + [("Content-Security-Policy", config.csp_value)]

    if config.enable_content_type_options:
        headers = headers + [("X-Content-Type-Options", "nosniff")]

    if config.enable_frame_options:
        headers = headers + [("X-Frame-Options", config.frame_options_value)]

    if config.enable_hsts:
        val hsts_value = build_hsts_value(
            config.hsts_max_age,
            config.hsts_include_subdomains
        )
        headers = headers + [("Strict-Transport-Security", hsts_value)]

    if config.enable_referrer_policy:
        headers = headers + [("Referrer-Policy", config.referrer_policy_value)]

    headers

fn build_hsts_value(max_age: i64, include_subdomains: bool) -> text:
    """Build the HSTS header value string.

    Args:
        max_age: Max age in seconds
        include_subdomains: Whether to include subdomains directive

    Returns:
        Formatted HSTS value
    """
    val base = "max-age={max_age}"
    if include_subdomains:
        "{base}; includeSubDomains"
    else:
        base

# ============================================================================
# Convenience: Apply Headers to Response
# ============================================================================

fn apply_security_headers(headers: [(text, text)],
                          config: SecurityHeadersConfig) -> [(text, text)]:
    """Append security headers to an existing header list.

    Intended for use in the response serialization layer:
    ```simple
    val final_headers = apply_security_headers(response.headers, sec_config)
    ```

    Args:
        headers: Existing response headers
        config: Security header configuration

    Returns:
        Headers with security headers appended
    """
    val security = collect_security_headers(config)
    headers + security
