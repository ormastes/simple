"""
# Access Log Handler

Logs HTTP requests in a combined-log-like format during the Log phase.

## Format

```
[2026-03-24 12:00:00] 127.0.0.1 "GET /path HTTP/1.1" 200 1234 12ms
```

## Usage

Registered as a Log phase middleware:

```simple
pipeline.add(Phase.Log, 50, "access_log", access_log_handler)
```
"""

use std.http_server.types.{
    Phase, PhaseResult, HttpRequestData, ServerConfig
}

# Time FFI
extern fn rt_time_now_ms() -> i64

# File FFI
extern fn rt_file_append_text(path: text, content: text) -> bool

# ============================================================================
# Access Log Handler
# ============================================================================

fn access_log_handler(request: HttpRequestData,
                      config: ServerConfig) -> PhaseResult:
    """Log phase handler: writes access log entry.

    Logs to config.access_log if set, otherwise to stdout.

    Args:
        request: Completed request
        config: Server config with access_log path

    Returns:
        Always Continue (logging never short-circuits)
    """
    val line = format_log_entry(request)

    if config.access_log.len() > 0:
        rt_file_append_text(config.access_log, line + "\n")
    else:
        print line

    PhaseResult.Continue

# ============================================================================
# Log Formatting
# ============================================================================

fn format_log_entry(request: HttpRequestData) -> text:
    """Format a request into a log line.

    Format: peer_addr "METHOD /path VERSION" - body_len

    Args:
        request: Request to log

    Returns:
        Formatted log line
    """
    val peer = request.peer_addr
    val method = request.method
    val path = request.path
    val version = request.version
    val body_len = request.body.len()

    "{peer} \"{method} {path} {version}\" - {body_len}"

fn format_log_entry_with_status(request: HttpRequestData,
                                 status: i64, duration_ms: i64) -> text:
    """Format a request with response status and timing.

    Format: peer_addr "METHOD /path VERSION" status body_len duration_ms

    Args:
        request: Request to log
        status: Response status code
        duration_ms: Request processing time in ms

    Returns:
        Formatted log line
    """
    val peer = request.peer_addr
    val method = request.method
    val path = request.path
    val version = request.version
    val body_len = request.body.len()

    "{peer} \"{method} {path} {version}\" {status} {body_len} {duration_ms}ms"
