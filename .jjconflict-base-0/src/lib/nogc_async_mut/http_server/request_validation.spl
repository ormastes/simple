"""
# Request Validation Middleware

Validates incoming HTTP requests for common attack patterns during the
Read phase. Checks for path traversal, null bytes, oversized headers,
and oversized URIs.

## Usage

```simple
pipeline.add(Phase.Read, 90, "request_validation",
    \req, cfg: request_validation_handler(req, cfg))
```
"""

use std.http_server.types.{
    Phase, PhaseResult, HttpRequestData, ServerConfig
}
use std.security.sanitize.{is_path_traversal}
use std.security.types.{SecurityEvent, AuditEntry, AuditConfig}
use std.security.audit_log.{log_security_event}

# ============================================================================
# Constants
# ============================================================================

val MAX_HEADER_SIZE: i64 = 8192
val MAX_URI_SIZE: i64 = 8192

# ============================================================================
# Handler
# ============================================================================

fn request_validation_handler(request: HttpRequestData,
                              config: ServerConfig) -> PhaseResult:
    """Read phase handler: validate request for common attack patterns.

    Checks:
    1. Path traversal (../ sequences, encoded variants)
    2. Null bytes in path or headers
    3. Overly long headers (> 8KB per header value)
    4. Overly long URI (> 8KB)

    Args:
        request: Parsed request data
        config: Server configuration

    Returns:
        Continue if valid, Error(400) if malicious input detected
    """
    # Check path traversal
    if is_path_traversal(request.path):
        log_input_violation(request, "path traversal detected")
        return PhaseResult.Error(400, "Bad request: path traversal detected")

    # Check null bytes in path
    if contains_null_byte(request.path):
        log_input_violation(request, "null byte in path")
        return PhaseResult.Error(400, "Bad request: null byte in path")

    # Check URI length
    val full_uri = if request.query.len() > 0:
        "{request.path}?{request.query}"
    else:
        request.path

    if full_uri.len() > MAX_URI_SIZE:
        log_input_violation(request, "URI too long: {full_uri.len()} bytes")
        return PhaseResult.Error(400, "Bad request: URI too long")

    # Check headers
    val header_result = validate_headers(request.headers)
    if header_result != "":
        log_input_violation(request, header_result)
        return PhaseResult.Error(400, "Bad request: {header_result}")

    PhaseResult.Continue

# ============================================================================
# Validation Helpers
# ============================================================================

fn contains_null_byte(input: text) -> bool:
    """Check for null bytes in text (raw and URL-encoded)."""
    if input.contains("\0"):
        return true
    if input.contains("%00"):
        return true
    false

fn validate_headers(headers: [(text, text)]) -> text:
    """Validate all headers for size and content.

    Returns empty string if valid, or error reason if invalid.
    """
    for header in headers:
        val name = header.0
        val value = header.1

        # Check for null bytes in header name or value
        if contains_null_byte(name) or contains_null_byte(value):
            return "null byte in header: {name}"

        # Check header value size
        if value.len() > MAX_HEADER_SIZE:
            return "header too large: {name} ({value.len()} bytes)"

        # Check header name size
        if name.len() > MAX_HEADER_SIZE:
            return "header name too large: ({name.len()} bytes)"

    ""

# ============================================================================
# Audit Logging
# ============================================================================

fn log_input_violation(request: HttpRequestData, reason: text):
    """Log an input validation violation as a security event."""
    val event = SecurityEvent.InputSanitized(
        field: reason,
        original_len: request.path.len()
    )
    val entry = AuditEntry.new(
        event: event,
        correlation_id: "",
        module_path: "http_server.request_validation"
    )
    log_security_event(entry, AuditConfig.default())
