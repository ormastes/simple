use std.ndarray.*

struct RootBracket:
    left: Float64
    right: Float64

struct SampleMinimum:
    x: Float64
    y: Float64
    index: Index

fn bracket_root_linear(x: NDArray, y: NDArray) -> Result<RootBracket, NdarrayError>:
    if x.dtype != DType.F64 or y.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if x.shape.dims.len() != 1 or y.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if x.len() != y.len() or x.len().value < 2:
        return Err(NdarrayError.ShapeMismatch)
    var i = 0
    while i < y.len().value - 1:
        val left_y = y.flat_f64(i).value
        val right_y = y.flat_f64(i + 1).value
        if left_y == 0.0:
            return Ok(RootBracket(left: x.flat_f64(i), right: x.flat_f64(i)))
        if (left_y < 0.0 and right_y > 0.0) or (left_y > 0.0 and right_y < 0.0) or right_y == 0.0:
            return Ok(RootBracket(left: x.flat_f64(i), right: x.flat_f64(i + 1)))
        i = i + 1
    Err(NdarrayError.InvalidShape)

fn minimize_samples(x: NDArray, y: NDArray) -> Result<SampleMinimum, NdarrayError>:
    if x.dtype != DType.F64 or y.dtype != DType.F64:
        return Err(NdarrayError.UnsupportedDType)
    if x.shape.dims.len() != 1 or y.shape.dims.len() != 1:
        return Err(NdarrayError.InvalidShape)
    if x.len() != y.len() or x.len().value == 0:
        return Err(NdarrayError.ShapeMismatch)
    var best_index = 0
    var best_value = y.flat_f64(0).value
    var i = 1
    while i < y.len().value:
        val current = y.flat_f64(i).value
        if current < best_value:
            best_value = current
            best_index = i
        i = i + 1
    Ok(SampleMinimum(x: x.flat_f64(best_index), y: y.flat_f64(best_index), index: Index.new(best_index)))
