# Legacy Editor Plugin Host Compatibility
#
# The active VS Code-like extension host lives in
# `src/lib/editor/extensions/host.spl` and loads `extension.sdn` manifests.
# Keep this tiny value-object registry only for old callers that still mention
# plugin_host_* during migration; new editor work should use extensions.

struct LegacyEditorPluginEntry:
    name: text
    version: text
    active: bool
    path: text

struct LegacyEditorPluginHost:
    plugins: [LegacyEditorPluginEntry]
    event_log: [text]

fn plugin_host_new() -> LegacyEditorPluginHost:
    LegacyEditorPluginHost(plugins: [], event_log: [])

fn plugin_host_register(host: LegacyEditorPluginHost, name: text, version: text, path: text) -> LegacyEditorPluginHost:
    var plugins = host.plugins
    plugins.push(LegacyEditorPluginEntry(name: name, version: version, active: false, path: path))
    LegacyEditorPluginHost(plugins: plugins, event_log: host.event_log)

fn plugin_host_activate(host: LegacyEditorPluginHost, name: text) -> LegacyEditorPluginHost:
    var plugins: [LegacyEditorPluginEntry] = []
    for p in host.plugins:
        if p.name == name:
            plugins.push(LegacyEditorPluginEntry(name: p.name, version: p.version, active: true, path: p.path))
        else:
            plugins.push(p)
    LegacyEditorPluginHost(plugins: plugins, event_log: host.event_log)

fn plugin_host_is_active(host: LegacyEditorPluginHost, name: text) -> bool:
    for p in host.plugins:
        if p.name == name and p.active:
            return true
    false

fn plugin_host_dispatch(host: LegacyEditorPluginHost, event: text) -> LegacyEditorPluginHost:
    var log = host.event_log
    log.push(event)
    LegacyEditorPluginHost(plugins: host.plugins, event_log: log)
