# Editor path/text helpers.
#
# Runtime-neutral string helpers shared by editor app adapters, MCP tools,
# IDE entrypoints, and examples.

fn editor_split_path_list(value: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    while i < value.len():
        if value.char_at(i) == ":":
            val part = value.slice(start, i).trim()
            if part != "":
                parts.push(part)
            start = i + 1
        i = i + 1
    val last = value.slice(start, value.len()).trim()
    if last != "":
        parts.push(last)
    parts

fn editor_dirname(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last <= 0:
        return ""
    path.slice(0, last)

fn editor_path_basename(path: text) -> text:
    var last = -1
    var i = 0
    while i < path.len():
        if path.char_at(i) == "/":
            last = i
        i = i + 1
    if last >= 0 and last + 1 < path.len():
        return path.slice(last + 1, path.len())
    path

fn editor_join_path(folder: text, name: text) -> text:
    if folder == "":
        return name
    if folder.ends_with("/"):
        return folder + name
    folder + "/" + name

fn editor_find_text(haystack: text, needle: text) -> i64:
    var i = 0
    while i < haystack.len():
        if haystack.slice(i, haystack.len()).starts_with(needle):
            return i
        i = i + 1
    -1

fn editor_text_list_contains(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false

fn editor_text_list_without_first(values: [text]) -> [text]:
    var out: [text] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn editor_payload_part(payload: text, index: i64) -> text:
    var current = ""
    var current_index = 0
    var i = 0
    while i < payload.len():
        val ch = payload.char_at(i)
        if ch == "|":
            if current_index == index:
                return current
            current = ""
            current_index = current_index + 1
        else:
            current = current + ch
        i = i + 1
    if current_index == index:
        return current
    ""

fn editor_payload_csv(payload: text) -> [text]:
    var values: [text] = []
    var current = ""
    var i = 0
    while i < payload.len():
        val ch = payload.char_at(i)
        if ch == ",":
            val item = current.trim()
            if item != "":
                values.push(item)
            current = ""
        else:
            current = current + ch
        i = i + 1
    val last = current.trim()
    if last != "":
        values.push(last)
    values

fn editor_parse_i64(value: text, fallback: i64) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return fallback
    var sign = 1
    var i = 0
    if trimmed.starts_with("-"):
        sign = 0 - 1
        i = 1
    var result = 0
    var any = false
    while i < trimmed.len():
        val ch = trimmed.char_at(i)
        if ch < "0" or ch > "9":
            if any:
                return result * sign
            return fallback
        result = result * 10 + editor_digit_value(ch)
        any = true
        i = i + 1
    if any:
        return result * sign
    fallback

fn editor_digit_value(ch: text) -> i64:
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    0

fn editor_last_dot(name: text) -> i64:
    var last = -1
    var i = 0
    while i < name.len():
        if name.char_at(i) == ".":
            last = i
        i = i + 1
    last

fn editor_clean_relative_dir(path: text) -> text:
    var clean = path.trim()
    while clean.starts_with("./"):
        clean = clean.slice(2, clean.len())
    while clean.starts_with("/"):
        clean = clean.slice(1, clean.len())
    while clean.ends_with("/") and clean.len() > 0:
        clean = clean.slice(0, clean.len() - 1)
    if clean == ".":
        return ""
    clean

fn editor_is_markdown_path(path: text) -> bool:
    val lower = path.to_lower()
    lower.ends_with(".md") or lower.ends_with(".markdown")
