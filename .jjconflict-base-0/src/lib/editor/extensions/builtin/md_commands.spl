# Markdown Commands — editor command handlers for Markdown documents.
#
# Provides: md_buffer_content, md_compute_stats, md_diagnose.

use std.editor.buffer.buffer.{EditorBuffer}
use std.editor.services.command_palette.{PaletteEntry}

struct MdStats:
    word_count: i64
    line_count: i64
    heading_count: i64
    code_block_count: i64

fn md_buffer_content(buffer: EditorBuffer) -> text:
    buffer.full_text()

fn md_compute_stats(content: text) -> text:
    val lines = content.split("\n")
    var words: i64 = 0
    var headings: i64 = 0
    var code_blocks: i64 = 0
    for line in lines:
        val t = line.trim()
        if t.starts_with("#"):
            headings = headings + 1
        if t.starts_with("```"):
            code_blocks = code_blocks + 1
        val ws = t.split(" ")
        for w in ws:
            if w.len() > 0:
                words = words + 1
    "words={words} headings={headings} code_blocks={code_blocks} lines={lines.len()}"

fn md_diagnose(content: text, path: text) -> [text]:
    []

fn md_commands_palette_entries() -> [PaletteEntry]:
    [
        PaletteEntry(name: "Markdown: Toggle Preview", description: "Show or hide the Markdown preview", command_name: "markdown.togglePreview", command_payload: ""),
        PaletteEntry(name: "Markdown: Toggle Outline", description: "Show or hide the Markdown outline", command_name: "markdown.toggleOutline", command_payload: ""),
        PaletteEntry(name: "Markdown: Go to Heading", description: "Open heading navigation for the active note", command_name: "markdown.goToHeading", command_payload: ""),
        PaletteEntry(name: "Markdown: Document Statistics", description: "Show document statistics for the active note", command_name: "markdown.documentStats", command_payload: ""),
        PaletteEntry(name: "Markdown: Toggle Task", description: "Toggle the current task item", command_name: "markdown.toggleTask", command_payload: ""),
        PaletteEntry(name: "Markdown: Insert Table", description: "Insert a Markdown table", command_name: "markdown.insertTable", command_payload: ""),
        PaletteEntry(name: "Markdown: Insert Link", description: "Insert a Markdown link", command_name: "markdown.insertLink", command_payload: ""),
        PaletteEntry(name: "Markdown: Insert Code Block", description: "Insert a fenced code block", command_name: "markdown.insertCodeBlock", command_payload: "")
    ]
