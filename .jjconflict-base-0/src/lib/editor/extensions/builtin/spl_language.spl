# Simple Language Extension — registers Simple (.spl) language support.
#
# Provides: spl_language_manifest, spl_language_id.

use std.editor.extensions.manifest.{ExtensionManifest, ExtensionCommand, ExtensionLanguage,
    ExtensionDebugAdapterManifest, ExtensionTheme, ExtensionKeybinding}

fn spl_language_id() -> text:
    "simple"

fn spl_language_manifest() -> ExtensionManifest:
    ExtensionManifest(
        name: "simple-language",
        version: "1.0.0",
        main: "",
        activation_events: ["onLanguage:simple"],
        contributes_commands: [
            ExtensionCommand(id: "simple.build", title: "Simple: Build"),
            ExtensionCommand(id: "simple.run", title: "Simple: Run"),
            ExtensionCommand(id: "simple.test", title: "Simple: Test")
        ],
        contributes_languages: [
            ExtensionLanguage(id: "simple", extensions: [".spl"])
        ],
        contributes_debug_adapters: [
            ExtensionDebugAdapterManifest(id: "simple-dap", label: "Simple Debug", program: "bin/simple")
        ],
        contributes_themes: [],
        contributes_keybindings: []
    )
