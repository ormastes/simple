# Markdown Vim Motions — vim-style movement commands for Markdown documents.
#
# Provides: md_vim_motion_next_heading, md_vim_motion_prev_heading.

fn md_vim_motion_next_heading(content: text, cursor_line: i64) -> i64:
    val lines = content.split("\n")
    var i = cursor_line + 1
    while i < lines.len():
        if lines[i].starts_with("#"):
            return i
        i = i + 1
    cursor_line

fn md_vim_motion_prev_heading(content: text, cursor_line: i64) -> i64:
    val lines = content.split("\n")
    var i = cursor_line - 1
    while i >= 0:
        if lines[i].starts_with("#"):
            return i
        i = i - 1
    cursor_line

fn md_vim_motion_next_block(content: text, cursor_line: i64) -> i64:
    val lines = content.split("\n")
    var i = cursor_line + 1
    while i < lines.len():
        if lines[i].trim().len() == 0:
            return i
        i = i + 1
    cursor_line

fn md_vim_motion_prev_block(content: text, cursor_line: i64) -> i64:
    val lines = content.split("\n")
    var i = cursor_line - 1
    while i >= 0:
        if lines[i].trim().len() == 0:
            return i
        i = i - 1
    cursor_line
