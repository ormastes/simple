# Editor Vim Mode Extension
#
# Vim-style modal editing layer: Normal, Insert, Visual, and Command modes.
# Translates raw key events into editor commands.

struct VimModeState:
    mode: text
    pending_operator: text
    pending_count: i64
    register: text
    last_search: text
    macro_recording: text

fn vim_mode_state_new() -> VimModeState:
    VimModeState(
        mode: "normal",
        pending_operator: "",
        pending_count: 0,
        register: "",
        last_search: "",
        macro_recording: ""
    )

fn vim_mode_enter_insert(state: VimModeState) -> VimModeState:
    VimModeState(
        mode: "insert",
        pending_operator: "",
        pending_count: 0,
        register: state.register,
        last_search: state.last_search,
        macro_recording: state.macro_recording
    )

fn vim_mode_enter_normal(state: VimModeState) -> VimModeState:
    VimModeState(
        mode: "normal",
        pending_operator: "",
        pending_count: 0,
        register: state.register,
        last_search: state.last_search,
        macro_recording: state.macro_recording
    )

fn vim_mode_enter_command(state: VimModeState) -> VimModeState:
    VimModeState(
        mode: "command",
        pending_operator: "",
        pending_count: 0,
        register: state.register,
        last_search: state.last_search,
        macro_recording: state.macro_recording
    )

fn vim_mode_translate_key(state: VimModeState, key: text) -> text:
    if state.mode == "insert":
        if key == "Escape":
            return "vim:enter_normal"
        return "insert:" + key
    elif state.mode == "command":
        if key == "Escape":
            return "vim:enter_normal"
        if key == "Return":
            return "vim:commit_command"
        return "command_append:" + key
    else:
        # normal mode
        if key == "i":
            return "vim:enter_insert"
        if key == "I":
            return "vim:enter_insert_bol"
        if key == "a":
            return "vim:enter_insert_after"
        if key == "A":
            return "vim:enter_insert_eol"
        if key == "v":
            return "vim:enter_visual"
        if key == ":":
            return "vim:enter_command"
        if key == "h":
            return "cursor:left"
        if key == "l":
            return "cursor:right"
        if key == "j":
            return "cursor:down"
        if key == "k":
            return "cursor:up"
        if key == "0":
            return "cursor:bol"
        if key == "$":
            return "cursor:eol"
        if key == "g":
            return "cursor:top"
        if key == "G":
            return "cursor:bottom"
        if key == "d":
            return "vim:delete_line"
        if key == "u":
            return "undo"
        if key == "r":
            return "redo"
        if key == "/":
            return "vim:search_forward"
        if key == "n":
            return "vim:search_next"
        if key == "N":
            return "vim:search_prev"
        ""
