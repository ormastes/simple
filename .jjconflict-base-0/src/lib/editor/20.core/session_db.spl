# Editor Session DB
#
# Persists editor session state (open tabs, cursor positions, editor state)
# using WAL for crash safety. Auto-saves on tab switch and periodic timer.

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

struct SessionDbConfig:
    db_dir: text
    auto_save_on_switch: bool

class SessionDb:
    config: SessionDbConfig
    wal: WalWriter
    last_save_sequence: i64

impl SessionDb:

    static fn new(db_dir: text) -> SessionDb:
        val wal_path = db_dir + "/session.wal"
        val db_path = db_dir + "/session.db"
        SessionDb(
            config: SessionDbConfig(db_dir: db_dir, auto_save_on_switch: true),
            wal: WalWriter.new(wal_path, db_path),
            last_save_sequence: 0
        )

    me save_open_tab(doc_id: i64, path: text, cursor_row: i64, cursor_col: i64):
        val data = "path={path};row={cursor_row};col={cursor_col}"
        self.wal.append_set("tabs", str(doc_id), data)

    me remove_tab(doc_id: i64):
        self.wal.append_delete("tabs", str(doc_id))

    me save_editor_state(active_doc_id: i64, mode: text, group_count: i64):
        val data = "active={active_doc_id};mode={mode};groups={group_count}"
        self.wal.append_set("state", "editor", data)

    me save_active_cursor(doc_id: i64, cursor_row: i64, cursor_col: i64):
        val data = "row={cursor_row};col={cursor_col}"
        self.wal.append_set("cursor", str(doc_id), data)

    me checkpoint() -> bool:
        self.wal.checkpoint()

    fn load_tabs() -> [SessionTabEntry]:
        val db_path = self.config.db_dir + "/session.db"
        val content = rt_file_read_text(db_path) ?? ""
        _sdb_parse_tabs(content)

    fn load_editor_state() -> SessionEditorState:
        val db_path = self.config.db_dir + "/session.db"
        val content = rt_file_read_text(db_path) ?? ""
        _sdb_parse_editor_state(content)


struct SessionTabEntry:
    doc_id: i64
    path: text
    cursor_row: i64
    cursor_col: i64

struct SessionEditorState:
    active_doc_id: i64
    mode: text
    group_count: i64

fn _sdb_parse_tabs(content: text) -> [SessionTabEntry]:
    var tabs: [SessionTabEntry] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            val line = content.slice(start, i)
            if line.starts_with("tabs:"):
                val entry = _sdb_parse_tab_line(line)
                if entry.doc_id > 0:
                    tabs.push(entry)
            start = i + 1
        i = i + 1
    tabs

fn _sdb_parse_tab_line(line: text) -> SessionTabEntry:
    val eq_pos = _sdb_find_char(line, "=")
    if eq_pos < 0:
        return SessionTabEntry(doc_id: 0, path: "", cursor_row: 0, cursor_col: 0)
    val key_part = line.slice(5, eq_pos)
    val data_part = line.slice(eq_pos + 1, line.len())
    val doc_id = _wal_parse_int(key_part)
    var path = ""
    var row = 0
    var col = 0
    val pairs = _sdb_split_semicolons(data_part)
    for pair in pairs:
        if pair.starts_with("path="):
            path = pair.slice(5, pair.len())
        if pair.starts_with("row="):
            row = _wal_parse_int(pair.slice(4, pair.len()))
        if pair.starts_with("col="):
            col = _wal_parse_int(pair.slice(4, pair.len()))
    SessionTabEntry(doc_id: doc_id, path: path, cursor_row: row, cursor_col: col)

fn _sdb_parse_editor_state(content: text) -> SessionEditorState:
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            val line = content.slice(start, i)
            if line.starts_with("state:editor="):
                val data = line.slice(13, line.len())
                return _sdb_parse_state_data(data)
            start = i + 1
        i = i + 1
    SessionEditorState(active_doc_id: 0, mode: "normal", group_count: 1)

fn _sdb_parse_state_data(data: text) -> SessionEditorState:
    var active = 0
    var mode = "normal"
    var groups = 1
    val pairs = _sdb_split_semicolons(data)
    for pair in pairs:
        if pair.starts_with("active="):
            active = _wal_parse_int(pair.slice(7, pair.len()))
        if pair.starts_with("mode="):
            mode = pair.slice(5, pair.len())
        if pair.starts_with("groups="):
            groups = _wal_parse_int(pair.slice(7, pair.len()))
    SessionEditorState(active_doc_id: active, mode: mode, group_count: groups)

fn _sdb_find_char(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s.char_at(i) == ch:
            return i
        i = i + 1
    -1

fn _sdb_split_semicolons(s: text) -> [text]:
    var parts: [text] = []
    var start = 0
    var i = 0
    while i < s.len():
        if s.char_at(i) == ";":
            parts.push(s.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= s.len():
        parts.push(s.slice(start, s.len()))
    parts
