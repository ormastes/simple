# Multi Buffer Manager
#
# Unified registry mapping EditorBufferId -> EditorDocument.
# All buffer lifecycle operations (open, close, save) go through here.

struct MultiBufferManager:
    buffers: [EditorDocument]
    id_counter: i64

fn multi_buffer_create() -> MultiBufferManager:
    MultiBufferManager(buffers: [], id_counter: 1)

fn multi_buffer_open(mgr: MultiBufferManager, path: text) -> EditorBufferId:
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].path() == path:
            return mgr.buffers[i].buffer.id
        i = i + 1
    val buf_id = EditorBufferId(value: mgr.id_counter)
    mgr.id_counter = mgr.id_counter + 1
    val doc_id = EditorDocumentId(value: mgr.id_counter)
    mgr.id_counter = mgr.id_counter + 1
    val doc = EditorDocument.open_file(doc_id, buf_id, path)
    mgr.buffers.push(doc)
    buf_id

fn multi_buffer_open_empty(mgr: MultiBufferManager) -> EditorBufferId:
    val buf_id = EditorBufferId(value: mgr.id_counter)
    mgr.id_counter = mgr.id_counter + 1
    val doc_id = EditorDocumentId(value: mgr.id_counter)
    mgr.id_counter = mgr.id_counter + 1
    val doc = EditorDocument.empty(doc_id, buf_id)
    mgr.buffers.push(doc)
    buf_id

fn multi_buffer_close(mgr: MultiBufferManager, id: EditorBufferId) -> bool:
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].buffer.id.value == id.value:
            mgr.buffers.remove(i)
            return true
        i = i + 1
    false

fn multi_buffer_get(mgr: MultiBufferManager, id: EditorBufferId) -> EditorDocument:
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].buffer.id.value == id.value:
            return mgr.buffers[i]
        i = i + 1
    nil

fn multi_buffer_list(mgr: MultiBufferManager) -> [EditorDocument]:
    mgr.buffers

fn multi_buffer_find_by_path(mgr: MultiBufferManager, path: text) -> EditorDocument:
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].path() == path:
            return mgr.buffers[i]
        i = i + 1
    nil

fn multi_buffer_save(mgr: MultiBufferManager, id: EditorBufferId) -> bool:
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].buffer.id.value == id.value:
            var doc = mgr.buffers[i]
            val ok = doc.buffer.save()
            mgr.buffers[i] = doc
            return ok
        i = i + 1
    false

fn multi_buffer_save_all(mgr: MultiBufferManager) -> i64:
    var count = 0
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].buffer.dirty:
            var doc = mgr.buffers[i]
            val ok = doc.buffer.save()
            mgr.buffers[i] = doc
            if ok:
                count = count + 1
        i = i + 1
    count

fn multi_buffer_dirty_count(mgr: MultiBufferManager) -> i64:
    var count = 0
    var i = 0
    while i < mgr.buffers.len():
        if mgr.buffers[i].buffer.dirty:
            count = count + 1
        i = i + 1
    count
