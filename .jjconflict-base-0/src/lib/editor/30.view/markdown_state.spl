# Editor Markdown State — per-document markdown preview/outline visibility.
#
# Provides: MarkdownState. Held on EditorDocument.md_state (nil until a
# markdown document opens its preview or outline pane).

use std.editor.view.outline_panel.{OutlinePanel, outline_panel_new}

class MarkdownState:
    preview_visible: bool
    outline_visible: bool
    outline: OutlinePanel

    static fn new() -> MarkdownState:
        MarkdownState(preview_visible: false, outline_visible: false, outline: outline_panel_new())
