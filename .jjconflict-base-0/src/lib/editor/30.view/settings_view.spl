# Editor Settings View State
#
# TUI/GUI settings panel state: category browsing, search, item selection,
# and inline editing. Rendered by the shell; logic lives here.

use std.editor.common.settings_schema.*

class SettingsViewState:
    schema: [SettingDescriptor]
    filtered: [SettingDescriptor]
    selected_index: i64
    category_index: i64
    categories: [text]
    search_query: text
    editing: bool
    edit_value: text

impl SettingsViewState:

    static fn new(schema: [SettingDescriptor]) -> SettingsViewState:
        val cats = ["All"] + settings_categories()
        SettingsViewState(
            schema: schema,
            filtered: schema,
            selected_index: 0,
            category_index: 0,
            categories: cats,
            search_query: "",
            editing: false,
            edit_value: ""
        )

    me select_next():
        val max = self.filtered.len() - 1
        if self.selected_index < max:
            self.selected_index = self.selected_index + 1

    me select_prev():
        if self.selected_index > 0:
            self.selected_index = self.selected_index - 1

    me next_category():
        val max = self.categories.len() - 1
        if self.category_index < max:
            self.category_index = self.category_index + 1
        self.apply_filter()

    me prev_category():
        if self.category_index > 0:
            self.category_index = self.category_index - 1
        self.apply_filter()

    me apply_filter():
        self.selected_index = 0
        if self.search_query != "":
            self.filtered = settings_search(self.schema, self.search_query)
        elif self.category_index > 0:
            val cat = self.categories[self.category_index]
            self.filtered = settings_filter_by_category(self.schema, cat)
        else:
            self.filtered = self.schema

    me start_edit(current_value: text):
        self.editing = true
        self.edit_value = current_value

    me cancel_edit():
        self.editing = false
        self.edit_value = ""

    fn current_setting() -> SettingDescriptor:
        if self.filtered.len() == 0:
            return SettingDescriptor(
                key: "",
                label: "",
                description: "",
                category: "",
                setting_type: "",
                default_value: "",
                enum_options: [],
                platform: ""
            )
        self.filtered[self.selected_index]
