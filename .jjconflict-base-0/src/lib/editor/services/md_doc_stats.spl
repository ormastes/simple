# Markdown Document Statistics
#
# Computes word count, character count, heading/link/image counts,
# and estimated reading time from raw markdown content.

struct MdDocStats:
    word_count: i64
    char_count: i64
    line_count: i64
    paragraph_count: i64
    heading_count: i64
    link_count: i64
    image_count: i64
    code_block_count: i64
    list_count: i64
    table_count: i64
    reading_time_minutes: i64

fn md_compute_stats(content: text) -> MdDocStats:
    val lines = content.split("\n")
    val total_lines = lines.len()
    val total_chars = content.len()
    var word_count: i64 = 0
    var paragraph_count: i64 = 0
    var heading_count: i64 = 0
    var link_count: i64 = 0
    var image_count: i64 = 0
    var code_block_count: i64 = 0
    var list_count: i64 = 0
    var table_count: i64 = 0
    var in_code_block = false
    var prev_blank = true
    var in_list = false
    var in_table = false
    var i = 0
    while i < total_lines:
        val line = lines[i]
        val trimmed = line.trim()
        if trimmed.starts_with("```"):
            if in_code_block:
                in_code_block = false
            else:
                in_code_block = true
                code_block_count = code_block_count + 1
            i = i + 1
            continue
        if in_code_block:
            word_count = word_count + _md_count_words(trimmed)
            i = i + 1
            continue
        if trimmed == "":
            prev_blank = true
            in_list = false
            in_table = false
            i = i + 1
            continue
        if trimmed.starts_with("#"):
            heading_count = heading_count + 1
            word_count = word_count + _md_count_words(_md_strip_heading_prefix(trimmed))
            link_count = link_count + _md_count_links_in_line(trimmed)
            image_count = image_count + _md_count_images_in_line(trimmed)
            prev_blank = false
            i = i + 1
            continue
        if (trimmed.starts_with("- ") or trimmed.starts_with("* ") or
            trimmed.starts_with("+ ") or _md_is_ordered_list_item(trimmed)):
            if not in_list:
                list_count = list_count + 1
                in_list = true
            word_count = word_count + _md_count_words(trimmed)
            link_count = link_count + _md_count_links_in_line(trimmed)
            image_count = image_count + _md_count_images_in_line(trimmed)
            prev_blank = false
            i = i + 1
            continue
        if trimmed.starts_with("|"):
            if not in_table:
                table_count = table_count + 1
                in_table = true
            word_count = word_count + _md_count_words(trimmed)
            prev_blank = false
            i = i + 1
            continue
        in_table = false
        in_list = false
        if prev_blank:
            paragraph_count = paragraph_count + 1
        word_count = word_count + _md_count_words(trimmed)
        link_count = link_count + _md_count_links_in_line(trimmed)
        image_count = image_count + _md_count_images_in_line(trimmed)
        prev_blank = false
        i = i + 1
    var reading_time: i64 = word_count / 200
    if reading_time < 1:
        reading_time = 1
    MdDocStats(
        word_count: word_count,
        char_count: total_chars,
        line_count: total_lines,
        paragraph_count: paragraph_count,
        heading_count: heading_count,
        link_count: link_count,
        image_count: image_count,
        code_block_count: code_block_count,
        list_count: list_count,
        table_count: table_count,
        reading_time_minutes: reading_time
    )

fn md_stats_to_status_bar(stats: MdDocStats) -> text:
    val words = stats.word_count.to_text()
    val mins = stats.reading_time_minutes.to_text()
    val headings = stats.heading_count.to_text()
    words + " words | " + mins + " min read | " + headings + " headings"

fn md_stats_to_panel(stats: MdDocStats) -> [text]:
    var lines: [text] = []
    lines.push("Words: " + stats.word_count.to_text())
    lines.push("Characters: " + stats.char_count.to_text())
    lines.push("Lines: " + stats.line_count.to_text())
    lines.push("Paragraphs: " + stats.paragraph_count.to_text())
    lines.push("Headings: " + stats.heading_count.to_text())
    lines.push("Links: " + stats.link_count.to_text())
    lines.push("Images: " + stats.image_count.to_text())
    lines.push("Code blocks: " + stats.code_block_count.to_text())
    lines.push("Lists: " + stats.list_count.to_text())
    lines.push("Tables: " + stats.table_count.to_text())
    lines.push("Reading time: ~" + stats.reading_time_minutes.to_text() + " min")
    lines

fn _md_count_words(text_content: text) -> i64:
    var count: i64 = 0
    var in_word = false
    var i = 0
    while i < text_content.len():
        val ch = text_content.char_at(i)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if in_word:
                count = count + 1
                in_word = false
        else:
            in_word = true
        i = i + 1
    if in_word:
        count = count + 1
    count

# --- internal helpers ---

fn _md_strip_heading_prefix(line: text) -> text:
    var i = 0
    while i < line.len() and line.char_at(i) == "#":
        i = i + 1
    while i < line.len() and line.char_at(i) == " ":
        i = i + 1
    line.slice(i, line.len())

fn _md_is_ordered_list_item(line: text) -> bool:
    var i = 0
    while i < line.len() and line.char_at(i) >= "0" and line.char_at(i) <= "9":
        i = i + 1
    if i == 0:
        return false
    if i >= line.len():
        return false
    val ch = line.char_at(i)
    ch == "." or ch == ")"

fn _md_count_links_in_line(line: text) -> i64:
    # Count [text](url) patterns (skip images which start with !)
    var count: i64 = 0
    var i = 0
    while i < line.len():
        val ch = line.char_at(i)
        if ch == "[":
            var before = " "
            if i > 0:
                before = line.char_at(i - 1)
            if before != "!":
                # look for ](
                val close_bracket = _md_find_char(line, "]", i + 1)
                if close_bracket > 0 and close_bracket + 1 < line.len():
                    if line.char_at(close_bracket + 1) == "(":
                        count = count + 1
                        i = close_bracket + 2
                        continue
            # also count [[wikilinks]]
            if i + 1 < line.len() and line.char_at(i + 1) == "[":
                count = count + 1
                i = i + 2
                continue
        i = i + 1
    count

fn _md_count_images_in_line(line: text) -> i64:
    # Count ![alt](url) patterns
    var count: i64 = 0
    var i = 0
    while i < line.len():
        if line.char_at(i) == "!" and i + 1 < line.len() and line.char_at(i + 1) == "[":
            val close_bracket = _md_find_char(line, "]", i + 2)
            if close_bracket > 0 and close_bracket + 1 < line.len():
                if line.char_at(close_bracket + 1) == "(":
                    count = count + 1
                    i = close_bracket + 2
                    continue
        i = i + 1
    count

fn _md_find_char(haystack: text, needle: text, start: i64) -> i64:
    var i = start
    while i < haystack.len():
        if haystack.char_at(i) == needle:
            return i
        i = i + 1
    -1
