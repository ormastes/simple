# Surface identification types: FrameSinkId, LocalSurfaceId, SurfaceId

class FrameSinkId:
    client_id: i32
    sink_id: i32

    me equals(other: FrameSinkId) -> bool:
        me.client_id == other.client_id and me.sink_id == other.sink_id

class LocalSurfaceId:
    parent_sequence_number: i32
    child_sequence_number: i32

    me equals(other: LocalSurfaceId) -> bool:
        (me.parent_sequence_number == other.parent_sequence_number and
         me.child_sequence_number == other.child_sequence_number)

class SurfaceId:
    frame_sink_id: FrameSinkId
    local_surface_id: LocalSurfaceId

    me equals(other: SurfaceId) -> bool:
        (me.frame_sink_id.equals(other.frame_sink_id) and
         me.local_surface_id.equals(other.local_surface_id))
