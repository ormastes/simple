# ============================================================================
# BLAS CPU-fallback Stubs
# ============================================================================

fn gpu_gemm(a: [f32], b: [f32], m: i64, n: i64, k: i64) -> Result<[f32], GpuError>:
    # Matrix multiply C[i,j] = sum(A[i,p] * B[p,j]) for p in 0..k. CPU fallback.
    var result = [for idx in 0..(m * n): 0.0]
    var i = 0
    while i < m:
        var j = 0
        while j < n:
            var sum = 0.0
            var p = 0
            while p < k:
                sum = sum + a[i * k + p] * b[p * n + j]
                p = p + 1
            result[i * n + j] = sum
            j = j + 1
        i = i + 1
    Ok(result)

fn gpu_dot(x: [f32], y: [f32]) -> Result<f32, GpuError>:
    # Dot product of two vectors. CPU fallback.
    var sum = 0.0
    var i = 0
    while i < x.len():
        sum = sum + x[i] * y[i]
        i = i + 1
    Ok(sum)

fn gpu_axpy(alpha: f32, x: [f32], y: [f32]) -> Result<[f32], GpuError>:
    # AXPY: result[i] = alpha * x[i] + y[i]. CPU fallback.
    var result = [for idx in 0..x.len(): 0.0]
    var i = 0
    while i < x.len():
        result[i] = alpha * x[i] + y[i]
        i = i + 1
    Ok(result)

# ============================================================================
# Thrust CPU-fallback Stubs
# ============================================================================

fn gpu_map(data: [f32], op: fn(f32) -> f32) -> Result<[f32], GpuError>:
    # Apply op to each element. CPU fallback.
    var result = [for idx in 0..data.len(): 0.0]
    var i = 0
    while i < data.len():
        result[i] = op(data[i])
        i = i + 1
    Ok(result)

fn gpu_reduce(data: [f32], init: f32, op: fn(f32, f32) -> f32) -> Result<f32, GpuError>:
    # Reduce array with binary op. CPU fallback.
    var acc = init
    var i = 0
    while i < data.len():
        acc = op(acc, data[i])
        i = i + 1
    Ok(acc)

fn gpu_scan(data: [f32], init: f32, op: fn(f32, f32) -> f32) -> Result<[f32], GpuError>:
    # Inclusive prefix scan. CPU fallback.
    var result = [for idx in 0..data.len(): 0.0]
    var acc = init
    var i = 0
    while i < data.len():
        acc = op(acc, data[i])
        result[i] = acc
        i = i + 1
    Ok(result)

fn gpu_filter(data: [f32], pred: fn(f32) -> bool) -> Result<[f32], GpuError>:
    # Filter elements matching predicate. CPU fallback.
    var result: [f32] = []
    var i = 0
    while i < data.len():
        if pred(data[i]):
            result.push(data[i])
        i = i + 1
    Ok(result)

fn gpu_sort(data: [f32]) -> Result<[f32], GpuError>:
    # Sort array. CPU fallback.
    var result = [for x in data: x]
    result.sort()
    Ok(result)

# Canonical aliases used by gpu/mod.spl
fn gpu_sync_threads():
    """Alias for gpu_syncthreads — synchronize threads within a block."""
    gpu_syncthreads()

fn gpu_shared_memory(size: i64) -> i64:
    """Alias for gpu_shared_array_f32 — allocate shared memory."""
    gpu_shared_array_f32(size)

fn gpu_global_size_x() -> i64:
    """Total global thread count in X (grid_dim_x * block_dim_x)."""
    gpu_grid_dim_x() * gpu_block_dim_x()

fn gpu_global_size_y() -> i64:
    """Total global thread count in Y (grid_dim_y * block_dim_y)."""
    gpu_grid_dim_y() * gpu_block_dim_y()

fn gpu_global_size_z() -> i64:
    """Total global thread count in Z (grid_dim_z * block_dim_z)."""
    gpu_grid_dim_z() * gpu_block_dim_z()

