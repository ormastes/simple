    pass_dn

fn gpu_load_i64(ptr: i64, index: i64) -> i64:
    """Load i64 from device memory at index. PTX: ld.global.s64"""
    0

fn gpu_store_i64(ptr: i64, index: i64, value: i64):
    """Store i64 to device memory at index. PTX: st.global.s64"""
    pass_dn

fn gpu_load_i32(ptr: GpuPtr, index: i64) -> i64:
    """Load i32 from device memory at index. PTX: ld.global.s32"""
