fn gpu_atomic_add_i32(ptr: GpuPtr, index: i64, value: i64) -> i64:
    """Atomic add on device memory (i32). PTX: atom.global.add.s32"""
    0

fn gpu_atomic_add_f32(ptr: GpuPtr, index: i64, value: f64) -> f64:
    """Atomic add on device memory (f32). PTX: atom.global.add.f32"""
    0.0

fn gpu_atomic_min_i64(ptr: GpuPtr, index: i64, value: i64) -> i64:
