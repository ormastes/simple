# Browser session — HTML/text utilities and stylesheet handling.
#
# Free functions for:
# - extract_title_text / extract_body_inner_html / own_text / html_to_text
# - escape_html_text / escape_js_string
# - strip_script_blocks / strip_tag_block
# - _guest_runtime_probe_url / _extract_simple_js_assignment
# - BrowserStylesheetExpansion class
# - extract_stylesheet_sources / extract_attr_value / has_tag_attr / rel_contains_stylesheet
# - expand_stylesheet_text / extract_css_import_sources / strip_css_imports
# - extract_css_import_href / trim_css_import_url / insert_stylesheet_sources

use common.string_builder.{StringBuilder}
use std.gc_async_mut.web.browser_session.{BrowserStylesheetSource, BrowserStylesheetExpansion}
use std.gc_async_mut.web.browser_session_url.{find_text, resolve_relative_url}

fn extract_title_text(html: text) -> text:
    val start = find_text(html, "<title>", 0)
    if start < 0:
        return ""
    val content_start = start + 7
    val end = find_text(html, "</title>", content_start)
    if end < 0:
        return ""
    html[content_start:end].trim()

fn extract_body_inner_html(html: text) -> text:
    val body_open = find_text(html, "<body", 0)
    if body_open < 0:
        return ""
    val open_end = find_text(html, ">", body_open)
    if open_end < 0:
        return ""
    val body_close = find_text(html, "</body>", open_end + 1)
    if body_close < 0:
        return html[open_end + 1:html.len()]
    html[open_end + 1:body_close]

fn own_text(value: text) -> text:
    # Force a fresh owned text value instead of retaining a borrowed slice.
    "{value}"

fn html_to_text(html: text) -> text:
    var out = ""
    var in_tag = false
    var tag_buf = ""
    var hidden_text_tag = ""
    var ruby_text_tag = ""
    var ruby_annotation_text = ""
    var edit_text_tag = ""
    var edit_text_value = ""
    var table_row_cell_count = 0
    var pos = 0
    val html_len = html.len()
    while pos < html_len:
        val ch = html.slice(pos, pos + 1)
        if ch == "<":
            in_tag = true
            tag_buf = ""
        else if ch == ">":
            val tag_name = html_tag_name(tag_buf)
            val closing = html_tag_is_closing(tag_buf)
            if hidden_text_tag != "":
                if closing and tag_name == hidden_text_tag:
                    hidden_text_tag = ""
            else if ruby_text_tag != "":
                if closing and tag_name == "rt":
                    val annotation = ruby_annotation_text.trim()
                    if annotation != "":
                        out = out + "(" + annotation + ")"
                    ruby_annotation_text = ""
                    ruby_text_tag = ""
                else if closing and tag_name == ruby_text_tag:
                    ruby_text_tag = ""
            else if edit_text_tag != "":
                if closing and tag_name == edit_text_tag:
                    val edit_text = edit_text_value.trim()
                    if edit_text != "":
                        if edit_text_tag == "ins":
                            out = out + "[+" + edit_text + "]"
                        else:
                            out = out + "[-" + edit_text + "]"
                    edit_text_tag = ""
                    edit_text_value = ""
            else if not closing and tag_name == "rt":
                ruby_text_tag = "rt"
                ruby_annotation_text = ""
            else if not closing and tag_name == "rp":
                ruby_text_tag = "rp"
            else if not closing and (tag_name == "ins" or tag_name == "del"):
                edit_text_tag = tag_name
                edit_text_value = ""
            else if not closing and html_tag_hides_text(tag_name):
                hidden_text_tag = tag_name
            else if not closing and html_tag_breaks_before(tag_name):
                if out != "" and not out.ends_with("\n"):
                    out = out + "\n"
            else if closing and html_tag_breaks_after(tag_name):
                if out != "" and not out.ends_with("\n"):
                    out = out + "\n"
            else if not closing and tag_name == "tr":
                if out != "" and not out.ends_with("\n"):
                    out = out + "\n"
                table_row_cell_count = 0
            else if not closing and (tag_name == "td" or tag_name == "th"):
                if table_row_cell_count > 0:
                    out = out + "\t"
                table_row_cell_count = table_row_cell_count + 1
            else if not closing and tag_name == "li":
                if out != "" and not out.ends_with("\n"):
                    out = out + "\n"
            else if not closing and tag_name == "dt":
                if out != "" and not out.ends_with("\n"):
                    out = out + "\n"
            else if not closing and tag_name == "dd":
                if out != "" and not out.ends_with(": ") and not out.ends_with("\n"):
                    out = out + ": "
            else if tag_name == "br":
                out = out + "\n"
            else if not closing and tag_name == "hr":
                if out != "" and not out.ends_with("\n"):
                    out = out + "\n"
            else if not closing and (tag_name == "img" or tag_name == "area"):
                val alt_text = extract_attr_value(tag_buf, "alt")
                if alt_text != "":
                    out = out + alt_text
            else if not closing and tag_name == "input":
                val value_text = extract_attr_value(tag_buf, "value")
                if value_text != "":
                    out = out + value_text
            else if not closing and (tag_name == "progress" or tag_name == "meter"):
                val value_text = extract_attr_value(tag_buf, "value")
                val max_text = extract_attr_value(tag_buf, "max")
                if value_text != "" and max_text != "":
                    out = out + value_text + "/" + max_text
                else if value_text != "":
                    out = out + value_text
            in_tag = false
            tag_buf = ""
        else if in_tag:
            tag_buf = tag_buf + ch
        else if hidden_text_tag != "":
            pass
        else if ruby_text_tag == "rt":
            ruby_annotation_text = ruby_annotation_text + ch
        else if edit_text_tag != "":
            edit_text_value = edit_text_value + ch
        else if ruby_text_tag == "":
            out = out + ch
        pos = pos + 1
    out.trim()

fn html_tag_name(tag_text: text) -> text:
    var trimmed = tag_text.trim().lower()
    if trimmed.starts_with("/"):
        trimmed = trimmed.slice(1, trimmed.len()).trim()
    var out = ""
    var pos = 0
    val trimmed_len = trimmed.len()
    while pos < trimmed_len:
        val ch = trimmed.slice(pos, pos + 1)
        if ch == " " or ch == "/" or ch == "\n" or ch == "\t":
            return out
        out = out + ch
        pos = pos + 1
    out

fn html_tag_is_closing(tag_text: text) -> bool:
    tag_text.trim().starts_with("/")

fn html_tag_hides_text(tag_name: text) -> bool:
    tag_name == "head" or tag_name == "title" or tag_name == "style" or tag_name == "script" or tag_name == "template"

fn html_tag_breaks_before(tag_name: text) -> bool:
    html_section_text_block_tag(tag_name)

fn html_tag_breaks_after(tag_name: text) -> bool:
    html_section_text_block_tag(tag_name)

fn html_section_text_block_tag(tag_name: text) -> bool:
    tag_name == "h1" or tag_name == "h2" or tag_name == "h3" or tag_name == "h4" or tag_name == "h5" or tag_name == "h6" or tag_name == "hgroup" or tag_name == "address"

fn escape_html_text(text_value: text) -> text:
    val sb = StringBuilder.new()
    var i = 0
    val text_len = text_value.len()
    while i < text_len:
        val ch = text_value.slice(i, i + 1)
        if ch == "&":
            sb.push("&amp;")
        else if ch == "<":
            sb.push("&lt;")
        else if ch == ">":
            sb.push("&gt;")
        else if ch == "\"":
            sb.push("&quot;")
        else:
            sb.push(ch)
        i = i + 1
    sb.to_text()

fn escape_js_string(value: text) -> text:
    var out = ""
    var i = 0
    val value_len = value.len()
    while i < value_len:
        val ch = value.slice(i, i + 1)
        if ch == "\\":
            out = out + "\\\\"
        else if ch == "\"":
            out = out + "\\\""
        else:
            out = out + ch
        i = i + 1
    out

fn strip_script_blocks(html: text) -> text:
    strip_tag_block(html, "script")

fn strip_template_blocks(html: text) -> text:
    strip_tag_block(html, "template")

fn strip_noscript_blocks(html: text) -> text:
    strip_tag_block(html, "noscript")

fn strip_tag_block(html: text, tag_name: text) -> text:
    var result = ""
    var pos = 0
    val open_tag = "<{tag_name}"
    val close_tag = "</{tag_name}>"
    val html_len = html.len()
    while pos < html_len:
        val start = find_text(html, open_tag, pos)
        if start < 0:
            result = "{result}{html[pos:html.len()]}"
            return result
        result = "{result}{html[pos:start]}"
        val open_end = find_text(html, ">", start)
        if open_end < 0:
            return result
        val end = find_text(html, close_tag, open_end + 1)
        if end < 0:
            return result
        pos = end + close_tag.len()
    result

fn _guest_runtime_probe_url(url: text) -> bool:
    url.starts_with("https://guest.runtime/")

fn _extract_simple_js_assignment(script: text, prefix: text) -> Option<text>:
    if not script.contains(prefix):
        return nil
    if val Some(start_idx) = script.index_of(prefix):
        val value_start = start_idx + prefix.len()
        if value_start >= script.len():
            return nil
        val quote = script[value_start:value_start + 1]
        if quote != "'" and quote != "\"":
            return nil
        val rest = script.substring(value_start + 1, script.len())
        if val Some(rel_end) = rest.index_of(quote):
            return Some(rest.substring(0, rel_end))
    nil

fn extract_attr_value(tag_content: text, attr_name: text) -> text:
    val lower = tag_content.lower()
    val needle = attr_name.lower() + "="
    val idx = find_text(lower, needle, 0)
    if idx < 0:
        return ""
    val start = idx + needle.len()
    if start >= tag_content.len():
        return ""
    val quote = tag_content.slice(start, start + 1)
    if quote == "\"" or quote == "'":
        val end = find_text(tag_content, quote, start + 1)
        if end < 0:
            return ""
        return tag_content.slice(start + 1, end)
    var end = start
    val tag_len = tag_content.len()
    while end < tag_len:
        val ch = tag_content.slice(end, end + 1)
        if ch == " " or ch == ">" or ch == "\n" or ch == "\t":
            return tag_content.slice(start, end)
        end = end + 1
    tag_content.slice(start, tag_content.len())

fn has_tag_attr(tag_content: text, attr_name: text) -> bool:
    val lower = tag_content.lower()
    val padded = " " + attr_name.lower()
    lower.contains(padded + " ") or
        lower.contains(padded + ">") or
        lower.contains(padded + "=") or
        lower.ends_with(padded)

fn extract_stylesheet_sources(html: text) -> [BrowserStylesheetSource]:
    val source_count = stylesheet_source_count(html)
    if source_count == 0:
        return []
    var sources: [BrowserStylesheetSource] = [BrowserStylesheetSource.inline(""); source_count]
    var write_idx = 0
    var style_pos = 0
    val html_len = html.len()
    while style_pos < html_len:
        val start = find_text(html, "<style", style_pos)
        if start < 0:
            break
        val tag_end = find_text(html, ">", start)
        if tag_end < 0:
            break
        val close = find_text(html, "</style>", tag_end + 1)
        if close < 0:
            break
        val content = html[tag_end + 1:close].trim()
        if content != "":
            sources[write_idx] = BrowserStylesheetSource.inline(content)
            write_idx = write_idx + 1
        style_pos = close + 8
    var link_pos = 0
    while link_pos < html_len:
        val start = find_text(html, "<link", link_pos)
        if start < 0:
            break
        val tag_end = find_text(html, ">", start)
        if tag_end < 0:
            break
        val tag_content = html[start:tag_end + 1]
        val rel_value = extract_attr_value(tag_content, "rel").lower()
        val href_value = extract_attr_value(tag_content, "href")
        if href_value != "" and rel_contains_stylesheet(rel_value):
            sources[write_idx] = BrowserStylesheetSource.external(href_value)
            write_idx = write_idx + 1
        link_pos = tag_end + 1
    sources

fn stylesheet_source_count(html: text) -> i32:
    var count = 0
    var style_pos = 0
    val html_len = html.len()
    while style_pos < html_len:
        val start = find_text(html, "<style", style_pos)
        if start < 0:
            break
        val tag_end = find_text(html, ">", start)
        if tag_end < 0:
            break
        val close = find_text(html, "</style>", tag_end + 1)
        if close < 0:
            break
        val content = html[tag_end + 1:close].trim()
        if content != "":
            count = count + 1
        style_pos = close + 8
    var link_pos = 0
    while link_pos < html_len:
        val start = find_text(html, "<link", link_pos)
        if start < 0:
            break
        val tag_end = find_text(html, ">", start)
        if tag_end < 0:
            break
        val tag_content = html[start:tag_end + 1]
        val rel_value = extract_attr_value(tag_content, "rel").lower()
        val href_value = extract_attr_value(tag_content, "href")
        if href_value != "" and rel_contains_stylesheet(rel_value):
            count = count + 1
        link_pos = tag_end + 1
    count

fn rel_contains_stylesheet(rel_value: text) -> bool:
    for part in rel_value.split(" "):
        if part.trim() == "stylesheet":
            return true
    false

fn expand_stylesheet_text(document_url: text, base_url: text, css_text: text) -> BrowserStylesheetExpansion:
    val imports = extract_css_import_sources(base_url, css_text)
    val cleaned = strip_css_imports(css_text).trim()
    val html = if cleaned != "": "<style>{cleaned}</style>" else: ""
    BrowserStylesheetExpansion.create(html, imports)

fn extract_css_import_sources(base_url: text, css_text: text) -> [BrowserStylesheetSource]:
    val source_count = css_import_source_count(css_text)
    if source_count == 0:
        return []
    var sources: [BrowserStylesheetSource] = [BrowserStylesheetSource.external(""); source_count]
    var write_idx = 0
    var pos = 0
    val css_len = css_text.len()
    while pos < css_len:
        val at = find_text(css_text, "@import", pos)
        if at < 0:
            return sources
        val semi = find_text(css_text, ";", at)
        if semi < 0:
            return sources
        val stmt = css_text.slice(at, semi + 1)
        val href = extract_css_import_href(stmt)
        if href != "":
            sources[write_idx] = BrowserStylesheetSource.external(resolve_relative_url(base_url, href))
            write_idx = write_idx + 1
        pos = semi + 1
    sources

fn css_import_source_count(css_text: text) -> i32:
    var count = 0
    var pos = 0
    val css_len = css_text.len()
    while pos < css_len:
        val at = find_text(css_text, "@import", pos)
        if at < 0:
            return count
        val semi = find_text(css_text, ";", at)
        if semi < 0:
            return count
        val stmt = css_text.slice(at, semi + 1)
        val href = extract_css_import_href(stmt)
        if href != "":
            count = count + 1
        pos = semi + 1
    count

fn strip_css_imports(css_text: text) -> text:
    var out = ""
    var pos = 0
    val css_len = css_text.len()
    while pos < css_len:
        val at = find_text(css_text, "@import", pos)
        if at < 0:
            return out + css_text.slice(pos, css_text.len())
        out = out + css_text.slice(pos, at)
        val semi = find_text(css_text, ";", at)
        if semi < 0:
            return out
        pos = semi + 1
    out

fn extract_css_import_href(stmt: text) -> text:
    val url_idx = find_text(stmt.lower(), "url(", 0)
    if url_idx >= 0:
        val close = find_text(stmt, ")", url_idx + 4)
        if close > url_idx:
            return trim_css_import_url(stmt.slice(url_idx + 4, close))
    val single = find_text(stmt, "'", 0)
    if single >= 0:
        val end = find_text(stmt, "'", single + 1)
        if end > single:
            return stmt.slice(single + 1, end)
    val double = find_text(stmt, "\"", 0)
    if double >= 0:
        val end = find_text(stmt, "\"", double + 1)
        if end > double:
            return stmt.slice(double + 1, end)
    ""

fn trim_css_import_url(value: text) -> text:
    var trimmed = value.trim()
    if trimmed.starts_with("'") and trimmed.ends_with("'") and trimmed.len() >= 2:
        trimmed = trimmed.slice(1, trimmed.len() - 1)
    else if trimmed.starts_with("\"") and trimmed.ends_with("\"") and trimmed.len() >= 2:
        trimmed = trimmed.slice(1, trimmed.len() - 1)
    trimmed

fn insert_stylesheet_sources(existing: [BrowserStylesheetSource], index: i32, additions: [BrowserStylesheetSource]) -> [BrowserStylesheetSource]:
    val additions_count = additions.len()
    if additions_count == 0:
        return existing
    val existing_count = existing.len()
    val seed = if existing_count > 0: existing[0] else: additions[0]
    var out: [BrowserStylesheetSource] = [seed; existing_count + additions_count]
    var i = 0
    var write_idx = 0
    while i < existing_count:
        if i == index:
            var add_idx = 0
            while add_idx < additions_count:
                out[write_idx] = additions[add_idx]
                write_idx = write_idx + 1
                add_idx = add_idx + 1
        out[write_idx] = existing[i]
        write_idx = write_idx + 1
        i = i + 1
    if index >= existing_count:
        var add_idx = 0
        while add_idx < additions_count:
            out[write_idx] = additions[add_idx]
            write_idx = write_idx + 1
            add_idx = add_idx + 1
    out
