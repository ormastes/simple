# Glass Demo Registry
#
# Catalogs all glassmorphism-themed UI demo SDN files for
# cross-pipeline pixel comparison testing.

# ============================================================================
# Types
# ============================================================================

struct GlassDemo:
    """A glass-themed UI demo for pipeline comparison."""
    name: text           # e.g., "demo_kitchen_sink"
    sdn_path: text       # e.g., "examples/ui/demo_kitchen_sink.ui.sdn"
    theme: text          # "glass_dark" or "glass_light"

# ============================================================================
# Registry
# ============================================================================

fn list_glass_demos() -> [GlassDemo]:
    """Return all glass demo entries — each SDN file × 2 themes."""
    val sdn_files: [text] = [
        "demo",
        "demo_basics",
        "demo_button_checkbox_dropdown",
        "demo_collections",
        "demo_controls",
        "demo_display",
        "demo_forms",
        "demo_input_textfield",
        "demo_kitchen_sink",
        "demo_layouts",
        "demo_menu_tooltip",
        "demo_menubar_statusbar",
        "demo_navigation",
        "demo_overlays",
        "demo_panel_text_divider",
        "demo_progress_image_tooltip",
        "demo_scroll_textarea",
        "demo_table_list",
        "demo_tabs_list_dialog",
        "demo_themes",
        "demo_tree",
        "demo_validation",
        "hello_electron",
        "hello_gui",
        "hello_web",
        "minimal",
        "widget_matrix"
    ]

    var demos: [GlassDemo] = []
    for name in sdn_files:
        val path = "examples/ui/{name}.ui.sdn"
        demos.push(GlassDemo(name: "{name}_dark", sdn_path: path, theme: "glass_dark"))
        demos.push(GlassDemo(name: "{name}_light", sdn_path: path, theme: "glass_light"))
    demos

fn list_glass_demos_dark_only() -> [GlassDemo]:
    """Return only glass_dark entries (faster subset for quick testing)."""
    val all = list_glass_demos()
    var dark: [GlassDemo] = []
    for d in all:
        if d.theme == "glass_dark":
            dark.push(d)
    dark

fn list_core_glass_demos() -> [GlassDemo]:
    """Return a small core set for fast iteration (3 demos × 2 themes)."""
    [
        GlassDemo(name: "minimal_dark", sdn_path: "examples/ui/minimal.ui.sdn", theme: "glass_dark"),
        GlassDemo(name: "minimal_light", sdn_path: "examples/ui/minimal.ui.sdn", theme: "glass_light"),
        GlassDemo(name: "demo_basics_dark", sdn_path: "examples/ui/demo_basics.ui.sdn", theme: "glass_dark"),
        GlassDemo(name: "demo_basics_light", sdn_path: "examples/ui/demo_basics.ui.sdn", theme: "glass_light"),
        GlassDemo(name: "kitchen_sink_dark", sdn_path: "examples/ui/demo_kitchen_sink.ui.sdn", theme: "glass_dark"),
        GlassDemo(name: "kitchen_sink_light", sdn_path: "examples/ui/demo_kitchen_sink.ui.sdn", theme: "glass_light")
    ]
