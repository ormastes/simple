"""
# FetchDispatch

Seam interface between ScriptHost and FetchClient.
ScriptHost holds a nullable FetchDispatch? field; if none, fetch() throws NetworkError.
NoopFetchDispatch is used in tests that don't need real network.
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, FetchResponse}

pub trait FetchDispatch:
    """Interface between ScriptHost and the fetch implementation."""
    fn dispatch(request: FetchRequest) -> FetchResponse

pub class NoopFetchDispatch:
    """A FetchDispatch that performs no network I/O.

    Returns zero-status empty responses. Used as a test double when real
    network is not needed.
    """

    static fn new() -> NoopFetchDispatch:
        """Create a NoopFetchDispatch."""
        return NoopFetchDispatch {}

    me fn dispatch(request: FetchRequest) -> FetchResponse:
        """Return an empty zero-status response (no network call)."""
        return FetchResponse {
            status: 0,
            headers: "",
            body: []
        }
