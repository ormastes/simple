"""
# Clipboard API

In-memory clipboard for the Simple browser engine.

JS Equivalent → Simple Function:
    navigator.clipboard.writeText() → clipboard_write_text()
    navigator.clipboard.readText()  → clipboard_read_text()
"""

#![allow(REQC001)]

# =========================================================================
# BrowserClipboard
# =========================================================================

pub class BrowserClipboard:
    """In-memory clipboard holding a single text value.

    Fields:
        _text - current clipboard text content
    """
    _text: text

    static fn new() -> BrowserClipboard:
        """Create an empty clipboard."""
        BrowserClipboard(_text: "")

# =========================================================================
# Clipboard Operations
# =========================================================================

pub fn clipboard_write_text(clip: BrowserClipboard, txt: text):
    """Write text to the clipboard."""
    clip._text = txt

pub fn clipboard_read_text(clip: BrowserClipboard) -> text:
    """Read text from the clipboard."""
    clip._text
