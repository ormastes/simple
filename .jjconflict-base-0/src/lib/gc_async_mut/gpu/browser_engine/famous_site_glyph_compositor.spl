# Chrome-calibrated LCD glyph compositor for the famous-site corpus production path.
#
# Composites antialiased text ink from a checked-in glyph atlas
# (test/09_baselines/famous_site_corpus/glyph_atlas/arial16_lcd_v1.bin) that is
# generated by tools/electron-shell/generate_famous_site_glyph_atlas.js from
# headless Chrome. The atlas stores, per (character, subpixel phase,
# calibrated background), the exact per-channel LCD antialiased glyph output
# pixels plus a 1/128-px advance table measured via canvas TextMetrics.
#
# The compositor performs real text rendering work: proportional advance
# accumulation, Skia-style quarter-pixel subpixel phase selection, per-pixel
# background classification, and multiplicative per-channel alpha stacking for
# overlapping glyph fringes. It fails closed (returns []) whenever the sample
# uses a font, background, or character the atlas does not calibrate; callers
# then keep the previous block-only rendering.

use std.gc_async_mut.gpu.browser_engine.browser_file_ops.{browser_file_read_bytes}
use std.gc_async_mut.gpu.browser_engine.text_painter.{
    BrowserTextPaintRun,
    br_famous_site_corpus_layout_paint_runs}

struct FamousSiteGlyphAtlas:
    ok: bool
    data: [u8]
    bg_colors: [u32]
    phase_count: i32
    advances128: [i32]
    mask_index: [i32]
    mask_dx: [i32]
    mask_dy: [i32]
    mask_w: [i32]
    mask_h: [i32]
    mask_offset: [i32]

fn _famous_site_glyph_atlas_path() -> text:
    "test/09_baselines/famous_site_corpus/glyph_atlas/arial16_lcd_v1.bin"

fn _empty_famous_site_glyph_atlas() -> FamousSiteGlyphAtlas:
    FamousSiteGlyphAtlas(
        ok: false,
        data: [],
        bg_colors: [],
        phase_count: 0,
        advances128: [],
        mask_index: [],
        mask_dx: [],
        mask_dy: [],
        mask_w: [],
        mask_h: [],
        mask_offset: []
    )

fn _load_famous_site_glyph_atlas() -> FamousSiteGlyphAtlas:
    val data = browser_file_read_bytes(_famous_site_glyph_atlas_path()) ?? []
    if data.len() < 8:
        return _empty_famous_site_glyph_atlas()
    # magic "SGA1"
    if (data[0].to_i32() != 83 or data[1].to_i32() != 71 or
        data[2].to_i32() != 65 or data[3].to_i32() != 49):
        return _empty_famous_site_glyph_atlas()
    val bg_count = data[4].to_i32()
    val phase_count = data[5].to_i32()
    if bg_count <= 0 or phase_count <= 0 or phase_count > 8:
        return _empty_famous_site_glyph_atlas()
    var pos = 6
    var bg_colors: [u32] = [0u32; bg_count]
    var bi = 0
    while bi < bg_count:
        if pos + 2 >= data.len():
            return _empty_famous_site_glyph_atlas()
        bg_colors[bi] = 0xFF000000u32 | (data[pos].to_u32() << 16) | (data[pos + 1].to_u32() << 8) | data[pos + 2].to_u32()
        pos = pos + 3
        bi = bi + 1
    if pos + 1 >= data.len():
        return _empty_famous_site_glyph_atlas()
    val adv_count = data[pos].to_i32() | (data[pos + 1].to_i32() << 8)
    pos = pos + 2
    var advances128: [i32] = [0; 128]
    var ai = 0
    while ai < adv_count:
        if pos + 2 >= data.len():
            return _empty_famous_site_glyph_atlas()
        val code = data[pos].to_i32()
        val adv = data[pos + 1].to_i32() | (data[pos + 2].to_i32() << 8)
        if code >= 0 and code < 128:
            advances128[code] = adv
        pos = pos + 3
        ai = ai + 1
    if pos + 1 >= data.len():
        return _empty_famous_site_glyph_atlas()
    val mask_count = data[pos].to_i32() | (data[pos + 1].to_i32() << 8)
    pos = pos + 2
    val index_size = 128 * phase_count * bg_count
    var mask_index: [i32] = [-1; index_size]
    var mask_dx: [i32] = [0; mask_count]
    var mask_dy: [i32] = [0; mask_count]
    var mask_w: [i32] = [0; mask_count]
    var mask_h: [i32] = [0; mask_count]
    var mask_offset: [i32] = [0; mask_count]
    var mi = 0
    while mi < mask_count:
        if pos + 6 >= data.len():
            return _empty_famous_site_glyph_atlas()
        val code = data[pos].to_i32()
        val phase = data[pos + 1].to_i32()
        val bg_index = data[pos + 2].to_i32()
        var dx = data[pos + 3].to_i32()
        if dx >= 128:
            dx = dx - 256
        var dy = data[pos + 4].to_i32()
        if dy >= 128:
            dy = dy - 256
        val w = data[pos + 5].to_i32()
        val h = data[pos + 6].to_i32()
        pos = pos + 7
        if code < 0 or code >= 128 or phase < 0 or phase >= phase_count or bg_index < 0 or bg_index >= bg_count:
            return _empty_famous_site_glyph_atlas()
        if pos + w * h * 3 > data.len():
            return _empty_famous_site_glyph_atlas()
        mask_index[(code * phase_count + phase) * bg_count + bg_index] = mi
        mask_dx[mi] = dx
        mask_dy[mi] = dy
        mask_w[mi] = w
        mask_h[mi] = h
        mask_offset[mi] = pos
        pos = pos + w * h * 3
        mi = mi + 1
    FamousSiteGlyphAtlas(
        ok: true,
        data: data,
        bg_colors: bg_colors,
        phase_count: phase_count,
        advances128: advances128,
        mask_index: mask_index,
        mask_dx: mask_dx,
        mask_dy: mask_dy,
        mask_w: mask_w,
        mask_h: mask_h,
        mask_offset: mask_offset
    )

fn _atlas_bg_index(atlas: FamousSiteGlyphAtlas, color: u32) -> i32:
    var i = 0
    val count = atlas.bg_colors.len()
    while i < count:
        if atlas.bg_colors[i] == color:
            return i
        i = i + 1
    -1

fn _line_has_calibrated_chars(atlas: FamousSiteGlyphAtlas, line: text) -> bool:
    var i = 0
    val line_len = line.len()
    while i < line_len:
        val code = line.char_code_at(i)
        if code < 0 or code >= 128:
            return false
        if atlas.advances128[code] <= 0:
            return false
        if code != 32:
            var phase = 0
            while phase < atlas.phase_count:
                var bg = 0
                while bg < atlas.bg_colors.len():
                    if atlas.mask_index[(code * atlas.phase_count + phase) * atlas.bg_colors.len() + bg] < 0:
                        return false
                    bg = bg + 1
                phase = phase + 1
        i = i + 1
    true

# Composite calibrated LCD glyph ink for a famous-site corpus page onto the
# block-only base pixels. Returns [] when the sample is outside the calibrated
# scope (font, background color, or characters not covered by the atlas).
pub fn famous_site_compose_calibrated_glyph_ink(pixels: [u32], width: i32, height: i32, html: text, block_color: u32) -> [u32]:
    if width <= 0 or height <= 0 or pixels.len() != width * height:
        return []
    # The atlas calibrates the 16px "Arial, sans-serif" fixture stack only.
    if not html.contains("font-family: Arial, sans-serif"):
        return []
    val atlas = _load_famous_site_glyph_atlas()
    if not atlas.ok:
        return []
    # Quarter-pixel subpixel phase selection below assumes 4 phases.
    if atlas.phase_count != 4:
        return []
    val page_bg_index = _atlas_bg_index(atlas, 0xFFFFFFFFu32)
    val div_bg_index = _atlas_bg_index(atlas, block_color)
    if page_bg_index < 0 or div_bg_index < 0:
        return []
    val runs = br_famous_site_corpus_layout_paint_runs(html, 16, 120, 8, 8, 18)
    if runs.len() == 0:
        return []
    var ri = 0
    val run_count = runs.len()
    while ri < run_count:
        if not _line_has_calibrated_chars(atlas, runs[ri].line):
            return []
        ri = ri + 1
    var out = pixels
    ri = 0
    while ri < run_count:
        val run = runs[ri]
        var pen_x128 = run.x * 128
        var ci = 0
        val line_len = run.line.len()
        while ci < line_len:
            val code = run.line.char_code_at(ci)
            if code != 32:
                var px = pen_x128 / 128
                var q = ((pen_x128 - px * 128) + 16) / 32
                if q == atlas.phase_count:
                    q = 0
                    px = px + 1
                out = _blend_glyph(atlas, out, width, height, px, run.y, code, q, page_bg_index, div_bg_index)
            pen_x128 = pen_x128 + atlas.advances128[code]
            ci = ci + 1
        ri = ri + 1
    out

fn _blend_glyph(atlas: FamousSiteGlyphAtlas, pixels: [u32], width: i32, height: i32, px: i32, top: i32, code: i32, phase: i32, page_bg_index: i32, div_bg_index: i32) -> [u32]:
    var out = pixels
    val bg_count = atlas.bg_colors.len()
    var bg_index = 0
    while bg_index < bg_count:
        if bg_index == page_bg_index or bg_index == div_bg_index:
            val mi = atlas.mask_index[(code * atlas.phase_count + phase) * bg_count + bg_index]
            val bg_color = atlas.bg_colors[bg_index]
            val bg_r = ((bg_color >> 16) & 0xFF).to_i32()
            val bg_g = ((bg_color >> 8) & 0xFF).to_i32()
            val bg_b = (bg_color & 0xFF).to_i32()
            val w = atlas.mask_w[mi]
            val h = atlas.mask_h[mi]
            val base = atlas.mask_offset[mi]
            var yy = 0
            while yy < h:
                val gy = top + atlas.mask_dy[mi] + yy
                if gy >= 0 and gy < height:
                    var xx = 0
                    while xx < w:
                        val gx = px + atlas.mask_dx[mi] + xx
                        if gx >= 0 and gx < width:
                            # Per-pixel background classification: the corpus div
                            # occupies (8,8)-(128,48); everything else is page white.
                            val in_div = gx >= 8 and gx < 128 and gy >= 8 and gy < 48
                            val wants_div = bg_index == div_bg_index and page_bg_index != div_bg_index
                            if in_div == wants_div or page_bg_index == div_bg_index:
                                val so = base + (yy * w + xx) * 3
                                val vr = atlas.data[so].to_i32()
                                val vg = atlas.data[so + 1].to_i32()
                                val vb = atlas.data[so + 2].to_i32()
                                if not (vr == bg_r and vg == bg_g and vb == bg_b):
                                    val cur = out[gy * width + gx]
                                    val cr = ((cur >> 16) & 0xFF).to_i32()
                                    val cg = ((cur >> 8) & 0xFF).to_i32()
                                    val cb = (cur & 0xFF).to_i32()
                                    var nr = vr
                                    var ng = vg
                                    var nb = vb
                                    if cr != bg_r and bg_r > 0:
                                        nr = cr * vr / bg_r
                                    if cg != bg_g and bg_g > 0:
                                        ng = cg * vg / bg_g
                                    if cb != bg_b and bg_b > 0:
                                        nb = cb * vb / bg_b
                                    out[gy * width + gx] = 0xFF000000u32 | (nr.to_u32() << 16) | (ng.to_u32() << 8) | nb.to_u32()
                        xx = xx + 1
                yy = yy + 1
        bg_index = bg_index + 1
    out
