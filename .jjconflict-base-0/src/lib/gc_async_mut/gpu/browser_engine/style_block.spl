# Style Block Processor — <style> tag CSS rule extraction and application
#
# Extracts CSS rules from <style> blocks in HTML, parses simple selectors
# (tag, .class, #id, compound), and applies matched styles to DOM nodes.
#
# Supports:
#   - Tag selectors: div, span, p, h1-h6, etc.
#   - Class selectors: .container, .active
#   - ID selectors: #main, #header
#   - Attribute selectors: [data-state], div[data-state="active"], prefix/suffix/substring/token/dash operators, i/s flags (partial)
#   - Compound: div.active, span.highlight
#   - Comma-separated: div, span { ... }
#   - Descendant: div span { ... } (limited — matches if ANY ancestor matches)
#   - Pseudo-classes: :nth-child(N/odd/even/common an+b forms) (bounded), :first-child, :last-child, :only-child, :empty, :is(), :where(), :not(), :has()
#     :has() supports simple descendant options and bounded relative child options (`> .class`, `> tag`, `> #id`).
#   - Shorthand properties: flex, border, background, margin multi-value
#
# Split into:
#   style_block.spl         — this file: types, helpers, apply-to-tree, public API
#   style_block_parse.spl   — keyframes, CSS parsing, shorthand expansion, var resolution
#   style_block_resolve.spl — selector matching

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.dom_accessors.{
    be_dom_get_tag, be_dom_get_id, be_dom_get_classes, be_dom_get_children,
    be_dom_get_is_text, be_dom_get_text, be_dom_set_children, be_dom_get_bg_color,
    be_dom_get_attr, be_dom_has_attr}
use std.gc_async_mut.gpu.browser_engine.dom_color.{parse_color_value}
use std.gc_async_mut.gpu.browser_engine.css.{parse_css_value, BoxEdges,
    BorderProps, CssValue}
use common.string_builder.{StringBuilder}
use std.gc_async_mut.gpu.browser_engine.style.supports.{eval_supports_query}
use std.gc_async_mut.gpu.browser_engine.style.custom_properties.{has_var_reference, parse_var_function}
use std.gc_async_mut.gpu.browser_engine.style.animation.{Keyframe, CSSValue, CSSDeclaration}
use std.gc_async_mut.gpu.browser_engine.style_block_parse.{
    extract_style_blocks, extract_keyframes, parse_css_rules,
    collect_css_vars, resolve_css_vars_in_rules}
use std.gc_async_mut.gpu.browser_engine.style_block_resolve.{selector_matches}

# =========================================================================
# CSS Rule types
# =========================================================================

pub class CssRule:
    selector: text
    declarations: [CssDecl]

pub class CssDecl:
    property: text
    value: text

pub fn css_decl_property(decl: CssDecl) -> text:
    decl.property

pub fn css_decl_value(decl: CssDecl) -> text:
    decl.value

pub fn css_decls_contain(decls: [CssDecl], property: text, value: text) -> bool:
    var i = 0
    while i < decls.len():
        val decl = decls[i]
        i = i + 1
        if decl.property == property and decl.value == value:
            return true
    false

# =========================================================================
# Apply rules to DOM tree
# =========================================================================

fn apply_css_rules_to_tree(root: BeDomNode, rules: [CssRule]):
    apply_rules_to_node(root, rules, nil, 1, 1)

fn apply_rules_to_node(node: BeDomNode, rules: [CssRule], parent: BeDomNode?, nth: i32, sibling_count: i32):
    if be_dom_get_is_text(node):
        return

    # Skip style/link/meta/title/head/html/!doctype elements
    val tag = be_dom_get_tag(node)
    if tag == "style" or tag == "link" or tag == "meta" or tag == "title" or tag == "head":
        return

    var color_ru_idx = 0
    while color_ru_idx < rules.len():
        val rule = rules[color_ru_idx]
        color_ru_idx = color_ru_idx + 1
        if selector_matches(rule.selector, node, parent, nth, sibling_count):
            var dc_idx = 0
            while dc_idx < rule.declarations.len():
                val decl = rule.declarations[dc_idx]
                dc_idx = dc_idx + 1
                if decl.property == "color":
                    node.set_style(decl.property, decl.value)
    var ru_idx = 0
    while ru_idx < rules.len():
        val rule = rules[ru_idx]
        ru_idx = ru_idx + 1
        if selector_matches(rule.selector, node, parent, nth, sibling_count):
            var dc_idx = 0
            while dc_idx < rule.declarations.len():
                val decl = rule.declarations[dc_idx]
                dc_idx = dc_idx + 1
                if decl.property != "color":
                    node.set_style(decl.property, decl.value)

    # Recurse to children with nth tracking, rebuilding the children array.
    # The interpreter copies class instances on array index/push, so the
    # `child` we fetch from children[i] is a detached copy. We style it,
    # recurse (which rebuilds its grandchildren in turn), then push the
    # styled copy into a new array and write the new array back via
    # be_dom_set_children so the parent sees the changes.
    var child_nth = 1
    val sb_kids = be_dom_get_children(node)
    var child_count = 0
    var count_idx = 0
    while count_idx < sb_kids.len():
        if not be_dom_get_is_text(sb_kids[count_idx]):
            child_count = child_count + 1
        count_idx = count_idx + 1
    var new_kids: [BeDomNode] = []
    var sc_idx = 0
    while sc_idx < sb_kids.len():
        var child = sb_kids[sc_idx]
        sc_idx = sc_idx + 1
        apply_rules_to_node(child, rules, node, child_nth, child_count)
        new_kids.push(child)
        if not be_dom_get_is_text(child):
            child_nth = child_nth + 1
    be_dom_set_children(node, new_kids)

# =========================================================================
# Public API: process HTML with <style> blocks
# =========================================================================

pub fn process_style_blocks(root: BeDomNode, html: text):
    val blocks = extract_style_blocks(html)
    var all_rules: [CssRule] = []
    var all_vars: [CssDecl] = []
    var bl_idx = 0
    while bl_idx < blocks.len():
        val block = blocks[bl_idx]
        bl_idx = bl_idx + 1
        val _kf_registry = extract_keyframes(block)
        val rules = parse_css_rules(block)
        val vars = collect_css_vars(rules)
        var vi = 0
        while vi < vars.len():
            all_vars.push(vars[vi])
            vi = vi + 1
        var ri_idx = 0
        while ri_idx < rules.len():
            val r = rules[ri_idx]
            ri_idx = ri_idx + 1
            all_rules.push(r)
    if all_rules.len() > 0:
        val resolved_rules = resolve_css_vars_in_rules(all_rules, all_vars)
        apply_css_rules_to_tree(root, resolved_rules)

pub fn process_style_blocks_result(root: BeDomNode, html: text) -> BeDomNode:
    process_style_blocks(root, html)
    root

# =========================================================================
# Helpers (shared by style_block_parse and style_block_resolve via import)
# =========================================================================

pub fn sb_find(s: text, target: text, start: i64) -> i64:
    var i = start
    val tlen = target.len()
    val slen = s.len()
    while i + tlen <= slen:
        if s.slice(i, i + tlen) == target:
            return i
        i = i + 1
    999999999

pub fn sb_split_char(s: text, delimiter: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == delimiter:
            parts.push(sb.to_text())
            sb.clear()
        else:
            sb.push(ch)
        idx = idx + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

pub fn sb_split_selector_list(s: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx = 0
    var paren_depth = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == "(":
            paren_depth = paren_depth + 1
            sb.push(ch)
        elif ch == ")" and paren_depth > 0:
            paren_depth = paren_depth - 1
            sb.push(ch)
        elif ch == "," and paren_depth == 0:
            parts.push(sb.to_text())
            sb.clear()
        else:
            sb.push(ch)
        idx = idx + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

pub fn sb_find_top_level_child_combinator(s: text) -> i64:
    var idx = 0
    var paren_depth = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == "(":
            paren_depth = paren_depth + 1
        elif ch == ")" and paren_depth > 0:
            paren_depth = paren_depth - 1
        elif ch == ">" and paren_depth == 0:
            return idx
        idx = idx + 1
    999999999

pub fn sb_split_ws(s: text) -> [text]:
    var parts: [text] = []
    val sb = StringBuilder.new()
    var idx = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if not sb.is_empty():
                parts.push(sb.to_text())
                sb.clear()
        else:
            sb.push(ch)
        idx = idx + 1
    if not sb.is_empty():
        parts.push(sb.to_text())
    parts

pub fn sb_skip_ws_comments(s: text, start: i64) -> i64:
    var pos = start
    val slen = s.len()
    while pos < slen:
        val ch = s.char_at(pos)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            pos = pos + 1
            continue
        # CSS comment: /* ... */
        if pos + 1 < slen and s.slice(pos, pos + 2) == "/*":
            val end = sb_find(s, "*/", pos + 2)
            if end < 999999999:
                pos = end + 2
                continue
            break
        break
    pos

pub fn sb_parse_int(s: text) -> i32:
    """Manual integer parser avoiding optional type bugs in Cranelift."""
    val t = s.trim()
    if t.len() == 0:
        return 0
    var neg = false
    var start = 0
    if t.slice(0, 1) == "-":
        neg = true
        start = 1
    elif t.slice(0, 1) == "+":
        start = 1
    var result = 0
    var idx = start
    val slen = t.len()
    while idx < slen:
        val ch = t.char_at(idx)
        var digit = -1
        if ch == "0": digit = 0
        elif ch == "1": digit = 1
        elif ch == "2": digit = 2
        elif ch == "3": digit = 3
        elif ch == "4": digit = 4
        elif ch == "5": digit = 5
        elif ch == "6": digit = 6
        elif ch == "7": digit = 7
        elif ch == "8": digit = 8
        elif ch == "9": digit = 9
        if digit < 0:
            break
        result = result * 10 + digit
        idx = idx + 1
    if neg:
        return 0 - result
    result

pub fn find_matching_brace(text_val: text, open: i32) -> i32:
    var depth = 0
    var pos = open
    while pos < text_val.len():
        val ch = text_val.char_at(pos)
        if ch == "{":
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0:
                return pos
        pos = pos + 1
    999999999
