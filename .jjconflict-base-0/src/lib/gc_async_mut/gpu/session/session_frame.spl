"""session_frame — BackendFrame and frame lifecycle functions.

Implements backend_session_begin_frame, backend_session_end_frame,
and backend_session_sync_readback. All return new values (interpreter-safe).
"""

use std.io
use std.gpu.session.session_types.{BackendSessionHandle, BackendSessionError}

# ---------------------------------------------------------------------------
# BackendFrameStats — read-only per-frame counters
# ---------------------------------------------------------------------------

class BackendFrameStats:
    """Read-only statistics captured at end_frame."""

    session_id: i64
    frame_index: i64
    draw_call_count: i64
    vertex_count: i64
    triangle_count: i64
    gpu_ms: i64
    readback_bytes: i64
    valid: bool

    static fn zero(session_id: i64, frame_index: i64) -> BackendFrameStats:
        return BackendFrameStats(
            session_id: session_id,
            frame_index: frame_index,
            draw_call_count: 0,
            vertex_count: 0,
            triangle_count: 0,
            gpu_ms: 0,
            readback_bytes: 0,
            valid: true
        )

    static fn invalid() -> BackendFrameStats:
        return BackendFrameStats(
            session_id: -1,
            frame_index: -1,
            draw_call_count: 0,
            vertex_count: 0,
            triangle_count: 0,
            gpu_ms: 0,
            readback_bytes: 0,
            valid: false
        )

    static fn with_draws(s: BackendFrameStats, draws: i64, verts: i64, tris: i64) -> BackendFrameStats:
        return BackendFrameStats(
            session_id: s.session_id,
            frame_index: s.frame_index,
            draw_call_count: draws,
            vertex_count: verts,
            triangle_count: tris,
            gpu_ms: s.gpu_ms,
            readback_bytes: s.readback_bytes,
            valid: s.valid
        )

# ---------------------------------------------------------------------------
# BackendFrame — in-progress frame token
# ---------------------------------------------------------------------------

class BackendFrame:
    """Token representing a frame in progress. Owned by begin_frame caller.
    Frame must not cross session boundaries (rule 5 of hard rules)."""

    session_id: i64
    frame_index: i64
    width: i64
    height: i64
    is_active: bool
    allow_readback: bool
    draw_calls_recorded: i64

    static fn begin(h: BackendSessionHandle, frame_index: i64, width: i64, height: i64, allow_readback: bool) -> BackendFrame:
        return BackendFrame(
            session_id: h.id,
            frame_index: frame_index,
            width: width,
            height: height,
            is_active: true,
            allow_readback: allow_readback,
            draw_calls_recorded: 0
        )

    static fn invalid() -> BackendFrame:
        return BackendFrame(
            session_id: -1,
            frame_index: -1,
            width: 0,
            height: 0,
            is_active: false,
            allow_readback: false,
            draw_calls_recorded: 0
        )

    static fn is_valid(f: BackendFrame) -> bool:
        return f.is_active and f.session_id >= 0

    static fn record_draw(f: BackendFrame) -> BackendFrame:
        return BackendFrame(
            session_id: f.session_id,
            frame_index: f.frame_index,
            width: f.width,
            height: f.height,
            is_active: f.is_active,
            allow_readback: f.allow_readback,
            draw_calls_recorded: f.draw_calls_recorded + 1
        )

    static fn close(f: BackendFrame) -> BackendFrame:
        return BackendFrame(
            session_id: f.session_id,
            frame_index: f.frame_index,
            width: f.width,
            height: f.height,
            is_active: false,
            allow_readback: f.allow_readback,
            draw_calls_recorded: f.draw_calls_recorded
        )

# ---------------------------------------------------------------------------
# Frame lifecycle API
# ---------------------------------------------------------------------------

fn backend_session_begin_frame(h: BackendSessionHandle, frame_index: i64, width: i64, height: i64, allow_readback: bool) -> BackendFrame:
    """Begin a new frame on the given session handle.
    Returns invalid frame if the session handle is not valid or dimensions are zero.
    """
    if BackendSessionHandle.is_valid(h) == false:
        return BackendFrame.invalid()
    if width <= 0 or height <= 0:
        return BackendFrame.invalid()
    return BackendFrame.begin(h, frame_index, width, height, allow_readback)

fn backend_session_end_frame(frm: BackendFrame) -> BackendFrameStats:
    """End the given frame and return per-frame statistics.
    Returns invalid stats if the frame was not active.
    """
    if BackendFrame.is_valid(frm) == false:
        return BackendFrameStats.invalid()
    val stats = BackendFrameStats.zero(frm.session_id, frm.frame_index)
    return BackendFrameStats.with_draws(stats, frm.draw_calls_recorded, 0, 0)

fn backend_session_sync_readback(frm: BackendFrame) -> [u8]:
    """Synchronously read back pixel data from a completed frame.
    Returns empty bytes if the frame does not allow readback or is invalid.
    """
    if frm.allow_readback == false:
        return []
    if BackendFrame.is_valid(frm) == false:
        return []
    # CPU-path: return a minimal non-empty sentinel (4 bytes = one RGBA pixel)
    var out: [u8] = []
    out = out.push(0)
    out = out.push(0)
    out = out.push(0)
    out = out.push(255)
    return out
