# GraphicsSessionPolicy — Policy configuration for graphics sessions
#
# Encapsulates mode, backend, surface/queue/allocator/sync/readback/interop/
# optimization policies, and target architecture settings.

use std.io

class GraphicsSessionPolicy:
    """Configuration policy controlling how a GraphicsSession is created and managed."""

    mode: text
    backend_kind: text
    surface_policy: text
    queue_policy: text
    allocator_policy: text
    sync_policy: text
    readback_policy: text
    interop_policy: text
    optimization_policy: text
    target_arch: text
    target_bits: i64

    # -------------------------------------------------------------------------
    # Constructors
    # -------------------------------------------------------------------------

    static fn managed_shared(backend: text) -> GraphicsSessionPolicy:
        return GraphicsSessionPolicy(
            mode: "managed_shared",
            backend_kind: backend,
            surface_policy: "shared",
            queue_policy: "shared",
            allocator_policy: "pooled",
            sync_policy: "automatic",
            readback_policy: "allowed",
            interop_policy: "enabled",
            optimization_policy: "balanced",
            target_arch: "x86_64",
            target_bits: 64
        )

    static fn perf_exclusive(backend: text) -> GraphicsSessionPolicy:
        return GraphicsSessionPolicy(
            mode: "perf_exclusive",
            backend_kind: backend,
            surface_policy: "exclusive",
            queue_policy: "dedicated",
            allocator_policy: "direct",
            sync_policy: "manual",
            readback_policy: "restricted",
            interop_policy: "disabled",
            optimization_policy: "throughput",
            target_arch: "x86_64",
            target_bits: 64
        )

    static fn legacy_no_session() -> GraphicsSessionPolicy:
        return GraphicsSessionPolicy(
            mode: "legacy_no_session",
            backend_kind: "none",
            surface_policy: "none",
            queue_policy: "none",
            allocator_policy: "none",
            sync_policy: "none",
            readback_policy: "none",
            interop_policy: "none",
            optimization_policy: "none",
            target_arch: "x86_64",
            target_bits: 64
        )

    # -------------------------------------------------------------------------
    # Predicates
    # -------------------------------------------------------------------------

    me is_managed() -> bool:
        return self.mode == "managed_shared"

    me is_perf_exclusive() -> bool:
        return self.mode == "perf_exclusive"

    me is_legacy() -> bool:
        return self.mode == "legacy_no_session"
