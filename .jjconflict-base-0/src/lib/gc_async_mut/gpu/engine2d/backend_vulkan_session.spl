# Vulkan Backend Session Adapter
#
# Provides a session-aware Vulkan adapter that uses pre-compiled SPIR-V or
# feature-gated shader compilation, avoiding the unsupported GLSL runtime
# compilation path. Supports clear/rect/readback smoke operations.
#
# Usage:
#   use std.gpu.engine2d.backend_vulkan_session.{VulkanShaderMode, VulkanSessionBackend}

use std.gpu.engine2d.backend_vulkan_session_runtime_ops.{
    backend_vulkan_session_create_device,
    backend_vulkan_session_has_spirv_support,
    backend_vulkan_session_has_glslc,
    backend_vulkan_session_clear,
    backend_vulkan_session_draw_rect,
    backend_vulkan_session_readback,
    backend_vulkan_session_submit,
    backend_vulkan_session_present,
    backend_vulkan_session_cleanup
}

# ============================================================================
# VulkanShaderMode
# ============================================================================

class VulkanShaderMode:
    """Describes which shader compilation path is available."""
    mode: text  # "spirv_precompiled", "glslc_feature_gated", "unavailable"

    static fn spirv() -> VulkanShaderMode:
        VulkanShaderMode(mode: "spirv_precompiled")

    static fn glslc() -> VulkanShaderMode:
        VulkanShaderMode(mode: "glslc_feature_gated")

    static fn unavailable() -> VulkanShaderMode:
        VulkanShaderMode(mode: "unavailable")

# ============================================================================
# VulkanSessionBackend
# ============================================================================

class VulkanSessionBackend:
    """Session-aware Vulkan adapter with pre-compiled SPIR-V or glslc fallback.

    Lifecycle:
      val b = VulkanSessionBackend.create("default")
      val err = b.init_device()
      if err == "":
          b.clear(0, 0, 0, 255)
          b.draw_rect(10, 10, 100, 100, 0xFF0000FF)
          b.submit()
          b.present()
          b.cleanup()
    """
    handle: i64
    device_name: text
    shader_mode: text
    initialized: bool
    clear_count: i64
    rect_count: i64
    readback_count: i64
    last_error: text
    session_mode: text

    static fn create(session_mode: text) -> VulkanSessionBackend:
        """Return an uninitialised session adapter. Call init_device() before use."""
        VulkanSessionBackend(
            handle: 0,
            device_name: "none",
            shader_mode: "unavailable",
            initialized: false,
            clear_count: 0,
            rect_count: 0,
            readback_count: 0,
            last_error: "",
            session_mode: session_mode
        )

    me init_device() -> text:
        """Create Vulkan device and detect shader mode. Returns "" on success."""
        val h = backend_vulkan_session_create_device()
        if h == 0:
            self.last_error = "backend_vulkan_session_create_device returned null handle"
            return self.last_error
        self.handle = h
        self.shader_mode = self.detect_shader_mode()
        self.device_name = "vulkan_device"
        self.initialized = true
        ""

    me detect_shader_mode() -> text:
        """Returns "spirv_precompiled", "glslc_feature_gated", or "unavailable"."""
        if self.handle == 0:
            return "unavailable"
        if backend_vulkan_session_has_spirv_support(self.handle):
            return "spirv_precompiled"
        if backend_vulkan_session_has_glslc(self.handle):
            return "glslc_feature_gated"
        "unavailable"

    me clear(r: i64, g: i64, b: i64, a: i64) -> text:
        """Submit a clear command. Returns "" on success, error message on failure."""
        if self.initialized == false:
            return "not initialized"
        val err = backend_vulkan_session_clear(self.handle, r, g, b, a)
        if err == "":
            self.clear_count = self.clear_count + 1
        else:
            self.last_error = err
        err

    me draw_rect(x: i64, y: i64, w: i64, h: i64, color: i64) -> text:
        """Submit a filled-rect draw command. Returns "" on success."""
        if self.initialized == false:
            return "not initialized"
        val err = backend_vulkan_session_draw_rect(self.handle, x, y, w, h, color)
        if err == "":
            self.rect_count = self.rect_count + 1
        else:
            self.last_error = err
        err

    me readback(x: i64, y: i64, w: i64, h: i64) -> text:
        """Read pixels from the framebuffer region. Returns "" or error."""
        if self.initialized == false:
            return "not initialized"
        val err = backend_vulkan_session_readback(self.handle, x, y, w, h)
        if err == "":
            self.readback_count = self.readback_count + 1
        else:
            self.last_error = err
        err

    me submit() -> text:
        """Flush pending commands. Returns "" on success."""
        if self.initialized == false:
            return "not initialized"
        val total = self.clear_count + self.rect_count
        val err = backend_vulkan_session_submit(self.handle, total)
        if err != "":
            self.last_error = err
        err

    me present() -> text:
        """Present the rendered frame. Returns "" on success."""
        if self.initialized == false:
            return "not initialized"
        val err = backend_vulkan_session_present(self.handle)
        if err != "":
            self.last_error = err
        err

    me is_available() -> bool:
        """True when the device is initialized and shader mode is not unavailable."""
        if self.initialized == false:
            return false
        self.shader_mode != "unavailable"

    me stats() -> text:
        """Return a single-line summary of session counters."""
        "mode=" + self.shader_mode + " clears=" + self.clear_count.to_text() + " rects=" + self.rect_count.to_text() + " readbacks=" + self.readback_count.to_text()

    me cleanup() -> text:
        """Destroy the Vulkan device handle. Returns "" on success."""
        if self.initialized == false:
            return ""
        val rc = backend_vulkan_session_cleanup(self.handle)
        self.handle = 0
        self.initialized = false
        if rc != 0:
            self.last_error = "backend_vulkan_session_cleanup failed"
            return self.last_error
        ""
