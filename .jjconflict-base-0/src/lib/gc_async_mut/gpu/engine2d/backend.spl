# 2D Engine — Backend Trait (Combined Core + Adv Interface)
#
# RenderBackend = RenderBackendCore + RenderBackendAdv.
# Full backends implement this trait directly.
# Minimal backends implement only RenderBackendCore and use the
# stateless emulation layer (backend_emu.spl) for Adv operations.
#
# See:
#   backend_core.spl — RenderBackendCore (minimum required interface)
#   backend_adv.spl  — RenderBackendAdv (optimized operations)
#   backend_emu.spl  — stateless emulation (Core → Adv)
#
# Usage:
#   use std.gpu.engine2d.backend.{RenderBackend}

# ============================================================================
# Render Backend Trait
# ============================================================================

trait RenderBackend:
    """Abstract 2D rendering interface.

    Backends implement this trait to provide hardware-accelerated or
    software rendering. The Engine2D facade selects the best backend
    at runtime and delegates all operations through this interface.

    Coordinate system: origin at top-left, x increases right, y increases down.
    Colors: packed u32 in ARGB layout (0xAARRGGBB).
    """

    # -- Identity --
    fn name() -> text

    # -- Lifecycle --
    me init(width: i32, height: i32) -> bool
    me shutdown()

    # -- Clear --
    me clear(color: u32)

    # -- Rectangles --
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32)
    # Paints columns [x, x+w) and rows [y, y+h). Right/bottom edge EXCLUSIVE.
    # A zero-width or zero-height rect is a no-op. Negative w/h is undefined
    # (implementations may silently no-op, wrap, or overrun — do not rely).
    # See doc/03_plan/sys_gui/d1_fill_rect_contract_doctest.md.
    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32)

    # -- Lines --
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32)

    # -- Circles --
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32)
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32)

    # -- Advanced shapes --
    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32)
    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32)
    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32)

    # -- Text --
    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32)

    # -- Ellipses --
    me draw_ellipse(cx: i32, cy: i32, rx: i32, ry: i32, color: u32)
    me draw_ellipse_filled(cx: i32, cy: i32, rx: i32, ry: i32, color: u32)

    # -- Arcs and curves --
    me draw_arc(cx: i32, cy: i32, r: i32, start_deg: i32, end_deg: i32, color: u32, thickness: i32)
    me draw_bezier(x1: i32, y1: i32, cx1: i32, cy1: i32, cx2: i32, cy2: i32, x2: i32, y2: i32, color: u32, thickness: i32)

    # -- Polygons --
    me draw_polygon_filled(xs: [i32], ys: [i32], count: i32, color: u32)
    me draw_polyline(xs: [i32], ys: [i32], count: i32, color: u32, thickness: i32)

    # -- Thick outlines --
    me draw_rect_thick(x: i32, y: i32, w: i32, h: i32, color: u32, thickness: i32)
    me draw_circle_thick(cx: i32, cy: i32, r: i32, color: u32, thickness: i32)
    me draw_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32)

    # -- Gradients --
    me draw_gradient_rect_h(x: i32, y: i32, w: i32, h: i32, left_color: u32, right_color: u32)
    me draw_radial_gradient(cx: i32, cy: i32, r: i32, center_color: u32, edge_color: u32)

    # -- Alpha blending --
    me draw_rect_blend(x: i32, y: i32, w: i32, h: i32, color: u32)
    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32])

    # -- Scaled image --
    me draw_image_scaled(dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, src_w: i32, src_h: i32, pixels: [u32])

    # -- Triangle outline --
    me draw_triangle_outline(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32, thickness: i32)

    # -- Blur and shadow --
    me draw_blur_rect(x: i32, y: i32, w: i32, h: i32, radius: i32)
    me draw_shadow_rect(x: i32, y: i32, w: i32, h: i32, offset_x: i32, offset_y: i32, blur_r: i32, color: u32)

    # -- Affine transform image --
    me draw_image_transform(dst_x: i32, dst_y: i32, src_w: i32, src_h: i32, a: i32, b: i32, c: i32, d: i32, tx: i32, ty: i32, pixels: [u32])

    # -- Blend modes --
    me draw_rect_blend_mode(x: i32, y: i32, w: i32, h: i32, color: u32, mode: i32)

    # -- Image blitting --
    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32])

    # -- Clipping --
    me set_clip(x: i32, y: i32, w: i32, h: i32)
    me clear_clip()

    # -- Stencil mask --
    me set_mask(mask_pixels: [u8], w: i32, h: i32)
    me clear_mask()

    # -- Present --
    me present()

    # -- Readback --
    fn read_pixels() -> [u32]
    fn width() -> i32
    fn height() -> i32

# ============================================================================
# Engine2DExtended — Optional rendering extensions over RenderBackend
# ============================================================================

trait Engine2DExtended:
    """Optional rendering extensions layered on top of `RenderBackend`.

    These methods are additive: a backend may implement `RenderBackend`
    without implementing `Engine2DExtended`. Methods that need a richer
    shape than the core trait provides (for example, text drawn with a
    per-pixel background) live here.

    Paints a run of `text_val` at (x, y) using `fg` for glyph foreground
    pixels and `bg` for pixels inside each glyph cell that are *not*
    covered by the glyph. Unlike the "pre-paint an opaque rect then
    overlay `draw_text`" workaround, this call lets each backend keep
    antialiased glyph edges by blending against `bg` directly, and it
    avoids forcing a fixed 8x16 cell pitch. It is the method the
    `Engine2dCompositorBackend.draw_text` wrapper should use.
    """
    me draw_text_bg(x: i32, y: i32, text_val: text, fg: u32, bg: u32, font_size: i32)
