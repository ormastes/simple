#[runtime_intrinsics]
extern fn rt_metal_create_device() -> i64
extern fn rt_metal_device_name(handle: i64) -> text
extern fn rt_metal_is_available() -> bool
extern fn rt_metal_create_queue(handle: i64) -> text
extern fn rt_metal_create_pipeline(handle: i64, shader: text) -> text
extern fn rt_metal_dispatch(handle: i64, w: i64, h: i64) -> text
extern fn rt_metal_wait(handle: i64) -> text
extern fn rt_metal_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text
extern fn rt_metal_cleanup(handle: i64) -> i64

fn metal_proof_host_create_device() -> i64:
    rt_metal_create_device()

fn metal_proof_host_device_name(handle: i64) -> text:
    rt_metal_device_name(handle)

fn metal_proof_host_is_available() -> bool:
    rt_metal_is_available()

fn metal_proof_host_create_queue(handle: i64) -> text:
    rt_metal_create_queue(handle)

fn metal_proof_host_create_pipeline(handle: i64, shader: text) -> text:
    rt_metal_create_pipeline(handle, shader)

fn metal_proof_host_dispatch(handle: i64, w: i64, h: i64) -> text:
    rt_metal_dispatch(handle, w, h)

fn metal_proof_host_wait(handle: i64) -> text:
    rt_metal_wait(handle)

fn metal_proof_host_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text:
    rt_metal_readback(handle, x, y, w, h)

fn metal_proof_host_cleanup(handle: i64) -> i64:
    rt_metal_cleanup(handle)

pub fn metal_proof_create_device() -> i64:
    metal_proof_host_create_device()

pub fn metal_proof_device_name(handle: i64) -> text:
    metal_proof_host_device_name(handle)

pub fn metal_proof_is_available() -> bool:
    metal_proof_host_is_available()

pub fn metal_proof_create_queue(handle: i64) -> text:
    metal_proof_host_create_queue(handle)

pub fn metal_proof_create_pipeline(handle: i64, shader: text) -> text:
    metal_proof_host_create_pipeline(handle, shader)

pub fn metal_proof_dispatch(handle: i64, w: i64, h: i64) -> text:
    metal_proof_host_dispatch(handle, w, h)

pub fn metal_proof_wait(handle: i64) -> text:
    metal_proof_host_wait(handle)

pub fn metal_proof_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text:
    metal_proof_host_readback(handle, x, y, w, h)

pub fn metal_proof_cleanup(handle: i64) -> i64:
    metal_proof_host_cleanup(handle)
