#![allow(unnamed_duplicate_typed_args)]
@allow(primitive_api)
# 2D Engine — Shared 5x7 Bitmap Font Glyph Data
#
# Provides a reusable glyph lookup table and rendering functions for the
# 5x7 bitmap font used across all 2D engine backends (CPU, software, CUDA).
#
# Each glyph is stored as 7 rows of 5-bit integers (MSB = leftmost pixel).
# Supports: A-Z, a-z, 0-9, space, and common punctuation.
#
# Usage:
#   use std.gpu.engine2d.glyph.{glyph_data, render_glyph_to_buffer, render_text_to_buffer}

# ============================================================================
# Glyph Constants
# ============================================================================

fn glyph_width() -> i32:
    """Width of a single glyph in pixels."""
    5

fn glyph_height() -> i32:
    """Height of a single glyph in pixels."""
    7

fn glyph_advance(scale: i32) -> i32:
    """Horizontal advance per character (glyph width + 1px spacing, scaled)."""
    6 * scale

# ============================================================================
# Glyph Bitmap Data
# ============================================================================

fn glyph_data(ch: text) -> [i32]:
    """Return 7-row bitmap for a character. Each row is 5 bits wide (MSB = leftmost).

    Covers: A-Z, a-z, 0-9, space, and common punctuation.
    Unknown characters return a filled 5x7 block.
    """

    # --- Uppercase Letters ---

    if ch == "A":
        return [0b01110, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]
    if ch == "B":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10001, 0b10001, 0b11110]
    if ch == "C":
        return [0b01110, 0b10001, 0b10000, 0b10000, 0b10000, 0b10001, 0b01110]
    if ch == "D":
        return [0b11100, 0b10010, 0b10001, 0b10001, 0b10001, 0b10010, 0b11100]
    if ch == "E":
        return [0b11111, 0b10000, 0b10000, 0b11110, 0b10000, 0b10000, 0b11111]
    if ch == "F":
        return [0b11111, 0b10000, 0b10000, 0b11110, 0b10000, 0b10000, 0b10000]
    if ch == "G":
        return [0b01110, 0b10001, 0b10000, 0b10111, 0b10001, 0b10001, 0b01110]
    if ch == "H":
        return [0b10001, 0b10001, 0b10001, 0b11111, 0b10001, 0b10001, 0b10001]
    if ch == "I":
        return [0b01110, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]
    if ch == "J":
        return [0b00111, 0b00010, 0b00010, 0b00010, 0b00010, 0b10010, 0b01100]
    if ch == "K":
        return [0b10001, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010, 0b10001]
    if ch == "L":
        return [0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b10000, 0b11111]
    if ch == "M":
        return [0b10001, 0b11011, 0b10101, 0b10101, 0b10001, 0b10001, 0b10001]
    if ch == "N":
        return [0b10001, 0b11001, 0b10101, 0b10011, 0b10001, 0b10001, 0b10001]
    if ch == "O":
        return [0b01110, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]
    if ch == "P":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10000, 0b10000, 0b10000]
    if ch == "Q":
        return [0b01110, 0b10001, 0b10001, 0b10001, 0b10101, 0b10010, 0b01101]
    if ch == "R":
        return [0b11110, 0b10001, 0b10001, 0b11110, 0b10100, 0b10010, 0b10001]
    if ch == "S":
        return [0b01110, 0b10001, 0b10000, 0b01110, 0b00001, 0b10001, 0b01110]
    if ch == "T":
        return [0b11111, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]
    if ch == "U":
        return [0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b10001, 0b01110]
    if ch == "V":
        return [0b10001, 0b10001, 0b10001, 0b10001, 0b01010, 0b01010, 0b00100]
    if ch == "W":
        return [0b10001, 0b10001, 0b10001, 0b10101, 0b10101, 0b11011, 0b10001]
    if ch == "X":
        return [0b10001, 0b10001, 0b01010, 0b00100, 0b01010, 0b10001, 0b10001]
    if ch == "Y":
        return [0b10001, 0b10001, 0b01010, 0b00100, 0b00100, 0b00100, 0b00100]
    if ch == "Z":
        return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b10000, 0b11111]

    # --- Lowercase Letters ---

    if ch == "a":
        return [0b00000, 0b00000, 0b01110, 0b00001, 0b01111, 0b10001, 0b01111]
    if ch == "b":
        return [0b10000, 0b10000, 0b10110, 0b11001, 0b10001, 0b10001, 0b11110]
    if ch == "c":
        return [0b00000, 0b00000, 0b01110, 0b10000, 0b10000, 0b10001, 0b01110]
    if ch == "d":
        return [0b00001, 0b00001, 0b01101, 0b10011, 0b10001, 0b10001, 0b01111]
    if ch == "e":
        return [0b00000, 0b00000, 0b01110, 0b10001, 0b11111, 0b10000, 0b01110]
    if ch == "f":
        return [0b00110, 0b01001, 0b01000, 0b11100, 0b01000, 0b01000, 0b01000]
    if ch == "g":
        return [0b00000, 0b01111, 0b10001, 0b10001, 0b01111, 0b00001, 0b01110]
    if ch == "h":
        return [0b10000, 0b10000, 0b10110, 0b11001, 0b10001, 0b10001, 0b10001]
    if ch == "i":
        return [0b00100, 0b00000, 0b01100, 0b00100, 0b00100, 0b00100, 0b01110]
    if ch == "j":
        return [0b00010, 0b00000, 0b00110, 0b00010, 0b00010, 0b10010, 0b01100]
    if ch == "k":
        return [0b10000, 0b10000, 0b10010, 0b10100, 0b11000, 0b10100, 0b10010]
    if ch == "l":
        return [0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]
    if ch == "m":
        return [0b00000, 0b00000, 0b11010, 0b10101, 0b10101, 0b10001, 0b10001]
    if ch == "n":
        return [0b00000, 0b00000, 0b10110, 0b11001, 0b10001, 0b10001, 0b10001]
    if ch == "o":
        return [0b00000, 0b00000, 0b01110, 0b10001, 0b10001, 0b10001, 0b01110]
    if ch == "p":
        return [0b00000, 0b00000, 0b11110, 0b10001, 0b11110, 0b10000, 0b10000]
    if ch == "q":
        return [0b00000, 0b00000, 0b01101, 0b10011, 0b01111, 0b00001, 0b00001]
    if ch == "r":
        return [0b00000, 0b00000, 0b10110, 0b11001, 0b10000, 0b10000, 0b10000]
    if ch == "s":
        return [0b00000, 0b00000, 0b01110, 0b10000, 0b01110, 0b00001, 0b11110]
    if ch == "t":
        return [0b01000, 0b01000, 0b11100, 0b01000, 0b01000, 0b01001, 0b00110]
    if ch == "u":
        return [0b00000, 0b00000, 0b10001, 0b10001, 0b10001, 0b10011, 0b01101]
    if ch == "v":
        return [0b00000, 0b00000, 0b10001, 0b10001, 0b10001, 0b01010, 0b00100]
    if ch == "w":
        return [0b00000, 0b00000, 0b10001, 0b10001, 0b10101, 0b10101, 0b01010]
    if ch == "x":
        return [0b00000, 0b00000, 0b10001, 0b01010, 0b00100, 0b01010, 0b10001]
    if ch == "y":
        return [0b00000, 0b00000, 0b10001, 0b10001, 0b01111, 0b00001, 0b01110]
    if ch == "z":
        return [0b00000, 0b00000, 0b11111, 0b00010, 0b00100, 0b01000, 0b11111]

    # --- Digits ---

    if ch == "0":
        return [0b01110, 0b10001, 0b10011, 0b10101, 0b11001, 0b10001, 0b01110]
    if ch == "1":
        return [0b00100, 0b01100, 0b00100, 0b00100, 0b00100, 0b00100, 0b01110]
    if ch == "2":
        return [0b01110, 0b10001, 0b00001, 0b00110, 0b01000, 0b10000, 0b11111]
    if ch == "3":
        return [0b01110, 0b10001, 0b00001, 0b00110, 0b00001, 0b10001, 0b01110]
    if ch == "4":
        return [0b00010, 0b00110, 0b01010, 0b10010, 0b11111, 0b00010, 0b00010]
    if ch == "5":
        return [0b11111, 0b10000, 0b11110, 0b00001, 0b00001, 0b10001, 0b01110]
    if ch == "6":
        return [0b01110, 0b10000, 0b10000, 0b11110, 0b10001, 0b10001, 0b01110]
    if ch == "7":
        return [0b11111, 0b00001, 0b00010, 0b00100, 0b01000, 0b01000, 0b01000]
    if ch == "8":
        return [0b01110, 0b10001, 0b10001, 0b01110, 0b10001, 0b10001, 0b01110]
    if ch == "9":
        return [0b01110, 0b10001, 0b10001, 0b01111, 0b00001, 0b00001, 0b01110]

    # --- Whitespace ---

    if ch == " ":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000]

    # --- Punctuation ---

    if ch == ".":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100]
    if ch == ",":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00100, 0b01000]
    if ch == ":":
        return [0b00000, 0b00100, 0b00000, 0b00000, 0b00000, 0b00100, 0b00000]
    if ch == ";":
        return [0b00000, 0b00100, 0b00000, 0b00000, 0b00100, 0b00100, 0b01000]
    if ch == "!":
        return [0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00000, 0b00100]
    if ch == "?":
        return [0b01110, 0b10001, 0b00001, 0b00010, 0b00100, 0b00000, 0b00100]
    if ch == "-":
        return [0b00000, 0b00000, 0b00000, 0b11111, 0b00000, 0b00000, 0b00000]
    if ch == "+":
        return [0b00000, 0b00100, 0b00100, 0b11111, 0b00100, 0b00100, 0b00000]
    if ch == "=":
        return [0b00000, 0b00000, 0b11111, 0b00000, 0b11111, 0b00000, 0b00000]
    if ch == "/":
        return [0b00001, 0b00010, 0b00010, 0b00100, 0b01000, 0b01000, 0b10000]
    if ch == "(":
        return [0b00010, 0b00100, 0b01000, 0b01000, 0b01000, 0b00100, 0b00010]
    if ch == ")":
        return [0b01000, 0b00100, 0b00010, 0b00010, 0b00010, 0b00100, 0b01000]
    if ch == "[":
        return [0b01110, 0b01000, 0b01000, 0b01000, 0b01000, 0b01000, 0b01110]
    if ch == "]":
        return [0b01110, 0b00010, 0b00010, 0b00010, 0b00010, 0b00010, 0b01110]
    if ch == "{":
        return [0b00110, 0b01000, 0b01000, 0b11000, 0b01000, 0b01000, 0b00110]
    if ch == "}":
        return [0b01100, 0b00010, 0b00010, 0b00011, 0b00010, 0b00010, 0b01100]
    if ch == "@":
        return [0b01110, 0b10001, 0b10111, 0b10101, 0b10110, 0b10000, 0b01110]
    if ch == "#":
        return [0b01010, 0b01010, 0b11111, 0b01010, 0b11111, 0b01010, 0b01010]
    if ch == "$":
        return [0b00100, 0b01111, 0b10100, 0b01110, 0b00101, 0b11110, 0b00100]
    if ch == "%":
        return [0b11001, 0b11001, 0b00010, 0b00100, 0b01000, 0b10011, 0b10011]
    if ch == "^":
        return [0b00100, 0b01010, 0b10001, 0b00000, 0b00000, 0b00000, 0b00000]
    if ch == "&":
        return [0b01100, 0b10010, 0b10100, 0b01000, 0b10101, 0b10010, 0b01101]
    if ch == "*":
        return [0b00000, 0b00100, 0b10101, 0b01110, 0b10101, 0b00100, 0b00000]
    if ch == "_":
        return [0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b00000, 0b11111]
    if ch == "\"":
        return [0b01010, 0b01010, 0b01010, 0b00000, 0b00000, 0b00000, 0b00000]
    if ch == "'":
        return [0b00100, 0b00100, 0b01000, 0b00000, 0b00000, 0b00000, 0b00000]
    if ch == "<":
        return [0b00010, 0b00100, 0b01000, 0b10000, 0b01000, 0b00100, 0b00010]
    if ch == ">":
        return [0b01000, 0b00100, 0b00010, 0b00001, 0b00010, 0b00100, 0b01000]
    if ch == "~":
        return [0b00000, 0b00000, 0b01000, 0b10101, 0b00010, 0b00000, 0b00000]
    if ch == "`":
        return [0b01000, 0b00100, 0b00010, 0b00000, 0b00000, 0b00000, 0b00000]
    if ch == "\\":
        return [0b10000, 0b01000, 0b01000, 0b00100, 0b00010, 0b00010, 0b00001]
    if ch == "|":
        return [0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100, 0b00100]

    # Unknown character: filled block
    [0b11111, 0b11111, 0b11111, 0b11111, 0b11111, 0b11111, 0b11111]

# ============================================================================
# Glyph Rendering
# ============================================================================

fn render_glyph_to_buffer(buf: [u32], buf_w: i32, x: i32, y: i32, ch: text, color: u32, scale: i32):
    """Render a single character glyph into a u32 ARGB pixel buffer.

    Writes pixels directly into `buf` (row-major, width = buf_w).
    Respects buffer bounds — pixels outside the buffer are clipped.
    Supports integer scaling (each font pixel becomes a scale x scale block).
    """
    val bitmap = glyph_data(ch)
    var row = 0
    while row < 7:
        val row_data = bitmap[row]
        var col = 0
        while col < 5:
            val bit = (row_data >> (4 - col)) & 1
            if bit != 0:
                # Fill a scale x scale block for this pixel
                var sy = 0
                while sy < scale:
                    var sx = 0
                    while sx < scale:
                        val px = x + col * scale + sx
                        val py = y + row * scale + sy
                        if px >= 0 and py >= 0 and px < buf_w:
                            val idx = py * buf_w + px
                            if idx >= 0 and idx < buf.len():
                                buf[idx] = color
                        sx = sx + 1
                    sy = sy + 1
            col = col + 1
        row = row + 1

fn render_text_to_buffer(buf: [u32], buf_w: i32, buf_h: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32):
    """Render a full text string into a u32 ARGB pixel buffer.

    Characters are rendered left-to-right with a horizontal advance of
    6 * scale pixels (5px glyph + 1px spacing, scaled). Scale is derived
    from font_size / 7 (minimum 1).
    """
    var scale = font_size / 7
    if scale < 1:
        scale = 1
    var cursor_x = x
    var idx = 0
    while idx < text_val.len():
        val ch = text_val.slice(idx, idx + 1)
        render_glyph_to_buffer(buf, buf_w, cursor_x, y, ch, color, scale)
        cursor_x = cursor_x + glyph_advance(scale)
        idx = idx + 1
