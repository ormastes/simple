# 2D Engine — CUDA Backend Proof
#
# Proves CUDA device memory rendering and readback with typed diagnostics.
# When CUDA is unavailable, returns structured errors — never crashes.
#
# Usage:
#   use std.gpu.engine2d.backend_cuda_proof.{CudaDiagnostics, CudaProofBackend}

# ============================================================================
# Extern CUDA runtime bindings
# ============================================================================

extern fn rt_cuda_device_count() -> i64
extern fn rt_cuda_device_name(device_id: i64) -> text
extern fn rt_cuda_device_init(device_id: i64) -> i64
extern fn rt_cuda_alloc_fb(handle: i64, w: i64, h: i64) -> text
extern fn rt_cuda_clear(handle: i64, r: i64, g: i64, b: i64) -> text
extern fn rt_cuda_draw_rect(handle: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> text
extern fn rt_cuda_readback(handle: i64, x: i64, y: i64, w: i64, h: i64) -> text
extern fn rt_cuda_cleanup(handle: i64) -> i64

# ============================================================================
# CudaDiagnostics
# ============================================================================

class CudaDiagnostics:
    """Typed snapshot of CUDA device availability at probe time.

    Always constructed — never crashes. When no CUDA device is present,
    available is false and error_message explains why.
    """
    device_count: i64
    device_name: text
    compute_capability_major: i64
    compute_capability_minor: i64
    total_memory_mb: i64
    available: bool
    error_message: text

    static fn probe() -> CudaDiagnostics:
        val count = rt_cuda_device_count()
        if count <= 0:
            return CudaDiagnostics(
                device_count: 0,
                device_name: "",
                compute_capability_major: 0,
                compute_capability_minor: 0,
                total_memory_mb: 0,
                available: false,
                error_message: "no CUDA devices found"
            )
        val name = rt_cuda_device_name(0)
        CudaDiagnostics(
            device_count: count,
            device_name: name,
            compute_capability_major: 0,
            compute_capability_minor: 0,
            total_memory_mb: 0,
            available: true,
            error_message: ""
        )

    fn is_available(self) -> bool:
        self.available

    fn summary(self) -> text:
        if self.available == false:
            return "cuda unavailable: " + self.error_message
        var s = "cuda devices=" + self.device_count.to_text()
        s = s + " name=" + self.device_name
        s

# ============================================================================
# CudaProofBackend
# ============================================================================

class CudaProofBackend:
    """Proof backend: exercises CUDA device alloc, render, and readback.

    All methods return a text result (ok:... or err:...) so callers can
    diagnose failures without exceptions.
    """
    handle: i64
    device_id: i64
    diagnostics: CudaDiagnostics
    initialized: bool
    render_count: i64
    readback_count: i64
    last_error: text

    static fn create(device_id: i64) -> CudaProofBackend:
        val diag = CudaDiagnostics.probe()
        CudaProofBackend(
            handle: 0,
            device_id: device_id,
            diagnostics: diag,
            initialized: false,
            render_count: 0,
            readback_count: 0,
            last_error: ""
        )

    fn init_device(self) -> text:
        if self.diagnostics.available == false:
            self.last_error = self.diagnostics.error_message
            return "err:" + self.last_error
        val h = rt_cuda_device_init(self.device_id)
        if h <= 0:
            self.last_error = "rt_cuda_device_init returned invalid handle"
            return "err:" + self.last_error
        self.handle = h
        self.initialized = true
        "ok:device_init handle=" + h.to_text()

    fn alloc_framebuffer(self, width: i64, height: i64) -> text:
        if self.initialized == false:
            return "err:device not initialized"
        val r = rt_cuda_alloc_fb(self.handle, width, height)
        r

    fn render_clear(self, r: i64, g: i64, b: i64) -> text:
        if self.initialized == false:
            return "err:device not initialized"
        val result = rt_cuda_clear(self.handle, r, g, b)
        self.render_count = self.render_count + 1
        result

    fn render_rect(self, x: i64, y: i64, w: i64, h: i64, color: i64) -> text:
        if self.initialized == false:
            return "err:device not initialized"
        val result = rt_cuda_draw_rect(self.handle, x, y, w, h, color)
        self.render_count = self.render_count + 1
        result

    fn readback(self, x: i64, y: i64, w: i64, h: i64) -> text:
        if self.initialized == false:
            return "err:device not initialized"
        val result = rt_cuda_readback(self.handle, x, y, w, h)
        self.readback_count = self.readback_count + 1
        result

    fn stats(self) -> text:
        var s = "cuda_proof device_id=" + self.device_id.to_text()
        s = s + " initialized=" + self.initialized.to_text()
        s = s + " renders=" + self.render_count.to_text()
        s = s + " readbacks=" + self.readback_count.to_text()
        if self.last_error != "":
            s = s + " last_error=" + self.last_error
        s

    fn cleanup(self) -> text:
        if self.initialized == false:
            return "ok:not initialized, nothing to clean"
        val rc = rt_cuda_cleanup(self.handle)
        self.initialized = false
        self.handle = 0
        if rc == 0:
            return "ok:cleanup complete"
        "err:cleanup returned " + rc.to_text()
