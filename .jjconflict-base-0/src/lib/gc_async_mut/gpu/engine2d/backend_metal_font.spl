# Metal font-atlas companion. Kept separate from the legacy Metal facade so
# the generated-kernel ABI and persistent atlas lifecycle stay reviewable.

use std.gc_async_mut.gpu.engine2d.metal_session.{MetalSession}
use std.gpu.engine2d.backend_software.{SoftwareBackend}
use std.common.gpu.font_atlas_composite.{font_atlas_composite_program_version_valid, font_atlas_subrect_pixels, font_destination_origin}
use std.gc_async_mut.text_layout.font_renderer.{FontRenderBatch}
use std.gpu.engine2d.backend_metal_runtime_ops.{metal_buffer_upload_ptr}
use std.gc_async_mut.io.metal_sffi.{
    metal_sffi_alloc_buffer, metal_sffi_free_buffer
}

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64

val METAL_FONT_PARAMS_BYTES: i64 = 52

fn _font_pack_i32_le(mut buf: [u8], offset: i32, value: i32) -> i32:
    buf[offset] = (value & 0xFF) as u8
    buf[offset + 1] = ((value >> 8) & 0xFF) as u8
    buf[offset + 2] = ((value >> 16) & 0xFF) as u8
    buf[offset + 3] = ((value >> 24) & 0xFF) as u8
    offset + 4

fn metal_font_atlas_composite_params(atlas_width: i32, atlas_height: i32, atlas_count: i64,
                                     atlas_x: i32, atlas_y: i32, quad_width: i32, quad_height: i32,
                                     dst_width: i32, dst_height: i32, dst_count: i64,
                                     dst_x: i32, dst_y: i32, color: u32) -> [u8]:
    var p: [u8] = [0u8; 52]
    var off = 0
    val values: [i32] = [atlas_width, atlas_height, atlas_count as i32, atlas_x, atlas_y,
        quad_width, quad_height, dst_width, dst_height, dst_count as i32, dst_x, dst_y, color as i32]
    for value in values:
        off = _font_pack_i32_le(p, off, value)
    p

class MetalFontBackendState:
    atlas_buffer: i64
    atlas_bytes: i64
    atlas_generation: i64
    atlas_owner_identity: text

    static fn create() -> MetalFontBackendState:
        MetalFontBackendState(atlas_buffer: 0, atlas_bytes: 0, atlas_generation: -1, atlas_owner_identity: "")

    me release():
        if self.atlas_buffer != 0:
            metal_sffi_free_buffer(self.atlas_buffer)
        self.atlas_buffer = 0
        self.atlas_bytes = 0
        self.atlas_generation = -1
        self.atlas_owner_identity = ""

    me invalidate():
        self.atlas_generation = -1
        self.atlas_owner_identity = ""

    me _upload(session: MetalSession, batch: FontRenderBatch) -> bool:
        if batch.atlas_width <= 0 or batch.atlas_height <= 0:
            return false
        val count = batch.atlas_width.to_i64() * batch.atlas_height.to_i64()
        if count <= 0 or count > 2147483647 or batch.atlas_pixels.len() != count:
            return false
        val bytes = count * 4
        if self.atlas_buffer == 0 or self.atlas_bytes != bytes:
            val fresh = metal_sffi_alloc_buffer(session.device, bytes)
            if fresh == 0:
                return false
            if self.atlas_buffer != 0:
                metal_sffi_free_buffer(self.atlas_buffer)
            self.atlas_buffer = fresh
            self.atlas_bytes = bytes
            self.atlas_generation = -1
            self.atlas_owner_identity = ""
        val owner_identity = batch.atlas_owner_identity()
        if self.atlas_generation == batch.atlas_generation and self.atlas_owner_identity == owner_identity:
            return true
        val host = rt_alloc(bytes)
        if host == 0:
            return false
        var i: i64 = 0
        while i < count:
            rt_ptr_write_i32(host, i * 4, batch.atlas_pixels[i])
            i = i + 1
        val ok = metal_buffer_upload_ptr(self.atlas_buffer, host, bytes) != 0
        rt_free(host)
        if ok:
            self.atlas_generation = batch.atlas_generation
            self.atlas_owner_identity = owner_identity
        else:
            self.atlas_generation = -1
            self.atlas_owner_identity = ""
        ok

    me draw_font_batch(session: MetalSession, framebuffer: i64, mirror: SoftwareBackend,
                       mirror_enabled: bool, width: i32, height: i32, origin_x: i32, origin_y: i32,
                       batch: FontRenderBatch) -> i64:
        if not font_atlas_composite_program_version_valid(batch.program_version):
            return 0
        if not batch.valid or batch.quads.len() == 0 or framebuffer == 0:
            return 0
        val dst_count = width.to_i64() * height.to_i64()
        if width <= 0 or height <= 0 or dst_count <= 0 or dst_count > 2147483647:
            return 0
        if mirror_enabled and (mirror.clip_enabled or mirror.mask_buf.len() != 0):
            return 0
        if not self._upload(session, batch):
            return 0
        var done: i64 = 0
        while done < batch.quads.len():
            val q = batch.quads[done]
            val pixels = font_atlas_subrect_pixels(batch.atlas_pixels, batch.atlas_width, batch.atlas_height,
                q.atlas_x, q.atlas_y, q.width, q.height, q.color)
            val total = q.width.to_i64() * q.height.to_i64()
            if total <= 0 or pixels.len() != total:
                return done
            val dst_x = font_destination_origin(origin_x, q.dst_x, q.width)
            val dst_y = font_destination_origin(origin_y, q.dst_y, q.height)
            if dst_x == nil or dst_y == nil:
                return done
            val p = metal_font_atlas_composite_params(batch.atlas_width, batch.atlas_height, batch.atlas_pixels.len(),
                q.atlas_x, q.atlas_y, q.width, q.height, width, height, dst_count,
                dst_x.?, dst_y.?, q.color)
            if not session.dispatch_font_atlas_composite(self.atlas_buffer, framebuffer, p, total):
                return done
            if mirror_enabled and mirror.width() == width and mirror.height() == height:
                mirror.draw_image_blend(dst_x.?, dst_y.?, q.width, q.height, pixels)
            done = done + 1
        done

export MetalFontBackendState
export METAL_FONT_PARAMS_BYTES
export metal_font_atlas_composite_params
