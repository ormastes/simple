class VulkanFontPipelineEvidence:
    status: text
    reason: text
    artifact_mode: text
    shader_handle: i64
    pipeline_handle: i64
    device_name: text
    device_type: text
    driver_identity: text
    artifact_identity: text = ""
    entry_name: text = ""
    program_version: i64 = 0
    emission_compile_ns: i64 = 0

class VulkanFontCompositeEvidence:
    status: text
    reason: text
    artifact_mode: text
    shader_handle: i64
    pipeline_handle: i64
    atlas_buffer_handle: i64
    params_buffer_handle: i64
    descriptor_handle: i64
    descriptor_created: bool
    descriptor_destroyed: bool
    command_handle: i64
    quad_count: i64
    dispatch_count: i64
    submitted: bool
    completion_waited: bool
    fence_handle: i64
    fence_evidence_available: bool
    fence_destroyed: bool
    device_name: text
    device_type: text
    driver_identity: text
    readback_source: text
    readback_buffer_handle: i64
    readback_byte_count: i64
    device_checksum: i64
    oracle_checksum: i64
    parity: bool
    device_executed: bool
    promotion_ready: bool
    elapsed_ns: i64 = 0
    evidence_overhead_ns: i64 = 0
    atlas_upload_count: i64 = 0
    atlas_upload_bytes: i64 = 0
    gpu_resource_high_water_bytes: i64 = 0
    fallback_pixels: [u32] = []
    artifact_identity: text = ""
    entry_name: text = ""
    program_version: i64 = 0
    emission_compile_ns: i64 = 0
    batch_identity: text = ""
    atlas_payload_sha256: text = ""
    dirty_upload_ns: i64 = 0
    queue_device_ns: i64 = 0
    sync_wait_ns: i64 = 0
    present_readback_ns: i64 = 0
    cpu_oracle_ns: i64 = 0
    present_mode: text = ""
    readback_nonblank_pixels: i64 = 0

    me clear_fallback_pixels():
        self.fallback_pixels = []

export VulkanFontPipelineEvidence, VulkanFontCompositeEvidence
