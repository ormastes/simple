# HTTP Client — gc_async_mut root shim
#
# Re-exports the flat HTTP client API from the gc_async_mut submodule directory.
# Consumers import: use std.gc_async_mut.http_client.{http_get, http_post, ...}

import std.gc_async_mut.http_client.types
import std.gc_async_mut.http_client.request
import std.gc_async_mut.http_client.response
import std.gc_async_mut.http_client.connection

# ============================================================================
# Request helpers — build request tuples
# ============================================================================

fn create_headers() -> list:
    request.create_headers()

fn add_header(headers: list, name: text, value: text) -> list:
    request.add_header(headers, name, value)

fn get_header(headers: list, name: text) -> text:
    request.get_header(headers, name)

fn has_header(headers: list, name: text) -> bool:
    request.has_header(headers, name)

fn remove_header(headers: list, name: text) -> list:
    request.remove_header(headers, name)

fn set_header(headers: list, name: text, value: text) -> list:
    request.set_header(headers, name, value)

fn http_get(url: text) -> (text, text, list, text):
    request.http_get(url)

fn http_post(url: text, body: text) -> (text, text, list, text):
    request.http_post(url, body)

fn http_put(url: text, body: text) -> (text, text, list, text):
    request.http_put(url, body)

fn http_delete(url: text) -> (text, text, list, text):
    request.http_delete(url)

# ============================================================================
# Response helpers — extract fields from response tuples
# ============================================================================

fn response_get_status_code(resp: (i64, text, list, text)) -> i64:
    response.response_get_status_code(resp)

fn response_get_status_text(resp: (i64, text, list, text)) -> text:
    response.response_get_status_text(resp)

fn response_get_headers(resp: (i64, text, list, text)) -> list:
    response.response_get_headers(resp)

fn response_get_body(resp: (i64, text, list, text)) -> text:
    response.response_get_body(resp)

fn response_get_header(resp: (i64, text, list, text), name: text) -> text:
    response.response_get_header(resp, name)

fn response_is_success(resp: (i64, text, list, text)) -> bool:
    response.response_is_success(resp)

fn response_is_redirect(resp: (i64, text, list, text)) -> bool:
    response.response_is_redirect(resp)

fn response_is_client_error(resp: (i64, text, list, text)) -> bool:
    response.response_is_client_error(resp)

fn response_is_server_error(resp: (i64, text, list, text)) -> bool:
    response.response_is_server_error(resp)
