# GC-async file operations — gc_async_mut.file_system.file_ops
#
# Provides basic file I/O for GC-async contexts.
# Consumer: gc_async_mut/oauth2.spl

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_rename(src: text, dst: text) -> bool
extern fn rt_file_delete(path: text) -> bool

fn file_read_text(path: text) -> text?:
    """Read file as text. Returns nil on error or missing file."""
    if not rt_file_exists(path):
        return nil
    val content = rt_file_read_text(path)
    Some(content)

fn file_write_text(path: text, content: text) -> bool:
    """Write text to file. Returns true on success."""
    rt_file_write_text(path, content)

fn file_exists(path: text) -> bool:
    """Return true if the file exists."""
    rt_file_exists(path)

fn file_rename(src: text, dst: text) -> bool:
    """Rename/move a file. Returns true on success."""
    rt_file_rename(src, dst)

fn file_delete(path: text) -> bool:
    """Delete a file. Returns true on success."""
    rt_file_delete(path)
