# GC-async file permissions — gc_async_mut.file_system.permissions
#
# Provides file_set_mode for setting POSIX file permissions.
# Consumer: gc_async_mut/oauth2.spl (sets token-cache to mode 0600)

extern fn rt_file_set_mode(path: text, mode: i64) -> bool

fn file_set_mode(path: text, mode: i64) -> bool:
    """Set POSIX file mode (e.g. 0o600). Returns true on success."""
    rt_file_set_mode(path, mode)
