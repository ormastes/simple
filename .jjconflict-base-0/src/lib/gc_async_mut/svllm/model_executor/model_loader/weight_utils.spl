# @gc — module uses GC runtime
#
# Weight/tensor dtype helpers. Names mirror vLLM / safetensors conventions
# so that installed packs can round-trip against upstream ecosystems.

enum Dtype:
    F32
    F16
    Bf16
    F64
    I8
    I16
    I32
    I64
    U8
    Bool

# Size of one element of this dtype in bytes. Used to translate
# (shape, dtype) into a byte length for chunk planning.
fn dtype_element_size(dt: Dtype) -> i64:
    match dt:
        Dtype.F32 => 4
        Dtype.F16 => 2
        Dtype.Bf16 => 2
        Dtype.F64 => 8
        Dtype.I8 => 1
        Dtype.I16 => 2
        Dtype.I32 => 4
        Dtype.I64 => 8
        Dtype.U8 => 1
        Dtype.Bool => 1

# Bytes for a tensor given its shape and dtype. Fails on overflow or
# negative dim by returning 0 (callers treat 0 as invalid).
fn tensor_byte_len(shape: [i64], dt: Dtype) -> i64:
    val elem = dtype_element_size(dt)
    var total: i64 = elem
    var i = 0
    while i < shape.len():
        val d = shape[i]
        if d < 0:
            return 0
        total = total * d
        i = i + 1
    total
