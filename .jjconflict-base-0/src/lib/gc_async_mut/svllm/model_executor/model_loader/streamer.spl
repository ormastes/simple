# @gc — module uses GC runtime
#
# Streaming loader core (Phase A3). Two pure stages, no I/O and no NvfsClient
# dependency so they are fully testable on their own:
#
#   1. plan_stream(pack, granule)   -> StreamPlan
#        The aligned read schedule. Each chunk's byte_len is split into
#        granule-sized read ops (the unit a real streamer would issue against
#        NvfsClient.read_range, sized to caps.preferred_read_granule).
#
#   2. stream_pack(pack, chunk_data) -> StreamResult
#        The staging step: given the raw bytes of each chunk (what a streamer
#        has fetched into pinned buffers), gather each tensor's byte slice out
#        of its chunk. This is where the model_loader materializes per-tensor
#        weight buffers from the on-disk chunk layout.
#
# The actual transport (open chunk objects on an NvfsClient and read aligned
# ranges into registered buffers) is a thin wrapper over these two functions
# in loader.spl; keeping the schedule + gather pure makes the heart of A3
# deterministic and unit-testable without a live filesystem.

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorPack, TensorInfo, ChunkInfo}

# Streaming-specific failures. Kept distinct from LoaderError so this module
# carries no dependency on loader.spl (which depends on this one).
enum StreamError:
    ChunkDataMissing      # fewer chunk buffers supplied than the pack has chunks
    ChunkTooShort         # a chunk buffer is shorter than its declared byte_len
    TensorOutOfBounds     # a tensor's [offset, offset+len) exceeds its chunk
    ChunkNotFound         # a tensor's chunk_id matches no chunk in the pack

# One aligned read against a chunk: read `length` bytes at `offset`.
struct StreamOp:
    chunk_id: i32
    offset: i64
    length: i64

# The full read schedule for a pack at a given granule.
struct StreamPlan:
    ops: [StreamOp]
    op_count: i64
    total_bytes: i64      # sum of op lengths == sum of chunk byte_lens
    granule: i64

# A staged (materialized) tensor: its gathered bytes plus identity.
struct TensorStage:
    name: text
    chunk_id: i32
    byte_len: i64
    bytes: [u8]

# Outcome of staging a whole pack.
struct StreamResult:
    bytes_streamed: i64   # total chunk bytes read (sum of chunk byte_lens)
    staged_bytes: i64     # total tensor bytes gathered (sum of tensor byte_lens)
    stages: [TensorStage]

# Build the aligned read schedule. granule <= 0 means "one read per chunk"
# (no splitting). Pure.
fn plan_stream(pack: TensorPack, granule: i64) -> StreamPlan:
    var ops: [StreamOp] = []
    var total: i64 = 0
    var i = 0
    while i < pack.chunks.len():
        val c = pack.chunks[i]
        if granule <= 0:
            if c.byte_len > 0:
                ops.push(StreamOp(chunk_id: c.id, offset: 0, length: c.byte_len))
                total = total + c.byte_len
        else:
            var off: i64 = 0
            while off < c.byte_len:
                var len = granule
                if off + len > c.byte_len:
                    len = c.byte_len - off
                ops.push(StreamOp(chunk_id: c.id, offset: off, length: len))
                total = total + len
                off = off + granule
        i = i + 1
    StreamPlan(ops: ops, op_count: ops.len(), total_bytes: total, granule: granule)

# Find the index in pack.chunks of the chunk whose id == id, or -1.
fn _chunk_index_by_id(pack: TensorPack, id: i32) -> i64:
    var i = 0
    while i < pack.chunks.len():
        if pack.chunks[i].id == id:
            return i
        i = i + 1
    -1

# Gather every tensor's bytes from the supplied chunk buffers. chunk_data[i]
# must hold the raw bytes of pack.chunks[i] (same order), at least byte_len
# long. Returns per-tensor staged buffers. Pure; no I/O.
fn stream_pack(pack: TensorPack, chunk_data: [[u8]]) -> Result<StreamResult, StreamError>:
    if (chunk_data.len() as i64) < pack.chunks.len():
        return Err(StreamError.ChunkDataMissing)
    var ci = 0
    while ci < pack.chunks.len():
        if (chunk_data[ci].len() as i64) < pack.chunks[ci].byte_len:
            return Err(StreamError.ChunkTooShort)
        ci = ci + 1
    var stages: [TensorStage] = []
    var staged: i64 = 0
    var ti = 0
    while ti < pack.tensors.len():
        val t = pack.tensors[ti]
        val idx = _chunk_index_by_id(pack, t.chunk_id)
        if idx < 0:
            return Err(StreamError.ChunkNotFound)
        if t.offset_in_chunk < 0 or t.byte_len < 0:
            return Err(StreamError.TensorOutOfBounds)
        var bytes: [u8] = []
        var chunk_idx = idx
        var chunk_offset = t.offset_in_chunk
        var remaining = t.byte_len
        while remaining > 0:
            if chunk_idx >= pack.chunks.len():
                return Err(StreamError.TensorOutOfBounds)
            val buf = chunk_data[chunk_idx]
            val chunk_byte_len = pack.chunks[chunk_idx].byte_len
            if chunk_offset < 0 or chunk_offset > chunk_byte_len:
                return Err(StreamError.TensorOutOfBounds)
            val available = chunk_byte_len - chunk_offset
            if available <= 0:
                return Err(StreamError.TensorOutOfBounds)
            var take = remaining
            if take > available:
                take = available
            var b = chunk_offset
            while b < chunk_offset + take:
                bytes.push(buf[b])
                b = b + 1
            remaining = remaining - take
            chunk_idx = chunk_idx + 1
            chunk_offset = 0
        stages.push(TensorStage(name: t.name, chunk_id: t.chunk_id, byte_len: t.byte_len, bytes: bytes))
        staged = staged + t.byte_len
        ti = ti + 1
    var streamed: i64 = 0
    var k = 0
    while k < pack.chunks.len():
        streamed = streamed + pack.chunks[k].byte_len
        k = k + 1
    Ok(StreamResult(bytes_streamed: streamed, staged_bytes: staged, stages: stages))
