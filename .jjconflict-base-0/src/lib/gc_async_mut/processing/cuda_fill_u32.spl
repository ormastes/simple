"""CUDA executor for the validated ProcessingIR FillU32 operation."""

use std.common.processing.processing_ir.{ProcessingIr, processing_ir_validate}
use std.gc_async_mut.cuda.{
    cuda_available, cuda_init, cuda_device_count, cuda_device_get,
    cuda_ctx_create, cuda_ctx_destroy,
    cuda_mem_alloc, cuda_mem_free, cuda_memcpy_dtoh,
    cuda_module_load_data, cuda_module_unload, cuda_launch_kernel, cuda_sync,
    CUDA_SUCCESS
}
use std.gc_async_mut.gpu_ffi.{cuda_device_identity}
use std.nogc_sync_mut.ptr.raw.{raw_alloc, raw_free, raw_read_i32, raw_write_i64}

val PROCESSING_CUDA_BLOCK_SIZE: i64 = 256
val PROCESSING_CUDA_ARG_BYTES: i64 = 24

struct ProcessingCudaResult:
    completed: bool
    reason: text
    values: [u32]
    backend_handle: i64
    device_identity: i64

fn _processing_cuda_ptx() -> text:
    ".version 7.0\n.target sm_52\n.address_size 64\n\n.visible .entry processing_fill_u32(\n    .param .u64 output,\n    .param .u32 value,\n    .param .u32 count\n) {\n    .reg .pred %p;\n    .reg .b32 %r<6>;\n    .reg .b64 %rd<4>;\n    mov.u32 %r0, %ctaid.x;\n    mov.u32 %r1, %ntid.x;\n    mov.u32 %r2, %tid.x;\n    mad.lo.u32 %r3, %r0, %r1, %r2;\n    ld.param.u32 %r4, [count];\n    setp.ge.u32 %p, %r3, %r4;\n    @%p bra done;\n    ld.param.u64 %rd0, [output];\n    mul.wide.u32 %rd1, %r3, 4;\n    add.u64 %rd2, %rd0, %rd1;\n    ld.param.u32 %r5, [value];\n    st.global.u32 [%rd2], %r5;\ndone:\n    ret;\n}\n"

fn _processing_cuda_cleanup(ctx: i64, module: i64, device: i64, values_ptr: i64, args_ptr: i64, host_ptr: i64, byte_count: i64):
    if device > 0:
        cuda_mem_free(device)
    if module > 0:
        cuda_module_unload(module)
    if values_ptr != 0:
        raw_free(values_ptr, PROCESSING_CUDA_ARG_BYTES)
    if args_ptr != 0:
        raw_free(args_ptr, PROCESSING_CUDA_ARG_BYTES)
    if host_ptr != 0:
        raw_free(host_ptr, byte_count)
    if ctx > 0:
        cuda_ctx_destroy(ctx)

fn processing_ir_execute_cuda(ir: ProcessingIr) -> ProcessingCudaResult:
    val valid = processing_ir_validate(ir)
    if not valid.valid:
        return ProcessingCudaResult(completed: false, reason: valid.reason, values: [], backend_handle: 0, device_identity: 0)
    if not cuda_available() or cuda_init() != CUDA_SUCCESS or cuda_device_count() < 1:
        return ProcessingCudaResult(completed: false, reason: "cuda-init-failed", values: [], backend_handle: 0, device_identity: 0)
    val device_handle = cuda_device_get(0)
    if device_handle < 0:
        return ProcessingCudaResult(completed: false, reason: "cuda-device-get-failed", values: [], backend_handle: 0, device_identity: 0)
    val ctx = cuda_ctx_create(device_handle)
    if ctx <= 0:
        return ProcessingCudaResult(completed: false, reason: "cuda-context-create-failed", values: [], backend_handle: 0, device_identity: 0)
    val module = cuda_module_load_data(_processing_cuda_ptx())
    if module <= 0:
        cuda_ctx_destroy(ctx)
        return ProcessingCudaResult(completed: false, reason: "cuda-module-load-failed", values: [], backend_handle: 0, device_identity: 0)

    val byte_count = ir.element_count * 4
    val device = cuda_mem_alloc(byte_count)
    val values_ptr = raw_alloc(PROCESSING_CUDA_ARG_BYTES)
    val args_ptr = raw_alloc(PROCESSING_CUDA_ARG_BYTES)
    val host_ptr = raw_alloc(byte_count)
    if device <= 0 or values_ptr == 0 or args_ptr == 0 or host_ptr == 0:
        _processing_cuda_cleanup(ctx, module, device, values_ptr, args_ptr, host_ptr, byte_count)
        return ProcessingCudaResult(completed: false, reason: "cuda-allocation-failed", values: [], backend_handle: 0, device_identity: 0)

    raw_write_i64(values_ptr, 0, device)
    raw_write_i64(values_ptr, 8, ir.value.to_i64())
    raw_write_i64(values_ptr, 16, ir.element_count)
    raw_write_i64(args_ptr, 0, values_ptr)
    raw_write_i64(args_ptr, 8, values_ptr + 8)
    raw_write_i64(args_ptr, 16, values_ptr + 16)
    val launched = cuda_launch_kernel(module, "processing_fill_u32", (ir.element_count + PROCESSING_CUDA_BLOCK_SIZE - 1) / PROCESSING_CUDA_BLOCK_SIZE, 1, 1, PROCESSING_CUDA_BLOCK_SIZE, 1, 1, args_ptr) == CUDA_SUCCESS
    val copied = launched and cuda_sync() == CUDA_SUCCESS and cuda_memcpy_dtoh(host_ptr, device, byte_count) == CUDA_SUCCESS
    var values: [u32] = []
    if copied:
        var i: i64 = 0
        while i < ir.element_count:
            values.push(raw_read_i32(host_ptr, i * 4) as u32)
            i = i + 1
    val handle = device_handle + 1
    val identity = cuda_device_identity(device_handle)
    _processing_cuda_cleanup(ctx, module, device, values_ptr, args_ptr, host_ptr, byte_count)
    if not copied:
        return ProcessingCudaResult(completed: false, reason: "cuda-dispatch-or-readback-failed", values: [], backend_handle: 0, device_identity: 0)
    if identity <= 0:
        return ProcessingCudaResult(completed: false, reason: "cuda-device-identity-unavailable", values: [], backend_handle: 0, device_identity: 0)
    ProcessingCudaResult(completed: true, reason: "ok", values: values, backend_handle: handle, device_identity: identity)

export ProcessingCudaResult, processing_ir_execute_cuda
