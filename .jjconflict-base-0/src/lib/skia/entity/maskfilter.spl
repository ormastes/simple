# Skia MaskFilter
#
# SkMaskFilter — alpha-channel mask effect (blur, emboss).

# ============================================================================
# SkBlurStyle
# ============================================================================

enum SkBlurStyle:
    Normal   # fuzzy inside and outside
    Solid    # solid inside, fuzzy outside
    Outer    # nothing inside, fuzzy outside
    Inner    # fuzzy inside, nothing outside

# ============================================================================
# SkMaskFilter
# ============================================================================

enum SkMaskFilterKind:
    Blur
    Emboss
    Table
    Empty

class SkMaskFilter:
    kind: SkMaskFilterKind
    blur_style: SkBlurStyle
    sigma: f64

fn sk_mask_filter_blur(style: SkBlurStyle, sigma: f64) -> SkMaskFilter:
    SkMaskFilter(kind: SkMaskFilterKind.Blur, blur_style: style, sigma: sigma)

fn sk_mask_filter_blur_normal(sigma: f64) -> SkMaskFilter:
    sk_mask_filter_blur(SkBlurStyle.Normal, sigma)

impl SkMaskFilter:
    fn to_string() -> text:
        "SkMaskFilter(blur sigma:{self.sigma})"
