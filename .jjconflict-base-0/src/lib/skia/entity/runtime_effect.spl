# SkRuntimeEffect — structural stub for SkSL runtime shaders.
#
# Mirrors Skia's SkRuntimeEffect. A RuntimeEffect is immutable SkSL source
# (or bytecode) + a schema of input uniforms + a schema of input children
# (sampled via sk_child_image()/sk_child_shader()).
#
# This module provides the container types only. SkSL parsing/execution is
# out of scope — when the SkSL frontend lands it will populate the `bytecode`
# field and implement `evaluate`.

use std.skia.entity.shader.{SkShader}

# ============================================================================
# UniformKind — scalar/vector/matrix kind tag for a uniform slot
# ============================================================================

enum UniformKind:
    Float
    Float2
    Float3
    Float4
    Int
    Matrix3
    Matrix4

# ============================================================================
# RuntimeEffectUniform — one entry in the uniform schema
# ============================================================================

class RuntimeEffectUniform:
    name: String
    kind: UniformKind
    # array_count is 1 for a plain scalar/vector/matrix, N for an array-typed
    # uniform (e.g. `uniform float kernel[9]` => array_count = 9).
    array_count: i64

# ============================================================================
# RuntimeEffectChild — one entry in the child (sub-effect) schema
# ============================================================================

class RuntimeEffectChild:
    name: String
    # kind is one of "shader", "colorFilter", "blender" — matches SkSL's
    # child declarations. We keep it as a String tag rather than an enum so
    # the SkSL frontend can extend without churning this entity module.
    kind: String

# ============================================================================
# SkRuntimeEffect — immutable compiled (or source-only) runtime effect
# ============================================================================

class SkRuntimeEffect:
    # sksl_source is the raw SkSL text. Opaque to us today; the future SkSL
    # frontend will parse it to populate `uniforms`/`children`/`bytecode`.
    sksl_source: String
    # uniforms is the declared uniform schema (manually populated at
    # construction time until the SkSL frontend lands and parses the source).
    uniforms: [RuntimeEffectUniform]
    # children is the declared child-effect schema (shader/colorFilter/blender
    # slots sampled from SkSL via sk_child_* intrinsics).
    children: [RuntimeEffectChild]
    # bytecode stays empty until the SkSL compiler populates it. Callers use
    # sk_runtime_effect_is_compiled() to branch on this.
    bytecode: [u8]

fn sk_runtime_effect_make(source: String, uniforms: [RuntimeEffectUniform], children: [RuntimeEffectChild]) -> SkRuntimeEffect:
    # Constructor stub: bytecode starts empty. A future SkSL frontend will
    # compile `source` and fill `bytecode`, at which point callers can
    # distinguish "source-only" from "compiled" effects.
    SkRuntimeEffect(
        sksl_source: source,
        uniforms: uniforms,
        children: children,
        bytecode: []
    )

fn sk_runtime_effect_is_compiled(effect: SkRuntimeEffect) -> bool:
    effect.bytecode.len() > 0

# ============================================================================
# SkRuntimeShaderBuilder — collects uniform values and child shaders, then
# produces an SkShader by binding them to the effect.
# ============================================================================

class SkRuntimeShaderBuilder:
    effect: SkRuntimeEffect
    # uniform_values is parallel to effect.uniforms — one byte-blob per slot.
    # Empty blob means "not yet set". The SkSL runtime will reject a build()
    # call that leaves a required slot empty, but we don't enforce that here.
    uniform_values: [[u8]]
    # children_shaders is parallel to effect.children. Entries default to a
    # nil-equivalent empty SkShader until set by the caller.
    children_shaders: [SkShader]

impl SkRuntimeShaderBuilder:
    fn set_uniform_float(name: String, value: f64) -> SkRuntimeShaderBuilder:
        # Linear search by name. WHY O(N): uniform counts are small (typical
        # SkSL effects have <10 uniforms), so a hash map would cost more in
        # allocation/constant-factor than it saves in lookup time.
        val n = self.effect.uniforms.len()
        var i = 0
        var new_values = self.uniform_values
        while i < n:
            val u = self.effect.uniforms[i]
            if u.name == name:
                # Encode the f64 as an 8-byte blob. Real Skia packs by kind;
                # we use a single placeholder byte per uniform because the
                # byte layout is opaque until the SkSL frontend lands.
                new_values[i] = [1u8]
                break
            i = i + 1
        SkRuntimeShaderBuilder(
            effect: self.effect,
            uniform_values: new_values,
            children_shaders: self.children_shaders
        )

    fn set_uniform_int(name: String, value: i64) -> SkRuntimeShaderBuilder:
        # Same O(N) linear search as set_uniform_float. See WHY above.
        val n = self.effect.uniforms.len()
        var i = 0
        var new_values = self.uniform_values
        while i < n:
            val u = self.effect.uniforms[i]
            if u.name == name:
                new_values[i] = [1u8]
                break
            i = i + 1
        SkRuntimeShaderBuilder(
            effect: self.effect,
            uniform_values: new_values,
            children_shaders: self.children_shaders
        )

    fn build() -> Option<SkShader>:
        # Returns None because building a runnable SkShader from SkSL
        # requires the SkSL compiler to turn `effect.bytecode` into an
        # executable program. WHY None: compiler not yet implemented.
        None
