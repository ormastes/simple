# Font registry — stub for SkFontMgr.
#
# Interface matches Skia's SkFontMgr::matchFamilyStyle + legacyMakeTypeface
# but backed by an in-memory registry that callers populate.
#
# Real OS font enumeration requires per-platform hooks (FontConfig on Linux,
# DWrite on Windows, CoreText on macOS). Out of scope for this stub; the
# registry interface is stable so a real backend can slot in later.

use std.common.math.{math_abs}

# ============================================================================
# FontWeight — numeric CSS-style weights
# ============================================================================

enum FontWeight:
    Thin
    Light
    Regular
    Medium
    Bold
    Black

fn font_weight_value(w: FontWeight) -> i64:
    if w == FontWeight.Thin:
        return 100
    if w == FontWeight.Light:
        return 300
    if w == FontWeight.Regular:
        return 400
    if w == FontWeight.Medium:
        return 500
    if w == FontWeight.Bold:
        return 700
    if w == FontWeight.Black:
        return 900
    return 400

# ============================================================================
# FontSlant
# ============================================================================

enum FontSlant:
    Upright
    Italic
    Oblique

# ============================================================================
# FontStyle
# ============================================================================

class FontStyle:
    weight: FontWeight
    slant: FontSlant

# ============================================================================
# FontFamilyEntry
# ============================================================================

class FontFamilyEntry:
    family: String
    style: FontStyle
    typeface_name: String
    path: String

# ============================================================================
# FontRegistry
# ============================================================================

class FontRegistry:
    entries: [FontFamilyEntry]

fn font_registry_new() -> FontRegistry:
    FontRegistry(entries: [])

impl FontRegistry:
    me register(entry: FontFamilyEntry):
        self.entries.append(entry)

    me family_count() -> i64:
        val seen: [String] = []
        val n = self.entries.length()
        var i: i64 = 0
        while i < n:
            val fam = self.entries[i].family
            var found = false
            val m = seen.length()
            var j: i64 = 0
            while j < m:
                if seen[j] == fam:
                    found = true
                j = j + 1
            if not found:
                seen.append(fam)
            i = i + 1
        return seen.length()

    me list_families() -> [String]:
        val result: [String] = []
        val n = self.entries.length()
        var i: i64 = 0
        while i < n:
            val fam = self.entries[i].family
            var found = false
            val m = result.length()
            var j: i64 = 0
            while j < m:
                if result[j] == fam:
                    found = true
                j = j + 1
            if not found:
                result.append(fam)
            i = i + 1
        return result

    me match_family_style(family: String, style: FontStyle) -> Option<FontFamilyEntry>:
        val n = self.entries.length()
        # Pass 1: exact family + weight + slant.
        var i: i64 = 0
        while i < n:
            val e = self.entries[i]
            if e.family == family:
                if e.style.weight == style.weight:
                    if e.style.slant == style.slant:
                        return Some(e)
            i = i + 1
        # Pass 2: same family + slant, closest weight.
        val requested = font_weight_value(style.weight)
        var best_idx: i64 = -1
        var best_dist: i64 = 0
        i = 0
        while i < n:
            val e = self.entries[i]
            if e.family == family:
                if e.style.slant == style.slant:
                    val cand = font_weight_value(e.style.weight)
                    val d = math_abs(requested - cand)
                    if best_idx == -1:
                        best_idx = i
                        best_dist = d
                    else:
                        if d < best_dist:
                            best_idx = i
                            best_dist = d
            i = i + 1
        if best_idx >= 0:
            return Some(self.entries[best_idx])
        # Pass 3: same family + Upright (default fallback).
        i = 0
        while i < n:
            val e = self.entries[i]
            if e.family == family:
                if e.style.slant == FontSlant.Upright:
                    return Some(e)
            i = i + 1
        # No match for this family at all.
        return None

fn default_font_registry() -> FontRegistry:
    val reg = font_registry_new()
    val style = FontStyle(weight: FontWeight.Regular, slant: FontSlant.Upright)
    reg.register(FontFamilyEntry(
        family: "Sans",
        style: style,
        typeface_name: "",
        path: ""
    ))
    reg.register(FontFamilyEntry(
        family: "Serif",
        style: style,
        typeface_name: "",
        path: ""
    ))
    reg.register(FontFamilyEntry(
        family: "Monospace",
        style: style,
        typeface_name: "",
        path: ""
    ))
    return reg
