# ASCII fallback glyph table — minimal 5x7 bitmap font.
#
# Used when a real font isn't loaded (tests, debug overlays, error messages).
# Covers codepoints 32..126 (printable ASCII). All glyphs are 5 columns × 7 rows
# packed as 7 bytes per glyph (one byte per row, bit 4 = leftmost column).
#
# Mirrors the 5x7 fallback font embedded in Chromium's base/strings for
# internal debug UIs.

const ASCII_GLYPH_WIDTH: i64 = 5
const ASCII_GLYPH_HEIGHT: i64 = 7

fn ascii_fallback_glyph(codepoint: i64) -> [i64]:
    # Out-of-range: return all-zeros (empty glyph)
    if codepoint < 32:
        [0, 0, 0, 0, 0, 0, 0]
    else:
        if codepoint > 126:
            [0, 0, 0, 0, 0, 0, 0]
        else:
            # Hand-crafted shapes for a small set of characters.
            if codepoint == 32:
                # ' ' space: all zeros
                [0, 0, 0, 0, 0, 0, 0]
            else:
                if codepoint == 45:
                    # '-' hyphen: middle row (row 3) bits 1,2,3 set = 0x0E
                    [0, 0, 0, 0x0E, 0, 0, 0]
                else:
                    if codepoint == 46:
                        # '.' period: bottom row, bit 2 only
                        [0, 0, 0, 0, 0, 0, 0x04]
                    else:
                        if codepoint == 48:
                            # '0': full border, middle empty
                            [0x0E, 0x11, 0x11, 0x11, 0x11, 0x11, 0x0E]
                        else:
                            if codepoint == 49:
                                # '1': vertical bar in column 2 (bit 2 = 0x04)
                                [0x04, 0x0C, 0x04, 0x04, 0x04, 0x04, 0x0E]
                            else:
                                if codepoint == 65:
                                    # 'A': triangular top + horizontal crossbar
                                    [0x04, 0x0A, 0x11, 0x11, 0x1F, 0x11, 0x11]
                                else:
                                    if codepoint == 73:
                                        # 'I': vertical bar with top/bottom serif
                                        [0x0E, 0x04, 0x04, 0x04, 0x04, 0x04, 0x0E]
                                    else:
                                        if codepoint == 79:
                                            # 'O': same as '0'
                                            [0x0E, 0x11, 0x11, 0x11, 0x11, 0x11, 0x0E]
                                        else:
                                            if codepoint == 88:
                                                # 'X': two diagonals crossing
                                                [0x11, 0x11, 0x0A, 0x04, 0x0A, 0x11, 0x11]
                                            else:
                                                if codepoint == 97:
                                                    # 'a': lowercase rounded (approximation)
                                                    [0, 0, 0x0E, 0x01, 0x0F, 0x11, 0x0F]
                                                else:
                                                    # Placeholder rectangular outline for undefined glyphs
                                                    [0x1F, 0x11, 0x11, 0x11, 0x11, 0x11, 0x1F]

fn ascii_glyph_to_bitmap_pixels(codepoint: i64) -> [i64]:
    # Expand packed 7x5 bitmap into 35 flat row-major pixels (0 or 255).
    val rows = ascii_fallback_glyph(codepoint)
    var pixels: [i64] = []
    var ry: i64 = 0
    while ry < ASCII_GLYPH_HEIGHT:
        val row = rows[ry]
        var cx: i64 = 0
        while cx < ASCII_GLYPH_WIDTH:
            # Bit 4 = leftmost column, bit 0 = rightmost column
            val shift = (ASCII_GLYPH_WIDTH - 1) - cx
            val mask = 1 << shift
            val on = (row & mask) != 0
            if on:
                pixels = [...pixels, 255]
            else:
                pixels = [...pixels, 0]
            cx = cx + 1
        ry = ry + 1
    pixels

fn ascii_glyph_advance_x(codepoint: i64) -> i64:
    # Space has no visible advance; other printable chars advance 6 px.
    if codepoint == 32:
        0
    else:
        if codepoint < 32:
            0
        else:
            if codepoint > 126:
                0
            else:
                6
