# Gaussian blur: two-pass separable convolution over a flat SkColor4f pixel buffer

use std.skia.entity.color.{SkColor4f}
use std.common.math.{math_clamp}

class ImageBuffer:
    width: i32
    height: i32
    pixels: [SkColor4f]

# exp(x) approximation via 12-term Taylor series, accurate for x in [-10, 0]
fn _exp_neg(x: f64) -> f64:
    var t = 1.0
    var s = 1.0
    var i = 1
    while i <= 12:
        t = t * x / i.to_f64()
        s = s + t
        i = i + 1
    if s < 0.0:
        0.0
    else:
        s

fn gaussian_kernel(sigma: f64) -> [f64]:
    if sigma <= 0.0:
        return [1.0]
    val sigma2 = sigma * sigma
    val r = (sigma * 3.0).to_i32()
    val size = 2 * r + 1
    var k: [f64] = []
    var total = 0.0
    var i = 0
    while i < size:
        val diff = (i - r).to_f64()
        val exponent = -(diff * diff) / (2.0 * sigma2)
        val v = _exp_neg(exponent)
        k = k + [v]
        total = total + v
        i = i + 1
    var norm: [f64] = []
    var j = 0
    while j < size:
        norm = norm + [k[j.to_i64()] / total]
        j = j + 1
    norm

fn _pixel_at(buf: ImageBuffer, x: i32, y: i32) -> SkColor4f:
    val cx = if x < 0: 0 elif x >= buf.width: buf.width - 1 else: x
    val cy = if y < 0: 0 elif y >= buf.height: buf.height - 1 else: y
    buf.pixels[(cy * buf.width + cx).to_i64()]

fn blur_horizontal(src: ImageBuffer, sigma: f64) -> ImageBuffer:
    val k = gaussian_kernel(sigma)
    val r = k.len().to_i32() / 2
    var out: [SkColor4f] = []
    var y = 0
    while y < src.height:
        var x = 0
        while x < src.width:
            var ar = 0.0
            var ag = 0.0
            var ab = 0.0
            var aa = 0.0
            var ki = 0
            while ki < k.len().to_i32():
                val p = _pixel_at(src, x + ki - r, y)
                val w = k[ki.to_i64()]
                ar = ar + p.r * w
                ag = ag + p.g * w
                ab = ab + p.b * w
                aa = aa + p.a * w
                ki = ki + 1
            out = out + [SkColor4f(r: math_clamp(ar, 0.0, 1.0),
                                   g: math_clamp(ag, 0.0, 1.0),
                                   b: math_clamp(ab, 0.0, 1.0),
                                   a: math_clamp(aa, 0.0, 1.0))]
            x = x + 1
        y = y + 1
    ImageBuffer(width: src.width, height: src.height, pixels: out)

fn blur_vertical(src: ImageBuffer, sigma: f64) -> ImageBuffer:
    val k = gaussian_kernel(sigma)
    val r = k.len().to_i32() / 2
    var out: [SkColor4f] = []
    var y = 0
    while y < src.height:
        var x = 0
        while x < src.width:
            var ar = 0.0
            var ag = 0.0
            var ab = 0.0
            var aa = 0.0
            var ki = 0
            while ki < k.len().to_i32():
                val p = _pixel_at(src, x, y + ki - r)
                val w = k[ki.to_i64()]
                ar = ar + p.r * w
                ag = ag + p.g * w
                ab = ab + p.b * w
                aa = aa + p.a * w
                ki = ki + 1
            out = out + [SkColor4f(r: math_clamp(ar, 0.0, 1.0),
                                   g: math_clamp(ag, 0.0, 1.0),
                                   b: math_clamp(ab, 0.0, 1.0),
                                   a: math_clamp(aa, 0.0, 1.0))]
            x = x + 1
        y = y + 1
    ImageBuffer(width: src.width, height: src.height, pixels: out)

fn gaussian_blur(src: ImageBuffer, sigma_x: f64, sigma_y: f64) -> ImageBuffer:
    val h = blur_horizontal(src, sigma_x)
    blur_vertical(h, sigma_y)
