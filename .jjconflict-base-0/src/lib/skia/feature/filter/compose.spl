# Filter composition — sequential application of multiple image filters.
#
# Mirrors Skia's SkImageFilters::Compose(outer, inner):
#   apply(inner, then outer) to src bitmap.
#
# Generalized to N-stage pipeline: ComposeFilter { stages: [FilterNode] }
# where FilterNode is a tagged union of {Blur, Color, Morphology, Identity}.
#
# Stage application order: stages[0] is applied first, then stages[1] to that
# result, and so on. So the convenience constructor compose_filter_new2(inner,
# outer) produces stages = [inner, outer], matching Skia's Compose(outer, inner)
# semantics where the inner runs first.

use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.feature.filter.blur.{BlurFilter, blur_filter_new, apply_blur}
use std.skia.feature.filter.color_filter.{ColorFilter, color_filter_identity, apply_color_filter_to_bitmap}
use std.skia.feature.filter.morphology.{MorphologyFilter, erode_filter_new, apply_morphology}

# ----------------------------------------------------------------------------
# FilterNodeKind — tag for the active branch of a FilterNode union.
# ----------------------------------------------------------------------------

enum FilterNodeKind:
    Identity
    Blur
    Color
    Morphology

# ----------------------------------------------------------------------------
# FilterNode — tagged union over the supported per-stage filters.
#
# Only the field matching `kind` is meaningful. Other fields are placeholders
# initialised with sensible defaults so the value is well-formed.
# ----------------------------------------------------------------------------

class FilterNode:
    kind: FilterNodeKind
    blur: BlurFilter
    color: ColorFilter
    morphology: MorphologyFilter

# Default placeholders (kept private to this module).

fn _fn_default_blur() -> BlurFilter:
    blur_filter_new(0.0, 0.0)

fn _fn_default_color() -> ColorFilter:
    color_filter_identity()

fn _fn_default_morphology() -> MorphologyFilter:
    erode_filter_new(0 as i64, 0 as i64)

# ----------------------------------------------------------------------------
# Constructors — each stamps the kind tag and fills unused slots with defaults.
# ----------------------------------------------------------------------------

fn filter_node_identity() -> FilterNode:
    FilterNode(
        kind: FilterNodeKind.Identity,
        blur: _fn_default_blur(),
        color: _fn_default_color(),
        morphology: _fn_default_morphology()
    )

fn filter_node_blur(f: BlurFilter) -> FilterNode:
    FilterNode(
        kind: FilterNodeKind.Blur,
        blur: f,
        color: _fn_default_color(),
        morphology: _fn_default_morphology()
    )

fn filter_node_color(f: ColorFilter) -> FilterNode:
    FilterNode(
        kind: FilterNodeKind.Color,
        blur: _fn_default_blur(),
        color: f,
        morphology: _fn_default_morphology()
    )

fn filter_node_morphology(f: MorphologyFilter) -> FilterNode:
    FilterNode(
        kind: FilterNodeKind.Morphology,
        blur: _fn_default_blur(),
        color: _fn_default_color(),
        morphology: f
    )

# ----------------------------------------------------------------------------
# ComposeFilter — ordered list of stages applied left-to-right.
# ----------------------------------------------------------------------------

class ComposeFilter:
    stages: [FilterNode]

fn compose_filter_new(stages: [FilterNode]) -> ComposeFilter:
    ComposeFilter(stages: stages)

# Skia-style convenience: SkImageFilters::Compose(outer, inner) applies the
# inner filter first, then the outer. We expose the natural pipeline ordering
# (inner first) to make call sites self-documenting.
fn compose_filter_new2(inner: FilterNode, outer: FilterNode) -> ComposeFilter:
    var stages = [FilterNode]()
    stages.push(inner)
    stages.push(outer)
    ComposeFilter(stages: stages)

# ----------------------------------------------------------------------------
# _bitmap_clone — defensive copy used for Identity / empty-stage pass-through
# so callers can mutate the result without aliasing the input.
# ----------------------------------------------------------------------------

fn _bitmap_clone(src: Bitmap) -> Bitmap:
    val w = src.width
    val h = src.height
    val out = Bitmap.zeros(w, h)
    val total = w * h * 4
    var i = 0 as i64
    while i < total:
        out.pixels[i] = src.pixels[i]
        i = i + 1
    out

# ----------------------------------------------------------------------------
# _apply_node — dispatch a single FilterNode onto a Bitmap.
# ----------------------------------------------------------------------------

fn _apply_node(src: Bitmap, node: FilterNode) -> Bitmap:
    if node.kind == FilterNodeKind.Blur:
        return apply_blur(src, node.blur)
    if node.kind == FilterNodeKind.Color:
        return apply_color_filter_to_bitmap(src, node.color)
    if node.kind == FilterNodeKind.Morphology:
        return apply_morphology(src, node.morphology)
    # Identity (and any unknown future kind) → defensive copy.
    _bitmap_clone(src)

# ----------------------------------------------------------------------------
# apply_compose — run the pipeline. stages[0] is applied first, stages[1] to
# that result, and so on. An empty stage list returns a clone of the input.
# ----------------------------------------------------------------------------

fn apply_compose(src: Bitmap, compose: ComposeFilter) -> Bitmap:
    val n = compose.stages.length()
    if n == 0:
        return _bitmap_clone(src)
    var cur = _apply_node(src, compose.stages[0])
    var i = 1 as i64
    while i < n:
        cur = _apply_node(cur, compose.stages[i])
        i = i + 1
    cur
