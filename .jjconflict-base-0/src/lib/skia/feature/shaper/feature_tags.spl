# OpenType feature tags for shaping

enum OpenTypeFeature:
    Kerning
    Ligatures
    ContextualAlt
    LocalizedForms
    SmallCaps
    StylisticAlt
    Fractions
    Superscript
    Subscript

fn feature_tag(f: OpenTypeFeature) -> text:
    if f == OpenTypeFeature.Kerning:
        "kern"
    else if f == OpenTypeFeature.Ligatures:
        "liga"
    else if f == OpenTypeFeature.ContextualAlt:
        "calt"
    else if f == OpenTypeFeature.LocalizedForms:
        "locl"
    else if f == OpenTypeFeature.SmallCaps:
        "smcp"
    else if f == OpenTypeFeature.StylisticAlt:
        "salt"
    else if f == OpenTypeFeature.Fractions:
        "frac"
    else if f == OpenTypeFeature.Superscript:
        "sups"
    else if f == OpenTypeFeature.Subscript:
        "subs"
    else:
        "    "
