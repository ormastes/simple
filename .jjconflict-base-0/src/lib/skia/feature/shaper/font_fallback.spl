# Font fallback chain for script-aware font selection

use std.skia.entity.font.{SkFont, sk_typeface_default, sk_font_new}
use std.skia.feature.shaper.script_detect.{Script}

class FallbackChain:
    primary: SkFont
    fallbacks: [SkFont]

fn fallback_chain_new(primary: SkFont) -> FallbackChain:
    FallbackChain(primary: primary, fallbacks: [])

fn fallback_chain_add(chain: FallbackChain, f: SkFont) -> FallbackChain:
    var new_fallbacks: [SkFont] = []
    for fb in chain.fallbacks:
        new_fallbacks.push(fb)
    new_fallbacks.push(f)
    FallbackChain(primary: chain.primary, fallbacks: new_fallbacks)

fn fallback_chain_font_for_script(chain: FallbackChain, s: Script) -> SkFont:
    # Stub: always return primary. Real impl resolves per script in Phase 3 final.
    chain.primary

fn system_default_chain() -> FallbackChain:
    val tf = sk_typeface_default()
    val font = sk_font_new(tf, 12.0)
    FallbackChain(primary: font, fallbacks: [])
