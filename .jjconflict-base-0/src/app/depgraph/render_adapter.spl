# Dependency Graph Render Adapter
#
# Bridges the depgraph app to the shared ui.render contract.
# Produces text (ASCII tree) and html (interactive CSS-positioned graph)
# views of package dependency relationships.

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{html_page, html_card, html_grid, html_badge,
    html_escape, css_reset, css_dark_theme, css_light_theme}
use app.ui.render.table.{TableBuilder, ALIGN_LEFT}

# =========================================================================
# Data Types
# =========================================================================

class DepNode:
    name: text
    version: text
    depth: i64
    children: [text]

class DepGraph:
    root: text
    root_version: text
    nodes: [DepNode]
    total_packages: i64
    max_depth: i64

# =========================================================================
# Render Adapter Entry Point
# =========================================================================

fn render_depgraph(config: RenderConfig, graph: DepGraph) -> RenderResult:
    """Render the dependency graph via the shared render contract.

    Produces an ASCII tree for text output and a CSS-positioned
    interactive graph for HTML output.
    """
    match config.format:
        "html":
            return render_as_html(graph, config)
        "both":
            val text_out = render_as_text(graph, config)
            val html_out = render_as_html(graph, config)
            return RenderResult.both(text_out.text_output, html_out.html_output)
        _:
            return render_as_text(graph, config)

# =========================================================================
# Text Rendering (ASCII dependency tree)
# =========================================================================

fn render_as_text(graph: DepGraph, config: RenderConfig) -> RenderResult:
    """Render dependency graph as an indented ASCII tree."""
    var lines: [text] = []

    lines.push("Dependency Graph: {graph.root} v{graph.root_version}")
    lines.push("  Packages: {graph.total_packages}  |  Max depth: {graph.max_depth}")
    lines.push("")

    # Render each node with indentation based on depth
    for node in graph.nodes:
        val indent = make_indent(node.depth)
        val connector = if node.depth == 0: "" else: "+-- "
        lines.push("{indent}{connector}{node.name} ({node.version})")

        # Show children count if any
        if node.children.len() > 0:
            val child_indent = make_indent(node.depth + 1)
            for child in node.children:
                val already_listed = node_exists(graph.nodes, child)
                if not already_listed:
                    lines.push("{child_indent}+-- {child} (not resolved)")

    lines.push("")
    lines.push("Total: {graph.total_packages} packages")

    return RenderResult.text(join_lines(lines))

# =========================================================================
# HTML Rendering (interactive graph with positioned nodes)
# =========================================================================

fn render_as_html(graph: DepGraph, config: RenderConfig) -> RenderResult:
    """Render dependency graph as an HTML page with CSS-positioned nodes and edges."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    var css = ""
    css = "{css}{css_reset()}\n{theme_css}\n"
    css = "{css}.container { max-width: 1400px; margin: 0 auto; }\n"
    css = "{css}.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }\n"
    css = "{css}.card h3 { margin-bottom: 8px; }\n"
    css = "{css}.card-body { color: var(--text-dim); font-size: 14px; }\n"
    css = "{css}.value { font-size: 28px; font-weight: bold; color: var(--blue); }\n"
    css = "{css}.sub { font-size: 13px; color: var(--text-dim); margin-top: 4px; }\n"
    css = "{css}.badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 12px; font-weight: 500; color: #fff; }\n"
    css = "{css}.graph-container { position: relative; min-height: 400px; margin: 20px 0; overflow: auto; }\n"
    css = "{css}.dep-node { position: absolute; background: var(--bg-card); border: 1px solid var(--border);\n"
    css = "{css}  border-radius: 6px; padding: 8px 14px; font-size: 13px; white-space: nowrap;\n"
    css = "{css}  transition: box-shadow 0.2s; cursor: default; }\n"
    css = "{css}.dep-node:hover { box-shadow: 0 0 12px rgba(88, 166, 255, 0.3); border-color: var(--blue); }\n"
    css = "{css}.dep-node .name { font-weight: 600; color: var(--text); }\n"
    css = "{css}.dep-node .ver { color: var(--text-dim); font-size: 11px; margin-left: 4px; }\n"
    css = "{css}.dep-edge { position: absolute; background: var(--border); }\n"
    css = "{css}.dep-edge-h { height: 2px; }\n"
    css = "{css}.dep-edge-v { width: 2px; }\n"

    var body = ""
    body = "{body}<div class=\"container\">\n"
    body = "{body}<h1>Dependency Graph</h1>\n"

    # Summary cards
    val summary_cards = [
        html_card("Root Package", "<p class=\"value\">{html_escape(graph.root)}</p><p class=\"sub\">v{html_escape(graph.root_version)}</p>"),
        html_card("Total Packages", "<p class=\"value\">{graph.total_packages}</p><p class=\"sub\">resolved dependencies</p>"),
        html_card("Max Depth", "<p class=\"value\">{graph.max_depth}</p><p class=\"sub\">deepest dependency chain</p>")
    ]
    body = "{body}{html_grid(3, \"12px\", summary_cards)}\n"

    # Graph visualization
    body = "{body}<h2 style=\"margin:20px 0 12px\">Graph</h2>\n"
    body = "{body}<div class=\"graph-container\">\n"

    # Position nodes in a tree layout
    val node_height = 40
    val node_x_step = 220
    val node_y_step = 50
    var y_offset = 10

    for node in graph.nodes:
        val x = (node.depth * node_x_step) + 10
        val y = y_offset
        val version_badge = html_badge("v{node.version}", "var(--blue, #58a6ff)")

        body = "{body}<div class=\"dep-node\" style=\"left:{x}px; top:{y}px\">"
        body = "{body}<span class=\"name\">{html_escape(node.name)}</span> {version_badge}"
        body = "{body}</div>\n"

        # Draw horizontal edge from parent depth
        if node.depth > 0:
            val edge_x = ((node.depth - 1) * node_x_step) + 160
            val edge_w = x - edge_x
            val edge_y = y + 16
            body = "{body}<div class=\"dep-edge dep-edge-h\" style=\"left:{edge_x}px; top:{edge_y}px; width:{edge_w}px\"></div>\n"

        y_offset = y_offset + node_y_step

    body = "{body}</div>\n"

    # Package list table
    body = "{body}<h2 style=\"margin:20px 0 12px\">Package List</h2>\n"
    var pkg_cards: [text] = []
    for node in graph.nodes:
        val dep_count = node.children.len()
        val depth_color = if node.depth == 0: "var(--green, #3fb950)" elif node.depth <= 2: "var(--blue, #58a6ff)" else: "var(--yellow, #d29922)"
        var card_body = ""
        card_body = "{card_body}<p>{html_badge(\"v{node.version}\", \"var(--blue, #58a6ff)\")}"
        card_body = "{card_body} {html_badge(\"depth {node.depth}\", depth_color)}</p>"
        if dep_count > 0:
            card_body = "{card_body}<p style=\"margin-top:6px; color:var(--text-dim)\">{dep_count} dependencies</p>"
        pkg_cards.push(html_card(node.name, card_body))
    body = "{body}{html_grid(3, \"12px\", pkg_cards)}\n"

    body = "{body}</div>\n"

    return RenderResult.html(html_page("Dependency Graph", css, body))

# =========================================================================
# Helpers
# =========================================================================

fn make_indent(depth: i64) -> text:
    """Build indentation string for the given depth level."""
    var result = ""
    var i = 0
    while i < depth:
        result = "{result}    "
        i = i + 1
    return result

fn node_exists(nodes: [DepNode], name: text) -> bool:
    """Check if a node with the given name exists in the node list."""
    for node in nodes:
        if node.name == name:
            return true
    return false

fn join_lines(lines: [text]) -> text:
    var result = ""
    var first = true
    for line in lines:
        if not first:
            result = "{result}\n"
        result = "{result}{line}"
        first = false
    return result
