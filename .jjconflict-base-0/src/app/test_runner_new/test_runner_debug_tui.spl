# Test Runner Debug TUI Surface
#
# Pure model for the session-debug view. The real runner prints the same
# session scheduling facts; this module exposes them as TUI text and SGTTI
# WinText nodes so system specs can query the UI without a live terminal.

use app.test_daemon.session_scheduler.{SessionSchedule, schedule_summary}
use app.test_daemon.session_types.{session_kind_name}
use common.ui.access_types.{UiAccessProp, UiAccessSurface}
use common.ui.win_text_access.{
    WinTextSnapshot,
    win_text_make_node,
    win_text_snapshot_from_parts,
    win_text_source
}

struct TestRunnerDebugTuiModel:
    title: text
    target: text
    mode: text
    session_enabled: bool
    session_debug: bool
    total_tests: i64
    session_groups: i64
    ungrouped: i64
    lines: [text]

fn test_runner_debug_tui_model(target: text, mode: text, session_enabled: bool, session_debug: bool, schedule: SessionSchedule) -> TestRunnerDebugTuiModel:
    TestRunnerDebugTuiModel(
        title: "Test Runner Debug",
        target: target,
        mode: mode,
        session_enabled: session_enabled,
        session_debug: session_debug,
        total_tests: schedule.total_tests,
        session_groups: schedule.total_groups,
        ungrouped: schedule.total_ungrouped,
        lines: test_runner_debug_tui_lines_for(target, mode, session_enabled, session_debug, schedule)
    )

fn test_runner_debug_tui_lines_for(target: text, mode: text, session_enabled: bool, session_debug: bool, schedule: SessionSchedule) -> [text]:
    var lines: [text] = []
    lines.push("Test Runner Debug")
    lines.push("target: {target}")
    lines.push("mode: {mode}")
    lines.push("session-enabled: {session_enabled}")
    lines.push("session-debug: {session_debug}")
    lines.push("total-tests: {schedule.total_tests}")
    lines.push("session-groups: {schedule.total_groups}")
    lines.push("ungrouped: {schedule.total_ungrouped}")
    for group in schedule.groups:
        lines.push("group: {session_kind_name(group.key.kind)} target={group.key.target} tests={group.entries.len()} priority={group.priority}")
    lines

fn test_runner_debug_tui_lines(model: TestRunnerDebugTuiModel) -> [text]:
    model.lines

fn test_runner_debug_tui_capture(model: TestRunnerDebugTuiModel) -> text:
    model.lines.join("\n")

fn test_runner_debug_tui_summary(model: TestRunnerDebugTuiModel) -> text:
    "test-runner-debug: target={model.target} mode={model.mode} enabled={model.session_enabled} debug={model.session_debug} groups={model.session_groups} ungrouped={model.ungrouped}"

fn test_runner_debug_tui_schedule_text(schedule: SessionSchedule) -> text:
    schedule_summary(schedule)

fn test_runner_debug_tui_snapshot(model: TestRunnerDebugTuiModel, captured_at_ms: i64, max_age_ms: i64, now_ms: i64) -> WinTextSnapshot:
    val surface_id = "test-runner-debug:tui"
    val surface = UiAccessSurface(
        surface_id: surface_id,
        title: model.title,
        active: true,
        window_id: "test-runner-debug",
        app_id: "test-runner",
        root_canonical_id: "{surface_id}#root"
    )
    val source = win_text_source(
        source_id: "test-runner-debug",
        source_kind: "in_process_tui",
        confidence: "high",
        capabilities: ["query_text", "layout_read"],
        captured_at_ms: captured_at_ms,
        max_age_ms: max_age_ms,
        now_ms: now_ms
    )
    var nodes = [
        win_text_make_node(surface_id, "root", "tui_panel", model.title, [], [
            UiAccessProp(key: "target", value: model.target),
            UiAccessProp(key: "mode", value: model.mode),
            UiAccessProp(key: "session_enabled", value: "{model.session_enabled}"),
            UiAccessProp(key: "session_debug", value: "{model.session_debug}")
        ])
    ]
    var i = 0
    for line in model.lines:
        nodes.push(win_text_make_node(surface_id, "line_{i}", "text", line, [], [
            UiAccessProp(key: "line", value: "{i}")
        ]))
        i = i + 1
    win_text_snapshot_from_parts("tui", surface_id, [surface], nodes, [source])
