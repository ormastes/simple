fn _render_launcher(config: RenderConfig) -> RenderResult:
    """Render the office launcher home screen."""
    use common.office.file_ops.{RecentFileStore}
    use app.office.launcher.{build_launcher_ui}

    val store = RecentFileStore.new(20)
    val recent = store.get_recent(10)
    val ui = build_launcher_ui(recent)

    val text_out = _build_text_lines([
        "Simple Office Launcher",
        "======================",
        "Recent files: {recent.len()}",
        "",
        "Apps: Word | Sheets | Slides | Mail | Planner",
        "",
        _widget_tree_to_text(ui.root_node(), 0)
    ])

    val meta = {
        "app": "launcher",
        "recent_count": "{recent.len()}",
        "root_id": "{ui.root_id}"
    }

    if config.format == "html":
        val state = UIState.new(ui)
        val html_out = render_html_tree(ui.root_node(), state)
        return RenderResult(
            format: "html",
            text_output: text_out,
            html_output: html_out,
            metadata: meta,
            warnings: []
        )

    return RenderResult(
        format: "text",
        text_output: text_out,
        html_output: "",
        metadata: meta,
        warnings: []
    )

# =========================================================================
# Text Rendering Helpers
# =========================================================================

fn _build_text_lines(lines: [text]) -> text:
    """Join lines with newlines."""
    return lines.join("\n")

fn _widget_tree_to_text(node: WidgetNode, depth: i32) -> text:
    """Recursively render a widget tree to indented text."""
    val indent = _indent(depth)
    val kind = node.kind_name()
    val label = node.get_prop("label")
    val display = if label != "": "{kind}: {label}" else: kind

    var result = "{indent}[{node.id}] {display}"

    for child in node.children():
        val child_text = _widget_tree_to_text(child, depth + 1)
        result = "{result}\n{child_text}"

    return result

fn _indent(depth: i32) -> text:
    """Return indentation string for the given depth."""
    var s = ""
    var i: i32 = 0
    while i < depth:
        s = "{s}  "
        i = i + 1
    return s
