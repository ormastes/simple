# Office Render Adapter
#
# Unified render adapter for the office suite. Routes render requests to the
# appropriate sub-app (word, sheets, slides, mail, planner) and converts
# each sub-app's UI tree into a shared RenderResult with text and HTML output.

use common.ui.widget.{WidgetNode, UITree, UIState}
use app.ui.render.widgets.{render_html_tree}
use app.ui.render.types.{RenderConfig, RenderResult}
use app.office.word.word_app.{WordApp}
use app.office.word.render.{render_document}
use app.office.sheets.sheets_app.{SheetsApp}
use app.office.sheets.cell.{cell_ref_to_string}
use app.office.slides.slides_app.{SlidesApp}
use app.office.slides.slide.{slide_count}
use app.office.slides.render.{render_slide_thumbnail}
use app.office.mail.mail_app.{MailApp}
use app.office.mail.message.{folder_name}
use app.office.planner.planner_app.{PlannerApp}
use app.office.theme.{office_theme}

# =========================================================================
# Main Render Entry Point
# =========================================================================

fn office_render(config: RenderConfig) -> RenderResult:
    """Route a render request to the appropriate office sub-app.

    The adapter_name field selects the sub-app:
      launcher, word, sheets, slides, mail, planner
    """
    match config.adapter_name:
        "word" =>
            return _render_word(config)
        "sheets" =>
            return _render_sheets(config)
        "slides" =>
            return _render_slides(config)
        "mail" =>
            return _render_mail(config)
        "planner" =>
            return _render_planner(config)
        "launcher" =>
            return _render_launcher(config)
        _ =>
            var result = RenderResult(
                format: "text",
                text_output: "Unknown office adapter: {config.adapter_name}",
                html_output: "",
                metadata: {},
                warnings: ["Unknown adapter_name: {config.adapter_name}"]
            )
            return result

# =========================================================================
# Sub-App Renderers
# =========================================================================

fn _render_word(config: RenderConfig) -> RenderResult:
    """Render the Word app."""
    val app = WordApp.new()
    val ui = app.build_ui()
    val word_count = app.word_count()
    val modified = app.modified

    val text_out = _build_text_lines([
        "Simple Word",
        "===========",
        "Words: {word_count}",
        "Modified: {modified}",
        "",
        _widget_tree_to_text(ui.root_node(), 0)
    ])

    val meta = {
        "app": "word",
        "word_count": "{word_count}",
        "modified": "{modified}",
        "root_id": "{ui.root_id}"
    }

    if config.format == "html":
        val state = UIState.new(ui)
        val html_out = render_html_tree(ui.root_node(), state)
        return RenderResult(
            format: "html",
            text_output: text_out,
            html_output: html_out,
            metadata: meta,
            warnings: []
        )

    return RenderResult(
        format: "text",
        text_output: text_out,
        html_output: "",
        metadata: meta,
        warnings: []
    )

fn _render_sheets(config: RenderConfig) -> RenderResult:
    """Render the Sheets app."""
    val app = SheetsApp.new()
    val ui = app.build_ui()
    val sheet_count = app.workbook.sheets.len()
    val active_ref = cell_ref_to_string(app.active_cell)

    val text_out = _build_text_lines([
        "Simple Sheets",
        "=============",
        "Sheets: {sheet_count}",
        "Active cell: {active_ref}",
        "Modified: {app.modified}",
        "",
        _widget_tree_to_text(ui.root_node(), 0)
    ])

    val meta = {
        "app": "sheets",
        "sheet_count": "{sheet_count}",
        "active_cell": "{active_ref}",
        "modified": "{app.modified}",
        "root_id": "{ui.root_id}"
    }

    if config.format == "html":
        val state = UIState.new(ui)
        val html_out = render_html_tree(ui.root_node(), state)
        return RenderResult(
            format: "html",
            text_output: text_out,
            html_output: html_out,
            metadata: meta,
            warnings: []
        )

    return RenderResult(
        format: "text",
        text_output: text_out,
        html_output: "",
        metadata: meta,
        warnings: []
    )

fn _render_slides(config: RenderConfig) -> RenderResult:
    """Render the Slides app."""
    val app = SlidesApp.new()
    val ui = app.build_ui()
    val total = slide_count(app.presentation)

    # Build slide thumbnail list
    var thumb_lines: [text] = []
    var idx: i32 = 0
    for slide in app.presentation.slides:
        val thumb = render_slide_thumbnail(slide, idx)
        thumb_lines = thumb_lines.push("  {thumb}")
        idx = idx + 1

    var lines: [text] = [
        "Simple Slides",
        "=============",
        "Slides: {total}",
        "Modified: {app.modified}",
        ""
    ]
    if thumb_lines.len() > 0:
        lines = lines.push("Slide List:")
        for tl in thumb_lines:
            lines = lines.push(tl)
        lines = lines.push("")
    lines = lines.push(_widget_tree_to_text(ui.root_node(), 0))

    val text_out = _build_text_lines(lines)
    val meta = {
        "app": "slides",
        "slide_count": "{total}",
        "modified": "{app.modified}",
        "root_id": "{ui.root_id}"
    }

    if config.format == "html":
        val state = UIState.new(ui)
        val html_out = render_html_tree(ui.root_node(), state)
        return RenderResult(
            format: "html",
            text_output: text_out,
            html_output: html_out,
            metadata: meta,
            warnings: []
        )

    return RenderResult(
        format: "text",
        text_output: text_out,
        html_output: "",
        metadata: meta,
        warnings: []
    )

