# Word Document HTML Rendering
#
# Renders a rich-text document to styled HTML using the shared office style
# resolver, giving the Word surface MS-Word-level typography from the same
# default theme the markdown and slide surfaces use.
#
# Built against the real `attributed_text` model (DocBlock { kind, spans } with
# the BlockKind enum) and kept separate from `word/render.spl`, which targets the
# UI widget tree and a stale DocBlock API.

use common.rich_text.attributed_text.{DocBlock, BlockKind, RichDocument, spans_to_plain_text}
use std.common.render_scene.office_style_resolver.{resolve_style, style_to_css_text}

fn _block_style_tag(kind: BlockKind) -> text:
    """Map a block kind to a resolver style tag from the shared default theme."""
    match kind:
        case Paragraph: return "paragraph"
        case Heading1: return "heading_1"
        case Heading2: return "heading_2"
        case Heading3: return "heading_3"
        case BulletItem: return "bullet_list"
        case CodeBlock: return "code_block"
        case Quote: return "quote"

fn render_block_html(block: DocBlock) -> text:
    """Render a single document block as a styled HTML <div> whose inline CSS
    comes from the shared office style resolver."""
    val tag = _block_style_tag(block.kind)
    val content = spans_to_plain_text(block.spans)
    val style = resolve_style(tag, [])
    val css = style_to_css_text(style)
    "<div class=\"{tag}\" style=\"{css}\">{content}</div>"

fn render_document_html(doc: RichDocument) -> text:
    """Render a whole rich-text document as a styled HTML article."""
    var out = "<article class=\"document\">"
    for block in doc.blocks:
        out = "{out}{render_block_html(block)}"
    "{out}</article>"
