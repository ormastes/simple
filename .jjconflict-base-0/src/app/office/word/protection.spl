# Word Document Protection (Restrict Editing)
#
# Pure functions modeling Word's "Restrict Editing" document protection:
# an editing mode (none/readOnly/comments/trackedChanges/forms), whether
# that mode is enforced, and an opaque password hash used to unprotect.
#
# Provides: Protection, protection_new, protection_none, protection_read_only,
# can_edit_body, can_add_comment, requires_password, protection_to_xml,
# protection_summary.
#
# Ground-truth permission matrix (enforced == true; when enforced == false,
# there is no restriction at all -- both permissions are always true):
#   mode            can_edit_body  can_add_comment
#   none            true           true
#   readOnly        false          false
#   comments        false          true
#   forms           false          false
#   trackedChanges  true           true   (edits allowed, but tracked)

struct Protection:
    mode: text
    enforced: bool
    password_hash: text

fn protection_new(mode: text, enforced: bool, password_hash: text) -> Protection:
    Protection(mode: mode, enforced: enforced, password_hash: password_hash)

fn protection_none() -> Protection:
    """No protection at all: mode "none", not enforced, no password."""
    protection_new("none", false, "")

fn protection_read_only(password_hash: text) -> Protection:
    """Enforced read-only protection guarded by `password_hash`."""
    protection_new("readOnly", true, password_hash)

fn can_edit_body(prot: Protection) -> bool:
    """True unless protection is enforced with a mode that restricts free
    body edits (readOnly/comments/forms). trackedChanges still allows body
    edits (they are simply tracked). A non-enforced protection never
    restricts anything."""
    if not prot.enforced:
        true
    else:
        if (prot.mode == "readOnly") or (prot.mode == "comments") or (prot.mode == "forms"):
            false
        else:
            true

fn can_add_comment(prot: Protection) -> bool:
    """True for none/comments/trackedChanges (or whenever not enforced);
    false for readOnly/forms while enforced."""
    if not prot.enforced:
        true
    else:
        if (prot.mode == "readOnly") or (prot.mode == "forms"):
            false
        else:
            true

fn requires_password(prot: Protection) -> bool:
    """True iff a non-empty password hash guards the protection."""
    prot.password_hash != ""

fn protection_to_xml(prot: Protection) -> text:
    """Render the Word <w:documentProtection> fragment. Mode "none" needs no
    protection element at all, so it renders to the empty string."""
    if prot.mode == "none":
        ""
    else:
        val enf_val = if prot.enforced: "1" else: "0"
        val base = "<w:documentProtection w:edit=\"{prot.mode}\" w:enforcement=\"{enf_val}\""
        if requires_password(prot):
            "{base} w:hash=\"{prot.password_hash}\"/>"
        else:
            "{base}/>"

fn protection_summary(prot: Protection) -> text:
    """Readable one-line summary, e.g. "readOnly (enforced, password)" or
    "none"."""
    if prot.mode == "none":
        "none"
    else:
        if prot.enforced:
            if requires_password(prot):
                "{prot.mode} (enforced, password)"
            else:
                "{prot.mode} (enforced)"
        else:
            "{prot.mode} (not enforced)"
