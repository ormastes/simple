# Word Footnotes & Endnotes
#
# Pure functions modeling Word's "Footnotes & Endnotes" feature: a Note has a
# kind (footnote or endnote), an auto-assigned reference number, an anchor
# position (paragraph index + character index in the document body), and
# text content. Footnotes and endnotes are numbered in two independent
# sequences, each renumbered from document position order on every insert or
# delete.
#
# Provides: NoteKind, Note, NoteCollection, notes_new, insert_footnote,
# insert_endnote, delete_note, footnotes, endnotes, footnote_count,
# endnote_count, render_footnotes, render_endnotes.
#
# Ground truth:
# - Each inserted note gets a unique `id` (never reused, monotonically
#   increasing) used to address it for deletion; `number` is the *visible*
#   reference number and is recomputed from scratch after every insert or
#   delete.
# - Numbering order is document position order: ascending by
#   (para_index, char_index), ties broken by keeping relative insertion
#   order stable.
# - Footnotes and endnotes are numbered in separate sequences: inserting an
#   endnote never changes footnote numbers and vice versa.
# - render_footnotes / render_endnotes format the notes of one kind as a
#   numbered block ("1. text", "2. text", ...) in document position order,
#   one line per note, joined by newlines.

# =========================================================================
# Types
# =========================================================================

enum NoteKind:
    Footnote
    Endnote

struct Note:
    id: i32
    kind: NoteKind
    number: i32
    para_index: i32
    char_index: i32
    text: text

struct NoteCollection:
    notes: [Note]
    next_id: i32

fn notes_new() -> NoteCollection:
    """An empty note collection; the first inserted note gets id 1."""
    NoteCollection(notes: [], next_id: 1)

# =========================================================================
# Document-position ordering (stable)
# =========================================================================

fn _position_less(a: Note, b: Note) -> bool:
    """True if `a` anchors strictly before `b` in document order."""
    if a.para_index < b.para_index:
        return true
    if a.para_index > b.para_index:
        return false
    a.char_index < b.char_index

fn _sort_by_position(notes: [Note]) -> [Note]:
    """Stable insertion sort of `notes` by (para_index, char_index) ascending."""
    var arr: [Note] = []
    for n in notes:
        arr.push(n)
    val siz = arr.len()
    var a = 1
    while a < siz:
        val key = arr[a]
        var b = a - 1
        var shifting = true
        while shifting and b >= 0:
            if _position_less(key, arr[b]):
                arr[b + 1] = arr[b]
                b = b - 1
            else:
                shifting = false
        arr[b + 1] = key
        a = a + 1
    arr

# =========================================================================
# Renumbering
# =========================================================================

fn _renumber(coll: NoteCollection) -> NoteCollection:
    """Re-sort `coll.notes` by document position and recompute each note's
    visible `number` within its own kind's sequence (footnotes 1..N,
    endnotes 1..M, independently)."""
    val sorted = _sort_by_position(coll.notes)
    var new_notes: [Note] = []
    var footnote_counter = 0
    var endnote_counter = 0
    for n in sorted:
        match n.kind:
            case Footnote:
                footnote_counter = footnote_counter + 1
                new_notes.push(Note(id: n.id, kind: n.kind, number: footnote_counter, para_index: n.para_index, char_index: n.char_index, text: n.text))
            case Endnote:
                endnote_counter = endnote_counter + 1
                new_notes.push(Note(id: n.id, kind: n.kind, number: endnote_counter, para_index: n.para_index, char_index: n.char_index, text: n.text))
    NoteCollection(notes: new_notes, next_id: coll.next_id)

# =========================================================================
# Insert / Delete
# =========================================================================

fn insert_footnote(coll: NoteCollection, para_index: i32, char_index: i32, text: text) -> NoteCollection:
    """Insert a new footnote anchored at (para_index, char_index) with the
    given text. Returns the updated collection with all footnotes renumbered
    in document order (coll is not mutated in place)."""
    var new_notes = coll.notes
    val note = Note(id: coll.next_id, kind: NoteKind.Footnote, number: 0, para_index: para_index, char_index: char_index, text: text)
    new_notes.push(note)
    _renumber(NoteCollection(notes: new_notes, next_id: coll.next_id + 1))

fn insert_endnote(coll: NoteCollection, para_index: i32, char_index: i32, text: text) -> NoteCollection:
    """Insert a new endnote anchored at (para_index, char_index) with the
    given text. Returns the updated collection with all endnotes renumbered
    in document order (coll is not mutated in place)."""
    var new_notes = coll.notes
    val note = Note(id: coll.next_id, kind: NoteKind.Endnote, number: 0, para_index: para_index, char_index: char_index, text: text)
    new_notes.push(note)
    _renumber(NoteCollection(notes: new_notes, next_id: coll.next_id + 1))

fn delete_note(coll: NoteCollection, id: i32) -> NoteCollection:
    """Remove the note with the given `id` (if any) and renumber the
    remaining notes of its kind. Returns the updated collection (coll is not
    mutated in place)."""
    var new_notes: [Note] = []
    for n in coll.notes:
        if n.id != id:
            new_notes.push(n)
    _renumber(NoteCollection(notes: new_notes, next_id: coll.next_id))

# =========================================================================
# Listing
# =========================================================================

fn footnotes(coll: NoteCollection) -> [Note]:
    """All footnotes in `coll`, in document position order."""
    var result: [Note] = []
    for n in coll.notes:
        if n.kind == NoteKind.Footnote:
            result.push(n)
    result

fn endnotes(coll: NoteCollection) -> [Note]:
    """All endnotes in `coll`, in document position order."""
    var result: [Note] = []
    for n in coll.notes:
        if n.kind == NoteKind.Endnote:
            result.push(n)
    result

fn footnote_count(coll: NoteCollection) -> i32:
    """Number of footnotes currently in `coll`."""
    footnotes(coll).len()

fn endnote_count(coll: NoteCollection) -> i32:
    """Number of endnotes currently in `coll`."""
    endnotes(coll).len()

# =========================================================================
# Rendering
# =========================================================================

fn _render_numbered_block(notes: [Note]) -> text:
    """Format `notes` (already numbered) as a numbered block: one
    "N. text" line per note, joined by newlines."""
    var lines: [text] = []
    for n in notes:
        val num = n.number
        lines.push("{num}. {n.text}")
    lines.join("\n")

fn render_footnotes(coll: NoteCollection) -> text:
    """Render the footnotes section as it would appear at the bottom of a
    page: a numbered block in document position order."""
    _render_numbered_block(footnotes(coll))

fn render_endnotes(coll: NoteCollection) -> text:
    """Render the endnotes section as it would appear at the end of the
    document: a numbered block in document position order."""
    _render_numbered_block(endnotes(coll))
