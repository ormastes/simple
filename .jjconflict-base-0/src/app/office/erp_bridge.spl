# ERP Bridge — Simple-ERP <-> Office interoperability
#
# Bridges the standalone Simple-ERP example (a separate reference repo, not
# vendored here) into the office toolchain: its Sale record and its on-disk
# persistence format become a Calc Sheet (formulas/pivot/charts/xlsx/fods
# export/find/sort all apply unmodified), and a Sheet edited in office
# round-trips back to the ERP's file format for re-import. An invoice
# document is rendered from an ERP row via the existing mail-merge machinery.
#
# ERP schema findings (read from a reference clone of the ERP repo):
#   - Record: `struct Sale` (src/lanes/sale.spl) / `class Sale`
#     (src/catalog.spl) — id: i64, channel: text, subtotal: i64, tax: i64,
#     paid: bool, status: text, audit_note: text. This is the ERP's closest
#     analog to an "invoice" line (gross = subtotal + tax; see sale_total in
#     src/lanes/sale.spl). The ERP's Sale row carries no separate
#     customer/product field — `channel` is its only categorical dimension,
#     so `channel` is used as the pivot/SUMIFS grouping key here.
#   - Persistence format: `src/kernel/durable_log.spl` (`save_log`/`load_log`)
#     is the ONLY on-disk format anywhere in the reference repo (confirmed:
#     no `.csv`/`.sdn` reader/writer exists in src/ or ubs_test/). It is a
#     line format: header `ubslog v1 count={n} checksum={c}`, then one line
#     per event `{seq}|{kind}|{entity}|{payload}`, backslash-escaped
#     (`\` -> `\\`, `|` -> `\p`, newline -> `\n`) per that file's
#     `escape_field`/`unescape_field`, with a position-weighted checksum
#     (`log_checksum`/`simple_text_score`). Loading fails CLOSED there: a
#     count/checksum mismatch yields an EMPTY log rather than a
#     silently-partial one. The outer line format is reimplemented here
#     verbatim (function-for-function) since this bridge cannot import
#     across repos.
#   - `payload` is documented as "opaque text ... owned by the emitting
#     dimension" (src/kernel/event_log.spl) — the ERP defines no concrete
#     Sale encoding inside payload, so this bridge defines the minimal
#     subset needed: for `kind == "sale.write"` rows, payload is a
#     positional CSV `channel,subtotal,tax,paid,status,audit_note` (the
#     event's `entity` field supplies `id`; `paid` is the literal `TRUE`/
#     `FALSE` token, matching this suite's own Sheet cell-display
#     convention (cell_display_text) rather than a Simple `true`/`false`
#     source literal, since the ERP does not constrain the choice).
#
#   CEILING (documented honestly): only `kind == "sale.write"` events
#   populate the Sheet; other kinds present in the ERP (crm.write,
#   reservation.write, market.write, restaurant.write, ...) are skipped —
#   out of scope for this bridge. Payload sub-field values must not contain
#   a literal comma (not escaped at this sub-layer; the outer ubslog `|`/
#   backslash/newline escaping IS fully implemented and fail-closed).

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, col_to_letter, parse_cell_ref}
use common.rich_text.attributed_text.RichDocument
use app.office.file_formats.parse_markdown_document
use app.office.word.mail_merge.merge_document

# =========================================================================
# Sale record schema (fixed column order, header row 1 of every Sheet built
# by erp_records_to_sheet / consumed by sheet_to_erp_records)
# =========================================================================

fn erp_sale_header() -> [text]:
    """The Sheet header row this bridge reads/writes, matching the ERP's
    `Sale` struct field order after `id` (src/lanes/sale.spl, src/catalog.spl)."""
    ["id", "channel", "subtotal", "tax", "paid", "status", "audit_note"]

struct ErpEvent:
    seq: i32
    kind: text
    entity: i32
    payload: text

# =========================================================================
# ubslog v1 line-format primitives
# (mirrors kernel/durable_log.spl's escape_field/unescape_field/
#  simple_text_score/log_checksum/serialize_log/parse_log/load_log exactly)
# =========================================================================

fn _erp_escape_field(s: text) -> text:
    """Escape backslash, '|', and newline so a payload can never break the
    pipe-delimited line format. Mirrors escape_field in kernel/durable_log.spl."""
    var r = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\\":
            r = r + "\\\\"
        elif ch == "|":
            r = r + "\\p"
        elif ch == "\n":
            r = r + "\\n"
        else:
            r = r + ch
        i = i + 1
    r

fn _erp_unescape_field(s: text) -> text:
    """Inverse of _erp_escape_field. Mirrors unescape_field in kernel/durable_log.spl."""
    var r = ""
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "\\":
            i = i + 1
            if i < s.len():
                val nx = s.char_at(i)
                if nx == "\\":
                    r = r + "\\"
                elif nx == "p":
                    r = r + "|"
                elif nx == "n":
                    r = r + "\n"
                else:
                    r = r + nx
        else:
            r = r + ch
        i = i + 1
    r

fn _erp_text_score(value: text) -> i32:
    """Position-weighted digest. Mirrors simple_text_score in kernel/durable_log.spl."""
    var total = 0
    var i = 0
    while i < value.len():
        total = total + value.char_code_at(i) * (i + 1)
        i = i + 1
    total

fn _erp_is_digit(c: text) -> bool:
    (c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or
     c == "5" or c == "6" or c == "7" or c == "8" or c == "9")

fn _erp_parse_int(s: text) -> i32:
    """Parse a (possibly negative) decimal integer; non-digit characters are
    skipped (matches parse_int_field in kernel/durable_log.spl)."""
    var i = 0
    var neg = false
    if s.len() > 0 and s.char_at(0) == "-":
        neg = true
        i = 1
    var n = 0
    while i < s.len():
        val code = s.char_code_at(i)
        if code >= 48 and code <= 57:
            n = n * 10 + (code - 48)
        i = i + 1
    if neg:
        return 0 - n
    n

fn _erp_field_value(t: text) -> text:
    """Value half of a 'key=value' header token."""
    val parts = t.split("=")
    if parts.len() >= 2:
        return parts[1]
    ""

fn _erp_log_checksum(events: [ErpEvent]) -> i32:
    """Mirrors log_checksum in kernel/durable_log.spl: a position-weighted,
    escape-safe digest over each event's (kind, payload, entity)."""
    var acc = 0
    var pos = 1
    for ev in events:
        val s = _erp_escape_field(ev.kind) + "|" + _erp_escape_field(ev.payload)
        acc = acc * 31 + pos * 17 + _erp_text_score(s) + ev.entity * 7
        pos = pos + 1
    acc

fn _erp_serialize_events(events: [ErpEvent]) -> text:
    """Mirrors serialize_log in kernel/durable_log.spl: header line
    'ubslog v1 count={n} checksum={c}' then one 'seq|kind|entity|payload'
    line per event."""
    val n = events.len()
    val c = _erp_log_checksum(events)
    var out = "ubslog v1 count={n} checksum={c}"
    for ev in events:
        val kind_esc = _erp_escape_field(ev.kind)
        val payload_esc = _erp_escape_field(ev.payload)
        out = out + "\n" + "{ev.seq}|{kind_esc}|{ev.entity}|{payload_esc}"
    out

fn erp_parse_events(records_text: text) -> [ErpEvent]:
    """Parse a ubslog v1 records file into events. Fail-closed exactly like
    kernel/durable_log.spl's load_log: a header not starting with "ubslog",
    a missing count=/checksum= token, or a count/checksum mismatch against
    the replayed events all yield an EMPTY list rather than a partial one."""
    var events: [ErpEvent] = []
    val lines = records_text.split("\n")
    if lines.len() == 0:
        return events
    var line_no = 0
    var header = ""
    for ln in lines:
        if line_no == 0:
            header = ln
        else:
            if ln.len() > 0:
                val fields = ln.split("|")
                if fields.len() >= 4:
                    val seq = _erp_parse_int(fields[0])
                    val kind = _erp_unescape_field(fields[1])
                    val entity = _erp_parse_int(fields[2])
                    val payload = _erp_unescape_field(fields[3])
                    events.push(ErpEvent(seq: seq, kind: kind, entity: entity, payload: payload))
        line_no = line_no + 1
    if not header.starts_with("ubslog"):
        var empty1: [ErpEvent] = []
        return empty1
    val tokens = header.split(" ")
    var declared_count = -1
    var declared_checksum = 0
    var have_count = false
    var have_checksum = false
    for t in tokens:
        if t.starts_with("count="):
            declared_count = _erp_parse_int(_erp_field_value(t))
            have_count = true
        if t.starts_with("checksum="):
            declared_checksum = _erp_parse_int(_erp_field_value(t))
            have_checksum = true
    if not have_count or not have_checksum:
        var empty2: [ErpEvent] = []
        return empty2
    if events.len() != declared_count:
        var empty3: [ErpEvent] = []
        return empty3
    if _erp_log_checksum(events) != declared_checksum:
        var empty4: [ErpEvent] = []
        return empty4
    events

# =========================================================================
# Records <-> Sheet
# =========================================================================

fn erp_records_to_sheet(records_text: text, name: text) -> Sheet:
    """Parse a ubslog v1 ERP records file into a header+rows Sheet: row 1 is
    erp_sale_header(), rows 2+ are one `sale.write` event per row (other
    event kinds are skipped — see module docstring ceiling). A fail-closed
    parse (bad header/count/checksum, per erp_parse_events) yields a
    header-only Sheet with zero data rows."""
    var sheet = Sheet.new(name)
    sheet.set_value("A1", "id")
    sheet.set_value("B1", "channel")
    sheet.set_value("C1", "subtotal")
    sheet.set_value("D1", "tax")
    sheet.set_value("E1", "paid")
    sheet.set_value("F1", "status")
    sheet.set_value("G1", "audit_note")
    val events = erp_parse_events(records_text)
    var row = 1
    for ev in events:
        if ev.kind == "sale.write":
            row = row + 1
            val parts = ev.payload.split(",")
            sheet.set_value("A{row}", "{ev.entity}")
            if parts.len() > 0:
                sheet.set_value("B{row}", parts[0])
            if parts.len() > 1:
                sheet.set_value("C{row}", parts[1])
            if parts.len() > 2:
                sheet.set_value("D{row}", parts[2])
            if parts.len() > 3:
                sheet.set_value("E{row}", parts[3])
            if parts.len() > 4:
                sheet.set_value("F{row}", parts[4])
            if parts.len() > 5:
                sheet.set_value("G{row}", parts[5])
    sheet

fn sheet_to_erp_records(sheet: Sheet) -> text:
    """Serialize a Sheet built by erp_records_to_sheet (or matching its
    header schema) back to the ERP's ubslog v1 format: one `sale.write`
    event per data row (row 1 = header, rows 2+ = data, skipping rows whose
    `id` column is blank). `id` -> event `entity`; the remaining six columns
    -> the positional-CSV payload. `seq` is assigned by data-row order
    (0-based) — the ERP's own kernel/event_log.append reassigns seq
    monotonically on ingest and treats the persisted seq as advisory
    (kernel/durable_log.spl comment), so this is re-import-safe."""
    var events: [ErpEvent] = []
    val range_str = sheet.used_range()
    val range_parts = range_str.split(":")
    if range_parts.len() < 2:
        return _erp_serialize_events(events)
    val end_ref = parse_cell_ref(range_parts[1])
    if end_ref == nil:
        return _erp_serialize_events(events)
    val last_row = end_ref.row + 1
    var row = 2
    var seq = 0
    while row <= last_row:
        val id_text = cell_display_text(sheet.get_cell("A{row}"))
        if id_text != "":
            val entity = _erp_parse_int(id_text)
            val channel = cell_display_text(sheet.get_cell("B{row}"))
            val subtotal = cell_display_text(sheet.get_cell("C{row}"))
            val tax = cell_display_text(sheet.get_cell("D{row}"))
            val paid = cell_display_text(sheet.get_cell("E{row}"))
            val status = cell_display_text(sheet.get_cell("F{row}"))
            val audit_note = cell_display_text(sheet.get_cell("G{row}"))
            val payload = channel + "," + subtotal + "," + tax + "," + paid + "," + status + "," + audit_note
            events.push(ErpEvent(seq: seq, kind: "sale.write", entity: entity, payload: payload))
            seq = seq + 1
        row = row + 1
    _erp_serialize_events(events)

# =========================================================================
# Invoice document (mail-merge)
# =========================================================================

fn _erp_ph(field: text) -> text:
    """Build a '{{field}}' mail-merge placeholder by concatenation — a
    literal '{{' in a Simple string literal is interpolation, not a
    placeholder (quirk ledger)."""
    "{" + "{" + field + "}" + "}"

fn default_invoice_template() -> text:
    """Default invoice markdown template. Placeholders match erp_sale_header:
    id, channel, subtotal, tax, paid, status, audit_note."""
    var out = "# Invoice " + _erp_ph("id")
    out = out + "\n\nChannel: " + _erp_ph("channel")
    out = out + "\n\nSubtotal: " + _erp_ph("subtotal")
    out = out + "\n\nTax: " + _erp_ph("tax")
    out = out + "\n\nPaid: " + _erp_ph("paid")
    out = out + "\n\nStatus: " + _erp_ph("status")
    out = out + "\n\nNote: " + _erp_ph("audit_note")
    out

fn erp_invoice_to_document(id: text, channel: text, subtotal: text, tax: text, paid: text, status: text, audit_note: text, template: text) -> RichDocument:
    """Render an ERP Sale record into a RichDocument by mail-merging
    `template` (a markdown string with {{field}} placeholders matching
    erp_sale_header) against a one-row Sheet built from the given fields.
    Reuses word.mail_merge.merge_document so the result exports to
    .docx/.odt/pdf-via-LibreOffice through the existing converters."""
    val doc = parse_markdown_document(template, "invoice")
    var sheet = Sheet.new("invoice_row")
    sheet.set_value("A1", "id")
    sheet.set_value("B1", "channel")
    sheet.set_value("C1", "subtotal")
    sheet.set_value("D1", "tax")
    sheet.set_value("E1", "paid")
    sheet.set_value("F1", "status")
    sheet.set_value("G1", "audit_note")
    sheet.set_value("A2", id)
    sheet.set_value("B2", channel)
    sheet.set_value("C2", subtotal)
    sheet.set_value("D2", tax)
    sheet.set_value("E2", paid)
    sheet.set_value("F2", status)
    sheet.set_value("G2", audit_note)
    merge_document(doc, sheet, 1)

fn erp_invoice_from_sheet(sheet: Sheet, row: i32, template: text) -> RichDocument:
    """Convenience for CLI/macro callers already holding a Sheet from
    erp_records_to_sheet: mail-merge `template` directly against `sheet` at
    the given 1-based data row (row 1 = sheet row 2), skipping the
    duplicate one-row-Sheet construction in erp_invoice_to_document."""
    val doc = parse_markdown_document(template, "invoice")
    merge_document(doc, sheet, row)
