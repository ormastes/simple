# Number Format Codes
#
# format_number() implements a practical subset of Excel's Format Cells >
# Number format-code language: fixed decimals, thousands grouping, percent,
# a generic currency/literal-prefix form, scientific notation, date
# serials, ";"-separated multi-section codes, thousands-scaling commas, a
# simple quoted-literal suffix, and "?" as a "#"-alike digit placeholder.
# It is the richer sibling of `cell_format._cf_excel_format` (which stays
# as-is to protect its existing green regression spec); this module is the
# new home for number-format work and the one to extend going forward.
#
# Subset shipped (docstring ceiling -- everything else falls back to
# general display rather than erroring):
#   "0" / "0.00" / "0.000"     fixed decimals, round-half-away-from-zero
#   "#,##0" / "#,##0.00"       thousands-grouped, fixed decimals
#   "0%" / "0.0%" / "0.00%"    value * 100 with a trailing "%"
#   "$#,##0.00"                any LITERAL run before the first "0"/"#" is
#                               kept as a prefix (currency symbol, "USD ", ...)
#   "#,##0.00)"-style suffix   any LITERAL run after the last "0"/"#"/"?" is
#                               kept as a suffix -- this is how a
#                               parenthesized negative section
#                               ("(#,##0.00)") and a quoted-literal unit
#                               suffix ("0.00 \"kg\"") both render.
#   "0.0,,"                    each TRAILING comma right after the last
#                               digit placeholder (nothing but commas
#                               between the digits and the end of the
#                               section) divides the value by 1000 --
#                               Excel's thousands/millions scaling. A comma
#                               INSIDE the digit run ("#,##0") is still
#                               plain thousands grouping, not scaling.
#   "0.00E+00"                 scientific notation, N-digit mantissa,
#                               2-digit signed exponent
#   "yyyy-mm-dd" / "mm/dd/yyyy" / "dd.mm.yyyy" / "dd/mm/yyyy" / "d/m/yyyy" /
#   "dd-mmm-yyyy" / "mmmm dd, yyyy"
#                               value read as an Excel date serial; date
#                               tokens (yyyy/yy, mmmm/mmm/mm/m, dd/d) are
#                               read in the order they appear in the code,
#                               so dd/mm and mm/dd are properly distinct
#                               (any other character is a literal
#                               separator, passed through as-is)
#   "@"                        text passthrough (meaningful at the
#                               cell_display_formatted layer; on a bare f64
#                               it degrades to general)
#   ""                         general -- trim to integer form when the
#                               value has no fraction
#   "[Red]", "[Blue]", ...     any "[...]" bracketed tag is stripped and
#                               ignored -- colors are never rendered in
#                               text output, and no other bracket-tag
#                               (locale, condition) is interpreted either
#   "\"literal\""              a quoted literal is unwrapped (the quote
#                               characters are dropped, the content kept in
#                               place) before the rest of the section is
#                               parsed -- this is how a quoted currency
#                               prefix, a quoted unit suffix, and a
#                               quoted-only section (e.g. a zero section of
#                               just "\"-\"") all work
#   "?"                        treated like "#" for locating the digit run
#                               and its right edge (so it participates in
#                               prefix/suffix detection without breaking
#                               parsing) -- ceiling: it does NOT get real
#                               Excel space-padding, and alone (with no "0"
#                               or "#" present) it does not anchor a
#                               section as numeric at all (kept so the
#                               landed "falls back to general for an
#                               unrecognized code" case ("???") stays
#                               unchanged)
#
# ";"-separated multi-section codes (Excel semantics):
#   1 section  -- applies to every value; a negative value gets a plain
#                 "-" prefix ahead of the formatted magnitude (unchanged
#                 single-section behavior).
#   2 sections -- section 1 for positive AND zero values; section 2 for
#                 negative values, applied to the ABSOLUTE value with NO
#                 automatic "-" -- a sign only appears if the section
#                 itself has one (a literal "-" prefix, or a parenthesized
#                 pattern like "(#,##0.00)").
#   3 sections -- section 1 positive, section 2 negative (as above,
#                 absolute value), section 3 zero.
#   4 sections -- as above plus a 4th TEXT section, applied only to text
#                 cell values via `format_text_with_code` (see below); a
#                 bare `format_number` call (always numeric) never reaches
#                 it. Splitting on ";" is quote-aware -- a ";" inside a
#                 quoted literal is never treated as a section boundary.
#
# Date serials reuse `civil_from_serial` from `std.math.financial` (the
# financial library's own Hinnant's-algorithm civil<->serial conversion) --
# no third copy of that arithmetic in this codebase.

use common.office.number.{office_pow10_f64, office_parse_signed_decimal_f64}
use std.math.financial.{civil_from_serial}
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{CellValue, cell_display_text}
use app.office.sheets.cell_format.{SheetFormats, formats_get}

# =========================================================================
# Public API
# =========================================================================

fn format_number(value: f64, code: text) -> text:
    """Format `value` per an Excel-style number-format `code` (see module
    docstring for the supported subset). `code` may have 1-4
    ";"-separated sections (positive[;negative[;zero[;text]]]); the text
    (4th) section never applies here since `value` is always numeric --
    use `format_text_with_code` for text cells. This function never
    errors -- unknown/unsupported section codes fall back to general
    display."""
    val sections = _nf_split_sections(code)
    val n = sections.len()
    if n == 1:
        return _nf_render_section(value, sections[0], true)
    if n == 2:
        if value < 0.0:
            return _nf_render_section(0.0 - value, sections[1], false)
        return _nf_render_section(value, sections[0], false)
    if value == 0.0:
        return _nf_render_section(value, sections[2], false)
    if value < 0.0:
        return _nf_render_section(0.0 - value, sections[1], false)
    _nf_render_section(value, sections[0], false)

fn format_text_with_code(text_value: text, code: text) -> text:
    """Applies the 4th ";"-separated (text) section of `code` to a text
    cell value: every "@" placeholder in that section is replaced with
    `text_value`. A `code` with fewer than 4 sections has no text section
    -- `text_value` passes through unchanged (matching Excel, which then
    falls back to plain text display)."""
    val sections = _nf_split_sections(code)
    if sections.len() < 4:
        return text_value
    val no_color = _nf_strip_color_tags(sections[3])
    val stripped = _nf_strip_quotes(no_color)
    _nf_apply_text_section(text_value, stripped)

fn cell_display_formatted(sheet: Sheet, formats: SheetFormats, ref: text) -> text:
    """Number-format-aware display text for one cell: applies `format_number`
    when the cell resolves to a number (a plain numeric cell, or a formula
    cell whose cached display is a plain numeric result) AND a format code
    is set; applies `format_text_with_code` when the cell is text AND the
    code has a 4th (text) section; otherwise falls back to
    `cell_display_text` (unchanged, general display). Opt-in at the call
    site -- `cell_display_text` itself is untouched."""
    val cell = sheet.get_cell(ref)
    val spec = formats_get(formats, ref)
    if spec.num_fmt != "":
        match cell.value:
            CellValue.NumberVal(value):
                return format_number(value, spec.num_fmt)
            CellValue.FormulaVal(expr, cached_display):
                if _nf_looks_numeric(cached_display):
                    return format_number(office_parse_signed_decimal_f64(cached_display), spec.num_fmt)
                return cell_display_text(cell)
            CellValue.TextVal(value):
                val sections = _nf_split_sections(spec.num_fmt)
                if sections.len() >= 4:
                    return format_text_with_code(value, spec.num_fmt)
                return cell_display_text(cell)
            _:
                pass
    cell_display_text(cell)

fn _nf_looks_numeric(s: text) -> bool:
    """True if `s` is a plain signed decimal ("5", "-1.25") -- used to
    detect a formula cell's cached_display holding a numeric result before
    re-formatting it. Text results ("hello") and error markers ("#ERR: ...")
    are rejected."""
    if s.len() == 0:
        return false
    var i = 0
    if s.substring(0, 1) == "-":
        i = 1
    if i >= s.len():
        return false
    var saw_digit = false
    var saw_dot = false
    while i < s.len():
        val c = s.substring(i, i + 1)
        if c == ".":
            if saw_dot:
                return false
            saw_dot = true
        else:
            val code = c.char_code_at(0)
            if code >= 48 and code <= 57:
                saw_digit = true
            else:
                return false
        i = i + 1
    saw_digit

# =========================================================================
# Helpers (private to this module; `_nf_` prefix avoids the interpreter's
# documented same-name flat-symbol-table collision across modules -- see
# cell_format.spl's `_cf_` helpers for the precedent).
# =========================================================================

fn _nf_split_sections(code: text) -> [text]:
    """Split `code` on ";" outside quoted "..." literals -- a ";" inside a
    quoted section (e.g. a literal containing a semicolon) is NOT a
    section boundary. Always returns at least one element (an empty
    `code` yields one empty section, matching the pre-multi-section
    general/empty-code fallback)."""
    var sections: [text] = []
    var current = ""
    var in_quote = false
    var i = 0
    val n = code.len()
    while i < n:
        val c = code.substring(i, i + 1)
        if c == "\"":
            in_quote = not in_quote
            current = "{current}{c}"
        elif c == ";" and (not in_quote):
            sections.push(current)
            current = ""
        else:
            current = "{current}{c}"
        i = i + 1
    sections.push(current)
    sections

fn _nf_strip_color_tags(s: text) -> text:
    """Remove any "[...]" bracketed tag (a color like "[Red]", or any other
    locale/condition tag) entirely -- tags are stripped and ignored, never
    interpreted (no color rendering, no "[>100]"-style conditional
    sections)."""
    var out = ""
    var i = 0
    val n = s.len()
    while i < n:
        val c = s.substring(i, i + 1)
        if c == "[":
            var j = i + 1
            while j < n and s.substring(j, j + 1) != "]":
                j = j + 1
            if j < n:
                i = j + 1
            else:
                out = "{out}{c}"
                i = i + 1
        else:
            out = "{out}{c}"
            i = i + 1
    out

fn _nf_strip_quotes(s: text) -> text:
    """Remove '"' characters, keeping their contents in place -- turns a
    quoted literal like "0.00 \"kg\"" into "0.00 kg" so the generic
    prefix/suffix scan below picks the literal up as a plain suffix (or
    prefix). Ceiling: backslash escapes inside a quoted literal are out of
    scope."""
    var out = ""
    var i = 0
    val n = s.len()
    while i < n:
        val c = s.substring(i, i + 1)
        if c != "\"":
            out = "{out}{c}"
        i = i + 1
    out

fn _nf_apply_text_section(text_value: text, section: text) -> text:
    """Replace each "@" placeholder in `section` with `text_value`; a
    section with no "@" is a literal-only text template."""
    var out = ""
    var i = 0
    val n = section.len()
    while i < n:
        val c = section.substring(i, i + 1)
        if c == "@":
            out = "{out}{text_value}"
        else:
            out = "{out}{c}"
        i = i + 1
    out

fn _nf_first_digit_idx(s: text) -> i32:
    """Index of the first "0" or "#" in `s` (whichever comes first), or -1
    if neither is present. Deliberately excludes "?" -- a section made of
    ONLY "?" placeholders (e.g. the historical "???" unrecognized-code
    probe) must still fall back to general display, not be treated as a
    real numeric pattern."""
    val zero_idx = s.index_of("0")
    val hash_idx = s.index_of("#")
    if zero_idx < 0:
        return hash_idx
    if hash_idx < 0:
        return zero_idx
    if zero_idx < hash_idx:
        return zero_idx
    hash_idx

fn _nf_last_digit_idx(core: text) -> i32:
    """Index of the LAST "0", "#", or "?" in `core` (used to find where
    the digit run ends and any literal/scaling suffix begins). Unlike
    `_nf_first_digit_idx`, "?" counts here -- by the time this runs, a
    real "0"/"#" anchor has already been found, so "?" safely extends the
    digit run for suffix-boundary purposes."""
    var last = -1
    var i = 0
    val n = core.len()
    while i < n:
        val c = core.substring(i, i + 1)
        if c == "0" or c == "#" or c == "?":
            last = i
        i = i + 1
    last

fn _nf_all_commas(s: text) -> bool:
    """True if every character of a non-empty `s` is ",". Used to tell a
    thousands-SCALING suffix (only commas, e.g. the ",," in "0.0,,") apart
    from a literal suffix like ")" or " kg"."""
    var i = 0
    val n = s.len()
    while i < n:
        if s.substring(i, i + 1) != ",":
            return false
        i = i + 1
    true

fn _nf_render_section(value: f64, section_in: text, allow_auto_sign: bool) -> text:
    """Render one ";"-separated section against `value`. `allow_auto_sign`
    is true only for a single-section code (`value` may be negative and
    gets an automatic "-" prefix); for a multi-section code the caller
    always passes the correct sign-appropriate value (already made
    absolute for a negative section) and `allow_auto_sign=false`, since
    Excel only shows a sign there if the section spells one out itself
    (a literal "-", or parentheses)."""
    val no_color = _nf_strip_color_tags(section_in)
    val section = _nf_strip_quotes(no_color)
    val had_quotes = no_color != section
    val lower = section.lower()
    if section == "" or lower == "general":
        return _nf_general(value)
    if section == "@":
        return _nf_general(value)
    if lower.contains("y") and (lower.contains("m") or lower.contains("d")):
        return _nf_format_date(value, lower)
    var neg = false
    var av = value
    if value < 0.0:
        av = 0.0 - value
        if allow_auto_sign:
            neg = true
    if lower.contains("e+") or lower.contains("e-"):
        val body = _nf_format_scientific(av, _nf_count_decimals(section))
        if neg:
            return "-{body}"
        return body
    if section.ends_with("%"):
        val decs = _nf_count_decimals(section)
        val body = "{_nf_fixed_grouped(av * 100.0, decs, false)}%"
        if neg:
            return "-{body}"
        return body
    val digit_idx = _nf_first_digit_idx(section)
    if digit_idx < 0:
        if had_quotes:
            return section
        return _nf_general(value)
    val prefix = section.substring(0, digit_idx)
    val core = section.substring(digit_idx, section.len())
    val last_idx = _nf_last_digit_idx(core)
    val raw_suffix = core.substring(last_idx + 1, core.len())
    var scale_count = 0
    var literal_suffix = raw_suffix
    if raw_suffix.len() > 0 and _nf_all_commas(raw_suffix):
        scale_count = raw_suffix.len()
        literal_suffix = ""
    val digit_portion = core.substring(0, last_idx + 1)
    val grouped = digit_portion.contains(",")
    val decs = _nf_count_decimals(digit_portion)
    var scaled_av = av
    var k = 0
    while k < scale_count:
        scaled_av = scaled_av / 1000.0
        k = k + 1
    val body = "{prefix}{_nf_fixed_grouped(scaled_av, decs, grouped)}{literal_suffix}"
    if neg:
        return "-{body}"
    body

fn _nf_general(value: f64) -> text:
    """General/unformatted display: integer form when there's no fraction,
    otherwise the plain f64 text form."""
    val i = value.to_i64()
    if value - i.to_f64() == 0.0:
        return "{i}"
    "{value}"

fn _nf_count_decimals(fmt: text) -> i32:
    """Zeros directly after the first '.' in a format code ("0.00" -> 2)."""
    val dot = fmt.index_of(".")
    if dot < 0:
        return 0
    var n = 0
    var i = dot + 1
    while i < fmt.len() and fmt.substring(i, i + 1) == "0":
        n = n + 1
        i = i + 1
    n

fn _nf_floor(x: f64) -> f64:
    """Largest integer <= x. Call sites in this module only ever pass
    non-negative x (sign is handled by the caller)."""
    val t = x.to_i64().to_f64()
    if t > x:
        return t - 1.0
    t

fn _nf_group_thousands(int_txt: text) -> text:
    """Insert commas every 3 digits from the right: "1234568" -> "1,234,568"."""
    var out = ""
    var count = 0
    var i = int_txt.len() - 1
    while i >= 0:
        out = "{int_txt.substring(i, i + 1)}{out}"
        count = count + 1
        if count % 3 == 0 and i > 0:
            out = ",{out}"
        i = i - 1
    out

fn _nf_fixed_grouped(v: f64, decimals: i32, grouped: bool) -> text:
    """Round a NON-NEGATIVE value to `decimals` places (round-half-away-
    from-zero), optionally inserting thousands commas in the integer part.
    Callers own the sign -- see `format_number`."""
    val scale = office_pow10_f64(decimals)
    val scaled = _nf_floor(v * scale + 0.5)
    val int_part = (scaled / scale).to_i64()
    val frac_scaled = scaled.to_i64() - int_part * scale.to_i64()
    var int_txt = "{int_part}"
    if grouped:
        int_txt = _nf_group_thousands(int_txt)
    if decimals > 0:
        var frac_txt = "{frac_scaled}"
        while frac_txt.len() < decimals:
            frac_txt = "0{frac_txt}"
        return "{int_txt}.{frac_txt}"
    int_txt

fn _nf_pad2(n: i64) -> text:
    """Zero-pad a non-negative integer to at least 2 digits."""
    if n < 10:
        return "0{n}"
    "{n}"

fn _nf_format_scientific(v: f64, decimals: i32) -> text:
    """Mantissa in [1,10) with `decimals` places + a 2-digit signed
    exponent ("1.23E+04"). `v` is assumed non-negative; the caller owns the
    sign (see `format_number`)."""
    if v == 0.0:
        return "{_nf_fixed_grouped(0.0, decimals, false)}E+00"
    var mantissa = v
    var exp = 0
    while mantissa >= 10.0:
        mantissa = mantissa / 10.0
        exp = exp + 1
    while mantissa < 1.0:
        mantissa = mantissa * 10.0
        exp = exp - 1
    var mant_txt = _nf_fixed_grouped(mantissa, decimals, false)
    if mant_txt.starts_with("10"):
        # Rounding pushed the mantissa up to 10.0[...] -- renormalize once.
        mantissa = mantissa / 10.0
        exp = exp + 1
        mant_txt = _nf_fixed_grouped(mantissa, decimals, false)
    val exp_abs = if exp < 0: 0 - exp else: exp
    val exp_sign = if exp < 0: "-" else: "+"
    "{mant_txt}E{exp_sign}{_nf_pad2(exp_abs)}"

fn _nf_match_at(s: text, i: i32, tok: text) -> bool:
    """True if `tok` occurs starting at index `i` in `s` (bounds-checked)."""
    val tlen = tok.len()
    if i + tlen > s.len():
        return false
    s.substring(i, i + tlen) == tok

fn _nf_month_abbr(m: i64) -> text:
    """3-letter English month abbreviation ("mmm" date token). Ceiling:
    English only -- no locale support."""
    if m == 1:
        return "Jan"
    if m == 2:
        return "Feb"
    if m == 3:
        return "Mar"
    if m == 4:
        return "Apr"
    if m == 5:
        return "May"
    if m == 6:
        return "Jun"
    if m == 7:
        return "Jul"
    if m == 8:
        return "Aug"
    if m == 9:
        return "Sep"
    if m == 10:
        return "Oct"
    if m == 11:
        return "Nov"
    "Dec"

fn _nf_month_full(m: i64) -> text:
    """Full English month name ("mmmm" date token). Ceiling: English only
    -- no locale support."""
    if m == 1:
        return "January"
    if m == 2:
        return "February"
    if m == 3:
        return "March"
    if m == 4:
        return "April"
    if m == 5:
        return "May"
    if m == 6:
        return "June"
    if m == 7:
        return "July"
    if m == 8:
        return "August"
    if m == 9:
        return "September"
    if m == 10:
        return "October"
    if m == 11:
        return "November"
    "December"

fn _nf_format_date(value: f64, fmt: text) -> text:
    """Excel-style date-code tokenizer: reads `fmt` left to right,
    recognizing "yyyy"/"yy", "mmmm"/"mmm"/"mm"/"m", "dd"/"d" (longest
    token first) in the ORDER they appear, emitting the corresponding
    piece of the date from `value` (an Excel date serial, converted via
    the financial library's own conversion -- no duplicated date
    arithmetic). Any other character (a separator like "/", "-", ".", or
    a space) passes through literally. Reading tokens in appearance order
    is what makes "dd/mm/yyyy" and "mm/dd/yyyy" render distinctly, unlike
    a fixed template. Ceiling: no locale month names (English only, see
    `_nf_month_abbr`/`_nf_month_full`), no time-of-day tokens."""
    val ymd = civil_from_serial(value)
    val y = ymd[0]
    val m = ymd[1]
    val d = ymd[2]
    var out = ""
    var i = 0
    val n = fmt.len()
    while i < n:
        if _nf_match_at(fmt, i, "yyyy"):
            out = "{out}{y}"
            i = i + 4
        elif _nf_match_at(fmt, i, "yy"):
            out = "{out}{_nf_pad2(y % 100)}"
            i = i + 2
        elif _nf_match_at(fmt, i, "mmmm"):
            out = "{out}{_nf_month_full(m)}"
            i = i + 4
        elif _nf_match_at(fmt, i, "mmm"):
            out = "{out}{_nf_month_abbr(m)}"
            i = i + 3
        elif _nf_match_at(fmt, i, "mm"):
            out = "{out}{_nf_pad2(m)}"
            i = i + 2
        elif _nf_match_at(fmt, i, "dd"):
            out = "{out}{_nf_pad2(d)}"
            i = i + 2
        elif fmt.substring(i, i + 1) == "m":
            out = "{out}{m}"
            i = i + 1
        elif fmt.substring(i, i + 1) == "d":
            out = "{out}{d}"
            i = i + 1
        else:
            out = "{out}{fmt.substring(i, i + 1)}"
            i = i + 1
    out
