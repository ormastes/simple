# Slide Model
#
# Types for presentation slides, elements, and layouts.

# =========================================================================
# Layout and Element Enums
# =========================================================================

enum SlideLayout:
    TitleSlide
    TitleContent
    TwoColumn
    Blank
    SectionHeader

enum SlideElementKind:
    TextBox(content: text)
    ImageEl(src: text, alt: text)
    ShapeEl(shape_type: text, fill_color: text)
    TableEl(rows: text)

# =========================================================================
# Core Structs
# =========================================================================

struct SlideElement:
    id: text
    kind: SlideElementKind
    x: i32
    y: i32
    width: i32
    height: i32

struct Slide:
    id: text
    layout: SlideLayout
    elements: [SlideElement]
    notes: text
    background: text
    transition: text

struct Presentation:
    title: text
    slides: [Slide]
    active_slide: i32
    theme_name: text

struct SlideEditResult:
    accepted: bool
    reason: text
    slide: Slide
    element_id: text
    expected_value: text
    actual_value: text
    new_value: text
    diff: text

# =========================================================================
# Presentation Helpers
# =========================================================================

fn empty_presentation(title: text) -> Presentation:
    """Create a new presentation with one title slide."""
    val first = title_slide("slide_0", title, "")
    return Presentation(
        title: title,
        slides: [first],
        active_slide: 0,
        theme_name: "default"
    )

fn slide_count(pres: Presentation) -> i32:
    """Return the number of slides in a presentation."""
    var count: i32 = 0
    for s in pres.slides:
        count = count + 1
    return count

fn current_slide(pres: Presentation) -> Slide?:
    """Return the currently active slide, or nil if out of range."""
    if pres.active_slide < 0:
        return nil
    var idx: i32 = 0
    for s in pres.slides:
        if idx == pres.active_slide:
            return s
        idx = idx + 1
    return nil

fn slide_layout_display_name(layout: SlideLayout) -> text:
    """Human-readable layout name."""
    match layout:
        SlideLayout.TitleSlide:
            return "Title Slide"
        SlideLayout.TitleContent:
            return "Title + Content"
        SlideLayout.TwoColumn:
            return "Two Column"
        SlideLayout.Blank:
            return "Blank"
        SlideLayout.SectionHeader:
            return "Section Header"

fn slide_layout_short_name(layout: SlideLayout) -> text:
    """Short display name for thumbnails."""
    match layout:
        SlideLayout.TitleSlide:
            return "Title"
        SlideLayout.TitleContent:
            return "Content"
        SlideLayout.TwoColumn:
            return "Two Column"
        SlideLayout.Blank:
            return "Blank"
        SlideLayout.SectionHeader:
            return "Section"

fn slide_with_elements(id: text, layout: SlideLayout, elements: [SlideElement]) -> Slide:
    """Create a slide with default notes, background, and transition."""
    return Slide(
        id: id,
        layout: layout,
        elements: elements,
        notes: "",
        background: "#FFFFFF",
        transition: ""
    )

# =========================================================================
# Slide Constructors
# =========================================================================

fn title_slide(id: text, title: text, subtitle: text) -> Slide:
    """Create a title slide with a centered title and optional subtitle."""
    var elements: [SlideElement] = []
    val title_el = SlideElement(
        id: "{id}_title",
        kind: SlideElementKind.TextBox(content: title),
        x: 100, y: 150,
        width: 760, height: 80
    )
    elements.push(title_el)
    if subtitle != "":
        val sub_el = SlideElement(
            id: "{id}_subtitle",
            kind: SlideElementKind.TextBox(content: subtitle),
            x: 150, y: 250,
            width: 660, height: 50
        )
        elements.push(sub_el)
    slide_with_elements(id, SlideLayout.TitleSlide, elements)

fn blank_slide(id: text) -> Slide:
    """Create an empty blank slide."""
    slide_with_elements(id, SlideLayout.Blank, [])

fn content_slide(id: text, title: text, body: text) -> Slide:
    """Create a title-and-content slide with title at top and body below."""
    var elements: [SlideElement] = []
    val title_el = SlideElement(
        id: "{id}_title",
        kind: SlideElementKind.TextBox(content: title),
        x: 50, y: 30,
        width: 860, height: 60
    )
    elements.push(title_el)
    val body_el = SlideElement(
        id: "{id}_body",
        kind: SlideElementKind.TextBox(content: body),
        x: 50, y: 110,
        width: 860, height: 400
    )
    elements.push(body_el)
    slide_with_elements(id, SlideLayout.TitleContent, elements)

# =========================================================================
# Element Manipulation
# =========================================================================

fn add_text_box(slide: Slide, id: text, content: text, x: i32, y: i32, w: i32, h: i32) -> Slide:
    """Add a text box element to a slide and return the updated slide."""
    val el = SlideElement(
        id: id,
        kind: SlideElementKind.TextBox(content: content),
        x: x, y: y,
        width: w, height: h
    )
    add_slide_element(slide, el)

fn add_slide_element(slide: Slide, el: SlideElement) -> Slide:
    """Append an element to a slide and return the updated slide."""
    var new_elements: [SlideElement] = []
    for e in slide.elements:
        new_elements.push(e)
    new_elements.push(el)
    return Slide(
        id: slide.id,
        layout: slide.layout,
        elements: new_elements,
        notes: slide.notes,
        background: slide.background,
        transition: slide.transition
    )

fn set_slide_notes(slide: Slide, notes: text) -> Slide:
    """Return a copy of the slide with speaker notes set."""
    return Slide(
        id: slide.id,
        layout: slide.layout,
        elements: slide.elements,
        notes: notes,
        background: slide.background,
        transition: slide.transition
    )

fn set_slide_transition(slide: Slide, transition: text) -> Slide:
    """Return a copy of the slide with a transition set. Allowed values:
    "fade", "wipe", "push", or "" for none."""
    return Slide(
        id: slide.id,
        layout: slide.layout,
        elements: slide.elements,
        notes: slide.notes,
        background: slide.background,
        transition: transition
    )

fn slide_edit_diff(element_id: text, old_value: text, new_value: text) -> text:
    "@@ slide element {element_id} @@\n- {old_value}\n+ {new_value}"

fn slide_reject_diff(element_id: text, expected: text, actual: text, replacement: text) -> text:
    "@@ slide element {element_id} @@\nexpected: {expected}\nactual: {actual}\nrejected: {replacement}"

fn slide_update_text_checked(slide: Slide, element_id: text, expected: text, replacement: text) -> SlideEditResult:
    """Update a text element only when the current content matches expected."""
    var found = false
    var actual = "<missing-element>"
    var new_elements: [SlideElement] = []
    for e in slide.elements:
        if e.id == element_id:
            found = true
            match e.kind:
                SlideElementKind.TextBox(content: content):
                    actual = content
                    if content == expected:
                        new_elements.push(SlideElement(
                            id: e.id,
                            kind: SlideElementKind.TextBox(content: replacement),
                            x: e.x,
                            y: e.y,
                            width: e.width,
                            height: e.height
                        ))
                    else:
                        new_elements.push(e)
                _:
                    actual = "<non-text-element>"
                    new_elements.push(e)
        else:
            new_elements.push(e)
    if not found:
        return SlideEditResult(
            accepted: false,
            reason: "missing-element",
            slide: slide,
            element_id: element_id,
            expected_value: expected,
            actual_value: actual,
            new_value: replacement,
            diff: slide_reject_diff(element_id, expected, actual, replacement)
        )
    if actual == "<non-text-element>":
        return SlideEditResult(
            accepted: false,
            reason: "non-text-element",
            slide: slide,
            element_id: element_id,
            expected_value: expected,
            actual_value: actual,
            new_value: replacement,
            diff: slide_reject_diff(element_id, expected, actual, replacement)
        )
    if actual != expected:
        return SlideEditResult(
            accepted: false,
            reason: "stale-slide-element",
            slide: slide,
            element_id: element_id,
            expected_value: expected,
            actual_value: actual,
            new_value: replacement,
            diff: slide_reject_diff(element_id, expected, actual, replacement)
        )
    val updated = Slide(
        id: slide.id,
        layout: slide.layout,
        elements: new_elements,
        notes: slide.notes,
        background: slide.background,
        transition: slide.transition
    )
    SlideEditResult(
        accepted: true,
        reason: "updated",
        slide: updated,
        element_id: element_id,
        expected_value: expected,
        actual_value: actual,
        new_value: replacement,
        diff: slide_edit_diff(element_id, actual, replacement)
    )
