# Presenter Mode
#
# Full-screen presentation view with speaker notes.

use common.ui.widget.{WidgetNode, UITree}
use common.ui.builder.{column, row, panel, text_widget, label, scroll, textarea, statusbar, build_tree_with_title, with_flex}
use app.office.slides.slide.{Presentation, Slide, current_slide, slide_count}
use app.office.slides.render.{render_slide_canvas, render_slide_thumbnail}

# =========================================================================
# Presenter UI
# =========================================================================

fn build_presenter_ui(pres: Presentation) -> UITree:
    """Build a presenter-mode UI with fullscreen current slide and notes below."""
    val cur = current_slide(pres)
    val total = slide_count(pres)
    val slide_num = pres.active_slide + 1

    # Current slide canvas
    var canvas_children: [WidgetNode] = []
    if cur != nil:
        val elements = render_slide_canvas(cur)
        for el in elements:
            canvas_children = canvas_children.push(el)
    else:
        canvas_children = canvas_children.push(label("presenter_empty", "No slide"))

    var canvas_panel = panel("presenter_canvas", "Slide {slide_num}", canvas_children)
    canvas_panel = with_flex(canvas_panel, 3)

    # Speaker notes
    val notes_text = if cur != nil: cur.notes else: ""
    var notes_panel = panel("presenter_notes", "Speaker Notes", [
        text_widget("presenter_notes_text", notes_text)
    ])
    notes_panel = with_flex(notes_panel, 1)

    # Navigation hint
    val nav_status = statusbar("presenter_status",
        "Slide {slide_num} of {total}",
        "Arrow keys to navigate | Esc to exit"
    )

    val root = column("presenter_root", [
        canvas_panel,
        notes_panel,
        nav_status
    ])

    return build_tree_with_title(root, "{pres.title} - Presenter", "ios_dark")
