# Simple CLI - query command
# Search source files for code patterns

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, file_read, cwd, dir_walk)
use std.log.{error}

fn print_help():
    print "Usage: simple query <pattern> [path] [options]"
    print ""
    print "Search Simple source files for patterns."
    print ""
    print "Arguments:"
    print "  <pattern>          Text pattern to search for"
    print "  [path]             Directory to search (default: src/)"
    print ""
    print "Options:"
    print "  --generated        Find LLM-generated code markers"
    print "  --todo             Find task-marker comments"
    print "  --fn               Find function definitions"
    print "  --class            Find class/struct definitions"
    print "  --extern           Find extern declarations"
    print "  --count            Show count only"
    for line in log_options_help():
        print "  {line}"
    print "  -i                 Case-insensitive search"
    print "  -h, --help         Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--no-progress" or
        arg == "--log-mode" or arg == "--surface" or arg == "--progress" or
        arg.starts_with("--log-mode=") or arg.starts_with("--surface=") or
        arg.starts_with("--progress=")

fn clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if _is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn search_file(path: text, pattern: text, case_insensitive: bool) -> [(i64, text)]:
    val content = file_read(path)
    val lines = content.split("\n")
    var matches = []
    var line_num = 1

    val search_pattern = if case_insensitive: pattern.lower() else: pattern

    for line in lines:
        val search_line = if case_insensitive: line.lower() else: line
        if search_line.contains(search_pattern):
            matches.push((line_num, line))
        line_num = line_num + 1

    matches

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("query", log_opts.error)
        return 1

    val args = clean_args(raw_args)

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"query\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_help()
        return 0

    var pattern = ""
    var search_path = ""
    var find_generated = false
    var find_todos = false
    var find_fns = false
    var find_classes = false
    var find_externs = false
    var count_only = false
    var case_insensitive = false

    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--generated":
            find_generated = true
        elif arg == "--todo":
            find_todos = true
        elif arg == "--fn":
            find_fns = true
        elif arg == "--class":
            find_classes = true
        elif arg == "--extern":
            find_externs = true
        elif arg == "--count":
            count_only = true
        elif arg == "-i":
            case_insensitive = true
        elif not arg.starts_with("-"):
            if pattern == "":
                pattern = arg
            else:
                search_path = arg

    # Set pattern based on flags
    if find_generated:
        pattern = "Generated by"
    elif find_todos:
        pattern = "TO" + "DO"
    elif find_fns:
        pattern = "fn "
    elif find_classes:
        pattern = "class "
    elif find_externs:
        pattern = "extern fn"

    if pattern == "":
        if log_opts.log_mode == "json":
            print "{\"command\":\"query\",\"status\":\"error\",\"error\":\"missing search pattern\"}"
            return 1
        error("query", "missing search pattern")
        return 1

    val cwd = cwd()
    if search_path == "":
        search_path = "{cwd}/src"

    if not file_exists(search_path):
        if log_opts.log_mode == "json":
            print "{\"command\":\"query\",\"status\":\"error\",\"error\":\"path not found\",\"path\":\"{search_path}\"}"
            return 1
        val progress = render_progress(log_opts.progress, 0, 1, "query")
        if progress != "":
            print progress
        error("query", "path not found: {search_path}")
        return 1

    val files = dir_walk(search_path)
    var total_matches = 0

    for file in files:
        if not file.ends_with(".spl"):
            pass
        else:
            val matches = search_file(path: file, pattern: pattern, case_insensitive: case_insensitive)
            if matches.len() > 0:
                total_matches = total_matches + matches.len()
                if not count_only:
                    val display_path = if file.starts_with(cwd): file[cwd.len() + 1:] else: file
                    for (line_num, line) in matches:
                        print "{display_path}:{line_num}: {line.trim()}"

    if count_only:
        print "{total_matches}"
    elif log_opts.log_mode == "json":
        print "{\"command\":\"query\",\"status\":\"ok\",\"pattern\":\"{pattern}\",\"count\":{total_matches}}"
    elif total_matches == 0:
        print "No matches found for '{pattern}'"

    0
