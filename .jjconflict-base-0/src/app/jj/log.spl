# JJ Log - Structured log output
#
# Wraps `jj log` and parses output into structured data.
# Usage: use app.jj.log.{jj_log, LogEntry, LogResult}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# A single log entry from jj log
struct LogEntry:
    change_id: text
    commit_id: text
    author: text
    timestamp: text
    description: text
    is_working_copy: bool

    fn display() -> text:
        val marker = if self.is_working_copy: "@ " else: "o "
        var line = "{marker}{self.change_id}"
        if self.author != "":
            line = line + " {self.author}"
        if self.timestamp != "":
            line = line + " {self.timestamp}"
        if self.description != "":
            line = line + " | {self.description}"
        line

# Structured result from jj log
struct LogResult:
    entries: [LogEntry]
    raw_output: text
    exit_code: i64

    fn display() -> text:
        if self.entries.len() == 0:
            return self.raw_output
        var lines: [text] = []
        for entry in self.entries:
            lines.push(entry.display())
        lines.join("\n")

fn jj_log(limit: i64, revsets: text) -> LogResult:
    """Run jj log and return structured result"""
    var jj_args = ["--no-pager", "--color", "never", "log"]

    if limit > 0:
        jj_args.push("--limit")
        jj_args.push("{limit}")

    if revsets != "":
        jj_args.push("-r")
        jj_args.push(revsets)

    val (stdout, stderr, code) = rt_process_run("jj", jj_args)

    if code != 0:
        return LogResult(
            entries: [],
            raw_output: if stderr != "": stderr else: stdout,
            exit_code: code
        )

    # Parse jj log output
    # Typical format:
    # @  change_id commit_id author timestamp
    # |  description
    # o  change_id commit_id author timestamp
    # |  description
    var entries: [LogEntry] = []
    val lines = stdout.split("\n")
    var current_change_id = ""
    var current_commit_id = ""
    var current_author = ""
    var current_timestamp = ""
    var current_desc = ""
    var current_is_wc = false
    var in_entry = false

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            if in_entry and current_change_id != "":
                entries.push(LogEntry(
                    change_id: current_change_id,
                    commit_id: current_commit_id,
                    author: current_author,
                    timestamp: current_timestamp,
                    description: current_desc.trim(),
                    is_working_copy: current_is_wc
                ))
                current_change_id = ""
                current_commit_id = ""
                current_author = ""
                current_timestamp = ""
                current_desc = ""
                current_is_wc = false
                in_entry = false
        elif trimmed.starts_with("@") or trimmed.starts_with("o") or trimmed.starts_with("x"):
            # New entry line - save previous if any
            if in_entry and current_change_id != "":
                entries.push(LogEntry(
                    change_id: current_change_id,
                    commit_id: current_commit_id,
                    author: current_author,
                    timestamp: current_timestamp,
                    description: current_desc.trim(),
                    is_working_copy: current_is_wc
                ))
                current_desc = ""

            current_is_wc = trimmed.starts_with("@")
            # Parse the entry header
            val parts = trimmed.split(" ")
            if parts.len() >= 2:
                current_change_id = parts[1]
            if parts.len() >= 3:
                current_commit_id = parts[2]
            if parts.len() >= 4:
                current_author = parts[3]
            if parts.len() >= 5:
                current_timestamp = parts[4]
            in_entry = true
        elif in_entry and (trimmed.starts_with("|") or trimmed.starts_with("~")):
            # Description continuation line
            val desc_part = trimmed[1:].trim()
            if desc_part != "":
                if current_desc != "":
                    current_desc = current_desc + " " + desc_part
                else:
                    current_desc = desc_part

    # Don't forget the last entry
    if in_entry and current_change_id != "":
        entries.push(LogEntry(
            change_id: current_change_id,
            commit_id: current_commit_id,
            author: current_author,
            timestamp: current_timestamp,
            description: current_desc.trim(),
            is_working_copy: current_is_wc
        ))

    LogResult(
        entries: entries,
        raw_output: stdout,
        exit_code: code
    )

fn run_log(args: [text]) -> i64:
    """CLI entry point for jj log

    Usage:
      simple jj log              - Show last 10 commits
      simple jj log -n 20        - Show last 20 commits
      simple jj log -r "main"    - Show specific revset
    """
    var limit = 10
    var revsets = ""

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "-n" and i + 1 < args.len():
            i = i + 1
            limit = args[i].to_int()
        elif arg.starts_with("-n"):
            limit = arg[2:].to_int()
        elif arg == "-r" and i + 1 < args.len():
            i = i + 1
            revsets = args[i]
        elif arg.starts_with("--limit="):
            limit = arg[8:].to_int()
        elif arg == "--raw":
            # Raw passthrough mode
            val result = jj_log(limit, revsets)
            print result.raw_output
            return result.exit_code
        i = i + 1

    val result = jj_log(limit, revsets)

    if result.exit_code != 0:
        print "Error running jj log:"
        print result.raw_output
        return result.exit_code

    # Print raw output (jj log is already well-formatted)
    print result.raw_output
    0
