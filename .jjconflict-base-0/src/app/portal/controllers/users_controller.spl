"""
# Users Controller

User profile viewing and editing.
All actions require authentication.
"""

use std.http_server.types.{HttpResponseData}
use std.web_framework.controller.{
    ControllerContext, render_page, render_redirect, render_error,
    render_forbidden, get_param
}
use std.web_framework.form_validation.{
    Validator, validator_new, validator_add_rule, validator_validate,
    validator_first_error, ValidationRule
}

# ============================================================================
# Actions
# ============================================================================

@requires_auth
fn action_user_show(ctx: ControllerContext) -> HttpResponseData:
    """Display user profile page."""
    val user_id = ctx.current_user_id
    if user_id == nil:
        return render_forbidden()

    var data: Dict<text, text> = {}
    data["title"] = "Profile"
    data["username"] = ""
    data["display_name"] = ""
    data["email"] = ""
    data["bio"] = ""
    data["role"] = "user"
    data["member_since"] = ""
    data["packages_html"] = "<p>No packages published yet.</p>"

    # In production, load user from database:
    # val user = find_user_by_id(db, uid)?
    # val packages = get_user_packages(db, uid)?

    render_page(ctx, "src/app/portal/views/users/show.html", data)

@requires_auth
fn action_user_edit(ctx: ControllerContext) -> HttpResponseData:
    """Render profile edit form."""
    val user_id = ctx.current_user_id
    if user_id == nil:
        return render_forbidden()

    var data: Dict<text, text> = {}
    data["title"] = "Edit Profile"
    data["username"] = ""
    data["display_name"] = ""
    data["email"] = ""
    data["bio"] = ""
    data["error_message"] = ""

    # In production, load current user data from database

    render_page(ctx, "src/app/portal/views/users/edit.html", data)

@requires_auth
fn action_user_update(ctx: ControllerContext) -> HttpResponseData:
    """Process profile update form submission."""
    val user_id = ctx.current_user_id
    if user_id == nil:
        return render_forbidden()

    val display_name = get_param(ctx, "display_name")
    val email = get_param(ctx, "email")
    val bio = get_param(ctx, "bio")

    # Validate input
    var v = validator_new()
    v = validator_add_rule(v, "display_name", ValidationRule.Required)
    v = validator_add_rule(v, "display_name", ValidationRule.MaxLength(100))
    v = validator_add_rule(v, "email", ValidationRule.Required)
    v = validator_add_rule(v, "email", ValidationRule.Email)

    val form_params: Dict<text, text> = {
        "display_name": display_name,
        "email": email
    }
    val valid = validator_validate(v, form_params)

    if not valid:
        var data: Dict<text, text> = {}
        data["title"] = "Edit Profile"
        data["display_name"] = display_name
        data["email"] = email
        data["bio"] = bio
        data["error_message"] = validator_first_error(v)
        return render_page(ctx, "src/app/portal/views/users/edit.html", data)

    # In production, save to database via auth_service.update_user_profile()
    # val uid = (user_id ?? "0").to_i64() ?? 0
    # update_user_profile(db, uid, display_name, bio, email)?

    render_redirect("/profile")
