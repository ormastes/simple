"""
# User Model

Portal user account with authentication data.
Implements DbCodec<User> for repository operations.
"""

use std.database.sql.types.{DbValue, DbRow, DbError}
use std.database.sql.schema.{TableSchema}
use std.database.sql.codec.{DbCodec}

# ============================================================================
# User Entity
# ============================================================================

class User:
    """A portal user account."""
    id: i64
    username: text
    email: text
    password_hash: text
    display_name: text
    bio: text
    role: text
    created_at: text
    updated_at: text

fn new_user(username: text, email: text, password_hash: text) -> User:
    """Create a new User with default values."""
    User(
        id: 0,
        username: username,
        email: email,
        password_hash: password_hash,
        display_name: username,
        bio: "",
        role: "user",
        created_at: "",
        updated_at: ""
    )

# ============================================================================
# UserCodec — DbCodec<User> implementation
# ============================================================================

class UserCodec with DbCodec<User>:
    """Codec for encoding/decoding User entities to/from database rows."""

    fn table_name() -> text:
        "users"

    fn schema() -> TableSchema:
        var s = TableSchema.new("users")
        s = s.id_col()
        s = s.text_col("username")
        s = s.text_col("email")
        s = s.text_col("password_hash")
        s = s.text_col("display_name")
        s = s.text_col("bio")
        s = s.text_col("role")
        s = s.text_col("created_at")
        s = s.text_col("updated_at")
        s

    fn columns() -> [text]:
        ["username", "email", "password_hash", "display_name", "bio", "role"]

    fn encode(entity: User) -> [DbValue]:
        [
            DbValue.Text(value: entity.username),
            DbValue.Text(value: entity.email),
            DbValue.Text(value: entity.password_hash),
            DbValue.Text(value: entity.display_name),
            DbValue.Text(value: entity.bio),
            DbValue.Text(value: entity.role)
        ]

    fn decode(row: DbRow) -> Result<User, DbError>:
        val id = row.get_int("id") ?? 0
        val username = row.get_text("username")
        val email = row.get_text("email")
        val password_hash = row.get_text("password_hash")
        val display_name = row.get_text("display_name")
        val bio = row.get_text("bio")
        val role = row.get_text("role")
        val created_at = row.get_text("created_at")
        val updated_at = row.get_text("updated_at")

        if username == nil:
            return Err(DbError.TypeMismatch(
                column: "username", expected: "text", actual: "missing"
            ))

        Ok(User(
            id: id,
            username: username ?? "",
            email: email ?? "",
            password_hash: password_hash ?? "",
            display_name: display_name ?? "",
            bio: bio ?? "",
            role: role ?? "user",
            created_at: created_at ?? "",
            updated_at: updated_at ?? ""
        ))
