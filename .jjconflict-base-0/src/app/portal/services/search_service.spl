"""
# Search Service

Full-text search over packages using SQLite LIKE queries.
Supports multi-term search and relevance ranking.
"""

use std.database.sql.connection.{Database}
use std.database.sql.types.{DbValue, DbError}
use portal.models.package_model.{Package, PackageCodec}

# ============================================================================
# Search Result
# ============================================================================

class SearchResult:
    """A search result with relevance score."""
    package: Package
    score: i64

# ============================================================================
# Search Operations
# ============================================================================

fn search_full_text(db: Database, query: text, limit: i64) -> Result<[SearchResult], text>:
    """Perform full-text search over packages.

    Searches package name, description, and license fields.
    Results are ranked by relevance (name match > description match).

    Args:
        db: Database connection
        query: Search query text
        limit: Maximum results to return

    Returns:
        Ok(results) ranked by relevance score
    """
    if query.len() == 0:
        return Ok([])

    val terms = query.split(" ")
    var results: [SearchResult] = []

    # Search by name first (highest relevance)
    val name_sql = "SELECT * FROM packages WHERE name LIKE ? ORDER BY downloads DESC LIMIT ?"
    val name_pattern = "%" + query + "%"
    val name_params: [DbValue] = [
        DbValue.Text(value: name_pattern),
        DbValue.Integer(value: limit)
    ]
    val name_result = db.query(name_sql, name_params)
    match name_result:
        Ok(rows):
            val codec = PackageCodec()
            for row in rows:
                val pkg_result = codec.decode(row)
                match pkg_result:
                    Ok(pkg):
                        var score = 100
                        # Exact name match gets highest score
                        if pkg.name == query:
                            score = 1000
                        elif pkg.name.starts_with(query):
                            score = 500
                        results.push(SearchResult(package: pkg, score: score))
                    Err(e): pass_do_nothing
        Err(e):
            return Err("Search query failed")

    # Search by description (lower relevance, avoid duplicates)
    val desc_sql = "SELECT * FROM packages WHERE description LIKE ? AND name NOT LIKE ? ORDER BY downloads DESC LIMIT ?"
    val desc_params: [DbValue] = [
        DbValue.Text(value: name_pattern),
        DbValue.Text(value: name_pattern),
        DbValue.Integer(value: limit)
    ]
    val desc_result = db.query(desc_sql, desc_params)
    match desc_result:
        Ok(rows):
            val codec = PackageCodec()
            for row in rows:
                val pkg_result = codec.decode(row)
                match pkg_result:
                    Ok(pkg):
                        results.push(SearchResult(package: pkg, score: 10))
                    Err(e): pass_do_nothing
        Err(e):
            pass_do_nothing

    # Sort by score descending (simple bubble sort since lists are small)
    var i = 0
    while i < results.len():
        var j = i + 1
        while j < results.len():
            if results[j].score > results[i].score:
                val temp = results[i]
                results[i] = results[j]
                results[j] = temp
            j = j + 1
        i = i + 1

    # Limit results
    if results.len() > limit:
        var trimmed: [SearchResult] = []
        var k = 0
        while k < limit:
            trimmed.push(results[k])
            k = k + 1
        return Ok(trimmed)

    Ok(results)

fn suggest_packages(db: Database, prefix: text, limit: i64) -> Result<[text], text>:
    """Get package name suggestions for autocomplete.

    Args:
        db: Database connection
        prefix: Prefix to search for
        limit: Maximum suggestions

    Returns:
        Ok(names) matching the prefix
    """
    if prefix.len() == 0:
        return Ok([])

    val sql = "SELECT name FROM packages WHERE name LIKE ? ORDER BY downloads DESC LIMIT ?"
    val pattern = prefix + "%"
    val params: [DbValue] = [
        DbValue.Text(value: pattern),
        DbValue.Integer(value: limit)
    ]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            var names: [text] = []
            for row in rows:
                val name = row.get_text("name")
                if name != nil:
                    names.push(name ?? "")
            Ok(names)
        Err(e):
            Err("Search suggestion query failed")
