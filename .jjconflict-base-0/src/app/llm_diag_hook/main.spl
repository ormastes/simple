#![allow(unnamed_duplicate_typed_args)]
# LLM Diagnostics Hook Binary
#
# Fast (<50ms) hook handler for Claude Code.
# Reads JSON from stdin, parses event, appends to JSONL log.
# Exit 0 = allow (never blocks Claude Code).
#
# Install in settings.json:
#   "hooks": {
#     "PreToolUse": [{"matcher": ".*", "hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}],
#     "PostToolUse": [{"matcher": ".*", "hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}],
#     "PostToolUseFailure": [{"matcher": ".*", "hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}],
#     "SessionStart": [{"hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}],
#     "SessionEnd": [{"hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}],
#     "SubagentStart": [{"hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}],
#     "SubagentStop": [{"hooks": [{"type": "command", "command": "bin/llm_diag_hook"}]}]
#   }

use std.nogc_async_mut.llm_diagnostics.hook_handler.{
    read_hook_stdin, parse_hook_json, extract_str
}
use std.nogc_async_mut.llm_diagnostics.exporters.file_exporter.{
    append_raw_jsonl
}

extern fn rt_env_get(name: text) -> text
extern fn rt_time_millis() -> i64

fn main() -> i64:
    # Read hook JSON from stdin
    val json = read_hook_stdin()
    if json.len() == 0:
        return 0

    # Determine log path
    val log_path = get_log_path()
    if log_path.len() == 0:
        return 0

    # Append raw JSON line to log (fastest path)
    # Prepend timestamp for ordering
    val now = rt_time_millis()
    val event_name = extract_str(json, "hook_event_name")
    val session_id = extract_str(json, "session_id")

    # Build minimal envelope with timestamp
    val line = build_log_line(now, event_name, session_id, json)
    append_raw_jsonl(log_path, line)

    # Exit 0 = allow
    0

fn get_log_path() -> text:
    """Get JSONL log path from env or default."""
    val env_path = rt_env_get("LLM_DIAG_LOG")
    if env_path.len() > 0:
        return env_path
    # Default: ~/.claude/diagnostics/session.jsonl
    val home = rt_env_get("HOME")
    if home.len() > 0:
        return home + "/.claude/diagnostics/session.jsonl"
    ""

fn build_log_line(timestamp: i64, event_name: text, session_id: text, raw_json: text) -> text:
    """Build JSONL line with envelope."""
    var parts: [text] = []
    parts.push("{\"ts\":")
    parts.push(timestamp.to_text())
    parts.push(",\"event\":\"")
    parts.push(event_name)
    parts.push("\",\"sid\":\"")
    parts.push(session_id)
    parts.push("\",\"data\":")
    parts.push(raw_json)
    parts.push("}")
    parts.join("")
