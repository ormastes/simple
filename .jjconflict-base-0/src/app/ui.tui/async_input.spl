# Async TUI Input Handler
#
# Reads terminal input in a background thread and pushes UIEvent values
# into a Channel. Two modes are provided:
#   - Line-based input (read_user_input + parse_input_line)
#   - Raw mode input  (rt_term_poll + rt_term_read_timeout)
#
# Both functions loop until the channel is closed.

use std.nogc_async_mut.concurrent.channel.{Channel}
use std.nogc_async_mut.concurrent.thread.{thread_sleep}
use common.ui.widget.{UIEvent}
use app.ui.tui.input.{parse_input_line, read_user_input, poll_raw_input, parse_raw_key}

# =========================================================================
# Line-Based Async Input
# =========================================================================

fn start_input_reader(channel: Channel):
    """Read stdin line-by-line and push parsed UIEvents into channel.

    Blocks on read_user_input() each iteration. Exits when the channel
    is closed externally (send becomes a no-op, but we check is_closed).
    """
    while not channel.is_closed():
        val user_input = read_user_input()

        if channel.is_closed():
            return

        if user_input == "":
            # Empty input means Enter was pressed with no text
            channel.send(UIEvent.KeyPress(key: "enter"))
        else:
            val event = parse_input_line(user_input)
            channel.send(event)

# =========================================================================
# Raw Mode Async Input
# =========================================================================

fn start_raw_input_reader(channel: Channel):
    """Read raw terminal key events and push UIEvents into channel.

    Uses rt_term_poll/rt_term_read_timeout for non-blocking key-by-key
    reading. Polls every 50ms so the loop can notice channel closure
    without blocking indefinitely.
    """
    val poll_timeout_ms = 50

    while not channel.is_closed():
        val data = poll_raw_input(poll_timeout_ms)

        if channel.is_closed():
            return

        if data == "":
            # No input within timeout -- loop and poll again
            pass_do_nothing
        else:
            val event = parse_raw_key(data)
            channel.send(event)
