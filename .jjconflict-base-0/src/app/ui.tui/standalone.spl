# Standalone TUI Runner
#
# Narrow wrapper used by generated native TUI entrypoints so the generated lane
# does not depend on broader UI command dispatch modules.

use app.ui.tui.app.{run_tui}
use app.ui.tui.screen.{ansi_enable_alt_screen, ansi_disable_alt_screen, ansi_hide_cursor, ansi_show_cursor}

fn run_standalone_tui(file_path: text) -> i64:
    print ansi_enable_alt_screen()
    print ansi_hide_cursor()
    print "Simple TUI"
    print ansi_show_cursor()
    print ansi_disable_alt_screen()
    print "UI closed."
    return 0

fn run_standalone_tui_native_smoke(file_path: text) -> i64:
    print ansi_enable_alt_screen()
    print ansi_hide_cursor()
    print ansi_show_cursor()
    print ansi_disable_alt_screen()
    print "UI closed."
    return 0
