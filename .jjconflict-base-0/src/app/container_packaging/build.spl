# Container Build - Generate Dockerfile for Simple projects
#
# Generates a Dockerfile based on the project type detected from
# the project structure and simple.sdn manifest.

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
use app.io.mod.{cwd}

# ============================================================================
# CLI Entry Point
# ============================================================================

"""Generate a Dockerfile for the current Simple project.

Usage:
    simple container build [options]

Options:
    --output, -o <path>   Output Dockerfile path (default: Dockerfile)
    --port <n>            Expose port (default: 8080)
    --type <type>         Project type: web, cli, service (default: auto-detect)
"""
fn cli_container_build(args: [text]) -> i64:
    var output_path = "Dockerfile"
    var port = 8080
    var project_type = ""
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--output" or arg == "-o":
            if i + 1 < args.len():
                i = i + 1
                output_path = args[i]
        elif arg.starts_with("--output="):
            output_path = arg[9:]
        elif arg == "--port":
            if i + 1 < args.len():
                i = i + 1
                port = args[i].to_i64() ?? 8080
        elif arg.starts_with("--port="):
            port = arg[7:].to_i64() ?? 8080
        elif arg == "--type":
            if i + 1 < args.len():
                i = i + 1
                project_type = args[i]
        elif arg.starts_with("--type="):
            project_type = arg[7:]
        elif arg == "--help" or arg == "-h":
            print "Usage: simple container build [--output <path>] [--port <n>] [--type web|cli|service]"
            return 0
        i = i + 1

    val current_dir = cwd()

    # Auto-detect project type if not specified
    if project_type == "":
        if rt_file_exists("{current_dir}/webapp.sdn"):
            project_type = "web"
        elif rt_file_exists("{current_dir}/service.sdn"):
            project_type = "service"
        else:
            project_type = "cli"

    # Generate Dockerfile content based on project type
    val dockerfile = _generate_dockerfile(project_type, port)

    # Write Dockerfile
    val write_ok = rt_file_write_text("{current_dir}/{output_path}", dockerfile)
    if not write_ok:
        print "Error: Failed to write {output_path}"
        return 1

    print "Generated {output_path} (type: {project_type})"
    if project_type == "web":
        print "  Exposes port {port}"
    print ""
    print "Build with: docker build -t myapp ."
    0

# ============================================================================
# Dockerfile Generation
# ============================================================================

fn _generate_dockerfile(project_type: text, port: i64) -> text:
    var lines: [text] = []

    # Base image
    lines.push("# Generated by: simple container build")
    lines.push("FROM ubuntu:22.04 AS base")
    lines.push("")
    lines.push("RUN apt-get update && apt-get install -y --no-install-recommends \\")
    lines.push("    ca-certificates \\")
    lines.push("    && rm -rf /var/lib/apt/lists/*")
    lines.push("")

    # Build stage
    lines.push("FROM base AS build")
    lines.push("WORKDIR /app")
    lines.push("COPY . .")
    lines.push("")

    if project_type == "web":
        lines.push("# Build web archive")
        lines.push("RUN simple web build")
        lines.push("")
        lines.push("# Runtime stage")
        lines.push("FROM base AS runtime")
        lines.push("WORKDIR /app")
        lines.push("COPY --from=build /app/*.swa /app/")
        lines.push("COPY --from=build /app/bin/simple /usr/local/bin/simple")
        lines.push("")
        lines.push("EXPOSE {port}")
        lines.push("CMD [\"simple\", \"web\", \"serve\", \"app.swa\", \"--port\", \"{port}\"]")
    elif project_type == "service":
        lines.push("# Build service")
        lines.push("RUN simple build --release")
        lines.push("")
        lines.push("# Runtime stage")
        lines.push("FROM base AS runtime")
        lines.push("WORKDIR /app")
        lines.push("COPY --from=build /app/build/release/ /app/")
        lines.push("")
        lines.push("EXPOSE {port}")
        lines.push("CMD [\"/app/simple\", \"run\"]")
    else:
        # CLI
        lines.push("# Build CLI application")
        lines.push("RUN simple build --release")
        lines.push("")
        lines.push("# Runtime stage")
        lines.push("FROM base AS runtime")
        lines.push("WORKDIR /app")
        lines.push("COPY --from=build /app/build/release/ /app/")
        lines.push("")
        lines.push("ENTRYPOINT [\"/app/simple\"]")

    lines.push("")
    lines.join("\n")
