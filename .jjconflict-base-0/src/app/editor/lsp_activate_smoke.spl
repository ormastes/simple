extern fn rt_file_write_text(path: text, content: text) -> bool

fn main() -> i64:
    val path = "/tmp/simple_editor_lsp_activate_smoke.spl"
    rt_file_write_text(path, "fn main():\n    return\n")
    var session = EditSession.new()
    session.open_file(path)
    var ctrl = EditorController.new(session)
    ctrl._activate_active_language()
    if not ctrl.simple_lsp_state.running:
        print "STATUS: FAIL lsp_activate_smoke not_running"
        return 1
    print "STATUS: PASS lsp_activate_smoke"
    0
