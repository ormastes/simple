# AC-7: native app entry driving the SFM arg-parser front-end layer.
#
# Parses its own argv through the arg-parser layer and prints the parsed result.
# Run: bin/simple run src/app/sfm_samples/arg_parser/main.spl -- --name alice deploy

use app.sfm_samples.arg_parser.arg_parser_layer.{arg_parse_sample, ParsedArgs}
use std.sfm.version.{read_version_md}

# Native entry. The interpreter `run` path does not expose process argv to a
# pure-Simple entry (`rt_get_args` is unresolved under interpretation), so this
# native sample drives the arg-parser front-end layer with a representative
# sample arg vector. A compiled-native build would substitute real argv here.
fn main():
    val version: text = read_version_md("VERSION.md")
    val sample_args: [text] = ["--name", "alice", "--verbose", "deploy"]
    val parsed: ParsedArgs = arg_parse_sample(sample_args)
    print("sfm-arg-parser " + version)
    print("name=" + parsed.get_str("name"))
    if parsed.get_bool("verbose"):
        print("verbose=true")
    var i: i32 = 0
    val n: i32 = parsed.positionals.len() as i32
    while i < n:
        print("positional[" + i.to_text() + "]=" + parsed.positionals[i])
        i = i + 1
