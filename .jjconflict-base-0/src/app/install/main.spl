# Simple CLI - install command
# Installs all dependencies from simple.sdn/simple.lock

use std.cli.cli_util (get_cli_args, find_manifest_path, parse_deps_section)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, file_read, file_write, dir_create, cwd)
use std.log.{error}

fn print_help():
    print "Usage: simple install [options]"
    print ""
    print "Install all dependencies from simple.sdn."
    print "Uses simple.lock if available, otherwise resolves from manifest."
    print ""
    print "Options:"
    print "  --json       Output as JSON"
    print "  --frozen     Only install from lockfile, fail if missing"
    print "  --dry-run    Show what would be installed without changes"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _json_array(names: [text]) -> text:
    var parts: [text] = []
    var i = 0
    while i < names.len():
        parts.push("\"{names[i]}\"")
        i = i + 1
    "[" + parts.join(",") + "]"

fn main() -> i64:
    val args = get_cli_args()

    var frozen = false
    var dry_run = false
    var as_json = false
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("install", log_opts.error)
        return 1

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--frozen":
            frozen = true
        elif arg == "--dry-run":
            dry_run = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        ai = ai + 1

    if log_opts.log_mode == "json":
        as_json = true

    val manifest_path = find_manifest_path()
    if manifest_path == "":
        print "install: no simple.sdn or simple.toml found in current directory"
        return 1

    val current_dir = cwd()
    val lockfile_path = "{current_dir}/simple.lock"
    val modules_dir = "{current_dir}/simple_modules"

    # Check for lockfile
    if frozen and not file_exists(lockfile_path):
        print "install: --frozen requires simple.lock to exist"
        return 1

    val content = file_read(manifest_path)
    val deps = parse_deps_section(content, "dependencies") + parse_deps_section(content, "dev_dependencies")

    if deps.len() == 0:
        if as_json:
            print "{\"dry_run\":{dry_run},\"frozen\":{frozen},\"count\":0,\"dependencies\":[]}"
            return 0
        print "No dependencies to install."
        return 0

    if as_json:
        print "{\"dry_run\":{dry_run},\"frozen\":{frozen},\"count\":{deps.len()},\"dependencies\":" + _json_array(deps) + "}"
        return 0

    if log_opts.progress != "summary":
        val progress_line = render_progress(log_opts.progress, deps.len(), deps.len(), "install")
        if progress_line != "":
            print progress_line

    if dry_run:
        print "Would install {deps.len()} dependencies:"
        for name in deps:
            print "  {name} (*)"
        return 0

    # Create simple_modules directory
    if not dir_create(modules_dir, true):
        print "install: failed to create simple_modules/"
        return 1

    print "Installing {deps.len()} dependencies..."

    var installed = 0
    for name in deps:
        # Create package directory
        val pkg_dir = "{modules_dir}/{name}"
        if not dir_create(pkg_dir, true):
            print "install: failed to create directory for '{name}'"
        else:
            # Write a placeholder module file
            val mod_content = "# {name} - installed by simple install\n# version: *\n# TODO: actual package download from registry\n"
            file_write("{pkg_dir}/__init__.spl", mod_content)
            print "  installed {name} (*)"
            installed = installed + 1

    print ""
    print "Installed {installed}/{deps.len()} packages to simple_modules/"

    # Generate lockfile if not frozen
    if not frozen and not file_exists(lockfile_path):
        var lock_content = "# simple.lock (generated)\n"
        for name in deps:
            lock_content = lock_content + "{name}: *\n"
        file_write(lockfile_path, lock_content)
        print "Generated simple.lock"

    0
