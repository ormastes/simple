#![allow(unnamed_duplicate_typed_args)]
# Chromium Shell Event Bridge (V3 simple_browser shell — M2)
#
# Mirrors `src/app/ui.browser/event_bridge.spl` but is specialised for the
# winit host used by `src/app/ui.chromium/main.spl`:
#
#   * raw winit event types / keycodes (the same `EVENT_*` and
#     `WINIT_KEY_*` constants `hosted_input_backend.spl` already uses) are
#     translated into the platform-independent `common.ui.widget.UIEvent`,
#     so the compositor input pump can consume chromium-shell events.
#   * a `ChromiumEventBridge` class tracks modifier state
#     (shift / ctrl / alt / super) across keyboard events so the
#     (key, modifiers) mapping can round-trip Ctrl/Shift/Alt/Super without
#     the compositor having to reimplement the state machine.
#   * mouse wheel deltas fan out to an `examples/browser/entity/dom`
#     `DomEvent` with `type_name: "wheel"`, satisfying M2's
#     "mouse wheel -> wheel DOM event" acceptance criterion.
#
# M2 scope:
#   * translation functions only — no runtime I/O, no FFI, no rt_winit_*
#     calls. The winit-event source is owned by `HostedInputBackend`
#     (already wired into the compositor via `ChromiumApp.new()`), and
#     by `ChromiumApp.run()` for window-close detection. This module is
#     the pure, compile-testable translation layer that sits between
#     those raw events and the UI / DOM event consumers.

use common.ui.widget.{UIEvent}
use examples.browser.entity.dom.event_types.{DomEvent}

# =========================================================================
# Winit Event Type / Keycode Mirrors
# =========================================================================
#
# Mirrors `src/os/compositor/hosted_input_backend.spl`. Kept local so the
# chromium shell can evolve its event numbering independently of the
# hosted backend without a cross-module import cycle.

val CHROMIUM_EVENT_CLOSE: i64 = 3
val CHROMIUM_EVENT_KEYBOARD: i64 = 10
val CHROMIUM_EVENT_MOUSE_BUTTON: i64 = 20
val CHROMIUM_EVENT_MOUSE_MOVED: i64 = 21
val CHROMIUM_EVENT_MOUSE_WHEEL: i64 = 22

# Modifier bitmask — matches `translate_key_event` in ui.browser.
val CHROMIUM_MOD_SHIFT: i32 = 1
val CHROMIUM_MOD_CTRL: i32 = 2
val CHROMIUM_MOD_ALT: i32 = 4
val CHROMIUM_MOD_SUPER: i32 = 8

# =========================================================================
# Key Event Translation
# =========================================================================

fn translate_key_event(key: i32, modifiers: i32) -> UIEvent?:
    """Translate a raw key code + modifier bitmask into a UIEvent.

    Modifier bits:
      0x01 = Shift
      0x02 = Ctrl
      0x04 = Alt
      0x08 = Meta / Super

    Mirrors `ui.browser.event_bridge.translate_key_event` verbatim — the
    chromium shell reuses the same mapping so `wm_compare` input specs
    continue to pass on both backends.
    """
    val has_ctrl = (modifiers / 2) % 2 == 1

    # Ctrl+Q or Ctrl+C -> Quit
    if has_ctrl and (key == 113 or key == 99):
        return UIEvent.Quit

    # Escape (27) -> NormalMode
    if key == 27:
        return UIEvent.NormalMode

    # Tab (9) -> FocusNext, Shift+Tab -> FocusPrev
    if key == 9:
        val has_shift = modifiers % 2 == 1
        if has_shift:
            return UIEvent.FocusPrev
        return UIEvent.FocusNext

    # Enter (13) -> Action("enter")
    if key == 13:
        return UIEvent.Action(name: "enter")

    # Colon (58) -> CommandMode
    if key == 58:
        return UIEvent.CommandMode

    # 'i' (105) -> InsertMode
    if key == 105:
        return UIEvent.InsertMode

    # Arrow keys
    if key == 37:
        return UIEvent.KeyPress(key: "left")
    if key == 38:
        return UIEvent.KeyPress(key: "up")
    if key == 39:
        return UIEvent.KeyPress(key: "right")
    if key == 40:
        return UIEvent.KeyPress(key: "down")

    # Printable ASCII range
    if key >= 32 and key <= 126:
        val ch = char_from_code(key)
        return UIEvent.KeyPress(key: ch)

    return nil

# =========================================================================
# Mouse Event Translation
# =========================================================================

fn translate_mouse_event(x: i32, y: i32, button: i32, action: text) -> UIEvent?:
    """Translate a raw mouse event into a UIEvent.

    action: "press", "release", "move"
    button: 0 = left, 1 = middle, 2 = right
    """
    match action:
        "press" =>
            if button == 0:
                return UIEvent.TouchPress(x: x, y: y)
            return nil
        "release" =>
            if button == 0:
                return UIEvent.TouchRelease(x: x, y: y)
            return nil
        "move" =>
            return UIEvent.TouchMove(x: x, y: y)
        _ =>
            return nil

# =========================================================================
# Wheel Event Translation
# =========================================================================

fn translate_wheel_dom_event(target_id: i64, timestamp: i64) -> DomEvent:
    """Translate a raw winit mouse-wheel event into a DOM `wheel` event.

    M2 acceptance: "Mouse wheel -> `wheel` DOM event". We only emit the
    event-shaped carrier here — deltaX / deltaY plumbing lives with the
    DOM engine (M5 / M9) and is not part of the V3 shell bring-up.
    """
    return DomEvent.create("wheel", target_id, timestamp)

fn translate_wheel_ui_event(delta_y: i32) -> UIEvent?:
    """Wheel -> UIEvent fallback for compositor focus-navigation.

    Positive `delta_y` scrolls down (FocusNext), negative scrolls up
    (FocusPrev). Returns nil for a zero delta.
    """
    if delta_y > 0:
        return UIEvent.FocusNext
    if delta_y < 0:
        return UIEvent.FocusPrev
    return nil

# =========================================================================
# Modifier-tracking Bridge
# =========================================================================

class ChromiumEventBridge:
    """Stateful winit -> UIEvent translator for the chromium shell.

    Tracks the current modifier bitmask across key press / release pairs
    so `translate_key_event` receives the correct `modifiers` argument.
    A single instance lives inside `ChromiumApp` for the lifetime of the
    window.
    """
    shift_down: bool
    ctrl_down: bool
    alt_down: bool
    super_down: bool

impl ChromiumEventBridge:

    static fn new() -> ChromiumEventBridge:
        ChromiumEventBridge(
            shift_down: false,
            ctrl_down: false,
            alt_down: false,
            super_down: false
        )

    me modifiers_mask() -> i32:
        """Pack the current modifier flags into the shift/ctrl/alt/super
        bitmask accepted by `translate_key_event`."""
        var mask: i32 = 0
        if self.shift_down:
            mask = mask + CHROMIUM_MOD_SHIFT
        if self.ctrl_down:
            mask = mask + CHROMIUM_MOD_CTRL
        if self.alt_down:
            mask = mask + CHROMIUM_MOD_ALT
        if self.super_down:
            mask = mask + CHROMIUM_MOD_SUPER
        return mask

    me update_modifier(keycode: i64, pressed: bool):
        """Update internal modifier state from a winit keycode edge.

        Shift = 16, Ctrl = 17, Alt = 18, Meta/Super = 91 — these match
        the raw codes surfaced by the `rt_winit_event_keyboard_input`
        FFI on the host desktops.
        """
        if keycode == 16:
            self.shift_down = pressed
        elif keycode == 17:
            self.ctrl_down = pressed
        elif keycode == 18:
            self.alt_down = pressed
        elif keycode == 91:
            self.super_down = pressed

    me on_key(keycode: i64, pressed: bool) -> UIEvent?:
        """Consume a raw winit keyboard event.

        Updates modifier state first, then — for press edges only —
        returns the translated `UIEvent`. Release edges return nil so
        the compositor does not see duplicate key presses when a
        modifier key is lifted.
        """
        self.update_modifier(keycode, pressed)
        if not pressed:
            return nil
        val key32: i32 = keycode.to_i32()
        return translate_key_event(key32, self.modifiers_mask())

    me on_mouse_button(x: i32, y: i32, button: i64, pressed: bool) -> UIEvent?:
        """Consume a raw winit mouse-button event."""
        val action = if pressed: "press" else: "release"
        val btn32: i32 = (button - 1).to_i32()
        return translate_mouse_event(x, y, btn32, action)

    me on_mouse_move(x: i32, y: i32) -> UIEvent?:
        """Consume a raw winit mouse-moved event."""
        return translate_mouse_event(x, y, 0, "move")

    me on_wheel(delta_y: i32) -> UIEvent?:
        """Consume a raw winit mouse-wheel event (UIEvent side)."""
        return translate_wheel_ui_event(delta_y)

    me on_event(event_type: i64, key: i64, pressed: bool, x: i32, y: i32, delta_y: i32) -> UIEvent?:
        """Dispatch a raw winit event by type code.

        Returns `UIEvent.Quit` for window-close, and nil for an unknown
        event type. The chromium shell's render loop calls this once per
        raw winit event polled off the event loop.
        """
        if event_type == CHROMIUM_EVENT_CLOSE:
            return UIEvent.Quit
        if event_type == CHROMIUM_EVENT_KEYBOARD:
            return self.on_key(key, pressed)
        if event_type == CHROMIUM_EVENT_MOUSE_BUTTON:
            return self.on_mouse_button(x, y, key, pressed)
        if event_type == CHROMIUM_EVENT_MOUSE_MOVED:
            return self.on_mouse_move(x, y)
        if event_type == CHROMIUM_EVENT_MOUSE_WHEEL:
            return self.on_wheel(delta_y)
        return nil

# =========================================================================
# Helpers
# =========================================================================

fn char_from_code(code: i32) -> text:
    """Convert an ASCII code to a single-character text value."""
    if code == 32: return " "
    if code == 33: return "!"
    if code == 34: return "\""
    if code == 35: return "#"
    if code == 36: return "$"
    if code == 37: return "%"
    if code == 38: return "&"
    if code == 39: return "'"
    if code == 40: return "("
    if code == 41: return ")"
    if code == 42: return "*"
    if code == 43: return "+"
    if code == 44: return ","
    if code == 45: return "-"
    if code == 46: return "."
    if code == 47: return "/"

    if code >= 48 and code <= 57:
        val digit = code - 48
        return "{digit}"

    if code == 58: return ":"
    if code == 59: return ";"
    if code == 60: return "<"
    if code == 61: return "="
    if code == 62: return ">"
    if code == 63: return "?"
    if code == 64: return "@"

    if code >= 65 and code <= 90:
        match code:
            65 => return "A"
            66 => return "B"
            67 => return "C"
            68 => return "D"
            69 => return "E"
            70 => return "F"
            71 => return "G"
            72 => return "H"
            73 => return "I"
            74 => return "J"
            75 => return "K"
            76 => return "L"
            77 => return "M"
            78 => return "N"
            79 => return "O"
            80 => return "P"
            81 => return "Q"
            82 => return "R"
            83 => return "S"
            84 => return "T"
            85 => return "U"
            86 => return "V"
            87 => return "W"
            88 => return "X"
            89 => return "Y"
            90 => return "Z"
            _ => return "?"

    if code == 91: return "["
    if code == 92: return "\\"
    if code == 93: return "]"
    if code == 94: return "^"
    if code == 95: return "_"
    if code == 96: return "`"

    if code >= 97 and code <= 122:
        match code:
            97 => return "a"
            98 => return "b"
            99 => return "c"
            100 => return "d"
            101 => return "e"
            102 => return "f"
            103 => return "g"
            104 => return "h"
            105 => return "i"
            106 => return "j"
            107 => return "k"
            108 => return "l"
            109 => return "m"
            110 => return "n"
            111 => return "o"
            112 => return "p"
            113 => return "q"
            114 => return "r"
            115 => return "s"
            116 => return "t"
            117 => return "u"
            118 => return "v"
            119 => return "w"
            120 => return "x"
            121 => return "y"
            122 => return "z"
            _ => return "?"

    if code == 123: return "{"
    if code == 124: return "|"
    if code == 125: return "}"
    if code == 126: return "~"

    return "?"
