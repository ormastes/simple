# svim quickfix traversal helpers
#
# Next/prev/jump helpers that operate on a flat [QuickfixEntry] list.
# These are pure functions; the session wires them into execute_named.

class QuickfixEntry:
    row: i64
    col: i64
    severity: text
    message: text

class QuickfixTraversal:
    entries: [QuickfixEntry]
    current_index: i64

impl QuickfixTraversal:

    static fn new() -> QuickfixTraversal:
        QuickfixTraversal(entries: [], current_index: 0)

    static fn from_entries(items: [QuickfixEntry]) -> QuickfixTraversal:
        QuickfixTraversal(entries: items, current_index: 0)

    me next() -> bool:
        if self.entries.len() == 0:
            return false
        if self.current_index + 1 < self.entries.len():
            self.current_index = self.current_index + 1
            return true
        false

    me prev() -> bool:
        if self.entries.len() == 0:
            return false
        if self.current_index > 0:
            self.current_index = self.current_index - 1
            return true
        false

    fn current() -> QuickfixEntry:
        if self.entries.len() == 0:
            return QuickfixEntry(row: 0, col: 0, severity: "", message: "")
        self.entries[self.current_index]

    fn len() -> i64:
        self.entries.len()

    me jump_to_index(idx: i64) -> bool:
        if idx >= 0 and idx < self.entries.len():
            self.current_index = idx
            return true
        false

fn svim_qf_make_entry(row: i64, col: i64, severity: text, message: text) -> QuickfixEntry:
    QuickfixEntry(row: row, col: col, severity: severity, message: message)

fn svim_qf_filter_severity(entries: [QuickfixEntry], severity: text) -> [QuickfixEntry]:
    """Return only entries matching severity."""
    var out: [QuickfixEntry] = []
    for entry in entries:
        if entry.severity == severity:
            out.push(entry)
    out
