    cmds

fn cli_command_names() -> [text]:
    var names: [text] = []
    val cmds = all_cli_commands()
    for c in cmds:
        names.push(c.name)
    names

fn cli_implemented_commands() -> [text]:
    var names: [text] = []
    val cmds = all_cli_commands()
    for c in cmds:
        if c.handler_status == "implemented":
            names.push(c.name)
    names

fn cli_experimental_commands() -> [text]:
    var names: [text] = []
    val cmds = all_cli_commands()
    for c in cmds:
        if c.handler_status == "experimental":
            names.push(c.name)
    names

fn cli_placeholder_commands() -> [text]:
    var names: [text] = []
    val cmds = all_cli_commands()
    for c in cmds:
        if c.handler_status == "placeholder":
            names.push(c.name)
    names

fn cli_commands_in_family(family: text) -> [text]:
    var names: [text] = []
    val cmds = all_cli_commands()
    for c in cmds:
        if c.family == family:
            names.push(c.name)
    names

fn cli_families() -> [text]:
    ["execution", "testing", "quality", "build", "llm", "docgen",
     "package", "verify", "ffi", "i18n", "other"]

# ============================================================================
# MCP Tool Classification
# ============================================================================

class McpToolClassification:
    name: text
    category: text        # "debug" | "debug-log" | "diagnostics" | "vcs" | "cli" | "query" | "task" | "test-daemon"
    handler_kind: text    # "cli" | "vcs" | "in_process" | "query"
    maturity: text        # "stable" | "beta" | "stub"
    cli_equivalent: text  # corresponding CLI command, or "" if MCP-only

fn mcp_class(name: text, cat: text, handler: text, maturity: text, cli_eq: text) -> McpToolClassification:
    McpToolClassification(name: name, category: cat, handler_kind: handler, maturity: maturity, cli_equivalent: cli_eq)

fn all_mcp_tools() -> [McpToolClassification]:
    var tools: [McpToolClassification] = []
    # Debug session tools (19)
    tools.push(mcp_class(name: "debug_create_session", cat: "debug", handler: "in_process", maturity: "stable", cli_eq: ""))
    tools.push(mcp_class(name: "debug_list_sessions", cat: "debug", handler: "in_process", maturity: "stable", cli_eq: ""))
    tools.push(mcp_class(name: "debug_close_session", cat: "debug", handler: "in_process", maturity: "stable", cli_eq: ""))
