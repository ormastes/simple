# Debug Info Bridge
# Adapter that wraps a DebugInfoProvider and exposes the methods
# needed by GDB handlers and the debug coordinator.

use std.debug.formats.debug_types.{SourceLocation, DebugFunction, DebugVariable, DebugLineEntry, DebugCompilationUnit, DebugFormatKind}
use std.debug.formats.debug_provider.{DebugInfoProvider}

class DebugInfoBridge:
    provider: DebugInfoProvider

    static fn wrap(provider: DebugInfoProvider) -> DebugInfoBridge:
        DebugInfoBridge(provider: provider)

impl DebugInfoBridge:
    fn format_kind() -> DebugFormatKind:
        self.provider.format_kind()

    fn addr_to_source(addr: i64) -> SourceLocation?:
        self.provider.addr_to_source(addr)

    fn source_to_addr(file: text, line: i64) -> i64?:
        self.provider.source_to_addr(file, line)

    fn function_at(addr: i64) -> DebugFunction?:
        self.provider.function_at(addr)

    fn function_name_at(addr: i64) -> text:
        val func = self.provider.function_at(addr)
        if func == nil:
            return ""
        func!.name

    fn functions_in_range(low: i64, high: i64) -> [DebugFunction]:
        self.provider.functions_in_range(low, high)

    fn locals_at(addr: i64) -> [DebugVariable]:
        self.provider.locals_at(addr)

    fn compilation_units() -> [DebugCompilationUnit]:
        self.provider.compilation_units()

    fn line_entries() -> [DebugLineEntry]:
        self.provider.line_entries()
