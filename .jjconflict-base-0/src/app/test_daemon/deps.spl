use app.test_dep_graph_shared.{SharedDepGraph}
use app.test_dep_graph_shared.{shared_dep_graph_new, shared_dep_graph_load}

class TestDepGraph:
    inner: SharedDepGraph

fn test_dep_graph_new(graph_path: text) -> TestDepGraph:
    TestDepGraph(inner: shared_dep_graph_new(graph_path, true))

fn test_dep_graph_load(graph_path: text) -> TestDepGraph:
    TestDepGraph(inner: shared_dep_graph_load(graph_path, true))

impl TestDepGraph:
    fn get_deps(test_path: text) -> [text]:
        self.inner.get_deps(test_path)

    fn get_affected_tests(source_path: text) -> [text]:
        self.inner.get_affected_tests(source_path)

    me analyze_test(test_path: text):
        self.inner.analyze_test(test_path)

    me save():
        self.inner.save()
