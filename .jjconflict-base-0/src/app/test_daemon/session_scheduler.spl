# Test Daemon Session Scheduler — Batches and prioritizes session-capable tests
#
# Groups tests by session key so that compatible tests share a single session.
# Applies per-kind concurrency limits and ordering heuristics:
#   1. read-only tests first (no reset needed between them)
#   2. shared-with-reset tests next (cheap reset between tests)
#   3. fresh-per-test last (each needs a new session)
#
# The scheduler does NOT own sessions — it produces a schedule that the broker
# executes. This keeps scheduling deterministic and testable.

use app.test_daemon.session_types.{
    SessionKey, TestSessionMeta,
    SESSION_KIND_LOCAL,
    REUSE_SHARED_READ_ONLY, REUSE_SHARED_WITH_RESET, REUSE_SHARED_WITH_SNAPSHOT,
    REUSE_EXCLUSIVE_REUSED, REUSE_FRESH_PER_TEST,
    session_kind_name, meta_to_session_key, meta_needs_session,
    session_key_to_id, session_key_matches
}

# ============================================================================
# Schedule Entry — one test in the ordered schedule
# ============================================================================

struct ScheduleEntry:
    file_path: text
    meta: TestSessionMeta
    key: SessionKey
    priority: i64
    group_id: text

# ============================================================================
# Schedule Group — tests sharing the same session key
# ============================================================================

struct ScheduleGroup:
    group_id: text
    key: SessionKey
    entries: [ScheduleEntry]
    priority: i64

# ============================================================================
# Session Schedule — the full ordered plan
# ============================================================================

struct SessionSchedule:
    groups: [ScheduleGroup]
    ungrouped: [ScheduleEntry]
    total_tests: i64
    total_groups: i64
    total_ungrouped: i64

# ============================================================================
# Priority calculation
# ============================================================================

fn reuse_priority(reuse_mode: i64) -> i64:
    """
    Lower number = higher priority (runs first).
    Read-only tests run first because they need no reset.
    Fresh-per-test runs last because each needs a new session.
    """
    if reuse_mode == REUSE_SHARED_READ_ONLY: return 0
    elif reuse_mode == REUSE_SHARED_WITH_SNAPSHOT: return 1
    elif reuse_mode == REUSE_SHARED_WITH_RESET: return 2
    elif reuse_mode == REUSE_EXCLUSIVE_REUSED: return 3
    elif reuse_mode == REUSE_FRESH_PER_TEST: return 4
    5

# ============================================================================
# Scheduler
# ============================================================================

fn schedule_session_tests(metas: [TestSessionMeta]) -> SessionSchedule:
    """
    Takes a list of test metadata and produces a SessionSchedule.
    Groups compatible tests by session key, sorts groups by priority,
    and separates local/ungrouped tests.
    """
    var groups: [ScheduleGroup] = []
    var ungrouped: [ScheduleEntry] = []

    # Build entries
    var i = 0
    while i < metas.len():
        val meta = metas[i]
        val key = meta_to_session_key(meta)
        val priority = reuse_priority(meta.reuse_mode)
        val group_id = session_key_to_id(key)
        val entry = ScheduleEntry(
            file_path: meta.file_path,
            meta: meta,
            key: key,
            priority: priority,
            group_id: group_id
        )

        if not meta_needs_session(meta):
            ungrouped.push(entry)
            i = i + 1
            continue

        # Find existing group
        var found = false
        var g = 0
        while g < groups.len():
            if session_key_matches(groups[g].key, key):
                groups[g].entries.push(entry)
                found = true
                break
            g = g + 1

        if not found:
            val group = ScheduleGroup(
                group_id: group_id,
                key: key,
                entries: [entry],
                priority: priority
            )
            groups.push(group)

        i = i + 1

    # Sort groups by priority (insertion sort — groups are typically small)
    var sorted_groups = _sort_groups_by_priority(groups)

    SessionSchedule(
        groups: sorted_groups,
        ungrouped: ungrouped,
        total_tests: metas.len(),
        total_groups: sorted_groups.len(),
        total_ungrouped: ungrouped.len()
    )

fn schedule_from_files(file_paths: [text], classify_fn: fn(text) -> TestSessionMeta) -> SessionSchedule:
    """
    Convenience: classify file paths and produce a schedule.
    """
    var metas: [TestSessionMeta] = []
    for path in file_paths:
        metas.push(classify_fn(path))
    schedule_session_tests(metas)

# ============================================================================
# Schedule queries
# ============================================================================

fn schedule_group_for_kind(schedule: SessionSchedule, kind: i64) -> [ScheduleGroup]:
    """Returns all groups matching a given session kind."""
    var result: [ScheduleGroup] = []
    for group in schedule.groups:
        if group.key.kind == kind:
            result.push(group)
    result

fn schedule_total_session_tests(schedule: SessionSchedule) -> i64:
    """Total number of tests that will use sessions (excludes ungrouped)."""
    var total: i64 = 0
    for group in schedule.groups:
        total = total + group.entries.len()
    total

fn schedule_group_by_id(schedule: SessionSchedule, group_id: text) -> [ScheduleEntry]:
    """Returns entries in the named group, or empty if not found."""
    for group in schedule.groups:
        if group.group_id == group_id:
            return group.entries
    []

fn schedule_summary(schedule: SessionSchedule) -> text:
    """Human-readable summary of the schedule."""
    var lines: [text] = []
    lines.push("Session Schedule:")
    lines.push("  Total tests: {schedule.total_tests}")
    lines.push("  Session groups: {schedule.total_groups}")
    lines.push("  Ungrouped (local): {schedule.total_ungrouped}")
    for group in schedule.groups:
        val kind_name = session_kind_name(group.key.kind)
        val entry_count = group.entries.len()
        lines.push("  Group [{kind_name}] target={group.key.target} tests={entry_count} priority={group.priority}")
    lines.join("\n")

# ============================================================================
# Flatten — produce ordered file list from schedule
# ============================================================================

fn schedule_flatten(schedule: SessionSchedule) -> [text]:
    """
    Flattens the schedule into an ordered list of file paths.
    Session groups come first (ordered by priority), then ungrouped.
    """
    var result: [text] = []
    for group in schedule.groups:
        for entry in group.entries:
            result.push(entry.file_path)
    for entry in schedule.ungrouped:
        result.push(entry.file_path)
    result

fn schedule_session_file_paths(schedule: SessionSchedule) -> [text]:
    """Returns only file paths that need sessions (no ungrouped)."""
    var result: [text] = []
    for group in schedule.groups:
        for entry in group.entries:
            result.push(entry.file_path)
    result

fn schedule_local_file_paths(schedule: SessionSchedule) -> [text]:
    """Returns only ungrouped (local) file paths."""
    var result: [text] = []
    for entry in schedule.ungrouped:
        result.push(entry.file_path)
    result

# ============================================================================
# Private helpers
# ============================================================================

fn _sort_groups_by_priority(groups: [ScheduleGroup]) -> [ScheduleGroup]:
    """Insertion sort by priority (ascending). Stable for equal priorities."""
    var sorted: [ScheduleGroup] = []
    for group in groups:
        var inserted = false
        var new_sorted: [ScheduleGroup] = []
        var j = 0
        while j < sorted.len():
            if not inserted and group.priority < sorted[j].priority:
                new_sorted.push(group)
                inserted = true
            new_sorted.push(sorted[j])
            j = j + 1
        if not inserted:
            new_sorted.push(group)
        sorted = new_sorted
    sorted

# ============================================================================
# Exports
# ============================================================================
