#!/usr/bin/env simple
# Git-to-JJ wrapper - Redirects git commands to jj equivalents
# This helps LLMs and users transitioning from git to jj
#
# Usage: git_wrapper <git-command> [args...]
# Migrated from: scripts/jj-wrappers/git.sh

use app.io


fn main():
    val args = get_args()

    if args.len() == 0:
        show_usage()
        exit(0)

    val git_cmd = args[0]
    val cmd_args = if args.len() > 1: args[1:] else: []

    print "NOTE: This project now routes repository workflows through sj."
    print "      Translating 'git {git_cmd}' -> sj equivalent..."
    print ""

    val exit_code = translate_git_command(git_cmd, cmd_args)
    exit(exit_code)

fn translate_git_command(cmd: text, args: [text]) -> i64:
    """Translate git command to jj equivalent and execute it"""
    match cmd:
        "status":
            run_sj(["git", "status"] + args)

        "diff":
            run_sj(["git", "diff"] + args)

        "log":
            run_sj(["git", "log"] + args)

        "add":
            print "Note: jj auto-tracks files, no need to add"
            run_sj(["git", "status"])

        "commit":
            handle_commit(args)

        "push":
            run_sj(["git", "push"] + args)

        "pull", "fetch":
            run_sj(["raw", "jj", "git", "fetch"] + args)

        "checkout":
            run_sj(["git", "checkout"] + args)

        "branch":
            run_sj(["raw", "jj", "bookmark"] + args)

        "stash":
            print "Note: jj doesn't need stash - changes are always preserved"
            run_sj(["git", "stash"] + args)

        "init":
            run_sj(["raw", "jj", "git", "init"] + args)

        "clone":
            run_sj(["raw", "jj", "git", "clone"] + args)

        "show":
            run_sj(["raw", "jj", "show"] + args)

        "reset":
            print "Note: use 'jj restore' or 'jj abandon' instead of git reset"
            run_sj(["git", "reset"] + args)

        _:
            print "Unknown git command: {cmd}"
            print "Use sj directly. Common commands:"
            print "  sj git status, sj git diff, sj git log, sj git commit -m ..."
            print "  sj git push --bookmark main, sj raw jj git fetch, sj git checkout <rev>"
            1

fn handle_commit(args: [text]) -> i64:
    """Handle git commit command with -m flag parsing"""
    if args.len() == 0:
        return run_jj(["commit"])

    # Check for -m flag
    if args[0] == "-m":
        if args.len() > 1:
            # Combine message args
            val message_parts = args[1:]
            val message = message_parts.join(" ")
            return run_sj(["git", "commit", "-m", message])
        else:
            print "Error: -m requires a message"
            return 1

    # Pass through other args
    run_sj(["git", "commit"] + args)

fn run_sj(args: [text]) -> i64:
    val (stdout, stderr, code) = process_run("bin/simple", ["run", "src/app/sj/main.spl"] + args)

    if stdout.len() > 0:
        print stdout

    if stderr.len() > 0:
        print stderr

    code

fn run_jj(args: [text]) -> i64:
    """Run jj command and return exit code"""
    val (stdout, stderr, code) = process_run("jj", args)

    if stdout.len() > 0:
        print stdout

    if stderr.len() > 0:
        print stderr

    code

fn show_usage():
    """Show usage information"""
    print "Git-to-JJ Wrapper"
    print ""
    print "Usage: git_wrapper <git-command> [args...]"
    print ""
    print "This wrapper translates git commands to sj equivalents."
    print "Consider using sj directly instead:"
    print ""
    print "Common translations:"
    print "  git status        -> sj git status"
    print "  git diff          -> sj git diff"
    print "  git log           -> sj git log"
    print "  git add           -> (auto-tracked, use sj git status)"
    print "  git commit -m ... -> sj git commit -m ..."
    print "  git push          -> sj git push --bookmark <name>"
    print "  git pull/fetch    -> sj raw jj git fetch / sj git pull"
    print "  git checkout      -> sj git checkout"
    print "  git branch        -> sj raw jj bookmark"
    print "  git stash         -> sj git stash (forbidden with guidance)"
    print "  git reset         -> sj git reset"
