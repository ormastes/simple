# Simple LSP MCP - tool implementations
#
# Uses shared mcp_sdk for JSON, shell helpers, and tool result building.

use .json_helpers.{Q, LB, RB, SB_L, SB_R, jp, js, jo1, jo2, extract_field, escape_json, jsonrpc_result, jsonrpc_error, find_simple_binary, clean_command_output, strip_ansi, run_command_text, make_tool_result, make_tool_error, has_method, _char_at, _is_ws, _find_json_value_start}
use std.io_runtime.{process_run}
# Import process_run_timeout from the light std module, NOT app.io.mod — the
# latter is a CLI/compiler re-export hub whose graph makes `bin/simple run` skip
# main() (LSP MCP server never starts). See
# doc/08_tracking/bug/mcp_source_mode_large_import_graph_2026-06-23.md
use std.nogc_sync_mut.io.process_ops.{process_run_timeout}

fn lsp_query_path() -> text:
    "src/lib/nogc_sync_mut/lsp/lsp_query.spl"

fn query_visibility_path() -> text:
    "src/app/cli/query_visibility.spl"

fn run_lsp_query(subcmd: text, file: text, line0: i64, char0: i64) -> text:
    run_command_text(find_simple_binary(), [lsp_query_path(), subcmd, file, str(line0 + 1), str(char0 + 1)])

fn run_visibility_query(subcmd: text, file: text, line0: i64, char0: i64) -> text:
    run_command_text(find_simple_binary(), [query_visibility_path(), subcmd, file, str(line0 + 1), str(char0 + 1)])

fn run_lsp_symbols(file: text) -> text:
    run_visibility_symbols(file)

fn run_visibility_symbols(file: text) -> text:
    run_command_text(find_simple_binary(), [query_visibility_path(), "symbols", file, file])

fn run_lsp_diagnostics(file: text) -> text:
    # `simple check` is a CLI subcommand that spawns its own delegate child.
    # Spawning it from inside the interpreted LSP server (source mode) deadlocks
    # the no-GC interpreter's process_run wait (zombie child + parent stuck in
    # futex_wait) — a Rust-runtime bug, not fixable from .spl. To avoid hanging
    # the whole server, diagnostics is gated: it is skipped unless explicitly
    # enabled with SIMPLE_LSP_ENABLE_DIAGNOSTICS=1 (safe only for a native build
    # whose tools/call actually works — currently none does). The other 10 LSP
    # tools run a plain script via process_run and are unaffected.
    # See doc/08_tracking/bug/lsp_mcp_native_arg_extract_and_source_diagnostics_deadlock_2026-06-18.md
    val enabled = env_get("SIMPLE_LSP_ENABLE_DIAGNOSTICS") ?? ""
    if enabled != "1":
        return "diagnostics unavailable in source mode (process_run deadlocks on the `simple check` subcommand spawn). Run `simple check " + file + "` directly, or set SIMPLE_LSP_ENABLE_DIAGNOSTICS=1 on a working native build."
    val (stdout, stderr, code) = process_run_timeout(find_simple_binary(), ["check", file], 10000)
    val clean = clean_command_output(stdout)
    if code == 0:
        return clean
    if stderr.trim() != "":
        return stderr.trim()
    if clean != "":
        return clean
    "command failed with exit code " + str(code)

fn lsp_parse_diag_line(line: text) -> text:
    # Parses: path:line:col: error/warning: message
    val clean = strip_ansi(line)
    val trimmed = clean.trim()
    if trimmed == "":
        return ""

    var colon1 = -1
    var colon2 = -1
    var colon3 = -1
    var pos = 0
    for ch in trimmed:
        if ch == ":":
            if colon1 < 0:
                colon1 = pos
            elif colon2 < 0:
                colon2 = pos
            elif colon3 < 0:
                colon3 = pos
                break
        pos = pos + 1

    if colon3 < 0:
        return ""

    val line_str = trimmed.substring(colon1 + 1, colon2).trim()
    val col_str = trimmed.substring(colon2 + 1, colon3).trim()
    val line_num = parse_nonnegative_int_or_minus_one(line_str)
    if line_num < 0:
        return ""

    val after = trimmed.substring(colon3 + 1, trimmed.len()).trim()
    var severity = "Error"
    var message = after
    if after.starts_with("error"):
        severity = "Error"
        message = after.substring(5, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("warning"):
        severity = "Warning"
        message = after.substring(7, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("info"):
        severity = "Information"
        message = after.substring(4, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    elif after.starts_with("hint"):
        severity = "Hint"
        message = after.substring(4, after.len()).trim()
        if message.starts_with(":"):
            message = message.substring(1, message.len()).trim()
    else:
        return ""

    if message == "":
        message = after
    "  " + severity + " (line " + line_str + ", col " + col_str + "): " + message + " (simple-lint)"

fn format_lsp_diagnostics_block(file: text, raw: text) -> text:
    val lines = raw.split("\n")
    var entries: [text] = []
    var i = 0
    while i < lines.len():
        val formatted = lsp_parse_diag_line(lines[i])
        if formatted != "":
            entries.push(formatted)
        i = i + 1
    if entries.len() == 0:
        return ""
    "<new-diagnostics>\n" + file + ":\n" + entries.join("\n") + "\n</new-diagnostics>"

fn make_empty_list_result(id: text, key: text) -> text:
    jsonrpc_result(id, jo1(jp(key: key, value: "[]")))

fn handle_resources_list(id: text) -> text:
    make_empty_list_result(id: id, key: "resources")

fn handle_resource_templates_list(id: text) -> text:
    make_empty_list_result(id: id, key: "resourceTemplates")

fn handle_prompts_list(id: text) -> text:
    make_empty_list_result(id: id, key: "prompts")

fn handle_roots_list(id: text) -> text:
    val cwd = lsp_get_cwd()
    val root = jo2(
        p1: jp(key: "uri", value: js("file://" + cwd)),
        p2: jp(key: "name", value: js("workspace"))
    )
    jsonrpc_result(id, jo1(jp(key: "roots", value: "[" + root + "]")))

fn handle_logging_set_level(id: text, body: text) -> text:
    var level = "info"
    if body.contains("\"level\":\"debug\"") or body.contains("\"level\": \"debug\""):
        level = "debug"
    elif body.contains("\"level\":\"info\"") or body.contains("\"level\": \"info\""):
        level = "info"
    elif body.contains("\"level\":\"warn\"") or body.contains("\"level\": \"warn\""):
        level = "warn"
    elif body.contains("\"level\":\"error\"") or body.contains("\"level\": \"error\""):
        level = "error"
    jsonrpc_result(id, jo1(jp(key: "level", value: js(level))))

fn arg_field(args: text, key: text) -> text:
    # Manual scanner - avoids the Cranelift `match Some(i)` codegen bug.
    # _find_json_value_start already handles whitespace after the colon,
    # so the three original search variants (no-space, with-space,
    # numeric) collapse into a single call.
    val start = _find_json_value_start(json: args, key: key)
    if start < 0 or start >= args.len():
        return ""
    val first = _char_at(args, start)
    if first == Q():
        var i = start + 1
        var escaped = false
        while i < args.len():
            val ch = _char_at(args, i)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return args.substring(start + 1, i)
            i = i + 1
        return ""
    var end = start
    while end < args.len():
        val ch = _char_at(args, end)
        if ch == "," or ch == RB() or ch == "]" or _is_ws(ch):
            break
        end = end + 1
    args.substring(start, end)

fn _digit_val(ch: text) -> i64:
    # Explicit `==` match only. `text.to_int()` and text ordering (`>=`/`<=`)
    # both miscompile on the native-build path (see bug
    # lsp_mcp_integer_position_args_corrupted_2026-06-14), so integer args must
    # be parsed with `==` digit comparison exclusively. -1 = non-digit.
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    -1

fn arg_int_field(args: text, key: text) -> i64:
    # Extract + parse an integer field in one pass using only primitives proven
    # to compile correctly here (_find_json_value_start, _char_at, `==`). Avoids
    # the codegen-broken `.to_int()` round-trip that produced garbage line/char
    # values. Returns -1 when the field is absent or non-numeric.
    val start = _find_json_value_start(json: args, key: key)
    if start < 0 or start >= args.len():
        return -1
    var i = start
    if _char_at(args, i) == Q():
        i = i + 1
    var result = 0
    var seen = false
    while i < args.len():
        val d = _digit_val(_char_at(args, i))
        if d < 0:
            break
        result = result * 10 + d
        seen = true
        i = i + 1
    if not seen:
        return -1
    result

fn parse_nonnegative_int_or_minus_one(value: text) -> i64:
    var result = 0
    var seen = false
    for ch in value:
        val d = _digit_val(ch)
        if d < 0:
            return -1
        result = result * 10 + d
        seen = true
    if not seen:
        return -1
    result

fn detect_tool_name(body: text) -> text:
    val requested = arg_field(args: body, key: "name")
    if requested == "lsp_definition":
        return "lsp_definition"
    if requested == "lsp_references":
        return "lsp_references"
    if requested == "lsp_hover":
        return "lsp_hover"
    if requested == "lsp_symbols":
        return "lsp_symbols"
    if requested == "lsp_diagnostics":
        return "lsp_diagnostics"
    if requested == "lsp_completion":
        return "lsp_completion"
    if requested == "lsp_type_at":
        return "lsp_type_at"
    if requested == "lsp_signature_help":
        return "lsp_signature_help"
    if requested == "lsp_implementation":
        return "lsp_implementation"
    if requested == "lsp_document_highlight":
        return "lsp_document_highlight"
    if requested == "lsp_type_definition":
        return "lsp_type_definition"

    # Legacy direct-call clients may still put the tool name in method.
    # Original 5 tools
    if has_method(body, "lsp_definition"):
        return "lsp_definition"
    if has_method(body, "lsp_references"):
        return "lsp_references"
    if has_method(body, "lsp_hover"):
        return "lsp_hover"
    if has_method(body, "lsp_symbols"):
        return "lsp_symbols"
    if has_method(body, "lsp_diagnostics"):
        return "lsp_diagnostics"
    # New 6 tools
    if has_method(body, "lsp_completion"):
        return "lsp_completion"
    if has_method(body, "lsp_type_at"):
        return "lsp_type_at"
    if has_method(body, "lsp_signature_help"):
        return "lsp_signature_help"
    if has_method(body, "lsp_implementation"):
        return "lsp_implementation"
    if has_method(body, "lsp_document_highlight"):
        return "lsp_document_highlight"
    if has_method(body, "lsp_type_definition"):
        return "lsp_type_definition"
    ""

fn handle_tool_call(id: text, body: text) -> text:
    val tool_name = detect_tool_name(body)
    if tool_name == "":
        return make_tool_error(id, "Missing tool name")

    # Position-based tools (file + line + character)
    if tool_name == "lsp_definition" or tool_name == "lsp_references" or tool_name == "lsp_hover" or tool_name == "lsp_completion" or tool_name == "lsp_type_at" or tool_name == "lsp_signature_help" or tool_name == "lsp_implementation" or tool_name == "lsp_document_highlight" or tool_name == "lsp_type_definition":
        val file = arg_field(args: body, key: "file")
        val line0 = arg_int_field(args: body, key: "line")
        val char0 = arg_int_field(args: body, key: "character")
        if file == "" or line0 < 0 or char0 < 0:
            return make_tool_error(id, "Missing required argument: file/line/character")

        if tool_name == "lsp_definition":
            return make_tool_result(id, run_lsp_query(subcmd: "definition", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_references":
            return make_tool_result(id, run_lsp_query(subcmd: "references", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_hover":
            return make_tool_result(id, run_visibility_query(subcmd: "hover", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_completion":
            return make_tool_result(id, run_visibility_query(subcmd: "completions", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_type_at":
            return make_tool_result(id, run_lsp_query(subcmd: "type-at", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_signature_help":
            return make_tool_result(id, run_lsp_query(subcmd: "signature-help", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_implementation":
            return make_tool_result(id, run_lsp_query(subcmd: "implementation", file: file, line0: line0, char0: char0))
        if tool_name == "lsp_document_highlight":
            return make_tool_result(id, run_lsp_query(subcmd: "document-highlight", file: file, line0: line0, char0: char0))
        return make_tool_result(id, run_lsp_query(subcmd: "type-definition", file: file, line0: line0, char0: char0))

    # File-only tools
    if tool_name == "lsp_symbols" or tool_name == "lsp_diagnostics":
        val file = arg_field(args: body, key: "file")
        if file == "":
            return make_tool_error(id, "Missing required argument: file")
        if tool_name == "lsp_symbols":
            return make_tool_result(id, run_visibility_symbols(file))
        val raw = run_lsp_diagnostics(file)
        val diag_block = format_lsp_diagnostics_block(file: file, raw: raw)
        if diag_block != "":
            return make_tool_result(id, raw + "\n" + diag_block)
        return make_tool_result(id, raw)

    jsonrpc_error(id, -32602, "Unknown tool: " + tool_name)

fn lsp_get_cwd() -> text:
    val (stdout, _stderr, code) = process_run("/bin/sh", ["-c", "pwd"])
    if code == 0 and stdout.trim() != "":
        return stdout.trim()
    "."

export arg_field
export arg_int_field
export run_lsp_query
export run_visibility_query
export run_visibility_symbols
export run_lsp_diagnostics
export format_lsp_diagnostics_block
export handle_tool_call
export handle_resources_list
export handle_resource_templates_list
export handle_prompts_list
export handle_roots_list
export handle_logging_set_level
