# snpm configuration — registry URLs, cache paths, authentication

extern fn rt_env_get(key: text) -> text

class SnpmConfig:
    registry_url: text
    cache_dir: text
    modules_dir: text
    lockfile_name: text
    manifest_name: text
    auth_token: text

fn default_config() -> SnpmConfig:
    val home = rt_env_get("HOME")
    var cache = ".snpm/cache"
    if home != "" and home != nil:
        cache = "{home}/.snpm/cache"
    SnpmConfig(
        registry_url: "https://registry.simple-lang.org",
        cache_dir: cache,
        modules_dir: "spl_modules",
        lockfile_name: "snpm-lock.sdn",
        manifest_name: "package.sdn",
        auth_token: ""
    )
