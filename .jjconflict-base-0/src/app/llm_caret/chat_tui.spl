# LLM Caret - Interactive Chat TUI
#
# An interactive, full-screen chat shell for llm_caret built on the stdlib TUI
# framework (std.tui). It replaces the headless raw-print experience with a
# scrollable transcript panel (BoxWidget) + a prompt input line (InputWidget)
# + a status/hint line.
#
# Design:
#   - Pure formatting helpers (format_turn_line, format_tool_line,
#     tui_role_style, select_renderer_mode, ...) hold NO terminal state, so they
#     are unit-testable without a live terminal.
#   - The mutable transcript lives in module-level state (TUI_TRANSCRIPT), the
#     same idiom chat.spl uses for history. render_turn / render_tool_call
#     append styled lines to it.
#   - tui_tool_renderer is the renderer seam handed to
#     chat.run_agent_loop_rendered: when a TUI session is active, tool results
#     are drawn as styled transcript lines instead of raw prints.
#
# ponytail: assistant replies render after completion (non-streaming). std.tui
# has no incremental/streaming re-render primitive; token-by-token streaming is
# the upgrade path (would need a partial-line redraw during responder()).

use std.tui.terminal.*
use std.tui.style.*
use std.tui.widget.{Rect, make_rect, pad_or_truncate}
use std.tui.widgets.box_widget.{BoxWidget, make_box_widget_with_content, box_render}
use std.tui.widgets.input.{InputWidget, make_input_widget, input_insert_char,
                            input_delete_back, input_clear, input_render}

use app.llm_caret.types.{Message, new_user_message, new_assistant_message}
use app.llm_caret.tools.{ToolCall, ToolResult, ModelResponse, PermissionPolicy}
use app.llm_caret.chat.{AgentResult, run_agent_loop, run_agent_loop_rendered,
                        tool_call_status, tool_call_summary}

extern fn rt_env_get(key: text) -> text
extern fn rt_stdin_read_line() -> text

# ============================================================================
# Module-level session state
# ============================================================================

# Accumulated styled conversation lines (transcript panel contents).
var TUI_TRANSCRIPT: [StyledLine] = []
# Full message history threaded back into the model each turn (real multi-turn).
var TUI_CONV: [Message] = []

# ============================================================================
# ChatTui - owns the session's widgets (transcript panel title, prompt input,
# hint line). Turn/tool styling is applied by the free tui_role_style /
# tui_tool_style functions at render time, not stored on the struct.
# ============================================================================

struct ChatTui:
    title: text
    hint: text
    input: InputWidget

fn make_chat_tui(title: text) -> ChatTui:
    ChatTui(
        title: title,
        hint: " Enter=send   /exit=quit   Ctrl-C/Ctrl-D=abort ",
        input: make_input_widget("> ", fg_style(COLOR_WHITE))
    )

fn _ui_set_input(ui: ChatTui, inp: InputWidget) -> ChatTui:
    ChatTui(
        title: ui.title,
        hint: ui.hint,
        input: inp
    )

# ============================================================================
# Pure formatting helpers (no terminal state - unit-testable)
# ============================================================================

fn tui_role_label(role: text) -> text:
    if role == "user":
        return "You"
    if role == "assistant":
        return "Claude"
    role

fn format_turn_line(role: text, content: text) -> text:
    tui_role_label(role) + ": " + content

fn tui_role_style(role: text) -> Style:
    if role == "user":
        return make_style(COLOR_CYAN, COLOR_NONE, true, false, false, false)
    if role == "assistant":
        return fg_style(COLOR_GREEN)
    tui_default_style()

fn format_tool_line(name: text, status: text, summary: text) -> text:
    "  -> tool " + name + " [" + status + "]: " + summary

fn tui_tool_style(status: text) -> Style:
    if status == "error":
        return fg_style(COLOR_RED)
    fg_style(COLOR_YELLOW)

# Renderer-seam selection. The explicit flag is the PRIMARY gate; "auto" (the
# default) falls back to a tty probe.
#   ui_mode == "plain" -> always plain print path
#   ui_mode == "tui"   -> always the full-screen TUI
#   ui_mode == "auto"  -> TUI on a tty, plain otherwise
fn select_renderer_mode(ui_mode: text, is_tty: bool) -> text:
    if ui_mode == "plain":
        return "plain"
    if ui_mode == "tui":
        return "tui"
    if is_tty:
        return "tui"
    "plain"

# Best-effort tty probe. NOTE: the stdlib exposes no isatty extern; this mirrors
# cli_output/progress.spl and gates on $TERM. LIMITATION: $TERM is inherited even
# when stdout is piped, so "auto" can wrongly pick TUI under a pipe with $TERM
# set - always pass an explicit ui_mode ("plain"/"tui") in CI/servers.
fn caret_is_tty() -> bool:
    val term = rt_env_get("TERM")
    if term == nil or term == "" or term == "dumb":
        return false
    true

# ============================================================================
# Transcript state ops
# ============================================================================

fn tui_transcript_reset():
    TUI_TRANSCRIPT = []
    TUI_CONV = []

fn tui_transcript_len() -> i64:
    TUI_TRANSCRIPT.len()

fn _line_plain_text(line: StyledLine) -> text:
    var out = ""
    var i = 0
    while i < line.segments.len():
        out = out + line.segments[i].content
        i = i + 1
    out

# Plain (ANSI-stripped) text of a transcript line - used by tests to assert on
# content without decoding escape codes.
fn tui_transcript_line_text(idx: i64) -> text:
    if idx < 0 or idx >= TUI_TRANSCRIPT.len():
        return ""
    _line_plain_text(TUI_TRANSCRIPT[idx])

# Append a styled conversation turn (user vs assistant visually distinct).
fn render_turn(role: text, content: text):
    val line = make_styled_line(format_turn_line(role, content), tui_role_style(role))
    TUI_TRANSCRIPT = TUI_TRANSCRIPT + [line]

# Append a styled tool-call line. This is what replaces the raw print that was
# at chat.spl:172 when a TUI session is active.
fn render_tool_call(name: text, status: text, summary: text):
    val line = make_styled_line(format_tool_line(name, status, summary), tui_tool_style(status))
    TUI_TRANSCRIPT = TUI_TRANSCRIPT + [line]

# The renderer seam handed to run_agent_loop_rendered. Signature matches the
# `on_tool: fn(ToolCall, ToolResult)` parameter.
fn tui_tool_renderer(call: ToolCall, result: ToolResult):
    render_tool_call(call.name, tool_call_status(result), tool_call_summary(result))

# ============================================================================
# Frame rendering
# ============================================================================

fn _visible_content(inner_h: i64) -> [StyledLine]:
    var lines: [StyledLine] = []
    var start = 0
    if TUI_TRANSCRIPT.len() > inner_h:
        start = TUI_TRANSCRIPT.len() - inner_h
    var i = start
    while i < TUI_TRANSCRIPT.len():
        lines = lines + [TUI_TRANSCRIPT[i]]
        i = i + 1
    lines

fn _draw_frame(ui: ChatTui):
    terminal_clear_screen()
    val size = terminal_get_size()
    val cols = size.cols
    val rows = size.rows
    var box_h = rows - 2
    if box_h < 3:
        box_h = 3
    val inner_h = box_h - 2
    val content = _visible_content(inner_h)
    val box = make_box_widget_with_content(ui.title, fg_style(COLOR_CYAN), content)
    val box_area = make_rect(0, 0, cols, box_h)
    val box_lines = box_render(box, box_area)
    var i = 0
    while i < box_lines.len():
        terminal_draw_at(i, 0, render_line(box_lines[i]))
        i = i + 1
    val input_area = make_rect(0, box_h, cols, 1)
    val input_lines = input_render(ui.input, input_area)
    if input_lines.len() > 0:
        terminal_draw_at(box_h, 0, render_line(input_lines[0]))
    val hint_style = make_style(COLOR_NONE, COLOR_NONE, false, false, false, true)
    terminal_draw_at(box_h + 1, 0, styled(pad_or_truncate(ui.hint, cols), hint_style))
    terminal_flush()

# ============================================================================
# Interactive line reader (raw mode, byte-at-a-time)
# ============================================================================

# Reads one prompt line, redrawing the frame on each keystroke. Returns the
# (updated ui, submitted text, status) where status: 0 = line submitted,
# 1 = exit requested (Ctrl-C / Ctrl-D / EOF).
fn _read_line(ui0: ChatTui) -> (ChatTui, text, i64):
    var ui = ui0
    var done = false
    var result_text = ""
    var status = 1
    while not done:
        _draw_frame(ui)
        val b = terminal_read_byte()
        if b < 0 or b == KEY_CTRL_C or b == KEY_CTRL_D:
            status = 1
            done = true
        elif b == KEY_ENTER or b == 10:
            result_text = ui.input.value
            status = 0
            done = true
        elif b == KEY_BACKSPACE or b == 8:
            ui = _ui_set_input(ui, input_delete_back(ui.input))
        elif b >= 32 and b <= 126:
            ui = _ui_set_input(ui, input_insert_char(ui.input, (b as char).to_text()))
    (ui, result_text, status)

# ============================================================================
# Interactive loop
# ============================================================================

# The full-screen interactive chat loop. Sets up the alt screen + raw mode per
# editor/tui_shell.spl, reads a prompt, runs one agent turn (threading the whole
# conversation for real multi-turn), renders the reply + any tool-call lines,
# and loops until /exit or Ctrl-C/Ctrl-D. Restores the terminal on exit.
#
# ponytail: teardown runs after the loop (Simple has no try/finally and no
# throwing by design). A hard runtime panic mid-loop could leave raw mode on;
# acceptable for a minimal shell.
fn run_chat_tui(ui0: ChatTui, policy: PermissionPolicy, responder: fn([Message]) -> ModelResponse):
    tui_transcript_reset()
    terminal_enter_alt_screen()
    terminal_enter_raw_mode()
    terminal_hide_cursor()
    var ui = ui0
    var running = true
    while running:
        val rl = _read_line(ui)
        ui = rl.0
        val submitted = rl.1
        val status = rl.2
        if status == 1:
            running = false
        else:
            val trimmed = submitted.trim()
            if trimmed == "/exit" or trimmed == "/quit":
                running = false
            elif trimmed == "":
                ui = _ui_set_input(ui, input_clear(ui.input))
            else:
                render_turn("user", trimmed)
                TUI_CONV = TUI_CONV + [new_user_message(trimmed)]
                # ponytail: past-turn tool_result plumbing is not threaded back
                # into TUI_CONV (only user/assistant text is); fine for a shell.
                val result = run_agent_loop_rendered(policy, TUI_CONV, responder, 25, tui_tool_renderer)
                TUI_CONV = TUI_CONV + [new_assistant_message(result.final_text)]
                render_turn("assistant", result.final_text)
                ui = _ui_set_input(ui, input_clear(ui.input))
    terminal_show_cursor()
    terminal_exit_raw_mode()
    terminal_exit_alt_screen()
    print "chat session ended"

# ============================================================================
# Plain fallback loop (non-tty: piped / CI / server)
# ============================================================================

fn run_chat_plain(policy: PermissionPolicy, responder: fn([Message]) -> ModelResponse):
    var conv: [Message] = []
    var running = true
    while running:
        print "> "
        val line = rt_stdin_read_line() ?? ""
        val trimmed = line.trim()
        # Empty line == EOF on a drained pipe -> exit. Explicit /exit too.
        if trimmed == "" or trimmed == "/exit" or trimmed == "/quit":
            running = false
        else:
            conv = conv + [new_user_message(trimmed)]
            val result = run_agent_loop(policy, conv, responder, 25)
            conv = conv + [new_assistant_message(result.final_text)]
            print "Claude: " + result.final_text

# ============================================================================
# Top-level entry: pick TUI vs plain per flag/tty
# ============================================================================

# Interactive chat entry point. `ui_mode` is "auto" (default), "tui", or
# "plain". TUI is the default for interactive TTY use; non-tty falls back to the
# plain print path so piped/CI/server output is not ANSI-corrupted.
fn caret_chat(ui: ChatTui, policy: PermissionPolicy, responder: fn([Message]) -> ModelResponse, ui_mode: text):
    val mode = select_renderer_mode(ui_mode, caret_is_tty())
    if mode == "tui":
        run_chat_tui(ui, policy, responder)
    else:
        run_chat_plain(policy, responder)
