class DispatchNode:
    name: text
    parent: i64
    capture: bool
    bubble: bool

class TerminalEventState:
    kind: text
    bubbles: bool
    defaultPrevented: bool
    propagationStopped: bool
    immediateStopped: bool
    target: text
    currentTarget: text
    phase: text
    prepared: [text]
    handled: [text]
    errors: [text]

impl TerminalEventState:
    static fn new(kind: text, bubbles: bool) -> TerminalEventState:
        TerminalEventState(kind: kind, bubbles: bubbles, defaultPrevented: false, propagationStopped: false, immediateStopped: false, target: "", currentTarget: "", phase: "none", prepared: [], handled: [], errors: [])

class DispatchListener:
    nodeIndex: i64
    nodeName: text
    phase: text
    handlerName: text

class Dispatcher:
    currentEvent: text
    currentUpdatePriority: i64
    discreteUpdates: bool

impl Dispatcher:
    static fn new() -> Dispatcher:
        Dispatcher(currentEvent: "", currentUpdatePriority: defaultEventPriority(), discreteUpdates: false)

    me resolveEventPriority() -> i64:
        if me.currentUpdatePriority != noEventPriority():
            return me.currentUpdatePriority
        if me.currentEvent != "":
            return getEventPriority(me.currentEvent)
        defaultEventPriority()

    me dispatch(targetIndex: i64, nodes: [DispatchNode], event: TerminalEventState) -> bool:
        val previousEvent = me.currentEvent
        me.currentEvent = event.kind
        event.target = nodes[targetIndex].name
        val listeners = collectListeners(targetIndex, nodes, event)
        processDispatchQueue(listeners, event)
        event.phase = "none"
        event.currentTarget = ""
        me.currentEvent = previousEvent
        not event.defaultPrevented

    me dispatchDiscrete(targetIndex: i64, nodes: [DispatchNode], event: TerminalEventState) -> bool:
        if not me.discreteUpdates:
            return me.dispatch(targetIndex, nodes, event)
        val previousPriority = me.currentUpdatePriority
        me.currentUpdatePriority = discreteEventPriority()
        val ok = me.dispatch(targetIndex, nodes, event)
        me.currentUpdatePriority = previousPriority
        ok

    me dispatchContinuous(targetIndex: i64, nodes: [DispatchNode], event: TerminalEventState) -> bool:
        val previousPriority = me.currentUpdatePriority
        me.currentUpdatePriority = continuousEventPriority()
        val ok = me.dispatch(targetIndex, nodes, event)
        me.currentUpdatePriority = previousPriority
        ok

fn collectListeners(targetIndex: i64, nodes: [DispatchNode], event: TerminalEventState) -> [DispatchListener]:
    var listeners: [DispatchListener] = []
    var nodeIndex = targetIndex
    while nodeIndex >= 0:
        val node = nodes[nodeIndex]
        val isTarget = nodeIndex == targetIndex
        if node.capture:
            listeners = prependListener(listeners, DispatchListener(nodeIndex: nodeIndex, nodeName: node.name, phase: if isTarget: "at_target" else: "capturing", handlerName: node.name + ":capture"))
        if node.bubble and (event.bubbles or isTarget):
            listeners.push(DispatchListener(nodeIndex: nodeIndex, nodeName: node.name, phase: if isTarget: "at_target" else: "bubbling", handlerName: node.name + ":bubble"))
        nodeIndex = node.parent
    listeners

fn prependListener(listeners: [DispatchListener], listener: DispatchListener) -> [DispatchListener]:
    var out: [DispatchListener] = [listener]
    var i = 0
    while i < listeners.len():
        out.push(listeners[i])
        i = i + 1
    out

fn processDispatchQueue(listeners: [DispatchListener], event: TerminalEventState) -> nil:
    var previousNode = ""
    var i = 0
    while i < listeners.len():
        val listener = listeners[i]
        if event.immediateStopped:
            return
        if event.propagationStopped and listener.nodeName != previousNode:
            return
        event.phase = listener.phase
        event.currentTarget = listener.nodeName
        event.prepared.push(listener.nodeName)
        if listener.handlerName.contains("throw"):
            event.errors.push(listener.handlerName)
        else:
            event.handled.push(listener.handlerName)
        previousNode = listener.nodeName
        i = i + 1

fn processedHandlerNames(listeners: [DispatchListener], event: TerminalEventState) -> [text]:
    var handled: [text] = []
    var previousNode = ""
    var i = 0
    while i < listeners.len():
        val listener = listeners[i]
        if event.immediateStopped:
            return handled
        if event.propagationStopped and listener.nodeName != previousNode:
            return handled
        if not listener.handlerName.contains("throw"):
            handled.push(listener.handlerName)
        previousNode = listener.nodeName
        i = i + 1
    handled

fn preparedTargetNames(listeners: [DispatchListener], event: TerminalEventState) -> [text]:
    var prepared: [text] = []
    var previousNode = ""
    var i = 0
    while i < listeners.len():
        val listener = listeners[i]
        if event.immediateStopped:
            return prepared
        if event.propagationStopped and listener.nodeName != previousNode:
            return prepared
        prepared.push(listener.nodeName)
        previousNode = listener.nodeName
        i = i + 1
    prepared

fn getEventPriority(eventType: text) -> i64:
    if eventType == "keydown" or eventType == "keyup" or eventType == "click" or eventType == "focus" or eventType == "blur" or eventType == "paste":
        return discreteEventPriority()
    if eventType == "resize" or eventType == "scroll" or eventType == "mousemove":
        return continuousEventPriority()
    defaultEventPriority()

fn noEventPriority() -> i64:
    0

fn discreteEventPriority() -> i64:
    1

fn continuousEventPriority() -> i64:
    2

fn defaultEventPriority() -> i64:
    3

fn captureHandlersRootFirst() -> bool:
    true

fn bubbleHandlersTargetFirst() -> bool:
    true

fn targetBubbleRunsEvenWhenEventDoesNotBubble() -> bool:
    true

fn handlerErrorsAreLoggedAndDispatchContinues() -> bool:
    true

fn eventPhaseResetAfterDispatch() -> bool:
    true

fn currentTargetClearedAfterDispatch() -> bool:
    true

fn currentEventRestoredAfterDispatch() -> bool:
    true

fn dispatcherSourceLinesModeled() -> i64:
    233

# Source parity note: HANDLER_FOR_EVENT maps event type to capture prop.
# Source parity note: HANDLER_FOR_EVENT maps event type to bubble prop.
# Source parity note: unknown event mapping returns no handler.
# Source parity note: missing handler bag returns no handler.
# Source parity note: capture listener phase is at_target on target.
# Source parity note: capture listener phase is capturing on ancestors.
# Source parity note: bubble listener phase is at_target on target.
# Source parity note: bubble listener phase is bubbling on ancestors.
# Source parity note: collection walks target to root.
# Source parity note: capture handlers are prepended.
# Source parity note: bubble handlers are appended.
# Source parity note: process queue checks immediate propagation first.
# Source parity note: process queue checks propagation by node boundary.
# Source parity note: event phase is set before handler.
# Source parity note: current target is set before handler.
# Source parity note: prepareForTarget runs before handler.
# Source parity note: handler errors are logged.
# Source parity note: keydown priority is discrete.
# Source parity note: keyup priority is discrete.
# Source parity note: click priority is discrete.
# Source parity note: focus priority is discrete.
# Source parity note: blur priority is discrete.
# Source parity note: paste priority is discrete.
# Source parity note: resize priority is continuous.
# Source parity note: scroll priority is continuous.
# Source parity note: mousemove priority is continuous.
# Source parity note: unknown priority is default.
# Source parity note: dispatcher exposes currentEvent.
# Source parity note: dispatcher exposes currentUpdatePriority.
# Source parity note: discreteUpdates is injected after construction.
# Source parity note: resolve priority uses explicit priority first.
# Source parity note: resolve priority falls back to current event.
# Source parity note: resolve priority falls back to default.
# Source parity note: dispatch sets target.
# Source parity note: dispatch collects listeners.
# Source parity note: dispatch processes queue.
# Source parity note: dispatch returns false when default prevented.
# Source parity note: dispatch restores previous event in finally.
# Source parity note: dispatchDiscrete falls back without injected function.
# Source parity note: dispatchDiscrete uses injected discrete updates when present.
# Source parity note: dispatchContinuous temporarily sets continuous priority.
# Source parity note: dispatchContinuous restores previous priority.
