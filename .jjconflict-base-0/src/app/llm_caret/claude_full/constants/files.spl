fn binaryExtensions() -> [text]:
    [".png", ".jpg", ".jpeg", ".gif", ".bmp", ".ico", ".webp", ".tiff", ".tif", ".mp4", ".mov", ".avi", ".mkv", ".webm", ".wmv", ".flv", ".m4v", ".mpeg", ".mpg", ".mp3", ".wav", ".ogg", ".flac", ".aac", ".m4a", ".wma", ".aiff", ".opus", ".zip", ".tar", ".gz", ".bz2", ".7z", ".rar", ".xz", ".z", ".tgz", ".iso", ".exe", ".dll", ".so", ".dylib", ".bin", ".o", ".a", ".obj", ".lib", ".app", ".msi", ".deb", ".rpm", ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".odt", ".ods", ".odp", ".ttf", ".otf", ".woff", ".woff2", ".eot", ".pyc", ".pyo", ".class", ".jar", ".war", ".ear", ".node", ".wasm", ".rlib", ".sqlite", ".sqlite3", ".db", ".mdb", ".idx", ".psd", ".ai", ".eps", ".sketch", ".fig", ".xd", ".blend", ".3ds", ".max", ".swf", ".fla", ".lockb", ".dat", ".data"]

fn containsBinaryExtension(value: text) -> bool:
    val extensions = binaryExtensions()
    var i = 0
    while i < extensions.len():
        if extensions[i] == value:
            return true
        i = i + 1
    false

fn hasBinaryExtension(filePath: text) -> bool:
    val dot = filePath.rfind(".")
    if dot == nil:
        return false
    containsBinaryExtension(filePath.slice(dot).lower())

val BINARY_CHECK_SIZE: i64 = 8192

fn isBinaryContentBytes(buffer: [i64]) -> bool:
    var checkSize = buffer.len()
    if checkSize > BINARY_CHECK_SIZE:
        checkSize = BINARY_CHECK_SIZE
    if checkSize == 0:
        return false
    var nonPrintable = 0
    var i = 0
    while i < checkSize:
        val byte = buffer[i]
        if byte == 0:
            return true
        if byte < 32 and byte != 9 and byte != 10 and byte != 13:
            nonPrintable = nonPrintable + 1
        i = i + 1
    nonPrintable * 10 > checkSize
