"""
Claude full HooksConfigMenu parity model.
"""

class HookConfig:
    id: text
    name: text
    event: text
    matcher: text
    mode: text
    prompt: text
    enabled: bool
    source: text

impl HookConfig:
    static fn new(id: text, name: text, event: text, matcher: text, mode: text, prompt: text, enabled: bool, source: text) -> HookConfig:
        HookConfig(id: normalizeHookId(id), name: name.trim(), event: normalizeHookEvent(event), matcher: normalizeHookMatcher(matcher), mode: normalizeHookMode(mode), prompt: prompt.trim(), enabled: enabled, source: normalizeHookSource(source))

    me title() -> text:
        if me.name.trim() != "":
            return me.name.trim()
        me.event + " " + me.matcher

    me statusLabel() -> text:
        if me.enabled:
            return "enabled"
        "disabled"

    me matches(query: text, eventFilter: text, matcherFilter: text, modeFilter: text) -> bool:
        if not hookEventMatches(me.event, eventFilter):
            return false
        if not hookMatcherMatches(me.matcher, matcherFilter):
            return false
        if not hookModeMatches(me.mode, modeFilter):
            return false
        val q = normalizeHookQuery(query)
        if q == "":
            return true
        me.id.lower().contains(q) or me.title().lower().contains(q) or me.event.lower().contains(q) or me.matcher.lower().contains(q) or me.mode.lower().contains(q) or me.prompt.lower().contains(q) or me.source.lower().contains(q)

    me validationMessage() -> text:
        validateHookConfig(me)

    me valid() -> bool:
        me.validationMessage() == ""

class HookConfigRow:
    hook: HookConfig
    index: i64
    selected: bool
    validation: text

impl HookConfigRow:
    static fn new(hook: HookConfig, index: i64, selected: bool) -> HookConfigRow:
        HookConfigRow(hook: hook, index: index, selected: selected, validation: validateHookConfig(hook))

    me marker() -> text:
        if me.selected:
            return ">"
        " "

    me summary() -> text:
        renderHookConfigRow(me)

class HookConfigGroup:
    event: text
    label: text
    rows: [HookConfigRow]
    enabledCount: i64
    disabledCount: i64
    invalidCount: i64

impl HookConfigGroup:
    static fn new(event: text, rows: [HookConfigRow]) -> HookConfigGroup:
        HookConfigGroup(event: normalizeHookEvent(event), label: hookEventLabel(event), rows: rows, enabledCount: countEnabledHookRows(rows), disabledCount: countDisabledHookRows(rows), invalidCount: countInvalidHookRows(rows))

    me summary() -> text:
        me.label + " " + me.enabledCount.to_text() + " enabled, " + me.disabledCount.to_text() + " disabled, " + me.invalidCount.to_text() + " invalid"

class HookPromptDialog:
    isOpen: bool
    hookId: text
    title: text
    value: text
    error: text

impl HookPromptDialog:
    static fn new(isOpen: bool, hookId: text, title: text, value: text, error: text) -> HookPromptDialog:
        HookPromptDialog(isOpen: isOpen, hookId: normalizeHookId(hookId), title: title.trim(), value: value, error: error.trim())

    static fn closed() -> HookPromptDialog:
        HookPromptDialog.new(false, "", "", "", "")

    static fn open(hook: HookConfig) -> HookPromptDialog:
        HookPromptDialog.new(true, hook.id, "Edit prompt for " + hook.title(), hook.prompt, "")

    me withValue(value: text) -> HookPromptDialog:
        HookPromptDialog.new(me.isOpen, me.hookId, me.title, value, "")

    me fail(message: text) -> HookPromptDialog:
        HookPromptDialog.new(me.isOpen, me.hookId, me.title, me.value, message)

class HooksConfigMenuState:
    isOpen: bool
    query: text
    eventFilter: text
    matcherFilter: text
    modeFilter: text
    selectedIndex: i64
    loading: bool
    error: text
    promptDialog: HookPromptDialog
    lastAction: text

impl HooksConfigMenuState:
    static fn new(isOpen: bool, query: text, eventFilter: text, matcherFilter: text, modeFilter: text, selectedIndex: i64, loading: bool, error: text, promptDialog: HookPromptDialog, lastAction: text) -> HooksConfigMenuState:
        HooksConfigMenuState(isOpen: isOpen, query: query, eventFilter: normalizeHookEventFilter(eventFilter), matcherFilter: normalizeHookMatcherFilter(matcherFilter), modeFilter: normalizeHookModeFilter(modeFilter), selectedIndex: selectedIndex, loading: loading, error: error.trim(), promptDialog: promptDialog, lastAction: lastAction)

    static fn closed() -> HooksConfigMenuState:
        HooksConfigMenuState.new(false, "", "all", "all", "all", 0, false, "", HookPromptDialog.closed(), "")

    me open() -> HooksConfigMenuState:
        HooksConfigMenuState.new(true, me.query, me.eventFilter, me.matcherFilter, me.modeFilter, me.selectedIndex, me.loading, me.error, me.promptDialog, "open")

    me close() -> HooksConfigMenuState:
        HooksConfigMenuState.new(false, me.query, me.eventFilter, me.matcherFilter, me.modeFilter, me.selectedIndex, me.loading, me.error, HookPromptDialog.closed(), "close")

    me withQuery(query: text) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, query, me.eventFilter, me.matcherFilter, me.modeFilter, 0, me.loading, me.error, me.promptDialog, "query")

    me withEventFilter(eventFilter: text) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, eventFilter, me.matcherFilter, me.modeFilter, 0, me.loading, me.error, me.promptDialog, "event-filter")

    me withMatcherFilter(matcherFilter: text) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, me.eventFilter, matcherFilter, me.modeFilter, 0, me.loading, me.error, me.promptDialog, "matcher-filter")

    me withModeFilter(modeFilter: text) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, me.eventFilter, me.matcherFilter, modeFilter, 0, me.loading, me.error, me.promptDialog, "mode-filter")

    me withSelectedIndex(selectedIndex: i64) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, me.eventFilter, me.matcherFilter, me.modeFilter, selectedIndex, me.loading, me.error, me.promptDialog, "select")

    me withLoading(loading: bool) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, me.eventFilter, me.matcherFilter, me.modeFilter, me.selectedIndex, loading, "", me.promptDialog, "loading")

    me withError(error: text) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, me.eventFilter, me.matcherFilter, me.modeFilter, me.selectedIndex, false, error, me.promptDialog, "error")

    me withPromptDialog(promptDialog: HookPromptDialog, action: text) -> HooksConfigMenuState:
        HooksConfigMenuState.new(me.isOpen, me.query, me.eventFilter, me.matcherFilter, me.modeFilter, me.selectedIndex, me.loading, me.error, promptDialog, action)

class HooksConfigMenuModel:
    hooks: [HookConfig]
    state: HooksConfigMenuState

impl HooksConfigMenuModel:
    static fn new(hooks: [HookConfig], state: HooksConfigMenuState) -> HooksConfigMenuModel:
        HooksConfigMenuModel(hooks: hooks, state: normalizeHooksConfigState(hooks, state))

    me open() -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.open())

    me close() -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.close())

    me query(query: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withQuery(query))

    me eventFilter(eventFilter: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withEventFilter(eventFilter))

    me matcherFilter(matcherFilter: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withMatcherFilter(matcherFilter))

    me modeFilter(modeFilter: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withModeFilter(modeFilter))

    me loading() -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withLoading(true))

    me fail(error: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withError(error))

    me rows() -> [HookConfigRow]:
        hookConfigRows(me.hooks, me.state)

    me groups() -> [HookConfigGroup]:
        groupHookConfigRows(me.rows())

    me selectedHook() -> HookConfig?:
        selectedHookConfig(me.hooks, me.state)

    me toggleSelected() -> HooksConfigMenuModel:
        toggleSelectedHookConfig(me)

    me openPromptForSelected() -> HooksConfigMenuModel:
        openPromptForSelectedHook(me)

    me updatePrompt(value: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, me.state.withPromptDialog(me.state.promptDialog.withValue(value), "prompt-input"))

    me applyPrompt() -> HooksConfigMenuModel:
        applyHookPromptDialog(me)

    me handleKey(key: text) -> HooksConfigMenuModel:
        HooksConfigMenuModel.new(me.hooks, hookConfigHandleKey(me.hooks, me.state, key))

    me summary() -> text:
        hooksConfigSummary(me.hooks, me.state)

    me render() -> text:
        renderHooksConfigMenu(me.hooks, me.state)

fn sampleHookConfigs() -> [HookConfig]:
    [
        HookConfig.new("pre-bash-format", "Format Bash command", "PreToolUse", "Bash", "project", "Run shellcheck before executing the tool.", true, "project"),
        HookConfig.new("post-edit-tests", "Run focused tests", "PostToolUse", "Edit", "user", "Run the focused test for edited files.", true, "user"),
        HookConfig.new("notify-stop", "Notify on stop", "Stop", "*", "local", "Show a desktop notification when Claude stops.", false, "local"),
        HookConfig.new("submit-summary", "Submit transcript summary", "Submit", "prompt", "project", "Append a short task summary before sending.", true, "project")
    ]

fn createHooksConfigMenu(hooks: [HookConfig]) -> HooksConfigMenuModel:
    HooksConfigMenuModel.new(hooks, HooksConfigMenuState.closed())

fn openHooksConfigMenu(hooks: [HookConfig]) -> HooksConfigMenuModel:
    createHooksConfigMenu(hooks).open()

fn normalizeHooksConfigState(hooks: [HookConfig], state: HooksConfigMenuState) -> HooksConfigMenuState:
    val rows = hookConfigRowsForFilters(hooks, state.query, state.eventFilter, state.matcherFilter, state.modeFilter)
    if rows.len() == 0:
        return HooksConfigMenuState.new(state.isOpen, state.query, state.eventFilter, state.matcherFilter, state.modeFilter, 0, state.loading, state.error, state.promptDialog, state.lastAction)
    HooksConfigMenuState.new(state.isOpen, state.query, state.eventFilter, state.matcherFilter, state.modeFilter, clampHookConfigIndex(state.selectedIndex, rows.len()), state.loading, state.error, state.promptDialog, state.lastAction)

fn hookConfigRows(hooks: [HookConfig], state: HooksConfigMenuState) -> [HookConfigRow]:
    val visible = hookConfigRowsForFilters(hooks, state.query, state.eventFilter, state.matcherFilter, state.modeFilter)
    val selected = clampHookConfigIndex(state.selectedIndex, visible.len())
    var rows: [HookConfigRow] = []
    var i = 0
    while i < visible.len():
        rows.push(HookConfigRow.new(visible[i], i, i == selected))
        i = i + 1
    rows

fn hookConfigRowsForFilters(hooks: [HookConfig], query: text, eventFilter: text, matcherFilter: text, modeFilter: text) -> [HookConfig]:
    sortHookConfigs(filterHookConfigs(hooks, query, eventFilter, matcherFilter, modeFilter))

fn filterHookConfigs(hooks: [HookConfig], query: text, eventFilter: text, matcherFilter: text, modeFilter: text) -> [HookConfig]:
    var out: [HookConfig] = []
    var i = 0
    while i < hooks.len():
        if hooks[i].matches(query, eventFilter, matcherFilter, modeFilter):
            out.push(hooks[i])
        i = i + 1
    out

fn sortHookConfigs(hooks: [HookConfig]) -> [HookConfig]:
    var out = hooks
    var changed = true
    while changed:
        changed = false
        var i = 0
        while i + 1 < out.len():
            if hookConfigSortKey(out[i + 1]) < hookConfigSortKey(out[i]):
                val tmp = out[i]
                out[i] = out[i + 1]
                out[i + 1] = tmp
                changed = true
            i = i + 1
    out

fn hookConfigSortKey(hook: HookConfig) -> text:
    hook.event + "|" + hook.matcher.lower() + "|" + hook.title().lower() + "|" + hook.id.lower()

fn groupHookConfigRows(rows: [HookConfigRow]) -> [HookConfigGroup]:
    var groups: [HookConfigGroup] = []
    groups = appendHookConfigGroup(rows, groups, "PreToolUse")
    groups = appendHookConfigGroup(rows, groups, "PostToolUse")
    groups = appendHookConfigGroup(rows, groups, "Notification")
    groups = appendHookConfigGroup(rows, groups, "Stop")
    groups = appendHookConfigGroup(rows, groups, "SubagentStop")
    groups = appendHookConfigGroup(rows, groups, "PreCompact")
    groups = appendHookConfigGroup(rows, groups, "SessionStart")
    groups = appendHookConfigGroup(rows, groups, "Submit")
    groups

fn appendHookConfigGroup(rows: [HookConfigRow], groups: [HookConfigGroup], event: text) -> [HookConfigGroup]:
    var out = groups
    val groupRows = hookRowsForEvent(rows, event)
    if groupRows.len() > 0:
        out.push(HookConfigGroup.new(event, groupRows))
    out

fn hookRowsForEvent(rows: [HookConfigRow], event: text) -> [HookConfigRow]:
    val normalized = normalizeHookEvent(event)
    var out: [HookConfigRow] = []
    var i = 0
    while i < rows.len():
        if rows[i].hook.event == normalized:
            out.push(rows[i])
        i = i + 1
    out

fn countEnabledHookRows(rows: [HookConfigRow]) -> i64:
    var count = 0
    var i = 0
    while i < rows.len():
        if rows[i].hook.enabled:
            count = count + 1
        i = i + 1
    count

fn countDisabledHookRows(rows: [HookConfigRow]) -> i64:
    rows.len() - countEnabledHookRows(rows)

fn countInvalidHookRows(rows: [HookConfigRow]) -> i64:
    var count = 0
    var i = 0
    while i < rows.len():
        if rows[i].validation != "":
            count = count + 1
        i = i + 1
    count

fn selectedHookConfig(hooks: [HookConfig], state: HooksConfigMenuState) -> HookConfig?:
    val visible = hookConfigRowsForFilters(hooks, state.query, state.eventFilter, state.matcherFilter, state.modeFilter)
    if visible.len() == 0:
        return nil
    visible[clampHookConfigIndex(state.selectedIndex, visible.len())]

fn toggleSelectedHookConfig(model: HooksConfigMenuModel) -> HooksConfigMenuModel:
    val visible = hookConfigRowsForFilters(model.hooks, model.state.query, model.state.eventFilter, model.state.matcherFilter, model.state.modeFilter)
    if visible.len() > 0:
        val hook = visible[clampHookConfigIndex(model.state.selectedIndex, visible.len())]
        return HooksConfigMenuModel.new(toggleHookConfig(model.hooks, hook.id), HooksConfigMenuState.new(model.state.isOpen, model.state.query, model.state.eventFilter, model.state.matcherFilter, model.state.modeFilter, model.state.selectedIndex, model.state.loading, model.state.error, model.state.promptDialog, "toggle"))
    HooksConfigMenuModel.new(model.hooks, model.state)

fn toggleHookConfig(hooks: [HookConfig], id: text) -> [HookConfig]:
    var out: [HookConfig] = []
    val normalized = normalizeHookId(id)
    var i = 0
    while i < hooks.len():
        if hooks[i].id == normalized:
            out.push(HookConfig.new(hooks[i].id, hooks[i].name, hooks[i].event, hooks[i].matcher, hooks[i].mode, hooks[i].prompt, not hooks[i].enabled, hooks[i].source))
        else:
            out.push(hooks[i])
        i = i + 1
    out

fn openPromptForSelectedHook(model: HooksConfigMenuModel) -> HooksConfigMenuModel:
    val visible = hookConfigRowsForFilters(model.hooks, model.state.query, model.state.eventFilter, model.state.matcherFilter, model.state.modeFilter)
    if visible.len() > 0:
        val hook = visible[clampHookConfigIndex(model.state.selectedIndex, visible.len())]
        return HooksConfigMenuModel.new(model.hooks, model.state.withPromptDialog(HookPromptDialog.open(hook), "prompt-open"))
    HooksConfigMenuModel.new(model.hooks, model.state.withPromptDialog(HookPromptDialog.new(true, "", "Edit hook prompt", "", "Select a hook first"), "prompt-open"))

fn applyHookPromptDialog(model: HooksConfigMenuModel) -> HooksConfigMenuModel:
    val dialog = model.state.promptDialog
    if not dialog.isOpen:
        return model
    val value = dialog.value.trim()
    if dialog.hookId == "":
        return HooksConfigMenuModel.new(model.hooks, model.state.withPromptDialog(dialog.fail("Select a hook first"), "prompt-error"))
    if value == "":
        return HooksConfigMenuModel.new(model.hooks, model.state.withPromptDialog(dialog.fail("Prompt cannot be empty"), "prompt-error"))
    HooksConfigMenuModel.new(updateHookPrompt(model.hooks, dialog.hookId, value), model.state.withPromptDialog(HookPromptDialog.closed(), "prompt-save"))

fn updateHookPrompt(hooks: [HookConfig], id: text, prompt: text) -> [HookConfig]:
    var out: [HookConfig] = []
    val normalized = normalizeHookId(id)
    var i = 0
    while i < hooks.len():
        if hooks[i].id == normalized:
            out.push(HookConfig.new(hooks[i].id, hooks[i].name, hooks[i].event, hooks[i].matcher, hooks[i].mode, prompt, hooks[i].enabled, hooks[i].source))
        else:
            out.push(hooks[i])
        i = i + 1
    out

fn hookConfigHandleKey(hooks: [HookConfig], state: HooksConfigMenuState, key: text) -> HooksConfigMenuState:
    val rows = hookConfigRowsForFilters(hooks, state.query, state.eventFilter, state.matcherFilter, state.modeFilter)
    if key == "down" or key == "j":
        return state.withSelectedIndex(nextHookConfigIndex(state.selectedIndex, rows.len()))
    if key == "up" or key == "k":
        return state.withSelectedIndex(previousHookConfigIndex(state.selectedIndex, rows.len()))
    if key == "home":
        return state.withSelectedIndex(0)
    if key == "end":
        return state.withSelectedIndex(rows.len() - 1)
    if key == "escape":
        return state.close()
    state

fn nextHookConfigIndex(index: i64, count: i64) -> i64:
    if count <= 0:
        return 0
    if index + 1 >= count:
        return 0
    index + 1

fn previousHookConfigIndex(index: i64, count: i64) -> i64:
    if count <= 0:
        return 0
    if index <= 0:
        return count - 1
    index - 1

fn clampHookConfigIndex(index: i64, count: i64) -> i64:
    if count <= 0:
        return 0
    if index < 0:
        return 0
    if index >= count:
        return count - 1
    index

fn renderHooksConfigMenu(hooks: [HookConfig], state: HooksConfigMenuState) -> text:
    if not state.isOpen:
        return "Hooks config menu closed"
    if state.loading:
        return "Loading hooks configuration..."
    if state.error != "":
        return "Hooks config error: " + state.error
    if hooks.len() == 0:
        return "No hooks configured"
    val rows = hookConfigRows(hooks, state)
    if rows.len() == 0:
        return hookConfigEmptyMessage(state)
    val groups = groupHookConfigRows(rows)
    var lines: [text] = []
    lines.push(hooksConfigSummary(hooks, state))
    var g = 0
    while g < groups.len():
        val group = groups[g]
        lines.push(group.summary())
        var r = 0
        while r < group.rows.len():
            lines.push(renderHookConfigRow(group.rows[r]))
            r = r + 1
        g = g + 1
    if state.promptDialog.isOpen:
        lines.push(renderHookPromptDialog(state.promptDialog))
    joinHookText(lines, "\n")

fn renderHookConfigRow(row: HookConfigRow) -> text:
    val hook = row.hook
    var textValue = row.marker() + " " + hook.title() + " [" + hookEventLabel(hook.event) + " / " + hook.matcher + " / " + hookModeLabel(hook.mode) + "] " + hook.statusLabel()
    if row.validation != "":
        textValue = textValue + " - " + row.validation
    textValue

fn renderHookPromptDialog(dialog: HookPromptDialog) -> text:
    if not dialog.isOpen:
        return ""
    if dialog.error != "":
        return dialog.title + " - " + dialog.error
    dialog.title + " - " + dialog.value.trim()

fn hooksConfigSummary(hooks: [HookConfig], state: HooksConfigMenuState) -> text:
    val rows = hookConfigRowsForFilters(hooks, state.query, state.eventFilter, state.matcherFilter, state.modeFilter)
    "Hooks config " + rows.len().to_text() + "/" + hooks.len().to_text() + " | " + countEnabledHookConfigs(rows).to_text() + " enabled | " + countInvalidHookConfigs(rows).to_text() + " invalid | event " + hookEventFilterLabel(state.eventFilter) + " | matcher " + hookMatcherFilterLabel(state.matcherFilter) + " | mode " + hookModeFilterLabel(state.modeFilter)

fn hookConfigEmptyMessage(state: HooksConfigMenuState) -> text:
    var parts: [text] = []
    if normalizeHookQuery(state.query) != "":
        parts.push("search \"" + state.query.trim() + "\"")
    if state.eventFilter != "all":
        parts.push("event " + hookEventFilterLabel(state.eventFilter))
    if state.matcherFilter != "all":
        parts.push("matcher " + hookMatcherFilterLabel(state.matcherFilter))
    if state.modeFilter != "all":
        parts.push("mode " + hookModeFilterLabel(state.modeFilter))
    if parts.len() == 0:
        return "No hooks match"
    "No hooks match " + joinHookText(parts, " and ")

fn countEnabledHookConfigs(hooks: [HookConfig]) -> i64:
    var count = 0
    var i = 0
    while i < hooks.len():
        if hooks[i].enabled:
            count = count + 1
        i = i + 1
    count

fn countInvalidHookConfigs(hooks: [HookConfig]) -> i64:
    var count = 0
    var i = 0
    while i < hooks.len():
        if validateHookConfig(hooks[i]) != "":
            count = count + 1
        i = i + 1
    count

fn validateHookConfig(hook: HookConfig) -> text:
    if hook.id == "":
        return "Hook id is required"
    if hook.event == "Unknown":
        return "Unsupported hook event"
    if hook.matcher == "":
        return "Matcher is required"
    if hook.mode == "unknown":
        return "Unsupported hook mode"
    if hook.prompt.trim() == "":
        return "Prompt is required"
    ""

fn hookEventMatches(event: text, filter: text) -> bool:
    val normalized = normalizeHookEventFilter(filter)
    normalized == "all" or normalizeHookEvent(event) == normalized

fn hookMatcherMatches(matcher: text, filter: text) -> bool:
    val normalized = normalizeHookMatcherFilter(filter)
    if normalized == "all":
        return true
    normalizeHookMatcher(matcher).lower() == normalized.lower()

fn hookModeMatches(mode: text, filter: text) -> bool:
    val normalized = normalizeHookModeFilter(filter)
    normalized == "all" or normalizeHookMode(mode) == normalized

fn normalizeHookId(id: text) -> text:
    id.trim().lower()

fn normalizeHookQuery(query: text) -> text:
    query.trim().lower()

fn normalizeHookEvent(event: text) -> text:
    val value = event.trim().lower()
    if value == "pretooluse" or value == "pre-tool-use" or value == "pre tool use":
        return "PreToolUse"
    if value == "posttooluse" or value == "post-tool-use" or value == "post tool use":
        return "PostToolUse"
    if value == "notification":
        return "Notification"
    if value == "stop":
        return "Stop"
    if value == "subagentstop" or value == "subagent-stop" or value == "subagent stop":
        return "SubagentStop"
    if value == "precompact" or value == "pre-compact" or value == "pre compact":
        return "PreCompact"
    if value == "sessionstart" or value == "session-start" or value == "session start":
        return "SessionStart"
    if value == "submit":
        return "Submit"
    "Unknown"

fn normalizeHookEventFilter(eventFilter: text) -> text:
    val value = eventFilter.trim().lower()
    if value == "" or value == "all" or value == "*":
        return "all"
    normalizeHookEvent(eventFilter)

fn normalizeHookMatcher(matcher: text) -> text:
    val value = matcher.trim()
    if value == "":
        return ""
    if value.lower() == "any" or value == "*":
        return "*"
    value

fn normalizeHookMatcherFilter(matcherFilter: text) -> text:
    val value = matcherFilter.trim()
    if value == "" or value.lower() == "all" or value == "*":
        return "all"
    normalizeHookMatcher(value)

fn normalizeHookMode(mode: text) -> text:
    val value = mode.trim().lower()
    if value == "project" or value == "workspace":
        return "project"
    if value == "user" or value == "global":
        return "user"
    if value == "local":
        return "local"
    "unknown"

fn normalizeHookModeFilter(modeFilter: text) -> text:
    val value = modeFilter.trim().lower()
    if value == "" or value == "all" or value == "*":
        return "all"
    normalizeHookMode(value)

fn normalizeHookSource(source: text) -> text:
    val value = source.trim().lower()
    if value == "":
        return "project"
    if value == "workspace":
        return "project"
    if value == "global":
        return "user"
    value

fn hookEventLabel(event: text) -> text:
    val value = normalizeHookEvent(event)
    if value == "PreToolUse":
        return "Pre tool use"
    if value == "PostToolUse":
        return "Post tool use"
    if value == "SubagentStop":
        return "Subagent stop"
    if value == "PreCompact":
        return "Pre compact"
    if value == "SessionStart":
        return "Session start"
    if value == "Notification":
        return "Notification"
    if value == "Stop":
        return "Stop"
    if value == "Submit":
        return "Submit"
    "Unknown"

fn hookEventFilterLabel(eventFilter: text) -> text:
    if normalizeHookEventFilter(eventFilter) == "all":
        return "All"
    hookEventLabel(eventFilter)

fn hookMatcherFilterLabel(matcherFilter: text) -> text:
    if normalizeHookMatcherFilter(matcherFilter) == "all":
        return "All"
    normalizeHookMatcher(matcherFilter)

fn hookModeLabel(mode: text) -> text:
    val value = normalizeHookMode(mode)
    if value == "project":
        return "Project"
    if value == "user":
        return "User"
    if value == "local":
        return "Local"
    "Unknown"

fn hookModeFilterLabel(modeFilter: text) -> text:
    if normalizeHookModeFilter(modeFilter) == "all":
        return "All"
    hookModeLabel(modeFilter)

fn hookEventOptions() -> [text]:
    ["all", "PreToolUse", "PostToolUse", "Notification", "Stop", "SubagentStop", "PreCompact", "SessionStart", "Submit"]

fn hookModeOptions() -> [text]:
    ["all", "project", "user", "local"]

fn hookMatcherOptions(hooks: [HookConfig]) -> [text]:
    var out: [text] = ["all"]
    var i = 0
    while i < hooks.len():
        val matcher = normalizeHookMatcher(hooks[i].matcher)
        if matcher != "" and not hookTextListContains(out, matcher):
            out.push(matcher)
        i = i + 1
    out

fn hookTextListContains(values: [text], needle: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

fn joinHookText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn hooksConfigModeledSourceFile() -> text:
    "src/components/hooks/HooksConfigMenu.tsx"

fn hooksConfigModeledStateHook() -> text:
    "useHooksConfigMenu"

fn hooksConfigModeledHookRowsHelper() -> text:
    "getHookRows"

fn hooksConfigModeledPromptDialog() -> text:
    "HookPromptDialog"

fn hooksConfigModeledLineCount() -> i64:
    577
