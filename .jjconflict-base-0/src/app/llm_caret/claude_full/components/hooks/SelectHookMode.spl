"""
Claude full hooks SelectHookMode parity.
"""

fn normalizeHookMode(mode: text) -> text:
    val clean = mode.trim()
    if clean == "command" or clean == "matcher" or clean == "session":
        return clean
    "command"

fn hookModeLabel(mode: text) -> text:
    val clean = normalizeHookMode(mode)
    if clean == "command":
        return "Command hook"
    if clean == "matcher":
        return "Matcher hook"
    "Session hook"

fn hookModeRequiresPrompt(mode: text) -> bool:
    normalizeHookMode(mode) == "command"

fn selectHookModeSourceLinesModeled() -> i64:
    111
