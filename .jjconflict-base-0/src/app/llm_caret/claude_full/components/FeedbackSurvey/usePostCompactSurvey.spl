"""
Claude full usePostCompactSurvey parity.
"""

class PostCompactSurveyState:
    compacted: bool
    token_savings: i64
    dismissed: bool
    rating: i64

impl PostCompactSurveyState:
    static fn new(compacted: bool, tokenSavings: i64, dismissed: bool, rating: i64) -> PostCompactSurveyState:
        PostCompactSurveyState(compacted: compacted, token_savings: clampPostCompactSavings(tokenSavings), dismissed: dismissed, rating: clampPostCompactRating(rating))

fn clampPostCompactSavings(value: i64) -> i64:
    if value < 0:
        return 0
    value

fn clampPostCompactRating(value: i64) -> i64:
    if value < 0:
        return 0
    if value > 5:
        return 5
    value

fn postCompactSurveyVisible(state: PostCompactSurveyState) -> bool:
    state.compacted and not state.dismissed and state.token_savings > 0

fn postCompactSurveyTitle(state: PostCompactSurveyState) -> text:
    if not postCompactSurveyVisible(state):
        return "Post compact survey hidden"
    "Was compaction useful?"

fn postCompactSurveySummary(state: PostCompactSurveyState) -> text:
    postCompactSurveyTitle(state) + " saved " + state.token_savings.to_text()

fn postCompactSurveyCanSubmit(state: PostCompactSurveyState) -> bool:
    postCompactSurveyVisible(state) and state.rating > 0

fn usePostCompactSurveySourceLinesModeled() -> i64:
    205
