"""
Claude full BridgeDialog component parity.
"""

class BridgeDialogState:
    visible: bool
    connected: bool
    connecting: bool
    provider: text
    target: text
    requestId: text
    error: text
    status: text

impl BridgeDialogState:
    static fn new(visible: bool, connected: bool, connecting: bool, provider: text, target: text, requestId: text, error: text, status: text) -> BridgeDialogState:
        BridgeDialogState(visible: visible, connected: connected, connecting: connecting, provider: provider.trim(), target: target.trim(), requestId: requestId.trim(), error: error.trim(), status: status.trim())

class BridgeDialogResult:
    action: text
    approved: bool
    cancelled: bool
    requestId: text
    summary: text

impl BridgeDialogResult:
    static fn new(action: text, approved: bool, cancelled: bool, requestId: text, summary: text) -> BridgeDialogResult:
        BridgeDialogResult(action: action, approved: approved, cancelled: cancelled, requestId: requestId.trim(), summary: summary.trim())

fn bridgeDialogProviderLabel(state: BridgeDialogState) -> text:
    if state.provider == "":
        return "Claude"
    state.provider

fn bridgeDialogTargetLabel(state: BridgeDialogState) -> text:
    if state.target == "":
        return "remote app"
    state.target

fn bridgeDialogConnectionState(state: BridgeDialogState) -> text:
    if state.error != "":
        return "failed"
    if state.connected:
        return "connected"
    if state.connecting:
        return "connecting"
    "disconnected"

fn bridgeDialogVisible(state: BridgeDialogState) -> bool:
    state.visible and bridgeDialogConnectionState(state) != "disconnected"

fn bridgeDialogTitle(state: BridgeDialogState) -> text:
    if not bridgeDialogVisible(state):
        return "Bridge dialog hidden"
    "Connect " + bridgeDialogProviderLabel(state) + " to " + bridgeDialogTargetLabel(state)

fn bridgeDialogStatusSummary(state: BridgeDialogState) -> text:
    val connection = bridgeDialogConnectionState(state)
    if state.error != "":
        return "Bridge failed: " + state.error
    if state.status != "":
        return state.status
    if connection == "connected":
        return "Bridge connected"
    if connection == "connecting":
        return "Bridge connecting"
    "Bridge disconnected"

fn bridgeDialogCanApprove(state: BridgeDialogState) -> bool:
    bridgeDialogVisible(state) and state.connected and state.error == ""

fn bridgeDialogApprove(state: BridgeDialogState) -> BridgeDialogResult:
    if bridgeDialogCanApprove(state):
        return BridgeDialogResult.new("approve", true, false, state.requestId, "Approved bridge to " + bridgeDialogTargetLabel(state))
    BridgeDialogResult.new("blocked", false, false, state.requestId, bridgeDialogStatusSummary(state))

fn bridgeDialogCancel(state: BridgeDialogState) -> BridgeDialogResult:
    BridgeDialogResult.new("cancel", false, true, state.requestId, "Cancelled bridge to " + bridgeDialogTargetLabel(state))

fn bridgeDialogSource() -> text:
    "BridgeDialog"

fn bridgeDialogSourceLinesModeled() -> i64:
    430
