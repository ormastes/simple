"""
Claude full MCP server multiselect dialog parity.
"""

class MCPServerMultiselectSettings:
    enabled_mcpjson_servers: [text]
    disabled_mcpjson_servers: [text]

impl MCPServerMultiselectSettings:
    static fn new(enabledServers: [text], disabledServers: [text]) -> MCPServerMultiselectSettings:
        MCPServerMultiselectSettings(enabled_mcpjson_servers: enabledServers, disabled_mcpjson_servers: disabledServers)

class MCPServerMultiselectChoice:
    approved_servers: [text]
    rejected_servers: [text]

impl MCPServerMultiselectChoice:
    static fn new(approvedServers: [text], rejectedServers: [text]) -> MCPServerMultiselectChoice:
        MCPServerMultiselectChoice(approved_servers: approvedServers, rejected_servers: rejectedServers)

class MCPServerMultiselectUpdate:
    settings: MCPServerMultiselectSettings
    approved_count: i64
    rejected_count: i64
    event_name: text

impl MCPServerMultiselectUpdate:
    static fn new(settings: MCPServerMultiselectSettings, approvedCount: i64, rejectedCount: i64, eventName: text) -> MCPServerMultiselectUpdate:
        MCPServerMultiselectUpdate(settings: settings, approved_count: approvedCount, rejected_count: rejectedCount, event_name: eventName)

fn mcpMultiselectContains(items: [text], value: text) -> bool:
    var i = 0
    while i < items.len():
        if items[i] == value:
            return true
        i = i + 1
    false

fn mcpMultiselectAddUnique(items: [text], value: text) -> [text]:
    var result = items
    if not mcpMultiselectContains(result, value):
        result.push(value)
    result

fn mcpMultiselectOptionLabels(serverNames: [text]) -> [text]:
    var labels: [text] = []
    var i = 0
    while i < serverNames.len():
        labels.push(serverNames[i] + ":" + serverNames[i])
        i = i + 1
    labels

fn mcpMultiselectPartition(serverNames: [text], selectedServers: [text]) -> MCPServerMultiselectChoice:
    var approved: [text] = []
    var rejected: [text] = []
    var i = 0
    while i < serverNames.len():
        val serverName = serverNames[i]
        if mcpMultiselectContains(selectedServers, serverName):
            approved.push(serverName)
        else:
            rejected.push(serverName)
        i = i + 1
    MCPServerMultiselectChoice.new(approved, rejected)

fn mcpMultiselectApplySubmit(serverNames: [text], selectedServers: [text], settings: MCPServerMultiselectSettings) -> MCPServerMultiselectUpdate:
    val choice = mcpMultiselectPartition(serverNames, selectedServers)
    var enabled = settings.enabled_mcpjson_servers
    var disabled = settings.disabled_mcpjson_servers
    var i = 0
    while i < choice.approved_servers.len():
        enabled = mcpMultiselectAddUnique(enabled, choice.approved_servers[i])
        i = i + 1
    i = 0
    while i < choice.rejected_servers.len():
        disabled = mcpMultiselectAddUnique(disabled, choice.rejected_servers[i])
        i = i + 1
    val updated = MCPServerMultiselectSettings.new(enabled, disabled)
    MCPServerMultiselectUpdate.new(updated, choice.approved_servers.len(), choice.rejected_servers.len(), "tengu_mcp_multidialog_choice")

fn mcpMultiselectRejectAll(serverNames: [text], settings: MCPServerMultiselectSettings) -> MCPServerMultiselectSettings:
    var disabled = settings.disabled_mcpjson_servers
    var i = 0
    while i < serverNames.len():
        disabled = mcpMultiselectAddUnique(disabled, serverNames[i])
        i = i + 1
    MCPServerMultiselectSettings.new(settings.enabled_mcpjson_servers, disabled)

fn mcpMultiselectTitle(serverNames: [text]) -> text:
    serverNames.len().to_text() + " new MCP servers found in .mcp.json"

fn mcpMultiselectSubtitle() -> text:
    "Select any you wish to enable."

fn mcpMultiselectKeyboardHint() -> text:
    "Space=select Enter=confirm Esc=reject all"

fn mcpMultiselectDefaultValues(serverNames: [text]) -> [text]:
    serverNames

fn mcpMultiselectDialogSummary(serverNames: [text], selectedServers: [text], settings: MCPServerMultiselectSettings) -> text:
    val update = mcpMultiselectApplySubmit(serverNames, selectedServers, settings)
    "approved=" + update.approved_count.to_text() + " rejected=" + update.rejected_count.to_text() + " enabled=" + update.settings.enabled_mcpjson_servers.len().to_text() + " disabled=" + update.settings.disabled_mcpjson_servers.len().to_text()

fn mcpServerMultiselectDialogSourceLinesModeled() -> i64:
    132
