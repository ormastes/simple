"""
Claude full user agent notification message parity model.
"""

const USER_AGENT_NOTIFICATION_MESSAGE_SOURCE_LINES = 82
const USER_AGENT_NOTIFICATION_BULLET = "●"

class UserAgentNotificationRender:
    visible: bool
    summary: text
    status: text
    color: text
    bullet: text
    margin_top: i64

impl UserAgentNotificationRender:
    static fn hidden() -> UserAgentNotificationRender:
        UserAgentNotificationRender(visible: false, summary: "", status: "", color: "", bullet: "", margin_top: 0)

    static fn new(summary: text, status: text, color: text, marginTop: i64) -> UserAgentNotificationRender:
        UserAgentNotificationRender(visible: true, summary: summary, status: status, color: color, bullet: USER_AGENT_NOTIFICATION_BULLET, margin_top: marginTop)

fn userAgentNotificationStatusColor(status: text) -> text:
    if status == "completed":
        return "success"
    if status == "failed":
        return "error"
    if status == "killed":
        return "warning"
    "text"

fn userAgentNotificationMessage(textValue: text, addMargin: bool) -> UserAgentNotificationRender:
    val summary = extractTaggedValue(textValue, "summary")
    if summary == "":
        return UserAgentNotificationRender.hidden()
    val status = extractTaggedValue(textValue, "status")
    var margin = 0
    if addMargin:
        margin = 1
    UserAgentNotificationRender.new(summary, status, userAgentNotificationStatusColor(status), margin)

fn userAgentNotificationLine(render: UserAgentNotificationRender) -> text:
    if not render.visible:
        return ""
    render.bullet + " " + render.summary

fn userAgentNotificationMessageSourceLinesModeled() -> i64:
    USER_AGENT_NOTIFICATION_MESSAGE_SOURCE_LINES
