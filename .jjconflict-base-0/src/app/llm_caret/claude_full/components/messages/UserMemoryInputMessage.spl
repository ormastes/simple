"""
Claude full user memory input message parity model.
"""

use app.llm_caret.claude_full.components.messages.UserBashInputMessage.{extractTaggedValue}

const USER_MEMORY_INPUT_MESSAGE_SOURCE_LINES = 74
const USER_MEMORY_INPUT_TAG = "user-memory-input"
const USER_MEMORY_SAVING_TEXT = "Got it."

class UserMemoryInputRender:
    visible: bool
    input: text
    marker: text
    margin_top: i64
    flex_direction: text
    width: text
    marker_color: text
    input_color: text
    background_color: text
    saving_text: text
    response_height: i64
    saving_dim: bool

impl UserMemoryInputRender:
    static fn hidden() -> UserMemoryInputRender:
        UserMemoryInputRender(visible: false, input: "", marker: "", margin_top: 0, flex_direction: "", width: "", marker_color: "", input_color: "", background_color: "", saving_text: "", response_height: 0, saving_dim: false)

    static fn new(input: text, marginTop: i64) -> UserMemoryInputRender:
        UserMemoryInputRender(visible: true, input: input, marker: "#", margin_top: marginTop, flex_direction: "column", width: "100%", marker_color: "remember", input_color: "text", background_color: "memoryBackgroundColor", saving_text: USER_MEMORY_SAVING_TEXT, response_height: 1, saving_dim: true)

fn getUserMemorySavingMessage() -> text:
    USER_MEMORY_SAVING_TEXT

fn userMemoryInputMessage(textValue: text, addMargin: bool) -> UserMemoryInputRender:
    val input = extractTaggedValue(textValue, USER_MEMORY_INPUT_TAG)
    if input == "":
        return UserMemoryInputRender.hidden()
    var margin = 0
    if addMargin:
        margin = 1
    UserMemoryInputRender.new(input, margin)

fn userMemoryInputMessageSourceLinesModeled() -> i64:
    USER_MEMORY_INPUT_MESSAGE_SOURCE_LINES
