"""
Claude full user resource update message parity model.
"""

const USER_RESOURCE_UPDATE_MESSAGE_SOURCE_LINES = 120
const USER_RESOURCE_UPDATE_REFRESH_ARROW = "↻"
const USER_RESOURCE_UPDATE_TRUNCATE_AT = 40

class UserResourceUpdate:
    kind: text
    server: text
    target: text
    reason: text

impl UserResourceUpdate:
    static fn new(kind: text, server: text, target: text, reason: text) -> UserResourceUpdate:
        UserResourceUpdate(kind: kind, server: server, target: target, reason: reason)

class UserResourceUpdateRender:
    visible: bool
    rows: [UserResourceUpdate]
    margin_top: i64
    flex_direction: text
    marker: text
    marker_color: text
    server_dim: bool
    target_color: text
    reason_dim: bool

impl UserResourceUpdateRender:
    static fn hidden() -> UserResourceUpdateRender:
        UserResourceUpdateRender(visible: false, rows: [], margin_top: 0, flex_direction: "", marker: "", marker_color: "", server_dim: false, target_color: "", reason_dim: false)

    static fn new(rows: [UserResourceUpdate], addMargin: bool) -> UserResourceUpdateRender:
        UserResourceUpdateRender(visible: true, rows: rows, margin_top: if addMargin: 1 else: 0, flex_direction: "column", marker: USER_RESOURCE_UPDATE_REFRESH_ARROW, marker_color: "success", server_dim: true, target_color: "suggestion", reason_dim: true)

fn userResourceUpdateFindFrom(value: text, needle: text, start: i64) -> i64:
    if needle == "":
        return start
    var i = start
    while i + needle.len() <= value.len():
        if value.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn userResourceUpdateAttr(attrs: text, name: text) -> text:
    val marker = name + "=\""
    val start = attrs.find(marker)
    if start < 0:
        return ""
    val valueStart = start + marker.len()
    val rest = attrs.slice(valueStart, attrs.len())
    val end = rest.find("\"")
    if end < 0:
        return ""
    rest.slice(0, end)

fn userResourceUpdateReason(body: text) -> text:
    val openTag = "<reason>"
    val closeTag = "</reason>"
    val start = body.find(openTag)
    if start < 0:
        return ""
    val valueStart = start + openTag.len()
    val rest = body.slice(valueStart, body.len())
    val end = rest.find(closeTag)
    if end < 0:
        return ""
    rest.slice(0, end)

class UserResourceUpdateParseResult:
    next: i64
    found: bool
    row: UserResourceUpdate

impl UserResourceUpdateParseResult:
    static fn none() -> UserResourceUpdateParseResult:
        UserResourceUpdateParseResult(next: -1, found: false, row: UserResourceUpdate.new("", "", "", ""))

    static fn some(next: i64, row: UserResourceUpdate) -> UserResourceUpdateParseResult:
        UserResourceUpdateParseResult(next: next, found: true, row: row)

fn userResourceUpdateParseTag(textValue: text, tag: text, kind: text, targetAttr: text, start: i64) -> UserResourceUpdateParseResult:
    val openPrefix = "<" + tag
    val openStart = userResourceUpdateFindFrom(textValue, openPrefix, start)
    if openStart < 0:
        return UserResourceUpdateParseResult.none()
    val openEnd = userResourceUpdateFindFrom(textValue, ">", openStart + openPrefix.len())
    if openEnd < 0:
        return UserResourceUpdateParseResult.none()
    val closeTag = "</" + tag + ">"
    val closeStart = userResourceUpdateFindFrom(textValue, closeTag, openEnd + 1)
    val bodyEnd = if closeStart < 0: openEnd else: closeStart
    val attrs = textValue.slice(openStart + openPrefix.len(), openEnd)
    val server = userResourceUpdateAttr(attrs, "server")
    val target = userResourceUpdateAttr(attrs, targetAttr)
    var next = openEnd + 1
    if closeStart < 0:
        next = openEnd + 1
    else:
        next = closeStart + closeTag.len()
    if server == "" and target == "":
        return UserResourceUpdateParseResult(next: next, found: false, row: UserResourceUpdate.new("", "", "", ""))
    UserResourceUpdateParseResult.some(next, UserResourceUpdate.new(kind, server, target, userResourceUpdateReason(textValue.slice(openEnd + 1, bodyEnd))))

fn parseUserResourceUpdates(textValue: text) -> [UserResourceUpdate]:
    var rows: [UserResourceUpdate] = []
    var start = 0
    while start >= 0:
        val parsed = userResourceUpdateParseTag(textValue, "mcp-resource-update", "resource", "uri", start)
        start = parsed.next
        if parsed.found:
            rows.push(parsed.row)
    start = 0
    while start >= 0:
        val parsed = userResourceUpdateParseTag(textValue, "mcp-polling-update", "polling", "tool", start)
        start = parsed.next
        if parsed.found:
            rows.push(parsed.row)
    rows

fn formatUserResourceUpdateUri(uri: text) -> text:
    if uri.starts_with("file://"):
        val path = uri.slice(7, uri.len())
        val parts = path.split("/")
        if parts.len() == 0:
            return path
        val name = parts[parts.len() - 1]
        if name == "":
            return path
        return name
    if uri.len() > USER_RESOURCE_UPDATE_TRUNCATE_AT:
        return uri.slice(0, USER_RESOURCE_UPDATE_TRUNCATE_AT - 1) + "…"
    uri

fn userResourceUpdateMessage(textValue: text, addMargin: bool) -> UserResourceUpdateRender:
    val rows = parseUserResourceUpdates(textValue)
    if rows.len() == 0:
        return UserResourceUpdateRender.hidden()
    UserResourceUpdateRender.new(rows, addMargin)

fn userResourceUpdateLine(render: UserResourceUpdateRender, index: i64) -> text:
    if not render.visible or index < 0 or index >= render.rows.len():
        return ""
    val row = render.rows[index]
    val target = if row.kind == "resource": formatUserResourceUpdateUri(row.target) else: row.target
    val reason = if row.reason == "": "" else: " · " + row.reason
    render.marker + " " + row.server + ": " + target + reason

fn userResourceUpdateMessageSourceLinesModeled() -> i64:
    USER_RESOURCE_UPDATE_MESSAGE_SOURCE_LINES
# parity ledger: UserResourceUpdateMessage line 024 parse resource update XML.
# parity ledger: UserResourceUpdateMessage line 040 parse polling update XML.
# parity ledger: UserResourceUpdateMessage line 056 format file URI basename.
# parity ledger: UserResourceUpdateMessage line 064 truncate long non-file URI.
# parity ledger: UserResourceUpdateMessage line 074 return hidden when no updates.
# parity ledger: UserResourceUpdateMessage line 079 render marker, server, target, reason.
