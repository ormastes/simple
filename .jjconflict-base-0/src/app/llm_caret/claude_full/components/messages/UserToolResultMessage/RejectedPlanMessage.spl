"""
Claude full rejected plan message parity model.
"""

const REJECTED_PLAN_MESSAGE_SOURCE_LINES = 30

class RejectedPlanRender:
    title: text
    plan: text
    title_color: text
    border_color: text
    border_style: text
    padding_x: i64
    overflow: text

impl RejectedPlanRender:
    static fn new(plan: text) -> RejectedPlanRender:
        RejectedPlanRender(title: "User rejected Claude's plan:", plan: plan, title_color: "subtle", border_color: "planMode", border_style: "round", padding_x: 1, overflow: "hidden")

fn rejectedPlanMessage(plan: text) -> RejectedPlanRender:
    RejectedPlanRender.new(plan)

fn rejectedPlanMessageSourceLinesModeled() -> i64:
    REJECTED_PLAN_MESSAGE_SOURCE_LINES
