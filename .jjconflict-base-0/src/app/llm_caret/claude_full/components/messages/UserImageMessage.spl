"""
Claude full user image message parity model.
"""

const USER_IMAGE_MESSAGE_SOURCE_LINES = 58

class UserImageRender:
    label: text
    image_path: text
    link_url: text
    clickable: bool
    margin_top: i64
    wrapped_in_message_response: bool

impl UserImageRender:
    static fn new(label: text, imagePath: text, linkUrl: text, clickable: bool, marginTop: i64, wrapped: bool) -> UserImageRender:
        UserImageRender(label: label, image_path: imagePath, link_url: linkUrl, clickable: clickable, margin_top: marginTop, wrapped_in_message_response: wrapped)

fn userImageLabel(imageId: i64) -> text:
    if imageId > 0:
        return "[Image #" + imageId.to_text() + "]"
    "[Image]"

fn userImageFileUrl(imagePath: text) -> text:
    if imagePath == "":
        return ""
    "file://" + imagePath

fn userImageMessage(imageId: i64, imagePath: text, supportsHyperlinks: bool, addMargin: bool) -> UserImageRender:
    val label = userImageLabel(imageId)
    var margin = 0
    var wrapped = true
    if addMargin:
        margin = 1
        wrapped = false
    var clickable = false
    var linkUrl = ""
    if imagePath != "" and supportsHyperlinks:
        clickable = true
        linkUrl = userImageFileUrl(imagePath)
    UserImageRender.new(label, imagePath, linkUrl, clickable, margin, wrapped)

fn userImageMessageSourceLinesModeled() -> i64:
    USER_IMAGE_MESSAGE_SOURCE_LINES
