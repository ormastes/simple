"""
Claude full CompactSummary component parity.
"""

fn compactSummaryTitle(tokenCount: i64) -> text:
    "Compact summary: " + tokenCount.to_text() + " tokens"

fn compactSummaryNeedsWarning(tokenCount: i64, limit: i64) -> bool:
    tokenCount >= limit

fn compactSummaryMessage(tokenCount: i64, limit: i64) -> text:
    if compactSummaryNeedsWarning(tokenCount, limit):
        return "Context limit approaching"
    "Context is within limit"

fn compactSummarySourceLinesModeled() -> i64:
    117
