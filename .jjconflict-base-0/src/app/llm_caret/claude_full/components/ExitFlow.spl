"""
Claude full ExitFlow parity.
"""

class ExitFlowState:
    dirty: bool
    confirmed: bool
    reason: text

impl ExitFlowState:
    static fn new(dirty: bool, confirmed: bool, reason: text) -> ExitFlowState:
        ExitFlowState(dirty: dirty, confirmed: confirmed, reason: reason.trim())

fn exitFlowCanExit(state: ExitFlowState) -> bool:
    not state.dirty or state.confirmed

fn exitFlowPrompt(state: ExitFlowState) -> text:
    if exitFlowCanExit(state):
        return "Exit"
    if state.reason != "":
        return state.reason
    "Unsaved changes"

fn exitFlowActionLabel(state: ExitFlowState) -> text:
    if exitFlowCanExit(state):
        return "Close"
    "Confirm exit"

fn exitFlowSourceLinesModeled() -> i64:
    47
