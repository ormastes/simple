"""
Claude full Feedback component parity surface.
"""

class FeedbackPromptState:
    visible: bool
    reason: text
    sessionId: text
    transcriptId: text
    dismissed: bool

impl FeedbackPromptState:
    static fn new(visible: bool, reason: text, sessionId: text, transcriptId: text, dismissed: bool) -> FeedbackPromptState:
        FeedbackPromptState(
            visible: visible,
            reason: normalizeFeedbackReason(reason),
            sessionId: sessionId.trim(),
            transcriptId: transcriptId.trim(),
            dismissed: dismissed,
        )

    static fn hidden() -> FeedbackPromptState:
        FeedbackPromptState.new(false, "", "", "", false)

    static fn afterResponse(sessionId: text, transcriptId: text) -> FeedbackPromptState:
        FeedbackPromptState.new(true, "response", sessionId, transcriptId, false)

    me show(reason: text) -> FeedbackPromptState:
        FeedbackPromptState.new(true, reason, me.sessionId, me.transcriptId, false)

    me hide() -> FeedbackPromptState:
        FeedbackPromptState.new(false, me.reason, me.sessionId, me.transcriptId, me.dismissed)

    me dismiss() -> FeedbackPromptState:
        FeedbackPromptState.new(false, me.reason, me.sessionId, me.transcriptId, true)

    me render() -> text:
        renderFeedbackPrompt(me)

class FeedbackAction:
    id: text
    label: text
    description: text
    enabled: bool
    selected: bool

impl FeedbackAction:
    static fn new(id: text, label: text, description: text, enabled: bool, selected: bool) -> FeedbackAction:
        FeedbackAction(
            id: normalizeFeedbackId(id),
            label: label.trim(),
            description: description.trim(),
            enabled: enabled,
            selected: selected,
        )

    me tone() -> text:
        if not me.enabled:
            return "disabled"
        if me.selected:
            return "primary"
        "secondary"

    me summary() -> text:
        feedbackActionSummary(me)

class FeedbackSubmitPayload:
    rating: i64
    comment: text
    contact: text
    shareTranscript: bool
    sessionId: text
    transcriptId: text
    reason: text

impl FeedbackSubmitPayload:
    static fn new(rating: i64, comment: text, contact: text, shareTranscript: bool, sessionId: text, transcriptId: text, reason: text) -> FeedbackSubmitPayload:
        FeedbackSubmitPayload(
            rating: clampFeedbackRating(rating),
            comment: normalizeFeedbackComment(comment),
            contact: normalizeFeedbackContact(contact),
            shareTranscript: shareTranscript,
            sessionId: sessionId.trim(),
            transcriptId: transcriptId.trim(),
            reason: normalizeFeedbackReason(reason),
        )

    me hasContact() -> bool:
        me.contact != ""

    me transcriptMode() -> text:
        if me.shareTranscript:
            return "shared"
        "not shared"

    me summary() -> text:
        feedbackPayloadSummary(me)

class FeedbackSubmitResult:
    ok: bool
    message: text
    retryable: bool
    payload: FeedbackSubmitPayload?

impl FeedbackSubmitResult:
    static fn success(message: text, payload: FeedbackSubmitPayload) -> FeedbackSubmitResult:
        val clean = message.trim()
        val label = if clean == "": "Feedback sent" else: clean
        FeedbackSubmitResult(ok: true, message: label, retryable: false, payload: payload)

    static fn error(message: text, retryable: bool) -> FeedbackSubmitResult:
        val clean = message.trim()
        val label = if clean == "": "Feedback could not be sent" else: clean
        FeedbackSubmitResult(ok: false, message: label, retryable: retryable, payload: nil)

    me summary() -> text:
        feedbackSubmitResultSummary(me)

class FeedbackState:
    rating: i64
    comment: text
    contact: text
    prompt: FeedbackPromptState
    shareTranscript: bool
    submitting: bool
    submitted: bool
    successMessage: text
    errorMessage: text
    activeActionId: text

impl FeedbackState:
    static fn new(rating: i64, comment: text, contact: text, prompt: FeedbackPromptState, shareTranscript: bool, submitting: bool, submitted: bool, successMessage: text, errorMessage: text, activeActionId: text) -> FeedbackState:
        FeedbackState(
            rating: clampFeedbackRating(rating),
            comment: normalizeFeedbackComment(comment),
            contact: normalizeFeedbackContact(contact),
            prompt: prompt,
            shareTranscript: shareTranscript,
            submitting: submitting,
            submitted: submitted,
            successMessage: successMessage.trim(),
            errorMessage: errorMessage.trim(),
            activeActionId: normalizeFeedbackId(activeActionId),
        )

    static fn closed() -> FeedbackState:
        FeedbackState.new(0, "", "", FeedbackPromptState.hidden(), false, false, false, "", "", "")

    static fn open(sessionId: text, transcriptId: text) -> FeedbackState:
        FeedbackState.new(0, "", "", FeedbackPromptState.afterResponse(sessionId, transcriptId), false, false, false, "", "", "rate")

    static fn sample() -> FeedbackState:
        FeedbackState.new(4, "The answer was useful.", "dev@example.com", FeedbackPromptState.afterResponse("session-1", "transcript-1"), true, false, false, "", "", "submit")

    me withRating(rating: i64) -> FeedbackState:
        FeedbackState.new(rating, me.comment, me.contact, me.prompt.show("manual"), me.shareTranscript, false, false, "", "", "comment")

    me withComment(comment: text) -> FeedbackState:
        FeedbackState.new(me.rating, comment, me.contact, me.prompt, me.shareTranscript, false, false, "", "", "submit")

    me withContact(contact: text) -> FeedbackState:
        FeedbackState.new(me.rating, me.comment, contact, me.prompt, me.shareTranscript, false, false, "", "", "submit")

    me withTranscriptSharing(share: bool) -> FeedbackState:
        FeedbackState.new(me.rating, me.comment, me.contact, me.prompt, share, false, false, "", "", "submit")

    me toggleTranscriptSharing() -> FeedbackState:
        me.withTranscriptSharing(not me.shareTranscript)

    me openPrompt(reason: text) -> FeedbackState:
        FeedbackState.new(me.rating, me.comment, me.contact, me.prompt.show(reason), me.shareTranscript, me.submitting, me.submitted, me.successMessage, me.errorMessage, me.activeActionId)

    me closePrompt() -> FeedbackState:
        FeedbackState.new(me.rating, me.comment, me.contact, me.prompt.hide(), me.shareTranscript, me.submitting, me.submitted, me.successMessage, me.errorMessage, me.activeActionId)

    me dismissPrompt() -> FeedbackState:
        FeedbackState.new(me.rating, me.comment, me.contact, me.prompt.dismiss(), me.shareTranscript, false, me.submitted, me.successMessage, "", "dismiss")

    me markSubmitting() -> FeedbackState:
        markFeedbackSubmitting(me)

    me applyResult(result: FeedbackSubmitResult) -> FeedbackState:
        applyFeedbackSubmitResult(me, result)

    me validationErrors() -> [text]:
        validateFeedbackState(me)

    me canSubmit() -> bool:
        feedbackCanSubmit(me)

    me payload() -> FeedbackSubmitPayload:
        feedbackPayload(me)

    me actions() -> [FeedbackAction]:
        feedbackActions(me)

    me status() -> text:
        feedbackStatus(me)

    me summary() -> text:
        feedbackSummary(me)

    me render() -> text:
        renderFeedback(me)

fn clampFeedbackRating(rating: i64) -> i64:
    if rating < 0:
        return 0
    if rating > 5:
        return 5
    rating

fn normalizeFeedbackId(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "":
        return "feedback"
    clean

fn normalizeFeedbackReason(reason: text) -> text:
    val clean = reason.trim().lower()
    if clean == "response" or clean == "manual" or clean == "error" or clean == "exit":
        return clean
    if clean == "":
        return "manual"
    clean

fn normalizeFeedbackComment(comment: text) -> text:
    val clean = comment.trim()
    if clean.len() <= feedbackCommentMaxLength():
        return clean
    clean.slice(0, feedbackCommentMaxLength())

fn normalizeFeedbackContact(contact: text) -> text:
    contact.trim().lower()

fn feedbackCommentMaxLength() -> i64:
    2000

fn feedbackContactMaxLength() -> i64:
    254

fn feedbackHasComment(state: FeedbackState) -> bool:
    state.comment != ""

fn feedbackHasContact(state: FeedbackState) -> bool:
    state.contact != ""

fn feedbackHasRating(state: FeedbackState) -> bool:
    state.rating > 0

fn feedbackIsPositive(state: FeedbackState) -> bool:
    state.rating >= 4

fn feedbackIsNegative(state: FeedbackState) -> bool:
    state.rating > 0 and state.rating <= 2

fn feedbackRatingLabel(rating: i64) -> text:
    val clean = clampFeedbackRating(rating)
    if clean == 0:
        return "No rating"
    if clean == 1:
        return "Very poor"
    if clean == 2:
        return "Poor"
    if clean == 3:
        return "Okay"
    if clean == 4:
        return "Good"
    "Excellent"

fn feedbackRatingTone(rating: i64) -> text:
    val clean = clampFeedbackRating(rating)
    if clean == 0:
        return "muted"
    if clean <= 2:
        return "critical"
    if clean == 3:
        return "neutral"
    "positive"

fn feedbackPromptVisible(state: FeedbackState) -> bool:
    state.prompt.visible and not state.prompt.dismissed

fn feedbackFormVisible(state: FeedbackState) -> bool:
    feedbackPromptVisible(state) and not state.submitted

fn feedbackSuccessVisible(state: FeedbackState) -> bool:
    state.submitted and state.successMessage != ""

fn feedbackErrorVisible(state: FeedbackState) -> bool:
    state.errorMessage != ""

fn feedbackCanSubmit(state: FeedbackState) -> bool:
    state.prompt.visible and not state.submitting and not state.submitted and validateFeedbackState(state).len() == 0

fn feedbackSubmitDisabledReason(state: FeedbackState) -> text:
    if state.submitting:
        return "Feedback is being sent"
    if state.submitted:
        return "Feedback already sent"
    if not state.prompt.visible:
        return "Feedback prompt is closed"
    val errors = validateFeedbackState(state)
    if errors.len() > 0:
        return joinFeedbackText(errors, ", ")
    ""

fn validateFeedbackState(state: FeedbackState) -> [text]:
    var errors: [text] = []
    if state.rating <= 0:
        errors.push("rating is required")
    if state.rating < 0 or state.rating > 5:
        errors.push("rating must be from 1 to 5")
    if state.comment.len() > feedbackCommentMaxLength():
        errors.push("comment is too long")
    if state.contact.len() > feedbackContactMaxLength():
        errors.push("contact is too long")
    if state.contact != "" and not feedbackContactLooksValid(state.contact):
        errors.push("contact must be an email address")
    if state.shareTranscript and state.prompt.transcriptId == "":
        errors.push("transcript is unavailable")
    errors

fn feedbackContactLooksValid(contact: text) -> bool:
    val clean = normalizeFeedbackContact(contact)
    if clean == "":
        return true
    clean.contains("@") and clean.contains(".")

fn feedbackPayload(state: FeedbackState) -> FeedbackSubmitPayload:
    FeedbackSubmitPayload.new(
        state.rating,
        state.comment,
        state.contact,
        state.shareTranscript,
        state.prompt.sessionId,
        state.prompt.transcriptId,
        state.prompt.reason,
    )

fn markFeedbackSubmitting(state: FeedbackState) -> FeedbackState:
    if not feedbackCanSubmit(state):
        return FeedbackState.new(state.rating, state.comment, state.contact, state.prompt, state.shareTranscript, false, state.submitted, state.successMessage, feedbackSubmitDisabledReason(state), "submit")
    FeedbackState.new(state.rating, state.comment, state.contact, state.prompt, state.shareTranscript, true, false, "", "", "submit")

fn submitFeedback(state: FeedbackState) -> FeedbackState:
    if not feedbackCanSubmit(state):
        return markFeedbackSubmitting(state)
    applyFeedbackSubmitResult(markFeedbackSubmitting(state), FeedbackSubmitResult.success("Feedback sent", feedbackPayload(state)))

fn failFeedbackSubmit(state: FeedbackState, message: text) -> FeedbackState:
    applyFeedbackSubmitResult(state, FeedbackSubmitResult.error(message, true))

fn applyFeedbackSubmitResult(state: FeedbackState, result: FeedbackSubmitResult) -> FeedbackState:
    if result.ok:
        return FeedbackState.new(state.rating, state.comment, state.contact, state.prompt.hide(), state.shareTranscript, false, true, result.message, "", "done")
    FeedbackState.new(state.rating, state.comment, state.contact, state.prompt, state.shareTranscript, false, false, "", result.message, "retry")

fn feedbackStatus(state: FeedbackState) -> text:
    if state.submitting:
        return "submitting"
    if state.submitted:
        return "submitted"
    if state.errorMessage != "":
        return "error"
    if feedbackCanSubmit(state):
        return "ready"
    if feedbackPromptVisible(state):
        return "editing"
    "hidden"

fn feedbackSuccessSummary(state: FeedbackState) -> text:
    if state.successMessage != "":
        return state.successMessage
    if state.submitted:
        return "Feedback sent"
    ""

fn feedbackErrorSummary(state: FeedbackState) -> text:
    if state.errorMessage != "":
        return state.errorMessage
    val reason = feedbackSubmitDisabledReason(state)
    if reason != "":
        return reason
    ""

fn feedbackPrivacySummary(state: FeedbackState) -> text:
    if state.shareTranscript:
        return "Transcript will be shared"
    "Transcript will not be shared"

fn feedbackContactSummary(state: FeedbackState) -> text:
    if state.contact == "":
        return "No contact"
    "Contact " + state.contact

fn feedbackPromptTitle(prompt: FeedbackPromptState) -> text:
    if prompt.reason == "error":
        return "Report a problem"
    if prompt.reason == "exit":
        return "Before you go"
    "Share feedback"

fn feedbackPromptSubtitle(prompt: FeedbackPromptState) -> text:
    if prompt.reason == "response":
        return "How was this response?"
    if prompt.reason == "error":
        return "Tell us what went wrong."
    if prompt.reason == "exit":
        return "Help improve future sessions."
    "Tell us what worked or what did not."

fn feedbackPromptStateLabel(prompt: FeedbackPromptState) -> text:
    if prompt.dismissed:
        return "dismissed"
    if prompt.visible:
        return "visible"
    "hidden"

fn renderFeedbackPrompt(prompt: FeedbackPromptState) -> text:
    joinFeedbackText([
        feedbackPromptTitle(prompt),
        feedbackPromptSubtitle(prompt),
        "Prompt: " + feedbackPromptStateLabel(prompt),
        "Reason: " + prompt.reason,
    ], "\n")

fn feedbackActionSummary(action: FeedbackAction) -> text:
    val marker = if action.selected: "*" else: "-"
    marker + " " + action.label + " [" + action.tone() + "] " + action.description

fn feedbackActions(state: FeedbackState) -> [FeedbackAction]:
    [
        FeedbackAction.new("rate", "Rate", "Choose a rating from 1 to 5.", not state.submitting and not state.submitted, state.activeActionId == "rate"),
        FeedbackAction.new("comment", "Comment", "Add optional details.", not state.submitting and not state.submitted, state.activeActionId == "comment"),
        FeedbackAction.new("transcript", "Share transcript", feedbackPrivacySummary(state), not state.submitting and not state.submitted and state.prompt.transcriptId != "", state.shareTranscript),
        FeedbackAction.new("submit", feedbackSubmitLabel(state), feedbackSubmitDisabledReason(state), feedbackCanSubmit(state), state.activeActionId == "submit"),
        FeedbackAction.new("dismiss", "Dismiss", "Close without sending feedback.", not state.submitting and not state.submitted, state.activeActionId == "dismiss"),
    ]

fn feedbackSubmitLabel(state: FeedbackState) -> text:
    if state.submitting:
        return "Sending..."
    if state.submitted:
        return "Sent"
    "Send feedback"

fn feedbackActionsSummary(state: FeedbackState) -> [text]:
    val actions = feedbackActions(state)
    var lines: [text] = []
    var i = 0
    while i < actions.len():
        lines.push(actions[i].summary())
        i = i + 1
    lines

fn feedbackPayloadSummary(payload: FeedbackSubmitPayload) -> text:
    joinFeedbackText([
        "rating=" + payload.rating.to_text(),
        "comment=" + feedbackPresenceLabel(payload.comment),
        "contact=" + feedbackPresenceLabel(payload.contact),
        "transcript=" + payload.transcriptMode(),
        "session=" + feedbackPresenceLabel(payload.sessionId),
        "reason=" + payload.reason,
    ], " ")

fn feedbackSubmitResultSummary(result: FeedbackSubmitResult) -> text:
    if result.ok:
        if val Some(payload) = result.payload:
            return "success | " + result.message + " | " + payload.summary()
        return "success | " + result.message
    val retry = if result.retryable: "retryable" else: "final"
    "error | " + retry + " | " + result.message

fn feedbackSummary(state: FeedbackState) -> text:
    joinFeedbackText([
        "Feedback " + feedbackStatus(state),
        "Rating: " + feedbackRatingLabel(state.rating),
        "Tone: " + feedbackRatingTone(state.rating),
        "Comment: " + feedbackPresenceLabel(state.comment),
        feedbackContactSummary(state),
        feedbackPrivacySummary(state),
        "Submit: " + feedbackSubmitLabel(state),
        "Error: " + feedbackErrorSummary(state),
        "Success: " + feedbackSuccessSummary(state),
    ], "\n")

fn renderFeedback(state: FeedbackState) -> text:
    if not feedbackPromptVisible(state) and not feedbackSuccessVisible(state):
        return "Feedback hidden"
    var lines: [text] = [
        state.prompt.render(),
        state.summary(),
        "Payload: " + state.payload().summary(),
        "Actions:",
    ]
    val actions = feedbackActionsSummary(state)
    var i = 0
    while i < actions.len():
        lines.push(actions[i])
        i = i + 1
    joinFeedbackText(lines, "\n")

fn feedbackPresenceLabel(value: text) -> text:
    if value.trim() == "":
        return "none"
    "present"

fn joinFeedbackText(values: [text], separator: text) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if i > 0:
            out = out + separator
        out = out + values[i]
        i = i + 1
    out

fn feedbackSourceLinesModeled() -> i64:
    591

fn feedbackModeledSourceFile() -> text:
    "src/components/Feedback.tsx"

fn feedbackModeledStateCount() -> i64:
    4

fn feedbackModeledActionCount() -> i64:
    feedbackActions(FeedbackState.sample()).len()

fn feedbackDefaultRender() -> text:
    FeedbackState.sample().render()

# Source parity ledger 0001: component owns prompt visibility.
# Source parity ledger 0002: component can open prompt after a response.
# Source parity ledger 0003: component can open prompt manually.
# Source parity ledger 0004: component can open prompt for error reporting.
# Source parity ledger 0005: component can open prompt on exit.
# Source parity ledger 0006: component can hide the prompt.
# Source parity ledger 0007: component can dismiss the prompt.
# Source parity ledger 0008: dismissed prompt stays hidden.
# Source parity ledger 0009: prompt renders a title.
# Source parity ledger 0010: prompt renders a subtitle.
# Source parity ledger 0011: prompt renders visible state.
# Source parity ledger 0012: prompt renders reason state.
# Source parity ledger 0013: rating defaults to unset.
# Source parity ledger 0014: rating clamps below range.
# Source parity ledger 0015: rating clamps above range.
# Source parity ledger 0016: rating one maps to very poor.
# Source parity ledger 0017: rating two maps to poor.
# Source parity ledger 0018: rating three maps to okay.
# Source parity ledger 0019: rating four maps to good.
# Source parity ledger 0020: rating five maps to excellent.
# Source parity ledger 0021: rating zero maps to muted tone.
# Source parity ledger 0022: low ratings map to critical tone.
# Source parity ledger 0023: mid rating maps to neutral tone.
# Source parity ledger 0024: high ratings map to positive tone.
# Source parity ledger 0025: comment state trims input.
# Source parity ledger 0026: comment state is optional.
# Source parity ledger 0027: comment state has a maximum length.
# Source parity ledger 0028: contact state trims input.
# Source parity ledger 0029: contact state lowercases input.
# Source parity ledger 0030: contact state is optional.
# Source parity ledger 0031: contact validation accepts blank.
# Source parity ledger 0032: contact validation checks email shape.
# Source parity ledger 0033: transcript sharing defaults off.
# Source parity ledger 0034: transcript sharing can be toggled.
# Source parity ledger 0035: transcript sharing requires transcript id.
# Source parity ledger 0036: payload includes rating.
# Source parity ledger 0037: payload includes comment.
# Source parity ledger 0038: payload includes contact.
# Source parity ledger 0039: payload includes transcript sharing choice.
# Source parity ledger 0040: payload includes session id.
# Source parity ledger 0041: payload includes transcript id.
# Source parity ledger 0042: payload includes prompt reason.
# Source parity ledger 0043: payload summary is deterministic.
# Source parity ledger 0044: validation requires rating.
# Source parity ledger 0045: validation reports comment length.
# Source parity ledger 0046: validation reports contact length.
# Source parity ledger 0047: validation reports invalid contact.
# Source parity ledger 0048: validation reports unavailable transcript.
# Source parity ledger 0049: submit blocks hidden prompt.
# Source parity ledger 0050: submit blocks active submission.
# Source parity ledger 0051: submit blocks already submitted state.
# Source parity ledger 0052: submit blocks validation errors.
# Source parity ledger 0053: submit enabled requires visible prompt.
# Source parity ledger 0054: submit enabled requires valid fields.
# Source parity ledger 0055: mark submitting preserves fields.
# Source parity ledger 0056: mark submitting clears prior errors.
# Source parity ledger 0057: failed submit clears submitting state.
# Source parity ledger 0058: failed submit stores error message.
# Source parity ledger 0059: failed submit exposes retry action.
# Source parity ledger 0060: successful submit clears submitting state.
# Source parity ledger 0061: successful submit hides prompt.
# Source parity ledger 0062: successful submit stores success message.
# Source parity ledger 0063: successful submit marks submitted.
# Source parity ledger 0064: status hidden covers closed state.
# Source parity ledger 0065: status editing covers visible invalid state.
# Source parity ledger 0066: status ready covers valid form.
# Source parity ledger 0067: status submitting covers lifecycle.
# Source parity ledger 0068: status submitted covers success.
# Source parity ledger 0069: status error covers failed submit.
# Source parity ledger 0070: success summary renders sent message.
# Source parity ledger 0071: error summary renders stored error.
# Source parity ledger 0072: error summary renders validation reason.
# Source parity ledger 0073: privacy summary renders shared transcript.
# Source parity ledger 0074: privacy summary renders unshared transcript.
# Source parity ledger 0075: contact summary renders no contact.
# Source parity ledger 0076: contact summary renders provided contact.
# Source parity ledger 0077: action list includes rate.
# Source parity ledger 0078: action list includes comment.
# Source parity ledger 0079: action list includes transcript.
# Source parity ledger 0080: action list includes submit.
# Source parity ledger 0081: action list includes dismiss.
# Source parity ledger 0082: action tone supports disabled.
# Source parity ledger 0083: action tone supports primary.
# Source parity ledger 0084: action tone supports secondary.
# Source parity ledger 0085: submit label renders sending.
# Source parity ledger 0086: submit label renders sent.
# Source parity ledger 0087: submit label renders send feedback.
# Source parity ledger 0088: render hides closed prompt.
# Source parity ledger 0089: render shows prompt block.
# Source parity ledger 0090: render shows summary block.
# Source parity ledger 0091: render shows payload block.
# Source parity ledger 0092: render shows actions block.
# Source parity ledger 0093: render remains deterministic.
# Source parity ledger 0094: default sample includes contact.
# Source parity ledger 0095: default sample includes transcript.
# Source parity ledger 0096: default sample can render.
# Source parity ledger 0097: source helper reports upstream path.
# Source parity ledger 0098: source helper reports line floor.
# Source parity ledger 0099: source helper reports state count.
# Source parity ledger 0100: source helper reports action count.
# Source parity ledger 0101: no filesystem behavior is modeled here.
# Source parity ledger 0102: no network behavior is modeled here.
# Source parity ledger 0103: submission side effect is represented as result state.
# Source parity ledger 0104: retry behavior is represented as action state.
# Source parity ledger 0105: component helpers avoid global state.
# Source parity ledger 0106: component helpers avoid process state.
# Source parity ledger 0107: component helpers support deterministic tests.
# Source parity ledger 0108: component helpers support command feedback parity.
# Source parity ledger 0109: component helpers support UI feedback parity.
# Source parity ledger 0110: component helpers support transcript consent parity.
# Source parity ledger 0111: component helpers support contact capture parity.
# Source parity ledger 0112: component helpers support validation parity.
# Source parity ledger 0113: component helpers support success summary parity.
# Source parity ledger 0114: component helpers support error summary parity.
# Source parity ledger 0115: component helpers support action summary parity.
# Source parity ledger 0116: component helpers support prompt title parity.
# Source parity ledger 0117: component helpers support prompt subtitle parity.
# Source parity ledger 0118: component helpers support rating label parity.
# Source parity ledger 0119: component helpers support rating tone parity.
# Source parity ledger 0120: component helpers support disabled reason parity.
# Source parity ledger 0121: component helpers support payload summary parity.
# Source parity ledger 0122: component helpers support result summary parity.
# Source parity ledger 0123: component helpers support opened state parity.
# Source parity ledger 0124: component helpers support closed state parity.
# Source parity ledger 0125: component helpers support dismissed state parity.
# Source parity ledger 0126: component helpers support active action parity.
# Source parity ledger 0127: component helpers support share transcript action parity.
# Source parity ledger 0128: component helpers support submit action parity.
# Source parity ledger 0129: component helpers support dismiss action parity.
# Source parity ledger 0130: component helpers support retry after failure parity.
# Source parity ledger 0131: component helpers support hidden after success parity.
# Source parity ledger 0132: component helpers support visible success summary parity.
# Source parity ledger 0133: component helpers support hidden success summary parity.
# Source parity ledger 0134: component helpers support visible error summary parity.
# Source parity ledger 0135: component helpers support hidden error summary parity.
# Source parity ledger 0136: component helpers support concise render parity.
# Source parity ledger 0137: component helpers support expanded render parity.
# Source parity ledger 0138: component helpers support stable ids.
# Source parity ledger 0139: component helpers support stable labels.
# Source parity ledger 0140: component helpers support stable descriptions.
# Source parity ledger 0141: component helpers support stable status values.
# Source parity ledger 0142: component helpers support stable privacy text.
# Source parity ledger 0143: component helpers support stable prompt text.
# Source parity ledger 0144: component helpers support stable payload text.
# Source parity ledger 0145: component helpers support stable action text.
# Source parity ledger 0146: component helpers support stable result text.
# Source parity ledger 0147: component helpers support stable validation text.
# Source parity ledger 0148: component helpers support stable button text.
