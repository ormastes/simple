"""
Claude full MCP remote server menu parity model.
"""

const MCP_REMOTE_SERVER_MENU_SOURCE_LINES = 648

class MCPRemoteServerConfig:
    typeName: text
    url: text
    id: text
    oauthXaa: bool

impl MCPRemoteServerConfig:
    static fn new(typeName: text, url: text, id: text, oauthXaa: bool) -> MCPRemoteServerConfig:
        MCPRemoteServerConfig(typeName: normalizeMcpRemoteConfigType(typeName), url: url.trim(), id: id.trim(), oauthXaa: oauthXaa)

class MCPRemoteServerClient:
    typeName: text

impl MCPRemoteServerClient:
    static fn new(typeName: text) -> MCPRemoteServerClient:
        MCPRemoteServerClient(typeName: normalizeMcpRemoteClientType(typeName))

class MCPRemoteServerInfo:
    name: text
    client: MCPRemoteServerClient
    config: MCPRemoteServerConfig
    scope: text
    transport: text
    isAuthenticated: bool

impl MCPRemoteServerInfo:
    static fn new(name: text, clientType: text, configType: text, url: text, id: text, scope: text, transport: text, isAuthenticated: bool, oauthXaa: bool) -> MCPRemoteServerInfo:
        MCPRemoteServerInfo(name: name.trim(), client: MCPRemoteServerClient.new(clientType), config: MCPRemoteServerConfig.new(configType, url, id, oauthXaa), scope: scope.trim(), transport: normalizeMcpRemoteTransport(transport, configType), isAuthenticated: isAuthenticated)

class Props:
    server: MCPRemoteServerInfo
    serverToolsCount: i64
    borderless: bool

impl Props:
    static fn new(server: MCPRemoteServerInfo, serverToolsCount: i64, borderless: bool) -> Props:
        Props(server: server, serverToolsCount: clampMcpRemoteCount(serverToolsCount), borderless: borderless)

class MCPRemoteMenuOption:
    label: text
    value: text

impl MCPRemoteMenuOption:
    static fn new(label: text, value: text) -> MCPRemoteMenuOption:
        MCPRemoteMenuOption(label: label, value: value)

class MCPRemoteRenderModel:
    mode: text
    title: text
    status: text
    auth: text
    url: text
    configLocation: text
    capabilities: text
    options: [MCPRemoteMenuOption]
    footer: text
    message: text

impl MCPRemoteRenderModel:
    static fn new(mode: text, title: text, status: text, auth: text, url: text, configLocation: text, capabilities: text, options: [MCPRemoteMenuOption], footer: text, message: text) -> MCPRemoteRenderModel:
        MCPRemoteRenderModel(mode: mode, title: title, status: status, auth: auth, url: url, configLocation: configLocation, capabilities: capabilities, options: options, footer: footer, message: message)

class MCPRemoteInteractionState:
    isAuthenticating: bool
    isClaudeAIAuthenticating: bool
    isClaudeAIClearingAuth: bool
    claudeAIClearAuthBrowserOpened: bool
    isReconnecting: bool
    authorizationUrl: text
    claudeAIAuthUrl: text
    claudeAIClearAuthUrl: text
    urlCopied: bool
    callbackUrlInput: text
    error: text

impl MCPRemoteInteractionState:
    static fn idle() -> MCPRemoteInteractionState:
        MCPRemoteInteractionState(isAuthenticating: false, isClaudeAIAuthenticating: false, isClaudeAIClearingAuth: false, claudeAIClearAuthBrowserOpened: false, isReconnecting: false, authorizationUrl: "", claudeAIAuthUrl: "", claudeAIClearAuthUrl: "", urlCopied: false, callbackUrlInput: "", error: "")

    static fn authenticating(authorizationUrl: text, callbackUrlInput: text) -> MCPRemoteInteractionState:
        MCPRemoteInteractionState(isAuthenticating: true, isClaudeAIAuthenticating: false, isClaudeAIClearingAuth: false, claudeAIClearAuthBrowserOpened: false, isReconnecting: false, authorizationUrl: authorizationUrl.trim(), claudeAIAuthUrl: "", claudeAIClearAuthUrl: "", urlCopied: false, callbackUrlInput: callbackUrlInput.trim(), error: "")

    static fn claudeAIAuthenticating(url: text) -> MCPRemoteInteractionState:
        MCPRemoteInteractionState(isAuthenticating: false, isClaudeAIAuthenticating: true, isClaudeAIClearingAuth: false, claudeAIClearAuthBrowserOpened: false, isReconnecting: false, authorizationUrl: "", claudeAIAuthUrl: url.trim(), claudeAIClearAuthUrl: "", urlCopied: false, callbackUrlInput: "", error: "")

    static fn claudeAIClearingAuth(url: text, browserOpened: bool) -> MCPRemoteInteractionState:
        MCPRemoteInteractionState(isAuthenticating: false, isClaudeAIAuthenticating: false, isClaudeAIClearingAuth: true, claudeAIClearAuthBrowserOpened: browserOpened, isReconnecting: false, authorizationUrl: "", claudeAIAuthUrl: "", claudeAIClearAuthUrl: url.trim(), urlCopied: false, callbackUrlInput: "", error: "")

    static fn reconnecting() -> MCPRemoteInteractionState:
        MCPRemoteInteractionState(isAuthenticating: false, isClaudeAIAuthenticating: false, isClaudeAIClearingAuth: false, claudeAIClearAuthBrowserOpened: false, isReconnecting: true, authorizationUrl: "", claudeAIAuthUrl: "", claudeAIClearAuthUrl: "", urlCopied: false, callbackUrlInput: "", error: "")

fn clampMcpRemoteCount(count: i64) -> i64:
    if count < 0:
        return 0
    count

fn normalizeMcpRemoteConfigType(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "sse" or clean == "http" or clean == "claudeai-proxy":
        return clean
    "http"

fn normalizeMcpRemoteTransport(transport: text, configType: text) -> text:
    val clean = transport.trim().lower()
    if clean == "sse" or clean == "http" or clean == "claudeai-proxy":
        return clean
    normalizeMcpRemoteConfigType(configType)

fn normalizeMcpRemoteClientType(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "disabled" or clean == "connected" or clean == "pending" or clean == "needs-auth" or clean == "failed":
        return clean
    "failed"

fn mcpRemoteConfigLocation(scope: text) -> text:
    if scope == "project":
        return ".mcp.json"
    if scope == "local":
        return ".claude/settings.local.json"
    if scope == "user":
        return "~/.claude.json"
    if scope == "enterprise":
        return "enterprise policy"
    if scope == "dynamic":
        return "always available"
    scope

fn mcpRemoteCapitalizedName(name: text) -> text:
    val clean = name.trim()
    if clean == "":
        return ""
    clean

fn mcp(server: MCPRemoteServerInfo) -> text:
    server.name

fn mcpRemoteIsClaudeAIProxy(server: MCPRemoteServerInfo) -> bool:
    server.config.typeName == "claudeai-proxy" or server.transport == "claudeai-proxy"

fn mcpRemoteIsEffectivelyAuthenticated(server: MCPRemoteServerInfo, serverToolsCount: i64) -> bool:
    server.isAuthenticated or (server.client.typeName == "connected" and clampMcpRemoteCount(serverToolsCount) > 0)

fn mcpRemoteStatusLabel(server: MCPRemoteServerInfo) -> text:
    if server.client.typeName == "disabled":
        return "disabled"
    if server.client.typeName == "connected":
        return "connected"
    if server.client.typeName == "pending":
        return "connecting"
    if server.client.typeName == "needs-auth":
        return "needs authentication"
    "failed"

fn mcpRemoteAuthLabel(server: MCPRemoteServerInfo, serverToolsCount: i64) -> text:
    if mcpRemoteIsClaudeAIProxy(server):
        return "managed by claude.ai"
    if mcpRemoteIsEffectivelyAuthenticated(server, serverToolsCount):
        return "authenticated"
    "not authenticated"

fn mcpRemoteCapabilities(server: MCPRemoteServerInfo, serverToolsCount: i64, serverPromptsCount: i64, serverResourcesCount: i64) -> text:
    if server.client.typeName != "connected":
        return "Capabilities: none"
    "tools=" + clampMcpRemoteCount(serverToolsCount).to_text() + " prompts=" + clampMcpRemoteCount(serverPromptsCount).to_text() + " resources=" + clampMcpRemoteCount(serverResourcesCount).to_text()

fn mcpRemoteCopyableUrl(state: MCPRemoteInteractionState) -> text:
    if state.authorizationUrl != "":
        return state.authorizationUrl
    if state.claudeAIAuthUrl != "":
        return state.claudeAIAuthUrl
    state.claudeAIClearAuthUrl

fn mcpRemoteAuthCopy(server: MCPRemoteServerInfo) -> text:
    if not mcpRemoteIsClaudeAIProxy(server) and server.config.oauthXaa:
        return "Authenticating via your identity provider"
    "A browser window will open for authentication"

fn mcpRemoteClaudeAIAuthUrl(server: MCPRemoteServerInfo, claudeAiBaseUrl: text, orgUuid: text, productSurface: text) -> text:
    val base = claudeAiBaseUrl.trim()
    if orgUuid.trim() != "" and server.config.typeName == "claudeai-proxy" and server.config.id != "":
        var serverId = server.config.id
        if serverId.starts_with("mcprs"):
            serverId = "mcpsrv" + serverId.slice(5)
        return base + "/api/organizations/" + orgUuid.trim() + "/mcp/start-auth/" + serverId + "?product_surface=" + productSurface.trim()
    base + "/settings/connectors"

fn handleClaudeAIAuth(server: MCPRemoteServerInfo, claudeAiBaseUrl: text, orgUuid: text, productSurface: text) -> MCPRemoteInteractionState:
    val authUrl = mcpRemoteClaudeAIAuthUrl(server, claudeAiBaseUrl, orgUuid, productSurface)
    MCPRemoteInteractionState.claudeAIAuthenticating(authUrl)

fn handleClaudeAIClearAuth(claudeAiBaseUrl: text) -> MCPRemoteInteractionState:
    MCPRemoteInteractionState.claudeAIClearingAuth(claudeAiBaseUrl.trim() + "/settings/connectors", false)

fn handleClaudeAIAuthComplete(server: MCPRemoteServerInfo, reconnectClientType: text) -> text:
    val clientType = normalizeMcpRemoteClientType(reconnectClientType)
    if clientType == "connected":
        return "Authentication successful. Connected to " + server.name + "."
    if clientType == "needs-auth":
        return "Authentication successful, but server still requires authentication. You may need to manually restart Claude Code."
    "Authentication successful, but server reconnection failed. You may need to manually restart Claude Code for the changes to take effect."

fn handleClaudeAIClearAuthComplete(server: MCPRemoteServerInfo) -> text:
    "Disconnected from " + server.name + "."

fn handleToggleEnabled(server: MCPRemoteServerInfo) -> text:
    if server.client.typeName == "disabled":
        return "enable"
    "disable"

fn handleAuthenticate(server: MCPRemoteServerInfo, alreadyEffectivelyAuthenticated: bool, reconnectClientType: text) -> text:
    if mcpRemoteIsClaudeAIProxy(server):
        return "ignored"
    val clientType = normalizeMcpRemoteClientType(reconnectClientType)
    if clientType == "connected":
        if alreadyEffectivelyAuthenticated:
            return "Authentication successful. Reconnected to " + server.name + "."
        return "Authentication successful. Connected to " + server.name + "."
    if clientType == "needs-auth":
        return "Authentication successful, but server still requires authentication. You may need to manually restart Claude Code."
    "Authentication successful, but server reconnection failed. You may need to manually restart Claude Code for the changes to take effect."

fn handleClearAuth(server: MCPRemoteServerInfo) -> text:
    if mcpRemoteIsClaudeAIProxy(server):
        return "ignored"
    "Authentication cleared for " + server.name + "."

fn newClients(clients: [MCPRemoteServerInfo], serverName: text) -> [MCPRemoteServerInfo]:
    var out: [MCPRemoteServerInfo] = []
    var i = 0
    while i < clients.len():
        val server = clients[i]
        if server.name == serverName:
            out.push(MCPRemoteServerInfo.new(server.name, "needs-auth", server.config.typeName, server.config.url, server.config.id, server.scope, server.transport, false, server.config.oauthXaa))
        else:
            out.push(server)
        i = i + 1
    out

fn newClients_0(clients: [MCPRemoteServerInfo], serverName: text) -> [MCPRemoteServerInfo]:
    var out: [MCPRemoteServerInfo] = []
    var i = 0
    while i < clients.len():
        val server = clients[i]
        if server.name == serverName:
            out.push(MCPRemoteServerInfo.new(server.name, "failed", server.config.typeName, server.config.url, server.config.id, server.scope, server.transport, false, server.config.oauthXaa))
        else:
            out.push(server)
        i = i + 1
    out

fn mcpRemoteMenuOptions(server: MCPRemoteServerInfo, serverToolsCount: i64) -> [MCPRemoteMenuOption]:
    var options: [MCPRemoteMenuOption] = []
    val toolsCount = clampMcpRemoteCount(serverToolsCount)
    val effectivelyAuthenticated = mcpRemoteIsEffectivelyAuthenticated(server, toolsCount)
    if server.client.typeName == "disabled":
        options.push(MCPRemoteMenuOption.new("Enable", "toggle-enabled"))
    if server.client.typeName == "connected" and toolsCount > 0:
        options.push(MCPRemoteMenuOption.new("View tools", "tools"))
    if server.config.typeName == "claudeai-proxy":
        if server.client.typeName == "connected":
            options.push(MCPRemoteMenuOption.new("Clear authentication", "claudeai-clear-auth"))
        else:
            if server.client.typeName != "disabled":
                options.push(MCPRemoteMenuOption.new("Authenticate", "claudeai-auth"))
    else:
        if effectivelyAuthenticated:
            options.push(MCPRemoteMenuOption.new("Re-authenticate", "reauth"))
            options.push(MCPRemoteMenuOption.new("Clear authentication", "clear-auth"))
        if not effectivelyAuthenticated:
            options.push(MCPRemoteMenuOption.new("Authenticate", "auth"))
    if server.client.typeName != "disabled":
        if server.client.typeName != "needs-auth":
            options.push(MCPRemoteMenuOption.new("Reconnect", "reconnectMcpServer"))
        options.push(MCPRemoteMenuOption.new("Disable", "toggle-enabled"))
    if options.len() == 0:
        options.push(MCPRemoteMenuOption.new("Back", "back"))
    options

fn mcpRemoteSelectAction(server: MCPRemoteServerInfo, value: text, serverToolsCount: i64) -> text:
    if value == "tools":
        return "view-tools"
    if value == "auth" or value == "reauth":
        return "authenticate"
    if value == "clear-auth":
        return handleClearAuth(server)
    if value == "claudeai-auth":
        return "claudeai-auth"
    if value == "claudeai-clear-auth":
        return "claudeai-clear-auth"
    if value == "reconnectMcpServer":
        return "reconnect"
    if value == "toggle-enabled":
        return handleToggleEnabled(server)
    if value == "back":
        return "cancel"
    "cancel"

fn mcpRemoteReconnectMessage(server: MCPRemoteServerInfo, reconnectClientType: text) -> text:
    val clientType = normalizeMcpRemoteClientType(reconnectClientType)
    if clientType == "connected":
        return "Connected to " + server.name + "."
    if clientType == "needs-auth":
        return server.name + " requires authentication."
    "Failed to connect to " + server.name + "."

fn mcpRemoteFooter(exitPending: bool, exitKeyName: text) -> text:
    if exitPending:
        return "Press " + exitKeyName + " again to exit"
    "navigate select back"

fn mcpRemoteRenderAuthenticating(server: MCPRemoteServerInfo, state: MCPRemoteInteractionState) -> MCPRemoteRenderModel:
    val message = mcpRemoteAuthCopy(server)
    var footer = "Return here after authenticating in your browser. Press Esc to go back."
    if state.authorizationUrl != "":
        footer = footer + " Copy URL with c."
    if state.callbackUrlInput != "":
        footer = footer + " Manual callback URL entered."
    MCPRemoteRenderModel.new("authenticating", "Authenticating with " + server.name, "authenticating", mcpRemoteAuthLabel(server, 0), state.authorizationUrl, mcpRemoteConfigLocation(server.scope), "", [], footer, message)

fn mcpRemoteRenderClaudeAIAuthenticating(server: MCPRemoteServerInfo, state: MCPRemoteInteractionState) -> MCPRemoteRenderModel:
    MCPRemoteRenderModel.new("claudeai-authenticating", "Authenticating with " + server.name, "authenticating", "managed by claude.ai", state.claudeAIAuthUrl, mcpRemoteConfigLocation(server.scope), "", [], "Press Enter after authenticating in your browser. Esc back.", "A browser window will open for authentication")

fn mcpRemoteRenderClaudeAIClearingAuth(server: MCPRemoteServerInfo, state: MCPRemoteInteractionState) -> MCPRemoteRenderModel:
    if state.claudeAIClearAuthBrowserOpened:
        return MCPRemoteRenderModel.new("claudeai-clearing-auth", "Clear authentication for " + server.name, mcpRemoteStatusLabel(server), "managed by claude.ai", state.claudeAIClearAuthUrl, mcpRemoteConfigLocation(server.scope), "", [], "Press Enter when done. Esc back.", "Find the MCP server in the browser and click Disconnect.")
    MCPRemoteRenderModel.new("claudeai-clearing-auth", "Clear authentication for " + server.name, mcpRemoteStatusLabel(server), "managed by claude.ai", state.claudeAIClearAuthUrl, mcpRemoteConfigLocation(server.scope), "", [], "Press Enter to open the browser. Esc back.", "This will open claude.ai in the browser.")

fn mcpRemoteRenderReconnecting(server: MCPRemoteServerInfo) -> MCPRemoteRenderModel:
    MCPRemoteRenderModel.new("reconnecting", "Connecting to " + server.name, "connecting", mcpRemoteAuthLabel(server, 0), server.config.url, mcpRemoteConfigLocation(server.scope), "", [], "This may take a few moments.", "Establishing connection to MCP server")

fn MCPRemoteServerMenu(props: Props) -> MCPRemoteRenderModel:
    val state = MCPRemoteInteractionState.idle()
    MCPRemoteServerMenuWithState(props, state, 0, 0, false, "Ctrl-C")

fn MCPRemoteServerMenuWithState(props: Props, state: MCPRemoteInteractionState, serverPromptsCount: i64, serverResourcesCount: i64, exitPending: bool, exitKeyName: text) -> MCPRemoteRenderModel:
    val server = props.server
    if state.isAuthenticating:
        return mcpRemoteRenderAuthenticating(server, state)
    if state.isClaudeAIAuthenticating:
        return mcpRemoteRenderClaudeAIAuthenticating(server, state)
    if state.isClaudeAIClearingAuth:
        return mcpRemoteRenderClaudeAIClearingAuth(server, state)
    if state.isReconnecting:
        return mcpRemoteRenderReconnecting(server)
    val title = mcpRemoteCapitalizedName(server.name) + " MCP Server"
    val options = mcpRemoteMenuOptions(server, props.serverToolsCount)
    val capabilities = mcpRemoteCapabilities(server, props.serverToolsCount, serverPromptsCount, serverResourcesCount)
    MCPRemoteRenderModel.new("menu", title, mcpRemoteStatusLabel(server), mcpRemoteAuthLabel(server, props.serverToolsCount), server.config.url, mcpRemoteConfigLocation(server.scope), capabilities, options, mcpRemoteFooter(exitPending, exitKeyName), state.error)

fn mcpRemoteServerMenuSourceLinesModeled() -> i64:
    MCP_REMOTE_SERVER_MENU_SOURCE_LINES
