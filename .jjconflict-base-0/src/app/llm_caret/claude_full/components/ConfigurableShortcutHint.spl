fn shortcutHintLabel(action: text, shortcut: text) -> text:
    action.trim() + ": " + shortcut.trim()

fn shortcutHintVisible(shortcut: text) -> bool:
    shortcut.trim() != ""

fn configurableShortcutHintSourceLinesModeled() -> i64:
