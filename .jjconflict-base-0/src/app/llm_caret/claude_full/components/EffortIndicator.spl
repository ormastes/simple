"""
Claude full EffortIndicator parity.
"""

fn normalizeEffortLevel(level: text) -> text:
    val clean = level.trim()
    if clean == "low" or clean == "medium" or clean == "high":
        return clean
    "medium"

fn effortIndicatorLabel(level: text) -> text:
    "effort " + normalizeEffortLevel(level)

fn effortIndicatorTone(level: text) -> text:
    val clean = normalizeEffortLevel(level)
    if clean == "high":
        return "warning"
    if clean == "low":
        return "muted"
    "default"

fn effortIndicatorSourceLinesModeled() -> i64:
    42
