"""
Claude full ApproveApiKey component parity.
"""

class ApiKeyApproval:
    provider: text
    maskedKey: text
    approved: bool

impl ApiKeyApproval:
    static fn new(provider: text, maskedKey: text, approved: bool) -> ApiKeyApproval:
        ApiKeyApproval(provider: provider.trim(), maskedKey: maskedKey.trim(), approved: approved)

fn approveApiKeyMessage(state: ApiKeyApproval) -> text:
    if state.approved:
        return "Approved " + state.provider + " key " + state.maskedKey
    "Approve " + state.provider + " key " + state.maskedKey

fn approveApiKeyCanSubmit(state: ApiKeyApproval) -> bool:
    state.provider != "" and state.maskedKey != ""

fn approveApiKeySourceLinesModeled() -> i64:
    122
