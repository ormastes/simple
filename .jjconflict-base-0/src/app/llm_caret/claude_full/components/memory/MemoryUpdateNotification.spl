"""
Claude full memory update notification parity model.
"""

const MEMORY_UPDATE_NOTIFICATION_SOURCE_LINES = 44

class MemoryUpdateNotificationModel:
    memoryPath: text
    homeDir: text
    cwd: text
    displayPath: text
    message: text

impl MemoryUpdateNotificationModel:
    static fn new(memoryPath: text, homeDir: text, cwd: text) -> MemoryUpdateNotificationModel:
        val displayPath = getRelativeMemoryPath(memoryPath, homeDir, cwd)
        MemoryUpdateNotificationModel(memoryPath: memoryPath, homeDir: homeDir, cwd: cwd, displayPath: displayPath, message: "Memory updated in " + displayPath + " - /memory to edit")

fn memoryRelativePath(fromDir: text, path: text) -> text:
    if path == fromDir:
        return ""
    if path.starts_with(fromDir + "/"):
        return path.slice(fromDir.len() + 1)
    path

fn getRelativeMemoryPath(path: text, homeDir: text, cwd: text) -> text:
    var relativeToHome = ""
    var relativeToCwd = ""
    if path.starts_with(homeDir):
        relativeToHome = "~" + path.slice(homeDir.len())
    if path.starts_with(cwd):
        relativeToCwd = "./" + memoryRelativePath(cwd, path)
    if relativeToHome != "" and relativeToCwd != "":
        if relativeToHome.len() <= relativeToCwd.len():
            return relativeToHome
        return relativeToCwd
    if relativeToHome != "":
        return relativeToHome
    if relativeToCwd != "":
        return relativeToCwd
    path

fn memoryUpdateNotification(memoryPath: text, homeDir: text, cwd: text) -> MemoryUpdateNotificationModel:
    MemoryUpdateNotificationModel.new(memoryPath, homeDir, cwd)

fn memoryUpdateNotificationSourceLinesModeled() -> i64:
    MEMORY_UPDATE_NOTIFICATION_SOURCE_LINES
# parity ledger: MemoryUpdateNotification line 044
