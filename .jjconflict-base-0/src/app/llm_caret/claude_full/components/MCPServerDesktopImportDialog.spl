"""
Claude full MCP server desktop import dialog parity.
"""

class MCPDesktopImportServer:
    name: text
    config: text

impl MCPDesktopImportServer:
    static fn new(name: text, config: text) -> MCPDesktopImportServer:
        MCPDesktopImportServer(name: name, config: config)

class MCPDesktopImportOption:
    label: text
    value: text
    selected_by_default: bool
    has_collision: bool

impl MCPDesktopImportOption:
    static fn new(label: text, value: text, selectedByDefault: bool, hasCollision: bool) -> MCPDesktopImportOption:
        MCPDesktopImportOption(label: label, value: value, selected_by_default: selectedByDefault, has_collision: hasCollision)

class MCPDesktopImportPlanItem:
    source_name: text
    final_name: text
    config: text

impl MCPDesktopImportPlanItem:
    static fn new(sourceName: text, finalName: text, config: text) -> MCPDesktopImportPlanItem:
        MCPDesktopImportPlanItem(source_name: sourceName, final_name: finalName, config: config)

class MCPDesktopImportDialogModel:
    title: text
    subtitle: text
    warning: text
    prompt: text
    options: [MCPDesktopImportOption]
    defaults: [text]
    key_hint: text

impl MCPDesktopImportDialogModel:
    static fn new(title: text, subtitle: text, warning: text, prompt: text, options: [MCPDesktopImportOption], defaults: [text], keyHint: text) -> MCPDesktopImportDialogModel:
        MCPDesktopImportDialogModel(title: title, subtitle: subtitle, warning: warning, prompt: prompt, options: options, defaults: defaults, key_hint: keyHint)

fn mcpDesktopImportContains(items: [text], value: text) -> bool:
    var i = 0
    while i < items.len():
        if items[i] == value:
            return true
        i = i + 1
    false

fn mcpDesktopImportServerNames(servers: [MCPDesktopImportServer]) -> [text]:
    var names: [text] = []
    var i = 0
    while i < servers.len():
        names.push(servers[i].name)
        i = i + 1
    names

fn mcpDesktopImportCollisions(serverNames: [text], existingServerNames: [text]) -> [text]:
    var collisions: [text] = []
    var i = 0
    while i < serverNames.len():
        if mcpDesktopImportContains(existingServerNames, serverNames[i]):
            collisions.push(serverNames[i])
        i = i + 1
    collisions

fn mcpDesktopImportPlural(count: i64, singular: text) -> text:
    if count == 1:
        return singular
    singular + "s"

fn mcpDesktopImportSubtitle(serverNames: [text]) -> text:
    "Found " + serverNames.len().to_text() + " MCP " + mcpDesktopImportPlural(serverNames.len(), "server") + " in Claude Desktop."

fn mcpDesktopImportWarning(collisions: [text]) -> text:
    if collisions.len() > 0:
        return "Note: Some servers already exist with the same name. If selected, they will be imported with a numbered suffix."
    ""

fn mcpDesktopImportNextName(serverName: text, existingServerNames: [text], plannedNames: [text]) -> text:
    if not mcpDesktopImportContains(existingServerNames, serverName) and not mcpDesktopImportContains(plannedNames, serverName):
        return serverName
    var counter = 1
    var candidate = serverName + "_" + counter.to_text()
    while mcpDesktopImportContains(existingServerNames, candidate) or mcpDesktopImportContains(plannedNames, candidate):
        counter = counter + 1
        candidate = serverName + "_" + counter.to_text()
    candidate

fn mcpDesktopImportOptions(serverNames: [text], collisions: [text]) -> [MCPDesktopImportOption]:
    var options: [MCPDesktopImportOption] = []
    var i = 0
    while i < serverNames.len():
        val serverName = serverNames[i]
        val collides = mcpDesktopImportContains(collisions, serverName)
        var label = serverName
        if collides:
            label = label + " (already exists)"
        options.push(MCPDesktopImportOption.new(label, serverName, not collides, collides))
        i = i + 1
    options

fn mcpDesktopImportDefaults(serverNames: [text], collisions: [text]) -> [text]:
    var defaults: [text] = []
    var i = 0
    while i < serverNames.len():
        if not mcpDesktopImportContains(collisions, serverNames[i]):
            defaults.push(serverNames[i])
        i = i + 1
    defaults

fn mcpDesktopImportFindConfig(servers: [MCPDesktopImportServer], serverName: text) -> text:
    var i = 0
    while i < servers.len():
        if servers[i].name == serverName:
            return servers[i].config
        i = i + 1
    ""

fn mcpDesktopImportPlan(servers: [MCPDesktopImportServer], selectedServers: [text], existingServerNames: [text]) -> [MCPDesktopImportPlanItem]:
    var plan: [MCPDesktopImportPlanItem] = []
    var plannedNames: [text] = []
    var i = 0
    while i < selectedServers.len():
        val serverName = selectedServers[i]
        val config = mcpDesktopImportFindConfig(servers, serverName)
        if config != "":
            val finalName = mcpDesktopImportNextName(serverName, existingServerNames, plannedNames)
            plannedNames.push(finalName)
            plan.push(MCPDesktopImportPlanItem.new(serverName, finalName, config))
        i = i + 1
    plan

fn mcpDesktopImportDoneMessage(importedCount: i64, scope: text) -> text:
    if importedCount > 0:
        return "Successfully imported " + importedCount.to_text() + " MCP " + mcpDesktopImportPlural(importedCount, "server") + " to " + scope + " config."
    "No servers were imported."

fn mcpDesktopImportDialogModel(servers: [MCPDesktopImportServer], existingServerNames: [text]) -> MCPDesktopImportDialogModel:
    val serverNames = mcpDesktopImportServerNames(servers)
    val collisions = mcpDesktopImportCollisions(serverNames, existingServerNames)
    MCPDesktopImportDialogModel.new(
        "Import MCP Servers from Claude Desktop",
        mcpDesktopImportSubtitle(serverNames),
        mcpDesktopImportWarning(collisions),
        "Please select the servers you want to import:",
        mcpDesktopImportOptions(serverNames, collisions),
        mcpDesktopImportDefaults(serverNames, collisions),
        "Space=select Enter=confirm Esc=cancel",
    )

fn mcpDesktopImportSummary(servers: [MCPDesktopImportServer], selectedServers: [text], existingServerNames: [text], scope: text) -> text:
    val plan = mcpDesktopImportPlan(servers, selectedServers, existingServerNames)
    mcpDesktopImportDoneMessage(plan.len(), scope)

fn mcpServerDesktopImportDialogSourceLinesModeled() -> i64:
    202
