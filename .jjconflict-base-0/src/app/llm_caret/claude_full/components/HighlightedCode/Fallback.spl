"""
Claude full HighlightedCode Fallback parity.
"""

class HighlightFallbackState:
    code: text
    language: text
    show_line_numbers: bool

impl HighlightFallbackState:
    static fn new(code: text, language: text, showLineNumbers: bool) -> HighlightFallbackState:
        HighlightFallbackState(code: code, language: language.trim(), show_line_numbers: showLineNumbers)

fn highlightFallbackLanguage(state: HighlightFallbackState) -> text:
    if state.language == "":
        return "text"
    state.language

fn highlightFallbackLineCount(state: HighlightFallbackState) -> i64:
    if state.code == "":
        return 0
    var count = 1
    var i = 0
    while i < state.code.len():
        if state.code[i] == "\n":
            count = count + 1
        i = i + 1
    count

fn highlightFallbackSummary(state: HighlightFallbackState) -> text:
    highlightFallbackLanguage(state) + " lines=" + highlightFallbackLineCount(state).to_text()

fn highlightFallbackRender(state: HighlightFallbackState) -> text:
    if state.show_line_numbers:
        return highlightFallbackSummary(state) + "\n" + state.code
    state.code

fn highlightFallbackSourceLinesModeled() -> i64:
    192
