"""
Claude full HighlightedCode parity.
"""

class HighlightedCodeState:
    code: text
    language: text
    theme: text
    fallback: bool

impl HighlightedCodeState:
    static fn new(code: text, language: text, theme: text, fallback: bool) -> HighlightedCodeState:
        HighlightedCodeState(code: code, language: language.trim(), theme: theme.trim(), fallback: fallback)

fn highlightedCodeLanguage(state: HighlightedCodeState) -> text:
    if state.language == "":
        return "text"
    state.language

fn highlightedCodeTheme(state: HighlightedCodeState) -> text:
    if state.theme == "":
        return "dark"
    state.theme

fn highlightedCodeCanHighlight(state: HighlightedCodeState) -> bool:
    not state.fallback and state.code != ""

fn highlightedCodeSummary(state: HighlightedCodeState) -> text:
    highlightedCodeLanguage(state) + " " + highlightedCodeTheme(state)

fn highlightedCodeRenderMode(state: HighlightedCodeState) -> text:
    if highlightedCodeCanHighlight(state):
        return "highlighted"
    "fallback"

fn highlightedCodeSourceLinesModeled() -> i64:
    189
