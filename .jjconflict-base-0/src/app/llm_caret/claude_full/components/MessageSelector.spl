"""
Claude full MessageSelector parity model.
"""

const MESSAGE_SELECTOR_SOURCE_LINES = 830
const MESSAGE_SELECTOR_MAX_VISIBLE_MESSAGES = 7
const MESSAGE_SELECTOR_CURRENT_UUID = "__current__"
const MESSAGE_SELECTOR_TAG_BASH_INPUT = "bash-input"
const MESSAGE_SELECTOR_TAG_COMMAND = "command-message"
const MESSAGE_SELECTOR_TAG_COMMAND_ARGS = "command-args"
const MESSAGE_SELECTOR_TAG_SKILL_FORMAT = "skill-format"
const MESSAGE_SELECTOR_TAG_LOCAL_COMMAND_STDOUT = "local-command-stdout"
const MESSAGE_SELECTOR_TAG_LOCAL_COMMAND_STDERR = "local-command-stderr"
const MESSAGE_SELECTOR_TAG_BASH_STDOUT = "bash-stdout"
const MESSAGE_SELECTOR_TAG_BASH_STDERR = "bash-stderr"
const MESSAGE_SELECTOR_TAG_TASK_NOTIFICATION = "task-notification"
const MESSAGE_SELECTOR_TAG_TEAMMATE_MESSAGE = "teammate-message"
const MESSAGE_SELECTOR_TAG_TICK = "tick"

class MessageSelectorTextBlock:
    typeName: text
    textValue: text

impl MessageSelectorTextBlock:
    static fn new(typeName: text, textValue: text) -> MessageSelectorTextBlock:
        MessageSelectorTextBlock(typeName: typeName, textValue: textValue)

    static fn text(textValue: text) -> MessageSelectorTextBlock:
        MessageSelectorTextBlock(typeName: "text", textValue: textValue)

    static fn toolResult(textValue: text) -> MessageSelectorTextBlock:
        MessageSelectorTextBlock(typeName: "tool_result", textValue: textValue)

    static fn toolUse(textValue: text) -> MessageSelectorTextBlock:
        MessageSelectorTextBlock(typeName: "tool_use", textValue: textValue)

    fn isText() -> bool:
        self.typeName == "text"

    fn isToolResult() -> bool:
        self.typeName == "tool_result"

    fn isToolUse() -> bool:
        self.typeName == "tool_use"

class MessageSelectorPayload:
    contentText: text
    blocks: [MessageSelectorTextBlock]

impl MessageSelectorPayload:
    static fn text(contentText: text) -> MessageSelectorPayload:
        MessageSelectorPayload(contentText: contentText, blocks: [])

    static fn blocks(blocks: [MessageSelectorTextBlock]) -> MessageSelectorPayload:
        MessageSelectorPayload(contentText: "", blocks: blocks)

    fn usesBlocks() -> bool:
        self.blocks.len() > 0

    fn lastBlock() -> MessageSelectorTextBlock?:
        if self.blocks.len() == 0:
            return nil
        self.blocks[self.blocks.len() - 1]

    fn firstBlock() -> MessageSelectorTextBlock?:
        if self.blocks.len() == 0:
            return nil
        self.blocks[0]

class MessageSelectorPatchHunk:
    lines: [text]

impl MessageSelectorPatchHunk:
    static fn new(lines: [text]) -> MessageSelectorPatchHunk:
        MessageSelectorPatchHunk(lines: lines)

class MessageSelectorToolResult:
    filePath: text
    resultType: text
    content: text
    structuredPatch: [MessageSelectorPatchHunk]

impl MessageSelectorToolResult:
    static fn none() -> MessageSelectorToolResult:
        MessageSelectorToolResult(filePath: "", resultType: "", content: "", structuredPatch: [])

    static fn edit(filePath: text, structuredPatch: [MessageSelectorPatchHunk]) -> MessageSelectorToolResult:
        MessageSelectorToolResult(filePath: filePath, resultType: "edit", content: "", structuredPatch: structuredPatch)

    static fn create(filePath: text, content: text) -> MessageSelectorToolResult:
        MessageSelectorToolResult(filePath: filePath, resultType: "create", content: content, structuredPatch: [])

    fn hasFilePatch() -> bool:
        self.filePath != "" and (self.structuredPatch.len() > 0 or self.resultType == "create")

class MessageSelectorMessage:
    uuid: text
    typeName: text
    payload: MessageSelectorPayload
    isMeta: bool
    isCompactSummary: bool
    isVisibleInTranscriptOnly: bool
    isSynthetic: bool
    toolResult: MessageSelectorToolResult
    timestamp: text

impl MessageSelectorMessage:
    static fn user(uuid: text, contentText: text) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "user", payload: MessageSelectorPayload.text(contentText), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: MessageSelectorToolResult.none(), timestamp: "")

    static fn userBlocks(uuid: text, blocks: [MessageSelectorTextBlock]) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "user", payload: MessageSelectorPayload.blocks(blocks), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: MessageSelectorToolResult.none(), timestamp: "")

    static fn assistant(uuid: text, blocks: [MessageSelectorTextBlock]) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "assistant", payload: MessageSelectorPayload.blocks(blocks), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: MessageSelectorToolResult.none(), timestamp: "")

    static fn system(uuid: text) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "system", payload: MessageSelectorPayload.text(""), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: MessageSelectorToolResult.none(), timestamp: "")

    static fn progress(uuid: text) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "progress", payload: MessageSelectorPayload.text(""), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: MessageSelectorToolResult.none(), timestamp: "")

    static fn attachment(uuid: text) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "attachment", payload: MessageSelectorPayload.text(""), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: MessageSelectorToolResult.none(), timestamp: "")

    static fn toolResult(uuid: text, result: MessageSelectorToolResult) -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: uuid, typeName: "tool_result", payload: MessageSelectorPayload.text(""), isMeta: false, isCompactSummary: false, isVisibleInTranscriptOnly: false, isSynthetic: false, toolResult: result, timestamp: "")

    fn withMeta() -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: self.uuid, typeName: self.typeName, payload: self.payload, isMeta: true, isCompactSummary: self.isCompactSummary, isVisibleInTranscriptOnly: self.isVisibleInTranscriptOnly, isSynthetic: self.isSynthetic, toolResult: self.toolResult, timestamp: self.timestamp)

    fn withSynthetic() -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: self.uuid, typeName: self.typeName, payload: self.payload, isMeta: self.isMeta, isCompactSummary: self.isCompactSummary, isVisibleInTranscriptOnly: self.isVisibleInTranscriptOnly, isSynthetic: true, toolResult: self.toolResult, timestamp: self.timestamp)

    fn withCompactSummary() -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: self.uuid, typeName: self.typeName, payload: self.payload, isMeta: self.isMeta, isCompactSummary: true, isVisibleInTranscriptOnly: self.isVisibleInTranscriptOnly, isSynthetic: self.isSynthetic, toolResult: self.toolResult, timestamp: self.timestamp)

    fn withTranscriptOnly() -> MessageSelectorMessage:
        MessageSelectorMessage(uuid: self.uuid, typeName: self.typeName, payload: self.payload, isMeta: self.isMeta, isCompactSummary: self.isCompactSummary, isVisibleInTranscriptOnly: true, isSynthetic: self.isSynthetic, toolResult: self.toolResult, timestamp: self.timestamp)

class MessageSelectorDiffStats:
    filesChanged: [text]
    insertions: i64
    deletions: i64

impl MessageSelectorDiffStats:
    static fn empty() -> MessageSelectorDiffStats:
        MessageSelectorDiffStats(filesChanged: [], insertions: 0, deletions: 0)

    static fn new(filesChanged: [text], insertions: i64, deletions: i64) -> MessageSelectorDiffStats:
        MessageSelectorDiffStats(filesChanged: filesChanged, insertions: insertions, deletions: deletions)

    fn canRestoreCode() -> bool:
        self.filesChanged.len() > 0

    fn deltaText() -> text:
        "+" + self.insertions.to_text() + " -" + self.deletions.to_text()

class MessageSelectorRestoreOption:
    value: text
    label: text
    acceptsFeedback: bool
    defaultFocus: bool

impl MessageSelectorRestoreOption:
    static fn new(value: text, label: text, acceptsFeedback: bool, defaultFocus: bool) -> MessageSelectorRestoreOption:
        MessageSelectorRestoreOption(value: value, label: label, acceptsFeedback: acceptsFeedback, defaultFocus: defaultFocus)

class MessageSelectorRestoreRequest:
    option: text
    messageUuid: text
    feedback: text
    direction: text
    shouldClose: bool
    shouldPreRestore: bool
    restoreConversation: bool
    restoreCode: bool
    summarize: bool
    error: text

impl MessageSelectorRestoreRequest:
    static fn error(message: text) -> MessageSelectorRestoreRequest:
        MessageSelectorRestoreRequest(option: "", messageUuid: "", feedback: "", direction: "", shouldClose: false, shouldPreRestore: false, restoreConversation: false, restoreCode: false, summarize: false, error: message)

    static fn closeOnly(option: text) -> MessageSelectorRestoreRequest:
        MessageSelectorRestoreRequest(option: option, messageUuid: "", feedback: "", direction: "", shouldClose: true, shouldPreRestore: false, restoreConversation: false, restoreCode: false, summarize: false, error: "")

class MessageSelectorWindow:
    firstVisibleIndex: i64
    selectedIndex: i64
    visibleCount: i64
    hasMessagesToSelect: bool

impl MessageSelectorWindow:
    static fn new(firstVisibleIndex: i64, selectedIndex: i64, visibleCount: i64, hasMessagesToSelect: bool) -> MessageSelectorWindow:
        MessageSelectorWindow(firstVisibleIndex: firstVisibleIndex, selectedIndex: selectedIndex, visibleCount: visibleCount, hasMessagesToSelect: hasMessagesToSelect)

    fn lastVisibleIndex() -> i64:
        self.firstVisibleIndex + self.visibleCount - 1

class MessageSelectorOptionRender:
    uuid: text
    label: text
    detail: text
    selected: bool
    current: bool
    canRestoreCode: bool
    warning: text

impl MessageSelectorOptionRender:
    static fn new(uuid: text, label: text, detail: text, selected: bool, current: bool, canRestoreCode: bool, warning: text) -> MessageSelectorOptionRender:
        MessageSelectorOptionRender(uuid: uuid, label: label, detail: detail, selected: selected, current: current, canRestoreCode: canRestoreCode, warning: warning)

class MessageSelectorRenderModel:
    title: text
    mode: text
    lead: text
    footer: text
    error: text
    options: [MessageSelectorOptionRender]
    restoreOptions: [MessageSelectorRestoreOption]
    confirmationText: text
    codeText: text

impl MessageSelectorRenderModel:
    static fn new(title: text, mode: text, lead: text, footer: text, error: text, options: [MessageSelectorOptionRender], restoreOptions: [MessageSelectorRestoreOption], confirmationText: text, codeText: text) -> MessageSelectorRenderModel:
        MessageSelectorRenderModel(title: title, mode: mode, lead: lead, footer: footer, error: error, options: options, restoreOptions: restoreOptions, confirmationText: confirmationText, codeText: codeText)

class MessageSelectorState:
    selectedIndex: i64
    messageToRestoreUuid: text
    diffStatsForRestore: MessageSelectorDiffStats
    hasDiffStatsForRestore: bool
    isRestoring: bool
    restoringOption: text
    selectedRestoreOption: text
    summarizeFromFeedback: text
    summarizeUpToFeedback: text
    error: text
    preselectedUuid: text
    fileHistoryEnabled: bool
    currentUuid: text
    exitPending: bool
    exitKeyName: text

impl MessageSelectorState:
    static fn new(selectedIndex: i64, fileHistoryEnabled: bool) -> MessageSelectorState:
        MessageSelectorState(selectedIndex: selectedIndex, messageToRestoreUuid: "", diffStatsForRestore: MessageSelectorDiffStats.empty(), hasDiffStatsForRestore: false, isRestoring: false, restoringOption: "", selectedRestoreOption: "both", summarizeFromFeedback: "", summarizeUpToFeedback: "", error: "", preselectedUuid: "", fileHistoryEnabled: fileHistoryEnabled, currentUuid: MESSAGE_SELECTOR_CURRENT_UUID, exitPending: false, exitKeyName: "Ctrl-C")

    fn selectedRestoreHasCode(stats: MessageSelectorDiffStats) -> bool:
        self.fileHistoryEnabled and stats.filesChanged.len() > 0 and (self.selectedRestoreOption == "both" or self.selectedRestoreOption == "code")

    me selectIndex(index: i64, optionCount: i64):
        self.selectedIndex = clampMessageSelectorIndex(index, optionCount)

    me moveUp(optionCount: i64):
        self.selectedIndex = clampMessageSelectorIndex(self.selectedIndex - 1, optionCount)

    me moveDown(optionCount: i64):
        self.selectedIndex = clampMessageSelectorIndex(self.selectedIndex + 1, optionCount)

    me jumpToTop(optionCount: i64):
        self.selectedIndex = clampMessageSelectorIndex(0, optionCount)

    me jumpToBottom(optionCount: i64):
        self.selectedIndex = clampMessageSelectorIndex(optionCount - 1, optionCount)

    me selectRestoreMessage(uuid: text, stats: MessageSelectorDiffStats):
        self.messageToRestoreUuid = uuid
        self.diffStatsForRestore = stats
        self.hasDiffStatsForRestore = true

    me clearRestoreMessage():
        self.messageToRestoreUuid = ""
        self.hasDiffStatsForRestore = false
        self.diffStatsForRestore = MessageSelectorDiffStats.empty()

    me setError(message: text):
        self.error = message

    me clearError():
        self.error = ""

class MessageSelectorModel:
    messages: [MessageSelectorMessage]
    state: MessageSelectorState
    columns: i64

impl MessageSelectorModel:
    static fn new(messages: [MessageSelectorMessage], state: MessageSelectorState, columns: i64) -> MessageSelectorModel:
        MessageSelectorModel(messages: messages, state: normalizeMessageSelectorState(messages, state), columns: columns)

    fn messageOptions() -> [MessageSelectorMessage]:
        messageSelectorOptions(self.messages, self.state.currentUuid)

    fn window() -> MessageSelectorWindow:
        val options = self.messageOptions()
        messageSelectorWindow(options.len(), self.state.selectedIndex)

    fn render() -> MessageSelectorRenderModel:
        renderMessageSelector(self)

fn messageSelectorSourceLinesModeled() -> i64:
    MESSAGE_SELECTOR_SOURCE_LINES

fn messageSelectorMaxVisibleMessages() -> i64:
    MESSAGE_SELECTOR_MAX_VISIBLE_MESSAGES

fn minMessageSelectorI64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn maxMessageSelectorI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn clampMessageSelectorIndex(index: i64, count: i64) -> i64:
    if count <= 0:
        return 0
    if index < 0:
        return 0
    if index >= count:
        return count - 1
    index

fn messageSelectorWindow(optionCount: i64, selectedIndex: i64) -> MessageSelectorWindow:
    val cleanSelected = clampMessageSelectorIndex(selectedIndex, optionCount)
    val rawFirst = cleanSelected - (MESSAGE_SELECTOR_MAX_VISIBLE_MESSAGES / 2)
    val maxFirst = maxMessageSelectorI64(0, optionCount - MESSAGE_SELECTOR_MAX_VISIBLE_MESSAGES)
    val firstVisible = maxMessageSelectorI64(0, minMessageSelectorI64(rawFirst, maxFirst))
    val visibleCount = minMessageSelectorI64(MESSAGE_SELECTOR_MAX_VISIBLE_MESSAGES, optionCount)
    MessageSelectorWindow.new(firstVisible, cleanSelected, visibleCount, optionCount > 1)

fn normalizeMessageSelectorState(messages: [MessageSelectorMessage], state: MessageSelectorState) -> MessageSelectorState:
    val options = messageSelectorOptions(messages, state.currentUuid)
    state.selectedIndex = clampMessageSelectorIndex(state.selectedIndex, options.len())
    state

fn messageSelectorOptions(messages: [MessageSelectorMessage], currentUuid: text) -> [MessageSelectorMessage]:
    var out: [MessageSelectorMessage] = []
    var i = 0
    while i < messages.len():
        if selectableUserMessagesFilter(messages[i]):
            out.push(messages[i])
        i = i + 1
    out.push(MessageSelectorMessage.user(currentUuid, ""))
    out

fn messageSelectorContentText(message: MessageSelectorMessage) -> text:
    if not message.payload.usesBlocks():
        return message.payload.contentText.trim()
    if val last = message.payload.lastBlock():
        if last.isText():
            return last.textValue.trim()
    ""

fn messageSelectorFirstBlockIsToolResult(message: MessageSelectorMessage) -> bool:
    if val first = message.payload.firstBlock():
        return first.isToolResult()
    false

fn stripMessageSelectorDisplayTags(value: text) -> text:
    var out = value
    out = removeMessageSelectorTagPair(out, "antml:function_calls")
    out = removeMessageSelectorTagPair(out, "antml:thinking")
    out.trim()

fn removeMessageSelectorTagPair(value: text, tagName: text) -> text:
    val openTag = "<" + tagName + ">"
    val closeTag = "</" + tagName + ">"
    var out = value
    while out.contains(openTag):
        val start = messageSelectorFindIndex(out, openTag)
        val end = messageSelectorFindIndex(out, closeTag)
        if start < 0 or end < start:
            return out
        out = out.slice(0, start) + out.slice(end + closeTag.len(), out.len())
    out

fn messageSelectorFindIndex(haystack: text, needle: text) -> i64:
    if needle == "":
        return 0
    var i = 0
    while i + needle.len() <= haystack.len():
        if haystack.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn messageSelectorContainsTag(value: text, tagName: text) -> bool:
    value.contains("<" + tagName + ">") or value.contains("<" + tagName + " ")

fn messageSelectorExtractTag(value: text, tagName: text) -> text:
    val simpleOpen = "<" + tagName + ">"
    val closeTag = "</" + tagName + ">"
    var start = messageSelectorFindIndex(value, simpleOpen)
    var bodyStart = start + simpleOpen.len()
    if start < 0:
        val attrOpen = "<" + tagName + " "
        start = messageSelectorFindIndex(value, attrOpen)
        if start < 0:
            return ""
        val openEnd = messageSelectorFindIndex(value.slice(start, value.len()), ">")
        if openEnd < 0:
            return ""
        bodyStart = start + openEnd + 1
    val relEnd = messageSelectorFindIndex(value.slice(bodyStart, value.len()), closeTag)
    if relEnd < 0:
        return ""
    value.slice(bodyStart, bodyStart + relEnd).trim()

fn messageSelectorIsMessageTextBlank(value: text) -> bool:
    val clean = stripMessageSelectorDisplayTags(value).trim()
    clean == "" or clean == "(no prompt)"

fn selectableUserMessagesFilter(message: MessageSelectorMessage) -> bool:
    if message.typeName != "user":
        return false
    if messageSelectorFirstBlockIsToolResult(message):
        return false
    if message.isSynthetic:
        return false
    if message.isMeta:
        return false
    if message.isCompactSummary or message.isVisibleInTranscriptOnly:
        return false
    val messageText = messageSelectorContentText(message)
    if messageSelectorIsNonUserAuthoredText(messageText):
        return false
    true

fn messageSelectorIsNonUserAuthoredText(messageText: text) -> bool:
    messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_LOCAL_COMMAND_STDOUT) or messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_LOCAL_COMMAND_STDERR) or messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_BASH_STDOUT) or messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_BASH_STDERR) or messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_TASK_NOTIFICATION) or messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_TICK) or messageSelectorContainsTag(messageText, MESSAGE_SELECTOR_TAG_TEAMMATE_MESSAGE)

fn messageSelectorCurrentOption(currentUuid: text) -> MessageSelectorMessage:
    MessageSelectorMessage.user(currentUuid, "")

fn messageSelectorHasMessagesToSelect(messages: [MessageSelectorMessage], currentUuid: text) -> bool:
    messageSelectorOptions(messages, currentUuid).len() > 1

fn messageSelectorSelectedOption(messages: [MessageSelectorMessage], state: MessageSelectorState) -> MessageSelectorMessage?:
    val options = messageSelectorOptions(messages, state.currentUuid)
    if options.len() == 0:
        return nil
    val index = clampMessageSelectorIndex(state.selectedIndex, options.len())
    options[index]

fn messageSelectorIndexOfUuid(messages: [MessageSelectorMessage], uuid: text) -> i64:
    var i = 0
    while i < messages.len():
        if messages[i].uuid == uuid:
            return i
        i = i + 1
    -1

fn messageSelectorIndexFromEnd(messages: [MessageSelectorMessage], uuid: text) -> i64:
    val index = messageSelectorIndexOfUuid(messages, uuid)
    if index < 0:
        return -1
    messages.len() - 1 - index

fn isSummarizeOption(option: text) -> bool:
    option == "summarize" or option == "summarize_up_to"

fn getRestoreOptionConversationText(option: text) -> text:
    if option == "summarize":
        return "Messages after this point will be summarized."
    if option == "summarize_up_to":
        return "Preceding messages will be summarized. This and subsequent messages will remain unchanged; you will stay at the end of the conversation."
    if option == "both" or option == "conversation":
        return "The conversation will be forked."
    "The conversation will be unchanged."

fn getRestoreOptions(canRestoreCode: bool, includeSummarizeUpTo: bool) -> [MessageSelectorRestoreOption]:
    var out: [MessageSelectorRestoreOption] = []
    if canRestoreCode:
        out.push(MessageSelectorRestoreOption.new("both", "Restore code and conversation", false, true))
        out.push(MessageSelectorRestoreOption.new("conversation", "Restore conversation", false, false))
        out.push(MessageSelectorRestoreOption.new("code", "Restore code", false, false))
    else:
        out.push(MessageSelectorRestoreOption.new("conversation", "Restore conversation", false, true))
    out.push(MessageSelectorRestoreOption.new("summarize", "Summarize from here", true, false))
    if includeSummarizeUpTo:
        out.push(MessageSelectorRestoreOption.new("summarize_up_to", "Summarize up to here", true, false))
    out.push(MessageSelectorRestoreOption.new("nevermind", "Never mind", false, false))
    out

fn messageSelectorDefaultRestoreFocus(canRestoreCode: bool) -> text:
    if canRestoreCode:
        return "both"
    "conversation"

fn messageSelectorRestoreDirection(option: text) -> text:
    if option == "summarize_up_to":
        return "up_to"
    if option == "summarize":
        return "from"
    ""

fn selectMessageForRestore(messages: [MessageSelectorMessage], state: MessageSelectorState, uuid: text, fileHistoryEnabled: bool) -> MessageSelectorRestoreRequest:
    val index = messageSelectorIndexOfUuid(messages, uuid)
    if index < 0:
        return MessageSelectorRestoreRequest.closeOnly("missing")
    if not fileHistoryEnabled:
        return MessageSelectorRestoreRequest(option: "conversation", messageUuid: uuid, feedback: "", direction: "", shouldClose: true, shouldPreRestore: true, restoreConversation: true, restoreCode: false, summarize: false, error: "")
    MessageSelectorRestoreRequest(option: "confirm", messageUuid: uuid, feedback: "", direction: "", shouldClose: false, shouldPreRestore: false, restoreConversation: false, restoreCode: false, summarize: false, error: "")

fn selectRestoreOption(messageUuid: text, option: text, summarizeFromFeedback: text, summarizeUpToFeedback: text, hasPreselectedMessage: bool) -> MessageSelectorRestoreRequest:
    if messageUuid == "":
        return MessageSelectorRestoreRequest.error("Message not found.")
    if option == "nevermind":
        return MessageSelectorRestoreRequest(option: option, messageUuid: messageUuid, feedback: "", direction: "", shouldClose: hasPreselectedMessage, shouldPreRestore: false, restoreConversation: false, restoreCode: false, summarize: false, error: "")
    if isSummarizeOption(option):
        val direction = messageSelectorRestoreDirection(option)
        val feedback = messageSelectorFeedbackForDirection(direction, summarizeFromFeedback, summarizeUpToFeedback)
        return MessageSelectorRestoreRequest(option: option, messageUuid: messageUuid, feedback: feedback, direction: direction, shouldClose: true, shouldPreRestore: true, restoreConversation: false, restoreCode: false, summarize: true, error: "")
    val restoreCode = option == "code" or option == "both"
    val restoreConversation = option == "conversation" or option == "both"
    MessageSelectorRestoreRequest(option: option, messageUuid: messageUuid, feedback: "", direction: "", shouldClose: true, shouldPreRestore: true, restoreConversation: restoreConversation, restoreCode: restoreCode, summarize: false, error: "")

fn messageSelectorFeedbackForDirection(direction: text, fromFeedback: text, upToFeedback: text) -> text:
    if direction == "up_to":
        return upToFeedback.trim()
    fromFeedback.trim()

fn messageSelectorEscapeAction(hasMessageToRestore: bool, hasPreselectedMessage: bool) -> text:
    if hasMessageToRestore and not hasPreselectedMessage:
        return "back_to_list"
    "close"

fn messageSelectorShowPickList(state: MessageSelectorState, hasMessagesToSelect: bool) -> bool:
    state.error == "" and state.messageToRestoreUuid == "" and state.preselectedUuid == "" and hasMessagesToSelect

fn messageSelectorCanRestoreCode(fileHistoryEnabled: bool, stats: MessageSelectorDiffStats) -> bool:
    fileHistoryEnabled and stats.filesChanged.len() > 0

fn computeDiffStatsBetweenMessages(messages: [MessageSelectorMessage], fromMessageId: text, toMessageId: text) -> MessageSelectorDiffStats?:
    val startIndex = messageSelectorIndexOfUuid(messages, fromMessageId)
    if startIndex < 0:
        return nil
    var endIndex = messages.len()
    if toMessageId != "":
        val foundEnd = messageSelectorIndexOfUuid(messages, toMessageId)
        if foundEnd >= 0:
            endIndex = foundEnd
    var filesChanged: [text] = []
    var insertions = 0
    var deletions = 0
    var i = startIndex + 1
    while i < endIndex:
        val msg = messages[i]
        if msg.typeName == "tool_result" and msg.toolResult.hasFilePatch():
            if not messageSelectorTextArrayContains(filesChanged, msg.toolResult.filePath):
                filesChanged.push(msg.toolResult.filePath)
            if msg.toolResult.resultType == "create":
                insertions = insertions + messageSelectorLineCount(msg.toolResult.content)
            else:
                val delta = messageSelectorPatchDelta(msg.toolResult.structuredPatch)
                insertions = insertions + delta.insertions
                deletions = deletions + delta.deletions
        i = i + 1
    MessageSelectorDiffStats.new(filesChanged, insertions, deletions)

fn messageSelectorPatchDelta(hunks: [MessageSelectorPatchHunk]) -> MessageSelectorDiffStats:
    var insertions = 0
    var deletions = 0
    var i = 0
    while i < hunks.len():
        var j = 0
        while j < hunks[i].lines.len():
            val line = hunks[i].lines[j]
            if line.starts_with("+"):
                insertions = insertions + 1
            elif line.starts_with("-"):
                deletions = deletions + 1
            j = j + 1
        i = i + 1
    MessageSelectorDiffStats.new([], insertions, deletions)

fn messageSelectorLineCount(content: text) -> i64:
    if content == "":
        return 0
    content.split("\n").len()

fn messageSelectorTextArrayContains(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn messageSelectorNextMessageUuid(options: [MessageSelectorMessage], index: i64, currentUuid: text) -> text:
    val nextIndex = index + 1
    if nextIndex >= options.len():
        return ""
    val next = options[nextIndex]
    if next.uuid == currentUuid:
        return ""
    next.uuid

fn buildMessageSelectorHistoryMetadata(messages: [MessageSelectorMessage], currentUuid: text) -> [MessageSelectorDiffStats]:
    val options = messageSelectorOptions(messages, currentUuid)
    var out: [MessageSelectorDiffStats] = []
    var i = 0
    while i < options.len():
        if options[i].uuid == currentUuid:
            out.push(MessageSelectorDiffStats.empty())
        else:
            val nextUuid = messageSelectorNextMessageUuid(options, i, currentUuid)
            val stats = computeDiffStatsBetweenMessages(messages, options[i].uuid, nextUuid)
            if val realStats = stats:
                out.push(realStats)
            else:
                out.push(MessageSelectorDiffStats.empty())
        i = i + 1
    out

fn messageSelectorBasename(path: text) -> text:
    val parts = path.split("/")
    if parts.len() == 0:
        return path
    val last = parts[parts.len() - 1]
    if last == "":
        return path
    last

fn messageSelectorFileLabel(filesChanged: [text]) -> text:
    if filesChanged.len() == 0:
        return ""
    if filesChanged.len() == 1:
        return messageSelectorBasename(filesChanged[0])
    if filesChanged.len() == 2:
        return messageSelectorBasename(filesChanged[0]) + " and " + messageSelectorBasename(filesChanged[1])
    messageSelectorBasename(filesChanged[0]) + " and " + (filesChanged.len() - 1).to_text() + " other files"

fn restoreCodeConfirmationText(stats: MessageSelectorDiffStats) -> text:
    if stats.filesChanged.len() == 0:
        return "The code has not changed (nothing will be restored)."
    "The code will be restored " + stats.deltaText() + " in " + messageSelectorFileLabel(stats.filesChanged) + "."

fn restoreOptionCodeText(option: text, canRestoreCode: bool, stats: MessageSelectorDiffStats) -> text:
    val showCodeRestore = canRestoreCode and (option == "both" or option == "code")
    if isSummarizeOption(option):
        return ""
    if showCodeRestore:
        return restoreCodeConfirmationText(stats)
    "The code will be unchanged."

fn messageSelectorLabelForCurrent() -> text:
    "(current)"

fn messageSelectorRawPrompt(message: MessageSelectorMessage) -> text:
    if not message.payload.usesBlocks():
        return message.payload.contentText.trim()
    if val last = message.payload.lastBlock():
        if last.isText():
            return last.textValue.trim()
    "(no prompt)"

fn userMessageOptionLabel(message: MessageSelectorMessage, isCurrent: bool, columns: i64, paddingRight: i64) -> text:
    if isCurrent:
        return messageSelectorLabelForCurrent()
    val rawMessageText = messageSelectorRawPrompt(message)
    val messageText = stripMessageSelectorDisplayTags(rawMessageText)
    if messageSelectorIsMessageTextBlank(messageText):
        return "((empty message))"
    if messageText.contains("<" + MESSAGE_SELECTOR_TAG_BASH_INPUT + ">"):
        val input = messageSelectorExtractTag(messageText, MESSAGE_SELECTOR_TAG_BASH_INPUT)
        if input != "":
            return "! " + input
    if messageText.contains("<" + MESSAGE_SELECTOR_TAG_COMMAND + ">"):
        val commandMessage = messageSelectorExtractTag(messageText, MESSAGE_SELECTOR_TAG_COMMAND)
        val args = messageSelectorExtractTag(messageText, MESSAGE_SELECTOR_TAG_COMMAND_ARGS)
        val isSkillFormat = messageSelectorExtractTag(messageText, MESSAGE_SELECTOR_TAG_SKILL_FORMAT) == "true"
        if commandMessage != "":
            if isSkillFormat:
                return "Skill(" + commandMessage + ")"
            return "/" + commandMessage + " " + args
    if paddingRight > 0:
        return messageSelectorTruncate(messageText, maxMessageSelectorI64(1, columns - paddingRight))
    messageSelectorFirstLines(messageText, 4, 500)

fn messageSelectorFirstLines(value: text, maxLines: i64, maxChars: i64) -> text:
    val clipped = messageSelectorTruncate(value, maxChars)
    val lines = clipped.split("\n")
    var out = ""
    var i = 0
    while i < lines.len() and i < maxLines:
        if out != "":
            out = out + "\n"
        out = out + lines[i]
        i = i + 1
    out

fn messageSelectorTruncate(value: text, maxWidth: i64) -> text:
    if maxWidth <= 0:
        return ""
    if value.len() <= maxWidth:
        return value
    if maxWidth <= 1:
        return "…"
    value.slice(0, maxWidth - 1) + "…"

fn renderMessageSelector(model: MessageSelectorModel) -> MessageSelectorRenderModel:
    val options = model.messageOptions()
    val hasMessagesToSelect = options.len() > 1
    if model.state.error != "":
        return MessageSelectorRenderModel.new("Rewind", "error", "", messageSelectorFooter(model.state, hasMessagesToSelect), model.state.error, [], [], "", "")
    if not hasMessagesToSelect:
        return MessageSelectorRenderModel.new("Rewind", "empty", "Nothing to rewind to yet.", messageSelectorFooter(model.state, hasMessagesToSelect), "", [], [], "", "")
    if model.state.messageToRestoreUuid != "" or model.state.preselectedUuid != "":
        val uuid = if model.state.messageToRestoreUuid != "": model.state.messageToRestoreUuid else: model.state.preselectedUuid
        val stats = model.state.diffStatsForRestore
        val canRestoreCode = messageSelectorCanRestoreCode(model.state.fileHistoryEnabled, stats)
        val restoreOptions = getRestoreOptions(canRestoreCode, false)
        val conversationText = getRestoreOptionConversationText(model.state.selectedRestoreOption)
        val codeText = restoreOptionCodeText(model.state.selectedRestoreOption, canRestoreCode, stats)
        val option = messageSelectorFindOptionByUuid(options, uuid)
        val rendered = if val item = option: [messageSelectorRenderOption(item, false, item.uuid == model.state.currentUuid, model.columns, 10, stats)] else: []
        return MessageSelectorRenderModel.new("Rewind", "confirm", "Confirm you want to restore to the point before you sent this message:", messageSelectorFooter(model.state, hasMessagesToSelect), "", rendered, restoreOptions, conversationText, codeText)
    if messageSelectorShowPickList(model.state, hasMessagesToSelect):
        val lead = if model.state.fileHistoryEnabled: "Restore the code and/or conversation to the point before…" else: "Restore and fork the conversation to the point before…"
        return MessageSelectorRenderModel.new("Rewind", "list", lead, messageSelectorFooter(model.state, hasMessagesToSelect), "", messageSelectorVisibleOptionRenders(model), [], "", "")
    MessageSelectorRenderModel.new("Rewind", "idle", "", messageSelectorFooter(model.state, hasMessagesToSelect), "", [], [], "", "")

fn messageSelectorVisibleOptionRenders(model: MessageSelectorModel) -> [MessageSelectorOptionRender]:
    val options = model.messageOptions()
    val stats = buildMessageSelectorHistoryMetadata(model.messages, model.state.currentUuid)
    val window = messageSelectorWindow(options.len(), model.state.selectedIndex)
    var out: [MessageSelectorOptionRender] = []
    var visibleOffset = 0
    while visibleOffset < window.visibleCount:
        val index = window.firstVisibleIndex + visibleOffset
        val option = options[index]
        val stat = if index < stats.len(): stats[index] else: MessageSelectorDiffStats.empty()
        out.push(messageSelectorRenderOption(option, index == window.selectedIndex, option.uuid == model.state.currentUuid, model.columns, 10, stat))
        visibleOffset = visibleOffset + 1
    out

fn messageSelectorRenderOption(message: MessageSelectorMessage, selected: bool, current: bool, columns: i64, paddingRight: i64, stats: MessageSelectorDiffStats) -> MessageSelectorOptionRender:
    val label = userMessageOptionLabel(message, current, columns, paddingRight)
    val detail = messageSelectorOptionDetail(stats)
    val warning = if stats.filesChanged.len() == 0 and not current: "No code restore" else: ""
    MessageSelectorOptionRender.new(message.uuid, label, detail, selected, current, stats.filesChanged.len() > 0, warning)

fn messageSelectorOptionDetail(stats: MessageSelectorDiffStats) -> text:
    if stats.filesChanged.len() == 0:
        return "No code changes"
    val changed = if stats.filesChanged.len() == 1: messageSelectorBasename(stats.filesChanged[0]) + " " else: stats.filesChanged.len().to_text() + " files changed "
    changed + stats.deltaText()

fn messageSelectorFooter(state: MessageSelectorState, hasMessagesToSelect: bool) -> text:
    if state.messageToRestoreUuid != "":
        return ""
    if state.exitPending:
        return "Press " + state.exitKeyName + " again to exit"
    if state.error == "" and hasMessagesToSelect:
        return "Enter to continue · Esc to exit"
    "Esc to exit"

fn messageSelectorFindOptionByUuid(options: [MessageSelectorMessage], uuid: text) -> MessageSelectorMessage?:
    var i = 0
    while i < options.len():
        if options[i].uuid == uuid:
            return options[i]
        i = i + 1
    nil

fn messagesAfterAreOnlySynthetic(messages: [MessageSelectorMessage], fromIndex: i64) -> bool:
    var i = fromIndex + 1
    while i < messages.len():
        val msg = messages[i]
        if messageSelectorMessageIsIgnorableAfterSelection(msg):
            i = i + 1
            continue
        if msg.typeName == "assistant":
            if messageSelectorAssistantHasMeaningfulContent(msg):
                return false
            i = i + 1
            continue
        if msg.typeName == "user":
            return false
        i = i + 1
    true

fn messageSelectorMessageIsIgnorableAfterSelection(msg: MessageSelectorMessage) -> bool:
    if msg.isSynthetic:
        return true
    if msg.typeName == "tool_result":
        return true
    if msg.typeName == "progress":
        return true
    if msg.typeName == "system":
        return true
    if msg.typeName == "attachment":
        return true
    if msg.typeName == "user" and msg.isMeta:
        return true
    false

fn messageSelectorAssistantHasMeaningfulContent(msg: MessageSelectorMessage) -> bool:
    if msg.payload.blocks.len() == 0:
        return false
    var i = 0
    while i < msg.payload.blocks.len():
        val block = msg.payload.blocks[i]
        if block.typeName == "text" and block.textValue.trim() != "":
            return true
        if block.typeName == "tool_use":
            return true
        i = i + 1
    false

fn messageSelectorAnalyticsOpenEvent() -> text:
    "tengu_message_selector_opened"

fn messageSelectorAnalyticsSelectedEvent() -> text:
    "tengu_message_selector_selected"

fn messageSelectorAnalyticsRestoreOptionEvent() -> text:
    "tengu_message_selector_restore_option_selected"

fn messageSelectorAnalyticsCancelledEvent() -> text:
    "tengu_message_selector_cancelled"

fn messageSelectorSelectedAnalyticsPayload(messages: [MessageSelectorMessage], message: MessageSelectorMessage, currentUuid: text) -> text:
    val indexFromEnd = messageSelectorIndexFromEnd(messages, message.uuid)
    val isCurrent = message.uuid == currentUuid
    "index_from_end=" + indexFromEnd.to_text() + ";message_type=" + message.typeName + ";is_current_prompt=" + isCurrent.to_text()

fn messageSelectorRestoreErrorText(conversationError: text, codeError: text) -> text:
    if conversationError != "" and codeError != "":
        return "Failed to restore the conversation and code:\n" + conversationError + "\n" + codeError
    if conversationError != "":
        return "Failed to restore the conversation:\n" + conversationError
    if codeError != "":
        return "Failed to restore the code:\n" + codeError
    ""

fn messageSelectorSummarizeErrorText(error: text) -> text:
    if error == "":
        return ""
    "Failed to summarize:\n" + error

fn messageSelectorRestoreConversationErrorText(error: text) -> text:
    if error == "":
        return ""
    "Failed to restore the conversation:\n" + error

fn messageSelectorKeybindingActive(state: MessageSelectorState, hasMessagesToSelect: bool) -> bool:
    not state.isRestoring and state.error == "" and state.messageToRestoreUuid == "" and hasMessagesToSelect

fn messageSelectorConfirmationCancelAction(hasPreselectedMessage: bool) -> text:
    if hasPreselectedMessage:
        return "close"
    "back_to_list"

fn messageSelectorMetadataLoaded(index: i64, metadataCount: i64) -> bool:
    index >= 0 and index < metadataCount

fn messageSelectorWarningText(canRestoreCode: bool) -> text:
    if canRestoreCode:
        return "Rewinding does not affect files edited manually or via bash."
    ""

fn messageSelectorSelectionMode(state: MessageSelectorState, hasMessagesToSelect: bool) -> text:
    if state.error != "":
        return "error"
    if not hasMessagesToSelect:
        return "empty"
    if state.messageToRestoreUuid != "" or state.preselectedUuid != "":
        return "confirm"
    "list"

fn messageSelectorCanShowDivider() -> bool:
    true

fn messageSelectorTitle() -> text:
    "Rewind"

fn messageSelectorNoMessagesText() -> text:
    "Nothing to rewind to yet."

fn messageSelectorConfirmText(hasDiffStats: bool) -> text:
    if hasDiffStats:
        return "Confirm you want to restore to the point before you sent this message:"
    "Confirm you want to restore the conversation to the point before you sent this message:"

fn messageSelectorListLead(fileHistoryEnabled: bool) -> text:
    if fileHistoryEnabled:
        return "Restore the code and/or conversation to the point before…"
    "Restore and fork the conversation to the point before…"

fn messageSelectorSpinnerText(restoringOption: text) -> text:
    if isSummarizeOption(restoringOption):
        return "Summarizing…"
    "Restoring…"

fn messageSelectorPointer(selected: bool) -> text:
    if selected:
        return "› "
    "  "

fn messageSelectorOptionHeight(fileHistoryEnabled: bool) -> i64:
    if fileHistoryEnabled:
        return 3
    2

fn messageSelectorBorderEnabledForConfirmation() -> bool:
    true

fn messageSelectorRenderCanUseHistoryMetadata(fileHistoryEnabled: bool, current: bool) -> bool:
    fileHistoryEnabled and not current

fn messageSelectorFormatRelativeTimeLabel(timestamp: text) -> text:
    if timestamp == "":
        return ""
    "(" + timestamp + ")"

fn messageSelectorCanSkipPickList(preselectedUuid: text) -> bool:
    preselectedUuid != ""

fn messageSelectorRestoringOptionLabel(option: text) -> text:
    if option == "both":
        return "Restore code and conversation"
    if option == "conversation":
        return "Restore conversation"
    if option == "code":
        return "Restore code"
    if option == "summarize":
        return "Summarize from here"
    if option == "summarize_up_to":
        return "Summarize up to here"
    "Never mind"

fn messageSelectorRestoreOptionAcceptsFeedback(option: text) -> bool:
    isSummarizeOption(option)

fn messageSelectorShouldClearMessageAfterOption(option: text) -> bool:
    option != "nevermind"

fn messageSelectorShouldCloseAfterRestore(error: text) -> bool:
    error == ""

fn messageSelectorCanGoBackFromConfirm(preselectedUuid: text) -> bool:
    preselectedUuid == ""

fn messageSelectorNoCodeRestoreWarning(metadataLoaded: bool, stats: MessageSelectorDiffStats) -> text:
    if metadataLoaded and stats.filesChanged.len() == 0:
        return "No code restore"
    ""

fn messageSelectorStatsLoadedDetail(metadataLoaded: bool, stats: MessageSelectorDiffStats) -> text:
    if not metadataLoaded:
        return ""
    if stats.filesChanged.len() == 0:
        return "No code changes"
    messageSelectorOptionDetail(stats)

fn messageSelectorFileCountWord(count: i64) -> text:
    if count == 1:
        return "file"
    "files"

fn messageSelectorOtherFilesLabel(count: i64) -> text:
    if count <= 1:
        return ""
    (count - 1).to_text() + " other " + messageSelectorFileCountWord(count - 1)

