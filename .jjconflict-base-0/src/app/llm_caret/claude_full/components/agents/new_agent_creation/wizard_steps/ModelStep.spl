"""
Importable alias for Claude full ModelStep parity.
"""

fn normalizeModelStep(raw: text) -> text:
    val model = raw.trim().to_lower()
    if model == "sonnet" or model == "opus" or model == "haiku":
        return model
    "sonnet"

fn modelStepSummary(raw: text) -> text:
    "Model: " + normalizeModelStep(raw)

fn modelStepSourceLinesModeled() -> i64:
    51
