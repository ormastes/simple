"""
Claude full LogoV2 emergency tip parity.
"""

class EmergencyTipState:
    message: text
    command: text
    visible: bool

impl EmergencyTipState:
    static fn new(message: text, command: text, visible: bool) -> EmergencyTipState:
        EmergencyTipState(message: emergencyTipMessage(message), command: emergencyTipCommand(command), visible: visible)

fn emergencyTipMessage(message: text) -> text:
    val clean = message.trim()
    if clean == "":
        return "Press Esc Esc to interrupt Claude."
    clean

fn emergencyTipCommand(command: text) -> text:
    val clean = command.trim()
    if clean == "":
        return "Esc Esc"
    clean

fn emergencyTipVisible(state: EmergencyTipState) -> bool:
    state.visible and state.message != ""

fn emergencyTipSummary(state: EmergencyTipState) -> text:
    if not emergencyTipVisible(state):
        return "emergency-tip hidden"
    "emergency-tip command=" + state.command + " message=" + state.message

fn emergencyTipSourceLinesModeled() -> i64:
    57
