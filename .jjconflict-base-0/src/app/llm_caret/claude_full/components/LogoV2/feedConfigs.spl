"""
Claude full LogoV2 feed config parity.
"""

class FeedConfig:
    id: text
    label: text
    refresh_ms: i64
    enabled: bool

impl FeedConfig:
    static fn new(id: text, label: text, refreshMs: i64, enabled: bool) -> FeedConfig:
        FeedConfig(id: normalizeFeedConfigId(id), label: normalizeFeedConfigLabel(label), refresh_ms: normalizeFeedRefreshMs(refreshMs), enabled: enabled)

fn normalizeFeedConfigId(id: text) -> text:
    val clean = id.trim().lower()
    if clean == "":
        return "updates"
    clean

fn normalizeFeedConfigLabel(label: text) -> text:
    val clean = label.trim()
    if clean == "":
        return "Updates"
    clean

fn normalizeFeedRefreshMs(refreshMs: i64) -> i64:
    if refreshMs < 1000:
        return 1000
    if refreshMs > 60000:
        return 60000
    refreshMs

fn defaultFeedConfigs() -> [FeedConfig]:
    [
        FeedConfig.new("updates", "Updates", 5000, true),
        FeedConfig.new("tips", "Tips", 12000, true),
        FeedConfig.new("status", "Status", 10000, true),
    ]

fn feedConfigById(id: text) -> FeedConfig?:
    val clean = normalizeFeedConfigId(id)
    val configs = defaultFeedConfigs()
    var i = 0
    while i < configs.len():
        if configs[i].id == clean:
            return configs[i]
        i = i + 1
    nil

fn feedConfigEnabledCount(configs: [FeedConfig]) -> i64:
    var count = 0
    var i = 0
    while i < configs.len():
        if configs[i].enabled:
            count = count + 1
        i = i + 1
    count

fn feedConfigSummary(config: FeedConfig) -> text:
    if config.enabled:
        return config.id + ":" + config.label + " every " + config.refresh_ms.to_text()
    config.id + ":" + config.label + " disabled"

fn feedConfigsSourceLinesModeled() -> i64:
    91
