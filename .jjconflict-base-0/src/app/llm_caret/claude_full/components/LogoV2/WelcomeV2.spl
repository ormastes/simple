"""
Claude full LogoV2 WelcomeV2 parity.
"""

val WELCOME_V2_WIDTH = 58

class WelcomeV2State:
    theme: text
    terminal: text
    version: text
    message: text

impl WelcomeV2State:
    static fn new(theme: text, terminal: text, version: text, message: text) -> WelcomeV2State:
        WelcomeV2State(theme: normalizeWelcomeV2Theme(theme), terminal: terminal.trim(), version: version.trim(), message: welcomeV2Message(message))

fn normalizeWelcomeV2Theme(theme: text) -> text:
    val clean = theme.trim().lower()
    if clean == "light" or clean == "light-daltonized" or clean == "light-ansi":
        return "light"
    if clean == "dark":
        return "dark"
    "dark"

fn welcomeV2Message(message: text) -> text:
    val clean = message.trim()
    if clean == "":
        return "Welcome to Claude Code"
    clean

fn welcomeV2IsAppleTerminal(state: WelcomeV2State) -> bool:
    state.terminal == "Apple_Terminal"

fn welcomeV2Palette(state: WelcomeV2State) -> text:
    if welcomeV2IsAppleTerminal(state):
        return "apple-" + state.theme
    state.theme

fn welcomeV2Header(state: WelcomeV2State) -> text:
    state.message + " v" + state.version

fn welcomeV2ArtLine(state: WelcomeV2State, index: i64) -> text:
    val palette = welcomeV2Palette(state)
    if index == 0:
        return welcomeV2Header(state)
    if palette == "light":
        return "light clawd body width=" + WELCOME_V2_WIDTH.to_text()
    if palette == "apple-light":
        return "apple light clawd body width=" + WELCOME_V2_WIDTH.to_text()
    if palette == "apple-dark":
        return "apple dark clawd body width=" + WELCOME_V2_WIDTH.to_text()
    "dark clawd body width=" + WELCOME_V2_WIDTH.to_text()

fn welcomeV2Rows(state: WelcomeV2State) -> [text]:
    [
        welcomeV2ArtLine(state, 0),
        welcomeV2ArtLine(state, 1),
        "clawd eyes",
        "star field",
    ]

fn welcomeV2Summary(state: WelcomeV2State) -> text:
    val rows = welcomeV2Rows(state)
    rows[0] + " | " + rows[1]

fn welcomeV2SourceLinesModeled() -> i64:
    432
