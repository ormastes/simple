"""
Claude full HelpV2 Commands parity.
"""

class HelpCommand:
    name: text
    description: text
    shortcut: text

impl HelpCommand:
    static fn new(name: text, description: text, shortcut: text) -> HelpCommand:
        HelpCommand(name: name.trim(), description: description.trim(), shortcut: shortcut.trim())

fn helpCommandLabel(command: HelpCommand) -> text:
    if command.shortcut == "":
        return command.name
    command.name + " [" + command.shortcut + "]"

fn helpCommandSummary(command: HelpCommand) -> text:
    if command.description == "":
        return helpCommandLabel(command)
    helpCommandLabel(command) + ": " + command.description

fn helpCommandMatches(command: HelpCommand, query: text) -> bool:
    val clean = query.trim()
    clean == "" or command.name.contains(clean) or command.description.contains(clean)

fn helpCommandsCountLabel(count: i64) -> text:
    count.to_text() + " command(s)"

fn helpCommandsSourceLinesModeled() -> i64:
    81
