class UtilCommandResult:
    rendered: bool
    unmounted: bool
    exitCode: i64
    events: [text]
    args: [text]
    warningShown: bool
    setupCalled: bool
    screen: text
    message: text

impl UtilCommandResult:
    static fn new(screen: text, events: [text]) -> UtilCommandResult:
        UtilCommandResult(rendered: true, unmounted: true, exitCode: 0, events: events, args: [], warningShown: false, setupCalled: false, screen: screen, message: "")

fn setupTokenHandler(anthropicAuthEnabled: bool) -> UtilCommandResult:
    val result = UtilCommandResult.new("setup-token", [setupTokenEventName()])
    result.warningShown = not anthropicAuthEnabled
    result.message = setupTokenStartingMessage()
    result

fn doctorHandler() -> UtilCommandResult:
    val result = UtilCommandResult.new("doctor", [doctorEventName()])
    result.message = "DoctorWithPlugins"
    result

fn installHandler(target: text, force: bool, installResult: text) -> UtilCommandResult:
    val result = UtilCommandResult.new("install", [])
    result.setupCalled = true
    result.args = installArgs(target, force)
    result.exitCode = if installResult.contains("failed"): 1 else: 0
    result.message = installResult
    result

fn installArgs(target: text, force: bool) -> [text]:
    var args: [text] = []
    if target != "":
        args.push(target)
    if force:
        args.push("--force")
    args

fn setupTokenWarningText() -> text:
    "Warning: You already have authentication configured via environment variable or API key helper."

fn setupTokenStartingMessage() -> text:
    "This will guide you through long-lived (1-year) auth token setup for your Claude account. Claude subscription required."

fn setupTokenEventName() -> text:
    "tengu_setup_token_command"

fn doctorEventName() -> text:
    "tengu_doctor_command"

fn setupTokenModeName() -> text:
    "setup-token"

fn installSetupModeName() -> text:
    "default"

fn doctorUsesPluginManager() -> bool:
    true

fn doctorUsesSuspenseFallbackNull() -> bool:
    true

fn doctorUsesMcpConnectionManager() -> bool:
    true

fn doctorStrictMcpConfig() -> bool:
    false

fn setupTokenUsesAppStateOnChange() -> bool:
    true

fn setupTokenUsesKeybindingSetup() -> bool:
    true

fn setupTokenRendersWelcome() -> bool:
    true

fn installCallsSetupBeforeCommand() -> bool:
    true

fn installFailureExitCode() -> i64:
    1

fn installSuccessExitCode() -> i64:
    0

fn cliSubcommandsIntentionallyExit() -> bool:
    true

fn utilHandlerSourceLinesModeled() -> i64:
    109

# Source parity note: util handlers are lazy-loaded from main.tsx.
# Source parity note: setup-token dynamically imports ConsoleOAuthFlow.
# Source parity note: setup-token logs before rendering.
# Source parity note: setup-token warning appears when Anthropic auth is disabled.
# Source parity note: setup-token renders WelcomeV2.
# Source parity note: setup-token renders inside AppStateProvider.
# Source parity note: setup-token wires onChangeAppState.
# Source parity note: setup-token renders inside KeybindingSetup.
# Source parity note: setup-token resolves on OAuth flow done.
# Source parity note: setup-token unmounts root after completion.
# Source parity note: setup-token exits with code zero.
# Source parity note: DoctorLazy imports Doctor screen lazily.
# Source parity note: DoctorWithPlugins calls useManagePlugins.
# Source parity note: doctor wraps screen in Suspense.
# Source parity note: doctor logs before rendering.
# Source parity note: doctor renders inside AppStateProvider.
# Source parity note: doctor renders inside KeybindingSetup.
# Source parity note: doctor renders inside MCPConnectionManager.
# Source parity note: doctor uses undefined dynamic MCP config.
# Source parity note: doctor uses non-strict MCP config.
# Source parity note: doctor resolves on done.
# Source parity note: doctor unmounts and exits zero.
# Source parity note: install dynamically imports setup.
# Source parity note: install calls setup with cwd and default mode.
# Source parity note: install dynamically imports command implementation.
# Source parity note: install appends target argument when present.
# Source parity note: install appends --force when requested.
# Source parity note: install exits one when result contains failed.
# Source parity note: install exits zero otherwise.
