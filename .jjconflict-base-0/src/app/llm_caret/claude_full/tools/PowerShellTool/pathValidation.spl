const POWERSHELL_PATH_VALIDATION_SOURCE_LINES = 2049

fn isDangerousRemovalRawPathRoute(command: text) -> bool:
    command.starts_with("Remove-Item /") || command.starts_with("rm /") || command.starts_with("Remove-Item C:\\") || command.starts_with("rm C:\\")

fn dangerousRemovalDenyRoute(command: text) -> text:
    if isDangerousRemovalRawPathRoute(command):
        return "deny dangerous removal"
    "not dangerous removal"

fn checkPathConstraintsRoute(command: text, parsed: bool, explicitPathInsideCwd: bool, pathDenied: bool, hasCwdChange: bool, pipelineRisk: bool, unknownPathExpression: bool) -> text:
    if !parsed:
        return "passthrough"
    if isDangerousRemovalRawPathRoute(command):
        return "deny dangerous removal"
    if pathDenied:
        return "deny blocked path"
    if explicitPathInsideCwd:
        return "passthrough"
    if command.starts_with("Invoke-WebRequest") && !command.contains("-OutFile"):
        return "passthrough"
    if hasCwdChange:
        return "ask cwd changing command"
    if pipelineRisk:
        return "ask pipeline path"
    if unknownPathExpression:
        return "ask complex path"
    if command.starts_with("Set-Content") || command.starts_with("Out-File") || command.starts_with("New-Item"):
        return "ask write target"
    "ask blocked path"

fn powershellPathValidationSourceLinesModeled() -> i64:
    POWERSHELL_PATH_VALIDATION_SOURCE_LINES
