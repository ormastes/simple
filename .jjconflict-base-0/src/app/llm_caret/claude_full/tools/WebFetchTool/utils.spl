"""
Claude full WebFetchTool utility parity surface.
"""

class DomainBlockedError:
    domain: text
    name: text
    message: text

impl DomainBlockedError:
    static fn new(domain: text) -> DomainBlockedError:
        DomainBlockedError(domain: domain, name: "DomainBlockedError", message: "Claude Code is unable to fetch from " + domain)

class DomainCheckFailedError:
    domain: text
    name: text
    message: text

impl DomainCheckFailedError:
    static fn new(domain: text) -> DomainCheckFailedError:
        DomainCheckFailedError(domain: domain, name: "DomainCheckFailedError", message: "Unable to verify if domain " + domain + " is safe to fetch. This may be due to network restrictions or enterprise security policies blocking claude.ai.")

class EgressBlockedError:
    domain: text
    name: text
    message: text

impl EgressBlockedError:
    static fn new(domain: text) -> EgressBlockedError:
        EgressBlockedError(domain: domain, name: "EgressBlockedError", message: "{\"error_type\":\"EGRESS_BLOCKED\",\"domain\":\"" + domain + "\",\"message\":\"Access to " + domain + " is blocked by the network egress proxy.\"}")

class WebFetchCacheState:
    urlEntries: i64
    domainEntries: i64

impl WebFetchCacheState:
    static fn new(urlEntries: i64, domainEntries: i64) -> WebFetchCacheState:
        WebFetchCacheState(urlEntries: urlEntries, domainEntries: domainEntries)

fn clearWebFetchCache(state: WebFetchCacheState) -> WebFetchCacheState:
    WebFetchCacheState.new(0, 0)

fn cacheTtlMs() -> i64:
    15 * 60 * 1000

fn maxCacheSizeBytes() -> i64:
    50 * 1024 * 1024

fn maxUrlLength() -> i64:
    2000

fn maxHttpContentLength() -> i64:
    10 * 1024 * 1024

fn fetchTimeoutMs() -> i64:
    60000

fn domainCheckTimeoutMs() -> i64:
    10000

fn maxRedirects() -> i64:
    10

fn maxMarkdownLength() -> i64:
    100000

fn validateURL(url: text) -> bool:
    if url.len() > maxUrlLength():
        return false
    if not (url.starts_with("http://") or url.starts_with("https://")):
        return false
    if url.contains("@"):
        return false
    val host = hostOfWebFetchUrl(url)
    host.contains(".")

fn isPermittedRedirect(originalUrl: text, redirectUrl: text) -> bool:
    if schemeOfWebFetchUrl(originalUrl) != schemeOfWebFetchUrl(redirectUrl):
        return false
    if portOfWebFetchUrl(originalUrl) != portOfWebFetchUrl(redirectUrl):
        return false
    if redirectUrl.contains("@"):
        return false
    stripWwwWebFetch(hostOfWebFetchUrl(originalUrl)) == stripWwwWebFetch(hostOfWebFetchUrl(redirectUrl))

fn isPreapprovedUrl(url: text) -> bool:
    val host = hostOfWebFetchUrl(url)
    host == "docs.anthropic.com" or host.ends_with(".anthropic.com")

fn shouldUpgradeToHttps(url: text) -> bool:
    url.starts_with("http://")

fn upgradedUrl(url: text) -> text:
    if shouldUpgradeToHttps(url):
        return "https://" + url.slice(7, url.len())
    url

fn egressBlockedMessage(domain: text) -> text:
    EgressBlockedError.new(domain).message

fn domainBlockedMessage(domain: text) -> text:
    DomainBlockedError.new(domain).message

fn domainCheckFailedMessage(domain: text) -> text:
    DomainCheckFailedError.new(domain).message

fn schemeOfWebFetchUrl(url: text) -> text:
    val pos = url.index_of("://") ?? -1
    if pos < 0:
        return ""
    url.slice(0, pos)

fn hostOfWebFetchUrl(url: text) -> text:
    val start = (url.index_of("://") ?? -3) + 3
    if start < 3:
        return ""
    val rest = url.slice(start, url.len())
    var end = rest.index_of("/") ?? rest.len()
    val authority = rest.slice(0, end)
    val colon = authority.index_of(":") ?? -1
    if colon >= 0:
        return authority.slice(0, colon)
    authority

fn portOfWebFetchUrl(url: text) -> text:
    val start = (url.index_of("://") ?? -3) + 3
    if start < 3:
        return ""
    val rest = url.slice(start, url.len())
    val slash = rest.index_of("/") ?? rest.len()
    val authority = rest.slice(0, slash)
    val colon = authority.index_of(":") ?? -1
    if colon < 0:
        return ""
    authority.slice(colon + 1, authority.len())

fn stripWwwWebFetch(host: text) -> text:
    if host.starts_with("www."):
        return host.slice(4, host.len())
    host

fn webFetchUtilsSourceLinesModeled() -> i64:
    530
