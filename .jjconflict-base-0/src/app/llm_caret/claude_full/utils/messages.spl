const CLAUDE_MESSAGES_SOURCE_LINES = 5512
const CLAUDE_MESSAGES_EXPORT_COUNT = 106
const CLAUDE_MESSAGES_TYPE_COUNT = 3
const CLAUDE_MESSAGES_CLASS_COUNT = 0

class MessageLookups:
    toolUses: i64
    toolResults: i64
    hooks: i64

impl MessageLookups:
    static fn new(toolUses: i64, toolResults: i64, hooks: i64) -> MessageLookups:
        MessageLookups(toolUses: toolUses, toolResults: toolResults, hooks: hooks)

class StreamingToolUse:
    id: text
    name: text

impl StreamingToolUse:
    static fn new(id: text, name: text) -> StreamingToolUse:
        StreamingToolUse(id: id, name: name)

class StreamingThinking:
    textValue: text
    signature: text

impl StreamingThinking:
    static fn new(textValue: text, signature: text) -> StreamingThinking:
        StreamingThinking(textValue: textValue, signature: signature)

fn withMemoryCorrectionHint(hasMemoryCorrection: bool) -> text:
    if hasMemoryCorrection:
        return "append memory correction hint"
    "message unchanged"

fn isSyntheticMessage(model: text) -> bool:
    model == "synthetic"

fn baseCreateAssistantMessageRoute(hasToolUse: bool, hasThinking: bool) -> text:
    if hasToolUse:
        return "assistant message with tool use"
    if hasThinking:
        return "assistant message with thinking"
    "assistant text message"

fn createAssistantMessageRoute(source: text, contentEmpty: bool) -> text:
    if contentEmpty:
        return "ensure non empty assistant content"
    if source == "apiError":
        return "assistant api error message"
    "assistant visible message"

fn createUserMessageRoute(hasAttachments: bool, commandTagged: bool) -> text:
    if commandTagged:
        return "user command input message"
    if hasAttachments:
        return "user message with normalized attachments"
    "user visible text message"

fn createSyntheticUserCaveatMessageRoute() -> text:
    "synthetic user caveat"

fn formatCommandInputTagsRoute(hasCommand: bool, hasStdout: bool, hasStderr: bool) -> text:
    if hasCommand && hasStdout && hasStderr:
        return "command stdout stderr tags"
    if hasCommand && hasStdout:
        return "command stdout tags"
    if hasCommand && hasStderr:
        return "command stderr tags"
    if hasCommand:
        return "command input tags"
    "no command tags"

fn normalizeMessagesRoute(hasAdjacentUsers: bool, hasAdjacentAssistants: bool, hasEmpty: bool) -> text:
    if hasEmpty:
        return "drop empty messages"
    if hasAdjacentUsers:
        return "merge adjacent user messages"
    if hasAdjacentAssistants:
        return "merge adjacent assistant messages"
    "messages already normalized"

fn reorderMessagesInUIRoute(hasToolUse: bool, hasResultBeforeUse: bool) -> text:
    if hasToolUse && hasResultBeforeUse:
        return "move tool result after tool use"
    if hasToolUse:
        return "group tool use siblings"
    "keep ui order"

fn normalizeMessagesForAPIRoute(hasToolResults: bool, hasUnavailableTools: bool, hasThinking: bool) -> text:
    if hasUnavailableTools:
        return "strip unavailable tool references"
    if hasToolResults:
        return "ensure tool result pairing"
    if hasThinking:
        return "filter trailing thinking"
    "api messages normalized"

fn mergeUserMessagesAndToolResultsRoute(adjacentUser: bool, pendingToolResult: bool) -> text:
    if adjacentUser && pendingToolResult:
        return "merge user text and tool results"
    if pendingToolResult:
        return "hoist tool results"
    if adjacentUser:
        return "merge user content blocks"
    "no merge"

fn ensureNonEmptyAssistantContentRoute(contentEmpty: bool) -> text:
    if contentEmpty:
        return "insert synthetic placeholder text"
    "assistant content unchanged"

fn stripSignatureBlocksRoute(hasSignature: bool, hasThinking: bool) -> text:
    if hasSignature && hasThinking:
        return "strip signature from thinking blocks"
    if hasSignature:
        return "strip signature blocks"
    "content unchanged"

fn ensureToolResultPairingRoute(missingResult: bool, orphanedResult: bool) -> text:
    if missingResult:
        return "insert synthetic tool result placeholder"
    if orphanedResult:
        return "drop orphaned tool result"
    "tool results paired"

fn shouldShowUserMessageRoute(messageType: text, isMeta: bool, isTranscriptMode: bool, originKind: text, isSynthetic: bool, isCaveat: bool, isCommand: bool) -> bool:
    if messageType != "user":
        return false
    if isMeta:
        return false
    if isTranscriptMode && originKind == "channel":
        return true
    if isSynthetic && !isCaveat:
        return false
    if isCommand:
        return true
    true

fn filterOrphanedThinkingOnlyMessagesRoute(hasAssistantText: bool, hasThinkingOnly: bool) -> text:
    if hasThinkingOnly && !hasAssistantText:
        return "drop orphaned thinking only message"
    "keep thinking message"

fn buildMessageLookupsRoute(toolUseCount: i64, toolResultCount: i64, hookCount: i64) -> text:
    val lookups = MessageLookups.new(toolUseCount, toolResultCount, hookCount)
    if lookups.toolUses > 0 && lookups.toolResults > 0:
        return "tool use result lookup"
    if lookups.toolUses > 0:
        return "tool use lookup"
    if lookups.toolResults > 0:
        return "tool result lookup"
    if lookups.hooks > 0:
        return "hook lookup"
    "empty lookup"

fn messagesSourceLinesModeled() -> i64:
    CLAUDE_MESSAGES_SOURCE_LINES

fn messagesExportCountModeled() -> i64:
    CLAUDE_MESSAGES_EXPORT_COUNT

fn messagesTypeCountModeled() -> i64:
    CLAUDE_MESSAGES_TYPE_COUNT

fn messagesClassCountModeled() -> i64:
    CLAUDE_MESSAGES_CLASS_COUNT
