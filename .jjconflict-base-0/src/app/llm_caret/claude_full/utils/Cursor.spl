"""
Claude full Cursor parity surface.
"""

class Position:
    line: i64
    column: i64

impl Position:
    static fn new(line: i64, column: i64) -> Position:
        Position(line: line, column: column)

class WrappedLine:
    text: text
    startOffset: i64
    isPrecededByNewline: bool
    endsWithNewline: bool

impl WrappedLine:
    static fn new(text: text, startOffset: i64, isPrecededByNewline: bool, endsWithNewline: bool) -> WrappedLine:
        WrappedLine(text: text, startOffset: startOffset, isPrecededByNewline: isPrecededByNewline, endsWithNewline: endsWithNewline)

    fn equals(other: WrappedLine) -> bool:
        self.text == other.text and self.startOffset == other.startOffset

    fn length() -> i64:
        if self.endsWithNewline:
            return self.text.len() + 1
        self.text.len()

class MeasuredText:
    text: text
    columns: i64

impl MeasuredText:
    static fn new(text: text, columns: i64) -> MeasuredText:
        MeasuredText(text: text, columns: maxI64Cursor(1, columns))

    fn getWrappedText() -> [text]:
        var lines: [text] = []
        val wrapped = self.getWrappedLines()
        var i = 0
        while i < wrapped.len():
            lines.push(wrapped[i].text)
            i = i + 1
        lines

    fn getWrappedLines() -> [WrappedLine]:
        var out: [WrappedLine] = []
        var start = 0
        while start < self.text.len():
            val end = minI64Cursor(self.text.len(), start + self.columns)
            out.push(WrappedLine.new(self.text.slice(start, end), start, start > 0, false))
            start = end
        if out.len() == 0:
            out.push(WrappedLine.new("", 0, false, false))
        out

    fn getOffsetFromPosition(position: Position) -> i64:
        val lines = self.getWrappedLines()
        val line = clampI64Cursor(position.line, 0, lines.len() - 1)
        minI64Cursor(self.text.len(), lines[line].startOffset + maxI64Cursor(0, position.column))

    fn getPositionFromOffset(offset: i64) -> Position:
        val clamped = clampI64Cursor(offset, 0, self.text.len())
        val lines = self.getWrappedLines()
        var i = 0
        while i < lines.len():
            val start = lines[i].startOffset
            val end = start + lines[i].text.len()
            if clamped >= start and clamped <= end:
                return Position.new(i, clamped - start)
            i = i + 1
        Position.new(lines.len() - 1, lines[lines.len() - 1].text.len())

    fn getLineLength(line: i64) -> i64:
        val lines = self.getWrappedLines()
        if line < 0 or line >= lines.len():
            return 0
        lines[line].length()

    fn lineCount() -> i64:
        self.getWrappedLines().len()

    fn nextOffset(offset: i64) -> i64:
        minI64Cursor(self.text.len(), offset + 1)

    fn prevOffset(offset: i64) -> i64:
        maxI64Cursor(0, offset - 1)

    fn stringIndexToDisplayWidth(value: text, index: i64) -> i64:
        clampI64Cursor(index, 0, value.len())

    fn displayWidthToStringIndex(value: text, targetWidth: i64) -> i64:
        clampI64Cursor(targetWidth, 0, value.len())

class Cursor:
    measuredText: MeasuredText
    offset: i64
    selection: i64

impl Cursor:
    static fn new(measuredText: MeasuredText, offset: i64, selection: i64) -> Cursor:
        Cursor(measuredText: measuredText, offset: clampI64Cursor(offset, 0, measuredText.text.len()), selection: selection)

    static fn fromText(text: text, columns: i64, offset: i64, selection: i64) -> Cursor:
        Cursor.new(MeasuredText.new(text, columns - 1), offset, selection)

    fn text() -> text:
        self.measuredText.text

    fn columns() -> i64:
        self.measuredText.columns

    fn getPosition() -> Position:
        self.measuredText.getPositionFromOffset(self.offset)

    fn getViewportStartLine(maxVisibleLines: i64) -> i64:
        if maxVisibleLines <= 0:
            return 0
        val line = self.getPosition().line
        val total = self.measuredText.lineCount()
        if total <= maxVisibleLines:
            return 0
        minI64Cursor(maxI64Cursor(0, line - (maxVisibleLines / 2)), total - maxVisibleLines)

    fn getViewportCharOffset(maxVisibleLines: i64) -> i64:
        val startLine = self.getViewportStartLine(maxVisibleLines)
        minI64Cursor(self.text().len(), startLine * self.measuredText.columns)

    fn getViewportCharEnd(maxVisibleLines: i64) -> i64:
        if maxVisibleLines <= 0:
            return self.text().len()
        val startLine = self.getViewportStartLine(maxVisibleLines)
        val endLine = minI64Cursor(self.measuredText.lineCount(), startLine + maxVisibleLines)
        if endLine >= self.measuredText.lineCount():
            return self.text().len()
        minI64Cursor(self.text().len(), endLine * self.measuredText.columns)

    fn left() -> Cursor:
        Cursor.new(self.measuredText, self.measuredText.prevOffset(self.offset), self.selection)

    fn right() -> Cursor:
        Cursor.new(self.measuredText, self.measuredText.nextOffset(self.offset), self.selection)

    fn startOfLine() -> Cursor:
        val pos = self.getPosition()
        Cursor.new(self.measuredText, self.measuredText.getOffsetFromPosition(Position.new(pos.line, 0)), self.selection)

    fn endOfLine() -> Cursor:
        val pos = self.getPosition()
        Cursor.new(self.measuredText, self.measuredText.getOffsetFromPosition(Position.new(pos.line, self.measuredText.getLineLength(pos.line))), self.selection)

    fn insert(insertString: text) -> Cursor:
        val nextText = self.text().slice(0, self.offset) + insertString + self.text().slice(self.offset, self.text().len())
        Cursor.fromText(nextText, self.columns() + 1, self.offset + insertString.len(), self.selection)

    fn del() -> Cursor:
        if self.offset >= self.text().len():
            return self
        val nextText = self.text().slice(0, self.offset) + self.text().slice(self.offset + 1, self.text().len())
        Cursor.fromText(nextText, self.columns() + 1, self.offset, self.selection)

    fn backspace() -> Cursor:
        if self.offset <= 0:
            return self
        val nextText = self.text().slice(0, self.offset - 1) + self.text().slice(self.offset, self.text().len())
        Cursor.fromText(nextText, self.columns() + 1, self.offset - 1, self.selection)

    fn equals(other: Cursor) -> bool:
        self.text() == other.text() and self.offset == other.offset and self.selection == other.selection

    fn isAtStart() -> bool:
        self.offset == 0

    fn isAtEnd() -> bool:
        self.offset == self.text().len()

    fn endOfFile() -> Cursor:
        Cursor.new(self.measuredText, self.text().len(), self.selection)

    fn goToLine(lineNumber: i64) -> Cursor:
        Cursor.new(self.measuredText, self.measuredText.getOffsetFromPosition(Position.new(maxI64Cursor(0, lineNumber), 0)), self.selection)

fn isVimWhitespace(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\t"

fn isVimWordChar(ch: text) -> bool:
    ch == "_" or (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9")

fn isVimPunctuation(ch: text) -> bool:
    ch.len() > 0 and not isVimWhitespace(ch) and not isVimWordChar(ch)

fn minI64Cursor(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn maxI64Cursor(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn clampI64Cursor(value: i64, minValue: i64, maxValue: i64) -> i64:
    minI64Cursor(maxI64Cursor(value, minValue), maxValue)

fn cursorSourceLinesModeled() -> i64:
    1530
