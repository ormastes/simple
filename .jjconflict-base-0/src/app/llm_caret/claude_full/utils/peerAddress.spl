class ParsedPeerAddress:
    scheme: text
    target: text

impl ParsedPeerAddress:
    static fn new(scheme: text, target: text) -> ParsedPeerAddress:
        ParsedPeerAddress(scheme: scheme, target: target)

fn parseAddress(to: text) -> ParsedPeerAddress:
    if to.starts_with("uds:"):
        return ParsedPeerAddress.new("uds", to.slice(4, to.len()))
    if to.starts_with("bridge:"):
        return ParsedPeerAddress.new("bridge", to.slice(7, to.len()))
    if to.starts_with("/"):
        return ParsedPeerAddress.new("uds", to)
    ParsedPeerAddress.new("other", to)
