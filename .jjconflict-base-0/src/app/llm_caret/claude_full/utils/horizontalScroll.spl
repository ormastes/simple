class HorizontalScrollWindow:
    startIndex: i64
    endIndex: i64
    showLeftArrow: bool
    showRightArrow: bool

fn calculateHorizontalScrollWindow(itemWidths: [i64], availableWidth: i64, arrowWidth: i64, selectedIdx: i64, firstItemHasSeparator: bool) -> HorizontalScrollWindow:
    val totalItems = itemWidths.len()
    if totalItems == 0:
        return HorizontalScrollWindow(startIndex: 0, endIndex: 0, showLeftArrow: false, showRightArrow: false)
    val selected = clampHorizontalScrollIndex(selectedIdx, totalItems)
    if sumHorizontalScrollWidths(itemWidths) <= availableWidth:
        return HorizontalScrollWindow(startIndex: 0, endIndex: totalItems, showLeftArrow: false, showRightArrow: false)
    var startIndex = 0
    var endIndex = 1
    var expandingRight = true
    while expandingRight:
        if endIndex >= totalItems:
            expandingRight = false
        else:
            val nextRangeWidth = horizontalScrollRangeWidth(itemWidths, startIndex, endIndex + 1, firstItemHasSeparator)
            val nextEffectiveWidth = horizontalScrollEffectiveWidth(availableWidth, arrowWidth, totalItems, startIndex, endIndex + 1)
            if nextRangeWidth > nextEffectiveWidth:
                expandingRight = false
            else:
                endIndex = endIndex + 1
    if selected >= startIndex and selected < endIndex:
        return HorizontalScrollWindow(startIndex: startIndex, endIndex: endIndex, showLeftArrow: startIndex > 0, showRightArrow: endIndex < totalItems)
    endIndex = selected + 1
    startIndex = selected
    var expandingLeft = true
    while expandingLeft:
        if startIndex <= 0:
            expandingLeft = false
        else:
            val nextRangeWidth = horizontalScrollRangeWidth(itemWidths, startIndex - 1, endIndex, firstItemHasSeparator)
            val nextEffectiveWidth = horizontalScrollEffectiveWidth(availableWidth, arrowWidth, totalItems, startIndex - 1, endIndex)
            if nextRangeWidth > nextEffectiveWidth:
                expandingLeft = false
            else:
                startIndex = startIndex - 1
    HorizontalScrollWindow(startIndex: startIndex, endIndex: endIndex, showLeftArrow: startIndex > 0, showRightArrow: endIndex < totalItems)

fn clampHorizontalScrollIndex(index: i64, totalItems: i64) -> i64:
    if index < 0:
        return 0
    if index >= totalItems:
        return totalItems - 1
    index

fn sumHorizontalScrollWidths(itemWidths: [i64]) -> i64:
    var total = 0
    for width in itemWidths:
        total = total + width
    total

fn horizontalScrollRangeWidth(itemWidths: [i64], startIndex: i64, endIndex: i64, firstItemHasSeparator: bool) -> i64:
    var total = 0
    var i = startIndex
    while i < endIndex:
        total = total + itemWidths[i]
        i = i + 1
    if firstItemHasSeparator and startIndex > 0:
        return total - 1
    total

fn horizontalScrollEffectiveWidth(availableWidth: i64, arrowWidth: i64, totalItems: i64, startIndex: i64, endIndex: i64) -> i64:
    var width = availableWidth
    if startIndex > 0:
        width = width - arrowWidth
    if endIndex < totalItems:
        width = width - arrowWidth
    width
