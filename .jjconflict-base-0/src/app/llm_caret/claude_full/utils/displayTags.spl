fn stripDisplayTags(textValue: text) -> text:
    val stripped = stripDisplayTagBlocks(textValue, false).trim()
    if stripped == "":
        return textValue
    stripped

fn stripDisplayTagsAllowEmpty(textValue: text) -> text:
    stripDisplayTagBlocks(textValue, false).trim()

fn stripIdeContextTags(textValue: text) -> text:
    stripDisplayTagBlocks(textValue, true).trim()

fn stripDisplayTagBlocks(textValue: text, ideOnly: bool) -> text:
    var out = ""
    var i = 0
    while i < textValue.len():
        val next = findDisplayTagEnd(textValue, i, ideOnly)
        if next > i:
            i = next
        else:
            out = out + textValue.slice(i, i + 1)
            i = i + 1
    out

fn findDisplayTagEnd(textValue: text, start: i64, ideOnly: bool) -> i64:
    if textValue.slice(start, start + 1) != "<":
        return start
    val nameEnd = findDisplayTagNameEnd(textValue, start + 1)
    if nameEnd <= start + 1:
        return start
    val tagName = textValue.slice(start + 1, nameEnd)
    if not isLowerDisplayTagName(tagName):
        return start
    if ideOnly and tagName != "ide_opened_file" and tagName != "ide_selection":
        return start
    val openEnd = findCharFrom(textValue, ">", nameEnd)
    if openEnd < 0:
        return start
    val closeStart = findTextFrom(textValue, "</" + tagName + ">", openEnd + 1)
    if closeStart < 0:
        return start
    var end = closeStart + tagName.len() + 3
    if end < textValue.len() and textValue.slice(end, end + 1) == "\n":
        end = end + 1
    end

fn findDisplayTagNameEnd(textValue: text, start: i64) -> i64:
    var i = start
    while i < textValue.len():
        val ch = textValue.slice(i, i + 1)
        if ch == ">" or ch == " " or ch == "\t" or ch == "\n":
            return i
        i = i + 1
    -1

fn isLowerDisplayTagName(tagName: text) -> bool:
    if tagName.len() == 0:
        return false
    val first = tagName.slice(0, 1)
    if first < "a" or first > "z":
        return false
    var i = 1
    while i < tagName.len():
        val ch = tagName.slice(i, i + 1)
        if not ((ch >= "a" and ch <= "z") or (ch >= "0" and ch <= "9") or (ch >= "A" and ch <= "Z") or ch == "_" or ch == "-"):
            return false
        i = i + 1
    true

fn findCharFrom(textValue: text, needle: text, start: i64) -> i64:
    var i = start
    while i < textValue.len():
        if textValue.slice(i, i + 1) == needle:
            return i
        i = i + 1
    -1

fn findTextFrom(textValue: text, needle: text, start: i64) -> i64:
    var i = start
    while i + needle.len() <= textValue.len():
        if textValue.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1
