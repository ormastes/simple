class DebugFilter:
    include: [text]
    exclude: [text]
    isExclusive: bool

fn parseDebugFilter(filterString: text) -> Option<DebugFilter>:
    if filterString.trim() == "":
        return nil

    var filters: [text] = []
    for raw in filterString.split(","):
        val trimmed = raw.trim()
        if trimmed != "":
            filters.push(trimmed)
    if filters.len() == 0:
        return nil

    var hasExclusive = false
    var hasInclusive = false
    for item in filters:
        if item.slice(0, 1) == "!":
            hasExclusive = true
        else:
            hasInclusive = true
    if hasExclusive and hasInclusive:
        return nil

    var clean: [text] = []
    for item in filters:
        var value = item
        if value.slice(0, 1) == "!":
            value = value.slice(1, value.len())
        clean.push(value.lower())

    if hasExclusive:
        return DebugFilter(include: [], exclude: clean, isExclusive: true)
    DebugFilter(include: clean, exclude: [], isExclusive: false)

fn shouldShowDebugCategories(categories: [text], filter: Option<DebugFilter>) -> bool:
    if not filter.?:
        return true
    val parsed = filter ?? DebugFilter(include: [], exclude: [], isExclusive: false)
    if categories.len() == 0:
        return false
    if parsed.isExclusive:
        for category in categories:
            if containsText(parsed.exclude, category.lower()):
                return false
        return true
    for category in categories:
        if containsText(parsed.include, category.lower()):
            return true
    false

fn containsText(values: [text], value: text) -> bool:
    for item in values:
        if item == value:
            return true
    false
