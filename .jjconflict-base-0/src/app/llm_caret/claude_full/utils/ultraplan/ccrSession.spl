"""
Claude full ultraplan CCR session parity surface.
"""

const ULTRAPLAN_TELEPORT_SENTINEL = "__ULTRAPLAN_TELEPORT_LOCAL__"
const ULTRAPLAN_POLL_INTERVAL_MS = 3000
const MAX_CONSECUTIVE_FAILURES = 5

class UltraplanPollError:
    name: text
    message: text
    reason: text
    rejectCount: i64

impl UltraplanPollError:
    static fn new(message: text, reason: text, rejectCount: i64) -> UltraplanPollError:
        UltraplanPollError(name: "UltraplanPollError", message: message, reason: reason, rejectCount: rejectCount)

class ExitPlanModeScanner:
    exitPlanCalls: [text]
    approvedPlans: [PlanResult]
    rejectedIds: [text]
    terminatedSubtype: text
    rescanAfterRejection: bool
    everSeenPending: bool

impl ExitPlanModeScanner:
    static fn new() -> ExitPlanModeScanner:
        ExitPlanModeScanner(exitPlanCalls: [], approvedPlans: [], rejectedIds: [], terminatedSubtype: "", rescanAfterRejection: false, everSeenPending: false)

    fn ingest(events: [CcrEvent]) -> ScanResult:
        var scanner = self.copy()
        var i = 0
        while i < events.len():
            val event = events[i]
            if event.kind == "tool_use":
                scanner.exitPlanCalls.push(event.id)
            elif event.kind == "tool_result":
                if event.isError:
                    scanner.rejectedIds.push(event.id)
                    scanner.rescanAfterRejection = true
                elif event.content.contains(ULTRAPLAN_TELEPORT_SENTINEL):
                    scanner.approvedPlans.push(PlanResult.new(event.id, extractTeleportPlan(event.content), "teleport"))
                else:
                    scanner.approvedPlans.push(PlanResult.new(event.id, event.content, "approved"))
            elif event.kind == "result_error":
                scanner.terminatedSubtype = event.subtype
            i = i + 1
        if scanner.approvedPlans.len() > 0:
            val plan = scanner.approvedPlans[scanner.approvedPlans.len() - 1]
            return ScanResult.new(plan.kind, plan.plan, plan.id, scanner)
        if scanner.terminatedSubtype != "":
            return ScanResult.new("terminated", scanner.terminatedSubtype, "", scanner)
        if scanner.hasPendingPlan():
            scanner.everSeenPending = true
            return ScanResult.new("pending", "", "", scanner)
        ScanResult.new("unchanged", "", "", scanner)

    fn rejectCount() -> i64:
        self.rejectedIds.len()

    fn hasPendingPlan() -> bool:
        if self.exitPlanCalls.len() == 0:
            return false
        val last = self.exitPlanCalls[self.exitPlanCalls.len() - 1]
        not containsPlanResult(self.approvedPlans, last) and not containsText(self.rejectedIds, last)

    fn copy() -> ExitPlanModeScanner:
        ExitPlanModeScanner(exitPlanCalls: copyUltraText(self.exitPlanCalls), approvedPlans: copyPlanResults(self.approvedPlans), rejectedIds: copyUltraText(self.rejectedIds), terminatedSubtype: self.terminatedSubtype, rescanAfterRejection: self.rescanAfterRejection, everSeenPending: self.everSeenPending)

class CcrEvent:
    kind: text
    id: text
    content: text
    isError: bool
    subtype: text

impl CcrEvent:
    static fn toolUse(id: text) -> CcrEvent:
        CcrEvent(kind: "tool_use", id: id, content: "", isError: false, subtype: "")

    static fn toolResult(id: text, content: text, isError: bool) -> CcrEvent:
        CcrEvent(kind: "tool_result", id: id, content: content, isError: isError, subtype: "")

    static fn resultError(subtype: text) -> CcrEvent:
        CcrEvent(kind: "result_error", id: "", content: "", isError: false, subtype: subtype)

class PlanResult:
    id: text
    plan: text
    kind: text

impl PlanResult:
    static fn new(id: text, plan: text, kind: text) -> PlanResult:
        PlanResult(id: id, plan: plan, kind: kind)

class ScanResult:
    kind: text
    plan: text
    id: text
    scanner: ExitPlanModeScanner

impl ScanResult:
    static fn new(kind: text, plan: text, id: text, scanner: ExitPlanModeScanner) -> ScanResult:
        ScanResult(kind: kind, plan: plan, id: id, scanner: scanner)

fn extractTeleportPlan(content: text) -> text:
    if not content.contains(ULTRAPLAN_TELEPORT_SENTINEL):
        return ""
    val parts = content.split(ULTRAPLAN_TELEPORT_SENTINEL + "\n")
    if parts.len() < 2:
        return ""
    parts[1].trim()

fn containsText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn containsPlanResult(values: [PlanResult], id: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i].id == id:
            return true
        i = i + 1
    false

fn copyUltraText(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn copyPlanResults(values: [PlanResult]) -> [PlanResult]:
    var out: [PlanResult] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

