class SessionEnvVar:
    name: text
    value: text

class SessionEnvVars:
    vars: [SessionEnvVar]

impl SessionEnvVars:
    static fn new() -> SessionEnvVars:
        SessionEnvVars(vars: [])

    fn getSessionEnvVars() -> [SessionEnvVar]:
        self.vars

    fn getSessionEnvVar(name: text) -> Option<text>:
        for item in self.vars:
            if item.name == name:
                return Some(item.value)
        nil

    me setSessionEnvVar(name: text, value: text):
        var updated: [SessionEnvVar] = []
        var replaced = false
        for item in self.vars:
            if item.name == name:
                updated.push(SessionEnvVar(name: name, value: value))
                replaced = true
            else:
                updated.push(item)
        if not replaced:
            updated.push(SessionEnvVar(name: name, value: value))
        self.vars = updated

    me deleteSessionEnvVar(name: text):
        var updated: [SessionEnvVar] = []
        for item in self.vars:
            if item.name != name:
                updated.push(item)
        self.vars = updated

    me clearSessionEnvVars():
        self.vars = []
