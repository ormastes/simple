fn stripMatchedQuotes(value: text) -> text:
    if value.starts_with("\"") && value.ends_with("\"") && value.len() >= 2:
        return value.slice(1, value.len() - 1)
    if value.starts_with("'") && value.ends_with("'") && value.len() >= 2:
        return value.slice(1, value.len() - 1)
    value

fn commandWords(value: text) -> [text]:
    var words: [text] = []
    var token = ""
    var inSingle = false
    var inDouble = false
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == "'" && not inDouble:
            inSingle = not inSingle
            token = token + ch
        else if ch == "\"" && not inSingle:
            inDouble = not inDouble
            token = token + ch
        else if (ch == " " || ch == "\t") && not inSingle && not inDouble:
            if token != "":
                words.push(token)
                token = ""
        else:
            token = token + ch
        i = i + 1
    if token != "":
        words.push(token)
    words

fn isSimpleCommandName(value: text) -> bool:
    if value == "":
        return false
    for ch in value.chars():
        if not ((ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") || (ch >= "0" && ch <= "9") || ch == "_" || ch == "-" || ch == "." || ch == "/"):
            return false
    true

fn isHelpCommandRoute(command: text) -> bool:
    val trimmed = command.trim()
    val parts = commandWords(trimmed)
    if parts.len() != 2:
        return false
    val name = stripMatchedQuotes(parts[0].trim())
    val flag = parts[1].trim()
    isSimpleCommandName(name) && (flag == "--help" || flag == "-h")

fn filterControlOperatorsRoute(command: text) -> text:
    var out = ""
    var inSingle = false
    var inDouble = false
    var i = 0
    while i < command.len():
        val ch = command.substring(i, i + 1)
        val next = if i + 1 < command.len(): command.substring(i + 1, i + 2) else: ""
        if ch == "'" && not inDouble:
            inSingle = not inSingle
            out = out + ch
        else if ch == "\"" && not inSingle:
            inDouble = not inDouble
            out = out + ch
        else if not inSingle && not inDouble && ((ch == "&" && next == "&") || (ch == "|" && next == "|")):
            out = out + " "
            i = i + 1
        else if not inSingle && not inDouble && (ch == ";" || ch == "|"):
            out = out + " "
        else:
            out = out + ch
        i = i + 1
    out.trim()
