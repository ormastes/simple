"""
Claude full terminal panel parity surface.
"""

const TMUX_SESSION = "panel"

class TerminalPanel:
    hasTmuxValue: bool
    hasTmuxKnown: bool
    cleanupRegistered: bool
    sessionExists: bool
    attached: bool
    fallbackLaunches: i64
    sessionId: text
    cwd: text
    shell: text
    log: [text]

impl TerminalPanel:
    static fn new(sessionId: text, cwd: text, shell: text) -> TerminalPanel:
        TerminalPanel(hasTmuxValue: false, hasTmuxKnown: false, cleanupRegistered: false, sessionExists: false, attached: false, fallbackLaunches: 0, sessionId: sessionId, cwd: cwd, shell: shell, log: [])

    fn checkTmux(status: i64) -> TerminalPanel:
        var next = self.copy()
        next.hasTmuxKnown = true
        next.hasTmuxValue = status == 0
        if not next.hasTmuxValue:
            next.log.push("Terminal panel: tmux not found, falling back to non-persistent shell")
        next

    fn createSession() -> TerminalPanel:
        var next = self.copy()
        if not next.hasTmuxValue:
            next.fallbackLaunches = next.fallbackLaunches + 1
            return next
        next.sessionExists = true
        next.cleanupRegistered = true
        next.log.push("bind M-j detach-client")
        next

    fn toggle() -> TerminalPanel:
        var next = self.copy()
        if not next.hasTmuxValue:
            next.fallbackLaunches = next.fallbackLaunches + 1
            return next
        if not next.sessionExists:
            next = next.createSession()
        next.attached = not next.attached
        next

    fn socket() -> text:
        "claude-panel-" + self.sessionId.slice(0, 8)

    fn copy() -> TerminalPanel:
        TerminalPanel(hasTmuxValue: self.hasTmuxValue, hasTmuxKnown: self.hasTmuxKnown, cleanupRegistered: self.cleanupRegistered, sessionExists: self.sessionExists, attached: self.attached, fallbackLaunches: self.fallbackLaunches, sessionId: self.sessionId, cwd: self.cwd, shell: self.shell, log: copyTerminalText(self.log))

fn getTerminalPanelSocket(sessionId: text) -> text:
    "claude-panel-" + sessionId.slice(0, 8)

fn copyTerminalText(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn terminalPanelSourceLinesModeled() -> i64: 191
