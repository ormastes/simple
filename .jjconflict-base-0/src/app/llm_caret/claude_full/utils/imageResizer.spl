"""
Claude full image resizer parity surface.
"""

class ImageResizeError:
    name: text
    message: text

impl ImageResizeError:
    static fn new(message: text) -> ImageResizeError:
        ImageResizeError(name: "ImageResizeError", message: message)

fn classifyImageErrorCode(code: text, message: text) -> i64:
    if code == "MODULE_NOT_FOUND" or code == "ERR_MODULE_NOT_FOUND" or code == "ERR_DLOPEN_FAILED":
        return 1
    if code == "EACCES" or code == "EPERM":
        return 8
    if code == "ENOMEM":
        return 5
    if message.contains("Native image processor module not available"):
        return 1
    if message.contains("unsupported image format") or message.contains("Input buffer contains unsupported image format"):
        return 7
    3

