"""
Claude full BigQuery metrics exporter parity surface.
"""

const EXPORT_SUCCESS = 0
const EXPORT_FAILED = 1

class MetricDataPoint:
    attributes: [MetricAttribute]
    value: i64
    timestamp: text

impl MetricDataPoint:
    static fn new(value: i64, timestamp: text) -> MetricDataPoint:
        MetricDataPoint(attributes: [], value: value, timestamp: timestamp)

    fn withAttribute(name: text, value: text) -> MetricDataPoint:
        var next = self.copy()
        next.attributes.push(MetricAttribute(name: name, value: value))
        next

    fn copy() -> MetricDataPoint:
        MetricDataPoint(attributes: copyMetricAttributes(self.attributes), value: self.value, timestamp: self.timestamp)

class MetricAttribute:
    name: text
    value: text

class InternalMetric:
    name: text
    description: text
    unit: text
    dataPoints: [MetricDataPoint]

impl InternalMetric:
    static fn new(name: text, value: i64) -> InternalMetric:
        InternalMetric(name: name, description: "", unit: "1", dataPoints: [MetricDataPoint.new(value, "0")])

class InternalMetricsPayload:
    resourceAttributes: [MetricAttribute]
    metrics: [InternalMetric]

impl InternalMetricsPayload:
    static fn new() -> InternalMetricsPayload:
        InternalMetricsPayload(resourceAttributes: [], metrics: [])

class BigQueryMetricsExporter:
    endpoint: text
    timeout: i64
    pendingExports: i64
    shutdown: bool
    userType: text
    metricsEndpointEnv: text

impl BigQueryMetricsExporter:
    static fn new(timeout: i64, userType: text, metricsEndpointEnv: text) -> BigQueryMetricsExporter:
        var endpoint = "https://api.anthropic.com/api/claude_code/metrics"
        if userType == "ant" and metricsEndpointEnv != "":
            endpoint = metricsEndpointEnv + "/api/claude_code/metrics"
        var actualTimeout = timeout
        if actualTimeout <= 0:
            actualTimeout = 5000
        BigQueryMetricsExporter(endpoint: endpoint, timeout: actualTimeout, pendingExports: 0, shutdown: false, userType: userType, metricsEndpointEnv: metricsEndpointEnv)

    fn export(metricsEnabled: bool, trustEstablished: bool, authError: text, postOk: bool, metricName: text, value: i64) -> BigQueryExportResult:
        if self.shutdown:
            return BigQueryExportResult.failure(self, "Exporter has been shutdown")
        var next = self.copy()
        next.pendingExports = next.pendingExports + 1
        if not trustEstablished:
            next.pendingExports = next.pendingExports - 1
            return BigQueryExportResult.success(next, InternalMetricsPayload.new(), "trust not established")
        if not metricsEnabled:
            next.pendingExports = next.pendingExports - 1
            return BigQueryExportResult.success(next, InternalMetricsPayload.new(), "metrics disabled")
        if authError != "":
            next.pendingExports = next.pendingExports - 1
            return BigQueryExportResult.failure(next, authError)
        val payload = self.transformMetricsForInternal(metricName, value, "delta", true, "pro")
        next.pendingExports = next.pendingExports - 1
        if not postOk:
            return BigQueryExportResult.failure(next, "post failed")
        BigQueryExportResult.success(next, payload, "exported")

    fn shutdownExporter() -> BigQueryMetricsExporter:
        var next = self.copy()
        next.shutdown = true
        next.pendingExports = 0
        next

    fn forceFlush() -> BigQueryExportResult:
        BigQueryExportResult.success(self.copy(), InternalMetricsPayload.new(), "flushed")

    fn selectAggregationTemporality() -> text:
        "delta"

    fn transformMetricsForInternal(metricName: text, value: i64, temporality: text, isClaudeSubscriber: bool, subscriptionType: text) -> InternalMetricsPayload:
        var payload = InternalMetricsPayload.new()
        payload.resourceAttributes.push(MetricAttribute(name: "service.name", value: "claude-code"))
        payload.resourceAttributes.push(MetricAttribute(name: "service.version", value: "unknown"))
        payload.resourceAttributes.push(MetricAttribute(name: "aggregation.temporality", value: temporality))
        if isClaudeSubscriber:
            payload.resourceAttributes.push(MetricAttribute(name: "user.customer_type", value: "claude_ai"))
            if subscriptionType != "":
                payload.resourceAttributes.push(MetricAttribute(name: "user.subscription_type", value: subscriptionType))
        else:
            payload.resourceAttributes.push(MetricAttribute(name: "user.customer_type", value: "api"))
        payload.metrics.push(InternalMetric.new(metricName, value))
        payload

    fn copy() -> BigQueryMetricsExporter:
        BigQueryMetricsExporter(endpoint: self.endpoint, timeout: self.timeout, pendingExports: self.pendingExports, shutdown: self.shutdown, userType: self.userType, metricsEndpointEnv: self.metricsEndpointEnv)

class BigQueryExportResult:
    code: i64
    error: text
    exporter: BigQueryMetricsExporter
    payload: InternalMetricsPayload
    note: text

impl BigQueryExportResult:
    static fn success(exporter: BigQueryMetricsExporter, payload: InternalMetricsPayload, note: text) -> BigQueryExportResult:
        BigQueryExportResult(code: EXPORT_SUCCESS, error: "", exporter: exporter, payload: payload, note: note)

    static fn failure(exporter: BigQueryMetricsExporter, error: text) -> BigQueryExportResult:
        BigQueryExportResult(code: EXPORT_FAILED, error: error, exporter: exporter, payload: InternalMetricsPayload.new(), note: "")

fn copyMetricAttributes(values: [MetricAttribute]) -> [MetricAttribute]:
    var out: [MetricAttribute] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn bigQueryExporterSourceLinesModeled() -> i64:
    252
