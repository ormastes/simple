fn difference(a: [text], b: [text]) -> [text]:
    var result: [text] = []
    for item in a:
        if not setContainsText(b, item) and not setContainsText(result, item):
            result = result + [item]
    result

fn intersects(a: [text], b: [text]) -> bool:
    if a.len() == 0 or b.len() == 0:
        return false
    for item in a:
        if setContainsText(b, item):
            return true
    false

fn every(a: [text], b: [text]) -> bool:
    for item in a:
        if not setContainsText(b, item):
            return false
    true

fn union(a: [text], b: [text]) -> [text]:
    var result: [text] = []
    for item in a:
        if not setContainsText(result, item):
            result = result + [item]
    for item in b:
        if not setContainsText(result, item):
            result = result + [item]
    result

fn setContainsText(values: [text], value: text) -> bool:
    for item in values:
        if item == value:
            return true
    false
