fn intersperse(values: [text], separator: text) -> [text]:
    intersperseWithIndex(values, fn(_index: i64) -> text: separator)

fn intersperseWithIndex(values: [text], separator: fn(i64) -> text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        if i > 0:
            out.push(separator(i))
        out.push(values[i])
        i = i + 1
    out

fn countTruthy(values: [bool]) -> i64:
    var n = 0
    var i = 0
    while i < values.len():
        if values[i]:
            n = n + 1
        i = i + 1
    n

fn containsText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

fn uniq(xs: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < xs.len():
        if not containsText(out, xs[i]):
            out.push(xs[i])
        i = i + 1
    out

fn arrayUtilsParityScope() -> text:
    "text arrays, indexed separators, and bool counts"
