fn detectSessionPatternType(pattern: text) -> Option<text>:
    val normalized = pattern.replace("\\", "/")
    if normalized.contains("session-memory") and (normalized.contains(".md") or normalized.ends_with("*")):
        return Some("session_memory")
    if normalized.contains(".jsonl") or (normalized.contains("projects") and normalized.contains("*.jsonl")):
        return Some("session_transcript")
    nil
