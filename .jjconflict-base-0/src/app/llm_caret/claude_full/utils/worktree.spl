const WORKTREE_SOURCE_LINES = 1519

fn validateWorktreeSlugRoute(slug: text) -> text:
    if slug.len() > 64:
        return "slug too long"
    if slug.starts_with("/") || slug.ends_with("/") || slug.contains("//"):
        return "invalid empty segment"
    for part in slug.split("/"):
        if part == "." || part == "..":
            return "invalid path segment"
    "valid"

fn flattenSlugRoute(slug: text) -> text:
    slug.replace("/", "+")

fn worktreeBranchNameRoute(slug: text) -> text:
    "worktree-" + flattenSlugRoute(slug)

fn sanitizeTmuxPartRoute(value: text) -> text:
    var out = value.replace("/", "_")
    out = out.replace(".", "_")
    out.replace("-", "_")

fn basenameRoute(path: text) -> text:
    val slash = path.rfind("/")
    if slash >= 0:
        return path.substring(slash + 1)
    path

fn generateTmuxSessionNameRoute(repoPath: text, branch: text) -> text:
    sanitizeTmuxPartRoute(basenameRoute(repoPath)) + "_" + sanitizeTmuxPartRoute(branch)

fn parsePRReferenceRoute(reference: text) -> text:
    if reference.starts_with("#"):
        return reference.substring(1)
    val marker = "/pull/"
    val pos = reference.find(marker)
    if pos < 0:
        return "null"
    val tail = reference.substring(pos + marker.len())
    var end = tail.find("?")
    val hash = tail.find("#")
    if end < 0 || (hash >= 0 && hash < end):
        end = hash
    if end >= 0:
        return tail.substring(0, end)
    tail

fn worktreeSourceLinesModeled() -> i64:
    WORKTREE_SOURCE_LINES
