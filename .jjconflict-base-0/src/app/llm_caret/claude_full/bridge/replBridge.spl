"""
Deterministic replBridge.ts parity surface for bridge state and poll loop.
"""

const REPL_BRIDGE_SOURCE_LINES: i64 = 2406

class ReplBridgeHandle:
    sessionId: text
    environmentId: text
    connected: bool

impl ReplBridgeHandle:
    static fn new(sessionId: text, environmentId: text) -> ReplBridgeHandle:
        ReplBridgeHandle(sessionId: sessionId, environmentId: environmentId, connected: true)

class BridgeState:
    status: text
    events: [text]
    reconnects: i64
    closed: bool

impl BridgeState:
    static fn new() -> BridgeState:
        BridgeState(status: "idle", events: [], reconnects: 0, closed: false)

class BridgeCoreParams:
    environmentId: text
    sessionId: text
    accessToken: text
    baseUrl: text

impl BridgeCoreParams:
    static fn new(environmentId: text, sessionId: text, accessToken: text, baseUrl: text) -> BridgeCoreParams:
        BridgeCoreParams(environmentId: environmentId, sessionId: sessionId, accessToken: accessToken, baseUrl: baseUrl)

class BridgeCoreHandle:
    handle: ReplBridgeHandle
    state: BridgeState
    pollCount: i64

impl BridgeCoreHandle:
    static fn new(handle: ReplBridgeHandle, state: BridgeState) -> BridgeCoreHandle:
        BridgeCoreHandle(handle: handle, state: state, pollCount: 0)

    me unregister() -> ():
        me.state.closed = true
        me.state.status = "unregistered"
        me.state.events = me.state.events + ["unregister"]

fn initBridgeCore(params: BridgeCoreParams) -> BridgeCoreHandle:
    val state = BridgeState.new()
    state.status = "connected"
    state.events = ["connect:" + params.environmentId]
    BridgeCoreHandle.new(ReplBridgeHandle.new(params.sessionId, params.environmentId), state)

fn tryReconnectInPlace(core: BridgeCoreHandle, token: text) -> bool:
    if token == "":
        core.state.events = core.state.events + ["reconnect:missing-token"]
        return false
    core.state.reconnects = core.state.reconnects + 1
    core.state.status = "connected"
    core.state.events = core.state.events + ["reconnect:in-place"]
    true

fn reconnectEnvironmentWithSession(environmentId: text, sessionId: text) -> text:
    environmentId + ":" + sessionId

fn doReconnect(core: BridgeCoreHandle, token: text) -> BridgeCoreHandle:
    val ok = tryReconnectInPlace(core, token)
    if not ok:
        core.state.status = "reconnect-failed"
    core

fn getOAuthToken(cachedToken: text, refreshedToken: text) -> text:
    if refreshedToken != "":
        return refreshedToken
    cachedToken

fn drainFlushGate(core: BridgeCoreHandle) -> ():
    core.state.events = core.state.events + ["flush"]

fn triggerTeardown(core: BridgeCoreHandle, reason: text) -> ():
    core.state.closed = true
    core.state.status = "closed"
    core.state.events = core.state.events + ["teardown:" + reason]

fn handleTransportPermanentClose(core: BridgeCoreHandle, code: i64) -> text:
    triggerTeardown(core, "transport:" + code.to_text())
    "closed"

fn onServerControlRequest(kind: text, payload: text) -> text:
    kind + ":" + payload

fn wireTransport(core: BridgeCoreHandle, transportStatus: text) -> BridgeCoreHandle:
    core.state.events = core.state.events + ["transport:" + transportStatus]
    core

fn startWorkPollLoop(core: BridgeCoreHandle, workItems: [text]) -> BridgeCoreHandle:
    var i = 0
    while i < workItems.len():
        core.pollCount = core.pollCount + 1
        core.state.events = core.state.events + ["work:" + workItems[i]]
        i = i + 1
    core

fn replBridgeSourceLinesModeled() -> i64:
    REPL_BRIDGE_SOURCE_LINES

