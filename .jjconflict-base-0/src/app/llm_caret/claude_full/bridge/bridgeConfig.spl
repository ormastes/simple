use app.io.mod.{env_get}

class BridgeOauthTokens:
    accessToken: text

impl BridgeOauthTokens:
    static fn new(accessToken: text) -> BridgeOauthTokens:
        BridgeOauthTokens(accessToken: accessToken)

    me hasAccessToken() -> bool:
        me.accessToken != ""

class BridgeOauthConfig:
    BASE_API_URL: text

impl BridgeOauthConfig:
    static fn new(BASE_API_URL: text) -> BridgeOauthConfig:
        BridgeOauthConfig(BASE_API_URL: BASE_API_URL)

class BridgeConfigContext:
    USER_TYPE: text
    CLAUDE_BRIDGE_OAUTH_TOKEN: text
    CLAUDE_BRIDGE_BASE_URL: text
    oauthTokens: BridgeOauthTokens
    oauthConfig: BridgeOauthConfig

impl BridgeConfigContext:
    static fn new(userType: text, tokenOverride: text, baseUrlOverride: text, accessToken: text, baseApiUrl: text) -> BridgeConfigContext:
        BridgeConfigContext(
            USER_TYPE: userType,
            CLAUDE_BRIDGE_OAUTH_TOKEN: tokenOverride,
            CLAUDE_BRIDGE_BASE_URL: baseUrlOverride,
            oauthTokens: BridgeOauthTokens.new(accessToken),
            oauthConfig: BridgeOauthConfig.new(baseApiUrl)
        )

    static fn fromEnv() -> BridgeConfigContext:
        BridgeConfigContext.new(
            env_get("USER_TYPE") ?? "",
            env_get("CLAUDE_BRIDGE_OAUTH_TOKEN") ?? "",
            env_get("CLAUDE_BRIDGE_BASE_URL") ?? "",
            env_get("CLAUDE_AI_OAUTH_ACCESS_TOKEN") ?? "",
            env_get("CLAUDE_BASE_API_URL") ?? "https://api.anthropic.com"
        )

    me getBridgeTokenOverride() -> text?:
        if me.USER_TYPE == "ant" and me.CLAUDE_BRIDGE_OAUTH_TOKEN != "":
            return Some(me.CLAUDE_BRIDGE_OAUTH_TOKEN)
        nil

    me getBridgeBaseUrlOverride() -> text?:
        if me.USER_TYPE == "ant" and me.CLAUDE_BRIDGE_BASE_URL != "":
            return Some(me.CLAUDE_BRIDGE_BASE_URL)
        nil

    me getBridgeAccessToken() -> text?:
        val token = me.getBridgeTokenOverride()
        if token.?:
            return token
        if me.oauthTokens.hasAccessToken():
            return Some(me.oauthTokens.accessToken)
        nil

    me getBridgeBaseUrl() -> text:
        me.getBridgeBaseUrlOverride() ?? me.oauthConfig.BASE_API_URL

fn bridgeConfigContextNew(userType: text, tokenOverride: text, baseUrlOverride: text, accessToken: text, baseApiUrl: text) -> BridgeConfigContext:
    BridgeConfigContext.new(userType, tokenOverride, baseUrlOverride, accessToken, baseApiUrl)

fn getBridgeTokenOverrideFrom(ctx: BridgeConfigContext) -> text?:
    ctx.getBridgeTokenOverride()

fn getBridgeBaseUrlOverrideFrom(ctx: BridgeConfigContext) -> text?:
    ctx.getBridgeBaseUrlOverride()

fn getBridgeAccessTokenFrom(ctx: BridgeConfigContext) -> text?:
    ctx.getBridgeAccessToken()

fn getBridgeBaseUrlFrom(ctx: BridgeConfigContext) -> text:
    ctx.getBridgeBaseUrl()

fn getBridgeTokenOverride() -> text?:
    BridgeConfigContext.fromEnv().getBridgeTokenOverride()

fn getBridgeBaseUrlOverride() -> text?:
    BridgeConfigContext.fromEnv().getBridgeBaseUrlOverride()

fn getBridgeAccessToken() -> text?:
    BridgeConfigContext.fromEnv().getBridgeAccessToken()

fn getBridgeBaseUrl() -> text:
    BridgeConfigContext.fromEnv().getBridgeBaseUrl()
