"""
Streaming tool executor parity model.

Captures queueing, concurrency safety, progress-first yielding, synthetic
errors, sibling Bash cancellation, context modifiers, and completion marking.
"""

class MessageUpdate:
    message: ToolMessage
    newContext: ToolUseContextModel

impl MessageUpdate:
    static fn new(message: ToolMessage, newContext: ToolUseContextModel) -> MessageUpdate:
        MessageUpdate(message: message, newContext: newContext)

class ToolBlock:
    id: text
    name: text
    inputSummary: text
    validInput: bool

impl ToolBlock:
    static fn new(id: text, name: text, inputSummary: text) -> ToolBlock:
        ToolBlock(id: id, name: name, inputSummary: inputSummary, validInput: true)

class AssistantMessage:
    uuid: text

impl AssistantMessage:
    static fn new(uuid: text) -> AssistantMessage:
        AssistantMessage(uuid: uuid)

class ToolDefinition:
    name: text
    concurrencySafe: bool
    interruptBehavior: text

impl ToolDefinition:
    static fn new(name: text, concurrencySafe: bool, interruptBehavior: text) -> ToolDefinition:
        ToolDefinition(name: name, concurrencySafe: concurrencySafe, interruptBehavior: interruptBehavior)

class ToolMessage:
    type: text
    content: text
    toolUseId: text
    isError: bool
    sourceToolAssistantUUID: text

impl ToolMessage:
    static fn result(toolUseId: text, content: text, isError: bool, uuid: text) -> ToolMessage:
        ToolMessage(type: "user", content: content, toolUseId: toolUseId, isError: isError, sourceToolAssistantUUID: uuid)

    static fn progress(toolUseId: text, content: text) -> ToolMessage:
        ToolMessage(type: "progress", content: content, toolUseId: toolUseId, isError: false, sourceToolAssistantUUID: "")

class ToolUseContextModel:
    abortReason: text
    inProgressToolUseIDs: [text]
    interruptible: bool
    completedToolUseIDs: [text]
    modifierCount: i64

impl ToolUseContextModel:
    static fn new() -> ToolUseContextModel:
        ToolUseContextModel(abortReason: "", inProgressToolUseIDs: [], interruptible: false, completedToolUseIDs: [], modifierCount: 0)

class TrackedTool:
    id: text
    block: ToolBlock
    assistantMessage: AssistantMessage
    status: text
    isConcurrencySafe: bool
    results: [ToolMessage]
    pendingProgress: [ToolMessage]
    contextModifierCount: i64
    willError: bool

impl TrackedTool:
    static fn new(block: ToolBlock, assistantMessage: AssistantMessage, status: text, isConcurrencySafe: bool) -> TrackedTool:
        TrackedTool(id: block.id, block: block, assistantMessage: assistantMessage, status: status, isConcurrencySafe: isConcurrencySafe, results: [], pendingProgress: [], contextModifierCount: 0, willError: false)

class StreamingToolExecutor:
    tools: [TrackedTool]
    toolDefinitions: [ToolDefinition]
    toolUseContext: ToolUseContextModel
    hasErrored: bool
    erroredToolDescription: text
    siblingAbortReason: text
    discarded: bool
    progressAvailable: bool

impl StreamingToolExecutor:
    static fn new(toolDefinitions: [ToolDefinition], toolUseContext: ToolUseContextModel) -> StreamingToolExecutor:
        StreamingToolExecutor(tools: [], toolDefinitions: toolDefinitions, toolUseContext: toolUseContext, hasErrored: false, erroredToolDescription: "", siblingAbortReason: "", discarded: false, progressAvailable: false)

    me discard() -> ():
        me.discarded = true

    me addTool(block: ToolBlock, assistantMessage: AssistantMessage) -> ():
        val defn = findToolByName(me.toolDefinitions, block.name)
        if defn.name == "":
            var missing = TrackedTool.new(block, assistantMessage, "completed", true)
            missing.results = [ToolMessage.result(block.id, "<tool_use_error>Error: No such tool available: " + block.name + "</tool_use_error>", true, assistantMessage.uuid)]
            me.tools = appendTrackedTool(me.tools, missing)
            return
        val safe = block.validInput and defn.concurrencySafe
        var tool = TrackedTool.new(block, assistantMessage, "queued", safe)
        if block.inputSummary == "ERROR":
            tool.willError = true
        me.tools = appendTrackedTool(me.tools, tool)
        me.processQueue()

    me canExecuteTool(isConcurrencySafe: bool) -> bool:
        val executing = executingTools(me.tools)
        if executing.len() == 0:
            return true
        if not isConcurrencySafe:
            return false
        var i = 0
        while i < executing.len():
            if not executing[i].isConcurrencySafe:
                return false
            i = i + 1
        true

    me processQueue() -> ():
        var i = 0
        while i < me.tools.len():
            if me.tools[i].status == "queued":
                if me.canExecuteTool(me.tools[i].isConcurrencySafe):
                    me.executeToolAt(i)
                else if not me.tools[i].isConcurrencySafe:
                    return
            i = i + 1

    me createSyntheticErrorMessage(toolUseId: text, reason: text, assistantMessage: AssistantMessage) -> ToolMessage:
        if reason == "user_interrupted":
            return ToolMessage.result(toolUseId, "User rejected tool use", true, assistantMessage.uuid)
        if reason == "streaming_fallback":
            return ToolMessage.result(toolUseId, "<tool_use_error>Error: Streaming fallback - tool execution discarded</tool_use_error>", true, assistantMessage.uuid)
        var msg = "Cancelled: parallel tool call errored"
        if me.erroredToolDescription != "":
            msg = "Cancelled: parallel tool call " + me.erroredToolDescription + " errored"
        ToolMessage.result(toolUseId, "<tool_use_error>" + msg + "</tool_use_error>", true, assistantMessage.uuid)

    me getAbortReason(tool: TrackedTool) -> text:
        if me.discarded:
            return "streaming_fallback"
        if me.hasErrored:
            return "sibling_error"
        if me.toolUseContext.abortReason != "":
            if me.toolUseContext.abortReason == "interrupt":
                if me.getToolInterruptBehavior(tool) == "cancel":
                    return "user_interrupted"
                return ""
            return "user_interrupted"
        ""

    me getToolInterruptBehavior(tool: TrackedTool) -> text:
        val defn = findToolByName(me.toolDefinitions, tool.block.name)
        if defn.interruptBehavior == "":
            return "block"
        defn.interruptBehavior

    me getToolDescription(tool: TrackedTool) -> text:
        if tool.block.inputSummary != "":
            if tool.block.inputSummary.len() > 40:
                return tool.block.name + "(" + tool.block.inputSummary.slice(0, 40) + "…)"
            return tool.block.name + "(" + tool.block.inputSummary + ")"
        tool.block.name

    me updateInterruptibleState() -> ():
        val executing = executingTools(me.tools)
        if executing.len() == 0:
            me.toolUseContext.interruptible = false
            return
        var allCancel = true
        var i = 0
        while i < executing.len():
            if me.getToolInterruptBehavior(executing[i]) != "cancel":
                allCancel = false
            i = i + 1
        me.toolUseContext.interruptible = allCancel

    me executeToolAt(index: i64) -> ():
        var tool = me.tools[index]
        tool.status = "executing"
        me.toolUseContext.inProgressToolUseIDs = appendTextStreaming(me.toolUseContext.inProgressToolUseIDs, tool.id)
        me.tools[index] = tool
        me.updateInterruptibleState()
        me.collectResults(index)

    me collectResults(index: i64) -> ():
        var tool = me.tools[index]
        val abortReason = me.getAbortReason(tool)
        if abortReason != "":
            tool.results = [me.createSyntheticErrorMessage(tool.id, abortReason, tool.assistantMessage)]
            tool.status = "completed"
            me.tools[index] = tool
            me.updateInterruptibleState()
            return
        if tool.block.inputSummary == "PROGRESS":
            tool.pendingProgress = appendToolMessage(tool.pendingProgress, ToolMessage.progress(tool.id, "progress:" + tool.block.name))
            me.progressAvailable = true
        if tool.willError:
            tool.results = [ToolMessage.result(tool.id, "<tool_use_error>Error</tool_use_error>", true, tool.assistantMessage.uuid)]
            if tool.block.name == "Bash":
                me.hasErrored = true
                me.erroredToolDescription = me.getToolDescription(tool)
                me.siblingAbortReason = "sibling_error"
        else:
            tool.results = [ToolMessage.result(tool.id, "result:" + tool.block.name, false, tool.assistantMessage.uuid)]
        if tool.block.inputSummary == "MODIFY":
            tool.contextModifierCount = 1
        tool.status = "completed"
        me.tools[index] = tool
        me.updateInterruptibleState()

    me getCompletedResults() -> [MessageUpdate]:
        var out: [MessageUpdate] = []
        if me.discarded:
            return out
        var i = 0
        while i < me.tools.len():
            var tool = me.tools[i]
            var p = 0
            while p < tool.pendingProgress.len():
                out = appendMessageUpdate(out, MessageUpdate.new(tool.pendingProgress[p], me.toolUseContext))
                p = p + 1
            tool.pendingProgress = []
            if tool.status == "yielded":
                me.tools[i] = tool
                i = i + 1
                continue
            if tool.status == "completed":
                tool.status = "yielded"
                var r = 0
                while r < tool.results.len():
                    out = appendMessageUpdate(out, MessageUpdate.new(tool.results[r], me.toolUseContext))
                    r = r + 1
                if not tool.isConcurrencySafe and tool.contextModifierCount > 0:
                    me.toolUseContext.modifierCount = me.toolUseContext.modifierCount + tool.contextModifierCount
                me.toolUseContext.completedToolUseIDs = appendTextStreaming(me.toolUseContext.completedToolUseIDs, tool.id)
                me.toolUseContext.inProgressToolUseIDs = removeTextStreaming(me.toolUseContext.inProgressToolUseIDs, tool.id)
                me.tools[i] = tool
            else if tool.status == "executing" and not tool.isConcurrencySafe:
                return out
            i = i + 1
        out

    me hasPendingProgress() -> bool:
        var i = 0
        while i < me.tools.len():
            if me.tools[i].pendingProgress.len() > 0:
                return true
            i = i + 1
        false

    me getRemainingResults() -> [MessageUpdate]:
        me.processQueue()
        me.getCompletedResults()

    me hasCompletedResults() -> bool:
        var i = 0
        while i < me.tools.len():
            if me.tools[i].status == "completed":
                return true
            i = i + 1
        false

    me hasExecutingTools() -> bool:
        executingTools(me.tools).len() > 0

    me hasUnfinishedTools() -> bool:
        var i = 0
        while i < me.tools.len():
            if me.tools[i].status != "yielded":
                return true
            i = i + 1
        false

    me getUpdatedContext() -> ToolUseContextModel:
        me.toolUseContext

fn executingTools(tools: [TrackedTool]) -> [TrackedTool]:
    var out: [TrackedTool] = []
    var i = 0
    while i < tools.len():
        if tools[i].status == "executing":
            out = appendTrackedTool(out, tools[i])
        i = i + 1
    out

fn findToolByName(tools: [ToolDefinition], name: text) -> ToolDefinition:
    var i = 0
    while i < tools.len():
        if tools[i].name == name:
            return tools[i]
        i = i + 1
    ToolDefinition.new("", false, "")

fn markToolUseAsComplete(toolUseContext: ToolUseContextModel, toolUseID: text) -> ():
    toolUseContext.completedToolUseIDs = appendTextStreaming(toolUseContext.completedToolUseIDs, toolUseID)
    toolUseContext.inProgressToolUseIDs = removeTextStreaming(toolUseContext.inProgressToolUseIDs, toolUseID)

fn appendTrackedTool(values: [TrackedTool], value: TrackedTool) -> [TrackedTool]:
    var out: [TrackedTool] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn appendToolMessage(values: [ToolMessage], value: ToolMessage) -> [ToolMessage]:
    var out: [ToolMessage] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn appendMessageUpdate(values: [MessageUpdate], value: MessageUpdate) -> [MessageUpdate]:
    var out: [MessageUpdate] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn appendTextStreaming(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn removeTextStreaming(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        if values[i] != value:
            out.push(values[i])
        i = i + 1
    out

fn streamingToolExecutorSourceLinesModeled() -> i64:
    530
