class BranchMessage:
    uuid: text
    kind: text
    content: text
    isSidechain: bool

    static fn new(uuid: text, kind: text, content: text, isSidechain: bool) -> BranchMessage:
        BranchMessage(uuid: uuid, kind: kind, content: content, isSidechain: isSidechain)

class BranchReplacement:
    sessionId: text
    value: text

    static fn new(sessionId: text, value: text) -> BranchReplacement:
        BranchReplacement(sessionId: sessionId, value: value)

class ForkedBranchEntry:
    uuid: text
    sessionId: text
    parentUuid: text
    forkedFromSessionId: text
    forkedFromMessageUuid: text

    static fn new(uuid: text, sessionId: text, parentUuid: text, forkedFromSessionId: text, forkedFromMessageUuid: text) -> ForkedBranchEntry:
        ForkedBranchEntry(uuid: uuid, sessionId: sessionId, parentUuid: parentUuid, forkedFromSessionId: forkedFromSessionId, forkedFromMessageUuid: forkedFromMessageUuid)

class BranchFork:
    sessionId: text
    title: text
    forkPath: text
    serializedMessages: [BranchMessage]
    entries: [ForkedBranchEntry]
    contentReplacementCount: i64

    static fn new(sessionId: text, title: text, forkPath: text, serializedMessages: [BranchMessage], entries: [ForkedBranchEntry], contentReplacementCount: i64) -> BranchFork:
        BranchFork(sessionId: sessionId, title: title, forkPath: forkPath, serializedMessages: serializedMessages, entries: entries, contentReplacementCount: contentReplacementCount)

class BranchCallResult:
    ok: bool
    doneMessage: text
    resumedSessionId: text
    resumeMode: text

    static fn new(ok: bool, doneMessage: text, resumedSessionId: text, resumeMode: text) -> BranchCallResult:
        BranchCallResult(ok: ok, doneMessage: doneMessage, resumedSessionId: resumedSessionId, resumeMode: resumeMode)

fn deriveFirstPrompt(firstUserContent: text) -> text:
    val raw = collapseWhitespace(firstUserContent).trim()
    if raw == "":
        return "Branched conversation"
    if raw.len() > 100:
        return raw.slice(0, 100)
    raw

fn collapseWhitespace(value: text) -> text:
    var out = ""
    var inWhitespace = false
    var i = 0
    while i < value.len():
        val ch = value[i]
        if ch == " " or ch == "\n" or ch == "\t" or ch == "\r":
            if not inWhitespace:
                out = out + " "
            inWhitespace = true
        else:
            out = out + ch
            inWhitespace = false
        i = i + 1
    out

fn getUniqueForkName(baseName: text, existingTitles: [text]) -> text:
    val candidateName = baseName + " (Branch)"
    if not containsText(existingTitles, candidateName):
        return candidateName
    var nextNumber = 2
    while containsText(existingTitles, baseName + " (Branch " + nextNumber.to_text() + ")"):
        nextNumber = nextNumber + 1
    baseName + " (Branch " + nextNumber.to_text() + ")"

fn createFork(originalSessionId: text, forkSessionId: text, forkPath: text, customTitle: text, messages: [BranchMessage], replacements: [BranchReplacement]) -> BranchFork:
    val mainMessages = mainConversationMessages(messages)
    if mainMessages.len() == 0:
        return BranchFork.new("", "error:No messages to branch", "", [], [], 0)
    var parentUuid = ""
    var entries: [ForkedBranchEntry] = []
    var i = 0
    while i < mainMessages.len():
        val message = mainMessages[i]
        entries.push(ForkedBranchEntry.new(message.uuid, forkSessionId, parentUuid, originalSessionId, message.uuid))
        if message.kind != "progress":
            parentUuid = message.uuid
        i = i + 1
    BranchFork.new(forkSessionId, customTitle, forkPath, mainMessages, entries, replacementCountForSession(replacements, originalSessionId))

fn callBranch(originalSessionId: text, fork: BranchFork, customTitle: text, canResume: bool) -> BranchCallResult:
    if fork.sessionId == "":
        return BranchCallResult.new(false, "Failed to branch conversation: No messages to branch", "", "")
    val titleInfo = if customTitle.trim() == "": "" else: " \"" + customTitle.trim() + "\""
    if canResume:
        return BranchCallResult.new(true, "Branched conversation" + titleInfo + ". You are now in the branch.\nTo resume the original: claude -r " + originalSessionId, fork.sessionId, "fork")
    BranchCallResult.new(true, "Branched conversation" + titleInfo + ". Resume with: /resume " + fork.sessionId, "", "")

fn firstUserPrompt(messages: [BranchMessage]) -> text:
    var i = 0
    while i < messages.len():
        val message = messages[i]
        if message.kind == "user":
            return deriveFirstPrompt(message.content)
        i = i + 1
    deriveFirstPrompt("")

fn effectiveBranchTitle(customTitle: text, messages: [BranchMessage], existingTitles: [text]) -> text:
    val base = if customTitle.trim() == "": firstUserPrompt(messages) else: customTitle.trim()
    getUniqueForkName(base, existingTitles)

fn mainConversationMessages(messages: [BranchMessage]) -> [BranchMessage]:
    var out: [BranchMessage] = []
    var i = 0
    while i < messages.len():
        val message = messages[i]
        if not message.isSidechain:
            out.push(message)
        i = i + 1
    out

fn replacementCountForSession(replacements: [BranchReplacement], originalSessionId: text) -> i64:
    var count = 0
    var i = 0
    while i < replacements.len():
        if replacements[i].sessionId == originalSessionId:
            count = count + 1
        i = i + 1
    count

fn containsText(values: [text], value: text) -> bool:
    var i = 0
    while i < values.len():
        if values[i] == value:
            return true
        i = i + 1
    false

