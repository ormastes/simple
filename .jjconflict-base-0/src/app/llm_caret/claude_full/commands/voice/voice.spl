"""
Claude full voice command parity.
"""

class VoiceCommandState:
    enabled: bool
    provider: text
    language: text

impl VoiceCommandState:
    static fn new(enabled: bool, provider: text, language: text) -> VoiceCommandState:
        VoiceCommandState(enabled: enabled, provider: provider.trim(), language: language.trim())

class VoiceCommandResult:
    state: VoiceCommandState
    message: text

impl VoiceCommandResult:
    static fn new(state: VoiceCommandState, message: text) -> VoiceCommandResult:
        VoiceCommandResult(state: state, message: message)

fn voiceCommandName() -> text:
    "voice"

fn normalizeVoiceProvider(raw: text) -> text:
    val provider = raw.trim().to_lower()
    if provider == "system" or provider == "whisper":
        return provider
    "system"

fn applyVoiceCommand(action: text, state: VoiceCommandState) -> VoiceCommandResult:
    val value = action.trim().to_lower()
    if value == "on" or value == "enable":
        val next = VoiceCommandState.new(true, normalizeVoiceProvider(state.provider), state.language)
        return VoiceCommandResult.new(next, "Voice input enabled")
    if value == "off" or value == "disable":
        val next = VoiceCommandState.new(false, normalizeVoiceProvider(state.provider), state.language)
        return VoiceCommandResult.new(next, "Voice input disabled")
    if value.starts_with("provider "):
        val provider = normalizeVoiceProvider(value.slice(9, value.len()))
        val next = VoiceCommandState.new(state.enabled, provider, state.language)
        return VoiceCommandResult.new(next, "Voice provider: " + provider)
    VoiceCommandResult.new(state, "Voice input is " + voiceEnabledLabel(state.enabled))

fn voiceEnabledLabel(enabled: bool) -> text:
    if enabled:
        return "enabled"
    "disabled"

fn voiceStatus(state: VoiceCommandState) -> text:
    "Voice " + voiceEnabledLabel(state.enabled) + " via " + normalizeVoiceProvider(state.provider) + " for " + state.language

fn voiceSourceLinesModeled() -> i64:
    150
