"""
Claude full PluginErrors parity.
"""

class PluginErrorView:
    title: text
    message: text
    recoverable: bool

impl PluginErrorView:
    static fn new(title: text, message: text, recoverable: bool) -> PluginErrorView:
        PluginErrorView(title: title, message: message, recoverable: recoverable)

fn pluginErrorView(code: text, message: text) -> PluginErrorView:
    if code == "network":
        return PluginErrorView.new("Network error", message, true)
    if code == "trust":
        return PluginErrorView.new("Trust required", message, true)
    PluginErrorView.new("Plugin error", message, false)

fn pluginErrorsSourceLinesModeled() -> i64:
    123
