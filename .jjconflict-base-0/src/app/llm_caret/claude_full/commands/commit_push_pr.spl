"""
Claude full commit-push-pr command parity.
"""

fn commitPushPrAllowedTools() -> [text]:
    ["Bash(git checkout --branch:*)", "Bash(git checkout -b:*)", "Bash(git add:*)", "Bash(git status:*)", "Bash(git push:*)", "Bash(git commit:*)", "Bash(gh pr create:*)", "Bash(gh pr edit:*)", "Bash(gh pr view:*)", "Bash(gh pr merge:*)", "ToolSearch", "mcp__slack__send_message", "mcp__claude_ai_Slack__slack_send_message"]

fn commitPushPrPromptContent(defaultBranch: text, prAttribution: text, commitAttribution: text, safeUser: text, username: text, userType: text, undercover: bool, undercoverInstructions: text, args: text) -> text:
    var prefix = ""
    var reviewerArg = " and `--reviewer anthropics/claude-code`"
    var addReviewerArg = " (and add `--add-reviewer anthropics/claude-code`)"
    var changelogSection = "\n\n## Changelog\n<!-- CHANGELOG:START -->\n[If this PR contains user-facing changes, add a changelog entry here. Otherwise, remove this section.]\n<!-- CHANGELOG:END -->"
    var slackStep = "\n\n5. After creating/updating the PR, check if the user's CLAUDE.md mentions posting to Slack channels."
    if userType == "ant" and undercover:
        prefix = undercoverInstructions + "\n"
        reviewerArg = ""
        addReviewerArg = ""
        changelogSection = ""
        slackStep = ""
    var attribution = ""
    if prAttribution != "":
        attribution = "\n\n" + prAttribution
    var extra = ""
    if args.trim() != "":
        extra = "\n\n## Additional instructions from user\n\n" + args.trim()
    prefix + "## Context\n\n- `SAFEUSER`: " + safeUser + "\n- `whoami`: " + username + "\n- `git status`: !`git status`\n- `git diff HEAD`: !`git diff HEAD`\n- `git branch --show-current`: !`git branch --show-current`\n- `git diff " + defaultBranch + "...HEAD`: !`git diff " + defaultBranch + "...HEAD`\n- `gh pr view --json number 2>/dev/null || true`: !`gh pr view --json number 2>/dev/null || true`\n\n## Git Safety Protocol\n\n- NEVER update the git config\n- NEVER run destructive/irreversible git commands (like push --force, hard reset, etc) unless the user explicitly requests them\n- NEVER run force push to main/master, warn the user if they request it\n- Never use git commands with the -i flag\n\n## Your task\n\nAnalyze all changes that will be included in the pull request.\n\nBased on the above changes:\n1. Create a new branch if on " + defaultBranch + "\n2. Create a single commit with an appropriate message using heredoc syntax\n3. Push the branch to origin\n4. Create or update a pull request" + addReviewerArg + reviewerArg + changelogSection + attribution + slackStep + extra

fn commitPushPrCommandDescriptor(defaultBranch: text) -> PromptCommandDescriptor:
    PromptCommandDescriptor.new("commit-push-pr", "Commit, push, and open a PR", commitPushPrAllowedTools(), commitPushPrPromptContent(defaultBranch, "", "", "", "", "", false, "", "").len(), "creating commit and PR")

fn commitPushPrSourceLinesModeled() -> i64:
    158
