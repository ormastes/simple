use app.llm_caret.claude_full.commands.mobile.mobile.*

class MobileCommandDescriptor:
    typeName: text
    name: text
    aliases: [text]
    description: text
    loadPath: text

    static fn new() -> MobileCommandDescriptor:
        MobileCommandDescriptor(typeName: "local-jsx", name: "mobile", aliases: ["ios", "android"], description: "Show QR code to download the Claude mobile app", loadPath: "./mobile.js")

fn mobileCommand() -> MobileCommandDescriptor:
    MobileCommandDescriptor.new()

fn mobileIndexSourceLinesModeled() -> i64:
    11
