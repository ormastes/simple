class CompactCommand:
    typeName: text
    name: text
    description: text
    enabled: bool
    supportsNonInteractive: bool
    argumentHint: text
    loadPath: text

    static fn new(disableCompactEnvTruthy: bool) -> CompactCommand:
        CompactCommand(typeName: "local", name: "compact", description: "Clear conversation history but keep a summary in context. Optional: /compact [instructions for summarization]", enabled: not disableCompactEnvTruthy, supportsNonInteractive: true, argumentHint: "<optional custom summarization instructions>", loadPath: "./compact.js")

fn compactCommand(disableCompactEnvTruthy: bool) -> CompactCommand:
    CompactCommand.new(disableCompactEnvTruthy)

fn compactIndexSourceLinesModeled() -> i64:
    15
