"""
Claude full memory command parity.
"""

class MemoryCommandDescriptor:
    typeName: text
    name: text
    description: text

impl MemoryCommandDescriptor:
    static fn new() -> MemoryCommandDescriptor:
        MemoryCommandDescriptor(typeName: "local-jsx", name: "memory", description: "Edit project memory")

fn memoryCommand() -> MemoryCommandDescriptor:
    MemoryCommandDescriptor.new()

fn memoryTargetPath(scope: text) -> text:
    if scope == "user":
        return "~/.claude/CLAUDE.md"
    "CLAUDE.md"

fn memorySourceLinesModeled() -> i64:
