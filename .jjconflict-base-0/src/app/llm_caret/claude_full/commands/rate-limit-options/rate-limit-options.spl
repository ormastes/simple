"""
Claude full rate-limit-options command parity.
"""

class RateLimitOption:
    name: text
    delaySeconds: i64

impl RateLimitOption:
    static fn new(name: text, delaySeconds: i64) -> RateLimitOption:
        RateLimitOption(name: name, delaySeconds: delaySeconds)

fn defaultRateLimitOptions() -> [RateLimitOption]:
    [
        RateLimitOption.new("wait", 60),
        RateLimitOption.new("switch-model", 0),
        RateLimitOption.new("retry", 10),
    ]

fn rateLimitOptionLabel(option: RateLimitOption) -> text:
    option.name + ":" + option.delaySeconds.to_text()

fn rateLimitOptionsSourceLinesModeled() -> i64:
    209
