"""
Claude full plan command parity.
"""

class PlanCommandState:
    mode: text
    readonly: bool

impl PlanCommandState:
    static fn new(mode: text, readonly: bool) -> PlanCommandState:
        PlanCommandState(mode: mode, readonly: readonly)

fn planCommandName() -> text:
    "plan"

fn enterPlanMode(state: PlanCommandState) -> PlanCommandState:
    PlanCommandState.new("plan", true)

fn leavePlanMode(state: PlanCommandState) -> PlanCommandState:
    PlanCommandState.new("default", false)

fn planModeMessage(state: PlanCommandState) -> text:
    if state.mode == "plan":
        return "Plan mode enabled"
    "Plan mode disabled"

fn planSourceLinesModeled() -> i64:
    121
