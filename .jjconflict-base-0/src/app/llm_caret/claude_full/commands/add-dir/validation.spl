"""
Claude full add-dir validation parity.
"""

class AddDirectoryResult:
    resultType: text
    directoryPath: text
    absolutePath: text
    workingDir: text

impl AddDirectoryResult:
    static fn success(absolutePath: text) -> AddDirectoryResult:
        AddDirectoryResult(resultType: "success", directoryPath: "", absolutePath: absolutePath, workingDir: "")

    static fn emptyPath() -> AddDirectoryResult:
        AddDirectoryResult(resultType: "emptyPath", directoryPath: "", absolutePath: "", workingDir: "")

    static fn pathNotFound(directoryPath: text, absolutePath: text) -> AddDirectoryResult:
        AddDirectoryResult(resultType: "pathNotFound", directoryPath: directoryPath, absolutePath: absolutePath, workingDir: "")

    static fn notADirectory(directoryPath: text, absolutePath: text) -> AddDirectoryResult:
        AddDirectoryResult(resultType: "notADirectory", directoryPath: directoryPath, absolutePath: absolutePath, workingDir: "")

    static fn alreadyInWorkingDirectory(directoryPath: text, workingDir: text) -> AddDirectoryResult:
        AddDirectoryResult(resultType: "alreadyInWorkingDirectory", directoryPath: directoryPath, absolutePath: "", workingDir: workingDir)

fn validateDirectoryForWorkspaceModel(directoryPath: text, pathExists: bool, isDirectory: bool, absolutePath: text, workingDirs: [text]) -> AddDirectoryResult:
    if directoryPath == "":
        return AddDirectoryResult.emptyPath()
    if not pathExists:
        return AddDirectoryResult.pathNotFound(directoryPath, absolutePath)
    if not isDirectory:
        return AddDirectoryResult.notADirectory(directoryPath, absolutePath)
    var i = 0
    while i < workingDirs.len():
        if pathInWorkingPathModel(absolutePath, workingDirs[i]):
            return AddDirectoryResult.alreadyInWorkingDirectory(directoryPath, workingDirs[i])
        i = i + 1
    AddDirectoryResult.success(absolutePath)

fn pathInWorkingPathModel(path: text, workingDir: text) -> bool:
    path == workingDir or path.starts_with(workingDir + "/")

fn addDirHelpMessage(result: AddDirectoryResult) -> text:
    if result.resultType == "emptyPath":
        return "Please provide a directory path."
    if result.resultType == "pathNotFound":
        return "Path " + result.absolutePath + " was not found."
    if result.resultType == "notADirectory":
        return result.directoryPath + " is not a directory. Did you mean to add the parent directory " + parentDirectoryModel(result.absolutePath) + "?"
    if result.resultType == "alreadyInWorkingDirectory":
        return result.directoryPath + " is already accessible within the existing working directory " + result.workingDir + "."
    "Added " + result.absolutePath + " as a working directory."

fn parentDirectoryModel(path: text) -> text:
    val parts = path.split("/")
    if parts.len() <= 1:
        return "/"
    var out = ""
    var i = 0
    while i < parts.len() - 1:
        if i > 0:
            out = out + "/"
        out = out + parts[i]
        i = i + 1
    if out == "":
        return "/"
    out

fn addDirValidationSourceLinesModeled() -> i64:
    110
