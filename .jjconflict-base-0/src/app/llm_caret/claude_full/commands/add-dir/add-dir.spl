class AddDirError:
    message: text

impl AddDirError:
    static fn new(message: text) -> AddDirError:
        AddDirError(message: message)

fn call(path: text, exists: bool, alreadyAdded: bool) -> text:
    handleAddDirectory(path, exists, alreadyAdded)

fn handleAddDirectory(path: text, exists: bool, alreadyAdded: bool) -> text:
    if path == "":
        return "error:missing-directory"
    if not exists:
        return "error:not-found:" + path
    if alreadyAdded:
        return "ok:already-added:" + path
    "ok:added:" + path

fn addDirSourceLinesModeled() -> i64:
    125
