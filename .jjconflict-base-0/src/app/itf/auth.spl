# ITF CLI — Authentication helpers
#
# Builds auth headers for Confluence REST v2 (Basic auth with API token)
# Delegates Jira auth to acli

use std.nogc_sync_mut.env.{env_get}
use std.common.encoding.base64.{base64_encode}
use app.itf.config.{ItfConfig, load_config, load_auth_token}
use app.itf.errors.{ItfError}


fn confluence_auth_header(config: ItfConfig) -> text:
    """Build Authorization header value for Confluence REST API.

    Confluence Cloud uses Basic auth: base64(email:api_token)
    """
    val token = load_auth_token("confluence")
    if token == "":
        return ""
    val user = config.confluence_user
    if user == "":
        return ""
    val credentials = "{user}:{token}"
    val encoded = base64_encode(credentials)
    "Basic {encoded}"


fn confluence_api_base(config: ItfConfig) -> text:
    """Get Confluence REST v2 API base URL."""
    val url = config.confluence_url
    if url == "":
        return ""
    # Ensure URL ends without trailing slash
    if url.ends_with("/"):
        return "{url}api/v2"
    "{url}/api/v2"


fn check_confluence_auth(config: ItfConfig) -> bool:
    """Check if Confluence auth is configured."""
    val token = load_auth_token("confluence")
    token != "" and config.confluence_user != "" and config.confluence_url != ""


fn check_jira_auth(config: ItfConfig) -> bool:
    """Check if Jira auth is configured (acli handles its own auth)."""
    config.jira_url != ""
