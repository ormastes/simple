# ITF CLI — Flag extraction helpers
#
# Matches the pattern from app.cli.query_helpers._extract_flag


fn _extract_flag(cmd_args: [text], flag_name: text, default_val: text) -> text:
    """Extract a flag value from args. E.g., --json fields -> "fields"."""
    var i = 0
    while i < cmd_args.len():
        if cmd_args[i] == flag_name and i + 1 < cmd_args.len():
            return cmd_args[i + 1]
        # Support --flag=value syntax
        if cmd_args[i].starts_with(flag_name + "="):
            return cmd_args[i].split("=", 2)[1]
        i = i + 1
    default_val


fn _has_flag(cmd_args: [text], flag_name: text) -> bool:
    """Check if a boolean flag is present. E.g., --yes, --json (no value)."""
    for arg in cmd_args:
        if arg == flag_name:
            return true
    false


fn _positional_args(cmd_args: [text]) -> [text]:
    """Extract positional arguments (skip flags and their values)."""
    var result: [text] = []
    var i = 0
    while i < cmd_args.len():
        val arg = cmd_args[i]
        if arg.starts_with("--"):
            # Skip flag + value pair (unless it's a boolean flag)
            if i + 1 < cmd_args.len() and not cmd_args[i + 1].starts_with("--"):
                i = i + 2
            else:
                i = i + 1
        else:
            result = result + [arg]
            i = i + 1
    result


fn _remove_flags(cmd_args: [text], flag_names: [text]) -> [text]:
    """Remove specified flags and their values from args."""
    var result: [text] = []
    var i = 0
    while i < cmd_args.len():
        val arg = cmd_args[i]
        var is_flag = false
        for name in flag_names:
            if arg == name:
                is_flag = true
            if arg.starts_with(name + "="):
                is_flag = true
        if is_flag:
            if not arg.contains("=") and i + 1 < cmd_args.len() and not cmd_args[i + 1].starts_with("--"):
                i = i + 2
            else:
                i = i + 1
        else:
            result = result + [arg]
            i = i + 1
    result
