use app.llm_runtime.manifest.{LlmRuntimeManifest}
use app.llm_runtime.serve_plan.{llm_runtime_static_serve_plan}
use app.llm_runtime.live_request_plan.{llm_runtime_vllm_models_request_plan}
use app.llm_runtime.serve_lifecycle.{LlmRuntimeServeLifecycleResult}
use app.llm_runtime.serve_lifecycle.{llm_runtime_start_vllm_serve, llm_runtime_vllm_serve_running_status, llm_runtime_stop_vllm_serve}
use app.llm_runtime.live_transport.{LlmRuntimeLiveTransportResult}
use app.llm_runtime.live_transport.{llm_runtime_fetch_vllm_models}
use app.llm_runtime.live_environment.{llm_runtime_vllm_live_environment_evidence}
use app.mcp.main_lazy_json.{LB, RB, jp, js}

pub class LlmRuntimeServeReadinessPolicy:
    max_attempts: i64
    poll_interval_ms: i64
    stop_on_timeout: bool
    stop_on_terminal_probe: bool
    require_process_running_before_probe: bool

pub class LlmRuntimeServeReadinessResult:
    status: text
    reason: text
    pid: i64
    running_status: text
    endpoint_status: text
    models_status: text
    models_reason: text
    http_status: i64
    command_preview: text
    evidence_jsonl: text

pub class LlmRuntimeServeReadinessRun:
    status: text
    reason: text
    pid: i64
    running_status: text
    endpoint_status: text
    models_status: text
    models_reason: text
    http_status: i64
    attempts: i64
    started_pid: i64
    stopped_pid: i64
    stopped_by_orchestrator: bool
    evidence_jsonl: text

pub fn llm_runtime_vllm_serve_readiness_default_policy() -> LlmRuntimeServeReadinessPolicy:
    LlmRuntimeServeReadinessPolicy(
        max_attempts: 3,
        poll_interval_ms: 0,
        stop_on_timeout: true,
        stop_on_terminal_probe: false,
        require_process_running_before_probe: true
    )

pub fn llm_runtime_vllm_serve_readiness_preflight(manifest: LlmRuntimeManifest) -> LlmRuntimeServeReadinessResult:
    val serve_plan = llm_runtime_static_serve_plan(manifest)
    if serve_plan.status != "planned":
        return _readiness_result("not_started", serve_plan.reason, -1, "not_started", "not_checked", "not_fetched", "serve_not_planned", 0, serve_plan.command_preview)
    val models_plan = llm_runtime_vllm_models_request_plan(manifest)
    if models_plan.status != "planned":
        return _readiness_result("not_ready", models_plan.reason, -1, "not_started", models_plan.endpoint_status, "not_fetched", "models_probe_not_planned", 0, serve_plan.command_preview)
    _readiness_result("planned", "serve_and_models_probe_planned", -1, "not_started", models_plan.endpoint_status, "not_fetched", "probe_not_run", 0, serve_plan.command_preview)

pub fn llm_runtime_vllm_serve_readiness_preflight_with_resources(manifest: LlmRuntimeManifest, vllm_available: bool, gpu_available: bool) -> LlmRuntimeServeReadinessResult:
    val environment = llm_runtime_vllm_live_environment_evidence(vllm_available, gpu_available, "")
    if environment.status == "skipped":
        return _readiness_result("skipped", environment.reason, -1, "not_started", "not_checked", "not_fetched", "environment_skipped", 0, "skipped")
    llm_runtime_vllm_serve_readiness_preflight(manifest)

pub fn llm_runtime_vllm_serve_readiness_from_observation(lifecycle: LlmRuntimeServeLifecycleResult, models: LlmRuntimeLiveTransportResult) -> LlmRuntimeServeReadinessResult:
    if lifecycle.status == "error":
        return _readiness_result("error", lifecycle.reason, lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)
    if lifecycle.status == "not_started":
        return _readiness_result("not_started", lifecycle.reason, lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)
    if lifecycle.running_status == "not_running":
        return _readiness_result("not_ready", "process_not_running", lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)
    if lifecycle.running_status != "running":
        return _readiness_result("not_ready", "process_state_unknown", lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)
    if models.status != "complete":
        return _readiness_result("not_ready", models.reason, lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)
    if models.response_status == "ready":
        return _readiness_result("ready", models.response_reason, lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)
    _readiness_result(models.response_status, models.response_reason, lifecycle.pid, lifecycle.running_status, models.endpoint_status, models.response_status, models.response_reason, models.http_status, lifecycle.command_preview)

pub fn llm_runtime_vllm_serve_readiness_orchestrate(manifest: LlmRuntimeManifest, policy: LlmRuntimeServeReadinessPolicy) -> LlmRuntimeServeReadinessRun:
    val preflight = llm_runtime_vllm_serve_readiness_preflight(manifest)
    if preflight.status != "planned":
        return _run_from_result(preflight, 0, -1, -1, false)
    val lifecycle = llm_runtime_start_vllm_serve(manifest)
    if lifecycle.status != "started":
        val observed = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", "spawn_failed"))
        return _run_from_result(observed, 0, lifecycle.pid, -1, false)
    var last = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", "probe_not_run"))
    var attempts: i64 = 0
    val max_attempts = _bounded_attempts(policy.max_attempts)
    while attempts < max_attempts:
        attempts = attempts + 1
        lifecycle.running_status = llm_runtime_vllm_serve_running_status(lifecycle.pid)
        if policy.require_process_running_before_probe and lifecycle.running_status != "running":
            last = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", "process_not_ready"))
        else:
            val models = llm_runtime_fetch_vllm_models(manifest)
            last = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, models)
        if _readiness_is_terminal(last, attempts, max_attempts):
            if policy.stop_on_terminal_probe and last.status != "ready":
                val stopped = llm_runtime_stop_vllm_serve(lifecycle.pid)
                return _run_from_result(last, attempts, lifecycle.pid, stopped.pid, stopped.status == "stopped")
            return _run_from_result(last, attempts, lifecycle.pid, -1, false)
    if policy.stop_on_timeout:
        val stopped = llm_runtime_stop_vllm_serve(lifecycle.pid)
        return _run_from_result(_timeout_result(last), attempts, lifecycle.pid, stopped.pid, stopped.status == "stopped")
    _run_from_result(_timeout_result(last), attempts, lifecycle.pid, -1, false)

pub fn llm_runtime_vllm_serve_readiness_orchestrate_with_resources(manifest: LlmRuntimeManifest, policy: LlmRuntimeServeReadinessPolicy, vllm_available: bool, gpu_available: bool) -> LlmRuntimeServeReadinessRun:
    val preflight = llm_runtime_vllm_serve_readiness_preflight_with_resources(manifest, vllm_available, gpu_available)
    if preflight.status != "planned":
        return _run_from_result(preflight, 0, -1, -1, false)
    llm_runtime_vllm_serve_readiness_orchestrate(manifest, policy)

pub fn llm_runtime_vllm_serve_readiness_from_sequences(manifest: LlmRuntimeManifest, lifecycle: LlmRuntimeServeLifecycleResult, running_status_plan: [text], models_plan: [LlmRuntimeLiveTransportResult], policy: LlmRuntimeServeReadinessPolicy) -> LlmRuntimeServeReadinessRun:
    val preflight = llm_runtime_vllm_serve_readiness_preflight(manifest)
    if preflight.status != "planned":
        return _run_from_result(preflight, 0, -1, -1, false)
    if lifecycle.status != "started":
        val observed = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", lifecycle.reason))
        return _run_from_result(observed, 0, lifecycle.pid, -1, false)
    var last = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", "probe_not_run"))
    var attempts: i64 = 0
    var model_index: i64 = 0
    val max_attempts = _bounded_attempts(policy.max_attempts)
    while attempts < max_attempts:
        attempts = attempts + 1
        lifecycle.running_status = _planned_running_status(running_status_plan, attempts)
        if policy.require_process_running_before_probe and lifecycle.running_status != "running":
            last = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, _not_fetched_models("not_fetched", "process_not_ready"))
        else:
            val models = _planned_models(models_plan, model_index)
            model_index = model_index + 1
            last = llm_runtime_vllm_serve_readiness_from_observation(lifecycle, models)
        if _readiness_is_terminal(last, attempts, max_attempts):
            if policy.stop_on_terminal_probe and last.status != "ready" and lifecycle.pid > 0:
                return _run_from_result(last, attempts, lifecycle.pid, lifecycle.pid, true)
            return _run_from_result(last, attempts, lifecycle.pid, -1, false)
    if policy.stop_on_timeout and lifecycle.pid > 0:
        return _run_from_result(_timeout_result(last), attempts, lifecycle.pid, lifecycle.pid, true)
    _run_from_result(_timeout_result(last), attempts, lifecycle.pid, -1, false)

pub fn llm_runtime_vllm_serve_readiness_jsonl_event(result: LlmRuntimeServeReadinessResult) -> text:
    LB() +
    jp("event", js("llm_runtime_vllm_serve_readiness")) +
    "," + jp("status", js(result.status)) +
    "," + jp("reason", js(result.reason)) +
    "," + jp("pid", str(result.pid)) +
    "," + jp("running", js(result.running_status)) +
    "," + jp("endpoint", js(result.endpoint_status)) +
    "," + jp("models_status", js(result.models_status)) +
    "," + jp("models_reason", js(result.models_reason)) +
    "," + jp("http_status", str(result.http_status)) +
    "," + jp("command_preview", js(result.command_preview)) +
    RB() + "\n"

pub fn llm_runtime_vllm_serve_readiness_run_jsonl_event(result: LlmRuntimeServeReadinessRun) -> text:
    LB() +
    jp("event", js("llm_runtime_vllm_serve_readiness_run")) +
    "," + jp("status", js(result.status)) +
    "," + jp("reason", js(result.reason)) +
    "," + jp("pid", str(result.pid)) +
    "," + jp("running", js(result.running_status)) +
    "," + jp("endpoint", js(result.endpoint_status)) +
    "," + jp("models_status", js(result.models_status)) +
    "," + jp("models_reason", js(result.models_reason)) +
    "," + jp("http_status", str(result.http_status)) +
    "," + jp("attempts", str(result.attempts)) +
    "," + jp("started_pid", str(result.started_pid)) +
    "," + jp("stopped_pid", str(result.stopped_pid)) +
    "," + jp("stopped_by_orchestrator", js(_bool_text(result.stopped_by_orchestrator))) +
    RB() + "\n"

fn _readiness_result(status: text, reason: text, pid: i64, running_status: text, endpoint_status: text, models_status: text, models_reason: text, http_status: i64, command_preview: text) -> LlmRuntimeServeReadinessResult:
    val result = LlmRuntimeServeReadinessResult(
        status: status,
        reason: reason,
        pid: pid,
        running_status: running_status,
        endpoint_status: endpoint_status,
        models_status: models_status,
        models_reason: models_reason,
        http_status: http_status,
        command_preview: command_preview,
        evidence_jsonl: ""
    )
    result.evidence_jsonl = llm_runtime_vllm_serve_readiness_jsonl_event(result)
    result

fn _run_from_result(result: LlmRuntimeServeReadinessResult, attempts: i64, started_pid: i64, stopped_pid: i64, stopped_by_orchestrator: bool) -> LlmRuntimeServeReadinessRun:
    val run = LlmRuntimeServeReadinessRun(
        status: result.status,
        reason: result.reason,
        pid: result.pid,
        running_status: result.running_status,
        endpoint_status: result.endpoint_status,
        models_status: result.models_status,
        models_reason: result.models_reason,
        http_status: result.http_status,
        attempts: attempts,
        started_pid: started_pid,
        stopped_pid: stopped_pid,
        stopped_by_orchestrator: stopped_by_orchestrator,
        evidence_jsonl: ""
    )
    run.evidence_jsonl = llm_runtime_vllm_serve_readiness_run_jsonl_event(run)
    run

fn _timeout_result(result: LlmRuntimeServeReadinessResult) -> LlmRuntimeServeReadinessResult:
    _readiness_result("not_ready", "readiness_timeout", result.pid, result.running_status, result.endpoint_status, result.models_status, result.models_reason, result.http_status, result.command_preview)

fn _readiness_is_terminal(result: LlmRuntimeServeReadinessResult, attempts: i64, max_attempts: i64) -> bool:
    if result.status == "ready" or result.status == "error" or result.status == "blocked" or result.status == "skipped":
        return true
    if result.reason == "auth_rejected" or result.reason == "malformed_models_response":
        return true
    false

fn _bounded_attempts(value: i64) -> i64:
    if value <= 0:
        return 1
    value

fn _planned_running_status(plan: [text], attempts: i64) -> text:
    val index = attempts - 1
    if index >= 0 and index < plan.len():
        return plan[index]
    "unknown_until_polled"

fn _planned_models(plan: [LlmRuntimeLiveTransportResult], index: i64) -> LlmRuntimeLiveTransportResult:
    if index >= 0 and index < plan.len():
        return plan[index]
    _not_fetched_models("not_fetched", "models_probe_not_observed")

fn _not_fetched_models(status: text, reason: text) -> LlmRuntimeLiveTransportResult:
    LlmRuntimeLiveTransportResult(
        status: status,
        reason: reason,
        endpoint_status: "not_checked",
        method: "GET",
        path: "/models",
        http_status: 0,
        response_status: "not_fetched",
        response_reason: reason,
        body_status: "empty",
        evidence_jsonl: ""
    )

fn _bool_text(value: bool) -> text:
    if value:
        return "true"
    "false"

export LlmRuntimeServeReadinessPolicy, LlmRuntimeServeReadinessResult, LlmRuntimeServeReadinessRun
export llm_runtime_vllm_serve_readiness_default_policy, llm_runtime_vllm_serve_readiness_preflight, llm_runtime_vllm_serve_readiness_preflight_with_resources, llm_runtime_vllm_serve_readiness_from_observation, llm_runtime_vllm_serve_readiness_orchestrate, llm_runtime_vllm_serve_readiness_orchestrate_with_resources, llm_runtime_vllm_serve_readiness_from_sequences, llm_runtime_vllm_serve_readiness_jsonl_event, llm_runtime_vllm_serve_readiness_run_jsonl_event
