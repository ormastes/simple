# Simple CLI - env command
# Virtual environment management

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use app.io.mod (file_exists, file_read, file_write, dir_create, cwd, env_get, dir_remove_all, is_dir)
use std.db_atomic.{atomic_write, DbConfig}
use std.log.{error}

fn print_help():
    print "Usage: simple env <subcommand>"
    print ""
    print "Manage Simple virtual environments."
    print ""
    print "Subcommands:"
    print "  create         Create a new virtual environment"
    print "  activate       Show activation instructions"
    print "  deactivate     Show deactivation instructions"
    print "  status         Show current environment status"
    print "  delete         Delete the virtual environment"
    print ""
    print "Options:"
    print "  --json        Output as JSON"
    print "  --name=<name>  Environment name (default: .simple-env)"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help     Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _json_escape(value: text) -> text:
    val slashes = value.replace("\\", "\\\\")
    val quotes = slashes.replace("\"", "\\\"")
    quotes.replace("\n", "\\n")

fn get_env_dir(name: text) -> text:
    val cwd = cwd()
    "{cwd}/{name}"

fn handle_create(env_name: text, as_json: bool) -> i64:
    val env_dir = get_env_dir(env_name)

    if is_dir(env_dir):
        error("env", "environment '{env_name}' already exists")
        return 1

    if not dir_create(env_dir, true):
        error("env", "failed to create environment directory")
        return 1

    dir_create("{env_dir}/lib", true)
    dir_create("{env_dir}/bin", true)
    dir_create("{env_dir}/simple_modules", true)

    val config = "# Simple Virtual Environment\nname: {env_name}\ncreated: 2026-02-03\n"
    val config_result = atomic_write("{env_dir}/env.sdn", config, DbConfig.defaults())
    match config_result:
        Ok(_): ()
        Err(message):
            error("env", "failed to write env.sdn: {message}")
            return 1

    val activate = "# Source this file to activate the environment\n# Usage: source {env_name}/activate.sh\nexport SIMPLE_ENV=\"{env_dir}\"\nexport OLD_PATH=\"$PATH\"\nexport PATH=\"{env_dir}/bin:$PATH\"\nexport SIMPLE_MODULES=\"{env_dir}/simple_modules\"\n"
    file_write("{env_dir}/activate.sh", activate)

    val deactivate = "# Source this file to deactivate the environment\nexport PATH=\"$OLD_PATH\"\nunset SIMPLE_ENV\nunset OLD_PATH\nunset SIMPLE_MODULES\n"
    file_write("{env_dir}/deactivate.sh", deactivate)

    if as_json:
        val name_json = _json_escape(env_name)
        val dir_json = _json_escape(env_dir)
        print "{\"command\":\"create\",\"status\":\"ok\",\"name\":\"{name_json}\",\"path\":\"{dir_json}\"}"
    else:
        print "Created virtual environment '{env_name}'"
        print ""
        print "To activate:"
        print "  source {env_name}/activate.sh"
    0

fn handle_activate(env_name: text, as_json: bool) -> i64:
    val env_dir = get_env_dir(env_name)
    if not is_dir(env_dir):
        error("env", "environment '{env_name}' does not exist")
        print "Run 'simple env create' first."
        return 1

    if as_json:
        val name_json = _json_escape(env_name)
        val dir_json = _json_escape(env_dir)
        print "{\"command\":\"activate\",\"status\":\"ok\",\"name\":\"{name_json}\",\"path\":\"{dir_json}\",\"script\":\"{name_json}/activate.sh\"}"
    else:
        print "To activate the environment:"
        print "  source {env_name}/activate.sh"
        print ""
        print "To deactivate:"
        print "  source {env_name}/deactivate.sh"
    0

fn handle_status(env_name: text, as_json: bool) -> i64:
    val active = env_get("SIMPLE_ENV")
    if active != nil and active != "":
        if as_json:
            val active_json = _json_escape(active)
            print "{\"command\":\"status\",\"status\":\"ok\",\"active\":true,\"path\":\"{active_json}\"}"
            return 0
        print "Active environment: {active}"
    else:
        val env_dir = get_env_dir(env_name)
        if is_dir(env_dir):
            if as_json:
                val name_json = _json_escape(env_name)
                val dir_json = _json_escape(env_dir)
                print "{\"command\":\"status\",\"status\":\"ok\",\"active\":false,\"exists\":true,\"name\":\"{name_json}\",\"path\":\"{dir_json}\"}"
                return 0
            print "Environment '{env_name}' exists but is not active."
            print "Run 'source {env_name}/activate.sh' to activate."
        else:
            if as_json:
                val name_json = _json_escape(env_name)
                print "{\"command\":\"status\",\"status\":\"ok\",\"active\":false,\"exists\":false,\"name\":\"{name_json}\"}"
                return 0
            print "No virtual environment found."
            print "Run 'simple env create' to create one."
    0

fn handle_delete(env_name: text, as_json: bool) -> i64:
    val env_dir = get_env_dir(env_name)
    if not is_dir(env_dir):
        error("env", "environment '{env_name}' does not exist")
        return 1

    val result = dir_remove_all(env_dir)
    if result != 0:
        error("env", "failed to delete environment")
        return 1

    if as_json:
        val name_json = _json_escape(env_name)
        print "{\"command\":\"delete\",\"status\":\"ok\",\"name\":\"{name_json}\"}"
    else:
        print "Deleted virtual environment '{env_name}'"
    0

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("env", log_opts.error)
        return 1

    if args.len() == 0:
        print_help()
        return 0

    var env_name = ".simple-env"
    var subcommand = ""
    var as_json = log_opts.log_mode == "json"

    var ai = 0
    while ai < args.len():
        val arg = args[ai]
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
        elif arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg.starts_with("--name="):
            env_name = arg[7:]
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        elif not arg.starts_with("-"):
            if subcommand == "":
                subcommand = arg
        ai = ai + 1

    if log_opts.progress != "summary":
        val label = if subcommand != "": "env {subcommand}" else: "env"
        val progress_line = render_progress(log_opts.progress, 1, 1, label)
        if progress_line != "":
            print progress_line

    match subcommand:
        case "create":
            return handle_create(env_name, as_json)
        case "activate":
            return handle_activate(env_name, as_json)
        case "deactivate":
            if as_json:
                val name_json = _json_escape(env_name)
                print "{\"command\":\"deactivate\",\"status\":\"ok\",\"name\":\"{name_json}\",\"script\":\"{name_json}/deactivate.sh\"}"
            else:
                print "To deactivate:"
                print "  source {env_name}/deactivate.sh"
            return 0
        case "status":
            return handle_status(env_name, as_json)
        case "delete":
            return handle_delete(env_name, as_json)
        case _:
            error("env", "unknown subcommand '{subcommand}'")
            print ""
            print_help()
            return 1
