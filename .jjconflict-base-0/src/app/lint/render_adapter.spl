#![allow(unnamed_duplicate_typed_args)]
# Lint Render Adapter
#
# Bridges lint output (warnings/errors with file:line:col and severity)
# to the shared ui.render contract.  Produces text (colored terminal)
# and html (grouped-by-file report with badges and tables).

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{html_page, html_card, html_badge, html_table,
    html_section, css_reset, css_dark_theme, css_light_theme, html_escape}
use app.ui.render.fmt.{fmt_number, pad_right}
use app.ui.render.ansi.{RESET, BOLD, DIM, RED, YELLOW, GREEN, CYAN, colorize}
use app.build.quality.{QualityResult}

# =========================================================================
# Data Types
# =========================================================================

struct LintIssue:
    file: text
    line: i64
    col: i64
    severity: text
    message: text

struct LintReport:
    issues: [LintIssue]
    total_warnings: i64
    total_errors: i64

# =========================================================================
# Parsing
# =========================================================================

fn parse_lint_output(result: QualityResult) -> LintReport:
    """Parse clippy/lint output into structured issues."""
    var issues: [LintIssue] = []
    var warnings = result.warnings
    var errors = result.errors

    val combined = "{result.stdout}\n{result.stderr}"
    val lines = combined.split("\n")
    for line in lines:
        if line.contains("warning:") and not line.contains("warnings emitted"):
            issues.push(LintIssue(
                file: extract_file_loc(line),
                line: 0,
                col: 0,
                severity: "warning",
                message: extract_message(line, "warning:")
            ))
        elif line.contains("error:") and not line.contains("aborting"):
            issues.push(LintIssue(
                file: extract_file_loc(line),
                line: 0,
                col: 0,
                severity: "error",
                message: extract_message(line, "error:")
            ))

    LintReport(issues: issues, total_warnings: warnings, total_errors: errors)

fn extract_file_loc(line: text) -> text:
    """Extract file location from a lint line."""
    val trimmed = line.trim()
    if trimmed.contains("-->"):
        val parts = trimmed.split("-->")
        if parts.len() > 1:
            return parts[1].trim()
    ""

fn extract_message(line: text, prefix: text) -> text:
    """Extract message after severity prefix."""
    val idx = line.find(prefix)
    if idx >= 0:
        return line.slice(idx + prefix.len()).trim()
    line.trim()

# =========================================================================
# Render Entry Point
# =========================================================================

fn render_lint(config: RenderConfig, result: QualityResult) -> RenderResult:
    """Render lint results via the shared render contract."""
    val report = parse_lint_output(result)

    match config.format:
        "html":
            return render_lint_html(report, config)
        "both":
            val text_out = render_lint_text(report, config)
            val html_out = render_lint_html(report, config)
            return RenderResult.both(text_out.text_output, html_out.html_output)
        _:
            return render_lint_text(report, config)

# =========================================================================
# Text Rendering
# =========================================================================

fn render_lint_text(report: LintReport, config: RenderConfig) -> RenderResult:
    """Render lint report as colored terminal text."""
    var lines: [text] = []

    lines.push("{BOLD}Lint Report{RESET}")
    lines.push("")

    if report.issues.len() == 0:
        lines.push("{GREEN}No issues found.{RESET}")
    else:
        for issue in report.issues:
            val sev_color = if issue.severity == "error": RED else: YELLOW
            val sev_label = colorize(issue.severity, sev_color)
            var loc = ""
            if issue.file != "":
                loc = "{DIM}{issue.file}{RESET} "
            lines.push("  {sev_label}  {loc}{issue.message}")

    lines.push("")
    val warn_str = colorize("{report.total_warnings} warnings", YELLOW)
    val err_str = colorize("{report.total_errors} errors", RED)
    lines.push("Summary: {warn_str}, {err_str}")

    var text_out = ""
    var first = true
    for line in lines:
        if not first:
            text_out = "{text_out}\n"
        text_out = "{text_out}{line}"
        first = false

    RenderResult.text(text_out)

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_lint_html(report: LintReport, config: RenderConfig) -> RenderResult:
    """Render lint report as HTML with grouped issues per file."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val css = "{css_reset()}\n{theme_css}\n{lint_css()}"

    var body = "<h1>Lint Report</h1>\n"

    # Summary badges
    val warn_badge = html_badge("{report.total_warnings} warnings", "#d29922")
    val err_badge = html_badge("{report.total_errors} errors", "#f85149")
    val status_badge = if report.total_errors == 0 and report.total_warnings == 0:
        html_badge("PASS", "#3fb950")
    elif report.total_errors > 0:
        html_badge("FAIL", "#f85149")
    else:
        html_badge("WARN", "#d29922")
    body = "{body}<div style=\"margin-bottom:16px\">{status_badge} {warn_badge} {err_badge}</div>\n"

    if report.issues.len() == 0:
        body = "{body}<p style=\"color:var(--green, #3fb950)\">No issues found.</p>\n"
    else:
        # Group issues by file
        var file_groups: Dict<text, [LintIssue]> = {}
        for issue in report.issues:
            val key = if issue.file != "": issue.file else: "(unknown)"
            if not file_groups.contains(key):
                file_groups[key] = []
            var group = file_groups[key]
            group.push(issue)
            file_groups[key] = group

        for file_key in file_groups.keys():
            val file_issues = file_groups[file_key]
            var rows: [[text]] = []
            for issue in file_issues:
                val sev_html = if issue.severity == "error":
                    "<span style=\"color:#f85149\">error</span>"
                else:
                    "<span style=\"color:#d29922\">warning</span>"
                rows.push([sev_html, issue.message])

            val table_html = html_table(["Severity", "Message"], rows)
            body = "{body}{html_card(file_key, table_html)}\n"

    RenderResult.html(html_page("Lint Report", css, body))

fn lint_css() -> text:
    """Additional CSS for lint report cards."""
    var s = ""
    s = "{s}.card { background:var(--bg-card); border:1px solid var(--border); border-radius:8px; padding:16px; margin-bottom:12px; }\n"
    s = "{s}.card h3 { font-size:14px; margin-bottom:8px; color:var(--blue, #58a6ff); font-family:monospace; }\n"
    s = "{s}table { width:100%; }\n"
    s = "{s}th { text-align:left; padding:4px 8px; border-bottom:1px solid var(--border); color:var(--text-dim); font-size:12px; }\n"
    s = "{s}td { padding:4px 8px; font-size:13px; }\n"
    s
