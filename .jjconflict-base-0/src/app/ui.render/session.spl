# UI Render Session Layer
#
# Session management for render operations.  A RenderSession bundles the
# resolved config with per-invocation state (timing, output buffering,
# warnings).

use app.ui.render.types.{RenderConfig, RenderResult}

extern fn rt_time_now_unix_micros() -> i64

# =========================================================================
# RenderSession
# =========================================================================

class RenderSession:
    """Holds config, timing, and output state for one render invocation."""
    config: RenderConfig
    start_time_us: i64
    output_buffer: text
    warnings: [text]

    fn elapsed_ms() -> i64:
        """Microseconds elapsed since session creation, converted to ms."""
        val now = rt_time_now_unix_micros()
        return (now - self.start_time_us) / 1000

    me append_output(chunk: text):
        """Append text to the output buffer."""
        self.output_buffer = self.output_buffer + chunk

    me add_warning(msg: text):
        """Record a non-fatal warning."""
        self.warnings = self.warnings + [msg]

    fn to_result(text_out: text, html_out: text) -> RenderResult:
        """Build a RenderResult from session state plus final outputs."""
        return RenderResult(
            format: self.config.format,
            text_output: text_out,
            html_output: html_out,
            metadata: {"elapsed_ms": "{self.elapsed_ms()}"},
            warnings: self.warnings
        )

# =========================================================================
# Factory
# =========================================================================

fn create_session(config: RenderConfig) -> RenderSession:
    """Create a new RenderSession from a resolved config."""
    return RenderSession(
        config: config,
        start_time_us: rt_time_now_unix_micros(),
        output_buffer: "",
        warnings: []
    )
