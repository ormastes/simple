# HTML Builder Utilities
#
# Reusable HTML building blocks for page scaffolds, layout containers,
# cards, badges, tables, and common patterns. Eliminates duplicated
# inline HTML across dashboard, llm_dashboard, and office apps.

# =========================================================================
# HTML Escaping
# =========================================================================

fn html_escape(s: text) -> text:
    """Escape HTML special characters."""
    var out = s
    out = out.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out = out.replace("'", "&#39;")
    return out

# =========================================================================
# CSS Color Variables
# =========================================================================

fn css_color_var(name: text) -> text:
    """Generate a CSS variable reference with fallback."""
    match name:
        "green" => "var(--green, #3fb950)"
        "red" => "var(--red, #f85149)"
        "yellow" => "var(--yellow, #d29922)"
        "blue" => "var(--blue, #58a6ff)"
        "gray" => "var(--gray, #8b949e)"
        "white" => "var(--white, #c9d1d9)"
        "bg" => "var(--bg, #0d1117)"
        "bg-card" => "var(--bg-card, #161b22)"
        "border" => "var(--border, #30363d)"
        _ => "var(--{name})"

# =========================================================================
# Page Scaffold
# =========================================================================

fn html_page(title: text, css: text, body: text) -> text:
    """Generate a complete HTML page with CSS and body content."""
    var h = ""
    h = "{h}<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n"
    h = "{h}  <meta charset=\"utf-8\">\n"
    h = "{h}  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
    h = "{h}  <title>{html_escape(title)}</title>\n"
    h = "{h}  <style>\n{css}\n  </style>\n"
    h = "{h}</head>\n<body>\n{body}\n</body>\n</html>\n"
    return h

fn html_page_with_js(title: text, css: text, body: text, js: text) -> text:
    """Generate a complete HTML page with CSS, body, and JavaScript."""
    var h = ""
    h = "{h}<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n"
    h = "{h}  <meta charset=\"utf-8\">\n"
    h = "{h}  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
    h = "{h}  <title>{html_escape(title)}</title>\n"
    h = "{h}  <style>\n{css}\n  </style>\n"
    h = "{h}</head>\n<body>\n{body}\n"
    h = "{h}<script>\n{js}\n</script>\n"
    h = "{h}</body>\n</html>\n"
    return h

# =========================================================================
# CSS Reset and Themes
# =========================================================================

fn css_reset() -> text:
    """Minimal CSS reset for consistent rendering."""
    var s = ""
    s = "{s}* { margin: 0; padding: 0; box-sizing: border-box; }\n"
    s = "{s}body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif; }\n"
    s = "{s}img { max-width: 100%; height: auto; }\n"
    s = "{s}table { border-collapse: collapse; }\n"
    return s

fn css_dark_theme() -> text:
    """Dark theme CSS variables and body styles."""
    var s = ""
    s = "{s}:root {\n"
    s = "{s}  --bg: #0d1117;\n"
    s = "{s}  --bg-card: #161b22;\n"
    s = "{s}  --bg-card-hover: #1c2128;\n"
    s = "{s}  --text: #c9d1d9;\n"
    s = "{s}  --text-dim: #8b949e;\n"
    s = "{s}  --border: #30363d;\n"
    s = "{s}  --green: #3fb950;\n"
    s = "{s}  --red: #f85149;\n"
    s = "{s}  --yellow: #d29922;\n"
    s = "{s}  --blue: #58a6ff;\n"
    s = "{s}  --white: #c9d1d9;\n"
    s = "{s}  --gray: #8b949e;\n"
    s = "{s}}\n"
    s = "{s}body {\n"
    s = "{s}  background: var(--bg);\n"
    s = "{s}  color: var(--text);\n"
    s = "{s}  min-height: 100vh;\n"
    s = "{s}  padding: 20px;\n"
    s = "{s}}\n"
    return s

fn css_light_theme() -> text:
    """Light theme CSS variables and body styles."""
    var s = ""
    s = "{s}:root {\n"
    s = "{s}  --bg: #ffffff;\n"
    s = "{s}  --bg-card: #f6f8fa;\n"
    s = "{s}  --bg-card-hover: #eef1f5;\n"
    s = "{s}  --text: #24292f;\n"
    s = "{s}  --text-dim: #57606a;\n"
    s = "{s}  --border: #d0d7de;\n"
    s = "{s}  --green: #1a7f37;\n"
    s = "{s}  --red: #cf222e;\n"
    s = "{s}  --yellow: #9a6700;\n"
    s = "{s}  --blue: #0969da;\n"
    s = "{s}  --white: #24292f;\n"
    s = "{s}  --gray: #57606a;\n"
    s = "{s}}\n"
    s = "{s}body {\n"
    s = "{s}  background: var(--bg);\n"
    s = "{s}  color: var(--text);\n"
    s = "{s}  min-height: 100vh;\n"
    s = "{s}  padding: 20px;\n"
    s = "{s}}\n"
    return s

# =========================================================================
# Layout Containers
# =========================================================================

fn html_grid(columns: i32, gap: text, items: [text]) -> text:
    """Render items in a CSS grid with the given column count and gap."""
    var h = "<div style=\"display:grid; grid-template-columns:repeat({columns}, 1fr); gap:{gap}\">\n"
    for item in items:
        h = "{h}  {item}\n"
    h = "{h}</div>\n"
    return h

fn html_flex_row(items: [text], gap: text) -> text:
    """Render items in a horizontal flex row."""
    var h = "<div style=\"display:flex; flex-direction:row; gap:{gap}; align-items:center\">\n"
    for item in items:
        h = "{h}  {item}\n"
    h = "{h}</div>\n"
    return h

fn html_flex_col(items: [text], gap: text) -> text:
    """Render items in a vertical flex column."""
    var h = "<div style=\"display:flex; flex-direction:column; gap:{gap}\">\n"
    for item in items:
        h = "{h}  {item}\n"
    h = "{h}</div>\n"
    return h

fn html_section(title: text, content: text) -> text:
    """Render a titled section with a heading and content."""
    var h = "<section style=\"margin-bottom:16px\">\n"
    h = "{h}  <h2 style=\"font-size:16px; margin-bottom:8px; color:var(--text-dim, #8b949e)\">{html_escape(title)}</h2>\n"
    h = "{h}  {content}\n"
    h = "{h}</section>\n"
    return h

# =========================================================================
# Cards
# =========================================================================

fn html_card(title: text, body: text) -> text:
    """Render a card with title and body."""
    var h = "<div class=\"card\">\n"
    h = "{h}  <h3>{html_escape(title)}</h3>\n"
    h = "{h}  <div class=\"card-body\">{body}</div>\n"
    h = "{h}</div>\n"
    return h

fn html_card_with_status(title: text, body: text, status: text) -> text:
    """Render a card with a status indicator dot in the header."""
    val dot = html_status_dot(status)
    var h = "<div class=\"card\">\n"
    h = "{h}  <div class=\"card-header\">{dot} <h3 style=\"display:inline\">{html_escape(title)}</h3></div>\n"
    h = "{h}  <div class=\"card-body\">{body}</div>\n"
    h = "{h}</div>\n"
    return h

fn html_metric_card(label: text, value: text, trend: text) -> text:
    """Render a compact metric card with label, large value, and trend subtitle."""
    var trend_html = ""
    if trend != "":
        trend_html = "<div class=\"sub\">{html_escape(trend)}</div>"
    var h = "<div class=\"card\">\n"
    h = "{h}  <h3>{html_escape(label)}</h3>\n"
    h = "{h}  <div class=\"value\">{html_escape(value)}</div>\n"
    h = "{h}  {trend_html}\n"
    h = "{h}</div>\n"
    return h

# =========================================================================
# Badges and Indicators
# =========================================================================

fn html_badge(label: text, color: text) -> text:
    """Render an inline badge/pill with the given background color."""
    return "<span class=\"badge\" style=\"background:{color}; color:#fff; padding:2px 8px; border-radius:12px; font-size:12px; font-weight:500\">{html_escape(label)}</span>"

fn html_status_dot(status: text) -> text:
    """Render a colored status dot based on status string."""
    val color = match status:
        "ok" => css_color_var("green")
        "success" => css_color_var("green")
        "passed" => css_color_var("green")
        "complete" => css_color_var("green")
        "warning" => css_color_var("yellow")
        "in_progress" => css_color_var("yellow")
        "error" => css_color_var("red")
        "failed" => css_color_var("red")
        "blocked" => css_color_var("red")
        "critical" => css_color_var("red")
        _ => css_color_var("gray")
    return "<span style=\"display:inline-block; width:8px; height:8px; border-radius:50%; background:{color}; margin-right:6px\"></span>"

fn html_progress_bar(percent: i64) -> text:
    """Render a horizontal progress bar (0-100)."""
    val clamped = if percent < 0: 0 elif percent > 100: 100 else: percent
    val bar_color = if clamped >= 80: css_color_var("green") elif clamped >= 50: css_color_var("yellow") else: css_color_var("red")
    var h = "<div style=\"background:var(--border, #30363d); border-radius:4px; height:8px; overflow:hidden; width:100%\">"
    h = "{h}<div style=\"background:{bar_color}; height:100%; width:{clamped}%; transition:width 0.3s\"></div>"
    h = "{h}</div>"
    return h

# =========================================================================
# Tables
# =========================================================================

fn html_table(headers: [text], rows: [[text]]) -> text:
    """Render an HTML table with headers and rows."""
    var h = "<table>\n<thead><tr>\n"
    for hdr in headers:
        h = "{h}  <th>{html_escape(hdr)}</th>\n"
    h = "{h}</tr></thead>\n<tbody>\n"
    for row in rows:
        h = "{h}<tr>\n"
        for cell in row:
            h = "{h}  <td>{html_escape(cell)}</td>\n"
        h = "{h}</tr>\n"
    h = "{h}</tbody>\n</table>\n"
    return h

fn html_kv_table(pairs: [(text, text)]) -> text:
    """Render a two-column key-value table."""
    var h = "<table>\n<tbody>\n"
    for pair in pairs:
        val key = pair.0
        val val_text = pair.1
        h = "{h}<tr><td style=\"font-weight:600; padding-right:16px\">{html_escape(key)}</td><td>{html_escape(val_text)}</td></tr>\n"
    h = "{h}</tbody>\n</table>\n"
    return h
