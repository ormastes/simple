# Text Formatting Utilities
#
# Shared helpers for number formatting, size/count display, time durations,
# text manipulation, and list rendering. Consolidates duplicated formatters
# from sheets/render, llm_dashboard/types, and dashboard.render/table.

# =========================================================================
# Internal Helpers
# =========================================================================

fn _truncate_to_i64(value: f64) -> i64:
    """Convert f64 to i64 by truncation toward zero."""
    val truncated: i64 = value
    truncated

fn _round_to_int(value: f64) -> i64:
    """Round a float to the nearest integer."""
    if value >= 0.0:
        return _truncate_to_i64(value + 0.5)
    _truncate_to_i64(value - 0.5)

fn _pow10(exp: i32) -> f64:
    """Calculate 10^exp for small non-negative exponents."""
    var result = 1.0
    var i = 0
    while i < exp:
        result = result * 10.0
        i = i + 1
    result

fn _pow10_i64(exp: i32) -> i64:
    """Calculate 10^exp as i64 for small non-negative exponents."""
    var result = 1
    var i = 0
    while i < exp:
        result = result * 10
        i = i + 1
    result

fn _insert_commas(int_str: text) -> text:
    """Insert comma separators into an integer string every 3 digits from the right."""
    var start = 0
    var negative = false
    if int_str.len() > 0 and int_str.char_at(0) == "-":
        negative = true
        start = 1
    val digits = if negative: int_str.slice(1) else: int_str
    val len = digits.len()
    if len <= 3:
        return int_str
    var result = ""
    var i = 0
    while i < len:
        val pos_from_right = len - i
        if pos_from_right % 3 == 0 and i > 0:
            result = "{result},"
        result = "{result}{digits.char_at(i)}"
        i = i + 1
    if negative:
        return "-{result}"
    result

fn _format_decimal(value: f64, places: i32) -> text:
    """Format a float with the specified number of decimal places (no commas)."""
    if places <= 0:
        val rounded = _round_to_int(value)
        return "{rounded}"
    val factor = _pow10(places)
    val factor_i = _pow10_i64(places)
    val shifted = value * factor
    val rounded_i = _round_to_int(shifted)
    val int_part = rounded_i / factor_i
    var frac_abs = rounded_i - (int_part * factor_i)
    if frac_abs < 0:
        frac_abs = 0 - frac_abs
    var frac_str = "{frac_abs}"
    while frac_str.len() < places:
        frac_str = "0{frac_str}"
    "{int_part}.{frac_str}"

fn _repeat_char(ch: text, count: i32) -> text:
    """Repeat a single character count times."""
    var result = ""
    var i = 0
    while i < count:
        result = "{result}{ch}"
        i = i + 1
    result

fn _abs_i64(n: i64) -> i64:
    if n < 0:
        return 0 - n
    n

# =========================================================================
# Number Formatting
# =========================================================================

fn fmt_number(n: i64) -> text:
    """Format an integer with comma separators. Example: 1234567 -> \"1,234,567\"."""
    _insert_commas("{n}")

fn fmt_decimal(n: f64, places: i32) -> text:
    """Format a float with comma separators and fixed decimal places.
    Example: fmt_decimal(1234.5, 2) -> \"1,234.50\"."""
    val base = _format_decimal(n, places)
    if base.contains("."):
        val parts = base.split(".")
        val int_str = parts[0]
        val dec_str = parts[1]
        val with_commas = _insert_commas(int_str)
        return "{with_commas}.{dec_str}"
    _insert_commas(base)

fn fmt_currency(n: f64, symbol: text) -> text:
    """Format a number as currency with 2 decimal places.
    Example: fmt_currency(1234.56, \"$\") -> \"$1,234.56\"."""
    if n < 0.0:
        val abs_val = 0.0 - n
        val formatted = fmt_decimal(abs_val, 2)
        return "-{symbol}{formatted}"
    val formatted = fmt_decimal(n, 2)
    "{symbol}{formatted}"

fn fmt_percent(n: f64) -> text:
    """Format a number as a percentage with one decimal place.
    The input is already in percentage form (73.2 -> \"73.2%\")."""
    val formatted = _format_decimal(n, 1)
    "{formatted}%"

fn fmt_fraction(current: i64, total: i64) -> text:
    """Format two numbers as a fraction. Example: fmt_fraction(3, 10) -> \"3/10\"."""
    "{current}/{total}"

# =========================================================================
# Size / Count Formatting
# =========================================================================

fn fmt_bytes(n: i64) -> text:
    """Format a byte count with human-readable suffix.
    Examples: 1536 -> \"1.5 KB\", 1572864 -> \"1.5 MB\", 1610612736 -> \"1.5 GB\"."""
    if n < 0:
        return "{n} B"
    if n < 1024:
        return "{n} B"
    if n < 1048576:
        # KB range
        val kb_10 = (n * 10) / 1024
        val whole = kb_10 / 10
        val frac = kb_10 % 10
        if frac == 0:
            return "{whole} KB"
        return "{whole}.{frac} KB"
    if n < 1073741824:
        # MB range
        val mb_10 = (n * 10) / 1048576
        val whole = mb_10 / 10
        val frac = mb_10 % 10
        if frac == 0:
            return "{whole} MB"
        return "{whole}.{frac} MB"
    # GB range
    val gb_10 = (n * 10) / 1073741824
    val whole = gb_10 / 10
    val frac = gb_10 % 10
    if frac == 0:
        return "{whole} GB"
    "{whole}.{frac} GB"

fn fmt_tokens(n: i64) -> text:
    """Format a token count with K/M suffix.
    Examples: 500 -> \"500\", 1500 -> \"1.5K\", 2500000 -> \"2.5M\"."""
    if n >= 1000000:
        val m = n / 100000
        return "{m / 10}.{m % 10}M"
    if n >= 1000:
        val k = n / 100
        return "{k / 10}.{k % 10}K"
    "{n}"

fn fmt_count(n: i64, singular: text, plural: text) -> text:
    """Format a count with the appropriate noun form.
    Examples: fmt_count(1, \"file\", \"files\") -> \"1 file\",
              fmt_count(3, \"file\", \"files\") -> \"3 files\"."""
    if n == 1:
        return "1 {singular}"
    "{n} {plural}"

# =========================================================================
# Time Formatting
# =========================================================================

fn fmt_duration_ms(ms: i64) -> text:
    """Format a duration in milliseconds to a human-readable string.
    Examples: 50 -> \"50ms\", 2300 -> \"2.3s\", 83000 -> \"1m 23s\"."""
    val abs_ms = _abs_i64(ms)
    if abs_ms < 1000:
        return "{ms}ms"
    if abs_ms < 60000:
        val s_10 = abs_ms / 100
        val whole = s_10 / 10
        val frac = s_10 % 10
        val prefix = if ms < 0: "-" else: ""
        if frac == 0:
            return "{prefix}{whole}s"
        return "{prefix}{whole}.{frac}s"
    val total_secs = abs_ms / 1000
    val mins = total_secs / 60
    val secs = total_secs % 60
    val prefix = if ms < 0: "-" else: ""
    if secs == 0:
        return "{prefix}{mins}m"
    "{prefix}{mins}m {secs}s"

fn fmt_duration_secs(secs: i64) -> text:
    """Format a duration in seconds to a human-readable string.
    Examples: 45 -> \"45s\", 3723 -> \"1h 2m\", 90 -> \"1m 30s\"."""
    val abs_secs = _abs_i64(secs)
    val prefix = if secs < 0: "-" else: ""
    if abs_secs < 60:
        return "{prefix}{abs_secs}s"
    if abs_secs < 3600:
        val mins = abs_secs / 60
        val rem = abs_secs % 60
        if rem == 0:
            return "{prefix}{mins}m"
        return "{prefix}{mins}m {rem}s"
    val hours = abs_secs / 3600
    val rem_secs = abs_secs % 3600
    val mins = rem_secs / 60
    if mins == 0:
        return "{prefix}{hours}h"
    "{prefix}{hours}h {mins}m"

fn fmt_timestamp(epoch_secs: i64) -> text:
    """Format a unix epoch timestamp (seconds) as YYYY-MM-DD HH:MM.
    Uses a simplified calendar (365-day years, 30-day months)."""
    val abs_ts = _abs_i64(epoch_secs)
    val total_mins = abs_ts / 60
    val total_hours = total_mins / 60
    val total_days = total_hours / 24

    val hour = total_hours % 24
    val minute = total_mins % 60

    val year_offset = total_days / 365
    val day_of_year = total_days % 365
    val month_index = day_of_year / 30
    val day_index = day_of_year % 30

    val year = 1970 + year_offset
    var month = month_index + 1
    var day = day_index + 1
    if month > 12:
        month = 12
    if day > 31:
        day = 31

    val mm = if month < 10: "0{month}" else: "{month}"
    val dd = if day < 10: "0{day}" else: "{day}"
    val hh = if hour < 10: "0{hour}" else: "{hour}"
    val mi = if minute < 10: "0{minute}" else: "{minute}"
    "{year}-{mm}-{dd} {hh}:{mi}"

fn fmt_relative_time(elapsed_ms: i64) -> text:
    """Format an elapsed time as a relative string.
    The input is the number of milliseconds that have passed.
    Examples: 5000 -> \"5s ago\", 180000 -> \"3 min ago\",
              7200000 -> \"2h ago\", 86400000 -> \"1d ago\"."""
    val abs_ms = _abs_i64(elapsed_ms)
    if abs_ms < 1000:
        return "just now"
    val secs = abs_ms / 1000
    if secs < 60:
        return "{secs}s ago"
    val mins = secs / 60
    if mins < 60:
        return "{mins} min ago"
    val hours = mins / 60
    if hours < 24:
        return "{hours}h ago"
    val days = hours / 24
    "{days}d ago"

# =========================================================================
# Text Manipulation
# =========================================================================

fn truncate(s: text, max_len: i32) -> text:
    """Truncate text with '...' suffix if exceeding max_len.
    Example: truncate(\"Hello world\", 8) -> \"Hello...\"."""
    if s.len() <= max_len:
        return s
    if max_len <= 3:
        return "..."
    "{s.slice(0, max_len - 3)}..."

fn truncate_middle(s: text, max_len: i32) -> text:
    """Truncate text in the middle, preserving start and end.
    Example: truncate_middle(\"Hello world!\", 9) -> \"Hel...ld!\"."""
    if s.len() <= max_len:
        return s
    if max_len <= 3:
        return "..."
    val avail = max_len - 3
    val left_len = (avail + 1) / 2
    val right_len = avail - left_len
    val left = s.slice(0, left_len)
    val right = s.slice(s.len() - right_len)
    "{left}...{right}"

fn word_wrap(s: text, width: i32) -> [text]:
    """Wrap text to a given width, breaking at word boundaries.
    Returns a list of lines."""
    if s.len() <= width:
        return [s]
    val words = s.split(" ")
    var lines: [text] = []
    var current_line = ""
    for word in words:
        if current_line.len() == 0:
            current_line = word
        elif current_line.len() + 1 + word.len() <= width:
            current_line = "{current_line} {word}"
        else:
            lines.push(current_line)
            current_line = word
    if current_line.len() > 0:
        lines.push(current_line)
    lines

fn indent(s: text, spaces: i32) -> text:
    """Indent a single line by the given number of spaces.
    Example: indent(\"hello\", 4) -> \"    hello\"."""
    val prefix = _repeat_char(" ", spaces)
    "{prefix}{s}"

fn indent_lines(lines: [text], spaces: i32) -> [text]:
    """Indent every line in the list by the given number of spaces."""
    val prefix = _repeat_char(" ", spaces)
    var result: [text] = []
    for line in lines:
        result.push("{prefix}{line}")
    result

fn pad_left(s: text, width: i32) -> text:
    """Pad a string on the left to the given width (right-align).
    Example: pad_left(\"42\", 6) -> \"    42\"."""
    val len = s.len()
    if len >= width:
        return s
    val padding = _repeat_char(" ", width - len)
    "{padding}{s}"

fn pad_right(s: text, width: i32) -> text:
    """Pad a string on the right to the given width (left-align).
    Example: pad_right(\"hi\", 6) -> \"hi    \"."""
    val len = s.len()
    if len >= width:
        return s
    val padding = _repeat_char(" ", width - len)
    "{s}{padding}"

fn pad_center(s: text, width: i32) -> text:
    """Center a string within the given width.
    Example: pad_center(\"hi\", 6) -> \"  hi  \"."""
    val len = s.len()
    if len >= width:
        return s
    val total_pad = width - len
    val left_pad = total_pad / 2
    val right_pad = total_pad - left_pad
    val left = _repeat_char(" ", left_pad)
    val right = _repeat_char(" ", right_pad)
    "{left}{s}{right}"

# =========================================================================
# Pluralization
# =========================================================================

fn pluralize(n: i64, singular: text) -> text:
    """Auto-pluralize by appending 's'. Handles common cases.
    Examples: pluralize(1, \"file\") -> \"1 file\",
              pluralize(3, \"file\") -> \"3 files\"."""
    if n == 1:
        return "1 {singular}"
    "{n} {singular}s"

# =========================================================================
# Heading / Section Helpers
# =========================================================================

fn heading(title: text, char: text, width: i32) -> text:
    """Create a centered heading with surrounding decoration.
    Example: heading(\"Title\", \"=\", 20) -> \"======= Title ======\"."""
    val title_with_spaces = " {title} "
    val title_len = title_with_spaces.len()
    if title_len >= width:
        return title_with_spaces
    val remaining = width - title_len
    val left_count = remaining / 2
    val right_count = remaining - left_count
    val left = _repeat_char(char, left_count)
    val right = _repeat_char(char, right_count)
    "{left}{title_with_spaces}{right}"

fn separator(char: text, width: i32) -> text:
    """Create a separator line of the given width.
    Example: separator(\"=\", 20) -> \"====================\"."""
    _repeat_char(char, width)

fn bullet_list(items: [text]) -> text:
    """Format items as a bulleted list.
    Example: bullet_list([\"a\", \"b\"]) -> \"- a\\n- b\"."""
    var result = ""
    var first = true
    for item in items:
        if not first:
            result = "{result}\n"
        result = "{result}- {item}"
        first = false
    result

fn numbered_list(items: [text]) -> text:
    """Format items as a numbered list.
    Example: numbered_list([\"a\", \"b\"]) -> \"1. a\\n2. b\"."""
    var result = ""
    var i = 1
    var first = true
    for item in items:
        if not first:
            result = "{result}\n"
        result = "{result}{i}. {item}"
        i = i + 1
        first = false
    result
