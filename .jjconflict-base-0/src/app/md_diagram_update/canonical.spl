# SDN Canonical Hash — deterministic hash from SDN graph AST

use std.editor.services.sdn_graph.{SdnGraph}
use std.nogc_sync_mut.io.crypto_sffi.{hash_sha256}

fn canonicalize_for_hash(graph: SdnGraph, layout: text, direction: text) -> text:
    var lines: [text] = []
    if direction != "":
        lines.push("option(direction," + direction + ")")
    if layout != "":
        lines.push("option(layout," + layout + ")")
    val node_ids = _canonical_node_ids(graph)
    for nid in node_ids:
        lines.push("node(" + nid + ")")
    val edge_keys = _canonical_edge_keys(graph)
    for ek in edge_keys:
        lines.push(ek)
    var result = ""
    for line in lines:
        if result != "":
            result = result + "\n"
        result = result + line
    result

fn canonical_hash(graph: SdnGraph, layout: text, direction: text) -> text:
    val canonical = canonicalize_for_hash(graph, layout, direction)
    val full_hash = hash_sha256(canonical)
    val short = full_hash.substring(0, 8)
    "sha256:" + short

fn _canonical_node_ids(graph: SdnGraph) -> [text]:
    var ids: [text] = []
    for node in graph.nodes:
        if not _text_in_arr(ids, node.id):
            ids.push(node.id)
    for edge in graph.edges:
        if not _text_in_arr(ids, edge.from_id):
            ids.push(edge.from_id)
        if not _text_in_arr(ids, edge.to_id):
            ids.push(edge.to_id)
    _sort_arr(ids)

fn _canonical_edge_keys(graph: SdnGraph) -> [text]:
    var keys: [text] = []
    for edge in graph.edges:
        keys.push("edge(" + edge.from_id + "," + edge.to_id + ")")
    _sort_arr(keys)

fn _text_in_arr(arr: [text], item: text) -> bool:
    for x in arr:
        if x == item:
            return true
    false

fn _sort_arr(arr: [text]) -> [text]:
    var result: [text] = []
    for x in arr:
        result.push(x)
    var i = 0
    while i < result.len():
        var j = i + 1
        while j < result.len():
            if result[j] < result[i]:
                val tmp = result[i]
                result[i] = result[j]
                result[j] = tmp
            j = j + 1
        i = i + 1
    result
