use .main_lazy_json
use .tool_registry
use .tool_table

fn _mcp_static_prop(param_name: text) -> text:
    jp(param_name, jo2(jp("type", js("string")), jp("description", js(param_name))))

# Append a prop entry to a parts array if the param appears in required_json.
# Arrays are value types; caller must reassign the return value.
fn _mcp_static_append_prop_parts(parts: [text], required_json: text, param_name: text) -> [text]:
    if not required_json.contains(Q() + param_name + Q()):
        return parts
    var p = parts
    p.push(_mcp_static_prop(param_name))
    p

fn _mcp_static_props(required_json: text) -> text:
    var parts: [text] = []
    parts = _mcp_static_append_prop_parts(parts, required_json, "program")
    parts = _mcp_static_append_prop_parts(parts, required_json, "target_type")
    parts = _mcp_static_append_prop_parts(parts, required_json, "session_id")
    parts = _mcp_static_append_prop_parts(parts, required_json, "breakpoint_id")
    parts = _mcp_static_append_prop_parts(parts, required_json, "file")
    parts = _mcp_static_append_prop_parts(parts, required_json, "line")
    parts = _mcp_static_append_prop_parts(parts, required_json, "mode")
    parts = _mcp_static_append_prop_parts(parts, required_json, "enabled")
    parts = _mcp_static_append_prop_parts(parts, required_json, "condition")
    parts = _mcp_static_append_prop_parts(parts, required_json, "expression")
    parts = _mcp_static_append_prop_parts(parts, required_json, "action")
    parts = _mcp_static_append_prop_parts(parts, required_json, "name")
    parts = _mcp_static_append_prop_parts(parts, required_json, "value")
    parts = _mcp_static_append_prop_parts(parts, required_json, "item_names")
    parts = _mcp_static_append_prop_parts(parts, required_json, "item_name")
    parts = _mcp_static_append_prop_parts(parts, required_json, "module")
    parts = _mcp_static_append_prop_parts(parts, required_json, "elf_path")
    parts = _mcp_static_append_prop_parts(parts, required_json, "script")
    parts = _mcp_static_append_prop_parts(parts, required_json, "command")
    parts = _mcp_static_append_prop_parts(parts, required_json, "function_name")
    parts = _mcp_static_append_prop_parts(parts, required_json, "url")
    parts = _mcp_static_append_prop_parts(parts, required_json, "path")
    parts = _mcp_static_append_prop_parts(parts, required_json, "target_dir")
    parts = _mcp_static_append_prop_parts(parts, required_json, "app_path")
    parts = _mcp_static_append_prop_parts(parts, required_json, "selector")
    parts = _mcp_static_append_prop_parts(parts, required_json, "text")
    parts = _mcp_static_append_prop_parts(parts, required_json, "key")
    parts = _mcp_static_append_prop_parts(parts, required_json, "js")
    parts = _mcp_static_append_prop_parts(parts, required_json, "x")
    parts = _mcp_static_append_prop_parts(parts, required_json, "y")
    parts = _mcp_static_append_prop_parts(parts, required_json, "base_url")
    parts = _mcp_static_append_prop_parts(parts, required_json, "widget_id")
    parts = _mcp_static_append_prop_parts(parts, required_json, "canonical_id")
    parts = _mcp_static_append_prop_parts(parts, required_json, "old_string")
    parts = _mcp_static_append_prop_parts(parts, required_json, "new_string")
    parts = _mcp_static_append_prop_parts(parts, required_json, "edits")
    parts = _mcp_static_append_prop_parts(parts, required_json, "query")
    parts = _mcp_static_append_prop_parts(parts, required_json, "task_id")
    parts = _mcp_static_append_prop_parts(parts, required_json, "prompt")
    parts = _mcp_static_append_prop_parts(parts, required_json, "signal")
    parts = _mcp_static_append_prop_parts(parts, required_json, "package")
    LB() + parts.join(",") + RB()

fn _mcp_static_prop_desc(param_name: text, description: text) -> text:
    jp(param_name, jo2(jp("type", js("string")), jp("description", js(description))))

fn _mcp_static_context_props() -> text:
    var parts: [text] = []
    parts.push(_mcp_static_prop_desc("file", "Source file path; required except when sql=true and query is non-empty"))
    parts.push(_mcp_static_prop_desc("target", "Target symbol or section"))
    parts.push(_mcp_static_prop_desc("format", "Output format: text, markdown/md, json"))
    parts.push(_mcp_static_prop_desc("index", "Emit a local context-pack index (true/false)"))
    parts.push(_mcp_static_prop_desc("query", "Query local or SQL context-pack index"))
    parts.push(_mcp_static_prop_desc("sql", "Use Simple embedded SQLite for index/query (true/false)"))
    parts.push(_mcp_static_prop_desc("db", "SQLite index database path"))
    parts.push(_mcp_static_prop_desc("source_filter", "Filter SQL query rows by stored source path"))
    LB() + parts.join(",") + RB()

fn _mcp_static_ponytail_props() -> text:
    var parts: [text] = []
    parts.push(_mcp_static_prop_desc("file", "Source file path"))
    parts.push(_mcp_static_prop_desc("format", "Output format: text, markdown, json"))
    parts.push(_mcp_static_prop_desc("mode", "Mode: audit/review, simplification/simplify"))
    LB() + parts.join(",") + RB()

fn _mcp_static_pipe_props() -> text:
    var parts: [text] = []
    parts.push(_mcp_static_prop_desc("surface", "Surface: spipe/pipe, context, codebase, search, ponytail/audit/simplification"))
    parts.push(_mcp_static_prop_desc("file", "Source file path"))
    parts.push(_mcp_static_prop_desc("target", "Target symbol or section"))
    parts.push(_mcp_static_prop_desc("query", "Search, codebase, or context index query"))
    parts.push(_mcp_static_prop_desc("kind", "Symbol kind filter for search/LSP: fn, class, struct, enum, import, type"))
    parts.push(_mcp_static_prop_desc("scope", "Codebase search scope: src, test, lib, compiler, app, all"))
    parts.push(_mcp_static_prop_desc("requester", "Requester path used to rank LSP workspace symbols"))
    parts.push(_mcp_static_prop_desc("format", "Output format: text, markdown/md, json"))
    parts.push(_mcp_static_prop_desc("sql", "Use Simple embedded SQLite for index/query (true/false)"))
    parts.push(_mcp_static_prop_desc("db", "SQLite index database path"))
    parts.push(_mcp_static_prop_desc("source_filter", "Filter SQL query rows by stored source path"))
    LB() + parts.join(",") + RB()

fn _mcp_static_props_for_tool(name: text, required_json: text) -> text:
    if name == "simple_pipe":
        return _mcp_static_pipe_props()
    if name == "simple_context":
        return _mcp_static_context_props()
    if name == "simple_ponytail":
        return _mcp_static_ponytail_props()
    _mcp_static_props(required_json)

fn _mcp_static_tool_schema(name: text, desc: text, required_json: text) -> text:
    val input_schema = jo3(
        jp("type", js("object")),
        jp("properties", _mcp_static_props_for_tool(name, required_json)),
        jp("required", required_json)
    )
    val annotations = jo4(
        jp("readOnlyHint", "false"),
        jp("destructiveHint", "false"),
        jp("idempotentHint", "true"),
        jp("openWorldHint", "false")
    )
    jo4(
        jp("name", js(name)),
        jp("description", js(desc)),
        jp("inputSchema", input_schema),
        jp("annotations", annotations)
    )

fn _mcp_static_tool_schema_from_entry(entry: McpToolEntry) -> text:
    _mcp_static_tool_schema(entry.name, entry.description, entry.required_json)

# Lightweight tool descriptor: name + description + required-params JSON.
# Used to build both the tools/list response and the cheap --probe manifest
# from a single source of truth (no schema strings, no per-tool prop chains).
struct McpStaticTool:
    name: text
    desc: text
    req: text

fn _mcp_static_tool(name: text, desc: text, req: text) -> McpStaticTool:
    McpStaticTool { name: name, desc: desc, req: req }

# The canonical tool descriptor table. Built once; callers cache the result.
