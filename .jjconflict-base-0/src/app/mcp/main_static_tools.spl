# Cheap probe count: number of tools in the manifest. Walks the descriptor
# table only (names/desc/req) — no schema JSON, no per-tool prop chains.
fn _mcp_probe_tool_count() -> i64:
    _mcp_static_tool_table().len()

# Cheap, stable djb2 hash over the tool-name list. Used by --probe to detect
# manifest drift without building the full tools/list JSON.
fn _mcp_probe_manifest_hash() -> text:
    val tools = _mcp_static_tool_table()
    var h: i64 = 5381
    var i = 0
    while i < tools.len():
        val name = tools[i].name
        for ch in name:
            val cv = ch.char_code_at(0)
            h = (h * 33) + cv
        h = (h * 33) + 10
        i = i + 1
    _mcp_hex_u64(h)

fn _mcp_hex_u64(v: i64) -> text:
    val digits = "0123456789abcdef"
    var n = v
    if n == 0:
        return "0"
    var out_parts: [text] = []
    var started = false
    var shift = 60
    while shift >= 0:
        val nib = (n >> shift) & 15
        if nib != 0 or started:
            started = true
            out_parts.push(digits.substring(nib, nib + 1))
        shift = shift - 4
    if out_parts.len() == 0:
        return "0"
    out_parts.join("")

# Build the full tools/list result JSON from the single descriptor table.
# Uses a parts array + single join to avoid O(n^2) string growth.
fn _mcp_static_tools_result() -> text:
    val tools = _mcp_static_tool_table()
    var schemas: [text] = []
    var i = 0
    while i < tools.len():
        val tool = tools[i]
        schemas.push(_mcp_static_tool_schema(tool.name, tool.desc, tool.req))
        i = i + 1
    "{\"tools\":[" + schemas.join(",") + "]}"

# Module-level cache for the full tools/list JSON. Empty string = not yet built.
var _MCP_FULL_JSON_CACHE = ""

# Return the full tools/list JSON, building it once and caching for the process lifetime.
fn _mcp_static_tools_result_cached() -> text:
    if _MCP_FULL_JSON_CACHE == "":
        _MCP_FULL_JSON_CACHE = _mcp_static_tools_result()
    _MCP_FULL_JSON_CACHE

# Core tool name set — ~20 essential dev tools for the "core" subset.
# Used by _mcp_tools_list_json_for_set("core").
fn _mcp_core_tool_names() -> [text]:
    var names: [text] = []
    names.push("simple_search")
    names.push("simple_pipe")
    names

# Return the tools/list JSON for a named set.
# set_name "all" -> full 151-tool list (byte-identical to _mcp_static_tools_result).
# set_name "core" -> ~20 essential dev tools filtered from the same table.
# Any unknown set_name falls back to "all".
fn _mcp_tools_list_json_for_set(set_name: text) -> text:
    if set_name != "core":
        return _mcp_static_tools_result()
    val wanted = _mcp_core_tool_names()
    val tools = _mcp_static_tool_table()
    var schemas: [text] = []
    var i = 0
    while i < tools.len():
        val tool = tools[i]
        var j = 0
        while j < wanted.len():
            if tool.name == wanted[j]:
                schemas.push(_mcp_static_tool_schema(tool.name, tool.desc, tool.req))
            j = j + 1
        i = i + 1
    "{\"tools\":[" + schemas.join(",") + "]}"

export _mcp_static_tools_result
export _mcp_static_tools_result_cached
export _mcp_static_tool_schema
export _mcp_static_props
export _mcp_probe_tool_count
export _mcp_probe_manifest_hash
export _mcp_tools_list_json_for_set
