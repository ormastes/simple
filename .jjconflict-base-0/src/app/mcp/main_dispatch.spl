fn _dispatch_vcs(id: text, name: text, body: text) -> text:
    if name == "simple_diff":
        return handle_simple_diff(id, body)
    if name == "simple_log":
        return handle_simple_log(id, body)
    if name == "simple_squash":
        return handle_simple_squash(id, body)
    if name == "simple_new":
        return handle_simple_new(id, body)
    if name == "simple_commit":
        return handle_simple_commit(id, body)
    if name == "simple_push":
        return handle_simple_push(id, body)
    if name == "simple_rebase":
        return handle_simple_rebase(id, body)
    if name == "simple_pull":
        return handle_simple_pull(id, body)
    make_tool_error(id, -32601, "Unknown VCS tool: " + name)

fn _dispatch_query(id: text, name: text, body: text) -> text:
    if name == "simple_dependencies":
        return handle_simple_dependencies(id, body)
    if name == "simple_api_diff":
        return handle_simple_api_diff(id, body)
    if name == "simple_context":
        return handle_simple_context(id, body)
    if name == "simple_search":
        return handle_simple_search(id, body)
    make_tool_error(id, -32601, "Unknown query tool: " + name)

