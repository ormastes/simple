# Shared Test Dependency Graph Helpers
#
# Used by both the standalone test runner and the test daemon.

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool

class SharedDepGraph:
    deps: {text: [text]}
    reverse_deps: {text: [text]}
    graph_path: text
    track_reverse_deps: bool

val TEST_DEP_GRAPH_VERSION: i64 = 2

fn shared_dep_graph_new(graph_path: text, track_reverse_deps: bool) -> SharedDepGraph:
    SharedDepGraph(
        deps: {},
        reverse_deps: {},
        graph_path: graph_path,
        track_reverse_deps: track_reverse_deps
    )

impl SharedDepGraph:
    fn get_deps(test_path: text) -> [text]:
        self.deps[test_path] ?? []

    fn get_affected_tests(source_path: text) -> [text]:
        if not self.track_reverse_deps:
            return []
        self.reverse_deps[source_path] ?? []

    me analyze_test(test_path: text):
        val previous = self.deps[test_path] ?? []
        if self.track_reverse_deps:
            clear_reverse_deps(self.reverse_deps, test_path, previous)

        val source = rt_file_read_text(test_path) ?? ""
        if source == "":
            self.deps[test_path] = []
            return

        val imports = extract_imports(source)
        var resolved: [text] = []
        var seen: {text: bool} = {}
        var i = 0
        while i < imports.len():
            val module_path = resolve_module_to_file(imports[i])
            if module_path != "":
                if not (seen[module_path] ?? false):
                    resolved.push(module_path)
                    seen[module_path] = true
                val transitive = extract_transitive_deps(module_path, 5)
                var j = 0
                while j < transitive.len():
                    if not (seen[transitive[j]] ?? false):
                        resolved.push(transitive[j])
                        seen[transitive[j]] = true
                    j = j + 1
            i = i + 1

        self.deps[test_path] = resolved

        if self.track_reverse_deps:
            var ri = 0
            while ri < resolved.len():
                val dep = resolved[ri]
                var tests = self.reverse_deps[dep] ?? []
                if not list_contains(tests, test_path):
                    tests.push(test_path)
                self.reverse_deps[dep] = tests
                ri = ri + 1

    me save():
        if self.graph_path == "":
            return

        val parent = dep_graph_parent(self.graph_path)
        rt_mkdir_p(parent)

        var lines: [text] = []
        lines.push("# Test Dependency Graph")
        lines.push("version={TEST_DEP_GRAPH_VERSION}")
        val keys = self.deps.keys()
        var i = 0
        while i < keys.len():
            val key = keys[i]
            val dep_list = self.deps[key] ?? []
            lines.push("")
            lines.push("[{dep_graph_escape_text(key)}]")
            var di = 0
            while di < dep_list.len():
                lines.push("dep={dep_graph_escape_text(dep_list[di])}")
                di = di + 1
            i = i + 1

        val content = lines.join("\n") + "\n"
        rt_file_write_text(self.graph_path, content)

fn shared_dep_graph_load(graph_path: text, track_reverse_deps: bool) -> SharedDepGraph:
    val graph = shared_dep_graph_new(graph_path, track_reverse_deps)

    if graph_path == "":
        return graph
    if not rt_file_exists(graph_path):
        return graph

    val content = rt_file_read_text(graph_path) ?? ""
    if content == "":
        return graph

    var seen_entry = false
    var declared_version: i64 = 1
    var current_key = ""
    var current_deps: [text] = []

    val lines = content.split("\n")
    var li = 0
    while li < lines.len():
        val line = lines[li].trim()
        if line.starts_with("[") and line.ends_with("]"):
            seen_entry = true
            if current_key != "":
                graph.deps[current_key] = current_deps
                if track_reverse_deps:
                    register_reverse_deps(graph.reverse_deps, current_key, current_deps)

            current_key = dep_graph_unescape_text(line.substring(1, line.len() - 1))
            current_deps = []
        elif line.starts_with("version=") and not seen_entry:
            declared_version = line.substring(8).to_i64() ?? 0
            if declared_version != 1 and declared_version != TEST_DEP_GRAPH_VERSION:
                return shared_dep_graph_new(graph_path, track_reverse_deps)
        elif line.starts_with("dep="):
            current_deps.push(dep_graph_unescape_text(line.substring(4)))
        li = li + 1

    if current_key != "":
        graph.deps[current_key] = current_deps
        if track_reverse_deps:
            register_reverse_deps(graph.reverse_deps, current_key, current_deps)

    graph

fn extract_imports(source: text) -> [text]:
    var imports: [text] = []
    val lines = source.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("use "):
            val module = parse_use_statement(line)
            if module != "":
                imports.push(module)
        i = i + 1
    imports

fn parse_use_statement(line: text) -> text:
    val rest = line.substring(4).trim()
    val brace_pos = rest.index_of(".{")
    if brace_pos > 0:
        return rest.substring(0, brace_pos)
    val star_pos = rest.index_of(".*")
    if star_pos > 0:
        return rest.substring(0, star_pos)
    rest

var _module_path_cache: {text: text} = {}

fn resolve_module_to_file(module_path: text) -> text:
    val cached = _module_path_cache[module_path] ?? ""
    if cached != "":
        if cached == "_NONE_":
            return ""
        return cached

    val result = resolve_module_uncached(module_path)
    if result == "":
        _module_path_cache[module_path] = "_NONE_"
    else:
        _module_path_cache[module_path] = result
    result

fn resolve_module_uncached(module_path: text) -> text:
    val parts = module_path.split(".")
    if parts.len() == 0:
        return ""

    val prefix = parts[0]
    var base_dirs: [text] = []
    if prefix == "std" or prefix == "lib":
        base_dirs = ["src/lib/common", "src/lib/nogc_sync_mut", "src/lib/nogc_async_mut", "src/lib/gc_async_mut", "src/lib/nogc_async_mut_noalloc"]
    elif prefix == "compiler":
        base_dirs = ["src/compiler"]
    elif prefix == "app":
        base_dirs = ["src/app"]
    else:
        return ""

    var rel_path = ""
    var i = 1
    while i < parts.len():
        if rel_path != "":
            rel_path = rel_path + "/"
        rel_path = rel_path + parts[i]
        i = i + 1

    var bi = 0
    while bi < base_dirs.len():
        val candidate = "{base_dirs[bi]}/{rel_path}.spl"
        if rt_file_exists(candidate):
            return candidate
        val mod_candidate = "{base_dirs[bi]}/{rel_path}/mod.spl"
        if rt_file_exists(mod_candidate):
            return mod_candidate
        bi = bi + 1

    ""

fn extract_transitive_deps(file_path: text, max_depth: i64) -> [text]:
    if max_depth <= 0:
        return []

    var result: [text] = []
    var seen: {text: bool} = {}
    var pending_paths: [text] = [file_path]
    var pending_depths: [i64] = [max_depth]
    var pending_index = 0
    while pending_index < pending_paths.len():
        val current_path = pending_paths[pending_index]
        val remaining_depth = pending_depths[pending_index]
        pending_index = pending_index + 1

        if remaining_depth <= 0:
            continue

        val source = rt_file_read_text(current_path) ?? ""
        if source == "":
            continue

        val imports = extract_imports(source)
        var i = 0
        while i < imports.len():
            val resolved = resolve_module_to_file(imports[i])
            if resolved != "" and not (seen[resolved] ?? false):
                result.push(resolved)
                seen[resolved] = true
                pending_paths.push(resolved)
                pending_depths.push(remaining_depth - 1)
            i = i + 1
    result

fn register_reverse_deps(reverse_deps: {text: [text]}, test_path: text, dep_list: [text]):
    var i = 0
    while i < dep_list.len():
        val dep_path = dep_list[i]
        var tests = reverse_deps[dep_path] ?? []
        if not list_contains(tests, test_path):
            tests.push(test_path)
        reverse_deps[dep_path] = tests
        i = i + 1

fn clear_reverse_deps(reverse_deps: {text: [text]}, test_path: text, dep_list: [text]):
    var i = 0
    while i < dep_list.len():
        val dep_path = dep_list[i]
        var tests = reverse_deps[dep_path] ?? []
        tests = list_remove(tests, test_path)
        reverse_deps[dep_path] = tests
        i = i + 1

fn list_contains(list: [text], item: text) -> bool:
    var i = 0
    while i < list.len():
        if list[i] == item:
            return true
        i = i + 1
    false

fn list_remove(list: [text], item: text) -> [text]:
    var result: [text] = []
    var i = 0
    while i < list.len():
        if list[i] != item:
            result.push(list[i])
        i = i + 1
    result

fn dep_graph_parent(path: text) -> text:
    val last_slash = path.last_index_of("/")
    if last_slash < 0:
        return "."
    path.substring(0, last_slash)

fn dep_graph_escape_text(s: text) -> text:
    s.replace("\\", "\\\\").replace("\n", "\\n").replace("=", "\\=").replace("[", "\\[").replace("]", "\\]")

fn dep_graph_unescape_text(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "\\" and i + 1 < s.len():
            val next = s.substring(i + 1, i + 2)
            if next == "n":
                result = result + "\n"
            else:
                result = result + next
            i = i + 2
        else:
            result = result + ch
            i = i + 1
    result
