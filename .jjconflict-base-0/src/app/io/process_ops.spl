# Process Execution - Pure Simple I/O
# Extracted from mod.spl for modularity

use std.nogc_sync_mut.io.process_governor (proc_slot_acquire, proc_slot_release)

# Extern fn declarations (runtime resolves at file level)
# Seed compat: do NOT import std.nogc_sync_mut.sffi.system here — this module
# is in the interpreted CLI closure and that module declares externs the
# deployed seed rejects (rt_shell_output), killing every native-build.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_bounded(cmd: text, args: [text], timeout_ms: i64, max_output_bytes: i64) -> (text, text, i64)
extern fn rt_process_run_inherit(cmd: text, args: [text]) -> i64
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_env_get(key: text) -> text
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_spawn_inherit() -> i64
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_getpid() -> i64

# Platform detection - inlined to avoid bootstrap runtime limitations
fn _is_windows_platform() -> bool:
    val os_env = rt_env_get("OS")
    if os_env == nil:
        false
    else:
        os_env.lower().contains("windows")

# ============================================================================
# Process Result struct
# ============================================================================

struct ProcessResult:
    stdout: text
    stderr: text
    exit_code: i64
    limit_exceeded: bool
    limit_type: text

# ============================================================================
# Process Execution
# ============================================================================

fn _resolve_process_cmd(cmd: text) -> text:
    var resolved_cmd = cmd
    if _is_windows_platform():
        if not cmd.ends_with(".exe") and not cmd.ends_with(".cmd") and not cmd.ends_with(".bat"):
            val check = rt_process_run("where", [cmd + ".exe"])
            if check.2 == 0:
                resolved_cmd = cmd + ".exe"
    else:
        if not cmd.contains("/"):
            val check = rt_process_run("which", [cmd])
            if check.2 == 0 and check.0.trim() != "":
                resolved_cmd = check.0.trim()
    resolved_cmd

fn process_run(cmd: text, args: [text]) -> (text, text, i64):
    val resolved_cmd = _resolve_process_cmd(cmd)
    proc_slot_acquire()
    val result = rt_process_run(resolved_cmd, args)
    proc_slot_release()
    result

fn process_run_bounded(cmd: text, args: [text], timeout_ms: i64, max_output_bytes: i64) -> (text, text, i64):
    val resolved_cmd = _resolve_process_cmd(cmd)
    proc_slot_acquire()
    val result = rt_process_run_bounded(resolved_cmd, args, timeout_ms, max_output_bytes)
    proc_slot_release()
    result

fn process_run_inherit(cmd: text, args: [text]) -> i64:
    # Foreground delegation: preserve the caller's stdin/stdout/stderr.
    rt_process_run_inherit(cmd, args)

fn process_run_timeout_unix(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32):
    # Unix timeout wrapper: use `timeout` plus temp files so orphaned
    # grandchildren cannot keep stdout/stderr pipes open forever.
    # See doc/08_tracking/bug/native_build_worker_zombie_parent_hang_2026-07-03.md.
    val timeout_secs = if timeout_ms <= 0:
        120
    else:
        val secs = timeout_ms / 1000
        if secs < 1: 1 else: secs

    var temp_dir = rt_env_get("TMPDIR")
    if temp_dir == "" or temp_dir == nil:
        temp_dir = "/tmp"

    val pid_str = "{rt_getpid()}"
    val time_str = "{rt_time_now_unix_micros()}"
    val stdout_file = "{temp_dir}/simple_out_{pid_str}_{time_str}.txt"
    val stderr_file = "{temp_dir}/simple_err_{pid_str}_{time_str}.txt"

    var quoted_parts: [text] = ["timeout", "--kill-after=5s", "{timeout_secs}s"]
    val cmd_escaped = cmd.replace("'", "'\\''")
    quoted_parts.push("'{cmd_escaped}'")
    for arg in args:
        val arg_escaped = arg.replace("'", "'\\''")
        quoted_parts.push("'{arg_escaped}'")
    val cmd_line = quoted_parts.join(" ")
    val redirected_cmd = "exec {cmd_line} > '{stdout_file}' 2> '{stderr_file}'"

    proc_slot_acquire()
    val pid = rt_process_spawn_async("/bin/sh", ["-c", redirected_cmd])
    val wrapper_code = if pid <= 0: -1 else: rt_process_wait(pid, 0)
    proc_slot_release()

    var stdout = ""
    var stderr = ""
    if rt_file_exists(stdout_file):
        stdout = rt_file_read_text(stdout_file)
        rt_file_delete(stdout_file)
    if rt_file_exists(stderr_file):
        stderr = rt_file_read_text(stderr_file)
        rt_file_delete(stderr_file)

    if pid <= 0:
        (stdout, stderr + "\n[ERROR: failed to spawn process '{cmd}']", -1)
    elif wrapper_code == 124:
        (stdout, stderr + "\n[TIMEOUT: Process killed after {timeout_secs}s]", -1)
    else:
        (stdout, stderr, wrapper_code)

fn process_run_timeout_windows(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32):
    val effective_timeout = if timeout_ms <= 0: 120000 else: timeout_ms
    # Preserve argv boundaries and avoid cmd.exe reinterpretation.
    rt_process_run_timeout(cmd, args, effective_timeout)

fn process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32):
    # Platform-agnostic timeout wrapper.
    if _is_windows_platform():
        process_run_timeout_windows(cmd, args, timeout_ms)
    else:
        process_run_timeout_unix(cmd, args, timeout_ms)

fn _process_run_with_limits(cmd: text, args: [text], timeout_ms: i64, memory_bytes: i64, cpu_seconds: i64, max_fds: i64, max_procs: i64, max_output_bytes: i64) -> ProcessResult:
    # Execute a process with resource limits enforced via ulimit.
    if _is_windows_platform():
        eprint("[WARNING] Resource limits not supported on Windows - using timeout only")
        val effective_timeout = if timeout_ms <= 0: 0 else: timeout_ms
        val (stdout, stderr, exit_code) = if max_output_bytes > 0:
            process_run_bounded(cmd, args, effective_timeout, max_output_bytes)
        elif effective_timeout <= 0:
            process_run(cmd, args)
        else:
            process_run_timeout(cmd, args, effective_timeout)
        val timed_out = effective_timeout > 0 and exit_code == -1 and (stderr.contains("TIMEOUT") or stderr.contains("timed out"))
        return ProcessResult(
            stdout: stdout,
            stderr: stderr,
            exit_code: exit_code,
            limit_exceeded: timed_out,
            limit_type: if timed_out: "timeout" else: ""
        )

    val memory_kb = if memory_bytes > 0: memory_bytes / 1024 else: 0

    var limit_parts: [text] = []
    if memory_kb > 0:
        limit_parts.push("ulimit -v {memory_kb} 2>/dev/null || true; ")
    if cpu_seconds > 0:
        limit_parts.push("ulimit -t {cpu_seconds} 2>/dev/null || true; ")
    if max_fds > 0:
        limit_parts.push("ulimit -n {max_fds} 2>/dev/null || true; ")
    if max_procs > 0:
        limit_parts.push("ulimit -u {max_procs} 2>/dev/null || true; ")
    val limit_cmds = limit_parts.join("")

    var arg_parts: [text] = []
    for arg in args:
        val escaped = arg.replace("'", "'\\''")
        arg_parts.push("'{escaped}'")
    val args_str = arg_parts.join(" ")

    val full_cmd = if args_str == "": "{cmd}" else: "{cmd} {args_str}"
    val wrapped_cmd = if timeout_ms > 0:
        val timeout_sec = if timeout_ms < 1000: 1 else: timeout_ms / 1000
        val timeout_buffer = timeout_sec + 5
        "{limit_cmds}exec timeout --kill-after=5s {timeout_buffer}s {full_cmd}"
    else:
        "{limit_cmds}exec {full_cmd}"

    proc_slot_acquire()
    val (stdout, stderr, code) = if max_output_bytes > 0:
        rt_process_run_bounded("/bin/sh", ["-c", wrapped_cmd], timeout_ms, max_output_bytes)
    else:
        rt_process_run("/bin/sh", ["-c", wrapped_cmd])
    proc_slot_release()

    var limit_exceeded = false
    var limit_type = ""

    if code == -1 and (stderr.contains("TIMEOUT") or stderr.contains("timed out")):
        limit_exceeded = true
        limit_type = "timeout"
    elif code == 124:
        limit_exceeded = true
        limit_type = "timeout"
    elif code == 137:
        limit_exceeded = true
        limit_type = "timeout"
    elif code == 139:
        limit_exceeded = true
        limit_type = "memory"
    else:
        val stderr_lower = stderr.lower()
        if stderr_lower.contains("cpu time limit exceeded") or stderr_lower.contains("cpu time"):
            limit_exceeded = true
            limit_type = "cpu"
        elif stderr_lower.contains("cannot allocate memory") or stderr_lower.contains("out of memory"):
            limit_exceeded = true
            limit_type = "memory"
        elif stderr_lower.contains("too many open files"):
            limit_exceeded = true
            limit_type = "fds"
        elif stderr_lower.contains("resource temporarily unavailable"):
            limit_exceeded = true
            limit_type = "procs"

    ProcessResult(
        stdout: stdout,
        stderr: stderr,
        exit_code: code,
        limit_exceeded: limit_exceeded,
        limit_type: limit_type
    )

fn process_run_with_limits(cmd: text, args: [text], timeout_ms: i64, memory_bytes: i64, cpu_seconds: i64, max_fds: i64, max_procs: i64) -> ProcessResult:
    _process_run_with_limits(cmd, args, timeout_ms, memory_bytes, cpu_seconds, max_fds, max_procs, 0)

fn process_run_with_limits_bounded(cmd: text, args: [text], timeout_ms: i64, memory_bytes: i64, cpu_seconds: i64, max_fds: i64, max_procs: i64, max_output_bytes: i64) -> ProcessResult:
    _process_run_with_limits(cmd, args, timeout_ms, memory_bytes, cpu_seconds, max_fds, max_procs, max_output_bytes)

fn process_output(cmd: text, args: [text]) -> text:
    val (stdout, stderr, code) = process_run(cmd, args)
    stdout

# ============================================================================
# Shell Functions
# ============================================================================

fn _shell_command_args(command: text) -> (text, [text]):
    if _is_windows_platform():
        ("cmd.exe", ["/c", command])
    else:
        ("/bin/sh", ["-c", command])

fn shell(command: text) -> ProcessResult:
    val (shell_path, shell_args) = _shell_command_args(command)
    proc_slot_acquire()
    val (stdout, stderr, code) = rt_process_run(shell_path, shell_args)
    proc_slot_release()
    ProcessResult(stdout: stdout, stderr: stderr, exit_code: code, limit_exceeded: false, limit_type: "")

fn shell_bool(command: text) -> bool:
    val (shell_path, shell_args) = _shell_command_args(command)
    proc_slot_acquire()
    val (_stdout, _stderr, code) = rt_process_run(shell_path, shell_args)
    proc_slot_release()
    code == 0

fn shell_output(command: text, default: text) -> text:
    val (shell_path, shell_args) = _shell_command_args(command)
    proc_slot_acquire()
    val (stdout, _stderr, code) = rt_process_run(shell_path, shell_args)
    proc_slot_release()
    if code == 0:
        stdout
    else:
        default

fn shell_output_trimmed(command: text, default: text) -> text:
    val (shell_path, shell_args) = _shell_command_args(command)
    proc_slot_acquire()
    val (stdout, _stderr, code) = rt_process_run(shell_path, shell_args)
    proc_slot_release()
    if code == 0:
        stdout.trim()
    else:
        default

fn shell_lines(command: text) -> [text]:
    val (shell_path, shell_args) = _shell_command_args(command)
    proc_slot_acquire()
    val (stdout, _stderr, code) = rt_process_run(shell_path, shell_args)
    proc_slot_release()
    if code == 0 and stdout.?:
        stdout.trim().split("\n")
    else:
        []

fn _shell_signed_int_or(value: text, default: i64) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return default
    var i = 0
    for ch in trimmed:
        if ch >= "0" and ch <= "9":
            i = i + 1
            continue
        if i == 0 and ch == "-":
            i = i + 1
            continue
        return default
    if trimmed == "-":
        return default
    int(trimmed)

fn shell_int(command: text, default: i64) -> i64:
    val (shell_path, shell_args) = _shell_command_args(command)
    proc_slot_acquire()
    val (stdout, _stderr, code) = rt_process_run(shell_path, shell_args)
    proc_slot_release()
    if code == 0:
        _shell_signed_int_or(stdout, default)
    else:
        default

# ============================================================================
# Async Process Management
# ============================================================================

fn process_spawn_async(cmd: text, args: [text]) -> i64:
    # Spawn a process asynchronously (non-blocking).
    rt_process_spawn_async(cmd, args)

fn process_spawn_inherit() -> i64:
    # Spawn the canonical MCP wrapper as a transparent stdio child.
    rt_process_spawn_inherit()

fn process_wait(pid: i64, timeout_ms: i64) -> i64:
    # Wait for a process to complete.
    if pid <= 0:
        return -1
    rt_process_wait(pid, timeout_ms)

fn process_is_running(pid: i64) -> bool:
    # Check if a process is still running.
    rt_process_is_running(pid)

fn process_kill(pid: i64) -> bool:
    # Terminate a running process.
    if pid <= 1:
        return false
    rt_process_kill(pid)

# ============================================================================
# Eprint (stderr simulation)
# ============================================================================

fn eprint(msg: text):
    print "[STDERR] {msg}"
