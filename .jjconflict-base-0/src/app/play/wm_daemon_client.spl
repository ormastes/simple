# WM daemon client helpers.
#
# Light-weight client surface for the resident WM daemon (see wm_daemon.spl).
# Deliberately does NOT import the compositor, so `wm windows list` can consult
# the daemon channel without dragging the full compositor module graph into its
# compile path. Records use the same normalized WindowInfo schema as the OS
# window shell adapter, so daemon-sourced and shell-sourced `windows list`
# output are identical.

use std.daemon_sdk.types.{DaemonRequest, DaemonResponse, daemon_config_new, daemon_request_new}
use std.daemon_sdk.client.{daemon_submit_and_wait}
use std.daemon_sdk.lock.{is_daemon_running}
use std.play.types.{WindowInfo}
# Direct definer import: app.io.mod hub drags the whole compiler (see
# wm_*_showcase_gui adapters, module-count regression 2026-07-18).
use app.io.env_ops.{home}

# Request kinds shared with the daemon server. Stop uses daemon_sdk's kind -1.
pub val WMD_WINDOWS_LIST: i64 = 1
pub val WMD_WINDOW_OPEN: i64 = 2
pub val WMD_WINDOW_CLOSE: i64 = 3
pub val WMD_STATUS: i64 = 4
pub val WMD_WINDOW_FOCUS: i64 = 5

pub fn wm_daemon_base_dir() -> text:
    "{home()}/.simple/cache/wm_daemon"

pub fn wm_daemon_config():
    val base = wm_daemon_base_dir()
    daemon_config_new("{base}/daemon.lock", "{base}/requests", "{base}/responses")

pub fn wm_daemon_is_running() -> bool:
    is_daemon_running(wm_daemon_config().lock_path)

pub fn wm_daemon_windows_from_response(resp: DaemonResponse) -> [WindowInfo]:
    """Decode the daemon `count`/`winN` fields into normalized WindowInfo rows.

    Each `winN` field is `id|title|width|height|focused`."""
    var out: [WindowInfo] = []
    val count = resp.get_field("count").to_i64() ?? 0
    var i: i64 = 0
    while i < count:
        val raw = resp.get_field("win{i}")
        val parts = raw.split("|")
        if parts.len() >= 5:
            val id = parts[0]
            out = out.push(WindowInfo(
                window_id: id,
                target_id: "wm:{id}#root",
                title: parts[1],
                url: "",
                x: 0,
                y: 0,
                width: parts[2].to_i64() ?? 0,
                height: parts[3].to_i64() ?? 0,
                focused: parts[4] == "true"
            ))
        i = i + 1
    out

pub fn wm_daemon_list_windows() -> [WindowInfo]?:
    """Return windows from the resident daemon, or nil when no daemon is
    running / the daemon did not answer — signalling the caller to fall back to
    the OS window shell adapter."""
    val config = wm_daemon_config()
    if not is_daemon_running(config.lock_path):
        return nil
    val req = daemon_request_new(WMD_WINDOWS_LIST)
    val resp = daemon_submit_and_wait(req, config, 5000)
    if resp.request_id == "":
        return nil
    wm_daemon_windows_from_response(resp)
