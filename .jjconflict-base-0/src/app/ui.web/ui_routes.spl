# UI Routes — /ui/* route dispatch for the Web UI server.
#
# Routes:
#   GET/WS /ui/ws   — WebSocket upgrade (bearer-gated via ws_handler), then
#                     construct WebRuntimeAdapter and run read/emit loop.
#   POST   /ui/resume — parse {session_id, snapshot_revision, last_sequence};
#                       send patch_batch or snapshot via adapter.
#
# /ui/login is handled by server.spl and must NOT be intercepted here.

use std.nogc_sync_mut.io.tcp.{TcpStream}
use common.ui.session.{UISession}
use app.ui.web.origin_guard.{OriginGuard, AuthError}
use app.ui.web.session_token.{verify, load_secret}
use app.ui.web.ws_handler.{handle_ws_upgrade, extract_ws_key, compute_ws_accept, send_ws_text}
use app.ui.web.async_ws.{read_ws_frame, extract_field}
use app.ui.web.web_runtime_adapter.{WebRuntimeAdapter}
use app.ui.web.wm_bridge.{WmBridge}
use app.ui.web.bounded_channel.{BoundedChannel}

extern fn rt_random_hex(len: i64) -> text
extern fn rt_time_ms() -> u64

# =========================================================================
# Route dispatcher
# =========================================================================

fn dispatch_ui_route(path: text, method: text, headers: text, body: text, stream: TcpStream, session: UISession, guard: OriginGuard, secret: text) -> bool:
    """Returns true if request was handled; false if path is not /ui/*.
    /ui/login is intentionally excluded — handled by server.spl."""
    if not path.starts_with("/ui/"):
        return false

    if path == "/ui/ws":
        _handle_ws_route(stream, headers, session, guard, secret)
        return true

    if path == "/ui/resume" and method == "POST":
        _handle_resume_route(stream, body, session)
        return true

    # Unknown /ui/ path
    val resp = "HTTP/1.1 404 Not Found\r\nContent-Length: 9\r\nConnection: close\r\n\r\nNot Found"
    stream.write_text(resp)
    return true

# =========================================================================
# /ui/ws — WebSocket upgrade + adapter loop
# =========================================================================

fn _handle_ws_route(stream: TcpStream, headers: text, session: UISession, guard: OriginGuard, secret: text):
    """Gate origin + bearer, complete WS handshake, then run adapter read loop."""
    # Security gate: origin check
    val origin_result = guard.check(headers)
    val origin = match origin_result:
        Err(_):
            stream.write_text("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
            return
        Ok(o): o

    # Security gate: bearer token
    val bearer = _extract_bearer(headers)
    if bearer == "":
        stream.write_text("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
        return
    val now = rt_time_ms()
    val tok_result = verify(bearer, origin, secret, now)
    val grant_id = match tok_result:
        Err(_):
            stream.write_text("HTTP/1.1 403 Forbidden\r\nContent-Length: 0\r\n\r\n")
            return
        Ok(tok): tok.grant_id

    # Complete WebSocket handshake
    val key = extract_ws_key(headers)
    if key == "":
        stream.write_text("HTTP/1.1 400 Bad Request\r\nContent-Length: 0\r\n\r\n")
        return
    val accept = compute_ws_accept(key)
    var ws_response = "HTTP/1.1 101 Switching Protocols\r\n"
    ws_response = "{ws_response}Upgrade: websocket\r\n"
    ws_response = "{ws_response}Connection: Upgrade\r\n"
    ws_response = "{ws_response}Sec-WebSocket-Accept: {accept}\r\n"
    ws_response = "{ws_response}\r\n"
    stream.write_text(ws_response)

    # Build adapter
    val session_id = rt_random_hex(16)
    val out_channel = BoundedChannel<text>.new(256)
    var adapter = WebRuntimeAdapter.new(session_id, session, grant_id, out_channel)

    # Send initial snapshot
    adapter.send_snapshot()
    _flush_out(stream, out_channel)

    # Read loop
    loop:
        val frame = read_ws_frame(stream)
        if frame == nil:
            break
        val msg_type = extract_field(frame, "t")
        match msg_type:
            "hello":
                val caps_payload = "{\"granted\": []}"
                val caps_frame = _make_frame("capabilities", session_id, "null", caps_payload)
                send_ws_text(stream, caps_frame)
            "open_session":
                adapter.send_snapshot()
            "resume_session":
                val rev_str = extract_field(frame, "snapshot_revision")
                val seq_str = extract_field(frame, "last_sequence")
                val rev: u64 = if rev_str == "": 0 else: rev_str.parse_u64()
                val seq: i64 = if seq_str == "": 0 else: seq_str.parse_i64()
                adapter.on_resume(rev, seq)
            "ack":
                val seq_str = extract_field(frame, "last_applied_sequence")
                val seq: i64 = if seq_str == "": 0 else: seq_str.parse_i64()
                adapter.on_ack(seq)
            "input_event":
                _handle_input_event(frame, session, session_id, out_channel)
            "window_cmd":
                _handle_window_cmd(frame, session, session_id, out_channel)
            "ping":
                val nonce = extract_field(frame, "nonce")
                val pong_payload = "{\"nonce\": \"{nonce}\"}"
                val pong_frame = _make_frame("pong", session_id, "null", pong_payload)
                send_ws_text(stream, pong_frame)
            _:
                pass_do_nothing

        # Emit any pending patches
        adapter.emit_patches()
        _flush_out(stream, out_channel)

fn _flush_out(stream: TcpStream, ch: BoundedChannel<text>):
    """Drain the adapter's output channel and send all frames."""
    loop:
        val item = ch.try_recv()
        if item == nil:
            break
        send_ws_text(stream, item as text)

fn _handle_input_event(frame: text, session: UISession, session_id: text, out: BoundedChannel<text>):
    val surface_id = extract_field(frame, "surface_id")
    val widget_id = extract_field(frame, "widget_id")
    if surface_id == "":
        _send_error(out, session_id, "UNKNOWN_SURFACE", "surface_id required")
        return
    val binding = session.window_surfaces.for_surface(surface_id)
    if binding == nil:
        _send_error(out, session_id, "UNKNOWN_SURFACE", "surface not registered")
        return
    val bridge = WmBridge.new(session)
    # Build a minimal WmInputEvent from the JSON event sub-object
    val event_json = _extract_object(frame, "event")
    val wm_event = _parse_wm_input_event(event_json)
    val result = bridge.handle_input(surface_id, widget_id, wm_event)
    match result:
        Err(_):
            _send_error(out, session_id, "CAP_DENIED", "InputInject capability denied")
        Ok(_):
            pass_do_nothing

fn _handle_window_cmd(frame: text, session: UISession, session_id: text, out: BoundedChannel<text>):
    val cmd_kind = extract_field(frame, "cmd_type")
    if cmd_kind == "":
        _send_error(out, session_id, "BAD_REQUEST", "cmd_type required")
        return
    val payload = _extract_object(frame, "payload")
    val bridge = WmBridge.new(session)
    val result = bridge.handle_window_cmd(cmd_kind, payload)
    match result:
        Err(_):
            _send_error(out, session_id, "CAP_DENIED", "window command capability denied")
        Ok(_):
            pass_do_nothing

# =========================================================================
# /ui/resume — HTTP POST resume
# =========================================================================

fn _handle_resume_route(stream: TcpStream, body: text, session: UISession):
    val session_id = _json_field(body, "session_id")
    val rev_str = _json_field(body, "snapshot_revision")
    val seq_str = _json_field(body, "last_sequence")
    val rev: u64 = if rev_str == "": 0 else: rev_str.parse_u64()
    val seq: i64 = if seq_str == "": 0 else: seq_str.parse_i64()
    val resp_json = "{\"session_id\": \"{session_id}\", \"snapshot_revision\": {rev}, \"last_sequence\": {seq}}"
    var resp = "HTTP/1.1 200 OK\r\n"
    resp = "{resp}Content-Type: application/json\r\n"
    resp = "{resp}Content-Length: {resp_json.len()}\r\n"
    resp = "{resp}Connection: close\r\n"
    resp = "{resp}\r\n"
    resp = "{resp}{resp_json}"
    stream.write_text(resp)

# =========================================================================
# Private helpers
# =========================================================================

fn _make_frame(msg_type: text, session_id: text, seq: text, payload: text) -> text:
    return "{\"t\": \"{msg_type}\", \"v\": 1, \"s\": \"{session_id}\", \"seq\": {seq}, \"payload\": {payload}}"

fn _send_error(out: BoundedChannel<text>, session_id: text, code: text, message: text):
    val payload = "{\"code\": \"{code}\", \"message\": \"{message}\", \"retry_after_ms\": 0}"
    val frame = _make_frame("error", session_id, "null", payload)
    out.send(frame)

fn _extract_bearer(headers: text) -> text:
    for line in headers.split("\n"):
        val trimmed = line.trim()
        if trimmed.to_lower().starts_with("authorization:"):
            val value = trimmed[14:].trim()
            if value.to_lower().starts_with("bearer "):
                return value[7:].trim()
    return ""

fn _json_field(json: text, field: text) -> text:
    val key = "\"{field}\":"
    val pos = json.find(key)
    if pos < 0:
        return ""
    val start = pos + key.len()
    if start >= json.len():
        return ""
    val first_ch = json[start]
    if first_ch == "\"":
        val inner = start + 1
        var end = inner
        while end < json.len() and json[end] != "\"":
            if json[end] == "\\":
                end = end + 1
            end = end + 1
        return json.slice(inner, end)
    var end = start
    while end < json.len():
        val ch = json[end]
        if ch == "," or ch == "}" or ch == "]":
            return json.slice(start, end).trim()
        end = end + 1
    return json.slice(start, json.len()).trim()

fn _extract_object(json: text, field: text) -> text:
    """Extract a nested JSON object for the given field key."""
    val key = "\"{field}\":"
    val pos = json.find(key)
    if pos < 0:
        return "{}"
    val after = pos + key.len()
    val brace = json.find_from("{", after)
    if brace < 0:
        return "{}"
    var depth = 0
    var i = brace
    while i < json.len():
        val ch = json[i]
        if ch == "{":
            depth = depth + 1
        elif ch == "}":
            depth = depth - 1
            if depth == 0:
                return json.slice(brace, i + 1)
        i = i + 1
    return "{}"

use common.window_protocol.window_protocol.{WmInputEvent}
use common.window_protocol.geometry.{WindowId, KeyCode, Modifiers, Point, WmEventType}

fn _parse_wm_input_event(event_json: text) -> WmInputEvent:
    val kind = _json_field(event_json, "kind")
    val key_code_str = _json_field(event_json, "key_code")
    val key_code_val: i32 = if key_code_str == "": 0 else: key_code_str.parse_i32()
    val event_type = match kind:
        "KeyDown": WmEventType(value: 1)
        "KeyUp":   WmEventType(value: 2)
        "MouseMove": WmEventType(value: 3)
        "MouseDown": WmEventType(value: 4)
        "MouseUp":   WmEventType(value: 5)
        _: WmEventType(value: 1)
    return WmInputEvent(
        window_id: WindowId(value: 0u64),
        event_type: event_type,
        key_code: KeyCode(value: key_code_val),
        mouse_pos: Point(x: 0, y: 0),
        modifiers: Modifiers(value: 0)
    )
