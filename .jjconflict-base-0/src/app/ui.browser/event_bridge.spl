#![allow(unnamed_duplicate_typed_args)]
# Browser Engine Event Bridge
#
# Maps raw system input events (keyboard, mouse, touch) to the
# platform-independent UIEvent enum used by the UI state machine.

use common.ui.widget.{UIEvent}
use common.layout.box_model.{LayoutBox}

# =========================================================================
# Key Event Translation
# =========================================================================

fn translate_key_event(key: i32, modifiers: i32) -> UIEvent?:
    """Translate a raw key code + modifier bitmask into a UIEvent.

    Modifier bits:
      0x01 = Shift
      0x02 = Ctrl
      0x04 = Alt
      0x08 = Meta/Super
    """
    val has_ctrl = (modifiers / 2) % 2 == 1

    # Ctrl+Q or Ctrl+C -> Quit
    if has_ctrl and (key == 113 or key == 99):
        return UIEvent.Quit

    # Escape (27) -> NormalMode
    if key == 27:
        return UIEvent.NormalMode

    # Tab (9) -> FocusNext, Shift+Tab -> FocusPrev
    if key == 9:
        val has_shift = modifiers % 2 == 1
        if has_shift:
            return UIEvent.FocusPrev
        return UIEvent.FocusNext

    # Enter (13) -> Action("enter")
    if key == 13:
        return UIEvent.Action(name: "enter")

    # Colon (58) -> CommandMode
    if key == 58:
        return UIEvent.CommandMode

    # 'i' (105) -> InsertMode
    if key == 105:
        return UIEvent.InsertMode

    # Arrow keys: map to key names
    if key == 37:
        return UIEvent.KeyPress(key: "left")
    if key == 38:
        return UIEvent.KeyPress(key: "up")
    if key == 39:
        return UIEvent.KeyPress(key: "right")
    if key == 40:
        return UIEvent.KeyPress(key: "down")

    # Printable ASCII range
    if key >= 32 and key <= 126:
        val ch = char_from_code(key)
        return UIEvent.KeyPress(key: ch)

    return nil

# =========================================================================
# Mouse Event Translation
# =========================================================================

fn translate_mouse_event(x: i32, y: i32, button: i32, action: text) -> UIEvent?:
    """Translate a raw mouse event into a UIEvent.

    action: "press", "release", "move"
    button: 0 = left, 1 = middle, 2 = right
    """
    match action:
        "press" =>
            if button == 0:
                return UIEvent.TouchPress(x: x, y: y)
            return nil
        "release" =>
            if button == 0:
                return UIEvent.TouchRelease(x: x, y: y)
            return nil
        "move" =>
            return UIEvent.TouchMove(x: x, y: y)
        _ =>
            return nil

# =========================================================================
# Hit Testing
# =========================================================================

fn hit_test(layout: LayoutBox, x: i32, y: i32) -> text?:
    """Find the widget id at pixel (x, y) by walking the layout tree.

    Returns the deepest (most specific) widget id that contains the point,
    or nil if no widget is hit.
    """
    val fx: f64 = x.to_f64()
    val fy: f64 = y.to_f64()
    return hit_test_recursive(layout, fx, fy)

fn hit_test_recursive(box: LayoutBox, fx: f64, fy: f64) -> text?:
    """Recursive hit test — returns deepest matching node id."""
    # Check if point is inside this box
    val inside = (fx >= box.x and fx < box.x + box.width
        and fy >= box.y and fy < box.y + box.height)

    if not inside:
        return nil

    # Check children in reverse order (last drawn = topmost = checked first)
    val child_list = box.children
    var i = child_list.len() - 1
    while i >= 0:
        val child = child_list[i]
        val child_hit = hit_test_recursive(child, fx, fy)
        if child_hit != nil:
            return child_hit
        i = i - 1

    # No child hit — this box is the target
    return "{box.node_id}"

# =========================================================================
# Helpers
# =========================================================================

fn char_from_code(code: i32) -> text:
    """Convert an ASCII code to a single-character text value."""
    # Common printable characters
    if code == 32: return " "
    if code == 33: return "!"
    if code == 34: return "\""
    if code == 35: return "#"
    if code == 36: return "$"
    if code == 37: return "%"
    if code == 38: return "&"
    if code == 39: return "'"
    if code == 40: return "("
    if code == 41: return ")"
    if code == 42: return "*"
    if code == 43: return "+"
    if code == 44: return ","
    if code == 45: return "-"
    if code == 46: return "."
    if code == 47: return "/"

    # Digits 0-9
    if code >= 48 and code <= 57:
        val digit = code - 48
        return "{digit}"

    if code == 58: return ":"
    if code == 59: return ";"
    if code == 60: return "<"
    if code == 61: return "="
    if code == 62: return ">"
    if code == 63: return "?"
    if code == 64: return "@"

    # Uppercase A-Z
    if code >= 65 and code <= 90:
        match code:
            65 => return "A"
            66 => return "B"
            67 => return "C"
            68 => return "D"
            69 => return "E"
            70 => return "F"
            71 => return "G"
            72 => return "H"
            73 => return "I"
            74 => return "J"
            75 => return "K"
            76 => return "L"
            77 => return "M"
            78 => return "N"
            79 => return "O"
            80 => return "P"
            81 => return "Q"
            82 => return "R"
            83 => return "S"
            84 => return "T"
            85 => return "U"
            86 => return "V"
            87 => return "W"
            88 => return "X"
            89 => return "Y"
            90 => return "Z"
            _ => return "?"

    if code == 91: return "["
    if code == 92: return "\\"
    if code == 93: return "]"
    if code == 94: return "^"
    if code == 95: return "_"
    if code == 96: return "`"

    # Lowercase a-z
    if code >= 97 and code <= 122:
        match code:
            97 => return "a"
            98 => return "b"
            99 => return "c"
            100 => return "d"
            101 => return "e"
            102 => return "f"
            103 => return "g"
            104 => return "h"
            105 => return "i"
            106 => return "j"
            107 => return "k"
            108 => return "l"
            109 => return "m"
            110 => return "n"
            111 => return "o"
            112 => return "p"
            113 => return "q"
            114 => return "r"
            115 => return "s"
            116 => return "t"
            117 => return "u"
            118 => return "v"
            119 => return "w"
            120 => return "x"
            121 => return "y"
            122 => return "z"
            _ => return "?"

    if code == 123: return "{"
    if code == 124: return "|"
    if code == 125: return "}"
    if code == 126: return "~"

    return "?"
