# Browser Renderer — GPU-accelerated DOM painting
#
# Renders a DomTree to a framebuffer using the browser example's paint pipeline.
# Supports text rendering, box model, borders, shadows, and compositing.

use examples.browser.entity.dom.node_types.{DomNode, NodeKind, Element, TextNode}
use examples.browser.entity.dom.css_types.{CSSRule, CSSDeclaration, CSSValue}
use examples.browser.entity.dom.box_types.{LayoutBox, BoxKind, BoxModel}
use examples.browser.entity.dom.paint_types.{PaintOp, DisplayList, DisplayItem}
use app.ui.browser.dom_bridge.{DomTree}
use common.ui.widget.{UIEvent}
use std.common.color.types.{Color, from_rgba}
use std.common.color.convert.{from_hex, from_name}

extern fn rt_sleep_ms(ms: i64)

# =========================================================================
# Framebuffer
# =========================================================================

class Framebuffer:
    width: i32
    height: i32
    pixels: [i64]

    static fn new(width: i32, height: i32) -> Framebuffer:
        val size = width * height
        var pixels: [i64] = []
        var i = 0
        while i < size:
            pixels = pixels.push(0)
            i = i + 1
        Framebuffer(width: width, height: height, pixels: pixels)

    me clear(color: i64):
        """Fill the entire framebuffer with a single color."""
        var i = 0
        val size = self.width * self.height
        while i < size:
            self.pixels[i] = color
            i = i + 1

    me set_pixel(x: i32, y: i32, color: i64):
        """Set a single pixel."""
        if x >= 0 and x < self.width and y >= 0 and y < self.height:
            val idx = y * self.width + x
            self.pixels[idx] = color

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: i64):
        """Fill a rectangle with a solid color."""
        var py = y
        while py < y + h and py < self.height:
            if py >= 0:
                var px = x
                while px < x + w and px < self.width:
                    if px >= 0:
                        val idx = py * self.width + px
                        self.pixels[idx] = color
                    px = px + 1
            py = py + 1

# =========================================================================
# Browser Renderer
# =========================================================================

class BrowserRenderer:
    width: i32
    height: i32
    framebuffer: Framebuffer
    display_list: DisplayList
    event_queue: [UIEvent]
    active: bool

    static fn new(width: i32, height: i32) -> BrowserRenderer:
        BrowserRenderer(
            width: width,
            height: height,
            framebuffer: Framebuffer.new(width, height),
            display_list: DisplayList.empty(),
            event_queue: [],
            active: true
        )

    me render_dom(dom_tree: DomTree):
        """Full render pipeline: layout -> paint -> composite."""
        # Step 1: Build layout boxes from DOM + CSS rules
        val layout_root = self.build_layout(dom_tree)

        # Step 2: Paint layout boxes into display list
        var ops: [PaintOp] = []
        ops = self.paint_layout_box(layout_root, ops)
        self.display_list = DisplayList(ops: ops)

        # Step 3: Composite display list to framebuffer
        self.composite()

    fn build_layout(dom_tree: DomTree) -> LayoutBox:
        """Build a layout tree from DOM elements and CSS rules.

        Assigns positions and sizes to each element using a simplified
        block-flow layout algorithm.
        """
        var root_box = LayoutBox.create(0, BoxKind.Block)
        root_box.width = self.width.to_f64()
        root_box.height = self.height.to_f64()

        var y_cursor = 0.0
        for elem in dom_tree.elements:
            var child_box = LayoutBox.create(elem.node_id, BoxKind.Block)

            # Apply CSS from matching rules
            val style = self.resolve_style(elem, dom_tree.css_rules)
            child_box.box_model = style.box_model
            child_box.x = style.box_model.margin_left + style.box_model.padding_left
            child_box.y = y_cursor + style.box_model.margin_top
            child_box.width = root_box.width - child_box.x - style.box_model.margin_right - style.box_model.padding_right
            child_box.height = style.height

            y_cursor = child_box.y + child_box.height + style.box_model.margin_bottom + style.box_model.padding_bottom

            root_box.children = root_box.children.push(child_box)

        return root_box

    fn resolve_style(elem: Element, rules: [CSSRule]) -> ResolvedStyle:
        """Resolve CSS properties for an element against the rule set."""
        var style = ResolvedStyle.default()

        for rule in rules:
            if selector_matches(rule.selector, elem):
                for decl in rule.declarations:
                    self.apply_declaration(style, decl)

        return style

    fn apply_declaration(style: ResolvedStyle, decl: CSSDeclaration) -> ResolvedStyle:
        """Apply a single CSS declaration to a resolved style."""
        match decl.property:
            "margin" | "margin-top":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.margin_top = v
                    _: pass_dn
            "margin-bottom":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.margin_bottom = v
                    _: pass_dn
            "margin-left":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.margin_left = v
                    _: pass_dn
            "margin-right":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.margin_right = v
                    _: pass_dn
            "padding" | "padding-top":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.padding_top = v
                    _: pass_dn
            "padding-bottom":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.padding_bottom = v
                    _: pass_dn
            "padding-left":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.padding_left = v
                    _: pass_dn
            "padding-right":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.padding_right = v
                    _: pass_dn
            "height":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.height = v
                    _: pass_dn
            "width":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.width = v
                    _: pass_dn
            "background-color" | "background":
                match decl.value:
                    CSSValue.Keyword(v):
                        style.bg_color = color_from_keyword(v)
                    CSSValue.Color(c):
                        style.bg_color = c
                    _: pass_dn
            "color":
                match decl.value:
                    CSSValue.Keyword(v):
                        style.fg_color = color_from_keyword(v)
                    CSSValue.Color(c):
                        style.fg_color = c
                    _: pass_dn
            "font-size":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.font_size = v
                    _: pass_dn
            "border-width":
                match decl.value:
                    CSSValue.Length(v, _):
                        style.box_model.border_top = v
                        style.box_model.border_right = v
                        style.box_model.border_bottom = v
                        style.box_model.border_left = v
                    _: pass_dn
            _:
                pass_dn

        return style

    fn paint_layout_box(box: LayoutBox, ops: [PaintOp]) -> [PaintOp]:
        """Paint a layout box and its children into paint operations."""
        var result = ops

        # Paint background
        val bg_color = from_rgba(255, 255, 255, 255)
        if box.width > 0.0 and box.height > 0.0:
            result = result.push(PaintOp.FillRect(
                x: box.x, y: box.y, w: box.width, h: box.height,
                color: bg_color
            ))

        # Paint borders if present
        val bm = box.box_model
        if bm.border_top > 0.0 or bm.border_right > 0.0 or bm.border_bottom > 0.0 or bm.border_left > 0.0:
            val border_widths = [bm.border_top, bm.border_right, bm.border_bottom, bm.border_left]
            val border_color = from_rgba(0, 0, 0, 255)
            val border_colors = [border_color, border_color, border_color, border_color]
            result = result.push(PaintOp.DrawBorder(
                x: box.x, y: box.y, w: box.width, h: box.height,
                widths: border_widths, colors: border_colors
            ))

        # Paint children
        for child in box.children:
            result = self.paint_layout_box(child, result)

        return result

    me composite():
        """Composite the display list to the framebuffer."""
        # Clear to white
        self.framebuffer.clear(0xFFFFFFFF)

        for op in self.display_list.ops:
            match op:
                PaintOp.FillRect(x, y, w, h, color):
                    val c = color_to_i64(color)
                    self.framebuffer.fill_rect(
                        x.to_i32(), y.to_i32(),
                        w.to_i32(), h.to_i32(), c
                    )
                PaintOp.DrawText(x, y, text_content, font_size, color):
                    # Text rendering: each character is a small filled rect
                    val c = color_to_i64(color)
                    val char_w = (font_size * 0.6).to_i32()
                    val char_h = font_size.to_i32()
                    var cx = x.to_i32()
                    var i = 0
                    while i < text_content.len():
                        self.framebuffer.fill_rect(cx, y.to_i32(), char_w, char_h, c)
                        cx = cx + char_w + 1
                        i = i + 1
                PaintOp.DrawBorder(x, y, w, h, widths, colors):
                    val c = if colors.len() > 0:
                        color_to_i64(colors[0])
                    else:
                        0xFF000000
                    val bw = if widths.len() > 0: widths[0].to_i32() else: 1
                    # Top border
                    self.framebuffer.fill_rect(x.to_i32(), y.to_i32(), w.to_i32(), bw, c)
                    # Bottom border
                    self.framebuffer.fill_rect(x.to_i32(), (y + h).to_i32() - bw, w.to_i32(), bw, c)
                    # Left border
                    self.framebuffer.fill_rect(x.to_i32(), y.to_i32(), bw, h.to_i32(), c)
                    # Right border
                    self.framebuffer.fill_rect((x + w).to_i32() - bw, y.to_i32(), bw, h.to_i32(), c)
                _:
                    pass_dn

    fn poll_event() -> UIEvent?:
        """Poll for the next UI event."""
        if self.event_queue.len() > 0:
            val event = self.event_queue[0]
            self.event_queue = self.event_queue[1:]
            return event
        return nil

    me push_event(event: UIEvent):
        """Queue a UI event for processing."""
        self.event_queue = self.event_queue.push(event)

    me shutdown():
        """Clean up renderer resources."""
        self.active = false

# =========================================================================
# Resolved Style
# =========================================================================

class ResolvedStyle:
    box_model: BoxModel
    width: f64
    height: f64
    bg_color: Color
    fg_color: Color
    font_size: f64

    static fn default() -> ResolvedStyle:
        ResolvedStyle(
            box_model: BoxModel.zero(),
            width: 0.0,
            height: 24.0,
            bg_color: from_rgba(255, 255, 255, 255),
            fg_color: from_rgba(0, 0, 0, 255),
            font_size: 14.0
        )

# =========================================================================
# Helpers
# =========================================================================

fn selector_matches(selector: examples.browser.entity.dom.css_types.Selector, elem: Element) -> bool:
    """Check if a CSS selector matches an element."""
    for part in selector.parts:
        match part:
            SelectorPart.Type(name):
                if name == elem.tag_name:
                    return true
            SelectorPart.Class(name):
                for attr in elem.attributes:
                    if attr.name == "class" and attr.value == name:
                        return true
            SelectorPart.Id(name):
                for attr in elem.attributes:
                    if attr.name == "id" and attr.value == name:
                        return true
            SelectorPart.Universal:
                return true
            _:
                pass_dn
    return false

fn color_to_i64(color: Color) -> i64:
    """Pack RGBA color into a 32-bit integer (0xAARRGGBB)."""
    val r = color.r.to_i64()
    val g = color.g.to_i64()
    val b = color.b.to_i64()
    val a = color.a.to_i64()
    return (a * 16777216) + (r * 65536) + (g * 256) + b

fn color_from_keyword(name: text) -> Color:
    """Resolve a CSS color keyword or hex value to a Color."""
    if name.starts_with("#"):
        return from_hex(name)
    match name:
        "white":
            return from_rgba(255, 255, 255, 255)
        "black":
            return from_rgba(0, 0, 0, 255)
        "red":
            return from_rgba(255, 0, 0, 255)
        "green":
            return from_rgba(0, 128, 0, 255)
        "blue":
            return from_rgba(0, 0, 255, 255)
        "gray" | "grey":
            return from_rgba(128, 128, 128, 255)
        "transparent":
            return from_rgba(0, 0, 0, 0)
        _:
            return from_name(name)
