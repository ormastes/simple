# SReplay — simple qemu CLI
#
# Usage:
#   simple qemu record --arch x86_64 --kernel boot.elf --trace boot.srrq
#   simple qemu replay --arch x86_64 --kernel boot.elf --trace boot.srrq
#   simple qemu checkpoint save <name>
#   simple qemu checkpoint restore <name>
#   simple qemu checkpoint list
#   simple qemu status

use std.io.{shell}
use app.qemu.commands.{cmd_record, cmd_replay, cmd_checkpoint, cmd_status}

fn main(args: [text]):
    if args.len() < 1:
        print_usage()
        return

    val subcmd = args[0]
    var rest: [text] = []
    var i = 1
    while i < args.len():
        rest.push(args[i])
        i = i + 1

    match subcmd:
        "record":
            cmd_record(rest)
        "replay":
            cmd_replay(rest)
        "checkpoint":
            cmd_checkpoint(rest)
        "status":
            cmd_status(rest)
        "help":
            print_usage()
        _:
            print "[sreplay] Unknown subcommand: {subcmd}"
            print_usage()

fn print_usage():
    print "SReplay — QEMU deterministic replay debugger"
    print ""
    print "Usage:"
    print "  simple qemu record   --arch <arch> --kernel <elf> --trace <file>"
    print "  simple qemu replay   --arch <arch> --kernel <elf> --trace <file>"
    print "  simple qemu checkpoint save|restore|list <name>"
    print "  simple qemu status"
    print ""
    print "Architectures: x86_64, i386, riscv32, riscv64, aarch64, arm32"
    print ""
    print "Record captures a deterministic execution trace."
    print "Replay replays it with GDB reverse-debug support."
