#![allow(unnamed_duplicate_typed_args)]
# Assistant Dashboard Sessions Subview

use app.dashboard.assistant_collectors.{AssistantDashboardSnapshot}
use app.dashboard.views.assistant_common.{
    assistant_plain_source, assistant_plain_state, assistant_render_limit,
    assistant_short_id, assistant_short_text, assistant_session_badge,
    assistant_source_badge
}
use app.ui.render.table.{render_html_table_limited}
use app.ui.render.types.{RenderConfig}

fn assistant_sessions_text(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    var out = "{BOLD}Sessions{RESET}\n"
    if snapshot.sessions.len() == 0:
        out = "{out}  No assistant sessions found.\n"
        return out

    val limit = assistant_render_limit(config, snapshot.sessions.len())
    var i = 0
    for session in snapshot.sessions:
        if i >= limit:
            break
        out = "{out}  - {assistant_short_id(session.session_id)} | {assistant_plain_state(session.session_state)} | {assistant_plain_source(session.source_state)} | {assistant_short_id(session.parent_session_id)} | {assistant_short_text(session.title, 34)} | {session.turn_count} | {assistant_short_text(session.last_event_detail, 28)}\n"
        i = i + 1

    out

fn assistant_sessions_html(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    if snapshot.sessions.len() == 0:
        return "<div class=\"card\" style=\"margin-top:12px\"><div class=\"section-title\">Sessions</div><div class=\"empty-state\">No assistant sessions found.</div></div>"

    var rows: [[text]] = []
    val limit = assistant_render_limit(config, snapshot.sessions.len())
    var i = 0
    for session in snapshot.sessions:
        if i >= limit:
            break
        rows.push([
            assistant_short_id(session.session_id),
            assistant_session_badge(session.session_state),
            assistant_source_badge(session.source_state),
            assistant_short_id(session.parent_session_id),
            assistant_short_text(session.title, 42),
            "{session.children.len()}",
            assistant_short_text(session.last_event_detail, 32)
        ])
        i = i + 1

    var h = "<div class=\"card\" style=\"margin-top:12px\">"
    h = "{h}<div class=\"section-title\">Sessions <span class=\"count\">{snapshot.sessions.len()}</span></div>"
    h = "{h}{render_html_table_limited([\"Session\", \"State\", \"Source\", \"Parent\", \"Title\", \"Children\", \"Last Event\"], rows, 24)}"
    h = "{h}</div>"
    h
