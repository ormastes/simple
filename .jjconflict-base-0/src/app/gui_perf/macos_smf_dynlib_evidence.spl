#[runtime_intrinsics]
# macOS arm64 SMF/dynlib evidence runner.

use app.gui_perf.macos_smf_dynlib_evidence_core.{
    gui_mac_smf_dynlib_default_paths,
    gui_mac_smf_dynlib_host_supported,
    gui_mac_smf_dynlib_skip_row,
    gui_mac_smf_dynlib_compile_dynlib_command,
    gui_mac_smf_dynlib_compile_wrapper_command,
    gui_mac_smf_dynlib_compile_probe_command,
    gui_mac_smf_dynlib_wrap_command,
    gui_mac_smf_dynlib_contract_command,
    gui_mac_smf_dynlib_qemu_parity_command,
    gui_mac_smf_dynlib_qemu_loader_parity_command,
    gui_mac_smf_dynlib_probe_command_with_host,
    gui_mac_smf_dynlib_select_stdout_row,
    gui_mac_smf_dynlib_row_value,
    gui_mac_smf_dynlib_accepts_contract_row,
    gui_mac_smf_dynlib_accepts_qemu_parity_row,
    gui_mac_smf_dynlib_accepts_qemu_loader_parity_row,
    gui_mac_smf_dynlib_accepts_probe_row,
    gui_mac_smf_dynlib_accepts_transcript,
    gui_mac_smf_dynlib_pass_row
}
use std.io_runtime.{env_get}
use std.nogc_sync_mut.io_runtime.{platform_name}
use app.io.mod.{process_run_timeout}

fn _env_or(key: text, fallback: text) -> text:
    val value = env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _shell(command: text, timeout_ms: i64) -> (text, text, i32):
    process_run_timeout("/bin/sh", ["-c", command], timeout_ms)

fn _host_arch() -> text:
    val env_arch = _env_or("SIMPLE_GUI_DYNLIB_ARCH", "")
    if env_arch != "":
        return env_arch
    val (stdout, _stderr, code) = process_run_timeout("uname", ["-m"], 5000)
    if code != 0:
        return ""
    stdout.trim()

fn _host_cpu(arch: text) -> text:
    val env_cpu = _env_or("SIMPLE_GUI_DYNLIB_HOST_CPU", "")
    if env_cpu != "":
        return env_cpu
    val (stdout, _stderr, code) = process_run_timeout("sysctl", ["-n", "machdep.cpu.brand_string"], 5000)
    if code == 0 and stdout.trim() != "":
        return stdout.trim()
    "unknown"

fn _run_step(name: text, command: text, timeout_ms: i64) -> bool:
    val (_stdout, stderr, code) = _shell(command, timeout_ms)
    if code != 0:
        print "GUI_MAC_SMF_DYNLIB_EVIDENCE status=fail step=" + name + " exit_code=" + code.to_text() + " stderr=" + stderr.replace("\n", " ").trim()
        return false
    true

fn main() -> i64:
    val host_os = platform_name()
    val arch = _host_arch()
    if not gui_mac_smf_dynlib_host_supported(host_os, arch):
        print gui_mac_smf_dynlib_skip_row(host_os, arch)
        return 0

    val host_profile = "macos-arm64"
    val host_cpu = _host_cpu(arch)
    val simple_bin = _env_or("SIMPLE_BIN", "src/compiler_rust/target/debug/simple")
    val paths = gui_mac_smf_dynlib_default_paths(simple_bin)
    if not _run_step("mkdir", "mkdir -p build/gui", 5000):
        return 1
    if not _run_step("compile-dynlib", gui_mac_smf_dynlib_compile_dynlib_command(paths), 120000):
        return 1
    if not _run_step("compile-wrapper", gui_mac_smf_dynlib_compile_wrapper_command(paths), 120000):
        return 1
    if not _run_step("compile-probe", gui_mac_smf_dynlib_compile_probe_command(paths), 120000):
        return 1
    if not _run_step("wrap-smf", gui_mac_smf_dynlib_wrap_command(paths), 30000):
        return 1

    var transcript = ""
    val (contract_out, contract_err, contract_code) = _shell(gui_mac_smf_dynlib_contract_command(paths), 30000)
    val contract_row = gui_mac_smf_dynlib_select_stdout_row(contract_out, "GUI_SMF_ARTIFACT_CONTRACT")
    if contract_row != "":
        print contract_row
        transcript = transcript + contract_row + "\n"
    if contract_code != 0 or not gui_mac_smf_dynlib_accepts_contract_row(contract_row):
        print "GUI_MAC_SMF_DYNLIB_EVIDENCE status=fail step=contract-smf exit_code=" + contract_code.to_text() + " stderr=" + contract_err.replace("\n", " ").trim()
        return 1

    val (qemu_out, qemu_err, qemu_code) = _shell(gui_mac_smf_dynlib_qemu_parity_command(paths), 30000)
    val qemu_row = gui_mac_smf_dynlib_select_stdout_row(qemu_out, "GUI_QEMU_ARM64_SMF_PARITY")
    if qemu_row != "":
        print qemu_row
        transcript = transcript + qemu_row + "\n"
    if qemu_code != 0 or not gui_mac_smf_dynlib_accepts_qemu_parity_row(qemu_row):
        print "GUI_MAC_SMF_DYNLIB_EVIDENCE status=fail step=qemu-parity-contract exit_code=" + qemu_code.to_text() + " stderr=" + qemu_err.replace("\n", " ").trim()
        return 1

    val (loader_qemu_out, loader_qemu_err, loader_qemu_code) = _shell(gui_mac_smf_dynlib_qemu_loader_parity_command(paths), 30000)
    val loader_qemu_row = gui_mac_smf_dynlib_select_stdout_row(loader_qemu_out, "GUI_QEMU_ARM64_SMF_LOADER_PARITY")
    if loader_qemu_row != "":
        print loader_qemu_row
        transcript = transcript + loader_qemu_row + "\n"
    if loader_qemu_code != 0 or not gui_mac_smf_dynlib_accepts_qemu_loader_parity_row(loader_qemu_row):
        print "GUI_MAC_SMF_DYNLIB_EVIDENCE status=fail step=qemu-loader-parity-contract exit_code=" + loader_qemu_code.to_text() + " stderr=" + loader_qemu_err.replace("\n", " ").trim()
        return 1

    val (probe_out, probe_err, probe_code) = _shell(gui_mac_smf_dynlib_probe_command_with_host(paths, host_profile, host_cpu), 30000)
    val row = gui_mac_smf_dynlib_select_stdout_row(probe_out, "GUI_DYNLIB_PERF")
    if row != "":
        print row
        transcript = transcript + row + "\n"
    if probe_code != 0 or not gui_mac_smf_dynlib_accepts_probe_row(row):
        print "GUI_MAC_SMF_DYNLIB_EVIDENCE status=fail step=probe exit_code=" + probe_code.to_text() + " stderr=" + probe_err.replace("\n", " ").trim()
        return 1
    val pass_row = gui_mac_smf_dynlib_pass_row(
        host_os,
        arch,
        host_profile,
        host_cpu,
        paths.smf_path,
        gui_mac_smf_dynlib_row_value(contract_row, "sha256"),
        gui_mac_smf_dynlib_row_value(contract_row, "size")
    )
    transcript = transcript + pass_row + "\n"
    if not gui_mac_smf_dynlib_accepts_transcript(transcript):
        print "GUI_MAC_SMF_DYNLIB_EVIDENCE status=fail step=transcript reason=incomplete-or-out-of-order-smf-dynlib-chain"
        return 1
    print pass_row
    0
