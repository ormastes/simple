# TUI Web Render Backend
#
# Implements RenderBackend concepts for the TUI-over-web proxy.
# Renders UIState to a Screen buffer, then converts the ANSI output
# to HTML using screen_to_html. Events are injected via push_event
# and polled from an internal queue.

use common.ui.widget.{UIState, UIEvent, WidgetNode, WidgetRect}
use common.ui.capability.{Capability}
use common.ui.layout.{compute_layout}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree, render_html_tree}
use app.ui.tui_web.screen_to_html.{screen_to_html}

# =========================================================================
# TUI Web Backend
# =========================================================================

class TuiWebBackend:
    width: i32
    height: i32
    initialized: bool
    current_html: text
    event_queue: [UIEvent]

    static fn new() -> TuiWebBackend:
        """Create a TUI web backend with a fixed 120x40 virtual terminal."""
        return TuiWebBackend(
            width: 120,
            height: 40,
            initialized: false,
            current_html: "",
            event_queue: []
        )

    # --- Lifecycle ---

    me init() -> Result<bool, text>:
        """Initialize the backend. No alt screen needed since headless."""
        self.initialized = true
        return Ok(true)

    me shutdown():
        """Shutdown the backend."""
        self.initialized = false

    # --- Rendering ---

    me render(state: UIState) -> Result<bool, text>:
        """Render UIState to Screen buffer, then convert to HTML via screen_to_html."""
        var screen = Screen.new(self.width, self.height)

        # Compute layout
        val rects = compute_layout(state.tree.root_node(), 0, 0, self.width, self.height)

        # Render widget tree to screen buffer
        screen = render_tui_tree(screen, state.tree.root_node(), rects, state)

        # Convert ANSI screen output to HTML
        val rendered = screen.render()
        self.current_html = screen_to_html(rendered)

        return Ok(true)

    fn render_html(state: UIState) -> text:
        """Render UIState directly to HTML tree (non-TUI style)."""
        return render_html_tree(state.tree.root_node(), state)

    # --- Events ---

    me push_event(event: UIEvent):
        """Add an event to the internal queue."""
        self.event_queue = self.event_queue + [event]

    me poll_event(timeout_ms: i32) -> UIEvent?:
        """Pop the next event from the queue, or return nil if empty."""
        if self.event_queue.len() == 0:
            return nil
        val event = self.event_queue[0]
        # Remove first element by rebuilding the list
        var new_queue: [UIEvent] = []
        var i = 1
        while i < self.event_queue.len():
            new_queue = new_queue + [self.event_queue[i]]
            i = i + 1
        self.event_queue = new_queue
        return event

    # --- Capabilities ---

    fn capabilities() -> [Capability]:
        return [Capability.Color]

    fn supports_mouse() -> bool:
        return false

    fn supports_color() -> bool:
        return true

    fn supports_images() -> bool:
        return false

    fn supports_touch() -> bool:
        return false

    # --- Viewport ---

    fn viewport_width() -> i32:
        return self.width

    fn viewport_height() -> i32:
        return self.height

    # --- Backend Info ---

    fn backend_name() -> text:
        return "tui_web"
