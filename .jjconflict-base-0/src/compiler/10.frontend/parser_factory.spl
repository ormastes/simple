# Parser Factory - Convenience constructor functions for Parser
#
# The Parser struct has no static fn new() since the constructor logic
# requires cross-module dependencies (lexer_create_internal, p_advance).
# These functions provide the canonical way to construct a Parser.

use lexer.*
use parser_types.*
use parser.*
use compiler.frontend.block_types.{LexerMode}

fn create_parser(src: text) -> Parser:
    """Create a Parser from source text."""
    var p = Parser(
        source: src,
        lexer: lexer_create_internal(src, nil),
        current: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        previous: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        errors: [],
        outline: nil,
        resolved_blocks: nil
    )
    p_advance(p)
    p

fn parser_with_resolved_blocks(src: text, resolved: any) -> Parser:
    """Create a Parser from source text with pre-resolved blocks."""
    var p = Parser(
        source: src,
        lexer: lexer_create_internal(src, nil),
        current: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        previous: Token(kind: TokenKind.Eof, span: Span(start: 0, end: 0, line: 1, col: 0), text: ""),
        errors: [],
        outline: nil,
        resolved_blocks: resolved
    )
    p_advance(p)
    p
