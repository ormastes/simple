# Block Resolver - Stub implementations (real code in .smf binary)

use compiler.blocks.registry.{BlockRegistry}

class BlockResolver:
    registry: BlockRegistry

    static fn new(registry: BlockRegistry) -> BlockResolver:
        BlockResolver(registry: registry)

struct ResolvedModule:
    name: text
    path: text

struct ResolutionResult:
    ok: bool
    message: text

fn resolve_blocks(source: text, registry: BlockRegistry) -> ResolutionResult:
    ResolutionResult(ok: true, message: "")

fn resolve_blocks_with_registry(source: text, registry: BlockRegistry) -> ResolutionResult:
    ResolutionResult(ok: true, message: "")

fn make_block_resolver(registry: BlockRegistry) -> BlockResolver:
    BlockResolver(registry: registry)

export BlockResolver, ResolvedModule, ResolutionResult
export resolve_blocks, resolve_blocks_with_registry, make_block_resolver
