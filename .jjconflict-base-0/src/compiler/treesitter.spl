# Top-level TreeSitter facade.
#
# The repo treats `compiler.treesitter` as the stable import path, while the
# implementation lives under `compiler.frontend`. Re-export the frontend surface
# here so both compiler and interpreter resolve the same package path.

export use compiler.frontend.treesitter.{
    OutlineModule, ImportOutline, ExportOutline, BlockOutline, AsmBlockOutline,
    FunctionOutline, ParamOutline, ClassOutline, StructOutline, FieldOutline,
    EnumOutline, VariantOutline, VariantPayload,
    BitfieldOutline, BitfieldFieldOutline,
    TraitOutline, ImplOutline, AssocTypeDeclOutline, TypeAliasOutline, ConstOutline, StaticAssertOutline,
    TypeParamOutline, TypeOutline, TypeOutlineKind,
    ParseError, ErrorSeverity, TreeSitter,
    HeuristicOutlineKind, HeuristicOutlineItem, HeuristicParseResult
}

export use compiler.frontend.treesitter_types.{
    OutlineModule, BlockOutline, AsmBlockOutline, ImportOutline, ExportOutline,
    FunctionOutline, ParamOutline,
    ClassOutline, StructOutline, FieldOutline, AttributeOutline,
    EnumOutline, VariantOutline, VariantPayload,
    BitfieldOutline, BitfieldFieldOutline,
    TraitOutline, ImplOutline, AssocTypeDeclOutline, TypeAliasOutline, ConstOutline, StaticAssertOutline,
    TypeParamOutline, TypeOutline, TypeOutlineKind,
    ParseError
}
