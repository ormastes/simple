# VHDL DSP Templates — operation metadata for DSP inference.

use compiler.backend.vhdl.vhdl_target_profile.{VhdlTargetProfile}

enum VhdlDspOperation:
    Multiply
    MultiplyAdd
    MultiplyAccumulate
    DotProduct

struct VhdlDspTemplate:
    name: text
    operation: VhdlDspOperation
    input_width: i32
    accumulator_width: i32
    signed_operands: bool
    binding: text
    latency_cycles: i32
    attribute_text: text

fn vhdl_dsp_binding(profile: VhdlTargetProfile, prefer_dsp: bool) -> text:
    if not prefer_dsp:
        return "lut"
    if profile.dsp_template_style == "xilinx":
        return "dsp48"
    if profile.dsp_template_style == "intel":
        return "dsp-block"
    if profile.dsp_template_style == "standard-cell":
        return "mul-cell"
    return "dsp"

fn vhdl_dsp_attribute(profile: VhdlTargetProfile, binding: text) -> text:
    if binding == "lut":
        return ""
    if profile.attribute_style == "xilinx":
        return "attribute use_dsp : string; attribute use_dsp of <signal> : signal is \"yes\";"
    if profile.attribute_style == "intel":
        return "attribute multstyle : string; attribute multstyle of <signal> : signal is \"dsp\";"
    if profile.attribute_style == "yosys":
        return "attribute keep : boolean; attribute keep of <signal> : signal is true;"
    return ""

fn vhdl_multiply_template(profile: VhdlTargetProfile, name: text, width: i32, prefer_dsp: bool) -> VhdlDspTemplate:
    val binding = vhdl_dsp_binding(profile, prefer_dsp)
    VhdlDspTemplate(
        name: name,
        operation: Multiply,
        input_width: width,
        accumulator_width: width * 2,
        signed_operands: false,
        binding: binding,
        latency_cycles: 1,
        attribute_text: vhdl_dsp_attribute(profile, binding)
    )

fn vhdl_mac_template(profile: VhdlTargetProfile, name: text, width: i32, accumulator_width: i32, prefer_dsp: bool) -> VhdlDspTemplate:
    val binding = vhdl_dsp_binding(profile, prefer_dsp)
    VhdlDspTemplate(
        name: name,
        operation: MultiplyAccumulate,
        input_width: width,
        accumulator_width: accumulator_width,
        signed_operands: false,
        binding: binding,
        latency_cycles: 2,
        attribute_text: vhdl_dsp_attribute(profile, binding)
    )

fn vhdl_dot_product_template(profile: VhdlTargetProfile, name: text, width: i32, accumulator_width: i32, prefer_dsp: bool) -> VhdlDspTemplate:
    val binding = vhdl_dsp_binding(profile, prefer_dsp)
    VhdlDspTemplate(
        name: name,
        operation: DotProduct,
        input_width: width,
        accumulator_width: accumulator_width,
        signed_operands: false,
        binding: binding,
        latency_cycles: 3,
        attribute_text: vhdl_dsp_attribute(profile, binding)
    )
