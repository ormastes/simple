# BYL Verification Model Backend
#
# BYL is a small generated proof-model IR. It is intentionally simpler than
# Lean: generated tools can replace BYL/Generated.lean, while manual Lean
# constraints import the generated surface and remain stable across code changes.

use compiler.mir.mir_data.{MirModule}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileError}
use compiler.backend.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}

class BylBackend:
    """Generated BYL proof-model backend."""
    module_prefix: text

    static fn create() -> BylBackend:
        BylBackend(module_prefix: "Simple")

fn byl_export_module(module_prefix: text, module: MirModule) -> text:
    var lines: [text] = []
    lines = lines.push("byl_version = \"0.1\"")
    lines = lines.push("schema = \"simple.proof_model\"")
    lines = lines.push("module = \"{module_prefix}.{module.name}\"")
    lines = lines.push("generated_surface = \"byl\"")
    lines = lines.push("manual_constraints = \"external\"")
    return lines.join("\n")

impl Codegen for BylBackend:
    fn backend_kind() -> BackendKind: BackendKind.Byl
    fn backend_name() -> text: "byl"
    fn supports_target(target: CodegenTarget) -> bool:
        val _ = target
        true
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.TextSource

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        Ok(CodegenOutput.text(module.name, byl_export_module(self.module_prefix, module)))
