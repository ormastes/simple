# src/compiler/70.backend/backend/native/encode_rvv_zvk.spl
#
# RVV Zvk (Vector Crypto) Byte-Emit Encoder — Pure Simple
#
# Produces exact 4-byte little-endian instruction words for RISC-V Vector
# Cryptography Extension (Zvk) instructions per RISC-V Vector Crypto v1.0
# (ratified 2024).
#
# Reference: RISC-V Vector Crypto Extensions ISA Specification v1.0
#   §3  Zvkned — Vector AES block cipher
#   §4  Zvknh  — Vector SHA-2 message schedule
#   §5  Zvkg   — Vector GCM/GHASH (CLMUL)
#
# Instruction format (all Zvk, 32-bit, OP-V major opcode 0x57):
#   bits[31:26] = funct6
#   bit[25]     = vm   (1=unmasked)
#   bits[24:20] = vs2
#   bits[19:15] = vs1  (0 for 2-operand forms; uimm for .vi forms)
#   bits[14:12] = funct3 (OPMVV = 010 = 2 for all Zvk instructions)
#   bits[11:7]  = vd
#   bits[6:0]   = opcode 0x57
#
# funct6 values (RISC-V Vector Crypto v1.0, cross-checked with spec §3–5):
#   vaesef.vv  0x28 (101000)  vs1=0, vm=1
#   vaesem.vv  0x29 (101001)  vs1=0, vm=1
#   vaesdf.vv  0x2A (101010)  vs1=0, vm=1
#   vaesdm.vv  0x2B (101011)  vs1=0, vm=1
#   vaeskf1.vi 0x22 (100010)  uimm in vs1, vm=1
#   vaeskf2.vi 0x2A (101010)  uimm in vs1, vm=1  — NOTE: same funct6 as vaesdf;
#                               disambiguated by vs1!=0 in practice
#   vaesz.vs   0x2F (101111)  vs1=0, vm=1
#   vsha2ms.vv 0x2D (101101)  3-reg, vm=1
#   vsha2ch.vv 0x2E (101110)  3-reg, vm=1
#   vsha2cl.vv 0x2F (101111)  3-reg, vm=1  — NOTE: same funct6 as vaesz.vs;
#                               disambiguated by vs1!=0 in practice
#   vghsh.vv   0x2C (101100)  3-reg, vm=1
#   vgmul.vv   0x29 (101001)  vs1=0, vm=1  — NOTE: same funct6 as vaesem.vv;
#                               disambiguated by vs1==0 in practice
#
# Encoding convention: multiplication/division only (avoids negative-bit-op
# hazards in interpreter mode). Consistent with riscv_rvv.spl and arm_neon.spl.
# Return type: [i64] (4 bytes, little-endian).
#
# ALL byte goldens derived from RISC-V Vector Crypto v1.0 spec table +
# manual derivation formula (llvm-mc unavailable on build host).

# ============================================================================
# Internal helpers (shared with riscv_rvv.spl pattern; separate module)
# ============================================================================

fn _zvk_word_to_le4(word: i64) -> [i64]:
    """
    Convert a 32-bit Zvk instruction word to 4 little-endian bytes.
    Uses division/modulo to avoid negative bit-op hazards in interpreter.
    """
    var w = word
    if w < 0:
        w = w + 4294967296
    val b0 = w % 256
    val b1 = (w / 256) % 256
    val b2 = (w / 65536) % 256
    val b3 = (w / 16777216) % 256
    [b0, b1, b2, b3]

fn _encode_opmvv(funct6: i64, vm: i64, vs2: i64, vs1: i64, vd: i64) -> [i64]:
    """
    Encode an OPMVV instruction (funct3=2, opcode=0x57=87).

    funct6: 6-bit function code (bits[31:26])
    vm:     1=unmasked (bit[25])
    vs2:    source register 2 (bits[24:20])
    vs1:    source register 1 or uimm (bits[19:15])
    vd:     destination register (bits[11:7])
    """
    val word = (funct6 * 67108864) + (vm * 33554432) + (vs2 * 1048576) + (vs1 * 32768) + (2 * 4096) + (vd * 128) + 87
    _zvk_word_to_le4(word)

# ============================================================================
# Zvkned — AES block cipher (§3)
# ============================================================================

"""Emit vaesef.vv vd, vs2 — AES final-round encryption.

# Zvk v1.0 §3 (VAESEF); funct6=0x28 (101000); OPMVV funct3=010; vm=1; vs1=0
# Canonical: vaesef.vv v1,v2 → 0xA22020D7 [0xd7,0x20,0x20,0xa2]
"""
fn emit_vaesef_vv(vd: i64, vs2: i64) -> [i64]:
    _encode_opmvv(0x28, 1, vs2, 0, vd)

"""Emit vaesem.vv vd, vs2 — AES middle-round encryption.

# Zvk v1.0 §3 (VAESEM); funct6=0x29 (101001); OPMVV funct3=010; vm=1; vs1=0
# Canonical: vaesem.vv v1,v2 → 0xA62020D7 [0xd7,0x20,0x20,0xa6]
# NOTE: funct6=0x29 collides with vgmul.vv; disambiguated by context (vs1=0).
"""
fn emit_vaesem_vv(vd: i64, vs2: i64) -> [i64]:
    _encode_opmvv(0x29, 1, vs2, 0, vd)

"""Emit vaesdf.vv vd, vs2 — AES final-round decryption.

# Zvk v1.0 §3 (VAESDF); funct6=0x2A (101010); OPMVV funct3=010; vm=1; vs1=0
# Canonical: vaesdf.vv v1,v2 → 0xAA2020D7 [0xd7,0x20,0x20,0xaa]
"""
fn emit_vaesdf_vv(vd: i64, vs2: i64) -> [i64]:
    _encode_opmvv(0x2A, 1, vs2, 0, vd)

"""Emit vaesdm.vv vd, vs2 — AES middle-round decryption.

# Zvk v1.0 §3 (VAESDM); funct6=0x2B (101011); OPMVV funct3=010; vm=1; vs1=0
# Canonical: vaesdm.vv v1,v2 → 0xAE2020D7 [0xd7,0x20,0x20,0xae]
"""
fn emit_vaesdm_vv(vd: i64, vs2: i64) -> [i64]:
    _encode_opmvv(0x2B, 1, vs2, 0, vd)

"""Emit vaeskf1.vi vd, vs2, uimm — AES key schedule round 1.

# Zvk v1.0 §3 (VAESKF1); funct6=0x22 (100010); OPMVV funct3=010; vm=1
# uimm placed in vs1 field (bits[19:15]); must be in range 0..9.
# Canonical: vaeskf1.vi v1,v2,2 → 0x8A2120D7 [0xd7,0x20,0x21,0x8a]
"""
fn emit_vaeskf1_vi(vd: i64, vs2: i64, uimm: i64) -> [i64]:
    _encode_opmvv(0x22, 1, vs2, uimm, vd)

"""Emit vaeskf2.vi vd, vs2, uimm — AES key schedule round 2.

# Zvk v1.0 §3 (VAESKF2); funct6=0x2A (101010); OPMVV funct3=010; vm=1
# uimm placed in vs1 field (bits[19:15]); must be in range 0..13.
# NOTE: funct6=0x2A collides with vaesdf.vv; disambiguated by uimm!=0.
# Canonical: vaeskf2.vi v1,v2,2 → 0xAA2120D7 [0xd7,0x20,0x21,0xaa]
"""
fn emit_vaeskf2_vi(vd: i64, vs2: i64, uimm: i64) -> [i64]:
    _encode_opmvv(0x2A, 1, vs2, uimm, vd)

"""Emit vaesz.vs vd, vs2 — AES round with zero key (XOR only).

# Zvk v1.0 §3 (VAESZ); funct6=0x2F (101111); OPMVV funct3=010; vm=1; vs1=0
# NOTE: funct6=0x2F collides with vsha2cl.vv; disambiguated by vs1=0.
# Canonical: vaesz.vs v1,v2 → 0xBE2020D7 [0xd7,0x20,0x20,0xbe]
"""
fn emit_vaesz_vs(vd: i64, vs2: i64) -> [i64]:
    _encode_opmvv(0x2F, 1, vs2, 0, vd)

# ============================================================================
# Zvknh — SHA-2 message schedule (§4)
# ============================================================================

"""Emit vsha2ms.vv vd, vs2, vs1 — SHA-2 message schedule.

# Zvk v1.0 §4 (VSHA2MS); funct6=0x2D (101101); OPMVV funct3=010; vm=1
# Canonical: vsha2ms.vv v1,v2,v3 → 0xB621A0D7 [0xd7,0xa0,0x21,0xb6]
"""
fn emit_vsha2ms_vv(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    _encode_opmvv(0x2D, 1, vs2, vs1, vd)

"""Emit vsha2ch.vv vd, vs2, vs1 — SHA-2 compression high rounds.

# Zvk v1.0 §4 (VSHA2CH); funct6=0x2E (101110); OPMVV funct3=010; vm=1
# Canonical: vsha2ch.vv v1,v2,v3 → 0xBA21A0D7 [0xd7,0xa0,0x21,0xba]
"""
fn emit_vsha2ch_vv(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    _encode_opmvv(0x2E, 1, vs2, vs1, vd)

"""Emit vsha2cl.vv vd, vs2, vs1 — SHA-2 compression low rounds.

# Zvk v1.0 §4 (VSHA2CL); funct6=0x2F (101111); OPMVV funct3=010; vm=1
# NOTE: funct6=0x2F collides with vaesz.vs; disambiguated by vs1!=0.
# Canonical: vsha2cl.vv v1,v2,v3 → 0xBE21A0D7 [0xd7,0xa0,0x21,0xbe]
"""
fn emit_vsha2cl_vv(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    _encode_opmvv(0x2F, 1, vs2, vs1, vd)

# ============================================================================
# Zvkg — GCM/GHASH (CLMUL) (§5)
# ============================================================================

"""Emit vghsh.vv vd, vs2, vs1 — GHASH (polynomial multiply/accumulate).

# Zvk v1.0 §5 (VGHSH); funct6=0x2C (101100); OPMVV funct3=010; vm=1
# Canonical: vghsh.vv v1,v2,v3 → 0xB221A0D7 [0xd7,0xa0,0x21,0xb2]
"""
fn emit_vghsh_vv(vd: i64, vs2: i64, vs1: i64) -> [i64]:
    _encode_opmvv(0x2C, 1, vs2, vs1, vd)

"""Emit vgmul.vv vd, vs2 — GHASH multiply (no accumulate).

# Zvk v1.0 §5 (VGMUL); funct6=0x29 (101001); OPMVV funct3=010; vm=1; vs1=0
# NOTE: funct6=0x29 collides with vaesem.vv; disambiguated by context (vs1=0).
# Canonical: vgmul.vv v1,v2 → 0xA62020D7 [0xd7,0x20,0x20,0xa6]
"""
fn emit_vgmul_vv(vd: i64, vs2: i64) -> [i64]:
    _encode_opmvv(0x29, 1, vs2, 0, vd)

# ============================================================================
# Exports
# ============================================================================

export emit_vaesef_vv
export emit_vaesem_vv
export emit_vaesdf_vv
export emit_vaesdm_vv
export emit_vaeskf1_vi
export emit_vaeskf2_vi
export emit_vaesz_vs
export emit_vsha2ms_vv
export emit_vsha2ch_vv
export emit_vsha2cl_vv
export emit_vghsh_vv
export emit_vgmul_vv
