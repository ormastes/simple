# Native Backend - Section Byte Collection Helper
#
# Shared helper for collecting rodata / data bytes from a module's data_sections.
# Used by both ELF and Mach-O emission modules to avoid duplicated loops.

use compiler.backend.native.mach_inst.{DataEntry}


fn collect_section_bytes(data_sections: [DataEntry], readonly: bool) -> [i64]:
    """Concatenate the .data of every section matching the `readonly` flag."""
    var out: [i64] = []
    for entry in data_sections:
        if entry.is_readonly == readonly:
            for b in entry.data:
                out.push(b)
    out
