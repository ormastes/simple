# src/compiler/70.backend/backend/native/encode_x86_64_avx2_cmp.spl
#
# AVX2 Compare and Shuffle Instruction Byte-Emit Encoder — Pure Simple
#
# Produces exact byte sequences for AVX2 YMM packed comparison/shuffle instructions:
#   VPCMPEQD  (packed 32-bit compare equal,        VEX.256.66.0F.WIG  76 /r)
#   VPCMPGTD  (packed 32-bit compare greater-than,  VEX.256.66.0F.WIG  66 /r)
#   VPCMPEQB  (packed 8-bit compare equal,          VEX.256.66.0F.WIG  74 /r)
#   VPCMPGTB  (packed 8-bit compare greater-than,   VEX.256.66.0F.WIG  64 /r)
#   VPERMD    (packed 32-bit permute,               VEX.256.66.0F38.W0 36 /r)
#   VPSHUFB   (packed byte shuffle,                 VEX.256.66.0F38.WIG 00 /r)
#   VPSHUFD   (packed 32-bit shuffle immediate,     VEX.256.66.0F.WIG  70 /r ib)
#
# VEX 3-byte prefix (C4h) for YMM (256-bit) register forms:
#   Byte 0: 0xC4
#   Byte 1: ~R  ~X  ~B  m4 m3 m2 m1 m0
#     ~R   = 1 when ModRM.reg operand < 8,  else 0
#     ~X   = 1 (no SIB; register-direct only)
#     ~B   = 1 when ModRM.rm  operand < 8,  else 0
#     mmmmm= 00001 (1) for 0F map
#     mmmmm= 00010 (2) for 0F38 map
#   Byte 2: W  ~v3 ~v2 ~v1 ~v0  L  p1 p0
#     W    = 0 (WIG — ignored for these instructions)
#     ~vvvv= inverted 4-bit vvvv index: (15 - vvvv_reg)
#     L    = 1 (256-bit YMM)
#     pp   = 01 (66 prefix)
#
# /r three-operand forms (VPCMPEQD/VPCMPGTD/VPCMPEQB/VPCMPGTB/VPERMD/VPSHUFB):
#   ModRM.reg = rd (destination)
#   VEX.vvvv  = rn (first source, inverted in byte2)
#   ModRM.rm  = rm (second source)
#
# VPSHUFD two-operand + imm form (vvvv=1111):
#   ModRM.reg = rd (destination)
#   VEX.vvvv  = 15 (1111b — no second source register)
#   ModRM.rm  = rm (source operand)
#   imm8      = shuffle control
#
# Arithmetic for byte1 (no SIB, register-direct):
#   0F   map: byte1 = 225 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32
#   0F38 map: byte1 = 226 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32
#   (225 = 0xE1, mmmmm=1; 226 = 0xE2, mmmmm=2)
#
# Arithmetic for byte2 (W=0, L=1, pp=01):
#   byte2 = (15 - vvvv) * 8 + 5
#   (L=1 contributes 4; pp=01 contributes 1; W=0 contributes 0)
#   For VPSHUFD: vvvv=15 → byte2 = (15-15)*8+5 = 5 = 0x05
#
# ALL byte goldens verified by formula cross-check against Intel SDM.
# Reference: Intel SDM Vol 2C VPCMPEQD/VPCMPGTD/VPCMPEQB/VPCMPGTB/VPERMD/VPSHUFB/VPSHUFD;
#            Intel SDM Vol 2A §2.3.5 (VEX prefix).

# ============================================================================
# Internal helpers
# ============================================================================

fn _modrm_direct_cmp(reg: i64, rm: i64) -> i64:
    """
    ModRM byte for register-direct operands (mod=11).
    mod=11 → 192; reg field uses low 3 bits of reg; rm field uses low 3 bits of rm.
    """
    192 + ((reg % 8) * 8) + (rm % 8)

fn _vex_byte1_0f_cmp(modrm_reg: i64, modrm_rm: i64) -> i64:
    """
    VEX Byte 1 for 0F map (mmmmm=1), register-register, no SIB.
    ~R=1 when modrm_reg<8, ~X=1, ~B=1 when modrm_rm<8, mmmmm=1.
    byte1 = 225 - (modrm_reg/8)*128 - (modrm_rm/8)*32
    (225 = 0xE1 = ~R=1 ~X=1 ~B=1 mmmmm=1)
    """
    225 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32

fn _vex_byte1_0f38_cmp(modrm_reg: i64, modrm_rm: i64) -> i64:
    """
    VEX Byte 1 for 0F38 map (mmmmm=2), register-register, no SIB.
    ~R=1 when modrm_reg<8, ~X=1, ~B=1 when modrm_rm<8, mmmmm=2.
    byte1 = 226 - (modrm_reg/8)*128 - (modrm_rm/8)*32
    (226 = 0xE2 = ~R=1 ~X=1 ~B=1 mmmmm=2)
    """
    226 - (modrm_reg / 8) * 128 - (modrm_rm / 8) * 32

fn _vex_byte2_ymm_cmp(vvvv: i64) -> i64:
    """
    VEX Byte 2 for YMM (256-bit) forms: W=0, ~vvvv=(15-vvvv), L=1, pp=01.
    byte2 = (15 - vvvv) * 8 + 5
    (L=1 contributes 4; pp=01 contributes 1; W=0 contributes 0)
    """
    (15 - vvvv) * 8 + 5

fn _pack_vex3_ymm_66_0f_cmp(rd: i64, rn: i64, rm: i64, opcode: i64) -> [i64]:
    """
    3-byte VEX emit for VEX.256.66.0F.WIG /r forms (5 bytes total).
    rd → ModRM.reg (destination), rn → VEX.vvvv (src1), rm → ModRM.rm (src2).
    Used by: VPCMPEQD, VPCMPGTD, VPCMPEQB, VPCMPGTB.
    """
    val b1    = _vex_byte1_0f_cmp(rd, rm)
    val b2    = _vex_byte2_ymm_cmp(rn)
    val modrm = _modrm_direct_cmp(rd, rm)
    [0xC4, b1, b2, opcode, modrm]

fn _pack_vex3_ymm_66_0f38_cmp(rd: i64, rn: i64, rm: i64, opcode: i64) -> [i64]:
    """
    3-byte VEX emit for VEX.256.66.0F38.WIG /r forms (5 bytes total).
    rd → ModRM.reg (destination), rn → VEX.vvvv (src1), rm → ModRM.rm (src2).
    Used by: VPERMD, VPSHUFB.
    """
    val b1    = _vex_byte1_0f38_cmp(rd, rm)
    val b2    = _vex_byte2_ymm_cmp(rn)
    val modrm = _modrm_direct_cmp(rd, rm)
    [0xC4, b1, b2, opcode, modrm]

fn _pack_vex3_ymm_66_0f_imm8(rd: i64, rn: i64, rm: i64, opcode: i64, imm: i64) -> [i64]:
    """
    3-byte VEX emit for VEX.256.66.0F.WIG /r ib forms (6 bytes total).
    rd → ModRM.reg (destination), rn → VEX.vvvv, rm → ModRM.rm (source).
    For VPSHUFD: rn=15 (vvvv=1111, no second source register).
    """
    val b1    = _vex_byte1_0f_cmp(rd, rm)
    val b2    = _vex_byte2_ymm_cmp(rn)
    val modrm = _modrm_direct_cmp(rd, rm)
    [0xC4, b1, b2, opcode, modrm, imm]

# ============================================================================
# VPCMPEQD — Packed 32-bit Compare Equal  (VEX.256.66.0F.WIG 76 /r)
# VPCMPEQD rd, rn, rm
#   rd ← (rn == rm) ? 0xFFFFFFFF : 0  (element-wise 32-bit)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPCMPEQD" — VEX.256.66.0F.WIG 76 /r
# ============================================================================

fn emit_vpcmpeqd_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPCMPEQD ymm, ymm, ymm — packed 32-bit compare equal (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG 76 /r
    rd, rn, rm: YMM register indices 0..15 (ymm0=0, ymm1=1, ...).
    Example: emit_vpcmpeqd_ymm(0, 0, 0) → [0xC4, 0xE1, 0x7D, 0x76, 0xC0]
      byte1: ~R=1,~X=1,~B=1,mmmmm=1 → 225
      byte2: W=0,~vvvv=15(rn=0),L=1,pp=01 → 15*8+5=125
      ModRM: mod=11,reg=0,rm=0 → 192
    Reference: Intel SDM Vol 2C VPCMPEQD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_cmp(rd, rn, rm, 0x76)

# ============================================================================
# VPCMPGTD — Packed 32-bit Compare Greater-Than  (VEX.256.66.0F.WIG 66 /r)
# VPCMPGTD rd, rn, rm
#   rd ← (rn > rm) ? 0xFFFFFFFF : 0  (element-wise 32-bit signed)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPCMPGTD" — VEX.256.66.0F.WIG 66 /r
# ============================================================================

fn emit_vpcmpgtd_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPCMPGTD ymm, ymm, ymm — packed 32-bit compare greater-than (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG 66 /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpcmpgtd_ymm(0, 0, 0) → [0xC4, 0xE1, 0x7D, 0x66, 0xC0]
    Reference: Intel SDM Vol 2C VPCMPGTD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_cmp(rd, rn, rm, 0x66)

# ============================================================================
# VPCMPEQB — Packed 8-bit Compare Equal  (VEX.256.66.0F.WIG 74 /r)
# VPCMPEQB rd, rn, rm
#   rd ← (rn == rm) ? 0xFF : 0  (element-wise 8-bit)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPCMPEQB" — VEX.256.66.0F.WIG 74 /r
# ============================================================================

fn emit_vpcmpeqb_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPCMPEQB ymm, ymm, ymm — packed 8-bit compare equal (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG 74 /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpcmpeqb_ymm(0, 0, 0) → [0xC4, 0xE1, 0x7D, 0x74, 0xC0]
    Reference: Intel SDM Vol 2C VPCMPEQB; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_cmp(rd, rn, rm, 0x74)

# ============================================================================
# VPCMPGTB — Packed 8-bit Compare Greater-Than  (VEX.256.66.0F.WIG 64 /r)
# VPCMPGTB rd, rn, rm
#   rd ← (rn > rm) ? 0xFF : 0  (element-wise 8-bit signed)
#   Routing: vvvv=rn, ModRM.reg=rd, ModRM.rm=rm
# Reference: Intel SDM Vol 2C "VPCMPGTB" — VEX.256.66.0F.WIG 64 /r
# ============================================================================

fn emit_vpcmpgtb_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPCMPGTB ymm, ymm, ymm — packed 8-bit compare greater-than (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG 64 /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpcmpgtb_ymm(0, 0, 0) → [0xC4, 0xE1, 0x7D, 0x64, 0xC0]
    Reference: Intel SDM Vol 2C VPCMPGTB; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_cmp(rd, rn, rm, 0x64)

# ============================================================================
# VPERMD — Packed 32-bit Permute  (VEX.256.66.0F38.W0 36 /r)
# VPERMD rd, rn, rm
#   rd[i] ← rm[rn[i] & 7]  (element-wise 32-bit permute indexed by rn)
#   Routing: vvvv=rn (index), ModRM.reg=rd, ModRM.rm=rm (data)
# Reference: Intel SDM Vol 2C "VPERMD" — VEX.256.66.0F38.W0 36 /r
# ============================================================================

fn emit_vpermd_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPERMD ymm, ymm, ymm — packed 32-bit permute (YMM 256-bit form).
    Encoding: VEX.256.66.0F38.W0 36 /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpermd_ymm(0, 0, 0) → [0xC4, 0xE2, 0x7D, 0x36, 0xC0]
      byte1: ~R=1,~X=1,~B=1,mmmmm=2 → 226
      byte2: W=0,~vvvv=15(rn=0),L=1,pp=01 → 15*8+5=125
      ModRM: mod=11,reg=0,rm=0 → 192
    Reference: Intel SDM Vol 2C VPERMD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f38_cmp(rd, rn, rm, 0x36)

# ============================================================================
# VPSHUFB — Packed Byte Shuffle  (VEX.256.66.0F38.WIG 00 /r)
# VPSHUFB rd, rn, rm
#   rd[i] ← (rm[i] & 0x80) ? 0 : rn[rm[i] & 0x0F]  (byte shuffle/zero)
#   Routing: vvvv=rn (data), ModRM.reg=rd, ModRM.rm=rm (control)
# Reference: Intel SDM Vol 2C "VPSHUFB" — VEX.256.66.0F38.WIG 00 /r
# ============================================================================

fn emit_vpshufb_ymm(rd: i64, rn: i64, rm: i64) -> [i64]:
    """
    VPSHUFB ymm, ymm, ymm — packed byte shuffle (YMM 256-bit form).
    Encoding: VEX.256.66.0F38.WIG 00 /r
    rd, rn, rm: YMM register indices 0..15.
    Example: emit_vpshufb_ymm(0, 0, 0) → [0xC4, 0xE2, 0x7D, 0x00, 0xC0]
      byte1: ~R=1,~X=1,~B=1,mmmmm=2 → 226
      byte2: W=0,~vvvv=15(rn=0),L=1,pp=01 → 15*8+5=125
      ModRM: mod=11,reg=0,rm=0 → 192
    Reference: Intel SDM Vol 2C VPSHUFB; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f38_cmp(rd, rn, rm, 0x00)

# ============================================================================
# VPSHUFD — Packed 32-bit Shuffle Immediate  (VEX.256.66.0F.WIG 70 /r ib)
# VPSHUFD rd, rm, imm8
#   rd[i] ← rm[imm8[(i*2+1):(i*2)]]  (32-bit lane shuffle)
#   2-operand + imm: vvvv=1111 (not used), ModRM.reg=rd, ModRM.rm=rm
#   Returns 6 bytes (includes imm8).
# Reference: Intel SDM Vol 2C "VPSHUFD" — VEX.256.66.0F.WIG 70 /r ib
# ============================================================================

fn emit_vpshufd_ymm(rd: i64, rm: i64, imm: i64) -> [i64]:
    """
    VPSHUFD ymm, ymm, imm8 — packed 32-bit shuffle immediate (YMM 256-bit form).
    Encoding: VEX.256.66.0F.WIG 70 /r ib  (6 bytes)
    rd: destination YMM register index 0..15.
    rm: source YMM register index 0..15.
    imm: 8-bit shuffle control (2-bit lane selectors for each of 4 dwords per 128-bit half).
    VEX.vvvv=1111 (no second source register).
    byte2 = (15-15)*8+5 = 5 = 0x05.
    Example: emit_vpshufd_ymm(0, 0, 0) → [0xC4, 0xE1, 0x05, 0x70, 0xC0, 0x00]
      byte1: ~R=1,~X=1,~B=1,mmmmm=1 → 225
      byte2: W=0,~vvvv=0(vvvv=15),L=1,pp=01 → 0*8+5=5
      ModRM: mod=11,reg=0,rm=0 → 192
    Reference: Intel SDM Vol 2C VPSHUFD; Vol 2A §2.3.5 (VEX prefix).
    """
    _pack_vex3_ymm_66_0f_imm8(rd, 15, rm, 0x70, imm)

# ============================================================================
# Exports
# ============================================================================

export emit_vpcmpeqd_ymm
export emit_vpcmpgtd_ymm
export emit_vpcmpeqb_ymm
export emit_vpcmpgtb_ymm
export emit_vpermd_ymm
export emit_vpshufb_ymm
export emit_vpshufd_ymm
