#![allow(export_outside_init)]
# Callback Trampoline Generation for SFFI
#
# Generates C callback typedefs and trampoline functions for SFFI interop.
# Converts C function pointers to Simple-callable patterns.
#
# v1: Stateless function pointers ONLY. Closures with captures are rejected
# by the SFFI lint (SFFI001). Plain Fn<(A) -> B> types without capture
# context map to C function pointer typedefs.
#
# Usage flow:
# 1. Type checker identifies Fn<(A) -> B> parameter types in @export("C") fns
# 2. This module generates typedef + trampoline for each unique signature
# 3. c_header.spl emits the typedefs before function declarations
# 4. c_backend_translate.spl uses function pointer params in wrappers
#
# Ownership: Callbacks are "borrowed" — the caller owns the function pointer,
# the callee (Simple side) does not store or free it.

use compiler.backend.c_type_mapper.{CTypeMapper}

# ============================================================================
# Callback Type Representation
# ============================================================================

class CallbackTypedef:
    """Represents a callback type for C header generation.

    Each unique function pointer signature gets one typedef:
        typedef return_type (*name)(param_types...);
    """
    name: text              # e.g. "spl_callback_i64_to_i64"
    return_type: text       # C return type
    param_types: List<text> # C parameter types

# ============================================================================
# Type Classification
# ============================================================================

fn is_callback_type(type_name: text) -> bool:
    """Check if a type represents a function pointer (not a closure).

    Function pointer types follow the pattern Fn<(Args) -> Ret> without
    a capture list. Closures with captures use Fn<(Args) -> Ret>[x, y].

    Examples:
        "Fn<(i64) -> i64>"           -> true  (stateless function pointer)
        "Fn<(i64, f64) -> bool>"     -> true  (multi-param function pointer)
        "Fn<() -> void>"             -> true  (no-arg function pointer)
        "Fn<(i64) -> i64>[x, y]"    -> false  (closure with captures)
        "i64"                        -> false  (not a function type)
    """
    if not type_name.starts_with("Fn<"):
        return false
    # Reject closures with captures — indicated by [...] suffix
    not type_name.contains("[")

fn is_closure_with_captures(type_name: text) -> bool:
    """Check if a type is a closure with captures (rejected by SFFI).

    Closures carry hidden state that has no stable C ABI representation.
    They are indicated by a [...] suffix after the Fn<...> type.
    """
    type_name.starts_with("Fn<") and type_name.contains("[")

# ============================================================================
# Naming
# ============================================================================

fn callback_typedef_name(param_types: List<text>, return_type: text) -> text:
    """Generate a unique callback typedef name from the function signature.

    Naming convention: spl_callback_{param1}_{param2}_to_{return}
    This ensures each unique signature gets a distinct typedef.

    Examples:
        (["i64"], "i64")          -> "spl_callback_i64_to_i64"
        (["i64", "f64"], "bool")  -> "spl_callback_i64_f64_to_bool"
        ([], "void")              -> "spl_callback_void_to_void"
    """
    var name = "spl_callback"
    if param_types.len() == 0:
        name = "{name}_void"
    else:
        var pi = 0
        while pi < param_types.len():
            name = "{name}_{param_types[pi]}"
            pi = pi + 1
    name = "{name}_to_{return_type}"
    name

# ============================================================================
# Type Extraction from Fn<(A, B) -> C> Strings
# ============================================================================

fn extract_callback_params(type_name: text) -> List<text>:
    """Extract parameter types from Fn<(A, B) -> C> type string.

    Parses the parameter list between the first ( and the matching ).

    Examples:
        "Fn<(i64, f64) -> bool>"  -> ["i64", "f64"]
        "Fn<(i64) -> i64>"        -> ["i64"]
        "Fn<() -> void>"          -> []
    """
    var params: List<text> = []

    # Find opening paren after "Fn<"
    val open_idx = type_name.index_of("(")
    if open_idx < 0:
        return params

    # Find closing paren
    val close_idx = type_name.index_of(")")
    if close_idx < 0 or close_idx <= open_idx + 1:
        return params

    # Extract content between parens
    val inner = type_name.slice(open_idx + 1, close_idx).trim()
    if inner == "":
        return params

    # Split on ", " to get individual param types
    val parts = inner.split(", ")
    var pi = 0
    while pi < parts.len():
        val part = parts[pi].trim()
        if part != "":
            params.push(part)
        pi = pi + 1

    params

fn extract_callback_return(type_name: text) -> text:
    """Extract return type from Fn<(A, B) -> C> type string.

    Parses the return type after the -> arrow and before the closing >.

    Examples:
        "Fn<(i64, f64) -> bool>"  -> "bool"
        "Fn<(i64) -> i64>"        -> "i64"
        "Fn<() -> void>"          -> "void"
    """
    # Find " -> " arrow
    val arrow_idx = type_name.index_of(" -> ")
    if arrow_idx < 0:
        return "void"

    # Extract from after arrow to before closing >
    val after_arrow = type_name.slice(arrow_idx + 4, type_name.len())
    # Strip trailing > and any whitespace
    var ret = after_arrow.trim()
    if ret.ends_with(">"):
        ret = ret.slice(0, ret.len() - 1).trim()

    if ret == "":
        return "void"

    ret

# ============================================================================
# C Type Mapping for Callback Types
# ============================================================================

fn _simple_param_to_c(type_name: text) -> text:
    """Map a Simple type name to C type string for callback parameters."""
    match type_name:
        case "i64": "int64_t"
        case "i32": "int32_t"
        case "i16": "int16_t"
        case "i8": "int8_t"
        case "u64": "uint64_t"
        case "u32": "uint32_t"
        case "u16": "uint16_t"
        case "u8": "uint8_t"
        case "f64": "double"
        case "f32": "float"
        case "bool": "int64_t"
        case "text": "const char*"
        case "Text": "const char*"
        case "str": "const char*"
        case "Unit": "void"
        case "unit": "void"
        case "()": "void"
        case _: "void*"

# ============================================================================
# Code Emission
# ============================================================================

fn emit_callback_typedef(cb: CallbackTypedef) -> text:
    """Generate C typedef for a callback type.

    Produces a function pointer typedef suitable for inclusion in a C header:
        typedef return_type (*name)(param_types...);

    If no parameters, emits (void) for C compatibility.
    """
    var params = ""
    var i = 0
    while i < cb.param_types.len():
        if i > 0:
            params = "{params}, "
        params = "{params}{cb.param_types[i]}"
        i = i + 1

    if params == "":
        params = "void"

    "typedef {cb.return_type} (*{cb.name})({params});"

fn emit_callback_trampoline(fn_name: text, cb: CallbackTypedef) -> text:
    """Generate the trampoline function that wraps a C callback for Simple.

    The trampoline validates the function pointer is non-null and invokes it.
    If the pointer is NULL, it returns a zero-initialized default value
    (or simply returns for void callbacks).

    Generated pattern:
        static return_type fn_name(name cb, params...) {
            if (!cb) { return default; }
            return cb(params...);
        }
    """
    var lines: [text] = []

    val ret_is_void = cb.return_type == "void"

    # Build parameter list: first param is the callback itself, rest are forwarded args
    var params: [text] = []
    params.push("{cb.name} _cb")
    var arg_names: [text] = []
    var i = 0
    while i < cb.param_types.len():
        val arg_name = "_a{i}"
        # Skip void params (for zero-arg callbacks)
        if cb.param_types[i] != "void":
            params.push("{cb.param_types[i]} {arg_name}")
            arg_names.push(arg_name)
        i = i + 1

    val params_str = params.join(", ")
    val args_str = arg_names.join(", ")

    lines.push("static {cb.return_type} {fn_name}({params_str}) " + "{")
    lines.push("    if (!_cb) " + "{")
    if ret_is_void:
        lines.push("        return;")
    else:
        lines.push("        {cb.return_type} _zero = " + "{" + "0" + "}" + ";")
        lines.push("        return _zero;")
    lines.push("    " + "}")
    if ret_is_void:
        lines.push("    _cb({args_str});")
    else:
        lines.push("    return _cb({args_str});")
    lines.push("" + "}")

    lines.join("\n")

# ============================================================================
# High-Level: Build CallbackTypedef from Fn<...> Type String
# ============================================================================

fn build_callback_typedef(type_name: text) -> CallbackTypedef:
    """Build a CallbackTypedef from a Fn<(A, B) -> C> type string.

    Extracts parameter and return types, maps them to C types, and
    generates a unique typedef name.

    Returns a CallbackTypedef ready for emission via emit_callback_typedef.
    """
    val simple_params = extract_callback_params(type_name)
    val simple_return = extract_callback_return(type_name)

    # Map Simple types to C types
    var c_params: List<text> = []
    var c_param_short: List<text> = []
    var pi = 0
    while pi < simple_params.len():
        val c_ty = _simple_param_to_c(simple_params[pi])
        c_params.push(c_ty)
        # Use short names for the typedef name generation
        c_param_short.push(simple_params[pi])
        pi = pi + 1

    val c_return = _simple_param_to_c(simple_return)
    val name = callback_typedef_name(c_param_short, simple_return)

    CallbackTypedef(
        name: name,
        return_type: c_return,
        param_types: c_params
    )

# ============================================================================
# Export
# ============================================================================

export CallbackTypedef
export is_callback_type
export is_closure_with_captures
export callback_typedef_name
export extract_callback_params
export extract_callback_return
export emit_callback_typedef
export emit_callback_trampoline
export build_callback_typedef
