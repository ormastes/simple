# LLVM Codegen Adapter
#
# Wraps MirToLlvm translator to implement the Codegen trait.
# Delegates to existing LLVM IR generation and llc compilation pipeline.

use compiler.mir.mir_data.{MirModule}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileOptions, CompileError, CompiledModule, compileerror_backend_error}
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.llvm_backend.{MirToLlvm, LlvmTargetConfig, MirToLlvm__create}
use compiler.backend.llvm_backend_tools.{LlvmObjectCode, compile_ir_to_object, llc_available}

# ============================================================================
# LLVM Codegen Adapter
# ============================================================================

class LlvmCodegenAdapter:
    """Adapts MirToLlvm translator to the Codegen trait interface."""
    options: CompileOptions

fn llvm_compile_module_direct(options: CompileOptions, module: MirModule) -> Result<CodegenOutput, CompileError>:
    print "[llvm-direct] start"
    print "[llvm-direct] module-name {module.name}"
    # Check llc availability
    if not llc_available():
        return Err(compileerror_backend_error(BackendKind.Llvm,
            "llc not found. Install LLVM: apt install llvm (Ubuntu) or brew install llvm (macOS)"))

    # Translate MIR to LLVM IR
    print "[llvm-direct] config"
    val config = LlvmTargetConfig.for_target_portable_numeric(options.target, nil)
    print "[llvm-direct] translator"
    var translator = MirToLlvm.create(module.name, options.target, nil)
    print "[llvm-direct] translate"
    val llvm_ir = translator.translate_module(module)

    # Compile IR to object code via llc
    print "[llvm-direct] llc"
    val result = compile_ir_to_object(llvm_ir, config, options.opt_level)
    print "[llvm-direct] result"
    if result.is_err():
        val err_msg = result.unwrap_err()
        return Err(compileerror_backend_error(BackendKind.Llvm, err_msg))

    print "[llvm-direct] bytes"
    val object_code: LlvmObjectCode = result.unwrap()
    val bytes = object_code.bytes
    print "[llvm-direct] done"
    Ok(CodegenOutput.object(module.name, bytes))

fn llvm_compile_module_direct_compiled(options: CompileOptions, module: MirModule) -> Result<CompiledModule, CompileError>:
    print "[llvm-direct] compiled:start"
    if not llc_available():
        return Err(compileerror_backend_error(BackendKind.Llvm,
            "llc not found. Install LLVM: apt install llvm (Ubuntu) or brew install llvm (MacOS)"))
    val config = LlvmTargetConfig.for_target_portable_numeric(options.target, nil)
    var translator = MirToLlvm.create("app.cli.bootstrap_main", options.target, nil)
    val llvm_ir = translator.translate_module(module)
    val result = compile_ir_to_object(llvm_ir, config, options.opt_level)
    if result.is_err():
        val err_msg = result.unwrap_err()
        return Err(compileerror_backend_error(BackendKind.Llvm, err_msg))
    val object_code = result.unwrap()
    print "[llvm-direct] compiled:bytes"
    Ok(CompiledModule(
        name: "app.cli.bootstrap_main",
        object_code: object_code.bytes,
        has_assembly: false,
        assembly: "",
        has_llvm_ir: false,
        llvm_ir: "",
        symbols: [],
        compile_time_ms: 0
    ))

impl Codegen for LlvmCodegenAdapter:
    fn backend_kind() -> BackendKind: BackendKind.Llvm
    fn backend_name() -> text: "llvm"
    fn supports_target(target: CodegenTarget) -> bool:
        match target:
            case X86_64: true
            case AArch64: true
            case Riscv64: true
            case X86: true
            case Arm32: true
            case Riscv32: true
            case Wasm32: false
            case Wasm64: false
            case C: false
            case CudaPtx: false
            case VulkanSpirv: false
            case Metal: false
            case OpenCL: false
            case Avr: false
            case I8086: false
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.ObjectCode

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        llvm_compile_module_direct(self.options, module)

# ============================================================================
# Exports
# ============================================================================
