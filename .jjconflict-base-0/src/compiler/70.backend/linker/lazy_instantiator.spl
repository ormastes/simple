# Lazy instantiation at link-time.
#
# This module handles on-demand instantiation of generic templates
# when resolving missing symbols during linking.
#
# Phase 4: Link-Time Lazy Instantiation

use compiler.mono.monomorphize.note_sdn.*
use compiler.common.compilation_context (GenericTemplate, ConcreteType)
use compiler.common.compilation_context.{TypeRegistry}
use compiler.common.di.{DiContainer}
use compiler.common.driver_core_types.{BootLogger}
use compiler.mono.instantiation (TemplateInstantiator, mangle)
use compiler.tools.aop.{AopWeaver}
use compiler.frontend.core.aop.{WeavingConfig}
use compiler.backend.linker.linker_context (LinkerCompilationContext)
use compiler.backend.linker.smf_reader (SmfReaderImpl)
use compiler.backend.linker.obj_taker (SmfSymbol, parse_template)

fn _lazy_split_type_params(raw: text) -> [text]:
    var params: [text] = []
    for part in raw.split(","):
        params = params.push(part.trim())
    params

fn _lazy_concrete_type_args(raw: text) -> [ConcreteType]:
    var args: [ConcreteType] = []
    for part in raw.split(","):
        args = args.push(ConcreteType(part.trim()))
    args

# ============================================================================
# Result Types
# ============================================================================

enum LazyInstantiationResult:
    """Result of lazy instantiation attempt."""
    Success(code: [u8], symbol: text, metadata: NoteSdnMetadata)
    NotFound(symbol: text)
    CircularDependency(cycle: [text])
    Deferred(symbol: text)
    Error(message: text)


# ============================================================================
# LazyInstantiationResult Methods (was: impl LazyInstantiationResult:)
# ============================================================================

# ============================================================================
# Configuration
# ============================================================================

struct LazyInstantiatorConfig:
    """Configuration for lazy instantiation."""
    allow_defer: bool
    max_depth: i32
    verbose: bool


# ============================================================================
# LazyInstantiatorConfig Methods (was: impl LazyInstantiatorConfig:)
# ============================================================================

impl LazyInstantiatorConfig:
    static fn default() -> LazyInstantiatorConfig:
        LazyInstantiatorConfig(true, 100, false)

fn lazyinstantiatorconfig_default() -> LazyInstantiatorConfig:
        LazyInstantiatorConfig.default()


# ============================================================================
# Lazy Instantiator
# ============================================================================

struct LazyInstantiator:
    """Lazy instantiator for link-time instantiation."""
    config: LazyInstantiatorConfig
    input_metadata: Dict<text, NoteSdnMetadata>
    output_metadata: NoteSdnMetadata
    in_progress: Set<text>
    depth: i32
    instantiated: Dict<text, [u8]>


# ============================================================================
# LazyInstantiator Methods (was: impl LazyInstantiator:)
# ============================================================================

impl LazyInstantiator:
    static fn new(config: LazyInstantiatorConfig) -> LazyInstantiator:
        """Create a new lazy instantiator."""
        LazyInstantiator(config, {}, NoteSdnMetadata.new(), {}, 0, {})

fn lazyinstantiator_new(config: LazyInstantiatorConfig) -> LazyInstantiator:
        """Create a new lazy instantiator."""
        LazyInstantiator.new(config)


me lazyinstantiator_try_instantiate(self: LazyInstantiator, symbol: text) -> LazyInstantiationResult:
        """Try to instantiate a missing symbol."""
        # Check depth limit
        if self.depth >= self.config.max_depth:
            return LazyInstantiationResult.Error(
                "Maximum instantiation depth ({self.config.max_depth}) exceeded"
            )

        # Check if already instantiated
        if self.instantiated.has(symbol):
            return LazyInstantiationResult.Success(
                self.instantiated[symbol],
                symbol,
                self.output_metadata
            )

        # Check for cycle
        if self.in_progress.contains(symbol):
            var cycle: [text] = []
            for sym in self.in_progress:
                cycle = cycle.push(sym)
            cycle = cycle.push(symbol)
            return LazyInstantiationResult.CircularDependency(cycle)

        # Find possible entry
        val found: (text, PossibleInstantiationEntry)? = self.find_possible(symbol)
        if not found.?:
            return LazyInstantiationResult.NotFound(symbol)

        val _destruct_0: (text, PossibleInstantiationEntry) = found.unwrap()
        val source_path = _destruct_0[0]
        val entry: PossibleInstantiationEntry = _destruct_0[1]

        # Check if can defer
        if entry.can_defer:
            if self.config.allow_defer:
                return LazyInstantiationResult.Deferred(symbol)

        # Start instantiation
        self.in_progress = self.in_progress.insert(symbol)
        self.depth = self.depth + 1

        if self.config.verbose:
            print "[lazy-inst] Instantiating {symbol} from {source_path}"

        # Perform instantiation
        val result = self.do_instantiate(entry, source_path)

        # Cleanup
        self.in_progress = self.in_progress.remove(symbol)
        self.depth = self.depth - 1

        result


me lazyinstantiator_do_instantiate(self: LazyInstantiator, entry: PossibleInstantiationEntry, source_path: text) -> LazyInstantiationResult:
        """Perform the actual instantiation through unified CompilationContext pipeline."""
        # Create instantiation entry for metadata tracking
        val inst_entry = InstantiationEntry(
            entry.template_name,
            entry.type_args,
            entry.mangled_name,
            source_path,
            "{source_path}:0:0",
            "link_output.o",
            InstantiationStatus.Compiled
        )

        # Add to output metadata
        self.output_metadata.add_instantiation(inst_entry)

        # Add dependency edge
        val dep = DependencyEdge(entry.required_by, entry.mangled_name, DependencyKind.TypeParam)
        self.output_metadata.add_dependency(dep)

        # Build linker compilation context from input metadata.
        # Load templates from input SMF TemplateCode sections:
        #   1. Open SmfReaderImpl for source_path
        #   2. Look up the template symbol
        #   3. Call read_template_section() to get GTPL bytes
        #   4. Deserialize via parse_template() from obj_taker
        #   5. Convert Template to GenericTemplate
        var object_templates: Dict<text, GenericTemplate> = {}
        val reader_result = SmfReaderImpl.open(source_path)
        if reader_result.is_ok():
            val reader = reader_result.unwrap()
            val sym_result = reader.lookup_symbol(entry.template_name)
            if sym_result.is_ok():
                val sym = sym_result.unwrap()
                if sym.is_generic_template:
                    val tpl_result = reader.read_template_section(sym)
                    if tpl_result.is_ok():
                        val tpl_bytes = tpl_result.unwrap()
                        val tpl = parse_template(tpl_bytes, sym)
                        object_templates[entry.template_name] = GenericTemplate(tpl.name, tpl.type_params, tpl.body)
                    else:
                        # TemplateCode section read failed -- fall back to placeholder
                        object_templates[entry.template_name] = GenericTemplate(entry.template_name, _lazy_split_type_params(entry.type_args), nil)
                else:
                    # Symbol exists but not a generic template
                    object_templates[entry.template_name] = GenericTemplate(entry.template_name, _lazy_split_type_params(entry.type_args), nil)
            else:
                # Symbol not found in SMF -- fall back to placeholder
                object_templates[entry.template_name] = GenericTemplate(entry.template_name, _lazy_split_type_params(entry.type_args), nil)
            reader.close()
        else:
            # Cannot open SMF file -- fall back to placeholder
            object_templates[entry.template_name] = GenericTemplate(entry.template_name, _lazy_split_type_params(entry.type_args), nil)

        val linker_ctx = LinkerCompilationContext(
            object_templates: object_templates,
            project_di: DiContainer(bindings: {}, singletons: {}, profile: "link", all_bindings: [], locked: false),
            project_aop: AopWeaver(advices: [], config: WeavingConfig.disabled(), logger: BootLogger(level: 0), runtime_enabled: false, runtime_allowlist: []),
            type_reg: TypeRegistry.empty(),
            recorded: []
        )
        var instantiator = TemplateInstantiator(linker_ctx, {}, {})

        # Parse type args from the entry
        val type_args = _lazy_concrete_type_args(entry.type_args)

        # Compile through unified pipeline
        match instantiator.instantiate(entry.template_name, type_args):
            case Ok(compiled_unit):
                val compiled_code = compiled_unit.code
                self.instantiated[entry.mangled_name] = compiled_code

                LazyInstantiationResult.Success(
                    compiled_code,
                    entry.mangled_name,
                    self.output_metadata
                )

            case Err(msg):
                LazyInstantiationResult.Error(msg)


# ============================================================================
# Statistics
# ============================================================================

struct LazyInstantiationStats:
    """Statistics from lazy instantiation."""
    instantiated: i32
    deferred: i32
    not_found: i32
    errors: i32


# ============================================================================
# LazyInstantiationStats Methods (was: impl LazyInstantiationStats:)
# ============================================================================

fn lazyinstantiationstats_default() -> LazyInstantiationStats:
        LazyInstantiationStats(0, 0, 0, 0)


fn lazyinstantiationstats_from_results(results: [LazyInstantiationResult]) -> LazyInstantiationStats:
        var stats = lazyinstantiationstats_default()

        for result in results:
            match result:
                case Success(_, _, _):
                    stats.instantiated = stats.instantiated + 1
                case Deferred(_):
                    stats.deferred = stats.deferred + 1
                case NotFound(_):
                    stats.not_found = stats.not_found + 1
                case Error(_):
                    stats.errors = stats.errors + 1
                case CircularDependency(_):
                    stats.errors = stats.errors + 1

        stats


# ============================================================================
# Exports
# ============================================================================
