# Transitive hosted-link dependencies for the Rust seed aggregate archive.

fn native_all_input_present(inputs: [text]) -> bool:
    for input in inputs:
        # Seed-parser compat: chained .replace().split() does not dispatch under
        # the deployed seed (known chained-method limitation) — use a typed val.
        val normalized: text = input.replace("\\", "/")
        val parts = normalized.split("/")
        val name = parts[parts.len() - 1].lower()
        if name == "libsimple_native_all.a" or name == "simple_native_all.lib":
            return true
    false

fn native_all_gnu_support_args(inputs: [text], os: text, macos_prefix: text) -> [text]:
    if not native_all_input_present(inputs):
        return []
    if os == "linux":
        return ["-lstdc++", "-lunwind", "-lsqlite3", "-lz", "-lzstd", "-ltinfo", "-lffi", "-lxml2", "-lncurses"]
    if os == "macos" or os == "darwin":
        return [
            "-L" + macos_prefix + "/lib", "-lc++", "-lz", "-lffi", "-ledit", "-lzstd", "-lxml2", "-lncurses", "-lobjc", "-liconv",
            "-framework", "CoreFoundation", "-framework", "Security", "-framework", "SystemConfiguration",
            "-framework", "IOKit", "-framework", "CoreServices", "-framework", "Foundation",
            "-framework", "AppKit", "-framework", "Metal", "-framework", "CoreGraphics"
        ]
    if os == "freebsd":
        return ["-L/usr/local/lib", "-lc++", "-lexecinfo", "-lz", "-lzstd", "-lutil", "-lrt"]
    if os == "windows-mingw":
        return [
            "-lkernel32", "-lntdll", "-luserenv", "-lws2_32", "-ldbghelp", "-ladvapi32", "-lbcrypt",
            "-lole32", "-loleaut32", "-lshell32", "-lpropsys", "-lruntimeobject", "-lsynchronization",
            "-lcrypt32", "-lsecur32", "-lncrypt", "-liphlpapi", "-ld3d11", "-ldxgi", "-luser32",
            "-lgdi32", "-ldwmapi", "-limm32", "-luxtheme", "-lwinmm", "-lshlwapi", "-lgcc_eh",
            "-lmsvcrt", "-lmingwex", "-lmingw32", "-lgcc"
        ]
    []

fn native_all_msvc_support_libraries(inputs: [text]) -> [text]:
    if not native_all_input_present(inputs):
        return []
    [
        "kernel32.lib", "ws2_32.lib", "bcrypt.lib", "userenv.lib", "ntdll.lib", "advapi32.lib",
        "dbghelp.lib", "ole32.lib", "oleaut32.lib", "shell32.lib", "crypt32.lib", "secur32.lib",
        "ncrypt.lib", "iphlpapi.lib", "d3d11.lib", "dxgi.lib", "user32.lib", "gdi32.lib",
        "ucrt.lib", "msvcrt.lib", "vcruntime.lib"
    ]
