# Noalloc reachable import verifier.
#
# This is the compiler-tool-owned implementation of the noalloc closure audit.
# It follows imports from src/lib/nogc_async_mut_noalloc and rejects reachable
# imports into allocating, OS/app/example, POSIX, Linux, @alloc, or host
# allocation surfaces.

use std.nogc_sync_mut.io.dir_ops.{dir_walk}
use std.nogc_sync_mut.io.file_ops.{file_exists, file_read}

val NOALLOC_ROOT = "src/lib/nogc_async_mut_noalloc"
val COMMON_ROOT = "src/lib/common"

fn _has_prefix(value: text, prefixes: [text]) -> bool:
    for prefix in prefixes:
        if value.starts_with(prefix):
            return true
    false

fn _forbidden_import_prefixes() -> [text]:
    [
        "std.nogc_sync_mut.",
        "std.nogc_async_mut.",
        "std.nogc_async_immut.",
        "std.gc_async_mut.",
        "std.posix.",
        "std.linux.",
        "posix.",
        "linux.",
        "os.",
        "app.",
        "examples.",
    ]

fn _dirname(path: text) -> text:
    var idx = path.len() - 1
    while idx >= 0:
        if path[idx:idx + 1] == "/":
            return path[0:idx]
        idx = idx - 1
    "."

fn _candidate(path_no_ext: text) -> text:
    val file_path = path_no_ext + ".spl"
    if file_exists(file_path):
        return file_path
    val init_path = path_no_ext + "/__init__.spl"
    if file_exists(init_path):
        return init_path
    ""

fn _module_rel_path(module: text) -> text:
    module.replace(".", "/")

fn _resolve_import(module: text, current_path: text) -> text:
    if module.starts_with("lib.nogc_async_mut_noalloc."):
        return _candidate(NOALLOC_ROOT + "/" + _module_rel_path(module[28:module.len()]))
    if module.starts_with("std.nogc_async_mut_noalloc."):
        return _candidate(NOALLOC_ROOT + "/" + _module_rel_path(module[28:module.len()]))
    if module.starts_with("std.common."):
        return _candidate(COMMON_ROOT + "/" + _module_rel_path(module[11:module.len()]))
    if module.starts_with("common."):
        return _candidate(COMMON_ROOT + "/" + _module_rel_path(module[7:module.len()]))
    if module.starts_with("std."):
        val rel = _module_rel_path(module[4:module.len()])
        val noalloc_path = _candidate(NOALLOC_ROOT + "/" + rel)
        if noalloc_path != "":
            return noalloc_path
        return _candidate(COMMON_ROOT + "/" + rel)

    return _candidate(_dirname(current_path) + "/" + _module_rel_path(module))

fn _trim_import_target(target: text) -> text:
    var end_idx = target.len()
    var i = 0
    while i < target.len():
        val ch = target[i:i + 1]
        if ch == " " or ch == "{" or ch == "(" or ch == ",":
            if i < end_idx:
                end_idx = i
        i = i + 1
    target[0:end_idx]

fn _import_from_line(line: text) -> text:
    val trimmed = line.trim()
    if trimmed == "" or trimmed.starts_with("#"):
        return ""
    if trimmed.starts_with("use lazy "):
        return _trim_import_target(trimmed[9:trimmed.len()])
    if trimmed.starts_with("use "):
        return _trim_import_target(trimmed[4:trimmed.len()])
    if trimmed.starts_with("from "):
        return _trim_import_target(trimmed[5:trimmed.len()])
    if trimmed.starts_with("import "):
        return _trim_import_target(trimmed[7:trimmed.len()])
    ""

fn _has_host_alloc_api(content: text) -> bool:
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("#"):
            continue
        if trimmed.contains("rt_alloc"):
            return true
        if trimmed.starts_with("extern fn ") and (
            trimmed.contains("malloc") or trimmed.contains("calloc") or
            trimmed.contains("free") or trimmed.contains("realloc")
        ):
            return true
        if trimmed.contains("libc.malloc(") or trimmed.contains("libc.calloc(") or trimmed.contains("libc.free("):
            return true
        if trimmed.contains("std.malloc(") or trimmed.contains("std.calloc(") or trimmed.contains("std.free("):
            return true
        if trimmed.contains("posix.malloc(") or trimmed.contains("posix.calloc(") or trimmed.contains("posix.free("):
            return true
    false

fn _has_alloc_annotation(content: text) -> bool:
    for line in content.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("@alloc") or trimmed.starts_with("# @alloc"):
            return true
    false

fn verify_noalloc_reachable_imports() -> [text]:
    var errors: [text] = []
    var queue: [text] = []
    var seen: [text] = []

    for path in dir_walk(NOALLOC_ROOT):
        if path.ends_with(".spl"):
            queue.push(path)

    var index = 0
    while index < queue.len():
        val path = queue[index]
        index = index + 1
        if seen.contains(path):
            continue
        seen.push(path)

        val content = file_read(path)
        if _has_alloc_annotation(content):
            errors.push("{path}: allocation annotation reachable from noalloc closure")
        if _has_host_alloc_api(content):
            errors.push("{path}: host allocation API reachable from noalloc closure")

        var line_no = 1
        for line in content.split("\n"):
            val module = _import_from_line(line)
            if module != "":
                if _has_prefix(module, _forbidden_import_prefixes()):
                    errors.push("{path}:{line_no}: forbidden reachable import {module}")
                else:
                    val resolved = _resolve_import(module, path)
                    if resolved != "" and not seen.contains(resolved) and not queue.contains(resolved):
                        queue.push(resolved)
            line_no = line_no + 1
    errors

fn print_noalloc_reachable_imports() -> i32:
    val errors = verify_noalloc_reachable_imports()
    if errors.len() == 0:
        print "noalloc reachable import closure is restricted to nogc_async_mut_noalloc/common"
        return 0
    for error in errors:
        print error
    1

extern fn rt_exit(code: i64)

fn main():
    val code = print_noalloc_reachable_imports()
    if code != 0:
        rt_exit(code)
