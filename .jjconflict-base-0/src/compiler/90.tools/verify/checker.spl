# Proof Checker
#
# Checks the authoritative Lean verification artifact inventory.
# A file only passes when Lean succeeds and the file contains no `sorry`.

use app.io.mod.{file_exists, file_read}
use compiler.tools.verify.lake_runner.{LakeRunner}
use verification.regenerate as regen

# ============================================================================
# Proof Status
# ============================================================================

enum ProofStatus:
    """Status of a single verification artifact."""
    Verified
    Failed
    Skipped
    Pending

impl ProofStatus:
    fn to_text() -> text:
        match self:
            case Verified: "verified"
            case Failed: "failed"
            case Skipped: "skipped"
            case Pending: "pending"

    fn is_success() -> bool:
        match self:
            case Verified: true
            case _: false

# ============================================================================
# Proof Result
# ============================================================================

struct ProofResult:
    """Result of checking a single file."""
    file_path: text
    status: ProofStatus
    sorry_count: i64
    error_message: text
    theorem_count: i64

impl ProofResult:
    fn summary_line() -> text:
        val status_str = self.status.to_text()
        var detail = ""
        if self.sorry_count > 0:
            detail = " ({self.sorry_count} sorry)"
        if self.error_message.len() > 0:
            detail = "{detail} - {self.error_message}"
        "[{status_str}] {self.file_path}: {self.theorem_count} theorems{detail}"

# ============================================================================
# Check Result (aggregate)
# ============================================================================

struct CheckResult:
    """Aggregate result of checking the inventory."""
    file_results: [ProofResult]

impl CheckResult:
    fn verified_count() -> i64:
        var count = 0
        for r in self.file_results:
            if r.status == ProofStatus.Verified:
                count = count + 1
        count

    fn pending_count() -> i64:
        var count = 0
        for r in self.file_results:
            if r.status == ProofStatus.Pending:
                count = count + 1
        count

    fn failure_count() -> i64:
        var count = 0
        for r in self.file_results:
            if r.status == ProofStatus.Failed:
                count = count + 1
        count

    fn skipped_count() -> i64:
        var count = 0
        for r in self.file_results:
            if r.status == ProofStatus.Skipped:
                count = count + 1
        count

    fn total_sorry_count() -> i64:
        var count = 0
        for r in self.file_results:
            count = count + r.sorry_count
        count

    fn total_theorem_count() -> i64:
        var count = 0
        for r in self.file_results:
            count = count + r.theorem_count
        count

    fn summary() -> text:
        val total = self.file_results.len()
        val verified = self.verified_count()
        val pending = self.pending_count()
        val failed = self.failure_count()
        val skipped = self.skipped_count()
        val theorems = self.total_theorem_count()
        val sorries = self.total_sorry_count()
        var lines: [text] = []
        lines = lines.push("Proof Check Summary")
        lines = lines.push("===================")
        lines = lines.push("Files checked: {total}")
        lines = lines.push("  Verified:  {verified}")
        lines = lines.push("  Failed:    {failed}")
        lines = lines.push("  Pending:   {pending}")
        lines = lines.push("  Skipped:   {skipped}")
        lines = lines.push("")
        lines = lines.push("Theorems: {theorems}")
        lines = lines.push("Pending proofs (sorry): {sorries}")
        lines.join("\n")

# ============================================================================
# Inventory
# ============================================================================

fn known_verification_files() -> [text]:
    regen.known_regenerated_files()

# ============================================================================
# Checker Configuration
# ============================================================================

class CheckerConfig:
    project_dir: text
    lean_path: text
    lake_path: text
    timeout_ms: i64

    static fn create() -> CheckerConfig:
        CheckerConfig(
            project_dir: ".",
            lean_path: "lean",
            lake_path: "lake",
            timeout_ms: 30000
        )

    fn with_project_dir(dir: text) -> CheckerConfig:
        CheckerConfig(
            project_dir: dir,
            lean_path: self.lean_path,
            lake_path: self.lake_path,
            timeout_ms: self.timeout_ms
        )

fn is_lean_available() -> bool:
    val config = CheckerConfig.create()
    val runner = LakeRunner.new(config.project_dir)
    runner.is_available()

# ============================================================================
# Proof Checker
# ============================================================================

class ProofChecker:
    """Checks Lean verification artifacts for correctness."""
    config: CheckerConfig
    lake: LakeRunner

    static fn create(config: CheckerConfig = CheckerConfig.create()) -> ProofChecker:
        ProofChecker(
            config: config,
            lake: LakeRunner.new(config.project_dir)
        )

impl ProofChecker:
    fn check_verification_dir() -> CheckResult:
        self.check_files(known_verification_files())

    fn check_files(file_paths: [text]) -> CheckResult:
        var results: [ProofResult] = []
        for file_path in file_paths:
            results = results.push(self.check_file(file_path))
        CheckResult(file_results: results)

    fn check_file(path: text) -> ProofResult:
        if not file_exists(path):
            return ProofResult(
                file_path: path,
                status: ProofStatus.Failed,
                sorry_count: 0,
                error_message: "missing file",
                theorem_count: 0
            )

        val content = file_read(path)
        val sorry_count = _count_sorry(content)
        val theorem_count = _count_theorems(content)

        if sorry_count > 0:
            return ProofResult(
                file_path: path,
                status: ProofStatus.Failed,
                sorry_count: sorry_count,
                error_message: "contains sorry",
                theorem_count: theorem_count
            )

        if not self.lake.is_available():
            return ProofResult(
                file_path: path,
                status: ProofStatus.Failed,
                sorry_count: sorry_count,
                error_message: "Lean 4 / Lake not available",
                theorem_count: theorem_count
            )

        match self.lake.check_file(path):
            case Ok(_):
                ProofResult(
                    file_path: path,
                    status: ProofStatus.Verified,
                    sorry_count: sorry_count,
                    error_message: "",
                    theorem_count: theorem_count
                )
            case Err(msg):
                ProofResult(
                    file_path: path,
                    status: ProofStatus.Failed,
                    sorry_count: sorry_count,
                    error_message: msg,
                    theorem_count: theorem_count
                )

    fn summary() -> text:
        self.check_verification_dir().summary()

# ============================================================================
# Helpers
# ============================================================================

fn _count_sorry(content: text) -> i64:
    var count = 0
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("--"):
            pass
        else:
            if trimmed.contains("sorry"):
                count = count + 1
    count

fn _count_theorems(content: text) -> i64:
    var count = 0
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("theorem "):
            count = count + 1
    count
