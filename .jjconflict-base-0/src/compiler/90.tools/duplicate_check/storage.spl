# Shared file helpers for duplicate-check persistence.

use std.nogc_sync_mut.io.file_ops.{file_exists, file_read, file_write}

fn read_text_if_exists(path: text) -> text:
    if not file_exists(path):
        return ""
    file_read(path) ?? ""

fn read_lines_if_exists(path: text) -> [text]:
    val content = read_text_if_exists(path)
    if content.len() == 0:
        return []
    content.split("\n")

fn write_lines(path: text, lines: [text]):
    file_write(path, lines.join("\n"))
