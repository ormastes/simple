# Size report — AC-3, AC-4
# AC-3: reusable size-budget script support
# AC-4: release packaging strip + budget wiring

# One binary measurement in a size report
class SizeReportEntry:
    binary_name: text
    size_bytes: i64
    budget_bytes: i64
    stripped: bool

    static fn create(name: text, sz: i64, budget: i64) -> SizeReportEntry:
        return SizeReportEntry(
            binary_name: name,
            size_bytes: sz,
            budget_bytes: budget,
            stripped: false
        )

    static fn stripped_entry(name: text, sz: i64, budget: i64) -> SizeReportEntry:
        return SizeReportEntry(
            binary_name: name,
            size_bytes: sz,
            budget_bytes: budget,
            stripped: true
        )

    me over_budget() -> bool:
        return self.size_bytes > self.budget_bytes

    me budget_pct() -> i64:
        if self.budget_bytes == 0:
            return 0
        return (self.size_bytes * 100) / self.budget_bytes

    me summary() -> text:
        var status = "ok"
        if self.over_budget() == true:
            status = "OVER"
        return self.binary_name + ": " + self.size_bytes.to_text() + "/" + self.budget_bytes.to_text() + "b [" + status + "]"


# CI gate — pass/warn/fail based on budget thresholds
class SizeCiGate:
    warn_pct: i64
    fail_pct: i64

    static fn default_gate() -> SizeCiGate:
        return SizeCiGate(warn_pct: 80, fail_pct: 100)

    static fn strict_gate() -> SizeCiGate:
        return SizeCiGate(warn_pct: 70, fail_pct: 95)

    me evaluate(entry: SizeReportEntry) -> text:
        var pct: i64 = entry.budget_pct()
        if pct >= self.fail_pct:
            return "fail"
        if pct >= self.warn_pct:
            return "warn"
        return "pass"

    me is_blocking(entry: SizeReportEntry) -> bool:
        return self.evaluate(entry) == "fail"


# Full size report for a release build
class BinarySizeReport:
    total_entries: i32
    over_budget_count: i32
    largest_bytes: i64
    total_bytes: i64

    static fn empty() -> BinarySizeReport:
        return BinarySizeReport(
            total_entries: 0,
            over_budget_count: 0,
            largest_bytes: 0,
            total_bytes: 0
        )

    me add(entry: SizeReportEntry) -> BinarySizeReport:
        var new_over: i32 = self.over_budget_count
        if entry.over_budget() == true:
            new_over = new_over + 1
        var new_largest: i64 = self.largest_bytes
        if entry.size_bytes > self.largest_bytes:
            new_largest = entry.size_bytes
        return BinarySizeReport(
            total_entries: self.total_entries + 1,
            over_budget_count: new_over,
            largest_bytes: new_largest,
            total_bytes: self.total_bytes + entry.size_bytes
        )

    me all_pass() -> bool:
        return self.over_budget_count == 0

    me average_bytes() -> i64:
        if self.total_entries == 0:
            return 0
        return self.total_bytes / self.total_entries.to_i64()


# Summary text output for CI logs
class SizeReportSummary:
    report_name: text
    pass_count: i32
    warn_count: i32
    fail_count: i32

    static fn create(name: text) -> SizeReportSummary:
        return SizeReportSummary(
            report_name: name,
            pass_count: 0,
            warn_count: 0,
            fail_count: 0
        )

    me record(status: text) -> SizeReportSummary:
        if status == "fail":
            return SizeReportSummary(
                report_name: self.report_name,
                pass_count: self.pass_count,
                warn_count: self.warn_count,
                fail_count: self.fail_count + 1
            )
        if status == "warn":
            return SizeReportSummary(
                report_name: self.report_name,
                pass_count: self.pass_count,
                warn_count: self.warn_count + 1,
                fail_count: self.fail_count
            )
        return SizeReportSummary(
            report_name: self.report_name,
            pass_count: self.pass_count + 1,
            warn_count: self.warn_count,
            fail_count: self.fail_count
        )

    me is_clean() -> bool:
        return self.fail_count == 0

    me headline() -> text:
        return self.report_name + ": " + self.pass_count.to_text() + " pass, " + self.warn_count.to_text() + " warn, " + self.fail_count.to_text() + " fail"
