use compiler.common.dependency.graph.{ImportGraph}

struct DSMMatrix:
    modules: [text]
    matrix: [[i64]]

fn _sort_text(values: [text]) -> [text]:
    var result = values
    for i in range(0, result.len()):
        for j in range(i + 1, result.len()):
            if result[j] < result[i]:
                val tmp = result[i]
                result[i] = result[j]
                result[j] = tmp
    result

fn _idx(values: [text], value: text) -> i64:
    for i in range(0, values.len()):
        if values[i] == value:
            return i
    -1

fn build_dsm(graph: ImportGraph) -> DSMMatrix:
    val modules = _sort_text(graph.edges.keys())
    var matrix: [[i64]] = []
    for _i in range(0, modules.len()):
        var row: [i64] = []
        for _j in range(0, modules.len()):
            row.push(0)
        matrix.push(row)
    for from in graph.edges.keys():
        val from_idx = _idx(modules, from)
        for to in graph.edges[from]:
            val to_idx = _idx(modules, to)
            if from_idx >= 0 and to_idx >= 0 and from_idx != to_idx:
                var row = matrix[from_idx]
                row[to_idx] = row[to_idx] + 1
                matrix[from_idx] = row
    DSMMatrix(modules: modules, matrix: matrix)

fn build_layer_ordered_dsm(graph: ImportGraph) -> DSMMatrix:
    build_dsm(graph)

export DSMMatrix
export build_dsm
export build_layer_ordered_dsm
