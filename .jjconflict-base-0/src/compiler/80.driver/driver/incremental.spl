# Incremental Compilation
#
# Hash-based change detection for avoiding unnecessary recompilation.
# Tracks file fingerprints, dependency relationships, and provides
# a build cache with integrity checking.


# ============================================================================
# File Fingerprinting
# ============================================================================

struct FileFingerprint:
    """Content hash + metadata for a source file."""
    path: text
    content_hash: text      # SHA-256 of file content
    modified_time: i64      # Unix timestamp
    size: i64               # File size in bytes

impl FileFingerprint:
    static fn from_file(path: text) -> FileFingerprint?:
        """Create fingerprint from a file on disk."""
        extern fn rt_file_exists(path: text) -> bool
        extern fn rt_file_size(path: text) -> i64
        extern fn rt_file_modified(path: text) -> i64
        extern fn rt_file_read_text(path: text) -> text
        extern fn rt_hash_sha256(content: text) -> text

        if not rt_file_exists(path):
            return nil

        val content = rt_file_read_text(path)
        val hash = rt_hash_sha256(content)
        val size = rt_file_size(path)
        val mtime = rt_file_modified(path)

        Some(FileFingerprint(path: path, content_hash: hash,
                             modified_time: mtime, size: size))

    static fn quick_changed(path: text, cached: FileFingerprint) -> bool:
        """Fast check using size only — avoids read+hash when size unchanged."""
        extern fn rt_file_exists(path: text) -> bool
        extern fn rt_file_size(path: text) -> i64
        if not rt_file_exists(path):
            return true
        val current_size = rt_file_size(path)
        current_size != cached.size

    fn matches(other: FileFingerprint) -> bool:
        """Check if two fingerprints match (same content)."""
        self.content_hash == other.content_hash

    fn is_stale(other: FileFingerprint) -> bool:
        """Check if the other fingerprint is newer."""
        self.content_hash != other.content_hash

# ============================================================================
# Dependency Tracking
# ============================================================================

struct DependencyEntry:
    """Tracks what a file depends on."""
    source: text            # Source file path
    fingerprint: FileFingerprint
    dependencies: [text]    # Files this source imports/uses
    outputs: [text]         # Generated artifact paths

impl DependencyEntry:
    fn needs_recompile(current: FileFingerprint, dep_cache: {text: FileFingerprint}) -> bool:
        """Check if this entry needs recompilation."""
        # Source file changed
        if self.fingerprint.is_stale(current):
            return true
        # Any dependency changed — quick size check before full hash
        for dep in self.dependencies:
            if dep_cache.contains_key(dep):
                val cached = dep_cache[dep]
                if FileFingerprint.quick_changed(dep, cached):
                    # Size changed — definitely stale, skip expensive hash
                    return true
                val fresh = FileFingerprint.from_file(dep)
                if fresh.? and cached.is_stale(fresh.unwrap()):
                    return true
        false

# ============================================================================
# Change Detection
# ============================================================================

enum ChangeKind:
    Added
    Modified
    Deleted
    DependencyChanged

struct ChangeSet:
    """Set of changes detected since last build."""
    changes: [(text, ChangeKind)]

impl ChangeSet:
    static fn empty() -> ChangeSet:
        ChangeSet(changes: [])

    fn add(path: text, kind: ChangeKind) -> ChangeSet:
        ChangeSet(changes: self.changes.push((path, kind)))

    fn is_empty() -> bool:
        self.changes.len() == 0

    fn changed_files() -> [text]:
        var out: [text] = []
        for item in self.changes:
            val path = item[0]
            out = out.push(path)
        out

    fn added() -> [text]:
        var out: [text] = []
        for item in self.changes:
            val kind = item[1]
            if kind == ChangeKind.Added:
                out = out.push(item[0])
        out

    fn modified() -> [text]:
        var out: [text] = []
        for item in self.changes:
            val kind = item[1]
            if kind == ChangeKind.Modified:
                out = out.push(item[0])
        out

    fn deleted() -> [text]:
        var out: [text] = []
        for item in self.changes:
            val kind = item[1]
            if kind == ChangeKind.Deleted:
                out = out.push(item[0])
        out

# ============================================================================
# Build Cache
# ============================================================================

class BuildCache:
    """Persistent build cache with integrity checking.

    Stores fingerprints and dependency info between builds.
    Serialized to .build_cache.sdn in project root.
    """
    entries: {text: DependencyEntry}
    fingerprints: {text: FileFingerprint}
    cache_path: text
    version: i64

impl BuildCache:
    static fn empty(cache_path: text) -> BuildCache:
        BuildCache(entries: {}, fingerprints: {}, cache_path: cache_path, version: 0)

    static fn load(cache_path: text) -> BuildCache:
        """Load cache from disk, or create empty if not found."""
        extern fn rt_file_exists(path: text) -> bool
        if not rt_file_exists(cache_path):
            return BuildCache.empty(cache_path)

        use std.sdn.{parse_file, SdnValue}

        match parse_file(cache_path):
            case Ok(sdn_value):
                val ver = sdn_value.get("version")
                var version: i64 = 0
                if ver.?:
                    val v = ver.unwrap().as_i64()
                    if v.?:
                        version = v.unwrap()

                var entries: {text: DependencyEntry} = {}
                var fingerprints: {text: FileFingerprint} = {}

                val entries_val = sdn_value.get("entries")
                if entries_val.?:
                    val arr = entries_val.unwrap().as_array()
                    if arr.?:
                        for item in arr.unwrap():
                            val src = item.get("source")
                            if not src.?:
                                continue
                            val source_str = src.unwrap().as_str()
                            if not source_str.?:
                                continue
                            val source = source_str.unwrap()

                            # Parse fingerprint
                            var fp_hash = ""
                            var fp_size: i64 = 0
                            var fp_mtime: i64 = 0
                            val fp_val = item.get("fingerprint")
                            if fp_val.?:
                                val fp_obj = fp_val.unwrap()
                                val h = fp_obj.get("hash")
                                if h.?:
                                    val hs = h.unwrap().as_str()
                                    if hs.?:
                                        fp_hash = hs.unwrap()
                                val s = fp_obj.get("size")
                                if s.?:
                                    val si = s.unwrap().as_i64()
                                    if si.?:
                                        fp_size = si.unwrap()
                                val m = fp_obj.get("modified_time")
                                if m.?:
                                    val mi = m.unwrap().as_i64()
                                    if mi.?:
                                        fp_mtime = mi.unwrap()

                            val fp = FileFingerprint(
                                path: source, content_hash: fp_hash,
                                modified_time: fp_mtime, size: fp_size)

                            # Parse dependencies
                            var deps: [text] = []
                            val deps_val = item.get("dependencies")
                            if deps_val.?:
                                val deps_arr = deps_val.unwrap().as_array()
                                if deps_arr.?:
                                    for d in deps_arr.unwrap():
                                        val ds = d.as_str()
                                        if ds.?:
                                            deps = deps.push(ds.unwrap())

                            # Parse outputs
                            var outs: [text] = []
                            val outs_val = item.get("outputs")
                            if outs_val.?:
                                val outs_arr = outs_val.unwrap().as_array()
                                if outs_arr.?:
                                    for o in outs_arr.unwrap():
                                        val os = o.as_str()
                                        if os.?:
                                            outs = outs.push(os.unwrap())

                            val entry = DependencyEntry(
                                source: source, fingerprint: fp,
                                dependencies: deps, outputs: outs)
                            entries[source] = entry
                            fingerprints[source] = fp

                BuildCache(entries: entries, fingerprints: fingerprints,
                           cache_path: cache_path, version: version)
            case Err(error):
                BuildCache.empty(cache_path)

    me save():
        """Persist cache to disk."""
        use std.sdn.{SdnValue, render_value}
        extern fn rt_file_write_text(path: text, content: text) -> bool
        extern fn rt_mkdir_p(path: text) -> bool

        self.version = self.version + 1

        var sdn_entries: [SdnValue] = []
        for key in self.entries.keys():
            val entry = self.entries[key]

            # Serialize fingerprint
            val fp_dict = SdnValue.Dict({
                "hash": SdnValue.String(entry.fingerprint.content_hash),
                "size": SdnValue.Int(entry.fingerprint.size),
                "modified_time": SdnValue.Int(entry.fingerprint.modified_time)
            })

            # Serialize dependencies
            var dep_values: [SdnValue] = []
            for dep in entry.dependencies:
                dep_values = dep_values.push(SdnValue.String(dep))

            # Serialize outputs
            var out_values: [SdnValue] = []
            for out in entry.outputs:
                out_values = out_values.push(SdnValue.String(out))

            val entry_dict = SdnValue.Dict({
                "source": SdnValue.String(entry.source),
                "fingerprint": fp_dict,
                "dependencies": SdnValue.Array(dep_values),
                "outputs": SdnValue.Array(out_values)
            })
            sdn_entries = sdn_entries.push(entry_dict)

        val sdn_doc = SdnValue.Dict({
            "version": SdnValue.Int(self.version),
            "entries": SdnValue.Array(sdn_entries)
        })

        # Ensure parent directory exists
        val parent_end = self.cache_path.last_index_of("/")
        if parent_end.?:
            val idx = parent_end.unwrap()
            if idx > 0:
                val parent = self.cache_path[0:idx]
                rt_mkdir_p(parent)

        val sdn_text = render_value(sdn_doc, 0)
        rt_file_write_text(self.cache_path, sdn_text)

    me update_entry(source: text, fingerprint: FileFingerprint,
                    dependencies: [text], outputs: [text]):
        """Update or create a cache entry."""
        self.fingerprints[source] = fingerprint
        self.entries[source] = DependencyEntry(
            source: source, fingerprint: fingerprint,
            dependencies: dependencies, outputs: outputs)

    me remove_entry(source: text):
        self.entries.remove(source)
        self.fingerprints.remove(source)

    fn has_cached_object(source: text) -> bool:
        """Check if source has a cached entry with fresh fingerprint and existing outputs."""
        extern fn rt_file_exists(path: text) -> bool
        if not self.entries.contains_key(source):
            return false
        val entry = self.entries[source]
        # Check fingerprint is still fresh
        val fresh = FileFingerprint.from_file(source)
        if not fresh.?:
            return false
        if entry.fingerprint.is_stale(fresh.unwrap()):
            return false
        # Check all output files still exist on disk
        for out in entry.outputs:
            if not rt_file_exists(out):
                return false
        true

    fn get_cached_outputs(source: text) -> [text]?:
        """Return cached output paths if entry is fresh, else nil."""
        if not self.has_cached_object(source):
            return nil
        Some(self.entries[source].outputs)

    me invalidate(source: text):
        """Remove a stale entry."""
        self.remove_entry(source)

    fn get_entry(source: text) -> DependencyEntry?:
        if self.entries.contains_key(source):
            Some(self.entries[source])
        else:
            nil

    fn detect_changes(source_files: [text]) -> ChangeSet:
        """Detect changes since last build."""
        var changes = ChangeSet.empty()

        # Check for modified and added files
        for path in source_files:
            val fresh = FileFingerprint.from_file(path)
            if not fresh.?:
                continue
            if not self.fingerprints.contains_key(path):
                changes = changes.add(path, ChangeKind.Added)
            elif self.fingerprints[path].is_stale(fresh.unwrap()):
                changes = changes.add(path, ChangeKind.Modified)

        # Check for deleted files
        for path in self.fingerprints.keys():
            if not source_files.contains(path):
                changes = changes.add(path, ChangeKind.Deleted)

        # Check transitive dependencies
        for (path, kind) in changes.changes:
            match kind:
                case Added | Modified:
                    # Find all files that depend on this one
                    # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
                    for src in self.entries.keys():
                        val entry = self.entries[src]
                        if entry.dependencies.contains(path):
                            if not changes.changed_files().contains(src):
                                changes = changes.add(src, ChangeKind.DependencyChanged)
                case _: ()

        changes

    me invalidate_all():
        """Clear entire cache."""
        self.entries = {}
        self.fingerprints = {}
        self.version = self.version + 1

    fn integrity_check() -> bool:
        """Verify cache integrity."""
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for path in self.fingerprints.keys():
            val fp = self.fingerprints[path]
            val fresh = FileFingerprint.from_file(path)
            if not fresh.?:
                return false
        true

# ============================================================================
# Incremental Compiler
# ============================================================================

class IncrementalCompiler:
    """Orchestrates incremental compilation using build cache."""
    cache: BuildCache
    source_root: text
    symbol_hashes: {text: {text: text}}
    cached_mir_index: {text: [text]}

impl IncrementalCompiler:
    static fn create(source_root: text, cache_path: text) -> IncrementalCompiler:
        val cache = BuildCache.load(cache_path)
        IncrementalCompiler(cache: cache, source_root: source_root,
                            symbol_hashes: {}, cached_mir_index: {})

    me compile_incremental(source_files: [text]) -> ([text], ChangeSet):
        """Determine which files need recompilation.

        Returns (files_to_compile, change_set).
        """
        val changes = self.cache.detect_changes(source_files)

        if changes.is_empty():
            return ([], changes)

        val to_compile = changes.changed_files()
        (to_compile, changes)

    me record_compilation(source: text, dependencies: [text], outputs: [text]):
        """Record a successful compilation."""
        val fp = FileFingerprint.from_file(source)
        if fp.?:
            self.cache.update_entry(source, fp.unwrap(), dependencies, outputs)

    me finish():
        """Save cache after build."""
        self.cache.save()

    me clean():
        """Clear build cache."""
        self.cache.invalidate_all()
        self.symbol_hashes = {}
        self.cached_mir_index = {}
        self.cache.save()

    # --- Symbol-Level Incremental MIR Cache ---

    me update_symbol_hashes(source: text, hashes: {text: text}):
        """Store symbol hashes for a source file after compilation."""
        self.symbol_hashes[source] = hashes

    fn get_changed_symbols(source: text, new_hashes: {text: text}) -> [text]:
        """Compare new symbol hashes against cached ones, return changed symbol names."""
        if not self.symbol_hashes.contains_key(source):
            # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
            var all_names: [text] = []
            for name in new_hashes.keys():
                all_names = all_names.push(name)
            return all_names

        val old_hashes = self.symbol_hashes[source]
        var changed: [text] = []

        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for name in new_hashes.keys():
            val new_hash = new_hashes[name]
            if old_hashes.contains_key(name):
                if old_hashes[name] != new_hash:
                    changed = changed.push(name)
            else:
                changed = changed.push(name)

        for name in old_hashes.keys():
            if not new_hashes.contains_key(name):
                changed = changed.push(name)

        changed

    fn get_cached_mir_functions(source: text):
        """Return cached MIR function SDN blobs for unchanged functions in a source file.

        Returns a dict mapping function name to serialized MIR text, or nil if no cache.
        Uses .build/mir_cache/ directory for per-function MIR storage.
        """
        extern fn rt_file_exists(path: text) -> bool
        extern fn rt_file_read_text(path: text) -> text

        if not self.cached_mir_index.contains_key(source):
            return nil

        val func_names = self.cached_mir_index[source]
        var result: {text: text} = {}
        val cache_dir = ".build/mir_cache"

        for name in func_names:
            val safe_name = name.replace("/", "_").replace(":", "_")
            val mir_path = "{cache_dir}/{safe_name}.sdn"
            if rt_file_exists(mir_path):
                val content = rt_file_read_text(mir_path)
                if content != "":
                    result[name] = content

        if result.len() == 0:
            return nil
        Some(result)

    me cache_mir_function(source: text, func_name: text, mir_sdn: text):
        """Cache a single function's MIR to disk."""
        extern fn rt_mkdir_p(path: text) -> bool
        extern fn rt_file_write_text(path: text, content: text) -> bool

        val cache_dir = ".build/mir_cache"
        rt_mkdir_p(cache_dir)

        val safe_name = func_name.replace("/", "_").replace(":", "_")
        val mir_path = "{cache_dir}/{safe_name}.sdn"
        rt_file_write_text(mir_path, mir_sdn)

        if not self.cached_mir_index.contains_key(source):
            self.cached_mir_index[source] = []
        val existing = self.cached_mir_index[source]
        if not existing.contains(func_name):
            self.cached_mir_index[source] = existing.push(func_name)

# ============================================================================
# MIR Merge (Symbol-Level)
# ============================================================================

fn merge_mir(cached_fns: {text: text}, new_fns: {text: text}) -> {text: text}:
    """Merge cached unchanged MIR functions with newly compiled changed functions.

    For each function, if it exists in new_fns (freshly compiled), use the new version.
    Otherwise, use the cached version. This allows symbol-level granularity:
    only changed functions are recompiled, unchanged ones reuse cached MIR.
    """
    var merged: {text: text} = {}

    # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
    for name in cached_fns.keys():
        merged[name] = cached_fns[name]

    for name in new_fns.keys():
        merged[name] = new_fns[name]

    merged
