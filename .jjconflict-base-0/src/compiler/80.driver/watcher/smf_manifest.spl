#![allow(unnamed_duplicate_typed_args)]
# SMF Manifest — Tracks compiled SMF files for interpreter cache lookup
#
# Provides a persistent index mapping source paths to compiled SMF files.
# Used by the watcher daemon (write) and interpreter (read) for
# SMF cache discovery without scanning the filesystem.
#
# Format: SDN at build/smf/manifest.sdn
# Concurrent access safety: atomic write via tmp+rename pattern.


extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_rename(src: text, dst: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_hash_text(s: text) -> i64

# ============================================================================
# Types
# ============================================================================

struct SmfManifestEntry:
    source_path: text
    smf_path: text
    source_hash: i64
    compiled_at: i64
    backend: text       # "cranelift" or "llvm"

struct SmfManifest:
    version: i64
    entries: Dict<text, SmfManifestEntry>  # source_path -> entry
    updated_at: i64

# ============================================================================
# Constructors
# ============================================================================

fn smf_manifest_new() -> SmfManifest:
    SmfManifest(
        version: 1,
        entries: {},
        updated_at: rt_time_now_unix_micros()
    )

fn smf_manifest_entry_new(source_path: text, smf_path: text, source_hash: i64, backend: text) -> SmfManifestEntry:
    SmfManifestEntry(
        source_path: source_path,
        smf_path: smf_path,
        source_hash: source_hash,
        compiled_at: rt_time_now_unix_micros(),
        backend: backend
    )

# ============================================================================
# Manifest Operations
# ============================================================================

fn smf_manifest_update(manifest: SmfManifest, entry: SmfManifestEntry) -> SmfManifest:
    """Add or update an entry in the manifest."""
    var entries = manifest.entries
    entries[entry.source_path] = entry
    SmfManifest(
        version: manifest.version,
        entries: entries,
        updated_at: rt_time_now_unix_micros()
    )

fn smf_manifest_remove(manifest: SmfManifest, source_path: text) -> SmfManifest:
    """Remove an entry from the manifest."""
    var entries = manifest.entries
    if entries.contains_key(source_path):
        entries.remove(source_path)
    SmfManifest(
        version: manifest.version,
        entries: entries,
        updated_at: rt_time_now_unix_micros()
    )

fn smf_manifest_find(manifest: SmfManifest, source_path: text) -> SmfManifestEntry?:
    """Look up the SMF path for a source file."""
    if manifest.entries.contains_key(source_path):
        return Some(manifest.entries[source_path])
    nil

fn smf_manifest_count(manifest: SmfManifest) -> i64:
    manifest.entries.len()

# ============================================================================
# SDN Serialization
# ============================================================================

fn smf_manifest_to_sdn(manifest: SmfManifest) -> text:
    """Serialize manifest to SDN format."""
    var lines: [text] = [
        "smf_manifest:",
        "  version: {manifest.version}",
        "  updated_at: {manifest.updated_at}",
        ""
    ]

    if manifest.entries.len() > 0:
        lines = lines + ["entries |source_path, smf_path, source_hash, compiled_at, backend|"]
        for key in manifest.entries.keys():
            val e = manifest.entries[key]
            lines = lines + ["    \"{e.source_path}\", \"{e.smf_path}\", {e.source_hash}, {e.compiled_at}, \"{e.backend}\""]

    lines.join("\n")

fn smf_manifest_from_sdn(content: text) -> SmfManifest:
    """Parse manifest from SDN format."""
    var version: i64 = 1
    var updated_at: i64 = 0
    var entries: Dict<text, SmfManifestEntry> = {}
    var in_entries = false

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            continue

        if trimmed.starts_with("version:"):
            val val_str = trimmed.replace("version:", "").trim()
            version = val_str.to_i64() ?? 1
        else if trimmed.starts_with("updated_at:"):
            val val_str = trimmed.replace("updated_at:", "").trim()
            updated_at = val_str.to_i64() ?? 0
        else if trimmed.starts_with("entries "):
            in_entries = true
        else if in_entries and trimmed.starts_with("\""):
            val entry = parse_manifest_entry_line(trimmed)
            if entry.?:
                val e = entry.unwrap()
                entries[e.source_path] = e

    SmfManifest(version: version, entries: entries, updated_at: updated_at)

fn parse_manifest_entry_line(line: text) -> SmfManifestEntry?:
    """Parse a single SDN table row: "source", "smf", hash, time, "backend" """
    val parts = line.split(", ")
    if parts.len() < 5:
        return nil

    val source_path = parts[0].trim().replace("\"", "")
    val smf_path = parts[1].trim().replace("\"", "")
    val source_hash = parts[2].trim().to_i64() ?? 0
    val compiled_at = parts[3].trim().to_i64() ?? 0
    val backend = parts[4].trim().replace("\"", "")

    Some(SmfManifestEntry(
        source_path: source_path,
        smf_path: smf_path,
        source_hash: source_hash,
        compiled_at: compiled_at,
        backend: backend
    ))

# ============================================================================
# File I/O (atomic write)
# ============================================================================

val SMF_MANIFEST_DEFAULT_PATH: text = "build/smf/manifest.sdn"

fn load_smf_manifest(path: text) -> SmfManifest:
    """Load manifest from file. Returns empty manifest if file doesn't exist."""
    if not rt_file_exists(path):
        return smf_manifest_new()
    val content = rt_file_read_text(path) ?? ""
    if content == "":
        return smf_manifest_new()
    smf_manifest_from_sdn(content)

fn save_smf_manifest(manifest: SmfManifest, path: text) -> bool:
    """Save manifest to file using atomic tmp+rename."""
    val dir = path_dir(path)
    rt_mkdir_p(dir)

    val sdn = smf_manifest_to_sdn(manifest)
    val tmp_path = "{path}.tmp"

    if not rt_file_write_text(tmp_path, sdn):
        return false
    rt_file_rename(tmp_path, path)

fn load_smf_manifest_default() -> SmfManifest:
    load_smf_manifest(SMF_MANIFEST_DEFAULT_PATH)

fn save_smf_manifest_default(manifest: SmfManifest) -> bool:
    save_smf_manifest(manifest, SMF_MANIFEST_DEFAULT_PATH)

# ============================================================================
# Convenience: update + save in one call
# ============================================================================

fn update_smf_manifest_entry(source_path: text, smf_path: text, source_hash: i64, backend: text) -> bool:
    """Load manifest, update entry, save. Convenience for single-entry updates."""
    var manifest = load_smf_manifest_default()
    val entry = smf_manifest_entry_new(source_path, smf_path, source_hash, backend)
    manifest = smf_manifest_update(manifest, entry)
    save_smf_manifest_default(manifest)

# ============================================================================
# Helpers
# ============================================================================

fn path_dir(path: text) -> text:
    """Extract directory from file path."""
    val last_slash = path.last_index_of("/")
    if last_slash >= 0:
        return path[0:last_slash]
    "."
