# Watcher Lock — Singleton enforcement via lock file with PID
#
# Delegates to daemon_sdk.lock for core lock logic.
# Preserves existing watcher API names for backward compatibility.


use std.daemon_sdk.lock.{
    try_acquire_daemon_lock, release_daemon_lock,
    is_daemon_running, read_daemon_pid, is_pid_alive
}

# ============================================================================
# Delegation to daemon_sdk
# ============================================================================

fn try_acquire_watcher_lock(lock_path: text) -> i64:
    try_acquire_daemon_lock(lock_path)

fn release_watcher_lock(pid: i64, lock_path: text) -> bool:
    release_daemon_lock(pid, lock_path)

fn is_watcher_running(lock_path: text) -> bool:
    is_daemon_running(lock_path)

fn read_watcher_pid(lock_path: text) -> i64:
    read_daemon_pid(lock_path)
