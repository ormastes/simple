# Bounds Check Elimination
#
# Removes provably redundant explicit bounds-check intrinsics.
#
# MIR array indexing lowers to an explicit bounds-check intrinsic followed by
# GetElementPtr + Load/Store. This pass keeps normal memory operations unchanged
# and only removes repeated explicit bounds-check intrinsics when the exact same
# check has already appeared earlier in the same basic block.
#
# Improvement A — Loop-aware bounds proof (pattern annotation):
#   When a loop condition block contains `i < arr.len()` guard AND the index var
#   is monotone-increasing (only `Add(i, const)` mutations in loop body), all
#   `BoundsCheck(i, arr_len)` accesses in the loop body are provably safe.
#   `propagate_loop_bounds_proof` detects and records these candidate proofs.
#   The proofs feed into eliminate_in_block as pre-seeded entries in `seen_checks`.

use compiler.mir.mir_data.*
use compiler.mir.mir.*
use compiler.mir.mir_instructions.{MirFunction, MirBlock}
use compiler.mir_opt.mod.{MirPass}

class LoopBoundsProof:
    """Records a proven loop-bounds proof for (index_var_id, arr_local_id).
    When a while-loop guard `i < arr.len()` is detected and `i` is monotone-
    increasing inside the loop body, all BoundsCheck(i, arr_len) in the body
    are safe and can be eliminated via pre-seeded seen_checks entries."""
    index_var_id: i64
    arr_local_id: i64
    proof_key: text

class ExplicitRangeProof:
    """Records an explicit range proof for a variable.
    When a guard like `if x >= lo and x < hi` is detected, the variable
    is proven to be in [lower_bound, upper_bound) and bounds checks
    against arrays of sufficient length can be eliminated."""
    var_id: i64
    lower_bound: i64
    upper_bound: i64
    proof_key: text

class ConstantIndexProof:
    """Records a constant-index proof for an array access.
    When the index is a compile-time constant and the array length is
    known or guarded, the bounds check can be eliminated."""
    index_const: i64
    arr_local_id: i64
    proof_key: text

class BoundsCheckElimination:
    """Conservative bounds-check elimination pass."""
    removed_checks: i64
    observed_checks: i64
    observed_geps: i64
    loop_proofs: [LoopBoundsProof]

impl BoundsCheckElimination:
    static fn new() -> BoundsCheckElimination:
        BoundsCheckElimination(
            removed_checks: 0,
            observed_checks: 0,
            observed_geps: 0,
            loop_proofs: []
        )

    fn name() -> text:
        "bounds_check_elimination"

    fn description() -> text:
        "Eliminates duplicate explicit bounds-check intrinsics"

    fn is_analysis_pass() -> bool:
        false

    fn dependencies() -> [text]:
        ["loop_invariant_motion"]

    me run_on_function(func: MirFunction) -> MirFunction:
        # Improvement A: collect loop-bounds proofs before per-block sweep.
        # Proofs are annotation records only — they feed seen_checks as pre-seeds
        # in eliminate_in_block so the dedup logic eliminates proven-safe checks.
        self.loop_proofs = collect_loop_bounds_proofs(func)

        # Build proof key set for fast lookup in eliminate_in_block.
        var proof_keys: Dict<text, bool> = {}
        for proof in self.loop_proofs:
            proof_keys[proof.proof_key] = true

        var optimized_blocks: [MirBlock] = []
        var modified = false

        for block in func.blocks:
            val optimized = self.eliminate_in_block_with_proofs(block, proof_keys)
            if optimized.instructions.len() != block.instructions.len():
                modified = true
            optimized_blocks = optimized_blocks.push(optimized)

        if modified:
            MirFunction(..func, blocks: optimized_blocks)
        else:
            func

    me eliminate_in_block_with_proofs(block: MirBlock, proof_keys: Dict<text, bool>) -> MirBlock:
        # Pre-seed seen_checks with any loop-bounds proof keys that apply here.
        # A proof key has the same format as bounds_check_key so the existing
        # dedup logic eliminates the proven-safe check on first occurrence.
        var seen_checks: Dict<text, bool> = {}
        for key in proof_keys.keys():
            seen_checks[key] = true
        self.eliminate_in_block_with_seen(block, seen_checks)

    me eliminate_in_block(block: MirBlock) -> MirBlock:
        val empty: Dict<text, bool> = {}
        self.eliminate_in_block_with_seen(block, empty)

    me eliminate_in_block_with_seen(block: MirBlock, pre_seen: Dict<text, bool>) -> MirBlock:
        var seen_checks: Dict<text, bool> = pre_seen
        var new_instructions: [MirInst] = []
        var changed = false

        for inst in block.instructions:
            match inst.kind:
                case GetElementPtr(_, _, _):
                    self.observed_geps = self.observed_geps + 1
                    new_instructions = new_instructions.push(inst)
                case Intrinsic(_, name, args):
                    if is_bounds_check_intrinsic(name):
                        self.observed_checks = self.observed_checks + 1
                        val key = bounds_check_key(name, args)
                        if seen_checks.has(key):
                            self.removed_checks = self.removed_checks + 1
                            changed = true
                        else:
                            seen_checks[key] = true
                            new_instructions = new_instructions.push(inst)
                    else:
                        new_instructions = new_instructions.push(inst)
                case Call(_, func_op, args):
                    val check_name = bounds_check_call_name(func_op)
                    if check_name.?:
                        self.observed_checks = self.observed_checks + 1
                        val key = bounds_check_key(check_name.unwrap(), args)
                        if seen_checks.has(key):
                            self.removed_checks = self.removed_checks + 1
                            changed = true
                        else:
                            seen_checks[key] = true
                            new_instructions = new_instructions.push(inst)
                    else:
                        new_instructions = new_instructions.push(inst)
                case _:
                    new_instructions = new_instructions.push(inst)

        if changed:
            MirBlock(
                id: block.id,
                label: block.label,
                instructions: new_instructions,
                terminator: block.terminator
            )
        else:
            block

    fn stats_summary() -> text:
        "BoundsCheckElim: removed {self.removed_checks} duplicate checks, observed {self.observed_checks} checks and {self.observed_geps} GEPs"

fn is_bounds_check_intrinsic(name: text) -> bool:
    (
        name == "bounds_check" or
        name == "array_bounds_check" or
        name == "rt_bounds_check" or
        name == "__simple_bounds_check"
    )

fn bounds_check_call_name(func_op: MirOperand) -> text?:
    match func_op.kind:
        case Const(value, type_):
            match type_.kind:
                case FuncPtr(_):
                    match value:
                        case Str(name):
                            if is_bounds_check_intrinsic(name):
                                Some(name)
                            else:
                                nil
                        case _:
                            nil
                case _:
                    nil
        case _:
            nil

fn bounds_check_key(name: text, args: [MirOperand]) -> text:
    var parts: [text] = [name]
    for arg in args:
        parts = parts.push(bounds_operand_key(arg))
    parts.join("|")

fn bounds_operand_key(op: MirOperand) -> text:
    match op.kind:
        case Copy(local):
            "copy:{local.id}"
        case Move(local):
            "move:{local.id}"
        case Const(value, _):
            "const:{bounds_const_key(value)}"

fn bounds_const_key(value: MirConstValue) -> text:
    match value:
        case Int(v): "int:{v}"
        case Float(v): "float:{v}"
        case Bool(v): "bool:{v}"
        case Str(v): "str:{v}"
        case Zero: "zero"
        case Array(_): "array"
        case Tuple(_): "tuple"
        case Struct(_): "struct"

fn create_bounds_check_elim_pass() -> BoundsCheckElimination:
    BoundsCheckElimination.new()

fn bounds_check_elim_run_on_function(bce_pass: BoundsCheckElimination, func: MirFunction) -> MirFunction:
    func

# ============================================================================
# Improvement A — Loop-aware bounds proof recognition (pattern annotation)
# ============================================================================
#
# Detects the shape: while i < arr.len() { ... arr[i] ... i = i + const }
# and records a LoopBoundsProof for each proven-safe (index_var, arr_local) pair.
# Proofs are annotation records; they pre-seed seen_checks before block sweeps
# so the existing dedup logic eliminates the redundant BoundsCheck intrinsics.

fn collect_loop_bounds_proofs(func: MirFunction) -> [LoopBoundsProof]:
    var proofs: [LoopBoundsProof] = []
    for block in func.blocks:
        val guard = detect_loop_guard(block)
        if guard.?:
            val g = guard.unwrap()
            # Only emit a proof when index var is monotone-increasing in this block.
            if is_monotone_increasing(block, g.index_var_id):
                val key = bounds_check_proof_key(g.index_var_id, g.arr_local_id)
                proofs = proofs.push(LoopBoundsProof(
                    index_var_id: g.index_var_id,
                    arr_local_id: g.arr_local_id,
                    proof_key: key
                ))
    proofs

class LoopGuardInfo:
    """Recognized i < arr.len() loop guard."""
    index_var_id: i64
    arr_local_id: i64

fn detect_loop_guard(block: MirBlock) -> LoopGuardInfo?:
    # Look for a Lt comparison terminator or a Lt BinOp in last instruction
    # pattern: BinOp(cond, Lt, Copy(i), Call("len", [arr])) or similar.
    for inst in block.instructions:
        val g = try_match_loop_guard_inst(inst)
        if g.?:
            return g
    nil

fn try_match_loop_guard_inst(inst: MirInst) -> LoopGuardInfo?:
    match inst.kind:
        case BinOp(_, op, left, right):
            match op:
                case Lt:
                    val idx_id = operand_local_id_raw(left)
                    val arr_id = operand_local_id_raw(right)
                    if idx_id.? and arr_id.?:
                        return LoopGuardInfo(
                            index_var_id: idx_id.unwrap(),
                            arr_local_id: arr_id.unwrap()
                        )
                    nil
                case _: nil
        case _: nil

fn is_monotone_increasing(block: MirBlock, index_var_id: i64) -> bool:
    # The index var is monotone-increasing if every assignment to it in the block
    # has the shape: BinOp(i, Add, Copy(i), Const(positive)) — i.e. i = i + c.
    # If ANY non-add assignment to the index var is found, return false.
    var found_increment = false
    for inst in block.instructions:
        val mutates = inst_mutates_local(inst, index_var_id)
        if mutates:
            if not inst_is_positive_add_of_self(inst, index_var_id):
                return false
            found_increment = true
    found_increment

fn inst_mutates_local(inst: MirInst, local_id: i64) -> bool:
    match inst.kind:
        case BinOp(dest, _, _, _):  dest.id == local_id
        case Copy(dest, _):          dest.id == local_id
        case Move(dest, _):          dest.id == local_id
        case Cast(dest, _, _):       dest.id == local_id
        case _:                      false

fn inst_is_positive_add_of_self(inst: MirInst, local_id: i64) -> bool:
    match inst.kind:
        case BinOp(dest, op, left, right):
            if dest.id != local_id:
                return false
            match op:
                case Add:
                    val self_ref = operand_local_id_raw(left)
                    val is_pos_const = operand_is_positive_const(right)
                    if self_ref.? and is_pos_const:
                        return self_ref.unwrap() == local_id
                    nil
                case _: false
        case _: false

fn operand_local_id_raw(op: MirOperand) -> i64?:
    match op.kind:
        case Copy(local): Some(local.id)
        case Move(local): Some(local.id)
        case _: nil

fn operand_is_positive_const(op: MirOperand) -> bool:
    match op.kind:
        case Const(value, _):
            match value:
                case Int(v): v > 0
                case _: false
        case _: false

fn bounds_check_proof_key(index_var_id: i64, arr_local_id: i64) -> text:
    # Key format mirrors bounds_check_key so pre-seeded entries match
    # checks of the form: bounds_check|copy:{index_var_id}|copy:{arr_local_id}
    "bounds_check|copy:{index_var_id}|copy:{arr_local_id}"
