# Target Family — L1 Identity Layer
#
# Classifies target triples into architecture families and builds
# feature sets for downstream optimization matrix evaluation.

# ============================================================================
# TargetFamily enum
# ============================================================================

pub enum TargetFamily:
    X86_64
    X86_32
    Aarch64
    Arm32
    Rv64
    Rv32
    Unknown

# ============================================================================
# TargetFeatureSet — normalized feature descriptor
# ============================================================================

pub struct TargetFeatureSet:
    triple: text
    family: TargetFamily
    cpu: text
    abi: text
    features: [text]
    strict: bool
    opt_level: i64

# ============================================================================
# Free functions
# ============================================================================

pub fn target_family_from_triple(triple: text) -> text:
    """Classify a target triple into a family name string."""
    val fam = target_family_enum_from_triple(triple)
    target_family_name(fam)

pub fn target_family_enum_from_triple(triple: text) -> TargetFamily:
    """Parse a target triple and return the TargetFamily enum variant."""
    if triple.len() == 0:
        return TargetFamily.Unknown
    if triple.starts_with("x86_64") or triple.starts_with("x86-64"):
        return TargetFamily.X86_64
    if triple.starts_with("i686") or triple.starts_with("i386") or triple.starts_with("x86_32"):
        return TargetFamily.X86_32
    if triple.starts_with("aarch64") or triple.starts_with("arm64"):
        return TargetFamily.Aarch64
    if triple.starts_with("armv7") or triple.starts_with("arm32") or triple.starts_with("thumbv7"):
        return TargetFamily.Arm32
    if triple.starts_with("riscv64") or triple.starts_with("rv64"):
        return TargetFamily.Rv64
    if triple.starts_with("riscv32") or triple.starts_with("rv32"):
        return TargetFamily.Rv32
    TargetFamily.Unknown

pub fn target_family_name(family: TargetFamily) -> text:
    """Convert a TargetFamily enum variant to its canonical name string."""
    match family:
        case X86_64:  "X86_64"
        case X86_32:  "X86_32"
        case Aarch64: "Aarch64"
        case Arm32:   "Arm32"
        case Rv64:    "Rv64"
        case Rv32:    "Rv32"
        case Unknown: "Unknown"

pub fn target_feature_set_new(triple: text, flags: [text]) -> TargetFeatureSet:
    """Build a TargetFeatureSet from a triple string and feature flags."""
    val fam = target_family_enum_from_triple(triple)
    TargetFeatureSet(
        triple: triple,
        family: fam,
        cpu: "",
        abi: "",
        features: flags,
        strict: false,
        opt_level: 2
    )
