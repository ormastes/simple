#![allow(unnamed_duplicate_typed_args)]
# Closure Capture Lint
#
# Detects when closures modify outer variables, which is a known
# runtime limitation. Changes made inside nested functions don't
# persist to the outer scope due to capture-by-value semantics.
#
# CLOS001: Closure modifies outer variable (changes won't persist)    WARNING
#
# Known limitation: Closures can READ outer vars but CANNOT MODIFY them.
# Changes made inside nested functions don't persist to outer scope.
#
# Example problem:
#   var count = 0
#   fn increment(): count = count + 1
#   increment()
#   print count  # Prints 0, not 1!
#
# Does NOT flag:
# - Module-level var mutations (those work correctly)
# - Reads of outer variables (only writes are problematic)
# - extern fn declarations (no body)
#
# Works with the arena-based core AST (integer-tagged nodes).

use compiler.core.ast_expr.{
    EXPR_IDENT, EXPR_ASSIGN, EXPR_COMPOUND_ASSIGN,
    EXPR_CALL, EXPR_METHOD_CALL, EXPR_BINARY, EXPR_UNARY,
    EXPR_INDEX, EXPR_FIELD_ACCESS, EXPR_ARRAY_LIT, EXPR_IF,
    EXPR_MATCH, EXPR_FOR, EXPR_WHILE, EXPR_BLOCK, EXPR_RETURN,
    EXPR_LAMBDA, EXPR_STRUCT_LIT, EXPR_DO_BLOCK,
    EXPR_DICT_LIT, EXPR_TUPLE, EXPR_SLICE, EXPR_NULL_COALESCE,
    EXPR_OPTIONAL_CHAIN, EXPR_CAST, EXPR_INTERPOLATED_STRING,
    EXPR_RANGE, EXPR_SPREAD, EXPR_LIST_COMP, EXPR_DICT_COMP,
    expr_tag, expr_s_val, expr_left, expr_right, expr_extra, expr_args, expr_stmts
}
use compiler.core.ast_stmt.{
    STMT_EXPR, STMT_VAL_DECL, STMT_VAR_DECL, STMT_ASSIGN,
    STMT_IF, STMT_FOR, STMT_WHILE, STMT_BLOCK, STMT_MATCH,
    STMT_COMPOUND_ASSIGN,
    stmt_tag, stmt_expr, stmt_name, stmt_body
}
use compiler.core.ast.{
    DECL_FN, DECL_EXTERN_FN, DECL_VAL, DECL_VAR,
    decl_tag, decl_name, decl_param_names, decl_body_stmts
}

# ============================================================================
# Warning Struct
# ============================================================================

struct ClosureCaptureWarning:
    code: text
    severity: text
    message: text
    hint: text
    fn_name: text
    var_name: text
    outer_fn: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message} in '{self.fn_name}' — {self.hint}"

# ============================================================================
# Main Entry Point
# ============================================================================

fn check_closure_capture(decl_indices: [i64]) -> [ClosureCaptureWarning]:
    """Run closure-capture lint on module declarations.

    For each function, tracks variable declarations at each scope level.
    When a nested function (closure) assigns to an outer variable,
    emit CLOS001 warning since the change won't persist.
    """
    var warnings: [ClosureCaptureWarning] = []

    # Collect module-level var declarations
    var module_vars: {text: bool} = {}
    for idx in decl_indices:
        val tag = decl_tag[idx]
        if tag == DECL_VAR:
            module_vars[decl_name[idx]] = true

    # Check each function for closure capture issues
    for idx in decl_indices:
        val tag = decl_tag[idx]
        if tag != DECL_FN:
            continue

        val fn_name = decl_name[idx]
        val params = decl_param_names[idx]
        val body = decl_body_stmts[idx]

        if body.len() == 0:
            continue

        # Collect local vars declared in this function
        var local_vars: {text: bool} = {}
        for p in params:
            local_vars[p] = true
        collect_local_var_decls(body, local_vars)

        # Look for nested function definitions that modify outer vars
        val fn_warnings = check_stmts_for_nested_capture(body, fn_name, local_vars, module_vars)
        for w in fn_warnings:
            warnings.push(w)

    warnings

# ============================================================================
# Local Variable Collection
# ============================================================================

fn collect_local_var_decls(stmts: [i64], vars: {text: bool}):
    """Collect all val/var declaration names from a statement list."""
    for s in stmts:
        if s < 0:
            continue
        val tag = stmt_tag[s]
        if tag == STMT_VAL_DECL or tag == STMT_VAR_DECL:
            val name = stmt_name[s]
            if name != "":
                vars[name] = true

        # Recurse into nested blocks (but NOT nested functions)
        if tag == STMT_IF or tag == STMT_BLOCK or tag == STMT_FOR or tag == STMT_WHILE or tag == STMT_MATCH:
            collect_local_var_decls(stmt_body[s], vars)

# ============================================================================
# Nested Capture Detection
# ============================================================================

fn check_stmts_for_nested_capture(
    stmts: [i64],
    outer_fn: text,
    outer_vars: {text: bool},
    module_vars: {text: bool}
) -> [ClosureCaptureWarning]:
    """Walk statements looking for nested functions/lambdas that modify outer vars."""
    var warnings: [ClosureCaptureWarning] = []

    for s in stmts:
        if s < 0:
            continue
        val tag = stmt_tag[s]

        # Check expressions for lambdas and nested function calls
        if tag == STMT_EXPR or tag == STMT_VAL_DECL or tag == STMT_VAR_DECL:
            val e = stmt_expr[s]
            if e >= 0:
                val ws = check_expr_for_nested_capture(e, outer_fn, outer_vars, module_vars)
                for w in ws:
                    warnings.push(w)

        # Recurse into nested statement blocks
        if tag == STMT_IF or tag == STMT_BLOCK or tag == STMT_FOR or tag == STMT_WHILE or tag == STMT_MATCH:
            val nested = check_stmts_for_nested_capture(stmt_body[s], outer_fn, outer_vars, module_vars)
            for w in nested:
                warnings.push(w)

    warnings

fn check_expr_for_nested_capture(
    e: i64,
    outer_fn: text,
    outer_vars: {text: bool},
    module_vars: {text: bool}
) -> [ClosureCaptureWarning]:
    """Check an expression for lambda/closure bodies that modify outer vars."""
    var warnings: [ClosureCaptureWarning] = []
    if e < 0:
        return warnings

    val tag = expr_tag[e]

    # Lambda expression — check its body for writes to outer vars
    if tag == EXPR_LAMBDA:
        val body = expr_right[e]
        if body >= 0:
            val ws = check_expr_for_outer_writes(body, outer_fn, "lambda", outer_vars, module_vars)
            for w in ws:
                warnings.push(w)
        # Also check stmts inside lambda
        for child_stmt in expr_stmts[e]:
            if child_stmt >= 0:
                val ws = check_stmts_for_outer_writes(
                    [child_stmt], outer_fn, "lambda", outer_vars, module_vars
                )
                for w in ws:
                    warnings.push(w)
        return warnings

    # Recurse into sub-expressions
    val left = expr_left[e]
    if left >= 0:
        val ws = check_expr_for_nested_capture(left, outer_fn, outer_vars, module_vars)
        for w in ws:
            warnings.push(w)

    val right = expr_right[e]
    if right >= 0:
        val ws = check_expr_for_nested_capture(right, outer_fn, outer_vars, module_vars)
        for w in ws:
            warnings.push(w)

    for arg in expr_args[e]:
        val ws = check_expr_for_nested_capture(arg, outer_fn, outer_vars, module_vars)
        for w in ws:
            warnings.push(w)

    for child_stmt in expr_stmts[e]:
        if child_stmt >= 0:
            val child_e = stmt_expr[child_stmt]
            if child_e >= 0:
                val ws = check_expr_for_nested_capture(child_e, outer_fn, outer_vars, module_vars)
                for w in ws:
                    warnings.push(w)
            val child_body = stmt_body[child_stmt]
            val nested = check_stmts_for_nested_capture(child_body, outer_fn, outer_vars, module_vars)
            for w in nested:
                warnings.push(w)

    warnings

# ============================================================================
# Outer Write Detection (inside closures)
# ============================================================================

fn check_stmts_for_outer_writes(
    stmts: [i64],
    outer_fn: text,
    closure_name: text,
    outer_vars: {text: bool},
    module_vars: {text: bool}
) -> [ClosureCaptureWarning]:
    """Check statements inside a closure for writes to outer variables."""
    var warnings: [ClosureCaptureWarning] = []

    for s in stmts:
        if s < 0:
            continue
        val tag = stmt_tag[s]

        if tag == STMT_ASSIGN or tag == STMT_COMPOUND_ASSIGN:
            val name = stmt_name[s]
            if name != "":
                # Only warn if it's an outer var and NOT a module-level var
                if outer_vars.contains_key(name) and not module_vars.contains_key(name):
                    warnings.push(ClosureCaptureWarning(
                        code: "CLOS001",
                        severity: "WARNING",
                        message: "closure '{closure_name}' modifies outer variable '{name}' — changes won't persist",
                        hint: "use return value or class/struct state instead of modifying captured variable",
                        fn_name: outer_fn,
                        var_name: name,
                        outer_fn: outer_fn
                    ))

        if tag == STMT_EXPR or tag == STMT_VAL_DECL or tag == STMT_VAR_DECL:
            val e = stmt_expr[s]
            if e >= 0:
                val ws = check_expr_for_outer_writes(e, outer_fn, closure_name, outer_vars, module_vars)
                for w in ws:
                    warnings.push(w)

        # Recurse into nested blocks
        if tag == STMT_IF or tag == STMT_BLOCK or tag == STMT_FOR or tag == STMT_WHILE or tag == STMT_MATCH:
            val nested = check_stmts_for_outer_writes(stmt_body[s], outer_fn, closure_name, outer_vars, module_vars)
            for w in nested:
                warnings.push(w)

    warnings

fn check_expr_for_outer_writes(
    e: i64,
    outer_fn: text,
    closure_name: text,
    outer_vars: {text: bool},
    module_vars: {text: bool}
) -> [ClosureCaptureWarning]:
    """Check an expression inside a closure for writes to outer variables."""
    var warnings: [ClosureCaptureWarning] = []
    if e < 0:
        return warnings

    val tag = expr_tag[e]

    # Assignment: check if target is an outer var
    if tag == EXPR_ASSIGN or tag == EXPR_COMPOUND_ASSIGN:
        val target = expr_left[e]
        if target >= 0:
            if expr_tag[target] == EXPR_IDENT:
                val var_name = expr_s_val[target]
                if outer_vars.contains_key(var_name) and not module_vars.contains_key(var_name):
                    warnings.push(ClosureCaptureWarning(
                        code: "CLOS001",
                        severity: "WARNING",
                        message: "closure '{closure_name}' modifies outer variable '{var_name}' — changes won't persist",
                        hint: "use return value or class/struct state instead of modifying captured variable",
                        fn_name: outer_fn,
                        var_name: var_name,
                        outer_fn: outer_fn
                    ))

    # Recurse into sub-expressions
    val left = expr_left[e]
    if left >= 0:
        val ws = check_expr_for_outer_writes(left, outer_fn, closure_name, outer_vars, module_vars)
        for w in ws:
            warnings.push(w)

    val right = expr_right[e]
    if right >= 0:
        val ws = check_expr_for_outer_writes(right, outer_fn, closure_name, outer_vars, module_vars)
        for w in ws:
            warnings.push(w)

    for arg in expr_args[e]:
        val ws = check_expr_for_outer_writes(arg, outer_fn, closure_name, outer_vars, module_vars)
        for w in ws:
            warnings.push(w)

    for child_stmt in expr_stmts[e]:
        if child_stmt >= 0:
            val child_e = stmt_expr[child_stmt]
            if child_e >= 0:
                val ws = check_expr_for_outer_writes(child_e, outer_fn, closure_name, outer_vars, module_vars)
                for w in ws:
                    warnings.push(w)
            val child_body = stmt_body[child_stmt]
            val nested = check_stmts_for_outer_writes(child_body, outer_fn, closure_name, outer_vars, module_vars)
            for w in nested:
                warnings.push(w)

    warnings

# ============================================================================
# Exports
# ============================================================================
