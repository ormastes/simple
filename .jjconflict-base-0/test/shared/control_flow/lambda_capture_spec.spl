# @platform: all
# # Lambda Capture Specification
#
# Regression coverage for backslash lambdas capturing parent locals and function
# parameters. These cases also protect compact multicore green fanout programs
# that build worker closures inside loops.

describe "lambda capture":
    it "captures parent locals":
        val seed = 5
        val f = \: seed + 7
        expect f() == 12

    it "captures function parameters":
        fn make(seed: i64) -> i64:
            val f = \: seed + 7
            f()

        expect make(5) == 12
