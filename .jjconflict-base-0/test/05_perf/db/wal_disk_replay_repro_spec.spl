# Isolation spec for wal-disk-replay-blank-row-p0 fix.
# Verifies MetaStore disk replay reconstructs exact field data (non-stub).
use std.spec.{describe, it, expect}
use nogc_sync_mut.db.dbfs_engine.meta_store.{MetaStore, MetaOp}
use nogc_sync_mut.db.dbfs_engine.schema.{InodeRow, DentryRow}

extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

fn replay_field() -> text:
    val path = "/tmp/wal_repro/iso.db"
    rt_dir_create_all("/tmp/wal_repro")
    rt_file_delete(path + ".meta.wal")
    rt_file_delete(path + ".meta.ckpt")
    var ms = MetaStore.create(path)
    ms.write_inode(InodeRow(ino_id: 42, gen: 1, mode: 33188 as u32, uid: 1000 as u32, gid: 1000 as u32, link_count: 1, size: 420, mtime: 111, ctime: 222, flags: 7 as u32))
    ms.write_dentry(DentryRow(parent_ino: 1, name: "bench.txt", child_ino: 42, gen: 1))
    val msr = MetaStore.open(path)
    match msr:
        case Ok(store):
            val entries = store.replay_journal()
            var ino_str: text = ""
            var size_str: text = ""
            var name_str: text = ""
            var i = 0
            while i < entries.len():
                match entries[i].op:
                    case MetaOp.InodeWrite(r):
                        ino_str = r.ino_id.to_text()
                        size_str = r.size.to_text()
                    case MetaOp.DentryWrite(d):
                        name_str = d.name
                    case _:
                        i = i
                i = i + 1
            ino_str + "|" + size_str + "|" + name_str
        case Err(msg):
            "ERR:" + msg

describe "wal disk replay isolation":
    it "reconstructs exact field data":
        expect(replay_field()).to_equal("42|420|bench.txt")
