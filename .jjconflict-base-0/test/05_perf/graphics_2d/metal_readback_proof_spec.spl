# @tag:perf
# @tag:graphics
# @tag:metal
#
# Verifies a real Metal compute dispatch can be downloaded through the raw
# pointer path and compared byte-for-byte without using the broken [u8] out-param.

use std.spec.*

extern fn rt_metal_is_available() -> i64
extern fn rt_metal_create_device(idx: i64) -> i64
extern fn rt_metal_destroy_device(dev: i64) -> i64
extern fn rt_metal_create_command_queue(dev: i64) -> i64
extern fn rt_metal_destroy_command_queue(q: i64) -> i64
extern fn rt_metal_alloc_buffer(dev: i64, size: i64) -> i64
extern fn rt_metal_free_buffer(buf: i64) -> i64
extern fn rt_metal_compile_shader(dev: i64, source: text) -> i64
extern fn rt_metal_destroy_shader(shader: i64) -> i64
extern fn rt_metal_create_compute_pipeline(dev: i64, shader: i64, entry: text) -> i64
extern fn rt_metal_destroy_pipeline(pipe: i64) -> i64
extern fn rt_metal_run_compute_frame(queue: i64, pipeline: i64, buf0: i64, buf1: i64, params_ptr: i64, params_size: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> i64
extern fn rt_metal_buffer_download(data_ptr: i64, buffer: i64, size: i64) -> i64
extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

val PROOF_W: i64 = 16
val PROOF_H: i64 = 16
val PROOF_BYTES: i64 = 16 * 16 * 4
val PROOF_COLOR: i64 = 0x10203040
val PROOF_PAIR: i64 = 0x1020304010203040
val PROOF_MSL: text = "#include <metal_stdlib>\nusing namespace metal;\n\nstruct FillParams { uint color; uint w; uint h; };\nkernel void fill_kernel(\n    device uint8_t *dst [[ buffer(0) ]],\n    constant FillParams &p [[ buffer(2) ]],\n    uint2 gid [[ thread_position_in_grid ]])\n{\n    if (gid.x >= p.w || gid.y >= p.h) return;\n    uint off = (gid.y * p.w + gid.x) * 4u;\n    dst[off+0] = (p.color) & 0xFF;\n    dst[off+1] = (p.color >> 8) & 0xFF;\n    dst[off+2] = (p.color >> 16) & 0xFF;\n    dst[off+3] = (p.color >> 24) & 0xFF;\n}\n"

fn cleanup(dev: i64, queue: i64, shader: i64, pipe: i64, buf: i64, params: i64, host: i64):
    if host != 0:
        rt_free(host)
    if params != 0:
        rt_free(params)
    if buf != 0:
        rt_metal_free_buffer(buf)
    if pipe != 0:
        rt_metal_destroy_pipeline(pipe)
    if shader != 0:
        rt_metal_destroy_shader(shader)
    if queue != 0:
        rt_metal_destroy_command_queue(queue)
    if dev != 0:
        rt_metal_destroy_device(dev)

fn metal_readback_mismatches() -> i64:
    if rt_metal_is_available() == 0:
        return -1
    val dev = rt_metal_create_device(0)
    val queue = if dev != 0: rt_metal_create_command_queue(dev) else: 0
    val shader = if dev != 0: rt_metal_compile_shader(dev, PROOF_MSL) else: 0
    val pipe = if dev != 0 and shader != 0: rt_metal_create_compute_pipeline(dev, shader, "fill_kernel") else: 0
    val buf = if dev != 0: rt_metal_alloc_buffer(dev, PROOF_BYTES) else: 0
    val params = rt_alloc(12)
    val host = rt_alloc(PROOF_BYTES)
    if dev == 0 or queue == 0 or shader == 0 or pipe == 0 or buf == 0 or params == 0 or host == 0:
        cleanup(dev, queue, shader, pipe, buf, params, host)
        return -2
    rt_ptr_write_i32(params, 0, PROOF_COLOR)
    rt_ptr_write_i32(params, 4, PROOF_W)
    rt_ptr_write_i32(params, 8, PROOF_H)
    val submitted = rt_metal_run_compute_frame(queue, pipe, buf, buf, params, 12, 1, 1, 1, 16, 16, 1)
    if submitted == 0:
        cleanup(dev, queue, shader, pipe, buf, params, host)
        return -3
    val downloaded = rt_metal_buffer_download(host, buf, PROOF_BYTES)
    if downloaded == 0:
        cleanup(dev, queue, shader, pipe, buf, params, host)
        return -4
    var mismatches: i64 = 0
    var i: i64 = 0
    while i < (PROOF_W * PROOF_H) / 2:
        if rt_ptr_read_i64(host, i * 8) != PROOF_PAIR:
            mismatches = mismatches + 2
        i = i + 1
    cleanup(dev, queue, shader, pipe, buf, params, host)
    mismatches

describe "Metal raw pointer readback proof":

    it "downloads a deterministic Metal compute buffer":
        val mismatches = metal_readback_mismatches()
        print "METAL_READBACK_PROOF mismatches={mismatches}"
        if mismatches == -1:
            expect(true).to_equal(true)
        else:
            expect(mismatches).to_equal(0)
