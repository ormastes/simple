# Compile-only spec for src/os/kernel/abi/syscall_shim.spl (Wave 10D).
#
# These tests verify the shim's public surface: function name, arity,
# and return type.  They do NOT invoke shims because that requires kernel
# context (UART port I/O / MMIO, live Scheduler).
#
# Run with: bin/simple test test/os/kernel/abi/syscall_shim_spec.spl

use std.spec.{describe, it, expect}
use os.kernel.abi.syscall_shim.{
    shim_init,
    spl_handle_debug_write,
    spl_handle_exit,
    spl_handle_yield,
    spl_handle_spawn,
    spl_handle_wait,
    spl_handle_getpid,
    spl_handle_list_tasks,
    spl_handle_get_task_info,
    spl_handle_signal,
    spl_handle_set_priority,
    spl_handle_get_parent_pid,
    spl_handle_mmap,
    spl_handle_munmap,
    spl_handle_mprotect,
    spl_handle_spawn_binary,
    spl_handle_ipc_send,
    spl_handle_ipc_recv,
    spl_handle_ipc_create_port,
    spl_handle_ipc_connect,
    spl_handle_notification_create,
    spl_handle_notification_signal,
    spl_handle_notification_wait,
    spl_handle_notification_poll,
    spl_handle_notification_destroy,
    spl_handle_notification_wait_any,
    spl_handle_file_open,
    spl_handle_file_read,
    spl_handle_file_write,
    spl_handle_file_close,
    spl_handle_file_stat,
    spl_handle_file_mkdir,
    spl_handle_file_readdir,
    spl_handle_mount,
    spl_handle_unmount,
    spl_handle_unlink,
    spl_handle_pledge,
    spl_handle_unveil,
    spl_handle_cap_grant,
    spl_handle_ftruncate,
    spl_handle_rename,
    spl_handle_rmdir,
    spl_handle_lseek,
    spl_handle_getcwd,
    spl_handle_chdir,
    spl_handle_clock_gettime,
    spl_handle_sleep,
    spl_handle_net_socket,
    spl_handle_net_bind,
    spl_handle_net_listen,
    spl_handle_net_connect,
    spl_handle_net_accept,
    spl_handle_net_send_to,
    spl_handle_net_recv_from,
    spl_handle_net_if_config,
    spl_handle_dev_enumerate,
    spl_handle_dev_get_info,
    spl_handle_device_grant,
    spl_handle_map_bar,
    spl_handle_alloc_dma,
    spl_handle_free_dma,
    spl_handle_log_write,
    spl_handle_log_read,
    spl_handle_sysinfo,
    spl_handle_get_hostname,
    spl_handle_set_hostname
}

describe "syscall_shim — compile-time surface checks":

    it "shim_init accepts Scheduler, IpcManager, KernelLog":
        val init_ref = shim_init
        expect(init_ref).to_not_be_nil()

    it "spl_handle_debug_write accepts six u64 arguments":
        val fn_ref: fn(u64, u64, u64, u64, u64, u64) -> i64 = spl_handle_debug_write
        expect(fn_ref).to_not_be_nil()

    it "spl_handle_debug_write return type is i64":
        val result: i64 = spl_handle_debug_write(0, 0, 0, 0, 0, 0)
        expect(result).to_be_i64()

    it "spl_handle_exit has arity six u64 -> i64":
        val fn_ref: fn(u64, u64, u64, u64, u64, u64) -> i64 = spl_handle_exit
        expect(fn_ref).to_not_be_nil()

