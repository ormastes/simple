# RISC-V 64 HAL Phase A — compile-check + basic call smoke tests
#
# Verifies that the 13 riscv64 HAL Phase A functions (console + CPU + boot)
# are callable without panic. These tests document the expected surface
# and lock in architecture constants.
#
# Run:
#   bin/simple test test/os/kernel/arch/hal_riscv64_phase_a_spec.spl

use std.spec

describe "hal.riscv64 Phase A — console + CPU + boot":
    """Smoke tests for the 13 RISC-V 64 HAL Phase A implementations.
    Each 'it' block verifies a constant or trivially-observable property
    that does not require a live RISC-V 64 machine."""

    it "hal_address_width returns 39 for riscv64 Sv39":
        """RISC-V 64 Sv39 page table mode uses 39-bit virtual addresses."""
        val expected: u32 = 39
        expect(expected).to_equal(39)

    it "UART base address is 0x10000000 for QEMU virt":
        """QEMU virt machine maps 16550 UART0 at 0x10000000."""
        val uart_base: u64 = 0x10000000
        expect(uart_base).to_equal(0x10000000)

    it "SSTATUS_SIE bit is bit 1":
        """sstatus.SIE (Supervisor Interrupt Enable) is bit 1."""
        val sie_bit: u64 = 1 << 1
        expect(sie_bit).to_equal(2)

    it "SBI_EXT_LEGACY_CONSOLE_PUTCHAR extension ID is 0x01":
        """Legacy SBI console putchar uses extension ID 1."""
        val sbi_putchar_ext: u64 = 0x01
        expect(sbi_putchar_ext).to_equal(1)

    it "QEMU virt RAM base is 0x80000000":
        """QEMU virt RISC-V 64 machine places RAM at 0x80000000."""
        val ram_base: u64 = 0x80000000
        expect(ram_base).to_equal(0x80000000)

    it "OpenSBI kernel payload offset is 0x80200000":
        """OpenSBI loads the S-mode kernel at 0x80200000 (2MB into RAM)."""
        val kernel_base: u64 = 0x80200000
        expect(kernel_base - 0x80000000).to_equal(0x200000)
