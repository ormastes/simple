#![allow(unnamed_duplicate_typed_args)]

# Spec for the x86_64 boot GDT selector layout (Wave 10A).
#
# The GDT in examples/simple_os/arch/x86_64/boot/crt0.s was expanded
# from 3 entries to 5 entries so MSR_STAR can be programmed for
# SYSCALL/SYSRET (Intel SDM Vol 3A §5.8.8).
#
# Entry order (each descriptor is 8 bytes):
#   0x00: null
#   0x08: kernel CS  — 64-bit, DPL=0, L=1
#   0x10: kernel SS/DS — DPL=0
#   0x18: user CS 32-bit compat — DPL=3, L=0, D=1  (SYSRET compat target)
#   0x20: user SS/DS — DPL=3                         (SYSRET SS)
#   0x28: user CS 64-bit — DPL=3, L=1               (SYSRET 64-bit target)
#
# MSR_STAR encoding:
#   bits[63:48] = USER_CS_32 | 3  = 0x001B  (SYSRET: CS = +16 = 0x28, SS = +8 = 0x20)
#   bits[47:32] = KERNEL_CS       = 0x0008  (SYSCALL: CS = 0x08, SS = 0x10)
#   => MSR_STAR = 0x001B_0008_0000_0000
#
# Run:
#   bin/simple test test/os/kernel/arch/gdt_layout_spec.spl

use std.spec

describe "kernel.arch.x86_64 GDT selector layout":
    """Documents and locks in the 5-entry GDT selector constants required
    for SYSCALL/SYSRET support. These values must match the descriptor
    order in crt0.s and the MSR_STAR encoding in cpu.spl (Wave 10B)."""

    val kernel_cs:  u64 = 0x08
    val kernel_ds:  u64 = 0x10
    val user_cs_32: u64 = 0x18
    val user_ds:    u64 = 0x20
    val user_cs_64: u64 = 0x28

    it "kernel selectors are 8 bytes apart":
        """Each GDT descriptor is 8 bytes, so consecutive selectors
        differ by 8. Kernel CS=0x08 and kernel DS=0x10."""
        expect(kernel_ds - kernel_cs).to_equal(8)

    it "user CS 32-bit immediately follows kernel DS":
        """The SYSRET compat target (user CS 32-bit, selector 0x18)
        must be exactly 8 bytes after kernel DS (0x10) so that the
        MSR_STAR USER_CS_32 field is consistent with the GDT order."""
        expect(user_cs_32 - kernel_ds).to_equal(8)

    it "user DS is 8 bytes after user CS 32-bit":
        """On SYSRET to compat mode the CPU loads SS = USER_CS_32 + 8.
        This asserts SS selector (user_ds=0x20) is exactly that offset."""
        expect(user_ds - user_cs_32).to_equal(8)

    it "user CS 64-bit is 16 bytes after user CS 32-bit":
        """On SYSRET to 64-bit mode the CPU loads CS = USER_CS_32 + 16.
        This asserts user_cs_64 (0x28) is that offset from user_cs_32 (0x18)."""
        expect(user_cs_64 - user_cs_32).to_equal(16)

    it "GDT spans 5 descriptors (40 bytes), limit is 39":
        """5 entries * 8 bytes = 40 bytes total. The LGDT limit field is
        size-1 = 39. Verify by checking the last selector plus 8 equals 40."""
        val gdt_size: u64 = user_cs_64 + 8
        expect(gdt_size).to_equal(40)
        expect(gdt_size - 1).to_equal(39)

    it "MSR_STAR kernel field matches kernel_cs":
        """MSR_STAR bits[47:32] = KERNEL_CS. On SYSCALL the CPU sets
        CS = KERNEL_CS and SS = KERNEL_CS + 8. Lock the expected value."""
        val msr_star_kernel_field: u64 = kernel_cs
        expect(msr_star_kernel_field).to_equal(0x08)

    it "MSR_STAR user field matches user_cs_32 or'd with RPL 3":
        """MSR_STAR bits[63:48] = USER_CS_32 | 3. On 64-bit SYSRET the
        CPU sets CS = (USER_CS_32 | 3) + 16 = 0x2B and
        SS = (USER_CS_32 | 3) + 8 = 0x23."""
        val msr_star_user_field: u64 = user_cs_32 | 3
        expect(msr_star_user_field).to_equal(0x1B)
        # Verify derived SYSRET 64-bit CS = 0x2B
        expect(msr_star_user_field + 16).to_equal(0x2B)
        # Verify derived SYSRET SS = 0x23
        expect(msr_star_user_field + 8).to_equal(0x23)
