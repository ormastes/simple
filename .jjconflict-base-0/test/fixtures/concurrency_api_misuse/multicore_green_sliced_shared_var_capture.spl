use std.concurrent.multicore_green.{multicore_green_spawn_sliced, MulticoreGreenSliceResult}

var shared_state = 0

fn main():
    val handle = multicore_green_spawn_sliced(0, \state:
        shared_state = shared_state + state
        MulticoreGreenSliceResult.completed(shared_state)
    )
    print handle.join()
