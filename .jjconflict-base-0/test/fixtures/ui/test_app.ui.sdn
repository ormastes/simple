app:
    title: "Test App"
    theme: dark

layout:
    type: vbox
    id: root
    children:
        main_panel:
            type: panel
            id: main_panel
            title: "Test App"
            children:
                action_btn:
                    type: button
                    id: action_btn
                    label: "Click Me"
                    action: "do_action"
                search_input:
                    type: input
                    id: search_input
                    placeholder: "Search..."
                nav_list:
                    type: list
                    id: nav_list
                    items:
                        0:
                            label: "Home"
                        1:
                            label: "Settings"
                        2:
                            label: "About"
                status_label:
                    type: text
                    id: status_label
                    content: "Ready"
        app_statusbar:
            type: statusbar
            id: app_statusbar
            left: "Test App"
            right: "Ready"
