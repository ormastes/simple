{"tests": [
  {"description": "Simple p element", "input": "<p>hello</p>", "output": [["StartTag", "p", {}], ["Character", "hello"], ["EndTag", "p"], ["EOF"]]},
  {"description": "Simple div", "input": "<div>content</div>", "output": [["StartTag", "div", {}], ["Character", "content"], ["EndTag", "div"], ["EOF"]]},
  {"description": "Empty string", "input": "", "output": [["EOF"]]},
  {"description": "Self-closing br", "input": "<br/>", "output": [["StartTag", "br", {}, true], ["EOF"]]},
  {"description": "Attribute", "input": "<a href=\"/\">link</a>", "output": [["StartTag", "a", {"href": "/"}], ["Character", "link"], ["EndTag", "a"], ["EOF"]]},
  {"description": "Nested elements", "input": "<div><span>text</span></div>", "output": [["StartTag", "div", {}], ["StartTag", "span", {}], ["Character", "text"], ["EndTag", "span"], ["EndTag", "div"], ["EOF"]]},
  {"description": "Text only", "input": "just text", "output": [["Character", "just text"], ["EOF"]]},
  {"description": "Doctype", "input": "<!DOCTYPE html><p>x</p>", "output": [["DOCTYPE", "html", null, null, true], ["StartTag", "p", {}], ["Character", "x"], ["EndTag", "p"], ["EOF"]]},
  {"description": "Comment", "input": "<!-- comment --><p>x</p>", "output": [["Comment", " comment "], ["StartTag", "p", {}], ["Character", "x"], ["EndTag", "p"], ["EOF"]]},
  {"description": "Script raw text", "input": "<script>var x = 1;</script>", "output": [["StartTag", "script", {}], ["Character", "var x = 1;"], ["EndTag", "script"], ["EOF"]]},
  {"description": "Named entity amp", "input": "<p>&amp;</p>", "output": [["StartTag", "p", {}], ["Character", "&"], ["EndTag", "p"], ["EOF"]]},
  {"description": "Multiple attributes", "input": "<input type=\"text\" name=\"q\">", "output": [["StartTag", "input", {"type": "text", "name": "q"}, true], ["EOF"]]},
  {"description": "H1 heading", "input": "<h1>Title</h1>", "output": [["StartTag", "h1", {}], ["Character", "Title"], ["EndTag", "h1"], ["EOF"]]},
  {"description": "Boolean attribute", "input": "<input disabled>", "output": [["StartTag", "input", {"disabled": ""}, true], ["EOF"]]},
  {"description": "Style tag raw text", "input": "<style>a > b { }</style>", "output": [["StartTag", "style", {}], ["Character", "a > b { }"], ["EndTag", "style"], ["EOF"]]},
  {"description": "UL with LI", "input": "<ul><li>item1</li><li>item2</li></ul>", "output": [["StartTag", "ul", {}], ["StartTag", "li", {}], ["Character", "item1"], ["EndTag", "li"], ["StartTag", "li", {}], ["Character", "item2"], ["EndTag", "li"], ["EndTag", "ul"], ["EOF"]]},
  {"description": "Table basic", "input": "<table><tr><td>cell</td></tr></table>", "output": [["StartTag", "table", {}], ["StartTag", "tr", {}], ["StartTag", "td", {}], ["Character", "cell"], ["EndTag", "td"], ["EndTag", "tr"], ["EndTag", "table"], ["EOF"]]},
  {"description": "Img void element", "input": "<img src=\"a.png\">", "output": [["StartTag", "img", {"src": "a.png"}, true], ["EOF"]]},
  {"description": "Span with class", "input": "<span class=\"foo\">bar</span>", "output": [["StartTag", "span", {"class": "foo"}], ["Character", "bar"], ["EndTag", "span"], ["EOF"]]},
  {"description": "Named entity lt", "input": "&lt;p&gt;", "output": [["Character", "<p>"], ["EOF"]]}
]}
