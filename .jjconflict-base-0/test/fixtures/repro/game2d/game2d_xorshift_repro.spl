# Game2D AC-4 xorshift64 determinism repro — Phase 7 verify.
# Seed → 2 calls; reset same seed → 2 calls. Outputs must match.
use std.nogc_sync_mut.game2d.time.det_guard as t

fn main():
    t.set_deterministic_mode(true)
    t.enter_callback()
    t.seed_random(0xCAFEBABE)
    val a1 = t.random_u64()
    val a2 = t.random_u64()
    t.seed_random(0xCAFEBABE)
    val b1 = t.random_u64()
    val b2 = t.random_u64()
    t.leave_callback()
    print("a1=" + a1.to_text() + " b1=" + b1.to_text())
    print("a2=" + a2.to_text() + " b2=" + b2.to_text())
    if a1 == b1 and a2 == b2:
        print("DETERMINISTIC=true")
    else:
        print("DETERMINISTIC=false")
