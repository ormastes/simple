use compiler.mir.mir_types.{MirType, LocalId, LocalKind, MirLocal, mir_type_integer_width_bytes, mir_type_storage_size, mir_local_storage_size, mir_local_storage_alignment}
use compiler.mir.mir_instructions.{MirFunction, mir_function_local_type}

fn main() -> i64:
    val local = MirLocal(id: LocalId(id: 7), name: nil, type_: MirType.bool(), kind: LocalKind.Temp, is_ghost: false)
    val func = MirFunction(name: "owner_oracle", locals: [local], blocks: [])
    val resolved = mir_function_local_type(func, 7)
    val width = mir_type_integer_width_bytes(resolved)
    val size = mir_type_storage_size(resolved)
    val local_size = mir_local_storage_size(local)
    val alignment = mir_local_storage_alignment(local)
    print(width)
    print(size)
    print(local_size)
    print(alignment)
    if width != 1 or size != 1 or local_size != 1 or alignment != 1:
        return 1
    0
