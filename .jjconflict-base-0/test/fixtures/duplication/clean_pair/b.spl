# Fixture: clean_pair/b.spl - structurally distinct from clean_pair/a.spl.
# The checker MUST report nothing (exit 0, no findings) for this directory.

struct Greeting:
    name: text
    greeted_count: i64

fn build_greeting(name: text) -> text:
    "hello, " + name + "!"

fn record_greeting(g: Greeting) -> Greeting:
    var updated = g
    updated.greeted_count = updated.greeted_count + 1
    updated
