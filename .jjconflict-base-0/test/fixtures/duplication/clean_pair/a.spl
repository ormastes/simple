# Fixture: clean_pair/a.spl - structurally distinct from clean_pair/b.spl.
# The checker MUST report nothing (exit 0, no findings) for this directory.

fn is_prime_candidate(n: i64) -> bool:
    if n < 2:
        return false
    var d = 2
    while d * d <= n:
        if n % d == 0:
            return false
        d = d + 1
    return true
