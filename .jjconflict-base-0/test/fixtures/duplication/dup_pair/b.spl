# Fixture: dup_pair/b.spl - same body as a.spl's score_order_total_a, just
# a renamed function (copy-paste duplication with only the identifier changed).

fn score_order_total_b(base: i64, extra: i64, discount: i64) -> i64:
    var total = base
    total = total + extra
    if discount > 0:
        total = total - discount
    var bonus = 0
    if total > 100:
        bonus = 10
    elif total > 50:
        bonus = 5
    else:
        bonus = 0
    total = total + bonus
    var tax = total / 10
    total = total + tax
    if total < 0:
        total = 0
    return total
