use std.spec.*
use std.gc_async_mut.gpu.browser_engine.layout.{
    LayoutContext, LayoutBox, LineBox, InlineFragment,
    layout_inline, layout_context_new
}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{
    html_tree_builder_build
}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}

fn _layout_inline_html(html: text) -> LayoutBox:
    val doc = html_tree_builder_build(html)
    val ctx = layout_context_new(200, 600)
    return layout_inline(doc, ctx)

fn _line_count(box_: LayoutBox) -> i32:
    return box_.line_boxes.len()

fn _first_line(box_: LayoutBox) -> LineBox:
    return box_.line_boxes[0]

fn _total_height(box_: LayoutBox) -> i32:
    return box_.height

# ============================================================================
# AC-4: IFC / LineBox — line break
# ============================================================================

describe "IFC LineBox line break":
    it "AC-4: short text fits on one line":
        val box_ = _layout_inline_html("<span>Hi</span>")
        val count = _line_count(box_)
        expect(count).to_equal(1)

    it "AC-4: long text wraps to multiple lines in narrow container":
        # 200px container, long word sequence should wrap
        val box_ = _layout_inline_html("<span>word1 word2 word3 word4 word5 word6 word7 word8 word9 word10</span>")
        val count = _line_count(box_)
        expect(count).to_be_greater_than(1)

    it "AC-4: total height grows with more lines":
        val box1 = _layout_inline_html("<span>short</span>")
        val box2 = _layout_inline_html("<span>word1 word2 word3 word4 word5 word6 word7 word8 word9 word10</span>")
        val h1 = _total_height(box1)
        val h2 = _total_height(box2)
        expect(h2).to_be_greater_than(h1)

# ============================================================================
# AC-4: IFC / LineBox — baseline alignment
# ============================================================================

describe "IFC LineBox baseline":
    it "AC-4: line box has non-negative baseline offset":
        val box_ = _layout_inline_html("<span>text</span>")
        val line = _first_line(box_)
        expect(line.baseline).to_be_greater_than(-1)

    it "AC-4: line box width does not exceed container width":
        val box_ = _layout_inline_html("<span>text that fits</span>")
        val line = _first_line(box_)
        expect(line.width).to_be_less_than(201)

# ============================================================================
# AC-4: IFC / LineBox — text-align
# ============================================================================

describe "IFC LineBox text-align":
    it "AC-4: left-aligned fragment starts at x=0 (default)":
        val box_ = _layout_inline_html("<span>left</span>")
        val line = _first_line(box_)
        val frag = line.fragments[0]
        expect(frag.x).to_equal(0)

    it "AC-4: center-aligned line fragment x is positive for short text":
        val box_ = _layout_inline_html("<div style=\"text-align:center;width:200px\">hi</div>")
        val line = _first_line(box_)
        val frag = line.fragments[0]
        expect(frag.x).to_be_greater_than(0)
