# scroll_damage scene — 2 DrawRects at different y-offsets simulating scroll, cull 400x400

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 400.0, bottom: 400.0)
    # Pre-scroll content rect at y=10
    val pre_scroll = SkRect(left: 10.0, top: 10.0, right: 390.0, bottom: 160.0)
    val paint_pre = sk_paint_fill(sk_color_argb(255, 100, 180, 100))
    # Post-scroll damage rect at y=60 (50px scroll delta)
    val post_scroll = SkRect(left: 10.0, top: 60.0, right: 390.0, bottom: 210.0)
    val paint_post = sk_paint_fill(sk_color_argb(180, 220, 80, 80))
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_rect(pre_scroll, paint_pre))
    ops.push(sk_picture_op_draw_rect(post_scroll, paint_post))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
