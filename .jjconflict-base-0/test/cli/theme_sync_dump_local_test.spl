        expect(sdn.contains("roundness: ROUND_TWELVE")).to_equal(true)

# ============================================================================
# Test Group 3: Round-trip (parse(dump(ds)) ≡ ds)
# ============================================================================

describe "parse_stitch_design_system_sdn round-trip":
    """Verify that parsing the output of the serializer produces correct values."""

    it "round-trips display_name":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test-source", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.display_name).to_equal("SimpleOS Obsidian")

    it "round-trips pulled_from":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test-source", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.pulled_from).to_equal("test-source")

    it "round-trips pulled_at":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test-source", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.pulled_at).to_equal("2026-04-12")

    it "round-trips color_mode":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.color_mode).to_equal("DARK")

    it "round-trips color_variant":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.color_variant).to_equal("FIDELITY")

    it "round-trips roundness":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.roundness).to_equal("ROUND_EIGHT")

    it "round-trips spacing_scale":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.spacing_scale).to_equal("2")

    it "round-trips headline_font":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.headline_font).to_equal("SPACE_GROTESK")

    it "round-trips body_font":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.body_font).to_equal("MANROPE")

    it "round-trips label_font":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.label_font).to_equal("INTER")

    it "round-trips override_primary_color":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.override_primary_color).to_equal("#F5F5F7")

    it "round-trips override_neutral_color":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.override_neutral_color).to_equal("#060612")

    it "round-trips named_color background":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.md3.background).to_equal("#12121f")

    it "round-trips named_color primary":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.md3.primary).to_equal("#c6c6c8")

    it "round-trips named_color surface":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.md3.surface).to_equal("#12121f")

    it "round-trips named_color tertiary_fixed_dim":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.md3.tertiary_fixed_dim).to_equal("#bec6e0")

# ============================================================================
# Test Group 4: Parser tolerates unknown fields
# ============================================================================

describe "parse_stitch_design_system_sdn - tolerance":
    it "ignores notes field at root level":
        val sdn = "display_name: \"Test\"\nnotes: |\n    Some long note\n    spanning multiple lines\npulled_at: \"2026-04-12\"\npulled_from: \"test\"\n\ntheme:\n    color_mode: \"DARK\"\n"
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.display_name).to_equal("Test")
        expect(parsed.metadata.color_mode).to_equal("DARK")

    it "ignores design_md field in content":
        val sdn = "display_name: \"Test\"\npulled_at: \"2026-04-12\"\npulled_from: \"test\"\n\ntheme:\n    color_mode: \"LIGHT\"\ndesign_md: |\n    # Some design doc\n    With lots of text\n"
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.display_name).to_equal("Test")
        expect(parsed.metadata.color_mode).to_equal("LIGHT")

    it "ignores unknown theme fields":
        val sdn = "display_name: \"Test\"\npulled_at: \"2026-04-12\"\npulled_from: \"test\"\n\ntheme:\n    color_mode: \"DARK\"\n    unknown_future_field: \"some_value\"\n    roundness: \"ROUND_EIGHT\"\n"
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.metadata.roundness).to_equal("ROUND_EIGHT")

    it "handles empty named_colors gracefully":
        val sdn = "display_name: \"Test\"\npulled_at: \"2026-04-12\"\npulled_from: \"test\"\n\ntheme:\n    color_mode: \"DARK\"\n    named_colors: {}\n"
        val parsed = parse_stitch_design_system_sdn(sdn)
        expect(parsed.md3.background).to_equal("")
