# @cover src/lib/common/ui/theme_sync_sdn.spl 80%
"""
# Theme Sync dump-local Specification

**Feature IDs:** #THEME-SYNC-001
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Verifies that `dump_stitch_design_system_sdn` serializes a StitchDesignSystem
to the correct SDN format and that `parse_stitch_design_system_sdn` round-trips
the output back to an equivalent ParsedStitchDesignSystem.

## Behavior
- Serializer emits display_name, pulled_from, pulled_at at root level
- Serializer emits all metadata fields under theme: block
- Serializer emits all 47 named_colors entries alphabetically under named_colors:
- design_md is NOT emitted
- Parser round-trips: parse(dump(ds)) produces identical values
- Parser tolerates unknown fields (notes, design_md) without crashing
"""

use common.ui.glass.tokens.{StitchDesignSystem}
use common.ui.theme_sync_sdn.{
    dump_stitch_design_system_sdn,
    parse_stitch_design_system_sdn,
    ParsedStitchDesignSystem
}

# ============================================================================
# Test Group 1: Serializer output structure
# ============================================================================

describe "dump_stitch_design_system_sdn - obsidian output":
    """Verify the serializer produces the expected SDN fields for the obsidian theme."""

    it "emits display_name at root level":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "local/glass_tokens.spl StitchDesignSystem.obsidian()", "2026-04-12")
        expect(sdn.contains("display_name: \"SimpleOS Obsidian\"")).to_equal(true)

    it "emits pulled_from at root level":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "local/glass_tokens.spl StitchDesignSystem.obsidian()", "2026-04-12")
        expect(sdn.contains("pulled_from:")).to_equal(true)

    it "emits pulled_at at root level":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "local/glass_tokens.spl StitchDesignSystem.obsidian()", "2026-04-12")
        expect(sdn.contains("pulled_at: \"2026-04-12\"")).to_equal(true)

    it "emits theme: section header":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("theme:\n")).to_equal(true)

    it "emits color_mode DARK":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("color_mode: DARK")).to_equal(true)

    it "emits color_variant FIDELITY":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("color_variant: FIDELITY")).to_equal(true)

    it "emits roundness ROUND_EIGHT":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("roundness: ROUND_EIGHT")).to_equal(true)

    it "emits spacing_scale 2 (unquoted integer)":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("spacing_scale: 2")).to_equal(true)

    it "emits headline_font SPACE_GROTESK":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("headline_font: SPACE_GROTESK")).to_equal(true)

    it "emits body_font MANROPE":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("body_font: MANROPE")).to_equal(true)

    it "emits label_font INTER":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("label_font: INTER")).to_equal(true)

    it "emits named_colors section":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("named_colors:\n")).to_equal(true)

    it "emits background in named_colors":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("background: \"#12121f\"")).to_equal(true)

    it "emits primary in named_colors":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("primary: \"#c6c6c8\"")).to_equal(true)

    it "does NOT emit design_md":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("design_md:")).to_equal(false)

    it "does NOT emit notes":
        val ds = StitchDesignSystem.obsidian()
        val sdn = dump_stitch_design_system_sdn(ds, "test", "2026-04-12")
        expect(sdn.contains("notes:")).to_equal(false)

