use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport,
    browser_renderer_normalize_style_rules}

val WIDTH: i32 = 32
val HEIGHT: i32 = 24

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn _renders_color(style: text, body: text, color: u32) -> bool:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color) > 0

fn _pixel_count(style: text, body: text, color: u32) -> i32:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color)

describe "WPT-derived CSS transforms subset":

    context "CSS transform property":

        it "translate moves element":
            val no_transform = _pixel_count(
                "div { width: 12px; height: 8px; background-color: #dc2626; }",
                "<div></div>",
                0xFFDC2626u32)
            val with_transform = _pixel_count(
                "div { width: 12px; height: 8px; background-color: #dc2626; transform: translate(4px, 4px); }",
                "<div></div>",
                0xFFDC2626u32)
            expect(no_transform > 0).to_equal(true)
            expect(with_transform > 0).to_equal(true)

        it "scale(2) doubles element size":
            val no_scale = _pixel_count(
                "div { width: 6px; height: 4px; background-color: #16a34a; }",
                "<div></div>",
                0xFF16A34Au32)
            val with_scale = _pixel_count(
                "div { width: 6px; height: 4px; background-color: #16a34a; transform: scale(2); }",
                "<div></div>",
                0xFF16A34Au32)
            expect(no_scale > 0).to_equal(true)
            expect(with_scale >= no_scale).to_equal(true)

        it "rotate(0deg) is identity":
            val no_rotate = _pixel_count(
                "div { width: 12px; height: 8px; background-color: #7c3aed; }",
                "<div></div>",
                0xFF7C3AEDu32)
            val with_rotate = _pixel_count(
                "div { width: 12px; height: 8px; background-color: #7c3aed; transform: rotate(0deg); }",
                "<div></div>",
                0xFF7C3AEDu32)
            expect(no_rotate > 0).to_equal(true)
            expect(with_rotate > 0).to_equal(true)

        it "transform-origin affects rotation center":
            val center_origin = _renders_color(
                "div { width: 8px; height: 8px; background-color: #0891b2; transform: rotate(45deg); transform-origin: 50% 50%; }",
                "<div></div>",
                0xFF0891B2u32)
            val corner_origin = _renders_color(
                "div { width: 8px; height: 8px; background-color: #0891b2; transform: rotate(45deg); transform-origin: 0% 0%; }",
                "<div></div>",
                0xFF0891B2u32)
            expect(center_origin).to_equal(true)
            expect(corner_origin).to_equal(true)

        it "multiple transforms compose":
            val composed = _renders_color(
                "div { width: 8px; height: 6px; background-color: #ea580c; transform: translate(2px, 0px) scale(1.5); }",
                "<div></div>",
                0xFFEA580Cu32)
            expect(composed).to_equal(true)
