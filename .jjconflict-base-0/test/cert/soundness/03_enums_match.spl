# Soundness corpus: custom enum + match with payload binding.
# Uses a CUSTOM enum (not built-in Result/Ok/Err) on purpose: the deployed
# binary has frozen bugs in Result.unwrap()/? that would mask real codegen
# behaviour here.
# expected stdout:
# 12
# 15
enum Shape:
    Circle(i64)
    Rect(i64, i64)

fn area(s: Shape) -> i64:
    match s:
        Shape.Circle(r): r * r * 3
        Shape.Rect(w, h): w * h

fn main():
    print(area(Shape.Circle(2)))    # 12
    print(area(Shape.Rect(3, 5)))   # 15
