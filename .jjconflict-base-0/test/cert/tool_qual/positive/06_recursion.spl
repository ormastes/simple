# Tool-qual positive case: recursion (Fibonacci + factorial).
# Hand-computed: fib(10)=55; fact(5)=120.
fn fib(n: i64) -> i64:
    if n < 2:
        n
    else:
        fib(n - 1) + fib(n - 2)

fn fact(n: i64) -> i64:
    if n <= 1:
        1
    else:
        n * fact(n - 1)

fn main():
    print(fib(10))    # 55
    print(fact(5))    # 120
