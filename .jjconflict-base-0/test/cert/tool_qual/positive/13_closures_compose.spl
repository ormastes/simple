# Tool-qual positive case: two sibling closures, each capturing a DIFFERENT
# outer local, one calling the other (closure composition), distinct from
# 04_closures.spl's single-closure single-capture case.
# Hand-computed: step(x) = x + base = 2 + 10 = 12; combo(2) = step(2)*mul =
# 12*3 = 36.
#
# SCOPE NOTE: a closure LEXICALLY NESTED inside another closure's body, reading
# a var captured by the OUTER closure, computes the wrong value on the
# deployed binary (see known_defects/nested_closure_capture_wrong_value.spl).
# This case avoids that construct by keeping both closures as siblings at the
# same scope (a supported pattern), while still exercising captured-state
# closure composition.
fn main():
    val base = 10
    val step = \y: y + base
    val mul = 3
    val combo = \x: step(x) * mul
    print(combo(2))   # 36
