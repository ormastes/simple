# Tool-qual NEGATIVE case: access of a field the struct does not declare.
# `Point` has only `x`; reading `p.zzz` is a type error that MUST be rejected
# (non-zero exit, diagnostic on stderr) and MUST NOT silently produce stdout.
struct Point:
    x: i64

fn main():
    val p = Point { x: 1 }
    print(p.zzz)
