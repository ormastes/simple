# OPEN DEFECT repro (NOT gated by the runner). See README.md.
# `add(a: i64, ...)` called with a text argument SHOULD be rejected. On the
# deployed binary it is silently ACCEPTED and prints GARBAGE (a raw text
# pointer reinterpreted as i64, e.g. 6295919127139) — a type-safety / memory
# hole, the most severe class for a safety-critical tool.
fn add(a: i64, b: i64) -> i64:
    a + b

fn main():
    print(add("x", 2))
