# damage_spec.spl — tests for Wave 3 (6c): damage aggregation across surfaces

use std.skia.entity.geometry.{SkRect}
use std.skia.entity.matrix.{Matrix3x3}
use std.viz.entity.render_pass.{RenderPass}
use std.viz.entity.compositor_frame.{CompositorFrame, FrameMetadata}
use std.viz.feature.damage.{
    union_rects,
    intersect_rect,
    damage_from_frame,
    aggregate_damage,
    propagate_damage_up
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn _rect(l: f64, t: f64, r: f64, b: f64) -> SkRect:
    SkRect(left: l, top: t, right: r, bottom: b)

fn _empty_rect() -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)

fn _rect_eq(a: SkRect, b: SkRect) -> bool:
    val eps = 1e-6
    val dl = a.left - b.left
    val dt = a.top - b.top
    val dr = a.right - b.right
    val db = a.bottom - b.bottom
    val al = if dl < 0.0: 0.0 - dl else: dl
    val at = if dt < 0.0: 0.0 - dt else: dt
    val ar = if dr < 0.0: 0.0 - dr else: dr
    val ab = if db < 0.0: 0.0 - db else: db
    (al < eps and at < eps and ar < eps and ab < eps)

fn _make_meta() -> FrameMetadata:
    FrameMetadata(
        device_scale_factor: 1.0,
        root_scroll_offset_x: 0.0,
        root_scroll_offset_y: 0.0,
        frame_token: 0
    )

fn _make_frame_with_damage(damage: SkRect, viewport: SkRect) -> CompositorFrame:
    var rp = RenderPass.new(1, viewport)
    rp.damage_rect = damage
    CompositorFrame(
        metadata: _make_meta(),
        render_pass_list: [rp],
        referenced_surfaces: [],
        device_viewport_rect: viewport
    )

fn _make_frame_viewport_only(viewport: SkRect) -> CompositorFrame:
    CompositorFrame(
        metadata: _make_meta(),
        render_pass_list: [],
        referenced_surfaces: [],
        device_viewport_rect: viewport
    )

# ---------------------------------------------------------------------------
# Test suite
# ---------------------------------------------------------------------------

describe "damage":

    # 1. union_rects: one side empty => return the other
    it "union_rects with empty second operand returns first":
        val a = _rect(10.0, 20.0, 50.0, 60.0)
        val empty = _empty_rect()
        val result = union_rects(a, empty)
        val eq = _rect_eq(result, a)
        eq.to_equal(true)

    # 2. union_rects: two disjoint rects => bounding box
    it "union_rects of two disjoint rects returns bounding box":
        val a = _rect(0.0, 0.0, 10.0, 10.0)
        val b = _rect(20.0, 30.0, 40.0, 50.0)
        val result = union_rects(a, b)
        result.left.to_equal(0.0)
        result.top.to_equal(0.0)
        result.right.to_equal(40.0)
        result.bottom.to_equal(50.0)

    # 3. union_rects: two overlapping rects => outer bounds
    it "union_rects of two overlapping rects returns outer bounds":
        val a = _rect(0.0, 0.0, 30.0, 30.0)
        val b = _rect(20.0, 20.0, 50.0, 50.0)
        val result = union_rects(a, b)
        result.left.to_equal(0.0)
        result.top.to_equal(0.0)
        result.right.to_equal(50.0)
        result.bottom.to_equal(50.0)

    # 4. intersect_rect: disjoint rects => empty (0,0,0,0)
    it "intersect_rect of disjoint rects returns empty":
        val a = _rect(0.0, 0.0, 10.0, 10.0)
        val b = _rect(20.0, 20.0, 40.0, 40.0)
        val result = intersect_rect(a, b)
        result.left.to_equal(0.0)
        result.top.to_equal(0.0)
        result.right.to_equal(0.0)
        result.bottom.to_equal(0.0)

    # 5. intersect_rect: contained rects => smaller rect
    it "intersect_rect of contained rects returns the smaller rect":
        val outer = _rect(0.0, 0.0, 100.0, 100.0)
        val inner = _rect(10.0, 10.0, 40.0, 40.0)
        val result = intersect_rect(outer, inner)
        result.left.to_equal(10.0)
        result.top.to_equal(10.0)
        result.right.to_equal(40.0)
        result.bottom.to_equal(40.0)

    # 6. aggregate_damage: root with no children == root's damage
    it "aggregate_damage with no children equals root damage clipped to viewport":
        val viewport = _rect(0.0, 0.0, 800.0, 600.0)
        val damage   = _rect(10.0, 20.0, 200.0, 150.0)
        val root = _make_frame_with_damage(damage, viewport)
        val no_children = [CompositorFrame]()
        val no_clips    = [SkRect]()
        val result = aggregate_damage(root, no_children, no_clips)
        val eq = _rect_eq(result, damage)
        eq.to_equal(true)

    # 7. aggregate_damage: unions child damage clipped by child clip
    it "aggregate_damage unions child damage clipped by child clip rect":
        val viewport      = _rect(0.0, 0.0, 800.0, 600.0)
        val root_damage   = _rect(0.0, 0.0, 50.0, 50.0)
        val root_frame    = _make_frame_with_damage(root_damage, viewport)

        # child damage extends to (300, 300) but clip cuts it to (100, 100)
        val child_damage  = _rect(0.0, 0.0, 300.0, 300.0)
        val child_frame   = _make_frame_with_damage(child_damage, viewport)
        val child_clip    = _rect(0.0, 0.0, 100.0, 100.0)

        val children      = [child_frame]
        val clips         = [child_clip]
        val result        = aggregate_damage(root_frame, children, clips)

        # union of root(0,0,50,50) and clipped-child(0,0,100,100) = (0,0,100,100)
        # then clamped to viewport (0,0,800,600) => (0,0,100,100)
        result.left.to_equal(0.0)
        result.top.to_equal(0.0)
        result.right.to_equal(100.0)
        result.bottom.to_equal(100.0)

    # 8. propagate_damage_up: identity matrix => rect unchanged
    it "propagate_damage_up through identity matrix returns unchanged rect":
        val dmg    = _rect(10.0, 20.0, 80.0, 90.0)
        val ident  = Matrix3x3.identity()
        val result = propagate_damage_up(dmg, ident)
        val eq = _rect_eq(result, dmg)
        eq.to_equal(true)
