# @cover src/lib/blink/html_parser/tokenizer.spl 80%
"""
# HTML Tokenizer Specification

**Feature IDs:** #BLK-HTML-TOK-001
**Category:** Browser / Blink port
**Difficulty:** 3/5
**Status:** Implemented

## Overview

Tests for `tokenize_html` — the first stage of the Blink HTML parser port.
Covers the happy-path WHATWG states: Data, TagOpen, EndTag, TagName,
BeforeAttributeName, AttributeName, AttributeValue, Comment, and Doctype.
The tree builder consumes this stream; it is out of scope for this spec.
"""

use std.spipe.*
use std.blink.html_parser.{
    HtmlTokenKind,
    HtmlAttribute,
    HtmlToken,
    tokenize_html
}

describe "html_tokenizer":
    it "tokenize_html: empty string produces [Eof]":
        val toks = tokenize_html("")
        expect toks.len() == 1
        expect toks[0].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: plain text \"hello\" produces one Character token with data \"hello\"":
        val toks = tokenize_html("hello")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.Character == true
        expect toks[0].data == "hello"
        expect toks[1].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: \"<div>\" produces StartTag with name \"div\"":
        val toks = tokenize_html("<div>")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.StartTag == true
        expect toks[0].name == "div"
        expect toks[0].self_closing == false
        expect toks[1].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: \"</div>\" produces EndTag with name \"div\"":
        val toks = tokenize_html("</div>")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.EndTag == true
        expect toks[0].name == "div"
        expect toks[1].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: \"<br/>\" produces StartTag with self_closing=true":
        val toks = tokenize_html("<br/>")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.StartTag == true
        expect toks[0].name == "br"
        expect toks[0].self_closing == true
        expect toks[1].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: '<a href=\"x.com\">' produces StartTag with attribute name=href value=x.com":
        val toks = tokenize_html("<a href=\"x.com\">")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.StartTag == true
        expect toks[0].name == "a"
        expect toks[0].attributes.len() == 1
        expect toks[0].attributes[0].name == "href"
        expect toks[0].attributes[0].value == "x.com"
        expect toks[1].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: \"<!-- comment -->\" produces Comment with data containing \"comment\"":
        val toks = tokenize_html("<!-- comment -->")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.Comment == true
        expect toks[0].data.len() > 0
        expect toks[1].kind == HtmlTokenKind.Eof == true

    it "tokenize_html: \"<!DOCTYPE html>\" produces Doctype token":
        val toks = tokenize_html("<!DOCTYPE html>")
        expect toks.len() == 2
        expect toks[0].kind == HtmlTokenKind.Doctype == true
        expect toks[0].name == "html"
        expect toks[1].kind == HtmlTokenKind.Eof == true