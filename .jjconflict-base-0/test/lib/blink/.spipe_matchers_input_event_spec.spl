# @cover src/lib/blink/input/event.spl 80%
"""
# Blink InputEvent Specification

**Category:** Browser / Blink
**Status:** Stub

## Overview

Tests for the Blink-style InputEvent — the unified envelope that mirrors
blink::WebInputEvent. Covers free constructors for mouse/key/char/touch/wheel
events, modifier bitmask queries, event-type classification, and the
handled-flag latch used by the dispatcher to stop propagation.
"""

use std.spipe.*
use std.lib.blink.input.event.{
    InputEvent, EventType, ModifierFlags, Point, TouchPoint,
    mouse_event, key_event, char_event, touch_event, wheel_event,
    touch_point,
}

describe "mouse_event":
    it "creates MouseDown with correct position":
        val ev = mouse_event(EventType.MouseDown, 120.5, 64.0, 1000.0, 0)
        val is_mouse_down = ev.event_type == EventType.MouseDown
        expect is_mouse_down == true
        expect ev.position.x == 120.5
        expect ev.position.y == 64.0
        expect ev.timestamp > 0.0

describe "key_event":
    it "creates KeyDown with key_code":
        val ev = key_event(EventType.KeyDown, 65, 2000.0, 0)
        val is_key_down = ev.event_type == EventType.KeyDown
        expect is_key_down == true
        expect ev.key_code == 65

describe "char_event":
    it "creates Char with char_code":
        val ev = char_event(97, 3000.0, 0)
        val is_char = ev.event_type == EventType.Char
        expect is_char == true
        expect ev.char_code == 97

describe "touch_event":
    it "stores touch list":
        val t0 = touch_point(1, 10.0, 20.0)
        val t1 = touch_point(2, 30.0, 40.0)
        val ev = touch_event(EventType.TouchStart, [t0, t1], 4000.0)
        val is_touch_start = ev.event_type == EventType.TouchStart
        expect is_touch_start == true
        expect ev.touches.len() == 2

describe "wheel_event":
    it "stores wheel deltas":
        val ev = wheel_event(50.0, 60.0, -120.0, 240.0, 5000.0, 0)
        val is_wheel = ev.event_type == EventType.MouseWheel
        expect is_wheel == true
        expect ev.wheel_delta_y == 240.0
        expect ev.wheel_delta_y > 0.0

describe "has_modifier":
    it "detects Shift set via bitmask":
        val ev = key_event(EventType.KeyDown, 65, 6000.0, 1)
        expect ev.has_modifier(1) == true
        expect ev.has_modifier(2) == false

describe "is_mouse/is_keyboard/is_touch":
    it "classify event types correctly":
        val m = mouse_event(EventType.MouseMove, 1.0, 2.0, 7000.0, 0)
        expect m.is_mouse() == true
        expect m.is_keyboard() == false
        expect m.is_touch() == false
        val k = key_event(EventType.KeyUp, 13, 7100.0, 0)
        expect k.is_keyboard() == true
        expect k.is_mouse() == false
        val t = touch_event(EventType.TouchMove, [], 7200.0)
        expect t.is_touch() == true
        expect t.is_mouse() == false

describe "mark_handled":
    it "sets handled flag":
        val ev = mouse_event(EventType.MouseUp, 5.0, 5.0, 8000.0, 0)
        expect ev.handled == false
        ev.mark_handled()
        expect ev.handled == true