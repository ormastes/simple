# @cover src/lib/blink/entity/computed_style.spl 80%
"""
# Blink ComputedStyle Specification

**Category:** Browser / Blink
**Status:** Stub

## Overview

Tests for the Blink-style ComputedStyle stub — the resolved CSS property bag
for a DOM element after style cascade. Covers default values, visibility,
positioning, margin totals, and block-level classification.
"""

use std.spipe.*
use std.lib.blink.entity.computed_style.{
    ComputedStyle, Display, Position, Overflow, Visibility, TextAlign, Length,
    computed_style_default
}

describe "computed_style_default":
    it "display is Inline":
        val style = computed_style_default()
        val is_inline = style.display == Display.Inline
        expect is_inline == true

    it "is_visible returns true":
        val style = computed_style_default()
        expect style.is_visible() == true

    it "is_positioned returns false":
        val style = computed_style_default()
        expect style.is_positioned() == false

describe "is_visible":
    it "opacity 0 returns false":
        val style = computed_style_default()
        style.opacity = 0.0
        expect style.is_visible() == false

describe "is_block_level":
    it "Block display returns true, Inline returns false":
        val style = computed_style_default()
        style.display = Display.Block
        expect style.is_block_level() == true
        style.display = Display.Inline
        expect style.is_block_level() == false

describe "total_margin_horizontal":
    it "sum of left + right margin":
        val style = computed_style_default()
        style.margin_left = Length(value: 12.0, unit: "px")
        style.margin_right = Length(value: 8.0, unit: "px")
        expect style.total_margin_horizontal() == 20.0
        expect style.total_margin_horizontal() > 0.0