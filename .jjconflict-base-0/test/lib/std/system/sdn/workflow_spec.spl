# SDN Workflow System Tests
#
# Tests for end-to-end SDN workflows:
# - Configuration management
# - Data migration (JSON <-> SDN)
# - Batch operations
# - Pipeline transformations
# - Error recovery

use std.spec.*
use std.io_runtime.{file_write, file_delete}
use lib.sdn.document.SdnDocument
use lib.sdn.parser.parse
use lib.sdn.{render_value, render_json}
use lib.sdn.value.SdnValue

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

struct ProcessResult:
    stdout: text
    stderr: text
    exit_code: i64

fn run(cmd: text, args: [text]) -> ProcessResult:
    val (out, err, code) = rt_process_run(cmd, args)
    ProcessResult(stdout: out, stderr: err, exit_code: code)

fn expect_path_text(doc: SdnDocument, path: text, expected: text):
    match doc.get_path(path):
        case Some(value):
            expect value.as_str() == Some(expected)
        case nil:
            fail("Missing path: ${path}")

fn expect_path_bool(doc: SdnDocument, path: text, expected: bool):
    match doc.get_path(path):
        case Some(value):
            expect value.as_bool() == Some(expected)
        case nil:
            fail("Missing path: ${path}")

# Helper constants for curly braces (avoids f-string parsing issues)
val LBRACE = "{"
val RBRACE = "}"

describe "SDN Workflow System Tests":
    context "configuration management":
        it "loads config, updates settings, and saves":
            # Create initial config
            val temp_config = "/tmp/test_config_workflow.sdn"
            val initial = "app:\n    name: MyApp\n    version: \"1.0.0\"\n    debug: false"
            file_write(temp_config, initial)

            # Load, update, save workflow
            match SdnDocument.from_file(temp_config):
                case Ok(mut doc):
                    # Update multiple settings
                    doc.set("app", SdnValue.Dict({
                        "name": SdnValue.text("MyApp"),
                        "version": SdnValue.text("2.0.0"),
                        "debug": SdnValue.bool(true)
                    }))

                    # Save
                    match doc.write_file(temp_config):
                        case Ok(_):
                            # Reload and verify all updates persisted
                            match SdnDocument.from_file(temp_config):
                                case Ok(reloaded):
                                    expect_path_text(reloaded, "app.version", "2.0.0")
                                    expect_path_bool(reloaded, "app.debug", true)
                                    # Original field should be preserved
                                    expect_path_text(reloaded, "app.name", "MyApp")
                                case Err(e):
                                    fail("Reload error: ${e.to_string()}")
                        case Err(e):
                            fail("Write error: ${e.to_string()}")
                case Err(e):
                    fail("Load error: ${e.to_string()}")

            file_delete(temp_config)

        it "manages multiple config files":
            # Load both configs
            match SdnDocument.parse("service: auth\nport: 8001"):
                case Ok(doc1):
                    match SdnDocument.parse("service: api\nport: 8002"):
                        case Ok(doc2):
                            # Verify independent configs
                            expect_path_text(doc1, "service", "auth")
                            expect_path_text(doc2, "service", "api")
                            match doc1.get_path("port"):
                                case Some(value):
                                    expect value.as_i64() == Some(8001)
                                case nil:
                                    fail("Missing path: port")
                            match doc2.get_path("port"):
                                case Some(value):
                                    expect value.as_i64() == Some(8002)
                                case nil:
                                    fail("Missing path: port")
                        case Err(e):
                            fail("Load error for config2: ${e.to_string()}")
                case Err(e):
                    fail("Load error for config1: ${e.to_string()}")

    context "data migration":
        it "migrates JSON config to SDN":
            # Verify equivalent SDN produced by JSON migration remains valid.
            match SdnDocument.parse("name: MyApp\nsettings:\n    debug: true"):
                case Ok(doc):
                    expect_path_text(doc, "name", "MyApp")
                    expect_path_bool(doc, "settings.debug", true)
                case Err(e):
                    fail("Parse error: ${e.to_string()}")

        it "migrates SDN data to JSON":
            val sdn_file = "/tmp/test_migrate_sdn_to_json.sdn"
            file_write(sdn_file, "name: MyApp\nsettings:\n    debug: true\n    level: info")

            # Use CLI to convert
            val result = run("./target/debug/simple", ["sdn", "to-json", sdn_file])
            expect result.exit_code == 0
            # Verify JSON output has expected structure
            expect result.stdout.contains("MyApp") == true
            expect result.stdout.contains("debug") == true
            val brace = "{"
            expect result.stdout.contains(brace) == true

            file_delete(sdn_file)

    context "batch operations":
        it "updates multiple values in batch":
            match SdnDocument.parse("a: 1\nb: 2\nc: 3\nd: 4\ne: 5"):
                case Ok(mut doc):
                    # Batch update - multiply all values by 10
                    doc.set("a", SdnValue.i32(10))
                    doc.set("b", SdnValue.i32(20))
                    doc.set("c", SdnValue.i32(30))
                    doc.set("d", SdnValue.i32(40))
                    doc.set("e", SdnValue.i32(50))

                    match SdnDocument.parse(doc.to_sdn()):
                        case Ok(reloaded):
                            match reloaded.get_path("a"):
                                case Some(value):
                                    expect value.as_i64() == Some(10)
                                case nil:
                                    fail("Missing path: a")
                            match reloaded.get_path("e"):
                                case Some(value):
                                    expect value.as_i64() == Some(50)
                                case nil:
                                    fail("Missing path: e")
                        case Err(e):
                            fail("Reload error: ${e.to_string()}")
                case Err(e):
                    fail("Load error: ${e.to_string()}")

        it "processes multiple files in sequence":
            val files = [
                "/tmp/test_seq_file1.sdn",
                "/tmp/test_seq_file2.sdn",
                "/tmp/test_seq_file3.sdn"
            ]

            # Create files
            for i in 0..3:
                file_write(files[i], "index: " + i.to_string() + "\nprocessed: false")

            # Process each file
            for file in files:
                match SdnDocument.from_file(file):
                    case Ok(mut doc):
                        doc.set("processed", SdnValue.bool(true))
                        doc.write_file(file)
                    case Err(e):
                        fail("Error processing ${file}: ${e.to_string()}")

            # Verify all processed
            for file in files:
                match SdnDocument.from_file(file):
                    case Ok(doc):
                        expect_path_bool(doc, "processed", true)
                    case Err(e):
                        fail("Verify error: ${e.to_string()}")

            # Cleanup
            for file in files:
                file_delete(file)

    context "pipeline transformations":
        it "transforms data through multiple stages":
            # Stage 1: Parse raw SDN
            val inner1 = "{" + "name: Alice, age: 30" + "}"
            val inner2 = "{" + "name: Bob, age: 25" + "}"
            val source = "users = [" + inner1 + ", " + inner2 + "]"
            match parse(source):
                case Ok(data):
                    # Stage 2: Transform to JSON
                    val json = render_json(data)
                    expect json.contains("Alice") == true
                    expect json.contains("Bob") == true

                    # Stage 3: Transform back to SDN
                    val sdn = render_value(data, 0)
                    expect sdn.len() > 0

                    # Stage 4: Re-parse and verify
                    match parse(sdn):
                        case Ok(final_data):
                            expect final_data.get_path("users").is_some() == true
                        case Err(e):
                            fail("Re-parse error: ${e.to_string()}")
                case Err(e):
                    fail("Initial parse error: ${e.to_string()}")

    context "error recovery":
        it "handles partial failures gracefully":
            val temp_file = "/tmp/test_partial_failure.sdn"
            file_write(temp_file, "valid_key: valid_value\nother: 42")

            match SdnDocument.from_file(temp_file):
                case Ok(mut doc):
                    # Successful update
                    doc.set("valid_key", SdnValue.text("updated"))

                    # Try invalid operation (set on non-existent nested path)
                    match doc.set("nonexistent.deep.path", SdnValue.i32(1)):
                        case Ok(_):
                            pass  # Unexpected success
                        case Err(_):
                            # Expected failure - but we can still save valid changes
                            pass

                    # Save what we have
                    match doc.write_file(temp_file):
                        case Ok(_):
                            # Verify the valid update was preserved
                            match SdnDocument.from_file(temp_file):
                                case Ok(reloaded):
                                    expect_path_text(reloaded, "valid_key", "updated")
                                case Err(e):
                                    fail("Reload error: ${e.to_string()}")
                        case Err(e):
                            fail("Write error: ${e.to_string()}")
                case Err(e):
                    fail("Load error: ${e.to_string()}")

            file_delete(temp_file)

        it "recovers from write failures":
            val temp_file = "/tmp/test_write_recovery.sdn"
            file_write(temp_file, "key: original")

            match SdnDocument.from_file(temp_file):
                case Ok(mut doc):
                    # Make changes
                    doc.set("key", SdnValue.text("modified"))

                    # Attempt to write to invalid path (should fail)
                    match doc.write_file("/invalid/path/file.sdn"):
                        case Ok(_):
                            fail("Should have failed writing to invalid path")
                        case Err(_):
                            # Write failed, but document still has our changes in memory
                            expect_path_text(doc, "key", "modified")

                            # Can still write to valid path
                            match doc.write_file(temp_file):
                                case Ok(_):
                                    # Verify recovery
                                    match SdnDocument.from_file(temp_file):
                                        case Ok(reloaded):
                                            expect_path_text(reloaded, "key", "modified")
                                        case Err(e):
                                            fail("Reload error: ${e.to_string()}")
                                case Err(e):
                                    fail("Recovery write error: ${e.to_string()}")
                case Err(e):
                    fail("Load error: ${e.to_string()}")

            file_delete(temp_file)
