# @cover src/lib/skia/feature/font_loader/registry.spl 80%
"""
# Skia Font Loader Specification

**Feature IDs:** #SKI-FONT-LOADER
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests for FontRegistry — the in-memory stub backing SkFontMgr-style family
enumeration and matchFamilyStyle lookup.
"""

use std.spipe.*
use std.skia.feature.font_loader.{
    FontWeight,
    FontSlant,
    FontStyle,
    FontFamilyEntry,
    FontRegistry,
    font_registry_new,
    default_font_registry
}

describe "font_loader":
    it "font_registry_new: empty registry has zero families":
        val reg = font_registry_new()
        expect reg.family_count() == 0
        expect reg.list_families().length() == 0

    it "register + list_families: returns added family names":
        val reg = font_registry_new()
        val style = FontStyle(weight: FontWeight.Regular, slant: FontSlant.Upright)
        reg.register(FontFamilyEntry(
            family: "Alpha",
            style: style,
            typeface_name: "",
            path: ""
        ))
        reg.register(FontFamilyEntry(
            family: "Beta",
            style: style,
            typeface_name: "",
            path: ""
        ))
        val families = reg.list_families()
        expect families.length() == 2
        expect families[0] == "Alpha"
        expect families[1] == "Beta"
        expect reg.family_count() == 2

    it "default_font_registry: has Sans, Serif, Monospace":
        val reg = default_font_registry()
        expect reg.family_count() == 3
        val families = reg.list_families()
        expect families[0] == "Sans"
        expect families[1] == "Serif"
        expect families[2] == "Monospace"

    it "match_family_style: exact match returns Some":
        val reg = default_font_registry()
        val style = FontStyle(weight: FontWeight.Regular, slant: FontSlant.Upright)
        val result = reg.match_family_style("Serif", style)
        val entry = result.unwrap()
        expect entry.family == "Serif"

    it "match_family_style: unknown family returns None":
        val reg = default_font_registry()
        val style = FontStyle(weight: FontWeight.Regular, slant: FontSlant.Upright)
        val result = reg.match_family_style("Nonexistent", style)
        expect result == nil

    it "match_family_style: fallback to closest weight when exact weight missing":
        val reg = font_registry_new()
        # Register only Thin (100) and Black (900) upright variants.
        reg.register(FontFamilyEntry(
            family: "Custom",
            style: FontStyle(weight: FontWeight.Thin, slant: FontSlant.Upright),
            typeface_name: "",
            path: ""
        ))
        reg.register(FontFamilyEntry(
            family: "Custom",
            style: FontStyle(weight: FontWeight.Black, slant: FontSlant.Upright),
            typeface_name: "",
            path: ""
        ))
        # Request Medium (500) — closer to Black (900, dist 400) than Thin (100, dist 400)?
        # Thin dist = |500 - 100| = 400; Black dist = |500 - 900| = 400. Tie — first wins (Thin).
        # Use Bold (700) instead: Thin dist 600, Black dist 200 -> Black wins.
        val style = FontStyle(weight: FontWeight.Bold, slant: FontSlant.Upright)
        val result = reg.match_family_style("Custom", style)
        val entry = result.unwrap()
        expect entry.family == "Custom"
        val is_black = entry.style.weight == FontWeight.Black
        expect is_black == true
        expect reg.family_count() > 0