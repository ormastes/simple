# test/system/gui/sdn_parsing_spec.spl
# @cover src/lib/common/ui/parse/sdn.spl 80%
# @cover src/lib/common/ui/widget.spl 80%
# @cover src/lib/common/ui/state.spl 80%
# @tag:system
# @gui: headless

"""
# SDN UI File Parsing Specification

**Feature IDs:** #GUI-SDN-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Verifies that `.ui.sdn` layout files are correctly parsed into `UITree`
structures. Tests the full pipeline: file loading, tree construction,
property extraction, child traversal, and state initialization.
"""

use std.spec.*

use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.widget.{UITree, WidgetNode, WidgetKind, UIState}
use common.ui.state.{init_state}

# ============================================================================
# 1. Minimal UI File Parsing
# ============================================================================

describe "Parsing minimal.ui.sdn":
    slow_it "parses successfully and returns Ok":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                expect true == true
            Err(e) :
                expect false == true

    slow_it "parsed tree root is not nil":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                val root = tree.root
                expect root.id.len() > 0
            Err(e) :
                expect false == true

    slow_it "parsed tree has a title property":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                expect tree.title == "Minimal"
            Err(e) :
                expect false == true

    slow_it "parsed tree has at least one child":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                val children = tree.root.children
                expect children.len() > 0
            Err(e) :
                expect false == true

    slow_it "contains a greeting text widget":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                val widget = tree.find_widget("greeting")
                if widget != nil:
                    val content = widget.get_prop("content")
                    expect (content).contains("Hello")
                else:
                    # Widget should be found somewhere in the tree
                    val ids = tree.all_widget_ids()
                    expect ids.len() > 0
            Err(e) :
                expect false == true

# ============================================================================
# 2. Demo UI File Parsing
# ============================================================================

describe "Parsing demo.ui.sdn":
    slow_it "parses successfully and returns Ok":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                expect true == true
            Err(e) :
                expect false == true

    slow_it "parsed tree root is not nil":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                val root = tree.root
                expect root.id.len() > 0
            Err(e) :
                expect false == true

    slow_it "parsed tree has correct title":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                expect tree.title == "Simple UI Demo"
            Err(e) :
                expect false == true

    slow_it "parsed tree has dark theme":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                expect tree.theme == "glass_dark"
            Err(e) :
                expect false == true

    slow_it "widget tree has multiple children":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                val children = tree.root.children
                expect children.len() > 1
            Err(e) :
                expect false == true

    slow_it "all_widget_ids returns multiple ids":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                val ids = tree.all_widget_ids()
                expect ids.len() > 3
            Err(e) :
                expect false == true

    slow_it "all_widget_ids includes status widget":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                val ids = tree.all_widget_ids()
                expect (ids).contains("status")
            Err(e) :
                expect false == true

# ============================================================================
# 3. Error Handling
# ============================================================================

describe "SDN parsing error handling":
    slow_it "returns Err for nonexistent file":
        val result = parse_ui_to_tree("nonexistent/path/does_not_exist.ui.sdn")
        match result:
            Err(e) :
                expect e.len() > 0
            Ok(tree) :
                expect false == true

    slow_it "error message contains useful information":
        val result = parse_ui_to_tree("/tmp/no_such_file_12345.ui.sdn")
        match result:
            Err(e) :
                expect (e).contains("File not found")
            Ok(tree) :
                expect false == true

# ============================================================================
# 4. State Initialization from Parsed Tree
# ============================================================================

describe "init_state from parsed tree":
    slow_it "creates a UIState with focused_id set":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                val state = init_state(tree)
                # focused_id should be set to the first widget id
                expect state.focused_id.len() > 0
            Err(e) :
                expect false == true

    slow_it "creates a UIState in Normal mode":
        val result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
        match result:
            Ok(tree) :
                val state = init_state(tree)
                expect state.mode_name() == "NORMAL"
            Err(e) :
                expect false == true

    slow_it "creates a UIState with empty command buffer":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                val state = init_state(tree)
                expect state.command_buffer == ""
            Err(e) :
                expect false == true

    slow_it "state tree preserves the original title":
        val result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
        match result:
            Ok(tree) :
                val state = init_state(tree)
                expect state.tree.title == "Simple UI Demo"
            Err(e) :
                expect false == true