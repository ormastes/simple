# Full Cross-Architecture Consistency QEMU Tests
#
# Verifies that ALL subsystems produce consistent results
# across all 4 target architectures.
#
# @tag: os,qemu,cross,consistency

use os.qemu_runner.{get_target, build_qemu_command, arch_display_name}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 30000

fn _can_run(arch: Architecture) -> bool:
    val target = get_target(arch)
    val qemu_check = rt_process_run_timeout("which", [target.qemu_system], 5000)
    if qemu_check[2] != 0:
        return false
    if not rt_file_exists(target.output):
        return false
    true

fn _run_qemu(arch: Architecture) -> text:
    val target = get_target(arch)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    val result = rt_process_run_timeout(qemu_bin, args, TIMEOUT_MS)
    result[0] + result[1]

describe "Full Cross-Architecture Consistency":
    slow_it "all architectures print SimpleOS banner":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("SimpleOS")

    slow_it "all architectures initialize PMM":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("[PMM]")

    slow_it "all architectures initialize interrupts":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("[IRQ]")

    slow_it "all architectures initialize timer":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("[TIMER]")

    slow_it "all architectures create scheduler tasks":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("[SCHED]")

    slow_it "all architectures pass 5 boot tests":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("passed=5 failed=0")

    slow_it "all architectures complete test suite":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("SimpleOS Tests Complete")

    slow_it "no architecture reports failures":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                val has_fail = output.contains("[FAIL]")
                expect(has_fail).to_equal(false)
