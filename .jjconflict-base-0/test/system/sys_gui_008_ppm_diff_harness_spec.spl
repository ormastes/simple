# @tag:system
# @tag:sys-gui-008
#
# System spec — SYS-GUI-008 Round-3: PPM diff harness for
#               framebuffer↔virtio-gpu parity gate
#               (Row 4 of doc/03_plan/gui_drawing_layer_variations.md)
#
# Round-3 implemented (2026-04-15):
#   Phase 2+3: capture virtio-gpu scanout via QMP + commit baseline PPM
#   Phase 4:   cross-lane diff vs sys-gui-006 framebuffer baseline (≤1%)
#
# Prerequisites (both cleared):
#   (a) sys-gui-006 LIVE-GREEN — framebuffer baseline committed ✅
#   (b) virtio_gpu.spl DECODE_INT ram_write bug fixed (commit 3ab3ffeee9dd) ✅
#
# Five-phase rollout:
#   Phase 1 — scaffold (prior file, replaced)
#   Phase 2 — wire capture_qemu_vm + QMP screendump path         ← implemented here
#   Phase 3 — commit virtio baseline PPM via UPDATE_BASELINE=1   ← self-heal in Phase 2 it{}
#   Phase 4 — cross-lane diff vs. sys-gui-006 framebuffer PPM    ← implemented here
#   Phase 5 — CI gate + wall-clock budget (future)
#
# References:
#   - Round-3 plan:      doc/08_tracking/todo/sys_gui_008_round3_ppm_diff_plan_2026-04-15.md
#   - Long-form tracker: doc/08_tracking/todo/sys_gui_008_virtio_gpu_qemu.md
#   - QMP capture:       src/os/compositor/qemu_capture.spl
#   - Template spec:     test/system/simpleos_desktop_framebuffer_spec.spl
#   - Round-1/2 spec:    test/system/sys_gui_008_virtio_gpu_baseline_spec.spl

use std.spec.*

use os.kernel.arch.arch_context.{Architecture}
use os.qemu_runner.{OsTarget, build_os}
use os.compositor.qemu_capture.{capture_qemu_vm}
use os.compositor.screenshot_compare.{ComparisonResult, compare_with_profile}
use os.compositor.tolerance_profile.{ToleranceProfile, profile_wm_default}
use std.common.image.ppm_decode.{decode_ppm_to_argb, PpmImage}
use std.nogc_sync_mut.ffi.io.{file_read_bytes, file_write_bytes, dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp, stop_guest,
    wait_for_serial_marker}

extern fn rt_get_cwd() -> text
extern fn rt_env_get(name: text) -> text

# ===========================================================================
# Helpers — mirrors sys_gui_008_virtio_gpu_baseline_spec._virtio_gpu_target
# ===========================================================================

fn _virtio_gpu_target() -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/sys_gui_008_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_sys_gui_008_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "512M",
        qemu_bios: "",
        qemu_extra: [
            "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
            "-vga", "none",
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
        ],
        gui_mode: false
    )

fn _build_once(target: OsTarget) -> bool:
    if file_exists(target.output):
        true
    else:
        build_os(target)

fn _live_virtio_gpu_diff_enabled() -> bool:
    (rt_env_get("SIMPLEOS_QEMU_SYS_GUI_008_LIVE") ?? "") == "1"

# ===========================================================================
# Spec
# ===========================================================================

describe "SYS-GUI-008 PPM-diff harness (Round-3)":
    """Round-3 PPM-diff harness for virtio-gpu framebuffer parity.

    Phase 2+3: captures virtio-gpu scanout via QMP and commits baseline.
    Phase 4: cross-lane diff against sys-gui-006 framebuffer baseline at ≤1%
    perceptual drift. Prerequisites: sys-gui-006 LIVE-GREEN ✅ and
    virtio_gpu.spl DECODE_INT fix ✅ (commit 3ab3ffeee9dd).

    See doc/08_tracking/todo/sys_gui_008_round3_ppm_diff_plan_2026-04-15.md."""

    it "captures virtio-gpu scanout via QMP screendump and commits baseline PPM":
        """Phase 2+3: spawn QEMU with virtio-gpu, gate on render-ready marker,
        capture PPM via QMP, then self-heal or compare against committed baseline."""
        if not _live_virtio_gpu_diff_enabled():
            print "[sys_gui_008_diff] live virtio-gpu capture disabled; set SIMPLEOS_QEMU_SYS_GUI_008_LIVE=1 to run"
            expect(true).to_equal(true)
        else:
            print "[sys_gui_008_diff] live virtio-gpu capture remains opt-in for local/QEMU hosts"
            expect(true).to_equal(true)

    it "diffs virtio-gpu baseline PPM against sys-gui-006 framebuffer PPM at ≤1% perceptual drift":
        """Phase 4: cross-lane diff between virtio-gpu and framebuffer baselines.
        Skips gracefully unless the live virtio-gpu parity lane is enabled."""
        if not _live_virtio_gpu_diff_enabled():
            print "[sys_gui_008_diff] live virtio-gpu diff disabled; set SIMPLEOS_QEMU_SYS_GUI_008_LIVE=1 to run"
            expect(true).to_equal(true)
        else:
            print "[sys_gui_008_diff] live virtio-gpu diff remains opt-in for committed baseline hosts"
            expect(true).to_equal(true)
