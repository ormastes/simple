# @cover src/compiler_rust/lib/std/src/ml/torch/__init__.spl 80%
use std.spipe.*
use std.ml.torch as torch

describe "std.ml.torch tensor smoke":
    it "creates a tensor and exposes shape metadata":
        val tensor = torch.tensor([1.0, 2.0, 3.0])
        expect(tensor.shape()).to_equal([3])
        expect(tensor.numel()).to_equal(3)
