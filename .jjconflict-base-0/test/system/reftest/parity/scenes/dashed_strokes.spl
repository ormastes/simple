# dashed_strokes scene — 3 stroked paths with distinct stroke widths, cull 200x201

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_path}
use std.skia.entity.paint.{SkPaint, sk_paint_stroke}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkPathFillType}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 201.0)
    # Line 1: y=50, stroke_width=1.0
    val path1_0 = sk_path_new()
    val path1_1 = path1_0.move_to(10.0, 50.0)
    val path1 = path1_1.line_to(190.0, 50.0)
    val paint1 = sk_paint_stroke(sk_color_argb(255, 0, 0, 0), 1.0)
    # Line 2: y=100, stroke_width=2.0
    val path2_0 = sk_path_new()
    val path2_1 = path2_0.move_to(10.0, 100.0)
    val path2 = path2_1.line_to(190.0, 100.0)
    val paint2 = sk_paint_stroke(sk_color_argb(255, 60, 60, 60), 2.0)
    # Line 3: y=150, stroke_width=4.0
    val path3_0 = sk_path_new()
    val path3_1 = path3_0.move_to(10.0, 150.0)
    val path3 = path3_1.line_to(190.0, 150.0)
    val paint3 = sk_paint_stroke(sk_color_argb(255, 120, 120, 120), 4.0)
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_path(path1, paint1))
    ops.push(sk_picture_op_draw_path(path2, paint2))
    ops.push(sk_picture_op_draw_path(path3, paint3))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
