"""
# LLM Agent Dashboard TUI

**Feature IDs:** FR-LLM-DASHBOARD-TUI
**Category:** Tooling
**Status:** Implemented
**Design:** src/app/llm_dashboard/main.spl

## Overview

The LLM Agent Dashboard gives an operator a single-screen terminal view of
work in flight across the Claude, Codex, and Gemini agent lanes. Running
`bin/simple run src/app/llm_dashboard/main.spl` renders the board — agent
columns, the Research/Code/Review/Verify task lanes, and a Tasks/Blockers/
Signals summary — and prints the `q:quit` hint so the operator knows how to
leave the screen. In this build the dashboard renders once and exits, so it
must stay stable and exit cleanly even when the terminal already has a burst
of keystrokes queued up (fast paste, held keys, or mashing before the process
is ready).

## Key Concepts

| Concept | Description |
|---------|-------------|
| Board | One-screen render of agent columns and task lanes |
| Agent columns | Claude, Codex, Gemini — one column per collaborating LLM agent |
| Task lanes | Research, Code, Review, Verify — the stages work moves through |
| Clean exit | Process drains any queued input and exits 0 without hanging |

## Related Specifications

- src/app/llm_dashboard/main.spl — dashboard entrypoint and board renderer
"""

# @req REQ-SSPEC-MODERN

use std.spec.*
use std.io_runtime.{process_run, dir_create_all, file_write}

# ============================================================================
# Step Helpers
# ============================================================================
# @manual_section: Opening the dashboard

# Named so docgen renders `open_dashboard_with_keys(...)` as readable prose.
fn open_dashboard_with_keys(keys: text) -> (text, text, i64):
    process_run("/bin/bash", ["-c",
        "printf '" + keys + "' | bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null"])

# TODO(REQ-SSPEC-MODERN): replace with std.spec capture API (FR-1) once
# std.spec exposes a real TUI screen-capture/region-check primitive. Until
# then this stub only records the raw stdout for inspection and reports
# whether the named regions happen to appear verbatim in that text.
fn capture_tui_screen(name: text, screen_text: text, check: [text]) -> bool:
    dir_create_all("build/spec_captures")
    val wrote = file_write("build/spec_captures/" + name + ".txt", screen_text)
    if not wrote:
        return false
    for region in check:
        if not screen_text.contains(region):
            return false
    true

# ============================================================================
# Primary Scenarios
# ============================================================================
# @manual_section: Monitoring agent work

describe "LLM Dashboard TUI":
    """
    The dashboard renders the current agent/task board and exits cleanly, even
    when the terminal has a burst of keys queued up before it starts.
    """

    it "opens in TUI mode, shows the agent board, and exits cleanly under rapid keys":
        step("Open the dashboard with a burst of queued keypresses")
        val (out, _err, code) = open_dashboard_with_keys("123456jjkkrq")

        step("Confirm the process exited cleanly")
        expect(code).to_equal(0)

        step("Confirm the task lanes are visible")
        expect(out.contains("Research")).to_equal(true)
        expect(out.contains("Code")).to_equal(true)

        step("Confirm the quit hint is visible")
        expect(out.contains("q:quit")).to_equal(true)

        step("Confirm every agent column is visible")
        expect(out.contains("Claude")).to_equal(true)
        expect(out.contains("Codex")).to_equal(true)
        expect(out.contains("Gemini")).to_equal(true)

        # @capture(tui)
        step("Capture the TUI screen")
        val captured = capture_tui_screen("llm_dashboard_home", out, ["task_list", "status_line"])
        expect(captured).to_equal(true)
