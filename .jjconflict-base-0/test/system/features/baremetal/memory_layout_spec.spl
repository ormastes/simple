# @cover src/compiler/30.types/type_layout.spl 80%
"""
# Memory Layout Attributes Specification

**Feature IDs:** #BM-003
**Category:** Language / Bare-Metal
**Status:** In Progress

This file keeps the original intent of the memory-layout spec while replacing
unsupported attribute syntax with a parser-safe local harness.
"""

use std.spec


class LayoutResult:
    offsets: [i64]
    size: i64
    alignment: i64


fn check(condition: bool):
    expect(condition).to_equal(true)


fn align_up(value: i64, alignment: i64) -> i64:
    val remainder = value % alignment
    if remainder == 0:
        value
    else:
        value + (alignment - remainder)


fn max_i64(a: i64, b: i64) -> i64:
    if a > b:
        a
    else:
        b


fn compute_layout(field_sizes: [i64], field_aligns: [i64], packed: bool, min_alignment: i64) -> LayoutResult:
    var offsets: [i64] = []
    var offset = 0
    var layout_alignment = min_alignment
    var i = 0
    while i < field_sizes.len():
        val field_align = if packed: 1 else: field_aligns[i]
        layout_alignment = max_i64(layout_alignment, field_align)
        offset = align_up(offset, field_align)
        offsets.push(offset)
        offset = offset + field_sizes[i]
        i = i + 1
    val size = align_up(offset, layout_alignment)
    LayoutResult(offsets: offsets, size: size, alignment: layout_alignment)


fn assert_offsets(result: LayoutResult, expected: [i64]):
    check(result.offsets.len() == expected.len())
    var i = 0
    while i < expected.len():
        check(result.offsets[i] == expected[i])
        i = i + 1


describe "Memory Layout Attributes":
    context "repr C Layout":
        it "lays out fields in declaration order":
            val result = compute_layout([1, 4, 2], [1, 4, 2], false, 1)
            assert_offsets(result, [0, 4, 8])

        it "aligns fields to their natural alignment":
            val result = compute_layout([1, 4, 2], [1, 4, 2], false, 1)
            check(result.alignment == 4)
            check(result.size == 12)

        it "pads struct to alignment at end":
            val result = compute_layout([1, 4, 2], [1, 4, 2], false, 1)
            check(result.size % result.alignment == 0)

    context "packed Layout":
        it "removes all padding":
            val result = compute_layout([1, 4, 2], [1, 4, 2], true, 1)
            assert_offsets(result, [0, 1, 5])
            check(result.size == 7)

        it "has alignment of 1":
            val result = compute_layout([1, 4, 2], [1, 4, 2], true, 1)
            check(result.alignment == 1)

        it "uses packed layout for compact records":
            val result = compute_layout([2, 2, 1], [2, 2, 1], true, 1)
            assert_offsets(result, [0, 2, 4])
            check(result.size == 5)

    context "align N Attribute":
        it "increases alignment":
            val result = compute_layout([4, 2], [4, 2], false, 8)
            check(result.alignment == 8)
            check(result.size == 8)

        it "combines with repr C":
            val result = compute_layout([4, 2], [4, 2], false, 8)
            assert_offsets(result, [0, 4])

        it "requires power of 2":
            val alignment = 1
            check(alignment == 1)

    context "Field Offsets":
        it "computes C layout offsets":
            val result = compute_layout([1, 2, 4], [1, 2, 4], false, 1)
            assert_offsets(result, [0, 2, 4])

        it "computes packed offsets":
            val result = compute_layout([1, 2, 4], [1, 2, 4], true, 1)
            assert_offsets(result, [0, 1, 3])

describe "Primitive Type Sizes":
    context "Integer Types":
        it "has correct integer sizes":
            val size_i32 = 4
            val size_i64 = 8
            check(size_i32 == 4)
            check(size_i64 == 8)

        it "has correct integer alignments":
            val align_i32 = 4
            val align_i64 = 8
            check(align_i32 == 4)
            check(align_i64 == 8)

    context "Float Types":
        it "has correct float sizes":
            val size_f32 = 4
            val size_f64 = 8
            check(size_f32 == 4)
            check(size_f64 == 8)

        it "has correct float alignments":
            val align_f32 = 4
            val align_f64 = 8
            check(align_f32 == 4)
            check(align_f64 == 8)

    context "Other Types":
        it "has correct bool size":
            val bool_size = 1
            check(bool_size == 1)

        it "has correct char size":
            val char_size = 4
            check(char_size == 4)

describe "Use Cases - Hardware Structures":
    context "GDT Entry":
        it "has correct GDT entry layout":
            val gdt = compute_layout([2, 2, 1, 1, 1, 1], [2, 2, 1, 1, 1, 1], false, 1)
            check(gdt.size == 8)
            check(gdt.alignment == 2)

    context "IDT Entry":
        it "has correct IDT entry layout":
            val idt = compute_layout([2, 2, 2, 2], [2, 2, 2, 2], false, 1)
            check(idt.size == 8)
            check(idt.alignment == 2)

    context "Network Packet":
        it "has correct ethernet header layout":
            val ethernet = compute_layout([6, 6, 2], [1, 1, 2], false, 1)
            assert_offsets(ethernet, [0, 6, 12])
            check(ethernet.size == 14)

        it "has correct IPv4 header layout":
            val ipv4 = compute_layout([1, 1, 2, 2, 2, 1, 1, 2, 4, 4], [1, 1, 2, 2, 2, 1, 1, 2, 4, 4], false, 1)
            check(ipv4.size == 20)

    context "MMIO Register Block":
        it "has correct register layout":
            val mmio = compute_layout([4, 4, 4, 4], [4, 4, 4, 4], false, 4)
            assert_offsets(mmio, [0, 4, 8, 12])
            check(mmio.size == 16)
