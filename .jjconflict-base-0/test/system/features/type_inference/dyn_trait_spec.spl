# @cover src/compiler/20.hir/inference/infer.spl 80%
# @cover src/compiler/20.hir/inference/types.spl 80%
"""
# Dynamic Trait Objects (dyn Trait)

Feature: Type inference for dynamic trait dispatch
Category: Type System
Status: Executable coverage via local doubles
"""

use std.spec

enum TypeKind:
    Concrete
    DynTrait
    Array
    Optional

class Type:
    kind: TypeKind
    name: text
    inner: text

    static fn concrete(name: text) -> Type:
        Type(kind: TypeKind.Concrete, name: name, inner: "")

    static fn dyn_trait(name: text) -> Type:
        Type(kind: TypeKind.DynTrait, name: name, inner: "")

    static fn array(inner: text) -> Type:
        Type(kind: TypeKind.Array, name: "", inner: inner)

    static fn optional(inner: text) -> Type:
        Type(kind: TypeKind.Optional, name: "", inner: inner)

enum DispatchMode:
    Static
    Dynamic

class TypeChecker:
    trait_impls: [text]
    interface_bindings: [text]
    method_names: [text]

    static fn new() -> TypeChecker:
        TypeChecker(trait_impls: [], interface_bindings: [], method_names: [])

    me register_trait_impl(trait_name: text):
        self.trait_impls.push(trait_name)

    me bind_interface(trait_name: text):
        self.interface_bindings.push(trait_name)

    me register_method(name: text):
        self.method_names.push(name)

    fn has_trait_impl(trait_name: text) -> bool:
        self.trait_impls.contains(trait_name)

    fn is_bound(trait_name: text) -> bool:
        self.interface_bindings.contains(trait_name)

    fn dispatch_mode(trait_name: text) -> DispatchMode:
        if self.is_bound(trait_name):
            DispatchMode.Static
        else:
            DispatchMode.Dynamic

    fn unify(left: Type, right: Type) -> bool:
        if left.kind == TypeKind.DynTrait and right.kind == TypeKind.DynTrait:
            left.name == right.name
        elif left.kind == TypeKind.DynTrait:
            false
        elif right.kind == TypeKind.DynTrait:
            false
        elif left.kind == TypeKind.Array and right.kind == TypeKind.Array:
            left.inner == right.inner
        elif left.kind == TypeKind.Optional and right.kind == TypeKind.Optional:
            left.inner == right.inner
        else:
            left.kind == right.kind and left.name == right.name and left.inner == right.inner

    fn can_coerce_to_dyn_trait(concrete_name: text, trait_name: text) -> bool:
        self.has_trait_impl(trait_name) and concrete_name != ""

    fn method_call_type_checks(trait_name: text, method_name: text) -> bool:
        self.is_bound(trait_name) and self.method_names.contains(method_name)

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Dynamic Trait Objects":
    """
    The type checker should correctly handle dynamic trait objects (dyn Trait),
    supporting runtime polymorphism with type safety.
    """

    it "same dyn trait types unify":
        val checker = TypeChecker.new()
        check(checker.unify(Type.dyn_trait("Display"), Type.dyn_trait("Display")))

    it "different dyn trait types do not unify":
        val checker = TypeChecker.new()
        check(not checker.unify(Type.dyn_trait("Display"), Type.dyn_trait("Debug")))

    it "concrete type coerces to dyn Trait":
        val checker = TypeChecker.new()
        checker.register_trait_impl("Display")
        check(checker.can_coerce_to_dyn_trait("Person", "Display"))

    it "dyn Trait in array types":
        val checker = TypeChecker.new()
        check(checker.unify(Type.array("dyn Display"), Type.array("dyn Display")))

    it "dyn Trait in Optional types":
        val checker = TypeChecker.new()
        check(checker.unify(Type.optional("dyn Display"), Type.optional("dyn Display")))

    it "static dispatch with interface binding":
        val checker = TypeChecker.new()
        checker.bind_interface("Display")
        check(checker.dispatch_mode("Display") == DispatchMode.Static)

    it "dynamic dispatch without interface binding":
        val checker = TypeChecker.new()
        check(checker.dispatch_mode("Display") == DispatchMode.Dynamic)

    it "cannot assign dyn Trait to concrete type":
        val checker = TypeChecker.new()
        check(not checker.unify(Type.dyn_trait("Display"), Type.concrete("Person")))

    it "dyn Trait method calls type check":
        val checker = TypeChecker.new()
        checker.bind_interface("Display")
        checker.register_method("render")
        check(checker.method_call_type_checks("Display", "render"))

    it "dyn Trait with generic methods":
        val checker = TypeChecker.new()
        checker.bind_interface("Iterable")
        checker.register_method("map")
        check(checker.method_call_type_checks("Iterable", "map"))
