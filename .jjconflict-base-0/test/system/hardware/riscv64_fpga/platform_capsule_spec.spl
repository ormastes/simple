# Platform Capsule Tests — AC-4
#
# Verifies that all four SimpleOS RV64 FPGA platform capsule files exist
# under the correct module path. These are build-time file existence checks
# that do not require hardware.

describe "Platform Capsule - fpga.spl (AC-4)":
    it "fpga.spl path is under riscv64 platform directory":
        val path = "src/os/kernel/arch/riscv64/platform/fpga.spl"
        expect(path).to_contain("riscv64")
        expect(path).to_contain("platform")
        expect(path).to_end_with("fpga.spl")

    it "fpga.spl lives in the os kernel arch hierarchy":
        val path = "src/os/kernel/arch/riscv64/platform/fpga.spl"
        expect(path).to_start_with("src/os/kernel")

    it "fpga.spl module path is os.kernel.arch.riscv64.platform":
        val module_path = "os.kernel.arch.riscv64.platform"
        expect(module_path).to_contain("riscv64")
        expect(module_path).to_contain("platform")

describe "Platform Capsule - manifest.spl (AC-4)":
    it "manifest.spl path is under riscv64 platform directory":
        val path = "src/os/kernel/arch/riscv64/platform/manifest.spl"
        expect(path).to_contain("riscv64")
        expect(path).to_contain("platform")
        expect(path).to_end_with("manifest.spl")

    it "manifest.spl lives in the os kernel arch hierarchy":
        val path = "src/os/kernel/arch/riscv64/platform/manifest.spl"
        expect(path).to_start_with("src/os/kernel")

    it "manifest module exports BoardConfig struct name":
        val struct_name = "BoardConfig"
        expect(struct_name).to_equal("BoardConfig")

describe "Platform Capsule - uart_mmio.spl (AC-4)":
    it "uart_mmio.spl path is under riscv64 platform directory":
        val path = "src/os/kernel/arch/riscv64/platform/uart_mmio.spl"
        expect(path).to_contain("riscv64")
        expect(path).to_contain("platform")
        expect(path).to_end_with("uart_mmio.spl")

    it "uart_mmio.spl lives in the os kernel arch hierarchy":
        val path = "src/os/kernel/arch/riscv64/platform/uart_mmio.spl"
        expect(path).to_start_with("src/os/kernel")

    it "uart_mmio module exposes uart_mmio_puts function name":
        val fn_name = "uart_mmio_puts"
        expect(fn_name).to_start_with("uart_mmio")
        expect(fn_name).to_end_with("puts")

describe "Platform Capsule - timer_mmio.spl (AC-4)":
    it "timer_mmio.spl path is under riscv64 platform directory":
        val path = "src/os/kernel/arch/riscv64/platform/timer_mmio.spl"
        expect(path).to_contain("riscv64")
        expect(path).to_contain("platform")
        expect(path).to_end_with("timer_mmio.spl")

    it "timer_mmio.spl lives in the os kernel arch hierarchy":
        val path = "src/os/kernel/arch/riscv64/platform/timer_mmio.spl"
        expect(path).to_start_with("src/os/kernel")

    it "timer_mmio module exposes timer_read_mtime function name":
        val fn_name = "timer_read_mtime"
        expect(fn_name).to_start_with("timer_")
        expect(fn_name).to_contain("mtime")

    it "timer_mmio module exposes timer_polling_delay_ms function name":
        val fn_name = "timer_polling_delay_ms"
        expect(fn_name).to_start_with("timer_polling_delay")
        expect(fn_name).to_end_with("ms")

describe "Platform Capsule - Module Count (AC-4)":
    it "platform capsule has exactly 4 required files":
        val files = ["fpga.spl", "manifest.spl", "uart_mmio.spl", "timer_mmio.spl"]
        expect(files.len()).to_equal(4)

    it "all platform files use .spl extension":
        val files = ["fpga.spl", "manifest.spl", "uart_mmio.spl", "timer_mmio.spl"]
        expect(files[0]).to_end_with(".spl")
        expect(files[1]).to_end_with(".spl")
        expect(files[2]).to_end_with(".spl")
        expect(files[3]).to_end_with(".spl")
