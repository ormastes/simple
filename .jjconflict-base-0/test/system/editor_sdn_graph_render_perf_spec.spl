# editor_sdn_graph_render_perf_spec
#
# Exercises SDN graph parse-to-HTML rendering without the full editor stack.

use std.spec
use std.editor.services.sdn_graph.*

fn perf_graph_sample(count: i64) -> text:
    var lines: [text] = []
    lines.push("graph: perf_preview")
    lines.push("direction: right")
    var i = 0
    while i < count:
        val id = "N" + i.to_text()
        val role = if i % 2 == 0 then "service" else: "database"
        lines.push(id + ": Node " + i.to_text() + " role: " + role)
        if i > 0:
            lines.push("N" + (i - 1).to_text() + " -> " + id + ": edge " + i.to_text() + " kind: request")
        i = i + 1
    lines.push("weave @:")
    lines.push("    node where role = service:")
    lines.push("        add: card")
    lines.push("    node where role = database:")
    lines.push("        add: storage")
    lines.push("    edge where kind = request:")
    lines.push("        add: primary")
    lines.join("\n")

describe "SDN graph render hot path":

    it "renders larger graph text to HTML with all woven CSS labels":
        val graph = sdn_graph_parse(perf_graph_sample(64))
        val html = sdn_graph_render_html(graph)
        expect(graph.nodes.len()).to_equal(64)
        expect(graph.edges.len()).to_equal(63)
        expect(html).to_contain("data-graph=\"perf_preview\"")
        expect(html).to_contain("data-node=\"N63\"")
        expect(html).to_contain("sdn-css-card")
        expect(html).to_contain("sdn-css-storage")
        expect(html).to_contain("sdn-css-primary")
