use std.spipe.*
use os.crypto.ed25519.{ed25519_verify}
use test.system.os_crypto_ref_helpers.{hex_to_bytes}

val RFC8032_PUBKEY_HEX = "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a"
val RFC8032_SIG_EMPTY_HEX = "e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b"

describe "os.crypto.ed25519 verify wrapper contract":

    it "verifies the RFC 8032 empty-message signature":
        val pubkey = hex_to_bytes(RFC8032_PUBKEY_HEX)
        val sig = hex_to_bytes(RFC8032_SIG_EMPTY_HEX)
        expect(ed25519_verify(pubkey, [], sig)).to_equal(true)

    it "rejects the RFC 8032 signature if the message changes":
        val pubkey = hex_to_bytes(RFC8032_PUBKEY_HEX)
        val sig = hex_to_bytes(RFC8032_SIG_EMPTY_HEX)
        expect(ed25519_verify(pubkey, [0x01u8], sig)).to_equal(false)
