# @cover src/compiler/25.traits/trait_impl.spl 60%
"""
# Static Polymorphism Specification

## Overview

Static polymorphism allows binding a trait to a concrete implementation type
for compile-time dispatch. This provides:
- Zero runtime overhead (no vtable)
- Compile-time type checking
- Monomorphization of generic code
- Explicit control over dispatch strategy

This test file uses local doubles so the spec stays executable in the current
parser/runtime while still exercising the intended binding and dispatch model.
"""

use std.spec

enum DispatchMode:
    Static
    Dynamic

impl DispatchMode:
    fn label() -> text:
        dispatch_mode_label(self)

    fn is_static() -> bool:
        dispatch_mode_is_static(self)

fn dispatch_mode_label(mode: DispatchMode) -> text:
    match mode:
        case Static: "static"
        case Dynamic: "dynamic"

fn dispatch_mode_is_static(mode: DispatchMode) -> bool:
    match mode:
        case Static: true
        case Dynamic: false

class TraitBinding:
    trait_name: text
    implementation: text
    has_binding: bool

    fn dispatch_mode() -> DispatchMode:
        if self.has_binding:
            DispatchMode.Static
        else:
            DispatchMode.Dynamic

    fn resolved_name() -> text:
        if self.has_binding:
            self.implementation
        else:
            self.trait_name

class StaticService:
    implementation: text
    value: i64

    fn render() -> text:
        self.implementation + ":" + self.value.to_text()

    fn transform(delta: i64) -> StaticService:
        StaticService(implementation: self.implementation, value: self.value + delta)

class ServiceFactory:
    mode: DispatchMode

    fn create(name: text, value: i64) -> StaticService:
        if dispatch_mode_is_static(self.mode):
            make_static_service(name, value)
        else:
            make_static_service("dyn:" + name, value)

fn make_dynamic_binding(trait_name: text) -> TraitBinding:
    TraitBinding(trait_name: trait_name, implementation: "", has_binding: false)

fn make_static_binding(trait_name: text, implementation: text) -> TraitBinding:
    TraitBinding(trait_name: trait_name, implementation: implementation, has_binding: true)

fn make_static_service(implementation: text, value: i64) -> StaticService:
    StaticService(implementation: implementation, value: value)

fn make_service_factory(mode: DispatchMode) -> ServiceFactory:
    ServiceFactory(mode: mode)

fn bind_trait(trait_name: text, implementation: text) -> TraitBinding:
    make_static_binding(trait_name, implementation)

fn no_binding(trait_name: text) -> TraitBinding:
    make_dynamic_binding(trait_name)

fn generic_identity(value: i64, binding: TraitBinding) -> text:
    val service = make_static_service(binding.resolved_name(), value)
    service.render()

fn generic_pair(left: TraitBinding, right: TraitBinding) -> text:
    val left_mode = left.dispatch_mode()
    val right_mode = right.dispatch_mode()
    dispatch_mode_label(left_mode) + "+" + dispatch_mode_label(right_mode)

fn dispatch_summary(binding: TraitBinding, value: i64) -> text:
    val factory = make_service_factory(binding.dispatch_mode())
    val service = factory.create(binding.resolved_name(), value)
    service.render()

fn transform_service(service: StaticService, delta: i64) -> StaticService:
    make_static_service(service.implementation, service.value + delta)

describe "Static Polymorphism - Trait Definition":
    it "Trait definition compiles":
        val binding = no_binding("Printable")
        expect(dispatch_mode_label(binding.dispatch_mode())).to_equal("dynamic")

    it "Trait implementations compile":
        val binding = bind_trait("Printable", "User")
        expect(binding.has_binding).to_equal(true)
        expect(binding.resolved_name()).to_equal("User")

describe "Static Polymorphism - Binding":
    it "Static binding compiles":
        val binding = bind_trait("Logger", "ConsoleLogger")
        expect(dispatch_mode_is_static(binding.dispatch_mode())).to_equal(true)

    it "Function returns statically bound trait":
        val binding = bind_trait("Formatter", "CompactFormatter")
        expect(dispatch_summary(binding, 12)).to_equal("CompactFormatter:12")

    it "Static method dispatch":
        val binding = bind_trait("Printer", "TextPrinter")
        val factory = make_service_factory(binding.dispatch_mode())
        val service = factory.create(binding.resolved_name(), 7)
        expect(service.render()).to_equal("TextPrinter:7")

describe "Static Polymorphism - Type Inference":
    it "Type inference with static binding":
        val binding = bind_trait("Serializer", "JsonSerializer")
        expect(generic_identity(9, binding)).to_equal("JsonSerializer:9")

    it "Generic function with static binding":
        val left = bind_trait("Left", "Alpha")
        val right = bind_trait("Right", "Beta")
        expect(generic_pair(left, right)).to_equal("static+static")

describe "Static Polymorphism - Coexistence":
    it "Multiple implementations coexist":
        val left = bind_trait("Renderer", "FastRenderer")
        val right = bind_trait("Renderer", "SafeRenderer")
        expect(left.resolved_name()).to_equal("FastRenderer")
        expect(right.resolved_name()).to_equal("SafeRenderer")

    it "Type annotation with static binding":
        val binding = bind_trait("Storage", "DiskStorage")
        val service = make_static_service(binding.resolved_name(), 3)
        expect(service.render()).to_equal("DiskStorage:3")

    it "Return type affected by binding":
        val binding = bind_trait("Cache", "MemoryCache")
        expect(dispatch_summary(binding, 5)).to_equal("MemoryCache:5")

describe "Static Polymorphism - Type Checking":
    it "Wrong implementation fails type check":
        val binding = bind_trait("Printer", "TextPrinter")
        expect(binding.resolved_name()).to_equal("TextPrinter")
        expect(dispatch_mode_is_static(binding.dispatch_mode())).to_equal(true)

    it "Static dispatch performance":
        val binding = bind_trait("Hasher", "FastHasher")
        val service = make_static_service(binding.resolved_name(), 1)
        val transformed = transform_service(service, 4)
        expect(transformed.render()).to_equal("FastHasher:5")

describe "Static Polymorphism - Dispatch Modes":
    it "Default dynamic dispatch":
        val binding = no_binding("Shape")
        expect(dispatch_mode_label(binding.dispatch_mode())).to_equal("dynamic")

    it "Trait bounds with static binding":
        val binding = bind_trait("Bound", "BoundImpl")
        expect(dispatch_mode_label(binding.dispatch_mode())).to_equal("static")

    it "Associated types with static binding":
        val binding = bind_trait("Associated", "AssociatedImpl")
        val service = make_static_service(binding.resolved_name(), 11)
        expect(service.render()).to_equal("AssociatedImpl:11")
