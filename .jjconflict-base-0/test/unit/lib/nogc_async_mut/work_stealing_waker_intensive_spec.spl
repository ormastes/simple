"""
# Work-Stealing, Waker & Collections Intensive Tests

**Feature IDs:** #RT-020
**Category:** Runtime
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** doc/requirement/async_promise_intensive_tests.md

## Overview
Intensive tests for WorkStealingQueue (LIFO pop, FIFO steal), Waker notification
system, JoinSet dynamic task collection, and FuturesUnordered.
"""

# --- Inline Stubs ---

class WorkStealingQueue:
    items: [i64]
    steal_end: i64

    static fn new() -> WorkStealingQueue:
        WorkStealingQueue(items: [], steal_end: 0)

    me push(item: i64):
        self.items = self.items + [item]

    me pop() -> i64:
        if self.items.len() <= self.steal_end:
            return 0
        val last = self.items.len() - 1
        val item = self.items[last]
        self.items = self.items[0:last]
        item

    me steal() -> i64:
        if self.steal_end >= self.items.len():
            return 0
        val item = self.items[self.steal_end]
        self.steal_end = self.steal_end + 1
        item

    fn is_empty() -> bool:
        self.items.len() <= self.steal_end

    fn len() -> i64:
        self.items.len() - self.steal_end

class Waker:
    task_id: i64
    wake_count: i64

    static fn new(task_id: i64) -> Waker:
        Waker(task_id: task_id, wake_count: 0)

    me wake():
        self.wake_count = self.wake_count + 1

    me wake_by_ref():
        self.wake()

    fn will_wake(other: Waker) -> bool:
        self.task_id == other.task_id

class Context:
    waker: Waker

    static fn from_waker(waker: Waker) -> Context:
        Context(waker: waker)

enum FState:
    Pending
    Ready(value)

class SFuture:
    state: FState
    static fn ready(v) -> SFuture: SFuture(state: FState.Ready(v))
    static fn pending() -> SFuture: SFuture(state: FState.Pending)
    fn is_ready() -> bool:
        match self.state:
            case FState.Ready(_): true
            case _: false
    fn get_value() -> i64:
        match self.state:
            case FState.Ready(v): v
            case _: 0

class JoinSet:
    tasks: [SFuture]

    static fn new() -> JoinSet:
        JoinSet(tasks: [])

    me add(future: SFuture):
        self.tasks = self.tasks + [future]

    fn len() -> i64:
        self.tasks.len()

    fn is_empty() -> bool:
        self.tasks.len() == 0

    me join_next() -> i64:
        var i = 0
        while i < self.tasks.len():
            if self.tasks[i].is_ready():
                val v = self.tasks[i].get_value()
                var new_tasks: [SFuture] = []
                var j = 0
                while j < self.tasks.len():
                    if j != i:
                        new_tasks = new_tasks + [self.tasks[j]]
                    j = j + 1
                self.tasks = new_tasks
                return v
            i = i + 1
        0

    fn pending_count() -> i64:
        var count = 0
        var i = 0
        while i < self.tasks.len():
            if not self.tasks[i].is_ready():
                count = count + 1
            i = i + 1
        count

class FuturesUnordered:
    futures: [SFuture]

    static fn new() -> FuturesUnordered:
        FuturesUnordered(futures: [])

    me push(f: SFuture):
        self.futures = self.futures + [f]

    fn len() -> i64:
        self.futures.len()

    fn is_empty() -> bool:
        self.futures.len() == 0

    me try_next() -> i64:
        var i = 0
        while i < self.futures.len():
            if self.futures[i].is_ready():
                val v = self.futures[i].get_value()
                var new_futs: [SFuture] = []
                var j = 0
                while j < self.futures.len():
                    if j != i:
                        new_futs = new_futs + [self.futures[j]]
                    j = j + 1
                self.futures = new_futs
                return v
            i = i + 1
        0

# --- Tests ---

describe "WorkStealingQueue Basics":
    it "new queue is empty":
        var q = WorkStealingQueue.new()
        expect(q.is_empty()).to_equal(true)
        expect(q.len()).to_equal(0)

    it "push increases length":
        var q = WorkStealingQueue.new()
        q.push(10)
        expect(q.len()).to_equal(1)
        expect(q.is_empty()).to_equal(false)

    it "single push and pop returns the item":
        var q = WorkStealingQueue.new()
        q.push(42)
        val result = q.pop()
        expect(result).to_equal(42)
        expect(q.is_empty()).to_equal(true)

describe "WorkStealingQueue LIFO Pop":
    it "pop returns items in LIFO order":
        var q = WorkStealingQueue.new()
        q.push(1)
        q.push(2)
        q.push(3)
        expect(q.pop()).to_equal(3)
        expect(q.pop()).to_equal(2)
        expect(q.pop()).to_equal(1)

    it "queue is empty after popping all items":
        var q = WorkStealingQueue.new()
        q.push(10)
        q.push(20)
        q.pop()
        q.pop()
        expect(q.is_empty()).to_equal(true)
        expect(q.len()).to_equal(0)

describe "WorkStealingQueue FIFO Steal":
    it "steal returns items in FIFO order":
        var q = WorkStealingQueue.new()
        q.push(1)
        q.push(2)
        q.push(3)
        expect(q.steal()).to_equal(1)
        expect(q.steal()).to_equal(2)
        expect(q.steal()).to_equal(3)

    it "queue is empty after stealing all items":
        var q = WorkStealingQueue.new()
        q.push(5)
        q.push(6)
        q.steal()
        q.steal()
        expect(q.is_empty()).to_equal(true)

describe "WorkStealingQueue Mixed Pop and Steal":
    it "pop and steal interleaved produce correct results":
        var q = WorkStealingQueue.new()
        q.push(1)
        q.push(2)
        q.push(3)
        q.push(4)
        # steal takes from front (FIFO), pop takes from back (LIFO)
        expect(q.steal()).to_equal(1)
        expect(q.pop()).to_equal(4)
        expect(q.steal()).to_equal(2)
        expect(q.pop()).to_equal(3)

    it "queue is empty after fully draining via mixed ops":
        var q = WorkStealingQueue.new()
        q.push(10)
        q.push(20)
        q.steal()
        q.pop()
        expect(q.is_empty()).to_equal(true)
        expect(q.len()).to_equal(0)

describe "WorkStealingQueue Edge Cases":
    it "pop on empty queue returns sentinel 0":
        var q = WorkStealingQueue.new()
        expect(q.pop()).to_equal(0)

    it "steal on empty queue returns sentinel 0":
        var q = WorkStealingQueue.new()
        expect(q.steal()).to_equal(0)

    it "single item can be popped or stolen":
        var q1 = WorkStealingQueue.new()
        q1.push(99)
        expect(q1.pop()).to_equal(99)

        var q2 = WorkStealingQueue.new()
        q2.push(99)
        expect(q2.steal()).to_equal(99)

describe "Waker Basics":
    it "new waker has zero wake count":
        var w = Waker.new(task_id: 1)
        expect(w.wake_count).to_equal(0)
        expect(w.task_id).to_equal(1)

    it "wake increments the count":
        var w = Waker.new(task_id: 1)
        w.wake()
        expect(w.wake_count).to_equal(1)

    it "wake_by_ref also increments the count":
        var w = Waker.new(task_id: 2)
        w.wake_by_ref()
        expect(w.wake_count).to_equal(1)

describe "Waker will_wake":
    it "returns true for same task_id":
        var w1 = Waker.new(task_id: 5)
        var w2 = Waker.new(task_id: 5)
        expect(w1.will_wake(w2)).to_equal(true)

    it "returns false for different task_id":
        var w1 = Waker.new(task_id: 5)
        var w2 = Waker.new(task_id: 6)
        expect(w1.will_wake(w2)).to_equal(false)

describe "Waker Multiple Wakes":
    it "tracks cumulative wake count":
        var w = Waker.new(task_id: 10)
        w.wake()
        w.wake()
        w.wake()
        w.wake()
        w.wake()
        expect(w.wake_count).to_equal(5)

    it "wake and wake_by_ref both contribute to count":
        var w = Waker.new(task_id: 20)
        w.wake()
        w.wake_by_ref()
        w.wake()
        expect(w.wake_count).to_equal(3)

describe "Context":
    it "from_waker preserves the waker":
        var w = Waker.new(task_id: 7)
        var ctx = Context.from_waker(waker: w)
        expect(ctx.waker.task_id).to_equal(7)
        expect(ctx.waker.wake_count).to_equal(0)

describe "JoinSet Basics":
    it "new JoinSet is empty":
        var js = JoinSet.new()
        expect(js.is_empty()).to_equal(true)
        expect(js.len()).to_equal(0)

    it "add increases length":
        var js = JoinSet.new()
        js.add(SFuture.ready(1))
        expect(js.len()).to_equal(1)
        expect(js.is_empty()).to_equal(false)

    it "add multiple tasks":
        var js = JoinSet.new()
        js.add(SFuture.ready(10))
        js.add(SFuture.pending())
        js.add(SFuture.ready(30))
        expect(js.len()).to_equal(3)

describe "JoinSet join_next":
    it "returns ready value and removes it":
        var js = JoinSet.new()
        js.add(SFuture.ready(42))
        val v = js.join_next()
        expect(v).to_equal(42)
        expect(js.len()).to_equal(0)

    it "returns 0 when no tasks are ready":
        var js = JoinSet.new()
        js.add(SFuture.pending())
        js.add(SFuture.pending())
        expect(js.join_next()).to_equal(0)
        expect(js.len()).to_equal(2)

    it "skips pending and returns first ready":
        var js = JoinSet.new()
        js.add(SFuture.pending())
        js.add(SFuture.ready(77))
        js.add(SFuture.pending())
        val v = js.join_next()
        expect(v).to_equal(77)
        expect(js.len()).to_equal(2)

describe "JoinSet pending_count":
    it "counts only pending futures":
        var js = JoinSet.new()
        js.add(SFuture.ready(1))
        js.add(SFuture.pending())
        js.add(SFuture.ready(3))
        js.add(SFuture.pending())
        expect(js.pending_count()).to_equal(2)

    it "returns 0 when all are ready":
        var js = JoinSet.new()
        js.add(SFuture.ready(1))
        js.add(SFuture.ready(2))
        expect(js.pending_count()).to_equal(0)

describe "FuturesUnordered Basics":
    it "new FuturesUnordered is empty":
        var fu = FuturesUnordered.new()
        expect(fu.is_empty()).to_equal(true)
        expect(fu.len()).to_equal(0)

    it "push adds futures":
        var fu = FuturesUnordered.new()
        fu.push(SFuture.ready(10))
        fu.push(SFuture.pending())
        expect(fu.len()).to_equal(2)
        expect(fu.is_empty()).to_equal(false)

describe "FuturesUnordered try_next":
    it "returns first ready value and removes it":
        var fu = FuturesUnordered.new()
        fu.push(SFuture.ready(55))
        val v = fu.try_next()
        expect(v).to_equal(55)
        expect(fu.len()).to_equal(0)

    it "returns 0 when none are ready":
        var fu = FuturesUnordered.new()
        fu.push(SFuture.pending())
        expect(fu.try_next()).to_equal(0)
        expect(fu.len()).to_equal(1)

    it "skips pending and returns first ready":
        var fu = FuturesUnordered.new()
        fu.push(SFuture.pending())
        fu.push(SFuture.pending())
        fu.push(SFuture.ready(88))
        val v = fu.try_next()
        expect(v).to_equal(88)
        expect(fu.len()).to_equal(2)

    it "drains all ready futures one by one":
        var fu = FuturesUnordered.new()
        fu.push(SFuture.ready(1))
        fu.push(SFuture.ready(2))
        fu.push(SFuture.ready(3))
        val v1 = fu.try_next()
        val v2 = fu.try_next()
        val v3 = fu.try_next()
        expect(v1).to_equal(1)
        expect(v2).to_equal(2)
        expect(v3).to_equal(3)
        expect(fu.is_empty()).to_equal(true)
