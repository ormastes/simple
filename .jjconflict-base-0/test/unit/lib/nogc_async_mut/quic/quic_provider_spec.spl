# QUIC Provider Spec — Pure-Simple tests for provider boundary
#
# Verifies that the QUIC provider layer can be constructed, inspected, and
# gated without any native quiche symbols.  No extern declarations appear
# in this file or any transitive import.
#
# Feature: Webserver hardening WQ-4 — keep QUIC/H3 as provider-bound

use nogc_async_mut.quic.quic_provider.{
    QuicProvider,
    quic_provider_check,
    quic_provider_label,
    quic_provider_is_usable,
    QuicTransportParams,
    quic_transport_params_default,
    H3_PROVIDER_FRAME_DATA,
    H3_PROVIDER_FRAME_HEADERS,
    H3_PROVIDER_FRAME_CANCEL_PUSH,
    H3_PROVIDER_FRAME_SETTINGS,
    H3_PROVIDER_FRAME_PUSH_PROMISE,
    H3_PROVIDER_FRAME_GOAWAY,
    H3_PROVIDER_FRAME_MAX_PUSH_ID,
    QuicProviderError,
    QuicProviderResult,
    quic_provider_gate
}

# ============================================================================
# Provider availability
# ============================================================================

describe "QUIC Provider":
    context "Provider availability check":
        it "returns Unavailable in pure-Simple builds":
            val p = quic_provider_check()
            val label = quic_provider_label(p)
            expect label == "unavailable"

        it "does not crash when checking availability":
            val p = quic_provider_check()
            val usable = quic_provider_is_usable(p)
            expect usable == false

        it "Available provider is usable":
            val p = QuicProvider.Available
            expect quic_provider_is_usable(p) == true

        it "Stub provider is not usable":
            val p = QuicProvider.Stub
            expect quic_provider_is_usable(p) == false

        it "labels Available correctly":
            expect quic_provider_label(QuicProvider.Available) == "available"

        it "labels Stub correctly":
            expect quic_provider_label(QuicProvider.Stub) == "stub"

    context "Provider gate":
        it "gates Unavailable with NativeUnavailable error":
            val result = quic_provider_gate(QuicProvider.Unavailable)
            expect result.ok == false

        it "gates Stub with StubOnly error":
            val result = quic_provider_gate(QuicProvider.Stub)
            expect result.ok == false

        it "passes Available provider":
            val result = quic_provider_gate(QuicProvider.Available)
            expect result.ok == true

        it "returns the provider in the result":
            val result = quic_provider_gate(QuicProvider.Unavailable)
            val label = quic_provider_label(result.provider)
            expect label == "unavailable"

# ============================================================================
# Wrapper types — constructible without native symbols
# ============================================================================

    context "QuicTransportParams":
        it "creates default params with RFC 9000 idle timeout":
            val tp = quic_transport_params_default()
            expect tp.max_idle_timeout == 30000

        it "creates default params with 1200-byte UDP payload":
            val tp = quic_transport_params_default()
            expect tp.max_udp_payload_size == 1200

        it "creates default params with 100 bidi streams":
            val tp = quic_transport_params_default()
            expect tp.initial_max_streams_bidi == 100

        it "creates default params with 100 uni streams":
            val tp = quic_transport_params_default()
            expect tp.initial_max_streams_uni == 100

        it "creates default params with 1 MiB initial max data":
            val tp = quic_transport_params_default()
            expect tp.initial_max_data == 1048576

        it "creates custom transport params":
            val tp = QuicTransportParams {
                max_idle_timeout: 5000,
                max_udp_payload_size: 1452,
                initial_max_data: 524288,
                initial_max_stream_data_bidi_local: 131072,
                initial_max_stream_data_bidi_remote: 131072,
                initial_max_stream_data_uni: 131072,
                initial_max_streams_bidi: 50,
                initial_max_streams_uni: 25
            }
            expect tp.max_idle_timeout == 5000
            expect tp.initial_max_streams_uni == 25

# ============================================================================
# H3 frame types — testable without runtime
# ============================================================================

    context "H3 frame type constants":
        it "DATA is 0x00":
            expect H3_PROVIDER_FRAME_DATA == 0

        it "HEADERS is 0x01":
            expect H3_PROVIDER_FRAME_HEADERS == 1

        it "CANCEL_PUSH is 0x03":
            expect H3_PROVIDER_FRAME_CANCEL_PUSH == 3

        it "SETTINGS is 0x04":
            expect H3_PROVIDER_FRAME_SETTINGS == 4

        it "PUSH_PROMISE is 0x05":
            expect H3_PROVIDER_FRAME_PUSH_PROMISE == 5

        it "GOAWAY is 0x07":
            expect H3_PROVIDER_FRAME_GOAWAY == 7

        it "MAX_PUSH_ID is 0x0d":
            expect H3_PROVIDER_FRAME_MAX_PUSH_ID == 13
