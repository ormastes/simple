# CPU shader evaluator tests

use std.spipe.*
use std.skia.entity.color.{SkColor4f, sk_color_argb}
use std.skia.entity.image.{SkImage, SkImageInfo, sk_image_info_n32_premul}
use std.skia.entity.geometry.{SkPoint}
use std.skia.entity.enums.{SkBlendMode, SkTileMode}
use std.skia.entity.shader.{SkShader, SkShaderKind, sk_shader_make_linear_gradient, sk_shader_make_radial_gradient}
use std.skia.backend.cpu.shaders.{
    interpolate_stops, tile_coord,
    eval_linear_gradient, eval_radial_gradient,
    sample_image_nearest,
    apply_blend
}

fn _approx(a: f64, b: f64) -> bool:
    val d = a - b
    val ad = if d < 0.0: -d else: d
    ad < 0.001

fn _red_color() -> SkColor4f:
    SkColor4f(r: 1.0, g: 0.0, b: 0.0, a: 1.0)

fn _blue_color() -> SkColor4f:
    SkColor4f(r: 0.0, g: 0.0, b: 1.0, a: 1.0)

fn _red_packed() -> i64:
    sk_color_argb(255, 255, 0, 0)

fn _blue_packed() -> i64:
    sk_color_argb(255, 0, 0, 255)

fn _make_two_stop_shader() -> SkShader:
    val colors = [_red_packed(), _blue_packed()]
    val positions = [0.0, 1.0]
    val start = SkPoint(x: 0.0, y: 0.0)
    val end = SkPoint(x: 100.0, y: 0.0)
    sk_shader_make_linear_gradient(start, end, colors, positions, SkTileMode.Clamp)

fn _make_radial_shader() -> SkShader:
    val colors = [_red_packed(), _blue_packed()]
    val positions = [0.0, 1.0]
    val center = SkPoint(x: 50.0, y: 50.0)
    sk_shader_make_radial_gradient(center, 50.0, colors, positions, SkTileMode.Clamp)

fn _empty_image() -> SkImage:
    val info = sk_image_info_n32_premul(4, 4)
    SkImage(info: info, pixels: [])

describe "interpolate_stops: midpoint":
    it "t=0.5 with two stops returns midpoint color":
        val colors = [_red_packed(), _blue_packed()]
        val positions = [0.0, 1.0]
        val result = interpolate_stops(colors, positions, 0.5)
        expect _approx(result.r, 0.5) to_equal true
        expect _approx(result.b, 0.5) to_equal true
        expect _approx(result.g, 0.0) to_equal true

describe "interpolate_stops: first stop":
    it "t=0 returns first stop color":
        val colors = [_red_packed(), _blue_packed()]
        val positions = [0.0, 1.0]
        val result = interpolate_stops(colors, positions, 0.0)
        expect _approx(result.r, 1.0) to_equal true
        expect _approx(result.b, 0.0) to_equal true

describe "tile_coord: Repeat":
    it "t=1.5 with Repeat returns 0.5":
        val result = tile_coord(1.5, SkTileMode.Repeat)
        expect _approx(result, 0.5) to_equal true

describe "tile_coord: Clamp":
    it "t=1.5 with Clamp returns 1.0":
        val result = tile_coord(1.5, SkTileMode.Clamp)
        expect _approx(result, 1.0) to_equal true

describe "tile_coord: Mirror":
    it "t=-0.3 with Mirror maps to 0.3":
        val result = tile_coord(-0.3, SkTileMode.Mirror)
        # tri-wave: -0.3 is in the range [-1,0]; mirror maps to 0.3
        val ok = _approx(result, 0.3) or _approx(result, 0.7)
        expect ok to_equal true

describe "eval_linear_gradient: start point":
    it "at start point returns first stop color":
        val shader = _make_two_stop_shader()
        val result = eval_linear_gradient(shader, 0.0, 0.0)
        expect _approx(result.r, 1.0) to_equal true
        expect _approx(result.b, 0.0) to_equal true

describe "eval_linear_gradient: end point":
    it "at end point returns last stop color":
        val shader = _make_two_stop_shader()
        val result = eval_linear_gradient(shader, 100.0, 0.0)
        expect _approx(result.r, 0.0) to_equal true
        expect _approx(result.b, 1.0) to_equal true

describe "eval_radial_gradient: center":
    it "at center returns first stop color":
        val shader = _make_radial_shader()
        val result = eval_radial_gradient(shader, 50.0, 50.0)
        expect _approx(result.r, 1.0) to_equal true
        expect _approx(result.b, 0.0) to_equal true

describe "sample_image_nearest: empty pixels":
    it "returns transparent black when pixel list is empty":
        val image = _empty_image()
        val result = sample_image_nearest(image, 1.0, 1.0)
        expect _approx(result.r, 0.0) to_equal true
        expect _approx(result.g, 0.0) to_equal true
        expect _approx(result.b, 0.0) to_equal true
        expect _approx(result.a, 0.0) to_equal true

describe "apply_blend: SrcOver with opaque src":
    it "opaque red over anything returns red":
        val src = SkColor4f(r: 1.0, g: 0.0, b: 0.0, a: 1.0)
        val dst = SkColor4f(r: 0.0, g: 1.0, b: 0.0, a: 1.0)
        val result = apply_blend(src, dst, SkBlendMode.SrcOver)
        expect _approx(result.r, 1.0) to_equal true
        expect _approx(result.g, 0.0) to_equal true
        expect _approx(result.a, 1.0) to_equal true

describe "apply_blend: Clear":
    it "Clear returns all-zero":
        val src = SkColor4f(r: 1.0, g: 1.0, b: 1.0, a: 1.0)
        val dst = SkColor4f(r: 1.0, g: 1.0, b: 1.0, a: 1.0)
        val result = apply_blend(src, dst, SkBlendMode.Clear)
        expect _approx(result.r, 0.0) to_equal true
        expect _approx(result.g, 0.0) to_equal true
        expect _approx(result.b, 0.0) to_equal true
        expect _approx(result.a, 0.0) to_equal true
