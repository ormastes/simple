use std.spec
use std.nogc_async_mut.game2d.render.canvas.{Canvas}
use std.nogc_async_mut.game2d.render.image.{Image, RenderError}
use std.nogc_async_mut.game2d.render.font.{Font, GAME2D_FONT_GLYPH_W, GAME2D_FONT_GLYPH_H}
use std.nogc_sync_mut.game2d.math.{DrawMode}

describe "gc_async_mut game2d render facade":

    it "re-exports canvas, image, font, and draw mode behavior":
        val image = Image.null()
        expect(image.is_null()).to_equal(true)
        val err = RenderError.null_image()
        expect(err.code).to_equal("GAME-RENDER-001")

        expect(GAME2D_FONT_GLYPH_W).to_equal(8)
        expect(GAME2D_FONT_GLYPH_H).to_equal(8)
