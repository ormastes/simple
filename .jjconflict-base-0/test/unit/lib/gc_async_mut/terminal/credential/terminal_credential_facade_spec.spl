use std.spec
use std.gc_async_mut.terminal.credential.store.{credential_resolve, credential_is_encrypted}

describe "gc_async_mut terminal credential facade":

    it "re-exports pure credential resolution helpers":
        expect(credential_resolve("plain-secret")).to_equal("plain-secret")
        expect(credential_is_encrypted("plain-secret")).to_equal(false)
        expect(credential_is_encrypted("encrypted:abc123")).to_equal(true)
