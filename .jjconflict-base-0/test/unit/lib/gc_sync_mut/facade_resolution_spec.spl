# Regression coverage for the GC sync mutable compatibility family.

use std.gc_sync_mut.array.{array_find_or, array_position, array_take_while}

describe "gc_sync_mut facade resolution":
    it "resolves pure helpers through the gc_async_mut backing family":
        val idx = array_position([10, 20, 30], _1 == 20)
        expect(idx).to_equal(1)

    it "preserves pure helper behavior through the sync facade":
        val found = array_find_or([1, 3, 5], _1 > 10, 99)
        expect(found).to_equal(99)

        val prefix = array_take_while([2, 4, 5, 6], _1 % 2 == 0)
        expect(prefix).to_equal([2, 4])
