# @cover src/lib/hardware/fpga_k26/k26_soc_top.spl 0%
"""
# K26 SoC Top VexRiscv-SMP Integration Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Draft
**Requirements:** REQ-2
**Artifacts:** N/A

## Overview

Verifies AC-2: k26_soc_top wires VexRiscv-SMP .v + AXI-HP bridge +
soc_rtl peripherals (CLINT, PLIC, UART16550). Tests that the generated
VHDL/SV top-level text references VexRiscv-SMP, CLINT, PLIC, and UART.

Covers:
- AC-2 (SOC integration: core wired to CLINT+PLIC+UART16550)
"""

use std.spipe.*
use lib.hardware.fpga_k26.k26_soc_top.{
    generate_k26_soc_top_vexriscv,
    k26_vexriscv_soc_config,
    K26VexRiscvSocConfig
}


# ============================================================================
# Helper
# ============================================================================

fn default_soc_config() -> K26VexRiscvSocConfig:
    return k26_vexriscv_soc_config()

fn soc_top_sv() -> text:
    val cfg = default_soc_config()
    return generate_k26_soc_top_vexriscv(cfg)


# ============================================================================
# AC-2: SoC Top Configuration Sanity
# ============================================================================

describe "K26VexRiscvSocConfig":
    it "AC-2: default config hart_count is 1":
        val cfg = default_soc_config()
        expect(cfg.hart_count).to_equal(1)

    it "AC-2: default config axi_data_width is 128":
        val cfg = default_soc_config()
        expect(cfg.axi_data_width).to_equal(128)


# ============================================================================
# AC-2: SoC Top Generated Output
# ============================================================================

describe "K26 SoC Top VexRiscv-SMP Wiring":
    it "AC-2: generated text contains VexRiscv reference":
        val sv = soc_top_sv()
        expect(sv).to_contain("VexRiscv")

    it "AC-2: generated text references CLINT":
        val sv = soc_top_sv()
        expect(sv).to_contain("clint")

    it "AC-2: generated text references PLIC":
        val sv = soc_top_sv()
        expect(sv).to_contain("plic")

    it "AC-2: generated text references UART":
        val sv = soc_top_sv()
        expect(sv).to_contain("uart")

    it "AC-2: generated text references AXI HP bridge":
        val sv = soc_top_sv()
        expect(sv).to_contain("HP0")

    it "AC-2: generated text is non-empty":
        val sv = soc_top_sv()
        val len = sv.length()
        expect(len).to_be_greater_than(0)
