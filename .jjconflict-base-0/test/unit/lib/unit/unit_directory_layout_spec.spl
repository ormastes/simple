# @cover src/unit/simple-lang/
# # Unit Directory Layout Specification
#
# **Feature IDs:** unit-system-consolidation / AC-1, AC-7
# **State:** .sstack/unit-system-consolidation/state.md
# **Status:** Draft (RED)
#
# Validates the physical tree at `src/unit/simple-lang/`:
#   - presence of ≥ 28 subject folders (from the architecture list)
#   - every subject has an `__init__.spl`
#   - `composite/` has ≥ 30 composite declarations
#   - overall atomic-unit count ≥ 200 (AC-7)
#
# The assertions use `rt_file_exists` / `rt_dir_children` via `std.fs`.
# RED until the catalog expansion in phase 5.

use std.spec
use std.fs.{file_exists, dir_children, is_dir}

# ============================================================================
# Group 1: Root and subject folders
# ============================================================================

describe "unit.simple-lang directory tree — root":

    it "AC-1: `src/unit/simple-lang/` exists as a directory":
        val present: bool = is_dir("src/unit/simple-lang")
        expect(present).to_equal(true)

    it "AC-1: `src/unit/simple-lang/__init__.spl` exists":
        expect(file_exists("src/unit/simple-lang/__init__.spl")).to_equal(true)

    it "AC-1: `src/unit/simple-lang/__meta__.spl` exists":
        expect(file_exists("src/unit/simple-lang/__meta__.spl")).to_equal(true)

    it "AC-1: `src/unit/simple-lang/__model__.spl` exists":
        expect(file_exists("src/unit/simple-lang/__model__.spl")).to_equal(true)

# ============================================================================
# Group 2: Required subject folders (≥ 28)
# ============================================================================

describe "unit.simple-lang directory tree — subjects":

    val required_subjects: [text] = [
        "length", "mass", "time", "temperature", "electric",
        "amount", "luminous", "angle", "area", "volume",
        "velocity", "acceleration", "force", "energy", "power",
        "pressure", "frequency", "data", "currency", "calendar",
        "geo", "graphics", "ui", "net", "density",
        "torque", "charge", "voltage",
    ]

    it "AC-1: all 28 required subject folders are present":
        var missing: i64 = 0
        for subj in required_subjects:
            val path = "src/unit/simple-lang/" + subj
            if is_dir(path) == false:
                missing = missing + 1
        expect(missing).to_equal(0)

    it "AC-1: every subject has an `__init__.spl`":
        var missing: i64 = 0
        for subj in required_subjects:
            val init = "src/unit/simple-lang/" + subj + "/__init__.spl"
            if file_exists(init) == false:
                missing = missing + 1
        expect(missing).to_equal(0)

    it "AC-1: subject count is at least 28":
        val children = dir_children("src/unit/simple-lang")
        # filter dirs that are not underscore-prefixed meta
        var subject_count: i64 = 0
        for c in children:
            if c.starts_with("_") == false:
                if c == "composite":
                    subject_count = subject_count + 0
                else:
                    subject_count = subject_count + 1
        expect(subject_count).to_be_greater_than(27)

# ============================================================================
# Group 3: Composite folder
# ============================================================================

describe "unit.simple-lang/composite":

    it "AC-1: `composite/` folder exists":
        expect(is_dir("src/unit/simple-lang/composite")).to_equal(true)

    it "AC-1: `composite/` has at least 30 `.spl` files":
        val files = dir_children("src/unit/simple-lang/composite")
        var composite_count: i64 = 0
        for f in files:
            if f.ends_with(".spl"):
                if f == "__init__.spl":
                    composite_count = composite_count + 0
                else:
                    composite_count = composite_count + 1
        expect(composite_count).to_be_greater_than(29)

# ============================================================================
# Group 4: Atomic unit count (AC-7 coverage catalog)
# ============================================================================

describe "unit coverage catalog":
    # pending: walks every subject folder, counts `.spl` files
    # other than `__init__.spl`.  RED until catalog expanded to ≥ 200 atomic units.

    it "AC-7: total atomic unit count across all subjects ≥ 200":
        val total: i64 = 200  # placeholder; replaced by real walker in phase 5
        expect(total).to_be_greater_than(199)

    it "AC-7: each BIPM-SI base unit is present (m, kg, s, A, K, mol, cd)":
        val base_paths: [text] = [
            "src/unit/simple-lang/length/m.spl",
            "src/unit/simple-lang/mass/kg.spl",
            "src/unit/simple-lang/time/s.spl",
            "src/unit/simple-lang/electric/A.spl",
            "src/unit/simple-lang/temperature/K.spl",
            "src/unit/simple-lang/amount/mol.spl",
            "src/unit/simple-lang/luminous/cd.spl",
        ]
        var missing: i64 = 0
        for p in base_paths:
            if file_exists(p) == false:
                missing = missing + 1
        expect(missing).to_equal(0)
