use std.spec
use std.fs_driver.fs_bench_harness.{time_function, create_benchmark_suite, add_benchmark}

# AC-1: Profiling harness captures per-function timing for RamFS and FAT32
# These specs verify the public API of the fs_bench_harness module.
# All specs FAIL until implementation exists.

describe "fs_bench_harness":
    describe "time_function":
        it "AC-1: returns elapsed microseconds greater than zero for RamFS open":
            val elapsed = time_function("ramfs_open")
            expect elapsed > 0

        it "AC-1: returns elapsed microseconds within reasonable range for RamFS open":
            val elapsed = time_function("ramfs_open")
            expect elapsed < 1000000

        it "AC-1: returns elapsed microseconds greater than zero for RamFS stat":
            val elapsed = time_function("ramfs_stat")
            expect elapsed > 0

        it "AC-1: returns elapsed microseconds within reasonable range for RamFS stat":
            val elapsed = time_function("ramfs_stat")
            expect elapsed < 1000000

        it "AC-1: returns elapsed microseconds greater than zero for RamFS close":
            val elapsed = time_function("ramfs_close")
            expect elapsed > 0

        it "AC-1: returns elapsed microseconds within reasonable range for RamFS close":
            val elapsed = time_function("ramfs_close")
            expect elapsed < 1000000

        it "AC-1: returns elapsed microseconds greater than zero for FAT32 parse":
            val elapsed = time_function("fat32_parse_superblock")
            expect elapsed > 0

        it "AC-1: returns elapsed microseconds within reasonable range for FAT32 parse":
            val elapsed = time_function("fat32_parse_superblock")
            expect elapsed < 1000000

        it "AC-1: returns elapsed microseconds greater than zero for FAT32 fat_search_long":
            val elapsed = time_function("fat32_fat_search_long")
            expect elapsed > 0

        it "AC-1: returns elapsed microseconds within reasonable range for FAT32 fat_search_long":
            val elapsed = time_function("fat32_fat_search_long")
            expect elapsed < 1000000

    describe "create_benchmark_suite":
        it "AC-1: creates a suite with a non-empty name":
            val suite = create_benchmark_suite("ramfs_suite")
            expect suite.name == "ramfs_suite"

        it "AC-1: new suite has zero recorded timings":
            val suite = create_benchmark_suite("empty_suite")
            expect suite.count == 0

    describe "add_benchmark":
        it "AC-1: adds a timing entry and increments count":
            val suite = create_benchmark_suite("test_suite")
            val suite2 = add_benchmark(suite, "ramfs_open", 42)
            expect suite2.count == 1

        it "AC-1: recorded timing value matches inserted value":
            val suite = create_benchmark_suite("test_suite")
            val suite2 = add_benchmark(suite, "ramfs_open", 99)
            expect suite2.last_timing == 99
