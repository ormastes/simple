# gzip_smoke_spec.spl — round-trip smoke tests for the gzip module.
#
# Levels 1-9 use fixed-Huffman DEFLATE blocks (RFC 1951 §3.2.6).
# Level 0 uses stored (uncompressed) blocks.
# Dynamic-Huffman blocks (BTYPE=10) are supported via inflate_block_dynamic.
# See doc/08_tracking/bug/gzip_module_crc32_unresolved_2026-05-01.md § Resolution.

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.gzip.{gzip_compress, gzip_decompress}

fn _make_small_payload() -> [u8]:
    return [
        0x61u8, 0x62u8, 0x63u8, 0x64u8,
        0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6Au8, 0x6Bu8, 0x6Cu8,
        0x6Du8, 0x6Eu8, 0x6Fu8, 0x70u8
    ]

fn _make_200_byte_payload() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 200:
        out.push((i % 251).to_u8())
        i = i + 1
    out

fn _make_aaa256() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 256:
        out.push(0x41u8)
        i = i + 1
    out

fn _make_zeros_1000() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 1000:
        out.push(0x00u8)
        i = i + 1
    out

fn _make_alpha_text_1k() -> [u8]:
    # "abcdefghijklmnopqrstuvwxyz " x 40 = 1080 bytes
    var out: [u8] = []
    var rep = 0
    while rep < 40:
        var c: i64 = 97
        while c < 123:
            out.push(c.to_u8())
            c = c + 1
        out.push(0x20u8)
        rep = rep + 1
    out

fn _make_random_64() -> [u8]:
    return [
        0x7cu8, 0x3au8, 0xf1u8, 0x09u8, 0xb4u8, 0x62u8, 0xd8u8, 0x55u8,
        0x1eu8, 0x97u8, 0x40u8, 0xc3u8, 0x2bu8, 0x8eu8, 0x73u8, 0xaau8,
        0x05u8, 0xd6u8, 0x91u8, 0x4fu8, 0xe2u8, 0xb7u8, 0x38u8, 0x6cu8,
        0x20u8, 0xdcu8, 0x59u8, 0x84u8, 0x17u8, 0xf0u8, 0x43u8, 0xc8u8,
        0x9bu8, 0x26u8, 0x71u8, 0xe5u8, 0x0au8, 0xbcu8, 0x6fu8, 0x34u8,
        0xd1u8, 0x8au8, 0x57u8, 0x2eu8, 0x93u8, 0x48u8, 0xc5u8, 0x7bu8,
        0x16u8, 0xe8u8, 0x3du8, 0xa2u8, 0x5fu8, 0x0bu8, 0xd4u8, 0x69u8,
        0x82u8, 0x25u8, 0xfbu8, 0x50u8, 0xc7u8, 0x3eu8, 0x9au8, 0x61u8
    ]

# Build the expected plaintext for _make_dyn_fixture: 50-byte phrase repeated, first 4096 bytes.
fn _make_dyn_plaintext() -> [u8]:
    # b'This is a test of the emergency broadcast system. ' = 50 bytes, repeated to 4096 bytes
    val phrase: [u8] = [
        0x54u8, 0x68u8, 0x69u8, 0x73u8, 0x20u8, 0x69u8, 0x73u8, 0x20u8, 0x61u8, 0x20u8,
        0x74u8, 0x65u8, 0x73u8, 0x74u8, 0x20u8, 0x6fu8, 0x66u8, 0x20u8, 0x74u8, 0x68u8,
        0x65u8, 0x20u8, 0x65u8, 0x6du8, 0x65u8, 0x72u8, 0x67u8, 0x65u8, 0x6eu8, 0x63u8,
        0x79u8, 0x20u8, 0x62u8, 0x72u8, 0x6fu8, 0x61u8, 0x64u8, 0x63u8, 0x61u8, 0x73u8,
        0x74u8, 0x20u8, 0x73u8, 0x79u8, 0x73u8, 0x74u8, 0x65u8, 0x6du8, 0x2eu8, 0x20u8
    ]
    var out: [u8] = []
    var i = 0
    while i < 4096:
        out.push(phrase[i % 50])
        i = i + 1
    out

# Dynamic-Huffman gzip fixture (92 bytes, BTYPE=10 / btype=2).
# Produced by: python3 -c "import zlib,struct,gzip; ..."
# Plaintext: b'This is a test of the emergency broadcast system. ' * 82  (first 4096 bytes)
# Verified with gzip.decompress() == original.
fn _make_dyn_fixture() -> [u8]:
    return [
        0x1fu8, 0x8bu8, 0x08u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0xffu8, 0xedu8, 0xcbu8,
        0xc1u8, 0x0du8, 0x80u8, 0x20u8, 0x10u8, 0x05u8, 0xd1u8, 0x56u8, 0x7eu8, 0x05u8, 0x56u8, 0x43u8,
        0x03u8, 0x88u8, 0x8bu8, 0x78u8, 0x40u8, 0x12u8, 0x76u8, 0x2fu8, 0x74u8, 0x2fu8, 0x6du8, 0x98u8,
        0x4cu8, 0x32u8, 0xb7u8, 0xc9u8, 0x4bu8, 0xedu8, 0x71u8, 0xedu8, 0xb2u8, 0xc2u8, 0x3cu8, 0x34u8,
        0xaau8, 0xa2u8, 0x99u8, 0xacu8, 0xdbu8, 0xbcu8, 0xedu8, 0x2du8, 0x4bu8, 0xe7u8, 0x1cu8, 0xf9u8,
        0x2au8, 0x79u8, 0x2fu8, 0x5fu8, 0x1eu8, 0xd6u8, 0x0fu8, 0x25u8, 0x04u8, 0x02u8, 0x81u8, 0x40u8,
        0x20u8, 0x10u8, 0x08u8, 0x04u8, 0x02u8, 0x81u8, 0x40u8, 0x20u8, 0x10u8, 0x3fu8, 0x13u8, 0x1fu8,
        0x33u8, 0x2fu8, 0x1du8, 0xf3u8, 0x00u8, 0x10u8, 0x00u8, 0x00u8
    ]

describe("gzip round-trip"):
    it("round-trips an empty payload"):
        val empty: [u8] = []
        val compressed = gzip_compress(empty, 6)
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 0

    it("round-trips a small 16-byte payload"):
        val payload = _make_small_payload()
        val compressed = gzip_compress(payload, 6)
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 16
        var i = 0
        var all_match = true
        while i < 16:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("round-trips a 200-byte payload"):
        val payload = _make_200_byte_payload()
        val compressed = gzip_compress(payload, 6)
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 200
        var i = 0
        var all_match = true
        while i < 200:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("compressed output is larger than empty input (header+footer overhead)"):
        val empty: [u8] = []
        val compressed = gzip_compress(empty, 0)
        # minimum gzip frame: 10-byte header + 5-byte stored block + 8-byte footer = 23 bytes
        expect compressed.len() >= 18 == true

    it("compressed output is larger than small input (overhead dominates)"):
        val payload = _make_small_payload()
        val compressed = gzip_compress(payload, 1)
        # gzip stored block adds ~18 bytes of overhead
        expect compressed.len() > payload.len() == true

    # --- fixed-Huffman (levels 1-9) tests ---

    it("fixed-Huffman: 256xA compresses to <50% and round-trips"):
        val payload = _make_aaa256()
        val compressed = gzip_compress(payload, 6)
        # 256 bytes → should be well under 128 bytes
        expect compressed.len() < 128 == true
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 256
        var i = 0
        var all_match = true
        while i < 256:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("fixed-Huffman: 1080-byte alpha text compresses to <80% and round-trips"):
        val payload = _make_alpha_text_1k()
        val compressed = gzip_compress(payload, 6)
        # compressed must be < 80% of original
        val limit = (payload.len() * 80) / 100
        expect compressed.len() < limit == true
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == payload.len()
        var i = 0
        var all_match = true
        while i < payload.len():
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("fixed-Huffman: 64-byte random payload round-trips"):
        val payload = _make_random_64()
        val compressed = gzip_compress(payload, 6)
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 64
        var i = 0
        var all_match = true
        while i < 64:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("fixed-Huffman: empty payload round-trips at level 6"):
        val empty: [u8] = []
        val compressed = gzip_compress(empty, 6)
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 0

    it("fixed-Huffman: 1000 zeros compress aggressively and round-trip"):
        val payload = _make_zeros_1000()
        val compressed = gzip_compress(payload, 6)
        # 1000 zeros should compress to well under 100 bytes
        expect compressed.len() < 100 == true
        val decoded = gzip_decompress(compressed)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 1000
        var i = 0
        var all_match = true
        while i < 1000:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

    it("level 0 stored blocks produce output larger than input"):
        val payload = _make_aaa256()
        val compressed = gzip_compress(payload, 0)
        # stored block: 10 header + 5 block header + 256 data + 8 footer = 279 bytes
        expect compressed.len() > payload.len() == true

    # --- dynamic-Huffman (BTYPE=10) tests ---
    # Fixture produced by Python's zlib.compressobj(9, DEFLATED, -15) wrapped in
    # a hand-built gzip frame (RFC 1952).  Verified: btype==2, gzip.decompress()==original.
    # Source: python3 -c "import zlib,struct; ..."
    # Plaintext: b'This is a test of the emergency broadcast system. ' * 82  (first 4096 bytes)

    it("dynamic-Huffman: decompresses known gzip fixture (btype=2) to correct length"):
        val fixture = _make_dyn_fixture()
        val decoded = gzip_decompress(fixture)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == 4096

    it("dynamic-Huffman: fixture decodes to exact expected plaintext (full byte comparison)"):
        val fixture = _make_dyn_fixture()
        val expected = _make_dyn_plaintext()
        val decoded = gzip_decompress(fixture)
        expect decoded == nil == false
        val out = decoded ?? []
        expect out.len() == expected.len()
        var i = 0
        var all_match = true
        while i < expected.len():
            if out[i] != expected[i]:
                all_match = false
            i = i + 1
        expect all_match == true