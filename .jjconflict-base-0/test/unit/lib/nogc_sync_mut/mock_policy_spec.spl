# @cover src/compiler_rust/lib/std/src/spec/mock.spl 80%
"""
# Mock Policy System Test Mock Ban Specification

**Feature IDs:** #MOCK-BAN
**Category:** Testing
**Difficulty:** 2/5
**Status:** Implemented
**Research:** doc/01_research/local/mocking_system_design_2026-01-21.md

## Overview

Language-level mock ban prevents mock/spy/stub usage in system tests.
Two enforcement layers:
1. **Rust FFI** (`__mock_policy_*`): Atomic policy checked by compiled-mode runtime
2. **Simple-side** (`mock_policy_*`): Module-var policy checked by Mock/Spy/Stub constructors

Both layers are synchronized by the executor before each test.

## Behavior

- Default mode is All (mocks allowed everywhere)
- Disabled mode blocks ALL mock creation (panics)
- HalOnly allows only `.hal.`/`.sub_hal.` caller modules (enforced by Rust FFI)
- Constructor ban uses `mock_policy_check_disabled()` — unspoofable (no name arg)
"""

use std.io_runtime

# ============================================================================
# Production FFI — exercises the REAL Rust-side enforcement
# ============================================================================
extern fn __mock_policy_init_all() -> ()
extern fn __mock_policy_init_hal_only() -> ()
extern fn __mock_policy_disable() -> ()
extern fn __mock_policy_try_check(module_path: text) -> text
extern fn __mock_policy_get_mode() -> text

# ============================================================================
# Local Simple-side policy mirror (same algorithm as spec/mock.spl)
# Tests the pattern-matching logic that lives in Simple code
# ============================================================================
enum MockMode:
    All
    HalOnly
    Disabled
    Custom

var _mock_policy_mode: MockMode = MockMode.All
var _mock_policy_patterns: [text] = []

fn spl_mock_policy_disable():
    _mock_policy_mode = MockMode.Disabled

fn spl_mock_policy_reset():
    _mock_policy_mode = MockMode.All
    _mock_policy_patterns = []

fn spl_mock_policy_is_enabled() -> bool:
    return _mock_policy_mode != MockMode.Disabled

fn spl_mock_policy_init_hal_only():
    _mock_policy_mode = MockMode.HalOnly
    _mock_policy_patterns = ["*.hal.*", "*.sub_hal.*"]

fn spl_mock_policy_init_with_patterns(patterns: [text]):
    _mock_policy_mode = MockMode.Custom
    _mock_policy_patterns = patterns

fn spl_mock_policy_check_disabled() -> text:
    """Returns empty if allowed, error message if Disabled."""
    if _mock_policy_mode == MockMode.Disabled:
        return "Mock/Spy/Stub creation blocked: mocks are disabled (system test policy)"
    return ""

fn spl_mock_policy_check_allowed(source_module: text) -> text:
    """Full check including patterns — requires caller's module path."""
    match _mock_policy_mode:
        case MockMode.All:
            return ""
        case MockMode.Disabled:
            return "Mock used while mocks are disabled (system test policy). Source: {source_module}"
        case MockMode.HalOnly:
            if spl_mock_policy_matches_hal(source_module):
                return ""
            return "Mock from '{source_module}' not allowed. Only HAL mocks permitted."
        case MockMode.Custom:
            if spl_mock_policy_matches_any(source_module):
                return ""
            return "Mock from '{source_module}' not allowed by current mock policy."

fn spl_mock_policy_matches_hal(module: text) -> bool:
    return module.contains(".hal.") or module.contains(".sub_hal.")

fn spl_mock_policy_matches_any(module: text) -> bool:
    for pattern in _mock_policy_patterns:
        if spl_pattern_matches(module, pattern):
            return true
    return false

fn spl_pattern_matches(module: text, pattern: text) -> bool:
    if pattern == "*":
        return true
    if not pattern.contains("*"):
        return module.contains(pattern)
    val parts = pattern.split("*")
    var idx = 0
    for part in parts:
        if part.is_empty():
            continue
        val found = module.index_of(part, idx)
        if found < 0:
            return false
        idx = found + part.len()
    return true

# ============================================================================
# Test Infrastructure
# ============================================================================
var test_passed = 0
var test_failed = 0
var test_errors: [text] = []

fn describe(name: text, block: fn()):
    print "{name}"
    block()

fn context(name: text, block: fn()):
    print "  context: {name}"
    block()

fn it(name: text, block: fn()):
    var error_before = test_errors.len()
    block()
    if test_errors.len() == error_before:
        test_passed = test_passed + 1
        print "    it {name} ... ok"
    else:
        test_failed = test_failed + 1
        val last_err = test_errors[test_errors.len() - 1]
        print "    it {name} ... FAILED"
        print "      Error: {last_err}"

fn expect(actual: Any) -> Expectation:
    return Expectation(actual: actual)

class Expectation:
    actual: Any

    fn to_equal(expected: Any):
        if self.actual != expected:
            test_errors.push("expected {expected}, got {self.actual}")

    fn to_be(expected: Any):
        self.to_equal(expected)

    fn to_contain(substring: text):
        val s = self.actual as text
        if not s.contains(substring):
            test_errors.push("expected '{s}' to contain '{substring}'")


# ============================================================================
# GROUP 1: Production FFI — Rust-side enforcement (REAL code paths)
# ============================================================================

describe "Production FFI Mock Policy":
    """
    Exercises the REAL Rust-side mock_policy through FFI extern calls.
    These are the same functions called by executor.spl in compiled mode.
    """

    context "when disabled via FFI":
        it "try_check returns disabled for any module":
            __mock_policy_disable()
            val result = __mock_policy_try_check("app.service.user")
            expect(result).to_equal("disabled")
            __mock_policy_init_all()

        it "try_check returns disabled even for HAL modules":
            __mock_policy_disable()
            val result = __mock_policy_try_check("driver.hal.spi")
            expect(result).to_equal("disabled")
            __mock_policy_init_all()

        it "get_mode reports disabled":
            __mock_policy_disable()
            val mode = __mock_policy_get_mode()
            expect(mode).to_equal("disabled")
            __mock_policy_init_all()

    context "when all allowed via FFI":
        it "try_check returns allowed for any module":
            __mock_policy_init_all()
            val result = __mock_policy_try_check("app.service.user")
            expect(result).to_equal("allowed")

        it "get_mode reports all":
            __mock_policy_init_all()
            val mode = __mock_policy_get_mode()
            expect(mode).to_equal("all")

    context "when hal_only via FFI":
        it "try_check returns allowed for HAL modules":
            __mock_policy_init_hal_only()
            val result = __mock_policy_try_check("driver.hal.spi")
            expect(result).to_equal("allowed")
            __mock_policy_init_all()

        it "try_check returns not_allowed for non-HAL modules":
            __mock_policy_init_hal_only()
            val result = __mock_policy_try_check("app.service.user")
            expect(result).to_equal("not_allowed")
            __mock_policy_init_all()

        it "HAL spoofing blocked — mock name is not the module path":
            # In production, __mock_policy_try_check receives the CALLER's
            # module_path!(), not the user-provided mock name.
            # The Rust FFI layer is unspoofable because module_path!()
            # is a compile-time macro.
            __mock_policy_init_hal_only()
            # A real non-HAL caller can't fake its module path
            val result = __mock_policy_try_check("app.service.pretending_to_be.hal.spi")
            # This returns "allowed" because the FFI check uses glob matching,
            # but in production the path comes from module_path!(), not user input.
            # The point: constructor ban (check_disabled) is the Simple-side gate;
            # pattern matching is the Rust-side gate with real module paths.
            expect(result).to_equal("allowed")
            __mock_policy_init_all()

    context "FFI disable-then-reinit cycle":
        it "reinit to all after disable restores access":
            __mock_policy_disable()
            expect(__mock_policy_try_check("any")).to_equal("disabled")
            __mock_policy_init_all()
            expect(__mock_policy_try_check("any")).to_equal("allowed")

        it "reinit to hal_only after disable restricts correctly":
            __mock_policy_disable()
            __mock_policy_init_hal_only()
            expect(__mock_policy_try_check("x.hal.y")).to_equal("allowed")
            expect(__mock_policy_try_check("app.svc")).to_equal("not_allowed")
            __mock_policy_init_all()


# ============================================================================
# GROUP 2: Simple-side constructor ban (mock_policy_check_disabled)
# ============================================================================

describe "Constructor Ban (check_disabled)":
    """
    Tests mock_policy_check_disabled() — the unspoofable gate in
    Mock.new()/Spy.new()/Stub.new(). Takes no name argument,
    so can't be bypassed by naming a mock "my.hal.fake".
    """

    context "when Disabled":
        it "returns error message":
            spl_mock_policy_disable()
            val result = spl_mock_policy_check_disabled()
            expect(result).to_contain("mocks are disabled")
            expect(result).to_contain("system test policy")
            spl_mock_policy_reset()

        it "blocks regardless of prior state":
            spl_mock_policy_reset()
            expect(spl_mock_policy_check_disabled()).to_equal("")
            spl_mock_policy_disable()
            expect(spl_mock_policy_check_disabled()).to_contain("blocked")
            spl_mock_policy_reset()

    context "when not Disabled":
        it "returns empty in All mode":
            spl_mock_policy_reset()
            expect(spl_mock_policy_check_disabled()).to_equal("")

        it "returns empty in HalOnly mode":
            spl_mock_policy_init_hal_only()
            expect(spl_mock_policy_check_disabled()).to_equal("")
            spl_mock_policy_reset()

        it "returns empty in Custom mode":
            spl_mock_policy_init_with_patterns(["*.cache.*"])
            expect(spl_mock_policy_check_disabled()).to_equal("")
            spl_mock_policy_reset()


# ============================================================================
# GROUP 3: Simple-side lifecycle
# ============================================================================

describe "Simple-Side Policy Lifecycle":

    context "when default":
        it "is enabled":
            spl_mock_policy_reset()
            expect(spl_mock_policy_is_enabled()).to_equal(true)

    context "when disabled":
        it "is not enabled":
            spl_mock_policy_disable()
            expect(spl_mock_policy_is_enabled()).to_equal(false)
            spl_mock_policy_reset()

    context "after reset":
        it "re-enables":
            spl_mock_policy_disable()
            spl_mock_policy_reset()
            expect(spl_mock_policy_is_enabled()).to_equal(true)


# ============================================================================
# GROUP 4: Full check_allowed (requires caller module path)
# ============================================================================

describe "Full check_allowed (Module Path)":
    """
    Tests the full pattern-matching check. In production, source_module
    is the caller's module path (from module_path!()), not user input.
    """

    context "Disabled mode":
        it "blocks any module":
            spl_mock_policy_disable()
            expect(spl_mock_policy_check_allowed("any.path")).to_contain("disabled")
            spl_mock_policy_reset()

    context "HalOnly mode":
        it "allows .hal. modules":
            spl_mock_policy_init_hal_only()
            expect(spl_mock_policy_check_allowed("driver.hal.spi")).to_equal("")
            spl_mock_policy_reset()

        it "allows .sub_hal. modules":
            spl_mock_policy_init_hal_only()
            expect(spl_mock_policy_check_allowed("hw.sub_hal.gpio")).to_equal("")
            spl_mock_policy_reset()

        it "blocks non-HAL modules":
            spl_mock_policy_init_hal_only()
            expect(spl_mock_policy_check_allowed("app.service")).to_contain("not allowed")
            spl_mock_policy_reset()

    context "Custom mode":
        it "allows matching pattern":
            spl_mock_policy_init_with_patterns(["*.cache.*"])
            expect(spl_mock_policy_check_allowed("app.cache.redis")).to_equal("")
            spl_mock_policy_reset()

        it "blocks non-matching":
            spl_mock_policy_init_with_patterns(["*.cache.*"])
            expect(spl_mock_policy_check_allowed("app.service")).to_contain("not allowed")
            spl_mock_policy_reset()


# ============================================================================
# GROUP 5: Pattern Matching Engine
# ============================================================================

describe "Pattern Matching":

    it "universal wildcard":
        expect(spl_pattern_matches("any.module", "*")).to_equal(true)

    it "exact substring":
        expect(spl_pattern_matches("app.hal.spi", "hal")).to_equal(true)

    it "missing substring":
        expect(spl_pattern_matches("app.service", "hal")).to_equal(false)

    it "multi-segment wildcard":
        expect(spl_pattern_matches("a.hal.b.c", "*.hal.*")).to_equal(true)

    it "partial wildcard mismatch":
        expect(spl_pattern_matches("a.service.b", "*.hal.*")).to_equal(false)

    it "leading wildcard":
        expect(spl_pattern_matches("hal.spi", "*hal*")).to_equal(true)


# ============================================================================
# GROUP 6: Dual-layer sync verification
# ============================================================================

describe "Dual-Layer Sync":
    """
    Verifies that FFI and Simple-side states can be set together,
    as the executor does in production.
    """

    it "both layers disabled simultaneously":
        # Simulate what executor.init_mock_policy_for_mode(Disabled) does
        spl_mock_policy_disable()
        __mock_policy_disable()
        # Both layers should block
        expect(spl_mock_policy_check_disabled()).to_contain("blocked")
        expect(__mock_policy_try_check("any")).to_equal("disabled")
        # Reset both
        spl_mock_policy_reset()
        __mock_policy_init_all()

    it "both layers re-enabled simultaneously":
        spl_mock_policy_disable()
        __mock_policy_disable()
        # Reset both (as executor does for MockMode.All)
        spl_mock_policy_reset()
        __mock_policy_init_all()
        expect(spl_mock_policy_check_disabled()).to_equal("")
        expect(__mock_policy_try_check("any")).to_equal("allowed")

    it "both layers set to hal_only":
        spl_mock_policy_init_hal_only()
        __mock_policy_init_hal_only()
        # Simple-side: check_disabled passes (not Disabled mode)
        expect(spl_mock_policy_check_disabled()).to_equal("")
        # Rust-side: HAL allowed, non-HAL blocked
        expect(__mock_policy_try_check("x.hal.y")).to_equal("allowed")
        expect(__mock_policy_try_check("app.svc")).to_equal("not_allowed")
        spl_mock_policy_reset()
        __mock_policy_init_all()


# ============================================================================
# Summary
# ============================================================================

print ""
print "Results: {test_passed} passed, {test_failed} failed"
if test_failed > 0:
    print "Failures:"
    for err in test_errors:
        print "  - {err}"
