# Tests for Phase 1 SIMD int arithmetic intrinsics dispatch (add/sub/mul).
# Feature: doc/08_tracking/feature_request/simd_int_intrinsics_for_crypto_2026-05-01.md
# Backfill: T1 (ChaCha20 SIMD) surfaced rt_simd_add/sub/mul_i32x{4,8} as
# declared-but-unwired in the interpreter dispatch table.

use std.simd.{Vec4i, Vec8i}
use std.simd.{simd_add_i32x4, simd_sub_i32x4, simd_mul_i32x4}
use std.simd.{simd_add_i32x8, simd_sub_i32x8, simd_mul_i32x8}

describe "std.simd int arithmetic dispatch (i32x4)":
    describe "simd_add_i32x4":
        it "lane-wise add of two vectors":
            val a = Vec4i(x: 1, y: 2, z: 3, w: 4)
            val b = Vec4i(x: 10, y: 20, z: 30, w: 40)
            val r = simd_add_i32x4(a, b)
            expect r.x == 11
            expect r.y == 22
            expect r.z == 33
            expect r.w == 44

        it "add with zero is identity":
            val v = Vec4i(x: 7, y: -3, z: 0, w: 12345)
            val z = Vec4i.zero()
            val r = simd_add_i32x4(v, z)
            expect r.x == 7
            expect r.y == -3
            expect r.z == 0
            expect r.w == 12345

    describe "simd_sub_i32x4":
        it "lane-wise sub of two vectors":
            val a = Vec4i(x: 10, y: 20, z: 30, w: 40)
            val b = Vec4i(x: 1, y: 2, z: 3, w: 4)
            val r = simd_sub_i32x4(a, b)
            expect r.x == 9
            expect r.y == 18
            expect r.z == 27
            expect r.w == 36

        it "self-sub is zero":
            val v = Vec4i(x: 7, y: -3, z: 99, w: 12345)
            val r = simd_sub_i32x4(v, v)
            expect r.x == 0
            expect r.y == 0
            expect r.z == 0
            expect r.w == 0

    describe "simd_mul_i32x4":
        it "lane-wise mul of two vectors":
            val a = Vec4i(x: 1, y: 2, z: 3, w: 4)
            val b = Vec4i(x: 2, y: 3, z: 4, w: 5)
            val r = simd_mul_i32x4(a, b)
            expect r.x == 2
            expect r.y == 6
            expect r.z == 12
            expect r.w == 20

        it "mul by one is identity":
            val v = Vec4i(x: 7, y: -3, z: 99, w: 12345)
            val ones = Vec4i.splat(1)
            val r = simd_mul_i32x4(v, ones)
            expect r.x == 7
            expect r.y == -3
            expect r.z == 99
            expect r.w == 12345

        it "mul by zero is zero":
            val v = Vec4i(x: 7, y: -3, z: 99, w: 12345)
            val z = Vec4i.zero()
            val r = simd_mul_i32x4(v, z)
            expect r.x == 0
            expect r.y == 0
            expect r.z == 0
            expect r.w == 0

describe "std.simd int arithmetic dispatch (i32x8)":
    describe "simd_add_i32x8":
        it "lane-wise add of two 8-lane vectors":
            val a = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val b = Vec8i(e0: 10, e1: 20, e2: 30, e3: 40, e4: 50, e5: 60, e6: 70, e7: 80)
            val r = simd_add_i32x8(a, b)
            expect r.e0 == 11
            expect r.e1 == 22
            expect r.e2 == 33
            expect r.e3 == 44
            expect r.e4 == 55
            expect r.e5 == 66
            expect r.e6 == 77
            expect r.e7 == 88

    describe "simd_sub_i32x8":
        it "self-sub is zero across all 8 lanes":
            val v = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val r = simd_sub_i32x8(v, v)
            expect r.e0 == 0
            expect r.e1 == 0
            expect r.e2 == 0
            expect r.e3 == 0
            expect r.e4 == 0
            expect r.e5 == 0
            expect r.e6 == 0
            expect r.e7 == 0

    describe "simd_mul_i32x8":
        it "lane-wise mul of two 8-lane vectors":
            val a = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val b = Vec8i(e0: 2, e1: 3, e2: 4, e3: 5, e4: 6, e5: 7, e6: 8, e7: 9)
            val r = simd_mul_i32x8(a, b)
            expect r.e0 == 2
            expect r.e1 == 6
            expect r.e2 == 12
            expect r.e3 == 20
            expect r.e4 == 30
            expect r.e5 == 42
            expect r.e6 == 56
            expect r.e7 == 72
