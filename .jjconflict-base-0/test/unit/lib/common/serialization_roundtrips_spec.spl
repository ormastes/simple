describe "write_varint extended":
    """
    ## Extended Varint Encoding Coverage

    Tests multi-byte encoding boundaries and edge cases.
    """

    it "encodes 128 as two bytes":
        val result = write_varint(128)
        expect(result.len()).to_equal(2)

    it "encodes 16384 as three bytes":
        val result = write_varint(16384)
        expect(result.len()).to_equal(3)

    it "encodes negative value with sign marker":
        val result = write_varint(-42)
        expect(result[0]).to_equal(255)
        expect(result.len()).to_be_greater_than(1)

    it "roundtrips large positive":
        val encoded = write_varint(100000)
        val decoded = read_varint(encoded, 0)
        expect(decoded.0).to_equal(100000)

    it "roundtrips large negative":
        val encoded = write_varint(-100000)
        val decoded = read_varint(encoded, 0)
        expect(decoded.0).to_equal(-100000)

describe "read_varint extended":
    """
    ## Extended Varint Decoding Coverage

    Tests consumed byte count and offset handling.
    """

    it "reports consumed bytes for multi-byte varint":
        val encoded = write_varint(1000)
        val decoded = read_varint(encoded, 0)
        expect(decoded.1).to_equal(encoded.len())

    it "reads varint at non-zero offset":
        var bytes = [99]
        val encoded = write_varint(42)
        var i = 0
        while i < encoded.len():
            bytes = bytes.push(encoded[i])
            i = i + 1
        val decoded = read_varint(bytes, 1)
        expect(decoded.0).to_equal(42)

    it "reports consumed bytes for negative varint":
        val encoded = write_varint(-50)
        val decoded = read_varint(encoded, 0)
        expect(decoded.1).to_equal(encoded.len())

describe "serialize_text_bytes extended":
    """
    ## Extended Text Binary Serialization Coverage

    Exercise character-by-character encoding path.
    """

    it "encodes empty text":
        val result = serialize_text_bytes("")
        expect(result[0]).to_equal(type_text())
        expect(result.len()).to_equal(2)

    it "encodes single character":
        val result = serialize_text_bytes("A")
        expect(result[0]).to_equal(type_text())
        val last = result[result.len() - 1]
        expect(last).to_equal(65)

    it "encodes multi-character text":
        val result = serialize_text_bytes("AB")
        expect(result[0]).to_equal(type_text())
        val second_last = result[result.len() - 2]
        val last = result[result.len() - 1]
        expect(second_last).to_equal(65)
        expect(last).to_equal(66)

describe "escape_string extended":
    """
    ## Extended String Escaping Coverage

    Exercise individual escape branches.
    """

    it "escapes double quote alone":
        val result = escape_string("\"")
        expect(result).to_equal("\\\"")

    it "escapes backslash alone":
        val result = escape_string("\\")
        expect(result).to_equal("\\\\")

    it "escapes tab alone":
        val result = escape_string("\t")
        expect(result).to_equal("\\t")

    it "escapes carriage return alone":
        val result = escape_string("\r")
        expect(result).to_equal("\\r")

    it "does not escape normal chars":
        val result = escape_string("abc")
        expect(result).to_equal("abc")

describe "unescape_string extended":
    """
    ## Extended String Unescaping Coverage

    Exercise individual unescape branches and edge cases.
    """

    it "unescapes backslash-quote alone":
        val result = unescape_string("\\\"")
        expect(result).to_equal("\"")

    it "unescapes backslash-backslash alone":
        val result = unescape_string("\\\\")
        expect(result).to_equal("\\")

    it "handles unknown escape code":
        val result = unescape_string("\\x")
        expect(result).to_equal("\\x")

    it "handles trailing backslash":
        val result = unescape_string("abc\\")
        expect(result).to_equal("abc\\")

    it "handles multiple escapes in sequence":
        val result = unescape_string("\\n\\t\\r")
        expect(result).to_equal("\n\t\r")

describe "unquote_string extended":
    """
    ## Extended Unquote Coverage
    """

    it "returns single char unchanged":
        val result = unquote_string("x")
        expect(result).to_equal("x")

    it "returns non-quoted two-char string unchanged":
        val result = unquote_string("ab")
        expect(result).to_equal("ab")

    it "unquotes minimal quoted string":
        val result = unquote_string("\"\"")
        expect(result).to_equal("")

