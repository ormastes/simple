# @covers src/lib/common/math_repr.spl 85%
"""
# Math Repr Text and Debug Rendering

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Status:** Implemented

## Overview

Tests for to_text and to_debug renderers across all AST node types.
"""

use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# 1. math_repr — to_text (Normalized plain text renderer)
# ============================================================================

describe "math_repr to_text":
    """
    ## Plain Text Rendering

    Tests the text renderer across all AST node types.
    """

    context "number literals":
        it "renders integer":
            expect to_text("42") == "42"

        it "renders decimal":
            expect to_text("3.14") == "3.14"

    context "identifiers":
        it "renders plain identifier":
            expect to_text("x") == "x"

        it "renders multi-char identifier":
            expect to_text("foo") == "foo"

    context "addition and subtraction":
        it "renders addition":
            expect to_text("x + 1") == "x + 1"

        it "renders subtraction":
            expect to_text("x - 1") == "x - 1"

        it "renders chained addition":
            expect to_text("a + b + c") == "a + b + c"

    context "multiplication and division":
        it "renders explicit multiplication":
            expect to_text("x * y") == "x * y"

        it "renders division":
            expect to_text("x / y") == "x / y"

        it "renders implicit multiplication":
            expect to_text("2x") == "2x"

    context "power":
        it "renders power expression":
            expect to_text("x^2") == "x^2"

        it "renders nested power":
            expect to_text("x^y") == "x^y"

    context "negation":
        it "renders negation":
            expect to_text("-x") == "-x"

        it "renders negation of number":
            expect to_text("-3") == "-3"

    context "grouping":
        it "renders parenthesized expression":
            expect to_text("(x + 1)") == "(x + 1)"

    context "subscript":
        it "renders subscript notation":
            expect to_text("x[i]") == "x[i]"

    context "transpose":
        it "renders transpose":
            expect to_text("A'") == "A'"

    context "function calls":
        it "renders single arg function":
            expect to_text("sin(x)") == "sin(x)"

        it "renders multi arg function":
            expect to_text("max(a, b)") == "max(a, b)"

    context "frac expression":
        it "renders fraction as division":
            expect to_text("frac(a, b)") == "a / b"

    context "sum expression":
        it "renders sum notation":
            expect to_text("sum(i, 1..n) i") == "sum(i, 1..n) i"

    context "int expression":
        it "renders integral notation":
            expect to_text("int(x, 0..1) x") == "int(x, 0..1) x"

    context "complex expressions":
        it "renders compound expression":
            expect to_text("x^2 + 2*x + 1") == "x^2 + 2 * x + 1"


# ============================================================================
# 2. math_repr — to_debug (AST structure renderer)
# ============================================================================

describe "math_repr to_debug":
    """
    ## Debug AST Rendering

    Tests the debug renderer for each node type producing AST notation.
    """

    context "leaf nodes":
        it "renders number node":
            expect to_debug("42") == "Num(42)"

        it "renders identifier node":
            expect to_debug("x") == "Id(x)"

    context "binary operations":
        it "renders Add node":
            expect to_debug("a + b") == "Add(Id(a), Id(b))"

        it "renders Sub node":
            expect to_debug("a - b") == "Sub(Id(a), Id(b))"

        it "renders Mul node":
            expect to_debug("a * b") == "Mul(Id(a), Id(b))"

        it "renders Div node":
            expect to_debug("a / b") == "Div(Id(a), Id(b))"

        it "renders Pow node":
            expect to_debug("a^b") == "Pow(Id(a), Id(b))"

    context "unary operations":
        it "renders Neg node":
            expect to_debug("-x") == "Neg(Id(x))"

    context "grouping":
        it "renders Group node":
            expect to_debug("(x)") == "Group(Id(x))"

    context "subscript and transpose":
        it "renders subscript as Sub":
            expect to_debug("x[i]") == "Sub(Id(x), Id(i))"

        it "renders Transpose node":
            expect to_debug("A'") == "Transpose(Id(A))"

    context "function calls":
        it "renders Call node":
            expect to_debug("f(x)") == "Call(f, Id(x))"

        it "renders Call with multiple args":
            expect to_debug("f(x, y)") == "Call(f, Id(x), Id(y))"

    context "frac expression":
        it "renders Frac node":
            expect to_debug("frac(a, b)") == "Frac(Id(a), Id(b))"

    context "sum and integral expressions":
        it "renders Sum node":
            expect to_debug("sum(i, 1..n) i") == "Sum(i, Num(1), Id(n), Id(i))"

        it "renders Int node":
            expect to_debug("int(x, 0..1) x") == "Int(x, Num(0), Num(1), Id(x))"

    context "implicit multiplication":
        it "renders implicit mul as Mul":
            expect to_debug("2x") == "Mul(Num(2), Id(x))"