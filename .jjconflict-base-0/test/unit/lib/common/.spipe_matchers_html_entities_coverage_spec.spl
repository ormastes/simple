# Test Group 5: text_from_digit
# =============================================================================

describe "text_from_digit":
    """
    ## Digit to Text Conversion

    Tests conversion of digit values 0-9 to their text representations.
    """

    context "all digits":
        it "converts 0":
            expect text_from_digit(0) == "0"

        it "converts 1":
            expect text_from_digit(1) == "1"

        it "converts 2":
            expect text_from_digit(2) == "2"

        it "converts 3":
            expect text_from_digit(3) == "3"

        it "converts 4":
            expect text_from_digit(4) == "4"

        it "converts 5":
            expect text_from_digit(5) == "5"

        it "converts 6":
            expect text_from_digit(6) == "6"

        it "converts 7":
            expect text_from_digit(7) == "7"

        it "converts 8":
            expect text_from_digit(8) == "8"

        it "converts 9":
            expect text_from_digit(9) == "9"

    context "out of range":
        it "returns empty for negative":
            expect text_from_digit(-1) == ""

        it "returns empty for 10":
            expect text_from_digit(10) == ""


