    context "out of range":
        it "returns empty for negative":
            expect text_from_lower(-1) == ""

        it "returns empty for 26":
            expect text_from_lower(26) == ""


# =============================================================================
# Test Group 8: is_digit helper
# =============================================================================

describe "is_digit":
    """
    ## Digit Character Detection

    Tests the is_digit helper that checks if a single character
    is a decimal digit (char code 48-57).
    """

    context "digit characters":
        it "returns true for 0":
            expect is_digit("0") == true

        it "returns true for 5":
            expect is_digit("5") == true

        it "returns true for 9":
            expect is_digit("9") == true

    context "non-digit characters":
        """
        ### Scenario: Characters outside digit range

        Tests the false branches where code < 48 or code > 57.
        """

        it "returns false for letter a":
            expect is_digit("a") == false

        it "returns false for space":
            expect is_digit(" ") == false

        it "returns false for special character":
            expect is_digit("!") == false

        it "returns false for slash (code 47, just below 0)":
            expect is_digit("/") == false

        it "returns false for colon (code 58, just above 9)":
            expect is_digit(":") == false