    """

    context "all uppercase letters":
        it "converts 0 to A":
            expect text_from_upper(0) == "A"

        it "converts 1 to B":
            expect text_from_upper(1) == "B"

        it "converts 12 to M":
            expect text_from_upper(12) == "M"

        it "converts 24 to Y":
            expect text_from_upper(24) == "Y"

        it "converts 25 to Z":
            expect text_from_upper(25) == "Z"

    context "out of range":
        it "returns empty for negative":
            expect text_from_upper(-1) == ""

        it "returns empty for 26":
            expect text_from_upper(26) == ""


