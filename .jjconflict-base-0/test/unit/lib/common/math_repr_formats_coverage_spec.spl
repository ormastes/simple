# @covers src/lib/common/math_repr.spl 85%
"""
# Math Repr Coverage Specification

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Branch coverage tests for `std.math_repr` parser and renderers.
Split from math_coverage_spec.spl for memory. Tests to_text, to_debug,
to_pretty, to_md, render_latex_raw, and tokenizer/parser edge cases.

## Key Concepts

| Concept | Description |
|---------|-------------|
| math_repr | Parser + renderer: to_text, to_debug, to_pretty, to_md, render_latex_raw |
"""

use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# 1. math_repr — to_text (Normalized plain text renderer)
# ============================================================================

describe "math_repr int_expr all renderers":
    """
    ## Integral Expression Coverage

    Exercises the int_expr branch in each renderer: text, debug, pretty, latex.
    """

    context "integral through text renderer":
        it "renders integral via to_text":
            val result = to_text("int(t, 0..1) t")
            expect(result).to_contain("int")
            expect(result).to_contain("t")

    context "integral through debug renderer":
        it "renders integral via to_debug":
            val result = to_debug("int(t, 0..1) t")
            expect(result).to_contain("Int")

    context "integral through pretty renderer":
        it "renders integral via to_pretty":
            val result = to_pretty("int(t, 0..1) t")
            expect(result).to_contain("t")

    context "integral through latex renderer":
        it "renders integral via render_latex_raw":
            val result = render_latex_raw("int(t, 0..1) t")
            expect(result).to_contain("\\int")

    context "integral through markdown renderer":
        it "renders integral via to_md":
            val result = to_md("int(t, 0..1) t")
            expect(result).to_start_with("$")
            expect(result).to_contain("t")


# ============================================================================
# 9. Negative idx paths and renderer edge cases
# ============================================================================


describe "math_repr renderer edge cases":
    """
    ## Renderer Edge Cases

    Tests for negative index paths (idx < 0) which occur when
    nodes have -1 for left/right children (e.g. leaf nodes).
    Also exercises tag fallthrough paths.
    """

    context "negative idx through render paths":
        it "neg of number exercises right=-1 path in text":
            # Neg node has right=-1, when rendering text it calls _render_text(left) only
            val result = to_text("-42")
            expect(result).to_equal("-42")

        it "neg of expr exercises render in debug":
            val result = to_debug("-42")
            expect(result).to_equal("Neg(Num(42))")

        it "neg exercises render in pretty":
            val result = to_pretty("-42")
            expect(result).to_equal("-42")

        it "neg exercises render in latex":
            val result = render_latex_raw("-42")
            expect(result).to_equal("-42")

    context "transpose exercises right=-1 in all renderers":
        it "transpose in text":
            val result = to_text("x'")
            expect(result).to_equal("x'")

        it "transpose in debug":
            val result = to_debug("x'")
            expect(result).to_contain("Transpose")

        it "transpose in pretty":
            val result = to_pretty("x'")
            expect(result).to_contain("T")

        it "transpose in latex":
            val result = render_latex_raw("A'")
            expect(result).to_contain("T")


# ============================================================================
# 10. Superscript and subscript operator characters
# ============================================================================


describe "math_repr superscript operator chars":
    """
    ## Superscript Operator Characters

    Exercises superscript_char branches for +, -, =, (, ) which are hit
    when pretty_power processes multi-character exponents containing operators.
    """

    context "superscript plus minus equals parens":
        it "exercises superscript + via power":
            val result = to_pretty("x^(n+1)")
            expect(result).to_contain("x")

        it "exercises superscript - via power":
            val result = to_pretty("x^(n-1)")
            expect(result).to_contain("x")

        it "exercises superscript = via power":
            # Use grouped exponent with equals-like expression
            val result = to_pretty("x^(a=b)")
            expect(result).to_contain("x")

    context "subscript plus minus":
        it "exercises subscript + via subscript":
            val result = to_pretty("x[i+1]")
            expect(result).to_contain("x")

        it "exercises subscript - via subscript":
            val result = to_pretty("x[i-1]")
            expect(result).to_contain("x")


# ============================================================================
# 11. Tokenizer branch coverage gaps
# ============================================================================


describe "math_repr tokenizer branch gaps":
    """
    ## Tokenizer Branch Coverage

    Exercises tokenizer branches that were missed: standalone dot followed
    by non-dot char, decimal number before range operator, and specific
    operator paths.
    """

    context "dot followed by non-dot character":
        it "handles dot followed by identifier":
            val result = to_text("x.y")
            expect(result).to_contain("x")

    context "decimal number before range":
        it "handles number with decimal part":
            val result = to_text("3.14")
            expect(result).to_equal("3.14")

    context "division operator tokenization":
        it "tokenizes division in complex expression":
            val result = to_text("a / b + c")
            expect(result).to_contain("/")

        it "tokenizes multiple divisions":
            val result = to_text("a / b / c")
            expect(result).to_contain("/")

    context "parentheses tokenization":
        it "tokenizes nested parens":
            val result = to_text("((a + b))")
            expect(result).to_contain("(")
            expect(result).to_contain(")")

    context "bracket tokenization standalone":
        it "tokenizes brackets in subscript":
            val result = to_text("a[b]")
            expect(result).to_contain("[")
            expect(result).to_contain("]")

    context "comma tokenization":
        it "tokenizes commas in multi-arg function":
            val result = to_text("f(a, b, c)")
            expect(result).to_contain(",")

    context "unknown character skipping":
        it "skips at sign":
            val result = to_text("a @ b")
            expect(result).to_contain("a")

        it "skips hash character":
            val result = to_text("a # b")
            expect(result).to_contain("a")

    context "underscore in identifiers":
        it "tokenizes identifier starting with underscore":
            val result = to_text("_x")
            expect(result).to_contain("x")

        it "tokenizes identifier with embedded underscore":
            val result = to_text("a_b")
            expect(result).to_contain("a")

    context "is_alnum exercising is_digit false then is_alpha":
        it "exercises alnum branch for letter after number in ident":
            val result = to_text("x1y")
            expect(result).to_contain("x1y")


# ============================================================================
# 12. Parser edge cases for deeper coverage
# ============================================================================


describe "math_repr parser edge cases deeper":
    """
    ## Parser Edge Cases - Deeper

    Exercises additional parser branches for frac, sum with edge cases,
    implicit mul distinctions, and can_start_expr false paths.
    """

    context "frac without comma":
        it "handles frac with space separation":
            val result = to_text("frac(a b)")
            expect(result).to_contain("a")

    context "sum without range":
        it "handles sum expression completely":
            val result = to_debug("sum(k, 1..n) k^2")
            expect(result).to_contain("Sum")
            expect(result).to_contain("Pow")

    context "can_start_expr false for non-expression tokens":
        it "handles expression ending at eof":
            val result = to_debug("x +")
            expect(result).to_contain("Id(x)")

    context "implicit mul variations":
        it "identifier followed by paren group":
            val result = to_debug("a(b + c)")
            expect(result).to_contain("Call")

        it "paren group followed by identifier":
            val result = to_debug("(a)b")
            expect(result).to_contain("Mul")
            expect(result).to_contain("Group")

    context "multi-arg function calls through all renderers":
        it "renders multi-arg call through pretty":
            val result = to_pretty("f(a, b, c)")
            expect(result).to_contain("f")
            expect(result).to_contain("a")

        it "renders multi-arg call through latex":
            val result = render_latex_raw("f(a, b, c)")
            expect(result).to_contain("f")

    context "sqrt through latex":
        it "renders sqrt in latex":
            val result = render_latex_raw("sqrt(x)")
            expect(result).to_contain("\\sqrt")

    context "frac through all renderers":
        it "frac through debug":
            val result = to_debug("frac(x, y)")
            expect(result).to_contain("Frac")

        it "frac through pretty":
            val result = to_pretty("frac(x, y)")
            expect(result).to_contain("x")
            expect(result).to_contain("y")

        it "frac through latex":
            val result = render_latex_raw("frac(x, y)")
            expect(result).to_contain("\\frac")

    context "subscript through all renderers":
        it "subscript through text":
            val result = to_text("a[0]")
            expect(result).to_equal("a[0]")

        it "subscript through debug":
            val result = to_debug("a[0]")
            expect(result).to_contain("Sub")

        it "subscript through latex":
            val result = render_latex_raw("a[0]")
            expect(result).to_contain("_")

    context "group through all renderers":
        it "group through debug":
            val result = to_debug("(a)")
            expect(result).to_contain("Group")

        it "group through pretty":
            val result = to_pretty("(a)")
            expect(result).to_start_with("(")
            expect(result).to_end_with(")")

        it "group through latex":
            val result = render_latex_raw("(a)")
            expect(result).to_start_with("(")

    context "division through all renderers":
        it "div through pretty":
            val result = to_pretty("a / b")
            expect(result).to_contain("/")

        it "div through latex":
            val result = render_latex_raw("a / b")
            expect(result).to_contain("/")

    context "explicit mul through latex":
        it "explicit mul renders cdot in latex":
            val result = render_latex_raw("a * b")
            expect(result).to_contain("\\cdot")

    context "implicit mul through latex":
        it "implicit mul renders space in latex":
            val result = render_latex_raw("2x")
            expect(result).to_contain("2")
            expect(result).to_contain("x")


# ============================================================================
# 13. All node types through all renderers for full branch coverage
# ============================================================================


describe "math_repr full renderer node coverage":
    """
    ## Full Renderer Node Coverage

    Each renderer (text, debug, pretty, latex) has if/elif chains for every
    node type. We must hit every node type through every renderer.
    """

    context "add through all renderers":
        it "add via pretty":
            val result = to_pretty("a + b")
            expect(result).to_equal("a + b")

        it "add via latex":
            val result = render_latex_raw("a + b")
            expect(result).to_equal("a + b")

    context "sub through all renderers":
        it "sub via text":
            val result = to_text("a - b")
            expect(result).to_equal("a - b")

        it "sub via debug":
            val result = to_debug("a - b")
            expect(result).to_equal("Sub(Id(a), Id(b))")

        it "sub via pretty":
            val result = to_pretty("a - b")
            expect(result).to_equal("a - b")

        it "sub via latex":
            val result = render_latex_raw("a - b")
            expect(result).to_equal("a - b")

    context "mul explicit through all renderers":
        it "mul via text":
            val result = to_text("a * b")
            expect(result).to_equal("a * b")

        it "mul via debug":
            val result = to_debug("a * b")
            expect(result).to_equal("Mul(Id(a), Id(b))")

        it "mul via pretty":
            val result = to_pretty("a * b")
            expect(result).to_contain("*")

    context "mul implicit through all renderers":
        it "implicit mul via text":
            val result = to_text("2x")
            expect(result).to_equal("2x")

        it "implicit mul via pretty":
            val result = to_pretty("2x")
            expect(result).to_contain("2")

        it "implicit mul via latex":
            val result = render_latex_raw("2x")
            expect(result).to_contain("x")

    context "div through all renderers":
        it "div via text":
            val result = to_text("a / b")
            expect(result).to_equal("a / b")

        it "div via debug":
            val result = to_debug("a / b")
            expect(result).to_equal("Div(Id(a), Id(b))")

    context "pow through all renderers":
        it "pow via text":
            val result = to_text("a^b")
            expect(result).to_equal("a^b")

        it "pow via debug":
            val result = to_debug("a^b")
            expect(result).to_equal("Pow(Id(a), Id(b))")

        it "pow via pretty":
            val result = to_pretty("a^b")
            expect(result).to_contain("a")

        it "pow via latex":
            val result = render_latex_raw("a^b")
            expect(result).to_contain("a")

    context "neg through all renderers":
        it "neg via text":
            val result = to_text("-a")
            expect(result).to_equal("-a")

        it "neg via debug":
            val result = to_debug("-a")
            expect(result).to_equal("Neg(Id(a))")

        it "neg via pretty":
            val result = to_pretty("-a")
            expect(result).to_equal("-a")

        it "neg via latex":
            val result = render_latex_raw("-a")
            expect(result).to_equal("-a")

    context "frac through all renderers":
        it "frac via text":
            val result = to_text("frac(a, b)")
            expect(result).to_equal("a / b")

        it "frac via debug":
            val result = to_debug("frac(a, b)")
            expect(result).to_equal("Frac(Id(a), Id(b))")

    context "group through all renderers":
        it "group via text":
            val result = to_text("(a)")
            expect(result).to_equal("(a)")

        it "group via latex":
            val result = render_latex_raw("(a)")
            expect(result).to_contain("(")

    context "subscript through all renderers":
        it "subscript via text":
            val result = to_text("a[i]")
            expect(result).to_equal("a[i]")

        it "subscript via pretty":
            val result = to_pretty("a[i]")
            expect(result).to_contain("a")

        it "subscript via latex":
            val result = render_latex_raw("a[i]")
            expect(result).to_contain("a")

    context "transpose through all renderers":
        it "transpose via text":
            val result = to_text("A'")
            expect(result).to_equal("A'")

        it "transpose via debug":
            val result = to_debug("A'")
            expect(result).to_contain("Transpose")

    context "call through all renderers":
        it "call via text":
            val result = to_text("f(x)")
            expect(result).to_equal("f(x)")

        it "call via pretty":
            val result = to_pretty("f(x)")
            expect(result).to_contain("f")

        it "call via latex known fn":
            val result = render_latex_raw("sin(x)")
            expect(result).to_contain("\\sin")

        it "call via latex unknown fn":
            val result = render_latex_raw("foo(x)")
            expect(result).to_contain("foo")

    context "sum_expr through all renderers":
        it "sum via text":
            val result = to_text("sum(i, 1..n) i")
            expect(result).to_contain("sum")

        it "sum via debug":
            val result = to_debug("sum(i, 1..n) i")
            expect(result).to_contain("Sum")

        it "sum via pretty":
            val result = to_pretty("sum(i, 1..n) i")
            expect(result).to_contain("i")

        it "sum via latex":
            val result = render_latex_raw("sum(i, 1..n) i")
            expect(result).to_contain("\\sum")

        it "sum via md":
            val result = to_md("sum(i, 1..n) i")
            expect(result).to_start_with("$")

    context "int_expr through all renderers":
        it "int via text":
            val result = to_text("int(x, 0..1) x")
            expect(result).to_contain("int")

        it "int via debug":
            val result = to_debug("int(x, 0..1) x")
            expect(result).to_contain("Int")

        it "int via pretty":
            val result = to_pretty("int(x, 0..1) x")
            expect(result).to_contain("x")

        it "int via latex":
            val result = render_latex_raw("int(x, 0..1) x")
            expect(result).to_contain("x")

    context "sqrt call special case":
        it "sqrt via pretty":
            val result = to_pretty("sqrt(x)")
            expect(result).to_contain("x")

        it "sqrt via latex":
            val result = render_latex_raw("sqrt(x)")
            expect(result).to_contain("\\sqrt")

        it "sqrt via text":
            val result = to_text("sqrt(x)")
            expect(result).to_contain("sqrt")

        it "sqrt via debug":
            val result = to_debug("sqrt(x)")
            expect(result).to_contain("Call")


# ============================================================================
# 14. _is_greek and _latex_greek false paths
# ============================================================================


describe "math_repr greek function false paths":
    """
    ## Greek Function False Paths

    Exercises the false return paths of _is_greek and _latex_greek when
    a non-greek name is passed through pretty and latex renderers.
    """

    context "non-greek through pretty":
        it "non-greek name passes through _resolve_greek unchanged":
            val result = to_pretty("myvar")
            expect(result).to_equal("myvar")

    context "non-greek through latex":
        it "non-greek name passes through _latex_greek unchanged":
            val result = render_latex_raw("myvar")
            expect(result).to_equal("myvar")


# ============================================================================
# 15. Parser edge cases for remaining uncovered branches
# ============================================================================


describe "math_repr additional parser coverage":
    """
    ## Additional Parser Coverage

    Exercises remaining uncovered parser branches: _can_start_expr false
    path, multiple postfix operations, frac/sum parsing edge cases.
    """

    context "postfix chaining":
        it "multiple subscripts chained":
            val result = to_debug("a[i][j]")
            expect(result).to_contain("Sub")

        it "transpose after group":
            val result = to_debug("(a)'")
            expect(result).to_contain("Transpose")
            expect(result).to_contain("Group")

    context "function with zero args through all renderers":
        it "zero-arg call via debug":
            val result = to_debug("f()")
            expect(result).to_contain("Call")

        it "zero-arg call via pretty":
            val result = to_pretty("f()")
            expect(result).to_contain("f")

        it "zero-arg call via latex":
            val result = render_latex_raw("f()")
            expect(result).to_contain("f")

    context "deeply nested expressions":
        it "nested power and mul":
            val result = to_text("x^2 * y^3")
            expect(result).to_contain("^")

        it "add then sub then mul":
            val result = to_debug("a + b - c * d")
            expect(result).to_contain("Sub")
            expect(result).to_contain("Mul")

    context "single dot at end of input":
        it "dot at very end":
            val result = to_text("a.")
            expect(result).to_contain("a")

    context "number at end without operator":
        it "bare number through all renderers":
            val result1 = to_pretty("42")
            expect(result1).to_equal("42")
            val result2 = render_latex_raw("42")
            expect(result2).to_equal("42")

    context "complex expressions through pretty and latex":
        it "power of sum through pretty":
            val result = to_pretty("(a + b)^2")
            expect(result).to_contain("a")

        it "power of sum through latex":
            val result = render_latex_raw("(a + b)^2")
            expect(result).to_contain("a")

        it "fraction in sum through pretty":
            val result = to_pretty("frac(x, y) + 1")
            expect(result).to_contain("x")

        it "fraction in sum through latex":
            val result = render_latex_raw("frac(x, y) + 1")
            expect(result).to_contain("x")

    context "multi-char exponent through latex":
        it "multi-char exponent uses braces":
            val result = render_latex_raw("x^(n+1)")
            expect(result).to_contain("x")

    context "multi-char subscript through latex":
        it "multi-char subscript uses braces":
            val result = render_latex_raw("a[ij]")
            expect(result).to_contain("a")


# ============================================================================
# 16. Chained operations for loop continuation coverage
# ============================================================================
