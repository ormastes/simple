describe "digit_to_hex exhaustive":
    """
    ## Call digit_to_hex With Every Possible Input 0-15
    """

    it "covers all 16 hex digits":
        expect digit_to_hex(0) == "0"
        expect digit_to_hex(1) == "1"
        expect digit_to_hex(2) == "2"
        expect digit_to_hex(3) == "3"
        expect digit_to_hex(4) == "4"
        expect digit_to_hex(5) == "5"
        expect digit_to_hex(6) == "6"
        expect digit_to_hex(7) == "7"
        expect digit_to_hex(8) == "8"
        expect digit_to_hex(9) == "9"
        expect digit_to_hex(10) == "a"
        expect digit_to_hex(11) == "b"
        expect digit_to_hex(12) == "c"
        expect digit_to_hex(13) == "d"
        expect digit_to_hex(14) == "e"
        expect digit_to_hex(15) == "f"

