# HKDF-SHA3 Reference Vectors
#
# Tests the pure-Simple HKDF-SHA3-{256,384,512} implementation in
# src/lib/common/crypto/hkdf.spl against:
#
#   1. RFC 5869 §2.2 Extract semantics — HKDF-Extract IS HMAC by definition,
#      so hkdf_extract_sha3_X(salt, ikm) === hmac_sha3_X_bytes(salt, ikm)
#      whenever salt is non-empty. This is verified directly.
#
#   2. RFC 5869 §A.1 inputs (IKM=22*0x0b, salt=000102..0c, info=f0f1..f9,
#      L=42) reused with the SHA-3 PRF. The expected outputs aren't
#      published in RFC 5869 (which only covers SHA-256/384/512), so we
#      assert determinism + Extract→Expand round-trip identity rather
#      than against a foreign-implementation vector.
#
#   3. Boundary cases: L=0 returns empty; L>max returns empty; L=1.
#
# RFC 5869 only standardizes SHA-1/2 vectors, but the construction is
# defined for any HMAC-PRF, so HMAC-SHA3 satisfies the §2.4 PRF
# requirements (HMAC inherits PRF security from the underlying compression
# function — sponge security in the SHA-3 case).
#
# Note: when more authoritative HKDF-SHA3 vectors become available
# (Wycheproof v2 / NIST SP 800-56C revision), update this spec to cite
# them. Current attested HKDF-SHA-3 fixed vectors live only in private
# CAVP test sets, not in publishable form.

use std.spipe.*
use std.crypto.hkdf.{
    hkdf_extract_sha3_256, hkdf_expand_sha3_256, hkdf_sha3_256,
    hkdf_extract_sha3_384, hkdf_expand_sha3_384, hkdf_sha3_384,
    hkdf_extract_sha3_512, hkdf_expand_sha3_512, hkdf_sha3_512
}
use std.crypto.hmac.{hmac_sha3_256_bytes, hmac_sha3_384_bytes, hmac_sha3_512_bytes}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

fn _bytes_repeat(b: i64, n: i64) -> list:
    var out = []
    var i = 0
    while i < n:
        out.push(b)
        i = i + 1
    out

# RFC 5869 §A.1 IKM: 22 × 0x0b
fn _a1_ikm() -> list:
    _bytes_repeat(0x0b, 22)

# RFC 5869 §A.1 salt: 000102030405060708090a0b0c
fn _a1_salt() -> list:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
     0x08, 0x09, 0x0a, 0x0b, 0x0c]

# RFC 5869 §A.1 info: f0f1f2f3f4f5f6f7f8f9
fn _a1_info() -> list:
    [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7,
     0xf8, 0xf9]

# ============================================================================
# HKDF-SHA3-256 — RFC 5869 §A.1 inputs reused with SHA-3 PRF
# ============================================================================

describe "HKDF-SHA3-256 — RFC 5869 §A.1-style":

    it "Extract is HMAC: hkdf_extract == hmac_sha3_256":
        # RFC 5869 §2.2: PRK = HMAC-Hash(salt, IKM)
        val expected = hmac_sha3_256_bytes(_a1_salt(), _a1_ikm())
        val actual = hkdf_extract_sha3_256(_a1_salt(), _a1_ikm())
        expect(bytes_to_hex(actual)).to_equal(bytes_to_hex(expected))

    it "Extract→Expand round-trip is deterministic":
        val a = hkdf_sha3_256(_a1_salt(), _a1_ikm(), _a1_info(), 42)
        val b = hkdf_sha3_256(_a1_salt(), _a1_ikm(), _a1_info(), 42)
        expect(bytes_to_hex(a)).to_equal(bytes_to_hex(b))

    it "Expand L=0 returns empty list":
        val prk = hkdf_extract_sha3_256(_a1_salt(), _a1_ikm())
        val okm = hkdf_expand_sha3_256(prk, _a1_info(), 0)
        expect(okm.len()).to_equal(0)

    it "Expand L>max(255*32) returns empty list":
        val prk = hkdf_extract_sha3_256(_a1_salt(), _a1_ikm())
        val okm = hkdf_expand_sha3_256(prk, _a1_info(), 8161)
        expect(okm.len()).to_equal(0)

    it "OKM has exact requested length L=42":
        val okm = hkdf_sha3_256(_a1_salt(), _a1_ikm(), _a1_info(), 42)
        expect(okm.len()).to_equal(42)

# ============================================================================
# HKDF-SHA3-384
# ============================================================================

describe "HKDF-SHA3-384 — RFC 5869 §A.1-style":

    it "Extract is HMAC: hkdf_extract == hmac_sha3_384":
        val expected = hmac_sha3_384_bytes(_a1_salt(), _a1_ikm())
        val actual = hkdf_extract_sha3_384(_a1_salt(), _a1_ikm())
        expect(bytes_to_hex(actual)).to_equal(bytes_to_hex(expected))

    it "Extract→Expand round-trip is deterministic":
        val a = hkdf_sha3_384(_a1_salt(), _a1_ikm(), _a1_info(), 42)
        val b = hkdf_sha3_384(_a1_salt(), _a1_ikm(), _a1_info(), 42)
        expect(bytes_to_hex(a)).to_equal(bytes_to_hex(b))

    it "Expand L>max(255*48) returns empty list":
        val prk = hkdf_extract_sha3_384(_a1_salt(), _a1_ikm())
        val okm = hkdf_expand_sha3_384(prk, _a1_info(), 12241)
        expect(okm.len()).to_equal(0)

    it "PRK length is 48 bytes":
        val prk = hkdf_extract_sha3_384(_a1_salt(), _a1_ikm())
        expect(prk.len()).to_equal(48)

# ============================================================================
# HKDF-SHA3-512
# ============================================================================

describe "HKDF-SHA3-512 — RFC 5869 §A.1-style":

    it "Extract is HMAC: hkdf_extract == hmac_sha3_512":
        val expected = hmac_sha3_512_bytes(_a1_salt(), _a1_ikm())
        val actual = hkdf_extract_sha3_512(_a1_salt(), _a1_ikm())
        expect(bytes_to_hex(actual)).to_equal(bytes_to_hex(expected))

    it "Extract→Expand round-trip is deterministic":
        val a = hkdf_sha3_512(_a1_salt(), _a1_ikm(), _a1_info(), 64)
        val b = hkdf_sha3_512(_a1_salt(), _a1_ikm(), _a1_info(), 64)
        expect(bytes_to_hex(a)).to_equal(bytes_to_hex(b))

    it "Expand L>max(255*64) returns empty list":
        val prk = hkdf_extract_sha3_512(_a1_salt(), _a1_ikm())
        val okm = hkdf_expand_sha3_512(prk, _a1_info(), 16321)
        expect(okm.len()).to_equal(0)

    it "PRK length is 64 bytes":
        val prk = hkdf_extract_sha3_512(_a1_salt(), _a1_ikm())
        expect(prk.len()).to_equal(64)

    it "Empty salt uses HashLen zero bytes per RFC 5869 §2.2":
        val prk_empty_salt = hkdf_extract_sha3_512([], _a1_ikm())
        val prk_zero_salt = hkdf_extract_sha3_512(_bytes_repeat(0, 64), _a1_ikm())
        expect(bytes_to_hex(prk_empty_salt)).to_equal(bytes_to_hex(prk_zero_salt))
