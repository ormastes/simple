"""
# DOM API Spec

Unit tests for the Simple browser engine DOM API.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.script.dom_api.{
    document_create_element, document_create_text_node,
    document_query_selector, document_query_selector_all,
    document_get_element_by_id,
    node_append_child, node_remove_child, node_insert_before,
    node_set_attribute, node_get_attribute, node_remove_attribute,
    node_set_text_content, node_get_text_content,
    node_class_list_add, node_class_list_remove,
    node_class_list_toggle, node_class_list_contains,
    node_set_style_property, node_children, node_tag_name
}

describe "DOM API - Element Creation":
    it "creates an element node with correct tag":
        val div = document_create_element("div")
        expect(node_tag_name(div)).to_equal("div")

    it "creates a text node":
        val tn = document_create_text_node("hello")
        expect(node_tag_name(tn)).to_equal("#text")

    it "creates a span element":
        val span = document_create_element("span")
        expect(node_tag_name(span)).to_equal("span")

describe "DOM API - Tree Manipulation":
    it "appends a child to parent":
        val parent = document_create_element("div")
        val child = document_create_element("p")
        node_append_child(parent, child)
        val kids = node_children(parent)
        expect(kids.len()).to_equal(1)

    it "removes a child by index":
        val parent = document_create_element("div")
        val c1 = document_create_element("p")
        val c2 = document_create_element("span")
        node_append_child(parent, c1)
        node_append_child(parent, c2)
        node_remove_child(parent, 0)
        val kids = node_children(parent)
        expect(kids.len()).to_equal(1)

    it "inserts a child before a reference index":
        val parent = document_create_element("div")
        val c1 = document_create_element("p")
        val c2 = document_create_element("span")
        node_append_child(parent, c1)
        node_insert_before(parent, c2, 0)
        val kids = node_children(parent)
        expect(kids.len()).to_equal(2)

describe "DOM API - Attributes":
    it "sets and gets an attribute":
        val el = document_create_element("div")
        node_set_attribute(el, "data-x", "42")
        val v = node_get_attribute(el, "data-x")
        expect(v != nil).to_equal(true)

    it "removes an attribute":
        val el = document_create_element("div")
        node_set_attribute(el, "data-x", "42")
        node_remove_attribute(el, "data-x")
        val v = node_get_attribute(el, "data-x")
        expect(v == nil).to_equal(true)

describe "DOM API - Text Content":
    it "sets text content on a node":
        val el = document_create_element("div")
        node_set_text_content(el, "hello world")
        val kids = node_children(el)
        expect(kids.len()).to_equal(1)

describe "DOM API - Class List":
    it "adds a class":
        val el = document_create_element("div")
        node_class_list_add(el, "active")
        expect(node_class_list_contains(el, "active")).to_equal(true)

    it "removes a class":
        val el = document_create_element("div")
        node_class_list_add(el, "active")
        node_class_list_remove(el, "active")
        expect(node_class_list_contains(el, "active")).to_equal(false)

    it "toggles a class on":
        val el = document_create_element("div")
        val result = node_class_list_toggle(el, "active")
        expect(result).to_equal(true)

    it "toggles a class off":
        val el = document_create_element("div")
        node_class_list_add(el, "active")
        val result = node_class_list_toggle(el, "active")
        expect(result).to_equal(false)

describe "DOM API - Query":
    it "finds element by id":
        val root = document_create_element("div")
        val child = document_create_element("span")
        node_set_attribute(child, "id", "myspan")
        node_append_child(root, child)
        val found = document_get_element_by_id(root, "myspan")
        expect(found != nil).to_equal(true)

    it "query selector by tag":
        val root = document_create_element("div")
        val child = document_create_element("p")
        node_append_child(root, child)
        val found = document_query_selector(root, "p")
        expect(found != nil).to_equal(true)

    it "query selector all returns multiple matches":
        val root = document_create_element("div")
        val c1 = document_create_element("p")
        val c2 = document_create_element("p")
        node_append_child(root, c1)
        node_append_child(root, c2)
        val all = document_query_selector_all(root, "p")
        expect(all.len()).to_equal(2)

describe "DOM API - Style Properties":
    it "sets a style property":
        val el = document_create_element("div")
        node_set_style_property(el, "display", "none")
        # Style is applied through BeDomNode.set_style
        expect(node_tag_name(el)).to_equal("div")
