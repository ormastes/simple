fn double(x: i64) -> i64: x * 2
fn triple(x: i64) -> i64: x * 3
fn add(a: i64, b: i64) -> i64: a + b
fn add1(x: i64) -> i64: x + 1

describe "Pipe operator |>":
    it "basic pipe":
        val result = 5 |> double
        expect(result).to_equal(10)

    it "pipe with extra args":
        val result = 1 |> add(2)
        expect(result).to_equal(3)

    it "chained pipe":
        val result = 2 |> double |> triple
        expect(result).to_equal(12)

    it "pipe to add1":
        val result = 10 |> add1
        expect(result).to_equal(11)

    it "pipe chain three":
        val result = 1 |> add1 |> double |> triple
        expect(result).to_equal(12)

    it "pipe to lambda":
        val result = 5 |> (\x: x * 3)
        expect(result).to_equal(15)

    it "pipe to composed function":
        val f = double >> triple
        val result = 2 |> f
        expect(result).to_equal(12)
