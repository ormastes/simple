# @cover src/os/compositor/wm_scene.spl 90%
# @tag: rendering, wm, scene
#
# WM Scene Specification
#
# Verifies standard WM scene builder: scene construction with decorations,
# glassmorphism, text, and desktop chrome. HTML conversion for Electron path.

use std.spec.{describe, context, it, expect}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.wm_scene.{
    WmSceneSpec, SceneElement,
    standard_wm_scene, render_scene_to_backend, scene_to_html, shared_wm_scene_to_wm_scene,
    shared_wm_scene_to_chromed_wm_scene}
use common.ui.web_render_api.{WEB_RENDER_TARGET_SIMPLE_WEB, WebRenderRequest}
use common.ui.builder.{column, label, build_tree_with_title}
use common.ui.taskbar_model.{AppRef, TaskbarModel, TrayItem, WindowRef}
use common.ui.window.{WindowManager}
use common.ui.window_surface_registry.{UiWindowSurfaceRegistry, UI_SURFACE_KIND_SIMPLE_WEB}
use common.ui.window_scene.{shared_wm_scene_from_window_manager}
use os.compositor.web_render_surface.{compositor_render_html_pixels}

# ============================================================================
# Constants
# ============================================================================

val W: i32 = 800
val H: i32 = 600

fn _shared_tree(title: text):
    build_tree_with_title(column("{title}_root", [label("{title}_label", title)]), title, "glass_dark")

fn _shared_taskbar() -> TaskbarModel:
    TaskbarModel(
        pinned: [
            AppRef(app_id: "terminal", display_name: "Terminal", icon: "term"),
            AppRef(app_id: "browser", display_name: "Browser", icon: "browser")
        ],
        running: [
            WindowRef(window_id: "win1", app_id: "simple.terminal", title: "Terminal", minimized: false)
        ],
        tray: [
            TrayItem(item_id: "clock", label: "09:41", icon: "clock")
        ]
    )

# ============================================================================
# Test Group 1: Scene Construction (AC-2, AC-3)
# ============================================================================

describe "WmScene — standard_wm_scene":

    context "scene structure":

        it "AC-2: standard scene has correct dimensions":
            val scene = standard_wm_scene(W, H)
            expect(scene.width).to_equal(W)
            expect(scene.height).to_equal(H)

        it "AC-2: standard scene has a name":
            val scene = standard_wm_scene(W, H)
            val has_name = scene.name.len() > 0
            expect(has_name).to_equal(true)

        it "AC-2: standard scene contains multiple elements":
            val scene = standard_wm_scene(W, H)
            expect(scene.elements.len()).to_be_greater_than(0)

    context "scene elements":

        it "AC-2: scene contains a desktop chrome element":
            val scene = standard_wm_scene(W, H)
            var found = false
            for elem in scene.elements:
                if elem.kind == "desktop_chrome":
                    found = true
            expect(found).to_equal(true)

        it "AC-2: scene contains a window decoration element":
            val scene = standard_wm_scene(W, H)
            var found = false
            for elem in scene.elements:
                if elem.kind == "decoration":
                    found = true
            expect(found).to_equal(true)

        it "AC-2: scene contains a glass panel element":
            val scene = standard_wm_scene(W, H)
            var found = false
            for elem in scene.elements:
                if elem.kind == "glass_panel":
                    found = true
            expect(found).to_equal(true)

        it "AC-2: scene contains a text label element":
            val scene = standard_wm_scene(W, H)
            var found = false
            for elem in scene.elements:
                if elem.kind == "text_label":
                    found = true
            expect(found).to_equal(true)

        it "AC-3: scene element positions are within bounds":
            val scene = standard_wm_scene(W, H)
            var all_in_bounds = true
            for elem in scene.elements:
                if elem.x < 0 or elem.y < 0:
                    all_in_bounds = false
                if elem.x + elem.w > W or elem.y + elem.h > H:
                    all_in_bounds = false
            expect(all_in_bounds).to_equal(true)

# ============================================================================
# Test Group 2: Scene Rendering to Backend (AC-3)
# ============================================================================

describe "WmScene — render_scene_to_backend":

    context "pixel buffer output":

        it "AC-3: rendered scene returns non-empty pixel buffer":
            val scene = standard_wm_scene(W, H)
            # Note: requires BrowserCompositorBackend — will fail without impl
            val pixels = render_scene_to_backend(scene, nil)
            expect(pixels.len()).to_be_greater_than(0)

        it "AC-3: render_scene_to_backend reuses a provided backend":
            val scene = WmSceneSpec(name: "empty_scene", width: W, height: H, elements: [])
            val backend = BrowserCompositorBackend.with_color(W, H, 0xFF123456)
            val pixels = render_scene_to_backend(scene, backend)
            expect(pixels[0]).to_equal(0xFF123456)

        it "AC-3: rendered pixel buffer has correct size (width * height)":
            val scene = standard_wm_scene(W, H)
            val pixels = render_scene_to_backend(scene, nil)
            val expected_len = W * H
            expect(pixels.len().to_i32()).to_equal(expected_len)

        it "AC-3: rendered pixels are non-zero (not all transparent)":
            val scene = standard_wm_scene(W, H)
            val pixels = render_scene_to_backend(scene, nil)
            var has_nonzero = false
            for p in pixels:
                if p != 0:
                    has_nonzero = true
            expect(has_nonzero).to_equal(true)

        it "AC-3: small scenes render through the Simple Web Renderer pixel path":
            val scene = standard_wm_scene(80, 60)
            val pixels = render_scene_to_backend(scene, nil)
            val html = scene_to_html(scene)
            val req = WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, scene.name, html, "", "", 80, 60).with_pixel_output()
            val expected = compositor_render_html_pixels(req, html)
            expect(pixels.len()).to_equal(80 * 60)
            expect(pixels[0]).to_equal(expected[0])
            expect(pixels[pixels.len() - 1]).to_equal(expected[expected.len() - 1])

# ============================================================================
# Test Group 3: HTML Conversion (AC-2)
# ============================================================================

describe "WmScene — scene_to_html":

    context "HTML output":

        it "AC-2: scene produces non-empty HTML":
            val scene = standard_wm_scene(W, H)
            val html = scene_to_html(scene)
            expect(html.len()).to_be_greater_than(0)

        it "AC-2: HTML contains doctype or html tag":
            val scene = standard_wm_scene(W, H)
            val html = scene_to_html(scene)
            val has_html = html.contains("<html") or html.contains("<!DOCTYPE")
            expect(has_html).to_equal(true)

        it "AC-2: HTML contains style information for glass panel":
            val scene = standard_wm_scene(W, H)
            val html = scene_to_html(scene)
            val has_style = html.contains("backdrop-filter") or html.contains("blur")
            expect(has_style).to_equal(true)

        it "AC-2: HTML dimensions match scene dimensions":
            val scene = standard_wm_scene(W, H)
            val html = scene_to_html(scene)
            val has_width = html.contains("800")
            expect(has_width).to_equal(true)

describe "WmScene — SharedWmScene projection":

    it "projects shared GUI windows into pure Simple WM scene elements":
        var manager = WindowManager.new()
        val _one = manager.open_window("surf1", "Terminal", 20, 30, 300, 200, _shared_tree("terminal"))
        val _two = manager.open_window("surf2", "Hidden", 40, 50, 300, 200, _shared_tree("hidden"))
        manager.minimize_window("surf2")
        var registry = UiWindowSurfaceRegistry.new()
        registry.bind_with_kind("win1", "surf1", 77u64, "simple.terminal", "Terminal", UI_SURFACE_KIND_SIMPLE_WEB)

        val shared = shared_wm_scene_from_window_manager(manager, registry, 640, 480)
        val scene = shared_wm_scene_to_wm_scene(shared)
        val html = scene_to_html(scene)

        expect(scene.width).to_equal(640)
        expect(scene.height).to_equal(480)
        expect(scene.elements.len()).to_equal(4)
        expect(html).to_contain("Terminal")
        expect(html.contains("Hidden")).to_equal(false)

    it "projects shared command lane, clock, right icons, taskbar launchers, and windows into render elements":
        var manager = WindowManager.new()
        val _opened = manager.open_window("surf1", "Terminal", 20, 40, 300, 200, _shared_tree("terminal"))
        var registry = UiWindowSurfaceRegistry.new()
        registry.bind_with_kind("win1", "surf1", 77u64, "simple.terminal", "Terminal", UI_SURFACE_KIND_SIMPLE_WEB)
        val shared = shared_wm_scene_from_window_manager(manager, registry, 800, 600)

        val scene = shared_wm_scene_to_chromed_wm_scene(shared, _shared_taskbar(), 1000, "09:41", 2)
        val html = scene_to_html(scene)

        var has_command = false
        var has_clock = false
        var right_icons = 0
        var launchers = 0
        var running = 0
        var has_window_bar = false
        for elem in scene.elements:
            if elem.kind == "command_lane":
                has_command = true
                expect(elem.y).to_equal(0)
                expect(elem.h).to_equal(32)
            elif elem.kind == "command_clock":
                has_clock = true
                expect(elem.text).to_equal("09:41")
            elif elem.kind == "command_icon":
                right_icons = right_icons + 1
            elif elem.kind == "taskbar_launcher":
                launchers = launchers + 1
            elif elem.kind == "taskbar_running":
                running = running + 1
            elif elem.kind == "decoration":
                has_window_bar = true

        expect(has_command).to_equal(true)
        expect(has_clock).to_equal(true)
        expect(right_icons).to_equal(2)
        expect(launchers).to_equal(2)
        expect(running).to_equal(1)
        expect(has_window_bar).to_equal(true)
        expect(html).to_contain("class='command-lane'")
        expect(html).to_contain("data-app='terminal'")
        expect(html).to_contain("data-window='win1'")
