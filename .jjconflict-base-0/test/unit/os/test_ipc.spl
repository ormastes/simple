fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn port_idx(port: i64, table_sz: i64) -> i64:
    port - (port / table_sz) * table_sz

fn has_flag(flags: i64, bit: i64) -> bool:
    (flags & (1 << bit)) != 0

fn main():
    print "=== IPC ==="
    check("p0", port_idx(0, 1024) == 0)
    check("p100", port_idx(100, 1024) == 100)
    check("p1024", port_idx(1024, 1024) == 0)
    check("p1025", port_idx(1025, 1024) == 1)
    check("f0", has_flag(5, 0))
    check("f1", not has_flag(5, 1))
    check("f2", has_flag(5, 2))
    print "=== DONE ==="
