use std.io_runtime

class TrapFrame:
    pc: i64
    cause: i32
    regs_saved: bool

    static fn create(pc: i64, cause: i32) -> TrapFrame:
        return TrapFrame(pc: pc, cause: cause, regs_saved: true)

    me preserves_registers() -> bool:
        return self.regs_saved

    me is_syscall() -> bool:
        return self.cause == 8

class SyscallDisp:
    caller_pc: i64
    return_pc: i64
    priv_before: text
    priv_after: text

    static fn create(caller: i64) -> SyscallDisp:
        return SyscallDisp(caller_pc: caller, return_pc: caller + 4, priv_before: "user", priv_after: "user")

    me returns_to_caller() -> bool:
        return self.return_pc == self.caller_pc + 4

    me no_escalation() -> bool:
        return self.priv_after == self.priv_before

class CapGrant:
    owner: text
    perm: text
    is_revoked: bool

    static fn create(owner: text, perm: text) -> CapGrant:
        return CapGrant(owner: owner, perm: perm, is_revoked: false)

    me revoke() -> CapGrant:
        return CapGrant(owner: self.owner, perm: self.perm, is_revoked: true)

    me is_valid() -> bool:
        return self.is_revoked == false

class SchedSt:
    state: text
    ctx_saved: bool

    static fn ready() -> SchedSt:
        return SchedSt(state: "ready", ctx_saved: false)

    me to_blocked() -> SchedSt:
        return SchedSt(state: "blocked", ctx_saved: true)

    me is_runnable() -> bool:
        return self.state == "ready" or self.state == "running"

class Transition:
    from_st: text
    to_st: text
    is_valid: bool

    static fn check(from: text, to: text) -> Transition:
        var valid = false
        if from == "ready" and to == "running":
            valid = true
        if from == "running" and to == "blocked":
            valid = true
        if from == "running" and to == "zombie":
            valid = true
        if from == "blocked" and to == "ready":
            valid = true
        return Transition(from_st: from, to_st: to, is_valid: valid)

    me no_zombie_runnable() -> bool:
        if self.from_st == "zombie":
            if self.to_st == "ready" or self.to_st == "running":
                return false
        return true

class Selection:
    w0_focused: bool
    w0_visible: bool
    w1_focused: bool
    w1_visible: bool

    static fn create(f0: bool, v0: bool, f1: bool, v1: bool) -> Selection:
        return Selection(w0_focused: f0, w0_visible: v0, w1_focused: f1, w1_visible: v1)

    me focused_count() -> i32:
        var count = 0
        if self.w0_focused:
            count = count + 1
        if self.w1_focused:
            count = count + 1
        return count

    me at_most_one() -> bool:
        return self.focused_count() <= 1

    me focus_implies_visible() -> bool:
        if self.w0_focused and self.w0_visible == false:
            return false
        if self.w1_focused and self.w1_visible == false:
            return false
        return true

class CrashPol:
    scope: text
    propagates: bool
    action: text

    static fn contained() -> CrashPol:
        return CrashPol(scope: "process", propagates: false, action: "restart")

    me doesnt_propagate() -> bool:
        return self.propagates == false

    me is_restart() -> bool:
        return self.action == "restart"

class VResult:
    status: text
    lane: text

    static fn pass_it(lane: text) -> VResult:
        return VResult(status: "pass", lane: lane)

    static fn fail_it(lane: text) -> VResult:
        return VResult(status: "fail", lane: lane)

    me is_pass() -> bool:
        return self.status == "pass"

class Claim:
    claim_id: text
    has_evidence: bool
    kind: text

    static fn bare(cid: text) -> Claim:
        return Claim(claim_id: cid, has_evidence: false, kind: "")

    me with_evidence(k: text) -> Claim:
        return Claim(claim_id: self.claim_id, has_evidence: true, kind: k)

    me needs_evidence() -> bool:
        return self.has_evidence == false

    me is_proven() -> bool:
        return self.kind == "proof"

class Evidence:
    kind: text
    strength: i32

    static fn proof() -> Evidence:
        return Evidence(kind: "proof", strength: 4)

    static fn test_ev() -> Evidence:
        return Evidence(kind: "test", strength: 3)

    static fn assertion_ev() -> Evidence:
        return Evidence(kind: "assertion", strength: 1)

    me is_strong() -> bool:
        return self.strength >= 3

fn check(label: text, ok: bool):
    if ok:
        print("PASS: " + label)
    else:
        print("FAIL: " + label)

fn main():
    check("test_trap_preserves_regs", TrapFrame.create(0x1000, 8).preserves_registers() == true)
    check("test_trap_is_syscall", TrapFrame.create(0x1000, 8).is_syscall() == true)
    check("test_syscall_returns_to_caller", SyscallDisp.create(0x2000).returns_to_caller() == true)
    check("test_cap_valid_initially", CapGrant.create("proc1", "read").is_valid() == true)
    check("test_cap_revoked_invalid", CapGrant.create("proc1", "read").revoke().is_valid() == false)
    check("test_no_privilege_escalation", SyscallDisp.create(0x2000).no_escalation() == true)
    check("test_ready_is_runnable", SchedSt.ready().is_runnable() == true)
    check("test_blocked_saves_context", SchedSt.ready().to_blocked().ctx_saved == true)
    check("test_no_zombie_runnable", Transition.check("zombie", "ready").no_zombie_runnable() == false)
    check("test_one_focused_ok", Selection.create(true, true, false, true).at_most_one() == true)
    check("test_two_focused_fail", Selection.create(true, true, true, true).at_most_one() == false)
    check("test_focus_implies_visible", Selection.create(true, true, false, false).focus_implies_visible() == true)
    check("test_crash_contained", CrashPol.contained().doesnt_propagate() == true)
    check("test_crash_restart", CrashPol.contained().is_restart() == true)
    check("test_pass_result", VResult.pass_it("kernel").is_pass() == true)
    check("test_fail_result", VResult.fail_it("desktop").is_pass() == false)
    check("test_bare_claim_needs_evidence", Claim.bare("c1").needs_evidence() == true)
    check("test_claim_with_proof", Claim.bare("c1").with_evidence("proof").is_proven() == true)
    check("test_proof_is_strong", Evidence.proof().is_strong() == true)
    check("test_assertion_not_strong", Evidence.assertion_ev().is_strong() == false)
    print("DONE")
