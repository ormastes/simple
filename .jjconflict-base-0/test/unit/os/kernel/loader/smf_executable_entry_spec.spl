use std.spec
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.smf.{
    SMF_ERR_WRONG_ARCH,
    smf_executable_entry_point_for_arch,
    smf_extract_executable_stub_for_arch
}

fn _smf_exec_fixture(arch_code: i64) -> [u8]:
    var out: [u8] = []
    out.push(0x7Fi64.to_u8())
    out.push(0x45i64.to_u8())
    out.push(0x4Ci64.to_u8())
    out.push(0x46i64.to_u8())
    while out.len() < 8:
        out.push(0.to_u8())

    var i: i64 = 0
    while i < 128:
        if i == 0:
            out.push(83.to_u8())
        elif i == 1:
            out.push(77.to_u8())
        elif i == 2:
            out.push(70.to_u8())
        elif i == 3:
            out.push(0.to_u8())
        elif i == 44:
            out.push(0x34i64.to_u8())
        elif i == 45:
            out.push(0x12i64.to_u8())
        elif i == 52:
            out.push(8.to_u8())
        elif i == 60:
            out.push(1.to_u8())
        elif i == 61:
            out.push(arch_code.to_u8())
        elif i == 62:
            out.push(1.to_u8())
        else:
            out.push(0.to_u8())
        i = i + 1
    out

describe "SMF executable entry helper":
    it "returns the typed entry point for an x86_64 executable envelope":
        val bytes = _smf_exec_fixture(1)
        val entry = smf_executable_entry_point_for_arch(bytes, Architecture.X86_64)
        expect(entry.is_ok()).to_equal(true)
        expect(entry.unwrap()).to_equal(0x1234)

    it "rejects an executable envelope for the wrong architecture":
        val bytes = _smf_exec_fixture(3)
        val entry = smf_executable_entry_point_for_arch(bytes, Architecture.X86_64)
        expect(entry.is_err()).to_equal(true)
        expect(entry.unwrap_err()).to_equal(SMF_ERR_WRONG_ARCH)

    it "extracts the same embedded ELF stub used by filesystem spawn":
        val bytes = _smf_exec_fixture(1)
        val stub = smf_extract_executable_stub_for_arch(bytes, Architecture.X86_64)
        expect(stub.is_ok()).to_equal(true)
        expect(stub.unwrap().len()).to_equal(8)
