use std.spec
use os.kernel.arch.riscv64.hal_cache.{
    CmoCapSnapshot,
    CacheOpLog,
    make_empty_log,
    hal_cache_probe_with_isa,
    hal_cache_probe_with_trap_fires,
    hal_cache_probe_with_trap_succeeds,
    hal_cache_probe_with_cmo_disabled,
    hal_cache_init_with_isa,
    portable_numeric_capabilities_has_riscv_zicbom,
    portable_numeric_capabilities_has_riscv_zicbom_default,
    hal_cache_sync_icache_with_log,
    hal_cache_clean_dcache_with_log,
    hal_cache_invalidate_dcache_with_log
}

# SA-3 scope: HalCache impl — sync_icache emits fence.i; clean_dcache emits cbo.clean
#             per-line when Zicbom advertised; fallback emits diagnostic; cacheline size
#             respects DTB.
# AC-2: HalCache trait canonical methods (hal_cache_sync_icache, hal_cache_clean_dcache,
#        hal_cache_invalidate_dcache)
# AC-3: Zicbom/Zicboz/Zicbop CMO probing via PortableNumericCapabilities
# AC-5: fence.i ordering after code-load; Zicbom available-vs-fallback
#
# Production module: src/os/kernel/arch/riscv64/hal_cache.spl
# The spec imports CmoCapSnapshot, CacheOpLog, make_empty_log, the probe helpers,
# hal_cache_init_with_isa, and the _with_log test-seam functions from the module.
#
# NOTE on negative-path tests: No to_raise is available. For illegal-instruction-probe
# tests, the impl returns a result sentinel (CmoCapSnapshot). Tests assert on the
# returned value, not on trap firing.

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "HalCache":

    describe "hal_cache_sync_icache — fence.i always emitted":
        it "AC-2: emits fence.i when Zicbom not available":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: false, has_zicboz: false, has_zicbop: false)
            hal_cache_sync_icache_with_log(log, caps, 0x80200000u64, 4096u64)
            expect(log.fence_i_count).to_be_greater_than(0u32)

        it "AC-2: emits fence.i when Zicbom IS available (fence.i always runs)":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)
            hal_cache_sync_icache_with_log(log, caps, 0x80200000u64, 4096u64)
            expect(log.fence_i_count).to_be_greater_than(0u32)

        it "AC-5: fence.i ordering — emitted after cbo.flush when Zicbom available":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)
            hal_cache_sync_icache_with_log(log, caps, 0x80200000u64, 128u64)
            expect(log.cbo_flush_count).to_be_greater_than(0u32)
            expect(log.fence_i_count).to_be_greater_than(0u32)

    describe "hal_cache_clean_dcache — cbo.clean per-line when Zicbom available":
        it "AC-2: emits cbo.clean for each cacheline in range when Zicbom=true":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)
            hal_cache_clean_dcache_with_log(log, caps, 0x80300000u64, 128u64, 64u32)
            expect(log.cbo_clean_count).to_equal(2u32)

        it "AC-2: cacheline count scales with range/stride":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)
            hal_cache_clean_dcache_with_log(log, caps, 0x80300000u64, 256u64, 64u32)
            expect(log.cbo_clean_count).to_equal(4u32)

        it "AC-2: emits diagnostic (no panic) when Zicbom=false":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: false, has_zicboz: false, has_zicbop: false)
            hal_cache_clean_dcache_with_log(log, caps, 0x80300000u64, 64u64, 64u32)
            expect(log.cbo_clean_count).to_equal(0u32)
            expect(log.diagnostic_emitted).to_equal(true)

        it "AC-2: cacheline size from DTB cbom-block-size (not hardcoded 64)":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)
            hal_cache_clean_dcache_with_log(log, caps, 0x80400000u64, 256u64, 128u32)
            expect(log.cbo_clean_count).to_equal(2u32)

    describe "hal_cache_invalidate_dcache — cbo.inval per-line when Zicbom available":
        it "AC-2: emits cbo.inval for each cacheline when Zicbom=true":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)
            hal_cache_invalidate_dcache_with_log(log, caps, 0x80500000u64, 64u64, 64u32)
            expect(log.cbo_inval_count).to_equal(1u32)

        it "AC-2: emits diagnostic (no panic) when Zicbom=false":
            val log = make_empty_log()
            val caps = CmoCapSnapshot(has_zicbom: false, has_zicboz: false, has_zicbop: false)
            hal_cache_invalidate_dcache_with_log(log, caps, 0x80500000u64, 64u64, 64u32)
            expect(log.cbo_inval_count).to_equal(0u32)
            expect(log.diagnostic_emitted).to_equal(true)

    describe "CMO probe ladder — 4 cases (AC-3, AC-5)":
        it "AC-3: DTB advertises Zicbom — probe returns true; cbo.clean emitted":
            val caps = hal_cache_probe_with_isa("rv64gc_zicbom_zicboz")
            expect(caps.has_zicbom).to_equal(true)

        it "AC-3: DTB silent + illegal-instr probe fires — probe returns false; fallback no-op + diagnostic":
            val caps = hal_cache_probe_with_trap_fires()
            expect(caps.has_zicbom).to_equal(false)

        it "AC-3: DTB silent + illegal-instr probe succeeds — probe returns true":
            val caps = hal_cache_probe_with_trap_succeeds()
            expect(caps.has_zicbom).to_equal(true)

        it "AC-3: config flag disables CMO — probe returns false unconditionally":
            val caps = hal_cache_probe_with_cmo_disabled()
            expect(caps.has_zicbom).to_equal(false)

    describe "PortableNumericCapabilities handshake (AC-3, cross-feature)":
        it "AC-3: after hal_cache_init, has_riscv_zicbom is true on probe-positive path":
            # NOTE: PortableNumericCapabilities.has_riscv_zicbom does not exist yet.
            # This test FAILS TO LOAD until Feature A Phase 3 adds the field.
            # That is intentional TDD red. Phase 5 wires both together.
            hal_cache_init_with_isa("rv64gc_zicbom")
            val cap_value = portable_numeric_capabilities_has_riscv_zicbom()
            expect(cap_value).to_equal(true)

        it "AC-3: before any hal_cache_init, has_riscv_zicbom defaults to false":
            val cap_value = portable_numeric_capabilities_has_riscv_zicbom_default()
            expect(cap_value).to_equal(false)
