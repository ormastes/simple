use os.apps.shell.shell_tools.{_toolchain_manifest_paths}

describe "shell toolchain manifest paths":
    it "maps clang commands to clang metadata instead of llvm metadata":
        val clang = _toolchain_manifest_paths("clang")
        expect clang.0 == "/SYS/CLANGVER.TXT"
        expect clang.1 == "/SYS/CLANGMAN.TXT"
        expect clang.2 == "/usr/bin/clang"

        val clang20 = _toolchain_manifest_paths("clang-20")
        expect clang20.0 == "/SYS/CLANGVER.TXT"
        expect clang20.1 == "/SYS/CLANGMAN.TXT"
        expect clang20.2 == "/usr/bin/clang-20"