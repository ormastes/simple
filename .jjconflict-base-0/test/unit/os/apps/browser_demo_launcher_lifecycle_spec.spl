# SYS-GUI-004 — Browser Demo multi-window launcher lifecycle spec
#
# Exercises the launcher → shell → WM → compositor ownership join for the
# Browser Demo built-in app. Two remote windows are created under a single
# launcher pid/app_id; the spec confirms both windows group under the same
# `/sys/apps/browser_demo` identity, that grouping survives a title change,
# and that destroying one window leaves the other intact.
#
# Covers SYS-GUI-004 Multi-window app live test (serial / unit half).

use std.spec
use os.desktop.shell.{DesktopShell}
use os.compositor.compositor.{Compositor}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.input_backend.{InputBackend}
use os.drivers.input.ps2_keyboard.{KeyEvent, Key}
use os.drivers.input.ps2_mouse.{MouseEvent}
use os.services.launcher.launcher.{
    launcher_init, launcher_record_process,
    launcher_get_process_app_id_for_pid, launcher_get_process_window_count,
    launcher_get_app_launch_state, launcher_get_app_window_count,
    launcher_get_app_path, launcher_get_app_identity
}
use os.services.wm.wm_service.{WmAction}

class SilentInputBackend:
    _unused: bool

impl InputBackend for SilentInputBackend:
    me poll_key() -> KeyEvent?:
        nil

    me poll_mouse() -> MouseEvent?:
        nil

    fn alt_held() -> bool:
        false

    fn shift_held() -> bool:
        false

    fn ctrl_held() -> bool:
        false

    fn key_to_char(key: Key) -> text?:
        nil

impl SilentInputBackend:
    static fn new() -> SilentInputBackend:
        SilentInputBackend(_unused: false)

describe "Browser Demo launcher lifecycle":
    it "exposes the built-in browser_demo manifest identity":
        launcher_init()
        expect(launcher_get_app_path(3)).to_equal("/sys/apps/browser_demo")
        expect(launcher_get_app_identity(3)).to_equal("/sys/apps/browser_demo")

    it "groups two remote windows under one launcher-owned app_id":
        launcher_init()
        val pid: u64 = 8301
        expect(launcher_record_process(pid, 3, "running", 0, 0, true)).to_be(true)

        var shell = _make_test_shell()
        shell.apply_wm_action(_create_window_action("Browser Demo", pid, 401))
        shell.apply_wm_action(_create_window_action("Browser Demo Inspector", pid, 402))

        expect(shell.compositor.window_count()).to_equal(2)
        expect(shell.compositor.window_count_for_process(pid)).to_equal(2)
        expect(shell.compositor.window_count_for_app("/sys/apps/browser_demo")).to_equal(2)
        expect(shell.wm.window_count_for_process(pid)).to_equal(2)
        expect(shell.wm.window_count_for_app("/sys/apps/browser_demo")).to_equal(2)
        expect(launcher_get_process_app_id_for_pid(pid)).to_equal("/sys/apps/browser_demo")
        expect(launcher_get_process_window_count(0)).to_equal(2)
        expect(launcher_get_app_window_count(3)).to_equal(2)
        expect(launcher_get_app_launch_state(3)).to_equal("running")

    it "keeps grouping stable after a title change on one window":
        launcher_init()
        val pid: u64 = 8402
        expect(launcher_record_process(pid, 3, "running", 0, 0, true)).to_be(true)

        var shell = _make_test_shell()
        shell.apply_wm_action(_create_window_action("Browser Demo", pid, 411))
        shell.apply_wm_action(_create_window_action("Browser Demo Inspector", pid, 412))
        expect(shell.compositor.window_count_for_app("/sys/apps/browser_demo")).to_equal(2)

        val ids_before = shell.compositor.windows_for_app("/sys/apps/browser_demo")
        expect(ids_before.len()).to_equal(2)
        val first_wid = ids_before[0]

        shell.apply_wm_action(WmAction(
            kind: "update_title",
            window_id: first_wid,
            title: "Browser Demo — new-tab.simple",
            x: 0,
            y: 0,
            width: 0,
            height: 0,
            content: "",
            process_id: 0,
            app_id: "",
            owner_port: 0,
            src_port: 411
        ))

        expect(shell.compositor.window_count_for_app("/sys/apps/browser_demo")).to_equal(2)
        expect(shell.wm.window_count_for_app("/sys/apps/browser_demo")).to_equal(2)
        expect(shell.wm.window_owner_app_id(first_wid)).to_equal("/sys/apps/browser_demo")

    it "destroys one window without breaking the other window's ownership":
        launcher_init()
        val pid: u64 = 8503
        expect(launcher_record_process(pid, 3, "running", 0, 0, true)).to_be(true)

        var shell = _make_test_shell()
        shell.apply_wm_action(_create_window_action("Browser Demo", pid, 421))
        shell.apply_wm_action(_create_window_action("Browser Demo Inspector", pid, 422))
        val ids = shell.compositor.windows_for_app("/sys/apps/browser_demo")
        expect(ids.len()).to_equal(2)

        shell.apply_wm_action(WmAction(
            kind: "destroy_window",
            window_id: ids[0],
            title: "",
            x: 0,
            y: 0,
            width: 0,
            height: 0,
            content: "",
            process_id: 0,
            app_id: "",
            owner_port: 0,
            src_port: 421
        ))

        expect(shell.compositor.window_count()).to_equal(1)
        expect(shell.compositor.window_count_for_app("/sys/apps/browser_demo")).to_equal(1)
        expect(shell.wm.window_count_for_app("/sys/apps/browser_demo")).to_equal(1)
        expect(launcher_get_process_window_count(0)).to_equal(1)
        expect(launcher_get_app_window_count(3)).to_equal(1)

fn _make_test_shell() -> DesktopShell:
    val backend = BrowserCompositorBackend.new(1024, 768)
    val input = SilentInputBackend.new()
    val compositor = Compositor.with_backends(backend, input, 1024, 768)
    var shell = DesktopShell.new(compositor)
    shell.set_task_reaper_enabled(false)
    shell

fn _create_window_action(title: text, process_id: u64, owner_port: u64) -> WmAction:
    WmAction(
        kind: "create_window",
        window_id: 0,
        title: title,
        x: 32,
        y: 48,
        width: 640,
        height: 480,
        content: "",
        process_id: process_id,
        app_id: "",
        owner_port: owner_port,
        src_port: owner_port
    )
