use std.spec
use os.packages.os_packages.{list_all_packages}
use os.tools.pkg.pkg_format.{PkgArch}

fn _find_tools_files() -> [text]:
    for pkg in list_all_packages(PkgArch.X86_64):
        if pkg.base.name == "simpleos-tools":
            return pkg.base.files
    []

describe "simpleos-tools toolchain paths":
    it "ships stable native command paths and manifests for the guest toolchain surface":
        val files = _find_tools_files()
        expect (files).contains("/usr/bin/cmake")
        expect (files).contains("/usr/bin/ninja")
        expect (files).contains("/SYS/CMAKEVER.TXT")
        expect (files).contains("/SYS/CMAKEMAN.TXT")
        expect (files).contains("/SYS/NINJAVER.TXT")
        expect (files).contains("/SYS/NINJAMAN.TXT")
        expect (files).contains("/SYS/LLVMMAN.TXT")
        expect (files).contains("/SYS/CLANGMAN.TXT")
        expect (files).contains("/SYS/RUSTMAN.TXT")
        expect (files).contains("/usr/share/simpleos/toolchain/llvm/hello.ll")
        expect (files).contains("/usr/share/simpleos/toolchain/llvm/pipeline.step")
        expect (files).contains("/usr/share/simpleos/toolchain/clang/hello.c")
        expect (files).contains("/usr/share/simpleos/toolchain/clang/pipeline.step")
        expect (files).contains("/usr/share/simpleos/toolchain/rust/hello.rs")
        expect (files).contains("/usr/share/simpleos/toolchain/rust/pipeline.step")