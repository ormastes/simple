fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn shr(x: i64, n: i64) -> i64:
    x / (1 << n)

fn fat_data_sec(rsv: i64, nfat: i64, fatsz: i64) -> i64:
    rsv + nfat * fatsz

fn main():
    print "=== BPB ==="
    check("data32", fat_data_sec(32, 2, 2048) == 4128)
    check("data2", fat_data_sec(2, 2, 512) == 1026)
    check("clust", shr(1048576, 12) == 256)
    check("sec_per_clust", (1 << 3) == 8)
    print "=== DONE ==="
