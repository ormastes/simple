# aes256_ccm — AES-256-CCM Known-Answer Tests
#
# Tests the pure-Simple AES-256-CCM implementation in
# src/os/crypto/aes256_ccm.spl against vectors computed with
# Python cryptography AESCCM (libssl CCM reference path).
#
# Coverage:
#   V1  AES-256-CCM  empty AAD, 23-byte PT, tag_len=8
#   V2  AES-256-CCM  8-byte AAD, 24-byte PT, tag_len=8
#   V3  AES-256-CCM  12-byte AAD, 24-byte PT, tag_len=12
#
# All three vectors: encrypt direction + round-trip decrypt + tag-mismatch
# rejection (flip one tag byte -> must return Aes256CcmResult.Err).
#
# Interpreter-mode note: bin/simple test verifies file loading only; it-block
# bodies are not executed. Byte-exact assertions fire in compiled/native mode.
#
# Vector source: Python cryptography.hazmat.primitives.ciphers.aead.AESCCM
# (verified 2026-05-02, all nonces 13 bytes, RFC 3610 N=13/L=2 profile).

use std.spipe.*
use os.crypto.aes256_ccm.{aes256_ccm_encrypt, aes256_ccm_decrypt, Aes256CcmResult}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

# ============================================================================
# Hex helpers -- module-level to avoid it-block var-mutation drop
# (per .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _unwrap_ok(r: Aes256CcmResult) -> [u8]:
    match r:
        Aes256CcmResult.Ok(pt): pt
        Aes256CcmResult.Err(_): _empty()

fn _is_err(r: Aes256CcmResult) -> bool:
    match r:
        Aes256CcmResult.Ok(_): false
        Aes256CcmResult.Err(_): true

fn _empty() -> [u8]:
    var out: [u8] = []
    out

