fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn has_cap(set: i64, cap: i64) -> bool:
    (set & (1 << cap)) != 0

fn grant(set: i64, cap: i64) -> i64:
    set | (1 << cap)

fn main():
    print "=== Capability ==="
    check("empty", not has_cap(0, 0))
    check("grant0", has_cap(grant(0, 0), 0))
    check("grant3", has_cap(grant(0, 3), 3))
    check("no_other", not has_cap(grant(0, 3), 2))
    check("multi", has_cap(grant(grant(0, 1), 5), 5))
    print "=== DONE ==="
