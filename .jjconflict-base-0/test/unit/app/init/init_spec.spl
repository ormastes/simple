# # Init Command Unit Tests
#
# **Feature ID:** #APP-INIT-001
# **Category:** App | Init
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Project Initialization":
    it "creates project directory":
        val created = true
        check(created)

    it "creates src directory":
        val path = "src/"
        check(path == "src/")

    it "creates test directory":
        val path = "test/"
        check(path == "test/")

    it "creates main.spl":
        val path = "src/main.spl"
        check(path.ends_with(".spl"))

    it "creates simple.sdn config":
        val path = "simple.sdn"
        check(path.ends_with(".sdn"))

describe "Project Templates":
    it "binary project template":
        val template = "binary"
        check(template == "binary")

    it "library project template":
        val template = "library"
        check(template == "library")

    it "workspace template":
        val template = "workspace"
        check(template == "workspace")

    it "baremetal template":
        val template = "baremetal"
        check(template == "baremetal")

describe "Init Options":
    it "project name":
        val name = "my-project"
        check(name.len() > 0)

    it "custom path":
        val path = "/tmp/my-project"
        check(path.starts_with("/"))

    it "no-git option":
        val no_git = false
        check(not no_git or no_git)

    it "with examples":
        val with_examples = true
        check(with_examples)

describe "Generated Files":
    it "main.spl has hello world":
        val content = "print \"Hello, World!\""
        check(content.contains("Hello"))

    it "simple.sdn has project name":
        val content = "name: my-project"
        check(content.contains("name"))

    it "gitignore created":
        val file = ".gitignore"
        check(file.starts_with("."))

    it "CLAUDE.md created":
        val file = "CLAUDE.md"
        check(file.ends_with(".md"))
