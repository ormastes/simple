use app.mcp.main_lazy_assistant.{handle_assistant_start, handle_assistant_spawn_task, handle_assistant_list_tasks}
use app.mcp.assistant.session_store.{assistant_store_list_sessions, assistant_store_load_session}

extern fn rt_time_now_unix_micros() -> i64

val ASSIST_ROOT = ".build/llm_dashboard/assistant"

fn unique_text(prefix: text) -> text:
    "{prefix}-{rt_time_now_unix_micros()}"

fn find_session_by_prompt(prompt: text) -> text:
    for session in assistant_store_list_sessions(ASSIST_ROOT):
        if session.prompt == prompt:
            return session.session_id
    ""

describe "assistant task linking":
    it "records child task state on the parent and lists structured child tasks":
        val parent_prompt = unique_text("assistant-parent")
        val child_prompt = unique_text("assistant-child")

        val start_body = "{\"name\":\"assistant_start\",\"prompt\":\"{parent_prompt}\"}"
        val start_result = handle_assistant_start("1", start_body)
        expect(start_result.contains(parent_prompt)).to_equal(true)

        val parent_session_id = find_session_by_prompt(parent_prompt)
        expect(parent_session_id != "").to_equal(true)

        val spawn_body = "{\"parent_session_id\":\"{parent_session_id}\",\"name\":\"assistant_spawn\",\"prompt\":\"{child_prompt}\",\"mode\":\"child-task\"}"
        val spawn_result = handle_assistant_spawn_task("2", spawn_body)
        expect(spawn_result.contains(child_prompt)).to_equal(true)

        val child_session_id = find_session_by_prompt(child_prompt)
        expect(child_session_id != "").to_equal(true)

        val parent = assistant_store_load_session(ASSIST_ROOT, parent_session_id)
        match parent:
            case Some(session):
                expect(session.children.len()).to_equal(1)
                expect(session.children[0]).to_equal(child_session_id)
                expect(session.child_tasks.len()).to_equal(1)
                expect(session.child_tasks[0].child_session_id).to_equal(child_session_id)
                expect(session.child_tasks[0].status).to_equal("running")
            case nil:
                expect(false).to_equal(true)

        val tasks_result = handle_assistant_list_tasks("3", "{\"source\":\"assistant\"}")
        expect(tasks_result.contains("\"kind\":\"assistant\"")).to_equal(true)
        expect(tasks_result.contains("\"kind\":\"child_task\"")).to_equal(true)
        expect(tasks_result.contains(child_session_id)).to_equal(true)
        expect(tasks_result.contains(parent_session_id)).to_equal(true)
