# MCP T32 JSON spec — tests JSON helper functions
# Note: lsp_json.extract_field_raw uses range() which fails in HIR/interpreter.
# Inline equivalent implementations that avoid range().

fn tq() -> text:
    "\""

fn tlb() -> text:
    "{"

fn trb() -> text:
    "}"

fn t_escape(s: text) -> text:
    var result = s
    result = result.replace(r"\", r"\\")
    result = result.replace(tq(), r"\" + tq())
    result = result.replace("\n", r"\n")
    result

fn tjs(s: text) -> text:
    tq() + t_escape(s) + tq()

fn tjp(key: text, value: text) -> text:
    tq() + key + tq() + ":" + value

fn tjo1(p1: text) -> text:
    tlb() + p1 + trb()

fn _is_ws_char(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn _char_at(s: text, i: i64) -> text:
    s.substring(i, i + 1)

fn _find_value_start(json: text, key: text) -> i64:
    val search = tq() + key + tq()
    var offset = 0
    while offset + search.len() <= json.len():
        var matches = true
        var j = 0
        while j < search.len():
            if json.substring(offset + j, offset + j + 1) != search.substring(j, j + 1):
                matches = false
                break
            j = j + 1
        if not matches:
            offset = offset + 1
            continue
        var vs = offset + search.len()
        while vs < json.len() and _is_ws_char(_char_at(json, vs)):
            vs = vs + 1
        if vs < json.len() and _char_at(json, vs) == ":":
            vs = vs + 1
            while vs < json.len() and _is_ws_char(_char_at(json, vs)):
                vs = vs + 1
            return vs
        offset = offset + search.len()
    return -1

fn lsp_extract_field(json: text, key: text) -> text:
    val start = _find_value_start(json, key)
    if start < 0 or start >= json.len():
        return ""
    if _char_at(json, start) != tq():
        return ""
    var i = start + 1
    var out = ""
    var esc = false
    while i < json.len():
        val ch = json.substring(i, i + 1)
        if esc:
            out = out + ch
            esc = false
        elif ch == "\\":
            esc = true
        elif ch == tq():
            return out
        else:
            out = out + ch
        i = i + 1
    return ""

fn lsp_extract_id(json: text) -> text:
    val start = _find_value_start(json, "id")
    if start < 0 or start >= json.len():
        return "null"
    var end = start
    while end < json.len():
        val ch = _char_at(json, end)
        if ch == "," or ch == "}" or ch == "]" or _is_ws_char(ch):
            break
        end = end + 1
    val raw = json.substring(start, end)
    if raw == "":
        return "null"
    return raw

fn lsp_extract_nested(json: text, key: text) -> text:
    val ps = _find_value_start(json, "params")
    if ps < 0:
        return ""
    val params_chunk = json.substring(ps, json.len())
    lsp_extract_field(params_chunk, key)

describe "T32 MCP JSON Helpers":
    it "wraps string in quotes":
        val result = tjs("hello")
        expect(result).to_equal("\"hello\"")

    it "escapes quotes in string":
        val result = tjs("say \"hi\"")
        expect(result).to_contain("\\\"")

    it "escapes newlines":
        val result = tjs("line1\nline2")
        expect(result).to_contain("\\n")

    it "creates key-value pair":
        val result = tjp("name", tjs("test"))
        expect(result).to_start_with("\"name\"")
        expect(result).to_contain("\"test\"")

    it "creates JSON object":
        val result = tjo1(tjp("key", tjs("val")))
        expect(result).to_start_with("{")
        expect(result).to_end_with("}")

    it "parses initialize method with shared extractor behavior":
        val json = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"capabilities\":{},\"clientInfo\":{\"name\":\"probe\",\"version\":\"1.0\"}}}"
        expect(lsp_extract_field(json, "method")).to_equal("initialize")

    it "parses numeric id with shared extractor behavior":
        val json = "{\"jsonrpc\":\"2.0\",\"id\":42,\"method\":\"initialize\"}"
        expect(lsp_extract_id(json)).to_equal("42")

    it "parses nested params fields with shared extractor behavior":
        val json = "{\"method\":\"tools/call\",\"params\":{\"name\":\"cmm_parse\",\"arguments\":{\"source\":\"do main\"}}}"
        expect(lsp_extract_nested(json, "name")).to_equal("cmm_parse")
