# @cover src/app/test_daemon/session_scheduler.spl 80%
# @cover src/app/test_daemon/session_types.spl 60%
# @cover src/app/test_daemon/session_broker.spl 60%
#
# Test Daemon Session Scheduler Specification
#
# Tests the session scheduler that groups and prioritizes session-capable tests.
# Verifies schedule grouping, priority ordering, flattening, and queries.
#
# **Feature IDs:** #TDMN-SCH-001 to #TDMN-SCH-030
# **Category:** Infrastructure

use std.spec.{describe, it, expect, context, before_each}
use std.io_runtime

use app.test_daemon.session_types.{
    SessionKey, TestSessionMeta,
    SESSION_KIND_QEMU_VM, SESSION_KIND_CONTAINER, SESSION_KIND_SERVICE,
    SESSION_KIND_GUI, SESSION_KIND_LOCAL,
    REUSE_SHARED_READ_ONLY, REUSE_SHARED_WITH_RESET, REUSE_SHARED_WITH_SNAPSHOT,
    REUSE_EXCLUSIVE_REUSED, REUSE_FRESH_PER_TEST,
    RESET_NONE, RESET_SOFT, RESET_SNAPSHOT_RESTORE, RESET_RECREATE,
    test_session_meta_default, meta_to_session_key, session_kind_name,
    session_key_to_id
}
use app.test_daemon.session_scheduler.{
    ScheduleEntry, ScheduleGroup, SessionSchedule,
    schedule_session_tests, schedule_group_for_kind, schedule_total_session_tests,
    schedule_group_by_id, schedule_summary, schedule_flatten,
    schedule_session_file_paths, schedule_local_file_paths,
    reuse_priority
}

# ============================================================================
# Test Group 1: Priority Calculation
# ============================================================================

describe "Session Scheduler Priority Calculation":
    """
    ## Priority Ordering

    Read-only tests should have highest priority (lowest number),
    fresh-per-test should have lowest priority (highest number).
    """

    it "assigns priority 0 to shared_read_only (#TDMN-SCH-001)":
        val p = reuse_priority(REUSE_SHARED_READ_ONLY)
        expect(p).to_equal(0)

    it "assigns priority 1 to shared_with_snapshot (#TDMN-SCH-002)":
        val p = reuse_priority(REUSE_SHARED_WITH_SNAPSHOT)
        expect(p).to_equal(1)

    it "assigns priority 2 to shared_with_reset (#TDMN-SCH-003)":
        val p = reuse_priority(REUSE_SHARED_WITH_RESET)
        expect(p).to_equal(2)

    it "assigns priority 3 to exclusive_reused (#TDMN-SCH-004)":
        val p = reuse_priority(REUSE_EXCLUSIVE_REUSED)
        expect(p).to_equal(3)

    it "assigns priority 4 to fresh_per_test (#TDMN-SCH-005)":
        val p = reuse_priority(REUSE_FRESH_PER_TEST)
        expect(p).to_equal(4)

    it "assigns priority 5 to unknown reuse mode (#TDMN-SCH-006)":
        val p = reuse_priority(99)
        expect(p).to_equal(5)

# ============================================================================
# Test Group 2: Empty and Single-Entry Schedules
# ============================================================================

describe "Session Scheduler Empty and Single Entry":
    """
    ## Edge Cases

    Verify that the scheduler handles empty input and single tests correctly.
    """

    it "produces empty schedule from empty input (#TDMN-SCH-007)":
        var metas: [TestSessionMeta] = []
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_tests).to_equal(0)
        expect(schedule.total_groups).to_equal(0)
        expect(schedule.total_ungrouped).to_equal(0)

    it "puts a local test into ungrouped (#TDMN-SCH-008)":
        val meta = test_session_meta_default("test/specs/basic_spec.spl")
        var metas: [TestSessionMeta] = [meta]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_tests).to_equal(1)
        expect(schedule.total_groups).to_equal(0)
        expect(schedule.total_ungrouped).to_equal(1)

    it "puts a QEMU test into a group (#TDMN-SCH-009)":
        val meta = _make_qemu_meta("test/qemu/boot_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [meta]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_tests).to_equal(1)
        expect(schedule.total_groups).to_equal(1)
        expect(schedule.total_ungrouped).to_equal(0)

# ============================================================================
# Test Group 3: Grouping by Session Key
# ============================================================================

describe "Session Scheduler Grouping":
    """
    ## Session Key Grouping

    Tests with the same session key should be grouped together.
    Tests with different keys should be in separate groups.
    """

    it "groups two QEMU tests with same target into one group (#TDMN-SCH-010)":
        val meta1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val meta2 = _make_qemu_meta("test/qemu/b_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [meta1, meta2]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(1)
        val session_count = schedule_total_session_tests(schedule)
        expect(session_count).to_equal(2)

    it "separates QEMU tests with different targets (#TDMN-SCH-011)":
        val meta1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val meta2 = _make_qemu_meta("test/qemu/b_spec.spl", "arm32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [meta1, meta2]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(2)

    it "separates tests with different reuse modes even if same target (#TDMN-SCH-012)":
        val meta1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val meta2 = _make_qemu_meta("test/qemu/b_spec.spl", "riscv32", REUSE_FRESH_PER_TEST)
        var metas: [TestSessionMeta] = [meta1, meta2]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(2)

    it "groups container tests separately from QEMU tests (#TDMN-SCH-013)":
        val qemu = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val container = _make_container_meta("test/container/b_spec.spl", "simple-test:latest")
        var metas: [TestSessionMeta] = [qemu, container]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(2)

    it "separates local and session tests correctly (#TDMN-SCH-014)":
        val local1 = test_session_meta_default("test/unit/basic_spec.spl")
        val local2 = test_session_meta_default("test/unit/other_spec.spl")
        val qemu = _make_qemu_meta("test/qemu/boot_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [local1, qemu, local2]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(1)
        expect(schedule.total_ungrouped).to_equal(2)

# ============================================================================
# Test Group 4: Priority Ordering
# ============================================================================

describe "Session Scheduler Priority Ordering":
    """
    ## Group Ordering

    Groups should be sorted by priority: read-only first, fresh-per-test last.
    """

    it "orders read-only groups before fresh-per-test groups (#TDMN-SCH-015)":
        val fresh = _make_qemu_meta("test/qemu/fresh_spec.spl", "x86_64", REUSE_FRESH_PER_TEST)
        val readonly = _make_qemu_meta("test/qemu/readonly_spec.spl", "arm32", REUSE_SHARED_READ_ONLY)
        # Insert fresh first, but scheduler should reorder
        var metas: [TestSessionMeta] = [fresh, readonly]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(2)
        val groups = schedule.groups
        val first_priority = groups[0].priority
        val second_priority = groups[1].priority
        expect(first_priority).to_be_less_than(second_priority)

    it "orders snapshot groups before reset groups (#TDMN-SCH-016)":
        val reset = _make_qemu_meta("test/qemu/reset_spec.spl", "mips", REUSE_SHARED_WITH_RESET)
        val snapshot = _make_qemu_meta("test/qemu/snap_spec.spl", "aarch64", REUSE_SHARED_WITH_SNAPSHOT)
        var metas: [TestSessionMeta] = [reset, snapshot]
        val schedule = schedule_session_tests(metas)
        val groups = schedule.groups
        expect(groups[0].priority).to_be_less_than(groups[1].priority)

    it "maintains stable order for equal priorities (#TDMN-SCH-017)":
        val meta1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val meta2 = _make_qemu_meta("test/qemu/b_spec.spl", "arm32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [meta1, meta2]
        val schedule = schedule_session_tests(metas)
        val groups = schedule.groups
        # Both have same priority; first inserted should remain first
        expect(groups[0].priority).to_equal(groups[1].priority)

# ============================================================================
# Test Group 5: Flatten and Path Queries
# ============================================================================

describe "Session Scheduler Flatten and Queries":
    """
    ## Flattening and Queries

    Verify that the schedule can be flattened to ordered file lists
    and that query functions work correctly.
    """

    it "flattens session groups before ungrouped (#TDMN-SCH-018)":
        val local = test_session_meta_default("test/unit/local_spec.spl")
        val qemu = _make_qemu_meta("test/qemu/boot_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [local, qemu]
        val schedule = schedule_session_tests(metas)
        val flat = schedule_flatten(schedule)
        expect(flat.len()).to_equal(2)
        # Session tests come first
        expect(flat[0]).to_equal("test/qemu/boot_spec.spl")
        expect(flat[1]).to_equal("test/unit/local_spec.spl")

    it "returns only session file paths (#TDMN-SCH-019)":
        val local = test_session_meta_default("test/unit/local_spec.spl")
        val qemu = _make_qemu_meta("test/qemu/boot_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [local, qemu]
        val schedule = schedule_session_tests(metas)
        val paths = schedule_session_file_paths(schedule)
        expect(paths.len()).to_equal(1)
        expect(paths[0]).to_equal("test/qemu/boot_spec.spl")

    it "returns only local file paths (#TDMN-SCH-020)":
        val local = test_session_meta_default("test/unit/local_spec.spl")
        val qemu = _make_qemu_meta("test/qemu/boot_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [local, qemu]
        val schedule = schedule_session_tests(metas)
        val paths = schedule_local_file_paths(schedule)
        expect(paths.len()).to_equal(1)
        expect(paths[0]).to_equal("test/unit/local_spec.spl")

    it "counts total session tests across groups (#TDMN-SCH-021)":
        val q1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val q2 = _make_qemu_meta("test/qemu/b_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val c1 = _make_container_meta("test/container/c_spec.spl", "simple-test:latest")
        var metas: [TestSessionMeta] = [q1, q2, c1]
        val schedule = schedule_session_tests(metas)
        val total = schedule_total_session_tests(schedule)
        expect(total).to_equal(3)

    it "finds groups by kind (#TDMN-SCH-022)":
        val q1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val c1 = _make_container_meta("test/container/c_spec.spl", "simple-test:latest")
        var metas: [TestSessionMeta] = [q1, c1]
        val schedule = schedule_session_tests(metas)
        val qemu_groups = schedule_group_for_kind(schedule, SESSION_KIND_QEMU_VM)
        val container_groups = schedule_group_for_kind(schedule, SESSION_KIND_CONTAINER)
        expect(qemu_groups.len()).to_equal(1)
        expect(container_groups.len()).to_equal(1)

    it "returns empty for nonexistent group id (#TDMN-SCH-023)":
        val q1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [q1]
        val schedule = schedule_session_tests(metas)
        val entries = schedule_group_by_id(schedule, "nonexistent_group_id")
        expect(entries.len()).to_equal(0)

# ============================================================================
# Test Group 6: Summary and Mixed Scenarios
# ============================================================================

describe "Session Scheduler Summary and Mixed":
    """
    ## Summary Output and Complex Scenarios

    Test the human-readable summary and multi-kind mixed inputs.
    """

    it "produces a non-empty summary (#TDMN-SCH-024)":
        val q1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        var metas: [TestSessionMeta] = [q1]
        val schedule = schedule_session_tests(metas)
        val summary = schedule_summary(schedule)
        expect(summary.len()).to_be_greater_than(0)
        expect(summary).to_contain("Session Schedule:")
        expect(summary).to_contain("Total tests: 1")

    it "handles mixed QEMU, container, service, and local tests (#TDMN-SCH-025)":
        val local1 = test_session_meta_default("test/unit/a_spec.spl")
        val local2 = test_session_meta_default("test/unit/b_spec.spl")
        val q1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val q2 = _make_qemu_meta("test/qemu/b_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val c1 = _make_container_meta("test/container/c_spec.spl", "simple-test:latest")
        val s1 = _make_service_meta("test/service/health_spec.spl", "local_web")
        var metas: [TestSessionMeta] = [local1, q1, c1, local2, s1, q2]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_tests).to_equal(6)
        expect(schedule.total_ungrouped).to_equal(2)
        expect(schedule.total_groups).to_equal(3)
        val session_count = schedule_total_session_tests(schedule)
        expect(session_count).to_equal(4)

    it "all session paths appear exactly once in flatten (#TDMN-SCH-026)":
        val local = test_session_meta_default("test/unit/a_spec.spl")
        val q1 = _make_qemu_meta("test/qemu/a_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val q2 = _make_qemu_meta("test/qemu/b_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY)
        val c1 = _make_container_meta("test/container/c_spec.spl", "simple-test:latest")
        var metas: [TestSessionMeta] = [local, q1, q2, c1]
        val schedule = schedule_session_tests(metas)
        val flat = schedule_flatten(schedule)
        expect(flat.len()).to_equal(4)
        # All 4 unique paths should be present
        var found_q1 = false
        var found_q2 = false
        var found_c1 = false
        var found_local = false
        for path in flat:
            if path == "test/qemu/a_spec.spl": found_q1 = true
            if path == "test/qemu/b_spec.spl": found_q2 = true
            if path == "test/container/c_spec.spl": found_c1 = true
            if path == "test/unit/a_spec.spl": found_local = true
        expect(found_q1).to_equal(true)
        expect(found_q2).to_equal(true)
        expect(found_c1).to_equal(true)
        expect(found_local).to_equal(true)

    it "scheduler handles many tests in same group (#TDMN-SCH-027)":
        var metas: [TestSessionMeta] = []
        var i = 0
        while i < 20:
            metas.push(_make_qemu_meta("test/qemu/test_{i}_spec.spl", "riscv32", REUSE_SHARED_READ_ONLY))
            i = i + 1
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(1)
        val session_count = schedule_total_session_tests(schedule)
        expect(session_count).to_equal(20)

# ============================================================================
# Test Group 7: Service and GUI Session Scheduling
# ============================================================================

describe "Session Scheduler Service and GUI":
    """
    ## Service and GUI Tests

    Verify that service process and GUI session tests are scheduled correctly.
    """

    it "groups service tests by target (#TDMN-SCH-028)":
        val s1 = _make_service_meta("test/service/a_spec.spl", "local_web")
        val s2 = _make_service_meta("test/service/b_spec.spl", "local_web")
        val s3 = _make_service_meta("test/service/c_spec.spl", "remote_api")
        var metas: [TestSessionMeta] = [s1, s2, s3]
        val schedule = schedule_session_tests(metas)
        val service_groups = schedule_group_for_kind(schedule, SESSION_KIND_SERVICE)
        expect(service_groups.len()).to_equal(2)

    it "schedules GUI tests as exclusive_reused (#TDMN-SCH-029)":
        val gui = _make_gui_meta("test/gui/window_spec.spl", "headless")
        var metas: [TestSessionMeta] = [gui]
        val schedule = schedule_session_tests(metas)
        expect(schedule.total_groups).to_equal(1)
        val groups = schedule.groups
        expect(groups[0].priority).to_equal(reuse_priority(REUSE_EXCLUSIVE_REUSED))

    it "orders service read-only before GUI exclusive (#TDMN-SCH-030)":
        val gui = _make_gui_meta("test/gui/window_spec.spl", "headless")
        val svc = _make_service_meta("test/service/api_spec.spl", "local_web")
        var metas: [TestSessionMeta] = [gui, svc]
        val schedule = schedule_session_tests(metas)
        val groups = schedule.groups
        # Service (read_only, priority 0) should be before GUI (exclusive, priority 3)
        expect(groups[0].priority).to_be_less_than(groups[1].priority)

# ============================================================================
# Helper Functions
# ============================================================================

fn _make_qemu_meta(path: text, target: text, reuse: i64) -> TestSessionMeta:
    TestSessionMeta(
        file_path: path,
        session_kind: SESSION_KIND_QEMU_VM,
        target: target,
        reuse_mode: reuse,
        reset_policy: if reuse == REUSE_SHARED_WITH_SNAPSHOT: RESET_SNAPSHOT_RESTORE elif reuse == REUSE_SHARED_WITH_RESET: RESET_SOFT else: RESET_NONE,
        artifact: "",
        startup_cmd: "",
        healthcheck: ""
    )

fn _make_container_meta(path: text, image: text) -> TestSessionMeta:
    TestSessionMeta(
        file_path: path,
        session_kind: SESSION_KIND_CONTAINER,
        target: image,
        reuse_mode: REUSE_EXCLUSIVE_REUSED,
        reset_policy: RESET_RECREATE,
        artifact: "",
        startup_cmd: "",
        healthcheck: ""
    )

fn _make_service_meta(path: text, target: text) -> TestSessionMeta:
    TestSessionMeta(
        file_path: path,
        session_kind: SESSION_KIND_SERVICE,
        target: target,
        reuse_mode: REUSE_SHARED_READ_ONLY,
        reset_policy: RESET_NONE,
        artifact: "",
        startup_cmd: "",
        healthcheck: ""
    )

fn _make_gui_meta(path: text, mode: text) -> TestSessionMeta:
    TestSessionMeta(
        file_path: path,
        session_kind: SESSION_KIND_GUI,
        target: mode,
        reuse_mode: REUSE_EXCLUSIVE_REUSED,
        reset_policy: RESET_SOFT,
        artifact: "",
        startup_cmd: "",
        healthcheck: ""
    )
