# Regression spec for paren-form call followed by indented colon-block.
#
# Before the fix, `describe("x"):` with an indented body leaked the trailing
# colon back to the statement parser, producing
#   "parse error: Unexpected token: expected expression, found Colon"
# because parse_with_no_paren_calls only attached a colon-block to plain
# Identifier/FieldAccess/Path callees, not to already-built Call/MethodCall
# expressions.
#
# See: src/compiler_rust/parser/src/expressions/no_paren.rs
# Found via: test/os/kernel/arch/syscall_dispatch_spec.spl (Wave 10B)

use std.spec.{describe, it, expect_eq, expect_true}

describe("paren-form describe block parses"):
    it("accepts describe(string): with indented body"):
        expect_eq(1, 1)

    it("accepts it(string): with indented body"):
        expect_true(true)

    it("accepts val with type annotation at module level"):
        val X: u64 = 0
        val Y:  u64 = 1
        val Z:                u64 = 2
        expect_eq(X, 0)
        expect_eq(Y, 1)
        expect_eq(Z, 2)
