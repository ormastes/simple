# @cover src/compiler/90.tools/duplicate_check/debug.spl 80%
"""
# Duplicate Check Debug Helpers Specification

**Feature IDs:** N/A
**Category:** Tooling
**Status:** Implemented

## Overview

Tests the debug flag helpers used by the duplicate detection tool.
The helpers read `SIMPLE_DUP_DEBUG` env var on demand and provide
throttled progress logging.

## Key Concepts

| Concept         | Description                                      |
|-----------------|--------------------------------------------------|
| get_debug_flag  | Returns true when SIMPLE_DUP_DEBUG is "1"/"true" |
| debug_log       | Emits message only when tracing is on            |
| debug_log_progress | Throttles output to every 10th step           |
"""

use compiler.tools.duplicate_check.debug.{get_debug_flag, debug_log, debug_log_progress, init_debug}


# ============================================================================
# Test Group 1: Debug Flag Reading
# ============================================================================

describe "Duplicate Check Debug Flag":
    it "get_debug_flag returns bool":
        val flag = get_debug_flag()
        expect(flag == true or flag == false).to_equal(true)

    it "get_debug_flag defaults to false when env unset":
        val flag = get_debug_flag()
        expect(flag).to_equal(false)


# ============================================================================
# Test Group 2: Debug Functions Do Not Error
# ============================================================================

describe "Duplicate Check Debug Functions":
    it "init_debug does not error":
        init_debug()
        expect(true).to_equal(true)

    it "debug_log does not error when debug is off":
        debug_log("test message")
        expect(true).to_equal(true)

    it "debug_log_progress does not error when debug is off":
        debug_log_progress(0, 10, "scanning")
        debug_log_progress(5, 10, "scanning")
        debug_log_progress(10, 10, "scanning")
        expect(true).to_equal(true)
