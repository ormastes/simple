class HardwareAttr:
    kind: text
    is_clocked: bool
    entity_name: text
    label_count: i32
    l0_name: text
    l1_name: text

class ReturnLabel:
    name: text
    bit_width: i32
    is_output: bool

class CallLowerResult:
    success: bool
    error_reason: text
    is_indirect: bool

class BitSlice:
    source_width: i32
    high_bit: i32
    low_bit: i32
    result_width: i32

class InstructionFormat:
    format_name: text
    has_rd: bool
    has_rs1: bool
    has_rs2: bool
    imm_width: i32

class AluControl:
    op_name: text
    funct3: i32
    is_immediate: bool

class DecodeResult:
    alu_op: text
    has_writeback: bool
    mem_read: bool
    branch: bool

class RegisterFile:
    depth: i32
    width: i32
    read_ports: i32
    write_ports: i32
    has_zero_reg: bool

class MemoryInference:
    kind: text
    depth: i32
    width: i32
    is_readonly: bool
    is_synchronous: bool

class ClockDomain:
    name: text
    reset_kind: text
    is_async_reset: bool

class PortBundle:
    bundle_name: text
    port_count: i32
    p0_name: text
    p0_dir: text
    p1_name: text
    p1_dir: text

class TestbenchSpec:
    entity_name: text
    clock_period_ns: i32
    sim_cycles: i32
    has_assertions: bool

class SimulationResult:
    entity_name: text
    passed: bool
    cycles_run: i32
    ghdl_exit_code: i32

fn test_hardware_attr_kind():
    var attr = HardwareAttr(kind: "hardware", is_clocked: false, entity_name: "alu", label_count: 0, l0_name: "", l1_name: "")
    var is_hardware = attr.kind == "hardware"
    if is_hardware:
        print("PASS: test_hardware_attr_kind")
    else:
        print("FAIL: test_hardware_attr_kind")

fn test_hardware_clocked():
    var attr = HardwareAttr(kind: "hardware", is_clocked: true, entity_name: "reg", label_count: 0, l0_name: "", l1_name: "")
    if attr.is_clocked:
        print("PASS: test_hardware_clocked")
    else:
        print("FAIL: test_hardware_clocked")

fn test_duplicate_label():
    var attr = HardwareAttr(kind: "hardware", is_clocked: false, entity_name: "comp", label_count: 2, l0_name: "sum", l1_name: "sum")
    var has_dup = attr.l0_name == attr.l1_name
    if has_dup:
        print("PASS: test_duplicate_label")
    else:
        print("FAIL: test_duplicate_label")

fn test_return_label_output():
    var lbl = ReturnLabel(name: "result", bit_width: 8, is_output: true)
    var dir = "in"
    if lbl.is_output:
        dir = "out"
    if dir == "out":
        print("PASS: test_return_label_output")
    else:
        print("FAIL: test_return_label_output")

fn test_return_label_vhdl_1bit():
    var lbl = ReturnLabel(name: "flag", bit_width: 1, is_output: true)
    if lbl.bit_width == 1:
        print("PASS: test_return_label_vhdl_1bit")
    else:
        print("FAIL: test_return_label_vhdl_1bit")

fn test_call_lower_ok():
    var r = CallLowerResult(success: true, error_reason: "", is_indirect: false)
    if r.success:
        print("PASS: test_call_lower_ok")
    else:
        print("FAIL: test_call_lower_ok")

fn test_call_lower_indirect_reject():
    var r = CallLowerResult(success: false, error_reason: "indirect not supported", is_indirect: true)
    var is_rejected = r.is_indirect == true and r.success == false
    if is_rejected:
        print("PASS: test_call_lower_indirect_reject")
    else:
        print("FAIL: test_call_lower_indirect_reject")

fn test_bit_slice_opcode():
    var s = BitSlice(source_width: 32, high_bit: 6, low_bit: 0, result_width: 7)
    var valid = s.high_bit >= s.low_bit and s.result_width == (s.high_bit - s.low_bit + 1)
    if valid:
        print("PASS: test_bit_slice_opcode")
    else:
        print("FAIL: test_bit_slice_opcode")

fn test_bit_slice_funct3():
    var s = BitSlice(source_width: 32, high_bit: 14, low_bit: 12, result_width: 3)
    var valid = s.high_bit >= s.low_bit and s.result_width == (s.high_bit - s.low_bit + 1)
    if valid:
        print("PASS: test_bit_slice_funct3")
    else:
        print("FAIL: test_bit_slice_funct3")

fn test_instruction_r_type():
    var f = InstructionFormat(format_name: "R", has_rd: true, has_rs1: true, has_rs2: true, imm_width: 0)
    var ok = f.has_rd and f.has_rs1 and f.has_rs2 and f.imm_width == 0
    if ok:
        print("PASS: test_instruction_r_type")
    else:
        print("FAIL: test_instruction_r_type")

fn test_instruction_i_type():
    var f = InstructionFormat(format_name: "I", has_rd: true, has_rs1: true, has_rs2: false, imm_width: 12)
    var has_immediate = f.imm_width > 0
    if has_immediate:
        print("PASS: test_instruction_i_type")
    else:
        print("FAIL: test_instruction_i_type")

fn test_alu_add():
    var a = AluControl(op_name: "ADD", funct3: 0, is_immediate: false)
    var is_add = a.op_name == "ADD"
    if is_add:
        print("PASS: test_alu_add")
    else:
        print("FAIL: test_alu_add")

fn test_decode_load():
    var d = DecodeResult(alu_op: "ADD", has_writeback: true, mem_read: true, branch: false)
    var is_memory = d.mem_read
    if is_memory:
        print("PASS: test_decode_load")
    else:
        print("FAIL: test_decode_load")

fn test_decode_branch():
    var d = DecodeResult(alu_op: "SUB", has_writeback: false, mem_read: false, branch: true)
    var is_control_flow = d.branch
    if is_control_flow:
        print("PASS: test_decode_branch")
    else:
        print("FAIL: test_decode_branch")

fn test_regfile_rv32():
    var rf = RegisterFile(depth: 32, width: 32, read_ports: 2, write_ports: 1, has_zero_reg: true)
    var is_rv32 = rf.depth == 32 and rf.width == 32 and rf.has_zero_reg
    if is_rv32:
        print("PASS: test_regfile_rv32")
    else:
        print("FAIL: test_regfile_rv32")

fn test_regfile_synthesizable():
    var rf = RegisterFile(depth: 32, width: 32, read_ports: 2, write_ports: 1, has_zero_reg: true)
    var synthesizable = rf.read_ports == 2 and rf.write_ports == 1
    if synthesizable:
        print("PASS: test_regfile_synthesizable")
    else:
        print("FAIL: test_regfile_synthesizable")

fn test_memory_rom():
    var m = MemoryInference(kind: "rom", depth: 1024, width: 32, is_readonly: true, is_synchronous: true)
    var is_rom = m.kind == "rom" and m.is_readonly
    if is_rom:
        print("PASS: test_memory_rom")
    else:
        print("FAIL: test_memory_rom")

fn test_clock_default():
    var c = ClockDomain(name: "clk", reset_kind: "sync", is_async_reset: false)
    var has_reset = c.reset_kind == "none" == false
    if has_reset:
        print("PASS: test_clock_default")
    else:
        print("FAIL: test_clock_default")

fn test_port_bundle_imem():
    var pb = PortBundle(bundle_name: "imem", port_count: 3, p0_name: "addr", p0_dir: "out", p1_name: "data", p1_dir: "in")
    var has_outputs = pb.p0_dir == "out"
    if has_outputs:
        print("PASS: test_port_bundle_imem")
    else:
        print("FAIL: test_port_bundle_imem")

fn test_simulation_pass():
    var sr = SimulationResult(entity_name: "alu_tb", passed: true, cycles_run: 100, ghdl_exit_code: 0)
    var is_pass = sr.passed and sr.ghdl_exit_code == 0
    if is_pass:
        print("PASS: test_simulation_pass")
    else:
        print("FAIL: test_simulation_pass")

fn main():
    test_hardware_attr_kind()
    test_hardware_clocked()
    test_duplicate_label()
    test_return_label_output()
    test_return_label_vhdl_1bit()
    test_call_lower_ok()
    test_call_lower_indirect_reject()
    test_bit_slice_opcode()
    test_bit_slice_funct3()
    test_instruction_r_type()
    test_instruction_i_type()
    test_alu_add()
    test_decode_load()
    test_decode_branch()
    test_regfile_rv32()
    test_regfile_synthesizable()
    test_memory_rom()
    test_clock_default()
    test_port_bundle_imem()
    test_simulation_pass()
    print("DONE")
