# Regression spec for: seed compiler self.field.method() resolution bug
#
# Expected: self.inner.foo() dispatches to Inner.foo(), returns 42
# Actual (pre-fix): method call on field-access receiver either
#   (a) lowers receiver type to ANY → lookup_method_return_type fails silently, or
#   (b) MIR mangler resolves to the enclosing method name → infinite recursion
#
# Fix landed in src/compiler_rust/compiler/src/hir/lower/expr/access.rs

struct Inner:
    value: i32

    fn foo() -> i32: self.value

struct Outer:
    inner: Inner

    fn trigger() -> i32: self.inner.foo()

fn make_outer(v: i32) -> Outer:
    val inner_val = Inner(value: v)
    Outer(inner: inner_val)

describe "self.field.method() resolution":
    it "dispatches through struct field to correct method":
        val outer_val = make_outer(42)
        val result = outer_val.trigger()
        expect(result).to_equal(42)

    it "two-level chained field method call returns correct value":
        val outer_val = make_outer(7)
        val result = outer_val.trigger()
        expect(result).to_equal(7)

    it "field method result used in arithmetic":
        val outer_val = make_outer(10)
        val doubled = outer_val.trigger() * 2
        expect(doubled).to_equal(20)
