use std.spec.{describe, it, expect}

bitfield TestFlags(u32):
    a: 4
    b: 28

describe "bitfield existing syntax e2e":
    it "round-trips field read/write":
        var f: TestFlags = TestFlags.new(0)
        f.a = 3
        expect(f.a).to_equal(3)

    it "preserves adjacent fields on write":
        var f: TestFlags = TestFlags.new(0)
        f.a = 3
        f.b = 5
        expect(f.a).to_equal(3)
        expect(f.b).to_equal(5)
