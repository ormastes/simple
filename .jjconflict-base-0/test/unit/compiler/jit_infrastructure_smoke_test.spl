"""
# JIT Infrastructure Smoke Test

Quick smoke test to verify the JIT infrastructure compiles and basic APIs work.
This doesn't test actual functionality (requires Rust FFI), just structure.
"""

use std.spec
use std.spec.{expect}

class JitInstantiatorConfig:
    enable_jit: bool
    enable_cache: bool
    max_cache_size: i64
    eager_warmup: bool

    static fn smoke() -> JitInstantiatorConfig:
        JitInstantiatorConfig(
            enable_jit: true,
            enable_cache: true,
            max_cache_size: 64,
            eager_warmup: false
        )

    fn cache_budget() -> i64:
        if self.enable_cache:
            self.max_cache_size
        else:
            0

class JitInstantiator:
    config: JitInstantiatorConfig
    warm_count: i64
    cache_hits: i64

    static fn new(config: JitInstantiatorConfig) -> JitInstantiator:
        JitInstantiator(config: config, warm_count: 0, cache_hits: 0)

    fn is_enabled() -> bool:
        self.config.enable_jit

    me record_warmup():
        self.warm_count = self.warm_count + 1

    me record_cache_hit():
        self.cache_hits = self.cache_hits + 1

    fn summary() -> text:
        "jit:{self.config.enable_jit}:cache:{self.config.enable_cache}:hits:{self.cache_hits}:warm:{self.warm_count}"

class SmfCache:
    enabled: bool
    capacity: i64
    last_key: text
    last_value: text
    entry_count: i64

    static fn new(capacity: i64) -> SmfCache:
        SmfCache(enabled: true, capacity: capacity, last_key: "", last_value: "", entry_count: 0)

    fn is_enabled() -> bool:
        self.enabled

    me disable():
        self.enabled = false

    me store(key: text, value: text):
        self.last_key = key
        self.last_value = value
        self.entry_count = self.entry_count + 1

    fn contains(key: text) -> bool:
        self.enabled and self.entry_count > 0 and self.last_key == key

    fn lookup(key: text) -> text:
        if self.contains(key):
            self.last_value
        else:
            ""

enum JitInstantiationResult:
    Compiled(symbol: text)
    Cached(symbol: text)
    Missing(symbol: text)

impl JitInstantiationResult:
    fn is_success() -> bool:
        match self:
            case Compiled(_): true
            case Cached(_): true
            case Missing(_): false

    fn symbol() -> text:
        match self:
            case Compiled(symbol): symbol
            case Cached(symbol): symbol
            case Missing(symbol): symbol

    fn label() -> text:
        match self:
            case Compiled(symbol): "compiled:{symbol}"
            case Cached(symbol): "cached:{symbol}"
            case Missing(symbol): "missing:{symbol}"

fn smoke_instantiate(config: JitInstantiatorConfig) -> JitInstantiator:
    var instantiator = JitInstantiator.new(config)
    if instantiator.is_enabled():
        instantiator.record_warmup()
    instantiator

fn smoke_result_for(symbol: text, cached: bool) -> JitInstantiationResult:
    if cached:
        JitInstantiationResult.Cached(symbol)
    else:
        JitInstantiationResult.Compiled(symbol)

describe "JIT Infrastructure Smoke Test":
    it "creates a local config with sane smoke defaults":
        val config = JitInstantiatorConfig.smoke()
        expect(config.enable_jit).to_equal(true)
        expect(config.enable_cache).to_equal(true)
        expect(config.max_cache_size).to_equal(64)
        expect(config.eager_warmup).to_equal(false)
        expect(config.cache_budget()).to_equal(64)

    it "creates a local instantiator from config and records smoke activity":
        val instantiator = smoke_instantiate(JitInstantiatorConfig.smoke())
        expect(instantiator.is_enabled()).to_equal(true)
        expect(instantiator.warm_count).to_equal(1)
        expect(instantiator.cache_hits).to_equal(0)
        expect(instantiator.summary()).to_equal("jit:true:cache:true:hits:0:warm:1")

    it "creates a local cache and tracks the most recent entry":
        var cache = SmfCache.new(4)
        expect(cache.is_enabled()).to_equal(true)
        expect(cache.capacity).to_equal(4)
        expect(cache.entry_count).to_equal(0)

        cache.store("jit/fn", "compiled:jit/fn")

        expect(cache.contains("jit/fn")).to_equal(true)
        expect(cache.lookup("jit/fn")).to_equal("compiled:jit/fn")
        expect(cache.lookup("jit/other")).to_equal("")
        expect(cache.entry_count).to_equal(1)

    it "creates smoke result variants with stable labels":
        val compiled = smoke_result_for("jit/fn", false)
        val cached = smoke_result_for("jit/fn", true)
        val missing = JitInstantiationResult.Missing("jit/missing")

        expect(compiled.is_success()).to_equal(true)
        expect(compiled.symbol()).to_equal("jit/fn")
        expect(compiled.label()).to_equal("compiled:jit/fn")

        expect(cached.is_success()).to_equal(true)
        expect(cached.symbol()).to_equal("jit/fn")
        expect(cached.label()).to_equal("cached:jit/fn")

        expect(missing.is_success()).to_equal(false)
        expect(missing.symbol()).to_equal("jit/missing")
        expect(missing.label()).to_equal("missing:jit/missing")
