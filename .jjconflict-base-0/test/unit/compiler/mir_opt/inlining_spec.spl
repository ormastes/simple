# # MIR Optimization - Inlining Tests
#
# **Feature ID:** #COMPILER-MIROPT-003
# **Category:** Compiler | MIR Optimization
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

fn identity(x: i64) -> i64:
    x

fn add_one(x: i64) -> i64:
    x + 1

fn max_val(a: i64, b: i64) -> i64:
    if a > b:
        a
    else:
        b

fn min_val(a: i64, b: i64) -> i64:
    if a < b:
        a
    else:
        b

fn abs_val(x: i64) -> i64:
    if x < 0:
        -x
    else:
        x

fn clamp(x: i64, lo: i64, hi: i64) -> i64:
    if x < lo:
        lo
    elif x > hi:
        hi
    else:
        x

describe "Simple Function Inlining":
    it "inline identity function":
        check(identity(42) == 42)

    it "inline add_one function":
        check(add_one(41) == 42)

    it "inline with zero":
        check(add_one(0) == 1)

    it "inline with negative":
        check(add_one(-1) == 0)

describe "Branching Function Inlining":
    it "inline max - first larger":
        check(max_val(10, 5) == 10)

    it "inline max - second larger":
        check(max_val(5, 10) == 10)

    it "inline max - equal":
        check(max_val(5, 5) == 5)

    it "inline min - first smaller":
        check(min_val(3, 7) == 3)

    it "inline min - second smaller":
        check(min_val(7, 3) == 3)

    it "inline abs - positive":
        check(abs_val(5) == 5)

    it "inline abs - negative":
        check(abs_val(-5) == 5)

    it "inline abs - zero":
        check(abs_val(0) == 0)

describe "Multi-branch Inlining":
    it "clamp within range":
        check(clamp(5, 0, 10) == 5)

    it "clamp below minimum":
        check(clamp(-5, 0, 10) == 0)

    it "clamp above maximum":
        check(clamp(15, 0, 10) == 10)

    it "clamp at minimum":
        check(clamp(0, 0, 10) == 0)

    it "clamp at maximum":
        check(clamp(10, 0, 10) == 10)

describe "Nested Call Inlining":
    it "inline nested calls":
        check(add_one(add_one(40)) == 42)

    it "inline max of add_one":
        check(max_val(add_one(5), add_one(3)) == 6)

    it "inline chained operations":
        val result = abs_val(min_val(-3, -5))
        check(result == 5)

    it "deeply nested inlining":
        check(add_one(add_one(add_one(add_one(0)))) == 4)
