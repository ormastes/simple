# test/unit/compiler/backend/avx2_int_emit_spec.spl
#
# Byte-level golden tests for AVX2 YMM integer instruction emit functions.
# Verifies emit_vpaddd_ymm, emit_vpsubd_ymm, emit_vpmulld_ymm,
# emit_vpand_ymm, emit_vpor_ymm, emit_vpxor_ymm,
# emit_vpsrld_ymm_imm, emit_vpslld_ymm_imm
# produce exact Intel SDM byte sequences.
#
# All goldens derived from VEX-3 encoding formula and cross-checked:
#   Byte 0: 0xC4 (3-byte VEX escape)
#   Byte 1: ~R ~X ~B mmmmm  (225=0xE1 for 0F map; 226=0xE2 for 0F38 map)
#   Byte 2: W ~vvvv L pp    (W=0, L=1 YMM, pp=01/66; formula: (15-vvvv)*8+5)
#   Byte N: ModRM direct    (192 + reg%8*8 + rm%8)
#
# Note: llvm-mc may emit 2-byte VEX (C5h) for all-low-register ops; these
# tests always verify the 3-byte (C4h) form the emitter produces.
#
# Reference: Intel SDM Vol 2C VPADDD/VPSUBD/VPMULLD/VPAND/VPOR/VPXOR/VPSRLD/VPSLLD;
#            Intel SDM Vol 2A §2.3.5 (VEX prefix).

import std.spec

use compiler.backend.native.encode_x86_64_avx2_int.{
    emit_vpaddd_ymm,
    emit_vpsubd_ymm,
    emit_vpmulld_ymm,
    emit_vpand_ymm,
    emit_vpor_ymm,
    emit_vpxor_ymm,
    emit_vpsrld_ymm_imm,
    emit_vpslld_ymm_imm
}

# ============================================================================
# VPADDD — VEX.256.66.0F.WIG FE /r
# emit_vpaddd_ymm(rd, rn, rm): rn→vvvv, rd→ModRM.reg, rm→ModRM.rm
# ============================================================================

describe "AVX2 emit_vpaddd_ymm ymm0 ymm1 ymm2 golden":
    # vpaddd ymm0, ymm1, ymm2 → [0xC4, 0xE1, 0x75, 0xFE, 0xC2]
    # byte1: ~R=1,~X=1,~B=1,mmmmm=1 → 225
    # byte2: W=0,~vvvv=14(rn=1),L=1,pp=01 → 14*8+5=117
    # ModRM: mod=11,reg=0,rm=2 → 194
    it "emits 5 bytes":
        val result = emit_vpaddd_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte0 is VEX 3-byte escape 0xC4":
        val result = emit_vpaddd_ymm(0, 1, 2)
        expect result[0] == 196

    it "byte1 is 0xE1 (~R=1 ~X=1 ~B=1 mmmmm=1)":
        val result = emit_vpaddd_ymm(0, 1, 2)
        expect result[1] == 225

    it "byte2 is 0x75 (W=0 ~vvvv=14 L=1 pp=01)":
        val result = emit_vpaddd_ymm(0, 1, 2)
        expect result[2] == 117

    it "byte3 is opcode 0xFE":
        val result = emit_vpaddd_ymm(0, 1, 2)
        expect result[3] == 254

    it "byte4 is ModRM 0xC2 (mod=11 reg=0 rm=2)":
        val result = emit_vpaddd_ymm(0, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpaddd_ymm extended dst ymm8":
    # vpaddd ymm8, ymm1, ymm2 → [0xC4, 0x61, 0x75, 0xFE, 0xC2]
    # byte1: ~R=0(rd=8>=8),~X=1,~B=1,mmmmm=1 → 225-128=97
    it "byte1 is 0x61 (~R=0 ~X=1 ~B=1 mmmmm=1)":
        val result = emit_vpaddd_ymm(8, 1, 2)
        expect result[1] == 97

    it "byte2 unchanged at 0x75":
        val result = emit_vpaddd_ymm(8, 1, 2)
        expect result[2] == 117

    it "byte4 is ModRM 0xC2 (mod=11 reg=0 rm=2)":
        # reg=8%8=0, rm=2%8=2 → 194
        val result = emit_vpaddd_ymm(8, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpaddd_ymm extended rn ymm9":
    # vpaddd ymm0, ymm9, ymm2 → [0xC4, 0xE1, 0x35, 0xFE, 0xC2]
    # byte2: ~vvvv=(15-9)=6, L=1, pp=01 → 6*8+5=53
    it "byte2 is 0x35 (W=0 ~vvvv=6 L=1 pp=01)":
        val result = emit_vpaddd_ymm(0, 9, 2)
        expect result[2] == 53

describe "AVX2 emit_vpaddd_ymm extended rm ymm8":
    # vpaddd ymm0, ymm1, ymm8 → [0xC4, 0xC1, 0x75, 0xFE, 0xC0]
    # byte1: ~R=1,~X=1,~B=0(rm=8>=8),mmmmm=1 → 225-32=193
    # ModRM: mod=11,reg=0,rm=0(8%8) → 192
    it "byte1 is 0xC1 (~R=1 ~X=1 ~B=0 mmmmm=1)":
        val result = emit_vpaddd_ymm(0, 1, 8)
        expect result[1] == 193

    it "byte4 is ModRM 0xC0 (mod=11 reg=0 rm=0)":
        val result = emit_vpaddd_ymm(0, 1, 8)
        expect result[4] == 192

# ============================================================================
# VPSUBD — VEX.256.66.0F.WIG FA /r
# ============================================================================

describe "AVX2 emit_vpsubd_ymm ymm0 ymm1 ymm2 golden":
    # vpsubd ymm0, ymm1, ymm2 → [0xC4, 0xE1, 0x75, 0xFA, 0xC2]
    it "emits 5 bytes":
        val result = emit_vpsubd_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte0 is 0xC4":
        val result = emit_vpsubd_ymm(0, 1, 2)
        expect result[0] == 196

    it "byte1 is 0xE1":
        val result = emit_vpsubd_ymm(0, 1, 2)
        expect result[1] == 225

    it "byte2 is 0x75 (W=0 ~vvvv=14 L=1 pp=01)":
        val result = emit_vpsubd_ymm(0, 1, 2)
        expect result[2] == 117

    it "byte3 is opcode 0xFA":
        val result = emit_vpsubd_ymm(0, 1, 2)
        expect result[3] == 250

    it "byte4 is ModRM 0xC2":
        val result = emit_vpsubd_ymm(0, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpsubd_ymm ymm3 ymm4 ymm5":
    # vpsubd ymm3, ymm4, ymm5 → [0xC4, 0xE1, 0x5D, 0xFA, 0xDD]
    # byte2: ~vvvv=(15-4)=11, L=1, pp=01 → 11*8+5=93
    # ModRM: mod=11,reg=3,rm=5 → 192+3*8+5=221
    it "byte2 is 0x5D (W=0 ~vvvv=11 L=1 pp=01)":
        val result = emit_vpsubd_ymm(3, 4, 5)
        expect result[2] == 93

    it "byte4 is ModRM 0xDD (mod=11 reg=3 rm=5)":
        val result = emit_vpsubd_ymm(3, 4, 5)
        expect result[4] == 221

# ============================================================================
# VPMULLD — VEX.256.66.0F38.WIG 40 /r
# ============================================================================

describe "AVX2 emit_vpmulld_ymm ymm0 ymm1 ymm2 golden":
    # vpmulld ymm0, ymm1, ymm2 → [0xC4, 0xE2, 0x75, 0x40, 0xC2]
    # byte1: mmmmm=2 → 226
    it "emits 5 bytes":
        val result = emit_vpmulld_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte0 is 0xC4":
        val result = emit_vpmulld_ymm(0, 1, 2)
        expect result[0] == 196

    it "byte1 is 0xE2 (0F38 map mmmmm=2)":
        val result = emit_vpmulld_ymm(0, 1, 2)
        expect result[1] == 226

    it "byte2 is 0x75 (W=0 ~vvvv=14 L=1 pp=01)":
        val result = emit_vpmulld_ymm(0, 1, 2)
        expect result[2] == 117

    it "byte3 is opcode 0x40":
        val result = emit_vpmulld_ymm(0, 1, 2)
        expect result[3] == 64

    it "byte4 is ModRM 0xC2":
        val result = emit_vpmulld_ymm(0, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpmulld_ymm ymm0 ymm3 ymm4":
    # vpmulld ymm0, ymm3, ymm4 → [0xC4, 0xE2, 0x65, 0x40, 0xC4]
    # byte2: ~vvvv=(15-3)=12, L=1, pp=01 → 12*8+5=101
    # ModRM: mod=11,reg=0,rm=4 → 192+0+4=196
    it "byte2 is 0x65 (W=0 ~vvvv=12 L=1 pp=01)":
        val result = emit_vpmulld_ymm(0, 3, 4)
        expect result[2] == 101

    it "byte4 is ModRM 0xC4 (mod=11 reg=0 rm=4)":
        val result = emit_vpmulld_ymm(0, 3, 4)
        expect result[4] == 196

# ============================================================================
# VPAND — VEX.256.66.0F.WIG DB /r
# ============================================================================

describe "AVX2 emit_vpand_ymm ymm0 ymm1 ymm2 golden":
    # vpand ymm0, ymm1, ymm2 → [0xC4, 0xE1, 0x75, 0xDB, 0xC2]
    it "emits 5 bytes":
        val result = emit_vpand_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte3 is opcode 0xDB":
        val result = emit_vpand_ymm(0, 1, 2)
        expect result[3] == 219

    it "byte4 is ModRM 0xC2":
        val result = emit_vpand_ymm(0, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpand_ymm ymm0 ymm2 ymm3":
    # vpand ymm0, ymm2, ymm3 → [0xC4, 0xE1, 0x6D, 0xDB, 0xC3]
    # byte2: ~vvvv=(15-2)=13, L=1, pp=01 → 13*8+5=109
    # ModRM: mod=11,reg=0,rm=3 → 195
    it "byte2 is 0x6D (W=0 ~vvvv=13 L=1 pp=01)":
        val result = emit_vpand_ymm(0, 2, 3)
        expect result[2] == 109

    it "byte4 is ModRM 0xC3 (mod=11 reg=0 rm=3)":
        val result = emit_vpand_ymm(0, 2, 3)
        expect result[4] == 195

# ============================================================================
# VPOR — VEX.256.66.0F.WIG EB /r
# ============================================================================

describe "AVX2 emit_vpor_ymm ymm0 ymm1 ymm2 golden":
    # vpor ymm0, ymm1, ymm2 → [0xC4, 0xE1, 0x75, 0xEB, 0xC2]
    it "emits 5 bytes":
        val result = emit_vpor_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte3 is opcode 0xEB":
        val result = emit_vpor_ymm(0, 1, 2)
        expect result[3] == 235

    it "byte4 is ModRM 0xC2":
        val result = emit_vpor_ymm(0, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpor_ymm ymm0 ymm3 ymm4":
    # vpor ymm0, ymm3, ymm4 → [0xC4, 0xE1, 0x65, 0xEB, 0xC4]
    # byte2: ~vvvv=12,L=1,pp=01 → 101   ModRM: 0+4=196
    it "byte2 is 0x65":
        val result = emit_vpor_ymm(0, 3, 4)
        expect result[2] == 101

    it "byte4 is ModRM 0xC4":
        val result = emit_vpor_ymm(0, 3, 4)
        expect result[4] == 196

# ============================================================================
# VPXOR — VEX.256.66.0F.WIG EF /r
# ============================================================================

describe "AVX2 emit_vpxor_ymm ymm0 ymm1 ymm2 golden":
    # vpxor ymm0, ymm1, ymm2 → [0xC4, 0xE1, 0x75, 0xEF, 0xC2]
    it "emits 5 bytes":
        val result = emit_vpxor_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte3 is opcode 0xEF":
        val result = emit_vpxor_ymm(0, 1, 2)
        expect result[3] == 239

    it "byte4 is ModRM 0xC2":
        val result = emit_vpxor_ymm(0, 1, 2)
        expect result[4] == 194

describe "AVX2 emit_vpxor_ymm ymm0 ymm4 ymm5":
    # vpxor ymm0, ymm4, ymm5 → [0xC4, 0xE1, 0x5D, 0xEF, 0xC5]
    # byte2: ~vvvv=(15-4)=11,L=1,pp=01 → 11*8+5=93
    # ModRM: mod=11,reg=0,rm=5 → 197
    it "byte2 is 0x5D (W=0 ~vvvv=11 L=1 pp=01)":
        val result = emit_vpxor_ymm(0, 4, 5)
        expect result[2] == 93

    it "byte4 is ModRM 0xC5 (mod=11 reg=0 rm=5)":
        val result = emit_vpxor_ymm(0, 4, 5)
        expect result[4] == 197

# ============================================================================
# VPSRLD — VEX.256.66.0F.WIG 72 /2 ib  (shift-right-logical imm8)
# emit_vpsrld_ymm_imm(rd, rn, imm8)
# Routing: vvvv=rd (dest), ModRM.r/m=rn (src), ModRM.reg=2 (opcode ext)
# ============================================================================

describe "AVX2 emit_vpsrld_ymm_imm ymm0 ymm1 imm8=8 golden":
    # vpsrld ymm0, ymm1, 8 → [0xC4, 0xE1, 0x7D, 0x72, 0xD1, 0x08]
    # byte1: opcode_ext=2<8 ~R=1; rn=1<8 ~B=1 → 225
    # byte2: vvvv=rd=0 → (15-0)*8+5=125
    # ModRM: mod=11,reg=2,rm=1 → 192+2*8+1=209
    it "emits 6 bytes":
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result.len() == 6

    it "byte0 is 0xC4":
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result[0] == 196

    it "byte1 is 0xE1 (~R=1 ~X=1 ~B=1 mmmmm=1)":
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result[1] == 225

    it "byte2 is 0x7D (W=0 ~vvvv=15 L=1 pp=01)":
        # rd=0 → vvvv=0 → ~vvvv=15 → 15*8+5=125
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result[2] == 125

    it "byte3 is opcode 0x72":
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result[3] == 114

    it "byte4 is ModRM 0xD1 (mod=11 reg=2 rm=1)":
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result[4] == 209

    it "byte5 is imm8 8":
        val result = emit_vpsrld_ymm_imm(0, 1, 8)
        expect result[5] == 8

describe "AVX2 emit_vpsrld_ymm_imm ymm1 ymm2 imm8=16":
    # vpsrld ymm1, ymm2, 16 → [0xC4, 0xE1, 0x75, 0x72, 0xD2, 0x10]
    # byte2: vvvv=rd=1 → (15-1)*8+5=117
    # ModRM: mod=11,reg=2,rm=2 → 192+2*8+2=210
    it "byte2 is 0x75 (vvvv=rd=1 → ~vvvv=14)":
        val result = emit_vpsrld_ymm_imm(1, 2, 16)
        expect result[2] == 117

    it "byte4 is ModRM 0xD2 (mod=11 reg=2 rm=2)":
        val result = emit_vpsrld_ymm_imm(1, 2, 16)
        expect result[4] == 210

    it "byte5 is imm8 16":
        val result = emit_vpsrld_ymm_imm(1, 2, 16)
        expect result[5] == 16

describe "AVX2 emit_vpsrld_ymm_imm extended rn ymm8":
    # vpsrld ymm0, ymm8, 4 → [0xC4, 0xC1, 0x7D, 0x72, 0xD0, 0x04]
    # byte1: rn=8>=8 → ~B=0 → 225-32=193
    # ModRM: mod=11,reg=2,rm=0(8%8) → 192+2*8+0=208
    it "byte1 is 0xC1 (~R=1 ~X=1 ~B=0 mmmmm=1)":
        val result = emit_vpsrld_ymm_imm(0, 8, 4)
        expect result[1] == 193

    it "byte4 is ModRM 0xD0 (mod=11 reg=2 rm=0)":
        val result = emit_vpsrld_ymm_imm(0, 8, 4)
        expect result[4] == 208

# ============================================================================
# VPSLLD — VEX.256.66.0F.WIG 72 /6 ib  (shift-left-logical imm8)
# emit_vpslld_ymm_imm(rd, rn, imm8)
# Routing: vvvv=rd (dest), ModRM.r/m=rn (src), ModRM.reg=6 (opcode ext)
# ============================================================================

describe "AVX2 emit_vpslld_ymm_imm ymm0 ymm1 imm8=3 golden":
    # vpslld ymm0, ymm1, 3 → [0xC4, 0xE1, 0x7D, 0x72, 0xF1, 0x03]
    # ModRM: mod=11,reg=6,rm=1 → 192+6*8+1=241
    it "emits 6 bytes":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result.len() == 6

    it "byte0 is 0xC4":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result[0] == 196

    it "byte1 is 0xE1":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result[1] == 225

    it "byte2 is 0x7D (W=0 ~vvvv=15 L=1 pp=01)":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result[2] == 125

    it "byte3 is opcode 0x72":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result[3] == 114

    it "byte4 is ModRM 0xF1 (mod=11 reg=6 rm=1)":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result[4] == 241

    it "byte5 is imm8 3":
        val result = emit_vpslld_ymm_imm(0, 1, 3)
        expect result[5] == 3

describe "AVX2 emit_vpslld_ymm_imm ymm2 ymm3 imm8=5":
    # vpslld ymm2, ymm3, 5 → [0xC4, 0xE1, 0x6D, 0x72, 0xF3, 0x05]
    # byte2: vvvv=rd=2 → (15-2)*8+5=109
    # ModRM: mod=11,reg=6,rm=3 → 192+6*8+3=243
    it "byte2 is 0x6D (vvvv=rd=2 → ~vvvv=13)":
        val result = emit_vpslld_ymm_imm(2, 3, 5)
        expect result[2] == 109

    it "byte4 is ModRM 0xF3 (mod=11 reg=6 rm=3)":
        val result = emit_vpslld_ymm_imm(2, 3, 5)
        expect result[4] == 243

    it "byte5 is imm8 5":
        val result = emit_vpslld_ymm_imm(2, 3, 5)
        expect result[5] == 5

describe "AVX2 emit_vpslld_ymm_imm extended rn ymm8":
    # vpslld ymm0, ymm8, 4 → [0xC4, 0xC1, 0x7D, 0x72, 0xF0, 0x04]
    # byte1: rn=8>=8 → ~B=0 → 225-32=193
    # ModRM: mod=11,reg=6,rm=0(8%8) → 192+6*8+0=240
    it "byte1 is 0xC1 (~R=1 ~X=1 ~B=0 mmmmm=1)":
        val result = emit_vpslld_ymm_imm(0, 8, 4)
        expect result[1] == 193

    it "byte4 is ModRM 0xF0 (mod=11 reg=6 rm=0)":
        val result = emit_vpslld_ymm_imm(0, 8, 4)
        expect result[4] == 240

    it "byte5 is imm8 4":
        val result = emit_vpslld_ymm_imm(0, 8, 4)
        expect result[5] == 4
