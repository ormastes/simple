"""
Feature: Direct Mock Import
Category: Mocking Framework
Status: Complete
"""

# Parser-safe local harness for the direct mock import shape.
# The production `spec.mock` module is not required for this coverage path.

use spec.{describe, it, expect}

class CallRecorder:
    calls: [text]

    static fn new() -> CallRecorder:
        CallRecorder(calls: [])

    fn record(name: text):
        self.calls = self.calls + [name]

describe "Direct Mock Import":
    """
    Tests the lightweight construction shape that the direct import would expose.
    """
    it "can call CallRecorder.new directly":
        val recorder = CallRecorder.new()
        expect(recorder.calls.len() == 0)

    it "records calls on the local harness":
        val recorder = CallRecorder.new()
        recorder.record("ping")
        expect(recorder.calls.len() == 1)
        expect(recorder.calls[0] == "ping")
