"""
# RV32 CSR Unit Tests

**Feature IDs:** #RV32-CSR-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** In Progress

## Overview

Unit tests for Control and Status Register file operations.
"""

# tag: only-compiled
# NOTE: Rv32CsrFile imported constructor is broken in interpreter mode.
# CSR logic is also verified in rv32imac_spec.spl system tests and compliance tests.

import std.spec

val CSR_MSTATUS: i64 = 0x300
val CSR_MISA: i64 = 0x301
val CSR_MIE: i64 = 0x304
val CSR_MTVEC: i64 = 0x305
val CSR_MSCRATCH: i64 = 0x340
val CSR_MEPC: i64 = 0x341
val CSR_MCAUSE: i64 = 0x342
val CSR_MCYCLE: i64 = 0xB00
val CSR_MINSTRET: i64 = 0xB02

# Inline CSR model to avoid imported class constructor limitation
class _CsrFile:
    mstatus: i64
    misa: i64
    mie: i64
    mtvec: i64
    mscratch: i64
    mepc: i64
    mcause: i64
    mtval: i64
    mip: i64
    mcycle: i64
    minstret: i64

    fn read(addr: i64) -> i64:
        if addr == CSR_MSTATUS: return self.mstatus
        elif addr == CSR_MISA: return self.misa
        elif addr == CSR_MIE: return self.mie
        elif addr == CSR_MTVEC: return self.mtvec
        elif addr == CSR_MSCRATCH: return self.mscratch
        elif addr == CSR_MEPC: return self.mepc
        elif addr == CSR_MCAUSE: return self.mcause
        elif addr == CSR_MCYCLE: return self.mcycle
        elif addr == CSR_MINSTRET: return self.minstret
        0

    me write(addr: i64, value: i64):
        if addr == CSR_MSTATUS:
            self.mstatus = value and 0x000019FF
        elif addr == CSR_MIE:
            self.mie = value
        elif addr == CSR_MTVEC:
            self.mtvec = value
        elif addr == CSR_MSCRATCH:
            self.mscratch = value
        elif addr == CSR_MEPC:
            self.mepc = value and 0xFFFFFFFC
        elif addr == CSR_MCAUSE:
            self.mcause = value

    me csrrw(addr: i64, rs1_data: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, rs1_data)
        old

    me csrrs(addr: i64, rs1_data: i64) -> i64:
        val old = self.read(addr)
        if rs1_data != 0:
            self.write(addr, old or rs1_data)
        old

    me csrrc(addr: i64, rs1_data: i64) -> i64:
        val old = self.read(addr)
        if rs1_data != 0:
            val mask = 0xFFFFFFFF xor rs1_data
            self.write(addr, old and mask)
        old

    me trap_enter(cause: i64, pc: i64, tval: i64):
        self.mepc = pc and 0xFFFFFFFC
        self.mcause = cause
        self.mtval = tval
        val mie_bit = (self.mstatus >> 3) and 1
        self.mstatus = (self.mstatus and 0xFFFFFF77) or (mie_bit << 7)

    me trap_return() -> i64:
        val mpie_bit = (self.mstatus >> 7) and 1
        self.mstatus = (self.mstatus and 0xFFFFFF77) or (mpie_bit << 3) or (1 << 7)
        self.mepc

    fn trap_vector() -> i64:
        self.mtvec and 0xFFFFFFFC

    me tick():
        self.mcycle = self.mcycle + 1

    me retire():
        self.minstret = self.minstret + 1

fn _new_csr() -> _CsrFile:
    _CsrFile(mstatus: 0, misa: 0x40101104, mie: 0, mtvec: 0,
             mscratch: 0, mepc: 0, mcause: 0, mtval: 0,
             mip: 0, mcycle: 0, minstret: 0)

describe "CSR Read/Write":
    """
    ## Basic CSR Access
    """

    it "writes and reads mtvec":
        var csr = _new_csr()
        csr.write(CSR_MTVEC, 0x80000100)
        expect(csr.read(CSR_MTVEC)).to_equal(0x80000100)

    it "writes and reads mscratch":
        var csr = _new_csr()
        csr.write(CSR_MSCRATCH, 0xCAFEBABE)
        expect(csr.read(CSR_MSCRATCH)).to_equal(0xCAFEBABE)

    it "mepc is word-aligned":
        var csr = _new_csr()
        csr.write(CSR_MEPC, 0x80001003)
        expect(csr.read(CSR_MEPC)).to_equal(0x80001000)

    it "misa reports RV32IMAC":
        val csr = _new_csr()
        expect(csr.read(CSR_MISA)).to_equal(0x40101104)

describe "CSR Atomic Operations":
    """
    ## CSRRW/CSRRS/CSRRC
    """

    it "CSRRW swaps value":
        var csr = _new_csr()
        csr.write(CSR_MSCRATCH, 0xAAAAAAAA)
        val old = csr.csrrw(CSR_MSCRATCH, 0x55555555)
        expect(old).to_equal(0xAAAAAAAA)
        expect(csr.read(CSR_MSCRATCH)).to_equal(0x55555555)

    it "CSRRS sets bits":
        var csr = _new_csr()
        csr.write(CSR_MIE, 0x00)
        csr.csrrs(CSR_MIE, 0x88)
        expect(csr.read(CSR_MIE)).to_equal(0x88)

    it "CSRRS with rs1=0 is read-only":
        var csr = _new_csr()
        csr.write(CSR_MIE, 0xFF)
        val old = csr.csrrs(CSR_MIE, 0)
        expect(old).to_equal(0xFF)
        expect(csr.read(CSR_MIE)).to_equal(0xFF)

    it "CSRRC clears bits":
        var csr = _new_csr()
        csr.write(CSR_MIE, 0xFF)
        csr.csrrc(CSR_MIE, 0x0F)
        expect(csr.read(CSR_MIE)).to_equal(0xF0)

describe "CSR Trap Handling":
    """
    ## Trap Entry/Return
    """

    it "saves state on trap entry":
        var csr = _new_csr()
        csr.write(CSR_MTVEC, 0x80000100)
        csr.write(CSR_MSTATUS, 0x08)  # MIE=1
        csr.trap_enter(11, 0x80001234, 0)
        expect(csr.read(CSR_MEPC)).to_equal(0x80001234)
        expect(csr.read(CSR_MCAUSE)).to_equal(11)

    it "trap_vector returns aligned mtvec":
        var csr = _new_csr()
        csr.write(CSR_MTVEC, 0x80000103)  # mode bits in low 2
        expect(csr.trap_vector()).to_equal(0x80000100)

    it "mret returns to mepc":
        var csr = _new_csr()
        csr.write(CSR_MTVEC, 0x80000100)
        csr.trap_enter(11, 0x80002000, 0)
        val return_pc = csr.trap_return()
        expect(return_pc).to_equal(0x80002000)

    it "tick increments mcycle":
        var csr = _new_csr()
        csr.tick()
        csr.tick()
        csr.tick()
        expect(csr.read(CSR_MCYCLE)).to_equal(3)

    it "retire increments minstret":
        var csr = _new_csr()
        csr.retire()
        csr.retire()
        expect(csr.read(CSR_MINSTRET)).to_equal(2)
