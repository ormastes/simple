# @cover doc/bugs/ 0%
"""
# RISC-V FPGA Bug Tracking Convention Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** Draft
**Requirements:** REQ-7
**Artifacts:** N/A

## Overview

Verifies AC-7: the bug tracking convention for RISC-V FPGA bugs uses the
correct ID namespace (BUG-RISCV-FPGA-NNN) and that the bug-doc helper
module generates conforming entry text.

Per ADR D-7, bug entries are process artifacts (doc/bugs/). This spec
tests the convention module that generates bug entry templates, not
actual hardware bugs (which are filed during phase 7-verify).

Covers:
- AC-7 (Bug tracking: documented and fixed or tracked with concrete IDs)
"""

use std.spipe.*
use doc.bugs.riscv_fpga_bug_convention.{
    riscv_fpga_bug_id_prefix,
    riscv_fpga_bug_doc_path,
    riscv_fpga_bug_entry_template,
    RiscvFpgaBugEntry,
    make_riscv_fpga_bug_entry
}


# ============================================================================
# Helpers
# ============================================================================

fn sample_entry() -> RiscvFpgaBugEntry:
    return make_riscv_fpga_bug_entry(1, "UART output garbled on first boot", "open")

fn sample_entry_text() -> text:
    val entry = sample_entry()
    return riscv_fpga_bug_entry_template(entry)


# ============================================================================
# AC-7: Bug ID prefix and path convention
# ============================================================================

describe "RISC-V FPGA Bug Convention":
    it "AC-7: bug id prefix is BUG-RISCV-FPGA":
        val prefix = riscv_fpga_bug_id_prefix()
        expect(prefix).to_equal("BUG-RISCV-FPGA")

    it "AC-7: bug doc path starts with doc/bugs/":
        val path = riscv_fpga_bug_doc_path(1)
        expect(path).to_start_with("doc/bugs/")

    it "AC-7: bug doc path contains BUG-RISCV-FPGA":
        val path = riscv_fpga_bug_doc_path(1)
        expect(path).to_contain("BUG-RISCV-FPGA")

    it "AC-7: bug doc path ends with .md":
        val path = riscv_fpga_bug_doc_path(1)
        expect(path).to_end_with(".md")


# ============================================================================
# AC-7: Bug entry template
# ============================================================================

describe "RISC-V FPGA Bug Entry Template":
    it "AC-7: entry template is non-empty":
        val t = sample_entry_text()
        val len = t.length()
        expect(len).to_be_greater_than(0)

    it "AC-7: entry template contains BUG-RISCV-FPGA-001":
        val t = sample_entry_text()
        expect(t).to_contain("BUG-RISCV-FPGA-001")

    it "AC-7: entry template contains the bug title":
        val t = sample_entry_text()
        expect(t).to_contain("UART output garbled on first boot")

    it "AC-7: entry template contains status field":
        val t = sample_entry_text()
        expect(t).to_contain("open")
