use std.spec.{describe, it, expect}
use app.itf.adapter_minio_mc.{McClient, mc_ls, mc_health_ready}

# Live smoke against MinIO public play sandbox at play.min.io.
# Public credentials posted on min.io. Test runner setup must register
# an mc alias `play` before invoking this spec.

describe("adapter_minio_mc — live play.min.io public sandbox", fn():
    it("play.min.io health endpoint is reachable", fn():
        val ok = mc_health_ready("https://play.min.io")
        expect(ok).to_be(true)
    )

    it("ls of a known existing bucket succeeds", fn():
        val client = McClient(alias_name: "play", mc_path: "mc")
        val (ok, _entries, _raw) = mc_ls(client, "001-ingest", false)
        expect(ok).to_be(true)
    )
)
