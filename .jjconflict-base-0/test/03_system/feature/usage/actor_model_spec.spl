"""
# Game Engine Actor Model Specification

**Feature IDs:** #GE-003
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview
Actor model for game entities with Vec3 positions and message-passing.

## Key Concepts
| Concept | Description |
|---------|-------------|
| GameMessage | Enum of standard game messages |
| EntityActor | Actor wrapper for game entities |
| EntityManager | Manages collections of entity actors |

## Behavior
- GameMessage uses math.Vec3 for positions
- EntityActor tracks position, health, alive state
- EntityManager provides spawn, despawn, message dispatch
"""

# use std.spec  # Not needed - all tests are compiled-only
use math
# use game_engine.actor_model  # Module not yet implemented

# ============================================================================
# GameMessage
# ============================================================================

describe "GameMessage", tag: ["only-compiled"]:
    it "creates spawn message with Vec3":
        val pos = math.Vec3(1.0, 2.0, 3.0)
        val msg = GameMessage.Spawn(pos)
        expect(msg.is_spawn()).to_equal(true)

    it "creates set position message with Vec3":
        val pos = math.Vec3(10.0, 20.0, 30.0)
        val msg = GameMessage.SetPosition(pos)
        expect(msg.is_set_position()).to_equal(true)

    it "provides message type checks":
        expect(GameMessage.Update(0.016).is_update()).to_equal(true)
        expect(GameMessage.Despawn.is_despawn()).to_equal(true)
        expect(GameMessage.GetPosition.is_get_position()).to_equal(true)
        expect(GameMessage.Damage(25).is_damage()).to_equal(true)
        expect(GameMessage.Heal(10).is_heal()).to_equal(true)

    it "gets delta from update message":
        val msg = GameMessage.Update(0.016)
        expect(msg.get_delta()).to_equal(0.016)

    it "converts to string":
        val msg = GameMessage.Damage(50)
        expect(msg.to_string()).to_equal("Damage(50)")

# ============================================================================
# EntityActor
# ============================================================================

describe "EntityActor", tag: ["only-compiled"]:
    it "creates with default values":
        val ent = EntityActor.create(1)
        expect(ent.get_entity_id()).to_equal(1)
        expect(ent.get_health()).to_equal(100)
        expect(ent.get_max_health()).to_equal(100)
        expect(ent.is_alive()).to_equal(true)
        expect(ent.is_full_health()).to_equal(true)
        expect(ent.is_dead()).to_equal(false)

    it "position is zero Vec3 by default":
        val ent = EntityActor.create(1)
        val pos = ent.get_position()
        expect(pos.x).to_equal(0.0)
        expect(pos.y).to_equal(0.0)
        expect(pos.z).to_equal(0.0)

    it "handles SetPosition message":
        var ent = EntityActor.create(1)
        val pos = math.Vec3(10.0, 20.0, 30.0)
        ent.handle_message(GameMessage.SetPosition(pos))
        val new_pos = ent.get_position()
        expect(new_pos.x).to_equal(10.0)
        expect(new_pos.y).to_equal(20.0)
        expect(new_pos.z).to_equal(30.0)

    it "handles Damage message":
        var ent = EntityActor.create(1)
        ent.handle_message(GameMessage.Damage(30))
        expect(ent.get_health()).to_equal(70)

    it "handles Heal message":
        var ent = EntityActor.create(1)
        ent.handle_message(GameMessage.Damage(50))
        ent.handle_message(GameMessage.Heal(20))
        expect(ent.get_health()).to_equal(70)

    it "dies when health reaches zero":
        var ent = EntityActor.create(1)
        ent.handle_message(GameMessage.Damage(100))
        expect(ent.get_health()).to_equal(0)
        expect(ent.is_alive()).to_equal(false)
        expect(ent.is_dead()).to_equal(true)

# ============================================================================
# EntityManager
# ============================================================================

describe "EntityManager", tag: ["only-compiled"]:
    it "starts empty":
        val mgr = EntityManager.create()
        expect(mgr.is_empty()).to_equal(true)
        expect(mgr.entity_count()).to_equal(0)
        expect(mgr.get_next_id()).to_equal(1)

    it "spawns entities with incrementing IDs":
        var mgr = EntityManager.create()
        val id1 = mgr.spawn_entity()
        val id2 = mgr.spawn_entity()
        expect(id1).to_equal(1)
        expect(id2).to_equal(2)
        expect(mgr.entity_count()).to_equal(2)
        expect(mgr.has_entities()).to_equal(true)

    it "checks entity existence":
        var mgr = EntityManager.create()
        val id = mgr.spawn_entity()
        expect(mgr.has_entity(id)).to_equal(true)
        expect(mgr.has_entity(999)).to_equal(false)

    it "despawns entities":
        var mgr = EntityManager.create()
        val id = mgr.spawn_entity()
        mgr.despawn_entity(id)
        expect(mgr.entity_count()).to_equal(0)
        expect(mgr.has_entity(id)).to_equal(false)

    it "provides summary":
        var mgr = EntityManager.create()
        mgr.spawn_entity()
        val s = mgr.summary()
        expect(s).to_equal("EntityManager: 1 entities, next_id=2")
