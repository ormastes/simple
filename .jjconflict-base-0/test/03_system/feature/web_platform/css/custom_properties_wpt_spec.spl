use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}
use std.gc_async_mut.gpu.browser_engine.html_string_parser.{browser_renderer_normalize_style_rules}

val WIDTH: i32 = 32
val HEIGHT: i32 = 24

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn _renders_color(style: text, body: text, color: u32) -> bool:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color) > 0

describe "WPT CSS custom properties":

    context "var() resolution":

        it "var() resolves custom property value":
            expect(_renders_color(
                "div { --color: #dc2626; background-color: var(--color); width: 12px; height: 8px; }",
                "<div></div>",
                0xFFDC2626u32
            )).to_equal(true)

        it "var() with fallback when undefined":
            expect(_renders_color(
                "div { background-color: var(--undefined, #16a34a); width: 12px; height: 8px; }",
                "<div></div>",
                0xFF16A34Au32
            )).to_equal(true)

        it "custom property inherits to child":
            expect(_renders_color(
                ".parent { --color: #2563eb; } .child { background-color: var(--color); width: 12px; height: 8px; }",
                "<div class='parent'><div class='child'></div></div>",
                0xFF2563EBu32
            )).to_equal(true)

        it "var() nested fallback":
            expect(_renders_color(
                "div { background-color: var(--a, var(--b, #9333ea)); width: 12px; height: 8px; }",
                "<div></div>",
                0xFF9333EAu32
            )).to_equal(true)
