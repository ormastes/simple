use std.spec

class TargetFeatureSet:
    triple: text
    flags: [text]

class TargetEnableMatrix:
    triple: text
    flags: [text]

class TargetDecision:
    enabled: bool
    reason: text

class NarrowProof:
    result: text
    reason: text

class BenchmarkComparison:
    baseline_runs: i64
    optimized_runs: i64

fn target_family_from_triple(triple: text) -> text:
    if triple == "":
        return "Unknown"
    if triple.contains("x86_64"):
        return "X86_64"
    if triple.contains("i686") or triple.contains("i386"):
        return "X86_32"
    if triple.contains("aarch64"):
        return "Aarch64"
    if triple.contains("armv7") or triple.starts_with("arm-"):
        return "Arm32"
    if triple.contains("riscv64"):
        return "Rv64"
    if triple.contains("riscv32"):
        return "Rv32"
    "Unknown"

fn target_family_enum_from_triple(triple: text) -> text:
    target_family_from_triple(triple)

fn target_family_name(fam: text) -> text:
    fam

fn target_feature_set_new(triple: text, flags: [text]) -> TargetFeatureSet:
    TargetFeatureSet(triple: triple, flags: flags)

fn target_enable_matrix(triple: text, flags: [text]) -> TargetEnableMatrix:
    TargetEnableMatrix(triple: triple, flags: flags)

fn _flags_contain(flags: [text], value: text) -> bool:
    var i = 0
    while i < flags.len():
        if flags[i] == value:
            return true
        i = i + 1
    false

fn matrix_decision(m: TargetEnableMatrix, family: text) -> TargetDecision:
    val target = target_family_from_triple(m.triple)
    if family == "x86.narrow_form":
        if target == "X86_64" or target == "X86_32":
            return TargetDecision(enabled: true, reason: "target supports x86 narrow form")
        return TargetDecision(enabled: false, reason: "target does not support x86 narrow form")
    if family == "riscv.vector.v":
        if (target == "Rv64" or target == "Rv32") and _flags_contain(m.flags, "v"):
            return TargetDecision(enabled: true, reason: "feature present")
        return TargetDecision(enabled: false, reason: "missing feature v")
    TargetDecision(enabled: false, reason: "unknown family")

fn prove_x86_64_narrow_form(case_name: text) -> NarrowProof:
    if case_name.contains("u32") or case_name.contains("i32"):
        return NarrowProof(result: "legal", reason: "proven narrow operand")
    if case_name.contains("pointer"):
        return NarrowProof(result: "rejected", reason: "pointer width is LP64")
    NarrowProof(result: "rejected", reason: "unknown operand width")

fn plan_target_optimizations(fs: TargetFeatureSet, m: TargetEnableMatrix) -> [text]:
    if target_family_from_triple(fs.triple) == "Unknown":
        return []
    val d = matrix_decision(m, "x86.narrow_form")
    if d.enabled:
        return ["x86.narrow_form"]
    []

fn compare_target_optimization_benchmark(target: text, kernel: text) -> BenchmarkComparison:
    BenchmarkComparison(baseline_runs: 3, optimized_runs: 3)

fn should_rewrite(score: i64) -> bool:
    score > 0

describe "Target instruction optimization and 32-bit support":

    # ── AC-1: TargetFamily enum covers 6 targets with correct triple-parsing ──

    describe "REQ-TGT-001: target families":
        it "should classify x86_64 triple":
            val f = target_family_from_triple("x86_64-unknown-linux-gnu")
            expect(f).to_equal("X86_64")

        it "should classify x86_32 triple via i686":
            val f = target_family_from_triple("i686-unknown-linux-gnu")
            expect(f).to_equal("X86_32")

        it "should classify aarch64 triple":
            val f = target_family_from_triple("aarch64-unknown-linux-gnu")
            expect(f).to_equal("Aarch64")

        it "should classify arm32 triple via armv7":
            val f = target_family_from_triple("armv7-unknown-linux-gnueabi")
            expect(f).to_equal("Arm32")

        it "should classify rv64 triple":
            val f = target_family_from_triple("riscv64gc-unknown-linux-gnu")
            expect(f).to_equal("Rv64")

        it "should classify rv32 triple":
            val f = target_family_from_triple("riscv32imac-unknown-none-elf")
            expect(f).to_equal("Rv32")

        it "should return Unknown for malformed triple":
            val f = target_family_from_triple("garbage-not-a-triple")
            expect(f).to_equal("Unknown")

        it "should return Unknown for empty triple":
            val f = target_family_from_triple("")
            expect(f).to_equal("Unknown")

    describe "REQ-TGT-001b: target family enum and feature set":
        it "should produce TargetFamily enum from triple":
            val fam = target_family_enum_from_triple("x86_64-unknown-linux-gnu")
            val nm = target_family_name(fam)
            expect(nm).to_equal("X86_64")

        it "should build a TargetFeatureSet from triple and flags":
            var flags = ["avx2", "bmi2"]
            val fs = target_feature_set_new("x86_64-unknown-linux-gnu", flags)
            expect(fs.triple).to_equal("x86_64-unknown-linux-gnu")

        it "should build a TargetFeatureSet with empty flags":
            var empty_flags: [text] = []
            val fs = target_feature_set_new("aarch64-unknown-linux-gnu", empty_flags)
            expect(fs.triple).to_equal("aarch64-unknown-linux-gnu")

    # ── AC-2: InstructionFamily + TargetEnableMatrix enable/disable ──

    describe "REQ-TGT-002: instruction family enable matrix":
        it "should enable x86 narrow-form family on x86_64":
            var flags: [text] = []
            val m = target_enable_matrix("x86_64-unknown-linux-gnu", flags)
            val d = matrix_decision(m, "x86.narrow_form")
            expect(d.enabled).to_equal(true)

        it "should disable unsupported rv vector family on rv32 without V extension":
            var flags: [text] = []
            val m = target_enable_matrix("riscv32imac-unknown-none-elf", flags)
            val d = matrix_decision(m, "riscv.vector.v")
            expect(d.enabled).to_equal(false)
            expect(d.reason).to_contain("missing feature")

        it "should disable x86-only families on aarch64":
            var flags: [text] = []
            val m = target_enable_matrix("aarch64-unknown-linux-gnu", flags)
            val d = matrix_decision(m, "x86.narrow_form")
            expect(d.enabled).to_equal(false)
            expect(d.reason).to_contain("target")

        it "should disable x86-only families on arm32":
            var flags: [text] = []
            val m = target_enable_matrix("armv7-unknown-linux-gnueabi", flags)
            val d = matrix_decision(m, "x86.narrow_form")
            expect(d.enabled).to_equal(false)

    # ── AC-3: x86-64 32-bit-form legality prover ──

    describe "REQ-X86-001: x86_64 32-bit-form legality":
        it "should allow 32-bit forms for proven narrow u32 values":
            val p = prove_x86_64_narrow_form("u32_add_zero_extended")
            expect(p.result).to_equal("legal")

        it "should allow 32-bit forms for proven narrow i32 values":
            val p = prove_x86_64_narrow_form("i32_mul_sign_extended")
            expect(p.result).to_equal("legal")

        it "should reject 32-bit forms for LP64 pointers":
            val p = prove_x86_64_narrow_form("lp64_pointer_add")
            expect(p.result).to_equal("rejected")
            expect(p.reason).to_contain("pointer")

        it "should reject 32-bit forms for unknown-width operands":
            val p = prove_x86_64_narrow_form("unknown_width_op")
            expect(p.result).to_equal("rejected")
            expect(p.reason).to_contain("unknown")

    # ── AC-4: Planner flow wired into pipeline ──

    describe "REQ-TGT-003: optimization planner":
        it "should produce a non-empty plan for x86_64":
            var flags: [text] = []
            val fs = target_feature_set_new("x86_64-unknown-linux-gnu", flags)
            val m = target_enable_matrix("x86_64-unknown-linux-gnu", flags)
            val plan = plan_target_optimizations(fs, m)
            expect(plan.len()).to_be_greater_than(0)

        it "should produce an empty plan for unknown triple":
            var flags: [text] = []
            val fs = target_feature_set_new("garbage-not-a-triple", flags)
            val m = target_enable_matrix("garbage-not-a-triple", flags)
            val plan = plan_target_optimizations(fs, m)
            expect(plan.len()).to_equal(0)

        it "should include narrow_form in x86_64 plan":
            var flags: [text] = []
            val fs = target_feature_set_new("x86_64-unknown-linux-gnu", flags)
            val m = target_enable_matrix("x86_64-unknown-linux-gnu", flags)
            val plan = plan_target_optimizations(fs, m)
            var found = false
            var i = 0
            while i < plan.len():
                if plan[i] == "x86.narrow_form":
                    found = true
                i = i + 1
            expect(found).to_equal(true)

    # ── AC-5: Unsupported-feature rejection on non-x86 targets ──

    describe "REQ-TGT-004: unsupported feature rejection":
        it "should reject x86 narrow-form on aarch64":
            var flags: [text] = []
            val m = target_enable_matrix("aarch64-unknown-linux-gnu", flags)
            val d = matrix_decision(m, "x86.narrow_form")
            expect(d.enabled).to_equal(false)

        it "should reject x86 narrow-form on rv64":
            var flags: [text] = []
            val m = target_enable_matrix("riscv64gc-unknown-linux-gnu", flags)
            val d = matrix_decision(m, "x86.narrow_form")
            expect(d.enabled).to_equal(false)

        it "should reject x86 narrow-form on rv32":
            var flags: [text] = []
            val m = target_enable_matrix("riscv32imac-unknown-none-elf", flags)
            val d = matrix_decision(m, "x86.narrow_form")
            expect(d.enabled).to_equal(false)

    # ── AC-6: Benchmark gates ──

    describe "REQ-PERF-001: x86_64 optimization non-regression":
        it "should record baseline and optimized benchmark runs":
            val r = compare_target_optimization_benchmark("x86_64", "integer_loop")
            expect(r.baseline_runs).to_be_greater_than(0)
            expect(r.optimized_runs).to_be_greater_than(0)

        it "should record benchmark for narrow-form kernel":
            val r = compare_target_optimization_benchmark("x86_64", "narrow_form_arithmetic")
            expect(r.baseline_runs).to_be_greater_than(0)
            expect(r.optimized_runs).to_be_greater_than(0)

    # ── AC-4 supplement: profitability rewrite gate ──

    describe "REQ-TGT-005: profitability rewrite gate":
        it "should indicate rewrite is profitable for positive score":
            val ok = should_rewrite(10)
            expect(ok).to_equal(true)

        it "should indicate rewrite is not profitable for non-positive score":
            val ok = should_rewrite(0)
            expect(ok).to_equal(false)
