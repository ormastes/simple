# @platform: all

use std.io_runtime.{shell}

describe "simple erp big-business demo":
    it "runs durability, snapshot, keys, tenant queue serialization, and org checks end to end":
        val result = shell("bin/release/x86_64-unknown-linux-gnu/simple examples/12_business/simple_erp/src/bigbiz_demo.spl")
        expect(result.exit_code).to_equal(0)
        expect(result.stdout).to_contain("bigbiz-ok events=1000 parity=true")
        expect(result.stdout).to_contain("snapshot-ok balance_match=true")
        expect(result.stdout).to_contain("keys-ok indexed=200 found=true missing_rejected=true dup_rejected=true")
        expect(result.stdout).to_contain("queue-ok serialized=true")
        expect(result.stdout).to_contain("org-ok roles_ok=true chains=ordered")
        expect(result.stdout).to_contain("bigbiz-ready")
