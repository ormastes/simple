## Task #78 repro: module-qualified constructor/function calls in the interpreter.
## `math.Vec3Math78(...)` and `math.add_vec3_78(...)` should dispatch against the
## imported module `math`, not the interpreter's flat module dict.
##
## The second describe block below adds a collision probe: the calling file
## defines its OWN `Vec3` struct with the same simple name as the struct
## exported by the imported `vmath` module, to confirm qualified calls resolve
## through the module namespace rather than the interp's flat/global registry.

use test.fixtures.interp_dispatch_78.math_mod78 as math
use test.fixtures.interp_dispatch_78.vec3_math_mod as vmath

struct Vec3:
    a: i64
    b: i64

describe "Module-qualified dispatch (task 78)":
    it "constructs a struct via module-qualified call":
        val v = math.Vec3Math78(x: 1, y: 2, z: 3)
        expect v.x == 1
        expect v.y == 2
        expect v.z == 3

    it "calls a free function via module-qualified call":
        val a = math.Vec3Math78(x: 1, y: 2, z: 3)
        val b = math.Vec3Math78(x: 10, y: 20, z: 30)
        val c = math.add_vec3_78(a, b)
        expect c.x == 11
        expect c.y == 22
        expect c.z == 33

describe "Module-qualified dispatch collision probe (task 78)":
    it "constructs vmath.Vec3 while a locally-named Vec3 struct also exists":
        val local_v = Vec3(a: 100, b: 200)
        val remote_v = vmath.Vec3(x: 1, y: 2, z: 3)
        expect local_v.a == 100
        expect remote_v.x == 1
        expect remote_v.y == 2
        expect remote_v.z == 3

    it "calls vmath.make_vec3 while a locally-named Vec3 struct also exists":
        val remote_v = vmath.make_vec3(7, 8, 9)
        expect remote_v.x == 7
        expect remote_v.z == 9
