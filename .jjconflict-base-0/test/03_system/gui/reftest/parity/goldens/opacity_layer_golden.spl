# Golden fixture: opacity_layer — SaveLayer(alpha paint), DrawRect, Restore
# SaveLayer/Restore are no-ops in the CPU backend; the rect renders with the full paint.

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_argb, sk_color_black}

fn _save_layer_op(paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.SaveLayer,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn _restore_op(paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.Restore,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    # Alpha-reduced layer paint (128/255 ~ 50% opacity)
    val alpha_color = sk_color_argb(128, 255, 0, 0)
    val alpha_paint = sk_paint_fill(alpha_color)
    val op_save = _save_layer_op(alpha_paint)
    # Rect drawn inside the layer
    val inner_rect = SkRect(left: 32.0, top: 32.0, right: 224.0, bottom: 224.0)
    val rect_color = sk_color_argb(128, 255, 0, 0)
    val rect_paint = sk_paint_fill(rect_color)
    val op_rect = sk_picture_op_draw_rect(inner_rect, rect_paint)
    # Restore
    val black_paint = sk_paint_fill(sk_color_black())
    val op_restore = _restore_op(black_paint)
    val ops = [op_save, op_rect, op_restore]
    val picture = SkPicture(cull_rect: cull, op_count: 3, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
