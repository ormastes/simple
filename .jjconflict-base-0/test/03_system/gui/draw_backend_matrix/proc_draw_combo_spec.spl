# @cover src/lib/gc_async_mut/gpu/engine2d/engine.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cuda.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl
# @cover src/lib/gc_async_mut/gpu/browser_engine/simple_web_renderer.spl
# @cover src/lib/common/ui/event.spl
# @tag: system, ui, engine2d, gpu, combination, headless
"""
# Processing × Drawing combination runs — headless offscreen readback

**Category:** Testing | **Status:** Implemented
**Plan:** doc/03_plan/ui/testing/gpu_draw_event_intensive_tests.md
**Requirements:** N/A
**Research:** N/A
**Design:** N/A

## Overview

`draw_backend_matrix_spec.spl` (this dir) pins ONE drawing backend at a time.
This spec instead runs full **processing × drawing COMBINATION** lanes on a
headless host, for three combos — **cuda/vulkan**, **vulkan/vulkan**, and **metal/vulkan**
(processing / drawing) — across three surfaces plus event handling:

1. **2D** — filled rect + line on a real vulkan framebuffer, `read_pixels()`
   absolute oracle.
2. **Web** — a styled-box HTML fixture rendered headlessly through the
   `simple_web_render_html_to_pixels_with_engine2d_backend(..., "vulkan")` lane;
   the box background AND the styled-box border color must both appear in the
   framebuffer (absolute-color oracle).
3. **GUI** — a widget-layer scene (titlebar bar + button rect) drawn through the
   `Engine2D` facade on vulkan, `read_pixels()` absolute oracle.
4. **Event** — a pointer `TouchPress` dispatched through the real
   `process_event` reducer moves `focused_id`; the button is re-rendered and the
   changed pixel flips from the NORMAL color to the FOCUSED color (both frames
   asserted against absolute values), while the background pixel is unchanged.

## Headless strategy (host has no display)

Every lane uses OFFSCREEN readback (`read_pixels()` → P6 PPM) — the established
oracle that needs no window, no `xvfb-run`, no container, no QEMU. Availability
is never a silent skip: a lane whose device is absent asserts the concrete
fail-closed classification instead.

## Honest processing/drawing split

- **cuda processing half** uses the real host probe `probe_cuda_processing()`
  and asserts EITHER outcome honestly, never a silent skip: if a CUDA device is
  present it must report `has_compute` (gate `cuda_2d_render`); if absent it must
  fail-closed with a concrete `feature_gate` (`cuda-device-unavailable` /
  `cuda_runtime` / `cuda_init`) and a non-empty reason. Whichever branch this
  host lands in, the vulkan drawing half runs in the same `it`. (On the host this
  was authored against, the probe reported `Initialized` / `cuda_2d_render`.)
- **vulkan processing half** exercises the payload-gated compute/offload lane
  (`assert_payload_gating(ComputeBackend.Vulkan)`): the reduce value equals the
  CPU oracle (60) in both gate branches while only the payload gate flips
  `ran_on_cpu` — an absolute oracle, not a masquerade.
- **metal processing half** exercises the same payload-gated compute/offload
  lane for `ComputeBackend.Metal`, so Metal cannot disappear from the processing
  matrix on non-macOS hosts.
- **vulkan drawing half** goes through `Engine2D.probe_backend`/
  `create_requested_backend("vulkan")`; if no Vulkan device is present it
  fail-closes on a concrete `reason` (never a silent skip).

## Syntax

`std.spec` matchers only; facades only (no raw `rt_*`); shared
`assert_color_eq` / `read_pixels_ppm` / `assert_payload_gating` helpers reused
from `test/helpers/gpu_draw_event_shared.spl`.

## Coverage matrix

| Processing | Drawing | 2D | GUI | Web | Event |
|------------|---------|----|-----|-----|-------|
| CUDA | Vulkan | real probe or fail-closed | real probe or fail-closed | real probe or fail-closed | real probe or fail-closed |
| Vulkan | Vulkan | payload gate + readback | payload gate + readback | payload gate + PPM oracle | payload gate + reducer-driven re-render |
| Metal | Vulkan | payload gate + readback | payload gate + readback | payload gate + PPM oracle | payload gate + reducer-driven re-render |
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgba}
use std.gpu.engine2d.backend_cuda.{probe_cuda_processing}
use std.gpu.engine2d.backend_probe.{BackendStatus}
use std.nogc_async_mut.compute.exec_target.{ComputeBackend}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_pixels_with_engine2d_backend}
use common.ui.widget.{WidgetNode, UIEvent, UIState}
use common.ui.builder.{column, button, build_tree}
use common.ui.event.{process_event}
use test.helpers.gpu_draw_event_shared.{
    assert_color_eq, read_pixels_ppm, assert_payload_gating}

val DRAW_W: i32 = 32
val DRAW_H: i32 = 24
val BG: u32 = rgba(3, 5, 7, 255)
val RECT_COLOR: u32 = rgba(255, 0, 0, 255)
val LINE_COLOR: u32 = rgba(0, 255, 0, 255)
val BTN_NORMAL: u32 = rgba(80, 80, 80, 255)
val BTN_FOCUSED: u32 = rgba(0, 120, 255, 255)

fn px_at(pixels: [u32], w: i32, x: i32, y: i32) -> u32:
    return pixels[(y * w + x) as i64]

fn count_color(pixels: [u32], color: u32) -> i32:
    var n = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] == color:
            n = n + 1
        i = i + 1
    return n

# ---------------------------------------------------------------------------
# Processing halves.
# ---------------------------------------------------------------------------
fn assert_cuda_processing_half():
    step("processing=cuda: honest host probe (probe_cuda_processing), fail-closed")
    val p = probe_cuda_processing()
    expect(p.api_name).to_equal("cuda")
    if p.status == BackendStatus.Initialized:
        step("cuda device present: probe reports compute capability")
        expect(p.has_compute).to_equal(true)
    else:
        step("host-unavailable(cuda): concrete feature_gate classification, not silent skip")
        val gate = p.feature_gate
        val ok = (gate == "cuda-device-unavailable" or
                  gate == "cuda_runtime" or
                  gate == "cuda_init")
        assert_true(ok)
        expect(p.reason.len()).to_be_greater_than(0)

fn assert_vulkan_processing_half():
    step("processing=vulkan: payload-gated offload lane, absolute oracle (60==60, gate flips ran_on_cpu)")
    assert_payload_gating(ComputeBackend.Vulkan)

fn assert_metal_processing_half():
    step("processing=metal: payload-gated offload lane, absolute oracle (60==60, gate flips ran_on_cpu)")
    assert_payload_gating(ComputeBackend.Metal)

# ---------------------------------------------------------------------------
# Vulkan drawing half via the Engine2D facade. Returns true if the scene was
# drawn+verified, false if the host has no Vulkan device (already fail-closed).
# ---------------------------------------------------------------------------
fn vulkan_draw_scene_or_unavailable(scene: text) -> bool:
    step("drawing=vulkan: probe via Engine2D facade")
    val probe = Engine2D.probe_backend(DRAW_W, DRAW_H, "vulkan")
    if not probe.is_ok():
        step("host-unavailable(vulkan): fail-closed checkpoint (concrete reason, not a skip)")
        assert_false(probe.available)
        expect(probe.reason.len()).to_be_greater_than(0)
        return false

    step("create-success: requested vulkan resolves to its honest name")
    val created = Engine2D.create_requested_backend(DRAW_W, DRAW_H, "vulkan")
    assert_true(created.is_ok())
    var eng = created.unwrap()
    expect(eng.backend_name()).to_equal("vulkan")

    eng.clear(BG)
    if scene == "2d":
        step("draw 2D: filled rect + line on a real framebuffer")
        eng.draw_rect_filled(4, 4, 10, 6, RECT_COLOR)
        eng.draw_line(0, 18, 31, 18, LINE_COLOR, 1)
    else:
        step("draw GUI widget-layer scene: titlebar bar + button rect")
        eng.draw_rect_filled(0, 0, DRAW_W, 4, LINE_COLOR)   # titlebar bar
        eng.draw_rect_filled(8, 10, 10, 8, RECT_COLOR)      # button
    eng.present()

    step("readback: read_pixels() absolute oracle")
    val px = eng.read_pixels()
    expect(px.len()).to_equal(DRAW_W * DRAW_H)
    if scene == "2d":
        assert_color_eq(px_at(px, DRAW_W, 8, 6), RECT_COLOR)
        assert_color_eq(px_at(px, DRAW_W, 15, 18), LINE_COLOR)
        assert_color_eq(px_at(px, DRAW_W, 1, 1), BG)
    else:
        assert_color_eq(px_at(px, DRAW_W, 12, 13), RECT_COLOR)   # button interior
        assert_color_eq(px_at(px, DRAW_W, 1, 1), LINE_COLOR)     # titlebar
        assert_color_eq(px_at(px, DRAW_W, 25, 20), BG)           # empty area

    step("P6 PPM wrapper encodes a valid header")
    val ppm = read_pixels_ppm(DRAW_W, DRAW_H, px)
    expect(ppm.len()).to_be_greater_than(DRAW_W * DRAW_H * 3)
    expect(ppm[0]).to_equal(80u8)   # 'P'
    expect(ppm[1]).to_equal(54u8)   # '6'
    eng.shutdown()
    return true

# ---------------------------------------------------------------------------
# Web surface: styled-box HTML fixture rendered headlessly, vulkan drawing lane.
# ---------------------------------------------------------------------------
fn assert_web_vulkan_render():
    step("web: render a styled-box HTML fixture headlessly via the vulkan Engine2D web lane")
    val html = "<html><head><style>.card{width:40px;height:18px;background-color:#1d4ed8;border:2px solid #f59e0b}</style></head><body><div class='card'></div></body></html>"
    val w: i32 = 80
    val h: i32 = 48
    val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(html, w, h, "vulkan")
    expect(pixels.len()).to_equal(w * h)
    step("PPM oracle: box background #1d4ed8 AND styled-box border #f59e0b both render (post Draw-IR fix)")
    expect(count_color(pixels, 0xFF1D4ED8u32)).to_be_greater_than(0)   # box background
    expect(count_color(pixels, 0xFFF59E0Bu32)).to_be_greater_than(0)   # styled-box border
    val ppm = read_pixels_ppm(w, h, pixels)
    expect(ppm[0]).to_equal(80u8)
    expect(ppm[1]).to_equal(54u8)

# ---------------------------------------------------------------------------
# Event surface: real reducer drives a re-render pixel change.
# ---------------------------------------------------------------------------
# Offscreen drawing surface: vulkan preferred, honest software offscreen
# fallback (always available, same absolute oracle) when no Vulkan device — the
# event chain, not the GPU device, is what this lane verifies.
fn open_draw_surface(w: i32, h: i32) -> Engine2D:
    val vprobe = Engine2D.probe_backend(w, h, "vulkan")
    if vprobe.is_ok():
        val cv = Engine2D.create_requested_backend(w, h, "vulkan")
        if cv.is_ok():
            return cv.unwrap()
    val cs = Engine2D.create_requested_backend(w, h, "software")
    return cs.unwrap()

fn render_button(eng: Engine2D, focused: bool):
    eng.clear(BG)
    var col = BTN_NORMAL
    if focused:
        col = BTN_FOCUSED
    # Button rect covers x 4..19, y 4..15 — press point (10,10) is inside.
    eng.draw_rect_filled(4, 4, 16, 12, col)
    eng.present()

fn assert_event_render_chain():
    step("build a one-button UI tree (real widget/builder path)")
    val root = column("combo_root", [button("combo_btn", "Click", "act")])
    val state0 = UIState.new(build_tree(root))

    step("frame 1: render button in NORMAL color (state not focused)")
    val w: i32 = 24
    val h: i32 = 16
    var s1 = open_draw_surface(w, h)
    render_button(s1, state0.focused_id == "combo_btn")
    val f1 = s1.read_pixels()
    s1.shutdown()

    step("dispatch TouchPress inside the button rect — real reducer moves focus")
    val pressed = process_event(state0, UIEvent.TouchPress(x: 10, y: 10))
    expect(pressed.focused_id).to_equal("combo_btn")

    step("frame 2: re-render; button pixel now FOCUSED color, driven by the new state")
    var s2 = open_draw_surface(w, h)
    render_button(s2, pressed.focused_id == "combo_btn")
    val f2 = s2.read_pixels()
    s2.shutdown()

    step("verify: changed pixel flips NORMAL -> FOCUSED (absolute both frames); background unchanged")
    assert_color_eq(px_at(f1, w, 10, 10), BTN_NORMAL)
    assert_color_eq(px_at(f2, w, 10, 10), BTN_FOCUSED)
    assert_false(px_at(f1, w, 10, 10) == px_at(f2, w, 10, 10))
    assert_color_eq(px_at(f1, w, 1, 1), BG)
    assert_color_eq(px_at(f2, w, 1, 1), BG)

describe "Processing × Drawing combination runs — headless offscreen (cuda/vulkan, vulkan/vulkan, metal/vulkan)":

    it "cuda/vulkan — 2D: cuda processing honest probe (device or fail-closed) + vulkan drawing readback":
        assert_cuda_processing_half()
        vulkan_draw_scene_or_unavailable("2d")

    it "vulkan/vulkan — 2D: vulkan payload-gated processing + vulkan drawing readback":
        assert_vulkan_processing_half()
        vulkan_draw_scene_or_unavailable("2d")

    it "metal/vulkan — 2D: metal payload-gated processing + vulkan drawing readback":
        assert_metal_processing_half()
        vulkan_draw_scene_or_unavailable("2d")

    it "cuda/vulkan — GUI widget-layer scene: cuda processing honest probe + vulkan drawing readback":
        assert_cuda_processing_half()
        vulkan_draw_scene_or_unavailable("gui")

    it "vulkan/vulkan — GUI widget-layer scene: vulkan processing + vulkan drawing readback":
        assert_vulkan_processing_half()
        vulkan_draw_scene_or_unavailable("gui")

    it "metal/vulkan — GUI widget-layer scene: metal processing + vulkan drawing readback":
        assert_metal_processing_half()
        vulkan_draw_scene_or_unavailable("gui")

    it "cuda/vulkan — Web: cuda processing honest probe + vulkan-drawn HTML fixture PPM oracle":
        assert_cuda_processing_half()
        assert_web_vulkan_render()

    it "vulkan/vulkan — Web: vulkan processing + vulkan-drawn HTML fixture PPM oracle":
        assert_vulkan_processing_half()
        assert_web_vulkan_render()

    it "metal/vulkan — Web: metal processing + vulkan-drawn HTML fixture PPM oracle":
        assert_metal_processing_half()
        assert_web_vulkan_render()

    it "cuda/vulkan — Event: pointer press moves focus, re-render flips the button pixel":
        assert_cuda_processing_half()
        assert_event_render_chain()

    it "vulkan/vulkan — Event: pointer press moves focus, re-render flips the button pixel":
        assert_vulkan_processing_half()
        assert_event_render_chain()

    it "metal/vulkan — Event: pointer press moves focus, re-render flips the button pixel":
        assert_metal_processing_half()
        assert_event_render_chain()
