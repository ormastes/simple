    val plan = file_read("doc/03_plan/agent_tasks/gui_rendering_parallel_agent_plan_2026-06-27.md")
    val spec = file_read("test/03_system/check/gui_web_2d_goal_completion_criteria_spec.spl")
    expect(plan).to_contain("| iOS Tauri/WKWebView Metal |")
    expect(plan).to_contain("| Android Tauri/WebView Vulkan |")
    expect(plan).to_contain("| Cross-platform freshness |")
    expect(plan).to_contain("scripts/check/check-gui-renderdoc-feature-coverage-status.shs")
    expect(plan).to_contain("scripts/check/check-tauri-mobile-renderer-parity-evidence.shs")
    expect(plan).to_contain("scripts/check/check-gui-web-2d-headless-handoff-prep.shs")
    expect(plan).to_contain("test/03_system/check/gui_web_2d_five_platform_handoff_contract_spec.spl")
    expect(plan).to_contain("Linux, macOS, Windows, iOS, and Android evidence reports are all fresh")
    expect(plan).to_contain("same current source revision")
    expect(plan).to_contain("runtime build")
    expect(plan).to_contain("browser/WebView/Electron revision")
    expect(plan).to_contain("graphics SDK/driver revision")
    expect(plan).to_contain("platform runbook version")
    expect(plan).to_contain("Historical evidence is retained as preparation only")
    expect(spec).to_contain("native_gui_platform_verification_required_platforms")
    expect(spec).to_contain("linux-vulkan,macos-metal,windows-d3d12")
    expect(spec).to_contain("tauri_mobile_renderer_parity_status")
    expect(spec).to_contain("tauri_mobile_renderer_parity_ios_status")
    expect(spec).to_contain("tauri_mobile_renderer_parity_android_status")
    "pass"

fn value_of(lines: text, key: text) -> text:
    val prefix = key + "="
    val parts = lines.split("\n")
    var found = ""
    for line in parts:
        if line.starts_with(prefix):
            found = line.slice(prefix.len(), line.len())
    found

fn assert_retained_perf_row(evidence: text, prefix: text, resolution: text, width: text, height: text, pixels: text, rss_budget: text):
    expect(value_of(evidence, prefix + "_status")).to_equal("pass")
    if resolution == "4k":
        expect(value_of(evidence, prefix + "_reason")).to_equal("met-200fps")
    else:
        expect(value_of(evidence, prefix + "_reason")).to_equal("met-target-fps")
    expect(value_of(evidence, prefix + "_resolution")).to_equal(resolution)
    expect(value_of(evidence, prefix + "_width")).to_equal(width)
    expect(value_of(evidence, prefix + "_height")).to_equal(height)
    expect(value_of(evidence, prefix + "_pixels")).to_equal(pixels)
    expect(value_of(evidence, prefix + "_backend")).to_equal("simple-retained-widget-showcase")
    expect((value_of(evidence, prefix + "_frames").to_i64() ?? 0)).to_be_greater_than(199)
    expect(value_of(evidence, prefix + "_target_fps")).to_equal("200")
    expect((value_of(evidence, prefix + "_fps_x1000").to_i64() ?? 0)).to_be_greater_than(199999)
    expect((value_of(evidence, prefix + "_frame_avg_ns").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "_frame_p50_ns").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "_frame_p95_ns").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "_frame_avg_ns").to_i64() ?? 0)).to_be_less_than(5000001)
    expect((value_of(evidence, prefix + "_frame_p50_ns").to_i64() ?? 0)).to_be_less_than(5000001)
    expect((value_of(evidence, prefix + "_frame_p95_ns").to_i64() ?? 0)).to_be_less_than(5000001)
    expect(value_of(evidence, prefix + "_frame_distribution_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_frame_elapsed_ns_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_max_rss_budget_kb")).to_equal(rss_budget)
    expect(value_of(evidence, prefix + "_rss_status")).to_equal("pass")
    expect((value_of(evidence, prefix + "_max_rss_kb").to_i64() ?? 0)).to_be_greater_than(0)
    expect((value_of(evidence, prefix + "_nonzero_pixels").to_i64() ?? 0)).to_be_greater_than(0)
    expect(value_of(evidence, prefix + "_nonzero_pixels_status")).to_equal("pass")
    expect((value_of(evidence, prefix + "_checksum").to_i64() ?? 0)).to_be_greater_than(0)
    expect(value_of(evidence, prefix + "_checksum_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_readback_mode")).to_equal("argb-checksum")
    expect(value_of(evidence, prefix + "_render_mode")).to_equal("retained-static-frame")
    expect(value_of(evidence, prefix + "_retained_render_mode_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_redraw_frames")).to_equal("1")
    expect(value_of(evidence, prefix + "_retained_redraw_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_source_revision_kind")).to_equal("content-sha256")
    expect(value_of(evidence, prefix + "_source_revision_files_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_missing_source_revision_files")).to_equal("")
    expect(value_of(evidence, prefix + "_require_current_source_revision")).to_equal("1")
    expect(value_of(evidence, prefix + "_source_revision_status")).to_equal("current")
    expect(value_of(evidence, prefix + "_source_revision")).to_equal(value_of(evidence, prefix + "_current_source_revision"))
    expect(value_of(evidence, prefix + "_simple_bin_source")).to_equal("self-hosted-release")
    expect(value_of(evidence, prefix + "_simple_bin_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_simple_bin")).to_contain("release/")
    expect(value_of(evidence, prefix + "_use_native")).to_equal("1")
    expect(value_of(evidence, prefix + "_native_build_mode")).to_equal("aggressive-native")
    expect(value_of(evidence, prefix + "_fallback_state")).to_equal("none")
    expect(value_of(evidence, prefix + "_native_bin_file_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_native_bin_executable_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_native_bin_format_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_alias_src_file_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_alias_raw_rt_count")).to_equal("0")
    expect(value_of(evidence, prefix + "_native_build_log_file_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_log_file_status")).to_equal("pass")
    expect(value_of(evidence, prefix + "_time_log_file_status")).to_equal("pass")

