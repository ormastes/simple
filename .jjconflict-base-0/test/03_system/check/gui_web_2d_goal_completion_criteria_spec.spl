fn verify_windows_electron_vulkan_parity_completion() -> text:
    val root = unique_build_root("windows-electron-vulkan")
    val command = "rm -rf " + root + " && " +
        aggregate_cache_env(root) +
        "BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md " +
        "sh scripts/check/check-gui-renderdoc-feature-coverage-status.shs >/dev/null || true"
    val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
    expect(code).to_equal(0)

    val evidence = file_read(root + "/out/evidence.env")
    expect(value_of(evidence, "electron_vulkan_web_parity_windows_status")).to_equal("pass")
    expect(value_of(evidence, "electron_vulkan_web_parity_windows_reason")).to_equal("pixel-exact-vulkan")
    expect(value_of(evidence, "electron_vulkan_web_parity_windows_host_os")).to_equal("Windows_NT")
