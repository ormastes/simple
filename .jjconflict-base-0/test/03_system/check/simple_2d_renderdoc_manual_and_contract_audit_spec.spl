# codex-system-test
# @req REQ-010 REQ-014 REQ-015
"""# Simple 2D RenderDoc Manual and Contract Audit

Keeps executable modern SSpec, generated manuals, guides, cooperative review,
and source-layout contracts synchronized.
"""
use std.spec.*
fn pending_manual_contract_audit(): fail("manual and workflow contract audit is required")

describe "Simple 2D RenderDoc documentation contract":
    it "should mirror every executable scenario into a zero-stub manual":
        step("Inspect all backend-equivalence spec and manual pairs")
        expect(13).to_be_greater_than(0)
        pending_manual_contract_audit()
    it "should keep modern steps captures requirements and direct matchers":
        step("Audit scenario source quality")
        expect(["step", "capture", "req", "expect"].len()).to_equal(4)
        pending_manual_contract_audit()
    # @manual: folded
    it "should reject executable specs under the generated manual tree":
        step("Scan doc/06_spec for executable Simple files")
        expect(0).to_equal(0)
        pending_manual_contract_audit()
    # @manual: folded
    it "should require sidecar merge and highest-capability review evidence":
        step("Inspect cooperative review completion")
        expect("highest-capability-review").to_contain("review")
        pending_manual_contract_audit()

