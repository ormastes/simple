"""
# SimpleOS WM Fullscreen Evidence Simple Binary Contract

Validates that the SimpleOS WM fullscreen evidence wrapper uses self-hosted
Simple binaries by default, rejects Rust seed overrides before launching
QEMU, and records launcher provenance in evidence output.

## Overview

The live fullscreen check requires QEMU and a running SimpleOS `wm-simple-web`
target, but its binary-selection contract and marker-name expectations can be
verified without launching either. Rust seed overrides must fail before
launch artifacts are produced.

## Requirements

**Requirements:** N/A

- REQ-SIMPLEOS-WM-FULLSCREEN-001: Default Simple binary selection is
  self-hosted only.
- REQ-SIMPLEOS-WM-FULLSCREEN-002: Explicit Rust seed paths produce
  `simple-bin-forbidden` before SimpleOS/QMP launch.
- REQ-SIMPLEOS-WM-FULLSCREEN-003: Evidence output records selected Simple
  binary, source, and status fields.
- REQ-SIMPLEOS-WM-FULLSCREEN-004: The wrapper waits for
  `[wm-demo] fullscreen-enter` / `[wm-demo] fullscreen-exit` markers and
  compares two independent QMP screendumps for a real pixel delta.
- REQ-SIMPLEOS-WM-FULLSCREEN-005: The boot-time WM demo derives the
  fullscreen marker's reported size from live window-state variables (not a
  hardcoded string), and restores prior window geometry after the hold.

## Plan

**Plan:** doc/03_plan/os/wm/simple_gui_wm_restart_2026-05-28.md

1. Inspect the wrapper source for self-hosted candidate selection.
2. Inspect the wrapper source for Rust seed detection and provenance fields.
3. Inspect the wrapper source for the fullscreen/restore marker and
   pixel-delta contract.
4. Inspect the guest entry source for the fullscreen state machine (maximize
   to framebuffer size, save/restore geometry, hold for capture).
5. Run the wrapper with a Rust seed `SIMPLE_BIN` override.
6. Confirm stdout and report show `simple-bin-forbidden`.
7. Confirm QEMU and screendump artifacts are not created.

## Design

**Design:** doc/04_architecture/compiler/graphics/accelerated_shared_ui_backend_architecture.md

The wrapper validates `SIMPLE_BIN` before launching the SimpleOS `wm-simple-web`
QEMU target so invalid Rust seed overrides cannot masquerade as GUI/QMP
evidence.

## Research

**Research:** doc/01_research/ui/render_path/gui_web_2d_path_assessment_2026-06-12.md

## Examples

```sh
SIMPLE_LIB=src bin/simple test test/03_system/check/simpleos_wm_fullscreen_evidence_simple_bin_spec.spl --mode=interpreter --clean
```
"""

# @tag: system, gui, simpleos, qmp, simple-bin, wm, fullscreen

use std.io_runtime.{file_read, process_run}
use std.spec.*

describe "SimpleOS WM fullscreen evidence Simple binary contract":

    it "selects self hosted Simple and records launcher provenance":
        val script = file_read("scripts/check/check-simpleos-wm-fullscreen-evidence.shs")
        expect(script).to_contain("SIMPLE_BIN_SOURCE=")
        expect(script).to_contain("SIMPLE_BIN_STATUS=pass")
        expect(script).to_contain("\"$ROOT_DIR\"/bin/release/*/simple")
        expect(script).to_contain("\"$ROOT_DIR\"/release/*/simple")
        expect(script).to_contain("\"$ROOT_DIR\"/build/bootstrap/stage3/simple")
        expect(script).to_contain("\"$ROOT_DIR\"/bin/simple")
        expect(script).to_contain("is_rust_seed_simple")
        expect(script).to_contain("SIMPLE_BIN_STATUS=forbidden")
        expect(script).to_contain("export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS")
        expect(script).to_contain("simpleos_wm_fullscreen_simple_bin=")
        expect(script).to_contain("simpleos_wm_fullscreen_simple_bin_source=")
        expect(script).to_contain("simpleos_wm_fullscreen_simple_bin_status=")

    it "waits for boot-time fullscreen markers and proves a real pixel delta":
        val script = file_read("scripts/check/check-simpleos-wm-fullscreen-evidence.shs")
        expect(script).to_contain("[wm-demo] fullscreen-enter")
        expect(script).to_contain("[wm-demo] fullscreen-exit")
        expect(script).to_contain("simpleos_wm_fullscreen_width")
        expect(script).to_contain("simpleos_wm_fullscreen_height")
        expect(script).to_contain("simpleos_wm_fullscreen_changed_bytes")
        expect(script).to_contain("fullscreen-size-not-framebuffer-size")
        expect(script).to_contain("fullscreen-restore-pixel-delta-not-proven")
        expect(script).to_contain("pmemsave")

    it "implements a real fullscreen/restore window-state toggle in the guest entry":
        val entry = file_read("examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d.spl")
        expect(entry).to_contain("_present_mdi_scene_direct_fb(fb_addr: u64, stride: i32, app_count: i64, win0_fullscreen: u64)")
        expect(entry).to_contain("_win0_default_x")
        expect(entry).to_contain("_win0_default_w")
        expect(entry).to_contain("[wm-demo] fullscreen-enter window=0 size=")
        expect(entry).to_contain("[wm-demo] fullscreen-exit window=0 restored=true")
        # The marker's size fields must come from live locals derived from
        # _fb_w()/_fb_h() (the WM's own framebuffer-size source of truth),
        # not a hardcoded string constant.
        expect(entry).to_contain("val fs_w: i32 = _fb_w()")
        expect(entry).to_contain("val fs_h: i32 = _fb_h()")
        # Marker must be emitted after the existing windows-ready phase.
        val windows_ready_idx = entry.index_of("[mdi-demo] windows-ready count=")
        val fullscreen_enter_idx = entry.index_of("[wm-demo] fullscreen-enter")
        assert_true(windows_ready_idx >= 0)
        assert_true(fullscreen_enter_idx > windows_ready_idx)

    it "rejects explicit Rust seed before SimpleOS QMP launch":
        val root = "build/test-simpleos-wm-fullscreen-seed-forbidden"
        val command = "rm -rf " + root + " && mkdir -p " + root + " && SIMPLE_BIN=src/compiler_rust/target/release/simple BUILD_DIR=" + root + "/out REPORT_PATH=" + root + "/report.md sh scripts/check/check-simpleos-wm-fullscreen-evidence.shs > " + root + "/stdout.txt 2> " + root + "/stderr.txt || true"
        val (_stdout, _stderr, code) = process_run("/bin/sh", ["-c", command])
        expect(code).to_equal(0)

        val output = file_read(root + "/stdout.txt")
        expect(output).to_contain("simpleos_wm_fullscreen_status=fail")
        expect(output).to_contain("simpleos_wm_fullscreen_reason=simple-bin-forbidden")
        expect(output).to_contain("simpleos_wm_fullscreen_simple_bin=src/compiler_rust/target/release/simple")
        expect(output).to_contain("simpleos_wm_fullscreen_simple_bin_source=explicit-env-rust-seed-forbidden")
        expect(output).to_contain("simpleos_wm_fullscreen_simple_bin_status=forbidden")

        val report = file_read(root + "/report.md")
        expect(report).to_contain("- reason: simple-bin-forbidden")
        val (_qemu_out, _qemu_err, qemu_code) = process_run("/bin/sh", ["-c", "test ! -f " + root + "/out/qemu.out"])
        expect(qemu_code).to_equal(0)
        val (_capture_out, _capture_err, capture_code) = process_run("/bin/sh", ["-c", "test ! -f " + root + "/out/capture.out"])
        expect(capture_code).to_equal(0)
