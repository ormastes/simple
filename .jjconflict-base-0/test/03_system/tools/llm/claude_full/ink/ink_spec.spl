"""
# Claude Full Ink File Matrix Spec

Matrix-location coverage for `ink/ink.tsx`; delegates to the focused component
slice shape while keeping the expected file artifact present.
"""

use std.spec.*
use app.llm_caret.claude_full.ink.ink.*

describe "Claude full Ink file matrix parity":
    it "should expose matrix-required ink.tsx symbols":
        step("Check exported type/function route surface")
        val options = Options.new(true, true, false, true)
        expect(options.exitOnCtrlC).to_equal(true)
        expect(makeAltScreenParkPatch(2)).to_equal("\x1b[2;1H")
        expect(deferredRenderRoute(false, true, false)).to_equal("queue microtask then schedule deferred frame")
        expect(blank(2)).to_equal("  ")
        expect(toDebug("debug")).to_equal("debug")
        expect(toError("error")).to_equal("error")
        expect(interceptWriteRoute(false, true, false, false)).to_equal("mark frame contaminated schedule render")
        expect(interceptCallbackRoute(false, true)).to_equal("stderr callback cleanup exactly once")
        expect(drainStdinPlatformRoute("linux", 64, true)).to_equal("bounded 64 reads cleanup")
        expect(inkSourceLinesModeled()).to_equal(1722)
