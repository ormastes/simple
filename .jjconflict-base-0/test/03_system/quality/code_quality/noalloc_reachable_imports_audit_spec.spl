# noalloc_reachable_imports_audit_spec
#
# Verifies the noalloc reachable-import audit runs through a Simple script.

use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "noalloc reachable imports audit":

    it "keeps reachable noalloc imports restricted to noalloc and common roots":
        val result = rt_process_run("bin/simple", ["run", "scripts/audit/noalloc_reachable_imports.spl"])
        expect(result.2).to_equal(0)
        expect(result.0).to_contain("noalloc reachable import closure is restricted to nogc_async_mut_noalloc/common")
