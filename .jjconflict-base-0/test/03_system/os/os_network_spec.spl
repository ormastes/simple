# OS Network Integration Test
#
# Tests: VirtIO-net driver -> TCP/IP stack -> socket API
# QEMU scenario: x64-net-user (user-mode networking, gateway at 10.0.2.2)
#
# Network stack tested:
#   PCI enumeration -> VirtIO-net driver -> Ethernet -> ARP/IPv4 ->
#   TCP/UDP -> POSIX socket API
#
# Note: QEMU user-mode networking provides a virtual gateway at 10.0.2.2
# and a DHCP server at 10.0.2.2. DNS is at 10.0.2.3. The guest IP defaults
# to 10.0.2.15 in the netstack configuration.
#
# This test runs as a baremetal OS entry point, not under the SPipe harness.
# Output goes to serial and is parsed by the QEMU test runner.

use os.kernel.boot.init_services.{init_services, services_storage_ready, services_network_ready}
use os.posix.mod.{posix_init}
use os.posix.socket_compat.{posix_socket, posix_bind, posix_connect, posix_send, posix_recv, posix_close_socket, sockaddr_in, sockaddr_any, AF_INET, SOCK_STREAM, SOCK_DGRAM, SockaddrIn}
use os.services.netstack.net_test_scaffold.{HttpCapReport, QemuTestPhase}
use os.userlib.syscall_raw.{syscall}

extern fn serial_println(msg: text)
extern fn rt_exit(code: i32)

val ISA_DEBUG_EXIT_PORT: u64 = 0xf4

var _pass_count: u32 = 0
var _fail_count: u32 = 0

fn _assert(condition: bool, name: text):
    if condition:
        serial_println("[TEST PASS] {name}")
        _pass_count = _pass_count + 1
    else:
        serial_println("[TEST FAIL: {name}]")
        _fail_count = _fail_count + 1

fn _report():
    """Print summary and exit QEMU."""
    serial_println("")
    serial_println("Network tests: {_pass_count} passed, {_fail_count} failed")
    if _fail_count == 0:
        serial_println("[ALL TESTS PASSED]")
    else:
        serial_println("[TESTS FAILED: {_fail_count}]")
    syscall(ISA_DEBUG_EXIT_PORT, 0, 0, 0, 0, 0)

fn os_network_test():
    """Entry point for VirtIO-net + TCP/IP integration tests."""
    serial_println("=== OS Network Integration Test ===")
    serial_println("")

    # Initialize POSIX layer
    posix_init()

    # Boot all services (including network when VirtIO-net is present)
    init_services()

    # ---- Test 1: Network stack initialization status ----
    val net_ready = services_network_ready()
    serial_println("[INFO] services_network_ready() = {net_ready}")
    _assert(net_ready, "Network stack initialized")

    # ---- Test 2: TCP socket creation ----
    val tcp_fd = posix_socket(AF_INET, SOCK_STREAM, 0)
    serial_println("[INFO] posix_socket(AF_INET, SOCK_STREAM, 0) = {tcp_fd}")
    _assert(tcp_fd >= 0, "TCP socket created (fd={tcp_fd})")

    # ---- Test 3: UDP socket creation ----
    val udp_fd = posix_socket(AF_INET, SOCK_DGRAM, 0)
    serial_println("[INFO] posix_socket(AF_INET, SOCK_DGRAM, 0) = {udp_fd}")
    _assert(udp_fd >= 0, "UDP socket created (fd={udp_fd})")

    # ---- Test 4: Invalid domain rejected ----
    val bad_fd = posix_socket(99, SOCK_STREAM, 0)
    _assert(bad_fd < 0, "Socket with invalid domain returns error (fd={bad_fd})")

    # ---- Test 5: Invalid socket type rejected ----
    val bad_type = posix_socket(AF_INET, 99, 0)
    _assert(bad_type < 0, "Socket with invalid type returns error (fd={bad_type})")

    # ---- Test 6: Bind to a port (if socket was created) ----
    if tcp_fd >= 0:
        val addr = sockaddr_any(8080)
        val bind_result = posix_bind(tcp_fd.to_i32(), addr)
        serial_println("[INFO] posix_bind(fd={tcp_fd}, port=8080) = {bind_result}")
        _assert(bind_result >= 0, "Bind TCP socket to port 8080")
        posix_close_socket(tcp_fd.to_i32())
    else:
        _assert(false, "Bind call skipped because TCP socket was unavailable")

    # ---- Test 7: TCP connect to QEMU gateway ----
    # QEMU user-mode networking exposes gateway at 10.0.2.2.
    # This prints phase and capability evidence for FR-NET-0001.
    val conn_fd = posix_socket(AF_INET, SOCK_STREAM, 0)
    if conn_fd >= 0:
        val connect_phase = QemuTestPhase.create("connect-success-qemu-gateway", 2000).start()
        val caps = HttpCapReport.create("portable", false, false, 64)
        serial_println("[INFO] net backend capability summary: {caps.startup_line()}")
        serial_println("[INFO] connect phase started: {connect_phase.phase_name} timeout_ms={connect_phase.timeout_ms} fd={conn_fd}")
        val gw_addr = sockaddr_in(80, 10, 0, 2, 2)
        val conn_result = posix_connect(conn_fd.to_i32(), gw_addr)
        serial_println("[INFO] posix_connect(10.0.2.2:80) = {conn_result}")
        val finished = connect_phase.complete()
        serial_println("[INFO] connect phase completed: {finished.phase_name} ok={finished.is_ok()} result={conn_result}")
        _assert(conn_result >= 0, "TCP connect to QEMU gateway succeeds")
        posix_close_socket(conn_fd.to_i32())
    else:
        _assert(false, "TCP connect skipped because socket was unavailable")

    # ---- Test 8: TCP refused/timeout connect is bounded and reported ----
    val fail_fd = posix_socket(AF_INET, SOCK_STREAM, 0)
    if fail_fd >= 0:
        val fail_phase = QemuTestPhase.create("connect-refused-or-timeout-qemu-gateway", 2000).start()
        serial_println("[INFO] connect phase started: {fail_phase.phase_name} timeout_ms={fail_phase.timeout_ms} fd={fail_fd}")
        val closed_addr = sockaddr_in(1, 10, 0, 2, 2)
        val fail_result = posix_connect(fail_fd.to_i32(), closed_addr)
        serial_println("[INFO] posix_connect(10.0.2.2:1) = {fail_result}")
        if fail_result < 0:
            val finished = fail_phase.complete()
            serial_println("[INFO] connect phase completed: {finished.phase_name} ok={finished.is_ok()} result={fail_result}")
        else:
            val timed_out = fail_phase.timeout()
            serial_println("[INFO] connect phase unexpected success: {timed_out.failure_message()} result={fail_result}")
        _assert(fail_result < 0, "TCP connect to closed QEMU gateway port reports refused or timeout")
        posix_close_socket(fail_fd.to_i32())
    else:
        _assert(false, "TCP refused/timeout connect skipped because socket was unavailable")

    # ---- Test 9: Close an already-closed socket ----
    if udp_fd >= 0:
        posix_close_socket(udp_fd.to_i32())
        # Second close should return an error, not crash
        val double_close = posix_close_socket(udp_fd.to_i32())
        _assert(not double_close, "Double close returns an error")
    else:
        _assert(false, "Double close skipped because UDP socket was unavailable")

    # ---- Test 10: sockaddr_in construction ----
    val sa = sockaddr_in(443, 192, 168, 1, 1)
    _assert(sa.family == AF_INET, "sockaddr_in family is AF_INET")
    _assert(sa.port == 443, "sockaddr_in port is 443")

    _report()
