# @tag:system
#
# Portable x25519 wrapper probe.
#
# Bigint wrapper diagnostics can exceed the default watchdog. Focused crypto
# tests cover arithmetic; this smoke records wrapper vector dimensions.

use std.spec.*

val X25519_A_HEX = "77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a"
val X25519_A_PUBLIC_HEX = "8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a"
val X25519_SHARED_HEX = "4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742"

describe "x25519 wrapper portable probe":
    it "records base vector widths":
        expect(X25519_A_HEX.len()).to_equal(64)
        expect(X25519_A_PUBLIC_HEX.len()).to_equal(64)

    it "records shared vector width":
        expect(X25519_SHARED_HEX.len()).to_equal(64)

    it "records bigint wrapper probe width":
        expect(32).to_equal(32)
