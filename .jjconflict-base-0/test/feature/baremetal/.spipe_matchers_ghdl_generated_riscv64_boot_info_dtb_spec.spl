#!/usr/bin/env simple

use std.spec.*

val GENERATED_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_boot_info_dtb_runner.shs"
val DEFAULT_FW_STUB = "examples/09_embedded/fpga_riscv/sw/generated_rv64_fw_jump_stub.s"
val PAYLOAD_ENV = "GHDL_GENERATED_RV64_BOOT_INFO_DTB_PAYLOAD"

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn payload_path() -> text:
    rt_env_get(PAYLOAD_ENV) ?? ""

fn payload_args(payload: text) -> [text]:
    if payload.ends_with(".bin"):
        return [GENERATED_RUNNER, "--payload-bin", payload, "--timeout=30"]
    [GENERATED_RUNNER, "--payload-elf", payload, "--timeout=30"]

fn runner_tools_available() -> bool:
    val result = rt_process_run("bash", ["-lc", "command -v ghdl >/dev/null && command -v riscv64-linux-gnu-as >/dev/null && command -v riscv64-linux-gnu-ld >/dev/null && command -v riscv64-linux-gnu-objcopy >/dev/null"])
    result[2] == 0

describe "Generated RV64 compiled-payload boot-info DTB GHDL lane":
    it "runner script exists and is syntax-valid":
        expect rt_file_exists(GENERATED_RUNNER) == true
        expect rt_file_exists(DEFAULT_FW_STUB) == true
        val result = rt_process_run("bash", ["-n", GENERATED_RUNNER])
        expect result[2] == 0

    slow_it "runs the compiled-payload boot-info DTB runner when a payload ELF/bin is provided":
        if not runner_tools_available():
            return "skip: ghdl or riscv toolchain not available"
        val payload = payload_path()
        if payload == "":
            return "skip: set {PAYLOAD_ENV} to a compiled RV64 payload ELF/bin"
        if not rt_file_exists(payload):
            return "skip: payload file not found: {payload}"
        val result = rt_process_run_timeout("bash", payload_args(payload), 120000)
        val output = result[0] + result[1]
        expect result[2] == 0
        expect (output).contains("GENERATED_RV64_BOOT_INFO_DTB: PASS")
        expect (output).contains("DONE_LOW32: 1")
        expect (output).contains("DTB_VALID_LOW32: 1")
        expect (output).contains("MAP_LEN_LOW32: 3")
        expect (output).contains("REGION0_KIND_LOW32: 2")
        expect (output).contains("REGION1_KIND_LOW32: 8")
        expect (output).contains("REGION2_KIND_LOW32: 1")
        expect (output).contains("DTB_PROBE_SEEN: true")
        expect (output).contains("UART_MARKER_SEEN: true")
        expect (output).contains("PRIV_MODE: 1")