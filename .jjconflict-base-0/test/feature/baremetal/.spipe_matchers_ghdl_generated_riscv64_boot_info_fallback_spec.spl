#!/usr/bin/env simple

use std.spec.*

val GENERATED_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_boot_info_fallback_runner.shs"
val GENERATED_SMOKE = "examples/09_embedded/fpga_riscv/sw/generated_rv64_boot_info_fallback_smoke.s"

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn runner_tools_available() -> bool:
    val result = rt_process_run("bash", ["-lc", "command -v ghdl >/dev/null && command -v riscv64-linux-gnu-as >/dev/null && command -v riscv64-linux-gnu-ld >/dev/null && command -v riscv64-linux-gnu-objcopy >/dev/null"])
    result[2] == 0

describe "Generated RV64 boot-info fallback GHDL smoke":
    it "runner script exists and is syntax-valid":
        expect rt_file_exists(GENERATED_RUNNER) == true
        val result = rt_process_run("bash", ["-n", GENERATED_RUNNER])
        expect result[2] == 0

    slow_it "runs a generated RV64 boot-info fallback smoke program":
        if not runner_tools_available():
            return "skip: ghdl or riscv toolchain not available"
        val result = rt_process_run_timeout("bash", [GENERATED_RUNNER, GENERATED_SMOKE, "--timeout=30"], 120000)
        val output = result[0] + result[1]
        expect result[2] == 0
        expect (output).contains("GENERATED_RV64_BOOT_INFO_FALLBACK: PASS")
        expect (output).contains("DTB_VALID_LOW32: 0")
        expect (output).contains("A1_HEX32: 88000000")
        expect (output).contains("DTB_PROBE_SEEN: true")
        expect (output).contains("DTB_PROBE_ADDR_HEX32: 88000000")
        expect (output).contains("SERIAL_HEX32: 10000000")
        expect (output).contains("RAM_BASE_HEX32: 80000000")
        expect (output).contains("RAM_SIZE_HEX32: 08000000")