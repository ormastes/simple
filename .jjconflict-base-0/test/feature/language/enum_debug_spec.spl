"""
Enum method debug spec
"""
use std.spec
use std.spec.{expect}

enum MaybeNumber:
    Some(value: i64)
    None

impl MaybeNumber:
    fn is_some() -> bool:
        match self:
            case Some(_): true
            case None: false
    fn unwrap_or(default: i64) -> i64:
        match self:
            case Some(value): value
            case None: default

enum TrafficLight:
    Red
    Amber
    Green

impl TrafficLight:
    fn next() -> TrafficLight:
        match self:
            case Red: TrafficLight.Amber
            case Amber: TrafficLight.Green
            case Green: TrafficLight.Red
    fn label() -> text:
        match self:
            case Red: "red"
            case Amber: "amber"
            case Green: "green"

fn describe_light(t: TrafficLight) -> text:
    t.label()

describe "enum_debug":
    it "inline_is_some":
        expect(MaybeNumber.Some(9).is_some()).to_equal(true)
    it "var_is_some":
        val value = MaybeNumber.Some(9)
        expect(value.is_some()).to_equal(true)
    it "inline_traffic_chain":
        expect(describe_light(TrafficLight.Red.next().next().next())).to_equal("red")
    it "var_traffic_chain":
        val start = TrafficLight.Green
        expect(describe_light(start.next().next())).to_equal("red")
    it "var_unwrap":
        val value = MaybeNumber.Some(9)
        expect(value.unwrap_or(0)).to_equal(9)
