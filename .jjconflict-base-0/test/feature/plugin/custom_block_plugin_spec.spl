# Custom Block Plugin — AC-2 Spec
#
# **Feature IDs:** #AC2-BLOCK-PLUGIN
# **Category:** Plugin / BlockRegistry
# **Status:** Planned (Phase 5 implements; Phase 4 specifies)
#
# Validates the BlockRegistry-driven plugin path using local doubles.
# Phase 5 swaps doubles for real imports from
# src/compiler/15.blocks/blocks/registry.spl and easy.spl.

use std.spec

# ============================================================================
# Local doubles — mirror the BlockRegistry 80%-shape API
# ============================================================================

class BlockDef:
    kind: text
    mode: text        # "raw" | "math" | "normal"
    description: text

    static fn create(kind: text, mode: text) -> BlockDef:
        BlockDef(kind: kind, mode: mode, description: "Custom block: {kind}")

var _registry: [text] = []
var _registry_defs: [BlockDef] = []

# Built-in keywords — never overridable without explicit unregister
var _builtins: [text] = ["m", "loss", "nograd", "sh", "sql", "re", "json", "md"]

fn _init_builtins():
    for kw in _builtins:
        var found = false
        for existing in _registry:
            if existing == kw:
                found = true
        if not found:
            _registry = _registry + [kw]
            _registry_defs = _registry_defs + [BlockDef.create(kw, "raw")]

fn is_block(kind: text) -> bool:
    for kw in _registry:
        if kw == kind:
            return true
    false

fn list_blocks() -> [text]:
    _registry

fn get_block(kind: text):
    for bdef in _registry_defs:
        if bdef.kind == kind:
            return bdef
    nil

fn _is_builtin(kind: text) -> bool:
    for kw in _builtins:
        if kw == kind:
            return true
    false

fn register_block(bdef: BlockDef) -> bool:
    # Reject silent override of built-ins — caller must unregister first.
    # Returns false if keyword already taken (matches real register_block -> bool).
    if _is_builtin(bdef.kind) and is_block(bdef.kind):
        return false
    # Also reject any already-registered non-builtin without prior unregister
    if is_block(bdef.kind):
        return false
    _registry = _registry + [bdef.kind]
    _registry_defs = _registry_defs + [bdef]
    true

fn unregister_block(kind: text) -> bool:
    var remaining_kw: [text] = []
    var remaining_defs: [BlockDef] = []
    var removed = false
    for kw in _registry:
        if kw == kind:
            removed = true
        else:
            remaining_kw = remaining_kw + [kw]
    for bdef in _registry_defs:
        if bdef.kind != kind:
            remaining_defs = remaining_defs + [bdef]
    _registry = remaining_kw
    _registry_defs = remaining_defs
    removed

fn with_block(bdef: BlockDef, body: fn() -> bool) -> bool:
    val _reg = register_block(bdef)
    val result = body()
    unregister_block(bdef.kind)
    result

fn _reset_registry():
    _registry = []
    _registry_defs = []
    _init_builtins()

# CSV parser double — returns the trimmed payload as the parsed value
fn parse_csv(payload: text) -> text:
    payload.trim()

fn check(condition: bool):
    expect(condition).to_equal(true)

# ============================================================================
# Two-phase plugin loading doubles (mirrors plugin_startup.spl API)
# ============================================================================

# Indexed plugin hook table (pure-Simple path)
var _plugin_hooks: [text] = []
var _plugin_hook_fns: [fn() -> bool] = []

fn register_simple_plugin(name: text, hook: fn() -> bool):
    """Register a pure-Simple plugin setup hook (local double)."""
    var i = 0
    while i < _plugin_hooks.len():
        if _plugin_hooks[i] == name:
            _plugin_hook_fns[i] = hook
            return
        i = i + 1
    _plugin_hooks = _plugin_hooks + [name]
    _plugin_hook_fns = _plugin_hook_fns + [hook]

fn activate_plugin(name: text) -> bool:
    """Activate a named plugin (local double — pure-Simple path only)."""
    var i = 0
    while i < _plugin_hooks.len():
        if _plugin_hooks[i] == name:
            return (_plugin_hook_fns[i])()
        i = i + 1
    false

fn _reset_plugin_hooks():
    _plugin_hooks = []
    _plugin_hook_fns = []

# ============================================================================
# Spec
# ============================================================================

describe "AC-2: Custom Block Plugin — add and replace":

    it "new block registers and is visible":
        _reset_registry()
        val csv_def = BlockDef.create("csv", "raw")
        val _ok = register_block(csv_def)
        check(is_block("csv"))
        val all = list_blocks()
        check(all.contains("csv"))

    it "block parser-fn is invoked on use":
        # In-process path: call the parser-fn directly (end-to-end source
        # compilation is not testable in interpreter mode).
        val payload = "1,2,3"
        val result = parse_csv(payload)
        check(result == "1,2,3")

    it "unregister_block removes the entry":
        _reset_registry()
        val csv_def = BlockDef.create("csv", "raw")
        val _ok = register_block(csv_def)
        check(is_block("csv"))
        val removed = unregister_block("csv")
        check(removed)
        check(not is_block("csv"))

    it "with_block scope-registers and auto-cleans":
        _reset_registry()
        val csv_def = BlockDef.create("csv", "raw")
        fn body() -> bool:
            is_block("csv")
        val inside = with_block(csv_def, body)
        check(inside)
        check(not is_block("csv"))

    it "replacing a built-in is rejected — built-in stays intact":
        # register_block now returns false when keyword is already taken.
        # Attempt to register a fake 'm' def; registry must reject it and
        # the original built-in definition must be unchanged.
        _reset_registry()
        val original = get_block("m")
        val fake_m = BlockDef(kind: "m", mode: "math_fake", description: "fake")
        val rejected = register_block(fake_m)
        # Must return false — keyword was already taken
        check(not rejected)
        val after = get_block("m")
        # Built-in must still be present and its mode must not have changed
        check(is_block("m"))
        check(after.mode == original.mode)

    it "replace flow: unregister then register succeeds with new def":
        _reset_registry()
        val csv_v1 = BlockDef.create("csv", "raw")
        val _ok1 = register_block(csv_v1)
        check(is_block("csv"))
        unregister_block("csv")
        val csv_v2 = BlockDef(kind: "csv", mode: "normal", description: "csv v2")
        val _ok2 = register_block(csv_v2)
        check(is_block("csv"))
        val current = get_block("csv")
        check(current.mode == "normal")
        check(current.description == "csv v2")

    it "use_plugin semantics: blocks register only after explicit activate_plugin call":
        # Validates the two-phase contract from plugin_startup.spl:
        #   Phase 1 (index): plugin hook is registered but blocks NOT yet active
        #   Phase 2 (activate): activate_plugin("csv_plugin") fires the hook,
        #                       which calls register_block; is_block returns true.
        #
        # This scenario uses local doubles (same API shape as real module) so it
        # runs in interpreter mode without importing compiler.blocks.plugin_startup.
        # The companion spec plugin_startup_block_spec.spl imports the real module.
        _reset_registry()
        _reset_plugin_hooks()

        # Phase 1: register the plugin hook (simulates module init of csv_plugin.spl)
        fn csv_register() -> bool:
            val csv_def = BlockDef.create("csv", "raw")
            val _r = register_block(csv_def)
            true

        register_simple_plugin("csv_plugin", csv_register)

        # Before activate: block must NOT be in registry
        check(not is_block("csv"))

        # Phase 2: activate the plugin
        val ok = activate_plugin("csv_plugin")
        check(ok)

        # After activate: block IS in registry
        check(is_block("csv"))

