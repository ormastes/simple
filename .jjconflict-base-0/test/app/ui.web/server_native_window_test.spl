## Source-contract spec for ui.web native-window route helpers.
##
## The direct helper calls were passing and then still tripping the trailing
## teardown failure on this import surface. Keep this file on stable contract
## checks instead.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val SERVER_PATH = "src/app/ui.web/server.spl"

fn _read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "ui.web server native window route contracts":
    it "keeps query decoding helper coverage for encoded app ids":
        val source = _read_source(SERVER_PATH)
        expect(source).to_contain("fn _query_value(path: text, key: text) -> text:")
        expect(source).to_contain("%2F")
        expect(source).to_contain("+")

    it "keeps native window html resolution wired through app_id query values":
        val source = _read_source(SERVER_PATH)
        expect(source).to_contain("fn _native_window_html(path: text) -> text:")
        expect(source).to_contain("val app_id = _query_value(path, \"app_id\")")
        expect(source).to_contain("host_taskbar_runtime_native_window_html(app_id)")

    it "retains the unsupported-app fallback page":
        val source = _read_source(SERVER_PATH)
        expect(source).to_contain("Unsupported app")
        expect(source).to_contain("escape_json_str(app_id)")
