# Test: test/[ tool
# Feature: TOOL-TEST - Conditional expressions
# @cover tools/shell/test/test_tool.spl

describe "test tool":
    context "string tests":
        it "detects empty string with -z":
            val s = ""
            expect(s.len()).to_equal(0)

        it "detects non-empty string with -n":
            val s = "hello"
            expect(s.len()).to_be_greater_than(0)

        it "compares strings for equality":
            expect("abc" == "abc").to_equal(true)

        it "compares strings for inequality":
            expect("abc" != "def").to_equal(true)

    context "integer tests":
        it "integer equality":
            expect(5 == 5).to_equal(true)

        it "integer less-than":
            expect(3 < 5).to_equal(true)

        it "integer greater-than":
            expect(7 > 2).to_equal(true)

    context "negation":
        it "negates true to false":
            val result = if not true: 1 else: 0
            expect(result).to_equal(0)
