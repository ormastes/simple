# Test: wc tool
# Feature: TOOL-WC - Word, line, byte count

# Local reimplementation to avoid interpreter-mode import issues
# (importing app.tools.wc.main fails with "cannot index string with type `symbol`")

fn count_words(content: text) -> i64:
    """Count words (whitespace-separated tokens)."""
    var count = 0
    var in_word = false
    var i = 0
    while i < content.len():
        val ch = content[i:i + 1]
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            in_word = false
        else:
            if not in_word:
                count = count + 1
                in_word = true
        i = i + 1
    count

fn count_lines(content: text) -> i64:
    """Count newlines."""
    var count = 0
    var i = 0
    while i < content.len():
        if content[i:i + 1] == "\n":
            count = count + 1
        i = i + 1
    count

fn max_line_length(content: text) -> i64:
    """Find the length of the longest line."""
    val lines = content.split("\n")
    var max_len = 0
    for line in lines:
        if line.len() > max_len:
            max_len = line.len()
    max_len

fn format_count(value: i64, width: i64) -> text:
    """Right-align a number to given width."""
    var s = "{value}"
    while s.len() < width:
        s = " " + s
    s

describe "wc tool":
    context "word counting":
        it "counts words in simple text":
            val count = count_words("hello world foo")
            expect(count).to_equal(3)

        it "counts words with multiple spaces":
            val count = count_words("hello   world")
            expect(count).to_equal(2)

        it "counts words with tabs":
            val count = count_words("hello\tworld")
            expect(count).to_equal(2)

        it "counts zero words in empty string":
            val count = count_words("")
            expect(count).to_equal(0)

        it "counts single word":
            val count = count_words("hello")
            expect(count).to_equal(1)

    context "line counting":
        it "counts newlines":
            val count = count_lines("line1\nline2\nline3\n")
            expect(count).to_equal(3)

        it "counts zero lines in empty string":
            val count = count_lines("")
            expect(count).to_equal(0)

        it "counts no newline as zero":
            val count = count_lines("no newline")
            expect(count).to_equal(0)

    context "max line length":
        it "finds longest line":
            val max_len = max_line_length("short\na much longer line\nmed")
            expect(max_len).to_equal(18)

        it "handles single line":
            val max_len = max_line_length("hello")
            expect(max_len).to_equal(5)

    context "formatting":
        it "right-aligns count":
            val formatted = format_count(42, 7)
            expect(formatted).to_equal("     42")

        it "handles count wider than width":
            val formatted = format_count(12345, 3)
            expect(formatted).to_equal("12345")
