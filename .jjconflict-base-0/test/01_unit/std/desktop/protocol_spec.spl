# Desktop protocol handler API specification

use std.nogc_sync_mut.desktop.protocol.{ProtocolConfig}

describe "Desktop Protocol Handler API":
    it "creates ProtocolConfig struct":
        val config = ProtocolConfig(scheme: "myapp", app_name: "My App", binary_path: "/usr/bin/myapp")
        expect config.scheme == "myapp"
        expect config.app_name == "My App"
