# Test: sleep tool
# Feature: TOOL-SLEEP - Delay execution
# @cover tools/shell/sleep/sleep_tool.spl

describe "sleep tool":
    context "argument parsing":
        it "parses integer seconds":
            val s = "5"
            var result: i32 = 0
            for ch in s:
                if ch >= "0" and ch <= "9":
                    result = result * 10 + (ch.to_i32() - "0".to_i32())
            expect(result).to_equal(5)

        it "rejects non-numeric input":
            val s = "abc"
            var valid = true
            for ch in s:
                if ch < "0" or ch > "9":
                    valid = false
            expect(valid).to_equal(false)
