# Test: file tool
# Feature: TOOL-FILE - Identify file type
# @cover tools/shell/file/file_tool.spl

describe "file tool":
    context "extension detection":
        it "identifies .spl as Simple source":
            val name = "main.spl"
            val is_spl = name.ends_with(".spl")
            expect(is_spl).to_equal(true)

        it "identifies .shs as Simple shell":
            val name = "build.shs"
            val is_shs = name.ends_with(".shs")
            expect(is_shs).to_equal(true)

        it "identifies .md as Markdown":
            val name = "README.md"
            val is_md = name.ends_with(".md")
            expect(is_md).to_equal(true)

    context "content inspection":
        it "detects shebang scripts":
            val content = "#!/bin/sh\necho hello"
            expect(content.starts_with("#!")).to_equal(true)

        it "detects JSON by opening brace":
            val content = "{\"key\": \"value\"}"
            expect(content.starts_with("{")).to_equal(true)
