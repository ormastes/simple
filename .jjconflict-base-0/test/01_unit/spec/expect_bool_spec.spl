# @tag:unit, spec, expect

use std.spec.{describe, it, expect, expect_not}

describe "Concise boolean expectations":
    it "accepts bare true expectations":
        assert_true(true)

    it "accepts bare false expectations through expect_not":
        expect_not(false)

    it "keeps non-boolean zero equality as a chained matcher":
        expect(0).to_equal(0)
