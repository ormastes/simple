"""graphics_3d_session_managed_backend_spec — 20 tests for session types, API, frame, and perf.

Self-contained: all classes and functions defined inline.
Uses std.spec for describe/it/expect.
"""

use std.spec

# ===========================================================================
# Inline type definitions (replicated from source files)
# ===========================================================================

class BackendSessionHandle:
    id: i64
    kind: text
    mode: text
    device_name: text
    api_name: text
    target_arch: text
    target_bits: i64
    owner_thread_id: i64
    generation: i64
    valid: bool

    static fn invalid() -> BackendSessionHandle:
        return BackendSessionHandle(
            id: -1, kind: "", mode: "", device_name: "", api_name: "",
            target_arch: "", target_bits: 64, owner_thread_id: 0,
            generation: 0, valid: false
        )

    static fn create(id: i64, kind: text, mode: text) -> BackendSessionHandle:
        return BackendSessionHandle(
            id: id, kind: kind, mode: mode,
            device_name: kind + "-device", api_name: kind,
            target_arch: "x86_64", target_bits: 64,
            owner_thread_id: 1, generation: 1, valid: true
        )

    static fn is_valid(h: BackendSessionHandle) -> bool:
        return h.valid and h.id >= 0

    static fn increment_generation(h: BackendSessionHandle) -> BackendSessionHandle:
        return BackendSessionHandle(
            id: h.id, kind: h.kind, mode: h.mode,
            device_name: h.device_name, api_name: h.api_name,
            target_arch: h.target_arch, target_bits: h.target_bits,
            owner_thread_id: h.owner_thread_id, generation: h.generation + 1,
            valid: h.valid
        )

class BackendSessionPolicy:
    mode: text
    allow_fallback: bool
    strict_backend: bool
    allow_readback: bool
    perf_counters_enabled: bool

    static fn default_managed() -> BackendSessionPolicy:
        return BackendSessionPolicy(
            mode: "managed_shared", allow_fallback: true,
            strict_backend: false, allow_readback: false,
            perf_counters_enabled: false
        )

    static fn perf_exclusive() -> BackendSessionPolicy:
        return BackendSessionPolicy(
            mode: "perf_exclusive", allow_fallback: false,
            strict_backend: true, allow_readback: true,
            perf_counters_enabled: true
        )

    static fn legacy_no_session() -> BackendSessionPolicy:
        return BackendSessionPolicy(
            mode: "legacy_no_session", allow_fallback: true,
            strict_backend: false, allow_readback: false,
            perf_counters_enabled: false
        )

class BackendSessionError:
    code: text
    message: text
    has_error: bool

    static fn none() -> BackendSessionError:
        return BackendSessionError(code: "", message: "", has_error: false)

    static fn mode_conflict(msg: text) -> BackendSessionError:
        return BackendSessionError(code: "MODE_CONFLICT", message: msg, has_error: true)

    static fn backend_unavailable(kind: text) -> BackendSessionError:
        return BackendSessionError(code: "BACKEND_UNAVAILABLE", message: "unavailable: " + kind, has_error: true)

class BackendFrame:
    session_id: i64
    frame_index: i64
    width: i64
    height: i64
    is_active: bool
    allow_readback: bool
    draw_calls_recorded: i64

    static fn begin(session_id: i64, frame_index: i64, width: i64, height: i64, allow_readback: bool) -> BackendFrame:
        return BackendFrame(
            session_id: session_id, frame_index: frame_index,
            width: width, height: height, is_active: true,
            allow_readback: allow_readback, draw_calls_recorded: 0
        )

    static fn invalid() -> BackendFrame:
        return BackendFrame(
            session_id: -1, frame_index: -1, width: 0, height: 0,
            is_active: false, allow_readback: false, draw_calls_recorded: 0
        )

    static fn is_valid(f: BackendFrame) -> bool:
        return f.is_active and f.session_id >= 0

    static fn record_draw(f: BackendFrame) -> BackendFrame:
        return BackendFrame(
            session_id: f.session_id, frame_index: f.frame_index,
            width: f.width, height: f.height, is_active: f.is_active,
            allow_readback: f.allow_readback,
            draw_calls_recorded: f.draw_calls_recorded + 1
        )

class BackendFrameStats:
    session_id: i64
    frame_index: i64
    draw_call_count: i64
    valid: bool

    static fn zero(session_id: i64, frame_index: i64) -> BackendFrameStats:
        return BackendFrameStats(
            session_id: session_id, frame_index: frame_index,
            draw_call_count: 0, valid: true
        )

    static fn invalid() -> BackendFrameStats:
        return BackendFrameStats(session_id: -1, frame_index: -1, draw_call_count: 0, valid: false)

class PerfCounterSet:
    total_frames: i64
    total_draw_calls: i64
    peak_gpu_ms: i64
    sample_count: i64
    cache_warmth: text

    static fn zero() -> PerfCounterSet:
        return PerfCounterSet(
            total_frames: 0, total_draw_calls: 0,
            peak_gpu_ms: 0, sample_count: 0, cache_warmth: "cold"
        )

    static fn add_frame(c: PerfCounterSet, gpu_ms: i64, draws: i64) -> PerfCounterSet:
        var peak = c.peak_gpu_ms
        if gpu_ms > peak:
            peak = gpu_ms
        var warmth = c.cache_warmth
        if c.total_frames > 0:
            warmth = "warm-managed"
        return PerfCounterSet(
            total_frames: c.total_frames + 1,
            total_draw_calls: c.total_draw_calls + draws,
            peak_gpu_ms: peak,
            sample_count: c.sample_count,
            cache_warmth: warmth
        )

class RenderBackendPerf:
    session_id: i64
    backend_mode_text: text
    counters: PerfCounterSet

    static fn create_for_mode(session_id: i64, mode: text) -> RenderBackendPerf:
        return RenderBackendPerf(
            session_id: session_id,
            backend_mode_text: mode,
            counters: PerfCounterSet.zero()
        )

    static fn record_frame(p: RenderBackendPerf, gpu_ms: i64, draws: i64) -> RenderBackendPerf:
        return RenderBackendPerf(
            session_id: p.session_id,
            backend_mode_text: p.backend_mode_text,
            counters: PerfCounterSet.add_frame(p.counters, gpu_ms, draws)
        )

    static fn reset_counters(p: RenderBackendPerf) -> RenderBackendPerf:
        return RenderBackendPerf(
            session_id: p.session_id,
            backend_mode_text: p.backend_mode_text,
            counters: PerfCounterSet.zero()
        )

    static fn backend_mode(p: RenderBackendPerf) -> text:
        return p.backend_mode_text

    static fn get_session_id(p: RenderBackendPerf) -> i64:
        return p.session_id

# ===========================================================================
# Module-level API functions (replicated from source files)
# ===========================================================================

fn backend_session_create(kind: text, policy: BackendSessionPolicy, ordinal: i64) -> BackendSessionHandle:
    if kind == "":
        return BackendSessionHandle.invalid()
    val allowed = policy.mode == "managed_shared" or policy.mode == "perf_exclusive" or policy.mode == "legacy_no_session"
    if allowed == false:
        return BackendSessionHandle.invalid()
    val sid = 100 + ordinal
    return BackendSessionHandle.create(sid, kind, policy.mode)

fn backend_session_retain(h: BackendSessionHandle) -> BackendSessionHandle:
    if BackendSessionHandle.is_valid(h) == false:
        return BackendSessionHandle.invalid()
    if h.mode == "perf_exclusive":
        return BackendSessionHandle.invalid()
    return BackendSessionHandle.increment_generation(h)

fn backend_session_release(h: BackendSessionHandle) -> BackendSessionHandle:
    return BackendSessionHandle.invalid()

fn backend_session_begin_frame(h: BackendSessionHandle, frame_index: i64, width: i64, height: i64, allow_readback: bool) -> BackendFrame:
    if BackendSessionHandle.is_valid(h) == false:
        return BackendFrame.invalid()
    if width <= 0 or height <= 0:
        return BackendFrame.invalid()
    return BackendFrame.begin(h.id, frame_index, width, height, allow_readback)

fn backend_session_end_frame(frm: BackendFrame) -> BackendFrameStats:
    if BackendFrame.is_valid(frm) == false:
        return BackendFrameStats.invalid()
    return BackendFrameStats.zero(frm.session_id, frm.frame_index)

fn backend_session_sync_readback(frm: BackendFrame) -> [u8]:
    if frm.allow_readback == false:
        return []
    if BackendFrame.is_valid(frm) == false:
        return []
    var out: [u8] = []
    out = out.push(0)
    out = out.push(0)
    out = out.push(0)
    out = out.push(255)
    return out

# ===========================================================================
# Tests
# ===========================================================================

describe "BackendSessionHandle":

    it "invalid handle has id -1 and valid false":
        val h = BackendSessionHandle.invalid()
        expect(h.id).to_equal(-1)
        expect(h.valid).to_equal(false)

    it "create handle has id >= 0 and valid true":
        val h = BackendSessionHandle.create(101, "cpu", "managed_shared")
        expect(h.id).to_equal(101)
        expect(h.valid).to_equal(true)

    it "is_valid returns false for invalid handle":
        val h = BackendSessionHandle.invalid()
        expect(BackendSessionHandle.is_valid(h)).to_equal(false)

    it "is_valid returns true for created handle":
        val h = BackendSessionHandle.create(42, "vulkan", "managed_shared")
        expect(BackendSessionHandle.is_valid(h)).to_equal(true)

    it "increment_generation increases generation by 1":
        val h = BackendSessionHandle.create(10, "cpu", "managed_shared")
        val h2 = BackendSessionHandle.increment_generation(h)
        expect(h2.generation).to_equal(2)

describe "BackendSessionPolicy":

    it "default_managed mode is managed_shared":
        val p = BackendSessionPolicy.default_managed()
        expect(p.mode).to_equal("managed_shared")

    it "perf_exclusive policy has allow_fallback false":
        val p = BackendSessionPolicy.perf_exclusive()
        expect(p.allow_fallback).to_equal(false)

    it "legacy_no_session policy has perf_counters_enabled false":
        val p = BackendSessionPolicy.legacy_no_session()
        expect(p.perf_counters_enabled).to_equal(false)

    it "perf_exclusive has allow_readback true":
        val p = BackendSessionPolicy.perf_exclusive()
        expect(p.allow_readback).to_equal(true)

describe "Session API":

    it "backend_session_create with empty kind returns invalid":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("", p, 1)
        expect(BackendSessionHandle.is_valid(h)).to_equal(false)

    it "backend_session_create with cpu kind returns valid handle":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("cpu", p, 1)
        expect(BackendSessionHandle.is_valid(h)).to_equal(true)

    it "backend_session_retain increments generation":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("cpu", p, 1)
        val h2 = backend_session_retain(h)
        expect(h2.generation).to_equal(2)

    it "backend_session_retain perf_exclusive returns invalid":
        val p = BackendSessionPolicy.perf_exclusive()
        val h = backend_session_create("vulkan", p, 1)
        val h2 = backend_session_retain(h)
        expect(BackendSessionHandle.is_valid(h2)).to_equal(false)

    it "backend_session_release returns invalid handle":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("cpu", p, 1)
        val released = backend_session_release(h)
        expect(BackendSessionHandle.is_valid(released)).to_equal(false)

describe "BackendFrame lifecycle":

    it "begin_frame on valid session sets is_active true":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("cpu", p, 1)
        val frm = backend_session_begin_frame(h, 0, 1920, 1080, false)
        expect(frm.is_active).to_equal(true)

    it "begin_frame on invalid session returns inactive frame":
        val h = BackendSessionHandle.invalid()
        val frm = backend_session_begin_frame(h, 0, 1920, 1080, false)
        expect(frm.is_active).to_equal(false)

    it "end_frame returns valid stats with correct session_id":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("cpu", p, 1)
        val frm = backend_session_begin_frame(h, 0, 800, 600, false)
        val stats = backend_session_end_frame(frm)
        expect(stats.valid).to_equal(true)
        expect(stats.session_id).to_equal(h.id)

    it "sync_readback returns empty when allow_readback false":
        val p = BackendSessionPolicy.default_managed()
        val h = backend_session_create("cpu", p, 1)
        val frm = backend_session_begin_frame(h, 0, 100, 100, false)
        val bytes = backend_session_sync_readback(frm)
        expect(bytes.length).to_equal(0)

    it "sync_readback returns 4 bytes when allow_readback true":
        val p = BackendSessionPolicy.perf_exclusive()
        val h = backend_session_create("cpu", p, 1)
        val frm = backend_session_begin_frame(h, 0, 100, 100, true)
        val bytes = backend_session_sync_readback(frm)
        expect(bytes.length).to_equal(4)

describe "RenderBackendPerf":

    it "perf counters start at zero":
        val perf = RenderBackendPerf.create_for_mode(1, "managed_shared")
        val c = perf.counters
        expect(c.total_frames).to_equal(0)
        expect(c.sample_count).to_equal(0)

    it "record_frame increments total_frames":
        val perf = RenderBackendPerf.create_for_mode(1, "managed_shared")
        val perf2 = RenderBackendPerf.record_frame(perf, 16, 100)
        expect(perf2.counters.total_frames).to_equal(1)

    it "reset_counters brings total_frames back to zero":
        val perf = RenderBackendPerf.create_for_mode(1, "managed_shared")
        val perf2 = RenderBackendPerf.record_frame(perf, 16, 100)
        val perf3 = RenderBackendPerf.reset_counters(perf2)
        expect(perf3.counters.total_frames).to_equal(0)

    it "backend_mode returns mode text":
        val perf = RenderBackendPerf.create_for_mode(5, "perf_exclusive")
        expect(RenderBackendPerf.backend_mode(perf)).to_equal("perf_exclusive")

    it "get_session_id returns session_id":
        val perf = RenderBackendPerf.create_for_mode(42, "managed_shared")
        expect(RenderBackendPerf.get_session_id(perf)).to_equal(42)
