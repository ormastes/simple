# AC-10: Verification spec — all_regions
# 20 tests covering domain outline, LSP symbols, parser domain blocks,
# schema contract, schema export, style theme, style layout, domain hardening,
# and domain registry.

class DomainOutlineEntry:
    kind: text
    start_line: i32
    end_line: i32
    payload_preview: text
    module_name: text

class DomainSymbolProvider:
    kind: text
    symbol_kind: text
    icon_hint: text
    detail: text

class SchemaField:
    name: text
    type_name: text
    required: bool
    default_value: text

class SchemaContract:
    name: text
    version: text
    field_count: i32
    f0_name: text
    f0_type: text
    f0_required: bool
    f1_name: text
    f1_type: text
    f1_required: bool

class SchemaExportFormat:
    target: text
    schema_name: text
    compatible: bool
    field_coverage: i32
    total_fields: i32

class StyleProperty:
    name: text
    value: text
    unit: text
    inherited: bool

class ThemeSubset:
    theme_name: text
    bg_color: text
    fg_color: text
    accent_color: text
    font_family: text
    font_size: i32

class LayoutConstraint:
    constraint_type: text
    columns: i32
    gap: i32
    direction: text

class DomainHardenEntry:
    kind: text
    parse_status: text
    known_limitations: text
    validation_level: text
    export_capable: bool

class DomainKindRegistry:
    kind: text
    handler_name: text
    validation_level: text
    export_formats: text
    enabled: bool

fn test_outline_entry_span():
    val entry = DomainOutlineEntry { kind: "schema", start_line: 10, end_line: 20, payload_preview: "", module_name: "main" }
    val span_length = entry.end_line - entry.start_line + 1
    if span_length == 11:
        print("PASS: test_outline_entry_span")
    else:
        print("FAIL: test_outline_entry_span")

fn test_outline_display_name():
    val entry = DomainOutlineEntry { kind: "schema", start_line: 1, end_line: 5, payload_preview: "", module_name: "main" }
    val display = entry.kind + " (" + entry.module_name + ")"
    if display == "schema (main)":
        print("PASS: test_outline_display_name")
    else:
        print("FAIL: test_outline_display_name")

fn test_symbol_schema_kind():
    val sym = DomainSymbolProvider { kind: "schema", symbol_kind: "Struct", icon_hint: "", detail: "" }
    if sym.symbol_kind == "Struct":
        print("PASS: test_symbol_schema_kind")
    else:
        print("FAIL: test_symbol_schema_kind")

fn test_symbol_rtl_kind():
    val sym = DomainSymbolProvider { kind: "rtl", symbol_kind: "Interface", icon_hint: "", detail: "" }
    if sym.symbol_kind == "Interface":
        print("PASS: test_symbol_rtl_kind")
    else:
        print("FAIL: test_symbol_rtl_kind")

fn test_symbol_model_kind():
    val sym = DomainSymbolProvider { kind: "bim", symbol_kind: "Module", icon_hint: "", detail: "" }
    val is_model = sym.kind == "bim" or sym.kind == "cad" or sym.kind == "city"
    if is_model:
        print("PASS: test_symbol_model_kind")
    else:
        print("FAIL: test_symbol_model_kind")

fn test_parser_domain_kinds():
    val kinds = "schema style music bim cad city rtl"
    val ok = kinds.contains("schema") and kinds.contains("style") and kinds.contains("music") and kinds.contains("bim") and kinds.contains("cad") and kinds.contains("city") and kinds.contains("rtl")
    if ok:
        print("PASS: test_parser_domain_kinds")
    else:
        print("FAIL: test_parser_domain_kinds")

fn test_parser_unknown_rejected():
    val known = "schema style music bim cad city rtl"
    val candidate = "unknown_block"
    val recognized = known.contains(candidate)
    if recognized == false:
        print("PASS: test_parser_unknown_rejected")
    else:
        print("FAIL: test_parser_unknown_rejected")

fn test_schema_required_field():
    val field = SchemaField { name: "id", type_name: "i32", required: true, default_value: "" }
    if field.required:
        print("PASS: test_schema_required_field")
    else:
        print("FAIL: test_schema_required_field")

fn test_schema_optional_field():
    val field = SchemaField { name: "note", type_name: "text", required: false, default_value: "" }
    val is_optional = field.required == false
    if is_optional:
        print("PASS: test_schema_optional_field")
    else:
        print("FAIL: test_schema_optional_field")

fn test_schema_json_type_int():
    val field = SchemaField { name: "count", type_name: "i32", required: true, default_value: "" }
    var json_type = "unknown"
    if field.type_name == "i32":
        json_type = "integer"
    if json_type == "integer":
        print("PASS: test_schema_json_type_int")
    else:
        print("FAIL: test_schema_json_type_int")

fn test_schema_contract_has_field():
    val contract = SchemaContract { name: "user", version: "1.0", field_count: 1, f0_name: "id", f0_type: "i32", f0_required: true, f1_name: "", f1_type: "", f1_required: false }
    val has_id = contract.field_count > 0 and contract.f0_name == "id"
    if has_id:
        print("PASS: test_schema_contract_has_field")
    else:
        print("FAIL: test_schema_contract_has_field")

fn test_schema_contract_missing_field():
    val contract = SchemaContract { name: "empty", version: "1.0", field_count: 0, f0_name: "", f0_type: "", f0_required: false, f1_name: "", f1_type: "", f1_required: false }
    val has_x = contract.field_count > 0 and contract.f0_name == "x"
    if has_x == false:
        print("PASS: test_schema_contract_missing_field")
    else:
        print("FAIL: test_schema_contract_missing_field")

fn test_schema_export_full_coverage():
    val exp = SchemaExportFormat { target: "json", schema_name: "user", compatible: true, field_coverage: 5, total_fields: 5 }
    val is_full = exp.field_coverage == exp.total_fields
    if is_full:
        print("PASS: test_schema_export_full_coverage")
    else:
        print("FAIL: test_schema_export_full_coverage")

fn test_schema_export_partial():
    val exp = SchemaExportFormat { target: "proto", schema_name: "user", compatible: true, field_coverage: 3, total_fields: 5 }
    val is_partial = exp.field_coverage < exp.total_fields
    if is_partial:
        print("PASS: test_schema_export_partial")
    else:
        print("FAIL: test_schema_export_partial")

fn test_style_color_property():
    val prop = StyleProperty { name: "background", value: "#fff", unit: "color", inherited: false }
    val is_color = prop.unit == "color"
    if is_color:
        print("PASS: test_style_color_property")
    else:
        print("FAIL: test_style_color_property")

fn test_style_dimension():
    val prop = StyleProperty { name: "width", value: "100", unit: "px", inherited: false }
    val is_dimension = prop.unit == "px"
    if is_dimension:
        print("PASS: test_style_dimension")
    else:
        print("FAIL: test_style_dimension")

fn test_theme_dark():
    val theme = ThemeSubset { theme_name: "dark", bg_color: "#1a1a1a", fg_color: "#fff", accent_color: "#6af", font_family: "mono", font_size: 14 }
    val is_dark = theme.bg_color.starts_with("#1")
    if is_dark:
        print("PASS: test_theme_dark")
    else:
        print("FAIL: test_theme_dark")

fn test_layout_grid():
    val layout = LayoutConstraint { constraint_type: "grid", columns: 3, gap: 8, direction: "row" }
    val is_grid = layout.constraint_type == "grid"
    val is_flex = layout.constraint_type == "flex"
    if is_grid and is_flex == false:
        print("PASS: test_layout_grid")
    else:
        print("FAIL: test_layout_grid")

fn test_harden_stable():
    val entry = DomainHardenEntry { kind: "schema", parse_status: "stable", known_limitations: "", validation_level: "full", export_capable: true }
    val is_stable = entry.parse_status == "stable"
    if is_stable:
        print("PASS: test_harden_stable")
    else:
        print("FAIL: test_harden_stable")

fn test_registry_export():
    val reg = DomainKindRegistry { kind: "schema", handler_name: "schema_handler", validation_level: "full", export_formats: "json_schema,protobuf", enabled: true }
    val supports_export = reg.export_formats.contains("json_schema") or reg.export_formats.contains("protobuf")
    if supports_export:
        print("PASS: test_registry_export")
    else:
        print("FAIL: test_registry_export")

fn main():
    test_outline_entry_span()
    test_outline_display_name()
    test_symbol_schema_kind()
    test_symbol_rtl_kind()
    test_symbol_model_kind()
    test_parser_domain_kinds()
    test_parser_unknown_rejected()
    test_schema_required_field()
    test_schema_optional_field()
    test_schema_json_type_int()
    test_schema_contract_has_field()
    test_schema_contract_missing_field()
    test_schema_export_full_coverage()
    test_schema_export_partial()
    test_style_color_property()
    test_style_dimension()
    test_theme_dark()
    test_layout_grid()
    test_harden_stable()
    test_registry_export()
    print("DONE")
