# # Bool Round-Trips (Cranelift Uniform-i64 Bool ABI)
#
# **Feature ID:** #COMPILER-BACKEND-BOOL-UNIFORM-I64-ABI
# **Category:** Compiler | Backend | Cranelift
# **Status:** Implemented
#
# Backs the cranelift uniform-i64 Bool ABI: bool values must always cross
# function boundaries and be stored/branched-on as a canonical 0/1 i64-width
# value, never a truncated i8 or a garbage-extended sign bit. If a bool were
# truncated to i8 on a call boundary or sign/garbage-extended back to i64, a
# comparison result that is logically `true` could still compare unequal to
# the literal `true`, or an `if` could take the wrong branch even though the
# printed value looks correct. These specs push bool values through
# comparisons, call chains, `not`, and var-then-branch patterns designed to
# expose exactly that class of bug.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn is_even(x: i64) -> bool:
    x % 2 == 0

fn pass_through(b: bool) -> bool:
    b

fn negate(b: bool) -> bool:
    not b

fn and_both(a: bool, b: bool) -> bool:
    a and b

fn or_both(a: bool, b: bool) -> bool:
    a or b

describe "bool returned directly from a comparison":
    it "returns true for a satisfying comparison":
        check(is_even(4) == true)

    it "returns false for a failing comparison":
        check(is_even(5) == false)

    it "round-trips through a boolean variable before being asserted":
        val result = is_even(4)
        check(result == true)

describe "bool passed through a call chain":
    it "preserves true through a single pass-through call":
        check(pass_through(is_even(4)) == true)

    it "preserves false through a single pass-through call":
        check(pass_through(is_even(5)) == false)

    it "preserves true through a three-deep call chain":
        check(pass_through(pass_through(pass_through(is_even(10)))) == true)

    it "preserves false through a three-deep call chain":
        check(pass_through(pass_through(pass_through(is_even(11)))) == false)

describe "not applied to a call-boundary-crossed comparison result":
    it "inverts a true comparison result carried across a call boundary":
        check(negate(pass_through(is_even(4))) == false)

    it "inverts a false comparison result carried across a call boundary":
        check(negate(pass_through(is_even(5))) == true)

    it "double negation restores the original value after two call boundaries":
        check(negate(negate(pass_through(is_even(4)))) == true)

describe "bool stored in a var then used to branch":
    it "takes the true branch when the stored comparison result is true":
        var flag = is_even(10)
        var branch_taken = ""
        if flag:
            branch_taken = "true"
        else:
            branch_taken = "false"
        check(branch_taken == "true")

    it "takes the false branch when the stored comparison result is false":
        var flag = is_even(11)
        var branch_taken = ""
        if flag:
            branch_taken = "true"
        else:
            branch_taken = "false"
        check(branch_taken == "false")

    it "branches correctly on a bool that traveled through a call boundary":
        var flag = pass_through(is_even(4))
        var branch_taken = ""
        if flag:
            branch_taken = "true"
        else:
            branch_taken = "false"
        check(branch_taken == "true")

describe "bool params combined with and/or across call boundaries":
    it "and_both is true only when both call-boundary-crossed comparisons are true":
        check(and_both(is_even(4), is_even(6)) == true)
        check(and_both(is_even(4), is_even(5)) == false)
        check(and_both(is_even(3), is_even(5)) == false)

    it "or_both is false only when both call-boundary-crossed comparisons are false":
        check(or_both(is_even(3), is_even(5)) == false)
        check(or_both(is_even(4), is_even(5)) == true)
        check(or_both(is_even(4), is_even(6)) == true)

describe "bool-driven loop counting across a call boundary":
    it "counts exactly the values matching a call-boundary-crossed predicate":
        var count = 0
        for i in 0..20:
            if pass_through(is_even(i)) and not pass_through(is_even(i + 1)):
                count = count + 1
        check(count == 10)
