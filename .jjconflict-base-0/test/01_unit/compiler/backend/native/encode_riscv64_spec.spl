fn riscv_expected_nops(count: i64) -> [i64]:
    var code: [i64] = []
    var i = 0
    while i < count:
        code.push(0x13)
        code.push(0x00)
        code.push(0x00)
        code.push(0x00)
        i = i + 1
    code

fn rv64_backward_patch_module() -> MachModule:
    val start = MachBlock(label: "start", insts: [new_mach_inst(RV_OP_NOP, [])], block_id: 0, offset: 0)
    val back = MachBlock(
        label: "back",
        insts: [
            new_mach_inst(RV_OP_BEQ, [op_phys(RV_X1), op_phys(RV_X2), op_label(0)]),
            new_mach_inst(RV_OP_JAL, [op_phys(RV_X1), op_label(0)])
        ],
        block_id: 1,
        offset: 0
    )
    val func = MachFunction(name: "rv64_backward_patch", blocks: [start, back], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv64_backward_patch", functions: [func], data_sections: [], extern_symbols: [])

