            new_mach_inst(RV_OP_SNEZ, [op_phys(RV_X1), op_phys(RV_X2)])
        ],
        block_id: 0,
        offset: 0
    )
    val func = MachFunction(name: "rv64_pseudo_alu", blocks: [block], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv64_pseudo_alu", functions: [func], data_sections: [], extern_symbols: [])

