fn rv64_far_branch_module() -> MachModule:
    val start = MachBlock(label: "start", insts: [new_mach_inst(RV_OP_BEQ, [op_phys(RV_X1), op_phys(RV_X2), op_label(2)])], block_id: 0, offset: 0)
    var padding_insts = [new_mach_inst(RV_OP_NOP, [])]
    for i in 0..1023:
        padding_insts.push(new_mach_inst(RV_OP_NOP, []))
    val padding = MachBlock(label: "padding", insts: padding_insts, block_id: 1, offset: 0)
    val target = MachBlock(label: "target", insts: [new_mach_inst(RV_OP_NOP, [])], block_id: 2, offset: 0)
    val func = MachFunction(name: "rv64_far_branch", blocks: [start, padding, target], frame_size: 0, num_virtual_regs: 0, used_callee_saved: [])
    MachModule(name: "rv64_far_branch", functions: [func], data_sections: [], extern_symbols: [])

