fn build_indirect_call_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val func_type = MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: i64_type, is_variadic: false)))
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("callee_ptr"), type_: func_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("copy_result"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("move_result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Call(Some(LocalId(id: 2)), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))), []), span: nil),
            MirInst(kind: MirInstKind.Call(Some(LocalId(id: 3)), MirOperand(kind: MirOperandKind.Move(LocalId(id: 1))), []), span: nil)
        ],
        terminator: MirTerminator.Ret(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 3)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: MirSignature(params: [], return_type: i64_type, is_variadic: false),
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_call_indirect_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64_type, is_variadic: false)
    val func_type = MirType(kind: MirTypeKind.FuncPtr(sig))
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("callee_ptr"), type_: func_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.CallIndirect(Some(LocalId(id: 2)), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))), [], sig), span: nil)
        ],
        terminator: MirTerminator.Ret(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: sig,
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_alloc_cast_module_with_type(name: text, alloc_type: MirType) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val unit_type = MirType(kind: MirTypeKind.Unit)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: unit_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("ptr"), type_: alloc_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("value"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("casted"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Alloc(LocalId(id: 1), alloc_type), span: nil),
            MirInst(kind: MirInstKind.Const(LocalId(id: 2), MirConstValue.Int(7), i64_type), span: nil),
            MirInst(kind: MirInstKind.Cast(LocalId(id: 3), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2))), i64_type), span: nil)
        ],
        terminator: MirTerminator.Unreachable
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: MirSignature(params: [], return_type: unit_type, is_variadic: false),
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_alloc_cast_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    build_alloc_cast_module_with_type(name, i64_type)

fn build_large_alloc_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val large_type = MirType(kind: MirTypeKind.Array(i64_type, 300))
    build_alloc_cast_module_with_type(name, large_type)

