fn build_call_module_with_arg_count(name: text, arg_count: i64) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val func_type = MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: i64_type, is_variadic: false)))
    val result_id = arg_count + 1
    var locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: result_id), name: Some("result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    var instructions: [MirInst] = []
    var args: [MirOperand] = []
    for i in 0..arg_count:
        val id = i + 1
        val local = LocalId(id: id)
        locals.push(MirLocal(id: local, name: Some("arg{id}"), type_: i64_type, kind: LocalKind.Temp))
        instructions.push(MirInst(kind: MirInstKind.Const(local, MirConstValue.Int(id), i64_type), span: nil))
        args.push(MirOperand(kind: MirOperandKind.Copy(local)))
    val func_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Str("callee"), func_type))
    instructions.push(MirInst(kind: MirInstKind.Call(Some(LocalId(id: result_id)), func_op, args), span: nil))
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: instructions,
        terminator: MirTerminator.Ret(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: result_id)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: MirSignature(params: [], return_type: i64_type, is_variadic: false),
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_call_module(name: text) -> MirModule:
    build_call_module_with_arg_count(name, 10)

fn build_many_arg_call_module(name: text) -> MirModule:
    build_call_module_with_arg_count(name, 265)

fn build_void_call_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val unit_type = MirType(kind: MirTypeKind.Unit)
    val func_type = MirType(kind: MirTypeKind.FuncPtr(MirSignature(params: [], return_type: i64_type, is_variadic: false)))
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: unit_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("arg1"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val func_op = MirOperand(kind: MirOperandKind.Const(MirConstValue.Str("void_callee"), func_type))
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Const(LocalId(id: 1), MirConstValue.Int(7), i64_type), span: nil),
            MirInst(kind: MirInstKind.Call(nil, func_op, [MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1)))]), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: MirSignature(params: [], return_type: unit_type, is_variadic: false),
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

