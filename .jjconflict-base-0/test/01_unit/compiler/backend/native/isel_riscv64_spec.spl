fn virt_operand(id: i64) -> Operand:
    Operand(kind: OperandKind.Reg(MachReg(kind: MachRegKind.Virtual(id))))

fn build_intrinsic_module(name: text, intrinsic_name: text, arity: i64) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64_type, is_variadic: false)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("value"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("count"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    var instructions = [
        MirInst(kind: MirInstKind.Const(LocalId(id: 1), MirConstValue.Int(0x123456789ABCDEF), i64_type), span: nil),
        MirInst(kind: MirInstKind.Const(LocalId(id: 2), MirConstValue.Int(13), i64_type), span: nil)
    ]
    var args = [MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1)))]
    if arity == 2:
        args.push(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2))))
    instructions.push(MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 3)), intrinsic_name, args), span: nil))
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: instructions,
        terminator: MirTerminator.Ret(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 3)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: sig,
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_memory_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("base"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("value"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("loaded"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Const(LocalId(id: 1), MirConstValue.Int(4096), i64_type), span: nil),
            MirInst(kind: MirInstKind.Const(LocalId(id: 2), MirConstValue.Int(7), i64_type), span: nil),
            MirInst(kind: MirInstKind.Load(LocalId(id: 3), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1)))), span: nil),
            MirInst(kind: MirInstKind.Store(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))), span: nil),
            MirInst(kind: MirInstKind.GetField(LocalId(id: 3), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))), 2), span: nil),
            MirInst(kind: MirInstKind.SetField(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))), 3, MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))), span: nil)
        ],
        terminator: MirTerminator.Ret(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 3)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: MirSignature(params: [], return_type: i64_type, is_variadic: false),
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

