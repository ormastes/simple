# test/unit/compiler/backend/neon_fp16_spec.spl
#
# Feature ID: #COMPILER-BACKEND-NATIVE-NEON-FP16
# Category:   Compiler | Backend | Native | AArch64 FP16 Conversion Encoding
#
# Byte-level golden tests for FP16 conversion emit variants:
#   FCVTN  Vd.4H,  Vn.4S  (Q=0, narrow fp32→fp16, lower half, ARMv8 ARM §C7.2.67)
#   FCVTN2 Vd.8H,  Vn.4S  (Q=1, narrow fp32→fp16, upper half, ARMv8 ARM §C7.2.67)
#   FCVTL  Vd.4S,  Vn.4H  (Q=0, widen fp16→fp32, lower half,  ARMv8 ARM §C7.2.66)
#   FCVTL2 Vd.4S,  Vn.8H  (Q=1, widen fp16→fp32, upper half,  ARMv8 ARM §C7.2.66)
#   FCVTZS Vd.4S,  Vn.4S  (Q=1, fp32→signed int32 truncate,   ARMv8 ARM §C7.2.68)
#   FCVTZU Vd.4S,  Vn.4S  (Q=1, fp32→unsigned int32 truncate, ARMv8 ARM §C7.2.69)
#
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
# 2-register encoding: base + Rn*32 + Rd
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.arm_neon.{emit_fcvtn_4h, emit_fcvtn2_8h, emit_fcvtl_4s, emit_fcvtl2_4s, emit_fcvtzs_4s, emit_fcvtzu_4s}

# ============================================================================
# FCVTN Vd.4H, Vn.4S — base 0x0E216800
# Canonical (V0,V0): LE [0x00, 0x68, 0x21, 0x0E]
# ============================================================================

describe "emit_fcvtn_4h — narrow fp32 to fp16 into lower half":
    it "FCVTN V0.4H, V0.4S encodes to base opcode bytes":
        # word = 0x0E216800 + 0*32 + 0 = 0x0E216800
        # LE: [0x00, 0x68, 0x21, 0x0E]
        var b = emit_fcvtn_4h(0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x68)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x0E)

    it "FCVTN V0.4H, V1.4S encodes rn=1 into bits[9:5]":
        # word = 0x0E216800 + 1*32 + 0 = 0x0E216820
        # LE: [0x20, 0x68, 0x21, 0x0E]
        var b = emit_fcvtn_4h(0, 1)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x20)
        expect(b[1]).to_equal(0x68)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x0E)

    it "FCVTN V1.4H, V2.4S encodes rd=1 rn=2 correctly":
        # word = 0x0E216800 + 2*32 + 1 = 0x0E216841
        # LE: [0x41, 0x68, 0x21, 0x0E]
        var b = emit_fcvtn_4h(1, 2)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x41)
        expect(b[1]).to_equal(0x68)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x0E)

# ============================================================================
# FCVTN2 Vd.8H, Vn.4S — base 0x4E216800
# Canonical (V0,V0): LE [0x00, 0x68, 0x21, 0x4E]
# ============================================================================

describe "emit_fcvtn2_8h — narrow fp32 to fp16 into upper half":
    it "FCVTN2 V0.8H, V0.4S encodes to base opcode bytes":
        # word = 0x4E216800 + 0*32 + 0 = 0x4E216800
        # LE: [0x00, 0x68, 0x21, 0x4E]
        var b = emit_fcvtn2_8h(0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x68)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x4E)

    it "FCVTN2 V0.8H, V1.4S encodes rn=1":
        # word = 0x4E216800 + 1*32 + 0 = 0x4E216820
        # LE: [0x20, 0x68, 0x21, 0x4E]
        var b = emit_fcvtn2_8h(0, 1)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x20)
        expect(b[1]).to_equal(0x68)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x4E)

    it "FCVTN2 V3.8H, V4.4S encodes rd=3 rn=4 correctly":
        # word = 0x4E216800 + 4*32 + 3 = 0x4E216883
        # LE: [0x83, 0x68, 0x21, 0x4E]
        var b = emit_fcvtn2_8h(3, 4)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x83)
        expect(b[1]).to_equal(0x68)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x4E)

# ============================================================================
# FCVTL Vd.4S, Vn.4H — base 0x0E217800
# Canonical (V0,V0): LE [0x00, 0x78, 0x21, 0x0E]
# ============================================================================

describe "emit_fcvtl_4s — widen fp16 to fp32 from lower half":
    it "FCVTL V0.4S, V0.4H encodes to base opcode bytes":
        # word = 0x0E217800 + 0*32 + 0 = 0x0E217800
        # LE: [0x00, 0x78, 0x21, 0x0E]
        var b = emit_fcvtl_4s(0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x78)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x0E)

    it "FCVTL V0.4S, V1.4H encodes rn=1":
        # word = 0x0E217800 + 1*32 + 0 = 0x0E217820
        # LE: [0x20, 0x78, 0x21, 0x0E]
        var b = emit_fcvtl_4s(0, 1)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x20)
        expect(b[1]).to_equal(0x78)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x0E)

    it "FCVTL V2.4S, V3.4H encodes rd=2 rn=3 correctly":
        # word = 0x0E217800 + 3*32 + 2 = 0x0E217862
        # LE: [0x62, 0x78, 0x21, 0x0E]
        var b = emit_fcvtl_4s(2, 3)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x62)
        expect(b[1]).to_equal(0x78)
        expect(b[2]).to_equal(0x21)
        expect(b[3]).to_equal(0x0E)

