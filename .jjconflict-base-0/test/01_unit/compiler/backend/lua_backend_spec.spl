# Lua Backend Spec
#
# Verifies MirToLua emission correctness using structural-substring oracles.
# (Neither luajit nor lua is assumed to be on PATH; assertions check emitted text.)
#
# Functions exercised:
#   - add(a, b): returns a + b  (BinOp, Arg locals, Ret)
#   - const42(): returns 42     (Const, Ret)

use compiler.backend.lua_backend.{MirToLua}
use compiler.mir.mir_data.*
use compiler.hir.hir_types.{SymbolId}

# ============================================================================
# Helpers: build minimal MIR modules
# ============================================================================

fn build_const_module() -> MirModule:
    """Build MIR for:  fn const42() -> i64:  return 42"""
    var b = MirBuilder.new()

    b.begin_simple_function("const42", "i64")
    val c = b.emit_const_int(42)
    val ret_op = MirOperand(kind: MirOperandKind.Copy(c))
    b.terminate_return(Some(ret_op))

    val fn_ = b.end_function()
    b.add_function(fn_)
    b.module

fn build_add_module() -> MirModule:
    """Build MIR for:  fn add(a: i64, b: i64) -> i64:  return a + b"""
    var b = MirBuilder.new()

    val i64_ty = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(
        params: [i64_ty, i64_ty],
        return_type: i64_ty,
        is_variadic: false
    )
    val sym = SymbolId(id: 0)
    b.begin_function(sym, "add", sig, nil)

    # Locals layout after begin_function:
    #   id=0: _return (Return)
    #   id=1: a (Arg 0)
    #   id=2: b (Arg 1)
    val a_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1)))
    val b_op = MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))
    val sum = b.emit_binop(MirBinOp.Add, a_op, b_op, i64_ty)

    val ret_op = MirOperand(kind: MirOperandKind.Copy(sum))
    b.terminate_return(Some(ret_op))

    val fn_ = b.end_function()
    b.add_function(fn_)
    b.module

# ============================================================================
# Tests
# ============================================================================

describe "Lua backend":
    it "emits module header local M":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("local M = {}")

    it "emits return M at end":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("return M")

    it "emits function declaration with correct name":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("function M.const42(")

    it "emits end after function body":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("end")

    it "emits integer constant assignment":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("= 42")

    it "emits return statement":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("return ")

    it "emits block label syntax":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("::bb")

    it "emits add function declaration":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_add_module())
        expect(src).to_contain("function M.add(")

    it "emits addition operator":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_add_module())
        expect(src).to_contain(" + ")

    it "quoted strings escape double-quotes":
        var t = MirToLua.create("test")
        val q = t.lua_quoted("say \"hello\"")
        expect(q).to_contain("\\\"")

    it "binop ne emits lua not-equal operator":
        var t = MirToLua.create("test")
        val op = t.binop_text(MirBinOp.Ne)
        expect(op).to_equal("~=")

    it "binop add emits plus":
        var t = MirToLua.create("test")
        val op = t.binop_text(MirBinOp.Add)
        expect(op).to_equal("+")

    it "const_value_text for bool true":
        var t = MirToLua.create("test")
        val v = t.const_value_text(MirConstValue.Bool(true))
        expect(v).to_equal("true")

    it "const_value_text for bool false":
        var t = MirToLua.create("test")
        val v = t.const_value_text(MirConstValue.Bool(false))
        expect(v).to_equal("false")

    it "const_value_text for integer":
        var t = MirToLua.create("test")
        val v = t.const_value_text(MirConstValue.Int(99))
        expect(v).to_equal("99")

    it "const_value_text for string":
        var t = MirToLua.create("test")
        val v = t.const_value_text(MirConstValue.Str("hello"))
        expect(v).to_contain("hello")

    it "emits generation comment header":
        var t = MirToLua.create("mymod")
        val src = t.translate_module(build_const_module())
        expect(src).to_contain("-- Generated by Simple Lua backend")
