# @cover src/compiler/70.backend/gpu_intrinsics.spl 80%
# @cover src/compiler/70.backend/backend/opencl_backend.spl 80%
# @cover src/compiler/70.backend/backend/cuda_backend.spl 80%
# @tag: unit, compiler, gpu, codegen, vec_types

use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, compileoptions_default_options, CompileError}
use compiler.backend.opencl_backend.{OpenClBackend}
use compiler.backend.cuda_backend.{CudaBackend}
use compiler.backend.gpu_intrinsics.{is_gpu_intrinsic, recognize_gpu_intrinsic, all_gpu_intrinsic_names}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_data.{MirFunction, MirModule, MirSignature, BlockId, LocalId}
use compiler.mir.mir_instructions.{MirBlock, MirInst, MirInstKind, MirTerminator, MirOperand, MirOperandKind, GpuBarrierScope}
use compiler.mir.mir_types.{MirLocal, MirType, MirTypeKind, MirConstValue, LocalKind}

# ============================================================================
# Helpers
# ============================================================================

fn i32_type() -> MirType:
    MirType(kind: MirTypeKind.I32)

fn i64_type() -> MirType:
    MirType(kind: MirTypeKind.I64)

fn ptr_type() -> MirType:
    MirType(kind: MirTypeKind.I64)

fn temp_local(id: i64, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: type_, kind: LocalKind.Temp, is_ghost: false)

fn i64_const_operand(v: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(v), MirType.i64()))

fn copy_operand(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(LocalId(id: id)))

fn make_opencl_vec_kernel(name: text, sym_id: i64, block: MirBlock) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: sym_id),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [temp_local(0, i32_type()), temp_local(1, ptr_type()), temp_local(2, i64_type()), temp_local(3, i32_type()), temp_local(4, i32_type()), temp_local(5, i32_type()), temp_local(6, i32_type())],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_cuda_vec_kernel(name: text, sym_id: i64, block: MirBlock) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: sym_id),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [temp_local(0, i32_type()), temp_local(1, ptr_type()), temp_local(2, i64_type()), temp_local(3, i32_type()), temp_local(4, i32_type()), temp_local(5, i32_type()), temp_local(6, i32_type())],
        blocks: [block],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "cuda",
        gpu_backend_order: "cuda",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_module_from(func: MirFunction) -> MirModule:
    var map: Dict<SymbolId, MirFunction> = {}
    map[func.symbol] = func
    MirModule(name: "vec_types_test_module", functions: map, statics: {}, constants: {}, types: {})

# ============================================================================
# MIR blocks for vector intrinsics
# ============================================================================

# gpu_vec4_load_f32(ptr=local1, index=local2) -> local0
fn vec4_load_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_vec4_load_f32", [copy_operand(1), copy_operand(2)]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# gpu_vec4_store_f32(ptr=local1, index=local2, v0..v3=local3..local6)
fn vec4_store_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(nil, "gpu_vec4_store_f32", [copy_operand(1), copy_operand(2), copy_operand(3), copy_operand(4), copy_operand(5), copy_operand(6)]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# gpu_vec2_load_f32(ptr=local1, index=local2) -> local0
fn vec2_load_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_vec2_load_f32", [copy_operand(1), copy_operand(2)]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# gpu_vec2_store_f32(ptr=local1, index=local2, v0=local3, v1=local4)
fn vec2_store_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(nil, "gpu_vec2_store_f32", [copy_operand(1), copy_operand(2), copy_operand(3), copy_operand(4)]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# gpu_vec4_load_f32 with only 1 arg — bad arity
fn vec4_load_bad_args_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(Some(LocalId(id: 0)), "gpu_vec4_load_f32", [copy_operand(1)]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# gpu_vec4_store_f32 with only 3 args — bad arity
fn vec4_store_bad_args_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [MirInst(kind: MirInstKind.Intrinsic(nil, "gpu_vec4_store_f32", [copy_operand(1), copy_operand(2), copy_operand(3)]), span: nil)],
        terminator: MirTerminator.Ret(nil)
    )

# ============================================================================
# Recognition tests
# ============================================================================

describe "vec_types — gpu_intrinsics recognition":

    it "recognizes gpu_vec4_load_f32 as a GPU intrinsic":
        assert_true(is_gpu_intrinsic("gpu_vec4_load_f32"))

    it "recognizes gpu_vec4_store_f32 as a GPU intrinsic":
        assert_true(is_gpu_intrinsic("gpu_vec4_store_f32"))

    it "recognizes gpu_vec2_load_f32 as a GPU intrinsic":
        assert_true(is_gpu_intrinsic("gpu_vec2_load_f32"))

    it "recognizes gpu_vec2_store_f32 as a GPU intrinsic":
        assert_true(is_gpu_intrinsic("gpu_vec2_store_f32"))

    it "rejects ordinary function names as GPU intrinsics":
        assert_true(not is_gpu_intrinsic("third"))

    it "all_gpu_intrinsic_names includes gpu_vec4_load_f32":
        val names = all_gpu_intrinsic_names()
        val found = names.contains("gpu_vec4_load_f32")
        assert_true(found)

    it "all_gpu_intrinsic_names includes gpu_vec4_store_f32":
        val names = all_gpu_intrinsic_names()
        val found = names.contains("gpu_vec4_store_f32")
        assert_true(found)

    it "all_gpu_intrinsic_names includes gpu_vec2_load_f32":
        val names = all_gpu_intrinsic_names()
        val found = names.contains("gpu_vec2_load_f32")
        assert_true(found)

    it "all_gpu_intrinsic_names includes gpu_vec2_store_f32":
        val names = all_gpu_intrinsic_names()
        val found = names.contains("gpu_vec2_store_f32")
        assert_true(found)

# ============================================================================
# OpenCL emission — vec4 load
# ============================================================================

describe "vec_types contract — OpenCL backend vec4 load":

    it "emits vload4 for gpu_vec4_load_f32":
        val func = make_opencl_vec_kernel("opencl_vec4_load", 300, vec4_load_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("vload4")

    it "emits float4 type for gpu_vec4_load_f32":
        val func = make_opencl_vec_kernel("opencl_vec4_load_ty", 301, vec4_load_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("float4")

    it "emits diagnostic comment for gpu_vec4_load_f32 with bad arity":
        val func = make_opencl_vec_kernel("opencl_vec4_load_bad", 302, vec4_load_bad_args_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("gpu_vec4_load_f32")

# ============================================================================
# OpenCL emission — vec4 store
# ============================================================================

describe "vec_types contract — OpenCL backend vec4 store":

    it "emits vstore4 for gpu_vec4_store_f32":
        val func = make_opencl_vec_kernel("opencl_vec4_store", 310, vec4_store_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("vstore4")

    it "emits diagnostic comment for gpu_vec4_store_f32 with bad arity":
        val func = make_opencl_vec_kernel("opencl_vec4_store_bad", 311, vec4_store_bad_args_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("gpu_vec4_store_f32")

# ============================================================================
# OpenCL emission — vec2 load/store
# ============================================================================

describe "vec_types contract — OpenCL backend vec2 load/store":

    it "emits vload2 for gpu_vec2_load_f32":
        val func = make_opencl_vec_kernel("opencl_vec2_load", 320, vec2_load_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("vload2")

    it "emits float2 type for gpu_vec2_load_f32":
        val func = make_opencl_vec_kernel("opencl_vec2_load_ty", 321, vec2_load_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("float2")

    it "emits vstore2 for gpu_vec2_store_f32":
        val func = make_opencl_vec_kernel("opencl_vec2_store", 322, vec2_store_block())
        val source = OpenClBackend.compile_module_to_opencl_source(make_module_from(func)).unwrap()
        expect(source).to_contain("vstore2")

# ============================================================================
# CUDA/PTX emission — vec4 load/store
# ============================================================================

describe "vec_types contract — CUDA backend vec4 load":

    it "emits ld.global.v4.f32 for gpu_vec4_load_f32":
        val func = make_cuda_vec_kernel("cuda_vec4_load", 400, vec4_load_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("ld.global.v4.f32")

    it "emits diagnostic comment for gpu_vec4_load_f32 with bad arity (PTX)":
        val func = make_cuda_vec_kernel("cuda_vec4_load_bad", 401, vec4_load_bad_args_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("gpu_vec4_load_f32")

describe "vec_types contract — CUDA backend vec4 store":

    it "emits st.global.v4.f32 for gpu_vec4_store_f32":
        val func = make_cuda_vec_kernel("cuda_vec4_store", 410, vec4_store_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("st.global.v4.f32")

    it "emits diagnostic comment for gpu_vec4_store_f32 with bad arity (PTX)":
        val func = make_cuda_vec_kernel("cuda_vec4_store_bad", 411, vec4_store_bad_args_block())
        val backend = CudaBackend.create((8, 6))
        val result = backend.compile(make_module_from(func))
        expect(result.is_ok()).to_equal(true)
        val ptx = result.unwrap().ptx
        expect(ptx).to_contain("gpu_vec4_store_f32")

