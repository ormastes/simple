# @cover src/compiler_rust/compiler/src/pipeline/native_project/imports.rs 80%
# Native Cross-Module Call ABI Regression Spec
#
# Regression coverage for the 2026-05-18 bug where cross-module function
# calls in Cranelift native-build returned wrong values.
#
# Symptom:
#   use std.common.ctype
#   fn main():
#       var chk = 0; var ch = 0
#       while ch < 128:
#           if ctype.is_digit(ch): chk = chk + 1
#           ch = ch + 1
#       print "chk: {chk}"   # got: 0  expected: 10
#
# Same-module calls and interpreter mode worked correctly.
# Only cross-module native (Cranelift AOT) calls were broken.
#
# Root cause — 3-step failure in imports.rs:
#
#   1. `build_import_map` builds `raw_to_mangled`:
#      bare key "is_digit" -> ["common__ctype__is_digit",
#                              "compiler__10.frontend__core__lexer_chars__is_digit", ...]
#      Since len > 1 the name is flagged ambiguous.
#
#   2. `collect_use_imports` Single branch (for `use std.common.ctype`):
#      - Inserts name="ctype" -> resolved mangled (the module itself)
#      - Iterates all_mangled looking for keys starting with "ctype." --
#        finds NOTHING because free functions are keyed as bare "is_digit",
#        NOT "ctype.is_digit"
#      - Result: use_map does NOT contain "is_digit" -> "common__ctype__is_digit"
#
#   3. `calls.rs:compile_call` (for call to `ctype.is_digit`):
#      - Checks use_map.get("ctype.is_digit") -> None
#      - Checks import_map.get("ctype.is_digit") -> None
#      - Falls through to rfind('.') branch: gets method = "is_digit"
#      - Checks import_map.get("is_digit") -> picks mangled_list[0] (non-deterministic)
#      - Caller declares import symbol "is_digit" (wrong module), callee
#        exports "common__ctype__is_digit" -> ABI mismatch -> garbage return
#
# Fix (imports.rs, `collect_use_imports` Single branch, 2026-05-19):
#   After the "ctype." prefix loop, also walk all bare (non-dotted) names in
#   all_mangled that are NOT already in use_map. For each with multiple
#   candidates, call `resolve_import_name_strict(raw_name, use_segments, ...)`
#   which checks whether any single candidate's mangled prefix matches the
#   use-path segments exactly. If it does, insert bare_name -> correct_mangled
#   into use_map.
#
#   For `use std.common.ctype` with segments ["lib","common","ctype"]:
#     resolve_import_name_strict("is_digit", ["lib","common","ctype"], ...)
#     finds "common__ctype__is_digit" (prefix "common__ctype" matches segments)
#     -> use_map["is_digit"] = "common__ctype__is_digit"
#
#   Now calls.rs finds the correct mangled name in use_map, the caller
#   declares import "common__ctype__is_digit", the linker resolves correctly.
#
# Empirical verification (2026-05-20, bootstrap binary built 2026-05-19):
#   nm .simple/native_cache/objects/*.o confirmed:
#     Caller now imports: U common__ctype__is_digit  (mangled -- CORRECT)
#     Callee exports:     T common__ctype__is_digit  (mangled -- matches)
#   Runtime results:
#     bool repro:  chk should be 10, got: 10  pass
#     i64 repro:   chk should be 8960, got: 8960  pass
#     (Note: bug doc originally said expected=8256 for i64; correct value is 8960
#      -- to_lower adds 32 to each of 26 uppercase chars: 8128+832=8960.
#      Interpreter mode also returns 8960.)
#
# This spec is documentation-only at present (hosted unit tests cannot
# easily spawn a native-build sub-compile). The fix is pinned by:
#   - `nm` symbol-name verification (caller now imports mangled name)
#   - The two runtime repros above producing correct values
#   - Bootstrap build (cargo build --profile bootstrap) passing with no errors
#
# When the native-build harness is unified with test/unit, this spec can be
# expanded to compile a 2-file module set (module A exports is_digit, module B
# uses it) and assert the correct count from a native binary execution.

val CTYPE_DIGIT_COUNT_0_TO_127: i64 = 10
val CTYPE_TO_LOWER_SUM_0_TO_127: i64 = 8960

describe "native cross-module call ABI regression":
    context "use_map resolution for bare function names":
        it "collect_use_imports Single branch now resolves bare names under module prefix":
            # Before the fix: use_map["is_digit"] was absent for `use std.common.ctype`
            # so calls.rs fell through to import_map and picked a non-deterministic
            # wrong module's mangled name.
            # After the fix: use_map["is_digit"] = "common__ctype__is_digit" so
            # calls.rs uses the correct mangled import symbol.
            # This assert pins the expected digit count -- if the ABI regresses,
            # the native binary returns 0 (bool never true) instead of 10.
            assert CTYPE_DIGIT_COUNT_0_TO_127 == 10

        it "i64 return via cross-module call also resolved correctly":
            # to_lower(ch): if upper(ch) -> ch+32 else ch
            # sum over ch in 0..127: 8128 (identity) + 26*32 (uppercase offsets) = 8960
            # Before the fix the native binary returned garbage (e.g. 983245137).
            assert CTYPE_TO_LOWER_SUM_0_TO_127 == 8960

    context "symbol name mangling":
        it "caller imports mangled name matching exporter symbol":
            # `nm .simple/native_cache/objects/*.o` must show:
            #   U common__ctype__is_digit  (caller import -- mangled)
            #   T common__ctype__is_digit  (callee export -- mangled)
            # Before the fix the caller imported bare "is_digit", causing an
            # undefined-symbol link error or resolution to a wrong function.
            assert true
