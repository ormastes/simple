extern fn rt_file_read_text(path: text) -> text

describe "erased Dict view MIR lowering source":
    it "routes unresolved keys and values through tag-safe Dict runtimes":
        val source = rt_file_read_text("src/compiler/50.mir/_MirLoweringExpr/method_calls_literals.spl") ?? ""

        expect(source).to_contain("if (receiver_is_dict or resolution_is_unresolved) and (method == \"values\" or method == \"keys\") and args.len() == 0:")
        expect(source).to_contain("if method == \"values\": \"rt_dict_values\" else: \"rt_dict_keys\"")
