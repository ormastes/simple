"""
# Cast and Less-Than Parser Regression

Keeps a spaced `<` after a cast as a binary operator while preserving adjacent
angle-bracket generic casts.
"""

use compiler.core.parser.{parser_init, parse_expr}
use compiler.core.ast.{expr_get_tag, expr_get_int, expr_get_left, EXPR_BINARY, EXPR_CAST}
use compiler.core.tokens.{TOK_LT}

describe "Cast and Less-Than Parser":
    it "parses spaced less-than after a cast as binary":
        parser_init("x as i64 < (a + 1) * b")
        val expression = parse_expr()
        expect(expr_get_tag(expression)).to_equal(EXPR_BINARY)
        expect(expr_get_int(expression)).to_equal(TOK_LT)
        expect(expr_get_tag(expr_get_left(expression))).to_equal(EXPR_CAST)

    it "keeps adjacent angle generic casts":
        parser_init("value as Box<i64>")
        val expression = parse_expr()
        expect(expr_get_tag(expression)).to_equal(EXPR_CAST)
