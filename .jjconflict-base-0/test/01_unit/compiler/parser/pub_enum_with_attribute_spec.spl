# Regression: parser must accept `@attr` followed by `pub enum`
#
# Prior bug: `parse_pub_item_with_attrs` only handled fn/struct/class/mixin/mod,
# rejecting `pub enum` after attributes with:
#   "Unexpected token: expected fn, struct, class, mixin, or mod after pub with
#    attributes, found Enum"
#
# Trigger from stdlib: src/compiler_rust/lib/std/src/core/json.spl had
#   @cfg(hosted)
#   pub enum JsonValue:
# which failed to parse, cascading to every test that imports `std.spec`.

@doc("Parser regression enum")
pub enum Color:
    Red
    Green
    Blue

@doc("Parser regression shape enum")
pub enum Shape:
    Circle(f64)
    Square(f64)
    Rectangle(f64, f64)

describe "pub enum with attribute":
    "Regression suite covering the `@attr pub enum` parser path."

    it "parses a known attribute followed by pub enum":
        "Simple unit-variant enum after an attribute must parse."
        val c = Color.Red
        expect(c).to_equal(Color.Red)

    it "parses a known attribute followed by pub enum with data variants":
        "Data-variant enum after an attribute must parse."
        val s = Shape.Circle(2.0)
        expect(s).to_equal(Shape.Circle(2.0))
