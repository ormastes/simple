use std.spec.{describe, it, expect}
use compiler.frontend.core.parser.{parse_module, parser_has_errors}

describe "bootstrap labeled tuple return parser":
    it "accepts the canonical process result labels":
        parse_module("extern fn process_run(command: text) -> (stdout: text, stderr: text, exit_code: i64)\n", "labeled_process_result.spl")

        expect(parser_has_errors()).to_equal(false)

    it "accepts labeled and anonymous tuple elements together":
        parse_module("fn mixed() -> (left: i64, text, ok: bool):\n    (1, \"ready\", true)\n", "mixed_tuple_result.spl")

        expect(parser_has_errors()).to_equal(false)

    it "rejects a label with no element type":
        parse_module("extern fn broken() -> (stdout:, stderr: text)\n", "missing_tuple_element_type.spl")

        expect(parser_has_errors()).to_equal(true)
