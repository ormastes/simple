"""
# Aliased Import Static-Call / Constructor Resolution Unit Spec

ALIAS-GAP lane (2026-07-17): the Rust seed had a bug where `use {Real as
Alias}` correctly resolved `Alias` in TYPE ANNOTATIONS (through
`resolve_type_alias`) but NOT in a static-method-call or constructor callee
(`Alias.method()` / `Alias(...)`), which was instead built from the raw
`Alias` token and could bind to an unrelated, same-printed-name GLOBAL type
when one existed elsewhere in the program (fixed at seed commit
3f0acf071cf; see doc/08_tracking/bug/
simpleos_native_build_entry_closure_codegen_defects_2026-07-17.md, C8-DEEP
section, "ALIAS-GAP lane").

This spec is the pure-Simple-side regression guard for the SAME bug class.
It reproduces the exact collision shape: an alias name ("Widget") that
ALSO names a genuine, unrelated class imported (under a different alias)
from a different module -- then checks that a static method call AND a
constructor call through the alias resolve to the alias TARGET
(RealWidget), never to the raw alias text nor to the decoy same-named
class.

Verified 2026-07-17 (bin/simple run, interpreter fallback -- see harness
note below): pure-Simple's `HirExprKind.NamedVar` payload already carries
the POST-`rename_symbol` canonical class name (baked at Ident-lowering
time by `symbol_display_name`, `hir_lowering/expressions.spl`), so every
downstream consumer that reads it (static-call resolution in
`50.mir/_MirLoweringExpr/method_calls_literals.spl`'s `Unresolved` arm,
struct construction in `switch_operators_calls.spl`'s `lower_call`, enum
variant reclassification in `method_calls_literals.spl`) sees the SAME
resolved name as the symbol table itself. This is architecturally
different from the Rust seed's per-consumer ad-hoc name reconstruction:
pure-Simple resolves the alias ONCE, at import registration
(`register_imported_symbol`'s `rename_symbol` call in
`hir_lowering/_Items/module_lowering.spl`), so there is only one source of
truth for every consumer. Both assertions below PASS today -- this is a
preventing test, not a reproduction of a live bug.
"""

# @cover src/compiler/20.hir/hir_lowering/_Items/module_lowering.spl 20%
# @cover src/compiler/20.hir/hir_lowering/expressions.spl 10%
# @cover src/compiler/50.mir/_MirLoweringExpr/method_calls_literals.spl 10%
# @cover src/compiler/50.mir/_MirLoweringExpr/switch_operators_calls.spl 10%

use compiler.hir.hir_lowering.types.{HirLowering}
use compiler.hir.hir_lowering.items.*
use compiler.hir.hir_definitions.*
use compiler.frontend.frontend.{parse_full_frontend}
use compiler.common.config.{Logger}

fn make_logger() -> Logger:
    Logger(level: 0)

fn lower_consumer(modules_map: Dict<text, any>, path_consumer: text, module_consumer: any) -> HirModule:
    var lowering = HirLowering.with_filename(path_consumer)
    lowering.modules_by_name = modules_map
    lowering.lower_module(module_consumer)

fn find_fn(hir: HirModule, name: text) -> HirFunction?:
    var found: HirFunction? = nil
    for fn_ in hir.functions.values():
        if fn_.name == name:
            found = Some(fn_)
    found

describe "aliased import static-call / constructor resolution (ALIAS-GAP lane)":
    """
    Reproduces the seed's C8 collision shape: `use {RealWidget as Widget}`
    while an UNRELATED real class also named `Widget` is imported (under a
    different local alias) from a different module in the same compile
    unit. A correct resolver must bind `Widget.make()` / `Widget(...)` to
    RealWidget, never to the raw alias text or to the decoy class.
    """

    it "static method call through an alias resolves to the alias target, not a same-named decoy class":
        val log = make_logger()

        val src_owner = "class RealWidget:\n    value: i64\n\nimpl RealWidget:\n    static fn make() -> RealWidget:\n        RealWidget(value: 7)\n"
        val module_owner = parse_full_frontend(src_owner, "owner_mod", "owner_mod", log)

        # Decoy: a genuine, DIFFERENT class also literally named "Widget",
        # imported into the SAME consumer under a different local alias so
        # it is live in the compile unit (mirrors Fat32Core existing
        # elsewhere in the C8 story).
        val src_decoy = "class Widget:\n    value: i64\n\nimpl Widget:\n    static fn make() -> Widget:\n        Widget(value: 99)\n"
        val module_decoy = parse_full_frontend(src_decoy, "decoy_mod", "decoy_mod", log)

        val open = "{"
        val close = "}"
        val src_consumer = "use owner_mod." + open + "RealWidget as Widget" + close + "\n" +
            "use decoy_mod." + open + "Widget as DecoyWidget" + close + "\n" +
            "fn build() -> i64:\n    val w = Widget.make()\n    0\n"
        val module_consumer = parse_full_frontend(src_consumer, "consumer_mod", "consumer_mod", log)

        var modules_map: Dict<text, any> = {}
        modules_map["owner_mod"] = module_owner
        modules_map["decoy_mod"] = module_decoy

        val hir = lower_consumer(modules_map, "consumer_mod", module_consumer)
        val build_fn = find_fn(hir, "build")

        if val bf = build_fn:
            val first_stmt = bf.body.stmts[0]
            match first_stmt.kind:
                case HirStmtKind.Let(_, _, init):
                    match init.kind:
                        case HirExprKind.MethodCall(receiver, method, _, _):
                            expect(method).to_equal("make")
                            match receiver.kind:
                                case HirExprKind.NamedVar(sym, name):
                                    # The alias must resolve to the TARGET
                                    # class name, not the raw alias text
                                    # ("Widget") and not left unresolved.
                                    expect(name).to_equal("RealWidget")
                                    if val s = hir.symbols.get_symbol(sym):
                                        expect(s.name).to_equal("RealWidget")
                                    else:
                                        assert_true(false)
                                case _:
                                    assert_true(false)
                        case _:
                            assert_true(false)
                case _:
                    assert_true(false)
        else:
            assert_true(false)

    it "constructor call through an alias resolves to the alias target, not a same-named decoy class":
        val log = make_logger()

        val src_owner = "class RealWidget:\n    value: i64\n"
        val module_owner = parse_full_frontend(src_owner, "owner_mod2", "owner_mod2", log)

        val open = "{"
        val close = "}"
        val src_consumer = "use owner_mod2." + open + "RealWidget as Widget" + close + "\n" +
            "fn build2() -> i64:\n    val w = Widget(value: 5)\n    0\n"
        val module_consumer = parse_full_frontend(src_consumer, "consumer_mod2", "consumer_mod2", log)

        var modules_map: Dict<text, any> = {}
        modules_map["owner_mod2"] = module_owner

        val hir = lower_consumer(modules_map, "consumer_mod2", module_consumer)
        val build_fn = find_fn(hir, "build2")

        if val bf = build_fn:
            val first_stmt = bf.body.stmts[0]
            match first_stmt.kind:
                case HirStmtKind.Let(_, _, init):
                    match init.kind:
                        case HirExprKind.Call(callee, _, _):
                            match callee.kind:
                                case HirExprKind.NamedVar(sym, name):
                                    expect(name).to_equal("RealWidget")
                                    if val s = hir.symbols.get_symbol(sym):
                                        expect(s.name).to_equal("RealWidget")
                                    else:
                                        assert_true(false)
                                case _:
                                    assert_true(false)
                        case _:
                            assert_true(false)
                case _:
                    assert_true(false)
        else:
            assert_true(false)
