"""
# FFI generator backend gating specification
#
# Verifies that unsupported @Lib backends fail with an explicit diagnostic
# instead of being silently skipped.
"""

use compiler.tools.ffi_gen.main.{ffi_backend_supported, ffi_backend_not_implemented_message}
use compiler.tools.ffi_gen.parser.{LibExternSpec}

describe "ffi generator backend gating":
    it "treats rust as the only supported direct generator backend":
        expect(ffi_backend_supported("rust")).to_equal(true)
        expect(ffi_backend_supported("c")).to_equal(false)
        expect(ffi_backend_supported("cpp")).to_equal(false)

    it "explains the shared-library bridge for unsupported C/C++ backends":
        val spec = LibExternSpec(
            lib_lang: "cpp",
            lib_name: "demo",
            lib_version: "",
            lib_features: [],
            lib_pkg_config: "",
            lib_link: "",
            class_name: "DemoLib",
            methods: [],
            source_file: "demo.spl",
            line_number: 1
        )

        val message = ffi_backend_not_implemented_message(spec)
        expect(message.contains("@Lib(lang: \"cpp\")")).to_equal(true)
        expect(message.contains("@export(\"C\")")).to_equal(true)
        expect(message.contains("shared-library/header bridge")).to_equal(true)
