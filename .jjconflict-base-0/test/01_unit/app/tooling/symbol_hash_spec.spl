fn collision_probability(symbol_count: f64, hash_space: f64) -> f64:
    if symbol_count <= 1.0:
        return 0.0
    (symbol_count * (symbol_count - 1.0)) / (2.0 * hash_space)

describe "Symbol Hash":
    it "computes zero collision probability for empty or single symbol sets":
        expect(collision_probability(0.0, 1024.0)).to_equal(0.0)
        expect(collision_probability(1.0, 1024.0)).to_equal(0.0)

    it "computes birthday-bound collision probability for multiple symbols":
        val probability = collision_probability(4.0, 100.0)
        expect(probability).to_equal(0.06)
