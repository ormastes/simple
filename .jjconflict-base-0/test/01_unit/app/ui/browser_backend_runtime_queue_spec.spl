# @cover src/app/ui.browser/backend.spl
# @tag: unit, ui, browser, host_gpu_queue
"""
# Browser Backend Runtime Queue Spec

## Overview

This focused spec proves a GPU-selected BrowserBackend frame surfaces
host/GPU runtime queue submit and drain provenance on the backend API.
Cache-hit behavior is explicit: an unchanged cached frame reports that no new
runtime queue request was made instead of leaving stale queue receipts visible.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** doc/03_plan/agent_tasks/real_host_gpu_runtime_queue_emission.md

## Design

**Design:** doc/04_architecture/ui/simple_gui_stack.md

## Research

**Research:** N/A

## Examples

The scenario renders a static BrowserBackend frame with the Vulkan backend,
asserts that the first frame reports one submitted and drained runtime queue
packet plus same-frame Engine2D device readback provenance and a
nonblank/nonuniform pixel oracle. The first frame carries a positive backend
handle and payload text from the Engine2D readback receipt.
The scenario then renders the same frame again and asserts that the cache hit
reports `not_requested` queue/readback status instead of stale receipt data.
"""

use std.spec.*

extern fn rt_process_run(command: text, args: [text]) -> (text, text, i32)
extern fn rt_env_get(key: text) -> text?

fn simple_binary() -> text:
    val configured = rt_env_get("SIMPLE_BIN") ?? ""
    if configured != "":
        return configured
    "./bin/simple"

describe "browser backend runtime queue provenance":

    it "surfaces queue evidence on GPU frames and resets it on cached frames":
        val (stdout, stderr, code) = rt_process_run(simple_binary(), ["run", "test/01_unit/app/ui/browser_backend_runtime_queue_probe.spl"])
        val output = stdout + stderr

        step("First GPU-selected render emits and drains one runtime queue packet")
        expect(code).to_equal(0)
        expect(output).to_contain("backend=vulkan")
        expect(output).to_contain("first_render_under_budget=true")
        expect(output).to_contain("first_pixel_count=3072")
        expect(output).to_contain("first_checksum=772887022")
        expect(output).to_contain("first_nonuniform_count=2884")
        expect(output).to_contain("first_submit=submitted")
        expect(output).to_contain("first_drain=drained")
        expect(output).to_contain("first_packet=1")
        expect(output).to_contain("first_drained=1")
        expect(output).to_contain("first_backend_handle_positive=true")
        expect(output).to_contain("first_payload_size=12288")
        expect(output).to_contain("first_payload_hash=782290402")
        expect(output).to_contain("first_payload_text=web-render-frame;backend=vulkan;pixels=3072;checksum=782290402")
        expect(output).to_contain("first_dispatch_status=dispatched")
        expect(output).to_contain("first_dispatch_reason=Draw IR runtime packet dispatched to Engine2D backend")
        expect(output).to_contain("first_dispatch_payload_size=512")
        expect(output).to_contain("first_dispatch_layout_command_count=8")
        expect(output).to_contain("first_dispatch_payload_hash=941781836")
        expect(output).to_contain("first_dispatch_payload_text=draw_ir schema=simple-draw-ir-v2")
        expect(output).to_contain("first_dispatch_rect_command_count=4")
        expect(output).to_contain("first_dispatch_text_command_count=3")
        expect(output).to_contain("first_dispatch_image_command_count=1")
        expect(output).to_contain("first_dispatch_has_gui_ast_source=true")
        expect(output).to_contain("first_dispatch_has_root_widget=true")
        expect(output).to_contain("first_dispatch_has_copy_text=true")
        expect(output).to_contain("first_dispatch_has_action_text=true")
        expect(output).to_contain("first_dispatch_has_image_widget=true")
        expect(output).to_contain("first_dispatch_has_image_uri=true")
        expect(output).to_contain("first_dispatch_target_context_resolved=true")
        expect(output).to_contain("first_dispatch_target_context_batch_id=browser-frame-16")
        expect(output).to_contain("first_dispatch_target_context_surface_id=browser-frame")
        expect(output).to_contain("first_dispatch_target_context_component_id=browser-frame")
        expect(output).to_contain("first_dispatch_target_context_source_kind=gui_ast")
        expect(output).to_contain("first_reason=drained runtime queue")
        expect(output).to_contain("first_readback_status=readback")
        expect(output).to_contain("first_readback_backend=vulkan")
        expect(output).to_contain("first_readback_pixel_count=3072")
        expect(output).to_contain("first_readback_reason=same-frame Engine2D read_pixels")
        expect(output).to_contain("first_gpu_readback_source=device_readback")
        expect(output).to_contain("first_event_correlation_status=event_frame_readback_correlated")
        expect(output).to_contain("first_event_correlation_id=browser-input-1")
        expect(output).to_contain("first_event_correlation_summary=event=browser-input-1;frame_packet=1;readback_source=device_readback;checksum=782290402")
        expect(output).to_contain("first_event_correlation_queue_packet=1")
        expect(output).to_contain("first_event_correlation_readback_source=device_readback")
        expect(output).to_contain("first_event_correlation_readback_checksum=782290402")
        expect(output).to_contain("event_roundtrip_status=rendered")
        expect(output).to_contain("event_enqueued_count=1")
        expect(output).to_contain("event_polled_count=1")
        expect(output).to_contain("event_dispatched_count=1")
        expect(output).to_contain("event_host_gpu_target_lane=gpu")
        expect(output).to_contain("event_host_gpu_forwarded=true")
        expect(output).to_contain("event_host_gpu_backward_completed=false")
        expect(output).to_contain("event_host_gpu_summary=event=browser-input-1")
        expect(output).to_contain("event_host_gpu_summary=")
        expect(output).to_contain("forwarded=true")
        expect(output).to_contain("backward_completed=false")

        step("Second unchanged frame is served from cache and reports no queue or readback request")
        expect(output).to_contain("second_render_under_budget=true")
        expect(output).to_contain("second_fast_hits=1")
        expect(output).to_contain("second_submit=not_requested")
        expect(output).to_contain("second_drain=not_requested")
        expect(output).to_contain("second_packet=0")
        expect(output).to_contain("second_drained=0")
        expect(output).to_contain("second_backend_handle=0")
        expect(output).to_contain("second_payload_size=0")
        expect(output).to_contain("second_payload_hash=0")
        expect(output).to_contain("second_payload_text=")
        expect(output).to_contain("second_dispatch_status=not_requested")
        expect(output).to_contain("second_dispatch_reason=runtime dispatch not requested")
        expect(output).to_contain("second_dispatch_payload_size=0")
        expect(output).to_contain("second_dispatch_layout_command_count=0")
        expect(output).to_contain("second_dispatch_payload_hash=0")
        expect(output).to_contain("second_dispatch_payload_text=")
        expect(output).to_contain("second_dispatch_rect_command_count=0")
        expect(output).to_contain("second_dispatch_text_command_count=0")
        expect(output).to_contain("second_dispatch_image_command_count=0")
        expect(output).to_contain("second_dispatch_has_gui_ast_source=false")
        expect(output).to_contain("second_dispatch_has_root_widget=false")
        expect(output).to_contain("second_dispatch_has_copy_text=false")
        expect(output).to_contain("second_dispatch_has_action_text=false")
        expect(output).to_contain("second_dispatch_has_image_widget=false")
        expect(output).to_contain("second_dispatch_has_image_uri=false")
        expect(output).to_contain("second_dispatch_target_context_resolved=false")
        expect(output).to_contain("second_dispatch_target_context_batch_id=")
        expect(output).to_contain("second_dispatch_target_context_surface_id=")
        expect(output).to_contain("second_dispatch_target_context_component_id=")
        expect(output).to_contain("second_dispatch_target_context_source_kind=")
        expect(output).to_contain("second_reason=runtime queue not requested")
        expect(output).to_contain("second_readback_status=not_requested")
        expect(output).to_contain("second_readback_pixel_count=0")
        expect(output).to_contain("second_readback_checksum=0")
        expect(output).to_contain("second_gpu_readback_source=not_requested")
        expect(output).to_contain("second_event_correlation_status=not_requested")
        expect(output).to_contain("second_event_correlation_id=")
        expect(output).to_contain("second_event_correlation_queue_packet=0")
        expect(output).to_contain("second_event_correlation_readback_source=not_requested")
