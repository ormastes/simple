use std.spec.{describe, it, expect}
use common.ui.access.{
    UI_ACCESS_PROTOCOL_VERSION,
    UiAccessEvent,
    UiAccessNode,
    UiAccessSnapshot,
    UiAccessSurface,
    ui_access_snapshot_to_json
}

fn _json_snapshot() -> UiAccessSnapshot:
    val main = UiAccessSurface(
        surface_id: "main",
        title: "Main",
        active: true,
        window_id: "w1",
        app_id: "app.main",
        root_canonical_id: "main#root"
    )
    val popup = UiAccessSurface(
        surface_id: "popup",
        title: "Popup",
        active: false,
        window_id: "w2",
        app_id: "app.popup",
        root_canonical_id: "popup#root"
    )
    val root = UiAccessNode(
        canonical_id: "main#root",
        surface_id: "main",
        widget_id: "root",
        kind: "panel",
        visible: true,
        focused: false,
        enabled: true,
        selected: false,
        text_value: "",
        props: [],
        child_ids: ["main#save", "main#cancel"],
        action_names: []
    )
    val save = UiAccessNode(
        canonical_id: "main#save",
        surface_id: "main",
        widget_id: "save",
        kind: "button",
        visible: true,
        focused: true,
        enabled: true,
        selected: false,
        text_value: "Save",
        props: [],
        child_ids: [],
        action_names: ["save", "submit"]
    )
    val event = UiAccessEvent(
        surface_id: "main",
        widget_id: "save",
        canonical_id: "main#save",
        event_kind: "action",
        payload: "save",
        sequence: 9
    )
    UiAccessSnapshot(
        protocol_version: UI_ACCESS_PROTOCOL_VERSION,
        snapshot_revision: 9,
        mode: "normal",
        active_surface: "main",
        surfaces: [main, popup],
        nodes: [root, save],
        recent_events: [event]
    )

describe "UI access JSON array serialization":

    it "keeps surfaces nodes child ids actions and events in stable order":
        val json = ui_access_snapshot_to_json(_json_snapshot())

        expect(json).to_equal("{\"protocol_version\":1,\"snapshot_revision\":9,\"mode\":\"normal\",\"active_surface\":\"main\",\"surfaces\":[{\"surface_id\":\"main\",\"title\":\"Main\",\"active\":true,\"window_id\":\"w1\",\"app_id\":\"app.main\",\"root_canonical_id\":\"main#root\"},{\"surface_id\":\"popup\",\"title\":\"Popup\",\"active\":false,\"window_id\":\"w2\",\"app_id\":\"app.popup\",\"root_canonical_id\":\"popup#root\"}],\"nodes\":[{\"canonical_id\":\"main#root\",\"surface_id\":\"main\",\"widget_id\":\"root\",\"kind\":\"panel\",\"visible\":true,\"focused\":false,\"enabled\":true,\"selected\":false,\"text\":\"\",\"props\":{},\"child_ids\":[\"main#save\",\"main#cancel\"],\"action_names\":[]},{\"canonical_id\":\"main#save\",\"surface_id\":\"main\",\"widget_id\":\"save\",\"kind\":\"button\",\"visible\":true,\"focused\":true,\"enabled\":true,\"selected\":false,\"text\":\"Save\",\"props\":{},\"child_ids\":[],\"action_names\":[\"save\",\"submit\"]}],\"recent_events\":[{\"surface_id\":\"main\",\"widget_id\":\"save\",\"canonical_id\":\"main#save\",\"event_kind\":\"action\",\"payload\":\"save\",\"sequence\":9}]}")
