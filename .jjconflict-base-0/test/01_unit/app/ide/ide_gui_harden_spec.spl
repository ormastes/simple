# IDE gui_sanity hardening spec.
#
# Verifies that GUI backend config is sane in headless environments and that
# the probe returns a valid result without starting a GUI event loop.

use std.spec
use app.ide.gui_sanity.{ide_gui_sanity, ide_gui_bounds_valid}

describe "gui_sanity: headless degradation — bounds and config checks":

    it "gui backend config has positive width (sane default even in headless)":
        expect(ide_gui_bounds_valid()).to_equal(true)

    it "ide_gui_sanity returns a result without crashing":
        val sanity = ide_gui_sanity()
        expect(sanity.theme.len() >= 0).to_equal(true)

    it "gui config width is positive":
        val sanity = ide_gui_sanity()
        expect(sanity.width > 0).to_equal(true)

    it "gui config height is positive":
        val sanity = ide_gui_sanity()
        expect(sanity.height > 0).to_equal(true)

    it "gui sanity has_backend_config is true":
        val sanity = ide_gui_sanity()
        expect(sanity.has_backend_config).to_equal(true)
