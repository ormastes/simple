# Profile Layout JIT Hotspots Specification
#
# **Category:** Compiler Perf / Profile-Guided
# **Status:** Implemented
#
# ## Overview
# profile_layout_jit_hotspots is the production sprof -> JIT wiring (review
# finding: the hotspot bridge previously had zero callers). It loads .sprof
# function records, converts them through the compiler-side hotspot bridge,
# and returns only candidates meeting the tier-1 threshold.

use std.spec.*
use app.optimize.profile_layout_cli.{profile_layout_jit_hotspots}
use compiler.interp.execution.tiered_jit.{TieredJitConfig}

fn _fixture_profile_text() -> text:
    [
        "header;schema=sprof-v1;module=demo;workload=jit-hotspot-spec",
        "function;key=c:rare:entry;count=0",
        "function;key=c:dispatch:entry;count=80",
        "function;key=c:parse:entry;count=6"
    ].join("\n") + "\n"

describe "profile_layout_jit_hotspots — sprof records drive JIT hotspot plan":
    it "returns only functions meeting the tier-1 threshold":
        val config = TieredJitConfig(tier1_threshold: 64, tier2_threshold: 1024, debug_mode: false)
        val hotspots = profile_layout_jit_hotspots(_fixture_profile_text(), config)
        expect(hotspots.len()).to_equal(1)
        expect(hotspots[0].function_name).to_equal("dispatch")
        expect(hotspots[0].call_count).to_equal(80)

    it "includes every counted function when the threshold is low":
        val config = TieredJitConfig(tier1_threshold: 1, tier2_threshold: 1024, debug_mode: false)
        val hotspots = profile_layout_jit_hotspots(_fixture_profile_text(), config)
        expect(hotspots.len()).to_equal(2)

    it "returns empty for empty profile text":
        val config = TieredJitConfig(tier1_threshold: 64, tier2_threshold: 1024, debug_mode: false)
        val hotspots = profile_layout_jit_hotspots("", config)
        expect(hotspots.len()).to_equal(0)

    it "ignores zero-count and non-function records":
        val config = TieredJitConfig(tier1_threshold: 1, tier2_threshold: 1024, debug_mode: false)
        val profile = "header;schema=sprof-v1;module=demo;workload=w\nfunction;key=c:rare:entry;count=0\n"
        val hotspots = profile_layout_jit_hotspots(profile, config)
        expect(hotspots.len()).to_equal(0)
