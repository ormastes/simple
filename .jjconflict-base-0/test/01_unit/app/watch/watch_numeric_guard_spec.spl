extern fn rt_file_read_text(path: text) -> text?

describe "watch numeric guard":
    it "defaults malformed interval values":
        val source = rt_file_read_text("src/app/watch/main.spl") ?? ""

        expect(source).to_contain("fn parse_watch_ms_or_default(value: text, default_value: i64) -> i64")
        expect(source).to_contain("return trimmed.to_int() ?? default_value")
        expect(source.contains("return trimmed.to_int()\n")).to_equal(false)
