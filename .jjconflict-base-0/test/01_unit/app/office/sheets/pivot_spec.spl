"""Office sheets pivot table spec.

Ground truth (hand-computed, scratchpad-verified before writing this spec):
dataset rows (region, product, sales):
  East,A,10
  East,B,20
  West,A,30
  West,B,40
  East,A,5
  West,B,15

1D pivot by region SUM(sales): East=35, West=85, Grand=120.
2D pivot region x product SUM: East/A=15, East/B=20, West/A=30, West/B=55,
row totals 35/85, col totals 45/75, grand 120.
2D COUNT: East/A=2, East/B=1, West/A=1, West/B=2, row totals 3/3, col
totals 3/3, grand 6.
2D AVERAGE (per-cell only -- row/grand region averages are repeating
decimals and are intentionally not asserted cell-exact): East/A=7.5,
East/B=20, West/A=30, West/B=27.5.
2D MIN/MAX: East/A min=5 max=10, East/B min=20 max=20, West/A min=30
max=30, West/B min=15 max=40; row East min=5 max=20, row West min=15
max=40; col A min=5 max=30, col B min=15 max=40; grand min=5 max=40.
1D COUNT/MIN/MAX by region: East count=3 min=5 max=20, West count=3
min=15 max=40, grand count=6 min=5 max=40.

Row/column keys are emitted in FIRST-SEEN order (not lexicographic) --
see pivot_build's docstring in src/app/office/sheets/pivot.spl.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.pivot.{pivot_build, pivot_to_sheet}
use app.office.sheets.cell.{cell_display_text}

fn _pivot_dataset() -> Sheet:
    var sheet = Sheet.new("data")
    sheet.set_value("A1", "East")
    sheet.set_value("B1", "A")
    sheet.set_value("C1", "10")
    sheet.set_value("A2", "East")
    sheet.set_value("B2", "B")
    sheet.set_value("C2", "20")
    sheet.set_value("A3", "West")
    sheet.set_value("B3", "A")
    sheet.set_value("C3", "30")
    sheet.set_value("A4", "West")
    sheet.set_value("B4", "B")
    sheet.set_value("C4", "40")
    sheet.set_value("A5", "East")
    sheet.set_value("B5", "A")
    sheet.set_value("C5", "5")
    sheet.set_value("A6", "West")
    sheet.set_value("B6", "B")
    sheet.set_value("C6", "15")
    sheet

describe "pivot_build: 1D SUM":
    """One-dimensional pivot (col_key_col = -1): group by region, sum sales."""

    it "groups by region in first-seen order with a grand-total row":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "sum")

        expect(result.len()).to_equal(4)
        expect(result[0][0]).to_equal("Row")
        expect(result[0][1]).to_equal("SUM")
        expect(result[1][0]).to_equal("East")
        expect(result[1][1]).to_equal("35")
        expect(result[2][0]).to_equal("West")
        expect(result[2][1]).to_equal("85")
        expect(result[3][0]).to_equal("Grand Total")
        expect(result[3][1]).to_equal("120")

describe "pivot_build: 1D COUNT/MIN/MAX":
    """Non-SUM aggregates on the one-dimensional form."""

    it "counts numeric values per region":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "count")
        expect(result[1][1]).to_equal("3")
        expect(result[2][1]).to_equal("3")
        expect(result[3][1]).to_equal("6")

    it "takes the min per region":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "min")
        expect(result[1][1]).to_equal("5")
        expect(result[2][1]).to_equal("15")
        expect(result[3][1]).to_equal("5")

    it "takes the max per region":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "max")
        expect(result[1][1]).to_equal("20")
        expect(result[2][1]).to_equal("40")
        expect(result[3][1]).to_equal("40")

describe "pivot_build: 2D SUM":
    """Two-dimensional cross-tab (region x product) with row, column, and
    grand totals."""

    it "cross-tabs region x product, cell-exact":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, 1, 2, "sum")

        expect(result.len()).to_equal(4)
        expect(result[0][0]).to_equal("Row/Col")
        expect(result[0][1]).to_equal("A")
        expect(result[0][2]).to_equal("B")
        expect(result[0][3]).to_equal("Grand Total")

        expect(result[1][0]).to_equal("East")
        expect(result[1][1]).to_equal("15")
        expect(result[1][2]).to_equal("20")
        expect(result[1][3]).to_equal("35")

        expect(result[2][0]).to_equal("West")
        expect(result[2][1]).to_equal("30")
        expect(result[2][2]).to_equal("55")
        expect(result[2][3]).to_equal("85")

        expect(result[3][0]).to_equal("Grand Total")
        expect(result[3][1]).to_equal("45")
        expect(result[3][2]).to_equal("75")
        expect(result[3][3]).to_equal("120")

describe "pivot_build: 2D COUNT":
    """COUNT aggregate, including row/column/grand totals (all integers)."""

    it "counts numeric cells per region x product, plus totals":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, 1, 2, "count")

        expect(result[1][1]).to_equal("2")
        expect(result[1][2]).to_equal("1")
        expect(result[1][3]).to_equal("3")
        expect(result[2][1]).to_equal("1")
        expect(result[2][2]).to_equal("2")
        expect(result[2][3]).to_equal("3")
        expect(result[3][1]).to_equal("3")
        expect(result[3][2]).to_equal("3")
        expect(result[3][3]).to_equal("6")

describe "pivot_build: 2D AVERAGE":
    """AVERAGE aggregate, per-cell only (row/grand region averages are
    repeating decimals and are out of scope for cell-exact assertions)."""

    it "averages sales per region x product cell":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, 1, 2, "average")

        expect(result[1][1]).to_equal("7.5")
        expect(result[1][2]).to_equal("20")
        expect(result[2][1]).to_equal("30")
        expect(result[2][2]).to_equal("27.5")

describe "pivot_build: 2D MIN/MAX":
    """MIN/MAX aggregates, including row/column/grand totals."""

    it "takes the min per region x product, plus totals":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, 1, 2, "min")

        expect(result[1][1]).to_equal("5")
        expect(result[1][2]).to_equal("20")
        expect(result[1][3]).to_equal("5")
        expect(result[2][1]).to_equal("30")
        expect(result[2][2]).to_equal("15")
        expect(result[2][3]).to_equal("15")
        expect(result[3][1]).to_equal("5")
        expect(result[3][2]).to_equal("15")
        expect(result[3][3]).to_equal("5")

    it "takes the max per region x product, plus totals":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, 1, 2, "max")

        expect(result[1][1]).to_equal("10")
        expect(result[1][2]).to_equal("20")
        expect(result[1][3]).to_equal("20")
        expect(result[2][1]).to_equal("30")
        expect(result[2][2]).to_equal("40")
        expect(result[2][3]).to_equal("40")
        expect(result[3][1]).to_equal("30")
        expect(result[3][2]).to_equal("40")
        expect(result[3][3]).to_equal("40")

describe "pivot_build: non-numeric value cells":
    """Non-numeric value cells are skipped, like Excel, not treated as
    errors."""

    it "excludes a non-numeric value cell from its group's aggregate":
        var sheet = _pivot_dataset()
        sheet.set_value("C2", "n/a")  # East,B,20 -> East,B,n/a
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "sum")

        # East now only sums 10 + 5 = 15 (20 was skipped); West unaffected.
        expect(result[1][1]).to_equal("15")
        expect(result[2][1]).to_equal("85")
        expect(result[3][1]).to_equal("100")

describe "pivot_build: fail-closed cases":
    """Invalid range, bad column indices, and unknown agg names all return
    an empty grid ([]) -- the #ERR-equivalent for a pivot call."""

    it "returns an empty grid for an unparsable range":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "NOTAROANGE", 0, -1, 2, "sum")
        expect(result.len()).to_equal(0)

    it "returns an empty grid for an unknown agg name":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "median")
        expect(result.len()).to_equal(0)

    it "returns an empty grid for an out-of-bounds value column":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 9, "sum")
        expect(result.len()).to_equal(0)

    it "returns an empty grid for an out-of-bounds row key column":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 9, -1, 2, "sum")
        expect(result.len()).to_equal(0)

describe "pivot_to_sheet":
    """Render a pivot_build grid into a Sheet for CSV/xlsx/ods export."""

    it "round-trips the 1D SUM grid into sheet cells":
        val sheet = _pivot_dataset()
        val result = pivot_build(sheet, "A1:C6", 0, -1, 2, "sum")
        val out_sheet = pivot_to_sheet(result, "pivot_out")

        expect(cell_display_text(out_sheet.get_cell("A1"))).to_equal("Row")
        expect(cell_display_text(out_sheet.get_cell("B1"))).to_equal("SUM")
        expect(cell_display_text(out_sheet.get_cell("A2"))).to_equal("East")
        expect(cell_display_text(out_sheet.get_cell("B2"))).to_equal("35")
        expect(cell_display_text(out_sheet.get_cell("A4"))).to_equal("Grand Total")
        expect(cell_display_text(out_sheet.get_cell("B4"))).to_equal("120")

    it "yields an empty sheet for an empty grid":
        val out_sheet = pivot_to_sheet([], "empty_pivot")
        expect(cell_display_text(out_sheet.get_cell("A1"))).to_equal("")
