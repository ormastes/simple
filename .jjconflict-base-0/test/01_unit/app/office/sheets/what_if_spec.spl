"""Office sheets What-If Analysis spec.

Hand-computed tests for What-If Analysis over a simple linear model
f(x) = slope*x + intercept: one-variable data tables, Goal Seek,
Scenario Manager, and two-variable data tables.
"""

use std.spec
use app.office.sheets.what_if.{LinearModel, model_new, model_eval, data_table_1d, goal_seek, Scenario, scenario_new, scenario_results, scenario_best, data_table_2d}

describe "model_eval: linear model evaluation":
    """f(x) = 2x + 3."""

    it "evaluates f(5) = 2*5+3 = 13":
        val model = model_new(2, 3)
        expect(model_eval(model, 5)).to_equal(13)

describe "data_table_1d: one-variable data table":
    """Evaluate f(x) = 2x+3 across a list of inputs."""

    it "produces one line per input in order":
        val model = model_new(2, 3)
        val rows = data_table_1d(model, [0, 1, 2])
        expect(rows.len()).to_equal(3)
        expect(rows[0]).to_equal("0 -> 3")
        expect(rows[1]).to_equal("1 -> 5")
        expect(rows[2]).to_equal("2 -> 7")

describe "goal_seek: algebraic solve for x":
    """x = (target_y - intercept) / slope for f(x) = 2x+3."""

    it "solves target 13 -> x=5":
        val model = model_new(2, 3)
        expect(goal_seek(model, 13)).to_equal(5)

    it "solves target 3 -> x=0":
        val model = model_new(2, 3)
        expect(goal_seek(model, 3)).to_equal(0)

    it "returns 0 for a degenerate zero-slope model":
        val model = model_new(0, 3)
        expect(goal_seek(model, 3)).to_equal(0)

describe "scenario_results and scenario_best: Scenario Manager":
    """Scenarios Low(x=1) and High(x=10) over f(x) = 2x+3."""

    it "summarizes each scenario as name: x=<x> -> <f(x)>":
        val model = model_new(2, 3)
        val low = scenario_new("Low", 1)
        val high = scenario_new("High", 10)
        val rows = scenario_results(model, [low, high])
        expect(rows.len()).to_equal(2)
        expect(rows[0]).to_equal("Low: x=1 -> 5")
        expect(rows[1]).to_equal("High: x=10 -> 23")

    it "picks the scenario with the highest f(x)":
        val model = model_new(2, 3)
        val low = scenario_new("Low", 1)
        val high = scenario_new("High", 10)
        val best = scenario_best(model, [low, high])
        expect(best).to_equal("High")

    it "breaks ties by keeping the first scenario":
        val model = model_new(2, 3)
        val first_tie = scenario_new("First", 5)
        val second_tie = scenario_new("Second", 5)
        val best = scenario_best(model, [first_tie, second_tie])
        expect(best).to_equal("First")

describe "data_table_2d: two-variable data table":
    """Row-major (slopes outer, intercepts inner) over slopes=[1,2],
    intercepts=[0,10], x=5. base_slope/base_intercept are unused by the
    per-cell evaluation (mirrors Excel referencing a base formula cell)."""

    it "evaluates slope*x+intercept for every (slope, intercept) pair in row-major order":
        val rows = data_table_2d(99, 99, [1, 2], [0, 10], 5)
        expect(rows.len()).to_equal(4)
        expect(rows[0]).to_equal("s=1 b=0 -> 5")
        expect(rows[1]).to_equal("s=1 b=10 -> 15")
        expect(rows[2]).to_equal("s=2 b=0 -> 10")
        expect(rows[3]).to_equal("s=2 b=10 -> 20")

    describe "deliberate-fail probe (fixed to green below)":
        """Temporary probe to confirm the runner actually executes this
        describe's assertions; asserts the true row-count so it stays
        green (kept as a nested sanity check, not a real failure)."""

        it "sanity: row count matches slopes.len() * intercepts.len()":
            val rows = data_table_2d(0, 0, [1, 2], [0, 10], 5)
            expect(rows.len()).to_equal(4)
