"""Calc text functions spec.

CONCAT/UPPER/LOWER/TRIM/LEN/LEFT/RIGHT/MID/EXACT over cell refs and string
literals. Text cells keep their text (no numeric coercion); MID is 1-based;
out-of-range counts clamp.
"""

use std.spec
use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text}
use app.office.file_formats.{recalculate_formula_cells}

fn _text_sheet() -> Sheet:
    var sh = Sheet.new("t")
    sh.set_value("A1", "hello")
    sh.set_value("A2", "World")
    sh

fn _eval(formula: text) -> text:
    var sh = _text_sheet()
    sh.set_value("B1", formula)
    sh = recalculate_formula_cells(sh)
    cell_display_text(sh.get_cell("B1"))

describe "Calc text functions":
    it "CONCAT joins refs and string literals":
        expect(_eval("=CONCAT(A1, \" \", A2)")).to_equal("hello World")

    it "UPPER/LOWER/TRIM transform case and whitespace":
        expect(_eval("=UPPER(A1)")).to_equal("HELLO")
        expect(_eval("=LOWER(A2)")).to_equal("world")
        expect(_eval("=TRIM(\"  x  \")")).to_equal("x")

    it "LEN counts characters of a text cell":
        expect(_eval("=LEN(A1)")).to_equal("5")

    it "LEFT/RIGHT/MID slice with 1-based MID and clamped counts":
        expect(_eval("=LEFT(A2, 3)")).to_equal("Wor")
        expect(_eval("=RIGHT(A2, 2)")).to_equal("ld")
        expect(_eval("=MID(A2, 2, 3)")).to_equal("orl")
        expect(_eval("=LEFT(A2, 99)")).to_equal("World")

    it "EXACT compares case-sensitively":
        expect(_eval("=EXACT(A1, \"hello\")")).to_equal("TRUE")
        expect(_eval("=EXACT(A1, \"Hello\")")).to_equal("FALSE")
