# Publisher built-in template gallery spec.
#
# Verifies gallery_names lists the 3 built-in templates, build_template
# composes each one correctly on top of page_layout + columns primitives,
# template_summary's preview text, and gallery_render_html's HTML output.
#
# Frame counts (hand-verified by running this spec):
#   flyer:      title + body                       -> 2 frames
#   newsletter: col0 + col1 + title                 -> 3 frames
#   brochure:   col0 + col1 + col2 + title          -> 4 frames
#   unknown:    title only (fail-soft)              -> 1 frame

use std.spec
use app.office.publisher.page_layout.{page_frame_count, frame_text}
use app.office.publisher.gallery.{gallery_names, build_template, template_summary, gallery_render_html}

describe "publisher gallery: listing":
    it "lists all three built-in templates":
        val names = gallery_names()
        expect(names).to_contain("flyer")
        expect(names).to_contain("newsletter")
        expect(names).to_contain("brochure")

    it "gives the newsletter its exact preview summary":
        expect(template_summary("newsletter")).to_equal("newsletter: title banner + 2 columns")

    it "gives the flyer its exact preview summary":
        expect(template_summary("flyer")).to_equal("flyer: title banner + single body frame")

    it "gives the brochure its exact preview summary":
        expect(template_summary("brochure")).to_equal("brochure: title banner + 3 columns")

describe "publisher gallery: flyer template":
    it "fills the title frame":
        val page = build_template("flyer", "Big Sale", "Everything half off")
        expect(frame_text(page, "title")).to_equal("Big Sale")

    it "flows the body into the body frame":
        val page = build_template("flyer", "Big Sale", "Everything half off")
        expect(frame_text(page, "body")).to_contain("Everything")

    it "has exactly title + body frames":
        val page = build_template("flyer", "Big Sale", "Everything half off")
        expect(page_frame_count(page)).to_equal(2)

describe "publisher gallery: newsletter template":
    it "fills the title banner":
        val page = build_template("newsletter", "Town Herald", "News from around the block")
        expect(frame_text(page, "title")).to_equal("Town Herald")

    it "flows the body into the columns":
        val page = build_template("newsletter", "Town Herald", "News from around the block")
        expect(frame_text(page, "col0")).to_contain("News")

    it "has exactly title + 2 column frames":
        val page = build_template("newsletter", "Town Herald", "News from around the block")
        expect(page_frame_count(page)).to_equal(3)

describe "publisher gallery: brochure template":
    it "fills the title banner":
        val page = build_template("brochure", "Visit Us", "Come see our new location")
        expect(frame_text(page, "title")).to_equal("Visit Us")

    it "flows the body into the columns":
        val page = build_template("brochure", "Visit Us", "Come see our new location")
        expect(frame_text(page, "col0")).to_contain("Come")

    it "has exactly title + 3 column frames":
        val page = build_template("brochure", "Visit Us", "Come see our new location")
        expect(page_frame_count(page)).to_equal(4)

describe "publisher gallery: unknown template fallback":
    it "fails soft to a title-only page":
        val page = build_template("nonexistent", "Just A Title", "ignored body")
        expect(frame_text(page, "title")).to_equal("Just A Title")
        expect(page_frame_count(page)).to_equal(1)

    it "gives unknown templates a generic summary":
        expect(template_summary("nonexistent")).to_equal("unknown template: title only")

describe "publisher gallery: html rendering":
    it "renders the flyer with the title in the HTML":
        val html = gallery_render_html("flyer", "Big Sale", "Everything half off")
        expect(html).to_contain("Big Sale")

    describe "deliberate-fail probe (must stay green)":
        it "sanity-checks the newsletter frame count ground truth":
            val page = build_template("newsletter", "Town Herald", "News from around the block")
            # Probe verified live: asserting 4 frames (brochure's count,
            # not newsletter's) failed with "expected 3 to equal 4",
            # confirming the harness executes this assertion. Correct
            # ground truth: newsletter has col0 + col1 + title = 3 frames.
            expect(page_frame_count(page)).to_equal(3)
