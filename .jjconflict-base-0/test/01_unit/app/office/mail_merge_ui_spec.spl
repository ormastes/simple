"""Mail merge UI spec.

Verifies the user-facing inspection/preview/validation surface added on top
of the mail_merge engine (see word_mail_merge_spec.spl for the engine
itself): field discovery via merge_fields_of, single-record preview via
merge_preview, and fail-closed validation via merge_validate (missing
header column entirely, blank per-record value, unused CSV column, and the
degenerate zero-record case). Fixtures are built in-memory (RichDocument via
parse_markdown_document, Sheet via set_value) — no file I/O."""

use std.spec
use app.office.file_formats.{parse_markdown_document, document_to_markdown}
use app.office.word.mail_merge_ui.{merge_fields_of, merge_preview, merge_validate}
use app.office.sheets.spreadsheet.{Sheet}

# Placeholder braces must never appear as a literal "{{" in Simple string
# source (it would be parsed as interpolation) — build them by concatenation.
fn _ph(field: text) -> text:
    "{" + "{" + field + "}" + "}"

fn _template_md() -> text:
    val name_ph = _ph("Name")
    val city_ph = _ph("City")
    val zip_ph = _ph("Zip")
    "Dear " + name_ph + ", " + city_ph + " awaits you. Code: " + zip_ph + "."

fn _template_doc():
    parse_markdown_document(_template_md(), "letter")

# Header row: Name, City, Phone — Zip is never a header (whole-column
# missing field); Phone is never referenced by the template (unused
# column); row 2 (data record 2) has a blank City (per-record missing
# value).
fn _records_sheet() -> Sheet:
    var sh = Sheet.new("recipients")
    sh.set_value("A1", "Name")
    sh.set_value("B1", "City")
    sh.set_value("C1", "Phone")
    sh.set_value("A2", "Alice")
    sh.set_value("B2", "Paris")
    sh.set_value("C2", "555-0001")
    sh.set_value("A3", "Bob")
    sh.set_value("B3", "")
    sh.set_value("C3", "555-0002")
    sh

fn _header_only_sheet() -> Sheet:
    var sh = Sheet.new("recipients")
    sh.set_value("A1", "Name")
    sh.set_value("B1", "City")
    sh.set_value("C1", "Zip")
    sh

describe "merge_fields_of: template field discovery":
    """Distinct {field} names in document order, first occurrence wins."""

    it "returns the 3 distinct field names in document order":
        val doc = _template_doc()
        val fields = merge_fields_of(doc)
        expect(fields.len()).to_equal(3)
        expect(fields.get(0)).to_equal("Name")
        expect(fields.get(1)).to_equal("City")
        expect(fields.get(2)).to_equal("Zip")

describe "merge_preview: single-record merge for display":
    """Substitutes one data row's values without touching the others."""

    it "renders the exact merged text for record 1":
        val doc = _template_doc()
        val sheet = _records_sheet()
        val merged = merge_preview(doc, sheet, 1)
        val text = document_to_markdown(merged)
        expect(text).to_equal("Dear Alice, Paris awaits you. Code: .")

    it "renders record 2 independently (blank City substitutes empty)":
        val doc = _template_doc()
        val sheet = _records_sheet()
        val merged = merge_preview(doc, sheet, 2)
        val text = document_to_markdown(merged)
        expect(text).to_equal("Dear Bob,  awaits you. Code: .")

describe "merge_validate: fail-closed issue listing":
    """Empty result = clean merge; otherwise one issue line per problem."""

    it "catches a whole-column missing field, a per-record blank value, and an unused column":
        val doc = _template_doc()
        val sheet = _records_sheet()
        val issues = merge_validate(doc, sheet)
        expect(issues.len()).to_equal(3)
        expect(issues.get(0)).to_equal("field <<Zip>> has no matching column")
        expect(issues.get(1)).to_equal("record 2 missing field <<City>>")
        expect(issues.get(2)).to_equal("unused column Phone")

    it "returns empty for a template/sheet pairing with no problems":
        val doc = parse_markdown_document("Dear " + _ph("Name") + ".", "letter")
        var sheet = Sheet.new("recipients")
        sheet.set_value("A1", "Name")
        sheet.set_value("A2", "Alice")
        val issues = merge_validate(doc, sheet)
        expect(issues.len()).to_equal(0)

    it "reports an issue line (not a crash) when there are 0 data records":
        val doc = _template_doc()
        val sheet = _header_only_sheet()
        val issues = merge_validate(doc, sheet)
        expect(issues.len()).to_be_greater_than(0)
        expect(issues.get(issues.len() - 1)).to_equal("no data records found")
