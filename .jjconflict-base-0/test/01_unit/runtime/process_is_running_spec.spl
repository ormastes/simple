# Regression test for rt_process_is_running with async-spawned children.
#
# Root cause (Round-13): rt_process_is_running used kill(pid,0) only.
# kill(pid,0) returns 0 for zombie processes (exited but not yet reaped),
# so a child that had exited was reported as still running.
# Fix: try waitpid(WNOHANG) first to correctly reap and detect exited children,
# then fall back to kill(pid,0)+errno for non-child processes.

use app.io.mod.{process_spawn_async, process_is_running, process_wait, process_kill, process_is_alive}

describe "rt_process_is_running with async-spawned children":
    it "reports async-spawned child as running while alive":
        # Spawn a child that sleeps for 5 seconds (long enough to check liveness)
        val pid = process_spawn_async("sleep", ["5"])
        expect(pid > 0).to_equal(true)

        # Child should be running immediately after spawn
        val running = process_is_running(pid)
        expect(running).to_equal(true)

        # Clean up: a short wait is only a poll for this long-lived child.
        process_wait(pid, 100)
        if process_is_running(pid):
            process_kill(pid)
            process_wait(pid, 2000)
        expect(process_is_running(pid)).to_equal(false)

    it "reports async-spawned child as not running after it exits":
        # Spawn a child that exits immediately
        val pid = process_spawn_async("true", [])
        expect(pid > 0).to_equal(true)

        # Wait for the child to finish
        val exit_code = process_wait(pid, 2000)
        expect(exit_code >= 0).to_equal(true)

        # After waitpid, process should not be running
        val running = process_is_running(pid)
        expect(running).to_equal(false)

    it "treats repeated terminal cleanup as a safe no-op":
        val pid = process_spawn_async("true", [])
        expect(pid > 0).to_equal(true)

        val first_wait = process_wait(pid, 2000)
        expect(first_wait >= 0).to_equal(true)
        expect(process_is_running(pid)).to_equal(false)

        expect(process_wait(pid, 100)).to_equal(-1)
        expect(process_kill(pid)).to_equal(false)
        expect(process_is_running(pid)).to_equal(false)

    it "returns false for invalid pid zero":
        val running = process_is_running(0)
        expect(running).to_equal(false)

    it "returns false for negative pid":
        val running = process_is_running(-1)
        expect(running).to_equal(false)

    it "returns false for invalid alive pids":
        expect(process_is_alive(-1)).to_equal(false)
        expect(process_is_alive(0)).to_equal(false)

    it "refuses to kill invalid or reserved pids":
        expect(process_kill(-1)).to_equal(false)
        expect(process_kill(0)).to_equal(false)
        expect(process_kill(1)).to_equal(false)

    it "returns error for invalid wait pids":
        expect(process_wait(-1, 100)).to_equal(-1)
        expect(process_wait(0, 100)).to_equal(-1)
