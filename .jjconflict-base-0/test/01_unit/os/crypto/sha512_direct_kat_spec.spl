use std.spipe.*
use os.crypto.sha512.{sha512}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _hex(data: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < data.len():
        val b = data[i]
        out = out + _hex_nibble((b >> 4) & 0x0f)
        out = out + _hex_nibble(b & 0x0f)
        i = i + 1
    out

describe "os.crypto.sha512 direct KAT":
    it "matches SHA-512 empty":
        expect(_hex(sha512([]))).to_equal("cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")

    it "matches SHA-512 abc":
        expect(_hex(sha512([0x61, 0x62, 0x63]))).to_equal("ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f")

    it "matches SHA-512 RFC8032 Ed25519 test seed":
        val seed: [u8] = [
            0x9d, 0x61, 0xb1, 0x9d, 0xef, 0xfd, 0x5a, 0x60,
            0xba, 0x84, 0x4a, 0xf4, 0x92, 0xec, 0x2c, 0xc4,
            0x44, 0x49, 0xc5, 0x69, 0x7b, 0x32, 0x69, 0x19,
            0x70, 0x3b, 0xac, 0x03, 0x1c, 0xae, 0x7f, 0x60
        ]
        expect(_hex(sha512(seed))).to_equal("357c83864f2833cb427a2ef1c00a013cfdff2768d980c0a3a520f006904de90f9b4f0afe280b746a778684e75442502057b7473a03f08f96f5a38e9287e01f8f")
