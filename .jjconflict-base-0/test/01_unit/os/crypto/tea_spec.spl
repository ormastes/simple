# TEA and XTEA Block Ciphers — Known-Answer Test Vectors
#
# Tests tea_encrypt, tea_decrypt, xtea_encrypt, xtea_decrypt against
# reference vectors computed from the canonical C reference implementation.
#
# TEA vectors (big-endian byte order):
#   Key: 00×16, PT: 00×8  → CT: 41ea3a0a94baa940
#   Key: 000102...0F, PT: 0102030405060708 → CT: b1a1ab198c45fa5b
#
# XTEA vectors (big-endian byte order):
#   Key: 00×16, PT: 00×8  → CT: dee9d4d8f7131ed9
#   Key: 000102...0F, PT: 0102030405060708 → CT: 88870e082874d853
#
# Reference: D. Wheeler, R. Needham — "TEA, a Tiny Encryption Algorithm" (1994)
#            D. Wheeler, R. Needham — "Tea extensions" (1997)

use std.spec.*
use os.crypto.tea.{tea_encrypt, tea_decrypt, xtea_encrypt, xtea_decrypt}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_to_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _zero_key() -> [u8]:
    var b: [u8] = []
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b

fn _zero_block() -> [u8]:
    var b: [u8] = []
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b

fn _seq_key() -> [u8]:
    var b: [u8] = []
    b.push(0x00)
    b.push(0x01)
    b.push(0x02)
    b.push(0x03)
    b.push(0x04)
    b.push(0x05)
    b.push(0x06)
    b.push(0x07)
    b.push(0x08)
    b.push(0x09)
    b.push(0x0A)
    b.push(0x0B)
    b.push(0x0C)
    b.push(0x0D)
    b.push(0x0E)
    b.push(0x0F)
    b

fn _seq_block() -> [u8]:
    var b: [u8] = []
    b.push(0x01)
    b.push(0x02)
    b.push(0x03)
    b.push(0x04)
    b.push(0x05)
    b.push(0x06)
    b.push(0x07)
    b.push(0x08)
    b

fn _tea_zero_ct() -> [u8]:
    var b: [u8] = []
    b.push(0x41)
    b.push(0xEA)
    b.push(0x3A)
    b.push(0x0A)
    b.push(0x94)
    b.push(0xBA)
    b.push(0xA9)
    b.push(0x40)
    b

fn _tea_seq_ct() -> [u8]:
    var b: [u8] = []
    b.push(0xB1)
    b.push(0xA1)
    b.push(0xAB)
    b.push(0x19)
    b.push(0x8C)
    b.push(0x45)
    b.push(0xFA)
    b.push(0x5B)
    b

fn _xtea_zero_ct() -> [u8]:
    var b: [u8] = []
    b.push(0xDE)
    b.push(0xE9)
    b.push(0xD4)
    b.push(0xD8)
    b.push(0xF7)
    b.push(0x13)
    b.push(0x1E)
    b.push(0xD9)
    b

fn _xtea_seq_ct() -> [u8]:
    var b: [u8] = []
    b.push(0x88)
    b.push(0x87)
    b.push(0x0E)
    b.push(0x08)
    b.push(0x28)
    b.push(0x74)
    b.push(0xD8)
    b.push(0x53)
    b

describe "TEA — known-answer vectors":

    it "TEA: encrypt zero key + zero block":
        val ct = tea_encrypt(_zero_key(), _zero_block())
        expect(_bytes_to_hex(ct)).to_equal("41ea3a0a94baa940")

    it "TEA: ciphertext is 8 bytes":
        val ct = tea_encrypt(_zero_key(), _zero_block())
        expect(ct.len()).to_equal(8)

    it "TEA: decrypt zero key + known CT recovers zero block":
        val pt = tea_decrypt(_zero_key(), _tea_zero_ct())
        expect(_bytes_to_hex(pt)).to_equal("0000000000000000")

    it "TEA: encrypt/decrypt round-trip (zero key)":
        val ct = tea_encrypt(_zero_key(), _zero_block())
        val pt = tea_decrypt(_zero_key(), ct)
        expect(_bytes_to_hex(pt)).to_equal("0000000000000000")

    it "TEA: encrypt seq key=0x000102..0F, plain=0x0102030405060708":
        val ct = tea_encrypt(_seq_key(), _seq_block())
        expect(_bytes_to_hex(ct)).to_equal("b1a1ab198c45fa5b")

    it "TEA: encrypt/decrypt round-trip (seq key)":
        val ct = tea_encrypt(_seq_key(), _seq_block())
        val pt = tea_decrypt(_seq_key(), ct)
        expect(_bytes_to_hex(pt)).to_equal("0102030405060708")

describe "XTEA — known-answer vectors":

    it "XTEA: encrypt zero key + zero block":
        val ct = xtea_encrypt(_zero_key(), _zero_block())
        expect(_bytes_to_hex(ct)).to_equal("dee9d4d8f7131ed9")

    it "XTEA: ciphertext is 8 bytes":
        val ct = xtea_encrypt(_zero_key(), _zero_block())
        expect(ct.len()).to_equal(8)

    it "XTEA: decrypt zero key + known CT recovers zero block":
        val pt = xtea_decrypt(_zero_key(), _xtea_zero_ct())
        expect(_bytes_to_hex(pt)).to_equal("0000000000000000")

    it "XTEA: encrypt/decrypt round-trip (zero key)":
        val ct = xtea_encrypt(_zero_key(), _zero_block())
        val pt = xtea_decrypt(_zero_key(), ct)
        expect(_bytes_to_hex(pt)).to_equal("0000000000000000")

    it "XTEA: encrypt seq key=0x000102..0F, plain=0x0102030405060708":
        val ct = xtea_encrypt(_seq_key(), _seq_block())
        expect(_bytes_to_hex(ct)).to_equal("88870e082874d853")

    it "XTEA: encrypt/decrypt round-trip (seq key)":
        val ct = xtea_encrypt(_seq_key(), _seq_block())
        val pt = xtea_decrypt(_seq_key(), ct)
        expect(_bytes_to_hex(pt)).to_equal("0102030405060708")
