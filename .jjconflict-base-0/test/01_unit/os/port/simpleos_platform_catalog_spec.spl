"""
Regression spec for P1 bug: interp_simpleos_lane_contract_crash_2026-06-13.

Verifies that catalog accessors work in interpreter mode without
'on Option' error or SIGSEGV after the index-based workaround.
"""
use std.spec.{describe, it, expect}
use os.port.simpleos_multiplatform_build.{
    simpleos_platform_target_by_name,
    simpleos_platform_target_names,
    simpleos_platform_qemu_smoke_lane,
    simpleos_platform_qemu_acceptance_lane,
    simpleos_platform_qemu_lane,
    simpleos_platform_qemu_lane_or_smoke,
    simpleos_platform_has_qemu_lane
}

describe "simpleos platform catalog — target_by_name":
    it "returns non-nil for riscv64":
        val names = simpleos_platform_target_names()
        var found = false
        for n in names:
            if n == "riscv64gc-simpleos":
                found = true
        expect(found).to_equal(true)

    it "target_names has 6 entries":
        val names = simpleos_platform_target_names()
        expect(names.len()).to_equal(6)

describe "simpleos platform catalog — qemu_smoke_lane (P1 regression)":
    it "riscv64 smoke lane name is non-empty":
        val lane = simpleos_platform_qemu_smoke_lane("riscv64")
        expect(lane.name != "").to_equal(true)

    it "riscv64 smoke lane name is riscv64-smoke":
        val lane = simpleos_platform_qemu_smoke_lane("riscv64")
        expect(lane.name).to_equal("riscv64-smoke")

    it "x86_64 smoke lane name is non-empty":
        val lane = simpleos_platform_qemu_smoke_lane("x86_64")
        expect(lane.name != "").to_equal(true)

describe "simpleos platform catalog — qemu_acceptance_lane":
    it "riscv64 acceptance lane name is riscv64-hosted":
        val lane = simpleos_platform_qemu_acceptance_lane("riscv64")
        expect(lane.name).to_equal("riscv64-hosted")

    it "arm64 acceptance lane name is arm64-virtio-fat32-smf":
        val lane = simpleos_platform_qemu_acceptance_lane("arm64")
        expect(lane.name).to_equal("arm64-virtio-fat32-smf")

describe "simpleos platform catalog — qemu_lane_or_smoke never-Option fallback (P1 fix)":
    it "unknown lane falls back to smoke lane (never Option)":
        val lane = simpleos_platform_qemu_lane_or_smoke("riscv64", "no-such-lane")
        expect(lane.name).to_equal("riscv64-smoke")

    it "known lane resolves to itself":
        val lane = simpleos_platform_qemu_lane_or_smoke("riscv64", "riscv64-virtio-fat32-smf")
        expect(lane.name).to_equal("riscv64-virtio-fat32-smf")

describe "simpleos platform catalog — qemu_lane named lookup":
    it "riscv64-virtio-fat32-smf lane found for riscv64":
        val found = simpleos_platform_has_qemu_lane("riscv64", "riscv64-virtio-fat32-smf")
        expect(found).to_equal(true)

    it "unknown-lane not found for riscv64":
        val found = simpleos_platform_has_qemu_lane("riscv64", "no-such-lane")
        expect(found).to_equal(false)

    it "riscv64-hosted lane found for riscv64":
        val found = simpleos_platform_has_qemu_lane("riscv64", "riscv64-hosted")
        expect(found).to_equal(true)
