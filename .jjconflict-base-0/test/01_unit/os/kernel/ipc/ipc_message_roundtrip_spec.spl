"""
# IPC Message Channel Round-Trip Specification

**Feature IDs:** #OS-006
**Category:** Runtime
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests `InlineChannel` (`src/os/kernel/ipc/message_buffer.spl`), a bounded
FIFO queue of `InlineMessage` owned as instance state by the caller rather
than a module-global table. Proves a message sent through the channel comes
back unchanged and in order, and that both the full-queue and empty-queue
edge cases fail closed (a distinct errno / nil, never a fabricated or
corrupted message).

`InlineChannel` is the hardened counterpart to the module-global `ep_inline_*`
flat arrays in the same file: same bounded-queue semantics, but state lives
in a struct the caller passes around instead of a shared global table
indexed by endpoint id — the correctness risk flagged by the IPC audit.
"""

use std.spec.{describe, it, expect}
use os.kernel.ipc.message_buffer.{InlineMessage, InlineChannel}

fn make_msg(method_id: u32, badge: u32, r0: u64) -> InlineMessage:
    InlineMessage(
        method_id: method_id,
        cap_count: 0,
        flags: 0,
        payload_len: 32,
        badge: badge,
        r0: r0,
        r1: r0 + 1,
        r2: r0 + 2,
        r3: r0 + 3,
        r4: r0 + 4,
        r5: r0 + 5,
        r6: r0 + 6,
        r7: r0 + 7
    )


describe "InlineChannel message round trip":
    describe "send then recv":
        it "returns the exact same payload that was sent":
            var ch = InlineChannel.new(4)
            val sent = make_msg(42, 7, 111)

            val send_rc = ch.send(sent)
            expect(send_rc).to_equal(0)

            val received = ch.recv()
            val got = received != nil
            expect(got).to_equal(true)
            if received != nil:
                val m = received
                expect(m.method_id).to_equal(42)
                expect(m.badge).to_equal(7)
                expect(m.payload_len).to_equal(32)
                expect(m.r0).to_equal(111)
                expect(m.r1).to_equal(112)
                expect(m.r7).to_equal(118)

    describe "ordering":
        it "preserves FIFO order across multiple sends":
            var ch = InlineChannel.new(4)
            ch.send(make_msg(10, 1, 1))
            ch.send(make_msg(20, 2, 100))

            val first = ch.recv()
            if first != nil:
                val m = first
                expect(m.method_id).to_equal(10)

            val second = ch.recv()
            if second != nil:
                val m = second
                expect(m.method_id).to_equal(20)

    describe "full queue (fail-closed)":
        it "rejects a send once the channel is at capacity":
            var ch = InlineChannel.new(4)
            var i: u32 = 0
            while i < 4:
                val rc = ch.send(make_msg(i + 1, 0, i.to_u64()))
                expect(rc).to_equal(0)
                i = i + 1

            expect(ch.is_full()).to_equal(true)

            # Channel is now full — the next send must fail with the
            # queue-full errno, not silently drop the oldest message or
            # overwrite a slot.
            val overflow_rc = ch.send(make_msg(99, 0, 999))
            expect(overflow_rc).to_equal(3)

            # Draining must yield exactly the messages that were accepted,
            # in order, and nothing from the rejected send.
            var j: u32 = 0
            while j < 4:
                val m = ch.recv()
                if m != nil:
                    val got = m
                    expect(got.method_id).to_equal(j + 1)
                j = j + 1

            val drained = ch.recv()
            expect(drained).to_equal(nil)

    describe "empty queue (fail-closed)":
        it "returns nil for a freshly-created channel":
            var ch = InlineChannel.new(4)
            expect(ch.is_empty()).to_equal(true)
            val received = ch.recv()
            expect(received).to_equal(nil)

        it "returns nil after the queue has been fully drained":
            var ch = InlineChannel.new(4)
            ch.send(make_msg(1, 0, 1))
            ch.recv()  # drain the only message
            val received = ch.recv()
            expect(received).to_equal(nil)
