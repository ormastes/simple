"""ShortcutHandler dynamic window-focus shortcuts (hardening item 5).

SC_1..SC_9 map to FocusWindow(0..8), generated from the contiguous PS/2
scancode range (0x02..0x0A) instead of one literal `if` arm per key. This
spec locks in the previously-untested SC_4..SC_9 extension and confirms
SC_1..SC_3 still behave as before.
"""

use std.spec
use os.gui.shortcut.{ShortcutHandler, uart_char_to_action}
use os.gui.input_event.{WmAction}

fn focus_index(action: WmAction) -> i64:
    match action:
        case WmAction.FocusWindow(idx: i):
            i.to_i64()
        case _:
            -1

describe "ShortcutHandler.handle_scancode FocusWindow range":
    it "maps SC_1..SC_3 to FocusWindow(0..2) (pre-existing behavior)":
        val h1 = ShortcutHandler.new()
        expect(focus_index(h1.handle_scancode(0x02))).to_equal(0)
        val h2 = ShortcutHandler.new()
        expect(focus_index(h2.handle_scancode(0x03))).to_equal(1)
        val h3 = ShortcutHandler.new()
        expect(focus_index(h3.handle_scancode(0x04))).to_equal(2)

    it "maps SC_4..SC_9 to FocusWindow(3..8)":
        val h4 = ShortcutHandler.new()
        expect(focus_index(h4.handle_scancode(0x05))).to_equal(3)
        val h5 = ShortcutHandler.new()
        expect(focus_index(h5.handle_scancode(0x06))).to_equal(4)
        val h6 = ShortcutHandler.new()
        expect(focus_index(h6.handle_scancode(0x07))).to_equal(5)
        val h7 = ShortcutHandler.new()
        expect(focus_index(h7.handle_scancode(0x08))).to_equal(6)
        val h8 = ShortcutHandler.new()
        expect(focus_index(h8.handle_scancode(0x09))).to_equal(7)
        val h9 = ShortcutHandler.new()
        expect(focus_index(h9.handle_scancode(0x0A))).to_equal(8)

    it "does not match a FocusWindow shortcut just past the 1..9 range":
        val h = ShortcutHandler.new()
        match h.handle_scancode(0x0B):
            case WmAction.FocusWindow(idx: _):
                assert_true(false)
            case _:
                assert_true(true)

describe "uart_char_to_action FocusWindow range":
    it "maps '4'..'9' to FocusWindow(3..8)":
        expect(focus_index(uart_char_to_action(52))).to_equal(3)  # '4'
        expect(focus_index(uart_char_to_action(57))).to_equal(8)  # '9'
