use std.spec.*
use os.kernel.memory.vmm.{PTE_PRESENT, PTE_WRITABLE, PTE_USER, PTE_NO_EXECUTE}
use os.kernel.memory.memory_leveling_vmm.{memory_vmm_flags_from_pte, memory_vmm_prepare_move_from_pte, memory_vmm_rollback_move, memory_vmm_finalize_move}

describe "memory-leveling VMM transaction":

    it "preserves PTE permissions when decoding a move":
        val flags = memory_vmm_flags_from_pte(PTE_PRESENT | PTE_WRITABLE | PTE_USER | PTE_NO_EXECUTE)
        expect(flags.present()).to_equal(true)
        expect(flags.writable()).to_equal(true)
        expect(flags.user()).to_equal(true)
        expect(flags.no_execute()).to_equal(true)

    it "captures a source mapping and cancels before page-table effects":
        val source: u64 = 0x8000
        val destination: u64 = 0xA000
        val source_pte = source | PTE_PRESENT | PTE_WRITABLE | PTE_USER | PTE_NO_EXECUTE
        val prepared = memory_vmm_prepare_move_from_pte(0x50000000, destination, source_pte)
        expect(prepared.ok).to_equal(true)
        expect(prepared.txn.source_phys_addr).to_equal(source)
        expect(prepared.txn.destination_phys_addr).to_equal(destination)
        expect(prepared.txn.flags.no_execute()).to_equal(true)
        expect(memory_vmm_rollback_move(prepared.txn).reason).to_equal("no-change")
        expect(memory_vmm_finalize_move(prepared.txn).unwrap_err()).to_equal("invalid-state")
