"""Unit tests for SimpleOS RV64 deployment boot profiles."""

use os.kernel.arch.riscv64.platform.boot_profile.{
    default_fpga_min_profile,
    default_fpga_network_ready_profile,
    default_qemu_network_gui_profile,
    is_feature_available,
    is_wm_mode_available
}
use testing.{describe, it, expect}

describe "SimpleOS RV64 boot profiles":
    it "keeps the FPGA minimum profile serial only":
        val profile = default_fpga_min_profile()
        expect(profile.name).to_equal("riscv64-fpga-min")
        expect(is_feature_available(profile, "uart_only")).to_equal(true)
        expect(is_feature_available(profile, "network")).to_equal(false)
        expect(is_feature_available(profile, "web")).to_equal(false)
        expect(is_feature_available(profile, "db")).to_equal(false)
        expect(is_wm_mode_available(profile, "full")).to_equal(false)

    it "enables QEMU network services and SimpleOS full-screen WM":
        val profile = default_qemu_network_gui_profile()
        expect(profile.name).to_equal("riscv64-qemu-net-gui")
        expect(is_feature_available(profile, "network")).to_equal(true)
        expect(is_feature_available(profile, "ssh")).to_equal(true)
        expect(is_feature_available(profile, "web")).to_equal(true)
        expect(is_feature_available(profile, "db")).to_equal(true)
        expect(is_feature_available(profile, "vulkan_gui")).to_equal(true)
        expect(is_feature_available(profile, "simple_wm")).to_equal(true)
        expect(is_wm_mode_available(profile, "full")).to_equal(true)
        expect(is_wm_mode_available(profile, "window")).to_equal(false)

    it "reserves FPGA network service capacity without GUI":
        val profile = default_fpga_network_ready_profile()
        expect(profile.name).to_equal("riscv64-fpga-net-ready")
        expect(is_feature_available(profile, "network")).to_equal(true)
        expect(is_feature_available(profile, "ssh")).to_equal(true)
        expect(is_feature_available(profile, "web")).to_equal(true)
        expect(is_feature_available(profile, "db")).to_equal(true)
        expect(is_feature_available(profile, "vulkan_gui")).to_equal(false)
        expect(is_feature_available(profile, "optimized_host_launch")).to_equal(true)
