# Z-Order Store persistence tests
#
# Verifies the stacking order + minimize state survive a WM restart by
# round-tripping through the zo_serialize()/zo_load() blob seam — the
# injectable backend that keeps the test off any real device.

use std.spec
use os.desktop.z_order_store.{ZOrderStore, ZOrderEntry}

describe "ZOrderStore persistence":
    it "restores stacking order into a fresh store":
        val store = ZOrderStore.new()
        store.touch(10)
        store.touch(20)
        store.touch(30)
        # 30 was touched last, so it is on top.
        expect(store.top_window()).to_equal(30)

        val blob = store.zo_serialize()
        assert_true(blob.len() > 0)

        val fresh = ZOrderStore.new()
        fresh.zo_load(blob)
        expect(fresh.len()).to_equal(3)
        expect(fresh.top_window()).to_equal(30)

    it "preserves per-window z ordering across reload":
        val store = ZOrderStore.new()
        store.touch(1)
        store.touch(2)
        store.focus(1)
        # focus raised 1 above 2.
        expect(store.top_window()).to_equal(1)

        val fresh = ZOrderStore.new()
        fresh.zo_load(store.zo_serialize())
        expect(fresh.top_window()).to_equal(1)
        val e1 = fresh.get(1)
        val e2 = fresh.get(2)
        assert_true(e1 != nil)
        assert_true(e2 != nil)
        assert_true(e1.z_index > e2.z_index)

    it "preserves minimized state across reload":
        val store = ZOrderStore.new()
        store.touch(7)
        store.touch(8)
        store.set_minimized(8, true)
        expect(store.is_minimized(8)).to_equal(true)

        val fresh = ZOrderStore.new()
        fresh.zo_load(store.zo_serialize())
        expect(fresh.is_minimized(8)).to_equal(true)
        expect(fresh.is_minimized(7)).to_equal(false)
        # Minimized 8 is excluded from top_window; 7 wins.
        expect(fresh.top_window()).to_equal(7)

    it "keeps next_z monotonic so a reloaded store raises above survivors":
        val store = ZOrderStore.new()
        store.touch(100)
        store.touch(200)

        val fresh = ZOrderStore.new()
        fresh.zo_load(store.zo_serialize())
        # A newly touched window after reload must land on top.
        fresh.touch(300)
        expect(fresh.top_window()).to_equal(300)
        val e300 = fresh.get(300)
        val e200 = fresh.get(200)
        assert_true(e300.z_index > e200.z_index)

    it "leaves the store untouched on a malformed blob":
        val store = ZOrderStore.new()
        store.touch(5)
        val before = store.len()
        store.zo_load([1u8, 2u8, 3u8])
        expect(store.len()).to_equal(before)
        expect(store.top_window()).to_equal(5)
