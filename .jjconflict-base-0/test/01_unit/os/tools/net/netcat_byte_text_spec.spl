# @cover src/os/tools/net/netcat_tool.spl 20%

use std.spipe.*
use os.tools.net.netcat_tool.{netcat_bytes_to_text}

describe "netcat byte text conversion":

    it "decodes received bytes without text.from_bytes":
        val decoded = netcat_bytes_to_text([110u8, 99u8, 10u8, 13u8, 9u8, 255u8])
        expect(decoded).to_equal("nc\n\r\t?")
