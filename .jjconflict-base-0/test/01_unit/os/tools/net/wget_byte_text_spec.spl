# @cover src/os/tools/net/wget_tool.spl 20%

use std.spipe.*
use os.tools.net.wget_tool.{wget_bytes_to_text}

describe "wget byte text conversion":

    it "decodes response bytes without text.from_bytes":
        val decoded = wget_bytes_to_text([72u8, 84u8, 84u8, 80u8, 47u8, 49u8, 46u8, 49u8, 32u8, 50u8, 48u8, 48u8, 13u8, 10u8, 9u8, 255u8])
        expect(decoded).to_equal("HTTP/1.1 200\r\n\t?")
