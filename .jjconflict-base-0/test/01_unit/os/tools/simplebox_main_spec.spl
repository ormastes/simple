"""simplebox entry point — proves it genuinely consumes the pure-Simple libc.

AC (simpleos-alpine-harden-musl-busybox): the simplebox userland binary must
actually call the pure-Simple libc, so packing it into the image wires the libc
in for real. seq's count is parsed by libc_strtoul; the whitespace-skip and
stop-at-non-digit cases below only pass if the libc parser (not open code) runs.
Dispatch routing (MDSOC+ router) is regression-guarded.
"""

use std.spec
use os.tools.simplebox.simplebox_main.{simplebox_seq_count, simplebox_run}

describe "simplebox entry (pure-Simple libc consumer)":
    context "seq count is parsed via the pure-Simple libc (libc_strtoul)":
        it "parses a plain decimal count":
            expect(simplebox_seq_count(["5"])).to_equal(5)
        it "skips leading whitespace (libc_strtoul behavior)":
            expect(simplebox_seq_count(["  42"])).to_equal(42)
        it "stops at the first non-digit (libc_strtoul behavior)":
            expect(simplebox_seq_count(["3abc"])).to_equal(3)
        it "empty args yields 0":
            expect(simplebox_seq_count([])).to_equal(0)

    context "dispatch routing preserved (MDSOC+ stateless router)":
        it "true applet returns 0":
            expect(simplebox_run(["simplebox", "true"])).to_equal(0)
        it "false applet returns 1":
            expect(simplebox_run(["simplebox", "false"])).to_equal(1)
        it "unknown applet returns 127":
            expect(simplebox_run(["simplebox", "nope"])).to_equal(127)
        it "seq applet runs and returns 0":
            expect(simplebox_run(["simplebox", "seq", "3"])).to_equal(0)
