use std.io_runtime

# Module-level types shared across tests

class MatrixEntry:
    label: text
    mandatory: bool
    status: text

class AcceptMatrix:
    entries: List<MatrixEntry>

fn matrix_all_mandatory_pass(m: AcceptMatrix) -> bool:
    var ok = true
    for e in m.entries:
        if e.mandatory and e.status != "pass":
            ok = false
    ok

fn matrix_pass_count(m: AcceptMatrix) -> int:
    var n = 0
    for e in m.entries:
        if e.status == "pass":
            n = n + 1
    n

fn matrix_fail_count(m: AcceptMatrix) -> int:
    var n = 0
    for e in m.entries:
        if e.status == "fail":
            n = n + 1
    n

class BootSummary:
    cpu_vendor: text
    ioapic_count: int
    uart_ok: bool
    pcie_ok: bool

fn boot_is_complete(s: BootSummary) -> bool:
    if s.cpu_vendor == "": return false
    if s.uart_ok == false: return false
    if s.pcie_ok == false: return false
    true

fn boot_emit_serial(s: BootSummary) -> text:
    "cpu=" + s.cpu_vendor + " ioapic=" + s.ioapic_count.to_text() + " uart=" + s.uart_ok.to_text()

fn interrupt_mode(s: BootSummary) -> text:
    if s.ioapic_count > 0: return "apic"
    "polling"

fn check_resident_launch(claimed: bool) -> text:
    if claimed: return "REJECT: resident launch not verified"
    ""

fn check_dma_heap_copy(heap_used: bool) -> text:
    if heap_used: return "REJECT: DMA must not copy through heap"
    ""

fn check_acceleration(claimed: bool, verified: bool) -> text:
    if claimed and verified == false: return "REJECT: acceleration claimed but not verified"
    ""

class DmaRead:
    elapsed_ms: int
    timeout_ms: int
    done: bool
    success: bool

fn dma_is_timeout(d: DmaRead) -> bool:
    d.elapsed_ms > d.timeout_ms

fn dma_complete_ok(d: DmaRead) -> DmaRead:
    DmaRead(elapsed_ms: d.elapsed_ms, timeout_ms: d.timeout_ms, done: true, success: true)

fn storage_primary(nvme_present: bool, sata_present: bool) -> text:
    if nvme_present: return "nvme"
    if sata_present: return "sata"
    "none"

fn display_is_accelerated(accelerated: bool, accel_verified: bool) -> bool:
    accelerated and accel_verified

fn net_is_ready(mac_set: bool, queue_ready: bool) -> bool:
    mac_set and queue_ready

# Tests

fn test_matrix_all_pass():
    val m = AcceptMatrix(entries: [
        MatrixEntry(label: "cpu", mandatory: true, status: "pass"),
        MatrixEntry(label: "uart", mandatory: true, status: "pass"),
        MatrixEntry(label: "pcie", mandatory: true, status: "pass"),
        MatrixEntry(label: "usb", mandatory: true, status: "pass"),
        MatrixEntry(label: "acpi", mandatory: true, status: "pass"),
        MatrixEntry(label: "nvme", mandatory: true, status: "pass"),
        MatrixEntry(label: "net", mandatory: true, status: "pass")
    ])
    if matrix_all_mandatory_pass(m): print("PASS: test_matrix_all_pass")
    else: print("FAIL: test_matrix_all_pass")

fn test_matrix_one_fail():
    val m = AcceptMatrix(entries: [
        MatrixEntry(label: "cpu", mandatory: true, status: "pass"),
        MatrixEntry(label: "uart", mandatory: true, status: "fail")
    ])
    if matrix_all_mandatory_pass(m) == false: print("PASS: test_matrix_one_fail")
    else: print("FAIL: test_matrix_one_fail")

fn test_matrix_fallback_not_pass():
    val m = AcceptMatrix(entries: [MatrixEntry(label: "net", mandatory: true, status: "fallback")])
    if matrix_all_mandatory_pass(m) == false: print("PASS: test_matrix_fallback_not_pass")
    else: print("FAIL: test_matrix_fallback_not_pass")

fn test_matrix_counts():
    val m = AcceptMatrix(entries: [
        MatrixEntry(label: "a", mandatory: true, status: "pass"),
        MatrixEntry(label: "b", mandatory: true, status: "pass"),
        MatrixEntry(label: "c", mandatory: true, status: "fail")
    ])
    val pc = matrix_pass_count(m)
    val fc = matrix_fail_count(m)
    if pc + fc == 3 and pc == 2 and fc == 1: print("PASS: test_matrix_counts")
    else: print("FAIL: test_matrix_counts")

fn test_matrix_add():
    var entries = [MatrixEntry(label: "cpu", mandatory: true, status: "pass")]
    entries.push(MatrixEntry(label: "uart", mandatory: true, status: "pass"))
    val m = AcceptMatrix(entries: entries)
    if m.entries.len() == 2: print("PASS: test_matrix_add")
    else: print("FAIL: test_matrix_add")

fn test_boot_summary_complete():
    val s = BootSummary(cpu_vendor: "GenuineIntel", ioapic_count: 1, uart_ok: true, pcie_ok: true)
    if boot_is_complete(s): print("PASS: test_boot_summary_complete")
    else: print("FAIL: test_boot_summary_complete")

fn test_boot_summary_incomplete():
    val s = BootSummary(cpu_vendor: "", ioapic_count: 0, uart_ok: true, pcie_ok: true)
    if boot_is_complete(s) == false: print("PASS: test_boot_summary_incomplete")
    else: print("FAIL: test_boot_summary_incomplete")

fn test_boot_emit_serial():
    val s = BootSummary(cpu_vendor: "AuthenticAMD", ioapic_count: 2, uart_ok: true, pcie_ok: true)
    val out = boot_emit_serial(s)
    if out.contains("AuthenticAMD") and out.contains("ioapic=2"): print("PASS: test_boot_emit_serial")
    else: print("FAIL: test_boot_emit_serial")

fn test_interrupt_mode_from_acpi():
    val a = BootSummary(cpu_vendor: "x", ioapic_count: 1, uart_ok: true, pcie_ok: true)
    val b = BootSummary(cpu_vendor: "x", ioapic_count: 0, uart_ok: true, pcie_ok: true)
    if interrupt_mode(a) == "apic" and interrupt_mode(b) == "polling": print("PASS: test_interrupt_mode_from_acpi")
    else: print("FAIL: test_interrupt_mode_from_acpi")

fn test_resident_launch_rejected():
    val r = check_resident_launch(true)
    if r.starts_with("REJECT:"): print("PASS: test_resident_launch_rejected")
    else: print("FAIL: test_resident_launch_rejected")

fn test_heap_dma_rejected():
    val r = check_dma_heap_copy(true)
    if r.starts_with("REJECT:"): print("PASS: test_heap_dma_rejected")
    else: print("FAIL: test_heap_dma_rejected")

fn test_false_accel_rejected():
    val r = check_acceleration(true, false)
    if r.starts_with("REJECT:"): print("PASS: test_false_accel_rejected")
    else: print("FAIL: test_false_accel_rejected")

fn test_valid_claims_pass():
    val r1 = check_resident_launch(false)
    val r2 = check_dma_heap_copy(false)
    val r3 = check_acceleration(true, true)
    if r1 == "" and r2 == "" and r3 == "": print("PASS: test_valid_claims_pass")
    else: print("FAIL: test_valid_claims_pass")

fn test_dma_read_complete():
    val d = DmaRead(elapsed_ms: 10, timeout_ms: 1000, done: false, success: false)
    val d2 = dma_complete_ok(d)
    if d2.done and d2.success: print("PASS: test_dma_read_complete")
    else: print("FAIL: test_dma_read_complete")

fn test_dma_timeout():
    val d = DmaRead(elapsed_ms: 2000, timeout_ms: 1000, done: false, success: false)
    if dma_is_timeout(d): print("PASS: test_dma_timeout")
    else: print("FAIL: test_dma_timeout")

fn test_storage_select_nvme():
    if storage_primary(true, true) == "nvme": print("PASS: test_storage_select_nvme")
    else: print("FAIL: test_storage_select_nvme")

fn test_display_accel_needs_verification():
    if display_is_accelerated(true, false) == false: print("PASS: test_display_accel_needs_verification")
    else: print("FAIL: test_display_accel_needs_verification")

fn test_ps2_passes_desktop():
    if net_is_ready(true, true): print("PASS: test_ps2_passes_desktop")
    else: print("FAIL: test_ps2_passes_desktop")

fn test_net_ready_needs_all():
    if net_is_ready(false, true) == false and net_is_ready(true, false) == false: print("PASS: test_net_ready_needs_all")
    else: print("FAIL: test_net_ready_needs_all")

fn test_net_no_implicit_advanced():
    val adv = false
    if adv == false: print("PASS: test_net_no_implicit_advanced")
    else: print("FAIL: test_net_no_implicit_advanced")

fn main():
    test_matrix_all_pass()
    test_matrix_one_fail()
    test_matrix_fallback_not_pass()
    test_matrix_counts()
    test_matrix_add()
    test_boot_summary_complete()
    test_boot_summary_incomplete()
    test_boot_emit_serial()
    test_interrupt_mode_from_acpi()
    test_resident_launch_rejected()
    test_heap_dma_rejected()
    test_false_accel_rejected()
    test_valid_claims_pass()
    test_dma_read_complete()
    test_dma_timeout()
    test_storage_select_nvme()
    test_display_accel_needs_verification()
    test_ps2_passes_desktop()
    test_net_ready_needs_all()
    test_net_no_implicit_advanced()
    print("DONE")
