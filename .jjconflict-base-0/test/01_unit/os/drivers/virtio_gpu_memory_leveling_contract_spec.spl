use std.spec.*
use os.drivers.virtio.virtio_gpu.{GpuDmaAllocResult, VirtioGpuDriver}

describe "VirtioGPU memory-leveling contract":

    it "preserves syscall allocation identity in canonical DMA metadata":
        val dma = GpuDmaAllocResult(virt: 0x70000000, phys: 0x200000, device: 0x200000, size: 4096, cache_policy: 0, allocation_id: 77, owner_device: 0x400, ok: true)
        expect(dma.into_descriptor().allocation_id).to_equal(77)
        expect(dma.into_descriptor().owner_device).to_equal(0x400)

    it "reports raw wrapper backing and physical migration as unavailable":
        val driver = VirtioGpuDriver.new()
        val capabilities = driver.capabilities()
        expect(capabilities.backing_registered).to_equal(false)
        expect(capabilities.physical_migration).to_equal(false)
        expect(capabilities.migration_reason).to_equal("migration-unavailable")
