# @cover src/lib/nogc_sync_mut/fs_driver/nvfs_arena.spl 60%
# @req REQ-NVFS-DURABLE-001
"""
# NVFS Durable Round-Trip

**Feature IDs:** #NVFS-DURABLE
**Category:** Runtime
**Status:** In Progress

## Overview

Proves that an NVFS arena write is persisted through a block device and can be
read back byte-for-byte, and that `arena_fsync_impl` is a real durability commit
(it writes the reserved header sector with the valid length) rather than a silent
no-op. The block device is an in-memory mock, so the whole round-trip is
host-verifiable via `bin/simple test` with no baremetal externs and no QEMU.

## Key Concepts

| Concept | Description |
|---------|-------------|
| nvme-backed arena | Appends write THROUGH the block device sectors (base_block+1..). |
| header sector | LBA=base_block is reserved for metadata; fsync commits the length there. |
| durable length | Recovered from the device header, independent of in-memory metadata. |
"""

use std.spec.{describe, it, expect}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.bytes_util.{text_to_bytes_pure}
use std.fs_driver.nvfs_arena.{nvfs_arena_set_block_device, arena_create_impl, arena_create_nvme_impl, arena_append_impl, arena_readv_impl, arena_fsync_impl, arena_durable_len_impl}


# ============================================================================
# In-memory mock block device (plain zeroed sectors, 512 B).
# Module-level banks work around the interpreter limit where trait (non-me)
# methods cannot mutate self fields — sector data lives in a global keyed by id.
# ============================================================================

var __nvfs_mock_banks: [[[u8]]] = []

fn _nvfs_zeros(n: i32) -> [u8]:
    var b: [u8] = []
    var i = 0
    while i < n:
        b.push(0)
        i = i + 1
    b

fn _nvfs_mock_alloc(sectors: i32) -> i32:
    var bank: [[u8]] = []
    var s = 0
    while s < sectors:
        bank.push(_nvfs_zeros(512))
        s = s + 1
    __nvfs_mock_banks.push(bank)
    __nvfs_mock_banks.len() - 1

fn _nvfs_mock_get(bid: i32, sec: i32) -> [u8]:
    var bk = __nvfs_mock_banks[bid]
    bk[sec]

fn _nvfs_mock_set(bid: i32, sec: i32, data: [u8]):
    var bk = __nvfs_mock_banks[bid]
    bk[sec] = data
    __nvfs_mock_banks[bid] = bk

fn _nvfs_mock_count(bid: i32) -> i32:
    var bk = __nvfs_mock_banks[bid]
    bk.len()

fn _nvfs_mock_extend(bid: i32, target: i32):
    var bk = __nvfs_mock_banks[bid]
    while bk.len() <= target:
        bk.push(_nvfs_zeros(512))
    __nvfs_mock_banks[bid] = bk

class NvfsMockDevice:
    bank_id: i32

impl NvfsMockDevice:
    static fn new() -> NvfsMockDevice:
        val bid = _nvfs_mock_alloc(128)
        NvfsMockDevice(bank_id: bid)

impl BlockDevice for NvfsMockDevice:
    fn read_sector(lba: u64) -> Result<[u8], text>:
        val bid = self.bank_id
        val idx = lba.to_i32()
        if idx < 0 or idx >= _nvfs_mock_count(bid):
            return Ok(_nvfs_zeros(512))
        Ok(_nvfs_mock_get(bid, idx))

    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        val bid = self.bank_id
        val idx = lba.to_i32()
        if idx < 0:
            return Err("invalid sector")
        if idx >= _nvfs_mock_count(bid):
            _nvfs_mock_extend(bid, idx)
        var dest = _nvfs_mock_get(bid, idx)
        var i = 0
        while i < data.len() and i < dest.len():
            dest[i] = data[i]
            i = i + 1
        _nvfs_mock_set(bid, idx, dest)
        Ok(true)

    fn sector_size() -> u32:
        512


# ============================================================================
# Scenarios
# ============================================================================

describe "NVFS durable round-trip (REQ-NVFS-DURABLE-001)":
    it "persists an arena write through the block device and reads it back":
        val dev = NvfsMockDevice.new()
        nvfs_arena_set_block_device(dev)
        val base = 8
        val arena = arena_create_nvme_impl(0, 4096, base, 64)
        expect(arena).to_be_greater_than(0)

        val payload = text_to_bytes_pure("simpleos durable payload")
        val n = arena_append_impl(arena, payload, 0)
        expect(n).to_equal(payload.len() as i64)

        val readback = arena_readv_impl(arena, 0, payload.len() as i64)
        expect(readback.len() as i64).to_equal(payload.len() as i64)
        var same = true
        var i = 0
        while i < payload.len() as i64:
            if readback[i as i32] != payload[i as i32]:
                same = false
            i = i + 1
        expect(same).to_equal(true)

    it "fsync is a real durability commit, not a silent no-op":
        val dev = NvfsMockDevice.new()
        nvfs_arena_set_block_device(dev)
        val base = 16
        val arena = arena_create_nvme_impl(0, 4096, base, 64)
        expect(arena).to_be_greater_than(0)

        val payload = text_to_bytes_pure("commit-me")
        val n = arena_append_impl(arena, payload, 0)
        expect(n).to_equal(payload.len() as i64)

        # Before fsync the reserved header sector is zeroed: no magic -> unknown length.
        val before = arena_durable_len_impl(base)
        expect(before).to_equal(-1)

        # fsync commits the valid length into the header sector on the device.
        val committed = arena_fsync_impl(arena)
        expect(committed).to_equal(true)

        # After fsync the length is recoverable straight from the device header,
        # independent of any in-memory arena metadata.
        val after = arena_durable_len_impl(base)
        expect(after).to_equal(payload.len() as i64)

    it "fsync honestly reports no durability for a volatile in-memory arena":
        val arena = arena_create_impl(0, 4096)
        expect(arena).to_be_greater_than(0)
        val payload = text_to_bytes_pure("volatile")
        val n = arena_append_impl(arena, payload, 0)
        expect(n).to_equal(payload.len() as i64)
        # No block backing -> fsync must not claim success.
        val committed = arena_fsync_impl(arena)
        expect(committed).to_equal(false)
