use std.spec

use os.apps.browser_demo.browser_demo.{BrowserDemoApp, render_demo_to_pixels}

describe "Browser Demo rendering":
    it "precomputes browser render stats for the desktop app tree":
        val app = BrowserDemoApp.new()
        expect(app.render_done).to_equal(true)
        expect(app.node_count).to_be_greater_than(0)
        expect(app.pixel_count).to_be_greater_than(0)

    it "renders non-background pixels through the browser engine":
        val pixels = render_demo_to_pixels(320, 240)
        var visible: i32 = 0
        for pixel in pixels:
            if pixel != 0xFFF0F0F0:
                visible = visible + 1
        expect(visible).to_be_greater_than(0)
