use std.spec.{describe, it, assert_equal}
use std.encoding.bson.{BsonValue, BsonError, bson_decode}

fn _bad_string_len_zero() -> [u8]:
    # {"a": <string length 0>} with document terminator.
    [12u8, 0u8, 0u8, 0u8, 0x02u8, 0x61u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]

fn _bad_string_missing_null() -> [u8]:
    # {"a": <string length 1, byte 'b'>}; length byte must be the null terminator.
    [13u8, 0u8, 0u8, 0u8, 0x02u8, 0x61u8, 0u8, 1u8, 0u8, 0u8, 0u8, 0x62u8, 0u8]

fn _valid_empty_string() -> [u8]:
    # {"a": ""}: string length 1, null terminator, document terminator.
    [13u8, 0u8, 0u8, 0u8, 0x02u8, 0x61u8, 0u8, 1u8, 0u8, 0u8, 0u8, 0u8, 0u8]

fn _bad_early_document_terminator() -> [u8]:
    # Declares 8 bytes, but terminates at byte 4 and leaves payload bytes inside the document.
    [8u8, 0u8, 0u8, 0u8, 0u8, 0x10u8, 0u8, 0u8]

fn _bad_embedded_int32_crosses_boundary() -> [u8]:
    # {"e": <embedded doc>} where the embedded doc declares 8 bytes but its int32 value crosses that boundary.
    [18u8, 0u8, 0u8, 0u8, 0x03u8, 0x65u8, 0u8, 8u8, 0u8, 0u8, 0u8, 0x10u8, 0x61u8, 0u8, 1u8, 0u8, 0u8, 0u8]

describe "BSON string decode guards":
    it "rejects zero string length":
        val r = bson_decode(_bad_string_len_zero())
        assert_equal(r.is_ok(), false)

    it "rejects non-null string terminator":
        val r = bson_decode(_bad_string_missing_null())
        assert_equal(r.is_ok(), false)

    it "rejects early document terminators with trailing payload bytes":
        val r = bson_decode(_bad_early_document_terminator())
        assert_equal(r.is_ok(), false)

    it "rejects embedded values that cross declared document boundaries":
        val r = bson_decode(_bad_embedded_int32_crosses_boundary())
        assert_equal(r.is_ok(), false)
        match r:
            case Err(e):
                match e:
                    case BsonError.UnexpectedEnd:
                        assert_equal(true, true)
                    case _:
                        assert_equal(false, true)
            case _:
                assert_equal(false, true)

    it "keeps valid empty strings":
        val r = bson_decode(_valid_empty_string())
        assert_equal(r.is_ok(), true)
        match r.unwrap():
            case BsonValue.Doc(ps):
                match ps[0].1:
                    case BsonValue.Str(s):
                        assert_equal(s, "")
                    case _:
                        assert_equal(false, true)
            case _:
                assert_equal(false, true)
