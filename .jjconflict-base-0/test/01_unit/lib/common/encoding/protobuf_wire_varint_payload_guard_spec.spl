use std.spec.{describe, it, assert_equal}
use std.common.encoding.protobuf_wire.{pb_varint_from_payload}

describe "Protobuf wire varint payload guards":
    it "rejects empty varint payloads":
        assert_equal(pb_varint_from_payload([]), 0)

    it "rejects truncated varint payloads":
        assert_equal(pb_varint_from_payload([128]), 0)

    it "rejects trailing invalid varint payload bytes":
        assert_equal(pb_varint_from_payload([1, 300]), 0)

    it "rejects trailing extra varint payload bytes":
        assert_equal(pb_varint_from_payload([1, 2]), 0)

    it "keeps valid varint payload decoding":
        assert_equal(pb_varint_from_payload([172, 2]), 300)
