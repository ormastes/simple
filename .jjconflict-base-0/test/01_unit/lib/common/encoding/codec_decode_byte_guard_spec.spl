use std.spec.{describe, it, assert_equal}
use std.common.encoding.codec.{decode, transcode, Encoding}

describe "encoding codec byte decode guards":
    it "keeps valid ASCII decode":
        assert_equal(decode([65, 66], Encoding.Ascii), "AB")

    it "rejects malformed ASCII bytes as question marks":
        assert_equal(decode([-1, 300], Encoding.Ascii), "??")

    it "keeps valid Latin-1 decode":
        assert_equal(decode([65], Encoding.Latin1), "A")

    it "rejects malformed Latin-1 bytes as question marks":
        assert_equal(decode([-1, 300], Encoding.Latin1), "??")

    it "uses guarded decode during transcode":
        assert_equal(decode(transcode([-1, 300], Encoding.Latin1, Encoding.Ascii), Encoding.Ascii), "??")
