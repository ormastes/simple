use std.spec.{describe, it, assert_equal}
use std.common.encoding.utf32.{utf32_to_bytes_le, utf32_to_bytes_be, utf32_from_bytes_le, utf32_from_bytes_be}

describe "utf32 byte encoding guards":
    it "keeps valid little-endian serialization":
        assert_equal(utf32_to_bytes_le([0x41]), [0x41, 0x00, 0x00, 0x00])

    it "keeps valid big-endian serialization":
        assert_equal(utf32_to_bytes_be([0x41]), [0x00, 0x00, 0x00, 0x41])

    it "serializes negative scalars as replacement":
        assert_equal(utf32_from_bytes_le(utf32_to_bytes_le([-1])), [0xFFFD])

    it "serializes above-range scalars as replacement":
        assert_equal(utf32_from_bytes_be(utf32_to_bytes_be([0x110000])), [0xFFFD])
