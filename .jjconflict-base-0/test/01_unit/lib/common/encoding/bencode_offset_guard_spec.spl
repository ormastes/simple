use std.spec.{describe, it, assert_equal}
use std.common.encoding.bencode.{bencode_decode_int, bencode_decode_str}

describe "bencode decode offset guards":
    it "rejects negative integer decode offsets":
        val r = bencode_decode_int("i42e", -1)
        assert_equal(r[0], "error")

    it "rejects negative string decode offsets":
        val r = bencode_decode_str("4:spam", -1)
        assert_equal(r[0], "error")

    it "rejects leading zero string lengths":
        val r = bencode_decode_str("04:spam", 0)
        assert_equal(r[0], "error")

    it "rejects oversized integer values before overflow":
        val r = bencode_decode_int("i9223372036854775808e", 0)
        assert_equal(r[0], "error")

    it "rejects oversized string lengths before overflow":
        val r = bencode_decode_str("9223372036854775808:x", 0)
        assert_equal(r[0], "error")

    it "keeps valid positive offsets":
        val i = bencode_decode_int("4:spami42e", 6)
        assert_equal(i[0], "42")
        val s = bencode_decode_str("i42e4:spam", 4)
        assert_equal(s[0], "spam")
