use std.spec.{describe, it, assert_equal}
use std.common.cbor.types.{bytes_to_text}

describe "CBOR bytes to text invalid guard":
    it "fails closed when bytes contain malformed values":
        assert_equal(bytes_to_text([-1]), "")
        assert_equal(bytes_to_text([65, 300]), "")

    it "keeps valid ASCII conversion working":
        assert_equal(bytes_to_text([72, 105]), "Hi")
