extern fn rt_file_read_text(path: text) -> text

fn pure_tensor_source() -> text:
    rt_file_read_text("src/lib/nogc_sync_mut/src/tensor.spl") ?? ""

describe "Tensor Ops":
    it "keeps tensor transpose and permutation operations available":
        val source = pure_tensor_source()

        expect(source).to_contain("fn T(self) -> Tensor<T, N>")
        expect(source).to_contain("fn t(self) -> Tensor<T, N>")
        expect(source).to_contain("fn transpose(self, dim0: i64, dim1: i64) -> Tensor<T, N>")
        expect(source).to_contain("fn permute(self, dims: [i64]) -> Tensor<T, N>")

    it "keeps tensor reduction operation contracts available":
        val source = pure_tensor_source()

        expect(source).to_contain("fn sum(self) -> T")
        expect(source).to_contain("fn mean(self) -> T")
        expect(source).to_contain("fn prod(self) -> T")
        expect(source).to_contain("fn min(self) -> T")
        expect(source).to_contain("fn max(self) -> T")
