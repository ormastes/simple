use std.spec.{describe, it, assert_equal}
use std.common.color.convert.{from_hex}

describe "color hex input guards":
    it "keeps valid shorthand color parsing":
        val c = from_hex("#F0A")
        assert_equal(c.r, 255)
        assert_equal(c.g, 0)
        assert_equal(c.b, 170)

    it "keeps valid full color parsing":
        val c = from_hex("#8040C0")
        assert_equal(c.r, 128)
        assert_equal(c.g, 64)
        assert_equal(c.b, 192)

    it "rejects invalid shorthand characters instead of partial parsing":
        val c = from_hex("#F0G")
        assert_equal(c.r, 0)
        assert_equal(c.g, 0)
        assert_equal(c.b, 0)

    it "rejects invalid full color characters instead of coercing nibbles":
        val c = from_hex("#12Z456")
        assert_equal(c.r, 0)
        assert_equal(c.g, 0)
        assert_equal(c.b, 0)
