use std.gc_async_mut.web.browser_session_loading.{_simple_script_args_are_ints}

describe "browser session simple script args":
    it "rejects count larger than args":
        expect(_simple_script_args_are_ints(["1"], 2)).to_equal(false)

    it "accepts valid numeric args":
        expect(_simple_script_args_are_ints(["1", "-2"], 2)).to_equal(true)
