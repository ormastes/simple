# @cover src/lib/common/ui/layout.spl 80%
# @cover src/lib/common/ui/form_factor.spl 60%
# @req FR-UI-LAYOUT-DPI-SCALE
#
# compute_layout()'s optional `scale_permille` DPI/UI scale factor: identity
# (1000, the default) must leave existing 4-arg call sites unaffected, and a
# non-identity scale must multiply every emitted rect's (x, y, w, h) uniformly
# — the root rect, and every descendant rect that flows from it. Also covers
# FormFactorProfile.scale_permille, which is meant to be fed straight into
# compute_layout by callers that know the device's DPI scale.

use std.spec.{describe, it, expect}
use common.ui.widget.{WidgetNode, WidgetKind}
use common.ui.builder.{column, button}
use common.ui.layout.{compute_layout, find_rect}
use common.ui.form_factor.{compute_form_factor}
use common.ui.viewport.{new_viewport}

# `column()`/`row()` wrap children in a WidgetKind.Panel container, and
# compute_layout gives panels a fixed (unscaled) 1px border on every side —
# so a panel's INNER geometry is never an exact 2x multiple of its 1x inner
# geometry. Build a border-free vbox container directly (any non-"panel"
# kind skips the border trim) so the child-doubling assertions below are
# exact instead of off-by-the-border-constant.
fn _vbox(id: text, child: WidgetNode) -> WidgetNode:
    var node = WidgetNode.new(id, WidgetKind.Card.to_wire())
    node = node.set_layout("vbox")
    node = node.add_child(child)
    node

describe "compute_layout scale_permille":

    it "defaults to identity (1000) when omitted — matches the 4-arg call":
        val root = column("scale_id_root", [button("scale_id_child", "C", "a")])
        val default_rects = compute_layout(WidgetNode(id: "scale_id_root"), 0, 0, 100, 50)
        val explicit_rects = compute_layout(WidgetNode(id: "scale_id_root"), 0, 0, 100, 50, 1000)
        match find_rect(default_rects, "scale_id_root"):
            case Some(a):
                match find_rect(explicit_rects, "scale_id_root"):
                    case Some(b):
                        expect(a.w).to_equal(b.w)
                        expect(a.h).to_equal(b.h)
                    case _: assert_true(false)
            case _: assert_true(false)

    it "scale 2000 (2.0x) doubles the root rect's size and position":
        val root = column("scale2_root", [button("scale2_child", "C", "a")])
        val rects = compute_layout(WidgetNode(id: "scale2_root"), 10, 20, 100, 50, 2000)
        match find_rect(rects, "scale2_root"):
            case Some(r):
                expect(r.x).to_equal(20)
                expect(r.y).to_equal(40)
                expect(r.w).to_equal(200)
                expect(r.h).to_equal(100)
            case _: assert_true(false)

    it "scale 2000 doubles a flex child's computed size vs scale 1000":
        val root_a = _vbox("scale3a_root", button("scale3a_child", "C", "a"))
        val rects_1x = compute_layout(WidgetNode(id: "scale3a_root"), 0, 0, 100, 50, 1000)
        val root_b = _vbox("scale3b_root", button("scale3b_child", "C", "a"))
        val rects_2x = compute_layout(WidgetNode(id: "scale3b_root"), 0, 0, 100, 50, 2000)
        match find_rect(rects_1x, "scale3a_child"):
            case Some(c1x):
                match find_rect(rects_2x, "scale3b_child"):
                    case Some(c2x):
                        expect(c2x.w).to_equal(c1x.w * 2)
                        expect(c2x.h).to_equal(c1x.h * 2)
                    case _: assert_true(false)
            case _: assert_true(false)

describe "FormFactorProfile.scale_permille":

    it "defaults to 1000 (identity) when compute_form_factor is called without it":
        val vp = new_viewport(1440, 900, "gui")
        val ff = compute_form_factor(vp, "macos", false)
        expect(ff.scale_permille).to_equal(1000)

    it "carries an explicit scale_permille through to the profile":
        val vp = new_viewport(1440, 900, "gui")
        val ff = compute_form_factor(vp, "macos", false, 1500)
        expect(ff.scale_permille).to_equal(1500)
