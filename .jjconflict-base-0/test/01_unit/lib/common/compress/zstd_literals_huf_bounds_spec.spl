use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.zstd_huf.{ZstdHufDecodeEntry}
use std.common.compress.zstd_literals.{zstd_huf_decode_stream_for_test, zstd_parse_direct_huffman_weights_for_test, zstd_parse_fse_huffman_weights, zstd_parse_literals_section_for_test, _zstd_decode_huffman_4streams}
use std.common.compress.zstd_types.{ZstdHufTableState, ZstdLiteralsSection}

fn expect_corrupt(result: Result<[u8], CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.CorruptStream(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_weight_truncated(result: Result<([i64], i64), CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_section_truncated(result: Result<(ZstdLiteralsSection, ZstdHufTableState?), CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

describe "Zstd Huffman literal stream bounds validation":
    it "rejects negative literal section offsets before indexing":
        expect_section_truncated(zstd_parse_literals_section_for_test([0x00u8], -1, 1, nil), "literals header")

    it "rejects literal section ends beyond the backing input before payload reads":
        expect_section_truncated(zstd_parse_literals_section_for_test([0x08u8], 0, 4, nil), "literals header")

    it "rejects negative FSE weight offsets before indexing":
        expect_weight_truncated(zstd_parse_fse_huffman_weights([0x01u8], -1, 1), "tree header")

    it "rejects FSE weight payload ends beyond the backing input before indexing":
        expect_weight_truncated(zstd_parse_fse_huffman_weights([0x01u8], 0, 2), "tree header")

    it "rejects negative direct weight offsets before indexing":
        expect_weight_truncated(zstd_parse_direct_huffman_weights_for_test([0x80u8], -1, 1), "tree header")

    it "rejects direct weight payload ends beyond the backing input before indexing":
        expect_weight_truncated(zstd_parse_direct_huffman_weights_for_test([0x80u8], 0, 2), "tree header")

    it "rejects negative regenerated sizes before decoding":
        val table = ZstdHufTableState(
            table_bits: 1,
            table: [
                ZstdHufDecodeEntry(symbol: 0, bits: 1),
                ZstdHufDecodeEntry(symbol: 1, bits: 1)
            ]
        )
        expect_corrupt(zstd_huf_decode_stream_for_test([0x02u8], 0, 1, -1, table), "regenerated size")

    it "rejects negative 4-stream regenerated sizes before jump-table math":
        val table = ZstdHufTableState(
            table_bits: 1,
            table: [
                ZstdHufDecodeEntry(symbol: 0, bits: 1),
                ZstdHufDecodeEntry(symbol: 1, bits: 1)
            ]
        )
        expect_corrupt(_zstd_decode_huffman_4streams([0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8], 0, 6, -1, table), "regenerated size")

    it "rejects 4-stream ends beyond the backing input before jump-table math":
        val table = ZstdHufTableState(
            table_bits: 1,
            table: [
                ZstdHufDecodeEntry(symbol: 0, bits: 1),
                ZstdHufDecodeEntry(symbol: 1, bits: 1)
            ]
        )
        expect_corrupt(_zstd_decode_huffman_4streams([0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8], 0, 7, 1, table), "4-stream range")

    it "rejects malformed Huffman table widths before peeking":
        val table = ZstdHufTableState(
            table_bits: 12,
            table: [ZstdHufDecodeEntry(symbol: 0, bits: 1)]
        )
        expect_corrupt(zstd_huf_decode_stream_for_test([0x02u8], 0, 1, 1, table), "table width")

    it "rejects too-short Huffman decode tables before indexing":
        val table = ZstdHufTableState(
            table_bits: 1,
            table: [ZstdHufDecodeEntry(symbol: 0, bits: 1)]
        )
        expect_corrupt(zstd_huf_decode_stream_for_test([0x03u8], 0, 1, 1, table), "table size")

    it "rejects entries that consume more bits than the table width":
        val table = ZstdHufTableState(
            table_bits: 1,
            table: [
                ZstdHufDecodeEntry(symbol: 0, bits: 1),
                ZstdHufDecodeEntry(symbol: 1, bits: 2)
            ]
        )
        expect_corrupt(zstd_huf_decode_stream_for_test([0x03u8], 0, 1, 1, table), "decode entry")
