use std.spec.{describe, it, expect}
use std.common.compress.zstd.{_zstd_read_le32}

describe "Zstd facade bounds validation":
    it "rejects negative little-endian offsets before indexing":
        val decoded = _zstd_read_le32([0x01u8, 0x02u8, 0x03u8, 0x04u8], -1)
        expect(decoded).to_equal(0)
