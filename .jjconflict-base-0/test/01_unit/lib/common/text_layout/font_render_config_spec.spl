use std.spec.{describe, it, expect}
use std.nogc_sync_mut.text_layout.font_types.{
    FontExecutionPolicy, FontGlyphRun, FontRenderConfig, font_execution_plan,
    font_render_config_identity, font_render_config_valid
}
use std.nogc_sync_mut.text_layout.font_renderer.{
    FontRenderer, _resolved_font_metric_language_config_key,
    font_render_config_selection_supported
}
use std.common.ui.draw_ir.{draw_ir_empty_glyph_run_payload}

fn _config(target: text, policy: FontExecutionPolicy) -> FontRenderConfig:
    FontRenderConfig(
        family: "Noto Sans Devanagari", category: "sans", language: "hi", script: "Deva", size: 24,
        weight: "normal", style: "normal", hinting: "none", antialiasing: "grayscale",
        atlas_policy: "shared-alpha-1024", execution_target: target, execution_policy: policy
    )

describe "shared font runtime configuration":
    it "builds one length-delimited identity from every configured field":
        val config = _config("CUDA", FontExecutionPolicy.Suggested)
        expect(font_render_config_valid(config)).to_be(true)
        expect(font_render_config_selection_supported(config)).to_be(true)
        expect(font_render_config_identity(config)).to_contain("family=20:noto sans devanagari")
        expect(font_render_config_identity(config)).to_contain("language=2:hi")
        expect(font_render_config_identity(config)).to_contain("script=4:deva")
        expect(font_render_config_identity(config)).to_contain("target=4:cuda|policy=suggested")
        val pixel = FontRenderConfig(
            family: "auto", category: "pixel/bitmap", language: "en", script: "latn", size: 16,
            weight: "normal", style: "normal", hinting: "none", antialiasing: "grayscale",
            atlas_policy: "shared-alpha-1024", execution_target: "cpu",
            execution_policy: FontExecutionPolicy.Required
        )
        expect(font_render_config_valid(pixel)).to_be(true)
        expect(font_render_config_selection_supported(pixel)).to_be(true)
        expect(font_render_config_identity(pixel)).to_contain("category=5:pixel")
        val cpu = _config("cpu", FontExecutionPolicy.Required)
        expect(_resolved_font_metric_language_config_key(
            "Noto Sans Devanagari", "A", 24, "sha256=test", "hi", font_render_config_identity(config)
        ) == _resolved_font_metric_language_config_key(
            "Noto Sans Devanagari", "A", 24, "sha256=test", "hi", font_render_config_identity(cpu)
        )).to_be(false)

    it "orders suggested preferred and required attempts exactly":
        val order = ["cuda", "metal", "rocm", "opencl", "vulkan", "cpu"]
        expect(font_execution_plan(_config("auto", FontExecutionPolicy.Suggested), order)).to_equal(order)
        expect(font_execution_plan(_config("vulkan", FontExecutionPolicy.Suggested), order)).to_equal(
            ["vulkan", "cuda", "metal", "rocm", "opencl", "cpu"]
        )
        expect(font_execution_plan(_config("metal", FontExecutionPolicy.Preferred), order)).to_equal(["metal", "cpu"])
        expect(font_execution_plan(_config("hip", FontExecutionPolicy.Suggested), order)).to_equal(
            ["rocm", "cuda", "metal", "opencl", "vulkan", "cpu"]
        )
        expect(font_execution_plan(_config("rocm", FontExecutionPolicy.Preferred), order)).to_equal(["rocm", "cpu"])
        expect(font_execution_plan(_config("HIP", FontExecutionPolicy.Required), order)).to_equal(["rocm"])
        expect(font_execution_plan(_config("opencl", FontExecutionPolicy.Required), order)).to_equal(["opencl"])
        expect(font_execution_plan(_config("cpu", FontExecutionPolicy.Preferred), order)).to_equal(["cpu"])

    it "canonicalizes the HIP alias to the ROCm execution identity":
        val rocm = _config("rocm", FontExecutionPolicy.Required)
        val hip = _config("HIP", FontExecutionPolicy.Required)
        expect(font_render_config_valid(rocm)).to_be(true)
        expect(font_render_config_valid(hip)).to_be(true)
        expect(font_render_config_identity(hip)).to_equal(font_render_config_identity(rocm))
        expect(font_render_config_identity(hip)).to_contain("target=4:rocm|policy=required")

    it "rejects invalid policy targets and rendering modes":
        val order = ["vulkan", "cpu"]
        expect(font_execution_plan(_config("auto", FontExecutionPolicy.Preferred), order).len()).to_equal(0)
        expect(font_execution_plan(_config("cuda", FontExecutionPolicy.Suggested), order).len()).to_equal(0)
        expect(font_execution_plan(_config("unknown", FontExecutionPolicy.Required), order).len()).to_equal(0)
        val unsupported = FontRenderConfig(
            family: "auto", category: "sans", language: "und", script: "auto", size: 24,
            weight: "bold", style: "normal", hinting: "none", antialiasing: "grayscale",
            atlas_policy: "shared-alpha-1024", execution_target: "cpu",
            execution_policy: FontExecutionPolicy.Required
        )
        expect(font_render_config_valid(unsupported)).to_be(false)
        expect(font_execution_plan(unsupported, order).len()).to_equal(0)

    it "stamps all configured material paths and keeps invalid calls immutable":
        var renderer = FontRenderer.new()
        val config = _config("cpu", FontExecutionPolicy.Required)
        val text_batch = renderer.prepare_text_configured("A", 0xffffffffu32, config)
        expect(text_batch.valid).to_be(true)
        expect(text_batch.render_config_identity).to_equal(font_render_config_identity(config))
        expect(text_batch.execution_target).to_equal("cpu")
        expect(text_batch.execution_policy).to_equal(FontExecutionPolicy.Required)
        val advanced = renderer.prepare_text_with_advances_configured("A", [12], 0xffffffffu32, config)
        expect(advanced.render_config_identity).to_equal(font_render_config_identity(config))
        val selected = renderer.prepare_selected_glyph_run_configured(
            draw_ir_empty_glyph_run_payload(), 0xffffffffu32, config
        )
        expect(selected.render_config_identity).to_equal(font_render_config_identity(config))
        val run = FontGlyphRun(valid: false, face_id: 0, face_generation: 0,
            glyph_ids: [], xs: [], ys: [], clusters: [])
        val shaped = renderer.prepare_glyph_run_configured(run, 0xffffffffu32, config)
        expect(shaped.render_config_identity).to_equal(font_render_config_identity(config))
        val before = renderer.cache_stats()
        val invalid = _config("auto", FontExecutionPolicy.Required)
        expect(renderer.prepare_text_configured("B", 0xffffffffu32, invalid).valid).to_be(false)
        val after = renderer.cache_stats()
        expect(after.entries).to_equal(before.entries)
        expect(after.bytes).to_equal(before.bytes)
        expect(after.generation).to_equal(before.generation)
        expect(after.hits).to_equal(before.hits)
        expect(after.misses).to_equal(before.misses)
        expect(after.rasterizations).to_equal(before.rasterizations)
        expect(after.evictions).to_equal(before.evictions)
        expect(after.render_config_identity).to_equal(before.render_config_identity)
        val unavailable = FontRenderConfig(
            family: "auto", category: "blackletter", language: "hi", script: "deva", size: 24,
            weight: "normal", style: "normal", hinting: "none", antialiasing: "grayscale",
            atlas_policy: "shared-alpha-1024", execution_target: "cpu",
            execution_policy: FontExecutionPolicy.Required
        )
        val unavailable_before = renderer.cache_stats()
        expect(font_render_config_selection_supported(unavailable)).to_be(false)
        expect(renderer.prepare_text_configured("A", 0xffffffffu32, unavailable).valid).to_be(false)
        val unavailable_after = renderer.cache_stats()
        expect(unavailable_after.entries).to_equal(unavailable_before.entries)
        expect(unavailable_after.hits).to_equal(unavailable_before.hits)
        expect(unavailable_after.misses).to_equal(unavailable_before.misses)
        expect(unavailable_after.render_config_identity).to_equal(unavailable_before.render_config_identity)
