use std.spec
use lib.gc_async_mut.io.string_helpers.{hex_to_char as gc_hex_to_char}
use lib.nogc_async_mut.io.string_helpers.{hex_to_char as nogc_hex_to_char}

describe "async io string helpers":
    it "convert ASCII codes without char casts":
        expect(gc_hex_to_char(65)).to_equal("A")
        expect(nogc_hex_to_char(90)).to_equal("Z")
