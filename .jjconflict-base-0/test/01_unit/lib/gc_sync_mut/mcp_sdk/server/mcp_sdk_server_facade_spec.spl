use std.spec
use std.gc_sync_mut.mcp_sdk.server.{server_config as package_server_config, parse_cursor as package_parse_cursor, dispatch_method as package_dispatch_method, state_reset as package_state_reset}
use std.gc_sync_mut.mcp_sdk.server.builder.{ServerConfig, server_config, server_add_tool_json, server_build_tools_list, server_tool_count}
use std.gc_sync_mut.mcp_sdk.server.pagination.{parse_cursor, make_cursor, paginate_items, paginate_tools_response}
use std.gc_sync_mut.mcp_sdk.server.method_detect.{has_method, detect_method}
use std.gc_sync_mut.mcp_sdk.server.router.{dispatch_method, handle_method, router_clear_caches}
use std.gc_sync_mut.mcp_sdk.server.state.{state_reset, state_register_progress, state_has_progress, state_remove_progress, state_cancel_request, state_is_cancelled, state_clear_cancelled, state_subscribe, state_is_subscribed, state_unsubscribe, state_set_log_level, state_get_log_level, state_should_emit_log, log_level_to_int, state_next_request_id, make_progress_notification}

describe "gc_sync_mut mcp sdk server facade":

    it "re-exports builder, pagination, method detection, and router helpers":
        var cfg = package_server_config("simple", "1.0")
        expect(cfg.info.name).to_equal("simple")
        cfg = server_add_tool_json(cfg, "ping", "{\"name\":\"ping\"}")
        expect(server_tool_count(cfg)).to_equal(1)
        expect(server_build_tools_list(cfg)).to_contain("\"ping\"")

        expect(package_parse_cursor("offset:5")).to_equal(5)
        expect(make_cursor(10)).to_equal("offset:10")
        expect(paginate_items(["\"a\"", "\"b\""], "", 1)).to_contain("nextCursor")
        expect(paginate_tools_response("1", ["{\"name\":\"a\"}"], "", 10)).to_contain("\"tools\"")

        val msg = "{\"jsonrpc\":\"2.0\",\"method\":\"tools/list\",\"id\":1}"
        expect(has_method(msg, "tools/list")).to_equal(true)
        expect(detect_method(msg, ["initialize", "tools/list"])).to_equal("tools/list")
        router_clear_caches()
        expect(package_dispatch_method(cfg, "tools/call", "1")).to_equal("DISPATCH_TOOL")
        expect(handle_method(cfg, "resources/read", "1", "{}")).to_equal("RESOURCES_READ")

    it "re-exports protocol state helpers":
        package_state_reset()
        state_register_progress("tok", "req")
        expect(state_has_progress("tok")).to_equal(true)
        state_remove_progress("tok")
        expect(state_has_progress("tok")).to_equal(false)

        state_cancel_request("req", "stop")
        expect(state_is_cancelled("req")).to_equal(true)
        state_clear_cancelled("req")
        expect(state_is_cancelled("req")).to_equal(false)

        state_subscribe("file://a")
        expect(state_is_subscribed("file://a")).to_equal(true)
        state_unsubscribe("file://a")
        expect(state_is_subscribed("file://a")).to_equal(false)

        state_set_log_level(log_level_to_int("warning"))
        expect(state_get_log_level()).to_equal(3)
        expect(state_should_emit_log(4)).to_equal(true)
        expect(state_next_request_id()).to_equal("srv-1")
        expect(make_progress_notification("tok", 1, 2, "half")).to_contain("notifications/progress")
