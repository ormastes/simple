use std.spec.{describe, it, assert_equal}
use std.http.h3.h3_frame.{H3VarintResult, H3FrameResult, h3_varint_decode, h3_frame_parse, h3_frame_emit, H3_FRAME_DATA}

fn _is_varint_err(result: H3VarintResult) -> bool:
    match result:
        case Err(_):
            true
        case _:
            false

fn _is_frame_err(result: H3FrameResult) -> bool:
    match result:
        case Err(_):
            true
        case _:
            false

describe "HTTP/3 parser negative offset guard":
    it "rejects negative varint offsets":
        assert_equal(_is_varint_err(h3_varint_decode([0u8], -1)), true)

    it "rejects negative frame offsets":
        val frame = h3_frame_emit(H3_FRAME_DATA, [1u8, 2u8])
        assert_equal(_is_frame_err(h3_frame_parse(frame, -1)), true)
