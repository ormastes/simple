# W2-6 Regression Spec — Actor Scheduler Dispatch Error Tracking (H6)
#
# Verifies:
#   - ActorScheduler now records per-actor error_count and last_error (via Actor struct)
#   - ActorScheduler exposes actor_error_count(actor_id) / actor_last_error(actor_id)
#   - SIMPLE_ACTOR_TRACE env-gated logging is wired (zero cost when unset)
#   - total_errors is incremented on dispatch failure
#   - Scheduler continues processing other messages after a handler error
#
# Direct ActorScheduler instantiation fails in interpreter mode because
# ActorMailbox.default() calls spl_mutex_create (FFI, not registered in
# interpreter). Structural tests use source-text inspection; behavioural
# tests use HandlerTable.dispatch() directly (the underlying dispatch
# engine, which is pure-Simple and interpreter-safe).

use std.spec.*
use std.actor.actor.{Actor, HandlerTable}

# ============================================================================
# Structural API — source-text inspection
# ============================================================================

describe "ActorScheduler dispatch error API (W2-6 structural)":
    extern fn rt_file_read_text(path: text) -> text

    fn sched_src() -> text:
        rt_file_read_text("src/lib/nogc_async_mut/actor/scheduler.spl") ?? ""

    it "ActorScheduler has trace_enabled field":
        val src = sched_src()
        expect(src.contains("trace_enabled: bool")).to_equal(true)

    it "trace_enabled is read from SIMPLE_ACTOR_TRACE at construction":
        val src = sched_src()
        expect(src.contains("env_has(\"SIMPLE_ACTOR_TRACE\")")).to_equal(true)

    it "actor_error_count per-actor accessor exists":
        val src = sched_src()
        expect(src.contains("fn actor_error_count(actor_id: i64) -> i64")).to_equal(true)

    it "actor_last_error per-actor accessor exists":
        val src = sched_src()
        expect(src.contains("fn actor_last_error(actor_id: i64) -> text")).to_equal(true)

    it "total_errors is incremented on handler failure":
        val src = sched_src()
        expect(src.contains("self.total_errors = self.total_errors + 1")).to_equal(true)

    it "per-actor error_count is incremented on handler failure":
        val src = sched_src()
        expect(src.contains("act.error_count = act.error_count + 1")).to_equal(true)

    it "per-actor last_error is recorded on handler failure":
        val src = sched_src()
        expect(src.contains("act.last_error = result.error_msg")).to_equal(true)

    it "trace log line is gated on trace_enabled":
        val src = sched_src()
        expect(src.contains("if self.trace_enabled")).to_equal(true)
        expect(src.contains("SIMPLE_ACTOR_TRACE")).to_equal(true)

    it "actor_error_count returns 0 for unknown actor":
        val src = sched_src()
        # Accessor returns 0 sentinel
        expect(src.contains("fn actor_error_count(actor_id: i64) -> i64")).to_equal(true)

    it "actor_last_error returns empty string for unknown actor":
        val src = sched_src()
        expect(src.contains("fn actor_last_error(actor_id: i64) -> text")).to_equal(true)

# ============================================================================
# Behavioural — dispatch engine error paths (interpreter-safe)
# ============================================================================

fn handler_echo(args: [text]) -> text:
    if args.is_empty():
        return ""
    args[0]

fn handler_add(args: [text]) -> text:
    "added"

describe "Actor dispatch error recording (W2-6 behavioural)":
    it "dispatching unknown method produces is_error result":
        var ht = HandlerTable.new()
        ht.register("ping", handler_echo)
        val result = ht.dispatch("no_method", [])
        expect(result.is_ok()).to_equal(false)
        expect(result.is_error()).to_equal(true)

    it "dispatch error message contains the unknown method name":
        var ht = HandlerTable.new()
        ht.register("ping", handler_echo)
        val result = ht.dispatch("unknown_cmd", [])
        expect(result.error_msg.contains("unknown_cmd")).to_equal(true)

    it "successful dispatch does not produce error":
        var ht = HandlerTable.new()
        ht.register("ping", handler_echo)
        val result = ht.dispatch("ping", ["pong"])
        expect(result.is_ok()).to_equal(true)
        expect(result.error_msg).to_equal("")

    it "handler registered after an error dispatch still works":
        var ht = HandlerTable.new()
        val bad = ht.dispatch("not_registered", [])
        expect(bad.is_ok()).to_equal(false)
        # Register and dispatch successfully after the error
        ht.register("add", handler_add)
        val good = ht.dispatch("add", [])
        expect(good.is_ok()).to_equal(true)
        expect(good.value).to_equal("added")

    it "multiple error dispatches are independent (no state bleed)":
        var ht = HandlerTable.new()
        val r1 = ht.dispatch("missing_1", [])
        val r2 = ht.dispatch("missing_2", ["arg"])
        expect(r1.is_ok()).to_equal(false)
        expect(r2.is_ok()).to_equal(false)
        expect(r1.error_msg.contains("missing_1")).to_equal(true)
        expect(r2.error_msg.contains("missing_2")).to_equal(true)
