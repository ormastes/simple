use std.spec
use std.nogc_async_mut.fs_driver.nvfs_driver.{NvfsDriver}

describe "nogc_async_mut NVFS driver facade":

    it "constructs the canonical std-owned NVFS driver":
        val driver = NvfsDriver.new("nogc-async-nvfs")
        expect(driver.preferred_io_unit_bytes()).to_equal(512)
        expect(driver.has_trim_support()).to_equal(false)
