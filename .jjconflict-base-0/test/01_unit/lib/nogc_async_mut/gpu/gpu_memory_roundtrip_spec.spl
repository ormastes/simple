# GpuArray CPU-fallback round-trip spec.
#
# CI host has no GPU; exercises the None_ backend host_buf store that gives
# upload/download round-trip parity with the CUDA path, so CPU-base code
# migrates to GPU backends without behavioral change.

use std.nogc_async_mut.gpu.memory.{GpuArray, gpu_alloc, gpu_alloc_upload, gpu_alloc_zeros, gpu_copy, gpu_free}
use std.nogc_async_mut.gpu.device.{gpu_none}

describe "GpuArray CPU fallback round-trip":

    it "upload then download round-trips data on None_ backend":
        val g = gpu_none()
        var data: [f32] = []
        data.push(1.5)
        data.push(2.5)
        data.push(-3.0)
        var arr = gpu_alloc_upload(g, data)
        val out = arr.download()
        expect(out.len()).to_equal(3)
        val first_ok = out[0] == 1.5
        expect(first_ok).to_equal(true)
        val last_ok = out[2] == -3.0
        expect(last_ok).to_equal(true)

    it "gpu_alloc yields count zeros on None_ backend":
        val g = gpu_none()
        var data: [f32] = []
        data.push(0.0)
        data.push(0.0)
        data.push(0.0)
        data.push(0.0)
        var arr = gpu_alloc_upload(g, data)
        var fresh = gpu_alloc_zeros(g, 4)
        val out = fresh.download()
        expect(out.len()).to_equal(4)
        val zero_ok = out[0] == 0.0 and out[3] == 0.0
        expect(zero_ok).to_equal(true)

    it "upload rejects size mismatch":
        val g = gpu_none()
        var data: [f32] = []
        data.push(1.0)
        data.push(2.0)
        var arr = gpu_alloc_upload(g, data)
        var wrong: [f32] = []
        wrong.push(9.0)
        val ok = arr.upload(wrong)
        expect(ok).to_equal(false)

    it "copy preserves host data on None_ backend":
        val g = gpu_none()
        var data: [f32] = []
        data.push(7.0)
        var arr = gpu_alloc_upload(g, data)
        var dup = gpu_copy(arr)
        val out = dup.download()
        expect(out.len()).to_equal(1)
        val val_ok = out[0] == 7.0
        expect(val_ok).to_equal(true)

    it "copy_to transfers host data between None_ arrays":
        val g = gpu_none()
        var src_data: [f32] = []
        src_data.push(4.0)
        src_data.push(5.0)
        var src = gpu_alloc_upload(g, src_data)
        var dst = gpu_alloc_zeros(g, 2)
        val ok = src.copy_to(dst)
        expect(ok).to_equal(true)
        val out = dst.download()
        expect(out.len()).to_equal(2)
        val moved_ok = out[1] == 5.0
        expect(moved_ok).to_equal(true)

    it "free clears host data and is idempotent":
        val g = gpu_none()
        var data: [f32] = []
        data.push(1.0)
        var arr = gpu_alloc_upload(g, data)
        arr.free()
        arr.free()
        val out = arr.download()
        expect(out.len()).to_equal(0)
