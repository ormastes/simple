use std.nogc_async_mut.ndarray.{array, array_bool, array_i64, Axis, Float32, Float64, Index, Int64, Shape, Slice}

describe "NDArray view bounds hardening":
    it "keeps the original array for invalid public reshape":
        val values = array([1.0, 2.0, 3.0])
        val reshaped = values.reshape(Shape.new([Index.new(2), Index.new(2)]))
        expect(reshaped.shape).to_equal(values.shape)
        expect(reshaped.len().value).to_equal(3)

    it "keeps the original array for invalid public transpose axes":
        val values = array([1.0, 2.0])
        val transposed = values.transpose_axes(Axis.new(0), Axis.new(1))
        expect(transposed.shape).to_equal(values.shape)
        expect(transposed.len().value).to_equal(2)

    it "keeps the original array for invalid public slice":
        val values = array([1.0, 2.0, 3.0])
        val sliced = values.slice(Slice.new(Index.new(0), Index.new(3), Index.new(0)))
        expect(sliced.shape).to_equal(values.shape)
        expect(sliced.len().value).to_equal(3)

    it "keeps the original array for invalid public 2D slice":
        val values = array([1.0, 2.0, 3.0])
        val one_d = values.slice_2d(
            Slice.new(Index.new(0), Index.new(1), Index.new(1)),
            Slice.new(Index.new(0), Index.new(1), Index.new(1))
        )
        expect(one_d.shape).to_equal(values.shape)
        val matrix = array([1.0, 2.0, 3.0, 4.0]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val bad_step = matrix.slice_2d(
            Slice.new(Index.new(0), Index.new(2), Index.new(0)),
            Slice.new(Index.new(0), Index.new(2), Index.new(1))
        )
        expect(bad_step.shape).to_equal(matrix.shape)

    it "keeps the original array for invalid public gather":
        val values = array([1.0, 2.0, 3.0])
        val gathered = values.gather(array_i64([Int64.new(0), Int64.new(9)]))
        expect(gathered.shape).to_equal(values.shape)
        expect(gathered.len().value).to_equal(3)

    it "keeps the original array for invalid public mask":
        val values = array([1.0, 2.0, 3.0])
        val masked = values.mask(array_bool([true, false]))
        expect(masked.shape).to_equal(values.shape)
        expect(masked.len().value).to_equal(3)

    it "keeps the original array for invalid public sort operations":
        val values = array_bool([true, false])
        val sorted = values.sort()
        expect(sorted.shape).to_equal(values.shape)
        val argsorted = values.argsort()
        expect(argsorted.shape).to_equal(values.shape)

    it "keeps the original array for invalid public binary operations":
        val values = array([1.0, 2.0, 3.0])
        val other = array([10.0, 20.0])
        expect(values.add(other).shape).to_equal(values.shape)
        expect(values.sub(other).shape).to_equal(values.shape)
        expect(values.mul(other).shape).to_equal(values.shape)
        expect(values.div(other).shape).to_equal(values.shape)

    it "keeps the original array for invalid public Float32 scalar operations":
        val values = array_i64([Int64.new(1), Int64.new(2)])
        expect(values.add_scalar_f32(Float32.new(1.0)).shape).to_equal(values.shape)
        expect(values.sub_scalar_f32(Float32.new(1.0)).shape).to_equal(values.shape)
        expect(values.mul_scalar_f32(Float32.new(1.0)).shape).to_equal(values.shape)
        expect(values.div_scalar_f32(Float32.new(1.0)).shape).to_equal(values.shape)

    it "keeps the original array for invalid public Float64 scalar operations":
        val values = array_i64([Int64.new(1), Int64.new(2)])
        expect(values.add_scalar(Float64.new(1.0)).shape).to_equal(values.shape)
        expect(values.sub_scalar(Float64.new(1.0)).shape).to_equal(values.shape)
        expect(values.mul_scalar(Float64.new(1.0)).shape).to_equal(values.shape)
        expect(values.div_scalar(Float64.new(1.0)).shape).to_equal(values.shape)

    it "keeps the original array for invalid public unary operations":
        val values = array_i64([Int64.new(1), Int64.new(-2)])
        expect(values.abs().shape).to_equal(values.shape)
        expect(values.abs_f32().shape).to_equal(values.shape)
        expect(values.square().shape).to_equal(values.shape)
        expect(values.square_f32().shape).to_equal(values.shape)
        expect(values.neg().shape).to_equal(values.shape)
        expect(values.neg_f32().shape).to_equal(values.shape)
        expect(values.sqrt().shape).to_equal(values.shape)
        expect(values.relu().shape).to_equal(values.shape)
        expect(values.clip(Float64.new(0.0), Float64.new(1.0)).shape).to_equal(values.shape)

    it "returns nil for invalid public get":
        val values = array([1.0, 2.0, 3.0])
        expect(values.get(Index.new(9))).to_be_nil()
        expect(values.get_at([Index.new(9)])).to_be_nil()

    it "returns zero for invalid public Float64 get":
        val values = array([1.0, 2.0, 3.0])
        val ints = array_i64([Int64.new(1), Int64.new(2)])
        expect(values.get_f64(Index.new(9))).to_equal(Float64.new(0.0))
        expect(values.get_f64_at([Index.new(9)])).to_equal(Float64.new(0.0))
        expect(ints.get_f64(Index.new(0))).to_equal(Float64.new(0.0))

    it "returns zero for invalid public Float64 flat get":
        val matrix = array([1.0, 2.0, 3.0, 4.0]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val ints = array_i64([Int64.new(1), Int64.new(2)])
        expect(matrix.flat_f64(9)).to_equal(Float64.new(0.0))
        expect(matrix.flat_f64(-1)).to_equal(Float64.new(0.0))
        expect(ints.flat_f64(0)).to_equal(Float64.new(0.0))

    it "returns zero for invalid public Float32 get":
        val values = array_f32([Float32.new(1.0), Float32.new(2.0)])
        val ints = array_i64([Int64.new(1), Int64.new(2)])
        expect(values.get_f32(Index.new(9))).to_equal(Float32.new(0.0))
        expect(values.get_f32_at([Index.new(9)])).to_equal(Float32.new(0.0))
        expect(ints.get_f32(Index.new(0))).to_equal(Float32.new(0.0))

    it "returns zero for invalid public Float32 flat get":
        val matrix = array_f32([Float32.new(1.0), Float32.new(2.0), Float32.new(3.0), Float32.new(4.0)]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val ints = array_i64([Int64.new(1), Int64.new(2)])
        expect(matrix.flat_f32(9)).to_equal(Float32.new(0.0))
        expect(matrix.flat_f32(-1)).to_equal(Float32.new(0.0))
        expect(ints.flat_f32(0)).to_equal(Float32.new(0.0))

    it "returns zero for invalid public Int64 get":
        val values = array_i64([Int64.new(1), Int64.new(2)])
        val floats = array([1.0, 2.0])
        expect(values.get_i64_at([Index.new(9)])).to_equal(Int64.new(0))
        expect(floats.get_i64_at([Index.new(0)])).to_equal(Int64.new(0))

    it "returns zero for invalid public Int64 flat get":
        val matrix = array_i64([Int64.new(1), Int64.new(2), Int64.new(3), Int64.new(4)]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val floats = array([1.0, 2.0])
        expect(matrix.flat_i64(9)).to_equal(Int64.new(0))
        expect(matrix.flat_i64(-1)).to_equal(Int64.new(0))
        expect(floats.flat_i64(0)).to_equal(Int64.new(0))

    it "returns false for invalid public Bool get":
        val values = array_bool([true, false])
        val floats = array([1.0, 2.0])
        expect(values.get_bool_at([Index.new(9)])).to_equal(false)
        expect(floats.get_bool_at([Index.new(0)])).to_equal(false)

    it "returns false for invalid public Bool flat get":
        val matrix = array_bool([true, false, true, false]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val floats = array([1.0, 2.0])
        expect(matrix.flat_bool(9)).to_equal(false)
        expect(matrix.flat_bool(-1)).to_equal(false)
        expect(floats.flat_bool(0)).to_equal(false)

    it "returns empty row for out-of-range row index":
        val matrix = array([1.0, 2.0, 3.0, 4.0]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val row = matrix.row(Index.new(9))
        expect(row.len().value).to_equal(0)
        expect(row.to_f64_values().len()).to_equal(0)

    it "returns empty column for out-of-range column index":
        val matrix = array([1.0, 2.0, 3.0, 4.0]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val col = matrix.column(Index.new(9))
        expect(col.len().value).to_equal(0)
        expect(col.to_f64_values().len()).to_equal(0)
