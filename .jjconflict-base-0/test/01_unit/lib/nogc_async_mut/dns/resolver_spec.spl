use std.spec
use std.nogc_async_mut.dns.resolver.{dns_response_bytes_to_text}

describe "async dns resolver byte conversion":
    it "decodes dns response text without text.from_bytes":
        val decoded = dns_response_bytes_to_text([68u8, 78u8, 83u8, 45u8, 77u8, 69u8, 83u8, 83u8, 65u8, 71u8, 69u8, 58u8, 10u8, 13u8, 9u8, 255u8])
        expect(decoded).to_equal("DNS-MESSAGE:\n\r\t?")
