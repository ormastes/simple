extern fn rt_file_read_text(path: text) -> text

fn _contains_quic_packet_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("pub fn quic_varint_decode(data: [u8], offset: i64) -> QuicVarintResult:") and
        source.to_contain("if offset < 0:\n        return QuicVarintResult.Err(\"varint: negative offset\")") and
        source.to_contain("fn _read_conn_id(data: [u8], offset: i64) -> ([u8], i64):") and
        source.to_contain("if offset < 0:\n        return ([], 0)") and
        source.to_contain("val first = data[offset]") and
        source.to_contain("val id_len = data[offset]")

describe "QUIC packet negative offset guards":
    it "guards varint and connection-id readers before indexed reads":
        expect(_contains_quic_packet_negative_guards("src/lib/nogc_async_mut/io/quic/quic_packet.spl")).to_equal(true)
