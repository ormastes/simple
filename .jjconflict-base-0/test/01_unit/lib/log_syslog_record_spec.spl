"""
Lane L observability Phase 1 — structured syslog record (RFC5424-ish).

std.log gains a SyslogRecord (ts_nanos, level, facility, pid, subsys, msg,
kv fields) with a formatter (syslog_format) and a parser (syslog_parse).
The wire format positionally mirrors RFC5424 (PRI/VERSION, TIMESTAMP,
HOSTNAME, APP-NAME, PROCID, MSGID, STRUCTURED-DATA, MSG) but is simplified:
TIMESTAMP carries raw ts_nanos, APP-NAME carries the subsys id, and
STRUCTURED-DATA uses comma (not space) separators so the record stays
parseable by repeated single-space partitioning.

Gate: format(record) then parse(that text) round-trips every field.
"""

use std.spec
use std.log.{
    SyslogRecord, SyslogKv, syslog_format, syslog_parse, syslog_record_with_kv,
    LOG_ERROR, LOG_WARN, SUBSYS_NET, SUBSYS_KERN
}

describe "syslog record — format/parse round trip":

    it "round-trips a record with no kv fields":
        val rec = SyslogRecord.new(LOG_ERROR, 3, 4242, SUBSYS_NET, "link down")
        val line = syslog_format(rec)
        val parsed = syslog_parse(line)

        expect(parsed.ts_nanos).to_equal(rec.ts_nanos)
        expect(parsed.level).to_equal(LOG_ERROR)
        expect(parsed.facility).to_equal(3)
        expect(parsed.pid).to_equal(4242)
        expect(parsed.subsys).to_equal(SUBSYS_NET)
        expect(parsed.msg).to_equal("link down")
        expect(parsed.kv.len()).to_equal(0)

    it "round-trips a record with kv fields":
        var rec = SyslogRecord.new(LOG_WARN, 1, 1, SUBSYS_KERN, "oom near threshold")
        rec = syslog_record_with_kv(rec, "free_kb", "2048")
        rec = syslog_record_with_kv(rec, "threshold_kb", "4096")

        val line = syslog_format(rec)
        val parsed = syslog_parse(line)

        expect(parsed.level).to_equal(LOG_WARN)
        expect(parsed.facility).to_equal(1)
        expect(parsed.pid).to_equal(1)
        expect(parsed.subsys).to_equal(SUBSYS_KERN)
        expect(parsed.msg).to_equal("oom near threshold")
        expect(parsed.kv.len()).to_equal(2)
        expect(parsed.kv[0].key).to_equal("free_kb")
        expect(parsed.kv[0].value).to_equal("2048")
        expect(parsed.kv[1].key).to_equal("threshold_kb")
        expect(parsed.kv[1].value).to_equal("4096")

    it "PRI encodes facility*8 + level like RFC5424":
        val rec = SyslogRecord.new(2, 16, 1, SUBSYS_KERN, "pri check")
        val line = syslog_format(rec)
        # facility=16, level=2 -> PRI = 16*8+2 = 130 -> "<130>1 ..."
        expect(line.starts_with("<130>1 ")).to_equal(true)

    it "message text with multiple words survives round trip":
        val rec = SyslogRecord.new(LOG_ERROR, 0, 7, SUBSYS_NET, "fault at rip=0xdead beef more words")
        val parsed = syslog_parse(syslog_format(rec))
        expect(parsed.msg).to_equal("fault at rip=0xdead beef more words")
