extern fn rt_file_read_text(path: text) -> text

fn _contains_brotli_ring_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn _ring_at(ring: [i64], idx: i64, offset: i64) -> i64:") and
        source.to_contain("if ring.len() < 4:\n        return 0") and
        source.to_contain("val pos = (idx - offset) & 3") and
        source.to_contain("ring[pos]")

describe "Brotli distance ring guards":
    it "guards ring lookup before indexed reads":
        expect(_contains_brotli_ring_guard("src/lib/nogc_sync_mut/compression/brotli/decoder_block.spl")).to_equal(true)
