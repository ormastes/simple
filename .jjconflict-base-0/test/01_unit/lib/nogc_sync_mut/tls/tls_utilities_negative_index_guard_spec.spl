extern fn rt_file_read_text(path: text) -> text

fn _contains_tls_utility_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn byte_at(data, index):") and
        source.to_contain("if data == nil:\n        return 0") and
        source.to_contain("if index < 0 or index >= data.len():\n        return 0") and
        source.to_contain("fn slice(data, start, end):") and
        source.to_contain("var i = if start < 0: 0 else: start") and
        source.to_contain("val safe_end = if end > data.len(): data.len() else: end") and
        source.to_contain("data[index]")

describe "TLS utility negative index guards":
    it "guards byte and slice helpers before indexed reads":
        expect(_contains_tls_utility_negative_guards("src/lib/nogc_sync_mut/tls/_TlsUtilities/hex_encoding.spl")).to_equal(true)
