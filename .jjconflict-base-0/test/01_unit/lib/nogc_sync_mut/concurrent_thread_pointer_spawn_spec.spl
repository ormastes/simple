extern fn rt_file_read_text(path: text) -> text

fn thread_source() -> text:
    rt_file_read_text("src/lib/nogc_sync_mut/concurrent/thread.spl") ?? ""

describe "nogc sync thread spawn":
    it "passes callable values to the owner runtime hook":
        val src = thread_source()
        expect(src.contains("extern fn rt_thread_spawn_isolated(closure: Any, data: Any) -> i64")).to_equal(true)
        expect(src.contains("extern fn rt_thread_spawn_isolated_with_args(closure: Any, data1: Any, data2: Any) -> i64")).to_equal(true)
        expect(src.contains("rt_thread_spawn_isolated(closure, nil)")).to_equal(true)
        expect(src.contains("closure: fn(Any, Any) -> Any")).to_equal(true)
        expect(src.contains("rt_thread_spawn_isolated_with_args(closure, data1, data2)")).to_equal(true)
