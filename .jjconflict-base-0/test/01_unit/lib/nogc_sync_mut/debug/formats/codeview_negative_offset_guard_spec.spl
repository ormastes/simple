extern fn rt_file_read_text(path: text) -> text

fn _contains_codeview_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn _read_u16_at(data: [u8], offset: i64) -> i64:") and
        source.to_contain("fn _read_u32_at(data: [u8], offset: i64) -> i64:") and
        source.to_contain("fn _read_cstr(data: [u8], offset: i64) -> text:") and
        source.to_contain("if offset < 0:\n        return 0") and
        source.to_contain("if offset < 0:\n        return \"\"")

describe "CodeView negative offset guards":
    it "guards mirrored CodeView byte readers before indexed reads":
        expect(_contains_codeview_negative_guards("src/lib/nogc_sync_mut/debug/formats/codeview_records.spl")).to_equal(true)
        expect(_contains_codeview_negative_guards("src/lib/nogc_async_mut/debug/formats/codeview_records.spl")).to_equal(true)
