extern fn rt_file_read_text(path: text) -> text

fn _contains_replay_codec_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("if offset < 0:\n        return Err(\"negative offset for ReplayEntry\")") and
        source.to_contain("if offset < 0 or offset + 7 >= bytes.len():\n        return 0") and
        source.to_contain("if offset < 0 or offset + 3 >= bytes.len():\n        return 0") and
        source.to_contain("result = result + bytes[offset] as i64") and
        source.to_contain("result = result + bytes[offset]")

fn _contains_process_trace_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("if offset < 0:\n        return Err(\"negative offset for ProcessReplayEvent\")") and
        source.to_contain("if offset < 0 or offset + 7 >= bytes.len():\n        return 0") and
        source.to_contain("if offset < 0 or offset + 3 >= bytes.len():\n        return 0") and
        source.to_contain("result = result + bytes[offset] as i64") and
        source.to_contain("result = result + bytes[offset]")

describe "Replay negative offset guards":
    it "guards replay decoders before indexed reads":
        expect(_contains_replay_codec_guards("src/lib/nogc_sync_mut/replay/codec.spl")).to_equal(true)
        expect(_contains_process_trace_guards("src/lib/nogc_sync_mut/replay/process/trace_io.spl")).to_equal(true)
