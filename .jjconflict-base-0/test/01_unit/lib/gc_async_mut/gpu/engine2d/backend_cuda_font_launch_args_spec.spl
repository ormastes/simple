# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cuda_launch_args.spl
# @tag: unit, engine2d, cuda, font

use std.gpu.engine2d.backend_cuda_launch_args.{CUDA_FONT_ARG_COUNT, CUDA_FONT_ARG_BYTES, _write_font_atlas_composite_launch_args}

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64, size: i64)
extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64

describe "CUDA font atlas launch arguments":

    it "writes the frozen 15-slot ABI in kernel order":
        val values = rt_alloc(CUDA_FONT_ARG_BYTES)
        val pointers = rt_alloc(CUDA_FONT_ARG_BYTES)
        _write_font_atlas_composite_launch_args(
            values, pointers, 0x12345678, 0x23456789,
            1024u32, 512u32, 524288u32, 11u32, 12u32, 31u32, 32u32,
            800u32, 600u32, 480000u32, -17, -19, 0xF1020304u32
        )
        val expected: [i64] = [
            0x12345678, 0x23456789, 1024, 512, 524288, 11, 12, 31,
            32, 800, 600, 480000, -17, -19, 0xF1020304
        ]
        var index: i64 = 0
        while index < CUDA_FONT_ARG_COUNT:
            val offset = index * 8
            expect(rt_ptr_read_i64(values, offset)).to_equal(expected[index])
            expect(rt_ptr_read_i64(pointers, offset)).to_equal(values + offset)
            index = index + 1
        rt_free(values, CUDA_FONT_ARG_BYTES)
        rt_free(pointers, CUDA_FONT_ARG_BYTES)
