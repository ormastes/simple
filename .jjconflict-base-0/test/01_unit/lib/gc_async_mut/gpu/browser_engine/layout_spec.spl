use std.spec.{describe, it, expect}

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, StyleProps}
use std.gc_async_mut.gpu.browser_engine.layout.{
    layout_tree, layout_get_children, layout_get_height
}

fn _style(bg: text, color: text, font_size: f64) -> StyleProps:
    var style = StyleProps.empty()
    style.background_color = bg
    style.color = color
    style.font_size = font_size
    style

fn _text(id: i64, value: text) -> BeDomNode:
    var node = BeDomNode.text_node(id, value)
    node.style = _style("", "#111111", 10.0)
    node

fn _root(children: [BeDomNode]) -> BeDomNode:
    BeDomNode(
        node_id: 1,
        tag_name: "main",
        data: "",
        attributes: {},
        style: _style("#ffffff", "#000000", 16.0),
        children: children,
        parent_id: -1)

describe "Browser engine layout traversal":

    it "lays out child boxes in source order and accumulates height":
        val root = _root([_text(2, "hello"), _text(3, "world")])
        val layout = layout_tree(root, 200.0, 100.0)
        val children = layout_get_children(layout)

        expect(children.len()).to_equal(2)
        expect(children[0].text_content).to_equal("hello")
        expect(children[1].text_content).to_equal("world")
        expect(layout_get_height(layout)).to_equal(30.0)
