use std.spec.{describe, it, expect}

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.dom_accessors.{
    be_dom_get_text_content, be_dom_find_by_id, be_dom_find_by_tag
}

fn _node(id: i64, tag: text) -> BeDomNode:
    BeDomNode.element(id, tag)

fn _text(id: i64, value: text) -> BeDomNode:
    BeDomNode.text_node(id, value)

describe "Browser engine DOM accessors":

    it "collects recursive text content without changing visible text":
        val span = BeDomNode(
            node_id: 2,
            tag_name: "span",
            data: "",
            attributes: {},
            style: _node(0, "x").style,
            children: [_text(3, "world")],
            parent_id: 1)
        val root = BeDomNode(
            node_id: 1,
            tag_name: "div",
            data: "",
            attributes: {},
            style: _node(0, "x").style,
            children: [_text(4, "hello "), span],
            parent_id: -1)

        expect(be_dom_get_text_content(root)).to_equal("hello world")

    it "finds nodes by id and tag in depth-first order":
        val style = _node(0, "x").style
        val section = BeDomNode(
            node_id: 2,
            tag_name: "section",
            data: "",
            attributes: {},
            style: style,
            children: [_node(3, "p"), _node(4, "p")],
            parent_id: 1)
        val root = BeDomNode(
            node_id: 1,
            tag_name: "div",
            data: "",
            attributes: {},
            style: style,
            children: [section, _node(5, "p")],
            parent_id: -1)

        match be_dom_find_by_id(root, 4):
            Some(found) =>
                expect(found.tag_name).to_equal("p")
            nil =>
                fail("Expected node id 4")

        val paragraphs = be_dom_find_by_tag(root, "p")
        expect(paragraphs.len()).to_equal(3)
        expect(paragraphs[0].node_id).to_equal(3)
        expect(paragraphs[1].node_id).to_equal(4)
        expect(paragraphs[2].node_id).to_equal(5)
