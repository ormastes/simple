# =============================================================================
# Salsa20/20 + HSalsa20 + XSalsa20 Known-Answer Tests
#
# Exercises src/os/crypto/salsa20.spl against:
#   - Salsa20/20: ECRYPT stream cipher test vectors
#       https://www.ecrypt.eu.org/stream/svn/viewcvs.cgi/ecrypt/trunk/submissions/salsa20/full/verified.test-vectors
#   - HSalsa20: libsodium / NaCl reference test (all-zero key + nonce)
#   - XSalsa20: libsodium crypto_stream_xsalsa20 test vectors
#       https://github.com/jedisct1/libsodium/blob/master/test/default/stream.c
#
# Execution note: the unit test runner (interpreter mode) verifies file
# loading and syntax, but does NOT execute it-block bodies. Assertions are
# structurally correct and use the real function signatures; they become
# live regression gates in compiled/native mode.
# See: .claude/memory/feedback_compile_mode_false_greens.md
# =============================================================================

use std.spipe.*
use os.crypto.salsa20.{salsa20_20_block, salsa20_20_xor, salsa20_xor, hsalsa20, xsalsa20_xor}

# =============================================================================
# Helpers
# =============================================================================

fn _repeat_byte(b: u8, n: u64) -> [u8]:
    """Build a list of n copies of byte b."""
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out.push(b)
        i = i + 1
    out

# Helper: take first n bytes of a list
fn _first_n(data: [u8], n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n and i < data.len():
        out.push(data[i])
        i = i + 1
    out

# =============================================================================
# Salsa20/20 ECRYPT Set 1, Vector 0
#
# Key    (32 bytes): 0x80 followed by 31 zero bytes
# Nonce  ( 8 bytes): all zeros
# Block 0 (64 bytes) expected keystream:
#   e3be8fdd8beca2e3ea8ef9475b29a6e7
#   003951e1097a5c38d23b7a5fad9f6844
#   b22c97559e2723c7cbbd3fe4fc8d9a07
#   4465a84789010df4848a5c59d5d2a94a
# Source: ECRYPT Salsa20/20 verified test vectors, Set 1, Vector 0
# =============================================================================

fn _key_s1v0() -> [u8]:
    var k: [u8] = []
    k.push(0x80u8)
    var i: u64 = 0
    while i < 31:
        k.push(0x00u8)
        i = i + 1
    k

fn _nonce_zero8() -> [u8]:
    _repeat_byte(0x00u8, 8)

