    # Python-verified: HSalsa20(key=0^32, input=0^16)
    # 35 1f 86 fa a3 b9 88 46 8a 85 01 22 b6 5b 0a ce
    # ce 9c 48 26 80 6a ee e6 3d e9 c0 da 2b d7 f9 1e
    var e: [u8] = []
    e.push(0x35u8)
    e.push(0x1fu8)
    e.push(0x86u8)
    e.push(0xfau8)
    e.push(0xa3u8)
    e.push(0xb9u8)
    e.push(0x88u8)
    e.push(0x46u8)
    e.push(0x8au8)
    e.push(0x85u8)
    e.push(0x01u8)
    e.push(0x22u8)
    e.push(0xb6u8)
    e.push(0x5bu8)
    e.push(0x0au8)
    e.push(0xceu8)
    e.push(0xceu8)
    e.push(0x9cu8)
    e.push(0x48u8)
    e.push(0x26u8)
    e.push(0x80u8)
    e.push(0x6au8)
    e.push(0xeeu8)
    e.push(0xe6u8)
    e.push(0x3du8)
    e.push(0xe9u8)
    e.push(0xc0u8)
    e.push(0xdau8)
    e.push(0x2bu8)
    e.push(0xd7u8)
    e.push(0xf9u8)
    e.push(0x1eu8)
    e

# =============================================================================
# XSalsa20 stream vector
#
# key  (32 bytes): 1b27556473e985d462cd51197a9a46c7
#                  6009549eac6474f206c4ee0844f68389
# nonce (24 bytes): 69696ee955b62b73cd62bda875fc73d6
#                   8219e0036b7a0b37
# stream[0..31] = encrypt(zeros[32]) — Python-verified:
#   3ef1fcae9d68f2a249780cc3c6fdb502
#   3193790 5a13a5a4d98ba916ef7 3f3d1d
# =============================================================================

