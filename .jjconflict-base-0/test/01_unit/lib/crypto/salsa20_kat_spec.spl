    n.push(0x6bu8)
    n.push(0x7au8)
    n.push(0x0bu8)
    n.push(0x37u8)
    n

fn _xsalsa20_expected_first32() -> [u8]:
    # Python-verified: XSalsa20 encrypt(zeros, key=_xsalsa20_key(), nonce=_xsalsa20_nonce())
    # 3e f1 fc ae 9d 68 f2 a2 49 78 0c c3 c6 fd b5 02
    # 31 93 79 05 a1 3a 5a 4d 98 ba 91 6e f7 3f 3d 1d
    var e: [u8] = []
    e.push(0x3eu8)
    e.push(0xf1u8)
    e.push(0xfcu8)
    e.push(0xaeu8)
    e.push(0x9du8)
    e.push(0x68u8)
    e.push(0xf2u8)
    e.push(0xa2u8)
