use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_app_root(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/main.spl\" " + joined
    ])

describe "app root log mode CLI options":
    it "keeps plain invocation quiet":
        val (out, err, code) = _run_app_root([])
        expect(code).to_equal(0)
        expect(out).to_equal("")

    it "shows shared log options in help":
        val (out, err, code) = _run_app_root(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Simple app root entrypoint")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for ready output":
        val (out, err, code) = _run_app_root(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"app-root\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_app_root(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Simple app root entrypoint")

    it "rejects invalid log mode":
        val (out, err, code) = _run_app_root(["--log-mode=noisy"])
        expect(code).to_equal(1)
