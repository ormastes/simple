# Direct Scene Executor Pixel Verification
#
# Tests the render scene executor directly — bypasses HTML/CSS/DOM/Layout.
# This isolates whether the pixel-writing pipeline works.
#
# Build: bin/simple native-build --source src/lib --source src/os --entry test/integration/rendering/pixel_verify_scene.spl -o build/pixel_verify_scene --entry-closure --runtime-bundle all
# Run:   ./build/pixel_verify_scene

use common.render_scene.scene.{SceneCommand, RenderScene, render_scene,
    scene_fill_rect, scene_stroke_rect, scene_text, scene_rounded_rect,
    scene_gradient_rect}
use common.render_scene.executor.{execute_scene_to_buffer}
use std.gc_async_mut.gpu.engine2d.color.{rgb, rgba, color_r, color_g, color_b, color_a}

extern fn rt_array_push(arr, val)
extern fn rt_array_new(cap: i32) -> [u32]

var total_checks: i32 = 0
var passed_checks: i32 = 0
var failed_checks: i32 = 0

fn check(name: text, condition: bool):
    total_checks = total_checks + 1
    if condition:
        passed_checks = passed_checks + 1
        print "  PASS: {name}"
    else:
        failed_checks = failed_checks + 1
        print "  FAIL: {name}"

fn make_buffer(w: i32, h: i32) -> [u32]:
    val count = w * h
    var buf: [u32] = rt_array_new(count)
    var i = 0
    while i < count:
        rt_array_push(buf, 0xFF000000)
        i = i + 1
    buf

fn main():
    val W: i32 = 20
    val H: i32 = 20

    # ==================================================================
    # Test 1: Fill rect writes red pixels
    # ==================================================================
    print "=== Test 1: Fill Rect (red) ==="
    var buf1 = make_buffer(W, H)
    check("buffer initialized", buf1.len() == W * H)

    # Create a scene with a single red filled rect covering the viewport
    val red_argb: u32 = 0xFFFF0000
    var cmds1: [SceneCommand] = []
    rt_array_push(cmds1, scene_fill_rect(0, 0, W, H, red_argb))
    val scene1 = render_scene(cmds1, W, H)
    check("scene has commands", scene1.commands.len() > 0)
    print "  Scene commands: {scene1.commands.len()}"

    execute_scene_to_buffer(scene1, buf1, W, H)

    # Check center pixel should be red
    val center = 10 * W + 10
    if center < buf1.len():
        val p = buf1[center]
        val r = color_r(p)
        val g = color_g(p)
        val b = color_b(p)
        val a = color_a(p)
        print "  Center pixel: R:{r} G:{g} B:{b} A:{a} raw:0x{p}"
        check("center pixel is red", r > 200 and g < 50 and b < 50)
    else:
        check("center pixel accessible", false)

    # Check corner pixel
    if buf1.len() > 0:
        val p0 = buf1[0]
        val r0 = color_r(p0)
        val g0 = color_g(p0)
        val b0 = color_b(p0)
        print "  Corner pixel: R:{r0} G:{g0} B:{b0} raw:0x{p0}"
        check("corner pixel is red", r0 > 200)

    # ==================================================================
    # Test 2: Fill rect writes blue pixels (different color)
    # ==================================================================
    print "\n=== Test 2: Fill Rect (blue) ==="
    var buf2 = make_buffer(W, H)
    val blue_argb: u32 = 0xFF0000FF
    var cmds2: [SceneCommand] = []
    rt_array_push(cmds2, scene_fill_rect(0, 0, W, H, blue_argb))
    val scene2 = render_scene(cmds2, W, H)
    execute_scene_to_buffer(scene2, buf2, W, H)

    if buf2.len() > 0:
        val bp = buf2[0]
        val br = color_r(bp)
        val bg = color_g(bp)
        val bb = color_b(bp)
        print "  Pixel[0]: R:{br} G:{bg} B:{bb} raw:0x{bp}"
        check("blue pixel has blue", bb > 200)
        check("blue pixel has no red", br < 50)

    # ==================================================================
    # Test 3: Red vs Blue pixel comparison
    # ==================================================================
    print "\n=== Test 3: Red vs Blue Difference ==="
    var diff_count: i32 = 0
    var idx = 0
    while idx < buf1.len() and idx < buf2.len():
        if buf1[idx] != buf2[idx]:
            diff_count = diff_count + 1
        idx = idx + 1
    print "  Different pixels: {diff_count}/{buf1.len()}"
    check("red and blue differ", diff_count > 0)

    # ==================================================================
    # Test 4: Partial rect (does not cover full viewport)
    # ==================================================================
    print "\n=== Test 4: Partial Fill Rect ==="
    var buf4 = make_buffer(W, H)
    val green_argb: u32 = 0xFF00FF00
    var cmds4: [SceneCommand] = []
    # Green rect in top-left 10x10 area only
    rt_array_push(cmds4, scene_fill_rect(0, 0, 10, 10, green_argb))
    val scene4 = render_scene(cmds4, W, H)
    execute_scene_to_buffer(scene4, buf4, W, H)

    # Top-left should be green
    if buf4.len() > 0:
        val gp = buf4[0]
        print "  Pixel[0,0]: R:{color_r(gp)} G:{color_g(gp)} B:{color_b(gp)} raw:0x{gp}"
        check("top-left is green", color_g(gp) > 200)

    # Bottom-right should be original black
    val br_idx = 15 * W + 15
    if br_idx < buf4.len():
        val brp = buf4[br_idx]
        print "  Pixel[15,15]: R:{color_r(brp)} G:{color_g(brp)} B:{color_b(brp)} raw:0x{brp}"
        check("bottom-right is black (unchanged)", color_r(brp) == 0 and color_g(brp) == 0 and color_b(brp) == 0)

    # ==================================================================
    # Test 5: Gradient rect
    # ==================================================================
    print "\n=== Test 5: Gradient Rect ==="
    var buf5 = make_buffer(W, H)
    var cmds5: [SceneCommand] = []
    rt_array_push(cmds5, scene_gradient_rect(0, 0, W, H, 0xFFFF0000, 0xFF0000FF))
    val scene5 = render_scene(cmds5, W, H)
    execute_scene_to_buffer(scene5, buf5, W, H)

    # Left edge should be more red
    if buf5.len() > 0:
        val left_p = buf5[10 * W + 0]
        val right_p = buf5[10 * W + 19]
        print "  Left pixel:  R:{color_r(left_p)} G:{color_g(left_p)} B:{color_b(left_p)}"
        print "  Right pixel: R:{color_r(right_p)} G:{color_g(right_p)} B:{color_b(right_p)}"
        check("left has more red than right", color_r(left_p) > color_r(right_p))
        check("right has more blue than left", color_b(right_p) > color_b(left_p))

    # ==================================================================
    # Test 6: Deterministic rendering
    # ==================================================================
    print "\n=== Test 6: Deterministic ==="
    var buf6a = make_buffer(W, H)
    var buf6b = make_buffer(W, H)
    var cmds6: [SceneCommand] = []
    rt_array_push(cmds6, scene_fill_rect(2, 2, 16, 16, 0xFFAA5500))
    val scene6 = render_scene(cmds6, W, H)
    execute_scene_to_buffer(scene6, buf6a, W, H)
    execute_scene_to_buffer(scene6, buf6b, W, H)

    var match6: i32 = 0
    var mi = 0
    while mi < buf6a.len() and mi < buf6b.len():
        if buf6a[mi] == buf6b[mi]:
            match6 = match6 + 1
        mi = mi + 1
    print "  Matching: {match6}/{buf6a.len()}"
    check("deterministic rendering", match6 == buf6a.len())

    # ==================================================================
    # Test 7: Rounded rect
    # ==================================================================
    print "\n=== Test 7: Rounded Rect ==="
    var buf7 = make_buffer(W, H)
    var cmds7: [SceneCommand] = []
    rt_array_push(cmds7, scene_rounded_rect(2, 2, 16, 16, 0xFFFF00FF, 4))
    val scene7 = render_scene(cmds7, W, H)
    execute_scene_to_buffer(scene7, buf7, W, H)

    # Center should be magenta
    val c7 = buf7[10 * W + 10]
    print "  Center: R:{color_r(c7)} G:{color_g(c7)} B:{color_b(c7)}"
    check("rounded rect center is magenta", color_r(c7) > 200 and color_b(c7) > 200)

    # Corner (0,0) should be black (outside rounded rect)
    val corner7 = buf7[0]
    print "  Corner(0,0): R:{color_r(corner7)} G:{color_g(corner7)} B:{color_b(corner7)}"
    check("corner outside rounded rect is black", color_r(corner7) == 0 and color_g(corner7) == 0)

    # ==================================================================
    # Summary
    # ==================================================================
    print "\n========================================"
    print "  Scene Executor Pixel Verification"
    print "========================================"
    print "  Total checks: {total_checks}"
    print "  Passed:       {passed_checks}"
    print "  Failed:       {failed_checks}"
    if failed_checks == 0:
        print "  Result: ALL PASSED"
    else:
        print "  Result: {failed_checks} FAILURES"
    print "========================================"
