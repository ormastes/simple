# @tag: rendering, screenshot, effect_engine
# @cover src/lib/common/render_scene/engine_int.spl 80%
# @cover src/lib/common/render_scene/engine_float.spl 80%
#
# Effect Engine Comparison Tests (Int32 vs Float64)
#
# Verifies that the integer (baremetal-safe) and float (hosted) effect
# engines produce visually equivalent output when rendering through the
# software rasterizer.

use std.spec.{describe, context, it, expect}
use os.compositor.screenshot_compare.{
    compare_pixel_buffers, compare_per_channel, print_comparison_report,
    print_channel_report}
use std.gc_async_mut.gpu.browser_engine.backend_screenshot_capture.{
    BackendCapture, capture_with_effect_engine}
use common.ui.glass_test_page.{generate_glass_test_html, build_rendering_stress_html}

# ============================================================================
# Constants
# ============================================================================

val W: i32 = 400
val H: i32 = 300
val THRESHOLD_EE: i32 = 3        # Effect engine tolerance
val MIN_PCT_EE: i64 = 9950       # 99.50%
val THRESHOLD_GRAD: i32 = 1      # Gradient-only tolerance
val THRESHOLD_BLEND: i32 = 1     # Blending tolerance
val THRESHOLD_SHADOW: i32 = 2    # Shadow computation tolerance

# ============================================================================
# Tests
# ============================================================================

describe "Effect Engine Comparison (Int32 vs Float64)":

    context "full scene comparison":

        it "glass_dark renders within effect engine tolerance":
            val html = generate_glass_test_html("glass_dark")
            val int_cap = capture_with_effect_engine(html, W, H, "int")
            val float_cap = capture_with_effect_engine(html, W, H, "float")
            expect(int_cap.success).to_equal(true)
            expect(float_cap.success).to_equal(true)
            val result = compare_pixel_buffers(int_cap.pixels, float_cap.pixels, W, H, THRESHOLD_EE)
            expect(result.match_percentage).to_be_greater_than(MIN_PCT_EE - 1)
            if result.match_percentage < 10000:
                print "Int32 vs Float64 on glass_dark:"
                print_comparison_report(result)

        it "glass_light renders within effect engine tolerance":
            val html = generate_glass_test_html("glass_light")
            val int_cap = capture_with_effect_engine(html, W, H, "int")
            val float_cap = capture_with_effect_engine(html, W, H, "float")
            expect(int_cap.success).to_equal(true)
            expect(float_cap.success).to_equal(true)
            val result = compare_pixel_buffers(int_cap.pixels, float_cap.pixels, W, H, THRESHOLD_EE)
            expect(result.match_percentage).to_be_greater_than(MIN_PCT_EE - 1)

        it "stress test renders within effect engine tolerance":
            val html = build_rendering_stress_html()
            val int_cap = capture_with_effect_engine(html, W, H, "int")
            val float_cap = capture_with_effect_engine(html, W, H, "float")
            expect(int_cap.success).to_equal(true)
            expect(float_cap.success).to_equal(true)
            val result = compare_pixel_buffers(int_cap.pixels, float_cap.pixels, W, H, THRESHOLD_EE)
            expect(result.match_percentage).to_be_greater_than(MIN_PCT_EE - 1)

    context "per-channel analysis":

        it "glass_dark per-channel diff within tolerance":
            val html = generate_glass_test_html("glass_dark")
            val int_cap = capture_with_effect_engine(html, W, H, "int")
            val float_cap = capture_with_effect_engine(html, W, H, "float")
            expect(int_cap.success).to_equal(true)
            expect(float_cap.success).to_equal(true)
            val channels = compare_per_channel(int_cap.pixels, float_cap.pixels, W, H, THRESHOLD_EE)
            print_channel_report(channels)
            # Each channel should be within tolerance
            for ch in channels:
                expect(ch.match_pct).to_be_greater_than(MIN_PCT_EE - 1)

    context "pixel buffer sizes match":

        it "int and float engines produce same buffer size":
            val html = generate_glass_test_html("glass_dark")
            val int_cap = capture_with_effect_engine(html, W, H, "int")
            val float_cap = capture_with_effect_engine(html, W, H, "float")
            expect(int_cap.success).to_equal(true)
            expect(float_cap.success).to_equal(true)
            expect(int_cap.pixels.len()).to_equal(float_cap.pixels.len())
            expect(int_cap.pixels.len()).to_equal(W * H)
