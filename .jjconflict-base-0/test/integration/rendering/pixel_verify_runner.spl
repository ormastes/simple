# Pixel-Level Drawing Verification Runner
#
# Tests pixel correctness using the browser engine pipeline (which works
# in interpreter mode) and direct pixel buffer comparison.
# Run with: bin/simple run test/integration/rendering/pixel_verify_runner.spl

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixel_array}
use std.gc_async_mut.gpu.engine2d.color.{rgb, rgba, color_r, color_g, color_b, color_a}
use os.compositor.screenshot_compare.{compare_pixel_buffers, print_comparison_report, compare_per_channel, print_channel_report}
use common.ui.glass_test_page.{generate_glass_test_html, build_rendering_stress_html}

var total_checks: i32 = 0
var passed_checks: i32 = 0
var failed_checks: i32 = 0

fn check(name: text, condition: bool):
    total_checks = total_checks + 1
    if condition:
        passed_checks = passed_checks + 1
        print "  PASS: {name}"
    else:
        failed_checks = failed_checks + 1
        print "  FAIL: {name}"

fn pixel_at(pixels: [u32], w: i32, x: i32, y: i32) -> u32:
    val idx = y * w + x
    if idx >= 0 and idx < pixels.len():
        pixels[idx]
    else:
        0

fn pixel_near(px: u32, target: u32, threshold: i32) -> bool:
    val dr = color_r(px) - color_r(target)
    val dg = color_g(px) - color_g(target)
    val db = color_b(px) - color_b(target)
    var adr = dr
    if adr < 0: adr = 0 - adr
    var adg = dg
    if adg < 0: adg = 0 - adg
    var adb = db
    if adb < 0: adb = 0 - adb
    adr <= threshold and adg <= threshold and adb <= threshold

val W: i32 = 200
val H: i32 = 150

# ============================================================================
# Test 1: Glass dark theme renders non-empty pixels
# ============================================================================

print "=== Test 1: Glass Dark Theme ==="
val dark_html = generate_glass_test_html("glass_dark")
check("dark HTML is non-empty", dark_html.len() > 100)

val dark_pixels = render_html_to_pixel_array(dark_html, W, H)
check("dark pixels count matches viewport", dark_pixels.len() == W * H)

# Check for dark background pixels (near #0A0A0F)
val dark_bg = rgb(10, 10, 15)
var dark_bg_count: i32 = 0
var i = 0
while i < 200:  # sample first 200 pixels (top row)
    if i < dark_pixels.len():
        if pixel_near(dark_pixels[i], dark_bg, 30):
            dark_bg_count = dark_bg_count + 1
    i = i + 1
check("top row has dark background pixels", dark_bg_count > 10)
print "  Dark bg pixels in first row: {dark_bg_count}/{W}"

# Check for non-uniform content (not all same color)
var unique_colors: i32 = 0
var last_color: u32 = 0
var j = 0
while j < dark_pixels.len() and j < 5000:
    if dark_pixels[j] != last_color:
        unique_colors = unique_colors + 1
        last_color = dark_pixels[j]
    j = j + 200  # sample every 200th pixel
check("dark theme has varied pixels", unique_colors > 3)
print "  Unique color transitions (sampled): {unique_colors}"

# ============================================================================
# Test 2: Glass light theme differs from dark
# ============================================================================

print "\n=== Test 2: Glass Light Theme ==="
val light_html = generate_glass_test_html("glass_light")
val light_pixels = render_html_to_pixel_array(light_html, W, H)
check("light pixels count matches viewport", light_pixels.len() == W * H)

val theme_cmp = compare_pixel_buffers(dark_pixels, light_pixels, W, H, 0)
check("dark != light (different themes)", theme_cmp.match_percentage < 5000)
print "  Dark vs Light match: {theme_cmp.match_percentage / 100}.{theme_cmp.match_percentage % 100}%"

# ============================================================================
# Test 3: Rendering stress test
# ============================================================================

print "\n=== Test 3: Stress Test ==="
val stress_html = build_rendering_stress_html()
check("stress HTML is non-empty", stress_html.len() > 100)

val stress_pixels = render_html_to_pixel_array(stress_html, W, H)
check("stress test renders pixels", stress_pixels.len() == W * H)

# Check for gradient/alpha content
var stress_unique: i32 = 0
var stress_last: u32 = 0
var k = 0
while k < stress_pixels.len() and k < 5000:
    if stress_pixels[k] != stress_last:
        stress_unique = stress_unique + 1
        stress_last = stress_pixels[k]
    k = k + 50
check("stress test has varied content", stress_unique > 5)
print "  Unique transitions: {stress_unique}"

# ============================================================================
# Test 4: Deterministic rendering
# ============================================================================

print "\n=== Test 4: Deterministic Rendering ==="
val px4a = render_html_to_pixel_array(dark_html, W, H)
val px4b = render_html_to_pixel_array(dark_html, W, H)

val det_cmp = compare_pixel_buffers(px4a, px4b, W, H, 0)
check("same HTML renders identically", det_cmp.match_percentage == 10000)
if det_cmp.match_percentage < 10000:
    print "  MISMATCH detected!"
    print_comparison_report(det_cmp)

# ============================================================================
# Test 5: Per-channel analysis
# ============================================================================

print "\n=== Test 5: Per-Channel Comparison (dark vs light) ==="
val channels = compare_per_channel(dark_pixels, light_pixels, W, H, 30)
print_channel_report(channels)
for ch in channels:
    check("channel {ch.channel} has differences", ch.different > 0)

# ============================================================================
# Summary
# ============================================================================

print "\n========================================"
print "  Pixel Verification Summary"
print "========================================"
print "  Total checks: {total_checks}"
print "  Passed:       {passed_checks}"
print "  Failed:       {failed_checks}"
if failed_checks == 0:
    print "  Result: ALL PASSED"
else:
    print "  Result: {failed_checks} FAILURES"
print "========================================"
