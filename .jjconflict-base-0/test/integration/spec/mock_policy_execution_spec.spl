# Mock policy executor integration tests
# Proves system-test mock banning and example-level override precedence

use std.spec
use std.spec.registry.{ExampleGroup, Example}
use std.spec.runner.executor.{TestExecutor, ExecutionResults}
use std.spec.{Mock, Spy, Stub, MockMode, mock_policy_reset}

fn mock_block():
    Mock.new("mock_block")

fn spy_block():
    Spy.new("spy_block")

fn stub_block():
    Stub.new("stub_block")

fn override_block():
    Mock.new("override_block")
    Spy.new("override_block")
    Stub.new("override_block")

fn execute_group(group: ExampleGroup) -> ExecutionResults:
    val executor = TestExecutor.new()
    val results = ExecutionResults.new()
    executor.execute_group(group, results)
    return results

describe "Mock policy executor integration":
    it "bans Mock.new, Spy.new, and Stub.new in system-test mode":
        mock_policy_reset()

        val group = ExampleGroup.new("system policy", nil).with_mock_mode(MockMode.Disabled)
        group.add_example(Example.new("Mock.new is blocked", mock_block).system_test())
        group.add_example(Example.new("Spy.new is blocked", spy_block).system_test())
        group.add_example(Example.new("Stub.new is blocked", stub_block).system_test())

        val results = execute_group(group)

        expect(results.total_count()).to_equal(3)
        expect(results.failed_count()).to_equal(3)
        expect(results.passed_count()).to_equal(0)

        mock_policy_reset()

    it "keeps a system-test group banned while allowing an explicit unit-test override":
        mock_policy_reset()

        val parent = ExampleGroup.new("parent", nil).with_mock_mode(MockMode.Disabled)
        val child = ExampleGroup.new("child", Some(parent))
        parent.add_child(child)

        child.add_example(Example.new("inherits disabled policy", mock_block).system_test())
        child.add_example(Example.new("overrides to allow mocks", override_block).unit_test())

        val results = execute_group(parent)

        expect(results.total_count()).to_equal(2)
        expect(results.failed_count()).to_equal(1)
        expect(results.passed_count()).to_equal(1)

        mock_policy_reset()
