# Baremetal Integration Smoke Tests
#
# Honest, bounded coverage for the checked-in SimpleOS baremetal path.
# This suite verifies only facts the file can directly observe:
# - the CLI exposes baremetal-oriented commands
# - supported architecture reporting is wired up
# - invalid arch selection fails before entering a long build
# - checked-in boot/linker assets exist for each supported architecture

use app.io.{shell}

extern fn rt_file_exists(path: text) -> bool

fn shell_stdout(cmd: text) -> text:
    shell(cmd).stdout

fn shell_stderr(cmd: text) -> text:
    shell(cmd).stderr

fn shell_exit_code(cmd: text) -> i32:
    shell(cmd).exit_code

fn all_baremetal_assets_exist() -> bool:
    rt_file_exists("src/os/kernel/arch/x86_64/boot.spl") and
    rt_file_exists("src/os/kernel/arch/x86_64/linker.ld") and
    rt_file_exists("src/os/kernel/arch/x86_32/boot.spl") and
    rt_file_exists("src/os/kernel/arch/x86_32/linker.ld") and
    rt_file_exists("src/os/kernel/arch/riscv64/boot.spl") and
    rt_file_exists("src/os/kernel/arch/riscv64/linker.ld") and
    rt_file_exists("src/os/kernel/arch/riscv32/boot.spl") and
    rt_file_exists("src/os/kernel/arch/riscv32/linker.ld") and
    rt_file_exists("src/os/kernel/arch/arm64/boot.spl") and
    rt_file_exists("src/os/kernel/arch/arm64/linker.ld") and
    rt_file_exists("src/os/kernel/arch/arm32/boot.spl") and
    rt_file_exists("src/os/kernel/arch/arm32/linker.ld")

describe "Baremetal Integration Smoke":
    context "simple os CLI surface":
        it "prints top-level baremetal help":
            val cmd = "bin/simple os --help"
            val stdout = shell_stdout(cmd)
            expect(shell_exit_code(cmd)).to_equal(0)
            expect(stdout.contains("Build the OS kernel")).to_equal(true)
            expect(stdout.contains("Build and run in QEMU")).to_equal(true)
            expect(stdout.contains("Build and run boot smoke test")).to_equal(true)
            expect(stdout.contains("List supported architectures")).to_equal(true)

        it "lists the six supported baremetal architectures":
            val cmd = "bin/simple os targets"
            val stdout = shell_stdout(cmd)
            expect(shell_exit_code(cmd)).to_equal(0)
            expect(stdout.contains("x86_64  ->  x86_64-unknown-none  (qemu-system-x86_64)")).to_equal(true)
            expect(stdout.contains("x86_32  ->  i686-unknown-none  (qemu-system-i386)")).to_equal(true)
            expect(stdout.contains("riscv64  ->  riscv64-unknown-none  (qemu-system-riscv64)")).to_equal(true)
            expect(stdout.contains("riscv32  ->  riscv32-unknown-none  (qemu-system-riscv32)")).to_equal(true)
            expect(stdout.contains("arm64  ->  aarch64-unknown-none  (qemu-system-aarch64)")).to_equal(true)
            expect(stdout.contains("arm32  ->  armv7-unknown-none-eabihf  (qemu-system-arm)")).to_equal(true)
            expect(stdout.contains("Default: x86_64")).to_equal(true)

    context "argument validation":
        it "rejects unknown architecture for build before a compile starts":
            val cmd = "bin/simple os build --arch=bogus"
            val stderr = shell_stderr(cmd)
            expect(shell_exit_code(cmd)).to_equal(1)
            expect(stderr.contains("unknown architecture 'bogus'")).to_equal(true)
            expect(stderr.contains("Run 'simple os targets' for supported architectures.")).to_equal(true)

        it "rejects unknown architecture for run before a qemu launch starts":
            val cmd = "bin/simple os run --arch=bogus"
            val stderr = shell_stderr(cmd)
            expect(shell_exit_code(cmd)).to_equal(1)
            expect(stderr.contains("unknown architecture 'bogus'")).to_equal(true)
            expect(stderr.contains("Run 'simple os targets' for supported architectures.")).to_equal(true)

    context "checked-in baremetal assets":
        it "has boot entries and linker scripts for every reported architecture":
            expect(all_baremetal_assets_exist()).to_equal(true)
