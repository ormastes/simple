# test/perf/bench/fs_driver_mount_table.spl — MountTable hot-path benchmarks.
#
# Measures algorithmic cost of MountTable resolve() and lookup() on the
# current in-memory implementation.
#
# DISCLAIMER: These numbers DO NOT reflect real SSD hardware. They measure
# CPU cost of prefix-match dispatch and string operations (str_char_at loop).
# Real SSD benchmarks require the NVMe driver layer (Phase 10+).
#
# Validates that the FR-STORAGE-0004 str_char_at implementation (replacing the
# broken Cranelift slice() path) has acceptable algorithmic cost.
#
# NOTE: bench_measure() closures cannot capture mutable local `var`s (Simple
# runtime limitation). Timing loops are inlined per-scenario using bench_now_ns
# and _bench_record() to keep the BenchResult accumulation logic in one place.
#
# Run: bin/simple run test/perf/bench/fs_driver_mount_table.spl

use test.perf.bench.lib.timing.{BenchResult, bench_print, bench_csv, bench_csv_header, bench_now_ns}
use std.fs_driver.mount_table.{MountTable, MountId}
use std.fs_driver.types.{Path, MountOptions}
use std.fs_driver.instance.{DriverInstance, RamFsStub}
use std.fs_driver.error.{FsError}

# ── Helpers ───────────────────────────────────────────────────────────────────

fn _make_driver() -> DriverInstance:
    DriverInstance.RamFs(driver: RamFsStub(name: "bench_ramfs"))

fn _make_opts() -> MountOptions:
    MountOptions.default()

fn _make_path(raw: text) -> Path:
    Path(raw: raw)

# ── Inline sort (ascending, insertion sort) ───────────────────────────────────

fn _bench_sort(samples: [i64]) -> [i64]:
    var result: [i64] = samples
    val n: i64 = result.len() as i64
    var i: i64 = 1
    while i < n:
        val key: i64 = result[i as i32]
        var j: i64 = i - 1
        while j >= 0 and result[j as i32] > key:
            result[(j + 1) as i32] = result[j as i32]
            j = j - 1
        result[(j + 1) as i32] = key
        i = i + 1
    result

fn _pct(sorted: [i64], pct_num: i64, pct_den: i64) -> i64:
    val n: i64 = sorted.len() as i64
    if n == 0:
        return 0
    var idx: i64 = (n * pct_num) / pct_den
    if idx >= n:
        idx = n - 1
    sorted[idx as i32]

fn _make_result(label: text, iters: i64, samples: [i64]) -> BenchResult:
    val sorted: [i64] = _bench_sort(samples)
    val n: i64 = sorted.len() as i64
    val mn: i64 = if n > 0: sorted[0] else: 0
    val mx: i64 = if n > 0: sorted[(n - 1) as i32] else: 0
    var total: i64 = 0
    var k: i64 = 0
    while k < n:
        total = total + sorted[k as i32]
        k = k + 1
    val tput: i64 = if total > 0: (iters * 1000) / total else: 0
    BenchResult(
        label: label,
        iters: iters,
        p50_ns: _pct(sorted, 50, 100),
        p99_ns: _pct(sorted, 99, 100),
        p99_9_ns: _pct(sorted, 999, 1000),
        min_ns: mn,
        max_ns: mx,
        total_ns: total,
        throughput_ops_per_s: tput,
    )

# ── Scenario 1: 10k × resolve("/foo/bar") — single mount at "/" ──────────────

fn bench_single_mount_resolve() -> BenchResult:
    var mt: MountTable = MountTable.new()
    mt.mount(_make_path("/"), _make_driver(), _make_opts())
    val target: Path = _make_path("/foo/bar")
    val iters: i64 = 10000
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        val _r = mt.resolve(target)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _make_result("resolve_single_mount_10k", iters, samples)

# ── Scenario 2: 10k × resolve("/mnt/data/file") — 5 mounts ──────────────────

fn bench_multi_mount_resolve() -> BenchResult:
    var mt: MountTable = MountTable.new()
    mt.mount(_make_path("/"), _make_driver(), _make_opts())
    mt.mount(_make_path("/mnt"), _make_driver(), _make_opts())
    mt.mount(_make_path("/mnt/data"), _make_driver(), _make_opts())
    mt.mount(_make_path("/tmp"), _make_driver(), _make_opts())
    mt.mount(_make_path("/var"), _make_driver(), _make_opts())
    val target: Path = _make_path("/mnt/data/file")
    val iters: i64 = 10000
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        val _r = mt.resolve(target)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _make_result("resolve_multi_mount_5_10k", iters, samples)

# ── Scenario 3: 10k × lookup("/fat") ─────────────────────────────────────────

fn bench_lookup() -> BenchResult:
    var mt: MountTable = MountTable.new()
    mt.mount(_make_path("/fat"), _make_driver(), _make_opts())
    mt.mount(_make_path("/ram"), _make_driver(), _make_opts())
    mt.mount(_make_path("/nvfs"), _make_driver(), _make_opts())
    val target: Path = _make_path("/fat")
    val iters: i64 = 10000
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        val _r = mt.lookup(target)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _make_result("lookup_fat_10k", iters, samples)

# ── Main ──────────────────────────────────────────────────────────────────────

fn main():
    print "=== MountTable hot-path benchmark ==="
    print "DISCLAIMER: in-memory only. No real SSD. Ticks = loop-counter proxy (FR-BENCH-CLOCK-001)."
    print ""

    val r1: BenchResult = bench_single_mount_resolve()
    val r2: BenchResult = bench_multi_mount_resolve()
    val r3: BenchResult = bench_lookup()

    bench_print(r1)
    print ""
    bench_print(r2)
    print ""
    bench_print(r3)

    print ""
    print "=== CSV (copy to doc/08_tracking/bench/ as baseline) ==="
    print bench_csv_header()
    print bench_csv(r1)
    print bench_csv(r2)
    print bench_csv(r3)
