#!/usr/bin/env bash
# Run ctype microbenchmarks and compare C vs Simple (interpreter + native).
#
# Usage:
#   bash test/perf/ctype/run_ctype_benchmarks.shs
#
# Env knobs:
#   SIMPLE_BIN                    (default: bin/simple)
#   SIMPLE_CTYPE_BENCH_SAMPLES    (default: 1)
#   SIMPLE_CTYPE_BENCH_MIN_RATIO  (default: 0.50 — minimum simple_native/c ratio)
#   SIMPLE_CTYPE_BENCH_ENFORCE    (default: 0 — set to 1 to fail on ratio floor miss)
#   SIMPLE_CTYPE_BENCH_CLEAN      (default: 0 — set to 1 to force native rebuild)
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
BENCH_DIR="$ROOT/test/perf/ctype"
BUILD_DIR="$ROOT/build/perf/ctype"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/bin/simple}"
SAMPLES="${SIMPLE_CTYPE_BENCH_SAMPLES:-1}"
MIN_RATIO="${SIMPLE_CTYPE_BENCH_MIN_RATIO:-0.50}"
ENFORCE="${SIMPLE_CTYPE_BENCH_ENFORCE:-0}"
CLEAN="${SIMPLE_CTYPE_BENCH_CLEAN:-0}"

mkdir -p "$BUILD_DIR"

# ---- helpers ----
median_ops_per_ms() {
    local file="$1" bench="$2"
    grep "\[ctypebench\].*bench=${bench} " "$file" \
        | sed 's/.*ops_per_ms=\([0-9]*\).*/\1/' \
        | sort -n | awk 'BEGIN{c=0;s=""} {v[c++]=$1} END{print v[int(c/2)]}'
}

checksum_value() {
    local file="$1" bench="$2"
    grep "\[ctypebench\].*bench=${bench} " "$file" \
        | tail -1 | sed 's/.*checksum=\([0-9]*\).*/\1/'
}

ratio() {
    local a="$1" b="$2"
    awk "BEGIN{if($b==0) print \"inf\"; else printf \"%.2f\", $a/$b}"
}

ratio_below() {
    local a="$1" b="$2" floor="$3"
    awk "BEGIN{exit !($b>0 && $a/$b < $floor)}"
}

run_samples() {
    local tag="$1"
    local outfile="$BUILD_DIR/${tag}.out"
    local cmd=("${@:2}")
    rm -f "$outfile"
    local s=0
    while [ "$s" -lt "$SAMPLES" ]; do
        "${cmd[@]}" >> "$outfile"
        s=$((s + 1))
    done
}

# ---- C reference ----
echo "[ctypebench] compiling C reference..."
gcc -O2 -o "$BUILD_DIR/bench_ctype_ref" "$BENCH_DIR/bench_ctype_ref.c"
run_samples c "$BUILD_DIR/bench_ctype_ref"
echo "[ctypebench] C reference done."

# ---- Simple interpreter ----
echo "[ctypebench] running Simple interpreter..."
run_samples simple_interp "$SIMPLE_BIN" run "$BENCH_DIR/bench_ctype.spl"
echo "[ctypebench] Simple interpreter done."

# ---- Simple native (optional) ----
native_ok=0
compile_log="$BUILD_DIR/native_compile.log"
native_bin="$BUILD_DIR/bench_ctype_native"
native_build_args=()
if [ "$CLEAN" = "1" ]; then
    native_build_args+=(--clean)
fi

if "$SIMPLE_BIN" native-build \
    "${native_build_args[@]}" \
    --entry "$BENCH_DIR/bench_ctype.spl" \
    --source "$ROOT/src/lib" \
    --entry-closure \
    --backend cranelift \
    --runtime-bundle core-c-bootstrap \
    -o "$native_bin" >"$compile_log" 2>&1; then
    run_samples simple_native "$native_bin"
    native_ok=1
    echo "[ctypebench] Simple native done."
else
    echo "[ctypebench-note] simple_native_compile=failed (interpreter-only comparison)"
fi

# ---- comparison table ----
BENCHES="is_digit is_upper is_lower is_alpha is_alnum is_xdigit is_space to_lower to_upper"

echo ""
if [ "$native_ok" -eq 1 ]; then
    printf "%-12s %12s %15s %15s %12s %12s\n" \
        "benchmark" "c_ops/ms" "interp_ops/ms" "native_ops/ms" "interp/c" "native/c"
else
    printf "%-12s %12s %15s %12s\n" \
        "benchmark" "c_ops/ms" "interp_ops/ms" "interp/c"
fi

warnings=""
for bench in $BENCHES; do
    c_sum="$(checksum_value "$BUILD_DIR/c.out" "$bench")"
    interp_sum="$(checksum_value "$BUILD_DIR/simple_interp.out" "$bench")"
    if [ "$c_sum" != "$interp_sum" ]; then
        echo "[ctypebench-error] checksum mismatch bench=$bench c=$c_sum interp=$interp_sum" >&2
        exit 1
    fi

    c_ops="$(median_ops_per_ms "$BUILD_DIR/c.out" "$bench")"
    interp_ops="$(median_ops_per_ms "$BUILD_DIR/simple_interp.out" "$bench")"

    if [ "$native_ok" -eq 1 ]; then
        native_sum="$(checksum_value "$BUILD_DIR/simple_native.out" "$bench")"
        if [ "$c_sum" != "$native_sum" ]; then
            echo "[ctypebench-error] checksum mismatch bench=$bench c=$c_sum native=$native_sum" >&2
            exit 1
        fi
        native_ops="$(median_ops_per_ms "$BUILD_DIR/simple_native.out" "$bench")"
        printf "%-12s %12s %15s %15s %12s %12s\n" \
            "$bench" "$c_ops" "$interp_ops" "$native_ops" \
            "$(ratio "$interp_ops" "$c_ops")x" "$(ratio "$native_ops" "$c_ops")x"
        if ratio_below "$native_ops" "$c_ops" "$MIN_RATIO"; then
            warnings="${warnings}[ctypebench-warn] bench=$bench native/c=$(ratio "$native_ops" "$c_ops")x below=${MIN_RATIO}x\n"
        fi
    else
        printf "%-12s %12s %15s %12s\n" \
            "$bench" "$c_ops" "$interp_ops" \
            "$(ratio "$interp_ops" "$c_ops")x"
    fi
done

echo ""
if [ -n "$warnings" ]; then
    printf "%b" "$warnings"
    if [ "$ENFORCE" = "1" ]; then
        echo "[ctypebench-error] ratio floor failed; set SIMPLE_CTYPE_BENCH_ENFORCE=0 to warn-only"
        exit 1
    fi
fi

echo "[ctypebench] outputs in $BUILD_DIR/"
