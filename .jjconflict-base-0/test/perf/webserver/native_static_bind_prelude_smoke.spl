# Native hosted smoke for full static server setup plus bind/close.

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn env_i64(key: text, default_value: i64) -> i64:
    val value = env_text(key, "")
    if value.len() > 0:
        value.parse_int() ?? default_value
    else:
        default_value

fn content_type(path: text) -> text:
    val lower = path.lower()
    if lower.ends_with(".html") or lower.ends_with(".htm"):
        return "text/html; charset=utf-8"
    if lower.ends_with(".css"):
        return "text/css; charset=utf-8"
    if lower.ends_with(".js"):
        return "application/javascript; charset=utf-8"
    if lower.ends_with(".json"):
        return "application/json; charset=utf-8"
    "text/plain; charset=utf-8"

fn build_response(status: text, mime: text, body: text, head_only: bool) -> text:
    var response = "HTTP/1.1 {status}\r\n"
    response = response + "Server: SimpleStaticPerf\r\n"
    response = response + "Content-Type: {mime}\r\n"
    response = response + "Content-Length: {body.len()}\r\n"
    response = response + "Connection: close\r\n"
    response = response + "\r\n"
    if not head_only:
        response = response + body
    response

fn main():
    val addr = env_text("SIMPLE_STATIC_SERVER_ADDR", "127.0.0.1:18085")
    val path = env_text("SIMPLE_STATIC_SERVER_FILE", "README.md")
    val request_limit = env_i64("SIMPLE_STATIC_SERVER_REQUESTS", 128)
    val exists = rt_file_exists(path)
    val body = if exists:
        rt_file_read_text(path)
    else:
        "missing fixture: {path}\n"
    val status = if exists: "200 OK" else: "404 Not Found"
    val mime = content_type(path)
    val get_response = build_response(status, mime, body, false)
    val head_response = build_response(status, mime, body, true)
    val method_response = build_response("405 Method Not Allowed", "text/plain; charset=utf-8", "method not allowed\n", false)
    val listener = rt_io_tcp_bind(addr)
    if listener < 0:
        print "[native-static-bind-prelude-smoke] bind_error addr={addr}"
        return
    val _closed = rt_io_tcp_close(listener)
    print "[native-static-bind-prelude-smoke] ok addr={addr} requests={request_limit} get={get_response.len()} head={head_response.len()} method={method_response.len()}"
