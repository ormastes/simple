# Native hosted FFI smoke for the static webserver's env/file hot path.
#
# This isolates the hosted externs used before the TCP accept loop so native
# crashes can be tied to one bridge instead of the full server.

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn main():
    val path = env_text("SIMPLE_STATIC_SERVER_FILE", "README.md")
    val exists = rt_file_exists(path)
    val body = if exists:
        rt_file_read_text(path)
    else:
        "missing"
    print "[native-hosted-ffi-smoke] path={path} exists={exists} bytes={body.len()}"
