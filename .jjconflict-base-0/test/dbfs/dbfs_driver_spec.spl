# Maps to: AC-2, AC-8, AC-9
# Run: bin/simple test test/dbfs/dbfs_driver_spec.spl

"""
DBFS FsDriver Seam Specification

Verifies DbFsDriver implements the FsDriver trait via MountTable:
  open, read, write, stat, readdir, mkdir, unlink, rename
"""

use std.spipe.*
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.ops.{FsDriver}
use std.fs_driver.types.{Path, OpenFlags, MountOptions, FileHandle, DirHandle, StatInfo}
use std.fs_driver.error.{FsError}
use std.fs_driver.mount_table.{MountTable}
use std.db.dbfs_driver.{DbFsDriver}

fn make_mounted() -> MountTable:
    val driver = DbFsDriver.new_hosted()
    val mt = MountTable.new()
    mt.mount("/data", DriverInstance.DbFs(driver), MountOptions.default()).unwrap()
    mt

describe "DBFS FsDriver — mkdir and stat":
    it "mkdir creates directory; stat returns is_dir=true":
        val mt = make_mounted()
        mt.mkdir("/data/mydir", 0o755).unwrap()
        val info = mt.stat("/data/mydir").unwrap()
        expect(info.is_dir).to_equal(true)

    it "stat on missing path returns error":
        val mt = make_mounted()
        val r = mt.stat("/data/ghost")
        expect(r.is_err()).to_equal(true)

describe "DBFS FsDriver — open, write, read":
    it "open with create_write creates file":
        val mt = make_mounted()
        val fh = mt.open("/data/hello.txt", OpenFlags.create_write()).unwrap()
        expect(fh.id > 0).to_equal(true)

    it "write then read round-trips content":
        val mt = make_mounted()
        val fh = mt.open("/data/rw.txt", OpenFlags.create_write()).unwrap()
        mt.write(fh, "hello dbfs").unwrap()
        val fh2 = mt.open("/data/rw.txt", OpenFlags.read_only()).unwrap()
        val got = mt.read(fh2, 10).unwrap()
        expect(got).to_equal("hello dbfs")

    it "read on closed handle returns error":
        val mt = make_mounted()
        val fh = mt.open("/data/tmp.txt", OpenFlags.create_write()).unwrap()
        mt.close(fh).unwrap()
        val r = mt.read(fh, 5)
        expect(r.is_err()).to_equal(true)

describe "DBFS FsDriver — readdir":
    it "readdir on mounted dir returns created entries":
        val mt = make_mounted()
        mt.mkdir("/data/alpha", 0o755).unwrap()
        mt.mkdir("/data/beta", 0o755).unwrap()
        val dh = mt.opendir("/data").unwrap()
        val entries = mt.readdir(dh).unwrap()
        expect(entries.len() >= 2).to_equal(true)

describe "DBFS FsDriver — unlink and rename":
    it "unlink removes file; stat returns error":
        val mt = make_mounted()
        val fh = mt.open("/data/del.txt", OpenFlags.create_write()).unwrap()
        mt.close(fh).unwrap()
        mt.unlink("/data/del.txt").unwrap()
        val r = mt.stat("/data/del.txt")
        expect(r.is_err()).to_equal(true)

    it "rename moves file; old path gone, new path exists":
        val mt = make_mounted()
        val fh = mt.open("/data/old.txt", OpenFlags.create_write()).unwrap()
        mt.close(fh).unwrap()
        mt.rename("/data/old.txt", "/data/new.txt").unwrap()
        val old_r = mt.stat("/data/old.txt")
        val new_r = mt.stat("/data/new.txt")
        expect(old_r.is_err()).to_equal(true)
        expect(new_r.is_ok()).to_equal(true)
