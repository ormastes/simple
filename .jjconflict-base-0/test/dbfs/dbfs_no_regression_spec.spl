# Maps to: AC-8, AC-9
# Run: bin/simple test test/dbfs/dbfs_no_regression_spec.spl

"""
DBFS Hosted Seam Specification

Runs the same hosted mount-table contract as FAT32 so DBFS stays compatible
with shared filesystem regression coverage.
"""

use std.spipe.*
use std.fs_driver.types.{MountOptions}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.mount_table.{MountTable}
use std.db.dbfs_driver.{DbFsDriver}
use test.dbfs.hosted_fs_no_regression_shared.{
    assert_mount_root_is_dir,
    assert_mount_root_slash_is_dir,
    assert_readdir_on_root_is_stable,
    assert_open_returns_handle,
    assert_read_returns_empty_or_better
}

fn make_dbfs_mounted() -> MountTable:
    val mt = MountTable.new()
    val dbfs = DbFsDriver.new_hosted()
    mt.mount("/data", DriverInstance.DbFs(dbfs), MountOptions.default()).unwrap()
    mt

describe "DBFS hosted seam — mount and stat":
    it "DBFS volume mounts without error":
        val mt = make_dbfs_mounted()
        assert_mount_root_is_dir(mt, "/data")

    it "stat on DBFS root returns is_dir=true":
        val mt = make_dbfs_mounted()
        assert_mount_root_slash_is_dir(mt, "/data")

describe "DBFS hosted seam — readdir and open":
    it "readdir on DBFS root returns a stable empty-or-better listing":
        val mt = make_dbfs_mounted()
        assert_readdir_on_root_is_stable(mt, "/data")

    it "open on a DBFS path returns a valid handle":
        val mt = make_dbfs_mounted()
        assert_open_returns_handle(mt, "/data/README.TXT")

    it "read on DBFS returns empty content rather than erroring":
        val mt = make_dbfs_mounted()
        assert_read_returns_empty_or_better(mt, "/data/README.TXT")
