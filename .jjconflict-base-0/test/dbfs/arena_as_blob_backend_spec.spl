# Maps to: AC-4, AC-9
# Run: bin/simple test test/dbfs/arena_as_blob_backend_spec.spl

"""
Arena Core Conformance Specification

Verifies the live NVFS arena core helpers still provide the blob-backend verbs
used by the hosted DBFS/NVFS path:
  - create / append / read / seal / discard / clone_range / preferred_granule
"""

use std.spipe.*
use examples.nvfs.src.core.arena.{
    arena_create_impl, arena_append_impl, arena_readv_impl,
    arena_seal_impl, arena_discard_impl,
    arena_clone_range_impl, arena_preferred_granule_impl
}

fn run_conformance_suite(class_tag: i32):
    val h = arena_create_impl(class_tag, 65536)
    expect(h > 0).to_equal(true)

    val data: [u8] = [0x01, 0x02, 0x03, 0x04]
    val written = arena_append_impl(h, data, 0)
    expect(written).to_equal(4)

    val buf = arena_readv_impl(h, 0, 4)
    expect(buf.len()).to_equal(4)
    expect(buf[0]).to_equal(0x01)
    expect(buf[3]).to_equal(0x04)

    val gran = arena_preferred_granule_impl(h)
    expect(gran > 0).to_equal(true)

    val sealed = arena_seal_impl(h, 1)
    expect(sealed).to_equal(true)

    val h2 = arena_create_impl(class_tag, 4096)
    expect(arena_discard_impl(h2)).to_equal(true)

describe "Arena core conformance":
    it "general-mutable arena passes full conformance suite":
        run_conformance_suite(0)

    it "clone_range copies data correctly":
        val src = arena_create_impl(0, 4096)
        val payload: [u8] = [0xAB, 0xCD]
        expect(arena_append_impl(src, payload, 0)).to_equal(2)
        val dst = arena_create_impl(0, 4096)
        expect(arena_clone_range_impl(src, 0, dst, 0, 2)).to_equal(2)
        val out = arena_readv_impl(dst, 0, 2)
        expect(out[0]).to_equal(0xAB)
        expect(out[1]).to_equal(0xCD)

    it "preferred_granule is at least 512":
        val h = arena_create_impl(0, 4096)
        expect(arena_preferred_granule_impl(h) >= 512).to_equal(true)
