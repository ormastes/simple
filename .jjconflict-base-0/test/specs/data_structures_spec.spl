use std.spec
use std.spec.{expect}

struct Vector2:
    x: i64
    y: i64

impl Vector2:
    static fn new(x: i64, y: i64) -> Vector2:
        Vector2(x: x, y: y)

    fn manhattan() -> i64:
        self.x + self.y

class Counter:
    value: i64

    static fn new(value: i64) -> Counter:
        Counter(value: value)

    me inc():
        self.value = self.value + 1

    me add(amount: i64):
        self.value = self.value + amount

    fn current() -> i64:
        self.value

class PropertyBox:
    name: text
    enabled: bool
    secret: text

    static fn new(name: text, enabled: bool, secret: text) -> PropertyBox:
        PropertyBox(name: name, enabled: enabled, secret: secret)

    fn is_enabled() -> bool:
        self.enabled

    me set_name(name: text):
        self.name = name

    me set_secret(secret: text):
        self.secret = secret

    fn label() -> text:
        val state = if self.enabled:
            "on"
        else:
            "off"
        "{self.name}:{state}"

enum MaybeNumber:
    Some(value: i64)
    None

impl MaybeNumber:
    fn is_some() -> bool:
        match self:
            case Some(_): true
            case None: false

    fn unwrap_or(default: i64) -> i64:
        match self:
            case Some(value): value
            case None: default

enum ResultValue:
    Ok(value: i64)
    Err(message: text)

impl ResultValue:
    fn is_ok() -> bool:
        match self:
            case Ok(_): true
            case Err(_): false

    fn unwrap_or(default: i64) -> i64:
        match self:
            case Ok(value): value
            case Err(_): default

    fn message() -> text:
        match self:
            case Ok(value): "ok:{value}"
            case Err(message): message

enum TrafficLight:
    Red
    Amber
    Green

impl TrafficLight:
    fn next() -> TrafficLight:
        match self:
            case Red: TrafficLight.Amber
            case Amber: TrafficLight.Green
            case Green: TrafficLight.Red

    fn label() -> text:
        match self:
            case Red: "red"
            case Amber: "amber"
            case Green: "green"

enum Color:
    Red
    Green
    Blue

impl Color:
    fn label() -> text:
        match self:
            case Red: "red"
            case Green: "green"
            case Blue: "blue"

enum TextOrNumber:
    Text(value: text)
    Number(value: i64)

impl TextOrNumber:
    fn describe() -> text:
        match self:
            case Text(value): "text:{value}"
            case Number(value): "number:{value}"

class AccessBox:
    public_value: i64
    _private_value: i64

    static fn new(public_value: i64, private_value: i64) -> AccessBox:
        AccessBox(public_value: public_value, _private_value: private_value)

    fn expose() -> i64:
        self.public_value + self._private_value

class BitRegister:
    raw: i64

    static fn new(raw: i64) -> BitRegister:
        BitRegister(raw: raw)

    me set_flag(mask: i64):
        self.raw = self.raw | mask

    me clear_flag(mask: i64):
        self.raw = self.raw & (255 - mask)

    fn has_flag(mask: i64) -> bool:
        (self.raw & mask) != 0

    me write_field(mask: i64, shift: i64, value: i64):
        val cleared = self.raw & (255 - mask)
        val encoded = (value << shift) & mask
        self.raw = cleared | encoded

    fn read_field(mask: i64, shift: i64) -> i64:
        (self.raw & mask) >> shift

fn same_vector(left: Vector2, right: Vector2) -> bool:
    left.x == right.x and left.y == right.y

fn add_checked(left: i64, right: i64) -> ResultValue:
    ResultValue.Ok(left + right)

fn describe_optional_number(value: MaybeNumber) -> text:
    match value:
        case MaybeNumber.Some(v): "some:{v}"
        case MaybeNumber.None: "none"

fn describe_result(result: ResultValue) -> text:
    match result:
        case ResultValue.Ok(value): "ok:{value}"
        case ResultValue.Err(message): "err:{message}"

fn describe_color(color: Color) -> text:
    color.label()

fn describe_light(light: TrafficLight) -> text:
    light.label()

fn describe_union(value: TextOrNumber) -> text:
    value.describe()

fn describe_register(register: BitRegister) -> text:
    "raw:{register.raw}"

fn is_wide_field(value: i64) -> bool:
    value > 15

describe "Data Structures Spec":
    it "structs_value_types_1":
        val p = Vector2.new(2, 3)
        expect(same_vector(p, Vector2.new(2, 3))).to_equal(true)
        expect(p.manhattan()).to_equal(5)

    it "structs_value_types_2":
        val p = Vector2.new(4, 1)
        expect(same_vector(p, Vector2.new(4, 1))).to_equal(true)
        expect(p.manhattan()).to_equal(5)

    it "classes_reference_types_3":
        val left = Counter.new(1)
        val right = left
        right.inc()
        expect(left.current()).to_equal(2)

    it "classes_reference_types_4":
        val counter = Counter.new(10)
        counter.add(5)
        expect(counter.current()).to_equal(15)

    it "classes_reference_types_5":
        val left = Counter.new(1)
        val right = Counter.new(1)
        right.inc()
        expect(left.current()).to_equal(1)
        expect(right.current()).to_equal(2)

    it "auto_forwarding_properties_getsetis_6":
        val box = PropertyBox.new("alpha", true, "hidden")
        expect(box.is_enabled()).to_equal(true)
        expect(box.label()).to_equal("alpha:on")

    it "auto_forwarding_properties_getsetis_7":
        val box = PropertyBox.new("beta", false, "hidden")
        box.set_name("gamma")
        expect(box.label()).to_equal("gamma:off")

    it "auto_forwarding_properties_getsetis_8":
        val box = PropertyBox.new("delta", true, "secret")
        box.set_secret("changed")
        expect(box.secret).to_equal("changed")

    it "enums_algebraic_data_types_9":
        val value = MaybeNumber.Some(9)
        expect(value.is_some()).to_equal(true)
        expect(value.unwrap_or(0)).to_equal(9)

    it "enums_algebraic_data_types_10":
        expect(describe_optional_number(MaybeNumber.Some(4))).to_equal("some:4")
        expect(describe_optional_number(MaybeNumber.None)).to_equal("none")

    it "enums_algebraic_data_types_11":
        expect(describe_color(Color.Red)).to_equal("red")
        expect(describe_color(Color.Green)).to_equal("green")
        expect(describe_color(Color.Blue)).to_equal("blue")

    it "enums_algebraic_data_types_12":
        expect(describe_union(TextOrNumber.Text("hello"))).to_equal("text:hello")
        expect(describe_union(TextOrNumber.Number(7))).to_equal("number:7")

    it "strong_enums_13":
        expect(describe_light(TrafficLight.Red.next().next().next())).to_equal("red")

    it "strong_enums_14":
        val start = TrafficLight.Green
        expect(describe_light(start.next().next())).to_equal("red")

    it "strong_enums_15":
        expect(describe_light(TrafficLight.Amber.next())).to_equal("green")

    it "union_types_16":
        expect(describe_union(TextOrNumber.Text("alpha"))).to_equal("text:alpha")
        expect(describe_union(TextOrNumber.Number(11))).to_equal("number:11")

    it "option_type_17":
        val some = MaybeNumber.Some(42)
        expect(some.is_some()).to_equal(true)
        expect(some.unwrap_or(0)).to_equal(42)

    it "option_type_18":
        val none = MaybeNumber.None
        expect(none.is_some()).to_equal(false)
        expect(none.unwrap_or(17)).to_equal(17)

    it "visibility_and_access_19":
        val record = AccessBox.new(7, 5)
        expect(record.expose()).to_equal(12)
        expect(record.public_value).to_equal(7)

    it "result_type_20":
        val result = add_checked(3, 4)
        expect(result.is_ok()).to_equal(true)
        expect(result.unwrap_or(0)).to_equal(7)

    it "result_type_21":
        val result = add_checked(8, 9)
        expect(describe_result(result)).to_equal("ok:17")

    it "result_type_22":
        val ok = ResultValue.Ok(5)
        val err = ResultValue.Err("broken")
        expect(ok.message()).to_equal("ok:5")
        expect(err.message()).to_equal("broken")

    it "result_type_23":
        val maybe = MaybeNumber.Some(6)
        val result = add_checked(maybe.unwrap_or(0), 1)
        expect(result.unwrap_or(0)).to_equal(7)

    it "bitfields_24":
        val register = BitRegister.new(0)
        expect(describe_register(register)).to_equal("raw:0")

    it "bitfields_25":
        val register = BitRegister.new(0)
        register.set_flag(1)
        expect(register.has_flag(1)).to_equal(true)

    it "bitfields_26":
        val register = BitRegister.new(0)
        register.write_field(12, 2, 3)
        expect(register.read_field(12, 2)).to_equal(3)

    it "bitfields_27":
        val register = BitRegister.new(0)
        register.set_flag(4)
        register.clear_flag(4)
        expect(register.has_flag(4)).to_equal(false)

    it "bitfields_28":
        val register = BitRegister.new(0)
        register.write_field(48, 4, 2)
        expect(register.read_field(48, 4)).to_equal(2)

    it "bitfields_29":
        val register = BitRegister.new(0)
        register.write_field(240, 4, 9)
        expect(is_wide_field(register.read_field(240, 4))).to_equal(false)

    it "bitfields_30":
        val register = BitRegister.new(0)
        register.write_field(240, 4, 15)
        expect(register.read_field(240, 4)).to_equal(15)

    it "bitfields_31":
        val register = BitRegister.new(0)
        register.write_field(15, 0, 7)
        expect(register.read_field(15, 0)).to_equal(7)

    it "bitfields_32":
        val register = BitRegister.new(0)
        register.write_field(240, 4, 16)
        expect(register.read_field(240, 4)).to_equal(0)
