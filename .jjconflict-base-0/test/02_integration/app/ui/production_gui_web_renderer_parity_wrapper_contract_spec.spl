use app.io.mod.{file_read_text, getpid, process_run, time_now_unix_micros}

fn run_wrapper_with_resume(resume_value: text) -> text:
    val root = "build/test-production-gui-web-renderer-parity-wrapper-{getpid()}-{time_now_unix_micros()}"
    val stub_dir = "test/fixtures/scripts/production_gui_web_renderer_parity_stubs"
    val build_root = root + "/evidence"
    val report_path = root + "/report.md"

    var cmd = "BUILD_ROOT=" + build_root
    cmd = cmd + " REPORT_PATH=" + report_path
    cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_MATRIX_SCRIPT=" + stub_dir + "/matrix.shs"
    cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_LAYOUT_SCRIPT=" + stub_dir + "/layout.shs"
    cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_SURFACE_SCRIPT=" + stub_dir + "/surface.shs"
    cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_BACKEND_SCRIPT=" + stub_dir + "/backend.shs"
    cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_FONT_OFFLOAD_SCRIPT=" + stub_dir + "/font.shs"
    cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_METAL_READBACK_SCRIPT=" + stub_dir + "/metal.shs"
    if resume_value != "":
        cmd = cmd + " PRODUCTION_GUI_WEB_RENDERER_PARITY_LAYOUT_MANIFEST_RESUME=" + resume_value
    cmd = cmd + " sh scripts/check/check-production-gui-web-renderer-parity-evidence.shs"

    val result = process_run("sh", ["-c", cmd])
    expect(result.2).to_equal(0)
    file_read_text(build_root + "/evidence.env") ?? ""

describe "production GUI web renderer parity wrapper contract":

    it "forwards fresh layout-manifest mode by default":
        val evidence = run_wrapper_with_resume("")
        expect(evidence).to_contain("production_gui_web_renderer_parity_status=pass")
        expect(evidence).to_contain("layout_layout_resume_seen=0")

    it "forwards layout-manifest resume only through the production override":
        val evidence = run_wrapper_with_resume("1")
        expect(evidence).to_contain("production_gui_web_renderer_parity_status=pass")
        expect(evidence).to_contain("layout_layout_resume_seen=1")
