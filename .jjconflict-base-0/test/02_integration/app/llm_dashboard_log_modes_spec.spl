use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_llm_dashboard(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_BIN=\"$SIMPLE_BINARY\"; if [ -z \"$SIMPLE_BIN\" ]; then if [ -x \"$REPO/bin/simple\" ]; then SIMPLE_BIN=\"$REPO/bin/simple\"; else SIMPLE_BIN=\"$REPO/release/x86_64-unknown-linux-gnu/simple\"; fi; fi; SIMPLE_LIB=\"$REPO/src\" \"$SIMPLE_BIN\" run \"$REPO/src/app/llm_dashboard/main.spl\" " + joined
    ])

describe "llm dashboard log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_llm_dashboard(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("LLM Agent Dashboard")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for ready tui output":
        val (out, err, code) = _run_llm_dashboard(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"llm-dashboard\"")
        expect(out).to_contain("\"status\":\"ready\"")
        expect(out).to_contain("\"mode\":\"tui\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_llm_dashboard(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("LLM Agent Dashboard")

    it "rejects invalid log mode":
        val (out, err, code) = _run_llm_dashboard(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "preserves gui mode argument parsing with shared options stripped":
        val (out, err, code) = _run_llm_dashboard(["--log-mode=json", "--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("LLM Agent Dashboard")
        expect(out).to_contain("--gui, --web")
