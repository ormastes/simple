use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_bug_add_resolve_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/doc/08_tracking/bug && cat > " + FIXTURE_DIR + "/doc/08_tracking/bug/bug_db.sdn <<'EOF'\nbugs_active |id, severity, status, title, file, line, reproducible_by, created_at, updated_at, valid|\n\nbugs |id, severity, status, title, file, line, reproducible_by, created_at, updated_at, valid|\n\nbug_descriptions |bug_id, line_num, content|\n\nbug_fix_strategies |bug_id, line_num, content|\n\nbug_investigation_logs |bug_id, line_num, content|\nEOF"
    ])

fn _run_bug_add(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/bug_add/main.spl\" " + joined
    ])

fn _run_bug_resolve(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/bug_resolve/main.spl\" " + joined
    ])

describe "bug add and resolve log mode CLI options":
    it "bug-add shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_bug_add(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "bug-resolve shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_bug_resolve(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "bug-add supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_bug_add(["--id=log_mode_bug_001", "--severity=p2", "--title=fixture", "--file=src/main.spl", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"bug-add\"")
        expect(out).to_contain("\"id\":\"log_mode_bug_001\"")

    it "bug-resolve supports log-mode json":
        _setup_fixture()
        val (_add_out, _add_err, _add_code) = _run_bug_add(["--id=log_mode_bug_002", "--severity=p2", "--title=fixture", "--file=src/main.spl"])
        val (out, err, code) = _run_bug_resolve(["--id=log_mode_bug_002", "--date=2026-05-24", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"bug-resolve\"")
        expect(out).to_contain("\"id\":\"log_mode_bug_002\"")

    it "bug-add supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_bug_add(["--id=log_mode_bug_003", "--severity=p2", "--title=fixture", "--file=src/main.spl", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Added bug log_mode_bug_003")

    it "bug-add rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_bug_add(["--id=log_mode_bug_004", "--title=fixture", "--log-mode=noisy"])
        expect(code).to_equal(1)

    it "bug-resolve rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_bug_resolve(["--id=log_mode_bug_004", "--log-mode=noisy"])
        expect(code).to_equal(1)
