use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_todo_gen_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/doc/08_tracking/todo && cat > " + FIXTURE_DIR + "/doc/08_tracking/todo/todo_db.sdn <<'EOF'\ntodos |id, keyword, area, priority, description, file, line, issue, blocked, status, valid|\n    1, TODO, runtime, P1, \"fixture todo\", src/main.spl, 3, 42, \"\", open, true\nEOF"
    ])

fn _run_todo_gen(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/todo_gen/main.spl\" " + joined
    ])

describe "todo-gen log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_todo_gen(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_todo_gen(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"todo-gen\"")
        expect(out).to_contain("\"todos\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_todo_gen(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Generated doc/TODO.md (1 items)")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_todo_gen(["--log-mode=noisy"])
        expect(code).to_equal(1)
