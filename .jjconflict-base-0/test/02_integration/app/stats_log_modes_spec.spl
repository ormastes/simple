use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_stats(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/stats/main.spl\" " + joined
    ])

describe "stats log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_stats(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple stats")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        val (out, err, code) = _run_stats(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"stats\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"files\":")

    it "supports dot progress for help output":
        val (out, err, code) = _run_stats(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple stats")

    it "rejects invalid log mode":
        val (out, err, code) = _run_stats(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "prints human statistics by default":
        val (out, err, code) = _run_stats([])
        expect(code).to_equal(0)
        expect(out).to_contain("Project statistics")
        expect(out).to_contain("Files scanned:")
