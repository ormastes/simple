"""Vulkan Strict Smoke Tests

@tag: rendering, engine2d, vulkan, strict, hardware
@cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl 70%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_spirv.spl 80%
@cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 20%

Strictly gates real hardware execution when Vulkan initializes: shader module
load, compute pipeline creation, kernel dispatch, device sync, and pixel
readback must all work before parity assertions run. Surfaces device
diagnostics via BackendProbeResult.

On non-Vulkan hosts, asserts the BackendProbeResult carries a typed
Failed status rather than silently succeeding.
On Vulkan hosts where initialization succeeds, runs the full clear ->
draw_rect_filled -> present -> readback pipeline against a CPU reference for a
16x16 framebuffer. This spec must not be read as proof that current SPIR-V
placeholder blobs provide Vulkan parity.
"""

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}

# ============================================================================
# Helpers
# ============================================================================

fn status_is_terminal_failure(probe: BackendProbeResult) -> bool:
    """True when the probe status is Failed or Unavailable (not Initialized)."""
    probe.status == BackendStatus.Failed or probe.status == BackendStatus.Unavailable

fn color_blue_u32() -> u32:
    """ARGB packed blue: 0xFF0000FF"""
    0xFF0000FFu32

fn color_red_u32() -> u32:
    """ARGB packed red: 0xFFFF0000"""
    0xFFFF0000u32

fn build_cpu_reference(w: i32, h: i32, bg: u32, fg: u32, rx: i32, ry: i32, rw: i32, rh: i32) -> [u32]:
    """Build a CPU reference framebuffer for parity comparison."""
    var buf = [bg; w * h]
    var py = ry
    while py < ry + rh:
        var px = rx
        while px < rx + rw:
            if px >= 0 and px < w and py >= 0 and py < h:
                buf[py * w + px] = fg
            px = px + 1
        py = py + 1
    buf

fn probe_vulkan() -> BackendProbeResult:
    """Probe the Vulkan backend availability without allocating a full engine."""
    Engine2D.probe_backend(16, 16, "vulkan")

# ============================================================================
# Tests
# ============================================================================

describe "Vulkan strict smoke tests":

    context "probe_vulkan device diagnostics":

        it "probe_vulkan returns a typed BackendProbeResult":
            val probe = probe_vulkan()
            val ok = probe.is_ok() or status_is_terminal_failure(probe)
            expect(ok).to_equal(true)

        it "probe_vulkan reports requested_name as vulkan":
            val probe = probe_vulkan()
            expect(probe.requested_name).to_equal("vulkan")

        it "probe_vulkan on success reports api_name as vulkan":
            val probe = probe_vulkan()
            if probe.is_ok():
                expect(probe.api_name).to_equal("vulkan")

        it "probe_vulkan on failure carries non-empty fallback_reason":
            val probe = probe_vulkan()
            if not probe.is_ok():
                expect(probe.fallback_reason).to_not_equal("")

        it "probe_vulkan diagnostic_text is non-empty":
            val probe = probe_vulkan()
            val txt = probe.diagnostic_text()
            expect(txt.len()).to_be_greater_than(0)

    context "create_with_backend_strict vulkan unavailable path":

        it "fails with typed error when Vulkan is not available":
            val probe = probe_vulkan()
            if not probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                expect(result.is_ok()).to_equal(false)
                val diag = result.unwrap_err()
                val failed_or_unavail = status_is_terminal_failure(diag)
                expect(failed_or_unavail).to_equal(true)
                expect(diag.requested_name).to_equal("vulkan")

        it "fallback_reason is non-empty when Vulkan fails":
            val probe = probe_vulkan()
            if not probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if not result.is_ok():
                    val diag = result.unwrap_err()
                    expect(diag.fallback_reason).to_not_equal("")

        it "does not silently fall back to cpu on Vulkan failure":
            val probe = probe_vulkan()
            if not probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                expect(result.is_ok()).to_equal(false)

    context "create_with_backend_strict vulkan hardware path":

        it "succeeds and returns Engine2D when hardware available":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                expect(result.is_ok()).to_equal(true)
                var engine = result.unwrap()
                expect(engine.width()).to_equal(16)
                expect(engine.height()).to_equal(16)
                engine.shutdown()

        it "backend_name is vulkan when hardware available":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    expect(engine.backend_name()).to_equal("vulkan")
                    engine.shutdown()

        it "SPIR-V shader modules load without error when hardware available":
            val probe = probe_vulkan()
            if probe.is_ok():
                # A successful init() implies all spirv_* blobs were accepted by the driver
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                expect(result.is_ok()).to_equal(true)
                if result.is_ok():
                    var engine = result.unwrap()
                    engine.shutdown()

    context "clear pixel parity with CPU reference":

        it "clear fills entire framebuffer with the given color":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val fill_color = color_blue_u32()
                    engine.clear(fill_color)
                    engine.present()
                    val pixels = engine.read_pixels()
                    # Check first, middle, and last pixel
                    expect(pixels[0]).to_equal(fill_color)
                    expect(pixels[127]).to_equal(fill_color)
                    expect(pixels[255]).to_equal(fill_color)
                    engine.shutdown()

        it "clear matches CPU reference pixel-for-pixel":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val fill_color = color_blue_u32()
                    engine.clear(fill_color)
                    engine.present()
                    val pixels = engine.read_pixels()
                    var mismatch_count = 0
                    var ci = 0
                    while ci < 256:
                        if pixels[ci] != fill_color:
                            mismatch_count = mismatch_count + 1
                        ci = ci + 1
                    expect(mismatch_count).to_equal(0)
                    engine.shutdown()

    context "draw_rect_filled pixel parity with CPU reference":

        it "checked clear and rect return exact device-backed readback before present":
            val probe = probe_vulkan()
            if probe.is_ok():
                var backend = VulkanBackend.create()
                val initialized = backend.init(16, 16)
                expect(initialized).to_equal(true)
                if initialized:
                    val bg = color_blue_u32()
                    val fg = color_red_u32()
                    backend.clear(bg)
                    backend.draw_rect_filled(2, 2, 6, 6, fg)
                    val readback = backend.read_pixels_with_source()
                    val cpu_ref = build_cpu_reference(16, 16, bg, fg, 2, 2, 6, 6)
                    var mismatch_count = 0
                    expect(readback.pixels.len()).to_equal(256)
                    if readback.pixels.len() == 256:
                        var ci = 0
                        while ci < 256:
                            if readback.pixels[ci] != cpu_ref[ci]:
                                mismatch_count = mismatch_count + 1
                            ci = ci + 1
                    expect(mismatch_count).to_equal(0)
                    expect(readback.source).to_equal("device_readback")
                    expect(readback.backend_handle).to_be_greater_than(0)
                    expect(backend.cpu_fallback_used).to_equal(false)
                    expect(backend.completion_unknown).to_equal(false)
                    backend.shutdown()

        it "draw_rect_filled writes correct pixels in the rect region":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val bg = color_blue_u32()
                    val fg = color_red_u32()
                    # Clear to blue, draw 4x4 red rect at (4,4)
                    engine.clear(bg)
                    engine.draw_rect_filled(4, 4, 4, 4, fg)
                    engine.present()
                    val pixels = engine.read_pixels()
                    # Pixel at (6,6) must be inside the rect (red)
                    val inside = pixels[6 * 16 + 6]
                    expect(inside).to_equal(fg)
                    # Pixel at (0,0) must be outside rect (blue)
                    val outside = pixels[0]
                    expect(outside).to_equal(bg)
                    engine.shutdown()

        it "clear then draw_rect_filled matches CPU reference pixel-for-pixel":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val bg = color_blue_u32()
                    val fg = color_red_u32()
                    engine.clear(bg)
                    engine.draw_rect_filled(2, 2, 6, 6, fg)
                    engine.present()
                    val pixels = engine.read_pixels()
                    # Build CPU reference
                    val cpu_ref = build_cpu_reference(16, 16, bg, fg, 2, 2, 6, 6)
                    var mismatch_count = 0
                    var ci = 0
                    while ci < 256:
                        if pixels[ci] != cpu_ref[ci]:
                            mismatch_count = mismatch_count + 1
                        ci = ci + 1
                    expect(mismatch_count).to_equal(0)
                    engine.shutdown()

        it "rect outside framebuffer bounds does not corrupt surrounding pixels":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val bg = color_blue_u32()
                    val fg = color_red_u32()
                    engine.clear(bg)
                    # Draw rect that starts at (14,14) with size (8,8) — mostly out of bounds
                    engine.draw_rect_filled(14, 14, 8, 8, fg)
                    engine.present()
                    val pixels = engine.read_pixels()
                    # Pixel at (0,0) must still be blue
                    expect(pixels[0]).to_equal(bg)
                    engine.shutdown()

    context "sync and readback correctness":

        it "read_pixels after present reflects latest draw":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val first_color = color_blue_u32()
                    val second_color = color_red_u32()
                    engine.clear(first_color)
                    engine.present()
                    val pixels_first = engine.read_pixels()
                    expect(pixels_first[0]).to_equal(first_color)
                    engine.clear(second_color)
                    engine.present()
                    val pixels_second = engine.read_pixels()
                    expect(pixels_second[0]).to_equal(second_color)
                    engine.shutdown()

        it "present idempotent — second present same content":
            val probe = probe_vulkan()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
                if result.is_ok():
                    var engine = result.unwrap()
                    val fill_color = color_red_u32()
                    engine.clear(fill_color)
                    engine.present()
                    val p1 = engine.read_pixels()
                    engine.present()
                    val p2 = engine.read_pixels()
                    expect(p1[0]).to_equal(p2[0])
                    expect(p1[255]).to_equal(p2[255])
                    engine.shutdown()
