# GPU-offload evidence harness: live-GUI paint -> Engine2D Metal dispatch.
#
# Proves, with honest provenance, that the GUI raster work (the same primitive
# ops the widget showcase and WM compositor issue) can be offloaded to a single
# PERSISTENT Metal session reused across frames, and reports an honest per-
# resolution perf verdict (CPU software vs Metal, with a draw/readback phase
# breakdown) plus the session-reuse-vs-per-frame-create delta.
#
# Not an SSpec: the engine2d GPU module graph segfaults the test runner on
# import (same reason engine2d_cpu_metal_parity_run.spl is a `run` harness), so
# this is driven via `bin/simple run ... --mode=interpreter` by the check gate
# scripts/check/check-engine2d-gpu-offload-evidence.shs.
#
# Honesty gates (guarding this area's history of false-greens):
#   - Metal readback source MUST be device_readback (gpu_frame_complete==true);
#     a CPU-mirror readback is reported as such and FAILS the parity gate.
#   - CPU and Metal frames are produced by independent backends, never one
#     renderer compared to itself.
#   - Perf uses the checksum-free read_pixels() so the O(n) interpreted checksum
#     loop does not distort the numbers; provenance uses read_pixels_with_source
#     once at a small resolution.

use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend.{Engine2DReadback}
use std.gc_async_mut.gpu.engine2d.backend_metal.{MetalBackend}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.nogc_sync_mut.io.time_ops.{time_now_micros}
use std.env.variables.{env_get}
use os.compositor.host_compositor_entry.{HostCompositor, HostedWindow, host_wm_force_direct_chrome}
use os.compositor.compositor_engine2d.{Engine2dCompositorBackend}
use common.window_protocol.geometry.{Size}

var _failures = 0

# ---------------------------------------------------------------------------
# Canonical GUI paint scenes (shared by CPU and Metal so the scene is identical)
# ---------------------------------------------------------------------------

# Primitive-only scene (clear/rect/rect_filled/line/circle/circle_filled/
# triangle_filled/gradient) — every op here is already proven bit-exact CPU vs
# Metal by engine2d_cpu_metal_parity_run.spl. Deliberately excludes draw_text
# (measured separately) and draw_rounded_rect (a known software-outline bug,
# D2 matrix line 227). Tiles a 130px cell across the surface so op-count scales
# with resolution the way a real GUI frame does.
fn paint_primitives(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF0F172A as u32)
    val tile = 130
    var ty = 0
    while (ty + tile) <= h:
        var tx = 0
        while (tx + tile) <= w:
            b.draw_rect_filled(tx + 5, ty + 5, 100, 60, 0xFF2563EB as u32)
            b.draw_rect(tx + 5, ty + 5, 100, 60, 0xFFFFFFFF as u32)
            b.draw_line(tx + 5, ty + 75, tx + 105, ty + 75, 0xFF64748B as u32, 2)
            b.draw_circle(tx + 20, ty + 100, 14, 0xFF22C55E as u32)
            b.draw_circle_filled(tx + 60, ty + 100, 10, 0xFFF59E0B as u32)
            b.draw_triangle_filled(tx + 80, ty + 85, tx + 105, ty + 85, tx + 92, ty + 120, 0xFFEF4444 as u32)
            b.draw_gradient_rect(tx + 5, ty + 118, 100, 8, 0xFF111111 as u32, 0xFF999999 as u32)
            tx = tx + tile
        ty = ty + tile

# Text scene — a few strings at the showcase's font size. draw_text on Metal
# dispatches ONE kernel_glyph_atlas_blit per call (GPU-dict use case #2,
# design doc/05_design/ui/rendering/cpu_gpu_dual_algorithm_design.md W4) —
# formerly one kernel_draw_rect_filled dispatch PER LIT GLYPH PIXEL. This
# scene exists to measure text parity + text dispatch cost honestly and
# separately from the primitive scene.
fn paint_text(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF000000 as u32)
    b.draw_text(10, 10, "Hello GPU", 0xFFFFFFFF as u32, 14)
    b.draw_text(10, 40, "Widget Showcase", 0xFF22C55E as u32, 14)
    b.draw_text(10, 70, "Metal Offload", 0xFFF59E0B as u32, 14)

# ---------------------------------------------------------------------------
# Single-frame renders (one backend each)
# ---------------------------------------------------------------------------

fn cpu_primitives(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend(w, h, "software")
    paint_primitives(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn metal_primitives(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    paint_primitives(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn cpu_text(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend(w, h, "software")
    paint_text(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn metal_text(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    paint_text(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

# ---------------------------------------------------------------------------
# GPU-dict use case #2 — glyph_atlas_blit draw_text EDGE-CASE parity (design
# doc/05_design/ui/rendering/cpu_gpu_dual_algorithm_design.md W4).
#
# paint_text above only exercises in-charset glyphs at scale=2, fully
# on-surface. This scene deliberately covers the edges the atlas lookup
# formula and the kernel's bounds guards must get exactly right:
#   - out-of-charset codepoints (`~`, `$`) -> atlas UNKNOWN slot (index 88,
#     glyph_atlas_unknown_index() in glyph.spl) must resolve to the SAME
#     FONT_UNKNOWN_PACKED box outline the CPU-lane's gi<0 path draws.
#   - scale=1 (font_size <= glyph_height()==7) -> advance=5, no per-pixel
#     scale block, exercises the glyph_col/glyph_row div-by-1 path.
#   - text positioned to run off the right/bottom framebuffer edge -> the
#     kernel's px/py bounds check must clip exactly like the CPU's
#     sw_set_pixel bounds guard (backend_software.spl).
fn paint_text_edge(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF000000 as u32)
    b.draw_text(2, 2, "~$Zz09", 0xFFFFFFFF as u32, 7)
    b.draw_text(w - 10, h - 10, "EDGE", 0xFF22C55E as u32, 14)

fn cpu_text_edge(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend(w, h, "software")
    paint_text_edge(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn metal_text_edge(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    paint_text_edge(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

# Heavy-volume text scene (perf evidence only, not a parity gate on its own —
# parity is already proven bit-exact by paint_text/paint_text_edge above at
# the SAME per-op granularity). 24 lines x ~40 chars exercises a text volume
# where the former one-dispatch-per-lit-glyph-pixel path (perf plan 2D-5,
# design cpu_gpu_dual_algorithm.md W4 motivation) issued thousands of GPU
# command-buffer round trips; kernel_glyph_atlas_blit issues exactly one
# dispatch per draw_text call (24 here) regardless of how many pixels are lit.
fn paint_text_heavy(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF000000 as u32)
    var line = 0
    while line < 24:
        b.draw_text(4, 4 + line * 16, "The quick brown fox jumps over lazy", 0xFFFFFFFF as u32, 14)
        line = line + 1

# ---------------------------------------------------------------------------
# GPU-dict pilot — indexed_fill palette-LUT parity (design
# doc/05_design/ui/rendering/cpu_gpu_dual_algorithm_design.md §3/§4).
#
# indexed_fill is a backend method (NOT an Engine2D op — it is not a
# RenderBackend trait requirement), so this lane drives MetalBackend and
# SoftwareBackend directly, exactly the two independent implementations the
# parity oracle pins. The scene deliberately includes out-of-range indices
# (keys >= palette.len()) so the 0xFFFFFFFF dense-miss sentinel path (design
# §3.2/§3.4) is proven bit-exact on the GPU too, not just the in-range gather.
# ---------------------------------------------------------------------------

fn _indexed_palette() -> [u32]:
    # 8 vivid ARGB entries; every key >= 8 is an out-of-range miss.
    [0xFF0F172Au32, 0xFF2563EBu32, 0xFFFFFFFFu32, 0xFF22C55Eu32,
     0xFFF59E0Bu32, 0xFFEF4444u32, 0xFF64748Bu32, 0xFF111111u32]

fn _indexed_idx(w: i32, h: i32) -> [u8]:
    var idx: [u8] = [0u8; w * h]
    var i = 0
    while i < w * h:
        idx[i] = (i % 10).to_u8()   # 0..9 over an 8-entry palette: 8,9 miss -> sentinel
        i = i + 1
    idx

fn cpu_indexed_fill(w: i32, h: i32) -> Engine2DReadback:
    var sw = SoftwareBackend.create()
    sw.init(w, h)
    sw.clear(0xFF000000 as u32)
    sw.indexed_fill(0, 0, w, h, _indexed_idx(w, h), _indexed_palette())
    sw.read_pixels_with_source()

fn metal_indexed_fill(w: i32, h: i32) -> Engine2DReadback:
    var e = MetalBackend.create()
    if not e.init(w, h):
        # Metal unavailable: report a cpu_mirror-source readback so compare_exact
        # fails loudly on the non-device source (never a silent skip-as-pass).
        return e.read_pixels_with_source()
    e.use_gpu_only()
    e.clear(0xFF000000 as u32)            # opens the GPU frame (gpu_frame_complete=true)
    e.indexed_fill(0, 0, w, h, _indexed_idx(w, h), _indexed_palette(), 1)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

# ---------------------------------------------------------------------------
# W3 (design cpu_gpu_dual_algorithm_plan.md) — draw_gradient_rect dual-algorithm
# parity: kernel_draw_gradient_rect (plain data-parallel kernel, no GpuLut) vs
# the CPU-lane integer-lerp oracle (emu_draw_gradient_rect, consolidated onto
# SharedRaster by the D2 gradient decision). draw_gradient_rect IS a
# RenderBackend trait op, so this lane drives it through Engine2D directly
# (paint_primitives already exercises one call; this isolates the op with
# edge cases the composite scene does not cover: h=1 -> max_t clamp to 1,
# an off-framebuffer-edge rect the kernel's px/py bounds guard must clip, and
# a non-opaque top/bottom color pair so the alpha channel's lerp is proven
# too, not just RGB).
# ---------------------------------------------------------------------------

fn _gradient_scene(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF000000 as u32)
    b.draw_gradient_rect(2, 2, 40, 24, 0xFFFF0000 as u32, 0xFF0000FF as u32)
    b.draw_gradient_rect(10, 30, 30, 1, 0xFF112233 as u32, 0xFF445566 as u32)
    b.draw_gradient_rect(w - 12, h - 12, 20, 20, 0xFF80FF00 as u32, 0xFF0080FF as u32)
    b.draw_gradient_rect(4, h - 8, 50, 6, 0x80FFFFFF as u32, 0x8000FF00 as u32)

fn cpu_gradient_rect(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend(w, h, "software")
    _gradient_scene(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn metal_gradient_rect(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    if not e.capability.is_accelerated("draw_gradient_rect"):
        # Honest capability under-report would mean the D3 self-description
        # lied about the GPU dispatch below; surfaced (not silently ignored)
        # so a regression in capability() is visible in the log even though
        # compare_exact's device_readback check is the actual gate.
        print "gradient_rect: WARN draw_gradient_rect missing from metal accelerated_ops (capability() under-report)"
    _gradient_scene(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

# ---------------------------------------------------------------------------
# rounded_rect FILL dual-algorithm parity (bug fix 2026-07-07):
# kernel_draw_rounded_rect (2D band/corner-arc-membership dispatch,
# backend_metal_msl.spl) vs the CPU-lane fill oracle (emu_draw_rounded_rect,
# backend_emu.spl) — the same reference SoftwareBackend.draw_rounded_rect now
# delegates to as of the 2026-07-06 outline-vs-fill fix (the Metal kernel was
# stale, still replaying the pre-fix CPU OUTLINE algorithm, which is why this
# op diverged 512/1024 mismatches on engine2d_cpu_metal_parity_run.spl).
# draw_rounded_rect IS a RenderBackend trait op, so this lane drives it
# through Engine2D directly (paint_primitives deliberately excludes it — see
# the comment above), isolating edge cases the composite scene does not
# cover: a corner-radius-dominated shape (radius == min(w,h)/2 clamp, i.e. a
# full "stadium" corner), an off-framebuffer-edge rect the kernel's px/py
# bounds guard must clip, and a non-opaque fill color so the alpha channel's
# blend_src_over is proven too, not just RGB.
# ---------------------------------------------------------------------------

fn _rounded_rect_scene(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF000000 as u32)
    b.draw_rounded_rect(2, 2, 30, 24, 6, 0xFFFF3355 as u32)
    b.draw_rounded_rect(w - 20, 4, 16, 16, 8, 0xFF33CC88 as u32)
    b.draw_rounded_rect(w - 14, h - 10, 20, 16, 6, 0xFF4488FF as u32)
    b.draw_rounded_rect(4, h - 14, 40, 12, 5, 0x80FFFFFF as u32)

fn cpu_rounded_rect(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend(w, h, "software")
    _rounded_rect_scene(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn metal_rounded_rect(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    if not e.capability.is_accelerated("draw_rounded_rect"):
        # Honest capability under-report would mean the D3 self-description
        # lied about the GPU dispatch below; surfaced (not silently ignored)
        # so a regression in capability() is visible in the log even though
        # compare_exact's device_readback check is the actual gate.
        print "rounded_rect: WARN draw_rounded_rect missing from metal accelerated_ops (capability() under-report)"
    _rounded_rect_scene(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

# ---------------------------------------------------------------------------
# draw_image (blit) dual-algorithm parity-COVERAGE close (2026-07-07 sweep):
# kernel_blit_image (backend_metal_msl.spl) — a plain data-parallel kernel,
# raw src->fb copy with a px/py bounds clip, no blend, no GpuLut — has had a
# real Metal dispatch path since the GPU-offload work landed
# (backend_metal.spl draw_image(), gated on session.pipe_blit != 0) but was
# never exercised by any parity harness. This is a verification GAP, not a
# reported divergence: ad hoc reproduction (2026-07-07 parity sweep) already
# found CPU vs Metal bit-exact for it, which is expected — SoftwareBackend.
# draw_image (backend_software.spl) is the same "clip then raw copy, no
# blend" formula the kernel implements. This lane closes the coverage gap so
# a future regression in either side is caught. draw_image IS a RenderBackend
# trait op, so this lane drives it through Engine2D directly, isolating edge
# cases the composite scenes do not cover: a fully on-surface blit, a rect
# straddling the right/bottom framebuffer edge (kernel's px/py >= fb bounds
# guard must clip exactly like the CPU bounds-clipped row loop), and a rect
# straddling the left/top edge (negative start_x/start_y src-offset clip).
# ---------------------------------------------------------------------------

fn _image_src(w: i32, h: i32) -> [u32]:
    # Varied per-pixel colors (not a solid fill) so a transposition/stride
    # bug in either the kernel or the CPU row-loop would show up as a
    # mismatch rather than being masked by a uniform source.
    var px: [u32] = [0u32; w * h]
    var i = 0
    while i < w * h:
        px[i] = (0xFF000000 as u32) + ((i * 2654435761u32) & 0x00FFFFFFu32)
        i = i + 1
    px

fn _image_scene(b: Engine2D, w: i32, h: i32):
    b.clear(0xFF0F172A as u32)
    b.draw_image(4, 4, 10, 8, _image_src(10, 8))               # fully on-surface
    b.draw_image(w - 6, h - 6, 12, 12, _image_src(12, 12))     # straddles right/bottom edge
    b.draw_image(-5, -3, 10, 10, _image_src(10, 10))           # straddles left/top edge

fn cpu_image(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend(w, h, "software")
    _image_scene(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

fn metal_image(w: i32, h: i32) -> Engine2DReadback:
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    if not e.capability.is_accelerated("draw_image"):
        # Honest capability under-report would mean the D3 self-description
        # lied about the GPU dispatch below; surfaced (not silently ignored)
        # so a regression in capability() is visible in the log even though
        # compare_exact's device_readback check is the actual gate.
        print "image: WARN draw_image missing from metal accelerated_ops (capability() under-report)"
    _image_scene(e, w, h)
    e.present()
    val rb = e.read_pixels_with_source()
    e.shutdown()
    rb

# ---------------------------------------------------------------------------
# Parity comparison (honest: requires device_readback source on the Metal side)
# ---------------------------------------------------------------------------

fn compare_exact(name: text, cpu_rb: Engine2DReadback, metal_rb: Engine2DReadback):
    val cpu_px = cpu_rb.pixels
    val metal_px = metal_rb.pixels
    print "{name}: cpu_source={cpu_rb.source} metal_source={metal_rb.source} cpu_checksum={cpu_rb.checksum} metal_checksum={metal_rb.checksum}"
    if metal_rb.source != "device_readback":
        _failures = _failures + 1
        print "{name}: DIVERGE reason=metal-not-device-readback source={metal_rb.source}"
        return
    if cpu_px.len() != metal_px.len():
        _failures = _failures + 1
        print "{name}: DIVERGE reason=length cpu={cpu_px.len()} metal={metal_px.len()}"
        return
    var mism = 0
    var first = -1
    var i = 0
    val n = cpu_px.len()
    while i < n:
        if cpu_px[i] != metal_px[i]:
            mism = mism + 1
            if first < 0:
                first = i
        i = i + 1
    if mism == 0:
        print "{name}: MATCH pixels={n} source={metal_rb.source}"
    else:
        _failures = _failures + 1
        val fc = cpu_px[first]
        val fm = metal_px[first]
        print "{name}: DIVERGE mism={mism}/{n} first={first} cpu={fc.to_text()} metal={fm.to_text()} source={metal_rb.source}"

# ---------------------------------------------------------------------------
# Perf helpers
# ---------------------------------------------------------------------------

# median of a list, ignoring index 0 (warmup frame). Small N; simple selection.
fn median_tail(times: [i64]) -> i64:
    var vals: [i64] = []
    var i = 1
    while i < times.len():
        vals.push(times[i])
        i = i + 1
    if vals.len() == 0:
        return -1
    # insertion sort
    var a = 0
    while a < vals.len():
        var b = a + 1
        while b < vals.len():
            if vals[b] < vals[a]:
                val tmp = vals[a]
                vals[a] = vals[b]
                vals[b] = tmp
            b = b + 1
        a = a + 1
    vals[vals.len() / 2]

# CPU perf: reuse one software Engine2D across frames. Returns (draw_us, readback_us) medians.
fn perf_cpu(w: i32, h: i32, frames: i64) -> (i64, i64):
    var e = Engine2D.create_with_backend(w, h, "software")
    var draws: [i64] = []
    var reads: [i64] = []
    var f = 0
    while f < frames:
        val t0 = time_now_micros()
        paint_primitives(e, w, h)
        e.present()
        val t1 = time_now_micros()
        val px = e.read_pixels()
        val t2 = time_now_micros()
        draws.push(t1 - t0)
        reads.push(t2 - t1)
        f = f + 1
    e.shutdown()
    (median_tail(draws), median_tail(reads))

# Metal perf, PERSISTENT session: create once, reuse across frames.
fn perf_metal_persistent(w: i32, h: i32, frames: i64) -> (i64, i64, text):
    var e = Engine2D.create_with_backend_fast(w, h, "metal")
    var draws: [i64] = []
    var reads: [i64] = []
    var src = "unknown"
    var f = 0
    while f < frames:
        val t0 = time_now_micros()
        paint_primitives(e, w, h)
        e.present()
        val t1 = time_now_micros()
        val px = e.read_pixels()
        val t2 = time_now_micros()
        draws.push(t1 - t0)
        reads.push(t2 - t1)
        f = f + 1
    val rb = e.read_pixels_with_source()
    src = rb.source
    e.shutdown()
    (median_tail(draws), median_tail(reads), src)

# Metal perf, PER-FRAME CREATE: create+shutdown a fresh session every frame
# (the anti-pattern the "gpu process" fix eliminates). Returns median total_us.
fn perf_metal_per_frame(w: i32, h: i32, frames: i64) -> i64:
    var totals: [i64] = []
    var f = 0
    while f < frames:
        val t0 = time_now_micros()
        var e = Engine2D.create_with_backend_fast(w, h, "metal")
        paint_primitives(e, w, h)
        e.present()
        val px = e.read_pixels()
        e.shutdown()
        val t1 = time_now_micros()
        totals.push(t1 - t0)
        f = f + 1
    median_tail(totals)

fn report_perf(label: text, w: i32, h: i32, frames: i64):
    val cpu = perf_cpu(w, h, frames)
    val cpu_draw = cpu.0
    val cpu_read = cpu.1
    val mp = perf_metal_persistent(w, h, frames)
    val m_draw = mp.0
    val m_read = mp.1
    val m_src = mp.2
    val m_pf = perf_metal_per_frame(w, h, frames)
    val cpu_total = cpu_draw + cpu_read
    val m_total = m_draw + m_read
    print "PERF[{label}] res={w}x{h} frames={frames}"
    print "PERF[{label}] cpu_draw_us={cpu_draw} cpu_readback_us={cpu_read} cpu_total_us={cpu_total}"
    print "PERF[{label}] metal_persistent_draw_us={m_draw} metal_persistent_readback_us={m_read} metal_persistent_total_us={m_total} metal_source={m_src}"
    print "PERF[{label}] metal_per_frame_create_total_us={m_pf}"
    val reuse_delta = m_pf - m_total
    print "PERF[{label}] session_reuse_saves_us={reuse_delta} (per_frame_create_total - persistent_total)"
    var verdict = "metal-wins"
    if m_total > cpu_total:
        verdict = "cpu-wins"
    print "PERF[{label}] verdict={verdict} (lower total_us is better)"

# ---------------------------------------------------------------------------
# WM compositor composite-frame lane (HostCompositor.render_frame through
# Engine2dCompositorBackend, direct-draw chrome pinned for determinism —
# the fast CSS chrome lane has its own cache/gates owned elsewhere).
# ---------------------------------------------------------------------------

fn _wm_test_window(id: i64, title: text, x: i32, y: i32, w: i32, h: i32, focused: bool) -> HostedWindow:
    HostedWindow(
        id: id,
        owner_port: 0,
        title: title,
        x: x,
        y: y,
        w: w,
        h: h,
        content: "count=1",
        process_id: 0,
        app_id: "gpu-offload-evidence",
        minimized: false,
        focused: focused
    )

# Render ONE composed WM frame (chrome + two app windows + taskbar) on the
# named Engine2D backend and return the COMPOSITOR: pixels must be read
# through comp.backend, NOT a local backend binding — mutations through
# comp.backend do not write back into the local copy (value semantics; same
# trap documented in wm_gui_window_drawing_evidence.spl).
fn wm_composite_frame(w: i32, h: i32, backend_name: text) -> HostCompositor:
    val backend = Engine2dCompositorBackend.create_named(w, h, backend_name)
    var comp = HostCompositor.new(backend, Size(width: w.to_u64(), height: h.to_u64()))
    comp.windows = [
        _wm_test_window(1, "Alpha", 24, 20, 200, 160, false),
        _wm_test_window(2, "Beta", 140, 96, 220, 170, true)
    ]
    comp.render_frame()
    comp

fn wm_parity(w: i32, h: i32):
    host_wm_force_direct_chrome(true)
    val t0 = time_now_micros()
    var cpu_comp = wm_composite_frame(w, h, "software")
    val t1 = time_now_micros()
    print "stage-time wm_cpu_frame_us={t1 - t0}"
    var metal_comp = wm_composite_frame(w, h, "metal")
    val t2 = time_now_micros()
    print "stage-time wm_metal_frame_us={t2 - t1}"
    val cpu_rb = cpu_comp.backend.engine.read_pixels_with_source()
    val metal_rb = metal_comp.backend.engine.read_pixels_with_source()
    compare_exact("wm_composite", cpu_rb, metal_rb)
    print "PROVENANCE wm_composite backend=metal source={metal_rb.source}"
    cpu_comp.backend.shutdown()
    metal_comp.backend.shutdown()
    host_wm_force_direct_chrome(false)

# WM composite perf: persistent compositor+session reused across frames
# (render_frame per frame; content web-layout cost is backend-independent and
# identical in both lanes — the delta isolates the raster backend).
fn wm_perf(w: i32, h: i32, frames: i64, backend_name: text) -> i64:
    host_wm_force_direct_chrome(true)
    val backend = Engine2dCompositorBackend.create_named(w, h, backend_name)
    var comp = HostCompositor.new(backend, Size(width: w.to_u64(), height: h.to_u64()))
    comp.windows = [
        _wm_test_window(1, "Alpha", 24, 20, 200, 160, false),
        _wm_test_window(2, "Beta", 140, 96, 220, 170, true)
    ]
    var times: [i64] = []
    var f = 0
    while f < frames:
        val t0 = time_now_micros()
        comp.render_frame()
        val px = comp.backend.engine.read_pixels()
        val t1 = time_now_micros()
        times.push(t1 - t0)
        f = f + 1
    comp.backend.shutdown()
    host_wm_force_direct_chrome(false)
    median_tail(times)

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

fn _is_macos() -> bool:
    val ostype = (env_get("OSTYPE") ?? "").lower()
    ostype.contains("darwin") or ostype.contains("mac")

fn main() -> i64:
    # macOS-only: native Metal. Non-macOS reports skip (not a pass).
    val uname_probe = env_get("SIMPLE_GPU_OFFLOAD_FORCE") ?? ""
    if uname_probe == "":
        # cheap platform check via a probe engine's backend name
        var probe = Engine2D.create_with_backend_fast(8, 8, "metal")
        val pname = probe.backend_name()
        probe.shutdown()
        if pname != "metal":
            print "GPU_OFFLOAD: skip reason=metal-unavailable backend={pname}"
            return 2

    val stage = env_get("GPU_OFFLOAD_STAGE") ?? "all"
    val frames = (env_get("GPU_OFFLOAD_FRAMES") ?? "4").parse_i64() ?? 4

    if stage == "all" or stage == "parity":
        print "=== GPU offload evidence: parity ==="
        # Parity at a modest resolution where a full pixel-exact compare is feasible.
        val pw = 256
        val ph = 192
        val t0 = time_now_micros()
        val cpu_prim = cpu_primitives(pw, ph)
        val t1 = time_now_micros()
        print "stage-time cpu_primitives_us={t1 - t0}"
        val metal_prim = metal_primitives(pw, ph)
        val t2 = time_now_micros()
        print "stage-time metal_primitives_us={t2 - t1}"
        compare_exact("primitives", cpu_prim, metal_prim)

        val t3 = time_now_micros()
        val cpu_txt = cpu_text(pw, ph)
        val t4 = time_now_micros()
        print "stage-time cpu_text_us={t4 - t3}"
        val metal_txt = metal_text(pw, ph)
        val t5 = time_now_micros()
        print "stage-time metal_text_us={t5 - t4}"
        compare_exact("text", cpu_txt, metal_txt)

        print "PROVENANCE primitives backend=metal source={metal_prim.source}"
        print "PROVENANCE text backend=metal source={metal_txt.source}"

    if stage == "all" or stage == "indexed_fill":
        print "=== GPU offload evidence: indexed_fill (GPU-dict palette LUT) parity ==="
        # Small surface where a full pixel-exact compare is cheap; indexed_fill
        # covers the whole surface so every pixel is a table lookup (no reliance
        # on the initial framebuffer contents).
        val iw = 64
        val ih = 48
        val ti0 = time_now_micros()
        val cpu_if = cpu_indexed_fill(iw, ih)
        val ti1 = time_now_micros()
        print "stage-time cpu_indexed_fill_us={ti1 - ti0}"
        val metal_if = metal_indexed_fill(iw, ih)
        val ti2 = time_now_micros()
        print "stage-time metal_indexed_fill_us={ti2 - ti1}"
        compare_exact("indexed_fill", cpu_if, metal_if)
        print "PROVENANCE indexed_fill backend=metal source={metal_if.source}"

    if stage == "all" or stage == "gradient_rect":
        print "=== GPU offload evidence: draw_gradient_rect (W3 dual-algorithm) parity ==="
        val gw = 64
        val gh = 48
        val tg0 = time_now_micros()
        val cpu_gr = cpu_gradient_rect(gw, gh)
        val tg1 = time_now_micros()
        print "stage-time cpu_gradient_rect_us={tg1 - tg0}"
        val metal_gr = metal_gradient_rect(gw, gh)
        val tg2 = time_now_micros()
        print "stage-time metal_gradient_rect_us={tg2 - tg1}"
        compare_exact("gradient_rect", cpu_gr, metal_gr)
        print "PROVENANCE gradient_rect backend=metal source={metal_gr.source}"

    if stage == "all" or stage == "rounded_rect":
        print "=== GPU offload evidence: draw_rounded_rect (fill dual-algorithm) parity ==="
        val rw = 64
        val rh = 48
        val tr0 = time_now_micros()
        val cpu_rr = cpu_rounded_rect(rw, rh)
        val tr1 = time_now_micros()
        print "stage-time cpu_rounded_rect_us={tr1 - tr0}"
        val metal_rr = metal_rounded_rect(rw, rh)
        val tr2 = time_now_micros()
        print "stage-time metal_rounded_rect_us={tr2 - tr1}"
        compare_exact("rounded_rect", cpu_rr, metal_rr)
        print "PROVENANCE rounded_rect backend=metal source={metal_rr.source}"

    if stage == "all" or stage == "image":
        print "=== GPU offload evidence: draw_image (blit dual-algorithm) parity ==="
        val iw2 = 64
        val ih2 = 48
        val tim0 = time_now_micros()
        val cpu_im = cpu_image(iw2, ih2)
        val tim1 = time_now_micros()
        print "stage-time cpu_image_us={tim1 - tim0}"
        val metal_im = metal_image(iw2, ih2)
        val tim2 = time_now_micros()
        print "stage-time metal_image_us={tim2 - tim1}"
        compare_exact("image", cpu_im, metal_im)
        print "PROVENANCE image backend=metal source={metal_im.source}"

    if stage == "all" or stage == "text_edge":
        print "=== GPU offload evidence: draw_text edge cases (GPU-dict glyph atlas) parity ==="
        val ew = 64
        val eh = 48
        val te0 = time_now_micros()
        val cpu_te = cpu_text_edge(ew, eh)
        val te1 = time_now_micros()
        print "stage-time cpu_text_edge_us={te1 - te0}"
        val metal_te = metal_text_edge(ew, eh)
        val te2 = time_now_micros()
        print "stage-time metal_text_edge_us={te2 - te1}"
        compare_exact("text_edge", cpu_te, metal_te)
        print "PROVENANCE text_edge backend=metal source={metal_te.source}"

    if stage == "all" or stage == "text_heavy":
        print "=== GPU offload evidence: draw_text heavy-volume perf (GPU-dict glyph atlas) ==="
        # Perf-only: parity for this op is already proven bit-exact by the
        # text/text_edge stages above. This isolates the win the plan/design
        # motivate W4 with — dispatch count no longer scales with lit-pixel
        # count, only with draw_text CALL count (24 lines = 24 dispatches here,
        # vs the former per-lit-pixel dispatch storm).
        val hw = 400
        val hh = 400
        val th0 = time_now_micros()
        var cpu_h = Engine2D.create_with_backend(hw, hh, "software")
        paint_text_heavy(cpu_h, hw, hh)
        cpu_h.present()
        val cpu_h_px = cpu_h.read_pixels()
        cpu_h.shutdown()
        val th1 = time_now_micros()
        print "stage-time cpu_text_heavy_us={th1 - th0}"
        var metal_h = Engine2D.create_with_backend_fast(hw, hh, "metal")
        paint_text_heavy(metal_h, hw, hh)
        metal_h.present()
        val metal_h_rb = metal_h.read_pixels_with_source()
        metal_h.shutdown()
        val th2 = time_now_micros()
        print "stage-time metal_text_heavy_us={th2 - th1}"
        print "PROVENANCE text_heavy backend=metal source={metal_h_rb.source}"

    if stage == "all" or stage == "wm":
        print "=== GPU offload evidence: WM composite parity (direct-draw chrome) ==="
        wm_parity(480, 360)
        val wm_cpu_us = wm_perf(480, 360, frames, "software")
        val wm_metal_us = wm_perf(480, 360, frames, "metal")
        print "PERF[wm-480x360] cpu_frame_us={wm_cpu_us} metal_frame_us={wm_metal_us}"
        var wm_verdict = "metal-wins"
        if wm_metal_us > wm_cpu_us:
            wm_verdict = "cpu-wins"
        print "PERF[wm-480x360] verdict={wm_verdict}"

    if stage == "all" or stage == "perf-small":
        print "=== GPU offload evidence: perf 520x660 ==="
        report_perf("showcase-520x660", 520, 660, frames)
    if stage == "all" or stage == "perf-big":
        print "=== GPU offload evidence: perf 1280x720 ==="
        report_perf("wm-1280x720", 1280, 720, frames)

    if _failures == 0:
        print "GPU_OFFLOAD: pass"
        return 0
    print "GPU_OFFLOAD: fail failures={_failures}"
    1
