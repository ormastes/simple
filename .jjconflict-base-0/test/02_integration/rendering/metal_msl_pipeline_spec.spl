# @tag: rendering, engine2d, metal, msl, pipeline
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_metal_msl.spl 60%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl 30%
#
# Guards the Metal MSL compile + GPU dispatch path. Before the MSL fix, the
# embedded shader failed to compile (Simple `#` comments are invalid C-pp
# directives; `int half` collided with MSL's reserved `half` type), so init()
# returned false and every "metal" test silently passed via the software-mirror
# fallback. These tests assert real pipeline creation and GPU dispatch.
#
# macOS-only: on Linux the asserts are skipped (Metal unavailable by design).

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_metal.{MetalBackend}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.nogc_sync_mut.env.platform.{is_macos}

describe "Metal MSL compile + GPU dispatch":

    context "on macOS":

        it "MSL compiles: all compute pipelines created":
            if is_macos():
                var b = MetalBackend.create()
                val ok = b.init(16, 16)
                expect(ok).to_equal(true)
                expect(b.session.pipe_clear).to_be_greater_than(0)
                expect(b.session.pipe_rect_filled).to_be_greater_than(0)
                expect(b.session.pipe_line).to_be_greater_than(0)
                expect(b.session.pipe_circle).to_be_greater_than(0)
                expect(b.session.pipe_triangle).to_be_greater_than(0)
                expect(b.session.pipe_gradient).to_be_greater_than(0)
                expect(b.session.pipe_blit).to_be_greater_than(0)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "GPU clear dispatch runs (1d) and marks dirty":
            if is_macos():
                var b = MetalBackend.create()
                b.init(16, 16)
                b.clear(rgb(3, 5, 7))
                expect(b.dirty).to_equal(true)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "GPU rect_filled dispatch runs (2d) and marks dirty":
            if is_macos():
                var b = MetalBackend.create()
                b.init(16, 16)
                b.draw_rect_filled(0, 0, 8, 8, rgb(40, 70, 100))
                expect(b.dirty).to_equal(true)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)
