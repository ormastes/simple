# T32 Native Integration Test
# Verifies the repo-managed TRACE32 native lane is wired for STM targets.

extern fn rt_file_exists(path: text) -> bool

class T32Config:
    t32rem_path: text
    launcher_path: text
    hidden_cfg_path: text
    wb_startup_path: text
    h7_startup_path: text
    wb_native_cmm: text
    h7_native_cmm: text
    fixture_asm: text
    fixture_ld: text
    host: text
    port: i32

impl T32Config:
    static fn default_config() -> T32Config:
        T32Config(
            t32rem_path: "/opt/t32/bin/pc_linux64/t32rem",
            launcher_path: "scripts/t32_start_stm.shs",
            hidden_cfg_path: "config/t32_stm_linux_hidden.t32",
            wb_startup_path: "/opt/t32/stm32wb_startup.cmm",
            h7_startup_path: "/opt/t32/stm32h7_startup.cmm",
            wb_native_cmm: "config/t32/stm32wb_native_start.cmm",
            h7_native_cmm: "config/t32/stm32h7_native_start.cmm",
            fixture_asm: "test/fixtures/baremetal/stm_semihost_smoke.s",
            fixture_ld: "test/fixtures/baremetal/stm_semihost_smoke.ld",
            host: "localhost",
            port: 20000
        )

    fn command(cmd: text) -> text:
        "{self.t32rem_path} {self.host} port={self.port} {cmd}"

    fn launcher(board: text) -> text:
        "{self.launcher_path} {board} native"

    fn ping_command() -> text:
        self.command("PING")

    fn system_up_command() -> text:
        self.command("SYStem.Up")

describe "T32 native repo readiness":
    it "uses the installed t32rem path":
        val cfg = T32Config.default_config()
        expect(cfg.t32rem_path).to_equal("/opt/t32/bin/pc_linux64/t32rem")

    it "ships the shared hidden Linux config":
        val cfg = T32Config.default_config()
        expect(rt_file_exists(cfg.hidden_cfg_path)).to_equal(true)

    it "ships the TRACE32 launcher helper":
        val cfg = T32Config.default_config()
        expect(rt_file_exists(cfg.launcher_path)).to_equal(true)

    it "ships both board-specific native startup scripts":
        val cfg = T32Config.default_config()
        expect(rt_file_exists(cfg.wb_native_cmm)).to_equal(true)
        expect(rt_file_exists(cfg.h7_native_cmm)).to_equal(true)

    it "requires the Lauterbach startup scripts already present on host":
        val cfg = T32Config.default_config()
        expect(rt_file_exists(cfg.wb_startup_path)).to_equal(true)
        expect(rt_file_exists(cfg.h7_startup_path)).to_equal(true)

    it "ships the shared STM smoke fixture":
        val cfg = T32Config.default_config()
        expect(rt_file_exists(cfg.fixture_asm)).to_equal(true)
        expect(rt_file_exists(cfg.fixture_ld)).to_equal(true)

    it "launcher command is well-formed for STM32WB":
        val cfg = T32Config.default_config()
        val cmd = cfg.launcher("stm32wb")
        expect(cmd.contains("scripts/t32_start_stm.shs")).to_equal(true)
        expect(cmd.contains("stm32wb native")).to_equal(true)

    it "launcher command is well-formed for STM32H7":
        val cfg = T32Config.default_config()
        val cmd = cfg.launcher("stm32h7")
        expect(cmd.contains("stm32h7 native")).to_equal(true)

    it "remote API ping command is well-formed":
        val cfg = T32Config.default_config()
        val cmd = cfg.ping_command()
        expect(cmd.contains("t32rem")).to_equal(true)
        expect(cmd.contains("PING")).to_equal(true)
        expect(cmd.contains("localhost")).to_equal(true)
        expect(cmd.contains("port=20000")).to_equal(true)

    it "system up command is well-formed":
        val cfg = T32Config.default_config()
        val cmd = cfg.system_up_command()
        expect(cmd.contains("SYStem.Up")).to_equal(true)
