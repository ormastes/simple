# Input & TextField Widget Demo
#
# Non-interactive demo that builds input and textfield widgets,
# computes layout on an 80x24 screen buffer, renders via TUI,
# and verifies the output contains expected placeholder text and field values.

use common.ui.builder.{column, panel, text_input, text_field, build_tree_with_title}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree, render_html_tree}

fn build_input_textfield_tree() -> UIState:
    """Build a widget tree with input and textfield widgets."""
    val search_input = text_input("search", "Search...")
    val email_input = text_input("email", "Enter email")
    val name_field = text_field("name", "John Doe", "Full name")
    val bio_field = text_field("bio", "", "Tell us about yourself")

    val form = panel("form", "Text Entry", [
        search_input,
        email_input,
        name_field,
        bio_field
    ])

    val root = column("root", [form])
    val tree = build_tree_with_title(root, "Input TextField Demo", "dark")
    return init_state(tree)

fn main() -> i64:
    var failures = 0
    var passes = 0

    print "=== Input & TextField Widget Demo ==="
    print ""

    # --- Build the widget tree ---
    val state = build_input_textfield_tree()

    val ids = state.tree.all_widget_ids()
    if ids.len() > 0:
        print "PASS: tree built with {ids.len()} widgets"
        passes = passes + 1
    else:
        print "FAIL: tree has no widgets"
        failures = failures + 1

    # Verify expected widget ids are present
    var found_search = false
    var found_email = false
    var found_name = false
    var found_bio = false
    for wid in ids:
        if wid == "search":
            found_search = true
        if wid == "email":
            found_email = true
        if wid == "name":
            found_name = true
        if wid == "bio":
            found_bio = true

    if found_search and found_email:
        print "PASS: input widgets (search, email) present"
        passes = passes + 1
    else:
        print "FAIL: input widgets missing (search={found_search}, email={found_email})"
        failures = failures + 1

    if found_name and found_bio:
        print "PASS: textfield widgets (name, bio) present"
        passes = passes + 1
    else:
        print "FAIL: textfield widgets missing (name={found_name}, bio={found_bio})"
        failures = failures + 1

    # --- Compute layout ---
    val width = 80
    val height = 24
    val rects = compute_layout(state.tree.root, 0, 0, width, height - 1)

    if rects.len() > 0:
        print "PASS: layout computed with {rects.len()} rects"
        passes = passes + 1
    else:
        print "FAIL: layout produced no rects"
        failures = failures + 1

    # --- Render to TUI screen buffer ---
    var screen = Screen.new(width, height - 1)
    screen = render_tui_tree(screen, state.tree.root, rects, state)
    val output = screen.render()

    if output.len() > 0:
        print "PASS: TUI render produced {output.len()} chars"
        passes = passes + 1
    else:
        print "FAIL: TUI render produced empty output"
        failures = failures + 1

    # --- Verify TUI output contains panel title ---
    if output.contains("Text Entry"):
        print "PASS: TUI output contains panel title 'Text Entry'"
        passes = passes + 1
    else:
        print "FAIL: TUI output missing panel title 'Text Entry'"
        failures = failures + 1

    # --- Verify input placeholder text ---
    # render_tui_input renders: "> {placeholder}"
    if output.contains("Search..."):
        print "PASS: TUI output contains input placeholder 'Search...'"
        passes = passes + 1
    else:
        print "FAIL: TUI output missing input placeholder 'Search...'"
        failures = failures + 1

    if output.contains("Enter email"):
        print "PASS: TUI output contains input placeholder 'Enter email'"
        passes = passes + 1
    else:
        print "FAIL: TUI output missing input placeholder 'Enter email'"
        failures = failures + 1

    # --- Verify textfield value and placeholder ---
    # render_tui_textfield renders: "|{value_or_placeholder}|"
    if output.contains("John Doe"):
        print "PASS: TUI output contains textfield value 'John Doe'"
        passes = passes + 1
    else:
        print "FAIL: TUI output missing textfield value 'John Doe'"
        failures = failures + 1

    # Bio has empty value, so placeholder should display
    if output.contains("Tell us about yourself"):
        print "PASS: TUI output contains textfield placeholder 'Tell us about yourself'"
        passes = passes + 1
    else:
        print "FAIL: TUI output missing textfield placeholder 'Tell us about yourself'"
        failures = failures + 1

    # --- Verify HTML rendering ---
    val html = render_html_tree(state.tree.root, state)

    if html.len() > 0:
        print "PASS: HTML render produced {html.len()} chars"
        passes = passes + 1
    else:
        print "FAIL: HTML render produced empty output"
        failures = failures + 1

    if html.contains("widget-input"):
        print "PASS: HTML contains input widget class"
        passes = passes + 1
    else:
        print "FAIL: HTML missing input widget class"
        failures = failures + 1

    if html.contains("widget-textfield"):
        print "PASS: HTML contains textfield widget class"
        passes = passes + 1
    else:
        print "FAIL: HTML missing textfield widget class"
        failures = failures + 1

    if html.contains("placeholder"):
        print "PASS: HTML contains placeholder attributes"
        passes = passes + 1
    else:
        print "FAIL: HTML missing placeholder attributes"
        failures = failures + 1

    # --- Summary ---
    print ""
    print "=== Results: {passes} passed, {failures} failed ==="

    if failures == 0:
        print "All tests passed."
        return 0
    else:
        print "{failures} test(s) failed."
        return 1
