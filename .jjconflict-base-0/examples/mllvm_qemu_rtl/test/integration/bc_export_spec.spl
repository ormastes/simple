"""
LLVM Bitcode Export End-to-End Integration Specification

Exercises the IR_TC -> LLVM bitcode export pipeline: build IR_TC modules
with standard and emulation ops, export via IrtcToBcAdapter, verify the
generated LLVM text IR contains expected keywords and structure.

**Feature IDs:** #MLLVM-BC-E2E
**Category:** Testing
**Status:** Implemented
"""

use std.spec.{describe, it, expect}
use core.types.{IrTcTypeKind, IrTcValue, IrTcCond, GuestArch}
use core.ops.{IrTcOp, IrTcInst}
use core.mem_op.{GuestRegId}
use core.block.{BlockId, IrTcBlock, IrTcFunction, IrTcParam, IrTcModule, IrTcModuleMode}
use core.builder.{IrTcBuilder}
use transform.irtc_to_bc.{IrtcToBcAdapter}

# ============================================================================
# BC Export — Simple compilation module
# ============================================================================

describe "Bitcode export of compilation module":
    """Export standard IR_TC modules and verify LLVM text IR output."""

    it "exports module with define keyword":
        var builder = IrTcBuilder.new("bc_simple", IrTcModuleMode.Compilation)
        builder.begin_function("add_i32", [
            IrTcParam.new("a", IrTcTypeKind.I32),
            IrTcParam.new("b", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val a = builder.param_value(0)
        val b = builder.param_value(1)
        val result = builder.add(a, b)
        builder.ret(Some(result))
        builder.end_function()

        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("define")

    it "exports function name in output":
        var builder = IrTcBuilder.new("bc_name", IrTcModuleMode.Compilation)
        builder.begin_function("my_special_func", [
            IrTcParam.new("x", IrTcTypeKind.I64)
        ], IrTcTypeKind.I64)

        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val x = builder.param_value(0)
        builder.ret(Some(x))
        builder.end_function()

        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("my_special_func")

    it "exports module ID comment":
        var builder = IrTcBuilder.new("bc_modid", IrTcModuleMode.Compilation)
        builder.begin_function("noop", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        builder.ret(nil)
        builder.end_function()

        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("ModuleID")
        expect(ll_text).to_contain("bc_modid")

    it "exports i32 type for i32 parameters":
        var builder = IrTcBuilder.new("bc_types", IrTcModuleMode.Compilation)
        builder.begin_function("typed_fn", [
            IrTcParam.new("a", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val a = builder.param_value(0)
        builder.ret(Some(a))
        builder.end_function()

        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("i32")

# ============================================================================
# BC Export — Multiple functions
# ============================================================================

describe "Bitcode export with multiple functions":
    """Export modules with multiple functions and declarations."""

    it "exports all function names":
        var builder = IrTcBuilder.new("bc_multi", IrTcModuleMode.Compilation)

        builder.begin_function("func_alpha", [], IrTcTypeKind.Void)
        val e1 = builder.new_block("entry")
        builder.set_block(e1)
        builder.ret(nil)
        builder.end_function()

        builder.begin_function("func_beta", [
            IrTcParam.new("x", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)
        val e2 = builder.new_block("entry")
        builder.set_block(e2)
        val x = builder.param_value(0)
        builder.ret(Some(x))
        builder.end_function()

        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("func_alpha")
        expect(ll_text).to_contain("func_beta")

    it "exports declarations with declare keyword":
        var builder = IrTcBuilder.new("bc_decl", IrTcModuleMode.Compilation)

        # Add a declaration (no body)
        builder.begin_declaration("external_fn", [
            IrTcParam.new("ptr", IrTcTypeKind.I64)
        ], IrTcTypeKind.I32)

        # Add a definition
        builder.begin_function("caller", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        builder.ret(nil)
        builder.end_function()

        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("declare")
        expect(ll_text).to_contain("external_fn")

# ============================================================================
# BC Export — Emulation module with guest state ops
# ============================================================================

describe "Bitcode export of emulation module":
    """Export emulation-mode modules and verify intrinsic markers."""

    it "exports emulation module":
        var builder = IrTcBuilder.new("bc_emu", IrTcModuleMode.Emulation)
        builder.set_target(GuestArch.Avr)

        builder.begin_function("avr_translate", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)

        val r0_id = GuestRegId.new(GuestArch.Avr, 0, "r0")
        val r1_id = GuestRegId.new(GuestArch.Avr, 1, "r1")
        val r0 = builder.read_guest_reg(r0_id, IrTcTypeKind.I8)
        val r1 = builder.read_guest_reg(r1_id, IrTcTypeKind.I8)
        val sum = builder.add(r0, r1)
        builder.write_guest_reg(r0_id, sum)
        builder.exit_tb(0)

        builder.end_function()
        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        # Should contain the function name
        expect(ll_text).to_contain("avr_translate")

    it "exports 8086 emulation module":
        var builder = IrTcBuilder.new("bc_x86_emu", IrTcModuleMode.Emulation)
        builder.set_target(GuestArch.I8086)

        builder.begin_function("x86_translate", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)

        val ax_id = GuestRegId.new(GuestArch.I8086, 0, "AX")
        val ax = builder.read_guest_reg(ax_id, IrTcTypeKind.I16)
        builder.write_guest_reg(ax_id, ax)
        builder.exit_tb(0)

        builder.end_function()
        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)

        expect(ll_text).to_contain("x86_translate")

# ============================================================================
# BC Export — Adapter statistics
# ============================================================================

describe "IrtcToBcAdapter export tracking":
    """Verify the adapter tracks export count."""

    it "increments modules_exported counter":
        var adapter = IrtcToBcAdapter.new()
        expect(adapter.modules_exported).to_equal(0)

        var builder = IrTcBuilder.new("count1", IrTcModuleMode.Compilation)
        builder.begin_function("f", [], IrTcTypeKind.Void)
        val e = builder.new_block("entry")
        builder.set_block(e)
        builder.ret(nil)
        builder.end_function()
        val mod1 = builder.finish()

        adapter.export_to_text(mod1)
        expect(adapter.modules_exported).to_equal(1)

    it "exports to BcModule structure":
        var adapter = IrtcToBcAdapter.new()

        var builder = IrTcBuilder.new("bc_struct", IrTcModuleMode.Compilation)
        builder.begin_function("fn1", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        builder.ret(nil)
        builder.end_function()
        val module = builder.finish()

        val bc = adapter.export(module)
        expect(bc.name).to_equal("bc_struct")
        expect(bc.functions.len()).to_equal(1)

# ============================================================================
# BC Export — Various type widths
# ============================================================================

describe "Bitcode export type widths":
    """Verify different IR_TC types produce correct LLVM type strings."""

    it "exports i8 type":
        var builder = IrTcBuilder.new("bc_i8", IrTcModuleMode.Compilation)
        builder.begin_function("byte_fn", [
            IrTcParam.new("b", IrTcTypeKind.I8)
        ], IrTcTypeKind.I8)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val b = builder.param_value(0)
        builder.ret(Some(b))
        builder.end_function()
        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)
        expect(ll_text).to_contain("i8")

    it "exports i64 type":
        var builder = IrTcBuilder.new("bc_i64", IrTcModuleMode.Compilation)
        builder.begin_function("long_fn", [
            IrTcParam.new("l", IrTcTypeKind.I64)
        ], IrTcTypeKind.I64)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val l = builder.param_value(0)
        builder.ret(Some(l))
        builder.end_function()
        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)
        expect(ll_text).to_contain("i64")

    it "exports void return type":
        var builder = IrTcBuilder.new("bc_void", IrTcModuleMode.Compilation)
        builder.begin_function("void_fn", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        builder.ret(nil)
        builder.end_function()
        val module = builder.finish()

        var adapter = IrtcToBcAdapter.new()
        val ll_text = adapter.export_to_text(module)
        expect(ll_text).to_contain("void")
