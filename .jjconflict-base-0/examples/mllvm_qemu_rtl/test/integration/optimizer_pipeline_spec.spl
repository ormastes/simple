"""
Optimizer Pipeline End-to-End Integration Specification

Exercises the full optimization pipeline: build IR_TC modules with
redundant operations, run the default pipeline, verify instruction
count reduction and constant folding behavior.

**Feature IDs:** #MLLVM-OPT-E2E
**Category:** Testing
**Status:** Implemented
"""

use std.spec.{describe, it, expect}
use core.types.{IrTcTypeKind, IrTcValue, IrTcCond}
use core.ops.{IrTcOp, IrTcInst}
use core.block.{BlockId, IrTcBlock, IrTcFunction, IrTcParam, IrTcModule, IrTcModuleMode}
use core.builder.{IrTcBuilder}
use core.verify.{IrTcVerifier}
use opt.pass_manager.{PassManager, create_default_pipeline, create_full_pipeline}

# ============================================================================
# Helper: count non-Nop instructions in a module
# ============================================================================

fn count_real_instructions(module: IrTcModule) -> i64:
    """Count instructions that are not Nop in all functions of the module."""
    var count: i64 = 0
    for func in module.functions:
        if func.is_declaration:
            pass_do_nothing
        else:
            for block in func.blocks:
                for inst in block.instructions:
                    match inst.kind:
                        IrTcOp.Nop: pass_do_nothing
                        _: count = count + 1
    count

fn count_all_instructions(module: IrTcModule) -> i64:
    """Count all instructions in the module (including Nop)."""
    var count: i64 = 0
    for func in module.functions:
        if func.is_declaration:
            pass_do_nothing
        else:
            for block in func.blocks:
                count = count + block.instructions.len()
    count

# ============================================================================
# Optimizer Pipeline — Default pipeline creation
# ============================================================================

describe "Default optimization pipeline":
    """Verify the default pipeline has the expected pass configuration."""

    it "creates pipeline with 3 passes":
        val pm = create_default_pipeline()
        expect(pm.pass_count()).to_equal(3)

    it "has const_fold as first pass":
        val pm = create_default_pipeline()
        val names = pm.pass_names()
        expect(names[0]).to_equal("const_fold")

    it "has dce as second pass":
        val pm = create_default_pipeline()
        val names = pm.pass_names()
        expect(names[1]).to_equal("dce")

    it "has cse as third pass":
        val pm = create_default_pipeline()
        val names = pm.pass_names()
        expect(names[2]).to_equal("cse")

# ============================================================================
# Optimizer Pipeline — Full pipeline
# ============================================================================

describe "Full optimization pipeline":
    """Verify the full pipeline includes all passes."""

    it "creates pipeline with 6 passes":
        val pm = create_full_pipeline()
        expect(pm.pass_count()).to_equal(6)

    it "includes width_narrow pass":
        val pm = create_full_pipeline()
        val names = pm.pass_names()
        expect(names).to_contain("width_narrow")

    it "includes tb_chain pass":
        val pm = create_full_pipeline()
        val names = pm.pass_names()
        expect(names).to_contain("tb_chain")

# ============================================================================
# Optimizer Pipeline — Constant folding E2E
# ============================================================================

describe "Constant folding through pipeline":
    """Build module with constant operations, verify folding replaces them with Nop."""

    it "folds constant addition to Nop":
        # Build: result = add(const_3, const_4) where both values are known
        # The const_fold pass should detect both operands as constants
        # and replace the add with Nop
        var builder = IrTcBuilder.new("const_mod", IrTcModuleMode.Compilation)
        builder.begin_function("const_add", [], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        builder.set_block(entry)

        # Create two values and add them
        # Since these are raw new_value, the const_fold pass tracks them
        val a = builder.new_value(IrTcTypeKind.I32)
        val b = builder.new_value(IrTcTypeKind.I32)
        val result = builder.add(a, b)
        builder.ret(Some(result))

        builder.end_function()
        val module = builder.finish()

        val before_count = count_all_instructions(module)

        # Run default pipeline
        val pm = create_default_pipeline()
        val optimized = pm.run_all(module)

        # Total instruction count should remain the same (Nop replaces folded)
        val after_count = count_all_instructions(optimized)
        expect(after_count).to_equal(before_count)

    it "pipeline preserves module verification":
        # Build a valid module, optimize, re-verify
        var builder = IrTcBuilder.new("verify_mod", IrTcModuleMode.Compilation)
        builder.begin_function("compute", [
            IrTcParam.new("x", IrTcTypeKind.I32),
            IrTcParam.new("y", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val x = builder.param_value(0)
        val y = builder.param_value(1)
        val sum = builder.add(x, y)
        val prod = builder.mul(x, y)
        val result = builder.sub(sum, prod)
        builder.ret(Some(result))
        builder.end_function()

        val module = builder.finish()

        # Verify before optimization
        val errors_before = IrTcVerifier.verify_module(module)
        expect(errors_before.len()).to_equal(0)

        # Optimize
        val pm = create_default_pipeline()
        val optimized = pm.run_all(module)

        # Verify after optimization - should still be valid
        val errors_after = IrTcVerifier.verify_module(optimized)
        expect(errors_after.len()).to_equal(0)

# ============================================================================
# Optimizer Pipeline — Dead code elimination E2E
# ============================================================================

describe "Dead code elimination through pipeline":
    """Build module with dead stores, verify DCE reduces real instruction count."""

    it "reduces real instruction count after optimization":
        # Build: function with add, mul, sub chain but only return sub result
        # The add and mul should remain (used by sub), but pipeline should
        # at least preserve correctness
        var builder = IrTcBuilder.new("dce_mod", IrTcModuleMode.Compilation)
        builder.begin_function("dce_test", [
            IrTcParam.new("a", IrTcTypeKind.I32),
            IrTcParam.new("b", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val a = builder.param_value(0)
        val b = builder.param_value(1)

        # These are used
        val sum = builder.add(a, b)

        # This is dead (result never used in return)
        val dead_prod = builder.mul(a, b)

        builder.ret(Some(sum))
        builder.end_function()

        val module = builder.finish()
        val before_real = count_real_instructions(module)

        # Run default pipeline (includes DCE)
        val pm = create_default_pipeline()
        val optimized = pm.run_all(module)

        val after_real = count_real_instructions(optimized)

        # After DCE, dead_prod mul should be eliminated
        # So real instruction count should be less or equal
        expect(after_real).to_be_less_than(before_real + 1)

# ============================================================================
# Optimizer Pipeline — Custom pipeline
# ============================================================================

describe "Custom optimization pipeline":
    """Build and run a custom pass manager configuration."""

    it "creates empty pipeline":
        var pm = PassManager.new()
        expect(pm.pass_count()).to_equal(0)

    it "adds passes incrementally":
        var pm = PassManager.new()
        pm.add_const_fold()
        expect(pm.pass_count()).to_equal(1)
        pm.add_dce()
        expect(pm.pass_count()).to_equal(2)

    it "runs empty pipeline without error":
        var pm = PassManager.new()

        var builder = IrTcBuilder.new("empty_pipe", IrTcModuleMode.Compilation)
        builder.begin_function("id", [IrTcParam.new("x", IrTcTypeKind.I32)], IrTcTypeKind.I32)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val x = builder.param_value(0)
        builder.ret(Some(x))
        builder.end_function()
        val module = builder.finish()

        val optimized = pm.run_all(module)
        expect(optimized.functions.len()).to_equal(1)

    it "preserves function count through optimization":
        var builder = IrTcBuilder.new("multi_fn", IrTcModuleMode.Compilation)

        # Function 1
        builder.begin_function("fn1", [], IrTcTypeKind.Void)
        val entry1 = builder.new_block("entry")
        builder.set_block(entry1)
        builder.ret(nil)
        builder.end_function()

        # Function 2
        builder.begin_function("fn2", [], IrTcTypeKind.Void)
        val entry2 = builder.new_block("entry")
        builder.set_block(entry2)
        builder.ret(nil)
        builder.end_function()

        val module = builder.finish()
        expect(module.functions.len()).to_equal(2)

        val pm = create_default_pipeline()
        val optimized = pm.run_all(module)
        expect(optimized.functions.len()).to_equal(2)
