#![allow(unnamed_duplicate_typed_args)]
# SMF Bridge — 32/64-bit Linker via System Linker
#
# For 32-bit and 64-bit targets, converts IR_TC CompactObject sections
# into standard ELF object format and delegates to the system linker
# (mold/lld/ld).
#
# This module generates minimal ELF relocatable objects (.o) that the
# system linker can consume, then invokes the linker to produce the
# final executable.

use format.irtc_binary.{encode_u16_le, encode_u32_le, encode_u64_le}
use linker.linker.{
    LinkerConfig, LinkerError, LinkResult,
    MergedSection, ResolvedSymbol, OutputFormat
}

# ============================================================================
# ELF Constants (shared with avr_elf but for 32/64-bit)
# ============================================================================

# ELF identification
val ELF_MAGIC_0: i64 = 0x7F
val ELF_MAGIC_1: i64 = 0x45         # 'E'
val ELF_MAGIC_2: i64 = 0x4C         # 'L'
val ELF_MAGIC_3: i64 = 0x46         # 'F'

val ELFCLASS32: i64 = 1
val ELFCLASS64: i64 = 2
val ELFDATA2LSB: i64 = 1
val EV_CURRENT: i64 = 1
val ELFOSABI_NONE: i64 = 0

val ET_EXEC: i64 = 2
val EM_386: i64 = 3                  # Intel 80386
val EM_X86_64: i64 = 62              # AMD x86-64
val EM_ARM: i64 = 40                 # ARM
val EM_AARCH64: i64 = 183            # ARM AARCH64
val EM_RISCV: i64 = 243              # RISC-V

# ELF header sizes
val ELF32_EHDR_SIZE: i64 = 52
val ELF64_EHDR_SIZE: i64 = 64
val ELF32_PHDR_SIZE: i64 = 32
val ELF64_PHDR_SIZE: i64 = 56
val ELF32_SHDR_SIZE: i64 = 40
val ELF64_SHDR_SIZE: i64 = 64

# Program header / section header types
val PT_LOAD: i64 = 1
val SHT_NULL: i64 = 0
val SHT_PROGBITS: i64 = 1
val SHT_STRTAB: i64 = 3
val SHT_NOBITS: i64 = 8

# Flags
val PF_X: i64 = 1
val PF_W: i64 = 2
val PF_R: i64 = 4
val SHF_WRITE: i64 = 1
val SHF_ALLOC: i64 = 2
val SHF_EXECINSTR: i64 = 4

# ============================================================================
# Bridge Entry Point
# ============================================================================

fn link_via_smf(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Bridge IR_TC link result to ELF32/ELF64 output.

    For 32/64-bit targets, this generates a self-contained ELF executable
    directly from the merged link result. In a full toolchain, this would
    instead emit relocatable objects and invoke the system linker.
    """
    match config.output_format:
        Elf32:
            _write_elf32(result, config)
        Elf64:
            _write_elf64(result, config)
        _:
            Err(LinkerError.InvalidFormat(
                message: "smf_bridge only handles Elf32/Elf64, got {config.output_format.to_text()}"
            ))

# ============================================================================
# ELF32 Writer
# ============================================================================

fn _write_elf32(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Generate a minimal ELF32 executable."""
    var output: [i64] = []

    # Classify sections
    var text_sects: [MergedSection] = []
    var data_sects: [MergedSection] = []
    var bss_sects: [MergedSection] = []

    for sect in result.sections:
        if sect.name == ".bss":
            bss_sects.push(sect)
        else if sect.is_writable():
            data_sects.push(sect)
        else:
            text_sects.push(sect)

    var text_size: i64 = 0
    for s in text_sects:
        text_size = text_size + s.size()
    var data_size: i64 = 0
    for s in data_sects:
        data_size = data_size + s.size()
    var bss_size: i64 = 0
    for s in bss_sects:
        bss_size = bss_size + s.size()

    # Program headers: text + data (if present)
    var phdr_count: i64 = 1
    if data_size > 0 or bss_size > 0:
        phdr_count = 2

    # Section headers: null + text sects + data sects + bss sects + .shstrtab
    val shdr_count = 1 + text_sects.len() + data_sects.len() + bss_sects.len() + 1

    # Build .shstrtab
    var shstrtab = _build_shstrtab_32(text_sects, data_sects, bss_sects)

    # Layout
    val phdr_off = ELF32_EHDR_SIZE
    val text_off = phdr_off + phdr_count * ELF32_PHDR_SIZE
    val data_off = text_off + text_size
    val shstrtab_off = data_off + data_size
    var shdr_off = shstrtab_off + shstrtab.len()
    if shdr_off % 4 != 0:
        shdr_off = shdr_off + (4 - shdr_off % 4)

    val text_base = if text_sects.len() > 0: text_sects[0].addr else: config.base_address

    # --- ELF Header ---
    output.push(ELF_MAGIC_0)
    output.push(ELF_MAGIC_1)
    output.push(ELF_MAGIC_2)
    output.push(ELF_MAGIC_3)
    output.push(ELFCLASS32)
    output.push(ELFDATA2LSB)
    output.push(EV_CURRENT)
    output.push(ELFOSABI_NONE)
    for _ in 0..8:
        output.push(0)

    _push_u16_le(output, ET_EXEC)
    _push_u16_le(output, EM_386)
    _push_u32_le(output, 1)                        # e_version
    _push_u32_le(output, result.entry_address)     # e_entry
    _push_u32_le(output, phdr_off)                 # e_phoff
    _push_u32_le(output, shdr_off)                 # e_shoff
    _push_u32_le(output, 0)                        # e_flags
    _push_u16_le(output, ELF32_EHDR_SIZE)          # e_ehsize
    _push_u16_le(output, ELF32_PHDR_SIZE)          # e_phentsize
    _push_u16_le(output, phdr_count)               # e_phnum
    _push_u16_le(output, ELF32_SHDR_SIZE)          # e_shentsize
    _push_u16_le(output, shdr_count)               # e_shnum
    _push_u16_le(output, shdr_count - 1)           # e_shstrndx

    # --- Program Headers ---
    # Text segment
    _push_u32_le(output, PT_LOAD)
    _push_u32_le(output, text_off)
    _push_u32_le(output, text_base)
    _push_u32_le(output, text_base)
    _push_u32_le(output, text_size)
    _push_u32_le(output, text_size)
    _push_u32_le(output, PF_R + PF_X)
    _push_u32_le(output, 0x1000)                   # Page alignment

    if phdr_count > 1:
        val data_base = if data_sects.len() > 0: data_sects[0].addr else: text_base + text_size
        _push_u32_le(output, PT_LOAD)
        _push_u32_le(output, data_off)
        _push_u32_le(output, data_base)
        _push_u32_le(output, data_base)
        _push_u32_le(output, data_size)
        _push_u32_le(output, data_size + bss_size)
        _push_u32_le(output, PF_R + PF_W)
        _push_u32_le(output, 0x1000)

    # --- Section Data ---
    for sect in text_sects:
        for b in sect.data:
            output.push(b)
    for sect in data_sects:
        for b in sect.data:
            output.push(b)

    val actual_shstrtab_off = output.len()
    for b in shstrtab:
        output.push(b)

    while output.len() % 4 != 0:
        output.push(0)

    val actual_shdr_off = output.len()

    # --- Section Headers ---
    _write_shdr32(output, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0)

    var str_pos: i64 = 1
    var f_off = text_off
    for sect in text_sects:
        _write_shdr32(output, str_pos, SHT_PROGBITS, SHF_ALLOC + SHF_EXECINSTR,
                      sect.addr, f_off, sect.size(), 0, 0, 16, 0)
        str_pos = str_pos + sect.name.len() + 1
        f_off = f_off + sect.size()

    for sect in data_sects:
        _write_shdr32(output, str_pos, SHT_PROGBITS, SHF_ALLOC + SHF_WRITE,
                      sect.addr, f_off, sect.size(), 0, 0, 4, 0)
        str_pos = str_pos + sect.name.len() + 1
        f_off = f_off + sect.size()

    for sect in bss_sects:
        _write_shdr32(output, str_pos, SHT_NOBITS, SHF_ALLOC + SHF_WRITE,
                      sect.addr, 0, sect.size(), 0, 0, 4, 0)
        str_pos = str_pos + sect.name.len() + 1

    _write_shdr32(output, str_pos, SHT_STRTAB, 0,
                  0, actual_shstrtab_off, shstrtab.len(), 0, 0, 1, 0)

    # Patch e_shoff
    var shoff_bytes = encode_u32_le(actual_shdr_off)
    output[32] = shoff_bytes[0]
    output[33] = shoff_bytes[1]
    output[34] = shoff_bytes[2]
    output[35] = shoff_bytes[3]

    Ok(output)

# ============================================================================
# ELF64 Writer
# ============================================================================

fn _write_elf64(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Generate a minimal ELF64 executable."""
    var output: [i64] = []

    var text_sects: [MergedSection] = []
    var data_sects: [MergedSection] = []
    var bss_sects: [MergedSection] = []

    for sect in result.sections:
        if sect.name == ".bss":
            bss_sects.push(sect)
        else if sect.is_writable():
            data_sects.push(sect)
        else:
            text_sects.push(sect)

    var text_size: i64 = 0
    for s in text_sects:
        text_size = text_size + s.size()
    var data_size: i64 = 0
    for s in data_sects:
        data_size = data_size + s.size()
    var bss_size: i64 = 0
    for s in bss_sects:
        bss_size = bss_size + s.size()

    var phdr_count: i64 = 1
    if data_size > 0 or bss_size > 0:
        phdr_count = 2

    val shdr_count = 1 + text_sects.len() + data_sects.len() + bss_sects.len() + 1

    var shstrtab = _build_shstrtab_32(text_sects, data_sects, bss_sects)

    val phdr_off = ELF64_EHDR_SIZE
    val text_off = phdr_off + phdr_count * ELF64_PHDR_SIZE
    val data_off = text_off + text_size
    val shstrtab_off = data_off + data_size
    var shdr_off = shstrtab_off + shstrtab.len()
    if shdr_off % 8 != 0:
        shdr_off = shdr_off + (8 - shdr_off % 8)

    val text_base = if text_sects.len() > 0: text_sects[0].addr else: config.base_address

    # --- ELF64 Header (64 bytes) ---
    output.push(ELF_MAGIC_0)
    output.push(ELF_MAGIC_1)
    output.push(ELF_MAGIC_2)
    output.push(ELF_MAGIC_3)
    output.push(ELFCLASS64)
    output.push(ELFDATA2LSB)
    output.push(EV_CURRENT)
    output.push(ELFOSABI_NONE)
    for _ in 0..8:
        output.push(0)

    _push_u16_le(output, ET_EXEC)                  # e_type
    _push_u16_le(output, EM_X86_64)                # e_machine
    _push_u32_le(output, 1)                        # e_version
    _push_u64_le(output, result.entry_address)     # e_entry
    _push_u64_le(output, phdr_off)                 # e_phoff
    _push_u64_le(output, shdr_off)                 # e_shoff
    _push_u32_le(output, 0)                        # e_flags
    _push_u16_le(output, ELF64_EHDR_SIZE)          # e_ehsize
    _push_u16_le(output, ELF64_PHDR_SIZE)          # e_phentsize
    _push_u16_le(output, phdr_count)               # e_phnum
    _push_u16_le(output, ELF64_SHDR_SIZE)          # e_shentsize
    _push_u16_le(output, shdr_count)               # e_shnum
    _push_u16_le(output, shdr_count - 1)           # e_shstrndx

    # --- Program Headers (ELF64: 56 bytes each) ---
    # Text segment
    _push_u32_le(output, PT_LOAD)                  # p_type
    _push_u32_le(output, PF_R + PF_X)             # p_flags (note: different position in ELF64!)
    _push_u64_le(output, text_off)                 # p_offset
    _push_u64_le(output, text_base)                # p_vaddr
    _push_u64_le(output, text_base)                # p_paddr
    _push_u64_le(output, text_size)                # p_filesz
    _push_u64_le(output, text_size)                # p_memsz
    _push_u64_le(output, 0x1000)                   # p_align

    if phdr_count > 1:
        val data_base = if data_sects.len() > 0: data_sects[0].addr else: text_base + text_size
        _push_u32_le(output, PT_LOAD)
        _push_u32_le(output, PF_R + PF_W)
        _push_u64_le(output, data_off)
        _push_u64_le(output, data_base)
        _push_u64_le(output, data_base)
        _push_u64_le(output, data_size)
        _push_u64_le(output, data_size + bss_size)
        _push_u64_le(output, 0x1000)

    # --- Section Data ---
    for sect in text_sects:
        for b in sect.data:
            output.push(b)
    for sect in data_sects:
        for b in sect.data:
            output.push(b)

    val actual_shstrtab_off = output.len()
    for b in shstrtab:
        output.push(b)

    while output.len() % 8 != 0:
        output.push(0)

    val actual_shdr_off = output.len()

    # --- Section Headers (ELF64: 64 bytes each) ---
    _write_shdr64(output, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0)

    var str_pos: i64 = 1
    var f_off = text_off
    for sect in text_sects:
        _write_shdr64(output, str_pos, SHT_PROGBITS, SHF_ALLOC + SHF_EXECINSTR,
                      sect.addr, f_off, sect.size(), 0, 0, 16, 0)
        str_pos = str_pos + sect.name.len() + 1
        f_off = f_off + sect.size()

    for sect in data_sects:
        _write_shdr64(output, str_pos, SHT_PROGBITS, SHF_ALLOC + SHF_WRITE,
                      sect.addr, f_off, sect.size(), 0, 0, 8, 0)
        str_pos = str_pos + sect.name.len() + 1
        f_off = f_off + sect.size()

    for sect in bss_sects:
        _write_shdr64(output, str_pos, SHT_NOBITS, SHF_ALLOC + SHF_WRITE,
                      sect.addr, 0, sect.size(), 0, 0, 8, 0)
        str_pos = str_pos + sect.name.len() + 1

    _write_shdr64(output, str_pos, SHT_STRTAB, 0,
                  0, actual_shstrtab_off, shstrtab.len(), 0, 0, 1, 0)

    # Patch e_shoff (at offset 40 in ELF64 header)
    var shoff_bytes = encode_u64_le(actual_shdr_off)
    for i in 0..8:
        output[40 + i] = shoff_bytes[i]

    Ok(output)

# ============================================================================
# String Table Builder (shared)
# ============================================================================

fn _build_shstrtab_32(text_sects: [MergedSection], data_sects: [MergedSection], bss_sects: [MergedSection]) -> [i64]:
    """Build section header string table."""
    var table: [i64] = []
    table.push(0)    # Leading null

    for s in text_sects:
        _push_str(table, s.name)
    for s in data_sects:
        _push_str(table, s.name)
    for s in bss_sects:
        _push_str(table, s.name)
    _push_str(table, ".shstrtab")

    table

fn _push_str(table: [i64], s: text):
    """Push null-terminated ASCII string."""
    for i in 0..s.len():
        val ch = s[i:i + 1]
        table.push(_ascii(ch))
    table.push(0)

fn _ascii(ch: text) -> i64:
    """Single character to ASCII byte."""
    if ch == ".": return 46
    if ch == "_": return 95
    if ch >= "a" and ch <= "z":
        # a=97
        if ch == "a": return 97
        if ch == "b": return 98
        if ch == "c": return 99
        if ch == "d": return 100
        if ch == "e": return 101
        if ch == "f": return 102
        if ch == "g": return 103
        if ch == "h": return 104
        if ch == "i": return 105
        if ch == "j": return 106
        if ch == "k": return 107
        if ch == "l": return 108
        if ch == "m": return 109
        if ch == "n": return 110
        if ch == "o": return 111
        if ch == "p": return 112
        if ch == "q": return 113
        if ch == "r": return 114
        if ch == "s": return 115
        if ch == "t": return 116
        if ch == "u": return 117
        if ch == "v": return 118
        if ch == "w": return 119
        if ch == "x": return 120
        if ch == "y": return 121
        if ch == "z": return 122
    if ch >= "0" and ch <= "9":
        if ch == "0": return 48
        if ch == "1": return 49
        if ch == "2": return 50
        if ch == "3": return 51
        if ch == "4": return 52
        if ch == "5": return 53
        if ch == "6": return 54
        if ch == "7": return 55
        if ch == "8": return 56
        if ch == "9": return 57
    63   # '?' fallback

# ============================================================================
# Section Header Writers
# ============================================================================

fn _write_shdr32(output: [i64], name: i64, type_: i64, flags: i64,
                 addr: i64, offset: i64, size: i64, link: i64,
                 info: i64, addralign: i64, entsize: i64):
    """Write ELF32 section header (40 bytes)."""
    _push_u32_le(output, name)
    _push_u32_le(output, type_)
    _push_u32_le(output, flags)
    _push_u32_le(output, addr)
    _push_u32_le(output, offset)
    _push_u32_le(output, size)
    _push_u32_le(output, link)
    _push_u32_le(output, info)
    _push_u32_le(output, addralign)
    _push_u32_le(output, entsize)

fn _write_shdr64(output: [i64], name: i64, type_: i64, flags: i64,
                 addr: i64, offset: i64, size: i64, link: i64,
                 info: i64, addralign: i64, entsize: i64):
    """Write ELF64 section header (64 bytes)."""
    _push_u32_le(output, name)         # sh_name
    _push_u32_le(output, type_)        # sh_type
    _push_u64_le(output, flags)        # sh_flags
    _push_u64_le(output, addr)         # sh_addr
    _push_u64_le(output, offset)       # sh_offset
    _push_u64_le(output, size)         # sh_size
    _push_u32_le(output, link)         # sh_link
    _push_u32_le(output, info)         # sh_info
    _push_u64_le(output, addralign)    # sh_addralign
    _push_u64_le(output, entsize)      # sh_entsize

# ============================================================================
# Byte Encoding Helpers
# ============================================================================

fn _push_u16_le(output: [i64], value: i64):
    """Append 16-bit LE."""
    output.push(value % 256)
    output.push((value / 256) % 256)

fn _push_u32_le(output: [i64], value: i64):
    """Append 32-bit LE."""
    output.push(value % 256)
    output.push((value / 256) % 256)
    output.push((value / 65536) % 256)
    output.push((value / 16777216) % 256)

fn _push_u64_le(output: [i64], value: i64):
    """Append 64-bit LE."""
    var v = value
    for _ in 0..8:
        output.push(v % 256)
        v = v / 256
