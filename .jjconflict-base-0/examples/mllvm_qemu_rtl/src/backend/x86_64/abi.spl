# System V AMD64 ABI Implementation
#
# Handles calling convention details for the x86_64 host backend:
# - Argument passing: RDI, RSI, RDX, RCX, R8, R9 (integers)
# - Return value: RAX (integer)
# - Callee-saved: RBX, RBP, R12-R15
# - Red zone: 128 bytes below RSP (leaf functions)
# - Stack alignment: 16-byte at call site

use core.types.{IrTcTypeKind, IrTcValue, CallConv}
use core.block.{IrTcFunction, IrTcParam}
use backend.isel_common.{X64Reg, X64Inst, X64Operand, X64Cond}
use backend.isel_common.{virt_reg, phys_reg, op_reg, op_phys, op_imm, op_mem}
use backend.isel_common.{new_x64_inst}
use backend.isel_common.{X64_RAX, X64_RCX, X64_RDX, X64_RBX, X64_RSP, X64_RBP}
use backend.isel_common.{X64_RSI, X64_RDI, X64_R8, X64_R9, X64_R10, X64_R11}
use backend.isel_common.{X64_R12, X64_R13, X64_R14, X64_R15}
use backend.isel_common.{X64_ARG_REGS, X64_ARG_REG_COUNT, X64_RET_REG}
use backend.isel_common.{X64_CALLEE_SAVED, X64_CALLER_SAVED}
use backend.isel_common.{X64_OP_MOV_RR, X64_OP_MOV_RM, X64_OP_MOV_MR, X64_OP_MOV_RI}
use backend.isel_common.{X64_OP_PUSH, X64_OP_POP, X64_OP_SUB_RI, X64_OP_ADD_RI}
use backend.isel_common.{X64_OP_RET, X64_OP_CALL, X64_OP_CALL_R}

# ============================================================================
# ABI Constants
# ============================================================================

val RED_ZONE_SIZE: i64 = 128
val STACK_ALIGNMENT: i64 = 16

# ============================================================================
# Function Prologue/Epilogue
# ============================================================================

fn emit_prologue(frame_size: i64, used_callee_saved: [i64]) -> [X64Inst]:
    """Generate function prologue instructions.

    push rbp
    mov rbp, rsp
    sub rsp, frame_size   (if frame_size > 0)
    push <callee-saved>   (for each used callee-saved register)
    """
    var insts: [X64Inst] = []

    # push rbp
    insts.push(new_x64_inst(X64_OP_PUSH, [op_phys(X64_RBP)]))

    # mov rbp, rsp
    insts.push(new_x64_inst(X64_OP_MOV_RR, [op_phys(X64_RBP), op_phys(X64_RSP)]))

    # Compute total frame: local frame + callee-saved saves
    val callee_saved_space = used_callee_saved.len() * 8
    val total = frame_size + callee_saved_space

    # Align to 16 bytes
    val aligned = if total % STACK_ALIGNMENT != 0:
        total + (STACK_ALIGNMENT - (total % STACK_ALIGNMENT))
    else:
        total

    if aligned > 0:
        # sub rsp, aligned
        insts.push(new_x64_inst(X64_OP_SUB_RI, [op_phys(X64_RSP), op_imm(aligned)]))

    # Save callee-saved registers
    for reg in used_callee_saved:
        insts.push(new_x64_inst(X64_OP_PUSH, [op_phys(reg)]))

    insts

fn emit_epilogue(frame_size: i64, used_callee_saved: [i64]) -> [X64Inst]:
    """Generate function epilogue instructions.

    pop <callee-saved>    (in reverse order)
    mov rsp, rbp          (or add rsp, frame)
    pop rbp
    ret
    """
    var insts: [X64Inst] = []

    # Restore callee-saved registers (reverse order)
    var i = used_callee_saved.len() - 1
    while i >= 0:
        insts.push(new_x64_inst(X64_OP_POP, [op_phys(used_callee_saved[i])]))
        i = i - 1

    # mov rsp, rbp
    insts.push(new_x64_inst(X64_OP_MOV_RR, [op_phys(X64_RSP), op_phys(X64_RBP)]))

    # pop rbp
    insts.push(new_x64_inst(X64_OP_POP, [op_phys(X64_RBP)]))

    # ret
    insts.push(new_x64_inst(X64_OP_RET, []))

    insts

# ============================================================================
# Argument Passing
# ============================================================================

fn emit_arg_setup(args: [X64Reg]) -> [X64Inst]:
    """Move arguments into the correct ABI registers before a call.

    First 6 integer args go to: RDI, RSI, RDX, RCX, R8, R9.
    Additional args are pushed on stack (right-to-left).
    """
    var insts: [X64Inst] = []

    # Register arguments (first 6)
    var i = 0
    while i < args.len():
        if i < X64_ARG_REG_COUNT:
            val target_reg = X64_ARG_REGS[i]
            # mov arg_reg, src
            insts.push(new_x64_inst(X64_OP_MOV_RR, [op_phys(target_reg), op_reg(args[i])]))
        i = i + 1

    # Stack arguments (pushed right-to-left)
    if args.len() > X64_ARG_REG_COUNT:
        var si = args.len() - 1
        while si >= X64_ARG_REG_COUNT:
            insts.push(new_x64_inst(X64_OP_PUSH, [op_reg(args[si])]))
            si = si - 1

    insts

fn emit_stack_arg_cleanup(num_stack_args: i64) -> [X64Inst]:
    """Clean up stack arguments after a call (caller cleans in System V)."""
    var insts: [X64Inst] = []
    if num_stack_args > 0:
        val bytes = num_stack_args * 8
        insts.push(new_x64_inst(X64_OP_ADD_RI, [op_phys(X64_RSP), op_imm(bytes)]))
    insts

fn emit_call_direct(offset: i64) -> [X64Inst]:
    """Emit a direct call instruction."""
    var insts: [X64Inst] = []
    insts.push(new_x64_inst(X64_OP_CALL, [op_imm(offset)]))
    insts

fn emit_call_indirect(target: X64Reg) -> [X64Inst]:
    """Emit an indirect call through a register."""
    var insts: [X64Inst] = []
    insts.push(new_x64_inst(X64_OP_CALL_R, [op_reg(target)]))
    insts

fn emit_return_value_move(src: X64Reg) -> [X64Inst]:
    """Move a value into RAX for return."""
    var insts: [X64Inst] = []
    insts.push(new_x64_inst(X64_OP_MOV_RR, [op_phys(X64_RET_REG), op_reg(src)]))
    insts

# ============================================================================
# Parameter Loading
# ============================================================================

fn emit_load_params(param_count: i64, param_vregs: [i64]) -> [X64Inst]:
    """Move function parameters from ABI registers to virtual registers.

    Called at function entry to capture incoming arguments.
    """
    var insts: [X64Inst] = []
    var i = 0
    while i < param_count:
        if i < X64_ARG_REG_COUNT:
            val arg_phys = X64_ARG_REGS[i]
            val dest_vreg = param_vregs[i]
            # mov vreg, arg_reg
            insts.push(new_x64_inst(X64_OP_MOV_RR, [
                op_reg(virt_reg(dest_vreg)),
                op_phys(arg_phys)
            ]))
        else:
            # Stack parameter: [RBP + 16 + (i - 6) * 8]
            val stack_offset = 16 + (i - X64_ARG_REG_COUNT) * 8
            val dest_vreg = param_vregs[i]
            insts.push(new_x64_inst(X64_OP_MOV_RM, [
                op_reg(virt_reg(dest_vreg)),
                op_mem(phys_reg(X64_RBP), stack_offset)
            ]))
        i = i + 1
    insts

# ============================================================================
# Stack Alignment Helper
# ============================================================================

fn align_stack_for_call(num_stack_args: i64) -> [X64Inst]:
    """Ensure 16-byte stack alignment before a call.

    After pushing N stack args (N*8 bytes), RSP must be 16-byte aligned
    at the call site (the call itself pushes 8 bytes for return address).
    """
    var insts: [X64Inst] = []
    if num_stack_args > 0:
        val arg_bytes = num_stack_args * 8
        val remainder = arg_bytes % STACK_ALIGNMENT
        if remainder != 0:
            val padding = STACK_ALIGNMENT - remainder
            insts.push(new_x64_inst(X64_OP_SUB_RI, [op_phys(X64_RSP), op_imm(padding)]))
    insts

# ============================================================================
# Query helpers
# ============================================================================

fn is_callee_saved(reg_id: i64) -> bool:
    """Check if a physical register is callee-saved."""
    for r in X64_CALLEE_SAVED:
        if r == reg_id:
            return true
    false

fn is_caller_saved(reg_id: i64) -> bool:
    """Check if a physical register is caller-saved."""
    for r in X64_CALLER_SAVED:
        if r == reg_id:
            return true
    false

fn arg_reg_for_index(index: i64) -> i64:
    """Return the physical register for argument at given index, or -1 if stack."""
    if index < X64_ARG_REG_COUNT:
        X64_ARG_REGS[index]
    else:
        -1

fn stack_arg_offset(index: i64) -> i64:
    """Return the RBP-relative offset for a stack argument (index >= 6)."""
    16 + (index - X64_ARG_REG_COUNT) * 8
