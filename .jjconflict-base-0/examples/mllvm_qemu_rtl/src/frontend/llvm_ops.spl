# LLVM Instruction → IR_TC Op Mapping
#
# Maps LLVM IR instructions to IR_TC ops.
# Most map 1:1; some LLVM instructions expand to multiple IR_TC ops.

use core.types.{IrTcTypeKind, IrTcValue, IrTcCond, CallConv}
use core.ops.{IrTcOp, SwitchCase, PhiEntry}
use core.mem_op.{MemOp, Endian}
use core.block.{BlockId}

# ============================================================================
# LLVM Instruction Representation
# ============================================================================

enum LlvmOpcode:
    """LLVM IR instruction opcodes relevant for IR_TC conversion."""
    # Arithmetic
    LlvmAdd
    LlvmSub
    LlvmMul
    LlvmUDiv
    LlvmSDiv
    LlvmURem
    LlvmSRem
    LlvmFAdd
    LlvmFSub
    LlvmFMul
    LlvmFDiv
    LlvmFRem
    LlvmFNeg

    # Bitwise
    LlvmAnd
    LlvmOr
    LlvmXor
    LlvmShl
    LlvmLShr
    LlvmAShr

    # Comparison
    LlvmICmp
    LlvmFCmp

    # Conversion
    LlvmZExt
    LlvmSExt
    LlvmTrunc
    LlvmBitCast
    LlvmFPToSI
    LlvmFPToUI
    LlvmSIToFP
    LlvmUIToFP
    LlvmPtrToInt
    LlvmIntToPtr

    # Memory
    LlvmLoad
    LlvmStore
    LlvmAlloca
    LlvmGetElementPtr

    # Control flow
    LlvmBr
    LlvmCondBr
    LlvmSwitch
    LlvmRet
    LlvmUnreachable

    # Other
    LlvmCall
    LlvmPhi
    LlvmSelect
    LlvmExtractValue
    LlvmInsertValue

# ============================================================================
# LLVM ICmp Predicate
# ============================================================================

enum LlvmICmpPred:
    IcmpEq
    IcmpNe
    IcmpSlt
    IcmpSle
    IcmpSgt
    IcmpSge
    IcmpUlt
    IcmpUle
    IcmpUgt
    IcmpUge

fn llvm_icmp_to_irtc_cond(pred: LlvmICmpPred) -> IrTcCond:
    match pred:
        IcmpEq: IrTcCond.Eq
        IcmpNe: IrTcCond.Ne
        IcmpSlt: IrTcCond.Lt
        IcmpSle: IrTcCond.Le
        IcmpSgt: IrTcCond.Gt
        IcmpSge: IrTcCond.Ge
        IcmpUlt: IrTcCond.Ltu
        IcmpUle: IrTcCond.Leu
        IcmpUgt: IrTcCond.Gtu
        IcmpUge: IrTcCond.Geu

# ============================================================================
# Opcode Mapping
# ============================================================================

fn map_llvm_binary_op(opcode: LlvmOpcode, dest: IrTcValue, a: IrTcValue, b: IrTcValue) -> IrTcOp?:
    """Map an LLVM binary operation to an IR_TC op."""
    match opcode:
        LlvmAdd: Some(IrTcOp.Add(dest: dest, a: a, b: b))
        LlvmFAdd: Some(IrTcOp.Add(dest: dest, a: a, b: b))
        LlvmSub: Some(IrTcOp.Sub(dest: dest, a: a, b: b))
        LlvmFSub: Some(IrTcOp.Sub(dest: dest, a: a, b: b))
        LlvmMul: Some(IrTcOp.Mul(dest: dest, a: a, b: b))
        LlvmFMul: Some(IrTcOp.Mul(dest: dest, a: a, b: b))
        LlvmUDiv: Some(IrTcOp.Div(dest: dest, a: a, b: b, signed: false))
        LlvmSDiv: Some(IrTcOp.Div(dest: dest, a: a, b: b, signed: true))
        LlvmFDiv: Some(IrTcOp.Div(dest: dest, a: a, b: b, signed: true))
        LlvmURem: Some(IrTcOp.Rem(dest: dest, a: a, b: b, signed: false))
        LlvmSRem: Some(IrTcOp.Rem(dest: dest, a: a, b: b, signed: true))
        LlvmFRem: Some(IrTcOp.Rem(dest: dest, a: a, b: b, signed: true))
        LlvmAnd: Some(IrTcOp.And(dest: dest, a: a, b: b))
        LlvmOr: Some(IrTcOp.Or(dest: dest, a: a, b: b))
        LlvmXor: Some(IrTcOp.Xor(dest: dest, a: a, b: b))
        LlvmShl: Some(IrTcOp.Shl(dest: dest, a: a, b: b))
        LlvmLShr: Some(IrTcOp.Shr(dest: dest, a: a, b: b))
        LlvmAShr: Some(IrTcOp.Sar(dest: dest, a: a, b: b))
        _: nil

fn map_llvm_cast_op(opcode: LlvmOpcode, dest: IrTcValue, src: IrTcValue) -> IrTcOp?:
    """Map an LLVM cast operation to an IR_TC op."""
    match opcode:
        LlvmZExt: Some(IrTcOp.Ext(dest: dest, src: src, signed: false))
        LlvmSExt: Some(IrTcOp.Ext(dest: dest, src: src, signed: true))
        LlvmTrunc: Some(IrTcOp.Trunc(dest: dest, src: src))
        LlvmBitCast: Some(IrTcOp.Bitcast(dest: dest, src: src))
        LlvmPtrToInt: Some(IrTcOp.Bitcast(dest: dest, src: src))
        LlvmIntToPtr: Some(IrTcOp.Bitcast(dest: dest, src: src))
        # FP conversions map to Ext/Trunc based on direction
        LlvmFPToSI: Some(IrTcOp.Bitcast(dest: dest, src: src))
        LlvmFPToUI: Some(IrTcOp.Bitcast(dest: dest, src: src))
        LlvmSIToFP: Some(IrTcOp.Bitcast(dest: dest, src: src))
        LlvmUIToFP: Some(IrTcOp.Bitcast(dest: dest, src: src))
        _: nil
