# LLVM Type → IR_TC Type Mapping
#
# Maps LLVM IR types to IR_TC types.
# LLVM types: i1, i8, i16, i32, i64, float, double, ptr, vector, struct, array, void

use core.types.{IrTcTypeKind}

# ============================================================================
# LLVM Type Representation
# ============================================================================

enum LlvmType:
    """Subset of LLVM IR types relevant for IR_TC conversion."""
    IntType(bits: i64)           # iN (i1, i8, i16, i32, i64, etc.)
    FloatType                     # float (32-bit IEEE 754)
    DoubleType                    # double (64-bit IEEE 754)
    PtrType(addr_space: i64)     # ptr addrspace(N)
    VectorType(elem: LlvmType, count: i64)
    StructType(fields: [LlvmType])
    ArrayType(elem: LlvmType, count: i64)
    VoidType
    FunctionType(ret: LlvmType, params: [LlvmType])
    LabelType

# ============================================================================
# Conversion
# ============================================================================

fn llvm_type_to_irtc(llvm_type: LlvmType) -> IrTcTypeKind:
    """Convert an LLVM type to the corresponding IR_TC type."""
    match llvm_type:
        IntType(bits):
            match bits:
                1: IrTcTypeKind.I1
                8: IrTcTypeKind.I8
                16: IrTcTypeKind.I16
                32: IrTcTypeKind.I32
                64: IrTcTypeKind.I64
                _:
                    # For arbitrary-width integers, round up to next power-of-2 width
                    if bits <= 8: IrTcTypeKind.I8
                    else if bits <= 16: IrTcTypeKind.I16
                    else if bits <= 32: IrTcTypeKind.I32
                    else: IrTcTypeKind.I64

        FloatType: IrTcTypeKind.F32
        DoubleType: IrTcTypeKind.F64
        PtrType(as_): IrTcTypeKind.Ptr(addr_space: as_)

        VectorType(elem, count):
            IrTcTypeKind.Vec(elem: llvm_type_to_irtc(elem), count: count)

        StructType(fields):
            var irtc_fields: [IrTcTypeKind] = []
            for f in fields:
                irtc_fields.push(llvm_type_to_irtc(f))
            IrTcTypeKind.Struct(fields: irtc_fields)

        ArrayType(elem, count):
            IrTcTypeKind.Array(elem: llvm_type_to_irtc(elem), count: count)

        VoidType: IrTcTypeKind.Void
        FunctionType(_, _): IrTcTypeKind.Ptr(addr_space: 0)  # Functions are pointers
        LabelType: IrTcTypeKind.Void  # Labels don't have runtime type

fn irtc_type_to_llvm(irtc_type: IrTcTypeKind) -> LlvmType:
    """Convert an IR_TC type back to LLVM type (for .bc export)."""
    match irtc_type:
        I1: LlvmType.IntType(bits: 1)
        I8: LlvmType.IntType(bits: 8)
        I16: LlvmType.IntType(bits: 16)
        I32: LlvmType.IntType(bits: 32)
        I64: LlvmType.IntType(bits: 64)
        F32: LlvmType.FloatType
        F64: LlvmType.DoubleType
        Ptr(as_): LlvmType.PtrType(addr_space: as_)
        Vec(elem, count): LlvmType.VectorType(elem: irtc_type_to_llvm(elem), count: count)
        Struct(fields):
            var llvm_fields: [LlvmType] = []
            for f in fields:
                llvm_fields.push(irtc_type_to_llvm(f))
            LlvmType.StructType(fields: llvm_fields)
        Array(elem, count): LlvmType.ArrayType(elem: irtc_type_to_llvm(elem), count: count)
        Void: LlvmType.VoidType
        Flag: LlvmType.IntType(bits: 8)  # Flags map to i8
