# 8086 Guest CPU Definition
#
# Intel 8086 16-bit processor.
# - 8 x 16-bit general purpose registers (AX, BX, CX, DX, SI, DI, BP, SP)
# - 8-bit sub-registers (AL/AH, BL/BH, CL/CH, DL/DH)
# - 4 x 16-bit segment registers (CS, DS, SS, ES)
# - 16-bit instruction pointer (IP)
# - 16-bit FLAGS register
# - Segmented memory model: physical addr = segment * 16 + offset (20-bit)

use core.types.{GuestArch}
use core.mem_op.{Endian, GuestRegId}
use guest.cpu_def.{GuestCpuDef, GuestRegDef, GuestRegAlias, AddrSpaceDef}

# ============================================================================
# Register Indices
# ============================================================================

# General purpose (0-7)
val X86_REG_AX: i64 = 0
val X86_REG_BX: i64 = 1
val X86_REG_CX: i64 = 2
val X86_REG_DX: i64 = 3
val X86_REG_SI: i64 = 4
val X86_REG_DI: i64 = 5
val X86_REG_BP: i64 = 6
val X86_REG_SP: i64 = 7

# Segment registers (8-11)
val X86_REG_CS: i64 = 8
val X86_REG_DS: i64 = 9
val X86_REG_SS: i64 = 10
val X86_REG_ES: i64 = 11

# IP and FLAGS (12-13)
val X86_REG_IP: i64 = 12
val X86_REG_FLAGS: i64 = 13

# FLAGS bit positions
val X86_FLAG_CF: i64 = 0     # Carry
val X86_FLAG_PF: i64 = 2     # Parity
val X86_FLAG_AF: i64 = 4     # Auxiliary carry
val X86_FLAG_ZF: i64 = 6     # Zero
val X86_FLAG_SF: i64 = 7     # Sign
val X86_FLAG_TF: i64 = 8     # Trap
val X86_FLAG_IF: i64 = 9     # Interrupt enable
val X86_FLAG_DF: i64 = 10    # Direction
val X86_FLAG_OF: i64 = 11    # Overflow

# ============================================================================
# 8086 CPU Definition Builder
# ============================================================================

fn build_i8086_cpu_def() -> GuestCpuDef:
    """Build the complete 8086 CPU definition."""
    var registers: [GuestRegDef] = []

    # AX with AL/AH sub-registers
    val ax_id = GuestRegId.new(GuestArch.I8086, X86_REG_AX, "AX")
    var ax_reg = GuestRegDef.new(ax_id, 16)
    ax_reg = ax_reg.with_alias(GuestRegAlias.new("AL", X86_REG_AX, 0, 8))
    ax_reg = ax_reg.with_alias(GuestRegAlias.new("AH", X86_REG_AX, 8, 8))
    registers.push(ax_reg)

    # BX with BL/BH
    val bx_id = GuestRegId.new(GuestArch.I8086, X86_REG_BX, "BX")
    var bx_reg = GuestRegDef.new(bx_id, 16)
    bx_reg = bx_reg.with_alias(GuestRegAlias.new("BL", X86_REG_BX, 0, 8))
    bx_reg = bx_reg.with_alias(GuestRegAlias.new("BH", X86_REG_BX, 8, 8))
    registers.push(bx_reg)

    # CX with CL/CH
    val cx_id = GuestRegId.new(GuestArch.I8086, X86_REG_CX, "CX")
    var cx_reg = GuestRegDef.new(cx_id, 16)
    cx_reg = cx_reg.with_alias(GuestRegAlias.new("CL", X86_REG_CX, 0, 8))
    cx_reg = cx_reg.with_alias(GuestRegAlias.new("CH", X86_REG_CX, 8, 8))
    registers.push(cx_reg)

    # DX with DL/DH
    val dx_id = GuestRegId.new(GuestArch.I8086, X86_REG_DX, "DX")
    var dx_reg = GuestRegDef.new(dx_id, 16)
    dx_reg = dx_reg.with_alias(GuestRegAlias.new("DL", X86_REG_DX, 0, 8))
    dx_reg = dx_reg.with_alias(GuestRegAlias.new("DH", X86_REG_DX, 8, 8))
    registers.push(dx_reg)

    # SI, DI, BP, SP (16-bit only, no sub-registers)
    val si_id = GuestRegId.new(GuestArch.I8086, X86_REG_SI, "SI")
    registers.push(GuestRegDef.new(si_id, 16))

    val di_id = GuestRegId.new(GuestArch.I8086, X86_REG_DI, "DI")
    registers.push(GuestRegDef.new(di_id, 16))

    val bp_id = GuestRegId.new(GuestArch.I8086, X86_REG_BP, "BP")
    registers.push(GuestRegDef.new(bp_id, 16))

    val sp_id = GuestRegId.new(GuestArch.I8086, X86_REG_SP, "SP")
    registers.push(GuestRegDef.new(sp_id, 16))

    # Segment registers (16-bit)
    val cs_id = GuestRegId.new(GuestArch.I8086, X86_REG_CS, "CS")
    registers.push(GuestRegDef.new(cs_id, 16))

    val ds_id = GuestRegId.new(GuestArch.I8086, X86_REG_DS, "DS")
    registers.push(GuestRegDef.new(ds_id, 16))

    val ss_id = GuestRegId.new(GuestArch.I8086, X86_REG_SS, "SS")
    registers.push(GuestRegDef.new(ss_id, 16))

    val es_id = GuestRegId.new(GuestArch.I8086, X86_REG_ES, "ES")
    registers.push(GuestRegDef.new(es_id, 16))

    # IP (instruction pointer)
    val ip_id = GuestRegId.new(GuestArch.I8086, X86_REG_IP, "IP")
    registers.push(GuestRegDef.new(ip_id, 16))

    # FLAGS
    val flags_id = GuestRegId.new(GuestArch.I8086, X86_REG_FLAGS, "FLAGS")
    registers.push(GuestRegDef.new(flags_id, 16))

    # Address space: 20-bit physical (segment*16 + offset), 1MB addressable
    val addr_spaces = [
        AddrSpaceDef.new(0, "memory", 20, 1048576)    # 1MB real mode address space
    ]

    GuestCpuDef(
        name: "i8086",
        arch: GuestArch.I8086,
        word_size: 16,
        endian: Endian.Little,
        registers: registers,
        pc_reg: ip_id,
        sp_reg: Some(sp_id),
        flags_reg: Some(flags_id),
        addr_spaces: addr_spaces
    )
