# Instruction Classifier
#
# Classifies RV32I instruction words into timing categories and extracts
# register operands for the pipeline model.

use timing.types.{InstructionCategory}
use guest.riscv.opcodes.{RvOpcode, decode_rv_opcode}

# ============================================================================
# Classification Result
# ============================================================================

struct InstructionClassification:
    """Classification of an RV32I instruction for timing purposes."""
    category: InstructionCategory
    rd: i64         # Destination register (0-31, or -1 for none)
    rs1: i64        # Source register 1 (0-31, or -1 for none)
    rs2: i64        # Source register 2 (0-31, or -1 for none)
    is_branch: bool
    is_load: bool
    is_store: bool

impl InstructionClassification:
    fn to_text() -> text:
        "cat={self.category.to_text()} rd={self.rd} rs1={self.rs1} rs2={self.rs2}"

# ============================================================================
# Classifier
# ============================================================================

fn classify_rv32_instruction(inst_word: i64) -> InstructionClassification:
    """Classify an RV32I instruction word for the timing model.

    Extracts the opcode, register operands, and instruction category
    without actually executing the instruction.
    """
    val opcode = decode_rv_opcode(inst_word, false)
    if opcode.? == nil:
        return InstructionClassification(
            category: InstructionCategory.System,
            rd: -1, rs1: -1, rs2: -1,
            is_branch: false, is_load: false, is_store: false
        )

    val op = opcode.!
    match op:
        # Upper immediate
        RvOpcode.LUI(rd, _):
            InstructionClassification(category: InstructionCategory.UpperImm, rd: rd, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.AUIPC(rd, _):
            InstructionClassification(category: InstructionCategory.UpperImm, rd: rd, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)

        # Jumps
        RvOpcode.JAL(rd, _):
            InstructionClassification(category: InstructionCategory.Jump, rd: rd, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.JALR(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.Jump, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)

        # Branches
        RvOpcode.BEQ(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Branch, rd: -1, rs1: rs1, rs2: rs2, is_branch: true, is_load: false, is_store: false)
        RvOpcode.BNE(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Branch, rd: -1, rs1: rs1, rs2: rs2, is_branch: true, is_load: false, is_store: false)
        RvOpcode.BLT(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Branch, rd: -1, rs1: rs1, rs2: rs2, is_branch: true, is_load: false, is_store: false)
        RvOpcode.BGE(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Branch, rd: -1, rs1: rs1, rs2: rs2, is_branch: true, is_load: false, is_store: false)
        RvOpcode.BLTU(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Branch, rd: -1, rs1: rs1, rs2: rs2, is_branch: true, is_load: false, is_store: false)
        RvOpcode.BGEU(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Branch, rd: -1, rs1: rs1, rs2: rs2, is_branch: true, is_load: false, is_store: false)

        # Loads
        RvOpcode.LB(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.Load, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: true, is_store: false)
        RvOpcode.LH(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.Load, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: true, is_store: false)
        RvOpcode.LW(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.Load, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: true, is_store: false)
        RvOpcode.LBU(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.Load, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: true, is_store: false)
        RvOpcode.LHU(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.Load, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: true, is_store: false)

        # Stores
        RvOpcode.SB(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Store, rd: -1, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: true)
        RvOpcode.SH(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Store, rd: -1, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: true)
        RvOpcode.SW(rs1, rs2, _):
            InstructionClassification(category: InstructionCategory.Store, rd: -1, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: true)

        # Immediate ALU
        RvOpcode.ADDI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SLTI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SLTIU(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.XORI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.ORI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.ANDI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SLLI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SRLI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SRAI(rd, rs1, _):
            InstructionClassification(category: InstructionCategory.AluImm, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)

        # Register ALU
        RvOpcode.ADD(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SUB(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SLL(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SLT(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SLTU(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.XOR(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SRL(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.SRA(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.OR(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)
        RvOpcode.AND(rd, rs1, rs2):
            InstructionClassification(category: InstructionCategory.AluReg, rd: rd, rs1: rs1, rs2: rs2, is_branch: false, is_load: false, is_store: false)

        # System
        RvOpcode.ECALL:
            InstructionClassification(category: InstructionCategory.System, rd: -1, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.EBREAK:
            InstructionClassification(category: InstructionCategory.System, rd: -1, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.FENCE(_, _):
            InstructionClassification(category: InstructionCategory.System, rd: -1, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)

        # CSR instructions
        RvOpcode.CSRRW(rd, _, rs1):
            InstructionClassification(category: InstructionCategory.System, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.CSRRS(rd, _, rs1):
            InstructionClassification(category: InstructionCategory.System, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.CSRRC(rd, _, rs1):
            InstructionClassification(category: InstructionCategory.System, rd: rd, rs1: rs1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.CSRRWI(rd, _, _):
            InstructionClassification(category: InstructionCategory.System, rd: rd, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.CSRRSI(rd, _, _):
            InstructionClassification(category: InstructionCategory.System, rd: rd, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
        RvOpcode.CSRRCI(rd, _, _):
            InstructionClassification(category: InstructionCategory.System, rd: rd, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)

        _:
            InstructionClassification(category: InstructionCategory.System, rd: -1, rs1: -1, rs2: -1, is_branch: false, is_load: false, is_store: false)
