# Mode Switcher
#
# Handles transitions between simulation modes (REQ-SIM-005).
# Fast <-> TimingApproximate <-> RtlCycleAccurate
#
# State snapshots are taken before each transition and can be
# restored to return to a previous execution point.

use timing.types.{SimMode, StateSnapshot}

# ============================================================================
# Mode Switch Result
# ============================================================================

struct ModeSwitchResult:
    """Result of a mode transition."""
    success: bool
    from_mode: SimMode
    to_mode: SimMode
    snapshot: StateSnapshot?
    message: text

impl ModeSwitchResult:
    static fn ok(from: SimMode, to: SimMode, snapshot: StateSnapshot) -> ModeSwitchResult:
        ModeSwitchResult(success: true, from_mode: from, to_mode: to, snapshot: Some(snapshot), message: "ok")

    static fn err(from: SimMode, to: SimMode, message: text) -> ModeSwitchResult:
        ModeSwitchResult(success: false, from_mode: from, to_mode: to, snapshot: nil, message: message)

    fn to_text() -> text:
        if self.success:
            "mode switch {self.from_mode.to_text()} -> {self.to_mode.to_text()}: ok"
        else:
            "mode switch {self.from_mode.to_text()} -> {self.to_mode.to_text()}: FAILED ({self.message})"

# ============================================================================
# Mode Switcher
# ============================================================================

class SimModeSwitcher:
    """Manages simulation mode transitions (AC-004).

    Ensures state is correctly transferred between modes.
    All transitions go through a StateSnapshot intermediate.
    """
    current_mode: SimMode
    snapshot_history: [StateSnapshot]

impl SimModeSwitcher:
    static fn new(initial_mode: SimMode) -> SimModeSwitcher:
        SimModeSwitcher(current_mode: initial_mode, snapshot_history: [])

    fn mode() -> SimMode:
        self.current_mode

    me prepare_switch(target_mode: SimMode, snapshot: StateSnapshot) -> ModeSwitchResult:
        """Prepare a mode switch by taking a state snapshot.

        The caller must provide the current state as a StateSnapshot.
        The switcher validates the transition and records the snapshot.
        """
        if self._same_mode(target_mode):
            return ModeSwitchResult.err(self.current_mode, target_mode, "already in target mode")

        # All mode transitions are valid in the hybrid simulator
        self.snapshot_history.push(snapshot)
        val from = self.current_mode
        self.current_mode = target_mode
        ModeSwitchResult.ok(from, target_mode, snapshot)

    fn last_snapshot() -> StateSnapshot?:
        """Return the most recent state snapshot."""
        if self.snapshot_history.len() > 0:
            return Some(self.snapshot_history[self.snapshot_history.len() - 1])
        nil

    fn snapshot_count() -> i64:
        self.snapshot_history.len()

    fn _same_mode(target: SimMode) -> bool:
        """Check if the target mode is the same as the current mode."""
        val current_text = self.current_mode.to_text()
        val target_text = target.to_text()
        current_text == target_text
