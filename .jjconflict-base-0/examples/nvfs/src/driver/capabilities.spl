# NVFS driver — CapabilitySet for the native NVFS driver.
#
# Returns the full set of capabilities that NvfsDriver supports.
# PosixCompat is intentionally excluded — that is provided by the
# NvfsPosixDriver shim (agent B2).
#
# Source: doc/05_design/fs_driver_interface.md §5; nvfs_design_v2.md §17.

use std.fs_driver.capability.{Capability, CapabilitySet}

fn nvfs_native_capabilities() -> CapabilitySet:
    """Return the CapabilitySet for the native NVFS driver.

    Included (16 capabilities):
      COW, Snapshot, Checksum, SelfHeal, Reflink, Compress, CaseSensitive,
      Hardlinks, SparseFiles, LargeFiles, UnicodeNames, SendReceive, Dedup,
      Scrub, Encrypt, AsyncIo.

    Excluded:
      PosixCompat  — handled by NvfsPosixDriver (agent B2).
      Clone        — not in the Phase 9 B1 cap set.
      Atime        — not yet implemented.
      Xattr        — not yet implemented.
      Acl          — not yet implemented.
      CaseFold     — NVFS is case-sensitive only for now.
      Quota        — not yet implemented.
    """
    val empty = CapabilitySet.empty()
    val c0  = empty.with(Capability.COW)
    val c1  = c0.with(Capability.Snapshot)
    val c2  = c1.with(Capability.Checksum)
    val c3  = c2.with(Capability.SelfHeal)
    val c4  = c3.with(Capability.Reflink)
    val c5  = c4.with(Capability.Compress)
    val c6  = c5.with(Capability.CaseSensitive)
    val c7  = c6.with(Capability.Hardlinks)
    val c8  = c7.with(Capability.SparseFiles)
    val c9  = c8.with(Capability.LargeFiles)
    val c10 = c9.with(Capability.UnicodeNames)
    val c11 = c10.with(Capability.SendReceive)
    val c12 = c11.with(Capability.Dedup)
    val c13 = c12.with(Capability.Scrub)
    val c14 = c13.with(Capability.Encrypt)
    c14.with(Capability.AsyncIo)
