use std.gpu.engine2d.backend_cpu.{CpuBackend}
use examples.ui.engine2d_line_scene.{W, H, run_engine2d_line_scene}

fn main() -> i64:
    print "  backend 'cpu_simd' line smoke:"
    var backend = CpuBackend.create()
    if not backend.init(W, H):
        print "    -> CPU SIMD backend failed to initialize"
        return 1
    if run_engine2d_line_scene(backend, "cpu_simd", false):
        return 0
    1
