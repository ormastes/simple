# x86_64 production filesystem-exec proof.
#
# Boots the normal ring-3 prerequisites, then launches /USR/BIN/SIMPLE through the
# shared exact-path filesystem loader. The loader retains only the bounded ELF
# header and streams each PT_LOAD segment from FAT32/NVMe into its mapped frame.

extern fn serial_println(msg: text)
extern fn rt_debug_exit_success()
extern fn rt_port_outb(port: u16, value: u8)
extern fn rt_x86_tss_init() -> i64
extern fn simpleos_nvme_init() -> i64
extern fn _get_kernel_start() -> u64
extern fn _get_kernel_end() -> u64

use os.kernel.arch.x86_64.arch_init.{arch_x86_64_early_init}
use os.kernel.memory.pmm.{pmm_init_identity_range, g_pmm}
use os.kernel.memory.vmm.{vmm_init}
use os.kernel.memory.vmm_address_space.{vmm_map_nvme_bar_high}
use os.kernel.loader.x86_64_fs_exec_spawn.{x86_64_fs_exec_spawn}
use generated.simpleos_fsexec_profile.{simpleos_fsexec_args, simpleos_fsexec_path}

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS x86_64 production ring-3 ===")

    arch_x86_64_early_init()
    rt_x86_tss_init()
    if simpleos_nvme_init() != 0:
        serial_println("[prod] FAIL nvme init")
        rt_debug_exit_success()
        return
    val kernel_start = _get_kernel_start()
    val kernel_end = _get_kernel_end()
    if not pmm_init_identity_range(0x20000000, kernel_start, kernel_end):
        serial_println("[prod] FAIL pmm_init")
        rt_debug_exit_success()
        return
    vmm_init(g_pmm, 0)
    vmm_map_nvme_bar_high()

    serial_println("[prod] boot ring3-capable ok")
    val rc = x86_64_fs_exec_spawn(simpleos_fsexec_path(), simpleos_fsexec_args(), [])
    serial_println("[prod] filesystem spawn completed rc={rc}")
    rt_port_outb(0xf4, 1)
