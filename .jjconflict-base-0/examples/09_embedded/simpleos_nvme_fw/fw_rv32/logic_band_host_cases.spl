use logic_band_core.*

fn rv32_band_host_cases_selftest() -> i32:
    if _rv32_band_host_can_open(2, 2) != 0:
        return 1
    if _rv32_band_host_can_open(3, 2) != 1:
        return 1
    if _rv32_band_host_writable_pages(63, 2, 2) != 1:
        return 1
    if _rv32_band_host_writable_pages(64, 4, 2) != 128:
        return 1
    0
