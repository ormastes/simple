use logic_sched_channel_cases.*
use logic_sched_step_cases.*
use logic_sched_done_cases.*

fn rv32_sched_cases_selftest() -> i32:
    if rv32_sched_channel_cases_selftest() != 0:
        return 1
    if rv32_sched_step_cases_selftest() != 0:
        return 1
    if rv32_sched_done_cases_selftest() != 0:
        return 1
    0
