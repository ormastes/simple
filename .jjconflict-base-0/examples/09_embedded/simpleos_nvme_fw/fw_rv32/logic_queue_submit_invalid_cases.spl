use logic_queue_phase_core.*

fn rv32_queue_submit_invalid_cases_selftest() -> i32:
    if _rv32_queue_submit_valid(65536, 0, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(-1, 0, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, -1, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, 64, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, 0, 64, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, 0, 0, 0) == 0:
        return 1
    if _rv32_queue_submit_valid(1, 0, 0, -1) == 0:
        return 1
    0
