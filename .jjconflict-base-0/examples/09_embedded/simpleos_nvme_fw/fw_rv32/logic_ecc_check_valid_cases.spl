use logic_ecc_core.{_rv32_ecc_compute, _rv32_ecc_check}

fn rv32_ecc_check_valid_cases_selftest() -> i32:
    val data: i64 = 66
    val lba: i64 = 100
    val seq: i64 = 5
    val ecc: i64 = _rv32_ecc_compute(data, lba, seq)
    if _rv32_ecc_check(data, lba, seq, ecc, 0) != 0:
        return 1
    if _rv32_ecc_check(data, lba, seq, ecc, -1) != 0:
        return 1
    0
