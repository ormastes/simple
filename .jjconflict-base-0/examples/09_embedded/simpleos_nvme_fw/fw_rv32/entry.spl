# NVMe firmware — bare-metal RV32 on-device self-test (gap-closure P9).
#
# Array-free, scalar re-expression of the firmware's core RAIN parity reconstruct,
# SECDED payload-window ECC floor, fixed scheduler floor, fixed power/thermal floor, fixed map-cache floor, fixed band floor, fixed journal-ring floor, fixed HIL command/queue floor, fixed queue-phase floor, fixed read-zero-trim-flush floor, fixed admin/format/fw-log floor, fixed reactor floor, fixed policy/target floor, fixed DRAM/durability floor, fixed wear/scrub floor, fixed media-retire floor, fixed power-cycle floor, fixed backpressure/abort floor, fixed feature-guard floor, fixed namespace-guard floor, fixed target-profile floor, and fixed task-pool fail-closed floor so it can run inside the bare-metal rv32 boot path with
# NO heap and NO arrays — matching the constraint documented in
# src/os/kernel/arch/riscv32/boot.spl ("keep this module freestanding and minimal ... without
# pulling runtime formatting, arrays, or boot metadata into the first-stage entry object").
# UART output uses rt_riscv_uart_put exactly like boot.spl's `_line_*` helpers — one byte at a
# time, no string runtime.
#
# Integration: call `nvme_fw_rv32_selftest()` from the rv32 boot chain (boot.spl `boot_main`,
# after `riscv_noalloc_log_init`), then build with the proven recipe (fw_rv32/build.shs) and boot
# (fw_rv32/boot.shs). It prints `ALL RV32 NVME FW CHECKS PASS` on success.
#
# BUILD STATUS (2026-06-30): toolchain FIXED + freestanding runtime COMPLETED. `native-build
# --target riscv32-unknown-none` routes to the in-process Rust LLVM handler (no silent 255), and the
# shared freestanding runtime (src/os/kernel/arch/riscv64/boot/freestanding_runtime.c, autodiscovered
# via the rv32 boot bridge baremetal_stubs.c) now provides every rt_* the rv32 kernel emits —
# rt_native_eq/neq + rt_riscv_uart_put were always there; rt_string_char_at/rt_value_as_int/
# rt_array_pop were added (commit 5ac934cd285). The rv32 boot.spl kernel links with 0 undefined
# runtime symbols, and the OS fs-exec rv32 ELF boots under qemu (-bios none) printing
# "SimpleOS RV32 boot OK". This `entry.spl` is the standalone *logic reference* (host-verified,
# XOR/ECC/scheduler/power-thermal/map-cache/band/journal-ring/HIL/queue-phase/read-zero-trim-flush/admin-format-fw-log/reactor/policy-target/DRAM-durability/wear-scrub/media-retire/power-cycle/backpressure-abort/feature-guard/namespace-guard/task-pool checks reproduce fail=0); a standalone native-build of it alone won't link (its dir has no
# boot/ for C autodiscovery) — the bootable path is the OS build, which links the shared runtime.
# Tracked in doc/08_tracking/bug/native_build_rv32_baremetal_silent_255_2026-06-30.md. Full 22-module
# no-alloc port of ../fw/ is the larger ceiling.

extern fn rt_riscv_uart_put(byte: u64)
use logic.{nvme_fw_rv32_logic_selftest}

fn _uart_put(byte: i64):
    rt_riscv_uart_put(byte as u64)

# Emit a NUL-terminated-style fixed byte sequence one byte at a time (no arrays, no string
# runtime, no `;` statement separators — native-build's parser rejects those).
fn _emit_pass():
    # "ALL RV32 NVME FW CHECKS PASS\n"
    _uart_put(65)
    _uart_put(76)
    _uart_put(76)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _uart_put(32)
    _uart_put(78)
    _uart_put(86)
    _uart_put(77)
    _uart_put(69)
    _uart_put(32)
    _uart_put(70)
    _uart_put(87)
    _uart_put(32)
    _uart_put(67)
    _uart_put(72)
    _uart_put(69)
    _uart_put(67)
    _uart_put(75)
    _uart_put(83)
    _uart_put(32)
    _uart_put(80)
    _uart_put(65)
    _uart_put(83)
    _uart_put(83)
    _uart_put(10)

fn _emit_fail():
    # "RV32 NVME FW FAIL\n"
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _uart_put(32)
    _uart_put(78)
    _uart_put(86)
    _uart_put(77)
    _uart_put(69)
    _uart_put(32)
    _uart_put(70)
    _uart_put(87)
    _uart_put(32)
    _uart_put(70)
    _uart_put(65)
    _uart_put(73)
    _uart_put(76)
    _uart_put(10)

fn _emit_begin():
    # "RV32 NVME FW BEGIN\n"
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _uart_put(32)
    _uart_put(78)
    _uart_put(86)
    _uart_put(77)
    _uart_put(69)
    _uart_put(32)
    _uart_put(70)
    _uart_put(87)
    _uart_put(32)
    _uart_put(66)
    _uart_put(69)
    _uart_put(71)
    _uart_put(73)
    _uart_put(78)
    _uart_put(10)

fn _emit_fail_mask(mask: i64):
    if (mask & 1) != 0:
        _uart_put(82)   # R
    if (mask & 2) != 0:
        _uart_put(69)   # E
    if (mask & 4) != 0:
        _uart_put(74)   # J
    if (mask & 8) != 0:
        _uart_put(77)   # M
    if (mask & 16) != 0:
        _uart_put(66)   # B
    if (mask & 32) != 0:
        _uart_put(83)   # S
    if (mask & 64) != 0:
        _uart_put(80)   # P
    if (mask & 128) != 0:
        _uart_put(72)   # H
    if (mask & 256) != 0:
        _uart_put(81)   # Q
    if (mask & 512) != 0:
        _uart_put(73)   # I
    if (mask & 1024) != 0:
        _uart_put(70)   # F
    if (mask & 2048) != 0:
        _uart_put(65)   # A
    if (mask & 4096) != 0:
        _uart_put(67)   # C
    if (mask & 8192) != 0:
        _uart_put(84)   # T
    if (mask & 16384) != 0:
        _uart_put(68)   # D
    if (mask & 32768) != 0:
        _uart_put(87)   # W
    if (mask & 65536) != 0:
        _uart_put(76)   # L
    if (mask & 131072) != 0:
        _uart_put(89)   # Y
    if (mask & 262144) != 0:
        _uart_put(75)   # K
    if (mask & 524288) != 0:
        _uart_put(71)   # G
    if (mask & 1048576) != 0:
        _uart_put(78)   # N
    if (mask & 2097152) != 0:
        _uart_put(79)   # O
    if (mask & 4194304) != 0:
        _uart_put(88)   # X
    _uart_put(10)

fn nvme_fw_rv32_selftest() -> i64:
    _emit_begin()
    val raw_fail = nvme_fw_rv32_logic_selftest()
    val fail = raw_fail
    if fail == 0:
        _emit_pass()
    else:
        _emit_fail_mask(fail)
        _emit_fail()
    fail

@export("C", name: "rt_rv32_boot_optional_nvme_fw_selftest")
fn rt_rv32_boot_optional_nvme_fw_selftest() -> i64:
    nvme_fw_rv32_selftest()

fn main() -> i64:
    nvme_fw_rv32_selftest()
