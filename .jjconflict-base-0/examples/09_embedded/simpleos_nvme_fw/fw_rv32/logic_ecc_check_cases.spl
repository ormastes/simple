use logic_ecc_check_correct_cases.*
use logic_ecc_check_inject_cases.*
use logic_ecc_check_valid_cases.*

fn rv32_ecc_check_cases_selftest() -> i32:
    if rv32_ecc_check_valid_cases_selftest() != 0:
        return 1
    if rv32_ecc_check_inject_cases_selftest() != 0:
        return 1
    if rv32_ecc_check_correct_cases_selftest() != 0:
        return 1
    0
