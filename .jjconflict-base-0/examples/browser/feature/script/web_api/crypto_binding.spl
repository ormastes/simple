# Web Crypto API binding — crypto.getRandomValues, crypto.randomUUID,
# and SubtleCrypto stubs (digest, encrypt, decrypt, sign, verify).

use browser.shared.logging.Logger
use browser.shared.error.BrowserResult
use browser.shared.error.script_error
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use std.js.engine.runtime.JsRuntime
use std.js.engine.interpreter_types.to_string

# ── Native function IDs ──────────────────────────────────────────────────

val NATIVE_CRYPTO_GET_RANDOM_VALUES = -700
val NATIVE_CRYPTO_RANDOM_UUID = -701
val NATIVE_SUBTLE_DIGEST = -710
val NATIVE_SUBTLE_ENCRYPT = -711
val NATIVE_SUBTLE_DECRYPT = -712
val NATIVE_SUBTLE_SIGN = -713
val NATIVE_SUBTLE_VERIFY = -714

# ── CryptoBinding ────────────────────────────────────────────────────────

class CryptoBinding:
    logger: Logger
    seed: i64

    static fn new(logger: Logger) -> CryptoBinding:
        CryptoBinding(logger: logger, seed: 42)

    # Install crypto and crypto.subtle objects on the JS runtime.
    me install(runtime: JsRuntime):
        self.logger.debug("Installing crypto bindings")

        # Create the crypto object
        val crypto_id = runtime.interpreter.object_store.create_object()

        runtime._define_method_on(crypto_id, "getRandomValues", NATIVE_CRYPTO_GET_RANDOM_VALUES)
        runtime._define_method_on(crypto_id, "randomUUID", NATIVE_CRYPTO_RANDOM_UUID)

        # Create the subtle sub-object
        val subtle_id = runtime.interpreter.object_store.create_object()
        runtime._define_method_on(subtle_id, "digest", NATIVE_SUBTLE_DIGEST)
        runtime._define_method_on(subtle_id, "encrypt", NATIVE_SUBTLE_ENCRYPT)
        runtime._define_method_on(subtle_id, "decrypt", NATIVE_SUBTLE_DECRYPT)
        runtime._define_method_on(subtle_id, "sign", NATIVE_SUBTLE_SIGN)
        runtime._define_method_on(subtle_id, "verify", NATIVE_SUBTLE_VERIFY)

        # Attach subtle to crypto
        runtime.interpreter.object_store.set_property(
            crypto_id, "subtle", JsValue.Object(id: subtle_id))

        # Bind crypto to global scope
        runtime.interpreter.env_stack.define_var(
            runtime.interpreter.global_env, "crypto", JsValue.Object(id: crypto_id))

        self.logger.debug("Crypto bindings installed")

# ── crypto.getRandomValues ───────────────────────────────────────────────

fn js_crypto_getRandomValues(args: [JsValue], runtime: JsRuntime) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("getRandomValues requires 1 argument"))

    # The argument should be a typed array (represented as a JS Array).
    # We fill it with pseudo-random bytes using the LCG.
    # NOTE: This is NOT cryptographically secure; it uses a simple LCG.
    match args.get(0):
        JsValue.Array(arr_id):
            # Fill the array with random values (0-255 range for Uint8Array)
            # Since we can't directly modify array contents without a proper
            # typed array implementation, create a new array with random values.
            val result_id = runtime.interpreter.object_store.create_object()
            var i = 0
            while i < 32:
                val random_byte = _lcg_next() % 256
                runtime.interpreter.object_store.set_property(
                    result_id, "{i}", JsValue.Number(v: random_byte.to_f64()))
                i = i + 1
            runtime.interpreter.object_store.set_property(
                result_id, "length", JsValue.Number(v: 32.0))
            return Ok(JsValue.Object(id: result_id))
        JsValue.Object(obj_id):
            # Same approach for object-based typed arrays
            var i = 0
            while i < 32:
                val random_byte = _lcg_next() % 256
                runtime.interpreter.object_store.set_property(
                    obj_id, "{i}", JsValue.Number(v: random_byte.to_f64()))
                i = i + 1
            runtime.interpreter.object_store.set_property(
                obj_id, "length", JsValue.Number(v: 32.0))
            return Ok(args.get(0))
        _:
            return Err(script_error("getRandomValues: argument must be a typed array"))

fn js_crypto_randomUUID(args: [JsValue]) -> JsValue:
    # Generate a v4 UUID: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx
    val uuid = generate_uuid_v4()
    JsValue.String(v: uuid)

# ── SubtleCrypto stubs ───────────────────────────────────────────────────

fn js_subtle_digest(args: [JsValue]) -> BrowserResult<JsValue>:
    # digest(algorithm, data) -> Promise<ArrayBuffer>
    if args.len() < 2:
        return Err(script_error("SubtleCrypto.digest requires 2 arguments"))
    Err(script_error("SubtleCrypto.digest not implemented"))

fn js_subtle_encrypt(args: [JsValue]) -> BrowserResult<JsValue>:
    # encrypt(algorithm, key, data) -> Promise<ArrayBuffer>
    if args.len() < 3:
        return Err(script_error("SubtleCrypto.encrypt requires 3 arguments"))
    Err(script_error("SubtleCrypto.encrypt not implemented"))

fn js_subtle_decrypt(args: [JsValue]) -> BrowserResult<JsValue>:
    # decrypt(algorithm, key, data) -> Promise<ArrayBuffer>
    if args.len() < 3:
        return Err(script_error("SubtleCrypto.decrypt requires 3 arguments"))
    Err(script_error("SubtleCrypto.decrypt not implemented"))

fn js_subtle_sign(args: [JsValue]) -> BrowserResult<JsValue>:
    # sign(algorithm, key, data) -> Promise<ArrayBuffer>
    if args.len() < 3:
        return Err(script_error("SubtleCrypto.sign requires 3 arguments"))
    Err(script_error("SubtleCrypto.sign not implemented"))

fn js_subtle_verify(args: [JsValue]) -> BrowserResult<JsValue>:
    # verify(algorithm, key, signature, data) -> Promise<Boolean>
    if args.len() < 4:
        return Err(script_error("SubtleCrypto.verify requires 4 arguments"))
    Err(script_error("SubtleCrypto.verify not implemented"))

# ── UUID generation ──────────────────────────────────────────────────────

# Generate a UUID v4 string: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx
# Uses a simple LCG for pseudo-random bytes. NOT cryptographically secure.
fn generate_uuid_v4() -> text:
    # Generate 16 pseudo-random hex nibbles per section.
    # Format: 8-4-4-4-12
    var result = ""

    # Section 1: 8 hex chars
    result = result + _hex_block(8)
    result = result + "-"

    # Section 2: 4 hex chars
    result = result + _hex_block(4)
    result = result + "-"

    # Section 3: 4xxx (version 4)
    result = result + "4"
    result = result + _hex_block(3)
    result = result + "-"

    # Section 4: yxxx (variant bits: 8, 9, a, or b)
    result = result + _variant_char()
    result = result + _hex_block(3)
    result = result + "-"

    # Section 5: 12 hex chars
    result = result + _hex_block(12)

    result

# ── Pseudo-random helpers ────────────────────────────────────────────────

# Simple LCG state — NOT cryptographically secure.
var _lcg_state: i64 = 12345

fn _lcg_next() -> i64:
    # LCG: state = (a * state + c) mod m
    _lcg_state = (_lcg_state * 1103515245 + 12345) % 2147483647
    if _lcg_state < 0:
        _lcg_state = 0 - _lcg_state
    _lcg_state

fn _hex_block(count: i64) -> text:
    val hex_chars = "0123456789abcdef"
    var result = ""
    var i = 0
    while i < count:
        val r = _lcg_next() % 16
        result = result + hex_chars[r:r + 1]
        i = i + 1
    result

fn _variant_char() -> text:
    # Variant must be 8, 9, a, or b
    val variants = "89ab"
    val r = _lcg_next() % 4
    variants[r:r + 1]
