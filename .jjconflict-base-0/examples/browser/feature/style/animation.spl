#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# CSS animations and transitions engine.
# Handles @keyframes animations, property transitions, timing functions
# (including cubic bezier), and per-tick interpolation of CSS values.

use std.common.color.types.{from_rgb}
use examples.browser.entity.dom.css_types.{CSSValue, CSSDeclaration}
use examples.browser.shared.logging.{Logger, LogLevel}

# ---------------------------------------------------------------------------
# Timing function — easing curves for animations and transitions.
# ---------------------------------------------------------------------------

enum TimingFunction:
    Linear
    Ease
    EaseIn
    EaseOut
    EaseInOut
    CubicBezier(x1: f64, y1: f64, x2: f64, y2: f64)
    Steps(count: i64, jump_start: bool)

# ---------------------------------------------------------------------------
# Animation lifecycle states.
# ---------------------------------------------------------------------------

enum AnimationState:
    Idle
    Running
    Paused
    Finished

# ---------------------------------------------------------------------------
# Fill mode — what styles apply before/after animation.
# ---------------------------------------------------------------------------

enum FillMode:
    None
    Forwards
    Backwards
    Both

# ---------------------------------------------------------------------------
# Play direction — iteration direction control.
# ---------------------------------------------------------------------------

enum PlayDirection:
    Normal
    Reverse
    Alternate
    AlternateReverse

# ---------------------------------------------------------------------------
# Keyframe — a single snapshot at a given offset [0.0, 1.0].
# ---------------------------------------------------------------------------

class Keyframe:
    offset: f64
    properties: [CSSDeclaration]

    static fn create(offset: f64, properties: [CSSDeclaration]) -> Keyframe:
        Keyframe(offset: offset, properties: properties)

# ---------------------------------------------------------------------------
# Animation — a full @keyframes animation instance.
# ---------------------------------------------------------------------------

class Animation:
    name: text
    keyframes: [Keyframe]
    duration_ms: f64
    delay_ms: f64
    timing: TimingFunction
    iteration_count: f64
    direction: PlayDirection
    fill_mode: FillMode
    state: AnimationState
    current_time: f64

    static fn create(name: text, keyframes: [Keyframe], duration_ms: f64) -> Animation:
        Animation(
            name: name,
            keyframes: keyframes,
            duration_ms: duration_ms,
            delay_ms: 0.0,
            timing: TimingFunction.Ease,
            iteration_count: 1.0,
            direction: PlayDirection.Normal,
            fill_mode: FillMode.None,
            state: AnimationState.Idle,
            current_time: 0.0
        )

# ---------------------------------------------------------------------------
# Transition — a single property transition between two values.
# ---------------------------------------------------------------------------

class Transition:
    property: text
    from_value: CSSValue
    to_value: CSSValue
    duration_ms: f64
    delay_ms: f64
    timing: TimingFunction
    start_time: f64
    state: AnimationState

    static fn create(property: text, from_value: CSSValue, to_value: CSSValue, duration_ms: f64) -> Transition:
        Transition(
            property: property,
            from_value: from_value,
            to_value: to_value,
            duration_ms: duration_ms,
            delay_ms: 0.0,
            timing: TimingFunction.Ease,
            start_time: 0.0,
            state: AnimationState.Idle
        )

# ---------------------------------------------------------------------------
# StyleUpdate — a single property change emitted by the animation engine.
# ---------------------------------------------------------------------------

class StyleUpdate:
    node_id: i64
    property: text
    value: CSSValue

    static fn create(node_id: i64, property: text, value: CSSValue) -> StyleUpdate:
        StyleUpdate(node_id: node_id, property: property, value: value)

# ---------------------------------------------------------------------------
# AnimationEngine — drives all active animations and transitions.
# ---------------------------------------------------------------------------

class AnimationEngine:
    animations: [Animation]
    transitions: [Transition]
    logger: Logger

    static fn new(logger: Logger) -> AnimationEngine:
        AnimationEngine(
            animations: [Animation](),
            transitions: [Transition](),
            logger: logger
        )

    me add_animation(anim: Animation):
        self.animations.push(anim)
        self.logger.debug("animation added: '{anim.name}', duration={anim.duration_ms}ms")

    me add_transition(trans: Transition):
        self.transitions.push(trans)
        self.logger.debug("transition added: property='{trans.property}', duration={trans.duration_ms}ms")

    # Advance all animations and transitions to the given time.
    # Returns a list of style property updates to apply.
    me tick(current_time_ms: f64) -> [StyleUpdate]:
        var updates = [StyleUpdate]()

        # Process animations
        var anim_idx = 0
        while anim_idx < self.animations.len():
            var anim = self.animations.get(anim_idx)

            match anim.state:
                AnimationState.Idle:
                    # Start the animation
                    anim.state = AnimationState.Running
                    anim.current_time = current_time_ms
                    self.animations.set(anim_idx, anim)
                AnimationState.Running:
                    val elapsed = current_time_ms - anim.current_time - anim.delay_ms
                    if elapsed < 0.0:
                        # Still in delay period
                        pass_dn
                    else:
                        val total_duration = anim.duration_ms * anim.iteration_count
                        if elapsed >= total_duration:
                            anim.state = AnimationState.Finished
                            self.animations.set(anim_idx, anim)
                        else:
                            # Compute progress within current iteration
                            val iteration_progress = elapsed / anim.duration_ms
                            var local_progress = iteration_progress - iteration_progress.floor()
                            if local_progress == 0.0 and elapsed > 0.0:
                                local_progress = 1.0

                            # Apply direction
                            val current_iteration = iteration_progress.floor().to_i64()
                            val effective_progress = apply_direction(local_progress, anim.direction, current_iteration)

                            # Apply timing function
                            val eased = ease_value(effective_progress, anim.timing)

                            # Interpolate keyframe properties
                            val kf_updates = interpolate_keyframes(anim.keyframes, eased)
                            for u in kf_updates:
                                updates.push(u)
                AnimationState.Paused:
                    pass_dn
                AnimationState.Finished:
                    pass_dn

            anim_idx = anim_idx + 1

        # Process transitions
        var trans_idx = 0
        while trans_idx < self.transitions.len():
            var trans = self.transitions.get(trans_idx)

            match trans.state:
                AnimationState.Idle:
                    trans.state = AnimationState.Running
                    trans.start_time = current_time_ms
                    self.transitions.set(trans_idx, trans)
                AnimationState.Running:
                    val elapsed = current_time_ms - trans.start_time - trans.delay_ms
                    if elapsed < 0.0:
                        pass_dn
                    else if elapsed >= trans.duration_ms:
                        # Transition complete — snap to final value
                        updates.push(StyleUpdate.create(0, trans.property, trans.to_value))
                        trans.state = AnimationState.Finished
                        self.transitions.set(trans_idx, trans)
                    else:
                        val raw_progress = elapsed / trans.duration_ms
                        val eased = ease_value(raw_progress, trans.timing)
                        val interp = interpolate(trans.from_value, trans.to_value, eased)
                        updates.push(StyleUpdate.create(0, trans.property, interp))
                AnimationState.Paused:
                    pass_dn
                AnimationState.Finished:
                    pass_dn

            trans_idx = trans_idx + 1

        self.logger.trace("tick at {current_time_ms}ms produced {updates.len()} updates")
        updates

# ---------------------------------------------------------------------------
# Value interpolation.
# ---------------------------------------------------------------------------

fn interpolate(from: CSSValue, to: CSSValue, progress: f64) -> CSSValue:
    match from:
        CSSValue.Length(fv, fu):
            match to:
                CSSValue.Length(tv, tu):
                    val result = interpolate_length(fv, tv, progress)
                    CSSValue.Length(v: result, unit: fu)
                _: to
        CSSValue.Number(fv):
            match to:
                CSSValue.Number(tv):
                    val result = interpolate_length(fv, tv, progress)
                    CSSValue.Number(v: result)
                _: to
        CSSValue.Color(color):
            match to:
                CSSValue.Color(to_color):
                    interpolate_color(color.r, color.g, color.b, to_color.r, to_color.g, to_color.b, progress)
                _: to
        CSSValue.Percentage(fv):
            match to:
                CSSValue.Percentage(tv):
                    val result = interpolate_length(fv, tv, progress)
                    CSSValue.Percentage(v: result)
                _: to
        _:
            # Discrete — snap at 50%
            if progress < 0.5:
                from
            else:
                to

fn interpolate_color(from_r: i64, from_g: i64, from_b: i64, to_r: i64, to_g: i64, to_b: i64, t: f64) -> CSSValue:
    val r = (from_r.to_f64() + (to_r.to_f64() - from_r.to_f64()) * t).to_i64()
    val g = (from_g.to_f64() + (to_g.to_f64() - from_g.to_f64()) * t).to_i64()
    val b = (from_b.to_f64() + (to_b.to_f64() - from_b.to_f64()) * t).to_i64()
    CSSValue.Color(color: from_rgb(r, g, b))

fn interpolate_length(from: f64, to: f64, t: f64) -> f64:
    from + (to - from) * t

# ---------------------------------------------------------------------------
# Easing / timing functions.
# ---------------------------------------------------------------------------

fn ease_value(t: f64, timing: TimingFunction) -> f64:
    match timing:
        TimingFunction.Linear:
            t
        TimingFunction.Ease:
            cubic_bezier(t, 0.25, 0.1, 0.25, 1.0)
        TimingFunction.EaseIn:
            cubic_bezier(t, 0.42, 0.0, 1.0, 1.0)
        TimingFunction.EaseOut:
            cubic_bezier(t, 0.0, 0.0, 0.58, 1.0)
        TimingFunction.EaseInOut:
            cubic_bezier(t, 0.42, 0.0, 0.58, 1.0)
        TimingFunction.CubicBezier(x1, y1, x2, y2):
            cubic_bezier(t, x1, y1, x2, y2)
        TimingFunction.Steps(count, jump_start):
            val step = (t * count.to_f64()).floor() / count.to_f64()
            if jump_start:
                val step_up = ((t * count.to_f64()).floor() + 1.0) / count.to_f64()
                if step_up > 1.0: 1.0
                else: step_up
            else:
                step

# Cubic bezier evaluation using iterative Newton-Raphson to find t for x,
# then evaluate y. The bezier is defined by P0=(0,0), P1=(x1,y1), P2=(x2,y2), P3=(1,1).
fn cubic_bezier(t: f64, x1: f64, y1: f64, x2: f64, y2: f64) -> f64:
    # Find the parametric t_param such that bezier_x(t_param) == t
    var t_param = t
    # Newton-Raphson iterations
    var i = 0
    while i < 8:
        val x_at = bezier_component(t_param, x1, x2) - t
        val dx_at = bezier_derivative(t_param, x1, x2)
        if dx_at.abs() < 0.00001:
            i = 8
        else:
            t_param = t_param - x_at / dx_at
        i = i + 1

    # Clamp t_param to [0, 1]
    if t_param < 0.0:
        t_param = 0.0
    if t_param > 1.0:
        t_param = 1.0

    bezier_component(t_param, y1, y2)

# Evaluate one component of a cubic bezier at parameter t.
# B(t) = 3(1-t)^2*t*p1 + 3(1-t)*t^2*p2 + t^3
fn bezier_component(t: f64, p1: f64, p2: f64) -> f64:
    val mt = 1.0 - t
    3.0 * mt * mt * t * p1 + 3.0 * mt * t * t * p2 + t * t * t

# Derivative of bezier_component with respect to t.
fn bezier_derivative(t: f64, p1: f64, p2: f64) -> f64:
    val mt = 1.0 - t
    3.0 * mt * mt * p1 + 6.0 * mt * t * (p2 - p1) + 3.0 * t * t * (1.0 - p2)

# ---------------------------------------------------------------------------
# Direction helpers.
# ---------------------------------------------------------------------------

fn apply_direction(progress: f64, direction: PlayDirection, iteration: i64) -> f64:
    match direction:
        PlayDirection.Normal:
            progress
        PlayDirection.Reverse:
            1.0 - progress
        PlayDirection.Alternate:
            if iteration % 2 == 0:
                progress
            else:
                1.0 - progress
        PlayDirection.AlternateReverse:
            if iteration % 2 == 0:
                1.0 - progress
            else:
                progress

# Interpolate between keyframes at a given progress [0.0, 1.0].
# Finds the two surrounding keyframes and interpolates their properties.
fn interpolate_keyframes(keyframes: [Keyframe], progress: f64) -> [StyleUpdate]:
    var updates = [StyleUpdate]()

    if keyframes.len() == 0:
        return updates

    if keyframes.len() == 1:
        for decl in keyframes.get(0).properties:
            updates.push(StyleUpdate.create(0, decl.property, decl.value))
        return updates

    # Find surrounding keyframes
    var from_kf = keyframes.get(0)
    var to_kf = keyframes.get(keyframes.len() - 1)

    var idx = 0
    while idx < keyframes.len() - 1:
        val current = keyframes.get(idx)
        val next = keyframes.get(idx + 1)
        if progress >= current.offset and progress <= next.offset:
            from_kf = current
            to_kf = next
            idx = keyframes.len()
        idx = idx + 1

    # Compute local progress between the two keyframes
    val range = to_kf.offset - from_kf.offset
    var local_t = 0.0
    if range > 0.0:
        local_t = (progress - from_kf.offset) / range

    # Interpolate matching properties
    for from_decl in from_kf.properties:
        for to_decl in to_kf.properties:
            if from_decl.property == to_decl.property:
                val interp = interpolate(from_decl.value, to_decl.value, local_t)
                updates.push(StyleUpdate.create(0, from_decl.property, interp))

    updates
