# CSS Logical Properties — maps logical properties to physical properties.
#
# CSS Logical Properties Level 1 defines flow-relative equivalents of
# physical box model properties. For example, `margin-inline-start`
# maps to `margin-left` in LTR writing mode or `margin-right` in RTL.
#
# Spec: https://www.w3.org/TR/css-logical-1/

# =========================================================================
# Writing Mode Context
# =========================================================================

class WritingContext:
    """Writing direction context for logical-to-physical mapping."""
    direction: text       # "ltr" or "rtl"
    writing_mode: text    # "horizontal-tb", "vertical-rl", "vertical-lr"

    static fn default_ctx() -> WritingContext:
        WritingContext(direction: "ltr", writing_mode: "horizontal-tb")

    fn is_horizontal() -> bool:
        self.writing_mode == "horizontal-tb"

    fn is_ltr() -> bool:
        self.direction == "ltr"

# =========================================================================
# Logical → Physical Mapping
# =========================================================================

fn map_logical_to_physical(property: text, ctx: WritingContext) -> text:
    """Map a logical CSS property name to its physical equivalent.
    Returns the original property if it's not a logical property.
    """
    val lower = property.to_lower()

    # Inline axis (horizontal in horizontal-tb)
    if ctx.is_horizontal():
        if ctx.is_ltr():
            return _map_horizontal_ltr(lower)
        else:
            return _map_horizontal_rtl(lower)
    else:
        # Vertical writing modes
        return _map_vertical(lower, ctx)

fn _map_horizontal_ltr(prop: text) -> text:
    match prop:
        # Margin
        "margin-inline-start": "margin-left"
        "margin-inline-end": "margin-right"
        "margin-block-start": "margin-top"
        "margin-block-end": "margin-bottom"
        "margin-inline": "margin-left"  # shorthand — both sides

        # Padding
        "padding-inline-start": "padding-left"
        "padding-inline-end": "padding-right"
        "padding-block-start": "padding-top"
        "padding-block-end": "padding-bottom"

        # Border
        "border-inline-start-width": "border-left-width"
        "border-inline-end-width": "border-right-width"
        "border-block-start-width": "border-top-width"
        "border-block-end-width": "border-bottom-width"
        "border-inline-start-color": "border-left-color"
        "border-inline-end-color": "border-right-color"
        "border-block-start-color": "border-top-color"
        "border-block-end-color": "border-bottom-color"
        "border-inline-start-style": "border-left-style"
        "border-inline-end-style": "border-right-style"
        "border-block-start-style": "border-top-style"
        "border-block-end-style": "border-bottom-style"

        # Sizing
        "inline-size": "width"
        "block-size": "height"
        "min-inline-size": "min-width"
        "max-inline-size": "max-width"
        "min-block-size": "min-height"
        "max-block-size": "max-height"

        # Positioning
        "inset-inline-start": "left"
        "inset-inline-end": "right"
        "inset-block-start": "top"
        "inset-block-end": "bottom"

        # Not a logical property
        _: prop

fn _map_horizontal_rtl(prop: text) -> text:
    match prop:
        "margin-inline-start": "margin-right"
        "margin-inline-end": "margin-left"
        "margin-block-start": "margin-top"
        "margin-block-end": "margin-bottom"
        "padding-inline-start": "padding-right"
        "padding-inline-end": "padding-left"
        "padding-block-start": "padding-top"
        "padding-block-end": "padding-bottom"
        "border-inline-start-width": "border-right-width"
        "border-inline-end-width": "border-left-width"
        "border-block-start-width": "border-top-width"
        "border-block-end-width": "border-bottom-width"
        "inline-size": "width"
        "block-size": "height"
        "min-inline-size": "min-width"
        "max-inline-size": "max-width"
        "min-block-size": "min-height"
        "max-block-size": "max-height"
        "inset-inline-start": "right"
        "inset-inline-end": "left"
        "inset-block-start": "top"
        "inset-block-end": "bottom"
        _: prop

fn _map_vertical(prop: text, ctx: WritingContext) -> text:
    # For vertical writing modes, inline = vertical, block = horizontal
    match prop:
        "margin-inline-start": "margin-top"
        "margin-inline-end": "margin-bottom"
        "margin-block-start": if ctx.is_ltr(): "margin-left" else: "margin-right"
        "margin-block-end": if ctx.is_ltr(): "margin-right" else: "margin-left"
        "inline-size": "height"
        "block-size": "width"
        "min-inline-size": "min-height"
        "max-inline-size": "max-height"
        "min-block-size": "min-width"
        "max-block-size": "max-width"
        _: prop

fn is_logical_property(property: text) -> bool:
    """Check if a property name is a CSS logical property."""
    val lower = property.to_lower()
    (lower.contains("inline-start") or lower.contains("inline-end") or
     lower.contains("block-start") or lower.contains("block-end") or
     lower.contains("inline-size") or lower.contains("block-size") or
     lower.starts_with("inset-") or lower == "margin-inline" or
     lower == "margin-block" or lower == "padding-inline" or
     lower == "padding-block")

# =========================================================================
# Inset Shorthand Expansion
# =========================================================================

fn expand_inset(property: text) -> [text]:
    """Expand `inset` shorthand to physical properties."""
    match property:
        "inset": ["top", "right", "bottom", "left"]
        "inset-inline": ["left", "right"]  # LTR default
        "inset-block": ["top", "bottom"]
        _: [property]
