# Float layout and CSS positioning (static, relative, absolute, fixed, sticky).
# Implements CSS 2.1 float placement rules: floats are removed from normal flow,
# placed to the left or right of their containing block, and subsequent content
# flows around them. Positioning offsets (top/right/bottom/left) are resolved
# and applied according to the position property.

use examples.browser.entity.dom.box_types.(BoxKind, BoxModel, LayoutBox)
use examples.browser.entity.dom.css_types.(CSSValue)
use examples.browser.feature.style.computed.(ComputedStyle, extract_px)
use examples.browser.feature.layout.block.(LayoutContext, resolve_length, resolve_margin, resolve_padding, resolve_border_width)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# FloatSide — which side a float attaches to.
# ---------------------------------------------------------------------------

enum FloatSide:
    Left
    Right

# ---------------------------------------------------------------------------
# FloatBox — a positioned float with geometry.
# ---------------------------------------------------------------------------

class FloatBox:
    x: f64
    y: f64
    width: f64
    height: f64
    side: FloatSide

    static fn create(x: f64, y: f64, w: f64, h: f64, side: FloatSide) -> FloatBox:
        FloatBox(x: x, y: y, width: w, height: h, side: side)

# ---------------------------------------------------------------------------
# FloatContext — tracks all active floats for a formatting context.
# ---------------------------------------------------------------------------

class FloatContext:
    left_floats: [FloatBox]
    right_floats: [FloatBox]
    current_y: f64

    static fn create() -> FloatContext:
        FloatContext(
            left_floats: [FloatBox](),
            right_floats: [FloatBox](),
            current_y: 0.0
        )

    static fn at_y(y: f64) -> FloatContext:
        FloatContext(
            left_floats: [FloatBox](),
            right_floats: [FloatBox](),
            current_y: y
        )

# ---------------------------------------------------------------------------
# PositionedBox — a box with CSS positioning metadata.
# ---------------------------------------------------------------------------

class PositionedBox:
    box_node: LayoutBox
    position: text
    top: CSSValue
    right_val: CSSValue
    bottom: CSSValue
    left_val: CSSValue

    static fn create(box_node: LayoutBox, pos: text, top: CSSValue, right_v: CSSValue, bottom: CSSValue, left_v: CSSValue) -> PositionedBox:
        PositionedBox(
            box_node: box_node,
            position: pos,
            top: top,
            right_val: right_v,
            bottom: bottom,
            left_val: left_v
        )

# ---------------------------------------------------------------------------
# FloatFormatter — places floats and computes available widths.
# ---------------------------------------------------------------------------

class FloatFormatter:
    logger: Logger

    static fn new(logger: Logger) -> FloatFormatter:
        FloatFormatter(logger: logger)

    # -------------------------------------------------------------------
    # Place a float box to the left or right side.
    # CSS 2.1 section 9.5.1: floats are shifted to the left or right
    # until their outer edge touches the containing block edge or
    # another float.
    # -------------------------------------------------------------------
    me place_float(box_node: LayoutBox, side: FloatSide, ctx: FloatContext, available_width: f64) -> LayoutBox:
        self.logger.debug("place_float node={box_node.node_id} side={float_side_name(side)} available_w={available_width}")

        val float_w = box_node.width + box_node.box_model.margin_left + box_node.box_model.margin_right
        val float_h = box_node.height + box_node.box_model.margin_top + box_node.box_model.margin_bottom

        # Find a y position where the float fits
        var try_y = ctx.current_y
        var placed = false
        var final_x = 0.0
        var final_y = try_y
        var attempts = 0
        val max_attempts = 100

        # Try to place at current y, move down if no room
        while not placed and attempts < max_attempts:
            val avail_at_y = available_width_at(try_y, ctx, available_width)
            if avail_at_y >= float_w:
                val pos = find_float_position(float_w, side, try_y, ctx, available_width)
                final_x = pos.first
                final_y = pos.second
                placed = true
            else:
                # Move below the lowest float at this y level
                val next_y = next_clear_y(try_y, ctx)
                if next_y <= try_y:
                    # No floats to clear — just place here
                    val pos = find_float_position(float_w, side, try_y, ctx, available_width)
                    final_x = pos.first
                    final_y = pos.second
                    placed = true
                else:
                    try_y = next_y
            attempts = attempts + 1

        var result = box_node
        result.x = final_x + box_node.box_model.margin_left
        result.y = final_y + box_node.box_model.margin_top

        self.logger.debug("placed float at x={result.x} y={result.y}")
        result

# ---------------------------------------------------------------------------
# Available width — width at a given y excluding floats.
# ---------------------------------------------------------------------------

fn available_width_at(y: f64, ctx: FloatContext, total_width: f64) -> f64:
    var left_intrusion = 0.0
    var right_intrusion = 0.0

    # Check left floats
    for fl in ctx.left_floats:
        if y >= fl.y and y < (fl.y + fl.height):
            val intrusion = fl.x + fl.width
            if intrusion > left_intrusion:
                left_intrusion = intrusion

    # Check right floats
    for fr in ctx.right_floats:
        if y >= fr.y and y < (fr.y + fr.height):
            val intrusion = total_width - fr.x
            if intrusion > right_intrusion:
                right_intrusion = intrusion

    val available = total_width - left_intrusion - right_intrusion
    if available > 0.0: available else: 0.0

# ---------------------------------------------------------------------------
# Clear floats — return the y position after clearing.
# CSS clear property: left, right, both, or none.
# ---------------------------------------------------------------------------

fn clear_floats(clear: text, ctx: FloatContext) -> f64:
    var clear_y = ctx.current_y

    if clear == "left" or clear == "both":
        for fl in ctx.left_floats:
            val bottom = fl.y + fl.height
            if bottom > clear_y:
                clear_y = bottom

    if clear == "right" or clear == "both":
        for fr in ctx.right_floats:
            val bottom = fr.y + fr.height
            if bottom > clear_y:
                clear_y = bottom

    clear_y

# ---------------------------------------------------------------------------
# Find float position — calculate x, y for a float of given width.
# ---------------------------------------------------------------------------

fn find_float_position(width: f64, side: FloatSide, y: f64, ctx: FloatContext, available: f64) -> Pair<f64, f64>:
    match side:
        FloatSide.Left:
            # Place to the right of existing left floats at this y
            var left_edge = 0.0
            for fl in ctx.left_floats:
                if y >= fl.y and y < (fl.y + fl.height):
                    val edge = fl.x + fl.width
                    if edge > left_edge:
                        left_edge = edge
            Pair(left_edge, y)

        FloatSide.Right:
            # Place to the left of existing right floats at this y
            var right_edge = available
            for fr in ctx.right_floats:
                if y >= fr.y and y < (fr.y + fr.height):
                    if fr.x < right_edge:
                        right_edge = fr.x
            Pair(right_edge - width, y)

# ---------------------------------------------------------------------------
# Next clear y — find the y position below the lowest active float.
# ---------------------------------------------------------------------------

fn next_clear_y(y: f64, ctx: FloatContext) -> f64:
    var min_bottom = y
    var found = false

    for fl in ctx.left_floats:
        if y >= fl.y and y < (fl.y + fl.height):
            val bottom = fl.y + fl.height
            if not found or bottom < min_bottom:
                min_bottom = bottom
                found = true

    for fr in ctx.right_floats:
        if y >= fr.y and y < (fr.y + fr.height):
            val bottom = fr.y + fr.height
            if not found or bottom < min_bottom:
                min_bottom = bottom
                found = true

    if found: min_bottom else: y

# ---------------------------------------------------------------------------
# CSS Positioning — apply position property to a laid-out box.
# ---------------------------------------------------------------------------

fn apply_position(box_node: LayoutBox, style: ComputedStyle, containing: LayoutContext) -> LayoutBox:
    val position = style.position

    match position:
        "static":
            box_node

        "relative":
            # Offset from normal flow position using actual style.top / style.left
            val top = resolve_position_offset(style.top, containing.containing_block_height)
            val left = resolve_position_offset(style.left_val, containing.containing_block_width)
            val bot = resolve_position_offset(style.bottom, containing.containing_block_height)
            val right_v = resolve_position_offset(style.right_val, containing.containing_block_width)
            # CSS 2.1: if both top and bottom are set, top wins. Same for left/right.
            var dy = 0.0
            var dx = 0.0
            if top >= 0.0:
                dy = top
            else if bot >= 0.0:
                dy = 0.0 - bot
            if left >= 0.0:
                dx = left
            else if right_v >= 0.0:
                dx = 0.0 - right_v
            apply_relative(box_node, dy, dx)

        "absolute":
            val top = resolve_position_offset(style.top, containing.containing_block_height)
            val right_v = resolve_position_offset(style.right_val, containing.containing_block_width)
            val bot = resolve_position_offset(style.bottom, containing.containing_block_height)
            val left = resolve_position_offset(style.left_val, containing.containing_block_width)
            apply_absolute(box_node, top, right_v, bot, left, containing)

        "fixed":
            val vp_ctx = LayoutContext.from_containing(
                containing.viewport_width,
                containing.viewport_height,
                0.0, 0.0,
                containing.viewport_width,
                containing.viewport_height,
                containing.logger
            )
            val top = resolve_position_offset(style.top, containing.viewport_height)
            val right_v = resolve_position_offset(style.right_val, containing.viewport_width)
            val bot = resolve_position_offset(style.bottom, containing.viewport_height)
            val left = resolve_position_offset(style.left_val, containing.viewport_width)
            apply_absolute(box_node, top, right_v, bot, left, vp_ctx)

        "sticky":
            # Sticky: treat as relative for now (needs scroll state)
            val top = resolve_position_offset(style.top, containing.containing_block_height)
            val left = resolve_position_offset(style.left_val, containing.containing_block_width)
            var dy = if top >= 0.0: top else: 0.0
            var dx = if left >= 0.0: left else: 0.0
            apply_relative(box_node, dy, dx)

        _:
            box_node

# ---------------------------------------------------------------------------
# Offset resolution — resolve a CSS offset value to px.
# ---------------------------------------------------------------------------

fn resolve_offset(value: CSSValue, reference: f64) -> f64:
    match value:
        CSSValue.Length(v, unit):
            match unit:
                "px": v
                "em": v * 16.0
                "rem": v * 16.0
                "%": (v / 100.0) * reference
                _: v
        CSSValue.Percentage(v):
            (v / 100.0) * reference
        CSSValue.Number(v):
            v
        _:
            0.0

fn resolve_position_offset(value: CSSValue, reference: f64) -> f64:
    match value:
        CSSValue.Keyword(v):
            if v == "auto":
                -1.0  # Sentinel: auto means "not specified"
            else:
                0.0
        _:
            resolve_offset(value, reference)

# ---------------------------------------------------------------------------
# Relative positioning — offset from normal flow position.
# ---------------------------------------------------------------------------

fn apply_relative(box_node: LayoutBox, top: f64, left: f64) -> LayoutBox:
    var result = box_node
    result.x = result.x + left
    result.y = result.y + top
    result

# ---------------------------------------------------------------------------
# Absolute positioning — position relative to containing block.
# Uses the CSS constraint equation:
#   top + margin-top + border-top + padding-top + height + padding-bottom
#   + border-bottom + margin-bottom + bottom = containing-height
# (and similarly for horizontal axis)
# ---------------------------------------------------------------------------

fn apply_absolute(box_node: LayoutBox, top: f64, right_val: f64, bottom: f64, left_val: f64, containing: LayoutContext) -> LayoutBox:
    var result = box_node
    val cw = containing.containing_block_width
    val ch = containing.containing_block_height

    # Horizontal positioning
    val has_left = left_val >= 0.0
    val has_right = right_val >= 0.0

    if has_left:
        result.x = containing.current_x + left_val + result.box_model.margin_left
    else if has_right:
        result.x = containing.current_x + cw - right_val - result.box_model.margin_right - result.width
    else:
        # Both auto — use static position
        pass_dn

    # Vertical positioning
    val has_top = top >= 0.0
    val has_bottom = bottom >= 0.0

    if has_top:
        result.y = containing.current_y + top + result.box_model.margin_top
    else if has_bottom:
        result.y = containing.current_y + ch - bottom - result.box_model.margin_bottom - result.height
    else:
        # Both auto — use static position
        pass_dn

    result

# ---------------------------------------------------------------------------
# Helpers.
# ---------------------------------------------------------------------------

fn float_side_name(side: FloatSide) -> text:
    match side:
        FloatSide.Left: "left"
        FloatSide.Right: "right"

fn float_side_from_text(value: text) -> FloatSide:
    match value:
        "right": FloatSide.Right
        _: FloatSide.Left
