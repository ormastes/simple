#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# DOM-to-Style bridge for the Simple Browser Platform.
# Tracks which DOM nodes are dirty and need style recalculation after
# insertions, removals, attribute changes, or text mutations.
#
# The style engine queries get_dirty_nodes() to know which subtrees require
# a fresh cascade + computed-value resolution pass.

use sbp.shared.logging.{Logger, LogLevel}
use examples.browser.feature.dom.generated_content.{GeneratedContentResolver, StyleMap}

# ---------------------------------------------------------------------------
# Threshold: if more than this many individual nodes are dirty, switch to
# a full-tree recalc instead of incremental per-node work.
# ---------------------------------------------------------------------------
val FULL_RECALC_THRESHOLD: i64 = 256

# ---------------------------------------------------------------------------
# DomToStyleBridge — accumulates dirty-node sets between style passes.
# ---------------------------------------------------------------------------
class DomToStyleBridge:
    dirty_nodes: [i64]
    dirty_subtrees: [i64]
    logger: Logger

    static fn new(logger: Logger) -> DomToStyleBridge:
        DomToStyleBridge(
            dirty_nodes: [i64](),
            dirty_subtrees: [i64](),
            logger: logger,
        )

    # --- Mutation handlers ---------------------------------------------------

    # A new node was inserted under `parent_id`.
    # Mark the node itself and its parent subtree as needing style recalc.
    me on_node_inserted(node_id: i64, parent_id: i64):
        self.logger.debug("DomToStyle: node inserted id={node_id} parent={parent_id}")
        self.mark_node_dirty(node_id)
        self.mark_subtree_dirty(parent_id)

    # A node was removed from the tree.
    # Invalidate the entire subtree rooted at the removed node so that any
    # cached styles referencing it are discarded.
    me on_node_removed(node_id: i64):
        self.logger.debug("DomToStyle: node removed id={node_id}")
        self.mark_subtree_dirty(node_id)

    # An attribute on `node_id` changed.  Only style-affecting attributes
    # (class, id, style, lang, dir) trigger dirty marking.
    me on_attribute_changed(node_id: i64, attr_name: text):
        if is_style_affecting_attribute(attr_name):
            self.logger.debug("DomToStyle: style-affecting attr '{attr_name}' on id={node_id}")
            self.mark_node_dirty(node_id)
            # class/id changes can affect descendant selectors too
            if attr_name == "class" or attr_name == "id":
                self.mark_subtree_dirty(node_id)

    # Text content of a text node changed.
    # The parent element may need re-layout (inline sizing) so mark it dirty.
    me on_text_changed(node_id: i64):
        self.logger.debug("DomToStyle: text changed on id={node_id}")
        self.mark_node_dirty(node_id)

    # --- Queries -------------------------------------------------------------

    # Return the list of individual node IDs that need style recalculation.
    fn get_dirty_nodes() -> [i64]:
        self.dirty_nodes

    # Return the list of subtree root IDs that need full subtree recalc.
    fn get_dirty_subtrees() -> [i64]:
        self.dirty_subtrees

    # After the style engine has finished its recalc pass, clear all dirty
    # state so the next frame starts clean.
    me clear_dirty():
        self.dirty_nodes = [i64]()
        self.dirty_subtrees = [i64]()
        self.logger.debug("DomToStyle: dirty state cleared")

    # If the dirty set is too large, a full recalc is cheaper than
    # incremental per-node work.
    fn needs_full_recalc() -> bool:
        val total = self.dirty_nodes.len() + self.dirty_subtrees.len()
        total > FULL_RECALC_THRESHOLD

    # Return true if there is any work to do.
    fn has_dirty_nodes() -> bool:
        self.dirty_nodes.len() > 0 or self.dirty_subtrees.len() > 0

    # --- Internal helpers ----------------------------------------------------

    me mark_node_dirty(node_id: i64):
        # Avoid duplicates — linear scan is fine for typical dirty-set sizes
        var found = false
        for id in self.dirty_nodes:
            if id == node_id:
                found = true
        if not found:
            self.dirty_nodes.push(node_id)

    me mark_subtree_dirty(node_id: i64):
        var found = false
        for id in self.dirty_subtrees:
            if id == node_id:
                found = true
        if not found:
            self.dirty_subtrees.push(node_id)

# ---------------------------------------------------------------------------
# Generated Content Hook — resolve ::before/::after pseudo-elements.
# Call this before the style recalc pass so pseudo-elements are part of the DOM.
# ---------------------------------------------------------------------------
fn resolve_generated_content(bridge: DomToStyleBridge, style_map: StyleMap):
    """Run generated content resolution using the dom_to_style bridge's logger.
    Should be called before style recalculation to insert ::before/::after nodes.
    """
    var resolver = GeneratedContentResolver(logger: bridge.logger)
    bridge.logger.debug("DomToStyle: resolving generated content (::before/::after)")
    # Note: Full integration requires passing the actual DomDocument.
    # The resolver will walk the document and insert pseudo-element nodes
    # for any elements with matched ::before/::after rules.

# ---------------------------------------------------------------------------
# Helper: determine whether an attribute name can affect style resolution.
# ---------------------------------------------------------------------------
fn is_style_affecting_attribute(attr: text) -> bool:
    match attr:
        "class": true
        "id": true
        "style": true
        "lang": true
        "dir": true
        "hidden": true
        "disabled": true
        "checked": true
        "readonly": true
        "type": true
        _: false
