#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# DOM event types for event propagation through the node tree.
# Events follow the capture-target-bubble phase model.

enum EventPhase:
    None
    Capturing
    AtTarget
    Bubbling

class EventInit:
    bubbles: bool
    cancelable: bool
    composed: bool

    static fn default() -> EventInit:
        EventInit(bubbles: false, cancelable: false, composed: false)

    static fn create(bubbles: bool, cancelable: bool, composed: bool) -> EventInit:
        EventInit(bubbles: bubbles, cancelable: cancelable, composed: composed)

class DomEvent:
    type_name: text
    target_id: i64
    current_target_id: i64
    phase: EventPhase
    init: EventInit
    prevented: bool
    stopped: bool
    timestamp: i64

    static fn create(type_name: text, target_id: i64, timestamp: i64) -> DomEvent:
        DomEvent(
            type_name: type_name,
            target_id: target_id,
            current_target_id: target_id,
            phase: EventPhase.None,
            init: EventInit.default(),
            prevented: false,
            stopped: false,
            timestamp: timestamp
        )

enum EventTarget:
    NodeTarget(node_id: i64)
    WindowTarget
