# Garbage collector types for the JS heap.
# Models generational GC with mark-sweep, object headers, and collection statistics.

enum Generation:
    Young
    Old
    Permanent

class GcHeader:
    marked: bool
    generation: Generation
    ref_count: i64

    static fn young() -> GcHeader:
        GcHeader(marked: false, generation: Generation.Young, ref_count: 0)

    static fn create(generation: Generation) -> GcHeader:
        GcHeader(marked: false, generation: generation, ref_count: 0)

class GcObject:
    header: GcHeader
    value: JsValue
    references: [i64]

    static fn create(value: JsValue) -> GcObject:
        GcObject(header: GcHeader.young(), value: value, references: [i64]())

class GcStats:
    total_allocated: i64
    total_freed: i64
    young_count: i64
    old_count: i64
    collections: i64

    static fn zero() -> GcStats:
        GcStats(total_allocated: 0, total_freed: 0, young_count: 0, old_count: 0, collections: 0)
