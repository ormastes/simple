# Telemetry and metrics collection for the Simple Browser Platform.
# Collects counters, gauges, and histograms for performance monitoring.

enum MetricKind:
    Counter
    Gauge
    Histogram

class Metric:
    name: text
    kind: MetricKind
    value: f64

    static fn create(name: text, kind: MetricKind, value: f64) -> Metric:
        Metric(name: name, kind: kind, value: value)

class MetricsCollector:
    metrics: [Metric]

    static fn new() -> MetricsCollector:
        MetricsCollector(metrics: [Metric]())

    me increment(name: text):
        # Find existing counter and increment, or create new one
        var found = false
        var i = 0
        while i < self.metrics.len():
            val m = self.metrics.get(i)
            if m.name == name:
                val updated = Metric(name: name, kind: MetricKind.Counter, value: m.value + 1.0)
                self.metrics.set(i, updated)
                found = true
            i = i + 1
        if not found:
            self.metrics.push(Metric.create(name, MetricKind.Counter, 1.0))

    me gauge(name: text, value: f64):
        # Set gauge to absolute value, replacing any existing
        var found = false
        var i = 0
        while i < self.metrics.len():
            val m = self.metrics.get(i)
            if m.name == name:
                val updated = Metric(name: name, kind: MetricKind.Gauge, value: value)
                self.metrics.set(i, updated)
                found = true
            i = i + 1
        if not found:
            self.metrics.push(Metric.create(name, MetricKind.Gauge, value))

    me histogram(name: text, value: f64):
        # Append observation to histogram bucket
        self.metrics.push(Metric.create(name, MetricKind.Histogram, value))

    fn get_all() -> [Metric]:
        self.metrics
