#!/bin/sh
# Electron Screenshot Generator for Browser Rendering Comparison
#
# Takes screenshots of HTML files using Electron and saves as PNG.
# Uses the same interface as chrome_screenshot.shs for drop-in compatibility.
#
# Usage:
#   ./electron_screenshot.shs <html_file_or_string> <output.png> [width] [height]
#   ./electron_screenshot.shs test.html output.png 800 600
#
# Dependencies: Electron (npm install in tools/electron-shell/)

HTML_INPUT="$1"
OUTPUT="${2:-screenshot.png}"
WIDTH="${3:-800}"
HEIGHT="${4:-600}"

if [ -z "$HTML_INPUT" ]; then
    echo "Usage: $0 <html_file_or_string> <output.png> [width] [height]"
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
ELECTRON_DIR="$PROJECT_ROOT/tools/electron-shell"
SCREENSHOT_JS="$ELECTRON_DIR/screenshot.js"

# Check that screenshot.js exists
if [ ! -f "$SCREENSHOT_JS" ]; then
    echo "Error: screenshot.js not found at $SCREENSHOT_JS"
    exit 1
fi

# Check that node_modules/electron exists
if [ ! -d "$ELECTRON_DIR/node_modules/electron" ]; then
    echo "Error: Electron not installed. Run: cd $ELECTRON_DIR && npm install"
    exit 1
fi

# Resolve Electron binary
ELECTRON_BIN="$ELECTRON_DIR/node_modules/.bin/electron"
if [ ! -x "$ELECTRON_BIN" ]; then
    echo "Error: Electron binary not found at $ELECTRON_BIN"
    exit 1
fi

# If input is not a file, create a temp HTML file
CLEANUP_TEMP=""
if [ ! -f "$HTML_INPUT" ]; then
    TEMP_HTML=$(mktemp /tmp/electron_compare_XXXXXX.html)
    cat > "$TEMP_HTML" << HTMLEOF
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>* { margin: 0; padding: 0; box-sizing: border-box; }</style>
</head>
<body style="margin: 0; padding: 0;">
$HTML_INPUT
</body>
</html>
HTMLEOF
    HTML_INPUT="$TEMP_HTML"
    CLEANUP_TEMP=1
fi

# Run Electron screenshot
"$ELECTRON_BIN" "$SCREENSHOT_JS" "$HTML_INPUT" "$OUTPUT" "$WIDTH" "$HEIGHT" 2>/dev/null

# Cleanup temp file
if [ -n "$CLEANUP_TEMP" ] && [ -f "$TEMP_HTML" ]; then
    rm -f "$TEMP_HTML"
fi

if [ -f "$OUTPUT" ]; then
    echo "Screenshot saved: $OUTPUT (${WIDTH}x${HEIGHT})"
else
    echo "Error: Electron screenshot failed"
    exit 1
fi
