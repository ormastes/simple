use examples.browser.feature.browser.devtools.{DevToolsServer}
use examples.browser.shared.logging.{Logger, LogLevel}

fn make_devtools() -> DevToolsServer:
    DevToolsServer.new(9222, Logger.new("devtools-spec", LogLevel.Error))

describe "DevToolsServer":
    describe "Page.captureScreenshot":
        it "reports unavailable framebuffer instead of returning a placeholder image":
            val devtools = make_devtools()

            val response = devtools.page_screenshot(1)

            expect(response).to_contain("\"data\":\"\"")
            expect(response).to_contain("screenshot framebuffer unavailable")

        it "returns the latest recorded screenshot for a tab":
            var devtools = make_devtools()

            devtools.record_screenshot(1, "old-png", "png", 10, 10)
            devtools.record_screenshot(2, "other-tab", "png", 20, 20)
            devtools.record_screenshot(1, "new-webp", "webp", 30, 40)

            val response = devtools.page_screenshot(1)

            expect(response).to_contain("\"data\":\"new-webp\"")
            expect(response).to_contain("\"format\":\"webp\"")
            expect(response).to_contain("\"width\":30")
            expect(response).to_contain("\"height\":40")
            expect(response).to_contain("\"timestamp\":2")

        it "ignores empty screenshot data":
            var devtools = make_devtools()

            devtools.record_screenshot(1, "", "png", 10, 10)

            expect(devtools.page_screenshot(1)).to_contain("screenshot framebuffer unavailable")
