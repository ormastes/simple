# Architecture: Sandbox Policy Enforcement Tests
# Category: Browser Platform Security
# Status: Active
#
# Validates that the Simple Browser Platform sandbox.sdn enforces correct
# capability-based sandboxing per process type. Follows OpenBSD pledge/unveil
# model. Each process type (renderer, network, gpu, browser) has a strict
# capability and denial list.
#
# Run with: bin/simple test examples/browser/test/architecture/sandbox_enforcement_spec.spl

use std.spec
use std.sdn.parser.{parse}
use std.io_runtime.{file_read}

val SANDBOX_PATH = "examples/browser/sandbox.sdn"

fn load_sandbox() -> SdnValue:
    val content = file_read(SANDBOX_PATH)
    match parse(content):
        case Ok(v): v
        case Err(e): SdnValue.Null

fn get_list(profile: SdnValue, key: text) -> [text]:
    """Extract a string list from a profile section."""
    var result: [text] = []
    val field = profile.get(key)
    if field.?:
        match field:
            case SdnValue.Array(arr):
                for item in arr:
                    match item:
                        case SdnValue.String(s):
                            result.push(s)
                        case _: pass_dn
            case _: pass_dn
    result

fn get_bool(profile: SdnValue, key: text) -> bool:
    """Extract a boolean from a profile section."""
    val field = profile.get(key)
    if field.?:
        match field:
            case SdnValue.Bool(b): return b
            case _: pass_dn
    false

fn list_contains(items: [text], target: text) -> bool:
    for item in items:
        if item == target:
            return true
    false

# ============================================================================
# Renderer process sandbox
# ============================================================================

describe "Sandbox enforcement":
    context "renderer process":
        it "renderer cannot spawn processes":
            """renderer_process denied list contains ProcessSpawn."""
            val sdn = load_sandbox()
            val renderer = sdn.get("renderer_process")
            if renderer.?:
                val denied = get_list(renderer, "denied")
                val has_spawn = list_contains(denied, "ProcessSpawn")
                expect(has_spawn).to_equal(true)
            else:
                expect("renderer_process should exist").to_equal("")

        it "renderer has no filesystem access":
            """renderer denied has FileRead, FileWrite, FileCreate."""
            val sdn = load_sandbox()
            val renderer = sdn.get("renderer_process")
            if renderer.?:
                val denied = get_list(renderer, "denied")
                val has_read = list_contains(denied, "FileRead")
                val has_write = list_contains(denied, "FileWrite")
                val has_create = list_contains(denied, "FileCreate")
                expect(has_read).to_equal(true)
                expect(has_write).to_equal(true)
                expect(has_create).to_equal(true)
            else:
                expect("renderer_process should exist").to_equal("")

        it "renderer capabilities are minimal":
            """renderer only has NetConnect and IpcConnect."""
            val sdn = load_sandbox()
            val renderer = sdn.get("renderer_process")
            if renderer.?:
                val caps = get_list(renderer, "capabilities")
                expect(caps.len()).to_equal(2)
                val has_net = list_contains(caps, "NetConnect")
                val has_ipc = list_contains(caps, "IpcConnect")
                expect(has_net).to_equal(true)
                expect(has_ipc).to_equal(true)
            else:
                expect("renderer_process should exist").to_equal("")

    # ============================================================================
    # Network process sandbox
    # ============================================================================

    context "network process":
        it "network process has cache access":
            """network unveil_paths contains /tmp/sbp-cache."""
            val sdn = load_sandbox()
            val network = sdn.get("network_process")
            if network.?:
                val paths = get_list(network, "unveil_paths")
                val has_cache = list_contains(paths, "/tmp/sbp-cache")
                expect(has_cache).to_equal(true)
            else:
                expect("network_process should exist").to_equal("")

    # ============================================================================
    # GPU process sandbox
    # ============================================================================

    context "GPU process":
        it "GPU process cannot access network":
            """gpu denied has NetConnect."""
            val sdn = load_sandbox()
            val gpu = sdn.get("gpu_process")
            if gpu.?:
                val denied = get_list(gpu, "denied")
                val has_net = list_contains(denied, "NetConnect")
                expect(has_net).to_equal(true)
            else:
                expect("gpu_process should exist").to_equal("")

    # ============================================================================
    # Browser process capabilities
    # ============================================================================

    context "browser process":
        it "browser process can spawn":
            """browser capabilities has ProcessSpawn."""
            val sdn = load_sandbox()
            val browser = sdn.get("browser_process")
            if browser.?:
                val caps = get_list(browser, "capabilities")
                val has_spawn = list_contains(caps, "ProcessSpawn")
                expect(has_spawn).to_equal(true)
            else:
                expect("browser_process should exist").to_equal("")

    # ============================================================================
    # Pledge enforcement across sandboxed processes
    # ============================================================================

    context "pledge enforcement":
        it "pledge is enabled for sandboxed processes":
            """renderer, network, gpu all have pledge: true."""
            val sdn = load_sandbox()
            val sandboxed = ["renderer_process", "network_process", "gpu_process"]
            var all_pledged = true
            for name in sandboxed:
                val profile = sdn.get(name)
                if profile.?:
                    val pledged = get_bool(profile, "pledge")
                    if not pledged:
                        all_pledged = false
                else:
                    all_pledged = false
            expect(all_pledged).to_equal(true)
