use std.spec
use std.js.types.js_types.{JsValue}
use examples.browser.feature.script.builtins.json.{json_parse, json_stringify}
use examples.browser.feature.script.builtins.string.{string_fromCharCode}

fn _parse_string(input: text) -> text:
    val parsed = json_parse(input)
    match parsed:
        Ok(value):
            match value:
                JsValue.String(s): s
                _: "<not-string>"
        Err(e): "Error: {e.message}"

describe "JSON builtins":
    describe "parse":
        it "shares the string builtin non ASCII mapping":
            expect(string_fromCharCode(233)).to_equal("é")

        it "decodes ASCII unicode escapes":
            expect(_parse_string("\"\\u003Cscript\\u003E\"")).to_equal("<script>")

        it "decodes BMP unicode escapes":
            expect(_parse_string("\"\\u00E9\"")).to_equal(string_fromCharCode(233))
            expect(_parse_string("\"\\u4E16\\u754C\"")).to_equal("世界")

        it "decodes surrogate pair escapes":
            expect(_parse_string("\"\\uD83D\\uDE00\"")).to_equal("😀")

        it "replaces unpaired surrogate escapes":
            expect(_parse_string("\"\\uD83D\"")).to_equal("\uFFFD")

    describe "stringify":
        it "keeps escaped JSON controls stable":
            expect(json_stringify(JsValue.String(v: "a\nb\tc"), 0)).to_equal("\"a\\nb\\tc\"")
