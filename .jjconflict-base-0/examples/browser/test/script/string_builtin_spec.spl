use std.spec
use examples.browser.feature.script.builtins.string.{string_charCodeAt, string_fromCharCode}

describe "String builtins":
    describe "fromCharCode":
        it "returns ASCII controls and punctuation without placeholders":
            expect(string_fromCharCode(9)).to_equal("\t")
            expect(string_fromCharCode(10)).to_equal("\n")
            expect(string_fromCharCode(60)).to_equal("<")
            expect(string_fromCharCode(126)).to_equal("~")

        it "returns non ASCII code units instead of question mark":
            expect(string_fromCharCode(233)).to_equal("é")
            expect(string_fromCharCode(30028)).to_equal("界")

        it "normalizes to unsigned 16 bit JavaScript code units":
            expect(string_fromCharCode(65536 + 65)).to_equal("A")
            expect(string_fromCharCode(0xD800)).to_equal("\uFFFD")

    describe "charCodeAt":
        it "returns character code points instead of UTF-8 bytes":
            expect(string_charCodeAt("é", 0)).to_equal(233)
            expect(string_charCodeAt("Aé", 1)).to_equal(233)
            expect(string_charCodeAt("界", 0)).to_equal(30028)
