use std.spec

describe "WebpCodec":
    it "should recognize RIFF container magic bytes":
        # RIFF header: 'R'=82 'I'=73 'F'=70 'F'=70
        val r = 82
        val i = 73
        val f1 = 70
        val f2 = 70
        val riff_sum = r + i + f1 + f2
        expect(riff_sum).to_equal(295)

    it "should recognize WEBP fourCC after RIFF size":
        # 'W'=87 'E'=69 'B'=66 'P'=80
        val w = 87
        val e = 69
        val b = 66
        val p = 80
        val webp_sum = w + e + b + p
        expect(webp_sum).to_equal(302)

    it "should recognize VP8 chunk type tag":
        # 'V'=86 'P'=80 '8'=56 ' '=32
        val vp8_tag = 86 + 80 + 56 + 32
        expect(vp8_tag).to_equal(254)

    it "should recognize VP8L lossless chunk tag":
        # 'V'=86 'P'=80 '8'=56 'L'=76
        val vp8l_tag = 86 + 80 + 56 + 76
        expect(vp8l_tag).to_equal(298)

    it "should validate quality range for encoder":
        # Quality 0-100; 85 is default for auto-convert
        val quality_min = 0
        val quality_default = 85
        val quality_max = 100
        expect(quality_min).to_equal(0)
        expect(quality_default).to_equal(85)
        expect(quality_max).to_equal(100)
        expect(quality_default).to_be_greater_than(quality_min)
        expect(quality_default).to_be_less_than(quality_max)

    it "should match ImageFormat.Webp ordinal":
        # WebP variant exists in ImageFormat enum
        # Verify it's distinct from PNG(0), JPEG(1), GIF(2)
        val png_id = 0
        val jpeg_id = 1
        val gif_id = 2
        val webp_id = 3
        expect(webp_id).to_be_greater_than(gif_id)
        expect(webp_id).to_be_greater_than(jpeg_id)
        expect(webp_id).to_be_greater_than(png_id)

    it "should compute minimum RIFF header size":
        # RIFF(4) + size(4) + WEBP(4) = 12 bytes minimum
        val riff_header_size = 12
        expect(riff_header_size).to_equal(12)
