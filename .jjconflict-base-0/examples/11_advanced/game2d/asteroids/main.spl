# Asteroids — physics + game2d demo
use std.nogc_sync_mut.game2d.app.run.{run}
use std.nogc_sync_mut.game2d.render.canvas.{Canvas}
use std.nogc_sync_mut.game2d.math.{DrawMode}
use std.common.engine.ids.{NodeId}
use std.common.engine.math2d.{Vec2}
use std.common.engine.color.{EngineColor}
use std.nogc_sync_mut.engine.physics.config.{default_physics_config_2d}
use std.nogc_sync_mut.engine.physics.world2d.{PhysicsWorld2D}

fn node(i: i64) -> NodeId:
    NodeId(raw: i)

class Game:
    world: PhysicsWorld2D
    count: i64

    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        val _ = dt

    fn fixed_update(self, step: f32):
        self.world.step(0.016)

    fn draw(self, ctx: Canvas):
        ctx.clear(EngineColor(r: 0.0, g: 0.0, b: 0.0, a: 1.0))
        val gray = EngineColor(r: 0.6, g: 0.6, b: 0.6, a: 1.0)
        var i = 0
        while i < self.count:
            val pos = self.world.get_position(node(i))
            val sx = 400.0 + pos.x * 30.0
            val sy = 300.0 - pos.y * 30.0
            val radius = 8.0 + (i % 4).to_f64() * 4.0
            ctx.circle(DrawMode.Fill, Vec2(x: sx, y: sy), radius, gray)
            i = i + 1
        ctx.text("Asteroids", Vec2(x: 10.0, y: 20.0), EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0))

fn setup_world() -> PhysicsWorld2D:
    var config = default_physics_config_2d()
    config.gravity = Vec2(x: 0.0, y: 0.0)
    config.restitution = 0.8
    config.friction = 0.0
    var world = PhysicsWorld2D.create(config)
    var i = 0
    while i < 15:
        val x = (i * 7 + 3) % 20 - 10
        val y = (i * 13 + 5) % 20 - 10
        world.add_dynamic_body(node(i), x.to_f64(), y.to_f64(), 1.0)
        world.add_circle_collider(node(i), 0.5)
        val vx = ((i * 3 + 1) % 5 - 2).to_f64()
        val vy = ((i * 7 + 2) % 5 - 2).to_f64()
        world.set_velocity(node(i), vx, vy)
        i = i + 1
    world

fn main():
    run(Game(world: setup_world(), count: 15), "Asteroids", 800, 600)
