    bridge_require_session, bridge_exec, bridge_gui_status,
    bridge_sessions_list, bridge_eval,
    bridge_window_list, bridge_window_open, bridge_window_capture,
    bridge_window_describe, bridge_screenshot,
    bridge_action_invoke, bridge_action_invoke_with_request, t32_action_request_id,
    bridge_action_list, bridge_field_get, bridge_field_set,
    bridge_history_tail, bridge_resources_list, bridge_resource_read
}
