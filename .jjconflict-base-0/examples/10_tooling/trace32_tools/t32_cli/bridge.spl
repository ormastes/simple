use app.t32_cli.types.{T32BridgeResult}
use app.mcp_t32.session_state.{McpT32Session, MCP_T32_SESSIONS, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE, MCP_T32_AREA_READY, MCP_T32_AREA_NAME}
