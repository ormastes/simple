#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# T32 LSP MCP — Persistent tool daemon
#
# Loads the heavy CMM parser/analyzer stack once, then processes file-backed
# requests from the lightweight MCP front-end.

use t32_lsp_mcp.tools.{handle_cmm_parse, handle_cmm_diagnostics, handle_cmm_complete, handle_cmm_hover, handle_cmm_symbols, handle_cmm_validate_cli}
use t32_lsp_mcp.debug_log.{lsp_debug_append, lsp_debug_bootstrap, lsp_debug_root}

extern fn sys_get_args() -> [text]
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_env_cwd() -> text

fn daemon_arg0_is_script(arg0: text) -> bool:
    arg0.ends_with(".spl") or arg0.ends_with("tool_daemon") or arg0.ends_with("tool_daemon.spl")

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and daemon_arg0_is_script(args[0]):
        args = args[1:args.len()]

    val root = lsp_normalize_root(if args.len() >= 1: args[0] else: lsp_default_daemon_root())
    lsp_debug_bootstrap()
    lsp_debug_append("daemon.log", "daemon start root=" + root + " debug_root=" + lsp_debug_root())
    rt_process_run(lsp_shell_bin_path(), ["-c", "mkdir -p " + lsp_shell_quote(root)])
    rt_file_write_text(root + "/ready", "ready")

    while true:
        val entries = rt_dir_list(root) ?? []
        var handled = false
        var i = 0
        while i < entries.len():
            val name = entries[i]
            if name.ends_with(".req"):
                handled = true
                daemon_handle_request(root, root + "/" + name)
            i = i + 1
        if not handled:
            rt_process_run(lsp_shell_bin_path(), ["-c", "sleep 0.05"])

fn lsp_default_daemon_root() -> text:
    val env_root = lsp_normalize_root(rt_env_get("T32_LSP_MCP_TOOL_DAEMON_DIR") ?? "")
    if env_root != "":
        return env_root
    val cwd = rt_env_cwd()
    var suffix = "workspace"
    if cwd != "":
        suffix = lsp_sanitize_path_segment(cwd)
    lsp_normalize_root("/tmp/t32_lsp_mcp_daemon_" + suffix)

fn lsp_normalize_root(candidate: text) -> text:
    val trimmed = candidate.trim()
    if trimmed == "" or trimmed == "/" or trimmed == "." or trimmed == "..":
        return "/tmp/t32_lsp_mcp_daemon_workspace"
    if not trimmed.starts_with("/"):
        return "/tmp/t32_lsp_mcp_daemon_workspace"
    trimmed

fn lsp_sanitize_path_segment(value: text) -> text:
    if value == "":
        return "empty"
    var parts: [text] = []
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_" or ch == "-":
            parts.push(ch)
        else:
            parts.push("_")
        i = i + 1
    val sanitized = parts.join("")
    if sanitized == "":
        return "empty"
    sanitized

fn lsp_shell_bin_path() -> text:
    val env_shell = rt_env_get("T32_LSP_MCP_SHELL_BIN") ?? ""
    if env_shell != "":
        return env_shell
    if rt_file_exists("/usr/bin/sh"):
        return "/usr/bin/sh"
    "/bin/sh"

fn lsp_shell_quote(value: text) -> text:
    if value == "":
        return "''"
    var parts: [text] = []
    parts.push("'")
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == "'":
            parts.push("'\\''")
        else:
            parts.push(ch)
        i = i + 1
    parts.push("'")
    parts.join("")

fn daemon_handle_request(root: text, req_path: text):
    val raw = rt_file_read_text(req_path) ?? ""
    val lines = raw.split("\n")
    if lines.len() < 4:
        lsp_debug_append("errors.log", "bad request file=" + req_path)
        rt_file_delete(req_path)
        return

    val id = lines[0]
    val tool_name = lines[1]
    val args_path = lines[2]
    val response_path = lines[3]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    lsp_debug_append("requests.log", "tool=" + tool_name + " id=" + id + " args=" + args_path)
    val response = daemon_dispatch_tool(id, tool_name, args_raw)
    rt_file_write_text(response_path, response)
    lsp_debug_append("daemon.log", "handled tool=" + tool_name + " id=" + id + " bytes=" + str(response.len()))
    rt_file_delete(req_path)

fn daemon_dispatch_tool(id: text, tool_name: text, args_raw: text) -> text:
    if tool_name == "cmm_parse":
        return handle_cmm_parse(id, args_raw)
    if tool_name == "cmm_diagnostics":
        return handle_cmm_diagnostics(id, args_raw)
    if tool_name == "cmm_complete":
        return handle_cmm_complete(id, args_raw)
    if tool_name == "cmm_hover":
        return handle_cmm_hover(id, args_raw)
    if tool_name == "cmm_symbols":
        return handle_cmm_symbols(id, args_raw)
    if tool_name == "cmm_validate_cli":
        return handle_cmm_validate_cli(id, args_raw)
    lsp_debug_append("errors.log", "unknown tool=" + tool_name + " id=" + id)
    ""
