#![allow(export_outside_init)]
# Matrix Helper Functions
#
# Small host-side helpers used by the CUDA example spec.

fn matrix_zeros(rows: i64, cols: i64) -> [f32]:
    var result: [f32] = []
    var i = 0
    val total = rows * cols
    while i < total:
        result.push(0.0)
        i = i + 1
    result

fn matrix_ones(rows: i64, cols: i64) -> [f32]:
    var result: [f32] = []
    var i = 0
    val total = rows * cols
    while i < total:
        result.push(1.0)
        i = i + 1
    result

fn matrix_random(rows: i64, cols: i64) -> [f32]:
    var result: [f32] = []
    var i = 0
    val total = rows * cols
    while i < total:
        # Deterministic pseudo-random-ish filler is enough for the spec.
        result.push(((i * 17 + 13) % 101) as f32 / 100.0)
        i = i + 1
    result

fn matrix_multiply_cpu(a: [f32], b: [f32], m: i64, n: i64, k: i64) -> [f32]:
    var result: [f32] = []
    var row = 0
    while row < m:
        var col = 0
        while col < n:
            var acc = 0.0
            var inner = 0
            while inner < k:
                val a_idx = row * k + inner
                val b_idx = inner * n + col
                acc = acc + a[a_idx] * b[b_idx]
                inner = inner + 1
            result.push(acc)
            col = col + 1
        row = row + 1
    result

fn matrix_equal(a: [f32], b: [f32], epsilon: f32) -> bool:
    if a.len() != b.len():
        return false

    var i = 0
    while i < a.len():
        var diff = a[i] - b[i]
        if diff < 0.0:
            diff = 0.0 - diff
        if diff > epsilon:
            return false
        i = i + 1
    true

export matrix_zeros, matrix_ones, matrix_random
export matrix_multiply_cpu, matrix_equal
