# Unit tests for LSP diagnostics module

use src.lsp.lsp_document.{vault_init, open_document, get_vault_note_names, get_vault_note_paths, set_vault_path}
use src.lsp.lsp_diagnostics.{compute_diagnostics_json}
use src.core.note_parser.{extract_wikilinks}

describe "LSP Diagnostics":
    """Tests for broken wikilink and orphan note detection"""

    context "wikilink extraction":
        """Extracting wikilinks from note content"""

        it "finds wikilinks in content":
            val content = "See [[Project Notes]] and [[Meeting Log]] for details."
            val links = extract_wikilinks(content)
            expect(links.len()).to_be_greater_than(0)

    context "broken wikilink detection":
        """Detecting wikilinks to non-existent notes"""

        it "detects broken wikilinks":
            val content = "Link to [[NonExistentNote]] here."
            val links = extract_wikilinks(content)
            expect(links.len()).to_be_greater_than(0)

    context "diagnostic JSON format":
        """Diagnostics are formatted as LSP publishDiagnostics"""

        it "produces valid JSON diagnostics":
            val content = "# Test Note\n\nSee [[BrokenLink]]"
            val diag = compute_diagnostics_json(content, [])
            expect(diag).to_contain("diagnostics")
