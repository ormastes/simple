# LSP-MCP Bridge — Entry Point
#
# Starts the LSP-MCP bridge server for Obsidian vault.
# Exposes 7 LSP-oriented tools via MCP protocol:
# diagnostics, completions, hover, link resolution, semantic health.
#
# Set OBSIDIAN_VAULT_PATH environment variable to your vault directory.
#
# Usage:
#   OBSIDIAN_VAULT_PATH=/path/to/vault simple run examples/obsidian-search/src/main_bridge.spl

use src.lsp_mcp.bridge_protocol.{run_bridge_server}

fn start_bridge_server():
    run_bridge_server()
