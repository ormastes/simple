# Copy this file to attempts/<attempt_id>.sdn for each LLM tuning attempt.

attempt:
  attempt_id: "llm_backed_app_server_dry_run"
  goal: "LLM-backed app/server development fine-tune dry run"
  app_or_server_target: "app/server"

research:
  research_doc: "doc/02_requirements/feature/spipe_llm_finetune_process_options.md"
  data_sources:
    - name: "dry-run-no-download"
      source: "requirements-options"
      license: "not-applicable"
      download_command: "not-run-until-requirements-selected"
      checksum: "not-applicable"
      cache_path: ".spipe/llm-finetune-process/data/dry-run"

model:
  base_model: "not-selected"
  base_model_revision: "not-selected"
  base_model_reason: "Requirement selection must choose scaffold, local QLoRA, provider adapter, or hybrid path before model choice."
  deployment_target: "not-selected"

tuning:
  method: "dry-run-record-only"
  training_script: ".spipe/llm-finetune-process/scripts/dry_run_training.sh"
  training_command: ".spipe/llm-finetune-process/scripts/dry_run_training.sh"
  model_artifact: "not-created"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/verify_attempt.sh .spipe/llm-finetune-process/attempts/llm_backed_app_server_dry_run.sdn"
  metrics: "record completeness only"
  target: "attempt record has research, model, tuning, training script, evaluation, and retry fields"
  result: "structural-pass"

decision:
  status: "try-other-way"
  retry_target: "requirements-selection"
  next_attempt: "first-selected-production-attempt"
  notes: "Dry-run proves the SPipe record and verification loop. It does not train a model."
