# New-model architecture evidence for SPipe LLM fine-tune attempts.

model_architecture:
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "fixed-format MCQ JSONL gate before real KorMedMCQA-derived rerun"
    training_strategy: "rerun local QLoRA only after data-quality gate passes on real licensed data"
    deployment_target: "local app/server handoff only after target eval pass"
    fallback: "switch base model or retrieval/tool strategy if retry remains below target"
  - attempt_id: "llm_backed_app_server_dry_run"
    architecture_doc: "doc/04_architecture/spipe_llm_finetune_process.md"
    model_family: "pending-user-selection"
    data_strategy: "pending-user-selection"
    training_strategy: "pending-user-selection"
    deployment_target: "pending-user-selection"
    fallback: "use existing base model or non-training approach after requirements selection"
  - attempt_id: "llm_backed_app_server_dry_run"
    architecture_doc: "doc/04_architecture/spipe_llm_finetune_model_architecture.md"
    model_family: "local-qlora-adapter"
    data_strategy: "recorded data downloads plus checksum/cache evidence feed instruction data preparation"
    training_strategy: "start with local QLoRA adapter; fallback to provider fine-tune; route eval failures to retrieval/tool/app changes when tuning is not the right fix"
    deployment_target: "local-or-provider"
    fallback: "provider-fine-tune"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "fixed-format KorMedMCQA-derived MCQ data-quality retry"
    training_strategy: "local QLoRA retry after data-format and evaluation contract cleanup"
    deployment_target: "local app/server handoff only after target eval pass"
    fallback: "try other base model or provider-managed path if retry remains below target"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "fixed-format synthetic gate plus local artifact manifest before real licensed data rerun"
    training_strategy: "local implementation dry-run writes artifact/eval manifest; real QLoRA remains required"
    deployment_target: "local app/server only after target-reaching eval"
    fallback: "switch to data/model/tool strategy if real rerun remains below target"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "licensed fixed-format medical QA data required before training"
    training_strategy: "do not run QLoRA until license and cache evidence are present"
    deployment_target: "local app/server only after target-reaching eval and accepted decision"
    fallback: "switch to retrieval/tool strategy or alternate dataset/model if license cannot be cleared"
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "licensed fixed-format medical QA data with recorded cache path and checksum before training"
    training_strategy: "do not run QLoRA until license, cache, and checksum evidence are present"
    deployment_target: "local app/server only after target-reaching eval and accepted decision"
    fallback: "switch to retrieval/tool strategy or alternate dataset/model if license cannot be cleared"
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "consume only retry5-approved licensed fixed-format cache with matching checksum"
    training_strategy: "run local QLoRA only after retry5 review emits PASS; write model and eval artifacts before normal review"
    deployment_target: "local app/server only after target-reaching eval and accepted decision"
    fallback: "switch to retrieval/tool strategy or alternate dataset/model if license or target eval cannot pass"
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
    architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    model_family: "MedGemma"
    data_strategy: "review retry6 licensed cache, artifact manifest, and target eval evidence; do not create new data"
    training_strategy: "normal acceptance review gate only; do not train in retry7"
    deployment_target: "local app/server only after target-reaching eval, license/safety/deployment evidence, and accepted decision"
    fallback: "switch to retrieval/tool strategy, alternate dataset/model, or another tuning retry if normal review rejects"
