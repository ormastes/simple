
use std.spec
use app.simple_portal.content_db.{simple_portal_default_app_root, simple_portal_default_data_root, portal_content_db_load}
use app.simple_portal.server.{SimplePortalServer}

fn _db_err() -> text:
    match portal_content_db_load(simple_portal_default_app_root()):
        Ok(_):
            "ok"
        Err(e):
            e

fn _server_err() -> text:
    match SimplePortalServer.new(4040, simple_portal_default_app_root(), simple_portal_default_data_root(), "dev-token"):
        Ok(_):
            "ok"
        Err(e):
            e

describe "portal diag":
    it "prints":
        print "APP_ROOT=[" + simple_portal_default_app_root() + "]"
        print "DATA_ROOT=[" + simple_portal_default_data_root() + "]"
        print "DB_LOAD=[" + _db_err() + "]"
        print "SERVER_NEW=[" + _server_err() + "]"
        expect true == true