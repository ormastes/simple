# base64 — Encode/decode base64
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

val BASE64_CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

fn tool_base64(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Encode or decode base64.

    Usage: base64 FILE         (encode)
           base64 -d FILE      (decode)
    """
    var decode_mode = false
    var file_path = ""

    for arg in args:
        if arg == "-d" or arg == "--decode":
            decode_mode = true
        elif not arg.starts_with("-"):
            file_path = arg

    if file_path == "":
        write_error(terminal, "base64: missing file operand")
        return 1
    if vfs == nil:
        write_error(terminal, "base64: no filesystem mounted")
        return 1

    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "base64: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    if decode_mode:
        write_line(terminal, _base64_decode(content))
    else:
        write_line(terminal, _base64_encode(content))
    return 0

fn _base64_encode(input: text) -> text:
    """Encode text to base64."""
    var result = ""
    var buffer: u32 = 0
    var bits: i32 = 0

    for ch in input:
        buffer = (buffer << 8) | (ch.to_i32() & 0xFF)
        bits = bits + 8
        while bits >= 6:
            bits = bits - 6
            val idx = (buffer >> bits) & 0x3F
            result = "{result}{BASE64_CHARS.char_at(idx as i32)}"
    if bits > 0:
        buffer = buffer << (6 - bits)
        val idx = buffer & 0x3F
        result = "{result}{BASE64_CHARS.char_at(idx as i32)}"
    # Padding
    while result.len() % 4 != 0:
        result = "{result}="
    return result

fn _base64_decode(input: text) -> text:
    """Decode base64 to text."""
    var result = ""
    var buffer: u32 = 0
    var bits: i32 = 0

    for ch in input:
        if ch == "=" or ch == "\n" or ch == "\r":
            pass_dn
        else:
            val idx = _b64_index(ch)
            if idx >= 0:
                buffer = (buffer << 6) | idx
                bits = bits + 6
                if bits >= 8:
                    bits = bits - 8
                    val byte_val = (buffer >> bits) & 0xFF
                    result = "{result}{_chr(byte_val as i32)}"
    return result

fn _b64_index(ch: text) -> u32:
    """Get base64 index of a character."""
    var i: u32 = 0
    for c in BASE64_CHARS:
        if c == ch:
            return i
        i = i + 1
    return 0

fn _chr(code: i32) -> text:
    """Convert byte value to a single-character text value."""
    return text.from_char_code(code as i64)
