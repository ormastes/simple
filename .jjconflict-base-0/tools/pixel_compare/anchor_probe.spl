# Temporary probe: is <a> text painted by the direct layout entry?
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}

fn ink(px: [u32]) -> i64:
    var n = 0i64
    var i = 0
    while i < px.len():
        if px[i] != 0xFFFFFFFF:
            n = n + 1
        i = i + 1
    n

val a = simple_web_layout_render_html_software_pixels("<html><body><a href=\"#\">Gmail</a></body></html>", 160, 40)
print("anchor_ink=" + ink(a).to_text())
val p = simple_web_layout_render_html_software_pixels("<html><body><p>Gmail</p></body></html>", 160, 40)
print("p_ink=" + ink(p).to_text())
val s = simple_web_layout_render_html_software_pixels("<html><body><span>Gmail</span></body></html>", 160, 40)
print("span_ink=" + ink(s).to_text())
val nb = simple_web_layout_render_html_software_pixels("<html><body><nobr><a href=\"#\">Gmail</a></nobr></body></html>", 160, 40)
print("nobr_anchor_ink=" + ink(nb).to_text())
