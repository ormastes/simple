# Temporary probe: JS pipeline via captured stdout (the real signal).
use std.gc_async_mut.gpu.browser_engine.script.script_runner.{
    ScriptRunner, run_script_with_type}
use std.gc_async_mut.gpu.browser_engine.script.js_transpiler.{js_transpile}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use app.io.mod.{file_read_text}

var runner = ScriptRunner.new()
val out1 = run_script_with_type(runner, "var a = 2; var b = 3; console.log(a + b);", "text/javascript")
print("SMALL-JS-OUT: [" + out1 + "] (want 5)")

val out2 = run_script_with_type(runner, "let msg = 'hi'; console.log(msg + ' there');", "text/javascript")
print("SMALL-JS-OUT2: [" + out2 + "] (want hi there)")

# show the transpilation of a google-style snippet head for diagnosis
val html = file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val tree = html_tree_builder_build_with_scripts(html)
var i = 0
var nonempty = 0
while i < tree.scripts.len():
    val o = run_script_with_type(runner, tree.scripts[i], "text/javascript")
    if o.len() > 0:
        nonempty = nonempty + 1
        if nonempty <= 2:
            print("GOOGLE-JS-OUT[" + i.to_text() + "]: " + o.substring(0, if o.len() < 200: o.len() else: 200))
    i = i + 1
print("GOOGLE-JS: scripts=" + tree.scripts.len().to_text() + " with_stdout=" + nonempty.to_text())
