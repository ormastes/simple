use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}
extern fn rt_env_get(name: text) -> text
val which = rt_env_get("WHICH")
var src = ""
if which == "0":
    src = "var greeting = 'Hello'; greeting + ', World from JS!'"
elif which == "1":
    src = "function fib(n){ return n < 2 ? n : fib(n-1) + fib(n-2) } 'fib(12) = ' + fib(12)"
elif which == "2":
    src = "var parts = ['simple', 'js', 'engine']; 'joined: ' + parts.join(' + ')"
elif which == "3":
    src = "function fib(n){ return n < 2 ? n : fib(n-1) + fib(n-2) } fib(3)"
elif which == "4":
    src = "var x = 5 < 2 ? 1 : 2; x"
val outs = run_page_scripts([src])
print("RESULT[" + which + "]: " + outs[0])
