use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}
val scripts: [text] = [
    "typeof document",
    "typeof window",
    "typeof navigator",
    "typeof localStorage",
    "typeof document.getElementById",
    "typeof [].forEach",
    "typeof ''.replace",
    "typeof Promise",
    "JSON.parse('[7,8]')[1]",
    "[1,2,3].map(function(n){return n*2;}).join(',')"
]
val r = run_page_scripts(scripts)
var i = 0
while i < r.len():
    print("[" + i.to_text() + "] " + r[i])
    i = i + 1
