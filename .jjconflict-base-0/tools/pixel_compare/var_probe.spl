# Temporary probe: var() fallback + nested var resolution.
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}

fn ink_nonwhite(px: [u32]) -> i64:
    var n = 0i64
    var i = 0
    while i < px.len():
        if px[i] != 0xFFFFFFFF:
            n = n + 1
        i = i + 1
    n

# google-style: undefined custom props, nested fallback -> #1f1f1f
val h1 = "<html><head><style>.gb_5{color:#1f1f1f;color:var(--og-link-color,var(--gm3-sys-color-on-surface,#1f1f1f))}</style></head><body><a class=\"gb_5\" href=\"#\">Gmail</a></body></html>"
val p1 = simple_web_layout_render_html_software_pixels(h1, 160, 40)
print("nested_fallback_ink=" + ink_nonwhite(p1).to_text() + " (must be > 0)")

# defined custom prop wins over fallback
val h2 = "<html><head><style>:root{--c:#ff0000}p{color:var(--c,#00ff00)}</style></head><body><p>X</p></body></html>"
val p2 = simple_web_layout_render_html_software_pixels(h2, 60, 30)
var red = 0
var green = 0
var i = 0
while i < p2.len():
    if p2[i] == 0xFFFF0000:
        red = red + 1
    elif p2[i] == 0xFF00FF00:
        green = green + 1
    i = i + 1
print("defined_var_red=" + red.to_text() + " green=" + green.to_text() + " (red>0, green==0)")
