FROM ubuntu:24.04

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        coreutils \
        jq \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/simple
COPY . /opt/simple

RUN chmod +x /opt/simple/bin/simple \
    && find /opt/simple/bin/release -type f -name simple -exec chmod +x {} \; 2>/dev/null || true

ENTRYPOINT ["/opt/simple/bin/simple"]
