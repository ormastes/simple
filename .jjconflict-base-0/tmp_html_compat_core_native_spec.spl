# @tag: sys, wm_compare, html_compat, geometry

use std.spec.{describe, it, expect}
use app.wm_compare.html_compat_geometry_probe.{html_compat_fixture_simple_boxes}

describe "html compat core native":

    it "renders core boxes without the compare bridge":
        val boxes = html_compat_fixture_simple_boxes("24_flex_wrap_reverse_basic", 320, 240)
        expect(boxes.len()).to_equal(4)
        expect(boxes[0].label).to_equal("wrap_reverse_shell")
        expect(boxes[1].y).to_equal(40)
