#!/bin/sh
set -eu

# run_simpleos_cortex_m33_qemu.shs — SimpleOS Lite on QEMU MPS2-AN505 (Cortex-M33)
#
# Usage:
#   sh scripts/run_simpleos_cortex_m33_qemu.shs              # build + run
#   sh scripts/run_simpleos_cortex_m33_qemu.shs --no-build   # run existing ELF
#   sh scripts/run_simpleos_cortex_m33_qemu.shs --smoke      # build + self-test + QEMU exit
#
# Env knobs:
#   SIMPLEOS_CM33_ELF   Path to kernel ELF (default: build/os/simpleos_cm33.elf)
#   QEMU_MEM            RAM (default: 16M)
#   QEMU_EXTRA_ARGS     Extra QEMU args

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

SIMPLEOS_CM33_ELF="${SIMPLEOS_CM33_ELF:-${ROOT_DIR}/build/os/simpleos_cm33.elf}"
QEMU_MEM="${QEMU_MEM:-16M}"
QEMU_EXTRA_ARGS="${QEMU_EXTRA_ARGS:-}"
LINKER_SCRIPT="${ROOT_DIR}/src/compiler/70.backend/baremetal/cortex_m33/linker.ld"

NO_BUILD=0
SMOKE=0
for arg in "$@"; do
    case "$arg" in
        --no-build) NO_BUILD=1 ;;
        --smoke) SMOKE=1 ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if [ "$NO_BUILD" -eq 0 ]; then
    echo "[cm33] Building SimpleOS Lite for Cortex-M33..."
    mkdir -p "$(dirname "$SIMPLEOS_CM33_ELF")"

    SHIM_C="${ROOT_DIR}/src/os/kernel/arch/cortex_m33/cm33_shim.c"

    if [ ! -f "$SHIM_C" ]; then
        echo "[cm33] ERROR: C shim not found: $SHIM_C" >&2
        exit 1
    fi

    BOARD_DIR="${ROOT_DIR}/src/os/kernel/arch/cortex_m33"

    SMOKE_CFLAGS=""
    if [ "$SMOKE" -eq 1 ]; then
        SMOKE_CFLAGS="-DSIMPLEOS_QEMU_SMOKE=1"
    fi

    clang \
        --target=thumbv8m.main-none-eabihf \
        -mcpu=cortex-m33 -mthumb -mfloat-abi=soft \
        -I "$BOARD_DIR" \
        -nostdlib -nostartfiles -ffreestanding -O1 \
        $SMOKE_CFLAGS \
        -T "$LINKER_SCRIPT" \
        -o "$SIMPLEOS_CM33_ELF" \
        "$SHIM_C" \
        -fuse-ld=lld \
        2>&1

    echo "[cm33] Built: $SIMPLEOS_CM33_ELF"
fi

if [ ! -f "$SIMPLEOS_CM33_ELF" ]; then
    echo "[cm33] ERROR: ELF not found: $SIMPLEOS_CM33_ELF" >&2
    exit 1
fi

echo "[cm33] Launching QEMU MPS2-AN505 (Cortex-M33)..."
echo "  elf  : $SIMPLEOS_CM33_ELF"
echo "  mem  : $QEMU_MEM"
echo "  smoke: $SMOKE"

if [ "$SMOKE" -eq 1 ]; then
    QEMU_EXTRA_ARGS="-semihosting-config enable=on,target=native $QEMU_EXTRA_ARGS"
fi

# shellcheck disable=SC2086
exec qemu-system-arm \
    -machine mps2-an505 \
    -cpu cortex-m33 \
    -kernel "$SIMPLEOS_CM33_ELF" \
    -m "$QEMU_MEM" \
    -serial stdio \
    -monitor none \
    -display none \
    -no-reboot \
    $QEMU_EXTRA_ARGS
