{
  "wrapper_config": {
    "mcp_json": ".mcp.json",
    "expected_servers": {
      "t32-mcp": {
        "command": "bin/t32_mcp_server",
        "args": []
      },
      "t32-lsp-mcp": {
        "command": "bin/t32_lsp_mcp_server",
        "args": []
      },
      "obsidian-search": {
        "command": "bin/obsidian_lsp_mcp_server",
        "args": [
          "mcp"
        ]
      },
      "obsidian-lsp-mcp": {
        "command": "bin/obsidian_lsp_mcp_server",
        "args": []
      }
    }
  },
  "wrapper_files": [
    {
      "path": "bin/t32_mcp_server",
      "must_contain": [
        "PREFERRED_BINARY",
        "COLD_ENTRY=",
        "SOURCE_ARTIFACT=\"$COLD_ENTRY\"",
        "exec \"$RUNTIME\" \"$SOURCE_ARTIFACT\" \"$@\""
      ],
      "must_not_contain": [
        "compile \"$ENTRY\" -o \"$CACHE_FILE\"",
        "exec \"$RUNTIME\" \"$ENTRY\""
      ]
    },
    {
      "path": "bin/t32_lsp_mcp_server",
      "must_contain": [
        "CACHE_FILE",
        "compile \"$ENTRY\" -o \"$CACHE_FILE\"",
        "exec \"$RUNTIME\" \"$CACHE_FILE\""
      ],
      "must_not_contain": [
        "exec \"$RUNTIME\" \"$ENTRY\""
      ]
    },
    {
      "path": "bin/obsidian_lsp_mcp_server",
      "must_contain": [
        "CACHE_FILE",
        "compile \"$ENTRY_SOURCE\" -o \"$CACHE_FILE\"",
        "exec \"$RUNTIME\" \"$CACHE_FILE\""
      ],
      "must_not_contain": [
        "exec \"$RUNTIME\" \"$ENTRY_SOURCE\""
      ]
    }
  ],
  "handler_scan_globs": [
    "examples/**/src/mcp/**/*.spl",
    "examples/**/src/lsp_mcp/**/*.spl"
  ],
  "forbidden_scan_patterns": [
    "rt_dir_walk(",
    "scan_vault_with_excludes("
  ],
  "handler_shell_subprocess_globs": [
    "examples/**/src/mcp/**/*.spl",
    "examples/**/src/lsp_mcp/**/*.spl"
  ],
  "forbidden_shell_subprocess_patterns": [
    "rt_process_run(\"/bin/sh\", [\"-c\"",
    "rt_process_run(\"sh\", [\"-c\"",
    "rt_process_run(\"bash\", [\"-c\""
  ],
  "mutation_invalidation": [
    {
      "path": "examples/obsidian-search/src/mcp/handlers_write.spl",
      "required_symbol": "invalidate_scan_vault_cache"
    },
    {
      "path": "examples/obsidian-search/src/mcp/handlers_metadata.spl",
      "required_symbol": "invalidate_scan_vault_cache"
    },
    {
      "path": "examples/obsidian-search/src/mcp/handlers_search_ext.spl",
      "required_symbol": "invalidate_scan_vault_cache"
    },
    {
      "path": "examples/obsidian-search/src/mcp/handlers_periodic.spl",
      "required_symbol": "invalidate_scan_vault_cache"
    }
  ],
  "startup_checks": [
    {
      "name": "simple-mcp",
      "command": [
        "bin/simple_mcp_server"
      ],
      "budget_ms": 1000.0,
      "budget_rss_mb": 256.0
    },
    {
      "name": "simple-lsp-mcp",
      "command": [
        "bin/simple_lsp_mcp_server"
      ],
      "budget_ms": 1000.0,
      "budget_rss_mb": 256.0
    },
    {
      "name": "t32-mcp",
      "command": [
        "bin/t32_mcp_server"
      ],
      "budget_ms": 500.0,
      "budget_rss_mb": 128.0
    },
    {
      "name": "t32-lsp-mcp",
      "command": [
        "bin/t32_lsp_mcp_server"
      ],
      "budget_ms": 500.0,
      "budget_rss_mb": 128.0
    },
    {
      "name": "obsidian-search",
      "command": [
        "bin/obsidian_lsp_mcp_server",
        "mcp"
      ],
      "budget_ms": 500.0,
      "budget_rss_mb": 128.0
    },
    {
      "name": "obsidian-lsp-mcp",
      "command": [
        "bin/obsidian_lsp_mcp_server"
      ],
      "budget_ms": 500.0,
      "budget_rss_mb": 128.0
    }
  ],
  "request_checks": [
    {
      "name": "obsidian-search/search_vault",
      "command": [
        "bin/obsidian_lsp_mcp_server",
        "mcp"
      ],
      "budget_ms": 2000.0,
      "fixture_vault": "test/fixtures/obsidian_perf_vault",
      "fixture_copies": 60
    }
  ],
  "doc_traceability": {
    "relevant_prefixes": [
      "bin/t32_mcp_server",
      "bin/t32_lsp_mcp_server",
      "bin/obsidian_lsp_mcp_server",
      ".mcp.json",
      "examples/obsidian-search/src/",
      "examples/10_tooling/trace32_tools/",
      "src/app/build/",
      "src/app/io/",
      "scripts/mcp_performance_guard.py",
      "scripts/mcp_performance_guard_config.json"
    ],
    "doc_prefixes": [
      "doc/03_plan/",
      "doc/04_architecture/",
      "doc/05_design/"
    ],
    "required_headings": [
      "Startup Path",
      "Hot Path Inventory",
      "Cache / Index Strategy",
      "Invalidation Strategy",
      "Performance Budgets"
    ]
  }
}
