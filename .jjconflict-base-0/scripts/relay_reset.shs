#!/bin/sh
# Power-cycle via USB relay: OFF -> wait -> ON.
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/relay_common.shs"

detect_relay_device

relay_log "Power OFF for reset"
serial_send_noreply "$RELAY_CMD_OFF"

relay_log "Waiting ${RELAY_RESET_DELAY}s for capacitors to drain"
sleep "$RELAY_RESET_DELAY"

serial_send_noreply "$RELAY_CMD_ON"
relay_log "Power ON after reset (delay=${RELAY_RESET_DELAY}s)"
