# Audit public-ish Simple API names against the production naming contract.

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_exit(code: i32) -> void

struct ApiAuditConfig:
    root: text
    baseline_path: text
    scan_roots: [text]
    explicit_scan_roots: bool

fn shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\"'\"'") + "'"

fn normalize_args(all_args: [text]) -> [text]:
    var start = 0
    var found = false
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("api_consistency_audit.spl"):
            start = i + 1
            found = true
            break
        i = i + 1
    if not found and all_args.len() > 0:
        start = 1

    var args: [text] = []
    i = start
    while i < all_args.len():
        if all_args[i] != "--":
            args = args.push(all_args[i])
        i = i + 1
    args

fn default_scan_roots() -> [text]:
    ["src/compiler", "src/app", "src/lib/common"]

fn default_config() -> ApiAuditConfig:
    ApiAuditConfig(
        root: ".",
        baseline_path: "scripts/audit/api_consistency_baseline.json",
        scan_roots: default_scan_roots(),
        explicit_scan_roots: false
    )

fn join_path(root: text, path: text) -> text:
    if root == "" or root == ".":
        return path
    if root.ends_with("/"):
        return root + path
    root + "/" + path

fn finalize_config(config: ApiAuditConfig) -> ApiAuditConfig:
    var result = config
    if result.root != "." and result.root != "":
        if not result.explicit_scan_roots:
            var roots: [text] = []
            for root in default_scan_roots():
                roots = roots.push(join_path(result.root, root))
            result.scan_roots = roots
        if result.baseline_path == "scripts/audit/api_consistency_baseline.json":
            result.baseline_path = join_path(result.root, result.baseline_path)
    result

fn parse_args(args: [text]) -> ApiAuditConfig:
    var config = default_config()
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--root" and i + 1 < args.len():
            config.root = args[i + 1]
            i = i + 2
        elif arg.starts_with("--root="):
            config.root = arg.substring("--root=".len())
            i = i + 1
        elif arg == "--baseline" and i + 1 < args.len():
            config.baseline_path = args[i + 1]
            i = i + 2
        elif arg.starts_with("--baseline="):
            config.baseline_path = arg.substring("--baseline=".len())
            i = i + 1
        elif arg == "--scan-root" and i + 1 < args.len():
            if not config.explicit_scan_roots:
                config.scan_roots = []
                config.explicit_scan_roots = true
            config.scan_roots = config.scan_roots.push(args[i + 1])
            i = i + 2
        elif arg.starts_with("--scan-root="):
            if not config.explicit_scan_roots:
                config.scan_roots = []
                config.explicit_scan_roots = true
            config.scan_roots = config.scan_roots.push(arg.substring("--scan-root=".len()))
            i = i + 1
        else:
            i = i + 1
    finalize_config(config)

fn list_scan_files(scan_roots: [text]) -> [text]:
    var roots = ""
    for root in scan_roots:
        roots = roots + " " + shell_quote(root)
    val command = "for p in" + roots + "; do if [ -e \"$p\" ]; then find \"$p\" -type f -name '*.spl'; fi; done | sort"
    val result = rt_process_run("/bin/sh", ["-c", command])
    if result.2 != 0:
        print("API Consistency Audit")
        print("=====================")
        print("find failed:")
        print(result.1)
        rt_exit(1)
    var files: [text] = []
    for raw in result.0.split("\n"):
        val path = raw.trim()
        if path != "" and not path.contains("/vendor/"):
            files = files.push(path)
    files

fn declaration_name(line: text) -> text:
    val trimmed = line.trim()
    var rest = ""
    if trimmed.starts_with("static fn "):
        rest = trimmed.substring("static fn ".len())
    elif trimmed.starts_with("fn "):
        rest = trimmed.substring("fn ".len())
    elif trimmed.starts_with("me "):
        rest = trimmed.substring("me ".len())
    else:
        return ""

    val paren = rest.index_of("(") ?? -1
    if paren <= 0:
        return ""
    val name = rest.substring(0, paren).trim()
    if name == "":
        return ""
    name

fn hard_rejected_reason(name: text) -> text:
    if name == "get_or_fail":
        return "Use fetch for required lookup or get for optional lookup."
    if name == "maybe_get_value":
        return "Use get for optional lookup."
    if name == "filter_not":
        return "Use reject for filter-drop semantics."
    if name == "append_all_items":
        return "Use extend or concat."
    if name == "stringify":
        return "Use to_string."
    if name == "str_value":
        return "Use as_str or to_string depending on allocation."
    if name == "do_validation":
        return "Use validate or check."
    if name == "transform_values":
        return "Use map when the receiver already implies values."
    if name == "for_each_item":
        return "Use each."
    if name == "iterate_all":
        return "Use each or iter."
    ""

fn is_advisory_predicate(name: text) -> bool:
    name.starts_with("is_") or name.starts_with("has_")

fn root_bucket(path: text, roots: [text]) -> text:
    for root in roots:
        if path == root or path.starts_with(root + "/"):
            return root
    val slash = path.index_of("/") ?? -1
    if slash < 0:
        return path
    path.substring(0, slash)

fn index_of_text(values: [text], target: text) -> i64:
    var i = 0
    while i < values.len():
        if values[i] == target:
            return i
        i = i + 1
    -1

fn number_after(source: text, marker: text, fallback: i64) -> i64:
    val marker_idx = source.index_of(marker) ?? -1
    if marker_idx < 0:
        return fallback
    val rest = source.substring(marker_idx + marker.len()).trim()
    var digits = ""
    var i = 0
    while i < rest.len():
        val ch = rest.substring(i, i + 1)
        if ch < "0" or ch > "9":
            break
        digits = digits + ch
        i = i + 1
    if digits == "":
        return fallback
    digits.to_i64()

fn baseline_total(source: text) -> i64:
    number_after(source, "\"advisory_predicate_prefix_debt\":", -1)

fn baseline_for_root(source: text, root: text) -> i64:
    number_after(source, "\"" + root + "\":", -1)

fn print_limited(items: [text], limit: i64):
    var shown = 0
    while shown < items.len() and shown < limit:
        print("  - " + items[shown])
        shown = shown + 1
    if items.len() > limit:
        print("  ... " + (items.len() - limit).to_string() + " more")

val config = parse_args(normalize_args(rt_cli_get_args()))
val files = list_scan_files(config.scan_roots)
val baseline_source = rt_file_read_text(config.baseline_path) ?? ""

var hard_hits: [text] = []
var advisory_hits: [text] = []
var advisory_roots: [text] = []
var advisory_counts: [i64] = []
var declarations = 0

for path in files:
    val source = rt_file_read_text(path) ?? ""
    val lines = source.split("\n")
    var line_no = 0
    while line_no < lines.len():
        val name = declaration_name(lines[line_no])
        if name != "":
            declarations = declarations + 1
            val reason = hard_rejected_reason(name)
            if reason != "":
                hard_hits = hard_hits.push(path + ":" + (line_no + 1).to_string() + ": " + name + " - " + reason)
            elif is_advisory_predicate(name):
                advisory_hits = advisory_hits.push(path + ":" + (line_no + 1).to_string() + ": " + name)
                val bucket = root_bucket(path, config.scan_roots)
                val idx = index_of_text(advisory_roots, bucket)
                if idx < 0:
                    advisory_roots = advisory_roots.push(bucket)
                    advisory_counts = advisory_counts.push(1)
                else:
                    advisory_counts[idx] = advisory_counts[idx] + 1
        line_no = line_no + 1

val baseline_advisory = baseline_total(baseline_source)
var baseline_violations: [text] = []
if baseline_advisory >= 0 and advisory_hits.len() > baseline_advisory:
    baseline_violations = baseline_violations.push("advisory predicate-prefix debt increased from " + baseline_advisory.to_string() + " to " + advisory_hits.len().to_string())

var root_idx = 0
while root_idx < advisory_roots.len():
    val bucket = advisory_roots[root_idx]
    val count = advisory_counts[root_idx]
    val baseline_count = baseline_for_root(baseline_source, bucket)
    if baseline_count >= 0 and count > baseline_count:
        baseline_violations = baseline_violations.push(bucket + " advisory predicate-prefix debt increased from " + baseline_count.to_string() + " to " + count.to_string())
    root_idx = root_idx + 1

print("API Consistency Audit")
print("=====================")
print("Scanned " + declarations.to_string() + " function/method declarations")
print("Hard violations: " + hard_hits.len().to_string())
print_limited(hard_hits, 50)
print("Advisory predicate-prefix debt: " + advisory_hits.len().to_string())
print_limited(advisory_hits, 20)
if baseline_advisory >= 0:
    print("Advisory baseline: " + baseline_advisory.to_string())
if advisory_roots.len() > 0:
    print("Advisory debt by root:")
    root_idx = 0
    while root_idx < advisory_roots.len():
        print("  - " + advisory_roots[root_idx] + ": " + advisory_counts[root_idx].to_string())
        root_idx = root_idx + 1
if baseline_violations.len() > 0:
    print("Baseline violations:")
    for item in baseline_violations:
        print("  - " + item)

if hard_hits.len() > 0 or baseline_violations.len() > 0:
    rt_exit(1)
rt_exit(0)
