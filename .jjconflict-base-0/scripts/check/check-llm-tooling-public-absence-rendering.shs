#!/bin/sh
# Public absence-rendering gate for the LLM tooling lanes.
#
# Simple internals still use an Option-none marker. Public manuals and evidence
# for the new LLM/runtime/context/ponytail surfaces must render absence as
# explicit status text such as "none", "missing", or "blocked".
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_tooling_public_absence_rendering}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_tooling_public_absence_rendering_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
SURFACE_MANIFEST="$BUILD_DIR/public_absence_surface_manifest.tsv"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$SURFACE_MANIFEST"

tmp_files="$(mktemp)"
tmp_body="$(mktemp)"
tmp_filtered="$(mktemp)"
trap 'rm -f "$tmp_files" "$tmp_body" "$tmp_filtered"' EXIT INT TERM

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "0"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

{
    printf '%s\n' \
        doc/03_plan/agent_tasks/llm_runtime_vllm_torch_interface.md \
        doc/03_plan/agent_tasks/llm_tooling_context_ponytail_mimic.md \
        doc/03_plan/agent_tasks/kairos_like_simple_mcp_llm_dashboard.md \
        doc/03_plan/sys_test/llm_runtime_vllm_torch_interface.md \
        doc/03_plan/sys_test/kairos_like_simple_mcp_llm_dashboard.md \
        doc/04_architecture/app/tools/llm_tooling_context_ponytail_mimic.md \
        doc/04_architecture/app/tools/llm_runtime_vllm_torch_interface.md \
        doc/04_architecture/app/ui/kairos_like_simple_mcp_llm_dashboard.md \
        doc/05_design/app/tools/llm_runtime_vllm_torch_interface.md \
        doc/05_design/app/tools/llm_tooling_context_ponytail_mimic.md \
        doc/05_design/app/ui/kairos_like_simple_mcp_llm_dashboard.md \
        doc/07_guide/app/llm/llm_tooling_context_ponytail_mimic.md \
        doc/07_guide/app/llm/llm_runtime_vllm_torch_interface.md \
        doc/07_guide/app/llm/spipe_llm_finetune_process.md \
        doc/07_guide/app/mcp/mcp.md
    find doc/08_tracking/bug \
        -maxdepth 1 -type f -name 'llm_strict_host_completion_blockers_*.md' 2>/dev/null
    find doc/09_report/2026/06 \
        -maxdepth 1 -type f -name 'llm_*.md' 2>/dev/null
    find doc/06_spec/01_unit/app/tooling doc/06_spec/unit/app/tooling \
        -maxdepth 1 -type f \( -name 'context_generate_spec.md' -o -name 'ponytail_audit_spec.md' \) 2>/dev/null
    find doc/06_spec/test/01_unit/app/tooling doc/06_spec/test/unit/app/tooling \
        -maxdepth 1 -type f \( -name 'context_generate_spec.md' -o -name 'ponytail_audit_spec.md' \) 2>/dev/null
    find doc/06_spec/03_system/app/llm_runtime -type f -name '*.md' 2>/dev/null
    find doc/06_spec/test/01_unit/app/llm_runtime doc/06_spec/test/unit/app/llm_runtime \
        -type f -name '*.md' 2>/dev/null
    find doc/06_spec/01_unit/app/llm_dashboard/collectors doc/06_spec/unit/app/llm_dashboard/collectors \
        -type f -name '*.md' 2>/dev/null
    find doc/06_spec/test/01_unit/app/llm_dashboard/collectors doc/06_spec/test/unit/app/llm_dashboard/collectors \
        -type f \( -name 'diagnostics_jsonl_collector_spec.md' -o -name 'tooling_artifact_collector_spec.md' \) 2>/dev/null
    find doc/06_spec/test/01_unit/app/llm_dashboard doc/06_spec/test/unit/app/llm_dashboard \
        -maxdepth 1 -type f \( -name 'assistant_digest_spec.md' -o -name 'assistant_live_view_spec.md' -o -name 'assistant_retention_spec.md' -o -name 'assistant_import_spec.md' \) 2>/dev/null
    find doc/06_spec/03_system/feature/app/web_dashboard \
        -type f -name '*diagnostics*spec.md' 2>/dev/null
    find doc/06_spec/03_system/tools/spipe doc/06_spec/test/03_system/tools/spipe \
        -type f \( -name 'llm_finetune_retry6_training_eval_gate_spec.md' -o -name 'llm_finetune_retry7_acceptance_gate_spec.md' \) 2>/dev/null
    find .spipe/llm-finetune-process \
        -type f \( -name '*.md' -o -name '*.sdn' -o -name '*.jsonl' \) ! -path '*/attempts/template.sdn' 2>/dev/null
} | sort -u >"$tmp_files"

while IFS= read -r path; do
    [ -n "$path" ] || continue
    [ -f "$path" ] || continue
    printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
done <"$tmp_files" >"$SURFACE_MANIFEST"

surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"

write_evidence() {
    status="$1"
    reason="$2"
    blocked_gates="$3"
    next_action="$4"
    {
        printf '%s\n' "llm_tooling_public_absence_rendering_status=$status"
        printf '%s\n' "llm_tooling_public_absence_rendering_reason=$reason"
        printf '%s\n' "llm_tooling_public_absence_rendering_required_gates=nil_marker_absent,option_none_absent,empty_string_absent"
        printf '%s\n' "llm_tooling_public_absence_rendering_blocked_gates=$blocked_gates"
        printf '%s\n' "llm_tooling_public_absence_rendering_primary_blocked_gate=$(printf '%s\n' "$blocked_gates" | cut -d '|' -f 1 | cut -d ',' -f 1)"
        printf '%s\n' "llm_tooling_public_absence_rendering_surface_manifest=$SURFACE_MANIFEST"
        printf '%s\n' "llm_tooling_public_absence_rendering_surface_manifest_count=$surface_manifest_count"
        printf '%s\n' "llm_tooling_public_absence_rendering_surface_manifest_size=$surface_manifest_size"
        printf '%s\n' "llm_tooling_public_absence_rendering_surface_manifest_sha256=$surface_manifest_sha256"
        printf '%s\n' "llm_tooling_public_absence_rendering_failure_count=$failures"
        printf '%s\n' "llm_tooling_public_absence_rendering_next_action=$next_action"
    } >"$OUT_ENV"

    {
        printf '# LLM Tooling Public Absence Rendering Evidence\n\n'
        printf '%s\n' "- status: \`$status\`"
        printf '%s\n' "- reason: \`$reason\`"
        printf '%s\n' "- required_gates: \`nil_marker_absent,option_none_absent,empty_string_absent\`"
        printf '%s\n' "- blocked_gates: \`$blocked_gates\`"
        printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
        printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
        printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
        printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
        printf '%s\n' "- failure_count: \`$failures\`"
        printf '%s\n' "- next_action: \`$next_action\`"
        printf '\n%s\n' 'The guard scans public manuals, generated/manual SPipe docs, dashboard wording, LLM runtime evidence reports, and strict blocker tracking surfaces that expose absence states. It excludes fenced code and executable SSpec details in Markdown so internal Simple source examples can still document implementation syntax.'
    } >"$REPORT_PATH"
}

failures=0
while IFS= read -r path; do
    [ -n "$path" ] || continue
    [ -f "$path" ] || continue

    case "$path" in
        *.md)
            awk '
                /^```/ { fenced = !fenced; next }
                !fenced { print }
            ' "$path" >"$tmp_body"
            awk '
                /^<summary>Executable SSpec<\/summary>$/ { executable = 1; next }
                executable && /^<\/details>$/ { executable = 0; next }
                !executable { print }
            ' "$tmp_body" >"$tmp_filtered"
            cp "$tmp_filtered" "$tmp_body"
            ;;
        *)
            cp "$path" "$tmp_body"
            ;;
    esac

    if grep -nE '(^|[^[:alnum:]_])nil([^[:alnum:]_]|$)' "$tmp_body" >/tmp/llm-public-absence.$$ 2>/dev/null; then
        while IFS= read -r line; do
            echo "public_absence_internal_marker=$path:$line" >&2
        done </tmp/llm-public-absence.$$
        failures=$((failures + 1))
    fi
    rm -f /tmp/llm-public-absence.$$

    if grep -nE 'Option-none|Option::None|None marker' "$tmp_body" >/tmp/llm-public-option.$$ 2>/dev/null; then
        while IFS= read -r line; do
            echo "public_absence_option_marker=$path:$line" >&2
        done </tmp/llm-public-option.$$
        failures=$((failures + 1))
    fi
    rm -f /tmp/llm-public-option.$$

    if grep -nE 'empty string|equals `""`|returns `""`|status: ""|content: ""' "$tmp_body" >/tmp/llm-public-empty.$$ 2>/dev/null; then
        while IFS= read -r line; do
            echo "public_absence_empty_string=$path:$line" >&2
        done </tmp/llm-public-empty.$$
        failures=$((failures + 1))
    fi
    rm -f /tmp/llm-public-empty.$$
done <"$tmp_files"

if [ "$failures" -gt 0 ]; then
    write_evidence "fail" "public_absence_marker_found" "public_absence_markers" "replace public nil, option-none, or empty-string wording with explicit status text"
    echo "STATUS: FAIL llm-tooling-public-absence-rendering" >&2
    exit 1
fi

write_evidence "pass" "absence_markers_absent" "none" "rerun after public manual or dashboard wording changes"
echo "STATUS: PASS llm-tooling-public-absence-rendering"
