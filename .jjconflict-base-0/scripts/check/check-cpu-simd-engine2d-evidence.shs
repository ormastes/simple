#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN_PINNED=0
if [ -n "${SIMPLE_BIN+x}" ]; then
    SIMPLE_BIN_PINNED=1
fi
SIMPLE_BIN="${SIMPLE_BIN:-bin/simple}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass
CANDIDATE_SMOKE_DIR="${BUILD_DIR:-build/cpu-simd-engine2d-evidence}/candidate-smoke"

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

# The genuine Engine2D SIMD evidence needs an interpreter binary that carries the
# rt_engine2d_simd_fill_row_u32 / copy / blend externs (the names the evidence
# .spl actually calls). Guarding on the NEW symbol means a binary that only has
# the legacy rt_simd_*_row_u32 names skips cleanly instead of crashing on an
# unknown extern. A freshly built driver
# has them; a stale bootstrap/release binary predating the kernels does not
# (deploy via scripts/bootstrap/bootstrap-from-scratch.sh --deploy). When the
# user pinned SIMPLE_BIN we honour it; otherwise prefer a capable driver and,
# if none exists, SKIP (not fail) so the gate never false-reds on an old binary.
binary_has_engine2d_simd_externs() {
    [ -x "$1" ] || return 1
    if ! command -v nm >/dev/null 2>&1; then
        return 1
    fi
    _symbols="$(nm -a "$1" 2>/dev/null || nm -D "$1" 2>/dev/null || true)"
    printf '%s\n' "$_symbols" | grep -q 'rt_engine2d_simd_fill_row_u32' \
        && printf '%s\n' "$_symbols" | grep -q 'rt_engine2d_simd_copy_row_u32' \
        && printf '%s\n' "$_symbols" | grep -q 'rt_engine2d_simd_blend_row_u32'
}

binary_runs_engine2d_simd_smoke() {
    [ -x "$1" ] || return 1
    mkdir -p "$CANDIDATE_SMOKE_DIR"
    _smoke_src="$CANDIDATE_SMOKE_DIR/engine2d_simd_candidate_smoke.spl"
    cat >"$_smoke_src" <<'SIMPLE'
use std.gpu.engine2d.simd_kernels.{engine2d_simd_fill_row_u32, engine2d_simd_copy_row_u32, engine2d_simd_blend_row_u32}
fn main() -> i64:
    val row = engine2d_simd_fill_row_u32(4, 0xFF010203u32)
    if row.len() != 4:
        return 1
    if row[0] != 0xFF010203u32:
        return 2
    val copy = engine2d_simd_copy_row_u32([0xFF000001u32, 0xFF000002u32, 0xFF000003u32, 0xFF000004u32])
    if copy.len() != 4:
        return 3
    if copy[2] != 0xFF000003u32:
        return 4
    val blend = engine2d_simd_blend_row_u32([0xFF102030u32, 0xFF203040u32], [0x00000000u32, 0xFFFFFFFFu32])
    if blend.len() != 2:
        return 5
    if blend[0] != 0xFF102030u32:
        return 6
    if blend[1] != 0xFFFFFFFFu32:
        return 7
    0
SIMPLE
    if command -v timeout >/dev/null 2>&1; then
        SIMPLE_LIB="${SIMPLE_LIB:-src}" timeout 20 "$1" run "$_smoke_src" --mode=interpreter --clean >"$CANDIDATE_SMOKE_DIR/$(basename "$1").stdout" 2>"$CANDIDATE_SMOKE_DIR/$(basename "$1").stderr"
    else
        SIMPLE_LIB="${SIMPLE_LIB:-src}" "$1" run "$_smoke_src" --mode=interpreter --clean >"$CANDIDATE_SMOKE_DIR/$(basename "$1").stdout" 2>"$CANDIDATE_SMOKE_DIR/$(basename "$1").stderr"
    fi
}

binary_has_runnable_engine2d_simd_externs() {
    binary_has_engine2d_simd_externs "$1" && binary_runs_engine2d_simd_smoke "$1"
}
if [ "$SIMPLE_BIN_PINNED" = "0" ] || [ "$SIMPLE_BIN" = "bin/simple" ]; then
    SIMPLE_BIN_SOURCE="missing-self-hosted-engine2d-simd"
    for _cand in \
        "$SIMPLE_BIN" \
        "release"/*/simple \
        "bin/release"/*/simple \
        "build/bootstrap/stage3/simple"; do
        if binary_has_runnable_engine2d_simd_externs "$_cand"; then
            SIMPLE_BIN="$_cand"
            SIMPLE_BIN_SOURCE="repo-self-hosted-engine2d-simd"
            break
        fi
    done
    if [ "$SIMPLE_BIN_SOURCE" = "missing-self-hosted-engine2d-simd" ] && [ "${ALLOW_PATH_SIMPLE_BIN:-0}" = "1" ] && command -v simple >/dev/null 2>&1; then
        _path_simple="$(command -v simple)"
        if binary_has_runnable_engine2d_simd_externs "$_path_simple"; then
            SIMPLE_BIN="$_path_simple"
            SIMPLE_BIN_SOURCE="path-opt-in-engine2d-simd"
        fi
    fi
else
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
fi
if [ "$SIMPLE_BIN" = "" ]; then
    SIMPLE_BIN_STATUS=missing
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS

TIMEOUT_SECS="${SIMPLE_CPU_SIMD_EVIDENCE_TIMEOUT_SECS:-120}"
WORK_DIR="${BUILD_DIR:-build/cpu-simd-engine2d-evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/cpu_simd_engine2d_evidence_$(date -u +%F).md}"
EVIDENCE_SRC="$WORK_DIR/cpu_simd_engine2d_evidence.spl"
EVIDENCE_LOG="$WORK_DIR/evidence.log"
ENV_PATH="$WORK_DIR/evidence.env"
FACADE_SPEC="test/01_unit/lib/gc_async_mut/gpu/engine2d/engine2d_facade_backend_mutation_spec.spl"
FACADE_LOG="$WORK_DIR/facade_draw_image_clip_mask.log"

have() {
    command -v "$1" >/dev/null 2>&1
}

run_with_timeout() {
    if have timeout; then
        timeout "$TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

value_of() {
    key="$1"
    sed -n "s/^${key}=//p" "$EVIDENCE_LOG" | tail -n 1
}

file_byte_count() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

file_cksum_value() {
    if [ -f "$1" ]; then
        cksum "$1" | sed 's/ .*//'
    else
        echo 0
    fi
}

emit_report() {
    EVIDENCE_LOG_BYTES="$(file_byte_count "$EVIDENCE_LOG")"
    EVIDENCE_LOG_CKSUM="$(file_cksum_value "$EVIDENCE_LOG")"
    mkdir -p "$(dirname -- "$REPORT_PATH")"
    {
        echo "cpu_simd_evidence_status=${STATUS:-unknown}"
        echo "cpu_simd_evidence_reason=${REASON:-unknown}"
        echo "cpu_simd_evidence_simple_bin=$SIMPLE_BIN"
        echo "cpu_simd_evidence_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "cpu_simd_evidence_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "cpu_simd_evidence_arch=${ARCH:-unknown}"
        echo "cpu_simd_evidence_feature=${FEATURE:-unknown}"
        echo "cpu_simd_evidence_level=${LEVEL:-unknown}"
        echo "cpu_simd_evidence_checksum=${CHECKSUM:-0}"
        echo "cpu_simd_evidence_native_simd_executed=${NATIVE_SIMD_EXECUTED:-unknown}"
        echo "cpu_simd_evidence_native_simd_bit_exact=${NATIVE_SIMD_BIT_EXACT:-unknown}"
        echo "cpu_simd_evidence_native_simd_hits=${NATIVE_SIMD_HITS:-0}"
        echo "cpu_simd_evidence_provider_hits=${REPORT_HITS:-0}"
        echo "cpu_simd_evidence_provider_changes=${REPORT_CHANGES:-0}"
        echo "cpu_simd_evidence_fill_expected_checksum=${FILL_EXPECTED:-0}"
        echo "cpu_simd_evidence_fill_actual_checksum=${FILL_ACTUAL:-0}"
        echo "cpu_simd_evidence_fill_mismatch_count=${FILL_MISMATCH:-}"
        echo "cpu_simd_evidence_copy_expected_checksum=${COPY_EXPECTED:-0}"
        echo "cpu_simd_evidence_copy_actual_checksum=${COPY_ACTUAL:-0}"
        echo "cpu_simd_evidence_copy_mismatch_count=${COPY_MISMATCH:-}"
        echo "cpu_simd_evidence_alpha_expected_checksum=${ALPHA_EXPECTED:-0}"
        echo "cpu_simd_evidence_alpha_actual_checksum=${ALPHA_ACTUAL:-0}"
        echo "cpu_simd_evidence_alpha_mismatch_count=${ALPHA_MISMATCH:-}"
        echo "cpu_simd_evidence_alpha_edge_expected_checksum=${ALPHA_EDGE_EXPECTED:-0}"
        echo "cpu_simd_evidence_alpha_edge_actual_checksum=${ALPHA_EDGE_ACTUAL:-0}"
        echo "cpu_simd_evidence_alpha_edge_mismatch_count=${ALPHA_EDGE_MISMATCH:-}"
        echo "cpu_simd_evidence_scroll_expected_checksum=${SCROLL_EXPECTED:-0}"
        echo "cpu_simd_evidence_scroll_actual_checksum=${SCROLL_ACTUAL:-0}"
        echo "cpu_simd_evidence_scroll_mismatch_count=${SCROLL_MISMATCH:-}"
        echo "cpu_simd_evidence_diagram_pixel_count=${DIAGRAM_PIXEL_COUNT:-0}"
        echo "cpu_simd_evidence_diagram_expected_checksum=${DIAGRAM_EXPECTED:-0}"
        echo "cpu_simd_evidence_diagram_actual_checksum=${DIAGRAM_ACTUAL:-0}"
        echo "cpu_simd_evidence_diagram_mismatch_count=${DIAGRAM_MISMATCH:-}"
        echo "cpu_simd_evidence_diagram_fill_hits=${DIAGRAM_FILL_HITS:-0}"
        echo "cpu_simd_evidence_diagram_copy_hits=${DIAGRAM_COPY_HITS:-0}"
        echo "cpu_simd_evidence_diagram_alpha_hits=${DIAGRAM_ALPHA_HITS:-0}"
        echo "cpu_simd_evidence_diagram_blit_hits=${DIAGRAM_BLIT_HITS:-0}"
        echo "cpu_simd_evidence_diagram_scroll_hits=${DIAGRAM_SCROLL_HITS:-0}"
        echo "cpu_simd_evidence_facade_draw_image_clip_mask_spec=$FACADE_SPEC"
        echo "cpu_simd_evidence_facade_draw_image_clip_mask_status=${FACADE_STATUS:-unknown}"
        echo "cpu_simd_evidence_facade_draw_image_clip_mask_examples=${FACADE_EXAMPLES:-0}"
        echo "cpu_simd_evidence_facade_draw_image_clip_mask_failures=${FACADE_FAILURES:-0}"
        echo "cpu_simd_evidence_cpu_simd_facade_draw_image_clip_mask_status=${FACADE_STATUS:-unknown}"
        echo "cpu_simd_evidence_policy=exact-bitmap-no-blur-no-tolerance"
        echo "cpu_simd_evidence_blur_or_tolerance_used=false"
        echo "cpu_simd_evidence_x86_status=${X86_STATUS:-unknown}"
        echo "cpu_simd_evidence_arm_status=${ARM_STATUS:-unknown}"
        echo "cpu_simd_evidence_riscv_status=${RISCV_STATUS:-unknown}"
        echo "cpu_simd_evidence_log=$EVIDENCE_LOG"
        echo "cpu_simd_evidence_log_bytes=$EVIDENCE_LOG_BYTES"
        echo "cpu_simd_evidence_log_cksum=$EVIDENCE_LOG_CKSUM"
    } >"$ENV_PATH"
    {
        echo "# CPU SIMD Engine2D Evidence"
        echo
        echo "- status: ${STATUS:-unknown}"
        echo "- reason: ${REASON:-unknown}"
        echo "- simple_bin: $SIMPLE_BIN"
        echo "- simple_bin_source: $SIMPLE_BIN_SOURCE"
        echo "- simple_bin_status: $SIMPLE_BIN_STATUS"
        echo "- arch: ${ARCH:-unknown}"
        echo "- feature: ${FEATURE:-unknown}"
        echo "- level: ${LEVEL:-unknown}"
        echo "- checksum: ${CHECKSUM:-0}"
        echo "- native_simd_executed: ${NATIVE_SIMD_EXECUTED:-unknown}"
        echo "- native_simd_bit_exact: ${NATIVE_SIMD_BIT_EXACT:-unknown}"
        echo "- native_simd_hits: ${NATIVE_SIMD_HITS:-0}"
        echo "- provider_hits: ${REPORT_HITS:-0}"
        echo "- provider_changes: ${REPORT_CHANGES:-0}"
        echo "- fill expected checksum: ${FILL_EXPECTED:-0}"
        echo "- fill actual checksum: ${FILL_ACTUAL:-0}"
        echo "- fill mismatch count: ${FILL_MISMATCH:-}"
        echo "- copy expected checksum: ${COPY_EXPECTED:-0}"
        echo "- copy actual checksum: ${COPY_ACTUAL:-0}"
        echo "- copy mismatch count: ${COPY_MISMATCH:-}"
        echo "- alpha expected checksum: ${ALPHA_EXPECTED:-0}"
        echo "- alpha actual checksum: ${ALPHA_ACTUAL:-0}"
        echo "- alpha mismatch count: ${ALPHA_MISMATCH:-}"
        echo "- alpha edge expected checksum: ${ALPHA_EDGE_EXPECTED:-0}"
        echo "- alpha edge actual checksum: ${ALPHA_EDGE_ACTUAL:-0}"
        echo "- alpha edge mismatch count: ${ALPHA_EDGE_MISMATCH:-}"
        echo "- scroll expected checksum: ${SCROLL_EXPECTED:-0}"
        echo "- scroll actual checksum: ${SCROLL_ACTUAL:-0}"
        echo "- scroll mismatch count: ${SCROLL_MISMATCH:-}"
        echo "- diagram pixel count: ${DIAGRAM_PIXEL_COUNT:-0}"
        echo "- diagram expected checksum: ${DIAGRAM_EXPECTED:-0}"
        echo "- diagram actual checksum: ${DIAGRAM_ACTUAL:-0}"
        echo "- diagram mismatch count: ${DIAGRAM_MISMATCH:-}"
        echo "- diagram fill hits: ${DIAGRAM_FILL_HITS:-0}"
        echo "- diagram copy hits: ${DIAGRAM_COPY_HITS:-0}"
        echo "- diagram alpha hits: ${DIAGRAM_ALPHA_HITS:-0}"
        echo "- diagram blit hits: ${DIAGRAM_BLIT_HITS:-0}"
        echo "- diagram scroll hits: ${DIAGRAM_SCROLL_HITS:-0}"
        echo "- facade draw_image clip/mask spec: $FACADE_SPEC"
        echo "- facade draw_image clip/mask status: ${FACADE_STATUS:-unknown}"
        echo "- facade draw_image clip/mask examples: ${FACADE_EXAMPLES:-0}"
        echo "- facade draw_image clip/mask failures: ${FACADE_FAILURES:-0}"
        echo "- cpu_simd facade draw_image clip/mask status: ${FACADE_STATUS:-unknown}"
        echo "- policy: exact bitmap, no blur, no tolerance"
        echo "- blur/tolerance used: false"
        echo "- x86_status: ${X86_STATUS:-unknown}"
        echo "- arm_status: ${ARM_STATUS:-unknown}"
        echo "- riscv_status: ${RISCV_STATUS:-unknown}"
        echo "- evidence_log: $EVIDENCE_LOG"
        echo "- evidence_log_bytes: $EVIDENCE_LOG_BYTES"
        echo "- evidence_log_cksum: $EVIDENCE_LOG_CKSUM"
        echo
        echo "## Raw Evidence"
        sed 's/^/- /' "$ENV_PATH"
        echo
        echo "## Evidence Log"
        sed 's/^/- /' "$EVIDENCE_LOG" 2>/dev/null || true
    } >"$REPORT_PATH"
}

mkdir -p "$WORK_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$EVIDENCE_LOG" "$ENV_PATH" "$REPORT_PATH"

echo "check=cpu_simd_engine2d_evidence"
echo "simple_bin=$SIMPLE_BIN"
echo "simple_bin_source=$SIMPLE_BIN_SOURCE"
echo "simple_bin_status=$SIMPLE_BIN_STATUS"
echo "timeout_secs=$TIMEOUT_SECS"

if [ "$SIMPLE_BIN_STATUS" = "forbidden" ]; then
    STATUS=fail
    REASON="simple-bin-forbidden"
    ARCH=unknown
    FEATURE=unknown
    LEVEL=unknown
    CHECKSUM=0
    REPORT_HITS=0
    X86_STATUS=unknown
    ARM_STATUS=unknown
    RISCV_STATUS=unknown
    emit_report
    echo "cpu_simd_evidence_status=$STATUS"
    echo "cpu_simd_evidence_reason=$REASON"
    echo "report_path=$REPORT_PATH"
    exit 1
fi

if [ ! -x "$SIMPLE_BIN" ] && [ "$SIMPLE_BIN_PINNED" = "1" ]; then
    STATUS=fail
    REASON="missing-simple-bin"
    ARCH=unknown
    FEATURE=unknown
    LEVEL=unknown
    CHECKSUM=0
    REPORT_HITS=0
    X86_STATUS=unknown
    ARM_STATUS=unknown
    RISCV_STATUS=unknown
    emit_report
    echo "cpu_simd_evidence_status=$STATUS"
    echo "cpu_simd_evidence_reason=$REASON"
    echo "report_path=$REPORT_PATH"
    exit 1
fi

if [ ! -x "$SIMPLE_BIN" ]; then
    echo "cpu_simd_evidence_status=skip"
    echo "cpu_simd_evidence_reason=engine2d-simd-capable-simple-bin-unavailable"
    echo "cpu_simd_evidence_simple_bin=$SIMPLE_BIN"
    echo "cpu_simd_evidence_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "cpu_simd_evidence_simple_bin_status=$SIMPLE_BIN_STATUS"
    mkdir -p "$WORK_DIR"
    {
        echo "cpu_simd_evidence_status=skip"
        echo "cpu_simd_evidence_reason=engine2d-simd-capable-simple-bin-unavailable"
        echo "cpu_simd_evidence_simple_bin=$SIMPLE_BIN"
        echo "cpu_simd_evidence_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "cpu_simd_evidence_simple_bin_status=$SIMPLE_BIN_STATUS"
    } >"$ENV_PATH"
    echo "cpu-simd-engine2d-evidence: skip (no Engine2D SIMD-capable Simple binary found)"
    exit 0
fi

# If no interpreter binary carries the Engine2D SIMD pixel-row externs yet, skip cleanly
# rather than hard-failing on "unknown extern function" — the kernels exist in
# source and need a bootstrap to reach the deployed binary.
if ! binary_has_engine2d_simd_externs "$SIMPLE_BIN"; then
    echo "cpu_simd_evidence_status=skip"
    echo "cpu_simd_evidence_reason=engine2d-simd-externs-not-in-binary-bootstrap-required"
    echo "cpu_simd_evidence_simple_bin=$SIMPLE_BIN"
    echo "cpu_simd_evidence_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "cpu_simd_evidence_simple_bin_status=$SIMPLE_BIN_STATUS"
    mkdir -p "$WORK_DIR"
    {
        echo "cpu_simd_evidence_status=skip"
        echo "cpu_simd_evidence_reason=engine2d-simd-externs-not-in-binary-bootstrap-required"
        echo "cpu_simd_evidence_simple_bin=$SIMPLE_BIN"
        echo "cpu_simd_evidence_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "cpu_simd_evidence_simple_bin_status=$SIMPLE_BIN_STATUS"
    } >"$ENV_PATH"
    echo "cpu-simd-engine2d-evidence: skip (Engine2D SIMD externs not in $SIMPLE_BIN; run bootstrap --deploy)"
    exit 0
fi

cat >"$EVIDENCE_SRC" <<'SIMPLE'
use std.gpu.engine2d.backend_probe.{StrictBackendFactory, backend_status_text}
use std.gpu.engine2d.rendering_opt_provider.{rendering_opt_report_from_simd}
use std.gpu.engine2d.simd_kernels.{cpu_simd_runtime_evidence, fill_span, copy_span, alpha_blend_span, simd_blit_rect, simd_scroll_region}
use std.gpu.engine2d.simd_provider.{reset_simd_hits, simd_hit_counts}

fn checksum_pixels(pixels: [u32]) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        sum = sum + pixels[i].to_i64() * ((i + 1) as i64)
        i = i + 1
    sum

fn mismatch_count(a: [u32], b: [u32]) -> i64:
    var mismatches: i64 = 0
    val max_len = if a.len() > b.len(): a.len() else: b.len()
    var i = 0
    while i < max_len:
        if i >= a.len() or i >= b.len() or a[i] != b[i]:
            mismatches = mismatches + 1
        i = i + 1
    mismatches

fn mismatch_summary(a: [u32], b: [u32]) -> text:
    var out = ""
    var shown: i64 = 0
    val max_len = if a.len() > b.len(): a.len() else: b.len()
    var i = 0
    while i < max_len and shown < 8:
        if i >= a.len() or i >= b.len() or a[i] != b[i]:
            out = out + "idx=" + i.to_text()
            if i < a.len():
                out = out + ":expected=" + a[i].to_text()
            if i < b.len():
                out = out + ":actual=" + b[i].to_text()
            out = out + ";"
            shown = shown + 1
        i = i + 1
    out

fn alpha_pixel(s: u32, d: u32) -> u32:
    val sa = (s >> 24) & 0xFF
    if sa == 255:
        return s
    if sa == 0:
        return d
    val inv_a = 255 - sa
    val dr = (d >> 16) & 0xFF
    val dg = (d >> 8) & 0xFF
    val db = d & 0xFF
    val sr = (s >> 16) & 0xFF
    val sg = (s >> 8) & 0xFF
    val sb = s & 0xFF
    val r = (sr * sa + dr * inv_a) / 255
    val g = (sg * sa + dg * inv_a) / 255
    val b = (sb * sa + db * inv_a) / 255
    (255 << 24) | (r << 16) | (g << 8) | b

fn scalar_fill(buf: any, offset: i64, count: i64, color: u32):
    var i: i64 = 0
    while i < count:
        buf[(offset + i).to_i32()] = color
        i = i + 1

fn scalar_copy(dst: any, dst_off: i64, src: [u32], src_off: i64, count: i64):
    var i: i64 = 0
    while i < count:
        dst[(dst_off + i).to_i32()] = src[(src_off + i).to_i32()]
        i = i + 1

fn scalar_alpha(dst: any, src: [u32], offset: i64, count: i64):
    var i: i64 = 0
    while i < count:
        val idx = (offset + i).to_i32()
        dst[idx] = alpha_pixel(src[idx], dst[idx])
        i = i + 1

fn scalar_blit_rect(dst: any, dst_stride: i64, dst_x: i64, dst_y: i64, src: [u32], src_stride: i64, src_x: i64, src_y: i64, w: i64, h: i64):
    var row: i64 = 0
    while row < h:
        scalar_copy(dst, (dst_y + row) * dst_stride + dst_x, src, (src_y + row) * src_stride + src_x, w)
        row = row + 1

fn scalar_scroll_region(buf: any, stride: i64, x: i64, y: i64, w: i64, h: i64, delta_y: i64):
    if w <= 0:
        return
    if h <= 0:
        return
    if delta_y == 0:
        return
    val abs_dy = if delta_y < 0: -delta_y else: delta_y
    val rows_to_copy = h - abs_dy
    if rows_to_copy <= 0:
        return
    if delta_y < 0:
        var row: i64 = 0
        while row < rows_to_copy:
            val dst_off = (y + row) * stride + x
            val src_off = (y + row + abs_dy) * stride + x
            var col: i64 = 0
            while col < w:
                buf[(dst_off + col).to_i32()] = buf[(src_off + col).to_i32()]
                col = col + 1
            row = row + 1
    else:
        var row: i64 = rows_to_copy - 1
        while row >= 0:
            val dst_off = (y + row + abs_dy) * stride + x
            val src_off = (y + row) * stride + x
            var col: i64 = 0
            while col < w:
                buf[(dst_off + col).to_i32()] = buf[(src_off + col).to_i32()]
                col = col + 1
            row = row - 1

fn draw_scalar_diagram(buf: any, tile: [u32], alpha_src: [u32]):
    val width: i64 = 16
    scalar_fill(buf, 0, 192, 0xFF101418u32)
    scalar_fill(buf, 1 * width + 1, 14, 0xFF2458A6u32)
    scalar_fill(buf, 3 * width + 2, 7, 0xFFE0A420u32)
    scalar_copy(buf, 9 * width + 1, tile, 4, 8)
    scalar_blit_rect(buf, width, 10, 4, tile, 4, 0, 0, 4, 4)
    var row: i64 = 0
    while row < 3:
        scalar_alpha(buf, alpha_src, (6 + row) * width + 3, 9)
        row = row + 1
    scalar_scroll_region(buf, width, 1, 2, 14, 5, 1)

fn draw_simd_diagram(buf: any, tile: [u32], alpha_src: [u32]):
    val width: i64 = 16
    fill_span(buf, 0, 192, 0xFF101418u32)
    fill_span(buf, 1 * width + 1, 14, 0xFF2458A6u32)
    fill_span(buf, 3 * width + 2, 7, 0xFFE0A420u32)
    copy_span(buf, 9 * width + 1, tile, 4, 8)
    simd_blit_rect(buf, width, 10, 4, tile, 4, 0, 0, 4, 4)
    var row: i64 = 0
    while row < 3:
        alpha_blend_span(buf, alpha_src, (6 + row) * width + 3, 9)
        row = row + 1
    simd_scroll_region(buf, width, 1, 2, 14, 5, 1)

fn main() -> i64:
    reset_simd_hits()
    val evidence = cpu_simd_runtime_evidence()
    val factory = StrictBackendFactory.strict()
    val general = factory.create_backend("cpu_simd")
    val x86 = factory.create_backend("cpu_simd_x86")
    val arm = factory.create_backend("cpu_simd_arm")
    val riscv = factory.create_backend("cpu_simd_riscv")

    var fill_actual: [u32] = [0; 16]
    var fill_expected: [u32] = [0xFF102030u32; 16]
    fill_span(fill_actual, 0, 16, 0xFF102030u32)

    var copy_actual: [u32] = [0; 16]
    var copy_expected: [u32] = [0; 16]
    val copy_src: [u32] = [0xFF000001u32, 0xFF000002u32, 0xFF000003u32, 0xFF000004u32, 0xFF000005u32, 0xFF000006u32, 0xFF000007u32, 0xFF000008u32, 0xFF000009u32, 0xFF00000Au32, 0xFF00000Bu32, 0xFF00000Cu32, 0xFF00000Du32, 0xFF00000Eu32, 0xFF00000Fu32, 0xFF000010u32]
    copy_span(copy_actual, 4, copy_src, 2, 8)
    var copy_i = 0
    while copy_i < 8:
        copy_expected[4 + copy_i] = copy_src[2 + copy_i]
        copy_i = copy_i + 1

    var alpha_actual: [u32] = [0xFF102030u32; 16]
    var alpha_expected: [u32] = [0xFF102030u32; 16]
    val alpha_src: [u32] = [0x804080C0u32; 16]
    alpha_blend_span(alpha_actual, alpha_src, 0, 16)
    var alpha_i = 0
    while alpha_i < 16:
        alpha_expected[alpha_i] = alpha_pixel(alpha_src[alpha_i], alpha_expected[alpha_i])
        alpha_i = alpha_i + 1

    var scroll_actual: [u32] = [0xFF000001u32, 0xFF000002u32, 0xFF000003u32, 0xFF000004u32, 0xFF000005u32, 0xFF000006u32, 0xFF000007u32, 0xFF000008u32, 0xFF000009u32, 0xFF00000Au32, 0xFF00000Bu32, 0xFF00000Cu32, 0xFF00000Du32, 0xFF00000Eu32, 0xFF00000Fu32, 0xFF000010u32]
    val scroll_expected: [u32] = [0xFF000001u32, 0xFF000002u32, 0xFF000003u32, 0xFF000004u32, 0xFF000001u32, 0xFF000002u32, 0xFF000003u32, 0xFF000004u32, 0xFF000005u32, 0xFF000006u32, 0xFF000007u32, 0xFF000008u32, 0xFF00000Du32, 0xFF00000Eu32, 0xFF00000Fu32, 0xFF000010u32]
    simd_scroll_region(scroll_actual, 4, 0, 0, 4, 3, 1)

    val diagram_tile: [u32] = [0xFF1A1A1Au32, 0xFF4FC3F7u32, 0xFFFF7043u32, 0xFF263238u32, 0xFF66BB6Au32, 0xFFFFD54Fu32, 0xFFAB47BCu32, 0xFF37474Fu32, 0xFF29B6F6u32, 0xFFEC407Au32, 0xFF9CCC65u32, 0xFF455A64u32, 0xFF78909Cu32, 0xFFFFA726u32, 0xFF26A69Au32, 0xFF546E7Au32]
    var diagram_alpha_src: [u32] = [0; 192]
    var alpha_row: i64 = 0
    while alpha_row < 3:
        var alpha_col: i64 = 0
        while alpha_col < 9:
            val idx = ((6 + alpha_row) * 16 + 3 + alpha_col).to_i32()
            diagram_alpha_src[idx] = if (alpha_col % 2) == 0: 0x80FFFFFFu32 else: 0x804080C0u32
            alpha_col = alpha_col + 1
        alpha_row = alpha_row + 1

    var diagram_expected: [u32] = [0; 192]
    var diagram_actual: [u32] = [0; 192]
    draw_scalar_diagram(diagram_expected, diagram_tile, diagram_alpha_src)
    draw_simd_diagram(diagram_actual, diagram_tile, diagram_alpha_src)
    val counts = simd_hit_counts()
    val report = rendering_opt_report_from_simd(evidence.arch, evidence.feature)

    print("cpu_simd_arch=" + evidence.arch)
    print("cpu_simd_feature=" + evidence.feature)
    print("cpu_simd_level=" + evidence.level)
    print("cpu_simd_executed_all=" + evidence.executed_all().to_text())
    print("cpu_simd_checksum=" + evidence.checksum.to_text())
    print("cpu_simd_hit_summary=" + evidence.hit_summary)
    print("cpu_simd_native_simd_executed=" + evidence.native_simd_executed.to_text())
    print("cpu_simd_native_simd_bit_exact=" + evidence.native_simd_bit_exact.to_text())
    print("cpu_simd_native_simd_hits=" + evidence.native_simd_hits.to_text())
    print("cpu_simd_native_simd_reason=" + evidence.reason)
    print("cpu_simd_provider_hits=" + report.total_hits.to_text())
    print("cpu_simd_provider_changes=" + report.total_changes.to_text())
    print("cpu_simd_fill_expected_checksum=" + checksum_pixels(fill_expected).to_text())
    print("cpu_simd_fill_actual_checksum=" + checksum_pixels(fill_actual).to_text())
    print("cpu_simd_fill_mismatch_count=" + mismatch_count(fill_expected, fill_actual).to_text())
    print("cpu_simd_copy_expected_checksum=" + checksum_pixels(copy_expected).to_text())
    print("cpu_simd_copy_actual_checksum=" + checksum_pixels(copy_actual).to_text())
    print("cpu_simd_copy_mismatch_count=" + mismatch_count(copy_expected, copy_actual).to_text())
    print("cpu_simd_alpha_expected_checksum=" + checksum_pixels(alpha_expected).to_text())
    print("cpu_simd_alpha_actual_checksum=" + checksum_pixels(alpha_actual).to_text())
    print("cpu_simd_alpha_mismatch_count=" + mismatch_count(alpha_expected, alpha_actual).to_text())

    var alpha_edge_actual: [u32] = [0xFF001122u32, 0xFF223344u32, 0xFF445566u32, 0xFF667788u32, 0xFF8899AAu32, 0xFFAABBCCu32, 0xFFCCDDEEu32, 0xFF102030u32]
    var alpha_edge_expected: [u32] = [0xFF001122u32, 0xFF223344u32, 0xFF445566u32, 0xFF667788u32, 0xFF8899AAu32, 0xFFAABBCCu32, 0xFFCCDDEEu32, 0xFF102030u32]
    val alpha_edge_src: [u32] = [0x00000000u32, 0x01010203u32, 0x7F4080C0u32, 0x804080C0u32, 0xFEF0A020u32, 0xFFFFFFFFu32, 0x00ABCDEFu32, 0xFF010203u32]
    alpha_blend_span(alpha_edge_actual, alpha_edge_src, 0, alpha_edge_actual.len().to_i64())
    var alpha_edge_i = 0
    while alpha_edge_i < alpha_edge_expected.len():
        alpha_edge_expected[alpha_edge_i] = alpha_pixel(alpha_edge_src[alpha_edge_i], alpha_edge_expected[alpha_edge_i])
        alpha_edge_i = alpha_edge_i + 1
    print("cpu_simd_alpha_edge_expected_checksum=" + checksum_pixels(alpha_edge_expected).to_text())
    print("cpu_simd_alpha_edge_actual_checksum=" + checksum_pixels(alpha_edge_actual).to_text())
    print("cpu_simd_alpha_edge_mismatch_count=" + mismatch_count(alpha_edge_expected, alpha_edge_actual).to_text())

    print("cpu_simd_scroll_expected_checksum=" + checksum_pixels(scroll_expected).to_text())
    print("cpu_simd_scroll_actual_checksum=" + checksum_pixels(scroll_actual).to_text())
    print("cpu_simd_scroll_mismatch_count=" + mismatch_count(scroll_expected, scroll_actual).to_text())
    print("cpu_simd_diagram_pixel_count=" + diagram_actual.len().to_text())
    print("cpu_simd_diagram_expected_checksum=" + checksum_pixels(diagram_expected).to_text())
    print("cpu_simd_diagram_actual_checksum=" + checksum_pixels(diagram_actual).to_text())
    print("cpu_simd_diagram_mismatch_count=" + mismatch_count(diagram_expected, diagram_actual).to_text())
    print("cpu_simd_diagram_mismatch_summary=" + mismatch_summary(diagram_expected, diagram_actual))
    print("cpu_simd_diagram_fill_hits=" + counts.fill_hits.to_text())
    print("cpu_simd_diagram_copy_hits=" + counts.copy_hits.to_text())
    print("cpu_simd_diagram_alpha_hits=" + counts.alpha_hits.to_text())
    print("cpu_simd_diagram_blit_hits=" + counts.blit_hits.to_text())
    print("cpu_simd_diagram_scroll_hits=" + counts.scroll_hits.to_text())
    print("cpu_simd_policy=exact-bitmap-no-blur-no-tolerance")
    print("cpu_simd_blur_or_tolerance_used=false")
    print("cpu_simd_probe_status=" + backend_status_text(general.status))
    print("cpu_simd_x86_status=" + backend_status_text(x86.status))
    print("cpu_simd_arm_status=" + backend_status_text(arm.status))
    print("cpu_simd_riscv_status=" + backend_status_text(riscv.status))
    print("cpu_simd_x86_diag=" + x86.diagnostic_text())
    print("cpu_simd_arm_diag=" + arm.diagnostic_text())
    print("cpu_simd_riscv_diag=" + riscv.diagnostic_text())

    if not evidence.executed_all():
        print("overall=fail")
        return 1
    if evidence.checksum <= 0:
        print("overall=fail")
        return 1
    if report.total_hits < 10:
        print("overall=fail")
        return 1
    if counts.fill_hits <= 0 or counts.copy_hits <= 0 or counts.alpha_hits <= 0 or counts.blit_hits <= 0 or counts.scroll_hits <= 0:
        print("overall=fail")
        return 1
    if mismatch_count(fill_expected, fill_actual) != 0 or mismatch_count(copy_expected, copy_actual) != 0 or mismatch_count(alpha_expected, alpha_actual) != 0 or mismatch_count(alpha_edge_expected, alpha_edge_actual) != 0 or mismatch_count(scroll_expected, scroll_actual) != 0:
        print("overall=fail")
        return 1
    if diagram_actual.len() != 192 or mismatch_count(diagram_expected, diagram_actual) != 0:
        print("overall=fail")
        return 1
    # Genuine native-SIMD gate: the native kernels must stay bit-identical to
    # scalar, and on x86/aarch64 the vectorized row path must actually execute
    # (hit counter advanced). This rejects the historical scalar false-green
    # where the path merely reported has_neon without running NEON.
    if not evidence.native_simd_bit_exact:
        print("overall=fail")
        return 1
    if (evidence.arch == "aarch64" or evidence.arch == "x86_64") and not evidence.native_simd_executed:
        print("overall=fail")
        return 1
    print("overall=pass")
    return 0
SIMPLE

echo "evidence_source=$EVIDENCE_SRC"

set +e
# SIMPLE_EXECUTION_MODE=interpret is required: without it the default loader
# resolves std.* relative to the evidence source dir, imports silently become
# stubs, and every SIMD probe reports Unavailable (same failure class as the
# engine3d readback gate).
SIMPLE_EXECUTION_MODE="${SIMPLE_EXECUTION_MODE:-interpret}" SIMPLE_LIB="${SIMPLE_LIB:-src}" run_with_timeout "$SIMPLE_BIN" run "$EVIDENCE_SRC" --mode=interpreter --clean >"$EVIDENCE_LOG" 2>&1
EVIDENCE_CODE=$?
SIMPLE_LIB="${SIMPLE_LIB:-src}" run_with_timeout "$SIMPLE_BIN" test --no-session-daemon "$FACADE_SPEC" --mode=interpreter --clean >"$FACADE_LOG" 2>&1
FACADE_CODE=$?
set -e

cat "$EVIDENCE_LOG"
echo "evidence_exit_code=$EVIDENCE_CODE"
echo "facade_draw_image_clip_mask_exit_code=$FACADE_CODE"

ARCH="$(value_of cpu_simd_arch)"
FEATURE="$(value_of cpu_simd_feature)"
LEVEL="$(value_of cpu_simd_level)"
EXECUTED_ALL="$(value_of cpu_simd_executed_all)"
CHECKSUM="$(value_of cpu_simd_checksum)"
REPORT_HITS="$(value_of cpu_simd_provider_hits)"
REPORT_CHANGES="$(value_of cpu_simd_provider_changes)"
FILL_EXPECTED="$(value_of cpu_simd_fill_expected_checksum)"
FILL_ACTUAL="$(value_of cpu_simd_fill_actual_checksum)"
FILL_MISMATCH="$(value_of cpu_simd_fill_mismatch_count)"
COPY_EXPECTED="$(value_of cpu_simd_copy_expected_checksum)"
COPY_ACTUAL="$(value_of cpu_simd_copy_actual_checksum)"
COPY_MISMATCH="$(value_of cpu_simd_copy_mismatch_count)"
ALPHA_EXPECTED="$(value_of cpu_simd_alpha_expected_checksum)"
ALPHA_ACTUAL="$(value_of cpu_simd_alpha_actual_checksum)"
ALPHA_MISMATCH="$(value_of cpu_simd_alpha_mismatch_count)"
ALPHA_EDGE_EXPECTED="$(value_of cpu_simd_alpha_edge_expected_checksum)"
ALPHA_EDGE_ACTUAL="$(value_of cpu_simd_alpha_edge_actual_checksum)"
ALPHA_EDGE_MISMATCH="$(value_of cpu_simd_alpha_edge_mismatch_count)"
SCROLL_EXPECTED="$(value_of cpu_simd_scroll_expected_checksum)"
SCROLL_ACTUAL="$(value_of cpu_simd_scroll_actual_checksum)"
SCROLL_MISMATCH="$(value_of cpu_simd_scroll_mismatch_count)"
DIAGRAM_PIXEL_COUNT="$(value_of cpu_simd_diagram_pixel_count)"
DIAGRAM_EXPECTED="$(value_of cpu_simd_diagram_expected_checksum)"
DIAGRAM_ACTUAL="$(value_of cpu_simd_diagram_actual_checksum)"
DIAGRAM_MISMATCH="$(value_of cpu_simd_diagram_mismatch_count)"
DIAGRAM_FILL_HITS="$(value_of cpu_simd_diagram_fill_hits)"
DIAGRAM_COPY_HITS="$(value_of cpu_simd_diagram_copy_hits)"
DIAGRAM_ALPHA_HITS="$(value_of cpu_simd_diagram_alpha_hits)"
DIAGRAM_BLIT_HITS="$(value_of cpu_simd_diagram_blit_hits)"
DIAGRAM_SCROLL_HITS="$(value_of cpu_simd_diagram_scroll_hits)"
GENERAL_STATUS="$(value_of cpu_simd_probe_status)"
X86_STATUS="$(value_of cpu_simd_x86_status)"
ARM_STATUS="$(value_of cpu_simd_arm_status)"
RISCV_STATUS="$(value_of cpu_simd_riscv_status)"
OVERALL="$(value_of overall)"
NATIVE_SIMD_EXECUTED="$(value_of cpu_simd_native_simd_executed)"
NATIVE_SIMD_BIT_EXACT="$(value_of cpu_simd_native_simd_bit_exact)"
NATIVE_SIMD_HITS="$(value_of cpu_simd_native_simd_hits)"
FACADE_EXAMPLES="$(grep -o 'Passed: *[0-9][0-9]*' "$FACADE_LOG" | sed 's/.*: *//' | tail -n 1)"
FACADE_FAILURES="$(grep -o 'Failed: *[0-9][0-9]*' "$FACADE_LOG" | sed 's/.*: *//' | tail -n 1)"
FACADE_EXAMPLES="${FACADE_EXAMPLES:-0}"
FACADE_FAILURES="${FACADE_FAILURES:-0}"
FACADE_STATUS=fail
if [ "$FACADE_CODE" -eq 0 ] && [ "$FACADE_FAILURES" = "0" ]; then
    FACADE_STATUS=pass
fi

STATUS=pass
REASON=runtime-evidence-verified

if [ "$EVIDENCE_CODE" -ne 0 ] || [ "$OVERALL" != "pass" ]; then
    STATUS=fail
    REASON=simple-evidence-program-failed
elif [ "$FACADE_STATUS" != "pass" ]; then
    STATUS=fail
    REASON=facade-draw-image-clip-mask-spec-failed
elif [ "$EXECUTED_ALL" != "true" ]; then
    STATUS=fail
    REASON=simd-kernels-not-executed
elif [ "$FILL_MISMATCH" != "0" ] || [ "$COPY_MISMATCH" != "0" ] || [ "$ALPHA_MISMATCH" != "0" ] || [ "$ALPHA_EDGE_MISMATCH" != "0" ] || [ "$SCROLL_MISMATCH" != "0" ]; then
    STATUS=fail
    REASON=simd-output-mismatch
elif [ "$DIAGRAM_PIXEL_COUNT" = "" ] || [ "$DIAGRAM_MISMATCH" = "" ] || [ "$DIAGRAM_FILL_HITS" = "" ] || [ "$DIAGRAM_COPY_HITS" = "" ] || [ "$DIAGRAM_ALPHA_HITS" = "" ] || [ "$DIAGRAM_BLIT_HITS" = "" ] || [ "$DIAGRAM_SCROLL_HITS" = "" ]; then
    STATUS=fail
    REASON=simd-diagram-evidence-missing
elif [ "$DIAGRAM_PIXEL_COUNT" != "192" ] || [ "$DIAGRAM_MISMATCH" != "0" ]; then
    STATUS=fail
    REASON=simd-diagram-bitmap-mismatch
elif [ "$DIAGRAM_FILL_HITS" -le 0 ] || [ "$DIAGRAM_COPY_HITS" -le 0 ] || [ "$DIAGRAM_ALPHA_HITS" -le 0 ] || [ "$DIAGRAM_BLIT_HITS" -le 0 ] || [ "$DIAGRAM_SCROLL_HITS" -le 0 ]; then
    STATUS=fail
    REASON=simd-diagram-missing-kernel-hit
elif [ "$GENERAL_STATUS" != "Initialized" ]; then
    STATUS=fail
    REASON=general-simd-probe-not-initialized
elif [ "$ARCH" = "x86_64" ] && [ "$FEATURE" != "scalar" ] && [ "$X86_STATUS" != "Initialized" ]; then
    STATUS=fail
    REASON=x86-simd-feature-without-initialized-probe
elif [ "$ARCH" = "aarch64" ] && [ "$FEATURE" != "scalar" ] && [ "$ARM_STATUS" != "Initialized" ]; then
    STATUS=fail
    REASON=arm-simd-feature-without-initialized-probe
elif [ "$ARCH" = "riscv64" ] && [ "$FEATURE" != "scalar" ] && [ "$RISCV_STATUS" != "Initialized" ]; then
    STATUS=fail
    REASON=riscv-simd-feature-without-initialized-probe
elif [ "$ARCH" != "x86_64" ] && [ "$X86_STATUS" = "Initialized" ]; then
    STATUS=fail
    REASON=x86-probe-initialized-on-non-x86-runtime
elif [ "$ARCH" != "aarch64" ] && [ "$ARM_STATUS" = "Initialized" ]; then
    STATUS=fail
    REASON=arm-probe-initialized-on-non-arm-runtime
elif [ "$ARCH" != "riscv64" ] && [ "$RISCV_STATUS" = "Initialized" ]; then
    STATUS=fail
    REASON=riscv-probe-initialized-on-non-riscv-runtime
fi

emit_report

echo "cpu_simd_evidence_status=$STATUS"
echo "cpu_simd_evidence_reason=$REASON"
echo "cpu_simd_evidence_arch=$ARCH"
echo "cpu_simd_evidence_feature=$FEATURE"
echo "cpu_simd_evidence_level=$LEVEL"
echo "cpu_simd_evidence_checksum=$CHECKSUM"
echo "cpu_simd_evidence_provider_hits=$REPORT_HITS"
echo "cpu_simd_evidence_provider_changes=$REPORT_CHANGES"
echo "cpu_simd_evidence_fill_mismatch_count=$FILL_MISMATCH"
echo "cpu_simd_evidence_copy_mismatch_count=$COPY_MISMATCH"
echo "cpu_simd_evidence_alpha_mismatch_count=$ALPHA_MISMATCH"
echo "cpu_simd_evidence_alpha_edge_mismatch_count=$ALPHA_EDGE_MISMATCH"
echo "cpu_simd_evidence_scroll_mismatch_count=$SCROLL_MISMATCH"
echo "cpu_simd_evidence_diagram_pixel_count=$DIAGRAM_PIXEL_COUNT"
echo "cpu_simd_evidence_diagram_expected_checksum=$DIAGRAM_EXPECTED"
echo "cpu_simd_evidence_diagram_actual_checksum=$DIAGRAM_ACTUAL"
echo "cpu_simd_evidence_diagram_mismatch_count=$DIAGRAM_MISMATCH"
echo "cpu_simd_evidence_diagram_fill_hits=$DIAGRAM_FILL_HITS"
echo "cpu_simd_evidence_diagram_copy_hits=$DIAGRAM_COPY_HITS"
echo "cpu_simd_evidence_diagram_alpha_hits=$DIAGRAM_ALPHA_HITS"
echo "cpu_simd_evidence_diagram_blit_hits=$DIAGRAM_BLIT_HITS"
echo "cpu_simd_evidence_diagram_scroll_hits=$DIAGRAM_SCROLL_HITS"
echo "cpu_simd_evidence_policy=exact-bitmap-no-blur-no-tolerance"
echo "cpu_simd_evidence_blur_or_tolerance_used=false"
echo "cpu_simd_evidence_general_status=$GENERAL_STATUS"
echo "cpu_simd_evidence_x86_status=$X86_STATUS"
echo "cpu_simd_evidence_arm_status=$ARM_STATUS"
echo "cpu_simd_evidence_riscv_status=$RISCV_STATUS"
echo "cpu_simd_evidence_log_bytes=$(file_byte_count "$EVIDENCE_LOG")"
echo "cpu_simd_evidence_log_cksum=$(file_cksum_value "$EVIDENCE_LOG")"
echo "report_path=$REPORT_PATH"

if [ "$STATUS" != "pass" ]; then
    exit 1
fi
