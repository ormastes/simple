#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/gui_color_image_pipeline_8k_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/gui_color_image_pipeline_8k_evidence_$(date -u +%F).md}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass
if [ -z "${SIMPLE_BIN+x}" ]; then
    SIMPLE_BIN=""
    SIMPLE_BIN_SOURCE=auto-self-hosted
    for _cand in bin/simple ./bin/simple release/*/simple bin/release/*/simple build/bootstrap/stage3/simple; do
        if [ -x "$_cand" ]; then
            SIMPLE_BIN="$_cand"
            break
        fi
    done
fi

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|./src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [ -z "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS
EVIDENCE_SRC="$BUILD_DIR/gui_color_image_pipeline_8k_evidence.spl"
EVIDENCE_OUT="$BUILD_DIR/evidence.env"
SPEC_OUT="$BUILD_DIR/spec.out"
FOCUSED_SPECS="
test/01_unit/lib/common/color/color_lab_xyz_spec.spl
"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$EVIDENCE_SRC" "$EVIDENCE_OUT" "$SPEC_OUT" "$REPORT_PATH"

write_early_report() {
    {
        echo "# GUI Color/Image Pipeline 8K Evidence"
        echo
        echo "- status: fail"
        echo "- reason: $1"
        echo "- simple_bin: $SIMPLE_BIN"
        echo "- simple_bin_source: $SIMPLE_BIN_SOURCE"
        echo "- simple_bin_status: $SIMPLE_BIN_STATUS"
        echo
        echo "## Evidence"
        echo
        sed 's/^/- /' "$EVIDENCE_OUT"
    } >"$REPORT_PATH"
}

fail_early() {
    {
        echo "gui_color_image_pipeline_8k_status=fail"
        echo "gui_color_image_pipeline_8k_reason=$1"
        echo "gui_color_image_pipeline_8k_simple_bin=$SIMPLE_BIN"
        echo "gui_color_image_pipeline_8k_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "gui_color_image_pipeline_8k_simple_bin_status=$SIMPLE_BIN_STATUS"
    } >"$EVIDENCE_OUT"
    write_early_report "$1"
    cat "$EVIDENCE_OUT"
    exit 1
}

if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    fail_early "simple-bin-$SIMPLE_BIN_STATUS"
fi

missing_specs=""
for spec_path in $FOCUSED_SPECS; do
    if [ ! -f "$spec_path" ]; then
        missing_specs="${missing_specs}${missing_specs:+,}$spec_path"
    fi
done
if [ -n "$missing_specs" ]; then
    {
        echo "gui_color_image_pipeline_8k_status=fail"
        echo "gui_color_image_pipeline_8k_reason=missing-focused-spec"
        echo "gui_color_image_pipeline_8k_missing_focused_specs=$missing_specs"
        echo "gui_color_image_pipeline_8k_simple_bin=$SIMPLE_BIN"
        echo "gui_color_image_pipeline_8k_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "gui_color_image_pipeline_8k_simple_bin_status=$SIMPLE_BIN_STATUS"
    } >"$EVIDENCE_OUT"
    write_early_report "missing-focused-spec"
    cat "$EVIDENCE_OUT"
    exit 1
fi

cat >"$EVIDENCE_SRC" <<'SIMPLE'
use std.common.color.lab_xyz.{
    cie_xyz_d65_to_srgb_packed_argb, cie_xyz_d65_white,
    lab_to_cie_xyz, packed_argb_to_lab_d65, plan_8k_uhd_surface,
    plan_packed_8k_surface, srgb_to_lab_d65
}
use std.common.image.image_info.{
    apply_detected_image_color_profile_to_rgba, detect_image_info,
    image_info_unknown
}

fn main() -> i64:
    val plan = plan_8k_uhd_surface()
    val same_plan = plan_packed_8k_surface(7680, 4320)
    val red_lab = srgb_to_lab_d65(255, 0, 0)
    val red_xyz = lab_to_cie_xyz(red_lab, cie_xyz_d65_white())
    val red_argb = cie_xyz_d65_to_srgb_packed_argb(red_xyz, 255)
    val packed_lab = packed_argb_to_lab_d65(red_argb)
    val alpha = (red_argb / 16777216) & 255
    val red = (red_argb / 65536) & 255
    val green = (red_argb / 256) & 255
    val blue = red_argb & 255
    val roundtrip_ok = alpha == 255 and red >= 253 and green <= 2 and blue <= 2
    val unknown = detect_image_info("not-an-image")
    val explicit_unknown = image_info_unknown("manual-unknown")
    val transform = apply_detected_image_color_profile_to_rgba("not-an-image", [red_argb])
    val image_fail_closed_ok = unknown.reason == "unknown-signature" and
        not unknown.supported and
        explicit_unknown.reason == "manual-unknown" and
        transform.supported and
        not transform.applied and
        transform.reason == "no-profile" and
        transform.pixels[0] == red_argb
    val status = plan.width == 7680 and
        plan.height == 4320 and
        plan.bytes_per_pixel == 4 and
        plan.framebuffer_bytes == 132710400 and
        plan.lab_xyz_full_frame_bytes == 796262400 and
        same_plan.framebuffer_bytes == plan.framebuffer_bytes and
        plan.uses_packed_hot_path and
        not plan.initializes_color_transforms and
        not plan.initializes_tiff_decoder and
        not plan.initializes_jpegxl_decoder and
        plan.default_semantic_space == "cielab" and
        plan.connection_space == "cie_xyz" and
        roundtrip_ok and
        packed_lab.white_point == "D65" and
        image_fail_closed_ok

    print("gui_color_image_pipeline_8k_status=" + (if status: "pass" else: "fail"))
    print("gui_color_image_pipeline_8k_reason=" + (if status: "pass" else: "surface-plan-mismatch"))
    print("gui_color_image_pipeline_8k_width=" + plan.width.to_text())
    print("gui_color_image_pipeline_8k_height=" + plan.height.to_text())
    print("gui_color_image_pipeline_8k_bytes_per_pixel=" + plan.bytes_per_pixel.to_text())
    print("gui_color_image_pipeline_8k_framebuffer_bytes=" + plan.framebuffer_bytes.to_text())
    print("gui_color_image_pipeline_8k_lab_xyz_full_frame_bytes=" + plan.lab_xyz_full_frame_bytes.to_text())
    print("gui_color_image_pipeline_8k_uses_packed_hot_path=" + plan.uses_packed_hot_path.to_text())
    print("gui_color_image_pipeline_8k_initializes_color_transforms=" + plan.initializes_color_transforms.to_text())
    print("gui_color_image_pipeline_8k_initializes_tiff_decoder=" + plan.initializes_tiff_decoder.to_text())
    print("gui_color_image_pipeline_8k_initializes_jpegxl_decoder=" + plan.initializes_jpegxl_decoder.to_text())
    print("gui_color_image_pipeline_8k_default_semantic_space=" + plan.default_semantic_space)
    print("gui_color_image_pipeline_8k_connection_space=" + plan.connection_space)
    print("gui_color_image_pipeline_8k_same_plan_framebuffer_bytes=" + same_plan.framebuffer_bytes.to_text())
    print("gui_color_image_pipeline_8k_red_argb=" + red_argb.to_text())
    print("gui_color_image_pipeline_8k_red_roundtrip_ok=" + roundtrip_ok.to_text())
    print("gui_color_image_pipeline_8k_lab_white_point=" + packed_lab.white_point)
    print("gui_color_image_pipeline_8k_unknown_image_reason=" + unknown.reason)
    print("gui_color_image_pipeline_8k_unknown_image_supported=" + unknown.supported.to_text())
    print("gui_color_image_pipeline_8k_color_transform_reason=" + transform.reason)
    print("gui_color_image_pipeline_8k_color_transform_applied=" + transform.applied.to_text())
    print("gui_color_image_pipeline_8k_image_fail_closed_ok=" + image_fail_closed_ok.to_text())
    return if status: 0 else: 1
SIMPLE

SIMPLE_EXECUTION_MODE=interpret SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" run "$EVIDENCE_SRC" --mode=interpreter --clean >"$EVIDENCE_OUT"
{
    echo "gui_color_image_pipeline_8k_simple_bin=$SIMPLE_BIN"
    echo "gui_color_image_pipeline_8k_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "gui_color_image_pipeline_8k_simple_bin_status=$SIMPLE_BIN_STATUS"
    echo "gui_color_image_pipeline_8k_simple_execution_mode=interpret"
} >>"$EVIDENCE_OUT"
spec_code=0
for spec_path in $FOCUSED_SPECS; do
    {
        echo "spec_path=$spec_path"
        SIMPLE_EXECUTION_MODE=interpret SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" test "$spec_path" --mode=interpreter --clean
        code=$?
        echo "spec_exit_code=$code"
        if [ "$code" -ne 0 ]; then
            spec_code="$code"
        fi
    } >>"$SPEC_OUT" 2>&1
done

if [ "$spec_code" -ne 0 ]; then
    cat "$SPEC_OUT"
    exit "$spec_code"
fi

status="$(grep '^gui_color_image_pipeline_8k_status=' "$EVIDENCE_OUT" | cut -d= -f2)"
reason="$(grep '^gui_color_image_pipeline_8k_reason=' "$EVIDENCE_OUT" | cut -d= -f2)"
width="$(grep '^gui_color_image_pipeline_8k_width=' "$EVIDENCE_OUT" | cut -d= -f2)"
height="$(grep '^gui_color_image_pipeline_8k_height=' "$EVIDENCE_OUT" | cut -d= -f2)"
framebuffer_bytes="$(grep '^gui_color_image_pipeline_8k_framebuffer_bytes=' "$EVIDENCE_OUT" | cut -d= -f2)"
lab_xyz_bytes="$(grep '^gui_color_image_pipeline_8k_lab_xyz_full_frame_bytes=' "$EVIDENCE_OUT" | cut -d= -f2)"
packed="$(grep '^gui_color_image_pipeline_8k_uses_packed_hot_path=' "$EVIDENCE_OUT" | cut -d= -f2)"
default_space="$(grep '^gui_color_image_pipeline_8k_default_semantic_space=' "$EVIDENCE_OUT" | cut -d= -f2)"
connection_space="$(grep '^gui_color_image_pipeline_8k_connection_space=' "$EVIDENCE_OUT" | cut -d= -f2)"
red_roundtrip="$(grep '^gui_color_image_pipeline_8k_red_roundtrip_ok=' "$EVIDENCE_OUT" | cut -d= -f2)"
image_fail_closed="$(grep '^gui_color_image_pipeline_8k_image_fail_closed_ok=' "$EVIDENCE_OUT" | cut -d= -f2)"

{
    echo "# GUI Color/Image Pipeline 8K Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- simple_bin: $SIMPLE_BIN"
    echo "- simple_bin_source: $SIMPLE_BIN_SOURCE"
    echo "- simple_bin_status: $SIMPLE_BIN_STATUS"
    echo "- surface: ${width}x${height} BGRA8"
    echo "- framebuffer_bytes: $framebuffer_bytes"
    echo "- lab_xyz_full_frame_bytes: $lab_xyz_bytes"
    echo "- packed_hot_path: $packed"
    echo "- default_semantic_space: $default_space"
    echo "- connection_space: $connection_space"
    echo "- lazy_startup: color transforms, TIFF decoder, and JPEG XL decoder are not initialized by the 8K surface plan"
    echo "- red_lab_xyz_argb_roundtrip: $red_roundtrip"
    echo "- image_metadata_fail_closed: $image_fail_closed"
    echo "- pure_simple_tiff_pixels: legacy browser raster spec path is no longer present in this tree; current gate covers lightweight image metadata fail-closed routing only"
    echo "- pure_simple_jpegxl_stage: legacy browser JPEG XL spec path is no longer present in this tree; full JPEG XL pixel decode remains a follow-up"
    echo
    echo "## Evidence"
    echo
    sed 's/^/- /' "$EVIDENCE_OUT"
    echo
    echo "## Focused Specs"
    echo
    sed 's/^/    /' "$SPEC_OUT"
} >"$REPORT_PATH"

cat "$EVIDENCE_OUT"

if [ "$status" != "pass" ]; then
    exit 1
fi
