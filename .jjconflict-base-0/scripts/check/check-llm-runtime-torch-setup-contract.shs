#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_runtime_torch_setup_contract}"
PROBE_BUILD_DIR="$BUILD_DIR/probe"
PROBE_REPORT="$BUILD_DIR/llm_runtime_torch_setup_contract_probe_report.md"
OUT_ENV="$BUILD_DIR/evidence.env"
PROBE_ENV="$PROBE_BUILD_DIR/evidence.env"
PROBE_STDOUT="$BUILD_DIR/probe_stdout.log"
mkdir -p "$BUILD_DIR"
rm -f "$OUT_ENV" "$PROBE_REPORT" "$PROBE_STDOUT"

failures=""
checked_count=0

add_failure() {
    if [ -z "$failures" ]; then
        failures="$1"
    else
        failures="$failures|$1"
    fi
}

env_value() {
    key="$1"
    if [ -f "$PROBE_ENV" ]; then
        sed -n "s/^${key}=//p" "$PROBE_ENV" | tail -n 1
    fi
}

require_env_key() {
    key="$1"
    checked_count=$((checked_count + 1))
    value="$(env_value "$key")"
    if [ -z "$value" ]; then
        add_failure "missing_env:$key"
    fi
}

require_positive_int_key() {
    key="$1"
    checked_count=$((checked_count + 1))
    value="$(env_value "$key")"
    case "$value" in
        ''|*[!0-9]*)
            add_failure "not_numeric:$key"
            ;;
        0)
            add_failure "not_positive:$key"
            ;;
    esac
}

require_report_key() {
    key="$1"
    checked_count=$((checked_count + 1))
    if ! rg -q "^- ${key}: \`.+" "$PROBE_REPORT"; then
        add_failure "missing_report:$key"
    fi
}

if BUILD_DIR="$PROBE_BUILD_DIR" REPORT_PATH="$PROBE_REPORT" sh scripts/check/check-llm-runtime-torch-cuda-optimizer-probe.shs >"$PROBE_STDOUT" 2>&1; then
    probe_exit=0
else
    probe_exit=$?
fi

if [ ! -s "$PROBE_ENV" ]; then
    add_failure "missing_probe_env"
else
    for key in \
        torch_cuda_optimizer_probe_python_torch_module_status \
        torch_cuda_optimizer_probe_python_torch_cuda_available \
        torch_cuda_optimizer_probe_python_torch_cuda_device_count \
        torch_cuda_optimizer_probe_python_torch_library_dir \
        torch_cuda_optimizer_probe_python_torch_libtorch_bundle_status \
        torch_cuda_optimizer_probe_python_torch_cuda_library_bundle_status \
        torch_cuda_optimizer_probe_python_torch_env_sha256 \
        torch_cuda_optimizer_probe_system_libtorch_status \
        torch_cuda_optimizer_probe_system_libtorch_probe_log_sha256 \
        torch_cuda_optimizer_probe_libtorch_env_status \
        torch_cuda_optimizer_probe_scilib_torch_root_status \
        torch_cuda_optimizer_probe_simple_sffi_path_status \
        torch_cuda_optimizer_probe_simple_sffi_libtorch_bridge_status \
        torch_cuda_optimizer_probe_ld_library_path_libtorch_status \
        torch_cuda_optimizer_probe_simple_runtime_torch_link_status \
        torch_cuda_optimizer_probe_surface_manifest_sha256 \
        torch_cuda_optimizer_probe_next_action
    do
        require_env_key "$key"
    done
    require_positive_int_key torch_cuda_optimizer_probe_surface_manifest_count
fi

if [ ! -s "$PROBE_REPORT" ]; then
    add_failure "missing_probe_report"
else
    for key in \
        python_torch_module_status \
        python_torch_cuda_available \
        python_torch_cuda_device_count \
        python_torch_library_dir \
        python_torch_libtorch_bundle_status \
        python_torch_cuda_library_bundle_status \
        system_libtorch_status \
        libtorch_env_status \
        scilib_torch_root_status \
        simple_sffi_path_status \
        simple_sffi_libtorch_bridge_status \
        ld_library_path_libtorch_status \
        simple_runtime_torch_link_status \
        surface_manifest_sha256 \
        next_action
    do
        require_report_key "$key"
    done
fi

if [ -z "$failures" ]; then
    status="pass"
    reason="torch_setup_diagnostics_present"
else
    status="fail"
    reason="$failures"
fi

{
    printf '%s\n' "llm_runtime_torch_setup_contract_status=$status"
    printf '%s\n' "llm_runtime_torch_setup_contract_reason=$reason"
    printf '%s\n' "llm_runtime_torch_setup_contract_checked_count=$checked_count"
    printf '%s\n' "llm_runtime_torch_setup_contract_probe_exit=$probe_exit"
    printf '%s\n' "llm_runtime_torch_setup_contract_probe_env=$PROBE_ENV"
    printf '%s\n' "llm_runtime_torch_setup_contract_probe_report=$PROBE_REPORT"
    printf '%s\n' "llm_runtime_torch_setup_contract_probe_stdout=$PROBE_STDOUT"
} >"$OUT_ENV"

if [ "$status" = "pass" ]; then
    printf '%s\n' "STATUS: PASS llm-runtime-torch-setup-contract checked_count=$checked_count"
    exit 0
fi

printf '%s\n' "STATUS: FAIL llm-runtime-torch-setup-contract reason=$reason"
exit 1
