#!/bin/sh
set -eu

file_matrix="doc/03_plan/trace/llm_caret_claude_cli_full_parity_file_matrix.tsv"
symbol_matrix="doc/03_plan/trace/llm_caret_claude_cli_full_parity_symbol_matrix.tsv"

if [ ! -f "$file_matrix" ] || [ ! -f "$symbol_matrix" ]; then
  echo "missing_matrix=true"
  echo "STATUS: FAIL llm-caret-full-parity-implementation"
  exit 1
fi

file_status=0
class_status=0

awk -F '\t' '
  NR == 1 { next }
  {
    total++
    target = $5
    min_loc = $6 + 0
    source_loc = $2 + 0
    target_loc = 0
    if ((getline target_loc < target) >= 0) {
      close(target)
      cmd = "wc -l < \"" target "\""
      cmd | getline target_loc
      close(cmd)
      exists++
    } else {
      missing++
      if (missing <= 10) {
        print "missing_file=" $1 " target=" target " source_loc=" source_loc
      }
    }
    if (target_loc + 0 >= min_loc) ge100++
    if ((target_loc + 0) * 100 >= source_loc * 80) ge80++
  }
  END {
    print "file_rows=" total + 0
    print "target_files_exist=" exists + 0
    print "target_files_missing=" missing + 0
    print "target_loc_ge_required=" ge100 + 0
    print "target_loc_ge_80pct_source=" ge80 + 0
    print "target_loc_lt_80pct_source=" (total - ge80)
    if (missing || ge100 < total || ge80 < total) exit 1
  }
' "$file_matrix" || file_status=$?

awk -F '\t' '
  NR == 1 { next }
  $3 == "class" {
    total++
    target = $6
    if ((getline line < target) >= 0) {
      close(target)
      exists++
    } else {
      missing++
      if (missing <= 10) print "missing_class=" $1 ":" $2 " " $4 " target=" target
    }
  }
  END {
    print "class_rows=" total + 0
    print "class_target_files_exist=" exists + 0
    print "class_target_files_missing=" missing + 0
    if (missing) exit 1
  }
' "$symbol_matrix" || class_status=$?

if [ "$file_status" -ne 0 ] || [ "$class_status" -ne 0 ]; then
  echo "STATUS: FAIL llm-caret-full-parity-implementation"
  exit 1
fi

echo "STATUS: PASS llm-caret-full-parity-implementation"
