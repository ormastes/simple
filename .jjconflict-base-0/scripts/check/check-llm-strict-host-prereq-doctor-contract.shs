#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_strict_host_prereq_doctor_contract}"
DOCTOR_BUILD_DIR="$BUILD_DIR/doctor"
DOCTOR_REPORT="$BUILD_DIR/llm_strict_host_prereq_doctor_contract_report.md"
OUT_ENV="$BUILD_DIR/evidence.env"
DOCTOR_ENV="$DOCTOR_BUILD_DIR/evidence.env"
DOCTOR_STDOUT="$BUILD_DIR/doctor_stdout.log"
mkdir -p "$BUILD_DIR"
rm -f "$OUT_ENV" "$DOCTOR_REPORT" "$DOCTOR_STDOUT"

failures=""
checked_count=0

add_failure() {
    if [ -z "$failures" ]; then
        failures="$1"
    else
        failures="$failures|$1"
    fi
}

require_env_key() {
    key="$1"
    checked_count=$((checked_count + 1))
    if ! rg -q "^${key}=.+" "$DOCTOR_ENV"; then
        add_failure "missing_env:$key"
    fi
}

require_report_key() {
    key="$1"
    checked_count=$((checked_count + 1))
    if ! rg -q "^- ${key}: \`.+" "$DOCTOR_REPORT"; then
        add_failure "missing_report:$key"
    fi
}

if BUILD_DIR="$DOCTOR_BUILD_DIR" REPORT_PATH="$DOCTOR_REPORT" sh scripts/check/check-llm-strict-host-prereq-doctor.shs >"$DOCTOR_STDOUT" 2>&1; then
    doctor_exit=0
else
    doctor_exit=$?
    add_failure "doctor_exit:$doctor_exit"
fi

if [ ! -s "$DOCTOR_ENV" ]; then
    add_failure "missing_doctor_env"
else
    for key in \
        llm_strict_host_prereq_doctor_dashboard_next_action \
        llm_strict_host_prereq_doctor_vllm_next_action \
        llm_strict_host_prereq_doctor_svllm_next_action \
        llm_strict_host_prereq_doctor_torch_next_action \
        llm_strict_host_prereq_doctor_finetune_next_action
    do
        require_env_key "$key"
    done
fi

if [ ! -s "$DOCTOR_REPORT" ]; then
    add_failure "missing_doctor_report"
else
    for key in \
        dashboard_next_action \
        vllm_next_action \
        svllm_next_action \
        torch_next_action \
        finetune_next_action
    do
        require_report_key "$key"
    done
fi

if [ -z "$failures" ]; then
    status="pass"
    reason="prereq_doctor_next_actions_present"
else
    status="fail"
    reason="$failures"
fi

{
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_status=$status"
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_reason=$reason"
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_checked_count=$checked_count"
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_doctor_exit=$doctor_exit"
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_doctor_env=$DOCTOR_ENV"
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_doctor_report=$DOCTOR_REPORT"
    printf '%s\n' "llm_strict_host_prereq_doctor_contract_doctor_stdout=$DOCTOR_STDOUT"
} >"$OUT_ENV"

if [ "$status" = "pass" ]; then
    printf '%s\n' "STATUS: PASS llm-strict-host-prereq-doctor-contract checked_count=$checked_count"
    exit 0
fi

printf '%s\n' "STATUS: FAIL llm-strict-host-prereq-doctor-contract reason=$reason"
exit 1
