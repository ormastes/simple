#!/bin/sh
set -eu

ELECTRON_BITMAP_SCENE="${ELECTRON_BITMAP_SCENE:-simple-web-layout-commandbar-taskbar-card}"
BUILD_DIR="${BUILD_DIR:-build/electron_simple_web_layout_commandbar_taskbar_card_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/electron_simple_web_layout_commandbar_taskbar_card_bitmap_evidence_$(date -u +%F).md}"
export ELECTRON_BITMAP_SCENE BUILD_DIR REPORT_PATH

exec sh scripts/check-electron-simple-web-layout-bitmap-evidence.shs
