# Validate interface-cache startup contract without loading full module bodies.

use std.nogc_sync_mut.io_runtime.{env_get, file_read, get_args}

fn field_value(raw: text, key: text) -> text:
    val marker = key + ":"
    val marker_pos = raw.find(marker)
    if marker_pos < 0:
        return ""
    var i = marker_pos + marker.len()
    while i < raw.len() and (raw.char_at(i) == " " or raw.char_at(i) == "\t" or raw.char_at(i) == "\n" or raw.char_at(i) == "\r"):
        i = i + 1
    if i < raw.len() and raw.char_at(i) == "\"":
        i = i + 1
        val quoted_start = i
        while i < raw.len() and raw.char_at(i) != "\"":
            i = i + 1
        return raw.substring(quoted_start, i)
    val bare_start = i
    while i < raw.len():
        val ch = raw.char_at(i)
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            break
        i = i + 1
    raw.substring(bare_start, i)

fn interface_cache_valid(cache_path: text, actual_mtime: text) -> bool:
    val cache = file_read(cache_path)
    if cache == "":
        return false
    if not cache.contains("interface_only: true"):
        return false
    if cache.contains("body_text:") or cache.contains("FULL_BODY_SENTINEL"):
        return false
    val cached_mtime = field_value(cache, "source_mtime")
    cached_mtime != "" and cached_mtime == actual_mtime

fn interface_cache_cached_mtime_text(cache_path: text) -> text:
    field_value(file_read(cache_path), "source_mtime")

fn arg_value(args: [text], key: text) -> text:
    var i: i64 = 0
    while i + 1 < args.len():
        if args[i] == key:
            return args[i + 1]
        i = i + 1
    ""

fn env_or_arg(args: [text], env_key: text, arg_key: text) -> text:
    val from_arg = arg_value(args, arg_key)
    if from_arg != "":
        return from_arg
    env_get(env_key) ?? ""

fn main() -> i32:
    val args = get_args()
    val source_path = env_or_arg(args, "SIMPLE_INTERFACE_CACHE_SOURCE", "--source")
    val valid_cache_path = env_or_arg(args, "SIMPLE_INTERFACE_CACHE_VALID", "--valid")
    val stale_cache_path = env_or_arg(args, "SIMPLE_INTERFACE_CACHE_STALE", "--stale")
    val body_cache_path = env_or_arg(args, "SIMPLE_INTERFACE_CACHE_BODY", "--body")
    val actual_mtime = env_or_arg(args, "SIMPLE_INTERFACE_CACHE_MTIME", "--actual-mtime")
    val valid_cache_ok = source_path != "" and actual_mtime != "" and interface_cache_valid(valid_cache_path, actual_mtime)
    val stale_cache_rejected = not interface_cache_valid(stale_cache_path, actual_mtime)
    val body_cache_rejected = not interface_cache_valid(body_cache_path, actual_mtime)
    print "interface_cache_valid=" + valid_cache_ok.to_string()
    print "interface_cache_cached_mtime_text=" + interface_cache_cached_mtime_text(valid_cache_path)
    print "interface_cache_actual_mtime=" + actual_mtime
    print "interface_cache_stale_rejected=" + stale_cache_rejected.to_string()
    print "interface_cache_body_rejected=" + body_cache_rejected.to_string()
    if valid_cache_ok and stale_cache_rejected and body_cache_rejected:
        return 0
    1
