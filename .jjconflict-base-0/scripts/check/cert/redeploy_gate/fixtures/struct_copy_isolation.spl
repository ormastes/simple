# redeploy-gate fixture: struct-copy-isolation (value semantics)
# Passing a STRUCT to a fn copies it (Value.Struct = value semantics); the
# callee's field mutation must NOT be visible to the caller. Contrast with
# class-in-array-mutation, where a CLASS mutates in place (reference semantics).
# A binary that passes structs by reference would print 999 (FAIL).
# EXPECT stdout: 5
struct Box:
    v: int

fn bump(mut b: Box):
    b.v = 999

fn main():
    val b = Box(v: 5)
    bump(b)
    print(b.v)
