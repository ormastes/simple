rtl_ready_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-ready-bin"
rtl_ready_sidecar="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-ready-sidecar.shs"
rtl_ready_sby_log="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-ready-sby-invocations.log"
mkdir -p "$rtl_ready_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_ready_bin/dirname"
printf '#!/bin/sh\nprintf "%%s %%s\\n" "$PWD" "$*" >> "$RTL_READY_SBY_LOG"\nexit 0\n' >"$rtl_ready_bin/sby"
for tool in yosys z3; do
    printf '#!/bin/sh\nexit 0\n' >"$rtl_ready_bin/$tool"
    chmod +x "$rtl_ready_bin/$tool"
done
chmod +x "$rtl_ready_bin/dirname" "$rtl_ready_bin/sby"
cat >"$rtl_ready_sidecar" <<'EOF'
#!/usr/bin/env sh
set -eu
for sby_file in \
    "$BUILD_ROOT/default/rv32/rtl/simple_rv32gc_core.sby" \
    "$BUILD_ROOT/default/rv64/rtl/simple_rv64gc_core.sby" \
    "$BUILD_ROOT/mlk/rv32/rtl/simple_rv32gc_core.sby" \
    "$BUILD_ROOT/mlk/rv64/rtl/simple_rv64gc_core.sby"
do
    mkdir -p "$(dirname "$sby_file")"
    sby_base="$(basename "$sby_file" .sby)"
    printf '[options]\nmode prove\n[engines]\nsmtbmc\n[script]\nprep -top %s_formal\n' "$sby_base" >"$sby_file"
done
EOF
chmod +x "$rtl_ready_sidecar"
: >"$rtl_ready_sby_log"
PATH="$rtl_ready_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_ready_sidecar" BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-ready-build" RTL_READY_SBY_LOG="$rtl_ready_sby_log" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-ready.out 2>/tmp/simpleos-formal-rtl-ready.err
grep -Fq "STATUS: PASS riscv-rtl-sby-proof" /tmp/simpleos-formal-rtl-ready.out || {
    echo "FAIL: RISC-V SBY proof fake ready stack missing pass status" >&2
    exit 1
}
for expected_sby in \
    "default/rv32/rtl -f simple_rv32gc_core.sby" \
    "default/rv64/rtl -f simple_rv64gc_core.sby" \
    "mlk/rv32/rtl -f simple_rv32gc_core.sby" \
    "mlk/rv64/rtl -f simple_rv64gc_core.sby"
do
    grep -Fq "$expected_sby" "$rtl_ready_sby_log" || {
        echo "FAIL: RISC-V SBY proof fake ready stack skipped $expected_sby" >&2
        exit 1
    }
done

