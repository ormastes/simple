#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
SETUP="$ROOT_DIR/scripts/setup/setup-simpleos-formal-env.shs"
PREREQ="$ROOT_DIR/scripts/check/check-simpleos-mission-critical-prereqs.shs"
RELEASE="$ROOT_DIR/scripts/check/check-simpleos-mission-critical-release.shs"
RTL_PROOF="$ROOT_DIR/scripts/check/check-riscv-rtl-sby-proof.shs"
MATRIX="$ROOT_DIR/scripts/check/check-simpleos-hardening-evidence-matrix.shs"

print_out="$(sh "$SETUP" --print-install)"
printf '%s\n' "$print_out" | grep -Fq "sudo apt-get install yosys symbiyosys boolector z3" || {
    echo "FAIL: setup helper missing package install guidance" >&2
    exit 1
}
printf '%s\n' "$print_out" | grep -Fq "scripts/check/check-simpleos-mission-critical-release.shs" || {
    echo "FAIL: setup helper missing release rerun guidance" >&2
    exit 1
}

if sh "$SETUP" --check >/tmp/simpleos-formal-setup-check.out 2>/tmp/simpleos-formal-setup-check.err; then
    grep -Fq "STATUS: PASS simpleos-mission-critical-prereqs" /tmp/simpleos-formal-setup-check.out || {
        echo "FAIL: setup --check passed without prereq PASS status" >&2
        exit 1
    }
else
    grep -Fq "simpleos_mission_critical_prereqs_status=blocked" /tmp/simpleos-formal-setup-check.out || {
        echo "FAIL: setup --check failed without blocked prereq status" >&2
        exit 1
    }
fi
expected_prereq_status="$(sed -n 's/^simpleos_mission_critical_prereqs_status=//p' /tmp/simpleos-formal-setup-check.out | tail -n 1)"
expected_prereq_missing="$(sed -n 's/^simpleos_mission_critical_prereqs_missing=//p' /tmp/simpleos-formal-setup-check.out | tail -n 1)"
expected_prereq_next_action="$(sed -n 's/^simpleos_mission_critical_prereqs_next_action=//p' /tmp/simpleos-formal-setup-check.out | tail -n 1)"
expected_prereq_status="${expected_prereq_status:-missing}"
expected_prereq_missing="${expected_prereq_missing:-missing}"
expected_prereq_next_action="${expected_prereq_next_action:-missing}"

grep -Fq "scripts/setup/setup-simpleos-formal-env.shs --print-install" "$PREREQ" || {
    echo "FAIL: prereq doctor missing setup helper next action" >&2
    exit 1
}

fake_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-bin"
mkdir -p "$fake_bin"
for tool in sby yosys boolector; do
    printf '#!/usr/bin/env sh\nexit 0\n' >"$fake_bin/$tool"
    chmod +x "$fake_bin/$tool"
done
PATH="$fake_bin:$PATH" sh "$PREREQ" >/tmp/simpleos-formal-prereq-ready.out 2>/tmp/simpleos-formal-prereq-ready.err
grep -Fq "simpleos_mission_critical_prereqs_status=ready" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing ready status" >&2
    exit 1
}
grep -Fq "STATUS: PASS simpleos-mission-critical-prereqs" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing pass status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=none" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing none blocker" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_next_action=none" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing none next action" >&2
    exit 1
}

z3_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/z3-bin"
mkdir -p "$z3_bin"
for tool in sby yosys z3; do
    : >"$z3_bin/$tool"
    chmod +x "$z3_bin/$tool"
done
PATH="$z3_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-z3.out 2>/tmp/simpleos-formal-prereq-z3.err
grep -Fq "simpleos_mission_critical_prereqs_status=ready" /tmp/simpleos-formal-prereq-z3.out || {
    echo "FAIL: prereq doctor fake z3 stack missing ready status" >&2
    exit 1
}
grep -Fq "STATUS: PASS simpleos-mission-critical-prereqs" /tmp/simpleos-formal-prereq-z3.out || {
    echo "FAIL: prereq doctor fake z3 stack missing pass status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=none" /tmp/simpleos-formal-prereq-z3.out || {
    echo "FAIL: prereq doctor fake z3 stack missing none blocker" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_next_action=none" /tmp/simpleos-formal-prereq-z3.out || {
    echo "FAIL: prereq doctor fake z3 stack missing none next action" >&2
    exit 1
}

missing_sby_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/missing-sby-bin"
mkdir -p "$missing_sby_bin"
for tool in yosys z3; do
    : >"$missing_sby_bin/$tool"
    chmod +x "$missing_sby_bin/$tool"
done
if PATH="$missing_sby_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-missing-sby.out 2>/tmp/simpleos-formal-prereq-missing-sby.err; then
    echo "FAIL: prereq doctor fake missing-sby stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_status=blocked" /tmp/simpleos-formal-prereq-missing-sby.out || {
    echo "FAIL: prereq doctor fake missing-sby stack missing blocked status" >&2
    exit 1
}
grep -Fq "STATUS: FAIL simpleos-mission-critical-prereqs missing=sby" /tmp/simpleos-formal-prereq-missing-sby.err || {
    echo "FAIL: prereq doctor fake missing-sby stack missing fail status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=sby" /tmp/simpleos-formal-prereq-missing-sby.out || {
    echo "FAIL: prereq doctor fake missing-sby stack missing sby blocker" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_next_action=run scripts/setup/setup-simpleos-formal-env.shs --print-install" /tmp/simpleos-formal-prereq-missing-sby.out || {
    echo "FAIL: prereq doctor fake missing-sby stack missing setup next action" >&2
    exit 1
}

missing_solver_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/missing-solver-bin"
mkdir -p "$missing_solver_bin"
for tool in sby yosys; do
    : >"$missing_solver_bin/$tool"
    chmod +x "$missing_solver_bin/$tool"
done
if PATH="$missing_solver_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-missing-solver.out 2>/tmp/simpleos-formal-prereq-missing-solver.err; then
    echo "FAIL: prereq doctor fake missing-solver stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_status=blocked" /tmp/simpleos-formal-prereq-missing-solver.out || {
    echo "FAIL: prereq doctor fake missing-solver stack missing blocked status" >&2
    exit 1
}
grep -Fq "STATUS: FAIL simpleos-mission-critical-prereqs missing=smt-solver" /tmp/simpleos-formal-prereq-missing-solver.err || {
    echo "FAIL: prereq doctor fake missing-solver stack missing fail status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=smt-solver" /tmp/simpleos-formal-prereq-missing-solver.out || {
    echo "FAIL: prereq doctor fake missing-solver stack missing smt blocker" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_next_action=run scripts/setup/setup-simpleos-formal-env.shs --print-install" /tmp/simpleos-formal-prereq-missing-solver.out || {
    echo "FAIL: prereq doctor fake missing-solver stack missing setup next action" >&2
    exit 1
}

broken_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/broken-bin"
mkdir -p "$broken_bin"
for tool in sby yosys z3; do
    printf '#!/bin/sh\nexit 17\n' >"$broken_bin/$tool"
    chmod +x "$broken_bin/$tool"
done
if PATH="$broken_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-broken.out 2>/tmp/simpleos-formal-prereq-broken.err; then
    echo "FAIL: prereq doctor fake broken stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_status=blocked" /tmp/simpleos-formal-prereq-broken.out || {
    echo "FAIL: prereq doctor fake broken stack missing blocked status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=sby,yosys,smt-solver" /tmp/simpleos-formal-prereq-broken.out || {
    echo "FAIL: prereq doctor fake broken stack missing full blocker list" >&2
    exit 1
}

partial_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/partial-bin"
mkdir -p "$partial_bin"
printf '#!/bin/sh\nexit 0\n' >"$partial_bin/sby"
chmod +x "$partial_bin/sby"
if PATH="$partial_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-partial.out 2>/tmp/simpleos-formal-prereq-partial.err; then
    echo "FAIL: prereq doctor fake partial stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_status=blocked" /tmp/simpleos-formal-prereq-partial.out || {
    echo "FAIL: prereq doctor fake partial stack missing blocked status" >&2
    exit 1
}
grep -Fq "STATUS: FAIL simpleos-mission-critical-prereqs missing=yosys,smt-solver" /tmp/simpleos-formal-prereq-partial.err || {
    echo "FAIL: prereq doctor fake partial stack missing fail status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=yosys,smt-solver" /tmp/simpleos-formal-prereq-partial.out || {
    echo "FAIL: prereq doctor fake partial stack missing yosys/smt blocker" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_next_action=run scripts/setup/setup-simpleos-formal-env.shs --print-install" /tmp/simpleos-formal-prereq-partial.out || {
    echo "FAIL: prereq doctor fake partial stack missing setup next action" >&2
    exit 1
}

rtl_partial_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-partial-bin"
mkdir -p "$rtl_partial_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_partial_bin/dirname"
printf '#!/bin/sh\nexit 0\n' >"$rtl_partial_bin/sby"
chmod +x "$rtl_partial_bin/dirname" "$rtl_partial_bin/sby"
fake_good_sidecar="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-good-sidecar.shs"
cat >"$fake_good_sidecar" <<'EOF'
#!/usr/bin/env sh
exit 0
EOF
chmod +x "$fake_good_sidecar"
if PATH="$rtl_partial_bin" SIDECAR_CONTRACT="$fake_good_sidecar" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-partial.out 2>/tmp/simpleos-formal-rtl-partial.err; then
    echo "FAIL: RISC-V SBY proof fake partial stack passed" >&2
    exit 1
fi
grep -Fq "reason=missing-formal-prereqs" /tmp/simpleos-formal-rtl-partial.err || {
    echo "FAIL: RISC-V SBY proof fake partial stack missing formal-prereq reason" >&2
    exit 1
}
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=missing-formal-prereqs" /tmp/simpleos-formal-rtl-partial.err || {
    echo "FAIL: RISC-V SBY proof fake partial stack missing fail status" >&2
    exit 1
}
grep -Fq "reason=missing-formal-prereqs missing=yosys,smt-solver" /tmp/simpleos-formal-rtl-partial.err || {
    echo "FAIL: RISC-V SBY proof fake partial stack missing yosys/smt blocker" >&2
    exit 1
}

fake_bad_sidecar="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-bad-sidecar.shs"
cat >"$fake_bad_sidecar" <<'EOF'
#!/usr/bin/env sh
echo "fake sidecar failed" >&2
exit 42
EOF
chmod +x "$fake_bad_sidecar"
if PATH="$rtl_partial_bin" SIDECAR_CONTRACT="$fake_bad_sidecar" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-sidecar-fail.out 2>/tmp/simpleos-formal-rtl-sidecar-fail.err; then
    echo "FAIL: RISC-V SBY proof fake sidecar failure passed" >&2
    exit 1
fi
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=sidecar-contract-failed" /tmp/simpleos-formal-rtl-sidecar-fail.err || {
    echo "FAIL: RISC-V SBY proof fake sidecar failure hidden by prereq blocker" >&2
    exit 1
}

if SIDECAR_CONTRACT="$fake_bad_sidecar" BUILD_DIR="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-sidecar-fail" \
    REPORT_PATH="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-sidecar-fail.md" \
    /bin/sh "$MATRIX" >/tmp/simpleos-formal-matrix-sidecar-fail.out 2>/tmp/simpleos-formal-matrix-sidecar-fail.err; then
    echo "FAIL: matrix accepted fake sidecar failure" >&2
    exit 1
fi
grep -Fq "simpleos_hardening_riscv_rtl_sby_proof_status=fail" /tmp/simpleos-formal-matrix-sidecar-fail.out || {
    echo "FAIL: matrix fake sidecar failure missing RTL proof fail status" >&2
    exit 1
}
grep -Fq "simpleos_hardening_riscv_rtl_sby_proof_blocker=sidecar-contract-failed" /tmp/simpleos-formal-matrix-sidecar-fail.out || {
    echo "FAIL: matrix fake sidecar failure hidden by prereq blocker" >&2
    exit 1
}
grep -Fq "simpleos_hardening_mission_critical_release_status=fail" /tmp/simpleos-formal-matrix-sidecar-fail.out || {
    echo "FAIL: matrix fake sidecar failure softened to blocked release status" >&2
    exit 1
}

rtl_missing_sby_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-sby-bin"
mkdir -p "$rtl_missing_sby_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_missing_sby_bin/dirname"
for tool in yosys z3; do
    : >"$rtl_missing_sby_bin/$tool"
    chmod +x "$rtl_missing_sby_bin/$tool"
done
chmod +x "$rtl_missing_sby_bin/dirname"
if PATH="$rtl_missing_sby_bin" SIDECAR_CONTRACT="$fake_good_sidecar" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-missing-sby.out 2>/tmp/simpleos-formal-rtl-missing-sby.err; then
    echo "FAIL: RISC-V SBY proof fake missing-sby stack passed" >&2
    exit 1
fi
grep -Fq "reason=missing-formal-prereqs" /tmp/simpleos-formal-rtl-missing-sby.err || {
    echo "FAIL: RISC-V SBY proof fake missing-sby stack missing formal-prereq reason" >&2
    exit 1
}
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=missing-formal-prereqs" /tmp/simpleos-formal-rtl-missing-sby.err || {
    echo "FAIL: RISC-V SBY proof fake missing-sby stack missing fail status" >&2
    exit 1
}
grep -Fq "reason=missing-formal-prereqs missing=sby" /tmp/simpleos-formal-rtl-missing-sby.err || {
    echo "FAIL: RISC-V SBY proof fake missing-sby stack missing sby blocker" >&2
    exit 1
}

rtl_missing_solver_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-solver-bin"
mkdir -p "$rtl_missing_solver_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_missing_solver_bin/dirname"
for tool in sby yosys; do
    : >"$rtl_missing_solver_bin/$tool"
    chmod +x "$rtl_missing_solver_bin/$tool"
done
chmod +x "$rtl_missing_solver_bin/dirname"
if PATH="$rtl_missing_solver_bin" SIDECAR_CONTRACT="$fake_good_sidecar" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-missing-solver.out 2>/tmp/simpleos-formal-rtl-missing-solver.err; then
    echo "FAIL: RISC-V SBY proof fake missing-solver stack passed" >&2
    exit 1
fi
grep -Fq "reason=missing-formal-prereqs" /tmp/simpleos-formal-rtl-missing-solver.err || {
    echo "FAIL: RISC-V SBY proof fake missing-solver stack missing formal-prereq reason" >&2
    exit 1
}
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=missing-formal-prereqs" /tmp/simpleos-formal-rtl-missing-solver.err || {
    echo "FAIL: RISC-V SBY proof fake missing-solver stack missing fail status" >&2
    exit 1
}
grep -Fq "reason=missing-formal-prereqs missing=smt-solver" /tmp/simpleos-formal-rtl-missing-solver.err || {
    echo "FAIL: RISC-V SBY proof fake missing-solver stack missing smt blocker" >&2
    exit 1
}

rtl_missing_artifact_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-artifact-bin"
rtl_missing_artifact_sidecar="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-artifact-sidecar.shs"
mkdir -p "$rtl_missing_artifact_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_missing_artifact_bin/dirname"
for tool in sby yosys z3; do
    printf '#!/bin/sh\nexit 0\n' >"$rtl_missing_artifact_bin/$tool"
    chmod +x "$rtl_missing_artifact_bin/$tool"
done
chmod +x "$rtl_missing_artifact_bin/dirname"
printf '#!/usr/bin/env sh\nset -eu\nmkdir -p "$BUILD_ROOT/default/rv32/rtl"\n' >"$rtl_missing_artifact_sidecar"
chmod +x "$rtl_missing_artifact_sidecar"
if PATH="$rtl_missing_artifact_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_missing_artifact_sidecar" BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-artifact-build" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-missing-artifact.out 2>/tmp/simpleos-formal-rtl-missing-artifact.err; then
    echo "FAIL: RISC-V SBY proof fake missing-artifact stack passed" >&2
    exit 1
fi
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=missing-artifact" /tmp/simpleos-formal-rtl-missing-artifact.err || {
    echo "FAIL: RISC-V SBY proof fake missing-artifact stack missing fail status" >&2
    exit 1
}
grep -Fq "artifact=$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-artifact-build/default/rv32/rtl/simple_rv32gc_core.sby" /tmp/simpleos-formal-rtl-missing-artifact.err || {
    echo "FAIL: RISC-V SBY proof fake missing-artifact stack missing artifact path" >&2
    exit 1
}

if PATH="$rtl_missing_artifact_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_missing_artifact_sidecar" \
    BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-artifact-build" \
    BUILD_DIR="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-missing-artifact" \
    REPORT_PATH="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-missing-artifact.md" \
    /bin/sh "$MATRIX" >/tmp/simpleos-formal-matrix-missing-artifact.out 2>/tmp/simpleos-formal-matrix-missing-artifact.err; then
    echo "FAIL: matrix accepted fake missing-artifact stack" >&2
    exit 1
fi
grep -Fq "simpleos_hardening_riscv_rtl_sby_proof_blocker=missing-artifact" /tmp/simpleos-formal-matrix-missing-artifact.out || {
    echo "FAIL: matrix fake missing-artifact stack collapsed into generic SBY failure" >&2
    exit 1
}
grep -Fq "simpleos_hardening_mission_critical_release_status=fail" /tmp/simpleos-formal-matrix-missing-artifact.out || {
    echo "FAIL: matrix fake missing-artifact stack softened to blocked release status" >&2
    exit 1
}

rtl_sby_run_fail_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-sby-run-fail-bin"
rtl_sby_run_fail_sidecar="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-sby-run-fail-sidecar.shs"
mkdir -p "$rtl_sby_run_fail_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_sby_run_fail_bin/dirname"
cat >"$rtl_sby_run_fail_bin/sby" <<'EOF'
#!/bin/sh
if [ "${1:-}" = "--version" ]; then
    exit 0
fi
exit 17
EOF
for tool in yosys z3; do
    printf '#!/bin/sh\nexit 0\n' >"$rtl_sby_run_fail_bin/$tool"
    chmod +x "$rtl_sby_run_fail_bin/$tool"
done
chmod +x "$rtl_sby_run_fail_bin/dirname" "$rtl_sby_run_fail_bin/sby"
cat >"$rtl_sby_run_fail_sidecar" <<'EOF'
#!/usr/bin/env sh
set -eu
for sby_file in \
    "$BUILD_ROOT/default/rv32/rtl/simple_rv32gc_core.sby" \
    "$BUILD_ROOT/default/rv64/rtl/simple_rv64gc_core.sby" \
    "$BUILD_ROOT/mlk/rv32/rtl/simple_rv32gc_core.sby" \
    "$BUILD_ROOT/mlk/rv64/rtl/simple_rv64gc_core.sby"
do
    mkdir -p "$(dirname "$sby_file")"
    : >"$sby_file"
done
EOF
chmod +x "$rtl_sby_run_fail_sidecar"
if PATH="$rtl_sby_run_fail_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_sby_run_fail_sidecar" BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-sby-run-fail-build" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-sby-run-fail.out 2>/tmp/simpleos-formal-rtl-sby-run-fail.err; then
    echo "FAIL: RISC-V SBY proof fake empty-artifact stack passed" >&2
    exit 1
fi
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=empty-artifact" /tmp/simpleos-formal-rtl-sby-run-fail.err || {
    echo "FAIL: RISC-V SBY proof fake empty-artifact stack missing fail status" >&2
    exit 1
}

if PATH="$rtl_sby_run_fail_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_sby_run_fail_sidecar" \
    BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-sby-run-fail-build" \
    BUILD_DIR="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-empty-artifact" \
    REPORT_PATH="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-empty-artifact.md" \
    /bin/sh "$MATRIX" >/tmp/simpleos-formal-matrix-empty-artifact.out 2>/tmp/simpleos-formal-matrix-empty-artifact.err; then
    echo "FAIL: matrix accepted fake empty-artifact stack" >&2
    exit 1
fi
grep -Fq "simpleos_hardening_riscv_rtl_sby_proof_blocker=empty-artifact" /tmp/simpleos-formal-matrix-empty-artifact.out || {
    echo "FAIL: matrix fake empty-artifact stack collapsed into generic failure" >&2
    exit 1
}

cat >"$rtl_sby_run_fail_sidecar" <<'EOF'
#!/usr/bin/env sh
set -eu
for sby_file in \
    "$BUILD_ROOT/default/rv32/rtl/simple_rv32gc_core.sby" \
    "$BUILD_ROOT/default/rv64/rtl/simple_rv64gc_core.sby" \
    "$BUILD_ROOT/mlk/rv32/rtl/simple_rv32gc_core.sby" \
    "$BUILD_ROOT/mlk/rv64/rtl/simple_rv64gc_core.sby"
do
    mkdir -p "$(dirname "$sby_file")"
    printf '[options]\nmode bmc\n' >"$sby_file"
done
EOF
chmod +x "$rtl_sby_run_fail_sidecar"
if PATH="$rtl_sby_run_fail_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_sby_run_fail_sidecar" BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-sby-run-fail-build" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-sby-run-fail.out 2>/tmp/simpleos-formal-rtl-sby-run-fail.err; then
    echo "FAIL: RISC-V SBY proof fake invalid-artifact stack passed" >&2
    exit 1
fi
grep -Fq "STATUS: FAIL riscv-rtl-sby-proof reason=invalid-artifact" /tmp/simpleos-formal-rtl-sby-run-fail.err || {
    echo "FAIL: RISC-V SBY proof fake invalid-artifact stack missing fail status" >&2
    exit 1
}
if PATH="$rtl_sby_run_fail_bin:/bin:/usr/bin" SIDECAR_CONTRACT="$rtl_sby_run_fail_sidecar" \
    BUILD_ROOT="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-sby-run-fail-build" \
    BUILD_DIR="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-invalid-artifact" \
