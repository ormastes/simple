#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_runtime_svllm_native_streaming}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_runtime_svllm_native_streaming_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
SURFACE_MANIFEST="$BUILD_DIR/svllm_native_streaming_surface_manifest.tsv"
LOCAL_BUILD_DIR="$BUILD_DIR/local_readiness"
LOCAL_REPORT="$BUILD_DIR/local_readiness_report.md"
LOCAL_ENV="$LOCAL_BUILD_DIR/evidence.env"
LOCAL_LOG="$BUILD_DIR/local_readiness.log"
CAPABILITY_PROBE_BUILD_DIR="$BUILD_DIR/capability_probe"
CAPABILITY_PROBE_REPORT="$BUILD_DIR/capability_probe_report.md"
LOCAL_SPEC_TIMEOUT_SECONDS="${SVLLM_READINESS_SPEC_TIMEOUT_SECONDS:-120}"
INPUT_READ_RANGE_STATUS="${SVLLM_NATIVE_READ_RANGE_STATUS:-unsupported}"
INPUT_PINNED_BUFFER_STATUS="${SVLLM_NATIVE_PINNED_BUFFER_STATUS:-unsupported}"
INPUT_DEVICE_STAGING_STATUS="${SVLLM_NATIVE_DEVICE_STAGING_STATUS:-unsupported}"
CAPABILITY_SOURCE="${SVLLM_NATIVE_CAPABILITY_SOURCE:-env_or_default}"
CAPABILITY_EVIDENCE_PATH="${SVLLM_NATIVE_CAPABILITY_EVIDENCE_PATH:-}"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$SURFACE_MANIFEST" "$LOCAL_REPORT" "$LOCAL_LOG" "$CAPABILITY_PROBE_REPORT"

status="fail"
reason="native_read_range_unavailable"
local_status="fail"
read_range_status="unsupported"
pinned_buffer_status="unsupported"
device_staging_status="unsupported"
local_read_bytes_status="unknown"
capability_provenance_status="missing"
capability_evidence_status="missing"
capability_evidence_sha256="missing"
capability_evidence_size="0"
capability_evidence_mtime="0"
capability_evidence_source="missing"
capability_evidence_schema_version="missing"
capability_probe_event="missing"
capability_probe_status="missing"
capability_probe_exit="missing"
capability_evidence_read_range_status="missing"
capability_evidence_pinned_buffer_status="missing"
capability_evidence_device_staging_status="missing"
capability_evidence_local_read_range_bytes_status="missing"
capability_evidence_local_read_range_bytes_reason="missing"
pass_integrity_status="not_applicable"
pass_integrity_reason="not_applicable"
blocked_gates="native_read_range"
primary_blocked_gate="native_read_range"
next_action="implement native read_range support, then rerun strict svLLM native streaming evidence"

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "0"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

normalize_capability_status() {
    case "$(printf '%s\n' "$1" | tr '[:upper:]' '[:lower:]')" in
        ready)
            printf '%s\n' "ready"
            ;;
        unsupported)
            printf '%s\n' "unsupported"
            ;;
        unavailable)
            printf '%s\n' "unavailable"
            ;;
        unchecked)
            printf '%s\n' "unchecked"
            ;;
        *)
            printf '%s\n' "unavailable"
            ;;
    esac
}

if BUILD_DIR="$LOCAL_BUILD_DIR" REPORT_PATH="$LOCAL_REPORT" SVLLM_READINESS_SPEC_TIMEOUT_SECONDS="$LOCAL_SPEC_TIMEOUT_SECONDS" sh scripts/check/check-llm-runtime-svllm-local-readiness.shs >"$LOCAL_LOG" 2>&1; then
    local_status="pass"
else
    local_status="fail"
    reason="local_readiness_failed"
fi
local_readiness_log_size="$(artifact_size "$LOCAL_LOG")"
local_readiness_log_sha256="$(artifact_sha256 "$LOCAL_LOG")"
local_readiness_env_size="$(artifact_size "$LOCAL_ENV")"
local_readiness_env_sha256="$(artifact_sha256 "$LOCAL_ENV")"
local_readiness_report_size="$(artifact_size "$LOCAL_REPORT")"
local_readiness_report_sha256="$(artifact_sha256 "$LOCAL_REPORT")"

read_range_status="$(normalize_capability_status "$INPUT_READ_RANGE_STATUS")"
pinned_buffer_status="$(normalize_capability_status "$INPUT_PINNED_BUFFER_STATUS")"
device_staging_status="$(normalize_capability_status "$INPUT_DEVICE_STAGING_STATUS")"
if grep -F 'expect(readiness.local_read_bytes_status).to_equal("ready")' test/01_unit/lib/gc_async_mut/svllm/model_loader_streaming_readiness_spec.spl >/dev/null 2>&1; then
    local_read_bytes_status="ready"
else
    local_read_bytes_status="unknown"
fi
case "$CAPABILITY_SOURCE" in
    ""|env_or_default|default|unknown)
        capability_provenance_status="missing"
        ;;
    *)
        capability_provenance_status="ready"
        ;;
esac
artifact_value() {
    key="$1"
    sed -n "s/^${key}=//p" "$CAPABILITY_EVIDENCE_PATH" 2>/dev/null | tail -n 1
}

if [ -z "$CAPABILITY_EVIDENCE_PATH" ] && [ "$CAPABILITY_SOURCE" = "env_or_default" ]; then
    if BUILD_DIR="$CAPABILITY_PROBE_BUILD_DIR" REPORT_PATH="$CAPABILITY_PROBE_REPORT" sh scripts/check/check-llm-runtime-svllm-native-capability-probe.shs >/dev/null 2>&1; then
        CAPABILITY_EVIDENCE_PATH="$CAPABILITY_PROBE_BUILD_DIR/evidence.env"
        CAPABILITY_SOURCE="$(sed -n 's/^svllm_native_capability_source=//p' "$CAPABILITY_EVIDENCE_PATH" | tail -n 1)"
        INPUT_READ_RANGE_STATUS="$(sed -n 's/^svllm_native_capability_read_range_status=//p' "$CAPABILITY_EVIDENCE_PATH" | tail -n 1)"
        INPUT_PINNED_BUFFER_STATUS="$(sed -n 's/^svllm_native_capability_pinned_buffer_status=//p' "$CAPABILITY_EVIDENCE_PATH" | tail -n 1)"
        INPUT_DEVICE_STAGING_STATUS="$(sed -n 's/^svllm_native_capability_device_staging_status=//p' "$CAPABILITY_EVIDENCE_PATH" | tail -n 1)"
        read_range_status="$(normalize_capability_status "$INPUT_READ_RANGE_STATUS")"
        pinned_buffer_status="$(normalize_capability_status "$INPUT_PINNED_BUFFER_STATUS")"
        device_staging_status="$(normalize_capability_status "$INPUT_DEVICE_STAGING_STATUS")"
        capability_provenance_status="ready"
    fi
fi

if [ -n "$CAPABILITY_EVIDENCE_PATH" ] && [ -s "$CAPABILITY_EVIDENCE_PATH" ]; then
    capability_evidence_size="$(artifact_size "$CAPABILITY_EVIDENCE_PATH")"
    capability_evidence_mtime="$(stat -c %Y "$CAPABILITY_EVIDENCE_PATH" 2>/dev/null || stat -f %m "$CAPABILITY_EVIDENCE_PATH" 2>/dev/null || printf 'unknown')"
    capability_evidence_sha256="$(artifact_sha256 "$CAPABILITY_EVIDENCE_PATH")"
    capability_evidence_source="$(artifact_value svllm_native_capability_source)"
    capability_evidence_schema_version="$(artifact_value svllm_native_capability_schema_version)"
    capability_probe_event="$(artifact_value svllm_native_capability_probe_event)"
    capability_probe_status="$(artifact_value svllm_native_capability_probe_status)"
    capability_probe_exit="$(artifact_value svllm_native_capability_probe_exit)"
    capability_evidence_read_range_status="$(normalize_capability_status "$(artifact_value svllm_native_capability_read_range_status)")"
    capability_evidence_pinned_buffer_status="$(normalize_capability_status "$(artifact_value svllm_native_capability_pinned_buffer_status)")"
    capability_evidence_device_staging_status="$(normalize_capability_status "$(artifact_value svllm_native_capability_device_staging_status)")"
    capability_evidence_local_read_range_bytes_status="$(normalize_capability_status "$(artifact_value svllm_native_capability_local_read_range_bytes_status)")"
    capability_evidence_local_read_range_bytes_reason="$(artifact_value svllm_native_capability_local_read_range_bytes_reason)"
    case "$CAPABILITY_SOURCE" in
        ""|env_or_default|default|unknown)
            if [ -n "$capability_evidence_source" ] && [ "$capability_evidence_source" != "missing" ]; then
                CAPABILITY_SOURCE="$capability_evidence_source"
                capability_provenance_status="ready"
            fi
            ;;
    esac
    if [ "$capability_evidence_schema_version" = "1" ] &&
       [ "$capability_evidence_source" = "$CAPABILITY_SOURCE" ] &&
       [ "$capability_probe_event" = "svllm_native_capability_probe" ] &&
       [ "$capability_probe_status" = "pass" ] &&
       [ "$capability_probe_exit" = "0" ] &&
       [ "$capability_evidence_read_range_status" = "$read_range_status" ] &&
       [ "$capability_evidence_pinned_buffer_status" = "$pinned_buffer_status" ] &&
       [ "$capability_evidence_device_staging_status" = "$device_staging_status" ]; then
        capability_evidence_status="ready"
    else
        capability_evidence_status="invalid"
    fi
fi

if [ "$local_status" = "pass" ] &&
   [ "$read_range_status" = "ready" ] &&
   [ "$pinned_buffer_status" = "ready" ] &&
   [ "$device_staging_status" = "ready" ] &&
   [ "$capability_provenance_status" = "ready" ] &&
   [ "$capability_evidence_status" = "ready" ]; then
    status="pass"
    reason="native_streaming_ready"
elif [ "$local_status" = "pass" ]; then
    if [ "$read_range_status" != "ready" ]; then
        reason="native_read_range_unavailable"
    elif [ "$pinned_buffer_status" != "ready" ]; then
        reason="pinned_buffer_registration_unavailable"
    elif [ "$device_staging_status" != "ready" ]; then
        reason="device_staging_unavailable"
    elif [ "$capability_evidence_status" != "ready" ]; then
        reason="capability_evidence_invalid"
    else
        reason="capability_provenance_missing"
    fi
fi

if [ "$status" = "pass" ]; then
    blocked_gates="none"
    primary_blocked_gate="n/a"
    next_action="strict svLLM native streaming evidence is ready"
elif [ "$local_status" != "pass" ]; then
    blocked_gates="local_readiness"
    primary_blocked_gate="local_readiness"
    next_action="fix local svLLM readiness failures, then rerun strict svLLM native streaming evidence"
else
    blocked_gates=""
    if [ "$read_range_status" != "ready" ]; then
        blocked_gates="native_read_range"
    fi
    if [ "$pinned_buffer_status" != "ready" ]; then
        if [ -z "$blocked_gates" ]; then blocked_gates="pinned_buffer"; else blocked_gates="$blocked_gates|pinned_buffer"; fi
    fi
    if [ "$device_staging_status" != "ready" ]; then
        if [ -z "$blocked_gates" ]; then blocked_gates="device_staging"; else blocked_gates="$blocked_gates|device_staging"; fi
    fi
    if [ "$capability_provenance_status" != "ready" ]; then
        if [ -z "$blocked_gates" ]; then blocked_gates="capability_provenance"; else blocked_gates="$blocked_gates|capability_provenance"; fi
    fi
    if [ "$capability_evidence_status" != "ready" ]; then
        if [ -z "$blocked_gates" ]; then blocked_gates="capability_evidence"; else blocked_gates="$blocked_gates|capability_evidence"; fi
    fi
    primary_blocked_gate="${blocked_gates%%|*}"
    case "$primary_blocked_gate" in
        native_read_range)
            next_action="implement native read_range support, then rerun strict svLLM native streaming evidence"
            ;;
        pinned_buffer)
            next_action="implement pinned-buffer registration, then rerun strict svLLM native streaming evidence"
            ;;
        device_staging)
            next_action="implement device staging, then rerun strict svLLM native streaming evidence"
            ;;
        capability_provenance)
            next_action="set SVLLM_NATIVE_CAPABILITY_SOURCE to the host probe or artifact that proved the ready native capabilities"
            ;;
        capability_evidence)
            next_action="set SVLLM_NATIVE_CAPABILITY_EVIDENCE_PATH to a structured probe artifact whose schema, event, exit, and reported native statuses match the ready capability claims"
            ;;
        *)
            next_action="collect strict svLLM native streaming evidence and resolve reported native blockers"
            ;;
    esac
fi

if [ "$status" = "pass" ]; then
    pass_integrity_status="pass"
    pass_integrity_reason="all_required_pass_fields_present"
fi

{
    for path in \
        scripts/check/check-llm-runtime-svllm-native-streaming-evidence.shs \
        scripts/check/check-llm-runtime-svllm-native-capability-probe.shs \
        scripts/check/check-llm-runtime-svllm-setup-contract.shs \
        scripts/check/check-llm-runtime-svllm-local-readiness.shs \
        src/lib/gc_async_mut/svllm/model_executor/model_loader/streaming_readiness.spl \
        src/lib/gc_async_mut/svllm/model_executor/model_loader/streamer.spl \
        src/lib/gc_async_mut/svllm/model_executor/model_loader/transport.spl \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_streaming_readiness_spec.spl \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_stream_plan_spec.spl \
        doc/07_guide/app/llm/llm_runtime_vllm_torch_interface.md
    do
        printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
    done
} >"$SURFACE_MANIFEST"
surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"

{
    printf '%s\n' "svllm_native_streaming_status=$status"
    printf '%s\n' "svllm_native_streaming_reason=$reason"
    printf '%s\n' "svllm_native_streaming_blocked_gates=$blocked_gates"
    printf '%s\n' "svllm_native_streaming_primary_blocked_gate=$primary_blocked_gate"
    printf '%s\n' "svllm_native_streaming_next_action=$next_action"
    printf '%s\n' "svllm_native_streaming_local_readiness_status=$local_status"
    printf '%s\n' "svllm_native_streaming_capability_source=$CAPABILITY_SOURCE"
    printf '%s\n' "svllm_native_streaming_capability_provenance_status=$capability_provenance_status"
    printf '%s\n' "svllm_native_streaming_capability_evidence_path=$CAPABILITY_EVIDENCE_PATH"
    printf '%s\n' "svllm_native_streaming_capability_evidence_status=$capability_evidence_status"
    printf '%s\n' "svllm_native_streaming_capability_evidence_sha256=$capability_evidence_sha256"
    printf '%s\n' "svllm_native_streaming_capability_evidence_size=$capability_evidence_size"
    printf '%s\n' "svllm_native_streaming_capability_evidence_mtime=$capability_evidence_mtime"
    printf '%s\n' "svllm_native_streaming_capability_evidence_source=$capability_evidence_source"
    printf '%s\n' "svllm_native_streaming_capability_evidence_schema_version=$capability_evidence_schema_version"
    printf '%s\n' "svllm_native_streaming_capability_probe_event=$capability_probe_event"
    printf '%s\n' "svllm_native_streaming_capability_probe_status=$capability_probe_status"
    printf '%s\n' "svllm_native_streaming_capability_probe_exit=$capability_probe_exit"
    printf '%s\n' "svllm_native_streaming_capability_evidence_reported_read_range_status=$capability_evidence_read_range_status"
    printf '%s\n' "svllm_native_streaming_capability_evidence_reported_pinned_buffer_status=$capability_evidence_pinned_buffer_status"
    printf '%s\n' "svllm_native_streaming_capability_evidence_reported_device_staging_status=$capability_evidence_device_staging_status"
    printf '%s\n' "svllm_native_streaming_capability_evidence_local_read_range_bytes_status=$capability_evidence_local_read_range_bytes_status"
    printf '%s\n' "svllm_native_streaming_capability_evidence_local_read_range_bytes_reason=$capability_evidence_local_read_range_bytes_reason"
    printf '%s\n' "svllm_native_streaming_capability_probe_report=$CAPABILITY_PROBE_REPORT"
    printf '%s\n' "svllm_native_streaming_capability_probe_report_size=$(artifact_size "$CAPABILITY_PROBE_REPORT")"
    printf '%s\n' "svllm_native_streaming_capability_probe_report_sha256=$(artifact_sha256 "$CAPABILITY_PROBE_REPORT")"
    printf '%s\n' "svllm_native_streaming_pass_integrity_status=$pass_integrity_status"
    printf '%s\n' "svllm_native_streaming_pass_integrity_reason=$pass_integrity_reason"
    printf '%s\n' "svllm_native_streaming_read_range_status=$read_range_status"
    printf '%s\n' "svllm_native_streaming_pinned_buffer_status=$pinned_buffer_status"
    printf '%s\n' "svllm_native_streaming_device_staging_status=$device_staging_status"
    printf '%s\n' "svllm_native_streaming_local_read_bytes_status=$local_read_bytes_status"
    printf '%s\n' "svllm_native_streaming_local_readiness_env=$LOCAL_ENV"
    printf '%s\n' "svllm_native_streaming_local_readiness_env_size=$local_readiness_env_size"
    printf '%s\n' "svllm_native_streaming_local_readiness_env_sha256=$local_readiness_env_sha256"
    printf '%s\n' "svllm_native_streaming_local_readiness_log=$LOCAL_LOG"
    printf '%s\n' "svllm_native_streaming_local_readiness_log_size=$local_readiness_log_size"
    printf '%s\n' "svllm_native_streaming_local_readiness_log_sha256=$local_readiness_log_sha256"
    printf '%s\n' "svllm_native_streaming_local_readiness_report=$LOCAL_REPORT"
    printf '%s\n' "svllm_native_streaming_local_readiness_report_size=$local_readiness_report_size"
    printf '%s\n' "svllm_native_streaming_local_readiness_report_sha256=$local_readiness_report_sha256"
    printf '%s\n' "svllm_native_streaming_local_spec_timeout_seconds=$LOCAL_SPEC_TIMEOUT_SECONDS"
    printf '%s\n' "svllm_native_streaming_surface_manifest=$SURFACE_MANIFEST"
    printf '%s\n' "svllm_native_streaming_surface_manifest_count=$surface_manifest_count"
    printf '%s\n' "svllm_native_streaming_surface_manifest_size=$surface_manifest_size"
    printf '%s\n' "svllm_native_streaming_surface_manifest_sha256=$surface_manifest_sha256"
} >"$OUT_ENV"

{
    printf '# LLM Runtime svLLM Native Streaming Evidence\n\n'
    printf '%s\n' "- status: \`$status\`"
    printf '%s\n' "- reason: \`$reason\`"
    printf '%s\n' "- blocked_gates: \`$blocked_gates\`"
    printf '%s\n' "- primary_blocked_gate: \`$primary_blocked_gate\`"
    printf '%s\n' "- next_action: \`$next_action\`"
    printf '%s\n' "- local_readiness: \`$local_status\`"
    printf '%s\n' "- local_readiness_env: \`$LOCAL_ENV\`"
    printf '%s\n' "- local_readiness_env_size: \`$local_readiness_env_size\`"
    printf '%s\n' "- local_readiness_env_sha256: \`$local_readiness_env_sha256\`"
    printf '%s\n' "- local_readiness_log: \`$LOCAL_LOG\`"
    printf '%s\n' "- local_readiness_log_size: \`$local_readiness_log_size\`"
    printf '%s\n' "- local_readiness_log_sha256: \`$local_readiness_log_sha256\`"
    printf '%s\n' "- local_readiness_report: \`$LOCAL_REPORT\`"
    printf '%s\n' "- local_readiness_report_size: \`$local_readiness_report_size\`"
    printf '%s\n' "- local_readiness_report_sha256: \`$local_readiness_report_sha256\`"
    printf '%s\n' "- capability_source: \`$CAPABILITY_SOURCE\`"
    printf '%s\n' "- capability_provenance: \`$capability_provenance_status\`"
    printf '%s\n' "- capability_evidence_path: \`$CAPABILITY_EVIDENCE_PATH\`"
    printf '%s\n' "- capability_evidence: \`$capability_evidence_status\`"
    printf '%s\n' "- capability_evidence_sha256: \`$capability_evidence_sha256\`"
    printf '%s\n' "- capability_evidence_size: \`$capability_evidence_size\`"
    printf '%s\n' "- capability_evidence_mtime: \`$capability_evidence_mtime\`"
    printf '%s\n' "- capability_evidence_source: \`$capability_evidence_source\`"
    printf '%s\n' "- capability_evidence_schema_version: \`$capability_evidence_schema_version\`"
    printf '%s\n' "- capability_probe_event: \`$capability_probe_event\`"
    printf '%s\n' "- capability_probe_status: \`$capability_probe_status\`"
    printf '%s\n' "- capability_probe_exit: \`$capability_probe_exit\`"
    printf '%s\n' "- capability_evidence_reported_read_range: \`$capability_evidence_read_range_status\`"
    printf '%s\n' "- capability_evidence_reported_pinned_buffer: \`$capability_evidence_pinned_buffer_status\`"
    printf '%s\n' "- capability_evidence_reported_device_staging: \`$capability_evidence_device_staging_status\`"
    printf '%s\n' "- capability_evidence_local_read_range_bytes: \`$capability_evidence_local_read_range_bytes_status\`"
    printf '%s\n' "- capability_evidence_local_read_range_bytes_reason: \`$capability_evidence_local_read_range_bytes_reason\`"
    printf '%s\n' "- capability_probe_report: \`$CAPABILITY_PROBE_REPORT\`"
    printf '%s\n' "- capability_probe_report_size: \`$(artifact_size "$CAPABILITY_PROBE_REPORT")\`"
    printf '%s\n' "- capability_probe_report_sha256: \`$(artifact_sha256 "$CAPABILITY_PROBE_REPORT")\`"
    printf '%s\n' "- pass_integrity_status: \`$pass_integrity_status\`"
    printf '%s\n' "- pass_integrity_reason: \`$pass_integrity_reason\`"
    printf '%s\n' "- read_range: \`$read_range_status\`"
    printf '%s\n' "- pinned_buffer: \`$pinned_buffer_status\`"
    printf '%s\n' "- device_staging: \`$device_staging_status\`"
    printf '%s\n' "- local_read_bytes: \`$local_read_bytes_status\`"
    printf '%s\n' "- local_spec_timeout_seconds: \`$LOCAL_SPEC_TIMEOUT_SECONDS\`"
    printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
    printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
    printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
    printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '\n'
    printf 'This evidence consumes the local svLLM readiness gate and records native streaming capability statuses from `SVLLM_NATIVE_READ_RANGE_STATUS`, `SVLLM_NATIVE_PINNED_BUFFER_STATUS`, and `SVLLM_NATIVE_DEVICE_STAGING_STATUS` (default `unsupported`). It hashes the wrapper/source/spec/doc surface manifest plus the nested local-readiness env, log, and report so strict native evidence identifies the exact contract and local readiness run it consumed. It only passes when local readiness passes, all three native capability statuses are `ready`, `SVLLM_NATIVE_CAPABILITY_SOURCE` names the host probe or artifact that proved those ready statuses, and `SVLLM_NATIVE_CAPABILITY_EVIDENCE_PATH` points at a non-empty schema-v1 probe artifact with matching `svllm_native_capability_source`, `svllm_native_capability_probe_event=svllm_native_capability_probe`, `svllm_native_capability_probe_status=pass`, `svllm_native_capability_probe_exit=0`, and reported native statuses matching the wrapper inputs. Local file-backed bytes alone remain explicit bring-up evidence, not native streaming completion.\n'
} >"$REPORT_PATH"

if [ "$status" = "pass" ]; then
    echo "STATUS: PASS llm-runtime-svllm-native-streaming"
else
    echo "STATUS: FAIL llm-runtime-svllm-native-streaming reason=$reason"
    exit 1
fi
