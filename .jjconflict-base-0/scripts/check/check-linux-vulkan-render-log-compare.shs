#!/bin/sh
# Normalize and compare Linux Vulkan Simple/Chrome/Electron render logs.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

. "$ROOT_DIR/scripts/lib/render-log-common.shs"
. "$ROOT_DIR/scripts/lib/renderdoc-evidence-common.shs"

BUILD_DIR="${BUILD_DIR:-build/linux-vulkan-render-log-compare}"
REPORT_PATH="${REPORT_PATH:-$BUILD_DIR/report.md}"
GUI_WEB_2D_VULKAN_ENV="${GUI_WEB_2D_VULKAN_ENV:-build/gui-web-2d-vulkan-env-run-current/evidence.env}"
GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV="${GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV:-build/gui-web-2d-vulkan-env-browser-backing/evidence.env}"
RDOC_SIMPLE_EVIDENCE_ENV="${RDOC_SIMPLE_EVIDENCE_ENV:-build/gui-web-2d-vulkan-env-renderdoc-simple/renderdoc/simple/evidence.env}"
RDOC_HTML_EVIDENCE_ENV="${RDOC_HTML_EVIDENCE_ENV:-build/renderdoc/chrome-implicit-layer-default-autocapture/html/evidence.env}"
RDOC_ELECTRON_HTML_EVIDENCE_ENV="${RDOC_ELECTRON_HTML_EVIDENCE_ENV:-build/renderdoc/electron-implicit-layer-default-autocapture/electron-html/evidence.env}"

OUT_ENV="$BUILD_DIR/evidence.env"
SIMPLE_LOG="$BUILD_DIR/simple.srl.env"
CHROME_LOG="$BUILD_DIR/chrome.srl.env"
ELECTRON_LOG="$BUILD_DIR/electron.srl.env"
COMPARE_LOG="$BUILD_DIR/compare.srl.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$SIMPLE_LOG" "$CHROME_LOG" "$ELECTRON_LOG" "$COMPARE_LOG" "$REPORT_PATH"

simple_status=""
simple_backend_status=""
simple_backend=""
simple_argb_backend=""
electron_backing=""
chrome_backing=""
browser_backing=""
backing_env="$GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV"
pixel_status=""
pixel_mode=""
ec_diff=""
es_diff=""
cs_diff=""
simple_argb_reason=""
chrome_argb_reason=""
electron_argb_reason=""
argb_viewport_reason=""
reason_parts=""
add_reason() {
    reason="$1"
    if [ -z "$reason_parts" ]; then
        reason_parts="$reason"
    else
        reason_parts="$reason_parts;$reason"
    fi
}

file_link_count() {
    path="$1"
    if command -v stat >/dev/null 2>&1; then
        count="$(stat -c '%h' "$path" 2>/dev/null || stat -f '%l' "$path" 2>/dev/null || true)"
        case "$count" in
            ''|*[!0-9]*) printf '%s\n' "" ;;
            *) printf '%s\n' "$count" ;;
        esac
    else
        printf '%s\n' ""
    fi
}

file_status() {
    path="$1"
    if [ -z "$path" ]; then
        printf '%s\n' "missing"
    elif [ -L "$path" ]; then
        printf '%s\n' "symlink"
    elif [ ! -f "$path" ]; then
        printf '%s\n' "missing"
    elif [ ! -s "$path" ]; then
        printf '%s\n' "empty"
    else
        link_count="$(file_link_count "$path")"
        if [ -n "$link_count" ] && [ "$link_count" -gt 1 ]; then
            printf '%s\n' "hardlink"
        else
            printf '%s\n' "pass"
        fi
    fi
}

value_or_missing() {
    value="$1"
    if [ -n "$value" ]; then
        printf '%s\n' "$value"
    else
        printf '%s\n' "missing"
    fi
}

first_available_command() {
    for candidate in "$@"; do
        if command -v "$candidate" >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    printf '%s\n' "missing"
}

command_presence_status() {
    tool="$1"
    if [ "$tool" = "missing" ]; then
        printf '%s\n' "missing"
    else
        printf '%s\n' "pass"
    fi
}

artifact_magic_status() {
    magic="$1"
    artifact_path="$2"
    if [ -n "$magic" ]; then
        printf '%s\n' "$magic"
    elif [ -s "$artifact_path" ]; then
        printf '%s\n' "invalid"
    else
        printf '%s\n' "missing"
    fi
}

if [ ! -s "$GUI_WEB_2D_VULKAN_ENV" ]; then
    compare_status="unavailable"
    reason_parts="missing-gui-web-2d-vulkan-env"
else
    compare_status="pass"
    backing_env="$GUI_WEB_2D_VULKAN_ENV"
    main_mode="$(render_log_value_of gui_web_2d_vulkan_mode "$GUI_WEB_2D_VULKAN_ENV")"
    main_browser_backing_status="$(render_log_value_of gui_web_2d_vulkan_browser_backing_status "$GUI_WEB_2D_VULKAN_ENV")"
    if [ -s "$GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV" ]; then
        backing_env="$GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV"
    fi
    if [ "$main_mode" = "--browser-backing" ] && [ -n "$main_browser_backing_status" ]; then
        backing_env="$GUI_WEB_2D_VULKAN_ENV"
    fi

    simple_status="$(render_log_value_of gui_web_2d_vulkan_simple_status "$GUI_WEB_2D_VULKAN_ENV")"
    simple_backend_status="$(render_log_value_of gui_web_2d_vulkan_simple_backend_status "$GUI_WEB_2D_VULKAN_ENV")"
    simple_backend="$(render_log_value_of gui_web_2d_vulkan_simple_backend_name "$GUI_WEB_2D_VULKAN_ENV")"
    simple_argb_backend="$(render_log_value_of gui_web_2d_vulkan_simple_argb_backend "$GUI_WEB_2D_VULKAN_ENV")"
    electron_backing="$(render_log_value_of gui_web_2d_vulkan_electron_browser_backing_status "$backing_env")"
    chrome_backing="$(render_log_value_of gui_web_2d_vulkan_chrome_browser_backing_status "$backing_env")"
    browser_backing="$(render_log_value_of gui_web_2d_vulkan_browser_backing_status "$backing_env")"
    pixel_status="$(render_log_value_of gui_web_2d_vulkan_pixel_comparison_status "$GUI_WEB_2D_VULKAN_ENV")"
    pixel_mode="$(render_log_value_of gui_web_2d_vulkan_pixel_comparison_mode "$GUI_WEB_2D_VULKAN_ENV")"
    ec_diff="$(render_log_value_of gui_web_2d_vulkan_electron_chrome_pairwise_diff_status "$GUI_WEB_2D_VULKAN_ENV")"
    es_diff="$(render_log_value_of gui_web_2d_vulkan_electron_simple_pairwise_diff_status "$GUI_WEB_2D_VULKAN_ENV")"
    cs_diff="$(render_log_value_of gui_web_2d_vulkan_chrome_simple_pairwise_diff_status "$GUI_WEB_2D_VULKAN_ENV")"

    if [ "$simple_status" != "pass" ] && [ "$simple_backend_status" != "pass" ]; then
        compare_status="fail"
        add_reason "simple-vulkan-status-${simple_status:-missing}"
    fi
    if [ "$simple_backend" != "vulkan" ] && [ "$simple_argb_backend" != "vulkan" ]; then
        compare_status="fail"
        add_reason "simple-backend-not-vulkan"
    fi
    if [ "$electron_backing" != "pass" ]; then
        compare_status="fail"
        add_reason "electron-browser-backing-${electron_backing:-missing}"
    fi
    if [ "$chrome_backing" != "pass" ]; then
        compare_status="fail"
        add_reason "chrome-browser-backing-${chrome_backing:-missing}"
    fi
    if [ "$browser_backing" != "pass" ]; then
        compare_status="fail"
        add_reason "browser-backing-${browser_backing:-missing}"
    fi
    if [ "$pixel_status" != "pass" ] || [ "$pixel_mode" != "pairwise-argb-diff" ]; then
        compare_status="fail"
        add_reason "pixel-comparison-${pixel_status:-missing}"
    fi
    if [ "$ec_diff" != "pass" ] || [ "$es_diff" != "pass" ] || [ "$cs_diff" != "pass" ]; then
        compare_status="fail"
        add_reason "pairwise-diff-incomplete-or-fail"
    fi
    simple_argb_reason="$(render_log_argb_source_reason gui_web_2d_vulkan simple "$GUI_WEB_2D_VULKAN_ENV")"
    chrome_argb_reason="$(render_log_argb_source_reason gui_web_2d_vulkan chrome "$GUI_WEB_2D_VULKAN_ENV")"
    electron_argb_reason="$(render_log_argb_source_reason gui_web_2d_vulkan electron "$GUI_WEB_2D_VULKAN_ENV")"
    for argb_reason in "$simple_argb_reason" "$chrome_argb_reason" "$electron_argb_reason"; do
        if [ "$argb_reason" != "pass" ]; then
            compare_status="fail"
            add_reason "$argb_reason"
        fi
    done
    argb_viewport_reason="$(render_log_argb_viewport_match_reason gui_web_2d_vulkan "$GUI_WEB_2D_VULKAN_ENV")"
    if [ "$argb_viewport_reason" != "pass" ]; then
        compare_status="fail"
        add_reason "$argb_viewport_reason"
    fi
fi

simple_rdoc_status="$(render_log_status_from_rdoc_env "$RDOC_SIMPLE_EVIDENCE_ENV" rdoc_simple_gate_status rdoc_capture_status rdoc_capture_magic)"
chrome_rdoc_status="$(render_log_status_from_rdoc_env "$RDOC_HTML_EVIDENCE_ENV" rdoc_external_host_capture_gate_status rdoc_capture_status rdoc_capture_magic)"
electron_rdoc_status="$(render_log_status_from_rdoc_env "$RDOC_ELECTRON_HTML_EVIDENCE_ENV" rdoc_electron_html_gate_status rdoc_capture_status rdoc_capture_magic)"
simple_rdoc_reason="$(render_log_reason_from_rdoc_env "$RDOC_SIMPLE_EVIDENCE_ENV" rdoc_simple_gate_reason rdoc_capture_reason)"
chrome_rdoc_reason="$(render_log_value_of rdoc_external_host_capture_reason_raw "$RDOC_HTML_EVIDENCE_ENV")"
if [ -z "$chrome_rdoc_reason" ]; then
    chrome_rdoc_reason="$(render_log_value_of rdoc_capture_reason "$RDOC_HTML_EVIDENCE_ENV")"
fi
if [ -z "$chrome_rdoc_reason" ]; then
    chrome_rdoc_reason="$(render_log_reason_from_rdoc_env "$RDOC_HTML_EVIDENCE_ENV" rdoc_external_host_gate_reason rdoc_external_host_capture_reason_raw)"
fi
[ -n "$chrome_rdoc_reason" ] || chrome_rdoc_reason="missing-reason"
electron_rdoc_reason="$(render_log_reason_from_rdoc_env "$RDOC_ELECTRON_HTML_EVIDENCE_ENV" rdoc_electron_html_gate_reason rdoc_capture_reason)"
chrome_gpu_exit_status="$(render_log_value_of rdoc_chromium_gpu_process_exit_status "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_exit_count="$(render_log_value_of rdoc_chromium_gpu_process_exit_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_exit_codes="$(render_log_value_of rdoc_chromium_gpu_process_exit_codes "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_exit_reason="$(render_log_value_of rdoc_chromium_gpu_process_exit_reason "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_exit_renderdoc_stack_status="$(render_log_value_of rdoc_chromium_gpu_process_exit_renderdoc_stack_status "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_exit_renderdoc_stack_count="$(render_log_value_of rdoc_chromium_gpu_process_exit_renderdoc_stack_count "$RDOC_HTML_EVIDENCE_ENV")"
if [ "$chrome_gpu_exit_status" = "" ]; then
    chrome_gpu_exit_status="$(render_log_value_of rdoc_external_host_gpu_process_exit_status "$RDOC_HTML_EVIDENCE_ENV")"
    chrome_gpu_exit_count="$(render_log_value_of rdoc_external_host_gpu_process_exit_count "$RDOC_HTML_EVIDENCE_ENV")"
    chrome_gpu_exit_codes="$(render_log_value_of rdoc_external_host_gpu_process_exit_codes "$RDOC_HTML_EVIDENCE_ENV")"
    chrome_gpu_exit_reason="$(render_log_value_of rdoc_external_host_gpu_process_exit_reason "$RDOC_HTML_EVIDENCE_ENV")"
fi
electron_gpu_exit_status="$(render_log_value_of rdoc_chromium_gpu_process_exit_status "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_exit_count="$(render_log_value_of rdoc_chromium_gpu_process_exit_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_exit_codes="$(render_log_value_of rdoc_chromium_gpu_process_exit_codes "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_exit_reason="$(render_log_value_of rdoc_chromium_gpu_process_exit_reason "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_exit_renderdoc_stack_status="$(render_log_value_of rdoc_chromium_gpu_process_exit_renderdoc_stack_status "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_exit_renderdoc_stack_count="$(render_log_value_of rdoc_chromium_gpu_process_exit_renderdoc_stack_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
chrome_gpu_launcher_angle_status="$(render_log_value_of rdoc_chromium_gpu_launcher_angle_status "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_launcher_angle_error_count="$(render_log_value_of rdoc_chromium_gpu_launcher_angle_error_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_launcher_clear_renderdoc_layer="$(render_log_value_of rdoc_gpu_launcher_clear_renderdoc_layer "$RDOC_HTML_EVIDENCE_ENV")"
chrome_gpu_launcher_vk_instance_layers="$(render_log_value_of rdoc_gpu_launcher_vk_instance_layers "$RDOC_HTML_EVIDENCE_ENV")"
chrome_autocapture_status="$(render_log_value_of rdoc_gpu_autocapture_status "$RDOC_HTML_EVIDENCE_ENV")"
chrome_autocapture_api="$(render_log_value_of rdoc_gpu_autocapture_api "$RDOC_HTML_EVIDENCE_ENV")"
chrome_autocapture_started="$(render_log_value_of rdoc_gpu_autocapture_started "$RDOC_HTML_EVIDENCE_ENV")"
chrome_autocapture_finished="$(render_log_value_of rdoc_gpu_autocapture_finished "$RDOC_HTML_EVIDENCE_ENV")"
chrome_autocapture_start_source="$(render_log_value_of rdoc_gpu_autocapture_start_source "$RDOC_HTML_EVIDENCE_ENV")"
chrome_autocapture_end_source="$(render_log_value_of rdoc_gpu_autocapture_end_source "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_loaded_count="$(render_log_value_of rdoc_gpu_delay_trigger_loaded_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_api_ready_count="$(render_log_value_of rdoc_gpu_delay_trigger_api_ready_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_mode="$(render_log_value_of rdoc_gpu_delay_trigger_mode "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_capture_count="$(render_log_value_of rdoc_gpu_delay_trigger_capture_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_last_end_ok="$(render_log_value_of rdoc_gpu_delay_trigger_last_end_ok "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_elf_status="$(render_log_value_of rdoc_gpu_delay_trigger_elf_status "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_capfile_template="$(render_log_value_of rdoc_gpu_delay_trigger_capfile_template "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_target_device="$(render_log_value_of rdoc_gpu_delay_trigger_target_device "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_last_vk_instance="$(render_log_value_of rdoc_gpu_delay_trigger_last_vk_instance "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_vk_create_instance_count="$(render_log_value_of rdoc_gpu_delay_trigger_vk_create_instance_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_num_captures_before="$(render_log_value_of rdoc_gpu_delay_trigger_num_captures_before "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_num_captures_after="$(render_log_value_of rdoc_gpu_delay_trigger_num_captures_after "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_is_capturing_after_start="$(render_log_value_of rdoc_gpu_delay_trigger_is_capturing_after_start "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_is_capturing_after_trigger="$(render_log_value_of rdoc_gpu_delay_trigger_is_capturing_after_trigger "$RDOC_HTML_EVIDENCE_ENV")"
chrome_delay_trigger_is_capturing_before_end="$(render_log_value_of rdoc_gpu_delay_trigger_is_capturing_before_end "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_get_platform_display_count="$(render_log_value_of rdoc_gpu_autocapture_egl_get_platform_display_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_initialize_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_initialize_return_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_return_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_initialize_success_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_success_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_initialize_fail_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_fail_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_initialize_last_result="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_last_result "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_initialize_last_error="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_last_error "$RDOC_HTML_EVIDENCE_ENV")"
chrome_egl_choose_config_count="$(render_log_value_of rdoc_gpu_autocapture_egl_choose_config_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_instance_layer_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_instance_layer_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_instance_extension_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_instance_extension_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_create_instance_count="$(render_log_value_of rdoc_gpu_autocapture_vk_create_instance_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_create_device_count="$(render_log_value_of rdoc_gpu_autocapture_vk_create_device_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_physical_device_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_physical_device_return_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_return_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_physical_device_last_result="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_last_result "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_physical_device_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_last_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_get_physical_device_properties_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_properties_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_get_physical_device_properties2_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_properties2_count "$RDOC_HTML_EVIDENCE_ENV")"
