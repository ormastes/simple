chrome_vk_get_physical_device_queue_family_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_get_physical_device_queue_family2_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family2_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_get_physical_device_queue_family_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family_last_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_get_physical_device_queue_family2_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family2_last_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_device_extension_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_device_extension_return_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_return_count "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_device_extension_last_result="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_last_result "$RDOC_HTML_EVIDENCE_ENV")"
chrome_vk_enum_device_extension_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_last_count "$RDOC_HTML_EVIDENCE_ENV")"
electron_gpu_launcher_angle_status="$(render_log_value_of rdoc_chromium_gpu_launcher_angle_status "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_launcher_angle_error_count="$(render_log_value_of rdoc_chromium_gpu_launcher_angle_error_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_launcher_clear_renderdoc_layer="$(render_log_value_of rdoc_gpu_launcher_clear_renderdoc_layer "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_gpu_launcher_vk_instance_layers="$(render_log_value_of rdoc_gpu_launcher_vk_instance_layers "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_autocapture_status="$(render_log_value_of rdoc_gpu_autocapture_status "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_autocapture_api="$(render_log_value_of rdoc_gpu_autocapture_api "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_autocapture_started="$(render_log_value_of rdoc_gpu_autocapture_started "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_autocapture_finished="$(render_log_value_of rdoc_gpu_autocapture_finished "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_autocapture_start_source="$(render_log_value_of rdoc_gpu_autocapture_start_source "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_autocapture_end_source="$(render_log_value_of rdoc_gpu_autocapture_end_source "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_loaded_count="$(render_log_value_of rdoc_gpu_delay_trigger_loaded_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_api_ready_count="$(render_log_value_of rdoc_gpu_delay_trigger_api_ready_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_mode="$(render_log_value_of rdoc_gpu_delay_trigger_mode "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_capture_count="$(render_log_value_of rdoc_gpu_delay_trigger_capture_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_last_end_ok="$(render_log_value_of rdoc_gpu_delay_trigger_last_end_ok "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_elf_status="$(render_log_value_of rdoc_gpu_delay_trigger_elf_status "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_capfile_template="$(render_log_value_of rdoc_gpu_delay_trigger_capfile_template "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_target_device="$(render_log_value_of rdoc_gpu_delay_trigger_target_device "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_last_vk_instance="$(render_log_value_of rdoc_gpu_delay_trigger_last_vk_instance "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_vk_create_instance_count="$(render_log_value_of rdoc_gpu_delay_trigger_vk_create_instance_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_num_captures_before="$(render_log_value_of rdoc_gpu_delay_trigger_num_captures_before "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_num_captures_after="$(render_log_value_of rdoc_gpu_delay_trigger_num_captures_after "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_is_capturing_after_start="$(render_log_value_of rdoc_gpu_delay_trigger_is_capturing_after_start "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_is_capturing_after_trigger="$(render_log_value_of rdoc_gpu_delay_trigger_is_capturing_after_trigger "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_delay_trigger_is_capturing_before_end="$(render_log_value_of rdoc_gpu_delay_trigger_is_capturing_before_end "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_get_platform_display_count="$(render_log_value_of rdoc_gpu_autocapture_egl_get_platform_display_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_initialize_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_initialize_return_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_return_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_initialize_success_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_success_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_initialize_fail_count="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_fail_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_initialize_last_result="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_last_result "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_initialize_last_error="$(render_log_value_of rdoc_gpu_autocapture_egl_initialize_last_error "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_egl_choose_config_count="$(render_log_value_of rdoc_gpu_autocapture_egl_choose_config_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_instance_layer_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_instance_layer_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_instance_extension_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_instance_extension_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_create_instance_count="$(render_log_value_of rdoc_gpu_autocapture_vk_create_instance_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_create_device_count="$(render_log_value_of rdoc_gpu_autocapture_vk_create_device_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_physical_device_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_physical_device_return_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_return_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_physical_device_last_result="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_last_result "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_physical_device_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_physical_device_last_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_properties_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_properties_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_properties2_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_properties2_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_features2_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_features2_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_queue_family_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_queue_family2_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family2_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_queue_family_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family_last_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_get_physical_device_queue_family2_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_get_physical_device_queue_family2_last_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_device_extension_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_device_extension_return_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_return_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_device_extension_last_result="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_last_result "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_vk_enum_device_extension_last_count="$(render_log_value_of rdoc_gpu_autocapture_vk_enum_device_extension_last_count "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
browser_angle_renderdoc_workaround_status="unknown"
browser_angle_renderdoc_workaround_reason="insufficient-egl-initialize-return-evidence"
if [ "$chrome_rdoc_status" = "pass" ] && [ "$electron_rdoc_status" = "pass" ]; then
    browser_angle_renderdoc_workaround_status="pass"
    browser_angle_renderdoc_workaround_reason="browser-renderdoc-rdc-present"
elif {
    [ "${chrome_egl_initialize_count:-0}" != "" ] && [ "${chrome_egl_initialize_return_count:-0}" != "" ] &&
    [ "${chrome_egl_initialize_count:-0}" -gt 0 ] 2>/dev/null &&
    [ "${chrome_egl_initialize_return_count:-0}" -eq 0 ] 2>/dev/null
} || {
    [ "${electron_egl_initialize_count:-0}" != "" ] && [ "${electron_egl_initialize_return_count:-0}" != "" ] &&
    [ "${electron_egl_initialize_count:-0}" -gt 0 ] 2>/dev/null &&
    [ "${electron_egl_initialize_return_count:-0}" -eq 0 ] 2>/dev/null
}; then
    browser_angle_renderdoc_workaround_status="needed"
    browser_angle_renderdoc_workaround_reason="linux-angle-eglinitialize-does-not-return-under-renderdoc-layer"
fi
if [ "$chrome_gpu_exit_status" = "fail" ]; then
    if [ "$chrome_gpu_exit_reason" = "gpu-process-segv-in-renderdoc" ]; then
        chrome_rdoc_reason="chromium-gpu-process-segv-in-renderdoc"
    else
        chrome_rdoc_reason="chromium-gpu-process-crashed-under-renderdoc"
    fi
fi
if [ "$electron_gpu_exit_status" = "fail" ]; then
    if [ "$electron_gpu_exit_reason" = "gpu-process-segv-in-renderdoc" ]; then
        electron_rdoc_reason="chromium-gpu-process-segv-in-renderdoc"
    else
        electron_rdoc_reason="chromium-gpu-process-crashed-under-renderdoc"
    fi
fi
host_renderdoc_home="$(rdoc_find_renderdoc_home "$ROOT_DIR" || true)"
if [ -n "$host_renderdoc_home" ]; then
    host_renderdoc_tool="$(rdoc_renderdoccmd_path "$host_renderdoc_home")"
else
    host_renderdoc_tool="$(first_available_command renderdoccmd qrenderdoc)"
fi
host_renderdoc_status="$(command_presence_status "$host_renderdoc_tool")"
host_chrome_tool="$(rdoc_find_chrome "$ROOT_DIR" || first_available_command google-chrome chromium chromium-browser)"
host_chrome_status="$(command_presence_status "$host_chrome_tool")"
host_electron_tool="$(rdoc_find_electron "$ROOT_DIR" || first_available_command electron)"
host_electron_status="$(command_presence_status "$host_electron_tool")"

require_renderdoc="${LINUX_VULKAN_RENDER_LOG_REQUIRE_RDOC:-1}"
if [ "$require_renderdoc" = "1" ]; then
    if [ "$simple_rdoc_status" != "pass" ]; then
        [ "$compare_status" = "unavailable" ] || compare_status="fail"
        add_reason "renderdoc-simple-${simple_rdoc_status:-missing}"
    fi
    if [ "$chrome_rdoc_status" != "pass" ]; then
        [ "$compare_status" = "unavailable" ] || compare_status="fail"
        add_reason "renderdoc-chrome-${chrome_rdoc_status:-missing}"
    fi
    if [ "$electron_rdoc_status" != "pass" ]; then
        [ "$compare_status" = "unavailable" ] || compare_status="fail"
        add_reason "renderdoc-electron-${electron_rdoc_status:-missing}"
    fi
fi

simple_artifact="$(render_log_value_of rdoc_capture_file "$RDOC_SIMPLE_EVIDENCE_ENV")"
simple_magic="$(render_log_rdoc_artifact_magic "$RDOC_SIMPLE_EVIDENCE_ENV" "$simple_artifact")"
simple_artifact_path="$(render_log_rdoc_artifact_path "$RDOC_SIMPLE_EVIDENCE_ENV" "$simple_artifact" || true)"
simple_artifact_file_status="$(file_status "$simple_artifact_path")"
chrome_artifact="$(render_log_value_of rdoc_capture_file "$RDOC_HTML_EVIDENCE_ENV")"
[ -n "$chrome_artifact" ] || chrome_artifact="$(render_log_value_of rdoc_external_host_capture_file "$RDOC_HTML_EVIDENCE_ENV")"
chrome_magic="$(render_log_rdoc_artifact_magic "$RDOC_HTML_EVIDENCE_ENV" "$chrome_artifact")"
chrome_artifact_path="$(render_log_rdoc_artifact_path "$RDOC_HTML_EVIDENCE_ENV" "$chrome_artifact" || true)"
chrome_artifact_file_status="$(file_status "$chrome_artifact_path")"
electron_artifact="$(render_log_value_of rdoc_capture_file "$RDOC_ELECTRON_HTML_EVIDENCE_ENV")"
electron_magic="$(render_log_rdoc_artifact_magic "$RDOC_ELECTRON_HTML_EVIDENCE_ENV" "$electron_artifact")"
electron_artifact_path="$(render_log_rdoc_artifact_path "$RDOC_ELECTRON_HTML_EVIDENCE_ENV" "$electron_artifact" || true)"
electron_artifact_file_status="$(file_status "$electron_artifact_path")"

if [ "$require_renderdoc" = "1" ]; then
    if [ "$simple_rdoc_status" = "pass" ] && [ "$simple_artifact_file_status" != "pass" ]; then
        compare_status="fail"
        add_reason "renderdoc-simple-artifact-file-${simple_artifact_file_status:-missing}"
    fi
    if [ "$chrome_rdoc_status" = "pass" ] && [ "$chrome_artifact_file_status" != "pass" ]; then
        compare_status="fail"
        add_reason "renderdoc-chrome-artifact-file-${chrome_artifact_file_status:-missing}"
    fi
    if [ "$electron_rdoc_status" = "pass" ] && [ "$electron_artifact_file_status" != "pass" ]; then
        compare_status="fail"
        add_reason "renderdoc-electron-artifact-file-${electron_artifact_file_status:-missing}"
    fi
fi

[ -n "$reason_parts" ] || reason_parts="pass"

pixel_gate_status="pass"
if [ "$pixel_status" != "pass" ] || [ "$pixel_mode" != "pairwise-argb-diff" ] ||
    [ "$ec_diff" != "pass" ] || [ "$es_diff" != "pass" ] || [ "$cs_diff" != "pass" ]; then
    pixel_gate_status="fail"
fi

browser_backing_gate_status="pass"
if [ "$electron_backing" != "pass" ] || [ "$chrome_backing" != "pass" ] || [ "$browser_backing" != "pass" ]; then
    browser_backing_gate_status="fail"
fi

simple_vulkan_gate_status="pass"
if { [ "$simple_status" != "pass" ] && [ "$simple_backend_status" != "pass" ]; } ||
    { [ "$simple_backend" != "vulkan" ] && [ "$simple_argb_backend" != "vulkan" ]; }; then
    simple_vulkan_gate_status="fail"
fi

argb_source_gate_status="pass"
if [ "$simple_argb_reason" != "pass" ] || [ "$chrome_argb_reason" != "pass" ] ||
    [ "$electron_argb_reason" != "pass" ] || [ "$argb_viewport_reason" != "pass" ]; then
    argb_source_gate_status="fail"
fi

renderdoc_gate_status="pass"
if [ "$require_renderdoc" != "1" ]; then
    renderdoc_gate_status="diagnostic-disabled"
elif [ "$simple_rdoc_status" != "pass" ] || [ "$chrome_rdoc_status" != "pass" ] ||
    [ "$electron_rdoc_status" != "pass" ] ||
    [ "$simple_artifact_file_status" != "pass" ] || [ "$chrome_artifact_file_status" != "pass" ] ||
    [ "$electron_artifact_file_status" != "pass" ]; then
    renderdoc_gate_status="fail"
fi

blocked_gates=""
blocked_gate_count=0
add_blocked_gate() {
    gate="$1"
    if [ "$compare_status" = "pass" ]; then
        return
    fi
    if [ -z "$blocked_gates" ]; then
        blocked_gates="$gate"
    else
        blocked_gates="$blocked_gates,$gate"
    fi
    blocked_gate_count=$((blocked_gate_count + 1))
}

if [ "$(file_status "$GUI_WEB_2D_VULKAN_ENV")" != "pass" ]; then
    add_blocked_gate "gui-web-2d-vulkan-env"
fi
[ "$simple_vulkan_gate_status" = "pass" ] || add_blocked_gate "simple-vulkan-backend"
[ "$browser_backing_gate_status" = "pass" ] || add_blocked_gate "browser-vulkan-backing"
[ "$pixel_gate_status" = "pass" ] || add_blocked_gate "pairwise-argb-diff"
[ "$argb_source_gate_status" = "pass" ] || add_blocked_gate "argb-source-evidence"
if [ "$require_renderdoc" = "1" ]; then
    { [ "$simple_rdoc_status" = "pass" ] && [ "$simple_artifact_file_status" = "pass" ]; } || add_blocked_gate "renderdoc-simple-rdc"
    { [ "$chrome_rdoc_status" = "pass" ] && [ "$chrome_artifact_file_status" = "pass" ]; } || add_blocked_gate "renderdoc-chrome-rdc"
    { [ "$electron_rdoc_status" = "pass" ] && [ "$electron_artifact_file_status" = "pass" ]; } || add_blocked_gate "renderdoc-electron-rdc"
fi

render_log_write_source_log "$SIMPLE_LOG" "simple" "simple-renderdoc" "$RDOC_SIMPLE_EVIDENCE_ENV" "$GUI_WEB_2D_VULKAN_ENV" "$simple_rdoc_status" "$simple_artifact" "$simple_magic" "simple-backend=${simple_backend:-};simple-argb-backend=${simple_argb_backend:-}" "$simple_rdoc_reason"
render_log_write_source_log "$CHROME_LOG" "chrome" "renderdoc" "$RDOC_HTML_EVIDENCE_ENV" "$GUI_WEB_2D_VULKAN_ENV" "$chrome_rdoc_status" "$chrome_artifact" "$chrome_magic" "browser-backing=${chrome_backing:-}" "$chrome_rdoc_reason"
render_log_write_source_log "$ELECTRON_LOG" "electron" "renderdoc" "$RDOC_ELECTRON_HTML_EVIDENCE_ENV" "$GUI_WEB_2D_VULKAN_ENV" "$electron_rdoc_status" "$electron_artifact" "$electron_magic" "browser-backing=${electron_backing:-}" "$electron_rdoc_reason"

{
    render_log_append_kv "simple_render_log_format" "simple-render-log-v1"
    render_log_append_kv "simple_render_log_platform" "linux"
    render_log_append_kv "simple_render_log_native_api" "vulkan"
    render_log_append_kv "simple_render_log_source" "compare"
    render_log_append_kv "simple_render_log_capture_tool" "aggregate"
    render_log_append_kv "simple_render_log_scene" "gui-web-2d-vulkan"
    render_log_append_kv "simple_render_log_status" "$compare_status"
    render_log_append_kv "simple_render_log_pairwise_reference" "$GUI_WEB_2D_VULKAN_ENV"
    render_log_append_kv "simple_render_log_pairwise_electron_chrome_status" "${ec_diff:-}"
    render_log_append_kv "simple_render_log_pairwise_electron_simple_status" "${es_diff:-}"
    render_log_append_kv "simple_render_log_pairwise_chrome_simple_status" "${cs_diff:-}"
    render_log_append_kv "simple_render_log_native_info" "$reason_parts"
} >"$COMPARE_LOG"

{
    render_log_append_kv "linux_vulkan_render_log_compare_status" "$compare_status"
    render_log_append_kv "linux_vulkan_render_log_compare_reason" "$reason_parts"
    render_log_append_kv "linux_vulkan_render_log_compare_blocked_gate_count" "$blocked_gate_count"
    render_log_append_kv "linux_vulkan_render_log_compare_blocked_gates" "$blocked_gates"
    render_log_append_kv "linux_vulkan_render_log_compare_simple_vulkan_gate_status" "$simple_vulkan_gate_status"
    render_log_append_kv "linux_vulkan_render_log_compare_browser_backing_gate_status" "$browser_backing_gate_status"
    render_log_append_kv "linux_vulkan_render_log_compare_pairwise_gate_status" "$pixel_gate_status"
    render_log_append_kv "linux_vulkan_render_log_compare_argb_source_gate_status" "$argb_source_gate_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_gate_status" "$renderdoc_gate_status"
    render_log_append_kv "linux_vulkan_render_log_compare_platform" "linux"
    render_log_append_kv "linux_vulkan_render_log_compare_required_api" "vulkan"
    render_log_append_kv "linux_vulkan_render_log_compare_host_renderdoc_status" "$host_renderdoc_status"
    render_log_append_kv "linux_vulkan_render_log_compare_host_renderdoc_tool" "$host_renderdoc_tool"
    render_log_append_kv "linux_vulkan_render_log_compare_host_chrome_status" "$host_chrome_status"
    render_log_append_kv "linux_vulkan_render_log_compare_host_chrome_tool" "$host_chrome_tool"
    render_log_append_kv "linux_vulkan_render_log_compare_host_electron_status" "$host_electron_status"
    render_log_append_kv "linux_vulkan_render_log_compare_host_electron_tool" "$host_electron_tool"
    render_log_append_kv "linux_vulkan_render_log_compare_gui_web_2d_vulkan_env" "$GUI_WEB_2D_VULKAN_ENV"
    render_log_append_kv "linux_vulkan_render_log_compare_gui_web_2d_vulkan_env_file_status" "$(file_status "$GUI_WEB_2D_VULKAN_ENV")"
    render_log_append_kv "linux_vulkan_render_log_compare_browser_backing_env" "${backing_env:-$GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV}"
    render_log_append_kv "linux_vulkan_render_log_compare_browser_backing_env_file_status" "$(file_status "${backing_env:-$GUI_WEB_2D_VULKAN_BROWSER_BACKING_EVIDENCE_ENV}")"
    render_log_append_kv "linux_vulkan_render_log_compare_simple_log" "$SIMPLE_LOG"
    render_log_append_kv "linux_vulkan_render_log_compare_chrome_log" "$CHROME_LOG"
    render_log_append_kv "linux_vulkan_render_log_compare_electron_log" "$ELECTRON_LOG"
    render_log_append_kv "linux_vulkan_render_log_compare_compare_log" "$COMPARE_LOG"
    render_log_append_kv "linux_vulkan_render_log_compare_pairwise_status" "$(value_or_missing "${pixel_status:-}")"
    render_log_append_kv "linux_vulkan_render_log_compare_pairwise_mode" "$(value_or_missing "${pixel_mode:-}")"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_env" "$RDOC_SIMPLE_EVIDENCE_ENV"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_env_file_status" "$(file_status "$RDOC_SIMPLE_EVIDENCE_ENV")"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_artifact" "$simple_artifact"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_artifact_file_status" "$simple_artifact_file_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_artifact_magic" "$(artifact_magic_status "$simple_magic" "$simple_artifact_path")"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_status" "$simple_rdoc_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_simple_reason" "$simple_rdoc_reason"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_linux_angle_workaround_status" "$browser_angle_renderdoc_workaround_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_linux_angle_workaround_reason" "$browser_angle_renderdoc_workaround_reason"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_env" "$RDOC_HTML_EVIDENCE_ENV"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_env_file_status" "$(file_status "$RDOC_HTML_EVIDENCE_ENV")"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_artifact" "$chrome_artifact"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_artifact_file_status" "$chrome_artifact_file_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_artifact_magic" "$(artifact_magic_status "$chrome_magic" "$chrome_artifact_path")"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_status" "$chrome_rdoc_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_reason" "$chrome_rdoc_reason"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_process_exit_status" "$chrome_gpu_exit_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_process_exit_count" "$chrome_gpu_exit_count"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_process_exit_codes" "$chrome_gpu_exit_codes"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_process_exit_reason" "$chrome_gpu_exit_reason"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_process_exit_renderdoc_stack_status" "$chrome_gpu_exit_renderdoc_stack_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_process_exit_renderdoc_stack_count" "$chrome_gpu_exit_renderdoc_stack_count"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_launcher_angle_status" "$chrome_gpu_launcher_angle_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_launcher_angle_error_count" "$chrome_gpu_launcher_angle_error_count"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_launcher_clear_renderdoc_layer" "$chrome_gpu_launcher_clear_renderdoc_layer"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_gpu_launcher_vk_instance_layers" "$chrome_gpu_launcher_vk_instance_layers"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_autocapture_status" "$chrome_autocapture_status"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_autocapture_api" "$chrome_autocapture_api"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_autocapture_started" "$chrome_autocapture_started"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_autocapture_finished" "$chrome_autocapture_finished"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_autocapture_start_source" "$chrome_autocapture_start_source"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_autocapture_end_source" "$chrome_autocapture_end_source"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_delay_trigger_loaded_count" "$chrome_delay_trigger_loaded_count"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_delay_trigger_api_ready_count" "$chrome_delay_trigger_api_ready_count"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_delay_trigger_mode" "$chrome_delay_trigger_mode"
    render_log_append_kv "linux_vulkan_render_log_compare_renderdoc_chrome_delay_trigger_capture_count" "$chrome_delay_trigger_capture_count"
