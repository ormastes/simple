use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.mount_table.{MountTable}
use std.fs_driver.types.{MountOptions, OpenFlags}
use std.fs_driver.ramfs.{RamFsDriver}
use std.fs_driver.nvfs_posix_driver.{NvfsPosixDriver}

fn make_table() -> MountTable:
    val mt = MountTable.new()
    var ramfs = RamFsDriver.new()
    ramfs.mount(MountOptions.default()).unwrap()
    mt.mount("/", DriverInstance.RamFs(ramfs), MountOptions.default()).unwrap()
    val nvfs = NvfsPosixDriver.new("NvfsPosixDriver")
    mt.mount("/data", DriverInstance.NvfsPosix(nvfs), MountOptions.default()).unwrap()
    mt

fn main():
    var mt = make_table()
    val fh_r = mt.open("/data/hello.txt", OpenFlags.write_only().with_append().with_create())
    print "open_ok={fh_r.is_ok()}"
    if fh_r.is_err():
        return
    val fh = fh_r.unwrap()
    print "fh_id={fh.id}"
    val wr = mt.write(fh, "hello")
    print "write_ok={wr.is_ok()}"
    if wr.is_err():
        print "write_err={wr.unwrap_err()}"
    val cl = mt.close(fh)
    print "close1_ok={cl.is_ok()}"
    val ro = mt.open("/data/hello.txt", OpenFlags.read_only())
    print "reopen_ok={ro.is_ok()}"
    if ro.is_err():
        return
    val rfh = ro.unwrap()
    print "rfh_id={rfh.id}"
    val rr = mt.pread(rfh, 0, 5)
    print "pread_ok={rr.is_ok()}"
    if rr.is_err():
        print "pread_err={rr.unwrap_err()}"
    if rr.is_ok():
        print "pread_val={rr.unwrap()}"
    val cl2 = mt.close(rfh)
    print "close2_ok={cl2.is_ok()}"
