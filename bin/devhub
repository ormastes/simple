#!/bin/sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)
runtime=""
runtime_usable() {
  candidate="$1"
  [ -n "${candidate}" ] || return 1
  [ -x "${candidate}" ] || return 1
  "${candidate}" --version >/dev/null 2>&1 || return 1
}

for candidate in \
  "${SIMPLE_BINARY:-}" \
  "${REPO_ROOT}/bin/simple" \
  "${REPO_ROOT}/bin/release/simple" \
  "${REPO_ROOT}/bin/release/x86_64-unknown-linux-gnu/simple" \
  "${REPO_ROOT}/bin/release/linux-x86_64/simple"
do
  if runtime_usable "${candidate}"; then
    runtime="${candidate}"
    break
  fi
done
if [ -z "${runtime}" ]; then
  {
    printf '%s\n' "error: no Simple runtime found for devhub"
    printf '%s\n' "checked:"
    printf '%s\n' "  SIMPLE_BINARY"
    printf '%s\n' "  ${REPO_ROOT}/bin/simple"
    printf '%s\n' "  ${REPO_ROOT}/bin/release/simple"
    printf '%s\n' "  ${REPO_ROOT}/bin/release/x86_64-unknown-linux-gnu/simple"
    printf '%s\n' "  ${REPO_ROOT}/bin/release/linux-x86_64/simple"
  } >&2
  exit 127
fi
exec "${runtime}" run "${REPO_ROOT}/src/app/itf/main.spl" "$@"
