#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Pick the host-appropriate platform binary. The release dir layout uses the
# 4-part Simple-native triple (…-macho on macOS); fall back through known
# aliases. x86_64-unknown-linux-gnu stays in the list so Linux behavior is
# unchanged when a host-specific dir is absent.
uname_s="$(uname -s 2>/dev/null || echo unknown)"
uname_m="$(uname -m 2>/dev/null || echo unknown)"

candidates=()
case "$uname_s" in
  Darwin)
    case "$uname_m" in
      arm64|aarch64)
        candidates+=("aarch64-apple-darwin-macho" "macos-arm64" "darwin-aarch64")
        ;;
      *)
        candidates+=("macos-x86_64" "x86_64-apple-darwin-macho")
        ;;
    esac
    ;;
  Linux)
    case "$uname_m" in
      aarch64|arm64)
        candidates+=("aarch64-unknown-linux-gnu" "linux-aarch64")
        ;;
      *)
        candidates+=("x86_64-unknown-linux-gnu" "linux-x86_64")
        ;;
    esac
    ;;
esac
# Universal fallbacks (preserve prior default for any unmatched host).
candidates+=("x86_64-unknown-linux-gnu" "linux-x86_64")

runtime=""
for cand in "${candidates[@]}"; do
  if [ -x "$script_dir/$cand/simple" ] || [ -f "$script_dir/$cand/simple" ]; then
    runtime="$script_dir/$cand/simple"
    break
  fi
done

if [ -z "$runtime" ]; then
  echo "bin/release/simple: no platform binary found under $script_dir (tried: ${candidates[*]})" >&2
  exit 127
fi

chmod +x "$runtime" 2>/dev/null || true
exec "$runtime" "$@"
