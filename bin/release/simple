#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
if [ "${1:-}" = "spipe-mcp" ]; then
  shift
  exec "$repo_root/bin/spipe_mcp_server" "$@"
fi

runtime="$script_dir/x86_64-unknown-linux-gnu/simple"
if [ ! -x "$runtime" ]; then
  runtime="$repo_root/release/x86_64-unknown-linux-gnu/simple"
fi
chmod +x "$runtime" 2>/dev/null || true
exec "$runtime" "$@"
