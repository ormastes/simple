#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
runtime="$script_dir/x86_64-unknown-linux-gnu/simple"
if [ ! -x "$runtime" ]; then
  repo_root="$(cd "$script_dir/../.." && pwd)"
  runtime="$repo_root/release/x86_64-unknown-linux-gnu/simple"
fi
chmod +x "$runtime" 2>/dev/null || true
exec "$runtime" "$@"
