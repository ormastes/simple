#!/bin/sh
# MCP server wrapper for simple-mcp (Simple language compiler MCP).
# Sources shared startup library for compile cache, debug logging, runtime resolution.
set -eu
MCP_SERVER="simple_mcp"
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="${DIR}/${SELF}" ;; esac
done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
. "${REPO_ROOT}/config/mcp/mcp_startup_lib.sh"
cd "$REPO_ROOT"

mcp_debug_init
mcp_find_runtime

ENTRY="${REPO_ROOT}/src/app/mcp/main.spl"
SIMPLE_LIB_DIR="${REPO_ROOT}/src"

if [ "$MCP_DEBUG_ENABLED" = "1" ]; then
  mcp_log_line "$MCP_WRAPPER_LOG" "cwd=$(pwd) repo_root=$REPO_ROOT"
  mcp_log_line "$MCP_WRAPPER_LOG" "runtime_kind=$MCP_RUNTIME_KIND runtime=$MCP_RUNTIME"
  mcp_log_line "$MCP_WRAPPER_LOG" "entry=$ENTRY simple_lib=$SIMPLE_LIB_DIR"
fi

export SIMPLE_LIB="${REPO_ROOT}/src"
mcp_exec_cached "$ENTRY" "$SIMPLE_LIB_DIR" "$@"
