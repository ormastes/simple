#!/bin/sh
# MCP server wrapper for t32-lsp-mcp (TRACE32 CMM LSP via MCP).
# Sources shared startup library. Adds: native binary probe, daemon/tool-runner support.
set -eu
MCP_SERVER="t32_lsp_mcp"
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="${DIR}/${SELF}" ;; esac
done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
. "${REPO_ROOT}/config/mcp/mcp_startup_lib.sh"
cd "$REPO_ROOT"

mcp_debug_init

# --- Native binary support ---
PREFERRED_BINARY=""
if [ -x "${REPO_ROOT}/bin/release/t32_lsp_mcp_native" ]; then
  PREFERRED_BINARY="${REPO_ROOT}/bin/release/t32_lsp_mcp_native"
fi
NATIVE_REQUESTED=0
case "${T32_LSP_MCP_USE_NATIVE:-auto}" in
  0|false|FALSE|no|NO|off|OFF) NATIVE_REQUESTED=0 ;;
  *) if [ -n "$PREFERRED_BINARY" ]; then NATIVE_REQUESTED=1; fi ;;
esac

if [ "$NATIVE_REQUESTED" = "1" ] && [ -n "$PREFERRED_BINARY" ]; then
  mcp_native_health_check "$PREFERRED_BINARY"
  if [ "$MCP_NATIVE_HEALTHY" = "1" ]; then
    MCP_RUNTIME="$PREFERRED_BINARY"
    MCP_RUNTIME_KIND="native"
  fi
fi

if [ -z "${MCP_RUNTIME:-}" ] || [ "${MCP_RUNTIME_KIND:-}" != "native" ]; then
  mcp_find_runtime
fi

# --- Paths ---
TRACE32_ROOT="${REPO_ROOT}/examples/10_tooling/trace32_tools"
ENTRY="${TRACE32_ROOT}/t32_lsp_mcp/main.spl"
SOURCE_SIMPLE_LIB="${TRACE32_ROOT}"

# --- Daemon + tool runner (server-specific) ---
CWD_SEG="$(mcp_sanitize_segment "$(pwd)")"
if [ -z "$CWD_SEG" ]; then CWD_SEG="workspace"; fi
DAEMON_DIR="${T32_LSP_MCP_TOOL_DAEMON_DIR:-/tmp/t32_lsp_mcp_shared_${CWD_SEG}}"
CACHE_ROOT="${REPO_ROOT}/.simple/cache/${MCP_SERVER}"
TOOL_DAEMON_SOURCE="${TRACE32_ROOT}/cmm_lsp/mcp_daemon.spl"
TOOL_DAEMON_CACHE_FILE="${CACHE_ROOT}/mcp_daemon.smf"
TOOL_RUNNER_BIN_DEFAULT="${REPO_ROOT}/bin/release/t32_lsp_mcp_tool_runner"

export SIMPLE_RUNTIME="${SIMPLE_RUNTIME:-$MCP_RUNTIME}"
export T32_LSP_MCP_TOOL_RUNNER="${T32_LSP_MCP_TOOL_RUNNER:-examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner.spl}"
if [ -x "$TOOL_RUNNER_BIN_DEFAULT" ]; then
  export T32_LSP_MCP_TOOL_RUNNER_BIN="${T32_LSP_MCP_TOOL_RUNNER_BIN:-$TOOL_RUNNER_BIN_DEFAULT}"
fi
if [ -f "$TOOL_DAEMON_CACHE_FILE" ]; then
  export T32_LSP_MCP_TOOL_DAEMON="${T32_LSP_MCP_TOOL_DAEMON:-$TOOL_DAEMON_CACHE_FILE}"
else
  export T32_LSP_MCP_TOOL_DAEMON="${T32_LSP_MCP_TOOL_DAEMON:-$TOOL_DAEMON_SOURCE}"
fi
export T32_LSP_MCP_TOOL_DAEMON_DIR="$DAEMON_DIR"

# --- Debug logging ---
if [ "$MCP_DEBUG_ENABLED" = "1" ]; then
  mcp_log_line "$MCP_WRAPPER_LOG" "cwd=$(pwd) repo_root=$REPO_ROOT"
  mcp_log_line "$MCP_WRAPPER_LOG" "runtime_kind=$MCP_RUNTIME_KIND runtime=$MCP_RUNTIME"
  if [ "$NATIVE_REQUESTED" = "1" ] && [ -n "$PREFERRED_BINARY" ]; then
    mcp_log_line "$MCP_WRAPPER_LOG" "native_preferred=1 native_binary=$PREFERRED_BINARY native_healthy=$MCP_NATIVE_HEALTHY"
  else
    mcp_log_line "$MCP_WRAPPER_LOG" "native_preferred=0"
  fi
  mcp_log_line "$MCP_WRAPPER_LOG" "entry=$ENTRY daemon_cache=$TOOL_DAEMON_CACHE_FILE runner_bin=${T32_LSP_MCP_TOOL_RUNNER_BIN:-}"
  export T32_LSP_MCP_DEBUG_FILE="$MCP_FRONTEND_LOG"
  export T32_LSP_MCP_REQUEST_LOG="$MCP_REQUESTS_LOG"
  export T32_LSP_MCP_ERROR_LOG="$MCP_ERROR_LOG"
fi

# Native binary: exec directly
if [ "${MCP_RUNTIME_KIND:-}" = "native" ]; then
  T32_LSP_MCP_STDERR_LOG="${REPO_ROOT}/.simple/logs/t32_lsp_mcp_stderr.log"
  mkdir -p "$(dirname "$T32_LSP_MCP_STDERR_LOG")"
  if [ "$MCP_DEBUG_ENABLED" = "1" ]; then
    mcp_log_line "$MCP_WRAPPER_LOG" "request_routing=native"
    exec "$MCP_RUNTIME" "$@" 2>>"$MCP_ERROR_LOG"
  fi
  exec "$MCP_RUNTIME" "$@" 2>>"$T32_LSP_MCP_STDERR_LOG"
fi

# Interpreter: compile + exec cached
export SIMPLE_LIB="${SIMPLE_LIB:-$SOURCE_SIMPLE_LIB}"
mcp_exec_cached "$ENTRY" "$SOURCE_SIMPLE_LIB" "$@"
