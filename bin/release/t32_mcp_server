#!/bin/sh
# Unified MCP launcher delegation — see tools/mcp-launcher/
SELF="$0"; while [ -L "$SELF" ]; do DIR="$(cd "$(dirname "$SELF")" && pwd)"; SELF="$(readlink "$SELF")"; case "$SELF" in /*) ;; *) SELF="${DIR}/${SELF}" ;; esac; done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
exec node "${SCRIPT_DIR}/../../tools/mcp-launcher/bin/mcp-launch.js" --server=t32-mcp "$@"
