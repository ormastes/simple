#!/bin/sh
# MCP server wrapper for t32-mcp (TRACE32 debugger MCP).
# Sources shared startup library. Adds: native binary probe, cold/full frontend modes.
set -eu
MCP_SERVER="t32_mcp"
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="${DIR}/${SELF}" ;; esac
done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
. "${REPO_ROOT}/config/mcp/mcp_startup_lib.sh"
cd "$REPO_ROOT"

mcp_debug_init

# --- Native binary support ---
PREFERRED_BINARY=""
if [ -x "${REPO_ROOT}/bin/release/t32_mcp_native" ]; then
  PREFERRED_BINARY="${REPO_ROOT}/bin/release/t32_mcp_native"
fi
HOST_KERNEL="$(uname -s 2>/dev/null || echo unknown)"
NATIVE_REQUESTED=0
case "${T32_MCP_USE_NATIVE:-auto}" in
  0|false|FALSE|no|NO|off|OFF) NATIVE_REQUESTED=0 ;;
  *) if [ -n "$PREFERRED_BINARY" ] || [ "$HOST_KERNEL" = "FreeBSD" ]; then NATIVE_REQUESTED=1; fi ;;
esac

if [ "$NATIVE_REQUESTED" = "1" ] && [ -n "$PREFERRED_BINARY" ]; then
  mcp_native_health_check "$PREFERRED_BINARY"
  if [ "$MCP_NATIVE_HEALTHY" = "1" ]; then
    MCP_RUNTIME="$PREFERRED_BINARY"
    MCP_RUNTIME_KIND="native"
  fi
fi

# Fall back to interpreter runtime if native not used
if [ -z "${MCP_RUNTIME:-}" ] || [ "${MCP_RUNTIME_KIND:-}" != "native" ]; then
  mcp_find_runtime
fi

# --- Frontend mode (cold/full) ---
T32_MCP_FRONTEND="${T32_MCP_FRONTEND:-full}"
TRACE32_ROOT="${REPO_ROOT}/examples/10_tooling/trace32_tools"
COLD_ENTRY="${TRACE32_ROOT}/t32_mcp/frontend_cold.spl"
FULL_ENTRY="${TRACE32_ROOT}/t32_mcp/main.spl"

case "$T32_MCP_FRONTEND" in
  full) SOURCE_ENTRY="$FULL_ENTRY" ;;
  *)    SOURCE_ENTRY="$COLD_ENTRY" ;;
esac
SOURCE_SIMPLE_LIB="${TRACE32_ROOT}"

export SIMPLE_LOG=error
export SIMPLE_TIMEOUT_SECONDS=86400
export SIMPLE_MEMORY_LIMIT_MB=${SIMPLE_MEMORY_LIMIT_MB:-${SIMPLE_TEST_MEMORY_LIMIT_MB:-100}}

# --- Debug logging ---
if [ "$MCP_DEBUG_ENABLED" = "1" ]; then
  mcp_log_line "$MCP_WRAPPER_LOG" "cwd=$(pwd) repo_root=$REPO_ROOT"
  mcp_log_line "$MCP_WRAPPER_LOG" "runtime_kind=$MCP_RUNTIME_KIND runtime=$MCP_RUNTIME"
  if [ "$NATIVE_REQUESTED" = "1" ] && [ -n "$PREFERRED_BINARY" ]; then
    mcp_log_line "$MCP_WRAPPER_LOG" "native_preferred=1 native_binary=$PREFERRED_BINARY native_healthy=$MCP_NATIVE_HEALTHY"
  else
    mcp_log_line "$MCP_WRAPPER_LOG" "native_preferred=0"
  fi
  mcp_log_line "$MCP_WRAPPER_LOG" "frontend_mode=$T32_MCP_FRONTEND entry=$SOURCE_ENTRY"
  export T32_MCP_DEBUG=1
  export T32_MCP_DEBUG_FILE="$MCP_FRONTEND_LOG"
fi

# Native binary: exec directly (no compile cache needed)
if [ "$MCP_RUNTIME_KIND" = "native" ]; then
  T32_MCP_STDERR_LOG="${REPO_ROOT}/.simple/logs/t32_mcp_stderr.log"
  mkdir -p "$(dirname "$T32_MCP_STDERR_LOG")"
  if [ "$MCP_DEBUG_ENABLED" = "1" ]; then
    mcp_log_line "$MCP_WRAPPER_LOG" "request_routing=native"
    exec "$MCP_RUNTIME" "$@" 2>>"$MCP_ERROR_LOG"
  fi
  exec "$MCP_RUNTIME" "$@" 2>>"$T32_MCP_STDERR_LOG"
fi

# Interpreter: compile + exec cached
mcp_exec_cached "$SOURCE_ENTRY" "$SOURCE_SIMPLE_LIB" "$@"
