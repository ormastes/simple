#!/bin/bash
# Simple language LSP wrapper for local editor/plugin clients.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
ENTRY="${SCRIPT_DIR}/../src/app/lsp/main.spl"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/linux-x86_64/simple"
fi

export SIMPLE_LIB="${SCRIPT_DIR}/../src"
export SIMPLE_LOG=error

RUST_LOG=error exec "$RUNTIME" run "$ENTRY" "$@" 2>/dev/null
