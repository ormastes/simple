#!/bin/bash
# Obsidian MCP wrapper for local clients.
# Modes:
#   bridge (default) -> examples/obsidian-search/src/main_bridge.spl
#   mcp              -> examples/obsidian-search/src/main.spl

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE_TARGET="$(readlink "$SOURCE")"
  if [[ "$SOURCE_TARGET" != /* ]]; then
    SOURCE="${SOURCE_DIR}/${SOURCE_TARGET}"
  else
    SOURCE="$SOURCE_TARGET"
  fi
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
RUNTIME="${REPO_ROOT}/src/compiler_rust/target/release/simple"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple_host"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple_native"
fi

export SIMPLE_LIB="${REPO_ROOT}/examples/obsidian-search/src:${REPO_ROOT}/src"
export SIMPLE_BINARY="$RUNTIME"
export SIMPLE_LOG="${SIMPLE_LOG:-error}"
unset DEBUG SIMPLE_TEST_DEBUG REPL_DEBUG

MODE="${1:-bridge}"
if [ "$#" -gt 0 ]; then
  case "$MODE" in
    bridge|mcp)
      shift
      ;;
    *)
      MODE="bridge"
      ;;
  esac
fi

if [ "$MODE" = "mcp" ]; then
  ENTRY_SOURCE="${REPO_ROOT}/examples/obsidian-search/src/main.spl"
  CACHE_NAME="obsidian-mcp.smf"
else
  ENTRY_SOURCE="${REPO_ROOT}/examples/obsidian-search/src/main_bridge.spl"
  CACHE_NAME="obsidian-bridge.smf"
fi

cd "$REPO_ROOT"
RUST_LOG=error exec "$RUNTIME" "$ENTRY_SOURCE" "$@" 2>/dev/null
