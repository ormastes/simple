#!/bin/bash
# Simple LSP MCP Server
# Entry point: src/app/simple_lsp_mcp/main.spl

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/simple"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple.exe"
fi

ENTRY="${SCRIPT_DIR}/../src/app/simple_lsp_mcp/main.spl"

export SIMPLE_LIB="${SCRIPT_DIR}/../src"
export SIMPLE_BINARY="$RUNTIME"
export SIMPLE_LOG=error

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@"
