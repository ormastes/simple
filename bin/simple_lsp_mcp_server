#!/bin/bash
# Simple-native wrapper for the minimal LSP MCP server.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
ENTRY="${SCRIPT_DIR}/../src/app/simple_lsp_mcp/main.spl"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_host"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_native"
fi

export SIMPLE_LIB="${SCRIPT_DIR}/../src"
export SIMPLE_BINARY="$RUNTIME"
export SIMPLE_LOG=error
unset DEBUG SIMPLE_TEST_DEBUG REPL_DEBUG

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
