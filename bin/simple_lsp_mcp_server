#!/usr/bin/env python3
"""Minimal MCP wrapper for Simple LSP-style code intelligence tools.

Supports both Content-Length framed stdio and raw JSON stdio so it can work
with Codex-style MCP clients and Claude's local MCP health checks.
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any


SCRIPT_DIR = Path(__file__).resolve().parent
SIMPLE_BIN = SCRIPT_DIR / "release" / "simple"
if not SIMPLE_BIN.exists():
    SIMPLE_BIN = SCRIPT_DIR / "release" / "linux-x86_64" / "simple"
LSP_QUERY = SCRIPT_DIR.parent / "src" / "app" / "lsp" / "lsp_query.spl"

TOOLS = [
    {
        "name": "lsp_definition",
        "description": "Find where a symbol is defined in a Simple source file.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "file": {"type": "string", "description": "Path to the source file"},
                "line": {"type": "integer", "description": "0-indexed line number"},
                "character": {
                    "type": "integer",
                    "description": "0-indexed character offset",
                },
            },
            "required": ["file", "line", "character"],
        },
    },
    {
        "name": "lsp_references",
        "description": "Find symbol references in Simple source.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "file": {"type": "string", "description": "Path to the source file"},
                "line": {"type": "integer", "description": "0-indexed line number"},
                "character": {
                    "type": "integer",
                    "description": "0-indexed character offset",
                },
            },
            "required": ["file", "line", "character"],
        },
    },
    {
        "name": "lsp_hover",
        "description": "Get hover information for a symbol in Simple source.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "file": {"type": "string", "description": "Path to the source file"},
                "line": {"type": "integer", "description": "0-indexed line number"},
                "character": {
                    "type": "integer",
                    "description": "0-indexed character offset",
                },
            },
            "required": ["file", "line", "character"],
        },
    },
    {
        "name": "lsp_symbols",
        "description": "List symbols in a Simple source file.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "file": {"type": "string", "description": "Path to the source file"}
            },
            "required": ["file"],
        },
    },
    {
        "name": "lsp_diagnostics",
        "description": "Run lightweight diagnostics via simple lint.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "file": {"type": "string", "description": "Path to the source file"}
            },
            "required": ["file"],
        },
    },
]

SERVER_INFO = {
    "protocolVersion": "2025-06-18",
    "capabilities": {"tools": {"listChanged": False}},
    "serverInfo": {
        "name": "simple-lsp-mcp",
        "version": "0.1.0-mvp",
        "instructions": (
            "Minimal Simple LSP MCP shim backed by lsp_query.spl and simple lint."
        ),
    },
}

transport_mode = "framed"
buffer = bytearray()
decoder = json.JSONDecoder()


def write_message(body: dict[str, Any]) -> None:
    payload = json.dumps(body, separators=(",", ":")).encode()
    if transport_mode == "raw":
        sys.stdout.write(payload.decode() + "\n")
        sys.stdout.flush()
        return
    sys.stdout.buffer.write(f"Content-Length: {len(payload)}\r\n\r\n".encode())
    sys.stdout.buffer.write(payload)
    sys.stdout.buffer.flush()


def _read_more() -> bool:
    chunk = sys.stdin.buffer.read1(4096)
    if not chunk:
        return False
    buffer.extend(chunk)
    return True


def _read_framed() -> dict[str, Any] | None:
    while True:
        header_end = buffer.find(b"\r\n\r\n")
        if header_end == -1:
            if not _read_more():
                return None
            continue
        header = bytes(buffer[:header_end]).decode(errors="replace")
        content_length = None
        for line in header.split("\r\n"):
            if line.lower().startswith("content-length:"):
                content_length = int(line.split(":", 1)[1].strip())
                break
        if content_length is None:
            return None
        total_needed = header_end + 4 + content_length
        while len(buffer) < total_needed:
            if not _read_more():
                return None
        payload = bytes(buffer[header_end + 4 : total_needed])
        del buffer[:total_needed]
        return json.loads(payload.decode())


def _read_raw() -> dict[str, Any] | None:
    while True:
        while buffer[:1] in (b" ", b"\n", b"\r", b"\t"):
            del buffer[:1]
        if not buffer:
            if not _read_more():
                return None
            continue
        try:
            text = buffer.decode()
            obj, idx = decoder.raw_decode(text)
            del buffer[:idx]
            return obj
        except json.JSONDecodeError:
            if not _read_more():
                return None


def read_message() -> dict[str, Any] | None:
    global transport_mode
    while not buffer:
        if not _read_more():
            return None
    probe = bytes(buffer[:32]).lstrip()
    if probe.startswith(b"{"):
        transport_mode = "raw"
        return _read_raw()
    transport_mode = "framed"
    return _read_framed()


def json_result(msg_id: Any, result: Any) -> dict[str, Any]:
    return {"jsonrpc": "2.0", "id": msg_id, "result": result}


def json_error(msg_id: Any, code: int, message: str) -> dict[str, Any]:
    return {"jsonrpc": "2.0", "id": msg_id, "error": {"code": code, "message": message}}


def tool_text_result(msg_id: Any, text: str) -> dict[str, Any]:
    return json_result(msg_id, {"content": [{"type": "text", "text": text}]})


def run_command(args: list[str]) -> str:
    env = os.environ.copy()
    proc = subprocess.run(
        args,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        env=env,
        check=False,
    )
    return proc.stdout.rstrip("\n")


def run_lsp_query(subcmd: str, file: str, line0: int = 0, char0: int = 0) -> str:
    return run_command(
        [
            str(SIMPLE_BIN),
            str(LSP_QUERY),
            subcmd,
            file,
            str(line0 + 1),
            str(char0 + 1),
        ]
    )


def run_lsp_symbols(file: str) -> str:
    return run_command([str(SIMPLE_BIN), str(LSP_QUERY), "symbols", file])


def run_lsp_diagnostics(file: str) -> str:
    return run_command([str(SIMPLE_BIN), "lint", file])


def handle_tool_call(msg_id: Any, req: dict[str, Any]) -> dict[str, Any]:
    params = req.get("params", {})
    args = params.get("arguments", {})
    name = params.get("name") or req.get("name", "")

    if name == "lsp_definition":
        return tool_text_result(
            msg_id,
            run_lsp_query(
                "definition", args.get("file", ""), int(args.get("line", 0)), int(args.get("character", 0))
            ),
        )
    if name == "lsp_references":
        return tool_text_result(
            msg_id,
            run_lsp_query(
                "references", args.get("file", ""), int(args.get("line", 0)), int(args.get("character", 0))
            ),
        )
    if name == "lsp_hover":
        return tool_text_result(
            msg_id,
            run_lsp_query(
                "hover", args.get("file", ""), int(args.get("line", 0)), int(args.get("character", 0))
            ),
        )
    if name == "lsp_symbols":
        return tool_text_result(msg_id, run_lsp_symbols(args.get("file", "")))
    if name == "lsp_diagnostics":
        return tool_text_result(msg_id, run_lsp_diagnostics(args.get("file", "")))
    return json_error(msg_id, -32602, f"Unknown tool: {name}")


def main() -> int:
    while True:
        req = read_message()
        if req is None:
            return 0
        method = req.get("method", "")
        msg_id = req.get("id")

        if method == "initialize":
            write_message(json_result(msg_id, SERVER_INFO))
        elif method in {
            "initialized",
            "notifications/initialized",
            "notifications/cancelled",
            "notifications/roots/list_changed",
        }:
            continue
        elif method == "shutdown":
            write_message(json_result(msg_id, None))
        elif method == "ping":
            write_message(json_result(msg_id, {}))
        elif method == "tools/list":
            write_message(json_result(msg_id, {"tools": TOOLS}))
        elif method == "tools/call":
            write_message(handle_tool_call(msg_id, req))
        else:
            write_message(json_error(msg_id, -32601, f"Method not found: {method}"))


if __name__ == "__main__":
    raise SystemExit(main())
