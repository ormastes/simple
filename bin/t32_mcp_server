#!/bin/bash
# TRACE32 MCP wrapper for local MCP clients.
# Use the checked-in release runtime and suppress stderr so runtime/debug
# output does not corrupt the stdio MCP transport.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
ENTRY="${SCRIPT_DIR}/../examples/10_tooling/trace32_tools/t32_mcp/main.spl"
REPO_ROOT="${SCRIPT_DIR}/.."
TRACE32_ROOT="${REPO_ROOT}/examples/10_tooling/trace32_tools"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_host"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_native"
fi

cd "$REPO_ROOT"

# T32 MCP spans two module roots:
# - app.mcp_t32.* lives under repo-root/src via fallback src resolution
# - cmm_lsp.* lives under examples/10_tooling/trace32_tools via SIMPLE_LIB
export SIMPLE_LIB="$TRACE32_ROOT"
export SIMPLE_LOG=error
unset DEBUG SIMPLE_TEST_DEBUG REPL_DEBUG

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
