#!/bin/bash
# Direct T32 MCP launcher — skips .spl intermediate layer
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
[ ! -x "$RUNTIME" ] && RUNTIME="${SCRIPT_DIR}/release/linux-x86_64/simple"
export SIMPLE_LIB="${PROJECT_ROOT}/src"
export SIMPLE_LOG=error
export RUST_LOG=error
exec "$RUNTIME" "${PROJECT_ROOT}/examples/10_tooling/trace32_tools/t32_mcp/main.spl" "$@"
