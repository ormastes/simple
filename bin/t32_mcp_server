#!/bin/bash
# TRACE32 MCP wrapper for local Codex/Cursor-style MCP clients.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
ENTRY="${SCRIPT_DIR}/../examples/10_tooling/trace32_tools/t32_mcp/main.spl"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/linux-x86_64/simple"
fi

export SIMPLE_LIB="${SCRIPT_DIR}/../src"
export SIMPLE_LOG=error

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
