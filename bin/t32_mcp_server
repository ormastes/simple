#!/bin/bash
# TRACE32 MCP Server
# Entry point: examples/10_tooling/trace32_tools/t32_mcp/main.spl

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}/.."
RUNTIME="${SCRIPT_DIR}/simple"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple.exe"
fi

ENTRY="${REPO_ROOT}/examples/10_tooling/trace32_tools/t32_mcp/main.spl"
TRACE32_ROOT="${REPO_ROOT}/examples/10_tooling/trace32_tools"

cd "$REPO_ROOT"
export SIMPLE_LIB="$TRACE32_ROOT"
export SIMPLE_LOG=error

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
