#!/bin/sh
# Thin wrapper: `bin/jira ...` == `bin/itf jira ...`.
#
# The old bin/jira -> ../tools/jira-cli/bin/jira symlink was broken
# (tools/jira-cli/ does not exist). itf's jira support (acli-backed, with a
# curl REST fallback) is the real implementation; this just forwards to it
# so muscle-memory `bin/jira ...` invocations keep working.
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
exec "${SCRIPT_DIR}/itf" jira "$@"
