#!/bin/bash
# TRACE32 CMM LSP MCP wrapper for local Codex/Cursor-style MCP clients.
# Uses the checked-in release runtime with the working source-backed entrypoint.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
ENTRY="${SCRIPT_DIR}/../examples/10_tooling/trace32_tools/t32_lsp_mcp/main.spl"
REPO_ROOT="${SCRIPT_DIR}/.."
TRACE32_ROOT="${REPO_ROOT}/examples/10_tooling/trace32_tools"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_host"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_native"
fi

cd "$REPO_ROOT"

# The T32 LSP MCP server resolves local t32_lsp_mcp.* modules from the entry
# directory and cmm_lsp.* from the TRACE32 tooling root via SIMPLE_LIB.
export SIMPLE_LIB="$TRACE32_ROOT"
export SIMPLE_RUNTIME="$RUNTIME"
export T32_LSP_MCP_TOOL_RUNNER="examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner.spl"
export SIMPLE_LOG=error
unset DEBUG SIMPLE_TEST_DEBUG REPL_DEBUG

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
