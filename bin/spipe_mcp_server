#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "${script_dir}/.." && pwd)

: "${SIMPLE_LOG:=error}"
: "${RUST_LOG:=error}"
export SIMPLE_LOG RUST_LOG

if [ "$#" -eq 0 ] || [ "${1:-}" = "serve" ]; then
  if [ "${SIMPLE_SPIPE_MCP_PREFER_NATIVE_SERVE:-}" != "1" ]; then
    exec "${script_dir}/release/simple" run "${repo_root}/src/app/spipe_mcp/main.spl" "$@"
  fi
fi

if [ "${SIMPLE_SPIPE_MCP_BINARY:-}" != "" ] && [ -x "${SIMPLE_SPIPE_MCP_BINARY}" ]; then
  exec "${SIMPLE_SPIPE_MCP_BINARY}" "$@"
fi

for native in \
  "${repo_root}/build/bootstrap/mcp-package/spipe_mcp" \
  "${script_dir}/release/x86_64-unknown-linux-gnu/spipe_mcp" \
  "${script_dir}/release/linux-x86_64/spipe_mcp"
do
  if [ -x "${native}" ]; then
    exec "${native}" "$@"
  fi
done

exec "${script_dir}/release/simple" run "${repo_root}/src/app/spipe_mcp/main.spl" "$@"
