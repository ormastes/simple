#!/bin/bash
# Simple MCP wrapper for local MCP clients.
# Use the checked-in release runtime and suppress stderr so runtime debug noise
# cannot corrupt the stdio MCP transport.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
ENTRY="${SCRIPT_DIR}/../src/app/mcp/main.spl"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_host"
fi

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/release/simple_native"
fi

export SIMPLE_LIB="${SCRIPT_DIR}/../src"
export SIMPLE_LOG=error
unset DEBUG SIMPLE_TEST_DEBUG REPL_DEBUG

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
