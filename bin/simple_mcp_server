#!/bin/bash
# Simple MCP Server — Full-featured (33 tools)
# Entry point: src/app/mcp/main.spl

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/simple"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple.exe"
fi

ENTRY="${SCRIPT_DIR}/../src/app/mcp/main.spl"

export SIMPLE_LIB="${SCRIPT_DIR}/../src"
export SIMPLE_LOG=error

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
