#!/bin/bash
# Simple MCP Server — runs the full-featured Pure Simple MCP server.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/release/simple"
if [ ! -x "$RUNTIME" ]; then
    RUNTIME="${SCRIPT_DIR}/release/linux-x86_64/simple"
fi
SIMPLE_LOG=error RUST_LOG=error exec "$RUNTIME" "${SCRIPT_DIR}/../src/app/mcp/main.spl" "$@"
