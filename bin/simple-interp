#!/bin/sh
# Interpreter-mode wrapper pinned to the deployed Simple binary.
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
for runtime in \
  "${script_dir}/simple" \
  "${script_dir}/release/simple" \
  "${script_dir}/release/x86_64-unknown-linux-gnu/simple" \
  "${script_dir}/release/linux-x86_64/simple"
do
  if [ -x "$runtime" ]; then
    exec "$runtime" "$@"
  fi
done
printf '%s\n' "error: no Simple runtime found under ${script_dir}" >&2
exit 127
