#!/bin/sh
# Thin wrapper: maps the bug_review skill's documented subcommands onto
# `bin/itf github issue ...`.
#
# The old bin/bug -> ../tools/bug-cli/bin/bug symlink was broken
# (tools/bug-cli/ does not exist). The bug_review skill's full contract
# (triage --limit N with severity/component classification, fix <id> with a
# proposed patch) needs LLM-driven analysis that doesn't belong in a shell
# wrapper — run the /bug_review skill directly for those. This wrapper
# covers the raw-data subcommands (list/view) honestly and says so for the
# rest, instead of pretending to implement them.
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ITF="${SCRIPT_DIR}/itf"

sub="${1:-}"
case "${sub}" in
  list)
    shift
    exec "${ITF}" github issue list --label bug "$@"
    ;;
  view)
    shift
    if [ -z "${1:-}" ]; then
      echo "usage: bug view <number>" >&2
      exit 2
    fi
    exec "${ITF}" github issue view "$@"
    ;;
  triage|fix)
    {
      echo "not yet supported: bug ${sub}"
      echo "this needs the AI-assisted analysis in the bug_review skill"
      echo "(severity/component triage, pattern grouping, fix-patch proposal)"
      echo "— that doesn't belong in a shell wrapper. Run the /bug_review"
      echo "skill directly, or use 'bug list' / 'bug view <number>' for the"
      echo "raw issue data."
    } >&2
    exit 1
    ;;
  -h|--help|help|"")
    cat <<'EOF'
Usage: bug <command> [args]

Commands:
  list            List open bugs (itf github issue list --label bug)
  view <number>   View a bug (itf github issue view <number>)

Not yet supported here (use the /bug_review skill instead):
  triage, fix
EOF
    ;;
  *)
    echo "unknown bug command: ${sub}" >&2
    echo "run 'bug --help' for usage" >&2
    exit 1
    ;;
esac
