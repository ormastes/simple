# Shell File Redirection
#
# Handles: > (write), >> (append), < (input), 2> (stderr), 2>> (stderr append)
# Parses redirection operators from command lines and applies/restores
# file descriptor redirections around command execution.
#
# MDSOC: feature dimension, shell layer

use os.posix.fd_io.{posix_open, posix_close, posix_dup, posix_dup2}
use os.posix.fd_table.{O_RDONLY, O_WRONLY, O_CREAT, O_TRUNC, O_APPEND}

# ============================================================================
# Redirect Types
# ============================================================================

enum RedirectType:
    """Type of I/O redirection."""
    OutputWrite       # >
    OutputAppend      # >>
    Input             # <
    ErrorWrite        # 2>
    ErrorAppend       # 2>>

# ============================================================================
# Redirect
# ============================================================================

struct Redirect:
    """A single I/O redirection."""
    type_: RedirectType
    file: text

impl Redirect:
    fn target_fd() -> i32:
        """Return the FD number this redirect targets."""
        match self.type_:
            RedirectType.OutputWrite: 1
            RedirectType.OutputAppend: 1
            RedirectType.Input: 0
            RedirectType.ErrorWrite: 2
            RedirectType.ErrorAppend: 2

    fn open_flags() -> u32:
        """Return the POSIX open flags for this redirect."""
        match self.type_:
            RedirectType.OutputWrite: O_WRONLY | O_CREAT | O_TRUNC
            RedirectType.OutputAppend: O_WRONLY | O_CREAT | O_APPEND
            RedirectType.Input: O_RDONLY
            RedirectType.ErrorWrite: O_WRONLY | O_CREAT | O_TRUNC
            RedirectType.ErrorAppend: O_WRONLY | O_CREAT | O_APPEND

# ============================================================================
# Parsed Command
# ============================================================================

struct ParsedCommand:
    """Command with redirections extracted."""
    command: text
    args: [text]
    redirects: [Redirect]
    background: bool

impl ParsedCommand:
    fn full_command_line() -> text:
        """Reconstruct the command line without redirections."""
        var result = self.command
        var i = 0
        while i < self.args.len():
            result = "{result} {self.args[i]}"
            i = i + 1
        result

# ============================================================================
# Saved FD State
# ============================================================================

struct SavedFd:
    """A saved file descriptor for restoration after redirect."""
    original_fd: i32
    saved_copy: i32

# ============================================================================
# Parsing
# ============================================================================

fn parse_redirects(tokens: [text]) -> ParsedCommand:
    """Parse token list, extract redirections and background flag.

    Processes tokens sequentially:
    - '>' followed by filename -> OutputWrite
    - '>>' followed by filename -> OutputAppend
    - '<' followed by filename -> Input
    - '2>' followed by filename -> ErrorWrite
    - '2>>' followed by filename -> ErrorAppend
    - Trailing '&' -> background flag
    - All other tokens are command/args
    """
    var command: text = ""
    var args: [text] = []
    var redirects: [Redirect] = []
    var background = false

    var i: u64 = 0
    while i < tokens.len():
        val token = tokens[i]

        # Check for background flag (trailing &)
        if token == "&" and i == tokens.len() - 1:
            background = true
            i = i + 1
            continue

        # Check for 2>> (stderr append)
        if token == "2>>" and i + 1 < tokens.len():
            val file = tokens[i + 1]
            redirects = redirects.push(Redirect(type_: RedirectType.ErrorAppend, file: file))
            i = i + 2
            continue

        # Check for 2> (stderr write)
        if token == "2>" and i + 1 < tokens.len():
            val file = tokens[i + 1]
            redirects = redirects.push(Redirect(type_: RedirectType.ErrorWrite, file: file))
            i = i + 2
            continue

        # Check for >> (output append)
        if token == ">>" and i + 1 < tokens.len():
            val file = tokens[i + 1]
            redirects = redirects.push(Redirect(type_: RedirectType.OutputAppend, file: file))
            i = i + 2
            continue

        # Check for > (output write)
        if token == ">" and i + 1 < tokens.len():
            val file = tokens[i + 1]
            redirects = redirects.push(Redirect(type_: RedirectType.OutputWrite, file: file))
            i = i + 2
            continue

        # Check for < (input)
        if token == "<" and i + 1 < tokens.len():
            val file = tokens[i + 1]
            redirects = redirects.push(Redirect(type_: RedirectType.Input, file: file))
            i = i + 2
            continue

        # Check for tokens that start with > (e.g., ">file" without space)
        if token.starts_with(">>"):
            val file = token.slice(2, token.len())
            if file != "":
                redirects = redirects.push(Redirect(type_: RedirectType.OutputAppend, file: file))
                i = i + 1
                continue

        if token.starts_with(">") and not token.starts_with(">>"):
            val file = token.slice(1, token.len())
            if file != "":
                redirects = redirects.push(Redirect(type_: RedirectType.OutputWrite, file: file))
                i = i + 1
                continue

        if token.starts_with("<"):
            val file = token.slice(1, token.len())
            if file != "":
                redirects = redirects.push(Redirect(type_: RedirectType.Input, file: file))
                i = i + 1
                continue

        # Regular token: first is command, rest are args
        if command == "":
            command = token
        else:
            args = args.push(token)

        i = i + 1

    ParsedCommand(
        command: command,
        args: args,
        redirects: redirects,
        background: background
    )

# ============================================================================
# Apply / Restore
# ============================================================================

fn apply_redirects(redirects: [Redirect]) -> Result<[SavedFd], text>:
    """Open redirect files and save original FDs for later restoration.

    For each redirect:
    1. Duplicate the target FD to save it
    2. Open the redirect file
    3. dup2 the opened file FD onto the target FD
    4. Close the intermediate FD

    Returns the list of saved FDs on success.
    """
    var saved: [SavedFd] = []
    var i: u64 = 0

    while i < redirects.len():
        val redir = redirects[i]
        val target = redir.target_fd()
        val flags = redir.open_flags()

        # Save original FD
        val saved_fd = posix_dup(target)
        if saved_fd < 0:
            # Restore any already-applied redirects
            restore_redirects(saved)
            return Err("redirect: failed to save fd {target}")

        # Open the file
        val file_fd = posix_open(redir.file, flags, 0o644)
        if file_fd < 0:
            # Restore saved FD and all previous
            posix_close(saved_fd)
            restore_redirects(saved)
            return Err("redirect: cannot open '{redir.file}'")

        # Redirect: point target FD to the opened file
        posix_dup2(file_fd, target)
        posix_close(file_fd)

        saved = saved.push(SavedFd(original_fd: target, saved_copy: saved_fd))
        i = i + 1

    Ok(saved)

fn restore_redirects(saved_fds: [SavedFd]):
    """Restore original FDs after command completes.

    For each saved FD, dup2 the saved copy back onto the original
    target FD, then close the saved copy.
    """
    var i: u64 = 0
    while i < saved_fds.len():
        val entry = saved_fds[i]
        posix_dup2(entry.saved_copy, entry.original_fd)
        posix_close(entry.saved_copy)
        i = i + 1
