# G11/G12/G13 syscall shims — split from syscall_shim.spl (Wave 10F, IF-01 Wave 1).
# Contains spl_handle_* for privilege (98), memory grant (99–102),
# brk (15), system_reboot (16), sys_mmap (103), sys_munmap (104),
# schedule (106), schedctl (107).

use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}
use os.kernel.ipc.syscall.{_handle_privctl}
use os.kernel.ipc.syscall.{_handle_mem_grant}
use os.kernel.ipc.syscall.{_handle_mem_revoke}
use os.kernel.ipc.syscall.{_handle_safecopy_from}
use os.kernel.ipc.syscall.{_handle_safecopy_to}
use os.kernel.ipc.syscall.{_handle_brk_for_task, _handle_system_reboot}
use os.kernel.ipc.syscall.{_handle_sys_mmap}
use os.kernel.ipc.syscall.{_handle_sys_munmap}
use os.kernel.ipc.syscall.{_handle_schedule}
use os.kernel.ipc.syscall.{_handle_schedctl}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.abi.syscall_shim.{g_shim_scheduler, _make_args}

# ============================================================================
# IF-01 Wave 1 — G11/G12 syscalls (2026-04-17)
# ============================================================================

# ===========================================================================
# syscall 98 — privctl   [IMPLEMENTED — G11]
#
# a0 = target_task (u32 task ID)
# a1 = op: PRIVCTL_SET_MASK(0)/GET_MASK(1)/ADD_PEER(2)/REMOVE_PEER(3)
# a2 = data (op-specific: peer id or kernel_calls bitmap)
# a3..a5 unused
# returns 0 or kernel_calls bitmap on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_privctl")
fn spl_handle_privctl(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_privctl stub.

    Forwards to _handle_privctl() in syscall.spl.
    Syscall number 98: read/write per-task kernel privilege mask.
    Requires SystemPrivilege capability.
    """
    val args = _make_args(98, a0, a1, a2, a3, a4, a5)
    val result = _handle_privctl(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 99 — mem_grant   [IMPLEMENTED — G12]
#
# a0 = grantee task ID (u32)
# a1 = vaddr — base virtual address in caller's space
# a2 = len — length in bytes
# a3 = flags — GRANT_R(1)/GRANT_W(2)/GRANT_RW(3)
# a4..a5 unused
# returns grant_id >= 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_mem_grant")
fn spl_handle_mem_grant(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_mem_grant stub.

    Forwards to _handle_mem_grant() in syscall.spl.
    Syscall number 99: create a temporary cross-task memory region grant.
    """
    val args = _make_args(99, a0, a1, a2, a3, a4, a5)
    val result = _handle_mem_grant(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 100 — mem_revoke   [IMPLEMENTED — G12]
#
# a0 = grant_id to revoke
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_mem_revoke")
fn spl_handle_mem_revoke(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_mem_revoke stub.

    Forwards to _handle_mem_revoke() in syscall.spl.
    Syscall number 100: revoke a previously issued memory grant.
    """
    val args = _make_args(100, a0, a1, a2, a3, a4, a5)
    val result = _handle_mem_revoke(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 101 — safecopy_from   [IMPLEMENTED — G12]
#
# a0 = src_task — grantor task ID (u32)
# a1 = grant_id
# a2 = src_off — byte offset within the granted region
# a3 = dst_vaddr — destination VA in caller's address space
# a4 = len — number of bytes to copy
# a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_safecopy_from")
fn spl_handle_safecopy_from(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_safecopy_from stub.

    Forwards to _handle_safecopy_from() in syscall.spl.
    Syscall number 101: bounds-checked copy from grantor's region.
    """
    val args = _make_args(101, a0, a1, a2, a3, a4, a5)
    val result = _handle_safecopy_from(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 102 — safecopy_to   [IMPLEMENTED — G12]
#
# a0 = dst_task — grantee task ID (u32)
# a1 = grant_id
# a2 = dst_off — byte offset within the granted region
# a3 = src_vaddr — source VA in caller's address space
# a4 = len — number of bytes to copy
# a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_safecopy_to")
fn spl_handle_safecopy_to(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_safecopy_to stub.

    Forwards to _handle_safecopy_to() in syscall.spl.
    Syscall number 102: bounds-checked copy to grantee's region.
    """
    val args = _make_args(102, a0, a1, a2, a3, a4, a5)
    val result = _handle_safecopy_to(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 15 — brk   [IMPLEMENTED — Kernel MVP]
#
# a0 = requested break, or 0 to query current break
# a1..a5 unused
# returns current/new break on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_brk")
fn spl_handle_brk(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_brk stub."""
    val args = _make_args(15, a0, a1, a2, a3, a4, a5)
    val result = _handle_brk_for_task(args, g_shim_scheduler.get_current().id)
    result.value

# ===========================================================================
# syscall 16 — system reboot
# ===========================================================================
@export("C", name: "spl_handle_system_reboot")
fn spl_handle_system_reboot(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_system_reboot stub."""
    val args = _make_args(16, a0, a1, a2, a3, a4, a5)
    val result = _handle_system_reboot(args)
    result.value

# ===========================================================================
# syscall 103 — sys_mmap   [IMPLEMENTED — G13]
#
# a0 = vaddr          — requested virtual address (0 = kernel picks)
# a1 = len            — length in bytes
# a2 = flags          — VMA_READ | VMA_WRITE | VMA_EXEC | VMA_COW (u32)
# a3 = kind           — VMA_ANON | VMA_FILE | VMA_SHARED (u32)
# a4 = backing        — file handle or 0 for anonymous
# a5 = backing_offset — byte offset into backing file
# returns mapped vaddr >= 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_sys_mmap")
fn spl_handle_sys_mmap(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_sys_mmap stub.

    Forwards to _handle_sys_mmap() in syscall.spl.
    Syscall number 103: map a virtual address range into the current task's space.
    """
    val args = _make_args(103, a0, a1, a2, a3, a4, a5)
    val result = _handle_sys_mmap(args)
    result.value

# ===========================================================================
# syscall 104 — sys_munmap   [IMPLEMENTED — G13]
#
# a0 = vaddr — start of region to unmap (page-aligned)
# a1 = len   — length in bytes
# a2..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_sys_munmap")
fn spl_handle_sys_munmap(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_sys_munmap stub.

    Forwards to _handle_sys_munmap() in syscall.spl.
    Syscall number 104: unmap a virtual address range from the current task's space.
    """
    val args = _make_args(104, a0, a1, a2, a3, a4, a5)
    val result = _handle_sys_munmap(args)
    result.value

# ===========================================================================
# syscall 106 — schedule   [IMPLEMENTED]
#
# a0 = op: 0 yield, 1 get current task id, 2 get tick count
# a1..a5 unused
# ===========================================================================
@export("C", name: "spl_handle_schedule")
fn spl_handle_schedule(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_schedule stub."""
    val args = _make_args(106, a0, a1, a2, a3, a4, a5)
    val result = _handle_schedule(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 107 — schedctl   [IMPLEMENTED]
#
# a0 = op: 0 query policy, 1 set policy metadata
# a1 = target task id
# a2 = policy code
# a3 = weight override
# a4 = requested slice ns override
# a5 = affinity mask override
# ===========================================================================
@export("C", name: "spl_handle_schedctl")
fn spl_handle_schedctl(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_schedctl stub."""
    val args = _make_args(107, a0, a1, a2, a3, a4, a5)
    val result = _handle_schedctl(args, g_shim_scheduler)
    result.value
