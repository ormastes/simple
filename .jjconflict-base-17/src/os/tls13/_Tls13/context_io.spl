extern fn rt_tls13_ed25519_verify(msg: [u8], pk: [u8], sig: [u8]) -> i64

# RFC 8446 record payloads are bounded; reject clearly invalid lengths
# before trying to allocate or read them from the transport.
val _TLS_MAX_RECORD_PAYLOAD: u64 = 18432
val _NETSTACK_PORT: u64 = 2
val _NET_SEND: u64 = 6
val _NET_RECV: u64 = 7

# ============================================================================
# Handshake message type constants (local copies from handshake13)
# ============================================================================

val _HS_ENCRYPTED_EXTENSIONS: u8 = 8
val _HS_CERTIFICATE: u8          = 11
val _HS_CERTIFICATE_REQUEST: u8  = 13
val _HS_CERTIFICATE_VERIFY: u8   = 15
val _HS_FINISHED: u8             = 20

# ============================================================================
# Data classes
# ============================================================================

class Tls13Context:
    io: Tls13Io
    server_key: RecordKey
    client_key: RecordKey
    server_seq: u64
    client_seq: u64
    # Session resumption state (RFC 8446 §4.6.1 + §7.1).
    # resumption_master_secret is derived after client Finished and stored here
    # so that any NewSessionTicket records arriving post-handshake can be
    # converted to StoredPsk entries via stored_psk_from_new_session_ticket.
    resumption_master_secret: [u8]
    hash_id: u8       # 1 = SHA-256, 2 = SHA-384
    cipher_suite: u16 # e.g. 0x1301 TLS_AES_128_GCM_SHA256
    tickets: [StoredPsk]

class Tls13RecvData:
    ctx: Tls13Context
    data: [u8]
    ok: bool
    reason: text

class Tls13SendResult:
    ctx: Tls13Context
    ok: bool
    reason: text

class Tls13CloseResult:
    ok: bool
    reason: text

enum Tls13ConnectResult:
    Connected(ctx: Tls13Context)
    Failed(reason: text)

class Tls13ClientConfig:
    client_cert_chain: [[u8]]
    client_pkcs8: [u8]
    client_sig_scheme: u16
    root_store: [[u8]]
    # Optional PSK / session resumption (RFC 8446 §2.2 + §4.2.11).
    # When offered_psk_count > 0 the client offers pre_shared_key + psk_key_exchange_modes
    # extensions. The actual binder MAC is computed at the partial-CH-emit site
    # (see tls13_compute_psk_binder + RFC 8446 §4.1.4).
    offered_psk_count: u32
    offered_psk_identity: [u8]      # Resumption ticket bytes or external label
    offered_psk_secret: [u8]        # Resumption_secret (HashLen bytes)
    offered_psk_age_ms: u32         # ticket_age in ms (raw, before age_add obfuscation)
    offered_psk_age_add: u32        # NewSessionTicket age_add value
    offered_psk_hash_id: u8         # 1=SHA-256, 2=SHA-384
    offered_psk_is_resumption: bool # true → "res binder", false → "ext binder"
    # 0-RTT (RFC 8446 §4.2.10) — empty body in client offer; server echoes
    # in EncryptedExtensions if accepted.
    offer_early_data: bool
    early_data_payload: [u8]        # Application data to send under client_early_traffic_secret

class Tls13Io:
    kind: text
    tcp_fd: i64
    host_stream: TcpStream

fn _tls_debug(msg: text):
    val _unused = msg.len()

fn _byte_buf(cap: u64) -> [u8]:
    rt_array_new_with_cap(cap.to_i64())

fn _push_byte(buf: [u8], byte_val: i64) -> [u8]:
    buf.push(byte_val.to_u8())
    buf

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _clone_bytes(buf: [u8]) -> [u8]:
    var out: [u8] = _byte_buf(buf.len())
    var i: u64 = 0
    while i < buf.len():
        out = _push_byte(out, _u8_at(buf, i).to_u64().to_i64())
        i = i + 1
    out

fn _copy_range(buf: [u8], start: u64, count: u64) -> [u8]:
    var out: [u8] = _byte_buf(count)
    var i: u64 = 0
    while i < count:
        out = _push_byte(out, _u8_at(buf, start + i).to_u64().to_i64())
        i = i + 1
    out

fn _append_bytes(a: [u8], b: [u8]) -> [u8]:
    var out: [u8] = _byte_buf(a.len() + b.len())
    var ai: u64 = 0
    while ai < a.len():
        out = _push_byte(out, _u8_at(a, ai).to_u64().to_i64())
        ai = ai + 1
    var i: u64 = 0
    while i < b.len():
        out = _push_byte(out, _u8_at(b, i).to_u64().to_i64())
        i = i + 1
    out

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if _u8_at(a, i) != _u8_at(b, i):
            return false
        i = i + 1
    true

# Constant-time byte compare for MAC/verify_data — RFC 8446 §4.4.4 advises
# implementations not to leak verify_data mismatch position via early-exit.
# We accumulate `acc |= a[i] ^ b[i]` over the full length and only branch on
# the final accumulator. Length-mismatch still returns false up front (length
# is not secret in TLS 1.3 Finished — verify_data length is fixed by the
# negotiated hash: 32 for SHA-256, 48 for SHA-384), but the byte-by-byte loop
# never short-circuits on the first differing byte.
#
# Cross-link (W7-B / W8-2 closeout): the byte-exact MAC round-trip remains
# blocked on `rt_tls13_sha256` / `rt_tls13_hkdf_expand_label_*` extern
# registration tracked under W8-6; this helper hardens the in-Simple compare
# path that runs for non-fd kinds today.
fn _tls13_ct_bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var acc: u8 = 0u8
    var i: u64 = 0
    while i < a.len():
        acc = acc | (_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    acc == 0u8

# Public test surface for `_tls13_ct_bytes_equal` — keeps the call sites
# private but lets the W8-2 closeout spec exercise CT-compare semantics
# (equal returns true, single-bit flip first/last returns false, length
# mismatch returns false) without having to drive a full handshake.
fn tls13_ct_bytes_equal(a: [u8], b: [u8]) -> bool:
    _tls13_ct_bytes_equal(a, b)

fn _debug_bytes4(label: text, buf: [u8]):
    if buf.len() >= 4:
        _tls_debug("{label} b0={_u8_at(buf, 0)} b1={_u8_at(buf, 1)} b2={_u8_at(buf, 2)} b3={_u8_at(buf, 3)} len={buf.len()}")
    else:
        _tls_debug("{label} short len={buf.len()}")

fn _debug_bytes32(label: text, buf: [u8]):
    if buf.len() < 32:
        _tls_debug("{label} short len={buf.len()}")
        return
    _tls_debug("{label} 0={_u8_at(buf, 0)} 1={_u8_at(buf, 1)} 2={_u8_at(buf, 2)} 3={_u8_at(buf, 3)} 4={_u8_at(buf, 4)} 5={_u8_at(buf, 5)} 6={_u8_at(buf, 6)} 7={_u8_at(buf, 7)}")
    _tls_debug("{label} 8={_u8_at(buf, 8)} 9={_u8_at(buf, 9)} 10={_u8_at(buf, 10)} 11={_u8_at(buf, 11)} 12={_u8_at(buf, 12)} 13={_u8_at(buf, 13)} 14={_u8_at(buf, 14)} 15={_u8_at(buf, 15)}")
    _tls_debug("{label} 16={_u8_at(buf, 16)} 17={_u8_at(buf, 17)} 18={_u8_at(buf, 18)} 19={_u8_at(buf, 19)} 20={_u8_at(buf, 20)} 21={_u8_at(buf, 21)} 22={_u8_at(buf, 22)} 23={_u8_at(buf, 23)}")
    _tls_debug("{label} 24={_u8_at(buf, 24)} 25={_u8_at(buf, 25)} 26={_u8_at(buf, 26)} 27={_u8_at(buf, 27)} 28={_u8_at(buf, 28)} 29={_u8_at(buf, 29)} 30={_u8_at(buf, 30)} 31={_u8_at(buf, 31)}")

fn _transcript_hash_fd(t: Transcript) -> [u8]:
    _clone_bytes(rt_tls13_sha256(t.buf))

fn _tls_label_bytes(label: text) -> [u8]:
    if label == "derived":
        return [0x64u8, 0x65u8, 0x72u8, 0x69u8, 0x76u8, 0x65u8, 0x64u8]
    if label == "key":
        return [0x6bu8, 0x65u8, 0x79u8]
    if label == "iv":
        return [0x69u8, 0x76u8]
    if label == "c hs traffic":
        return [0x63u8, 0x20u8, 0x68u8, 0x73u8, 0x20u8, 0x74u8, 0x72u8, 0x61u8, 0x66u8, 0x66u8, 0x69u8, 0x63u8]
    if label == "s hs traffic":
        return [0x73u8, 0x20u8, 0x68u8, 0x73u8, 0x20u8, 0x74u8, 0x72u8, 0x61u8, 0x66u8, 0x66u8, 0x69u8, 0x63u8]
    []

fn _tls13_traffic_keys_fd(traffic_secret: [u8]) -> TrafficKeys:
    val key = _copy_range(_clone_bytes(rt_tls13_hkdf_expand_label_key(traffic_secret)), 0, 16)
    val iv = _copy_range(_clone_bytes(rt_tls13_hkdf_expand_label_iv(traffic_secret)), 0, 12)
    TrafficKeys(key: key, iv: iv)

# ============================================================================
# TCP I/O helpers
# ============================================================================

fn _fd_io(fd: i64) -> Tls13Io:
    Tls13Io(kind: "fd", tcp_fd: fd, host_stream: TcpStream(fd: -1, open: false))

fn _host_stream_io(stream: TcpStream) -> Tls13Io:
    Tls13Io(kind: "host_stream", tcp_fd: -1, host_stream: stream)

fn _net_push_i32(dst: [u8], value: i32):
    val raw = value as u32
    dst = _push_byte(dst, (raw & 0xFF).to_i64())
    dst = _push_byte(dst, ((raw >> 8) & 0xFF).to_i64())
    dst = _push_byte(dst, ((raw >> 16) & 0xFF).to_i64())
    dst = _push_byte(dst, ((raw >> 24) & 0xFF).to_i64())

fn _net_push_u32(dst: [u8], value: u32):
    val raw = value
    dst = _push_byte(dst, (raw & 0xFF).to_i64())
    dst = _push_byte(dst, ((raw >> 8) & 0xFF).to_i64())
    dst = _push_byte(dst, ((raw >> 16) & 0xFF).to_i64())
    dst = _push_byte(dst, ((raw >> 24) & 0xFF).to_i64())

fn _net_read_i32(buf: [u8], offset: u64) -> i32:
    val b0 = buf[offset] as u32
    val b1 = buf[offset + 1] as u32
    val b2 = buf[offset + 2] as u32
    val b3 = buf[offset + 3] as u32
    (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) as i32

fn _net_send_direct(fd: i32, data: [u8]) -> Result<u64, text>:
    var payload: [u8] = _byte_buf(data.len() + 4)
    _net_push_i32(payload, fd)
    var i: u64 = 0
    while i < data.len():
        payload = _push_byte(payload, data[i].to_u64().to_i64())
        i = i + 1
    val send_rc = rt_ipc_send_bytes(_NETSTACK_PORT, _NET_SEND, payload)
    if send_rc < 0:
        return Err("ipc send failed")
    val reply = rt_ipc_recv_bytes(_NETSTACK_PORT, 64)
    _tls_debug("_net_send_direct reply_len={reply.len()}")
    if reply.len() < 4:
        return Err("short send reply")
    val status = _net_read_i32(reply, 0)
    _tls_debug("_net_send_direct status={status}")
    if status < 0:
        return Err("send failed status {status}")
    val wrote = if reply.len() >= 8: _net_read_i32(reply, 4) else: status
    _tls_debug("_net_send_direct wrote={wrote}")
    if wrote < 0:
        return Err("send failed value {wrote}")
    Ok(wrote.to_u64())

fn _net_recv_direct(fd: i32, max_len: u64) -> Result<[u8], text>:
    var payload: [u8] = _byte_buf(8)
    _net_push_i32(payload, fd)
    _net_push_u32(payload, max_len.to_u32())
    val send_rc = rt_ipc_send_bytes(_NETSTACK_PORT, _NET_RECV, payload)
    if send_rc < 0:
        return Err("ipc recv request failed")
    val reply = rt_ipc_recv_bytes(_NETSTACK_PORT, (max_len + 16).to_i64())
    _tls_debug("_net_recv_direct reply_len={reply.len()}")
    if reply.len() < 4:
        return Err("short recv reply")
    val status = _net_read_i32(reply, 0)
    _tls_debug("_net_recv_direct status={status}")
    if status < 0:
        return Err("recv failed status {status}")
    var data: [u8] = _byte_buf(reply.len())
    var i: u64 = 4
    while i < reply.len():
        data = _push_byte(data, reply[i].to_u64().to_i64())
        i = i + 1
    Ok(data)

fn _io_send(io: Tls13Io, data: [u8]) -> bool:
    """Send all bytes over TCP. Returns false if the write fails."""
    _tls_debug("_io_send start kind={io.kind} len={data.len()}")
    if io.kind == "host_stream":
        match io.host_stream.write_all(data):
            Ok(()): true
            Err(_): false
    else:
        var sent: u64 = 0
        var zero_writes: u64 = 0
        while sent < data.len():
            _tls_debug("_io_send loop sent={sent} total={data.len()}")
            val wrote_i = rt_net_send_bytes(io.tcp_fd, data)
            if wrote_i < 0:
                _tls_debug("_io_send send err status={wrote_i}")
                return false
            val wrote = wrote_i.to_u64()
            _tls_debug("_io_send wrote={wrote}")
            if wrote == 0:
                zero_writes = zero_writes + 1
                if zero_writes > 100000:
                    return false
                rt_thread_sleep(1)
                pass_dn
            else:
                zero_writes = 0
            sent = sent + wrote
        true

fn _io_recv(io: Tls13Io, length: u64) -> [u8]:
    """Read exactly length bytes from TCP. Returns partial data on close."""
    _tls_debug("_io_recv request len={length} kind={io.kind}")
    if length == 0:
        return []
    if length > _TLS_MAX_RECORD_PAYLOAD and length != 5:
        return []
    var result: [u8] = _byte_buf(length)
    var empty_spins: u64 = 0
    while result.len() < length:
        if result.len() > length:
            var trimmed: [u8] = _byte_buf(length)
            var trim_idx: u64 = 0
            while trim_idx < length:
                trimmed = _push_byte(trimmed, result[trim_idx].to_u64().to_i64())
                trim_idx = trim_idx + 1
            return trimmed
        val remaining = length - result.len()
        if remaining == 0:
            return result
        if remaining > _TLS_MAX_RECORD_PAYLOAD and remaining != 5:
            return result
        _tls_debug("_io_recv remaining={remaining} have={result.len()}")
        val chunk = if io.kind == "host_stream":
            match io.host_stream.read(remaining.to_i64()):
                Ok(data): data
                Err(_): []
        else:
            rt_net_recv_bytes(io.tcp_fd, remaining.to_i64())
        _tls_debug("_io_recv chunk_len={chunk.len()}")
        if chunk.len() == 0:
            empty_spins = empty_spins + 1
            if empty_spins > 100000:
                return result
            rt_thread_sleep(1)
            pass_dn
        else:
            empty_spins = 0
        # Defensive cap: some guest-side net shims can return a chunk larger
        # than the requested max_len. If we blindly append it, result.len()
        # can overshoot length and the next remaining computation underflows
        # into a giant allocation request.
        val copy_len = if chunk.len() < remaining { chunk.len() } else { remaining }
        var i: u64 = 0
        while i < copy_len:
            result = _push_byte(result, _u8_at(chunk, i).to_u64().to_i64())
            i = i + 1
    result

fn _io_recv_record(io: Tls13Io) -> [u8]:
    """Read one complete TLS record: 5-byte header + payload."""
    _tls_debug("_io_recv_record start")
    if io.kind == "fd":
        return rt_tls13_recv_record(io.tcp_fd)
    val header = _io_recv(io, 5)
    if header.len() < 5:
        _tls_debug("_io_recv_record short_header={header.len()}")
        return header
    val h0 = _u8_at(header, 0)
    val h3 = _u8_at(header, 3)
    val h4 = _u8_at(header, 4)
    val pay_len_i = rt_tls13_record_payload_len(header)
    if pay_len_i <= 0:
        return []
    val pay_len = pay_len_i.to_u64()
    _tls_debug("_io_recv_record header type={h0} pay_len={pay_len}")
    if pay_len == 0 or pay_len > _TLS_MAX_RECORD_PAYLOAD:
        return []
    val payload = _io_recv(io, pay_len)
    if payload.len() < pay_len:
        return []
    var result: [u8] = _byte_buf(header.len() + payload.len())
    _tls_debug("_io_recv_record concat header={header.len()} payload={payload.len()}")
    var i: u64 = 0
    while i < header.len():
        result = _push_byte(result, _u8_at(header, i).to_u64().to_i64())
        i = i + 1
    i = 0
    while i < payload.len():
        result = _push_byte(result, _u8_at(payload, i).to_u64().to_i64())
        i = i + 1
    result

# ============================================================================
# Helper: build a plaintext TLS record with legacy ClientHello framing
# ============================================================================

fn _build_plaintext_record(content_type: u8, payload: [u8]) -> [u8]:
    """Build a plaintext TLS record. Uses 0x0301 legacy version for ClientHello."""
    val pay_len = payload.len()
    var rec: [u8] = _byte_buf(pay_len + 5)
    rec = _push_byte(rec, content_type.to_u64().to_i64())
    rec = _push_byte(rec, 0x03)
    rec = _push_byte(rec, 0x01)
    rec = _push_byte(rec, ((pay_len >> 8) & 0xFF).to_i64())
    rec = _push_byte(rec, (pay_len & 0xFF).to_i64())
    var i: u64 = 0
    while i < pay_len:
        rec = _push_byte(rec, payload[i].to_u64().to_i64())
        i = i + 1
    rec

fn _sig_algs_contains(sig_algs: [u16], scheme: u16) -> bool:
    if sig_algs.len() == 0:
        return true
    var i: u64 = 0
    while i < sig_algs.len():
        if sig_algs[i] == scheme:
            return true
        i = i + 1
    false

fn _build_client_cert_verify_content(thash: [u8]) -> [u8]:
    """Build the client-side RFC 8446 CertificateVerify signed content."""
    var content: [u8] = []
    var i: u64 = 0
    while i < 64:
        content = _push_byte(content, 0x20)
        i = i + 1

    val prefix = [
        0x54u8, 0x4C, 0x53, 0x20, 0x31, 0x2E, 0x33, 0x2C, 0x20,
        0x63, 0x6C, 0x69, 0x65, 0x6E, 0x74, 0x20,
        0x43, 0x65, 0x72, 0x74, 0x69, 0x66, 0x69, 0x63, 0x61,
        0x74, 0x65, 0x56, 0x65, 0x72, 0x69, 0x66, 0x79
    ]
    i = 0
    while i < prefix.len():
        content = _push_byte(content, prefix[i].to_u64().to_i64())
        i = i + 1
    content = _push_byte(content, 0x00)

    i = 0
    while i < thash.len():
        content = _push_byte(content, thash[i].to_u64().to_i64())
        i = i + 1
    content

# ============================================================================
# PSK + 0-RTT wire integration helpers (RFC 8446 §4.1.4 + §4.2.11)
#
# tls13_connect_io_with_config splices an OfferedPsks pre_shared_key
# extension + psk_key_exchange_modes extension into a CH built by
# build_client_hello_bytes(_with_p256). The pre_shared_key extension MUST
# be the LAST extension of the ClientHello (RFC 8446 §4.2.11).
#
# Per RFC 8446 §4.1.4 the binder MAC is computed over a transcript hash of
# a partial ClientHello "up to and including the PreSharedKeyExtension.
# identities field" — i.e., the hash STOPS at the end of the identities
# block, BEFORE the binders_len u16 field. Wire bytes carry the binders
# block with binders zeroed; the hash input does not include it.
# ============================================================================

class PskCh:
    bytes: [u8]
    binders_field_offset: u64   # offset of binders_len u16 in `bytes` (first byte after end-of-identities)
    binders_data_offset: u64    # offset of the first binder length-prefix byte (binders_field_offset + 2)

fn _u16_be_at(buf: [u8], off: u64) -> u32:
    val hi = _u8_at(buf, off).to_u32()
    val lo = _u8_at(buf, off + 1).to_u32()
    (hi << 8) | lo

fn _u8_at_i64(buf: [u8], idx: u64) -> i64:
    """Return byte at idx as i64 — workaround for interpreter `push(u8)` bug
    (see doc/08_tracking/bug/interpreter_array_push_u8_literal_lost_2026-05-02.md)."""
    rt_bytes_u8_at(buf, idx.to_i64())

