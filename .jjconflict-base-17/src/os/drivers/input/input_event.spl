# Input Event Types — Unified input event evidence structs
# MDSOC: feature dimension, drivers layer
#
# Provides KeyEvent, MouseEvent, TouchEvent, GamepadEvent, and
# InputEventQueue for aggregating input evidence across PS/2, USB HID,
# touch, and gamepad devices.

# ============================================================================
# KeyEvent — keyboard event
# ============================================================================

class KeyEvent:
    """A single keyboard event with scancode, keycode, modifiers, and timing."""
    scan_code: i64
    key_code: i64
    is_pressed: bool
    is_repeat: bool
    modifiers: i64
    timestamp_us: i64

impl KeyEvent:
    static fn press(scan: i64, key: i64, mods: i64, ts: i64) -> KeyEvent:
        """Create a key-press event."""
        KeyEvent(
            scan_code: scan,
            key_code: key,
            is_pressed: true,
            is_repeat: false,
            modifiers: mods,
            timestamp_us: ts
        )

    static fn release(scan: i64, key: i64, mods: i64, ts: i64) -> KeyEvent:
        """Create a key-release event."""
        KeyEvent(
            scan_code: scan,
            key_code: key,
            is_pressed: false,
            is_repeat: false,
            modifiers: mods,
            timestamp_us: ts
        )

    me is_modifier_key() -> bool:
        """True if the key_code is a modifier (shift/ctrl/alt/meta)."""
        if self.key_code == 16:
            return true
        if self.key_code == 17:
            return true
        if self.key_code == 18:
            return true
        if self.key_code == 91:
            return true
        false

    me has_shift() -> bool:
        (self.modifiers & 1) != 0

    me has_ctrl() -> bool:
        (self.modifiers & 2) != 0

    me has_alt() -> bool:
        (self.modifiers & 4) != 0

    me summary() -> text:
        val state = if self.is_pressed: "pressed" else: "released"
        "key scan=" + self.scan_code.to_text() +
            " code=" + self.key_code.to_text() +
            " " + state +
            " mods=" + self.modifiers.to_text() +
            " ts=" + self.timestamp_us.to_text()

# ============================================================================
# MouseEvent — mouse event
# ============================================================================

class MouseEvent:
    """A single mouse event with deltas, absolute position, and button state."""
    delta_x: i64
    delta_y: i64
    delta_scroll: i64
    button_state: i64
    is_absolute: bool
    abs_x: i64
    abs_y: i64
    timestamp_us: i64

impl MouseEvent:
    static fn relative(dx: i64, dy: i64, scroll: i64, btns: i64, ts: i64) -> MouseEvent:
        """Create a relative-movement mouse event."""
        MouseEvent(
            delta_x: dx,
            delta_y: dy,
            delta_scroll: scroll,
            button_state: btns,
            is_absolute: false,
            abs_x: 0,
            abs_y: 0,
            timestamp_us: ts
        )

    static fn absolute(x: i64, y: i64, btns: i64, ts: i64) -> MouseEvent:
        """Create an absolute-position mouse event."""
        MouseEvent(
            delta_x: 0,
            delta_y: 0,
            delta_scroll: 0,
            button_state: btns,
            is_absolute: true,
            abs_x: x,
            abs_y: y,
            timestamp_us: ts
        )

    me left_down() -> bool:
        (self.button_state & 1) != 0

    me right_down() -> bool:
        (self.button_state & 2) != 0

    me middle_down() -> bool:
        (self.button_state & 4) != 0

    me summary() -> text:
        if self.is_absolute:
            "mouse abs x=" + self.abs_x.to_text() +
                " y=" + self.abs_y.to_text() +
                " btns=" + self.button_state.to_text() +
                " ts=" + self.timestamp_us.to_text()
        else:
            "mouse rel dx=" + self.delta_x.to_text() +
                " dy=" + self.delta_y.to_text() +
                " scroll=" + self.delta_scroll.to_text() +
                " btns=" + self.button_state.to_text() +
                " ts=" + self.timestamp_us.to_text()

# ============================================================================
# TouchEvent — touchscreen / touchpad event
# ============================================================================

class TouchEvent:
    """A single touch contact event with phase, position, and pressure."""
    touch_id: i64
    phase: text
    x: i64
    y: i64
    pressure: i64
    timestamp_us: i64

impl TouchEvent:
    static fn create(id: i64, phase: text, x: i64, y: i64, press: i64, ts: i64) -> TouchEvent:
        """Create a touch event."""
        TouchEvent(
            touch_id: id,
            phase: phase,
            x: x,
            y: y,
            pressure: press,
            timestamp_us: ts
        )

    me summary() -> text:
        "touch id=" + self.touch_id.to_text() +
            " phase=" + self.phase +
            " x=" + self.x.to_text() +
            " y=" + self.y.to_text() +
            " pressure=" + self.pressure.to_text() +
            " ts=" + self.timestamp_us.to_text()

# ============================================================================
# GamepadEvent — gamepad / joystick event
# ============================================================================

class GamepadEvent:
    """A single gamepad axis or button event."""
    device_id: i64
    axis_id: i64
    axis_value: i64
    button_id: i64
    button_pressed: bool
    is_axis: bool
    timestamp_us: i64

impl GamepadEvent:
    static fn axis(dev: i64, axis: i64, val: i64, ts: i64) -> GamepadEvent:
        """Create a gamepad axis event."""
        GamepadEvent(
            device_id: dev,
            axis_id: axis,
            axis_value: val,
            button_id: 0,
            button_pressed: false,
            is_axis: true,
            timestamp_us: ts
        )

    static fn button(dev: i64, btn: i64, pressed: bool, ts: i64) -> GamepadEvent:
        """Create a gamepad button event."""
        GamepadEvent(
            device_id: dev,
            axis_id: 0,
            axis_value: 0,
            button_id: btn,
            button_pressed: pressed,
            is_axis: false,
            timestamp_us: ts
        )

    me summary() -> text:
        if self.is_axis:
            "gamepad dev=" + self.device_id.to_text() +
                " axis=" + self.axis_id.to_text() +
                " val=" + self.axis_value.to_text() +
                " ts=" + self.timestamp_us.to_text()
        else:
            val state = if self.button_pressed: "down" else: "up"
            "gamepad dev=" + self.device_id.to_text() +
                " btn=" + self.button_id.to_text() +
                " " + state +
                " ts=" + self.timestamp_us.to_text()

# ============================================================================
# InputEventQueue — simple event aggregator
# ============================================================================

class InputEventQueue:
    """Counts and tracks last-seen values for each event type."""
    key_count: i64
    mouse_count: i64
    touch_count: i64
    gamepad_count: i64
    last_key_scan: i64
    last_mouse_dx: i64
    last_touch_id: i64
    last_gamepad_dev: i64

impl InputEventQueue:
    static fn create() -> InputEventQueue:
        """Create an empty event queue."""
        InputEventQueue(
            key_count: 0,
            mouse_count: 0,
            touch_count: 0,
            gamepad_count: 0,
            last_key_scan: 0,
            last_mouse_dx: 0,
            last_touch_id: 0,
            last_gamepad_dev: 0
        )

    me record_key(ev: KeyEvent) -> i64:
        self.key_count = self.key_count + 1
        self.last_key_scan = ev.scan_code
        self.key_count

    me record_mouse(ev: MouseEvent) -> i64:
        self.mouse_count = self.mouse_count + 1
        self.last_mouse_dx = ev.delta_x
        self.mouse_count

    me record_touch(ev: TouchEvent) -> i64:
        self.touch_count = self.touch_count + 1
        self.last_touch_id = ev.touch_id
        self.touch_count

    me record_gamepad(ev: GamepadEvent) -> i64:
        self.gamepad_count = self.gamepad_count + 1
        self.last_gamepad_dev = ev.device_id
        self.gamepad_count

    me total() -> i64:
        self.key_count + self.mouse_count + self.touch_count + self.gamepad_count

    me stats() -> text:
        "input queue: keys=" + self.key_count.to_text() +
            " mouse=" + self.mouse_count.to_text() +
            " touch=" + self.touch_count.to_text() +
            " gamepad=" + self.gamepad_count.to_text() +
            " total=" + self.total().to_text()
