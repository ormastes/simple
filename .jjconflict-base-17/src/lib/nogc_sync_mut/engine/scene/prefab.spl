# Prefab System — Reusable Entity Templates
#
# A Prefab stores a template of field overrides that can be instantiated
# as scene nodes. Supports per-instance property overrides and hierarchical
# child templates.
#
# Usage:
#   var tmpl = PrefabTemplate.new("Sprite", "player")
#   tmpl.set_property("speed", "10.0")
#   var pstore = PrefabStore.new()
#   val idx = pstore.register(tmpl)
#   var node_store = NodeStore.new()
#   val node_id = pstore.instantiate(idx, node_store)

use std.common.engine.ids.{NodeId}
use std.nogc_sync_mut.engine.scene.node.{NodeStore}

# ============================================================================
# PrefabProperty — a single named property override
# ============================================================================

struct PrefabProperty:
    """A key-value property for a prefab template."""
    name: text
    value: text

# ============================================================================
# PrefabTemplate — reusable entity template with children
# ============================================================================

struct PrefabTemplate:
    """Template describing a prefab with type, name, properties, and children."""
    type_name: text
    name: text
    properties: [PrefabProperty]
    children: [PrefabTemplate]

impl PrefabTemplate:
    static fn new(type_name: text, name: text) -> PrefabTemplate:
        """Create a new prefab template with no properties or children."""
        PrefabTemplate(
            type_name: type_name,
            name: name,
            properties: [],
            children: []
        )

    me set_property(prop_name: text, value: text):
        """Add or update a property by name."""
        # Check if property already exists
        var found = false
        var i = 0
        while i < self.properties.len():
            if self.properties[i].name == prop_name:
                self.properties[i] = PrefabProperty(name: prop_name, value: value)
                found = true
            i = i + 1
        if not found:
            self.properties.push(PrefabProperty(name: prop_name, value: value))

    fn get_property(prop_name: text) -> text?:
        """Look up a property value by name. Returns nil if not found."""
        var i = 0
        while i < self.properties.len():
            if self.properties[i].name == prop_name:
                return self.properties[i].value
            i = i + 1
        nil

    me add_child(child: PrefabTemplate):
        """Add a child template."""
        self.children.push(child)

    fn child_count() -> i64:
        """Number of child templates."""
        self.children.len()

# ============================================================================
# PrefabStore — registry of prefab templates
# ============================================================================

class PrefabStore:
    """Stores and instantiates prefab templates."""
    prefabs: [PrefabTemplate]
    count: i64

impl PrefabStore:
    static fn new() -> PrefabStore:
        """Create an empty prefab store."""
        PrefabStore(
            prefabs: [],
            count: 0
        )

    me register(prefab: PrefabTemplate) -> i64:
        """Register a prefab template. Returns its index."""
        val idx = self.prefabs.len()
        self.prefabs.push(prefab)
        self.count = self.count + 1
        idx

    fn get(index: i64) -> PrefabTemplate?:
        """Look up a prefab by index. Returns nil if out of range."""
        if index < 0 or index >= self.prefabs.len():
            return nil
        self.prefabs[index]

    fn find_by_name(name: text) -> PrefabTemplate?:
        """Find the first prefab with the given name."""
        var i = 0
        while i < self.prefabs.len():
            if self.prefabs[i].name == name:
                return self.prefabs[i]
            i = i + 1
        nil

    fn find_by_type(type_name: text) -> [PrefabTemplate]:
        """Find all prefabs with the given type_name."""
        var result: [PrefabTemplate] = []
        var i = 0
        while i < self.prefabs.len():
            if self.prefabs[i].type_name == type_name:
                result.push(self.prefabs[i])
            i = i + 1
        result

    me instantiate(index: i64, store: NodeStore) -> NodeId:
        """Create Node2D nodes from a prefab template.

        Uses the template name as the node name. Recursively instantiates
        child templates and sets parent relationships.
        Returns the root node id, or NodeId.invalid() if index is invalid.
        """
        if index < 0 or index >= self.prefabs.len():
            return NodeId.invalid()
        val tmpl = self.prefabs[index]
        self._instantiate_template(tmpl, store)

    fn size() -> i64:
        """Number of registered prefabs."""
        self.count

    # --- Private helpers ---

    me _instantiate_template(tmpl: PrefabTemplate, store: NodeStore) -> NodeId:
        """Recursively create nodes from a template."""
        val node_id = store.create_node(tmpl.name)
        # Recurse children
        var ci = 0
        while ci < tmpl.children.len():
            val child_tmpl = tmpl.children[ci]
            val child_id = self._instantiate_template(child_tmpl, store)
            store.set_parent(child_id, node_id)
            ci = ci + 1
        node_id
