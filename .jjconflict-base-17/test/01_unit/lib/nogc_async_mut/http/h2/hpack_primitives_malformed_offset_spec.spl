use std.spec.{describe, it, expect}
use std.http.h2.hpack_primitives.{
    HpackIntResult,
    HpackStringResult,
    hpack_decode_int,
    hpack_decode_string
}

fn _is_int_error(result: HpackIntResult) -> bool:
    match result:
        case Err(_):
            return true
        case Ok(_):
            return false
    return false

fn _is_string_error(result: HpackStringResult) -> bool:
    match result:
        case Err(_):
            return true
        case Ok(_):
            return false
    return false

describe "async HPACK primitive malformed offset guards":
    it "rejects negative public decode offsets without indexing before the buffer":
        val bytes: [u8] = [0x00]
        expect(_is_int_error(hpack_decode_int(bytes, -1, 7))).to_equal(true)
        expect(_is_string_error(hpack_decode_string(bytes, -1))).to_equal(true)

    it "rejects invalid prefix widths before computing a prefix mask":
        val bytes: [u8] = [0x00]
        expect(_is_int_error(hpack_decode_int(bytes, 0, 0))).to_equal(true)
        expect(_is_int_error(hpack_decode_int(bytes, 0, 9))).to_equal(true)
