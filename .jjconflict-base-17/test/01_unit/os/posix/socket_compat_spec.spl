"""
# POSIX socket_compat pure helpers
**Feature IDs:** #WAVE3-G14
**Category:** POSIX shim

Covers the address helpers and constant contract. The IPC path
(`posix_socket`, `posix_bind`, …) requires netstack to be running
and is exercised in system tests.
"""
use std.spec.*
use os.posix.socket_compat.{SockaddrIn, sockaddr_in, sockaddr_any, AF_INET, SOCK_STREAM, SOCK_DGRAM, posix_bind, posix_listen, posix_connect, set_ai_cli_socket_manifest_for_test, clear_ai_cli_socket_manifest_for_test}
use os.posix.fd_table.{fd_table_init, fd_set}
use os.ai_cli_js_node_contract.{codex_cli_smoke_manifest}

describe "sockaddr_in":
    """IPv4 address packing matches little-endian wire order of octets."""

    it "packs four octets into the addr field":
        """127.0.0.1 => 0x0100007F."""
        val a = sockaddr_in(8080u16, 127u8, 0u8, 0u8, 1u8)
        expect a.family.to_equal(AF_INET)
        expect a.port.to_equal(8080u16)
        expect a.addr.to_equal(0x0100007Fu32)

    it "INADDR_ANY has addr=0":
        """sockaddr_any must bind to all interfaces."""
        val a = sockaddr_any(22u16)
        expect a.family.to_equal(AF_INET)
        expect a.port.to_equal(22u16)
        expect a.addr.to_equal(0u32)

describe "socket constants":
    """Pin POSIX socket-type constants so ABI drift fails here first."""

    it "AF_INET is 2":
        expect AF_INET.to_equal(2)

    it "SOCK_STREAM is 1":
        expect SOCK_STREAM.to_equal(1)

    it "SOCK_DGRAM is 2":
        expect SOCK_DGRAM.to_equal(2)

describe "AI CLI socket network grants":
    """Socket boundary operations must deny ungranted endpoints before netstack IPC."""

    it "denies connect endpoints outside the active manifest grants":
        fd_table_init()
        expect(fd_set(3, 4, 0, 42u64)).to_equal(0)
        set_ai_cli_socket_manifest_for_test(codex_cli_smoke_manifest())
        val denied = posix_connect(3, sockaddr_in(443u16, 127u8, 0u8, 0u8, 1u8))
        expect(denied).to_equal(-13)
        clear_ai_cli_socket_manifest_for_test()

    it "denies bind endpoints outside the active manifest grants":
        fd_table_init()
        expect(fd_set(3, 4, 0, 42u64)).to_equal(0)
        set_ai_cli_socket_manifest_for_test(codex_cli_smoke_manifest())
        val denied = posix_bind(3, sockaddr_any(3000u16))
        expect(denied).to_equal(-13)
        clear_ai_cli_socket_manifest_for_test()

    it "denies listen without a granted bound endpoint":
        fd_table_init()
        expect(fd_set(3, 4, 0, 42u64)).to_equal(0)
        set_ai_cli_socket_manifest_for_test(codex_cli_smoke_manifest())
        val denied = posix_listen(3, 16)
        expect(denied).to_equal(-13)
        clear_ai_cli_socket_manifest_for_test()
