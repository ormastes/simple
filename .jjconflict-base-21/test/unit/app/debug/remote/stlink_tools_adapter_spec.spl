# ST-Link Tools Adapter Tests
# Tests config factories, capability flags, supported/unsupported ops.

# --- Local copies ---

class AdapterCapabilities:
    can_reset: bool
    supports_memory: bool
    supports_registers: bool
    supports_breakpoints: bool

impl AdapterCapabilities:
    static fn basic() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: false, supports_memory: false, supports_registers: false, supports_breakpoints: false)

    fn with_reset() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: true, supports_memory: self.supports_memory, supports_registers: self.supports_registers, supports_breakpoints: self.supports_breakpoints)

    fn with_memory() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: self.can_reset, supports_memory: true, supports_registers: self.supports_registers, supports_breakpoints: self.supports_breakpoints)

class AdapterConfig:
    adapter_type: text
    host: text
    port: i32
    program: text
    architecture: text

impl AdapterConfig:
    static fn stlink_tools(serial: text, program: text) -> AdapterConfig:
        AdapterConfig(adapter_type: "stlink-tools", host: "", port: 0, program: program, architecture: serial)

# Mock adapter to test capabilities
class MockStLinkAdapter:
    name_val: text
    capabilities: AdapterCapabilities
    attached: bool

impl MockStLinkAdapter:
    static fn create() -> MockStLinkAdapter:
        MockStLinkAdapter(
            name_val: "stlink-tools",
            capabilities: AdapterCapabilities.basic().with_reset().with_memory(),
            attached: true
        )

    fn name() -> text:
        self.name_val

    fn is_attached() -> bool:
        self.attached

    fn can_halt() -> bool:
        false

    fn can_step() -> bool:
        false

    fn can_set_breakpoint() -> bool:
        false

    fn can_read_registers() -> bool:
        false

    fn can_reset() -> bool:
        self.capabilities.can_reset

    fn can_read_memory() -> bool:
        self.capabilities.supports_memory

# --- Tests ---

describe "StLinkToolsAdapter config factories":
    it "stlink-tools config for STM32H7":
        val cfg = AdapterConfig.stlink_tools("002600213137510833333639", "test.bin")
        expect(cfg.adapter_type).to_equal("stlink-tools")
        expect(cfg.architecture).to_equal("002600213137510833333639")

    it "stlink-tools config for STM32WB":
        val cfg = AdapterConfig.stlink_tools("0671FF555755846687041216", "test.bin")
        expect(cfg.architecture).to_equal("0671FF555755846687041216")

    it "stlink-tools config has no host":
        val cfg = AdapterConfig.stlink_tools("serial", "test.bin")
        expect(cfg.host).to_equal("")

    it "stlink-tools config has port 0":
        val cfg = AdapterConfig.stlink_tools("serial", "test.bin")
        expect(cfg.port).to_equal(0)

describe "StLinkToolsAdapter capabilities":
    it "has reset capability":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.can_reset()).to_equal(true)

    it "has memory capability":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.can_read_memory()).to_equal(true)

    it "does NOT have halt capability":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.can_halt()).to_equal(false)

    it "does NOT have step capability":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.can_step()).to_equal(false)

    it "does NOT have breakpoint capability":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.can_set_breakpoint()).to_equal(false)

    it "does NOT have register capability":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.can_read_registers()).to_equal(false)

describe "StLinkToolsAdapter name":
    it "adapter name is stlink-tools":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.name()).to_equal("stlink-tools")

    it "adapter is attached after creation":
        val adapter = MockStLinkAdapter.create()
        expect(adapter.is_attached()).to_equal(true)
