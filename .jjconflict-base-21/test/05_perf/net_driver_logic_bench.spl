# Pure logic microbenchmarks for the current SimpleOS virtio-net driver.
#
# These benchmarks intentionally avoid live QEMU/device I/O. They measure the
# arithmetic helpers that shape descriptor/ring work before hardware access.

use test.perf.bench.lib.timing.{BenchResult, bench_print, bench_csv, bench_csv_header, bench_now_ns}
use os.drivers.virtio.virtio_net.{
    virtqueue_desc_size,
    virtqueue_avail_size,
    virtqueue_used_size,
    virtqueue_total_size
}

fn bench_result(label: text, iters: i64, total_ns: i64, checksum: u64) -> BenchResult:
    val avg = if iters > 0: total_ns / iters else: 0
    val tput = if total_ns > 0: (iters * 1000000) / total_ns else: 0
    BenchResult(
        label: label + "_checksum_" + checksum.to_text(),
        iters: iters,
        p50_ns: avg,
        p99_ns: avg,
        p99_9_ns: avg,
        min_ns: avg,
        max_ns: avg,
        total_ns: total_ns,
        throughput_ops_per_s: tput
    )

fn bench_desc_size(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + virtqueue_desc_size(((i % 128) + 1).to_u64())
        i = i + 1
    bench_result("virtqueue_desc_size", iters, bench_now_ns() - t0, checksum)

fn bench_avail_size(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + virtqueue_avail_size(((i % 128) + 1).to_u64())
        i = i + 1
    bench_result("virtqueue_avail_size", iters, bench_now_ns() - t0, checksum)

fn bench_used_size(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + virtqueue_used_size(((i % 128) + 1).to_u64())
        i = i + 1
    bench_result("virtqueue_used_size", iters, bench_now_ns() - t0, checksum)

fn bench_total_size(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + virtqueue_total_size(((i % 128) + 1).to_u64())
        i = i + 1
    bench_result("virtqueue_total_size", iters, bench_now_ns() - t0, checksum)

fn bench_ring_slot_mod(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val base: u64 = 0x1000
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + base + 4 + ((i.to_u64() % 128) * 2)
        i = i + 1
    bench_result("virtio_ring_slot_mod", iters, bench_now_ns() - t0, checksum)

fn bench_used_ring_alignment(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val q = ((i % 128) + 1).to_u64()
        val desc_avail = virtqueue_desc_size(q) + virtqueue_avail_size(q)
        checksum = checksum + ((desc_avail + 4095) & ~4095)
        i = i + 1
    bench_result("virtio_used_ring_alignment", iters, bench_now_ns() - t0, checksum)

fn bench_queue_pfn_shift(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + ((0x80000000 + i.to_u64() * 4096) >> 12)
        i = i + 1
    bench_result("virtio_queue_pfn_shift", iters, bench_now_ns() - t0, checksum)

fn bench_descriptor_offset(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val base: u64 = 0x100000
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + base + ((i.to_u64() % 128) * 16)
        i = i + 1
    bench_result("virtio_descriptor_offset", iters, bench_now_ns() - t0, checksum)

fn bench_buffer_offset(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val base: u64 = 0x200000
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        checksum = checksum + base + ((i.to_u64() % 128) * 2048) + 10
        i = i + 1
    bench_result("virtio_buffer_offset", iters, bench_now_ns() - t0, checksum)

fn bench_tx_packet_slot_pair(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val head = i.to_u64() % 128
        val payload = (head + 1) % 128
        checksum = checksum + (head * 16) + (payload * 16)
        i = i + 1
    bench_result("virtio_tx_packet_slot_pair", iters, bench_now_ns() - t0, checksum)

fn bench_phys_addr_split(iters: i64) -> BenchResult:
    var checksum: u64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val phys = 0x100000000 + i.to_u64() * 2048
        checksum = checksum + (phys & 0xFFFFFFFF) + (phys >> 32)
        i = i + 1
    bench_result("virtio_phys_addr_split", iters, bench_now_ns() - t0, checksum)

fn main():
    val iters: i64 = 200000
    print "=== SimpleOS virtio-net pure logic benchmark ==="
    print "note: arithmetic-only; not live QEMU packet throughput."

    val r1 = bench_desc_size(iters)
    val r2 = bench_avail_size(iters)
    val r3 = bench_used_size(iters)
    val r4 = bench_total_size(iters)
    val r5 = bench_ring_slot_mod(iters)
    val r6 = bench_used_ring_alignment(iters)
    val r7 = bench_queue_pfn_shift(iters)
    val r8 = bench_descriptor_offset(iters)
    val r9 = bench_buffer_offset(iters)
    val r10 = bench_tx_packet_slot_pair(iters)
    val r11 = bench_phys_addr_split(iters)

    bench_print(r1)
    bench_print(r2)
    bench_print(r3)
    bench_print(r4)
    bench_print(r5)
    bench_print(r6)
    bench_print(r7)
    bench_print(r8)
    bench_print(r9)
    bench_print(r10)
    bench_print(r11)

    print ""
    print bench_csv_header()
    print bench_csv(r1)
    print bench_csv(r2)
    print bench_csv(r3)
    print bench_csv(r4)
    print bench_csv(r5)
    print bench_csv(r6)
    print bench_csv(r7)
    print bench_csv(r8)
    print bench_csv(r9)
    print bench_csv(r10)
    print bench_csv(r11)
