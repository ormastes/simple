# Deploy Smoke Test Specification
#
# Smoke tests to verify the Simple runtime is properly deployed and functional.
# Tests binary existence, version output, and key files.
#
# Feature: Deployment Smoke Tests
# Category: Deploy Testing
# Status: Active

use std.io_runtime.{file_exists}

fn find_simple_binary() -> text:
    if file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if file_exists("src/compiler_rust/target/bootstrap/simple"):
        return "src/compiler_rust/target/bootstrap/simple"
    if file_exists("bin/simple"):
        return "bin/simple"
    if file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    ""

describe "deploy: binary existence":
    it "a usable Simple runtime exists":
        val found = find_simple_binary() != ""
        expect(found).to_equal(true)

describe "deploy: key files present":
    it "src/ directory exists":
        val found = file_exists("src")
        expect(found).to_equal(true)

    it "test/ directory exists":
        val found = file_exists("test")
        expect(found).to_equal(true)

    it "CLAUDE.md exists":
        val found = file_exists("CLAUDE.md")
        expect(found).to_equal(true)
