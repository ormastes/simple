# Spec for the platform build-extension seam (variants/ platform overlay),
# exercised through the public platform API. lib_ext()/exe_ext() delegate to the
# target_ext seam; the canonical (src) seam returns host extensions, so on this
# Linux test host lib_ext() == ".so" and exe_ext() == "".
#
# Variant selection itself (explicit platform: windows|mac|linux -> fixed
# extension) is covered by the resolver specs
# (test/01_unit/compiler/module_resolver/var_resolution_spec.spl), which prove
# full-segment variant resolution with default fall-through to src.

use std.nogc_sync_mut.platform.{lib_ext, exe_ext}

describe "platform build-extension seam (canonical / default via public API)":
    it "lib_ext returns the host dynamic-library extension":
        expect(lib_ext()).to_equal(".so")

    it "exe_ext returns the host executable extension (empty on unix)":
        # prefix dodges the empty-string falsy-matcher bug
        # ([[sspec_matcher_to_equal_zero_falsy]]); exe_ext() is "" on this host
        expect("exe=" + exe_ext()).to_equal("exe=")
