extern fn rt_file_read_text(path: text) -> text

fn _contains_msf_negative_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn _read_u32_le_at(data: [u8], offset: i64) -> i64:") and
        source.to_contain("if offset < 0:\n        return 0") and
        source.to_contain("val b0 = data[offset] as i64")

describe "MSF parser negative offset guards":
    it "guards mirrored MSF byte readers before indexed reads":
        expect(_contains_msf_negative_guard("src/lib/nogc_sync_mut/debug/formats/msf_parser.spl")).to_equal(true)
        expect(_contains_msf_negative_guard("src/lib/nogc_async_mut/debug/formats/msf_parser.spl")).to_equal(true)
