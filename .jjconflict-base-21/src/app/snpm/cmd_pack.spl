# snpm pack — Create .spk tarball

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn cmd_pack(config: SnpmConfig, args: [text]):
    """Create a .spk tarball of the current package."""
    if not rt_file_exists(config.manifest_name):
        print "snpm: no {config.manifest_name} found"
        return

    val manifest_result = parse_manifest(config.manifest_name)
    match manifest_result:
        Err(msg):
            print "snpm: {msg}"
            return
        Ok(manifest):
            val tarball = "{manifest.name}-{manifest.version}.spk"
            print "snpm: packing {tarball}..."

            # Create tar archive (exclude spl_modules, .git, build)
            val result = rt_process_run("tar", [
                "czf", tarball,
                "--exclude=spl_modules",
                "--exclude=.git",
                "--exclude=.jj",
                "--exclude=build",
                "."
            ])
            if result.2 == 0:
                print "snpm: created {tarball}"
            else:
                print "snpm: pack failed"
                if result.1 != "":
                    print "  {result.1}"
