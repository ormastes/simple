# Process Separation Types

enum ProcessMode:
    Shared
    Actor
    Separated

    static fn from_text(s: text) -> ProcessMode:
        if s == "actor": return ProcessMode.Actor
        if s == "separated": return ProcessMode.Separated
        ProcessMode.Shared

    static fn to_text(m: ProcessMode) -> text:
        if m == ProcessMode.Actor: return "actor"
        if m == ProcessMode.Separated: return "separated"
        "shared"

enum IpcTransport:
    Channel
    FileQueue

    static fn from_text(s: text) -> IpcTransport:
        if s == "file_queue": return IpcTransport.FileQueue
        IpcTransport.Channel

    static fn to_text(t: IpcTransport) -> text:
        if t == IpcTransport.FileQueue: return "file_queue"
        "channel"

struct ServiceGroupConfig:
    name: text
    services: [text]
    db_group: text
    process_name: text

struct DbGroupConfig:
    name: text
    path: text
    db_type: text
    databases: [text]

struct WorkerConfig:
    name: text
    restart: text
    max_memory_mb: i64
    count: i64

struct ProcessSeparationConfig:
    mode: ProcessMode
    ipc_transport: IpcTransport
    queue_dir: text
    service_groups: [ServiceGroupConfig]
    db_groups: [DbGroupConfig]
    workers: [WorkerConfig]

enum ProcessSetError:
    ConfigError(message: text)
    SpawnError(message: text)
    IpcError(message: text)
    WorkerDied(name: text)

    static fn message(e: ProcessSetError) -> text:
        if e == ProcessSetError.ConfigError: return e.message
        if e == ProcessSetError.SpawnError: return e.message
        if e == ProcessSetError.IpcError: return e.message
        e.name

fn default_process_config() -> ProcessSeparationConfig:
    ProcessSeparationConfig(
        mode: ProcessMode.Shared,
        ipc_transport: IpcTransport.Channel,
        queue_dir: "/tmp/simple_ipc",
        service_groups: [],
        db_groups: [],
        workers: []
    )
