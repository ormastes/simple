"""
# No-GC Async 3D color helpers

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.gpu.engine3d.color3d.{
    _c3d_sqrt, _c3d_pow, _c3d_clamp_byte, _c3d_clamp_f32, _c3d_to_u32, _c3d_to_i32, rgba3d,
    rgb3d, c3d_r, c3d_g, c3d_b, c3d_a, srgb_to_linear_component, linear_to_srgb_component,
    srgb_to_linear, linear_to_srgb, blend3d, lerp_color3d, pack_hdr_color, tonemap_reinhard,
    luminance3d, luminance_linear, color3d_white, color3d_black, color3d_red, color3d_green,
    color3d_blue, color3d_transparent
}
