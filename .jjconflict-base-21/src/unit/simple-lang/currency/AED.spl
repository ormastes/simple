# Unit: Aed
# Kind: Currency
# Symbol: AED
# Canonical scale: 1.0 USD

class Aed:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Aed) -> Aed: Aed(value: self.value + other.value)
    fn sub(other: Aed) -> Aed: Aed(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "AED"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Aed: Aed(value: 0.0)

export Aed
