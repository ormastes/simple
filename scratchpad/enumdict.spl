struct FV:
    name: text
    n: i64
enum Val:
    Func(FV)
    Nil

fn main():
    val fv = FV(name: "P", n: 7)
    val v: Val = Val.Func(fv)
    # direct extract (no dict)
    match v:
        case Val.Func(f):
            print("direct f_nil={f == nil} name={f.name}")
        case Val.Nil:
            print("direct nil")
    # through Dict<text,Val>
    var d: Dict<text, Val> = {}
    d["P"] = v
    val loaded = d["P"]
    match loaded:
        case Val.Func(f2):
            print("dict f_nil={f2 == nil}")
        case Val.Nil:
            print("dict nil")
