# Repro for issue #45: interpreter @cfg arch-variant dispatch.
# Order B: arm64 variant declared FIRST, x86_64 second.
# Pre-fix, first-declared wins and this order returns "arm64" (bug).
# On an x86_64 host, arch_name() must return "x86_64" in BOTH orders.

@cfg(arm64)
fn arch_name() -> text:
    "arm64"

@cfg(x86_64)
fn arch_name() -> text:
    "x86_64"

fn main() -> i32:
    val got = arch_name()
    print("order B (arm64 first): arch_name() = {got}")
    if got == "x86_64":
        print("PASS")
        return 0
    print("FAIL: expected x86_64")
    1
