+    me lower_array_fold(arr: LocalId, init: LocalId, lam_op: MirOperand) -> LocalId:
+        """Lower `arr.fold(init, \\acc, x: expr)` for a runtime `[i64]` array.
+
+        Same counted-loop shape as `lower_array_map`/`lower_array_filter`, but
+        accumulates into a mutable `acc` Var local (initialized from `init`,
+        already the raw i64 ABI value since it comes from a plain expression,
+        not an array element) instead of building a result array. Each
+        iteration calls the 2-arg lifted lambda as `lam(acc, elem_raw)` and
+        stores the raw i64 result back into `acc`; the final `acc` is
+        returned once the loop exits.
+        """
+        val loop_ty = MirType.i64()
+
+        var b_len = self.builder
+        val len_call = b_len.emit_call(self.rt_array_len_operand(), [mir_operand_copy(arr)], MirType.i64())
+        val len_local = len_call ?? b_len.new_temp(MirType.i64())
+        self.builder = b_len
+
+        var b_init = self.builder
+        val acc = b_init.new_local(nil, loop_ty, LocalKind.Var)
+        val init_i64 = b_init.emit_cast(mir_operand_copy(init), loop_ty)
+        b_init.emit_copy(acc, init_i64)
+        val counter = b_init.new_local(nil, loop_ty, LocalKind.Var)
+        val zero = b_init.new_temp(loop_ty)
+        b_init.emit_const(zero, MirConstValue.Int(0), loop_ty)
+        b_init.emit_copy(counter, zero)
+        val one = b_init.new_temp(loop_ty)
+        b_init.emit_const(one, MirConstValue.Int(1), loop_ty)
+        self.builder = b_init
+
+        var b_blocks = self.builder
+        val cond_block = b_blocks.new_block(Some("fold_cond"))
+        val body_block = b_blocks.new_block(Some("fold_body"))
+        val inc_block = b_blocks.new_block(Some("fold_inc"))
+        val exit_block = b_blocks.new_block(Some("fold_exit"))
+        self.builder = b_blocks
+
+        var b_goto = self.builder
+        b_goto.terminate_goto(cond_block)
+        b_goto.switch_to_block(cond_block)
+        self.builder = b_goto
+
+        var b_cond = self.builder
+        val cond_result = b_cond.emit_binop(MirBinOp.Lt, mir_operand_copy(counter), mir_operand_copy(len_local), MirType.bool())
+        b_cond.terminate_if(mir_operand_copy(cond_result), body_block, exit_block)
+        b_cond.switch_to_block(body_block)
+        self.builder = b_cond
+
+        var b_get = self.builder
+        val get_call = b_get.emit_call(self.rt_array_get_operand(), [mir_operand_copy(arr), mir_operand_copy(counter)], MirType.i64())
+        val elem_tagged = get_call ?? b_get.new_temp(MirType.i64())
+        self.builder = b_get
+        val elem_raw = self.decode_runtime_value(elem_tagged, MirType.i64())
+
+        var b_call = self.builder
+        val call_result = b_call.emit_call(lam_op, [mir_operand_copy(acc), mir_operand_copy(elem_raw)], MirType.i64())
+        val new_acc = call_result ?? b_call.new_temp(MirType.i64())
+        b_call.emit_copy(acc, new_acc)
+        self.builder = b_call
+
+        var b_body_end = self.builder
+        if not b_body_end.current_block_has_explicit_terminator():
+            b_body_end.terminate_goto(inc_block)
+        self.builder = b_body_end
+
+        var b_inc = self.builder
+        b_inc.switch_to_block(inc_block)
+        val incremented = b_inc.emit_binop(MirBinOp.Add, mir_operand_copy(counter), mir_operand_copy(one), loop_ty)
+        b_inc.emit_copy(counter, incremented)
+        self.builder = b_inc
+        var b_back = self.builder
+        b_back.terminate_goto(cond_block)
+        self.builder = b_back
+
+        var b_exit = self.builder
+        b_exit.switch_to_block(exit_block)
+        self.builder = b_exit
+        acc
+
