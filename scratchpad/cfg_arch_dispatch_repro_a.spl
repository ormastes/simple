# Repro for issue #45: interpreter @cfg arch-variant dispatch.
# Order A: x86_64 variant declared FIRST, arm64 second.
# On an x86_64 host, arch_name() must return "x86_64" in BOTH orders.

@cfg(x86_64)
fn arch_name() -> text:
    "x86_64"

@cfg(arm64)
fn arch_name() -> text:
    "arm64"

fn main() -> i32:
    val got = arch_name()
    print("order A (x86_64 first): arch_name() = {got}")
    if got == "x86_64":
        print("PASS")
        return 0
    print("FAIL: expected x86_64")
    1
