"""
# Adversarial: Privilege Escalation + Attenuation Bypass (OCap Hardening)

**Feature IDs:** #OS-OCAP-HARDEN
**Category:** Runtime / Security (adversarial)
**Difficulty:** 4/5
**Status:** Implemented
**Plan:** doc/04_architecture/os/security/ocap_privilege_architecture.md (§P1)

## Overview

These specs TRY TO BREAK the OCap privilege invariants and assert every attempt
FAILS CLOSED — an escalation or attenuation-widening request is REJECTED, never
silently granted.

Requirement 1 (escalation): a child C-Space cannot obtain a cap the parent
lacks; a fork of an empty pouch stays empty (no ambient gain); an ambient
`full()` parent authorizes NOTHING through `spawn_with_cspace`; a subrole cannot
widen its own rights; and `create_child_session` cannot be handed an ambient-full
ceiling to mint a child ABOVE its parent.

Requirement 2 (attenuation): a request for a WIDER path-prefix, a BROADER device
class, a LARGER extent, or a WIDER rights-mask than the parent grant is denied by
`capability_kind_allows` and dropped by the mint.

### FOUND + FIXED — a real fail-OPEN bypass

`create_child_session` used `capset_subset(ceiling, parent.current)` to enforce
containment. `capset_subset` iterates only the SUB set's concrete tokens, so an
ambient-full ceiling (`is_pledged:false` + zero tokens) has NOTHING to iterate
and VACUOUSLY passed containment — minting a child session whose `current`
authorizes everything the narrow parent did NOT (a session-authority
escalation). Root-fixed minimally in `create_child_session` (an ambient ceiling
is contained ONLY by an ambient parent). The regression guard is
`create_child_session cannot be handed an ambient-full ceiling` below.
"""

use std.spec.{describe, it, expect}
use os.kernel.types.task_types.{TaskId}
use os.kernel.types.capability_types.{CapabilityToken, CapabilityKind, CapabilitySet, CAP_RIGHT_READ, CAP_RIGHT_WRITE, capability_kind_allows}
use os.kernel.types.session_types.{SessionKind}
use os.kernel.ipc.capability.{CapabilityManager}
use os.kernel.ipc.cspace_spawn.{SpawnSpec, CapGrant, AttenuationSpec, CspaceMint, spawn_with_cspace, fork_cspace, spawn_full, atten_identity, atten_rights}

# ============================================================================
# Fixtures
# ============================================================================

val CAL_OBJ: u64 = 4242u64
val CAL_GEN: u64 = 7u64
val IMG: text = "blake3:same-binary"

fn _tickets() -> CapabilityKind:
    CapabilityKind.IpcConnect(port_name: "svc.tickets")

fn _calendar_rw() -> CapabilityKind:
    CapabilityKind.SharedDataset(object_id: CAL_OBJ, generation: CAL_GEN, rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE)

fn _calendar_ro() -> CapabilityKind:
    CapabilityKind.SharedDataset(object_id: CAL_OBJ, generation: CAL_GEN, rights: CAP_RIGHT_READ)

fn _fwrite_var() -> CapabilityKind:
    CapabilityKind.FileWrite(path_prefix: "/var")

fn _fread_var() -> CapabilityKind:
    CapabilityKind.FileRead(path_prefix: "/var")

fn _tok(kind: CapabilityKind, generation: u64, tid: u64, depth: i64) -> CapabilityToken:
    CapabilityToken(kind: kind, generation: generation, owner: 1u64, token_id: tid, parent_token_id: 0u64, depth: depth)

fn make_parent() -> CapabilitySet:
    """Orchestrator holds tickets(tid 100) + calendar rw(tid 101) — but NO FS write."""
    CapabilitySet(caps: [_tok(_tickets(), 1u64, 100u64, 2), _tok(_calendar_rw(), 2u64, 101u64, 2)], is_pledged: true)

# ============================================================================
# Group 1 — Privilege escalation attempts (must fail closed)
# ============================================================================

describe "adversarial escalation: child cannot exceed parent authority":
    """Every escalation attempt is REJECTED and the illicit cap stays absent."""

    it "a multi-grant recipe drops the ONE cap the parent lacks (FileWrite)":
        val spec = SpawnSpec(
            image_hash: IMG,
            grants: [
                CapGrant(label: "ipc.tickets", requested: _tickets(), atten: atten_identity()),
                CapGrant(label: "fs.write",    requested: _fwrite_var(), atten: atten_identity()),
                CapGrant(label: "mem.calendar", requested: _calendar_rw(), atten: atten_identity())
            ],
            isolation: "sandbox", budget: 0u64
        )
        val m = spawn_with_cspace(make_parent(), spec, 20u64, 1000u64, 300u64)
        expect(m.rejected).to_equal(1)
        expect(m.caps.has(_tickets())).to_equal(true)
        expect(m.caps.has(_calendar_ro())).to_equal(true)
        expect(m.caps.has(_fwrite_var())).to_equal(false)

    it "fork of an EMPTY pouch stays empty (no ambient authority gained)":
        val fk = fork_cspace(CapabilitySet.empty(), 30u64, 2000u64, 400u64)
        expect(fk.caps.caps.len()).to_equal(0)
        expect(fk.caps.is_pledged).to_equal(true)
        expect(fk.caps.has(CapabilityKind.ProcessSpawn)).to_equal(false)
        expect(fk.caps.has(_fread_var())).to_equal(false)

    it "an ambient full() parent authorizes NOTHING through spawn_with_cspace":
        val spec = SpawnSpec(
            image_hash: IMG,
            grants: [
                CapGrant(label: "ipc.tickets", requested: _tickets(), atten: atten_identity()),
                CapGrant(label: "mem.calendar", requested: _calendar_rw(), atten: atten_identity())
            ],
            isolation: "sandbox", budget: 0u64
        )
        val m = spawn_with_cspace(spawn_full(), spec, 21u64, 3000u64, 500u64)
        expect(m.rejected).to_equal(2)
        expect(m.caps.caps.len()).to_equal(0)
        expect(m.caps.has(_tickets())).to_equal(false)
        expect(m.caps.has(_calendar_ro())).to_equal(false)

    it "a subrole cannot WIDEN its own rights (parent ro, mask asks rw)":
        var mgr = CapabilityManager.new()
        val user = mgr.login("alice", CapabilitySet(caps: [_tok(_calendar_ro(), 1u64, 60u64, 2)], is_pledged: true))
        val sub = mgr.open_subrole(user, [_calendar_rw()])
        # Asked for rw; parent only held ro -> pledge keeps only EXACT-kind matches,
        # so the subrole gets NEITHER rw NOR the original ro. No widening, ever.
        expect(sub.current.has(_calendar_rw())).to_equal(false)
        expect(sub.current.has(_calendar_ro())).to_equal(false)

    it "a subrole cannot REGAIN a cap the parent never held (FileWrite)":
        var mgr = CapabilityManager.new()
        val user = mgr.login("bob", CapabilitySet(caps: [_tok(_fread_var(), 1u64, 61u64, 2)], is_pledged: true))
        val sub = mgr.open_subrole(user, [_fwrite_var()])
        expect(sub.current.has(_fwrite_var())).to_equal(false)

describe "adversarial escalation: session containment (create_child_session)":
    """A child session can NEVER be minted above its parent — including via the
    ambient-full ceiling trick that once vacuously passed capset_subset."""

    it "REGRESSION GUARD: an ambient-full ceiling under a narrow parent is REJECTED":
        var mgr = CapabilityManager.new()
        val narrow = CapabilitySet(caps: [_tok(_fread_var(), 1u64, 10u64, 2)], is_pledged: true)
        val root = mgr.login("root", narrow)
        val ambient = CapabilitySet.full()
        val esc = mgr.create_child_session(root.id, SessionKind.User, "evil", ambient, ambient, 0u64)
        expect(esc == nil).to_equal(true)

    it "a child whose CURRENT exceeds its own ceiling is REJECTED":
        var mgr = CapabilityManager.new()
        val root = mgr.login("root", CapabilitySet(caps: [_tok(_fread_var(), 1u64, 11u64, 2), _tok(_fwrite_var(), 2u64, 12u64, 2)], is_pledged: true))
        val ceil = CapabilitySet(caps: [_tok(_fread_var(), 3u64, 13u64, 2)], is_pledged: true)
        val cur_over = CapabilitySet(caps: [_tok(_fwrite_var(), 4u64, 14u64, 2)], is_pledged: true)
        val bad = mgr.create_child_session(root.id, SessionKind.Tenant, "x", ceil, cur_over, 0u64)
        expect(bad == nil).to_equal(true)

    it "a legit narrowing child IS accepted (fix does not over-block)":
        var mgr = CapabilityManager.new()
        val narrow = CapabilitySet(caps: [_tok(_fread_var(), 1u64, 15u64, 2)], is_pledged: true)
        val root = mgr.login("root", narrow)
        val within = CapabilitySet(caps: [_tok(_fread_var(), 2u64, 16u64, 2)], is_pledged: true)
        val ok = mgr.create_child_session(root.id, SessionKind.Tenant, "sub", within, within, 0u64)
        expect(ok != nil).to_equal(true)

# ============================================================================
# Group 2 — Attenuation bypass attempts (capability_kind_allows must deny)
# ============================================================================

describe "adversarial attenuation: widening is denied by capability_kind_allows":
    """Path, class, extent, and rights widening are all rejected; only NARROWING
    is authorized."""

    it "wider path-prefix is denied (/var held -> / requested)":
        expect(capability_kind_allows(_fread_var(), CapabilityKind.FileRead(path_prefix: "/"))).to_equal(false)

    it "sibling path is denied (/var held -> /etc requested)":
        expect(capability_kind_allows(_fread_var(), CapabilityKind.FileRead(path_prefix: "/etc"))).to_equal(false)

    it "narrower path IS allowed (/var held -> /var/log requested)":
        expect(capability_kind_allows(_fread_var(), CapabilityKind.FileRead(path_prefix: "/var/log"))).to_equal(true)

    it "sneaky prefix-not-on-boundary is denied (/var held -> /vardata requested)":
        expect(capability_kind_allows(_fread_var(), CapabilityKind.FileRead(path_prefix: "/vardata"))).to_equal(false)

    it "broader device class is denied (class 1 held -> class 2 requested)":
        val held = CapabilityKind.DeviceEnumerate(class_code: 1, subclass: 0)
        val req = CapabilityKind.DeviceEnumerate(class_code: 2, subclass: 0)
        expect(capability_kind_allows(held, req)).to_equal(false)

    it "widening the subclass wildcard is denied (class1/sub5 -> class1/all)":
        val held = CapabilityKind.DeviceEnumerate(class_code: 1, subclass: 5)
        val req = CapabilityKind.DeviceEnumerate(class_code: 1, subclass: 0)
        expect(capability_kind_allows(held, req)).to_equal(false)

    it "larger DMA byte budget is denied (1000 held -> 2000 requested)":
        val held = CapabilityKind.DeviceDma(bdf_bus: 0, bdf_device: 4, bdf_func: 0, max_bytes: 1000)
        val req = CapabilityKind.DeviceDma(bdf_bus: 0, bdf_device: 4, bdf_func: 0, max_bytes: 2000)
        expect(capability_kind_allows(held, req)).to_equal(false)

    it "an extent reaching outside the parent window is denied":
        val held = CapabilityKind.StorageExtent(object_id: 44, offset_lba: 100, lba_count: 50, rights: CAP_RIGHT_READ, generation: 7)
        val outside = CapabilityKind.StorageExtent(object_id: 44, offset_lba: 80, lba_count: 100, rights: CAP_RIGHT_READ, generation: 7)
        expect(capability_kind_allows(held, outside)).to_equal(false)

    it "an extent inside the parent window IS allowed":
        val held = CapabilityKind.StorageExtent(object_id: 44, offset_lba: 100, lba_count: 50, rights: CAP_RIGHT_READ, generation: 7)
        val inside = CapabilityKind.StorageExtent(object_id: 44, offset_lba: 120, lba_count: 8, rights: CAP_RIGHT_READ, generation: 7)
        expect(capability_kind_allows(held, inside)).to_equal(true)

    it "rights widening r -> rw is denied (SharedDataset)":
        expect(capability_kind_allows(_calendar_ro(), _calendar_rw())).to_equal(false)

    it "rights widening r -> rw is denied (Mount)":
        val held = CapabilityKind.Mount(path_prefix: "/data", rights: CAP_RIGHT_READ)
        val req = CapabilityKind.Mount(path_prefix: "/data", rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE)
        expect(capability_kind_allows(held, req)).to_equal(false)

    it "the mint DROPS a path-widening attenuation (/var parent, / attenuation)":
        val parent = CapabilitySet(caps: [_tok(_fread_var(), 1u64, 50u64, 2)], is_pledged: true)
        val widen = SpawnSpec(
            image_hash: IMG,
            grants: [CapGrant(label: "fs.read", requested: _fread_var(), atten: AttenuationSpec(rights_mask: 0u32, path_prefix: "/", depth_limit: -1, single_use: false))],
            isolation: "sandbox", budget: 0u64
        )
        val mm = spawn_with_cspace(parent, widen, 40u64, 4000u64, 600u64)
        expect(mm.rejected).to_equal(1)
        expect(mm.caps.has(CapabilityKind.FileRead(path_prefix: "/"))).to_equal(false)
