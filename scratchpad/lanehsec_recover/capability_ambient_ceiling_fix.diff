+    # ========================================================================
+    # S1–S3 — Privilege Session Hierarchy
+    #
+    # login() mints a root User session; open_subrole() irreversibly narrows a
+    # child; session_teardown() DFS-seals a subtree and bumps each epoch (O(1)
+    # bulk revoke). check() consults _session_live() so a bound task's caps die
+    # the instant its session (or any ancestor) is torn down.
+    # ========================================================================
+
+    me login(principal: text, max_caps: CapabilitySet) -> Session:
+        """S1: mint a root User session for an authenticated principal.
+
+        ceiling == current == max_caps (the principal's full granted authority).
+        Root sessions have no parent (parent = 0) so no containment check
+        applies. Each login draws a FRESH id AND a FRESH epoch, so two
+        concurrent logins are disjoint in both identity and generation — the
+        keystone that lets one login's teardown never touch another's caps.
+        """
+        val sid = self.next_session_id
+        self.next_session_id = self.next_session_id + 1
+        val ep = self.next_session_epoch
+        self.next_session_epoch = self.next_session_epoch + 1
+        val s = Session(
+            id: sid,
+            kind: SessionKind.User,
+            epoch: ep,
+            principal: principal,
+            ceiling: max_caps,
+            current: max_caps,
+            budget: 0u64,
+            parent: 0u64,
+            children: [],
+            sealed: false
+        )
+        self.sessions.push(s)
+        s
+
+    me create_child_session(parent_id: u64, kind: SessionKind, principal: text, ceiling: CapabilitySet, current: CapabilitySet, budget: u64) -> Session?:
+        """Create a child session under `parent_id`, enforcing the S1 invariant
+        ceiling(child) ⊆ current(parent) (and current ⊆ ceiling). Returns nil
+        (fail closed) when the parent is unknown, sealed, or the containment
+        invariant is violated — a child can NEVER be minted above its parent.
+        """
+        val parent_opt = self._find_session(parent_id)
+        if parent_opt == nil:
+            return nil
+        val parent = parent_opt
+        if parent.sealed:
+            return nil
+        # SECURITY (fail-closed): an ambient-full set (is_pledged:false + zero
+        # tokens) represents ALL authority, but capset_subset only iterates its
+        # (empty) token list and would VACUOUSLY pass containment — minting a
+        # child ABOVE its parent (a session-authority escalation). Guard it
+        # explicitly: an ambient ceiling is contained only by an ambient parent,
+        # and an ambient current only by an ambient ceiling.
+        val ceiling_ambient = (not ceiling.is_pledged) and (ceiling.caps.len() == 0)
+        val parent_ambient = (not parent.current.is_pledged) and (parent.current.caps.len() == 0)
+        if ceiling_ambient and (not parent_ambient):
+            return nil
+        val current_ambient = (not current.is_pledged) and (current.caps.len() == 0)
+        if current_ambient and (not ceiling_ambient):
+            return nil
+        # Invariant: the child's ceiling must sit within the parent's CURRENT
+        # authority, and the child's current within its own ceiling.
+        if not capset_subset(ceiling, parent.current):
+            return nil
+        if not capset_subset(current, ceiling):
+            return nil
+        val sid = self.next_session_id
+        self.next_session_id = self.next_session_id + 1
+        val ep = self.next_session_epoch
+        self.next_session_epoch = self.next_session_epoch + 1
+        val child = Session(
+            id: sid,
+            kind: kind,
+            epoch: ep,
+            principal: principal,
+            ceiling: ceiling,
+            current: current,
+            budget: budget,
+            parent: parent_id,
+            children: [],
+            sealed: false
+        )
+        self.sessions.push(child)
+        self._add_child(parent_id, sid)
+        child
+
+    me open_subrole(parent_session: Session, mask: [CapabilityKind]) -> Session:
+        """S2: drop into an irreversibly narrowed SubRole of `parent_session`.
+
+        The child's current is a FRESH unpledged clone of the parent's current
+        set, then pledge(mask) filters it to exactly the masked caps the parent
+        actually holds. Because pledge can only KEEP tokens already present, a
+        subrole can NEVER regain a dropped cap and can never exceed the parent
+        ceiling — the drop is monotonic and irreversible. On an unknown/sealed
+        parent, returns a sealed deny-all session (fail closed).
+        """
+        var parent = parent_session
+        val live = self._find_session(parent_session.id)
+        if live != nil:
+            parent = live
+        var child_current = capset_clone_unpledged(parent.current)
+        child_current.pledge(mask)
+        val child_opt = self.create_child_session(parent.id, SessionKind.SubRole, parent.principal, child_current, child_current, 0u64)
+        if child_opt != nil:
+            val child = child_opt
+            return child
+        Session(
+            id: 0u64,
+            kind: SessionKind.SubRole,
+            epoch: 0u64,
+            principal: parent.principal,
+            ceiling: CapabilitySet.empty(),
+            current: CapabilitySet.empty(),
+            budget: 0u64,
+            parent: parent.id,
+            children: [],
+            sealed: true
+        )
+
+    me bind_task_to_session(task: TaskId, session_id: u64):
+        """Bind a task's capability record to a session. Capability checks for
+        the task then also require the session to be live at its bound epoch."""
+        var ep = 0u64
+        val s_opt = self._find_session(session_id)
+        if s_opt != nil:
+            val s = s_opt
+            ep = s.epoch
+        var idx = 0
+        while idx < self.records.len():
+            var rec = self.records[idx]
+            if rec.task_id.id == task.id:
+                rec.session_id = session_id
+                rec.session_epoch = ep
+                self.records[idx] = rec
+                return
+            idx = idx + 1
+
+    me session_teardown(root_session: Session):
+        """S3: tear down `root_session` and its whole subtree.
+
+        DFS the subtree via parent links; each session is sealed and given a
+        FRESH epoch. That single epoch bump revokes every capability bound to
+        the session in O(1) (no per-token walk) — bound records fail
+        _session_live on the epoch mismatch. The subtree's remaining budget is
+        refunded upward to the teardown root's parent.
+        """
+        var worklist: [u64] = []
+        worklist.push(root_session.id)
+        var subtree: [u64] = []
+        var wi = 0
+        while wi < worklist.len():
+            val cur = worklist[wi]
+            wi = wi + 1
+            var seen = false
+            for sid in subtree:
+                if sid == cur:
+                    seen = true
+            if not seen:
+                subtree.push(cur)
+                for s in self.sessions:
+                    if s.parent == cur:
+                        worklist.push(s.id)
+        var refund: u64 = 0u64
+        var root_parent: u64 = 0u64
+        var idx = 0
+        while idx < self.sessions.len():
+            var s = self.sessions[idx]
+            var in_sub = false
+            for sid in subtree:
+                if sid == s.id:
+                    in_sub = true
+            if in_sub:
+                if s.id == root_session.id:
+                    root_parent = s.parent
+                refund = refund + s.budget
+                s.budget = 0u64
+                s.sealed = true
+                val nep = self.next_session_epoch
+                self.next_session_epoch = self.next_session_epoch + 1
+                s.epoch = nep
+                self.sessions[idx] = s
+            idx = idx + 1
+        if root_parent != 0u64:
+            self._credit_budget(root_parent, refund)
+
+    fn session_of(session_id: u64) -> Session?:
+        """Public accessor: current table state for a session id (or nil)."""
+        self._find_session(session_id)
+
+    fn _find_session(session_id: u64) -> Session?:
+        """Find a session by id, or nil."""
+        for s in self.sessions:
+            if s.id == session_id:
+                return s
+        nil
+
+    me _add_child(parent_id: u64, child_id: u64):
+        """Register child_id under the parent's children list (idempotent)."""
+        var idx = 0
+        while idx < self.sessions.len():
+            var s = self.sessions[idx]
+            if s.id == parent_id:
+                var already = false
+                for c in s.children:
+                    if c == child_id:
+                        already = true
+                if not already:
+                    s.children.push(child_id)
+                    self.sessions[idx] = s
+                return
+            idx = idx + 1
+
+    me _credit_budget(session_id: u64, amount: u64):
+        """Add refunded budget to a live session (S3 upward refund)."""
+        var idx = 0
+        while idx < self.sessions.len():
+            var s = self.sessions[idx]
+            if s.id == session_id:
+                s.budget = s.budget + amount
+                self.sessions[idx] = s
+                return
+            idx = idx + 1
+
+    fn _session_live(session_id: u64, bound_epoch: u64) -> bool:
+        """A bound capability is live iff its session exists, is not sealed, and
+        its epoch still matches the epoch captured at bind time."""
+        val s_opt = self._find_session(session_id)
+        if s_opt == nil:
+            return false
+        val s = s_opt
+        if s.sealed:
+            return false
+        if s.epoch != bound_epoch:
+            return false
+        true
+
+    # ========================================================================
+    # S5 — Container: CSpace + budget + namespace, session-owned, epoch-bound
+    #
+    # A container is the §3.6/§17 SHAPE of a CSpace (cspace + sub-budget + label
+    # namespace) owned by exactly ONE session. It captures that session's epoch
+    # at creation, so session_teardown's epoch bump revokes every container the
+    # session owns in O(1) — a container cap dies with its session.
+    # ========================================================================
+
+    me create_container(owner_session_id: u64, cspace: CapabilitySet, budget: u64, labels: [text]) -> Container?:
+        """S5: create a container owned by `owner_session_id`. Fail-closed unless
+        the owner session exists and is live, cspace ⊆ owner.current (a container
+        can never see wider authority than the session that owns it), AND the
+        container budget fits within the owner's budget (quota). The container
+        captures owner.epoch, so an owner teardown revokes it with no walk."""
+        val owner_opt = self._find_session(owner_session_id)
+        if owner_opt == nil:
+            return nil
+        val owner = owner_opt
+        if owner.sealed:
+            return nil
+        if not capset_subset(cspace, owner.current):
+            return nil
+        if budget > owner.budget:
+            return nil
+        val cid = self.next_container_id
+        self.next_container_id = self.next_container_id + 1
+        val c = Container(
+            id: cid,
+            owner_session: owner_session_id,
+            cspace: cspace,
+            budget: budget,
+            labels: labels,
+            epoch: owner.epoch
+        )
+        self.containers.push(c)
+        c
+
+    fn container_live(c: Container) -> bool:
+        """A container is live iff its owning session is still live at the epoch
+        captured when the container was created. A session teardown bumps that
+        epoch (or seals the session), so every container it owns dies at once."""
+        self._session_live(c.owner_session, c.epoch)
+
+    fn container_of(container_id: u64) -> Container?:
+        """Public accessor: current table state for a container id (or nil)."""
+        for c in self.containers:
+            if c.id == container_id:
+                return c
+        nil
+
+    # ========================================================================
+    # S5 — Escrow: cross-session single-use cowork (powerbox, research §17)
+    #
+    # The "scheduler-LLM hands ticketing-LLM a one-shot create-ticket cap" flow:
+    # a single-use cap minted into the RECEIVER's arena, bound to the RECEIVER's
+    # epoch (so it dies with the receiver, never leaks out of a torn-down sender),
+    # consumed on first use, and monotonic (never exceeds the sender's current).
+    # ========================================================================
+
+    me escrow_cap(from_session_id: u64, to_session_id: u64, cap: CapabilityToken) -> EscrowCap?:
+        """S5: mint a SINGLE-USE cap from `from_session` into `to_session`'s arena.
+
+        Monotonic: the sender must actually hold `cap.kind` in its CURRENT
+        authority (never the sender's max) — an escrow can never exceed the
+        sender. Fail-closed when either session is unknown/sealed or the sender
+        lacks the authority. The escrow is bound to the RECEIVER's epoch, so it
+        dies with the receiver."""
+        val from_opt = self._find_session(from_session_id)
+        if from_opt == nil:
+            return nil
+        val from_s = from_opt
+        if from_s.sealed:
+            return nil
+        val to_opt = self._find_session(to_session_id)
+        if to_opt == nil:
+            return nil
+        val to_s = to_opt
+        if to_s.sealed:
+            return nil
+        if not from_s.current.has(cap.kind):
+            return nil
+        val eid = self.next_escrow_id
+        self.next_escrow_id = self.next_escrow_id + 1
+        val e = EscrowCap(
+            id: eid,
+            from_session: from_session_id,
+            to_session: to_session_id,
+            to_epoch: to_s.epoch,
+            cap: cap,
+            consumed: false
+        )
+        self.escrows.push(e)
+        e
+
+    me consume_escrow(escrow_id: u64, by_session_id: u64) -> CapabilityToken?:
+        """S5: redeem a single-use escrow. Returns the cap on the FIRST consume by
+        the intended receiver while its session is live; every later attempt (a
+        second consume, a wrong receiver, or a torn-down receiver) is DENIED
+        (nil). Single-use is enforced by flipping `consumed` on first success."""
+        var idx = 0
+        while idx < self.escrows.len():
+            var e = self.escrows[idx]
+            if e.id == escrow_id:
+                if e.consumed:
+                    return nil
+                if e.to_session != by_session_id:
+                    return nil
+                if not self._session_live(e.to_session, e.to_epoch):
+                    return nil
+                e.consumed = true
+                self.escrows[idx] = e
+                return e.cap
+            idx = idx + 1
+        nil
+
+    # ========================================================================
+    # S6 — Multi-tenant tree: System → Tenant → User, disjoint arenas + quota
+    #
+    # open_system mints the root of trust with a resource budget; Tenants and
+    # Users are create_child_quota children whose budget can NEVER exceed the
+    # parent's (per-node quota) and whose ceiling ⊆ parent.current (disjoint,
+    # monotone-down arenas). Teardown of a Tenant cascades to all descendants via
+    # the existing session_teardown DFS epoch bump.
+    # ========================================================================
+
+    me open_system(principal: text, ceiling: CapabilitySet, budget: u64) -> Session:
+        """S6: mint the root System session — the top of the multi-tenant tree.
+
+        Like login() but kind == System and with an explicit resource budget that
+        Tenant/User children draw against via create_child_quota. Fresh id +
+        epoch, no parent (parent = 0)."""
+        val sid = self.next_session_id
+        self.next_session_id = self.next_session_id + 1
+        val ep = self.next_session_epoch
+        self.next_session_epoch = self.next_session_epoch + 1
+        val s = Session(
+            id: sid,
+            kind: SessionKind.System,
+            epoch: ep,
+            principal: principal,
+            ceiling: ceiling,
+            current: ceiling,
+            budget: budget,
+            parent: 0u64,
+            children: [],
+            sealed: false
+        )
+        self.sessions.push(s)
+        s
+
+    me create_child_quota(parent_id: u64, kind: SessionKind, principal: text, ceiling: CapabilitySet, current: CapabilitySet, budget: u64) -> Session?:
+        """S6: create a multi-tenant child (System → Tenant → User) enforcing the
+        per-node budget quota ON TOP of the S1 ceiling containment. Returns nil
+        (fail closed) when budget > parent.budget (a child can never be funded
+        above its parent) or when the ceiling(child) ⊆ current(parent) invariant
+        fails. The plain create_child_session keeps its budget-agnostic behavior
+        for callers that account budget separately."""
+        val parent_opt = self._find_session(parent_id)
+        if parent_opt == nil:
+            return nil
+        val parent = parent_opt
+        if budget > parent.budget:
+            return nil
+        self.create_child_session(parent_id, kind, principal, ceiling, current, budget)
+
