struct SymId:
    id: i64
struct FV:
    symbol: SymId
    name: text
struct Decoy:
    name: text
    a: i64
    b: i64
    c: i64
enum Val:
    Int(i64)
    Func(FV)
    Str(text)
    Nil

fn get_it(d: Dict<text, Val>, k: text) -> Val?:
    val v = d[k]
    if v == nil:
        return nil
    return Some(v)

fn main():
    val fv = FV(symbol: SymId(id: 3), name: "P")
    val v: Val = Val.Func(fv)
    var d: Dict<text, Val> = {}
    d["P"] = v
    # mirror env.lookup -> Option<Val> -> unwrap
    val opt = get_it(d, "P")
    if opt.?:
        val loaded = opt.unwrap()
        match loaded:
            case Val.Func(f):
                print("opt f_nil={f == nil} name={f.name}")
            case _:
                print("opt other")
    else:
        print("opt miss")
