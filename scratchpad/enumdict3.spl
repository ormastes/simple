struct FV:
    name: text
enum Val:
    Int(i64)
    Func(FV)
    Nil

fn main():
    val fv = FV(name: "P")
    val v: Val = Val.Func(fv)
    # (a) inline Some(enum) unwrap, no dict/fn
    val optA: Val? = Some(v)
    match optA.unwrap():
        case Val.Func(f): print("A ok name={f.name}")
        case _: print("A CORRUPT")
    # (b) dict then inline Some
    var d: Dict<text, Val> = {}
    d["P"] = v
    val vb = d["P"]
    val optB: Val? = Some(vb)
    match optB.unwrap():
        case Val.Func(f): print("B ok name={f.name}")
        case _: print("B CORRUPT")
    # (c) dict, no Option, direct match
    match d["P"]:
        case Val.Func(f): print("C ok name={f.name}")
        case _: print("C CORRUPT")
