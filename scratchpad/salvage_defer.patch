+# if/while/for/match body, ...). Unlike `convert_flat_stmt` (one raw stmt ->
+# exactly one `Stmt`), this can expand to zero statements (a top-level defer
+# registers itself and contributes nothing at its own position) or more than
+# one (a `return` — at any nesting depth in this function — gets the current
+# pending defers spliced in LIFO order immediately before it).
+fn convert_flat_stmt_in_list(idx: i64, is_top_level: bool) -> [Stmt]:
+    val tag = stmt_get_tag(idx)
+    if tag == STMT_DEFER:
+        if is_top_level:
