diff --git a/src/compiler/50.mir/mir_lowering_stmts.spl b/src/compiler/50.mir/mir_lowering_stmts.spl
index f5ce2106897..6416f348611 100644
--- a/src/compiler/50.mir/mir_lowering_stmts.spl
+++ b/src/compiler/50.mir/mir_lowering_stmts.spl
@@ -703,8 +703,14 @@ impl MirLowering:
 
         self.lower_block(body)
 
+        # If the body's last statement already terminated the current block
+        # (an explicit break/continue/return with no trailing code), don't
+        # add a second terminator -- doing so would silently overwrite it
+        # (e.g. turning a trailing `break` into a backedge, making the loop
+        # infinite). Mirrors the guard in lower_for.
         var b3 = self.builder
-        b3.terminate_goto(loop_block)
+        if not b3.current_block_has_explicit_terminator():
+            b3.terminate_goto(loop_block)
         self.builder = b3
 
         self.loop_stack = self.loop_stack[0:self.loop_stack.len() - 1]
@@ -738,8 +744,15 @@ impl MirLowering:
 
         self.lower_block(body)
 
+        # If the body's last statement already terminated the current block
+        # (an explicit break/continue/return with no trailing code), don't
+        # add a second terminator -- doing so would silently overwrite it
+        # (e.g. turning a trailing `break` into a backedge, making the loop
+        # infinite -- #163: `while true:`/`loop:` + continue). Mirrors the
+        # guard in lower_for.
         var b4 = self.builder
-        b4.terminate_goto(cond_block)
+        if not b4.current_block_has_explicit_terminator():
+            b4.terminate_goto(cond_block)
         self.builder = b4
 
         self.loop_stack = self.loop_stack[0:self.loop_stack.len() - 1]
