@when(x86_64)
fn arch_name() -> text:
    "x86_64"
@end

@when(arm64)
fn arch_name() -> text:
    "arm64"
@end

fn main() -> i32:
    val got = arch_name()
    print("when-form (x86_64 first): arch_name() = {got}")
    if got == "x86_64":
        print("PASS")
        return 0
    print("FAIL: expected x86_64")
    1
