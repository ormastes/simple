use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_spec_gen_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/test/feature && cat > " + FIXTURE_DIR + "/test/feature/sample_spec.spl <<'EOF'\n/// Sample feature docs\ndescribe \"sample feature\":\n    it \"does useful work\":\n        assert true\nEOF"
    ])

fn _run_spec_gen(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/spec_gen/main.spl\" " + joined
    ])

describe "spec-gen log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_spec_gen(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_spec_gen(["--log-mode=json", "test/feature"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"spec-gen\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"generated\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_spec_gen(["--progress=dot", "test/feature"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Generated 1 spec documents")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_spec_gen(["--log-mode=noisy", "test/feature"])
        expect(code).to_equal(1)
