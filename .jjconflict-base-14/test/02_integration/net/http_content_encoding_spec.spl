# End-to-end integration spec for Phase 1 HTTP Content-Encoding negotiation +
# compression round-trip.
#
# Exercises: Accept-Encoding parse → negotiate_encoding → compress_response_for
# → compressed bytes → client-side decompress → length match.
#
# No sockets, no file-system I/O, no real listener — pure library round-trip.

use std.spipe.*
use std.http_server.types.{HttpResponseData}
use std.nogc_async_mut.http_server.compression.{
    compress_response_body,
    compress_response_for,
    supported_encodings,
}
use std.common.compress.{decompress_bytes}
use std.nogc_sync_mut.compression.gzip.{gzip_decompress}
use std.nogc_sync_mut.compression.zlib.{zlib_decompress}

# ----------------------------------------------------------------------------
# Module-level payload helpers — built outside it-blocks to avoid the
# it-block var-mutation footgun (rebinds in while-loops don't persist).
# ----------------------------------------------------------------------------

# 1 120 bytes of repetitive ASCII — well above the 256-byte minimum threshold.
fn _make_payload() -> [u8]:
    val unit: [u8] = [
        0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6au8
    ]
    var bytes: [u8] = []
    var i: i64 = 0
    while i < 112:
        bytes = bytes + unit
        i = i + 1
    bytes

# 100 bytes — deliberately below the 256-byte COMPRESSION_MIN_BODY_BYTES guard.
fn _make_tiny_payload() -> [u8]:
    val unit: [u8] = [
        0x41u8, 0x42u8, 0x43u8, 0x44u8, 0x45u8, 0x46u8, 0x47u8, 0x48u8,
        0x49u8, 0x4au8
    ]
    var bytes: [u8] = []
    var i: i64 = 0
    while i < 10:
        bytes = bytes + unit
        i = i + 1
    bytes

fn _resp_with_byte_body(body_bytes: [u8]) -> HttpResponseData:
    HttpResponseData(
        status: 200,
        reason: "OK",
        headers: [("Content-Type", "application/octet-stream")],
        body: "",
        body_bytes: body_bytes,
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

fn _resp_with_text_body(body: text) -> HttpResponseData:
    HttpResponseData(
        status: 200,
        reason: "OK",
        headers: [("Content-Type", "text/plain")],
        body: body,
        body_bytes: [],
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

fn _has_header(headers: [(text, text)], name: text) -> bool:
    for h in headers:
        if h.0.lower() == name.lower():
            return true
    false

fn _get_header(headers: [(text, text)], name: text) -> text:
    for h in headers:
        if h.0.lower() == name.lower():
            return h.1
    ""

# ----------------------------------------------------------------------------
# Integration spec — all 12 cases in a single describe block
# ----------------------------------------------------------------------------

describe "Phase 1 HTTP Content-Encoding integration":

    # 1. Full Accept-Encoding header with multiple codecs — server picks zstd
    #    (highest server preference), then body decompresses back to original.
    it "zstd wins when client offers gzip, zstd, lz4, deflate; body round-trips":
        val payload = _make_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "gzip, zstd, lz4, deflate")
        expect(_get_header(out.headers, "content-encoding")).to_equal("zstd")
        expect(out.body_bytes.len() > 0).to_equal(true)
        val round_trip = decompress_bytes(out.body_bytes, nil)
        expect(round_trip.is_ok()).to_equal(true)
        val decoded = round_trip.unwrap()
        expect(decoded.len()).to_equal(payload.len())

    # 2. gzip-only client — server must use gzip; body decompresses via gzip.
    it "gzip-only client: Content-Encoding gzip, body round-trips via gzip_decompress":
        val payload = _make_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "gzip")
        expect(_get_header(out.headers, "content-encoding")).to_equal("gzip")
        expect(out.body_bytes.len() > 0).to_equal(true)
        # Verify gzip frame magic (RFC 1952)
        expect(out.body_bytes[0]).to_equal(0x1fu8)
        expect(out.body_bytes[1]).to_equal(0x8bu8)
        val decoded = gzip_decompress(out.body_bytes) ?? []
        expect(decoded.len()).to_equal(payload.len())

    # 3. deflate-only client — server uses deflate (zlib-wrapped). First byte
    #    must be 0x78 (zlib CMF). Body round-trips via zlib_decompress.
    it "deflate-only client: Content-Encoding deflate, zlib 0x78 magic, round-trips":
        val payload = _make_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "deflate")
        expect(_get_header(out.headers, "content-encoding")).to_equal("deflate")
        expect(out.body_bytes.len() > 0).to_equal(true)
        expect(out.body_bytes[0]).to_equal(0x78u8)
        val decoded = zlib_decompress(out.body_bytes) ?? []
        expect(decoded.len()).to_equal(payload.len())

    # 4. lz4-only client — server uses lz4 frame format; auto-detect magic OK.
    it "lz4-only client: Content-Encoding lz4, body round-trips via decompress_bytes":
        val payload = _make_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "lz4")
        expect(_get_header(out.headers, "content-encoding")).to_equal("lz4")
        expect(out.body_bytes.len() > 0).to_equal(true)
        val round_trip = decompress_bytes(out.body_bytes, nil)
        expect(round_trip.is_ok()).to_equal(true)
        val decoded = round_trip.unwrap()
        expect(decoded.len()).to_equal(payload.len())

    # 5. q-value preference: "lz4;q=0.5, gzip;q=0.9"
    #    negotiate_encoding iterates supported order (zstd→lz4→gzip→deflate),
    #    keeps highest q. zstd absent, lz4=500, gzip=900 → gzip wins.
    it "q-value: gzip;q=0.9 beats lz4;q=0.5 — highest q wins, server order breaks ties":
        val payload = _make_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "lz4;q=0.5, gzip;q=0.9")
        expect(_get_header(out.headers, "content-encoding")).to_equal("gzip")
        val decoded = gzip_decompress(out.body_bytes) ?? []
        expect(decoded.len()).to_equal(payload.len())

    # 6. All unsupported codecs — server has no matching codec → identity
    #    fallback. No Content-Encoding header; body_bytes unchanged.
    it "identity fallback when client only offers unsupported codecs":
        val payload = _make_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "br, snappy, weird")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)
        expect(out.body_bytes.len()).to_equal(payload.len())

    # 7. Tiny body (100 bytes) — below COMPRESSION_MIN_BODY_BYTES (256).
    #    Even with zstd in Accept-Encoding, response passes through unchanged.
    it "identity fallback for tiny body (below compression threshold)":
        val payload = _make_tiny_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "zstd")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)
        expect(out.body_bytes.len()).to_equal(payload.len())

    # 8. Chunked response — compression must be skipped regardless of accept.
    it "chunked response: compression skipped regardless of Accept-Encoding":
        val payload = _make_payload()
        val base = _resp_with_byte_body(payload)
        val resp = HttpResponseData(
            status: base.status,
            reason: base.reason,
            headers: base.headers,
            body: base.body,
            body_bytes: base.body_bytes,
            body_file: base.body_file,
            body_offset: base.body_offset,
            body_length: base.body_length,
            chunked: true
        )
        val out = compress_response_for(resp, "zstd, gzip, lz4, deflate")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)

    # 9. body_file path — sendfile path, compression skipped.
    it "body_file set: compression skipped, body_file preserved":
        val base = _resp_with_byte_body(_make_payload())
        val resp = HttpResponseData(
            status: base.status,
            reason: base.reason,
            headers: base.headers,
            body: "",
            body_bytes: [],
            body_file: "/tmp/foo.html",
            body_offset: 0,
            body_length: 1024,
            chunked: false
        )
        val out = compress_response_for(resp, "zstd")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)
        expect(out.body_file).to_equal("/tmp/foo.html")

    # 10. Pre-existing Content-Length removed after compression (caller must
    #     re-set it after chunked / re-framing).
    it "Content-Length removed from headers after successful compression":
        val payload = _make_payload()
        val base = _resp_with_byte_body(payload)
        val resp = HttpResponseData(
            status: base.status,
            reason: base.reason,
            headers: [("Content-Type", "text/plain"), ("Content-Length", "1120")],
            body: base.body,
            body_bytes: base.body_bytes,
            body_file: base.body_file,
            body_offset: base.body_offset,
            body_length: base.body_length,
            chunked: base.chunked
        )
        val out = compress_response_for(resp, "zstd")
        expect(_get_header(out.headers, "content-encoding")).to_equal("zstd")
        expect(_has_header(out.headers, "content-length")).to_equal(false)

    # 11. Existing Content-Encoding — compress_response_for must NOT re-compress.
    #     Original Content-Encoding header is preserved as-is.
    it "existing Content-Encoding preserved: no double-encoding":
        val payload = _make_payload()
        val base = _resp_with_byte_body(payload)
        val resp = HttpResponseData(
            status: base.status,
            reason: base.reason,
            headers: [("Content-Type", "image/png"), ("Content-Encoding", "gzip")],
            body: base.body,
            body_bytes: base.body_bytes,
            body_file: base.body_file,
            body_offset: base.body_offset,
            body_length: base.body_length,
            chunked: base.chunked
        )
        val out = compress_response_for(resp, "zstd")
        expect(_get_header(out.headers, "content-encoding")).to_equal("gzip")

    # 12. Determinism — "deflate, gzip, lz4, zstd" always picks zstd (highest
    #     server preference). Run 3 times to confirm.
    it "multi-codec selection is deterministic: zstd always wins over 3 runs":
        val payload = _make_payload()
        val accept = "deflate, gzip, lz4, zstd"

        val resp1 = _resp_with_byte_body(payload)
        val out1 = compress_response_for(resp1, accept)
        expect(_get_header(out1.headers, "content-encoding")).to_equal("zstd")

        val resp2 = _resp_with_byte_body(payload)
        val out2 = compress_response_for(resp2, accept)
        expect(_get_header(out2.headers, "content-encoding")).to_equal("zstd")

        val resp3 = _resp_with_byte_body(payload)
        val out3 = compress_response_for(resp3, accept)
        expect(_get_header(out3.headers, "content-encoding")).to_equal("zstd")
