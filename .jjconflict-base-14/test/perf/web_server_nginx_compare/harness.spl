# Nginx vs Simple Static File Server Benchmark Harness
#
# Runs wrk or ab (Apache Bench) against a running HTTP server and collects:
#   - requests/sec
#   - p99 latency (ms)
#   - throughput (MB/s)
#
# The caller is responsible for starting the server under test before calling
# run_benchmark, and stopping it afterwards.
#
# Depends on: std.io_runtime (shell_output_trimmed)

use std.io_runtime.{shell_output_trimmed, print}

# ============================================================================
# Result type
# ============================================================================

class BenchmarkResult:
    """Results from one benchmark run against one file size."""
    server: text        # "simple" or "nginx"
    rps: f64            # requests per second
    p99_latency_ms: f64 # 99th-percentile latency in milliseconds
    throughput_mbps: f64 # throughput in MB/s
    failure_count: i64  # non-2xx responses + socket errors
    file_size: i64      # file size in bytes that was tested
    timestamp: text     # ISO-8601 timestamp of this run

class BenchmarkConfig:
    """Configuration for a benchmark run."""
    server_label: text  # "simple" or "nginx"
    host: text          # e.g. "127.0.0.1"
    port: i64           # TCP port
    concurrency: i64    # number of concurrent connections
    duration_s: i64     # test duration in seconds
    fixture_dir: text   # directory containing bench/ fixtures

# ============================================================================
# Internal: parse wrk output
# ============================================================================

fn _parse_wrk_rps(output: text) -> f64:
    """Extract Requests/sec from wrk output."""
    val marker = "Requests/sec:"
    val idx = output.find(marker)
    if idx < 0:
        return 0.0
    val rest = output.slice(idx + marker.len(), output.len())
    val trimmed = rest.trim()
    val space_idx = trimmed.find(" ")
    val newline_idx = trimmed.find("\n")
    var end_idx = trimmed.len()
    if space_idx >= 0 and space_idx < end_idx:
        end_idx = space_idx
    if newline_idx >= 0 and newline_idx < end_idx:
        end_idx = newline_idx
    val num_text = trimmed.slice(0, end_idx).trim()
    num_text.parse_f64()

fn _parse_wrk_throughput(output: text) -> f64:
    """Extract Transfer/sec in MB/s from wrk output."""
    val marker = "Transfer/sec:"
    val idx = output.find(marker)
    if idx < 0:
        return 0.0
    val rest = output.slice(idx + marker.len(), output.len())
    val trimmed = rest.trim()
    # wrk reports e.g. "1.23MB" or "456.78KB"
    val mb_idx = trimmed.find("MB")
    val kb_idx = trimmed.find("KB")
    if mb_idx >= 0:
        val num_text = trimmed.slice(0, mb_idx).trim()
        return num_text.parse_f64()
    if kb_idx >= 0:
        val num_text = trimmed.slice(0, kb_idx).trim()
        return num_text.parse_f64() / 1024.0
    0.0

fn _parse_wrk_p99(output: text) -> f64:
    """Extract 99th-percentile latency in ms from wrk output.

    wrk prints latency percentiles like:
      99%    4.50ms
    Units may be us, ms, or s.
    """
    val marker = "99%"
    val idx = output.find(marker)
    if idx < 0:
        return 0.0
    val rest = output.slice(idx + marker.len(), output.len())
    val trimmed = rest.trim()
    val newline = trimmed.find("\n")
    var line = trimmed
    if newline >= 0:
        line = trimmed.slice(0, newline).trim()
    if line.find("ms") >= 0:
        val num_text = line.slice(0, line.find("ms")).trim()
        return num_text.parse_f64()
    if line.find("us") >= 0:
        val num_text = line.slice(0, line.find("us")).trim()
        return num_text.parse_f64() / 1000.0
    if line.find("s") >= 0:
        val num_text = line.slice(0, line.find("s")).trim()
        return num_text.parse_f64() * 1000.0
    0.0

fn _parse_wrk_failures(output: text) -> i64:
    """Extract failure count from wrk output.

    wrk prints 'Non-2xx or 3xx responses: NNN' and/or
    'Socket errors: connect N, read N, write N, timeout N'.
    Sum non-2xx count + socket error counts. Lines may be absent (= 0).
    """
    var total: i64 = 0
    # Non-2xx responses
    val non2xx_marker = "Non-2xx or 3xx responses:"
    val non2xx_idx = output.find(non2xx_marker)
    if non2xx_idx >= 0:
        val rest = output.slice(non2xx_idx + non2xx_marker.len(), output.len())
        val trimmed = rest.trim()
        val nl = trimmed.find("\n")
        var line = trimmed
        if nl >= 0:
            line = trimmed.slice(0, nl).trim()
        total = total + line.parse_i64()

    # Socket errors
    val sock_marker = "Socket errors:"
    val sock_idx = output.find(sock_marker)
    if sock_idx >= 0:
        val rest = output.slice(sock_idx + sock_marker.len(), output.len())
        val trimmed = rest.trim()
        val nl = trimmed.find("\n")
        var line = trimmed
        if nl >= 0:
            line = trimmed.slice(0, nl).trim()
        # Format: "connect N, read N, write N, timeout N"
        # Sum all numbers
        var pos = 0
        while pos < line.len():
            val ch = line.char_at(pos)
            if ch >= "0" and ch <= "9":
                var num_end = pos + 1
                while num_end < line.len():
                    val nc = line.char_at(num_end)
                    if nc >= "0" and nc <= "9":
                        num_end = num_end + 1
                    else:
                        break
                val num_text = line.slice(pos, num_end)
                total = total + num_text.parse_i64()
                pos = num_end
            else:
                pos = pos + 1
    total

# ============================================================================
# Internal: parse ab output
# ============================================================================

fn _parse_ab_rps(output: text) -> f64:
    """Extract Requests per second from ab output."""
    val marker = "Requests per second:"
    val idx = output.find(marker)
    if idx < 0:
        return 0.0
    val rest = output.slice(idx + marker.len(), output.len())
    val trimmed = rest.trim()
    val space_idx = trimmed.find(" ")
    var end_idx = trimmed.len()
    if space_idx >= 0:
        end_idx = space_idx
    val num_text = trimmed.slice(0, end_idx).trim()
    num_text.parse_f64()

fn _parse_ab_p99(output: text) -> f64:
    """Extract 99th-percentile latency in ms from ab output.

    ab prints:
      99%    1234  (in milliseconds)
    """
    val marker = "99%"
    val idx = output.find(marker)
    if idx < 0:
        return 0.0
    val rest = output.slice(idx + marker.len(), output.len())
    val trimmed = rest.trim()
    val newline = trimmed.find("\n")
    var line = trimmed
    if newline >= 0:
        line = trimmed.slice(0, newline).trim()
    line.parse_f64()

fn _parse_ab_throughput(output: text) -> f64:
    """Extract Transfer rate in MB/s from ab output."""
    val marker = "Transfer rate:"
    val idx = output.find(marker)
    if idx < 0:
        return 0.0
    val rest = output.slice(idx + marker.len(), output.len())
    val trimmed = rest.trim()
    val space_idx = trimmed.find(" ")
    var end_idx = trimmed.len()
    if space_idx >= 0:
        end_idx = space_idx
    val num_text = trimmed.slice(0, end_idx).trim()
    # ab reports in Kbytes/sec — convert to MB/s
    num_text.parse_f64() / 1024.0

fn _parse_ab_failures(output: text) -> i64:
    """Extract failure count from ab output.

    ab prints 'Failed requests: NNN' and optionally 'Non-2xx responses: NNN'.
    Return the max of these (they overlap).
    """
    var failed: i64 = 0
    var non2xx: i64 = 0

    val fail_marker = "Failed requests:"
    val fail_idx = output.find(fail_marker)
    if fail_idx >= 0:
        val rest = output.slice(fail_idx + fail_marker.len(), output.len())
        val trimmed = rest.trim()
        val nl = trimmed.find("\n")
        var line = trimmed
        if nl >= 0:
            line = trimmed.slice(0, nl).trim()
        failed = line.parse_i64()

    val non2xx_marker = "Non-2xx responses:"
    val non2xx_idx = output.find(non2xx_marker)
    if non2xx_idx >= 0:
        val rest = output.slice(non2xx_idx + non2xx_marker.len(), output.len())
        val trimmed = rest.trim()
        val nl = trimmed.find("\n")
        var line = trimmed
        if nl >= 0:
            line = trimmed.slice(0, nl).trim()
        non2xx = line.parse_i64()

    if non2xx > failed:
        return non2xx
    failed

fn _get_timestamp() -> text:
    """Return current ISO-8601 timestamp via shell date command."""
    shell_output_trimmed("date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null", "1970-01-01T00:00:00Z")

# ============================================================================
# Public API
# ============================================================================

pub fn run_benchmark(server_type: text, host: text, port: i64, file_sizes: [i64]) -> [BenchmarkResult]:
    """Run benchmark against a server for each file size in file_sizes.

    Tries wrk first; falls back to ab if wrk is not found.
    The server must already be running and serving /bench/<size>.html.

    server_type: label for output ("simple" or "nginx")
    host:        hostname, e.g. "127.0.0.1"
    port:        TCP port
    file_sizes:  list of file sizes to test (bytes); matching files must exist
    Returns list of BenchmarkResult, one per file size.
    """
    val cfg = BenchmarkConfig(
        server_label: server_type,
        host: host,
        port: port,
        concurrency: 10,
        duration_s: 10,
        fixture_dir: ""
    )
    run_benchmark_with_config(cfg, file_sizes)

pub fn run_benchmark_with_config(cfg: BenchmarkConfig, file_sizes: [i64]) -> [BenchmarkResult]:
    """Run benchmark using a BenchmarkConfig for each file size.

    Tries wrk first; falls back to ab if wrk is not found.
    The server must already be running and serving /bench/<size>.html.
    Returns list of BenchmarkResult, one per file size.
    """
    val wrk_check = shell_output_trimmed("which wrk 2>/dev/null", "")
    val use_wrk = wrk_check.len() > 0
    val ts = _get_timestamp()

    var results: [BenchmarkResult] = []
    var idx = 0
    while idx < file_sizes.len():
        val sz = file_sizes[idx]
        val url = "http://{cfg.host}:{cfg.port}/bench/{sz}.html"
        val conc = cfg.concurrency
        val dur = cfg.duration_s

        var output = ""
        if use_wrk:
            val cmd = "wrk -t2 -c{conc} -d{dur}s --latency '{url}' 2>&1"
            output = shell_output_trimmed(cmd, "")
        else:
            val nreqs = conc * dur * 100
            val cmd = "ab -n {nreqs} -c {conc} -e /dev/null '{url}' 2>&1"
            output = shell_output_trimmed(cmd, "")

        var rps_val: f64 = 0.0
        var p99_val: f64 = 0.0
        var tp_val: f64 = 0.0
        var fail_val: i64 = 0

        if use_wrk:
            rps_val = _parse_wrk_rps(output)
            p99_val = _parse_wrk_p99(output)
            tp_val = _parse_wrk_throughput(output)
            fail_val = _parse_wrk_failures(output)
        else:
            rps_val = _parse_ab_rps(output)
            p99_val = _parse_ab_p99(output)
            tp_val = _parse_ab_throughput(output)
            fail_val = _parse_ab_failures(output)

        results.push(BenchmarkResult(
            server: cfg.server_label,
            rps: rps_val,
            p99_latency_ms: p99_val,
            throughput_mbps: tp_val,
            failure_count: fail_val,
            file_size: sz,
            timestamp: ts
        ))
        idx = idx + 1

    results
