# Minimal u64 blit-tile native-build repro for packed framebuffer pixels.

struct TinyFbU64:
    data: [u64]
    width: i32
    height: i32
    stride: i32

fn sprite_pixel_u64(id: i64) -> u64:
    if id == 0: 0xFF0000FF
    else if id == 1: 0xFF00FF00
    else if id == 2: 0xFFFF0000
    else: 0xFF00FFFF

fn make_fb_u64() -> TinyFbU64:
    var data: [u64] = []
    var i: i64 = 0
    while i < 256 * 64:
        data.push(0xFF000000)
        i = i + 1
    TinyFbU64(data: data, width: 256, height: 64, stride: 256)

fn render_row_u64(mut fb: TinyFbU64):
    var tx: i64 = 0
    while tx < fb.width:
        val sid: i64 = (tx / 64) % 4
        val color: u64 = sprite_pixel_u64(sid)
        print "BLIT_TILE_U64_CALL x={tx} y=0 w=64 h=64 color={color}"
        var yy: i64 = 0
        while yy < 64:
            var xx: i64 = tx
            var off: i64 = yy * (fb.stride as i64) + tx
            while xx < tx + 64:
                fb.data[off as i32] = color
                off = off + 1
                xx = xx + 1
            yy = yy + 1
        tx = tx + 64

fn main():
    var fb = make_fb_u64()
    render_row_u64(fb)
    print "BLIT_TILE_U64_REPRO sid0={(0 / 64) % 4} sid64={(64 / 64) % 4} sid128={(128 / 64) % 4} sid192={(192 / 64) % 4}"
    print "BLIT_TILE_U64_REPRO p0={fb.data[0]} p64={fb.data[64]} p128={fb.data[128]} p192={fb.data[192]} p240={fb.data[240]}"
