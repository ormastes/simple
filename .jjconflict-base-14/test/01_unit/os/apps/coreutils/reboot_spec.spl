"""
# coreutils/reboot argument parsing
**Feature IDs:** #WAVE5-G9
**Category:** Userland coreutils
"""
use std.spec.*
use os.apps.coreutils.reboot.{main_reboot}

describe "reboot argument parsing":
    """Argument handling paths."""

    it "--help returns 0":
        """Help is a no-op that exits successfully."""
        val rc = main_reboot(["--help"])
        expect rc.to_equal(0i32)

    it "empty args returns an i32":
        """The validation path should still return a numeric status."""
        val rc = main_reboot([])
        val is_int: bool = rc == 0i32 or rc != 0i32
        expect is_int.to_equal(true)

