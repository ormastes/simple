# Async Primitives Unit Tests
#
# **Feature ID:** #LIB-ASYNC-PRIM-001
# **Category:** Lib | Async
# **Status:** Implemented
#
# Behavioral tests for CancellationToken, AsyncMutex, AsyncSemaphore,
# TimerFuture, and timeout_with_deadline.
#
# Interpreter quirks observed in async_basics_spec:
#   - Chained enum method calls fail; always use intermediate vars.
#   - return inside it blocks not supported; avoided in all test bodies.
#   - no bare expect(cond); no expect(a==b).to_equal(true)
#   - no named-arg fn calls in some positions — prefer positional
#   - arrays are value types (mutate inline or return)
#   - cross-module free fn(self: Class) loses field mutations — use me-methods

use std.nogc_async_mut.async.cancellation.{CancellationToken, token_new}
use std.nogc_async_mut.async.sync.{AsyncMutex, AsyncSemaphore}
use std.nogc_async_mut.async.timer.{TimerFuture, timer_new, timeout_with_deadline}
use std.nogc_async_mut.async.future.{Future}
use std.nogc_async_mut.async.poll.{Poll}

# ============================================================
# CancellationToken
# ============================================================

describe "CancellationToken":
    it "new token is not cancelled":
        var tok = token_new()
        val c = tok.is_cancelled()
        assert_false(c)

    it "cancel marks token as cancelled":
        var tok = token_new()
        tok.cancel()
        val c = tok.is_cancelled()
        assert_true(c)

    it "cancel propagates to child token":
        var parent = token_new()
        var child = parent.child()
        parent.cancel()
        val pc = parent.is_cancelled()
        val cc = child.is_cancelled()
        assert_true(pc)
        assert_true(cc)

    it "child not cancelled until parent cancels":
        var parent = token_new()
        var child = parent.child()
        val cc_before = child.is_cancelled()
        parent.cancel()
        val cc_after = child.is_cancelled()
        assert_false(cc_before)
        assert_true(cc_after)

    it "cancelling child does not cancel parent":
        var parent = token_new()
        var child = parent.child()
        child.cancel()
        val cc = child.is_cancelled()
        val pc = parent.is_cancelled()
        assert_true(cc)
        assert_false(pc)

    it "multiple children all cancelled when parent cancels":
        var parent = token_new()
        var c0 = parent.child()
        var c1 = parent.child()
        var c2 = parent.child()
        parent.cancel()
        val v0 = c0.is_cancelled()
        val v1 = c1.is_cancelled()
        val v2 = c2.is_cancelled()
        assert_true(v0)
        assert_true(v1)
        assert_true(v2)

    it "guard_future pending when not cancelled":
        var tok = token_new()
        val f = tok.guard_future()
        val p = f.poll()
        val pend = p.is_pending()
        assert_true(pend)

    it "guard_future ready when cancelled":
        var tok = token_new()
        tok.cancel()
        val f = tok.guard_future()
        val p = f.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "guard_future ready value is true":
        var tok = token_new()
        tok.cancel()
        val f = tok.guard_future()
        val p = f.poll()
        val v = p.unwrap()
        assert_true(v)

# ============================================================
# AsyncMutex
# ============================================================

describe "AsyncMutex":
    it "acquire on free mutex returns Ready":
        var m = AsyncMutex(locked: false)
        val f = m.acquire()
        val p = f.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "acquire on held mutex returns Pending":
        var m = AsyncMutex(locked: true)
        val f = m.acquire()
        val p = f.poll()
        val pend = p.is_pending()
        assert_true(pend)

    it "try_acquire on free mutex returns true and locks":
        var m = AsyncMutex(locked: false)
        val got = m.try_acquire()
        val locked_after = m.locked
        assert_true(got)
        assert_true(locked_after)

    it "try_acquire on held mutex returns false":
        var m = AsyncMutex(locked: true)
        val got = m.try_acquire()
        assert_false(got)

    it "release unlocks mutex so next acquire is Ready":
        var m = AsyncMutex(locked: true)
        m.release()
        val f = m.acquire()
        val p = f.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "acquire locks mutex so second acquire is Pending":
        var m = AsyncMutex(locked: false)
        val f1 = m.acquire()
        val p1 = f1.poll()
        val rdy1 = p1.is_ready()
        # mutex is now locked by above acquire
        val f2 = m.acquire()
        val p2 = f2.poll()
        val pend2 = p2.is_pending()
        assert_true(rdy1)
        assert_true(pend2)

    it "release then acquire cycles correctly":
        var m = AsyncMutex(locked: false)
        val f1 = m.acquire()
        val p1 = f1.poll()
        val rdy1 = p1.is_ready()
        m.release()
        val f2 = m.acquire()
        val p2 = f2.poll()
        val rdy2 = p2.is_ready()
        assert_true(rdy1)
        assert_true(rdy2)

# ============================================================
# AsyncSemaphore
# ============================================================

describe "AsyncSemaphore":
    it "acquire with permits available returns Ready":
        var sem = AsyncSemaphore(permits: 2, max_permits: 2)
        val f = sem.acquire()
        val p = f.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "acquire decrements permit count":
        var sem = AsyncSemaphore(permits: 2, max_permits: 2)
        val f = sem.acquire()
        val p = f.poll()
        val rdy = p.is_ready()
        val remaining = sem.permits
        assert_true(rdy)
        expect(remaining).to_equal(1)

    it "acquire when no permits returns Pending":
        var sem = AsyncSemaphore(permits: 0, max_permits: 2)
        val f = sem.acquire()
        val p = f.poll()
        val pend = p.is_pending()
        assert_true(pend)

    it "try_acquire with permits returns true":
        var sem = AsyncSemaphore(permits: 1, max_permits: 1)
        val got = sem.try_acquire()
        assert_true(got)

    it "try_acquire with no permits returns false":
        var sem = AsyncSemaphore(permits: 0, max_permits: 1)
        val got = sem.try_acquire()
        assert_false(got)

    it "release increments permits up to max":
        var sem = AsyncSemaphore(permits: 0, max_permits: 2)
        sem.release()
        val p1 = sem.permits
        expect(p1).to_equal(1)

    it "release clamps at max_permits":
        var sem = AsyncSemaphore(permits: 2, max_permits: 2)
        sem.release()
        val p = sem.permits
        expect(p).to_equal(2)

    it "exhaust all permits then release makes next acquire Ready":
        var sem = AsyncSemaphore(permits: 1, max_permits: 1)
        val f1 = sem.acquire()
        val p1 = f1.poll()
        val rdy1 = p1.is_ready()
        val perm_after_acq = sem.permits
        sem.release()
        val f2 = sem.acquire()
        val p2 = f2.poll()
        val rdy2 = p2.is_ready()
        assert_true(rdy1)
        expect(perm_after_acq).to_equal(0)
        assert_true(rdy2)

# ============================================================
# TimerFuture
# ============================================================

describe "TimerFuture":
    it "0ms timer is immediately ready on first poll":
        val tf = timer_new(0)
        val p = tf.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "1ms timer with deadline already past is ready":
        # Use negative duration to ensure deadline is in the past
        val tf = timer_new(-1)
        val p = tf.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "large future deadline is still Pending":
        val tf = timer_new(999999999)
        val p = tf.poll()
        val pend = p.is_pending()
        assert_true(pend)

    it "as_future with 0ms deadline returns Ready future":
        val tf = timer_new(0)
        val f = tf.as_future()
        val p = f.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "as_future with large deadline returns Pending future":
        val tf = timer_new(999999999)
        val f = tf.as_future()
        val p = f.poll()
        val pend = p.is_pending()
        assert_true(pend)

# ============================================================
# timeout_with_deadline
# ============================================================

describe "timeout_with_deadline":
    it "ready inner returns inner value before deadline":
        val inner = Future.from_value("done")
        val result = timeout_with_deadline(inner, 999999999)
        val p = result.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "ready inner value is the inner text":
        val inner = Future.from_value("hello")
        val result = timeout_with_deadline(inner, 999999999)
        val p = result.poll()
        val v = p.unwrap()
        expect(v).to_equal("hello")

    it "pending inner with expired deadline returns timed out":
        val inner = Future.pending<text>()
        # Use negative deadline to simulate already-expired
        val result = timeout_with_deadline(inner, -1)
        val p = result.poll()
        val rdy = p.is_ready()
        assert_true(rdy)

    it "pending inner expired deadline value is timed out text":
        val inner = Future.pending<text>()
        val result = timeout_with_deadline(inner, -1)
        val p = result.poll()
        val v = p.unwrap()
        expect(v).to_equal("timed out")

    it "pending inner with large deadline returns Pending":
        val inner = Future.pending<text>()
        val result = timeout_with_deadline(inner, 999999999)
        val p = result.poll()
        val pend = p.is_pending()
        assert_true(pend)
