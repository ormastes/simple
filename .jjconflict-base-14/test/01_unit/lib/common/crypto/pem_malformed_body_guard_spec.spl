use std.spec.{describe, it, assert_equal}
use std.crypto.pem.{parse_pem}

describe "PEM malformed body guard":
    it "ignores invalid base64 body bytes":
        val pem = "-----BEGIN TEST-----\nS@GVs#bG8=\n-----END TEST-----\n"
        val blocks = parse_pem(pem)
        assert_equal(blocks.len(), 1)
        assert_equal(blocks[0].label, "TEST")
        assert_equal(blocks[0].der_bytes.len(), 5)
        assert_equal(blocks[0].der_bytes[0u64].to_i64(), 72)
