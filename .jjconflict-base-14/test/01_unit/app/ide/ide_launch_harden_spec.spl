# IDE launch sanity hardening spec.
#
# Verifies that empty argv and unknown options are handled gracefully.

use std.spec
use app.ide.launch_sanity.{ide_launch_sanity, ide_launch_empty_argv_safe, ide_launch_unknown_only}

describe "launch_sanity: empty argv and unknown option handling":

    it "empty argv parse does not crash":
        expect(ide_launch_empty_argv_safe()).to_equal(true)

    it "unknown-only flag populates unknown_option not mode":
        expect(ide_launch_unknown_only()).to_equal(true)

    it "launch sanity tui mode is non-empty":
        val sanity = ide_launch_sanity()
        expect(sanity.tui_mode.len() > 0).to_equal(true)

    it "launch sanity bad mode populates unknown_option":
        val sanity = ide_launch_sanity()
        expect(sanity.unknown_option.len() > 0).to_equal(true)

    it "launch sanity file_count is non-negative":
        val sanity = ide_launch_sanity()
        expect(sanity.file_count >= 0).to_equal(true)
