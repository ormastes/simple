use std.cli.cli_util (get_cli_args)
use os.port.simpleos_board_hardening.{simpleos_physical_serial_acceptance_reason}

extern fn rt_file_read_text(path: text) -> text

fn _arg_value(args: [text], name: text) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with(name + "="):
            return arg.slice((name + "=").len())
        if arg == name and i + 1 < args.len():
            return args[i + 1]
        i = i + 1
    ""

fn _print_usage():
    print "Usage: simple run src/app/simpleos_board_serial_check/main.spl --board <id> --mode <off|detect|enforce|fault-test> --serial-log <path>"

fn main() -> i64:
    val args = get_cli_args()
    val board = _arg_value(args, "--board")
    val mode = _arg_value(args, "--mode")
    val serial_log = _arg_value(args, "--serial-log")
    if board == "" or mode == "" or serial_log == "":
        _print_usage()
        return 2
    val serial_output = rt_file_read_text(serial_log) ?? ""
    val reason = simpleos_physical_serial_acceptance_reason(board, mode, serial_output)
    print "board={board} mode={mode} serial_log={serial_log} reason={reason}"
    if reason == "ready":
        return 0
    1
