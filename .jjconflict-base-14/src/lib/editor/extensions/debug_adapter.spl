# Editor Debug Adapter Extension
#
# Debug Adapter Protocol (DAP) integration for the editor.
# Manages debug sessions, breakpoints, and step/continue commands.

struct DebugBreakpoint:
    path: text
    line: i64
    condition: text
    enabled: bool

struct EditorDebugAdapterState:
    adapter_id: text
    session_id: i64
    running: bool
    paused: bool
    current_path: text
    current_line: i64
    breakpoints: [DebugBreakpoint]
    status: text

fn debug_adapter_state_new(adapter_id: text) -> EditorDebugAdapterState:
    EditorDebugAdapterState(
        adapter_id: adapter_id,
        session_id: 0,
        running: false,
        paused: false,
        current_path: "",
        current_line: 0,
        breakpoints: [],
        status: "stopped"
    )

fn debug_adapter_add_breakpoint(state: EditorDebugAdapterState, path: text, line: i64) -> EditorDebugAdapterState:
    var bps = state.breakpoints
    bps.push(DebugBreakpoint(path: path, line: line, condition: "", enabled: true))
    EditorDebugAdapterState(
        adapter_id: state.adapter_id,
        session_id: state.session_id,
        running: state.running,
        paused: state.paused,
        current_path: state.current_path,
        current_line: state.current_line,
        breakpoints: bps,
        status: state.status
    )

fn debug_adapter_has_breakpoint(state: EditorDebugAdapterState, path: text, line: i64) -> bool:
    for bp in state.breakpoints:
        if bp.path == path and bp.line == line and bp.enabled:
            return true
    false
