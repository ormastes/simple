# YAML serialization: flow style, block style, and multi-document output.

use lib.yaml.types.{yaml_get_scalar_type, yaml_get_scalar_content, yaml_get_sequence_items, yaml_get_mapping_pairs}

fn _yaml_join(parts: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < parts.length():
        if i > 0:
            out = out + sep
        out = out + parts[i]
        i = i + 1
    out

fn yaml_serialize_scalar(v: any) -> text:
    val t = yaml_get_scalar_type(v)
    if t == "null":
        return "null"
    yaml_get_scalar_content(v)

fn yaml_serialize_flow(v: any) -> text:
    val t = yaml_get_scalar_type(v)
    if t == "sequence":
        return yaml_serialize_flow_sequence(v)
    if t == "mapping":
        return yaml_serialize_flow_mapping(v)
    yaml_serialize_scalar(v)

fn yaml_serialize_flow_sequence(v: any) -> text:
    var parts = []
    for item in yaml_get_sequence_items(v):
        parts.push(yaml_serialize_flow(item))
    "[" + _yaml_join(parts, ", ") + "]"

fn yaml_serialize_flow_mapping(v: any) -> text:
    var parts = []
    for pair in yaml_get_mapping_pairs(v):
        parts.push("{pair.0}: " + yaml_serialize_flow(pair.1))
    "{" + _yaml_join(parts, ", ") + "}"

fn yaml_serialize_sequence_block(v: any) -> text:
    var parts = []
    for item in yaml_get_sequence_items(v):
        parts.push("- " + yaml_serialize_flow(item))
    _yaml_join(parts, "\n")

fn yaml_serialize_mapping_block(v: any) -> text:
    var parts = []
    for pair in yaml_get_mapping_pairs(v):
        parts.push("{pair.0}: " + yaml_serialize_flow(pair.1))
    _yaml_join(parts, "\n")

fn yaml_serialize_block(v: any) -> text:
    val t = yaml_get_scalar_type(v)
    if t == "sequence":
        return yaml_serialize_sequence_block(v)
    if t == "mapping":
        return yaml_serialize_mapping_block(v)
    yaml_serialize_scalar(v)

fn yaml_serialize(v: any, style: text) -> text:
    if style == "flow":
        return yaml_serialize_flow(v)
    yaml_serialize_block(v)

fn yaml_serialize_documents(docs: [any], style: text) -> text:
    var parts = []
    for doc in docs:
        parts.push(yaml_serialize(doc, style))
    _yaml_join(parts, "\n---\n")
