# X86 Mixed-Mode JIT Manager
#
# Manages both x86_64 (Cranelift) and x86_32 (LLVM) JIT instances.
# Applies the I32NarrowPass before compilation to reduce register pressure
# and improve throughput on mixed-width workloads.
#
# Usage:
#   use std.jit.jit_x86_mixed.{X86MixedJit}

use std.io
use std.jit.opt_i32_narrow.{I32NarrowPass}

extern fn rt_jit_create() -> i64
extern fn rt_jit_create_for_target(arch: text) -> i64
extern fn rt_jit_backend_name(handle: i64) -> text
extern fn rt_jit_compile_source(handle: i64, source: text) -> text
extern fn rt_jit_call_i64(handle: i64, name: text, arg: i64) -> i64
extern fn rt_jit_has_function(handle: i64, name: text) -> bool
extern fn rt_jit_cleanup(handle: i64) -> i64
extern fn rt_time_now_micros() -> i64

class CompileResult:
    name: text
    backend: text
    err: text
    compile_us: i64
    narrowed: bool

    static fn create(name: text, backend: text, err: text, compile_us: i64, narrowed: bool) -> CompileResult:
        CompileResult(
            name: name,
            backend: backend,
            err: err,
            compile_us: compile_us,
            narrowed: narrowed
        )

class X86MixedJit:
    handle_64: i64
    handle_32: i64
    backend_64: text
    backend_32: text
    narrow_pass: I32NarrowPass
    compile_count: i64
    total_compile_us: i64

    static fn create() -> X86MixedJit:
        val h64 = rt_jit_create()
        val b64 = rt_jit_backend_name(h64)
        val h32 = rt_jit_create_for_target("x86_32")
        val b32 = rt_jit_backend_name(h32)
        X86MixedJit(
            handle_64: h64,
            handle_32: h32,
            backend_64: b64,
            backend_32: b32,
            narrow_pass: I32NarrowPass.create(),
            compile_count: 0,
            total_compile_us: 0
        )

    me compile_for_64(name: text, source: text) -> CompileResult:
        val t0 = rt_time_now_micros()
        val err = rt_jit_compile_source(self.handle_64, source)
        val t1 = rt_time_now_micros()
        if err == "":
            self.compile_count = self.compile_count + 1
            self.total_compile_us = self.total_compile_us + (t1 - t0)
        return CompileResult.create(name, self.backend_64, err, t1 - t0, false)

    me compile_for_32(name: text, source: text) -> CompileResult:
        if self.handle_32 < 1:
            return CompileResult.create(name, "llvm-jit", "SKIP: x86_32 JIT not available", 0, false)
        val t0 = rt_time_now_micros()
        val err = rt_jit_compile_source(self.handle_32, source)
        val t1 = rt_time_now_micros()
        if err == "":
            self.compile_count = self.compile_count + 1
            self.total_compile_us = self.total_compile_us + (t1 - t0)
        return CompileResult.create(name, self.backend_32, err, t1 - t0, false)

    me compile_optimized(name: text, source: text) -> CompileResult:
        # Apply narrowing pass first, then compile for host (x86_64)
        val annotated = self.narrow_pass.analyze(source)
        val t0 = rt_time_now_micros()
        val err = rt_jit_compile_source(self.handle_64, annotated)
        val t1 = rt_time_now_micros()
        if err == "":
            self.compile_count = self.compile_count + 1
            self.total_compile_us = self.total_compile_us + (t1 - t0)
        return CompileResult.create(name, self.backend_64, err, t1 - t0, true)

    me is_compiled_64(name: text) -> bool:
        return rt_jit_has_function(self.handle_64, name)

    me is_compiled_32(name: text) -> bool:
        if self.handle_32 < 1:
            return false
        return rt_jit_has_function(self.handle_32, name)

    me call_i64_on_64(name: text, arg: i64) -> i64:
        return rt_jit_call_i64(self.handle_64, name, arg)

    me call_i64_on_32(name: text, arg: i64) -> i64:
        if self.handle_32 < 1:
            return -1
        return rt_jit_call_i64(self.handle_32, name, arg)

    me stats() -> text:
        var msg = "X86MixedJit:"
        msg = msg + " 64bit=" + self.backend_64
        msg = msg + " 32bit=" + self.backend_32
        msg = msg + " compiled=" + self.compile_count.to_text()
        msg = msg + " compile_time=" + self.total_compile_us.to_text() + "us"
        msg = msg + " | " + self.narrow_pass.stats()
        return msg

    me cleanup():
        rt_jit_cleanup(self.handle_64)
        if self.handle_32 >= 1:
            rt_jit_cleanup(self.handle_32)
