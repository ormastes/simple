# SimpleOS Machine Learning Module
#
# GPU-accelerated deep learning with autograd, optimizers, and data loading.
#
# Usage:
#   use os.ml.{GpuTensor, GradTensor, ComputeGraph}
#   use os.ml.{GpuLinear, GpuReLU, GpuSequential}
#   use os.ml.{Dataset, TensorDataset, DataLoader}
#   use os.ml.{save_model, load_weights}

export GpuTensor from gpu_tensor
export gpu_matmul, gpu_add, gpu_mul, gpu_relu, gpu_sigmoid, gpu_tanh, gpu_softmax from gpu_tensor
export gpu_reduce_sum, gpu_reduce_mean, gpu_scale, gpu_scalar from gpu_tensor

export GradTensor, ComputeGraph, GradOp, TapeEntry from autograd
export SGD, Adam from optimizer
export Dataset, TensorDataset, DataLoader from data
export Module, GpuLinear, GpuReLU, GpuSequential from model
export save_model, load_weights from model
