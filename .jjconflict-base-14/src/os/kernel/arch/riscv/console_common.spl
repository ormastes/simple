# Shared RISC-V 16550 console helpers.

use os.kernel.boot.uart16550_mmio.{uart16550_mmio_init, uart16550_mmio_read_byte, uart16550_mmio_write_byte}

val RISCV_VIRT_UART_BASE: u64 = 0x10000000

fn riscv_uart_init(base: u64, ready: bool) -> bool:
    """Initialize a RISC-V virt 16550 UART once and return the ready state."""
    if ready:
        return true
    uart16550_mmio_init(base)
    true

fn riscv_uart_write_byte(base: u64, byte: u8):
    """Write one byte to the RISC-V virt UART."""
    uart16550_mmio_write_byte(base, byte)

fn riscv_uart_write(base: u64, msg: text):
    """Write text to the RISC-V virt UART."""
    for i in 0..msg.len():
        val ch = msg.char_at(i)
        riscv_uart_write_byte(base, ch as u8)

fn riscv_uart_writeln(base: u64, msg: text):
    """Write text plus CRLF to the RISC-V virt UART."""
    riscv_uart_write(base, msg)
    riscv_uart_write_byte(base, 0x0D)
    riscv_uart_write_byte(base, 0x0A)

fn riscv_uart_read_byte(base: u64) -> u8?:
    """Read one byte from the RISC-V virt UART when data is available."""
    uart16550_mmio_read_byte(base)
