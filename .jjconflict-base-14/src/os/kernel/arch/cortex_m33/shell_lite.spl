"""SimpleOS Lite Shell — minimal command loop over serial UART.

Commands: help, info, echo <text>, peek <hex_addr>, reboot
Runs on Cortex-M33 bare-metal with CMSDK UART I/O.
"""

use os.kernel.arch.cortex_m33.console.{uart_write, uart_writeln, uart_write_byte, uart_read_byte}
use os.kernel.boot.mmio.{mmio_read32}

fn shell_main():
    uart_writeln("SimpleOS Lite v0.1 — Cortex-M33")
    uart_writeln("Type 'help' for commands.")
    uart_writeln("")

    var buf: [u8] = []
    shell_prompt()

    loop:
        val ch = uart_read_byte()
        if ch < 0:
            continue

        val byte = ch as u8

        if byte == 0x0D or byte == 0x0A:
            uart_write_byte(0x0D)
            uart_write_byte(0x0A)
            if buf.len() > 0:
                val line = bytes_to_text(buf)
                shell_dispatch(line)
                buf = []
            shell_prompt()
            continue

        if byte == 0x7F or byte == 0x08:
            if buf.len() > 0:
                buf.pop()
                uart_write_byte(0x08)
                uart_write_byte(0x20)
                uart_write_byte(0x08)
            continue

        if buf.len() < 128:
            buf.push(byte)
            uart_write_byte(byte)

fn shell_prompt():
    uart_write("simpleos> ")

fn shell_dispatch(line: text):
    if line == "help":
        cmd_help()
    elif line == "info":
        cmd_info()
    elif line == "reboot":
        cmd_reboot()
    elif line.starts_with("echo "):
        val msg = line.slice(5, line.len())
        uart_writeln(msg)
    elif line.starts_with("peek "):
        val addr_str = line.slice(5, line.len())
        cmd_peek(addr_str)
    elif line == "":
        pass_do_nothing
    else:
        uart_write("unknown command: ")
        uart_writeln(line)
        uart_writeln("Type 'help' for available commands.")

fn cmd_help():
    uart_writeln("SimpleOS Lite Shell Commands:")
    uart_writeln("  help          — show this message")
    uart_writeln("  info          — system information")
    uart_writeln("  echo <text>   — print text")
    uart_writeln("  peek <addr>   — read 32-bit word at hex address")
    uart_writeln("  reboot        — reset the system")

fn cmd_info():
    uart_writeln("SimpleOS Lite v0.1")
    uart_writeln("  CPU:      ARM Cortex-M33 (ARMv8-M Mainline)")
    uart_writeln("  Platform: MPS2-AN505 (QEMU)")
    uart_writeln("  RAM:      0x20000000 — 0x20400000 (4 MB)")
    uart_writeln("  UART:     CMSDK APB @ 0x40004000")

fn cmd_peek(addr_str: text):
    val addr = parse_hex_u32(addr_str)
    if addr == 0 and addr_str != "0" and addr_str != "0x0":
        uart_write("invalid hex address: ")
        uart_writeln(addr_str)
        return
    val value = mmio_read32(addr as u64)
    uart_write("[")
    write_hex32(addr)
    uart_write("] = 0x")
    write_hex32(value)
    uart_writeln("")

fn cmd_reboot():
    uart_writeln("Resetting...")
    val aircr_addr: u64 = 0xE000ED0C
    val reset_key: u32 = 0x05FA0004
    unsafe:
        asm volatile:
            "ldr r0, =0xE000ED0C"
            "ldr r1, =0x05FA0004"
            "str r1, [r0]"
            "dsb"
            "isb"
            ".Lwait_reset:"
            "b .Lwait_reset"

fn bytes_to_text(buf: [u8]) -> text:
    var result: text = ""
    for i in 0..buf.len():
        val ch = buf[i] as i32
        result = result + chr(ch)
    result

fn chr(code: i32) -> text:
    extern fn rt_string_from_char(c: i32) -> text
    rt_string_from_char(code)

fn parse_hex_u32(s: text) -> u32:
    var start = 0
    if s.len() >= 2 and s.starts_with("0x"):
        start = 2
    var result: u32 = 0
    for i in start..s.len():
        val ch = s.char_at(i) as u8
        var nibble: u32 = 0
        if ch >= 0x30 and ch <= 0x39:
            nibble = (ch - 0x30) as u32
        elif ch >= 0x41 and ch <= 0x46:
            nibble = (ch - 0x41 + 10) as u32
        elif ch >= 0x61 and ch <= 0x66:
            nibble = (ch - 0x61 + 10) as u32
        else:
            return 0
        result = (result << 4) | nibble
    result

fn write_hex32(val_: u32):
    var shift: i32 = 28
    while shift >= 0:
        val nibble = ((val_ >> (shift as u32)) & 0x0F) as u8
        val ch: u8 = if nibble < 10: (0x30 + nibble) as u8 else: (0x57 + nibble) as u8
        uart_write_byte(ch)
        shift = shift - 4
