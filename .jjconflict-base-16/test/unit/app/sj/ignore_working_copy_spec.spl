"""
# Ignore Working Copy Specification
#
# Tests that read-only jj verbs get --ignore-working-copy injected,
# and that all commands get --no-pager --color never.
"""

use std.io_runtime

# --- Inline flag injection logic ---

fn _verb_key(argv: [text]) -> text:
    if argv.len() < 2i64:
        return ""
    if argv.len() > 2i64 and argv[1i64] == "op":
        return "op " + argv[2i64]
    if argv.len() > 2i64 and argv[1i64] == "file":
        return "file " + argv[2i64]
    if argv.len() > 2i64 and argv[1i64] == "bookmark":
        return "bookmark " + argv[2i64]
    if argv.len() > 2i64 and argv[1i64] == "config":
        return "config " + argv[2i64]
    argv[1i64]

fn is_read_bypass(argv: [text]) -> bool:
    val key = _verb_key(argv)
    key == "log" or
    key == "status" or
    key == "diff" or
    key == "show" or
    key == "op log" or
    key == "op show" or
    key == "evolog" or
    key == "file annotate" or
    key == "file list" or
    key == "file show" or
    key == "bookmark list" or
    key == "config list"

fn inject_flags(argv: [text]) -> [text]:
    if argv.len() == 0i64:
        return argv
    if argv[0i64] != "jj":
        return argv
    var out: [text] = ["jj"]
    if is_read_bypass(argv):
        out.push("--ignore-working-copy")
    out.push("--no-pager")
    out.push("--color")
    out.push("never")
    var i = 1i64
    while i < argv.len():
        out.push(argv[i])
        i = i + 1i64
    out

fn build_command(argv: [text]) -> text:
    inject_flags(argv).join(" ")

fn _has_flag(result: [text], flag: text) -> bool:
    var i = 0i64
    while i < result.len():
        if result[i] == flag:
            return true
        i = i + 1i64
    false

# ============================================================================
# Tests
# ============================================================================

describe "Ignore Working Copy - Read Verbs":
    it "injects --ignore-working-copy for jj log":
        val result = inject_flags(["jj", "log"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj status":
        val result = inject_flags(["jj", "status"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj diff":
        val result = inject_flags(["jj", "diff"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj show":
        val result = inject_flags(["jj", "show"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj op log":
        val result = inject_flags(["jj", "op", "log"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj evolog":
        val result = inject_flags(["jj", "evolog"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj file annotate":
        val result = inject_flags(["jj", "file", "annotate", "src/main.spl"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj file list":
        val result = inject_flags(["jj", "file", "list"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj file show":
        val result = inject_flags(["jj", "file", "show", "path"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj bookmark list":
        val result = inject_flags(["jj", "bookmark", "list"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj config list":
        val result = inject_flags(["jj", "config", "list"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

    it "injects --ignore-working-copy for jj op show":
        val result = inject_flags(["jj", "op", "show"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(true)

describe "Ignore Working Copy - No-Pager and Color":
    it "all commands get --no-pager":
        val result = inject_flags(["jj", "describe", "-m", "test"])
        expect(_has_flag(result, "--no-pager")).to_equal(true)

    it "all commands get --color never":
        val result = inject_flags(["jj", "describe", "-m", "test"])
        expect(_has_flag(result, "--color")).to_equal(true)
        expect(_has_flag(result, "never")).to_equal(true)

describe "Ignore Working Copy - Negative Cases":
    it "does NOT inject --ignore-working-copy for jj describe":
        val result = inject_flags(["jj", "describe", "-m", "test"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(false)

    it "does NOT inject --ignore-working-copy for jj new":
        val result = inject_flags(["jj", "new"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(false)

    it "does NOT inject --ignore-working-copy for jj rebase":
        val result = inject_flags(["jj", "rebase", "-d", "main"])
        expect(_has_flag(result, "--ignore-working-copy")).to_equal(false)

    it "does not modify non-jj commands":
        val result = inject_flags(["git", "status"])
        expect(result.len()).to_equal(2i64)
        expect(result[0i64]).to_equal("git")

    it "build_command combines inject and join":
        val cmd = build_command(["jj", "log"])
        expect(cmd).to_contain("--ignore-working-copy")
        expect(cmd).to_contain("--no-pager")
