# ELF Load Chain Specification
#
# Verifies the full ELF loading pipeline: parse → segment extract → image build.
# Uses synthetic ELF headers to test without real binaries.
#
# Run: bin/simple test test/system/kernel/elf_load_chain_spec.spl

use std.spipe.*
use os.kernel.loader.elf_loader.{
    load_user_executable, ElfImage, ElfLoadSegment, ElfClass,
    elf_image_entry, elf_image_segments
}
use os.kernel.arch.arch_context.{Architecture}

describe "ELF Loader — magic validation":

    it "rejects empty bytes":
        val bytes: [u8] = []
        val result = load_user_executable(bytes, Architecture.X86_64)
        expect(result.is_err()).to_equal(true)

    it "rejects too-short bytes":
        val bytes: [u8] = [0x7F, 0x45, 0x4C]
        val result = load_user_executable(bytes, Architecture.X86_64)
        expect(result.is_err()).to_equal(true)

    it "rejects invalid magic":
        val bytes = _make_bytes(64, 0)
        val result = load_user_executable(bytes, Architecture.X86_64)
        expect(result.is_err()).to_equal(true)

describe "ELF Loader — valid ELF64 x86_64 header":

    it "parses minimal valid ELF64 x86_64 header":
        val bytes = _make_minimal_elf64_x86()
        val result = load_user_executable(bytes, Architecture.X86_64)
        expect(result.is_ok()).to_equal(true)
        val image = result.unwrap()
        expect(image.entry > 0).to_equal(true)

describe "ELF Loader — valid ELF64 RISC-V header":

    it "parses minimal valid ELF64 RV64 header":
        val bytes = _make_minimal_elf64_rv64()
        val result = load_user_executable(bytes, Architecture.Riscv64)
        expect(result.is_ok()).to_equal(true)
        val image = result.unwrap()
        expect(image.entry > 0).to_equal(true)

describe "ElfImage — struct accessors":

    it "ElfLoadSegment stores fields correctly":
        val seg = ElfLoadSegment(
            file_offset: 0x1000,
            file_size:   0x200,
            virt_addr:   0x400000,
            mem_size:    0x300,
            flags:       5,
            align:       0x1000
        )
        expect(seg.file_offset as i64).to_equal(0x1000)
        expect(seg.virt_addr as i64).to_equal(0x400000)
        expect(seg.mem_size > seg.file_size).to_equal(true)

fn _make_bytes(count: i64, fill: u8) -> [u8]:
    var result: [u8] = []
    var idx: i64 = 0
    while idx < count:
        result.push(fill)
        idx = idx + 1
    result

fn _make_minimal_elf64_x86() -> [u8]:
    # Minimal ELF64 header for x86_64 (64 bytes + 56 byte PHDR = 120 bytes)
    var hdr: [u8] = _make_bytes(120, 0)
    # ELF magic
    hdr[0] = 0x7F
    hdr[1] = 0x45
    hdr[2] = 0x4C
    hdr[3] = 0x46
    # EI_CLASS = ELFCLASS64
    hdr[4] = 2
    # EI_DATA = ELFDATA2LSB
    hdr[5] = 1
    # EI_VERSION = EV_CURRENT
    hdr[6] = 1
    # e_type = ET_EXEC (2)
    hdr[16] = 2
    hdr[17] = 0
    # e_machine = EM_X86_64 (62 = 0x3E)
    hdr[18] = 0x3E
    hdr[19] = 0
    # e_version = 1
    hdr[20] = 1
    # e_entry = 0x401000 (little-endian u64)
    hdr[24] = 0x00
    hdr[25] = 0x10
    hdr[26] = 0x40
    hdr[27] = 0x00
    # e_phoff = 64 (program header table offset)
    hdr[32] = 64
    # e_ehsize = 64
    hdr[52] = 64
    # e_phentsize = 56
    hdr[54] = 56
    # e_phnum = 1
    hdr[56] = 1
    # Program header at offset 64:
    # p_type = PT_LOAD (1)
    hdr[64] = 1
    # p_flags = PF_R | PF_X (5)
    hdr[68] = 5
    # p_offset = 0
    # p_vaddr = 0x400000
    hdr[80] = 0x00
    hdr[81] = 0x00
    hdr[82] = 0x40
    # p_filesz = 120
    hdr[96] = 120
    # p_memsz = 120
    hdr[104] = 120
    # p_align = 0x1000
    hdr[112] = 0x00
    hdr[113] = 0x10
    hdr

fn _make_minimal_elf64_rv64() -> [u8]:
    var hdr: [u8] = _make_bytes(120, 0)
    hdr[0] = 0x7F
    hdr[1] = 0x45
    hdr[2] = 0x4C
    hdr[3] = 0x46
    hdr[4] = 2
    hdr[5] = 1
    hdr[6] = 1
    hdr[16] = 2
    hdr[17] = 0
    # e_machine = EM_RISCV (243 = 0xF3)
    hdr[18] = 0xF3
    hdr[19] = 0
    hdr[20] = 1
    hdr[24] = 0x00
    hdr[25] = 0x10
    hdr[26] = 0x40
    hdr[27] = 0x00
    hdr[32] = 64
    hdr[52] = 64
    hdr[54] = 56
    hdr[56] = 1
    hdr[64] = 1
    hdr[68] = 5
    hdr[80] = 0x00
    hdr[81] = 0x00
    hdr[82] = 0x40
    hdr[96] = 120
    hdr[104] = 120
    hdr[112] = 0x00
    hdr[113] = 0x10
    hdr
