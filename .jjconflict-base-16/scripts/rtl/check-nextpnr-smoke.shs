#!/usr/bin/env sh
set -eu

REQUIRE_TOOLS="${REQUIRE_TOOLS:-0}"

if ! command -v nextpnr-ice40 >/dev/null 2>&1; then
    if [ "$REQUIRE_TOOLS" = "1" ]; then
        echo "ERROR: nextpnr-ice40 not found" >&2
        exit 1
    fi
    echo "SKIP: nextpnr-ice40 not found"
    exit 0
fi

echo "PASS: nextpnr-ice40 is available"
