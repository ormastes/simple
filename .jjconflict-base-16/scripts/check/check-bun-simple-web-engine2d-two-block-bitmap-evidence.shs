#!/bin/sh
set -eu

JS_RENDER_RUNTIME="${JS_RENDER_RUNTIME:-bun}"
JS_RENDER_RUNTIME_BIN="${JS_RENDER_RUNTIME_BIN:-bun}"
SIMPLE_WEB_ENGINE2D_SCENE="${SIMPLE_WEB_ENGINE2D_SCENE:-simple-web-engine2d-two-block-content}"
BUILD_DIR="${BUILD_DIR:-build/bun_simple_web_engine2d_two_block_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/bun_simple_web_engine2d_two_block_bitmap_evidence_$(date -u +%F).md}"
export JS_RENDER_RUNTIME JS_RENDER_RUNTIME_BIN SIMPLE_WEB_ENGINE2D_SCENE BUILD_DIR REPORT_PATH

exec sh scripts/check/check-simple-web-engine2d-js-bitmap-evidence.shs
