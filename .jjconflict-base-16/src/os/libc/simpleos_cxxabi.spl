# SimpleOS C++ ABI canary surface.
#
# The linked C shim owns the exported ABI symbols today. This Simple mirror is
# the hardening/audit source of truth for the stack-guard policy: the guard is
# initialized from boot entropy, never from a fixed sentinel.

var g_stack_canary: u64 = 0

fn simpleos_cxxabi_canary_init(seed: u64) -> u64:
    """Install and return a non-zero stack canary seed."""
    if seed == 0:
        g_stack_canary = 0xA5A5A5A55A5A5A5A
    else:
        g_stack_canary = seed
    g_stack_canary

fn simpleos_cxxabi_canary_value() -> u64:
    """Return the current stack canary value."""
    g_stack_canary

fn simpleos_cxxabi_canary_ready() -> bool:
    """Return true once the canary has been initialized."""
    g_stack_canary != 0
