# echo — Print arguments
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line}

fn tool_echo(args: [text], terminal: Terminal) -> i32:
    """Echo arguments to terminal."""
    var output = ""
    var i = 0
    for arg in args:
        if i > 0:
            output = "{output} "
        output = "{output}{arg}"
        i = i + 1
    write_line(terminal, output)
    return 0
