use os.userlib.device.{DeviceEntry, enumerate_devices, get_device_info, device_class_name}

## List PCI devices.
## Flags: -v (verbose), -h (help)

fn _parse_verbose(args: [text]) -> bool:
    var verbose = false
    for arg in args:
        if arg == "-v":
            verbose = true
    verbose

fn _format_bdf(entry: DeviceEntry) -> text:
    val bus = entry.bus
    val device = entry.device
    val function = entry.function
    "{bus:02x}:{device:02x}.{function}"

fn _format_device_line(entry: DeviceEntry) -> text:
    val bdf = _format_bdf(entry)
    val class_name = device_class_name(entry.class_code)
    val vendor = entry.vendor_id
    val dev_id = entry.device_id
    "{bdf} {class_name}: {vendor:04x}:{dev_id:04x}"

fn _format_verbose_details(entry: DeviceEntry) -> text:
    val class_code = entry.class_code
    val subclass = entry.subclass
    val prog_if = entry.prog_if
    val irq = entry.irq
    var lines = "  Class: {class_code:02x}, Subclass: {subclass:02x}, ProgIF: {prog_if:02x}\n"
    lines = lines + "  IRQ: {irq}"
    lines

fn _print_usage():
    print "Usage: lspci [-v] [-h]"
    print ""
    print "List PCI devices."
    print ""
    print "Options:"
    print "  -v    Verbose output (show class, subclass, prog_if, irq)"
    print "  -h    Show this help"

fn run_lspci(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_usage()
            return 0

    val verbose = _parse_verbose(args)
    val devices = enumerate_devices()

    if devices.len() == 0:
        print "No PCI devices found."
        return 0

    for entry in devices:
        val line = _format_device_line(entry)
        print line
        if verbose:
            val details = _format_verbose_details(entry)
            print details
            print ""

    0
