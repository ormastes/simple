"""
# std.error — Standard Error Type

SimpleError is the standard error type used by SFFI extern fn bindings
(net, fs, tcp, etc.). It is a builtin runtime type; this module makes it
importable and re-exports the common error helper.
"""

extern class SimpleError:
    """Runtime error type used by extern SFFI bindings (net, fs, etc.)."""
    message: text
    code: i32

pub fn error(message: text) -> SimpleError:
    """Construct a SimpleError with the given message and code 0."""
    SimpleError(message: message, code: 0)

export SimpleError, error
