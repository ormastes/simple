use std.common.window_protocol.geometry.{WindowId, Point, KeyCode, Modifiers}
use std.common.window_protocol.window_protocol.{WmInputEvent}

fn ascii_code_for_key(key_char: text?) -> u32:
    if key_char == nil:
        return 0 as u32
    val ch = key_char ?? ""
    if ch == "":
        return 0 as u32
    val first = ch.slice(0, 1)
    val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    var i = 0
    while i < chars.len():
        if chars.slice(i, i + 1) == first:
            return (32 + i) as u32
        i = i + 1
    0 as u32

fn key_char_to_wm_key_event(window_id: WindowId, key_char: text?) -> WmInputEvent:
    val code = ascii_code_for_key(key_char)
    val name = key_char ?? ""
    WmInputEvent.key_down(window_id, KeyCode(code: code, name: name), Modifiers.none())

fn pointer_to_wm_mouse_event(window_id: WindowId, kind: text, x: i32, y: i32, modifiers: Modifiers) -> WmInputEvent:
    val point = Point.xy(x, y)
    if kind == "down" or kind == "mouse_down" or kind == "pointer_down":
        return WmInputEvent.mouse_down(window_id, point, modifiers)
    if kind == "up" or kind == "mouse_up" or kind == "pointer_up":
        return WmInputEvent.mouse_up(window_id, point, modifiers)
    WmInputEvent.mouse_move(window_id, point)

fn wheel_to_wm_scroll_event(window_id: WindowId, x: i32, y: i32, dx: f64, dy: f64, modifiers: Modifiers) -> WmInputEvent:
    WmInputEvent.scroll(window_id, Point.xy(x, y), dx, dy, modifiers)
