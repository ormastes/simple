"""
# Platform Event — Cross-Platform Network Event Abstraction

Provides a unified API over platform-native I/O notification mechanisms.
Delegates to the appropriate backend based on runtime OS detection.

## Backends

| Backend | Platform | Characteristics |
|---------|----------|----------------|
| Epoll | Linux | Level/edge-triggered, O(1) readiness notification |
| Kqueue | BSD/macOS | Edge-triggered by default, filters for fine-grained events |
| Iocp | Windows | Completion-based (proactor pattern), not readiness-based |
| EventPorts | Solaris/illumos | port_create/port_associate/port_get, one-shot by default |
| Poll | Other | Cooperative fallback, O(n) per poll call |

## Usage

```simple
val pe = PlatformEvent.new()
val handle = pe.create()
pe.register(handle, socket_fd, EventMode.Read)
val ready_fds = pe.poll(handle, 64, 100)
pe.close(handle)
```
"""

use std.io.types.{IoError, IoErrorKind}

# ============================================================================
# Enums
# ============================================================================

enum EventMode:
    """Interest mode for event registration.

    Encodes which I/O directions to monitor on a file descriptor.
    Maps to the extern ABI integer encoding: 0=Read, 1=Write, 2=ReadWrite.

    ```simple
    val mode = EventMode.Read
    val both = EventMode.ReadWrite
    ```
    """
    Read
    Write
    ReadWrite

enum EventBackend:
    """Platform-native I/O notification backend.

    Detected at runtime via `rt_platform_name()`. Only one backend
    is active per process.

    ```simple
    val backend = detect_backend()
    # Returns EventBackend.Epoll on Linux
    ```
    """
    Epoll
    Kqueue
    Iocp
    EventPorts
    Poll

# ============================================================================
# Platform Detection
# ============================================================================

extern fn rt_platform_name() -> text

fn detect_backend() -> EventBackend:
    """Detect the best event notification backend for the current OS.

    Returns:
        EventBackend enum variant matching the running platform.
        Falls back to EventBackend.Poll on unknown platforms.

    Example:
        val backend = detect_backend()
        # Linux -> EventBackend.Epoll
        # macOS -> EventBackend.Kqueue
    """
    val platform = rt_platform_name()
    if platform == "linux":
        EventBackend.Epoll
    else if platform == "macos" or platform == "freebsd":
        EventBackend.Kqueue
    else if platform == "windows":
        EventBackend.Iocp
    else if platform == "solaris" or platform == "illumos":
        EventBackend.EventPorts
    else:
        EventBackend.Poll

# ============================================================================
# EventMode <-> i64 Mapping
# ============================================================================

fn _mode_to_i64(mode: EventMode) -> i64:
    """Convert EventMode enum to extern ABI integer."""
    match mode:
        case EventMode.Read: 0
        case EventMode.Write: 1
        case EventMode.ReadWrite: 2

fn _i64_to_mode(value: i64) -> EventMode:
    """Convert extern ABI integer back to EventMode enum."""
    if value == 1:
        EventMode.Write
    else if value == 2:
        EventMode.ReadWrite
    else:
        EventMode.Read

# ============================================================================
# Extern Stubs — Per-Backend Native Functions
# ============================================================================

# Epoll (Linux) — delegates to the existing rt_event_loop_* implementation
extern fn rt_event_loop_create() -> i64
extern fn rt_event_loop_register(loop_fd: i64, fd: i64, interest: i64, token: i64, edge: bool) -> bool
extern fn rt_event_loop_deregister(loop_fd: i64, fd: i64) -> bool
extern fn rt_event_loop_poll(loop_fd: i64, max_events: i64, timeout_ms: i64) -> [i64]
extern fn rt_event_loop_close(loop_fd: i64) -> bool

# Kqueue (BSD/macOS)
extern fn rt_kqueue_create() -> i64
extern fn rt_kqueue_register(loop_fd: i64, fd: i64, interest: i64, token: i64, edge: bool) -> bool
extern fn rt_kqueue_deregister(loop_fd: i64, fd: i64) -> bool
extern fn rt_kqueue_poll(loop_fd: i64, max_events: i64, timeout_ms: i64) -> [i64]
extern fn rt_kqueue_close(loop_fd: i64) -> bool

# IOCP (Windows)
# NOTE: IOCP is completion-based (proactor pattern). The register/poll API
# here provides a readiness-based facade. Internally IOCP uses
# GetQueuedCompletionStatusEx or WSAPoll as a transitional fallback.
extern fn rt_iocp_create() -> i64
extern fn rt_iocp_register(loop_fd: i64, fd: i64, interest: i64, token: i64, edge: bool) -> bool
extern fn rt_iocp_deregister(loop_fd: i64, fd: i64) -> bool
extern fn rt_iocp_poll(loop_fd: i64, max_events: i64, timeout_ms: i64) -> [i64]
extern fn rt_iocp_close(loop_fd: i64) -> bool

# Event Ports (Solaris/illumos)
# NOTE: Event ports are one-shot by default — after receiving an event the fd
# must be re-associated via port_associate before the next poll.
extern fn rt_event_ports_create() -> i64
extern fn rt_event_ports_register(loop_fd: i64, fd: i64, interest: i64, token: i64, edge: bool) -> bool
extern fn rt_event_ports_deregister(loop_fd: i64, fd: i64) -> bool
extern fn rt_event_ports_poll(loop_fd: i64, max_events: i64, timeout_ms: i64) -> [i64]
extern fn rt_event_ports_close(loop_fd: i64) -> bool

# ============================================================================
# PlatformEvent — Cross-Platform Event Abstraction
# ============================================================================

class PlatformEvent:
    """Cross-platform event notification abstraction.

    Detects the native backend at construction time and dispatches all
    operations to the appropriate platform-specific extern functions.

    On Linux, delegates to the real epoll implementation. On other platforms,
    delegates to stub externs that will be filled in as backends mature.

    Example:
        val pe = PlatformEvent.new()
        val handle = pe.create()
        pe.register(handle, socket_fd, EventMode.ReadWrite)
        val ready = pe.poll(handle, 64, 100)
        pe.close(handle)
    """
    _backend: EventBackend

    static fn new() -> PlatformEvent:
        """Create a PlatformEvent with auto-detected backend.

        Returns:
            PlatformEvent configured for the current platform.
        """
        PlatformEvent(_backend: detect_backend())

    static fn with_backend(backend: EventBackend) -> PlatformEvent:
        """Create a PlatformEvent with a specific backend (for testing).

        Args:
            backend: The backend to use.

        Returns:
            PlatformEvent configured for the given backend.
        """
        PlatformEvent(_backend: backend)

    fn backend() -> EventBackend:
        """Return the active backend enum.

        Returns:
            The EventBackend variant in use.
        """
        self._backend

    fn backend_name() -> text:
        """Return the backend name as a string.

        Returns:
            One of: "epoll", "kqueue", "iocp", "event_ports", "poll"
        """
        match self._backend:
            case EventBackend.Epoll: "epoll"
            case EventBackend.Kqueue: "kqueue"
            case EventBackend.Iocp: "iocp"
            case EventBackend.EventPorts: "event_port"
            case EventBackend.Poll: "poll"

    fn create() -> i64:
        """Create a new event notification handle.

        Returns the platform-native event fd/handle, or -1 on error.
        - epoll: epoll_create1(0) fd
        - kqueue: kqueue() fd
        - IOCP: CreateIoCompletionPort handle (stub, returns handle id)
        - event_ports: port_create() fd (stub, returns handle id)
        - poll: -1 (no native support)

        Returns:
            Native event handle (>= 0) or -1 on error.
        """
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_create()
            case EventBackend.Kqueue: rt_kqueue_create()
            case EventBackend.Iocp: rt_iocp_create()
            case EventBackend.EventPorts: rt_event_ports_create()
            case EventBackend.Poll: -1

    fn register(handle: i64, fd: i64, mode: EventMode) -> bool:
        """Register an fd for level-triggered event monitoring.

        Args:
            handle: Event loop handle from create()
            fd: File descriptor to monitor
            mode: EventMode.Read, EventMode.Write, or EventMode.ReadWrite

        Platform notes:
            - epoll: EPOLL_CTL_ADD with EPOLLIN/EPOLLOUT
            - kqueue: EV_ADD with EVFILT_READ/EVFILT_WRITE (level-triggered via EV_CLEAR absent)
            - IOCP: WSAPoll registration (stub)
            - event_ports: port_associate with POLLIN/POLLOUT (one-shot by default)

        Returns:
            true on success, false on error.
        """
        if handle < 0 or fd < 0:
            return false
        val interest = _mode_to_i64(mode)
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_register(handle, fd, interest, fd, false)
            case EventBackend.Kqueue: rt_kqueue_register(handle, fd, interest, fd, false)
            case EventBackend.Iocp: rt_iocp_register(handle, fd, interest, fd, false)
            case EventBackend.EventPorts: rt_event_ports_register(handle, fd, interest, fd, false)
            case EventBackend.Poll: false

    fn register_edge(handle: i64, fd: i64, mode: EventMode) -> bool:
        """Register an fd for edge-triggered event monitoring.

        Edge-triggered mode only notifies on state transitions. The caller
        must drain the fd fully on each notification.

        Args:
            handle: Event loop handle from create()
            fd: File descriptor to monitor
            mode: EventMode.Read, EventMode.Write, or EventMode.ReadWrite

        Platform notes:
            - epoll: adds EPOLLET flag
            - kqueue: edge-triggered by default (EV_CLEAR); this is a no-op upgrade
            - IOCP: not applicable (completion-based); behaves like level-triggered
            - event_ports: one-shot semantics; caller must re-associate after each event

        Returns:
            true on success, false on error.
        """
        if handle < 0 or fd < 0:
            return false
        val interest = _mode_to_i64(mode)
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_register(handle, fd, interest, fd, true)
            case EventBackend.Kqueue: rt_kqueue_register(handle, fd, interest, fd, true)
            case EventBackend.Iocp: rt_iocp_register(handle, fd, interest, fd, true)
            case EventBackend.EventPorts: rt_event_ports_register(handle, fd, interest, fd, true)
            case EventBackend.Poll: false

    fn register_with_token(handle: i64, fd: i64, mode: EventMode, token: i64, edge: bool) -> bool:
        """Register an fd with explicit token and edge-trigger control.

        Used by EventLoop which manages its own token mapping.

        Args:
            handle: Event loop handle from create()
            fd: File descriptor to monitor
            mode: EventMode.Read, EventMode.Write, or EventMode.ReadWrite
            token: User-supplied token returned in poll results
            edge: true for edge-triggered, false for level-triggered

        Returns:
            true on success, false on error.
        """
        if handle < 0 or fd < 0:
            return false
        val interest = _mode_to_i64(mode)
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_register(handle, fd, interest, token, edge)
            case EventBackend.Kqueue: rt_kqueue_register(handle, fd, interest, token, edge)
            case EventBackend.Iocp: rt_iocp_register(handle, fd, interest, token, edge)
            case EventBackend.EventPorts: rt_event_ports_register(handle, fd, interest, token, edge)
            case EventBackend.Poll: false

    fn deregister(handle: i64, fd: i64) -> bool:
        """Remove an fd from event monitoring.

        Args:
            handle: Event loop handle from create()
            fd: File descriptor to remove

        Platform notes:
            - epoll: EPOLL_CTL_DEL
            - kqueue: EV_DELETE for both read/write filters
            - IOCP: CancelIoEx or disassociate (stub)
            - event_ports: port_dissociate (stub)

        Returns:
            true on success, false on error.
        """
        if handle < 0 or fd < 0:
            return false
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_deregister(handle, fd)
            case EventBackend.Kqueue: rt_kqueue_deregister(handle, fd)
            case EventBackend.Iocp: rt_iocp_deregister(handle, fd)
            case EventBackend.EventPorts: rt_event_ports_deregister(handle, fd)
            case EventBackend.Poll: false

    fn poll(handle: i64, max: i64, timeout_ms: i64) -> [i64]:
        """Wait for I/O events and return ready descriptors.

        Blocks up to timeout_ms milliseconds. Returns a flat array of
        (fd, ready, token) triples: [fd1, ready1, token1, fd2, ...].

        ready encoding: 0=Read, 1=Write, 2=ReadWrite.

        Args:
            handle: Event loop handle from create()
            max: Maximum number of events to return
            timeout_ms: Max wait time (-1 for infinite, 0 for non-blocking)

        Platform notes:
            - epoll: epoll_wait with max events
            - kqueue: kevent with timeout; coalesces read+write for same fd
            - IOCP: GetQueuedCompletionStatusEx (stub, returns [])
            - event_ports: port_getn; must re-associate fds after (one-shot)

        Returns:
            Flat [i64] array of (fd, ready, token) triples.
        """
        if handle < 0 or max <= 0:
            return []
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_poll(handle, max, timeout_ms)
            case EventBackend.Kqueue: rt_kqueue_poll(handle, max, timeout_ms)
            case EventBackend.Iocp: rt_iocp_poll(handle, max, timeout_ms)
            case EventBackend.EventPorts: rt_event_ports_poll(handle, max, timeout_ms)
            case EventBackend.Poll: []

    fn close(handle: i64) -> bool:
        """Close the event notification handle and release resources.

        Args:
            handle: Event loop handle from create()

        Returns:
            true on success, false on error.
        """
        if handle < 0:
            return false
        match self._backend:
            case EventBackend.Epoll: rt_event_loop_close(handle)
            case EventBackend.Kqueue: rt_kqueue_close(handle)
            case EventBackend.Iocp: rt_iocp_close(handle)
            case EventBackend.EventPorts: rt_event_ports_close(handle)
            case EventBackend.Poll: false
