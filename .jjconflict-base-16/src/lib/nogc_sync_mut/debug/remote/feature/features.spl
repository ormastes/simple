# Feature Definitions
# All debug capabilities expressed as FeatureId values.
# Each backend registers handlers for features at a numeric rank.

# Debug capability identifier
enum FeatureId:
    # Execution control
    Halt
    Resume
    SingleStep
    StepOver
    Reset

    # Memory
    ReadMemory
    WriteMemory

    # Registers
    ReadRegister
    WriteRegister
    ReadAllRegisters

    # Breakpoints
    SetBreakpoint
    ClearBreakpoint
    SetWatchpoint
    ConditionalBreakpoint
    FunctionBreakpoint
    EnableBreakpoint
    DisableBreakpoint
    ListBreakpoints

    # Inspection
    ReadLocals
    ReadGlobals
    ReadArguments
    EvaluateExpression
    ReadStackTrace

    # Frame navigation
    SelectFrame
    FrameLocals
    FrameArguments
    SetVariable

    # Ptrace (native process tracing)
    PtraceAttach
    PtraceDetach
    PtraceContinue
    PtraceSingleStep
    PtraceReadMemory
    PtraceWriteMemory

    # DWARF (debug info)
    DwarfAddrToSource
    DwarfSourceToAddr
    DwarfFunctionName

    # System operations (used by emulation)
    ProfileSample
    FlashProgram
    SystemReset

    # Trace32-unique operations
    TraceCapture
    CoverageCollect

    # T32/OpenOCD hardware-specific operations
    PracticeScript
    OpenocdMonitor
    SemihostRead

    # GDB RSP (direct protocol, no GDB process)
    RspConnect
    RspPacketSend

    # GDB enhancements
    ReverseStep
    ReverseContinue
    NonStopMode
    AsyncInterrupt
    PrettyPrint

    # LLDB via DAP subprocess
    LldbDapLaunch
    LldbDapAttach

    # Windows DbgEng
    DbgEngAttach

    # Replay / reverse debugging lifecycle
    RecordStart
    RecordStop
    ReplayStart
    ReplayStop
    ReverseFinish
    ReverseWatch
    CheckpointSave
    CheckpointRestore

    fn to_string() -> text:
        match self:
            Halt: "Halt"
            Resume: "Resume"
            SingleStep: "SingleStep"
            StepOver: "StepOver"
            Reset: "Reset"
            ReadMemory: "ReadMemory"
            WriteMemory: "WriteMemory"
            ReadRegister: "ReadRegister"
            WriteRegister: "WriteRegister"
            ReadAllRegisters: "ReadAllRegisters"
            SetBreakpoint: "SetBreakpoint"
            ClearBreakpoint: "ClearBreakpoint"
            SetWatchpoint: "SetWatchpoint"
            ConditionalBreakpoint: "ConditionalBreakpoint"
            FunctionBreakpoint: "FunctionBreakpoint"
            EnableBreakpoint: "EnableBreakpoint"
            DisableBreakpoint: "DisableBreakpoint"
            ListBreakpoints: "ListBreakpoints"
            ReadLocals: "ReadLocals"
            ReadGlobals: "ReadGlobals"
            ReadArguments: "ReadArguments"
            EvaluateExpression: "EvaluateExpression"
            ReadStackTrace: "ReadStackTrace"
            SelectFrame: "SelectFrame"
            FrameLocals: "FrameLocals"
            FrameArguments: "FrameArguments"
            SetVariable: "SetVariable"
            PtraceAttach: "PtraceAttach"
            PtraceDetach: "PtraceDetach"
            PtraceContinue: "PtraceContinue"
            PtraceSingleStep: "PtraceSingleStep"
            PtraceReadMemory: "PtraceReadMemory"
            PtraceWriteMemory: "PtraceWriteMemory"
            DwarfAddrToSource: "DwarfAddrToSource"
            DwarfSourceToAddr: "DwarfSourceToAddr"
            DwarfFunctionName: "DwarfFunctionName"
            ProfileSample: "ProfileSample"
            FlashProgram: "FlashProgram"
            SystemReset: "SystemReset"
            TraceCapture: "TraceCapture"
            CoverageCollect: "CoverageCollect"
            PracticeScript: "PracticeScript"
            OpenocdMonitor: "OpenocdMonitor"
            SemihostRead: "SemihostRead"
            RspConnect: "RspConnect"
            RspPacketSend: "RspPacketSend"
            ReverseStep: "ReverseStep"
            ReverseContinue: "ReverseContinue"
            NonStopMode: "NonStopMode"
            AsyncInterrupt: "AsyncInterrupt"
            PrettyPrint: "PrettyPrint"
            LldbDapLaunch: "LldbDapLaunch"
            LldbDapAttach: "LldbDapAttach"
            DbgEngAttach: "DbgEngAttach"
            RecordStart: "RecordStart"
            RecordStop: "RecordStop"
            ReplayStart: "ReplayStart"
            ReplayStop: "ReplayStop"
            ReverseFinish: "ReverseFinish"
            ReverseWatch: "ReverseWatch"
            CheckpointSave: "CheckpointSave"
            CheckpointRestore: "CheckpointRestore"

    fn to_text() -> text:
        self.to_string()

    fn to_i32() -> i32:
        match self:
            Halt: 1
            Resume: 2
            SingleStep: 3
            StepOver: 4
            Reset: 5
            ReadMemory: 6
            WriteMemory: 7
            ReadRegister: 8
            WriteRegister: 9
            ReadAllRegisters: 10
            SetBreakpoint: 11
            ClearBreakpoint: 12
            SetWatchpoint: 13
            ConditionalBreakpoint: 14
            FunctionBreakpoint: 15
            EnableBreakpoint: 16
            DisableBreakpoint: 17
            ListBreakpoints: 18
            ReadLocals: 19
            ReadGlobals: 20
            ReadArguments: 21
            EvaluateExpression: 22
            ReadStackTrace: 23
            SelectFrame: 24
            FrameLocals: 25
            FrameArguments: 26
            SetVariable: 27
            PtraceAttach: 28
            PtraceDetach: 29
            PtraceContinue: 30
            PtraceSingleStep: 31
            PtraceReadMemory: 32
            PtraceWriteMemory: 33
            DwarfAddrToSource: 34
            DwarfSourceToAddr: 35
            DwarfFunctionName: 36
            ProfileSample: 37
            FlashProgram: 38
            SystemReset: 39
            TraceCapture: 40
            CoverageCollect: 41
            PracticeScript: 42
            OpenocdMonitor: 43
            SemihostRead: 44
            RspConnect: 45
            RspPacketSend: 46
            ReverseStep: 47
            ReverseContinue: 48
            NonStopMode: 49
            AsyncInterrupt: 50
            PrettyPrint: 51
            LldbDapLaunch: 52
            LldbDapAttach: 53
            DbgEngAttach: 54
            RecordStart: 55
            RecordStop: 56
            ReplayStart: 57
            ReplayStop: 58
            ReverseFinish: 59
            ReverseWatch: 60
            CheckpointSave: 61
            CheckpointRestore: 62

    static fn from_i32(id: i32) -> FeatureId:
        match id:
            1: FeatureId::Halt
            2: FeatureId::Resume
            3: FeatureId::SingleStep
            4: FeatureId::StepOver
            5: FeatureId::Reset
            6: FeatureId::ReadMemory
            7: FeatureId::WriteMemory
            8: FeatureId::ReadRegister
            9: FeatureId::WriteRegister
            10: FeatureId::ReadAllRegisters
            11: FeatureId::SetBreakpoint
            12: FeatureId::ClearBreakpoint
            13: FeatureId::SetWatchpoint
            14: FeatureId::ConditionalBreakpoint
            15: FeatureId::FunctionBreakpoint
            16: FeatureId::EnableBreakpoint
            17: FeatureId::DisableBreakpoint
            18: FeatureId::ListBreakpoints
            19: FeatureId::ReadLocals
            20: FeatureId::ReadGlobals
            21: FeatureId::ReadArguments
            22: FeatureId::EvaluateExpression
            23: FeatureId::ReadStackTrace
            24: FeatureId::SelectFrame
            25: FeatureId::FrameLocals
            26: FeatureId::FrameArguments
            27: FeatureId::SetVariable
            28: FeatureId::PtraceAttach
            29: FeatureId::PtraceDetach
            30: FeatureId::PtraceContinue
            31: FeatureId::PtraceSingleStep
            32: FeatureId::PtraceReadMemory
            33: FeatureId::PtraceWriteMemory
            34: FeatureId::DwarfAddrToSource
            35: FeatureId::DwarfSourceToAddr
            36: FeatureId::DwarfFunctionName
            37: FeatureId::ProfileSample
            38: FeatureId::FlashProgram
            39: FeatureId::SystemReset
            40: FeatureId::TraceCapture
            41: FeatureId::CoverageCollect
            42: FeatureId::PracticeScript
            43: FeatureId::OpenocdMonitor
            44: FeatureId::SemihostRead
            45: FeatureId::RspConnect
            46: FeatureId::RspPacketSend
            47: FeatureId::ReverseStep
            48: FeatureId::ReverseContinue
            49: FeatureId::NonStopMode
            50: FeatureId::AsyncInterrupt
            51: FeatureId::PrettyPrint
            52: FeatureId::LldbDapLaunch
            53: FeatureId::LldbDapAttach
            54: FeatureId::DbgEngAttach
            55: FeatureId::RecordStart
            56: FeatureId::RecordStop
            57: FeatureId::ReplayStart
            58: FeatureId::ReplayStop
            59: FeatureId::ReverseFinish
            60: FeatureId::ReverseWatch
            61: FeatureId::CheckpointSave
            62: FeatureId::CheckpointRestore
            _: FeatureId::Halt

    fn eq(other: FeatureId) -> bool:
        self.to_string() == other.to_string()

# Rank constants for feature handler priority
# Lower rank = preferred handler
class FeatureRank:
    # Rank 0: Native support (zero overhead, direct protocol command)
    static fn NATIVE() -> i32:
        0

    # Rank 1: Bridge translation (minor overhead, translated command)
    static fn BRIDGE() -> i32:
        1

    # Rank 2: Secondary native (alternative protocol, higher overhead)
    static fn SECONDARY() -> i32:
        2

    # Rank 3: External tool (OpenOCD, etc.)
    static fn EXTERNAL() -> i32:
        3

    # Rank 4: Emulated (synthesized from lower-level operations)
    static fn EMULATED() -> i32:
        4

# Feature rank table: default rankings per backend
#
# | Feature              | GDB | Ptrace | DWARF | Emulated | T32 |
# |----------------------|-----|--------|-------|----------|------|
# | Halt                 |  0  |   -    |   -   |    -     |
# | Resume               |  0  |   -    |   -   |    -     |
# | SingleStep           |  0  |   -    |   -   |    -     |
# | ReadMemory           |  0  |   -    |   -   |    -     |
# | WriteMemory          |  0  |   -    |   -   |    -     |
# | ReadRegister         |  0  |   -    |   -   |    -     |
# | ReadLocals           |  0  |   -    |   -   |    4     |
# | ReadArguments        |  0  |   -    |   -   |    4     |
# | ReadStackTrace       |  0  |   -    |   -   |    4     |
# | EvaluateExpression   |  0  |   -    |   -   |    -     |
# | SetBreakpoint        |  0  |   -    |   -   |    -     |
# | ConditionalBreakpoint|  0  |   -    |   -   |    -     |
# | FunctionBreakpoint   |  0  |   -    |   -   |    -     |
# | EnableBreakpoint     |  0  |   -    |   -   |    -     |
# | DisableBreakpoint    |  0  |   -    |   -   |    -     |
# | ListBreakpoints      |  0  |   -    |   -   |    -     |
# | SelectFrame          |  0  |   -    |   -   |    -     |
# | FrameLocals          |  0  |   -    |   -   |    -     |
# | FrameArguments       |  0  |   -    |   -   |    -     |
# | SetVariable          |  0  |   -    |   -   |    -     |
# | PtraceAttach         |  -  |   0    |   -   |    -     |
# | PtraceDetach         |  -  |   0    |   -   |    -     |
# | PtraceContinue       |  -  |   0    |   -   |    -     |
# | PtraceSingleStep     |  -  |   0    |   -   |    -     |
# | PtraceReadMemory     |  -  |   0    |   -   |    -     |
# | PtraceWriteMemory    |  -  |   0    |   -   |    -     |
# | DwarfAddrToSource    |  -  |   -    |   0   |    -     |
# | DwarfSourceToAddr    |  -  |   -    |   0   |    -     |
# | DwarfFunctionName    |  -  |   -    |   0   |    -     |
# | ProfileSample        |  -  |   -    |   -   |    3     |
# | FlashProgram         |  -  |   -    |   -   |    3     |   0    |
# | SystemReset          |  -  |   -    |   -   |    3     |   0    |
# | TraceCapture         |  -  |   -    |   -   |    4     |   0    |
# | CoverageCollect      |  -  |   -    |   -   |    4     |   0    |
# | PracticeScript       |  -  |   -    |   -   |    -     |   0    |
# | OpenocdMonitor       |  -  |   -    |   -   |    -     |   0    |  (OpenOCD)
# | SemihostRead         |  -  |   -    |   -   |    4     |   -    |
