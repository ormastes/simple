# Shader source data shared by shader compilation.

struct ShaderSource:
    vertex_code: text
    fragment_code: text
    name: text

impl ShaderSource:
    fn is_valid() -> bool:
        self.vertex_code.len() > 0 and self.fragment_code.len() > 0

    fn to_text() -> text:
        "ShaderSource({self.name})"
