# Installer Package Types
#
# Shared types for cross-platform installer generation.

# Target package format
enum InstallerPlatform:
    Deb          # Ubuntu/Debian .deb
    Rpm          # Fedora/RHEL .rpm
    MacosPkg     # macOS .pkg (via FPM osxpkg)
    FreeBsd      # FreeBSD .txz
    WindowsExe   # Windows .exe installer (via NSIS)

    static fn all() -> [InstallerPlatform]:
        [
            InstallerPlatform.Deb,
            InstallerPlatform.Rpm,
            InstallerPlatform.MacosPkg,
            InstallerPlatform.FreeBsd,
            InstallerPlatform.WindowsExe
        ]

    static fn from_string(name: text) -> Option<InstallerPlatform>:
        match name:
            case "deb": Some(InstallerPlatform.Deb)
            case "rpm": Some(InstallerPlatform.Rpm)
            case "macos": Some(InstallerPlatform.MacosPkg)
            case "freebsd": Some(InstallerPlatform.FreeBsd)
            case "windows": Some(InstallerPlatform.WindowsExe)
            case _: nil

impl InstallerPlatform:
    fn to_string() -> text:
        match self:
            case InstallerPlatform.Deb: "deb"
            case InstallerPlatform.Rpm: "rpm"
            case InstallerPlatform.MacosPkg: "macos"
            case InstallerPlatform.FreeBsd: "freebsd"
            case InstallerPlatform.WindowsExe: "windows"

    fn file_extension() -> text:
        match self:
            case InstallerPlatform.Deb: ".deb"
            case InstallerPlatform.Rpm: ".rpm"
            case InstallerPlatform.MacosPkg: ".pkg"
            case InstallerPlatform.FreeBsd: ".txz"
            case InstallerPlatform.WindowsExe: ".exe"

    fn fpm_type() -> Option<text>:
        """FPM -t flag value, nil for non-FPM platforms"""
        match self:
            case InstallerPlatform.Deb: Some("deb")
            case InstallerPlatform.Rpm: Some("rpm")
            case InstallerPlatform.MacosPkg: Some("osxpkg")
            case InstallerPlatform.FreeBsd: Some("freebsd")
            case InstallerPlatform.WindowsExe: nil

    fn description() -> text:
        match self:
            case InstallerPlatform.Deb: "Debian/Ubuntu package"
            case InstallerPlatform.Rpm: "RPM package (Fedora/RHEL)"
            case InstallerPlatform.MacosPkg: "macOS installer package"
            case InstallerPlatform.FreeBsd: "FreeBSD package"
            case InstallerPlatform.WindowsExe: "Windows installer"


# Configuration for installer generation
struct InstallerConfig:
    version: text
    package_name: text
    description: text
    maintainer: text
    homepage: text
    license: text
    source_dir: text       # Where release binaries live (e.g. bin/release/)
    output_dir: text       # Where to write packages (e.g. build/installers/)
    architecture: text     # e.g. "amd64", "arm64"

fn default_config() -> InstallerConfig:
    InstallerConfig(
        version: "0.0.0",
        package_name: "simple-lang",
        description: "Simple Language Compiler and Runtime",
        maintainer: "Simple Language Team <team@simple-lang.org>",
        homepage: "https://simple-lang.org",
        license: "MIT",
        source_dir: "bin/release",
        output_dir: "build/installers",
        architecture: "amd64"
    )


# Result of an installer build
struct InstallerResult:
    platform: InstallerPlatform
    success: bool
    output_path: text      # Path to generated package file
    message: text          # Success/error message


# Available packaging tools on the system
struct ToolAvailability:
    fpm_available: bool
    makensis_available: bool
    dpkg_deb_available: bool
    fpm_path: text
    makensis_path: text
    dpkg_deb_path: text
