# Shared infrastructure for GPU backend adapters.
# Used by cpu, cuda, metal, vulkan, and webgpu adapters.

use std.io

class AdapterState:
    handle: i64
    initialized: bool
    session_mode: text
    backend_name: text

    static fn create(backend_name: text) -> AdapterState:
        AdapterState(
            handle: 0,
            initialized: false,
            session_mode: "exclusive",
            backend_name: backend_name,
        )

    me is_ready() -> bool:
        self.initialized

    me require_init() -> text:
        if self.initialized == false:
            return self.backend_name + ": device not initialized"
        ""


class AdapterCapabilities:
    compute: bool
    graphics: bool
    present: bool
    raytracing: bool

    static fn full() -> AdapterCapabilities:
        AdapterCapabilities(
            compute: true,
            graphics: true,
            present: true,
            raytracing: false,
        )

    static fn compute_only() -> AdapterCapabilities:
        AdapterCapabilities(
            compute: true,
            graphics: false,
            present: false,
            raytracing: false,
        )

    static fn graphics_only() -> AdapterCapabilities:
        AdapterCapabilities(
            compute: false,
            graphics: true,
            present: true,
            raytracing: false,
        )

    me summary() -> text:
        "compute=" + self.compute.to_text() +
        " graphics=" + self.graphics.to_text() +
        " present=" + self.present.to_text() +
        " raytracing=" + self.raytracing.to_text()


class DeviceInfoBuilder:
    backend: text
    device_name: text
    vendor: text
    vram_mb: i32
    driver_version: text

    static fn create(
        backend: text,
        device_name: text,
        vendor: text,
        vram_mb: i32,
        driver_version: text,
    ) -> DeviceInfoBuilder:
        DeviceInfoBuilder(
            backend: backend,
            device_name: device_name,
            vendor: vendor,
            vram_mb: vram_mb,
            driver_version: driver_version,
        )

    me build() -> text:
        "backend=" + self.backend +
        " device=" + self.device_name +
        " vendor=" + self.vendor +
        " vram=" + self.vram_mb.to_text() + "mb" +
        " driver=" + self.driver_version


class CommandValidator:
    max_commands: i32
    max_batch_size: i32

    static fn standard() -> CommandValidator:
        CommandValidator(
            max_commands: 1024,
            max_batch_size: 64,
        )

    static fn high_throughput() -> CommandValidator:
        CommandValidator(
            max_commands: 4096,
            max_batch_size: 256,
        )

    me validate_count(count: i32) -> text:
        if count < 0:
            return "invalid command count: " + count.to_text()
        if count > self.max_commands:
            return "command count " + count.to_text() + " exceeds max " + self.max_commands.to_text()
        ""

    me validate_batch(batch_size: i32) -> text:
        if batch_size < 0:
            return "invalid batch size: " + batch_size.to_text()
        if batch_size > self.max_batch_size:
            return "batch size " + batch_size.to_text() + " exceeds max " + self.max_batch_size.to_text()
        ""


class InitCleanupGuard:
    phase: text

    static fn create() -> InitCleanupGuard:
        InitCleanupGuard(phase: "created")

    me begin_init() -> text:
        if self.phase == "created":
            self.phase = "initializing"
            return ""
        "cannot begin init from phase: " + self.phase

    me complete_init() -> text:
        if self.phase == "initializing":
            self.phase = "ready"
            return ""
        "cannot complete init from phase: " + self.phase

    me begin_cleanup() -> text:
        if self.phase == "ready":
            self.phase = "cleaning"
            return ""
        "cannot begin cleanup from phase: " + self.phase

    me complete_cleanup() -> text:
        if self.phase == "cleaning":
            self.phase = "disposed"
            return ""
        "cannot complete cleanup from phase: " + self.phase
