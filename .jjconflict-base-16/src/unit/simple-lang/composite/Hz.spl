# Composite Unit: Hertz
# Kind: Frequency
# Symbol: Hz
# Scale to SI base: 1.0 Hz

class Hertz:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Hertz) -> Hertz: Hertz(value: self.value + other.value)
    fn sub(other: Hertz) -> Hertz: Hertz(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "Hz"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "Hz"
    static fn numerator() -> [text]: ["cycle"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> Hertz: Hertz(value: 0.0)

export Hertz
