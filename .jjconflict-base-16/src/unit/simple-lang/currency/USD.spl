# Unit: Usd
# Kind: Currency
# Symbol: USD
# Canonical scale: 1.0 USD

class Usd:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Usd) -> Usd: Usd(value: self.value + other.value)
    fn sub(other: Usd) -> Usd: Usd(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "USD"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Usd: Usd(value: 0.0)

export Usd
