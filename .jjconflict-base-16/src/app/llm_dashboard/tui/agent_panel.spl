use app.llm_dashboard.data.agent_tree.{AgentTree}

fn _display_text(value: text?) -> text:
    value ?? ""

pub fn render_agent_tree(tree: AgentTree, max_lines: i64) -> [text]:
    if max_lines <= 0:
        return []
    val agents = tree.all_agents()
    if agents.len() == 0:
        var empty_lines = ["No agents connected", "Waiting for activity"]
        if max_lines == 1:
            return [empty_lines[0]]
        return empty_lines

    var lines: [text] = []
    for agent in agents:
        if lines.len() >= max_lines:
            return lines
        var label = _display_text(agent.id)
        val model = _display_text(agent.model)
        if model != "":
            label = label + " " + model
        lines.push(label)
    lines

export render_agent_tree
