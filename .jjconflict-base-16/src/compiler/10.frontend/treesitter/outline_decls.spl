# TreeSitter Outline Declarations - Function/Class/Actor/Struct/Field Parsers
#
# Handles parsing of:
# - function outlines (regular, extern)
# - parameter and type parameter outlines
# - class and actor outlines
# - struct outlines
# - field outlines (with volatile, memory-mapped, defaults)
#
# Split from outline.spl for modularity.

use compiler.frontend.core.lexer.*
use compiler.frontend.treesitter_types.*
use compiler.common.dependency.visibility.{Visibility}
use compiler.frontend.treesitter.outline_lexer.{TreeSitter}
use compiler.frontend.treesitter.outline_types.{merge_spans, typeoutlinekind_Optional}

fn bounds_push(bounds: [TypeOutline], item: TypeOutline) -> [TypeOutline]:
        bounds.push(item)
use compiler.frontend.treesitter.outline_types.*

fn functionoutline_with_flags(fn_: FunctionOutline, is_async: bool, is_static: bool, is_method: bool, is_const: bool, is_kernel: bool) -> FunctionOutline:
        FunctionOutline(
            name: fn_.name,
            params: fn_.params,
            has_return_type: fn_.has_return_type,
            return_type: fn_.return_type,
            visibility: fn_.visibility,
            is_async: is_async,
            is_static: is_static,
            is_public: fn_.is_public,
            is_method: is_method,
            is_mutable: fn_.is_mutable,
            is_const: is_const,
            is_kernel: is_kernel,
            is_extern: fn_.is_extern,
            has_doc_comment: fn_.has_doc_comment,
            doc_comment: fn_.doc_comment,
            span: fn_.span,
            body_span: fn_.body_span
        )

fn functionoutline_as_method(fn_: FunctionOutline) -> FunctionOutline:
        functionoutline_with_flags(fn_, fn_.is_async, fn_.is_static, true, fn_.is_const, fn_.is_kernel)

fn functionoutline_as_static(fn_: FunctionOutline) -> FunctionOutline:
        functionoutline_with_flags(fn_, fn_.is_async, true, fn_.is_method, fn_.is_const, fn_.is_kernel)

fn functionoutline_as_async(fn_: FunctionOutline) -> FunctionOutline:
        functionoutline_with_flags(fn_, true, fn_.is_static, fn_.is_method, fn_.is_const, fn_.is_kernel)

fn functionoutline_as_const(fn_: FunctionOutline) -> FunctionOutline:
        functionoutline_with_flags(fn_, fn_.is_async, fn_.is_static, fn_.is_method, true, fn_.is_kernel)

fn functionoutline_as_kernel(fn_: FunctionOutline) -> FunctionOutline:
        functionoutline_with_flags(fn_, fn_.is_async, fn_.is_static, fn_.is_method, fn_.is_const, true)

me treesitter_parse_visibility(self: TreeSitter) -> Visibility:
        """Parse optional visibility modifier."""
        if self.match_token(TokenKind.KwPub):
            if self.check(TokenKind.LParen):
                self.advance()  # consume '('
                val mod_text = self.parse_identifier()
                self.expect(TokenKind.RParen, "expected ')' after visibility modifier")
                if mod_text == "peer":
                    return Visibility.Peer
                elif mod_text == "up":
                    return Visibility.Up
                elif mod_text == "friend":
                    return Visibility.Internal
                elif mod_text == "package":
                    return Visibility.Package
                else:
                    self.warning("unknown visibility modifier '" + mod_text + "', using public")
                    return Visibility.Public
            return Visibility.Public
        elif self.match_token(TokenKind.KwPri):
            return Visibility.Private
        Visibility.Private

# ============================================================================
# Function Parsing
# ============================================================================

me treesitter_parse_function_outline(self: TreeSitter, visibility: Visibility, is_mutable: bool, doc: text?) -> FunctionOutline:
        """Parse function signature, skipping body."""
        val start = self.current.span
        self.advance()  # Consume 'fn' or 'me'

        val name = self.parse_identifier()
        var type_params: [TypeParamOutline] = []

        # Generic parameters
        if self.match_token(TokenKind.Lt):
            type_params = self.parse_type_params()
            self.expect(TokenKind.Gt, "expected '>' after type parameters")

        # Parameters
        self.expect(TokenKind.LParen, "expected '(' after function name")
        val params = self.parse_params()
        self.expect(TokenKind.RParen, "expected ')' after parameters")

        # Return type
        var return_type: TypeOutline = nil
        if self.match_token(TokenKind.Arrow):
            return_type = self.parse_type_outline()

        # Body
        self.expect(TokenKind.Colon, "expected ':' before function body")
        self.skip_newlines()

        # Set context for block tracking
        val prev_context = self.current_context
        self.current_context = name

        val body_start = self.current.span.start
        self.skip_block()
        val body_end = self.previous.span.end_pos

        # Restore previous context
        self.current_context = prev_context

        FunctionOutline(
            name: name,
            params: params,
            return_type: return_type,
            visibility: visibility,
            is_async: false,
            is_static: false,
            is_public: visibility == Visibility.Public,
            is_method: false,
            is_mutable: is_mutable,
            is_const: false,
            is_kernel: false,
            is_extern: false,
            doc_comment: doc,
            span: merge_spans(start, self.previous.span),
            body_span: span_new(body_start, body_end, 0, 0)
        )


me treesitter_parse_extern_function_outline(self: TreeSitter, visibility: Visibility, doc: text?) -> FunctionOutline:
        """Parse extern function signature (no body)."""
        val start = self.current.span
        self.advance()  # Consume 'fn'

        val name = self.parse_identifier()

        # Parameters
        self.expect(TokenKind.LParen, "expected '(' after function name")
        val params = self.parse_params()
        self.expect(TokenKind.RParen, "expected ')' after parameters")

        # Return type
        var return_type: TypeOutline = nil
        if self.match_token(TokenKind.Arrow):
            return_type = self.parse_type_outline()

        # Skip optional newline
        self.skip_newlines()

        FunctionOutline(
            name: name,
            params: params,
            return_type: return_type,
            visibility: visibility,
            is_async: false,
            is_static: false,
            is_public: visibility == Visibility.Public,
            is_method: false,
            is_mutable: false,
            is_const: false,
            is_kernel: false,
            is_extern: true,
            doc_comment: doc,
            span: merge_spans(start, self.previous.span),
            body_span: span_new(0, 0, 0, 0)
        )


# ============================================================================
# Parameter Parsing
# ============================================================================

me treesitter_parse_param(self: TreeSitter) -> ParamOutline:
        """Parse a single parameter."""
        val start = self.current.span
        val name = self.parse_identifier()

        var type_: TypeOutline = nil
        if self.match_token(TokenKind.Colon):
            type_ = self.parse_type_outline()

        var default_span: Span = nil
        if self.match_token(TokenKind.Assign):
            val default_start = self.current.span.start
            self.skip_expression()
            default_span = span_new(default_start, self.previous.span.end_pos, 0, 0)

        ParamOutline(
            name: name,
            type_: type_,
            default_span: default_span,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_type_param(self: TreeSitter) -> TypeParamOutline:
        """Parse a single type parameter."""
        val start = self.current.span
        val name = self.parse_identifier()

        var bounds: [TypeOutline] = []
        if self.match_token(TokenKind.Colon):
            bounds = bounds_push(bounds, self.parse_type_outline())
            while self.match_token(TokenKind.Plus):
                bounds = bounds_push(bounds, self.parse_type_outline())

        var default: TypeOutline = nil
        if self.match_token(TokenKind.Assign):
            default = self.parse_type_outline()

        TypeParamOutline(
            name: name,
            bounds: bounds,
            default: default,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_params(self: TreeSitter) -> [ParamOutline]:
        var params: [ParamOutline] = []
        if self.check(TokenKind.RParen):
            return params

        params = params.push(self.parse_param())
        while self.match_token(TokenKind.Comma):
            if self.check(TokenKind.RParen):
                break
            params = params.push(self.parse_param())
        params


me treesitter_parse_type_params(self: TreeSitter) -> [TypeParamOutline]:
        var type_params: [TypeParamOutline] = []
        if self.check(TokenKind.Gt):
            return type_params

        type_params = type_params.push(self.parse_type_param())
        while self.match_token(TokenKind.Comma):
            if self.check(TokenKind.Gt):
                break
            type_params = type_params.push(self.parse_type_param())
        type_params


me treesitter_parse_optional_type_params(self: TreeSitter) -> [TypeParamOutline]:
        """Parse optional type parameters if present.

        Handles the common pattern:
            var type_params: [TypeParamOutline] = []
            if self.match_token(TokenKind.Lt):
                type_params = self.parse_type_params()
                self.expect(TokenKind.Gt, ...)

        Returns:
            List of type parameters (empty if none present)
        """
        var type_params: [TypeParamOutline] = []
        if self.match_token(TokenKind.Lt):
            type_params = self.parse_type_params()
            self.expect(TokenKind.Gt, "expected '>' after type parameters")
        type_params


# ============================================================================
# Class / Actor Parsing
# ============================================================================

me treesitter_parse_class_outline(self: TreeSitter, visibility: Visibility, doc: text, attrs: [AttributeOutline]) -> ClassOutline:
        """Parse class outline."""
        val start = self.current.span
        self.advance()  # Consume 'class'

        val name = self.parse_identifier()
        val type_params = self.parse_optional_type_params()

        self.expect(TokenKind.Colon, "expected ':' after class name")
        self.skip_newlines()
        self.expect(TokenKind.Indent, "expected indented class body")

        # Try to parse body docstring (triple-quoted string after indent)
        val body_doc = self.try_parse_body_docstring()
        # Use body docstring if no doc was passed, or prefer body doc
        val final_doc = body_doc ?? doc

        var fields: [FieldOutline] = []
        var methods: [FunctionOutline] = []

        while not self.check(TokenKind.Dedent) and not self.is_at_end():
            self.skip_newlines()
            if self.check(TokenKind.Dedent):
                break

            val member_doc = self.take_doc_comment()
            val member_visibility = self.parse_visibility()

            match self.peek():
                case KwFn:
                    val m = self.parse_function_outline(member_visibility, false, member_doc)
                    methods = methods_push(methods, functionoutline_as_method(m))
                case KwMe:
                    val m = self.parse_function_outline(member_visibility, true, member_doc)
                    methods = methods_push(methods, functionoutline_as_method(m))
                case KwVar:
                    # Check for deprecated 'var fn' syntax
                    self.advance()  # consume 'var'
                    if self.check(TokenKind.KwFn):
                        self.warning("Deprecated: Replace `var fn method()` with `me method()`")
                        val m = self.parse_function_outline(member_visibility, true, member_doc)
                        methods = methods_push(methods, functionoutline_as_method(m))
                    else:
                        self.error("expected field or method in class")
                        self.synchronize()
                case KwStatic:
                    self.advance()
                    val m = self.parse_function_outline(member_visibility, false, member_doc)
                    methods = methods_push(methods, functionoutline_as_static(m))
                case Ident:
                    fields = fields_push(fields, self.parse_field_outline(member_visibility))
                case _:
                    self.error("expected field or method in class")
                    self.synchronize()

        self.match_token(TokenKind.Dedent)

        ClassOutline(
            name: name,
            type_params: type_params,
            fields: fields,
            methods: methods,
            visibility: visibility,
            is_public: visibility == Visibility.Public,
            doc_comment: final_doc,
            attributes: attrs,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_actor_outline(self: TreeSitter, visibility: Visibility, doc: text, attrs: [AttributeOutline]) -> ActorOutline:
        """Parse actor outline (same structure as class)."""
        val start = self.current.span
        self.advance()  # Consume 'actor'

        val name = self.parse_identifier()
        val type_params = self.parse_optional_type_params()

        self.expect(TokenKind.Colon, "expected ':' after actor name")
        self.skip_newlines()
        self.expect(TokenKind.Indent, "expected indented actor body")

        # Try to parse body docstring
        val body_doc = self.try_parse_body_docstring()
        val final_doc = body_doc ?? doc

        var fields: [FieldOutline] = []
        var methods: [FunctionOutline] = []

        while not self.check(TokenKind.Dedent) and not self.is_at_end():
            self.skip_newlines()
            if self.check(TokenKind.Dedent):
                break

            val member_doc = self.take_doc_comment()
            val member_visibility = self.parse_visibility()

            match self.peek():
                case KwFn:
                    val m = self.parse_function_outline(member_visibility, false, member_doc)
                    methods = methods_push(methods, functionoutline_as_method(m))
                case KwMe:
                    val m = self.parse_function_outline(member_visibility, true, member_doc)
                    methods = methods_push(methods, functionoutline_as_method(m))
                case KwVar:
                    # Check for deprecated 'var fn' syntax
                    self.advance()  # consume 'var'
                    if self.check(TokenKind.KwFn):
                        self.warning("Deprecated: Replace `var fn method()` with `me method()`")
                        val m = self.parse_function_outline(member_visibility, true, member_doc)
                        methods = methods_push(methods, functionoutline_as_method(m))
                    else:
                        self.error("expected field or method in actor")
                        self.synchronize()
                case KwStatic:
                    self.advance()
                    val m = self.parse_function_outline(member_visibility, false, member_doc)
                    methods = methods_push(methods, functionoutline_as_static(m))
                case Ident:
                    fields = fields_push(fields, self.parse_field_outline(member_visibility))
                case _:
                    self.error("expected field or method in actor")
                    self.synchronize()

        self.match_token(TokenKind.Dedent)

        ActorOutline(
            name: name,
            type_params: type_params,
            fields: fields,
            methods: methods,
            visibility: visibility,
            is_public: visibility == Visibility.Public,
            doc_comment: final_doc,
            attributes: attrs,
            span: merge_spans(start, self.previous.span)
        )


# ============================================================================
# Struct Parsing
# ============================================================================

me treesitter_parse_struct_outline(self: TreeSitter, visibility: Visibility, doc: text, attrs: [AttributeOutline]) -> StructOutline:
        """Parse struct outline."""
        val start = self.current.span
        self.advance()  # Consume 'struct'

        val name = self.parse_identifier()
        val type_params = self.parse_optional_type_params()

        self.expect(TokenKind.Colon, "expected ':' after struct name")
        self.skip_newlines()
        self.expect(TokenKind.Indent, "expected indented struct body")

        # Try to parse body docstring (triple-quoted string after indent)
        val body_doc = self.try_parse_body_docstring()
        val final_doc = body_doc ?? doc

        var fields: [FieldOutline] = []

        while not self.check(TokenKind.Dedent) and not self.is_at_end():
            self.skip_newlines()
            if self.check(TokenKind.Dedent):
                break

            val field_visibility = self.parse_visibility()

            if self.check(TokenKind.Ident):
                fields = fields_push(fields, self.parse_field_outline(field_visibility))
            else:
                self.error("expected field in struct")
                self.synchronize()

        self.match_token(TokenKind.Dedent)

        StructOutline(
            name: name,
            type_params: type_params,
            fields: fields,
            visibility: visibility,
            is_public: visibility == Visibility.Public,
            doc_comment: final_doc,
            attributes: attrs,
            span: merge_spans(start, self.previous.span)
        )


me treesitter_parse_field_outline(self: TreeSitter, visibility: Visibility) -> FieldOutline:
        """Parse a field definition.

        Supports:
        - name: Type
        - name: Type = default
        - @volatile name: Type
        - name: Type @bits(N)
        - name: Type @ 0x40020000  (memory-mapped)
        """
        val start = self.current.span

        # Check for @volatile attribute before field name
        var is_volatile = false
        if self.check(TokenKind.At):
            self.advance()  # consume '@'
            if self.check(TokenKind.Ident):
                if self.current.text == "volatile":
                    self.advance()  # consume 'volatile'
                    is_volatile = true
            else:
                # Not @volatile, unexpected - rewind not possible, continue
                self.error("expected 'volatile' after '@' in field")

        val name = self.parse_identifier()

        self.expect(TokenKind.Colon, "expected ':' after field name")
        val type_ = self.parse_type_outline()

        var bits: i64 = nil

        # Check for trailing @bits(N) attribute after the field type.
        var saw_address_marker = false
        if self.check(TokenKind.At):
            self.advance()  # consume '@'
            if self.check(TokenKind.Ident) and self.current.text == "bits":
                self.advance()  # consume 'bits'
                self.expect(TokenKind.LParen, "expected '(' after @bits")
                if self.check(TokenKind.IntLit):
                    bits = self.parse_int_literal()
                self.expect(TokenKind.RParen, "expected ')' after bit count")
            else:
                saw_address_marker = true

        # Check for @ address syntax: field: Type @ 0x40020000
        var address_span: Span = nil
        if saw_address_marker or self.check(TokenKind.At):
            if not saw_address_marker:
                self.advance()  # consume '@'
            val addr_start = self.current.span.start
            self.skip_expression()  # Skip the address expression
            address_span = span_new(addr_start, self.previous.span.end_pos, 0, 0)

        var default_span: Span = nil
        if self.match_token(TokenKind.Assign):
            val default_start = self.current.span.start
            self.skip_expression()
            default_span = span_new(default_start, self.previous.span.end_pos, 0, 0)

        self.skip_newlines()

        FieldOutline(
            name: name,
            type_: type_,
            visibility: visibility,
            is_public: visibility == Visibility.Public,
            is_volatile: is_volatile,
            bits: bits,
            address_span: address_span,
            default_span: default_span,
            span: merge_spans(start, self.previous.span)
        )


# ============================================================================
# Exports
# ============================================================================
