#!/usr/bin/env simple
use compiler.tools.duplicate_check.features.{build_feature_vector}

fn main():
    print "Test: features.spl build_feature_vector..."
    var freq = {}
    freq["hello"] = 2
    freq["world"] = 1
    val fv = build_feature_vector(0, freq)
    print "  features keys: {fv.features.keys().len()}"
    print "  magnitude: {fv.magnitude}"
    print "Passed!"
