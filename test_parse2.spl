extern fn rt_file_read_text(path: text) -> text

fn s_strip(s: text) -> text:
    s.strip()

fn s_split(s: text, d: text) -> [text]:
    s.split(d)

fn s_starts(s: text, p: text) -> bool:
    s.starts_with(p)

fn s_len(s: text) -> i64:
    s.len()

fn s_find(s: text, n: text) -> i64:
    val idx = s.index_of(n)
    match idx:
        case Some(i):
            return i
        case _:
            return -1

fn unwrap_opt(v: any) -> any:
    match v:
        case Some(s):
            return s
        case _:
            return v

fn main():
    val raw = rt_file_read_text("examples/ui/demo.ui.sdn")
    val source = unwrap_opt(raw)
    val lines = s_split(source, "\n")
    var result: Dict<text, text> = {}
    var count = 0

    for line in lines:
        val stripped = s_strip(line)
        if stripped == "":
            continue
        if s_starts(stripped, "#"):
            continue
        val cp = s_find(stripped, ":")
        if cp < 0:
            continue
        val key = s_strip(stripped[0:cp])
        val sl = s_len(stripped)
        var after = ""
        if cp + 1 < sl:
            after = s_strip(stripped[cp + 1:])
        if after != "" and after != "|":
            result[key] = after
            count = count + 1
            if count <= 5:
                print "  {key} = {after}"
    print "Total leaf values: {count}"
    print "Dict size: {result.len()}"
