use std.spec.{describe, it, expect}

describe "shared WM renderer unification documentation contract":
    it "names the concrete shared web render API files":
        val api_file = "src/lib/common/ui/web_render_api.spl"
        val web_backend = "src/app/ui.web/backend.spl"
        val electron_backend = "src/app/ui.electron/backend.spl"
        val tauri_backend = "src/app/ui.tauri/backend.spl"

        expect(api_file).to_end_with("web_render_api.spl")
        expect(web_backend).to_contain("ui.web")
        expect(electron_backend).to_contain("ui.electron")
        expect(tauri_backend).to_contain("ui.tauri")

    it "documents the canonical Engine2D backend files":
        val trait_file = "src/lib/gc_async_mut/gpu/engine2d/backend.spl"
        val cpu_file = "src/lib/gc_async_mut/gpu/engine2d/backend_cpu.spl"
        val metal_file = "src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl"
        val cuda_file = "src/lib/gc_async_mut/gpu/engine2d/backend_cuda.spl"

        expect(trait_file).to_end_with("backend.spl")
        expect(cpu_file).to_contain("backend_cpu")
        expect(metal_file).to_contain("backend_metal")
        expect(cuda_file).to_contain("backend_cuda")

    it "keeps Qt baseline unavailable as a non blocking state":
        val qt_status = "optional_baseline_unavailable"
        val report_path = "doc/09_report/qt_gui_size_baseline_2026-05-29.md"

        expect(qt_status).to_contain("unavailable")
        expect(report_path).to_end_with(".md")
