# @tag:design

use std.spec.*

describe "x86 dual-arch qemu boot":

    describe "REQ-001 explicit x86 lanes":
        it "should define separate x86_32 and x86_64 lane ownership":
            expect(true).to_equal(true)

    describe "REQ-004 explicit QEMU tuples":
        it "should bind x86_32 to qemu-system-i386 and qemu32":
            expect("qemu-system-i386").to_start_with("qemu-system")

        it "should bind x86_64 to qemu-system-x86_64 and qemu64":
            expect("qemu-system-x86_64").to_start_with("qemu-system")

    describe "REQ-006 no false equivalence":
        it "should not let x86_32 validation stand in for x86_64 validation":
            expect("x86_32" == "x86_64").to_equal(false)

    describe "NFR-001 deterministic markers":
        it "should require lane-specific serial markers":
            expect("[x86_32]").to_start_with("[")
            expect("[x86_64]").to_start_with("[")
