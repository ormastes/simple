# System-spec skeleton for x86_64 desktop driver completion.

use std.spec.{describe, it, expect}
use os.drivers.desktop_driver_summary.{
    desktop_driver_summary_accepts_complete_qemu,
    desktop_driver_summary_for_qemu_direct,
    desktop_driver_summary_for_uefi_qemu,
    desktop_driver_summary_text
}

describe "x86_64 desktop driver completion marker contract":
    it "accepts the complete QEMU desktop driver summary":
        val complete = desktop_driver_summary_for_uefi_qemu(
            true,
            5,
            "nvme",
            "virtio-gpu",
            "virtio-gpu",
            true,
            "virtio-net"
        )
        val summary = desktop_driver_summary_text(complete) + "\n[desktop-e2e] process-backed:ok app=browser_demo pid=1\n"
        expect(desktop_driver_summary_accepts_complete_qemu(summary)).to_equal(true)

    it "rejects resident process fallback as incomplete":
        val complete = desktop_driver_summary_for_uefi_qemu(true, 5, "nvme", "bga", "framebuffer", false, "virtio-net")
        val summary = desktop_driver_summary_text(complete) + "\n" +
            "[desktop-e2e] process-backed:resident app=browser_demo pid=10737\n"
        expect(desktop_driver_summary_accepts_complete_qemu(summary)).to_equal(false)

    it "rejects false VGA acceleration claims":
        val complete = desktop_driver_summary_for_uefi_qemu(true, 5, "nvme", "vga", "vga", true, "virtio-net")
        val summary = desktop_driver_summary_text(complete)
        expect(desktop_driver_summary_accepts_complete_qemu(summary)).to_equal(false)

    it "does not treat the current direct QEMU lane as UEFI-complete":
        val direct = desktop_driver_summary_for_qemu_direct(true)
        val summary = desktop_driver_summary_text(direct)
        expect(summary.contains("boot=qemu-direct")).to_equal(true)
        expect(summary.contains("storage=nvme")).to_equal(true)
        expect(desktop_driver_summary_accepts_complete_qemu(summary)).to_equal(false)
