# System-spec skeleton for x86_64 desktop driver completion.
#
# This pins the expected marker contract before implementation fills the
# summary emitters.

use std.spec.{describe, it, expect}

fn driver_summary_accepts_complete_qemu(summary: text) -> bool:
    summary.contains("[driver-summary] platform=x86_64 boot=uefi") and
        summary.contains("acpi=madt-ok") and
        summary.contains("storage=") and
        summary.contains("display=") and
        summary.contains("input=ps2") and
        summary.contains("network=virtio-net") and
        not summary.contains("process-backed:resident") and
        not summary.contains("process-backed:unknown") and
        not summary.contains("hidden_copy=true") and
        not summary.contains("accelerated=true driver=vga")

describe "x86_64 desktop driver completion marker contract":
    it "accepts the complete QEMU desktop driver summary":
        val summary = "[driver-summary] platform=x86_64 boot=uefi acpi=madt-ok pci_devices=5 interrupt_mode=polling\n" +
            "[driver-summary] storage=nvme dma=shared hidden_copy=false\n" +
            "[driver-summary] display=framebuffer accelerated=false\n" +
            "[driver-summary] input=ps2\n" +
            "[driver-summary] network=virtio-net\n" +
            "[desktop-e2e] process-backed:ok app=browser_demo pid=1\n"
        expect(driver_summary_accepts_complete_qemu(summary)).to_equal(true)

    it "rejects resident process fallback as incomplete":
        val summary = "[driver-summary] platform=x86_64 boot=uefi acpi=madt-ok storage=nvme display=framebuffer input=ps2 network=virtio-net\n" +
            "[desktop-e2e] process-backed:resident app=browser_demo pid=10737\n"
        expect(driver_summary_accepts_complete_qemu(summary)).to_equal(false)

    it "rejects false VGA acceleration claims":
        val summary = "[driver-summary] platform=x86_64 boot=uefi acpi=madt-ok storage=nvme display=vga accelerated=true driver=vga input=ps2 network=virtio-net\n"
        expect(driver_summary_accepts_complete_qemu(summary)).to_equal(false)

