# System spec for executable size reduction.

describe "executable size reduction":
    describe "REQ-001 through REQ-004: native runtime archive retention":
        it "uses explicit runtime roots instead of default ELF whole-archive linking":
            val link_mode = "explicit-runtime-roots"
            expect link_mode == "explicit-runtime-roots"

        it "keeps a diagnostic fallback for legacy runtime whole-archive linking":
            val fallback_env = "SIMPLE_NATIVE_FORCE_WHOLE_ARCHIVE"
            expect fallback_env == "SIMPLE_NATIVE_FORCE_WHOLE_ARCHIVE"

    describe "REQ-005 and REQ-006: release size guardrails":
        it "strips packaged native MCP binaries":
            val package_flag = "--strip"
            expect package_flag == "--strip"

        it "checks release executable and runtime archive budgets":
            val script = "scripts/check-executable-size-budgets.shs"
            expect (script).ends_with("check-executable-size-budgets.shs")

    describe "REQ-007 through REQ-010: loader dependency closure":
        it "owns the runtime symbol ABI in a dedicated crate":
            val abi_crate = "simple-runtime-abi"
            expect abi_crate == "simple-runtime-abi"

        it "audits loader dependency closure with a dedicated script":
            val script = "scripts/check-loader-dependency-closure.shs"
            expect (script).ends_with("check-loader-dependency-closure.shs")

        it "keeps simple-native-loader off simple-runtime normal deps":
            val runtime_edge = "simple-native-loader -> simple-runtime"
            expect (runtime_edge).contains("simple-runtime")

    describe "REQ-011 through REQ-014: native binary dependency audit":
        it "audits native binary dependency closure with a dedicated script":
            val script = "scripts/check-native-binary-dependency-closure.shs"
            expect (script).ends_with("check-native-binary-dependency-closure.shs")

        it "tracks the CLI root through simple-driver":
            val cli_root = "simple-driver"
            expect cli_root == "simple-driver"

        it "surfaces simple-native-all overreach into simple-driver":
            val edge = "simple-native-all -> simple-driver"
            expect (edge).contains("simple-driver")

        it "keeps stale external jj crate deps out of simple-driver":
            val forbidden = "jj-lib,jj-cli"
            expect (forbidden).contains("jj-lib")