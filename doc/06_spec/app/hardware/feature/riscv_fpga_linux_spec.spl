"""
# RISC-V FPGA Linux System Specification

Executable requirement trace for the dual-arch orchestration layer.
"""

import std.spec

use hardware.fpga_linux.riscv_fpga_linux.{RiscvReadinessStatus, XilinxBoardProfile, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest, create_default_riscv_fpga_linux_manifest_with_experimental_rv32_linux, create_riscv_fpga_linux_manifest_for_board, generate_default_riscv_fpga_rtl_bundle, generate_default_riscv_fpga_rtl_bundle_with_experimental_rv32_linux, generate_riscv_fpga_rtl_bundle_for_board, known_riscv_fpga_board_ids, read_generated_riscv_fpga_rtl_file}

describe "REQ-RFL-001..003: board and lane contracts":
    it "keeps board validation separate from hardware boot validation":
        val profile = XilinxBoardProfile.generic()
        expect(profile.validate_for_prepare().len()).to_equal(0)
        expect(profile.validate_for_hardware_boot()).to_contain("xilinx part must be selected before hardware boot")

    it "supports named board profiles for future multi-board growth":
        expect(known_riscv_fpga_board_ids()).to_contain("xilinx_generic")
        expect(known_riscv_fpga_board_ids()).to_contain("mlk_s02_100t")
        val mlk = XilinxBoardProfile.from_id("mlk_s02_100t").ok().unwrap()
        expect(mlk.part).to_equal("xc7a100t-2ffg484i")
        expect(mlk.clock_hz).to_equal(25000000)
        expect(mlk.constraints_path).to_equal("examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc")

    it "defines RV32 as generated baremetal and RV64 as generated Linux":
        val rv64 = RiscvFpgaLane.rv64_default()
        val rv32 = RiscvFpgaLane.rv32_default()
        expect(rv64.readiness_status()).to_equal(RiscvReadinessStatus.Contract)
        expect(rv64.platform_profile.name).to_equal("qemu_virt_rv64")
        expect(rv32.platform_profile.name).to_equal("qemu_virt_rv32")
        expect(rv32.xlen.linux_policy()).to_equal("repo-native-rv32-baremetal")
        expect(rv64.xlen.linux_policy()).to_equal("repo-native-rv64-linux")

    it "keeps RV32 Linux as an explicit experimental lane rather than repurposing the default RV32 proof lane":
        val lane = RiscvFpgaLane.rv32_linux_experimental()
        expect(lane.proof_lane().to_text()).to_equal("generated_rv32_linux")
        expect(lane.bundle_root_name()).to_equal("rv32_linux")
        expect(lane.linux_policy()).to_equal("experimental-generated-rv32-linux")
        expect(lane.scope_note).to_contain("experimental")

describe "REQ-RFL-004..006: deterministic dual-arch orchestration":
    it "creates a deterministic dual-arch default manifest with stable rtl directories":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect(manifest.lanes.len()).to_equal(2)
        expect(manifest.readiness_summary()).to_contain("rv32:contract:qemu_virt_rv32:simple_rv32gc_core")
        expect(manifest.readiness_summary()).to_contain("rv64:contract:qemu_virt_rv64:simple_rv64gc_core")
        expect(manifest.vivado_tcl_plan()).to_contain("add_files build/fpga/rv32/rtl")
        expect(manifest.vivado_tcl_plan()).to_contain("add_files build/fpga/rv64/rtl")

    it "creates board-specific manifests without changing lane structure":
        val manifest = create_riscv_fpga_linux_manifest_for_board("mlk_s02_100t").ok().unwrap()
        expect(manifest.board.name).to_equal("mlk_s02_100t")
        expect(manifest.board.part).to_equal("xc7a100t-2ffg484i")
        expect(manifest.vivado_project_dir).to_equal("build/fpga/mlk_s02_100t/vivado")
        expect(manifest.generated_dir).to_equal("build/fpga/mlk_s02_100t/generated")
        expect(manifest.vivado_tcl_plan()).to_contain("examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc")

    it "adds the experimental RV32 Linux bundle path only when explicitly requested":
        val manifest = create_default_riscv_fpga_linux_manifest_with_experimental_rv32_linux()
        val default_manifest = create_default_riscv_fpga_linux_manifest()
        expect(default_manifest.lanes.len()).to_equal(2)
        expect(manifest.lanes.len()).to_equal(3)
        val text = manifest.rtl_manifest_text("/tmp/simple_riscv_fpga_system_spec_exp")
        expect(text).to_contain("bundle_dir = \"rv32_linux\"")
        expect(text).to_contain("proof_lane = \"generated_rv32_linux\"")
        expect(text).to_contain("authoritative = \"false\"")
        expect(text).to_contain("runner_testbench = \"/tmp/simple_riscv_fpga_system_spec_exp/rv32_linux/rtl/tb_generated_rv32_linux_handoff.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/simple_riscv_fpga_system_spec_exp/rv32_linux/rtl/tb_generated_rv32_boot_info_real_dtb.vhd\"")

    it "emits manifest metadata derived from the shared platform profiles":
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_riscv_fpga_system_spec")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.ok().unwrap()
        expect(bundle.generated_files.len()).to_equal(10)
        val rv64_core = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_system_spec/rv64/rtl/simple_rv64gc_core.vhd")
        val rv64_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_system_spec/rv64/rtl/simple_rv64gc_core.spl")
        val manifest_text = read_generated_riscv_fpga_rtl_file(bundle.manifest_path)
        val vivado_plan_text = read_generated_riscv_fpga_rtl_file(bundle.vivado_plan_path)
        val board_interface_text = read_generated_riscv_fpga_rtl_file(bundle.board_interface_contract_path)
        val bundle_readme_text = read_generated_riscv_fpga_rtl_file(bundle.bundle_readme_path)
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_i_immediate")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_upper_immediate")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_execute_datapath")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_branch_datapath")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_control_flow_datapath")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_memory_access_control")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_dispatch_class")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_trap_halt_control")
        expect(rv64_source).to_contain("bitfield RiscvDispatchClass(u32):")
        expect(rv64_source).to_contain("bitfield RiscvTrapHaltControl(u32):")
        expect(rv64_source).to_contain("if addr_i(0) = '1' then")
        expect(rv64_source).to_contain("if addr_i(1 downto 0) /= \"00\" then")
        expect(rv64_source).to_contain("if addr_i(2 downto 0) /= \"000\" then")
        expect(rv64_source).to_contain("bitfield RiscvExecuteDatapath(u32):")
        expect(rv64_source).to_contain("bitfield RiscvExecuteDatapathEncoding(u32):")
        expect(rv64_source).to_contain("bitfield RiscvBranchDatapath(u32):")
        expect(rv64_source).to_contain("bitfield RiscvBranchDatapathEncoding(u32):")
        expect(rv64_source).to_contain("bitfield RiscvControlFlowDatapath(u32):")
        expect(rv64_source).to_contain("bitfield RiscvControlFlowDatapathEncoding(u32):")
        expect(rv64_core).to_contain("-- readiness: contract linux-boot-validated=false")
        expect(rv64_core).to_contain("dmem_re       : out std_logic;")
        expect(rv64_core).to_contain("dmem_width    : out std_logic_vector(1 downto 0);")
        expect(rv64_core).to_contain("dmem_wstrb    : out std_logic_vector((XLEN / 8) - 1 downto 0);")
        expect(rv64_core).to_contain("dmem_re <= dmem_re_reg;")
        expect(rv64_core).to_contain("dmem_width <= dmem_width_reg;")
        expect(rv64_core).to_contain("dmem_wstrb <= dmem_wstrb_reg;")
        expect(rv64_core).to_contain("dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect(rv64_core).to_contain("shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8)")
        expect(rv64_core).to_contain("-- source-map: RiscvIImmediateEncoding.value => imem_rdata(31 downto 20)")
        expect(rv64_core).to_contain("-- source-map: RiscvUpperImmediateEncoding.high20 => imem_rdata(31 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteDatapathEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteDatapathEncoding.bit30 => imem_rdata(30 downto 30)")
        expect(rv64_core).to_contain("-- source-map: RiscvBranchDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvBranchDatapathEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvControlFlowDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvMemoryAccessControlEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvDispatchClassEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvTrapHaltControlEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("decode_execute_alu_op := decode_execute_datapath_bits(4 downto 1);")
        expect(rv64_core).to_contain("decode_branch_op := decode_branch_datapath_bits(2 downto 0);")
        expect(rv64_core).to_contain("decode_next_pc_op := decode_control_flow_datapath_bits(1 downto 0);")
        expect(rv64_core).to_contain("decode_dispatch_class := decode_dispatch_class_bits(3 downto 0);")
        expect(rv64_core).to_contain("decode_should_halt := decode_trap_halt_control_bits(2);")
        expect(rv64_core).to_contain("case decode_dispatch_class is")
        val has_handwritten_funct3_case = rv64_core.contains("case decode_funct3 is")
        expect(has_handwritten_funct3_case).to_equal(false)
        val has_handwritten_opcode_case = rv64_core.contains("case imem_rdata(6 downto 0) is")
        expect(has_handwritten_opcode_case).to_equal(false)
        expect(manifest_text).to_contain("platform = \"qemu_virt_rv32\"")
        expect(manifest_text).to_contain("platform = \"qemu_virt_rv64\"")
        expect(manifest_text).to_contain("authoritative_rtl_root = \"/tmp/simple_riscv_fpga_system_spec/rv32/rtl\"")
        expect(manifest_text).to_contain("authoritative_rtl_root = \"/tmp/simple_riscv_fpga_system_spec/rv64/rtl\"")
        expect(manifest_text).to_contain("board_id = \"xilinx_generic\"")
        expect(manifest_text).to_contain("constraints_path = \"constraints/xilinx_generic.xdc\"")
        expect(manifest_text).to_contain("programmer = \"hw_server\"")
        expect(manifest_text).to_contain("scope = \"repo-native RV32GC generated-core baremetal lane\"")
        expect(manifest_text).to_contain("linux_policy = \"repo-native-rv32-baremetal\"")
        expect(manifest_text).to_contain("abi = \"lp64d\"")
        expect(manifest_text).to_contain("scope = \"repo-native RV64GC generated-core Linux lane\"")
        expect(manifest_text).to_contain("linux_policy = \"repo-native-rv64-linux\"")
        expect(vivado_plan_text).to_contain("create_project simple_riscv_fpga")
        expect(vivado_plan_text).to_contain("add_files constraints/xilinx_generic.xdc")
        expect(board_interface_text).to_contain("board_id = \"xilinx_generic\"")
        expect(board_interface_text).to_contain("clock = \"sys_clk\"")
        expect(board_interface_text).to_contain("led_count = 8")
        expect(bundle_readme_text).to_contain("Board: `xilinx_generic` (`BOARD_PART_TBD`)")
        expect(bundle_readme_text).to_contain("Generated bundle root: `/tmp/simple_riscv_fpga_system_spec`")
        expect(bundle_readme_text).to_contain("logical board I/O contract: `board_interface_contract.sdn`")
        expect(bundle_readme_text).to_contain("This bundle proves source and RTL artifact generation.")
        expect(bundle_readme_text).to_contain("This bundle is the authoritative source for runner-consumed generated-core RTL.")
        expect(bundle_readme_text).to_contain("Generated-core runners must compile RTL only from the emitted `rv32/rtl` and `rv64/rtl` bundle directories.")
        val manifest_uses_handwritten_rtl = manifest_text.contains("examples/09_embedded/fpga_riscv/rtl")
        expect(manifest_uses_handwritten_rtl).to_equal(false)
        val readme_uses_handwritten_rtl = bundle_readme_text.contains("examples/09_embedded/fpga_riscv/rtl")
        expect(readme_uses_handwritten_rtl).to_equal(false)

    it "emits board-specific metadata for mlk_s02_100t bundles":
        val result = generate_riscv_fpga_rtl_bundle_for_board("/tmp/simple_riscv_fpga_system_spec_mlk", "mlk_s02_100t")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.ok().unwrap()
        val manifest_text = read_generated_riscv_fpga_rtl_file(bundle.manifest_path)
        val vivado_plan_text = read_generated_riscv_fpga_rtl_file(bundle.vivado_plan_path)
        val board_interface_text = read_generated_riscv_fpga_rtl_file(bundle.board_interface_contract_path)
        expect(manifest_text).to_contain("board = \"mlk_s02_100t\"")
        expect(manifest_text).to_contain("part = \"xc7a100t-2ffg484i\"")
        expect(manifest_text).to_contain("clock_hz = 25000000")
        expect(manifest_text).to_contain("uart_baud = 115200")
        expect(manifest_text).to_contain("constraints_path = \"examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc\"")
        expect(vivado_plan_text).to_contain("create_project simple_riscv_fpga build/fpga/mlk_s02_100t/vivado -part xc7a100t-2ffg484i")
        expect(vivado_plan_text).to_contain("add_files examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc")
        expect(board_interface_text).to_contain("board_id = \"mlk_s02_100t\"")
        expect(board_interface_text).to_contain("clock = \"clk25\"")
        expect(board_interface_text).to_contain("uart_tx = \"uart_tx\"")
        expect(board_interface_text).to_contain("button_count = 4")

    it "emits experimental RV32 Linux handoff and DTB benches in a separate bundle root":
        val result = generate_default_riscv_fpga_rtl_bundle_with_experimental_rv32_linux("/tmp/simple_riscv_fpga_system_spec_exp")
        expect(result.is_ok()).to_equal(true)
        val manifest_text = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_system_spec_exp/riscv_fpga_rtl_manifest.sdn")
        val rv32_linux_handoff_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_system_spec_exp/rv32_linux/rtl/tb_generated_rv32_linux_handoff.vhd")
        val rv32_linux_real_dtb_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_system_spec_exp/rv32_linux/rtl/tb_generated_rv32_boot_info_real_dtb.vhd")
        expect(rv32_linux_handoff_tb).to_contain("GENERATED_RV32_LINUX_HANDOFF: PASS")
        expect(rv32_linux_real_dtb_tb).to_contain("GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS")
        expect(manifest_text).to_contain("authoritative_rtl_root = \"/tmp/simple_riscv_fpga_system_spec_exp/rv32_linux/rtl\"")
        expect(manifest_text.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
