"""
# RISC-V FPGA Linux System Specification

Executable requirement trace for the pre-hardware FPGA Linux preparation
contract. The implementation-facing copy lives in
test/unit/hardware/fpga_linux/riscv_fpga_linux_spec.spl.
"""

import std.spec

use hardware.fpga_linux.riscv_fpga_linux.{RiscvXlen, XilinxBoardProfile, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest}

describe "REQ-RFL-001..002: Xilinx board profile":
    it "accepts generic Xilinx profile for prepare and rejects it for hardware boot":
        val profile = XilinxBoardProfile.generic()
        expect(profile.validate_for_prepare().len()).to_equal(0)
        expect(profile.validate_for_hardware_boot()).to_contain("xilinx part must be selected before hardware boot")

describe "REQ-RFL-003..005: RV32/RV64 Linux lanes":
    it "defines RV64 as upstream Sv39 and RV32 as experimental Sv32":
        val rv64 = RiscvFpgaLane.rv64_default()
        val rv32 = RiscvFpgaLane.rv32_default()
        expect(rv64.xlen).to_equal(RiscvXlen.Rv64)
        expect(rv64.xlen.linux_policy()).to_equal("upstream")
        expect(rv64.xlen.mmu_mode()).to_equal("sv39")
        expect(rv32.xlen).to_equal(RiscvXlen.Rv32)
        expect(rv32.xlen.linux_policy()).to_equal("experimental")
        expect(rv32.xlen.mmu_mode()).to_equal("sv32")

describe "REQ-RFL-006..007: deterministic pre-hardware Vivado plan":
    it "creates a deterministic prepare manifest without connected hardware":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect(manifest.validate_for_prepare().len()).to_equal(0)
        expect(manifest.vivado_tcl_plan()).to_contain("create_project simple_riscv_fpga")
        expect(manifest.vivado_tcl_plan()).to_contain("add_files build/fpga/rv32/rtl")
        expect(manifest.vivado_tcl_plan()).to_contain("add_files build/fpga/rv64/rtl")
