# codex-system-test

use std.spec.{describe, context, it, expect}

extern fn rt_file_read_text(path: text) -> text

val PLAN_PATH = "doc/03_plan/chrome_modern_web_platform_compat_plan.md"
val TEST_PLAN_PATH = "doc/03_plan/sys_test/chrome_modern_web_platform_compat.md"
val FEATURE_REQ_PATH = "doc/02_requirements/feature/chrome_modern_web_platform_compat.md"
val NFR_REQ_PATH = "doc/02_requirements/nfr/chrome_modern_web_platform_compat.md"
val AUDIT_PATH = "doc/09_report/chrome_modern_web_platform_compat_2026-05-06.md"
val RENDERER_SPEC_PATH = "test/unit/lib/gc_async_mut/gpu/browser_engine/browser_renderer_spec.spl"
val WPT_SUBSET_PLAN_PATH = "doc/03_plan/sys_test/wpt_subset_migration.md"
val WPT_SELECTOR_COLOR_SPEC_PATH = "test/web_platform/css/selector_color_subset_spec.spl"
val STYLE_BLOCK_PATH = "src/lib/gc_async_mut/gpu/browser_engine/style_block.spl"
val BROWSER_RENDERER_PATH = "src/lib/gc_async_mut/gpu/browser_engine/browser_renderer.spl"

fn _read(path: text) -> text:
    rt_file_read_text(path)

describe "Chrome modern web platform compatibility plan":

    context "REQ-001 compatibility matrix":

        it "should require HTML CSS DOM rendering and JavaScript matrix coverage":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("HTML, CSS, DOM/rendering, and JavaScript")
            expect (plan).contains("web_platform_feature_matrix.md")

        it "should require explicit compatibility statuses":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("`supported`, `partial`, `missing`, or `not-applicable`")

        it "should gate migration on first WPT and Test262 subset selection":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("identify the first WPT/Test262 subset to migrate")

    context "REQ-002 WPT subset migration":

        it "should define a repeatable WPT subset import surface":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("tools/wpt_to_sspec/")
            expect (plan).contains("test/web_platform/")

        it "should provide the first executable WPT selector color subset":
            val subset_plan = _read(WPT_SUBSET_PLAN_PATH)
            val subset_spec = _read(WPT_SELECTOR_COLOR_SPEC_PATH)
            expect (subset_plan).contains("selector_color_subset_spec.spl")
            expect (subset_plan).contains("At least 25 selected WPT-shaped cases")
            expect (subset_spec).contains("WPT-derived CSS selector and color subset")
            expect (subset_spec).contains("covers partial :has descendant matching")

        it "should cover selector color parser and rendering basics":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("CSS selectors")
            expect (plan).contains("CSS colors")
            expect (plan).contains("HTML parser basics")
            expect (plan).contains("Rendering basics")

        it "should require at least twenty five WPT derived cases":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("At least 25 selected WPT-derived cases")

    context "REQ-003 Test262 subset migration":

        it "should define a repeatable Test262 subset import surface":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("tools/test262_to_sspec/")
            expect (plan).contains("test/js/test262_subset/")

        it "should classify JavaScript conformance outcomes":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("expected-pass, expected-fail, and unsupported-host")

        it "should require at least fifty stable Test262 derived cases":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("At least 50 selected Test262-derived cases")

    context "REQ-004 supported feature evidence":

        it "should require SSpec or external suite mapping for supported features":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("Every supported feature has SSpec coverage or an explicit external-suite mapping")

        it "should cover modern is selector behavior in renderer SSpec":
            expect (_read(RENDERER_SPEC_PATH)).contains("applies :is selector lists in fallback pixels")

        it "should cover modern where selector behavior in renderer SSpec":
            expect (_read(RENDERER_SPEC_PATH)).contains("applies :where selector lists in fallback pixels")

        it "should cover modern not selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies :not selector lists in fallback pixels")
            expect (spec).contains("rejects :not selectors when an option matches")

        it "should cover partial has selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies :has descendant selectors in fallback pixels")
            expect (spec).contains("rejects :has selectors when no descendant option matches")

        it "should cover partial empty selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies :empty selectors in fallback pixels")
            expect (spec).contains("rejects :empty selectors when the fallback div has content")

        it "should cover partial first child selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies :first-child selectors in fallback pixels")
            expect (spec).contains("rejects :first-child selectors for later fallback divs")

        it "should cover partial last child selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies :last-child selectors in fallback pixels")
            expect (spec).contains("rejects :last-child selectors for earlier fallback divs")

        it "should cover partial only child selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies :only-child selectors in fallback pixels")
            expect (spec).contains("rejects :only-child selectors when a sibling exists")

        it "should cover simple CSS layer block behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies simple rules nested inside CSS layer blocks")
            expect (spec).contains("applies functional selectors nested inside CSS layer blocks")

        it "should cover basic attribute selector behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies attribute presence selectors in fallback pixels")
            expect (spec).contains("applies exact attribute value selectors in fallback pixels")
            expect (spec).contains("rejects exact attribute value selectors with different values")

        it "should cover bounded attribute selector operator behavior in renderer SSpec":
            val spec = _read(RENDERER_SPEC_PATH)
            expect (spec).contains("applies attribute prefix selectors in fallback pixels")
            expect (spec).contains("applies attribute substring selectors in fallback pixels")
            expect (spec).contains("applies attribute whitespace token selectors in fallback pixels")
            expect (spec).contains("applies attribute dash match selectors in fallback pixels")
            expect (spec).contains("rejects attribute dash match selectors without a boundary")
            expect (spec).contains("applies case insensitive attribute selectors in fallback pixels")
            expect (spec).contains("keeps attribute selectors case sensitive without the i flag")
            expect (spec).contains("applies explicit case sensitive attribute selectors in fallback pixels")
            expect (spec).contains("rejects explicit case sensitive attribute selectors with different case")

    context "REQ-005 unsupported feature tracking":

        it "should explicitly reject full Chrome compatibility claims":
            val audit = _read(AUDIT_PATH)
            expect (audit).contains("Simple is not a full Chrome-compatible browser engine")

        it "should require unsupported high value feature tracking":
            val req = _read(FEATURE_REQ_PATH)
            expect (req).contains("Every unsupported high-value feature shall be recorded")

        it "should list broad WPT Test262 HTML and CSS gaps":
            val audit = _read(AUDIT_PATH)
            expect (audit).contains("No complete WPT migration yet")
            expect (audit).contains("No complete Test262 migration yet")
            expect (audit).contains("HTML modern element semantics")
            expect (audit).contains("CSS modern layout systems")

    context "REQ-006 verification gate":

        it "should define PASS WARN and FAIL states":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("STATUS: PASS")
            expect (plan).contains("STATUS: WARN")
            expect (plan).contains("STATUS: FAIL")

        it "should require the broad library check command":
            val plan = _read(PLAN_PATH)
            expect (plan).contains("bin/simple check src/lib")

        it "should reject manual visual inspection as the only signal":
            val req = _read(FEATURE_REQ_PATH)
            val nfr = _read(NFR_REQ_PATH)
            expect (req).contains("without relying on manual visual inspection")
            expect (nfr).contains("shall not depend on manual visual inspection")

    context "REQ-007 initial modern CSS BDD slice":

        it "should implement is and where selector matching in style blocks":
            val source = _read(STYLE_BLOCK_PATH)
            expect (source).contains(":is() and :where()")
            expect (source).contains("functional_selector_list_matches")

        it "should avoid splitting fallback selector lists inside functional pseudos":
            val source = _read(BROWSER_RENDERER_PATH)
            expect (source).contains("paren_depth")
            expect (source).contains("br_functional_selector_contains")

        it "should implement partial not and has selector matching":
            val style_source = _read(STYLE_BLOCK_PATH)
            val renderer_source = _read(BROWSER_RENDERER_PATH)
            expect (style_source).contains("not_selector_list_matches")
            expect (style_source).contains("has_descendant_selector_list_match")
            expect (renderer_source).contains("br_style_block_rule_for_has_descendant")
            expect (renderer_source).contains("br_selector_matches_not_self")
            expect (style_source).contains("node_is_empty")
            expect (renderer_source).contains("br_style_block_rule_for_empty_self")
            expect (style_source).contains(":first-child")
            expect (renderer_source).contains("br_style_block_rule_for_first_child_self")
            expect (style_source).contains(":last-child")
            expect (renderer_source).contains("br_style_block_rule_for_last_child_self")
            expect (style_source).contains(":only-child")
            expect (renderer_source).contains("br_style_block_rule_for_only_child_self")

        it "should flatten simple CSS layer blocks before existing rule scans":
            val style_source = _read(STYLE_BLOCK_PATH)
            val renderer_source = _read(BROWSER_RENDERER_PATH)
            val subset_spec = _read(WPT_SELECTOR_COLOR_SPEC_PATH)
            expect (style_source).contains("flatten_layer_blocks")
            expect (renderer_source).contains("br_flatten_layer_blocks")
            expect (subset_spec).contains("covers simple rules nested inside CSS layer blocks")

        it "should implement basic attribute selector matching":
            val style_source = _read(STYLE_BLOCK_PATH)
            val renderer_source = _read(BROWSER_RENDERER_PATH)
            val subset_spec = _read(WPT_SELECTOR_COLOR_SPEC_PATH)
            expect (style_source).contains("attribute_selector_matches")
            expect (renderer_source).contains("br_style_block_rule_for_attr_self")
            expect (subset_spec).contains("covers attribute presence selector matching")
            expect (subset_spec).contains("covers exact attribute value selector matching")

        it "should implement bounded attribute selector operators":
            val style_source = _read(STYLE_BLOCK_PATH)
            val renderer_source = _read(BROWSER_RENDERER_PATH)
            val subset_spec = _read(WPT_SELECTOR_COLOR_SPEC_PATH)
            expect (style_source).contains("sb_attr_value_matches")
            expect (renderer_source).contains("br_attr_value_matches")
            expect (subset_spec).contains("covers attribute prefix selector matching")
            expect (subset_spec).contains("covers attribute substring selector matching")
            expect (subset_spec).contains("covers attribute whitespace token selector matching")
            expect (subset_spec).contains("covers attribute dash match selector matching")
            expect (style_source).contains("sb_attr_has_i_flag")
            expect (style_source).contains("sb_attr_has_s_flag")
            expect (renderer_source).contains("br_attr_has_i_flag")
            expect (renderer_source).contains("br_attr_has_s_flag")
            expect (subset_spec).contains("covers case insensitive attribute selector matching")
            expect (subset_spec).contains("covers explicit case sensitive attribute selector matching")

        it "should trace the BDD slice through the system test plan":
            val test_plan = _read(TEST_PLAN_PATH)
            expect (test_plan).contains("REQ-007: Initial Modern CSS BDD Slice")
            expect (test_plan).contains("attribute selector/operator, `:empty`, `:first-child`, `:last-child`, and `:only-child` examples should pass")