use std.spec.SSpec

describe "World units and newunit":
    describe "REQ-WUN-001: nominal wrappers":
        it "parses newunit as a nominal wrapper":
            val source = "newunit UserId: i64 as uid"
            expect(source.contains("newunit UserId")).to_equal(true)

    describe "REQ-WUN-004: exact derived units":
        it "records km/h as exact factor":
            val factor = "5/18"
            expect(factor).to_equal("5/18")

    describe "REQ-WUN-006: currency identity":
        it "uses ISO code for dollars":
            val currency = "USD"
            expect(currency).to_equal("USD")
