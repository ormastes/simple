use std.spec.SPipe

describe "Target instruction optimization and 32-bit support":
    describe "REQ-TGT-001: target families":
        it "should classify x86_64 and x86_32 as separate families":
            val x64_family = target_family_from_triple("x86_64-unknown-linux-gnu")
            val x32_family = target_family_from_triple("i686-unknown-linux-gnu")
            expect(x64_family).to_equal("X86_64")
            expect(x32_family).to_equal("X86_32")

        it "should classify rv64 and rv32 as separate families":
            val rv64_family = target_family_from_triple("riscv64gc-unknown-linux-gnu")
            val rv32_family = target_family_from_triple("riscv32imac-unknown-none-elf")
            expect(rv64_family).to_equal("Rv64")
            expect(rv32_family).to_equal("Rv32")

    describe "REQ-TGT-002: unsupported instruction families":
        it "should disable unsupported families by target":
            val matrix = target_enable_matrix("riscv32imac-unknown-none-elf", [])
            val decision = matrix_decision(matrix, "riscv.vector.v")
            expect(decision.enabled).to_equal(false)
            expect(decision.reason).to_contain("missing feature")

    describe "REQ-X86-001: x86_64 32-bit-form legality":
        it "should allow 32-bit forms for proven narrow values":
            val proof = prove_x86_64_narrow_form("u32_add_zero_extended")
            expect(proof.result).to_equal("legal")

        it "should reject 32-bit forms for LP64 pointers":
            val proof = prove_x86_64_narrow_form("lp64_pointer_add")
            expect(proof.result).to_equal("rejected")
            expect(proof.reason).to_contain("pointer")

    describe "REQ-PERF-001: x86_64 optimization non-regression":
        it "should record an optimization-on and optimization-off benchmark result":
            val result = compare_target_optimization_benchmark("x86_64", "integer_loop")
            expect(result.baseline_runs).to_be_greater_than(0)
            expect(result.optimized_runs).to_be_greater_than(0)
