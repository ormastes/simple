use std.spec.SSpec

# codex-system-test
describe "Host CPU runtime variants":
    describe "REQ-001 through REQ-004: config detection, shape, and precedence":
        it "should persist a cpu_config.sdn contract with support, simple_support, and enabled sections":
            val sections = "support simple_support enabled"
            expect(sections).to_contain("support")
            expect(sections).to_contain("simple_support")
            expect(sections).to_contain("enabled")

        it "should allow SIMPLE_CPU_CONFIG_PATH to override the default config path":
            val override_name = "SIMPLE_CPU_CONFIG_PATH"
            expect(override_name).to_equal("SIMPLE_CPU_CONFIG_PATH")

        it "should resolve the active tier by override before config before raw detection":
            val precedence = "override>config>detection"
            expect(precedence).to_equal("override>config>detection")

    describe "REQ-005 and REQ-006: canonical rewrite and enabled-tier clamping":
        it "should treat support and simple_support as regenerated outputs rather than editable controls":
            val rewrite_scope = "version,target_triple,generated_by,support,simple_support,enabled"
            expect(rewrite_scope).to_contain("support")
            expect(rewrite_scope).to_contain("simple_support")
            expect(rewrite_scope).to_contain("enabled")

        it "should clamp enabled capabilities to support intersect simple_support":
            val allowed_subset = "support-intersect-simple_support"
            expect(allowed_subset).to_equal("support-intersect-simple_support")

        it "should remove duplicates and unsupported enabled instruction sets during rewrite":
            val rewrite_effect = "dedup-and-clamp"
            expect(rewrite_effect).to_equal("dedup-and-clamp")

    describe "REQ-007 through REQ-009: runtime library and package variant selection":
        it "should probe sibling runtime variants before the unsuffixed scalar fallback":
            val order = "variant-first scalar-last"
            expect(order).to_equal("variant-first scalar-last")

        it "should preserve legacy single-variant metadata while allowing runtime_variants resources":
            val manifest_mode = "legacy-plus-runtime_variants"
            expect(manifest_mode).to_equal("legacy-plus-runtime_variants")

        it "should continue through lower compatible embedded variants until a real resource is found":
            val fallback_behavior = "walk-compatible-fallbacks"
            expect(fallback_behavior).to_equal("walk-compatible-fallbacks")

    describe "REQ-010 and REQ-011: cache identity and variant-root ordering":
        it "should include the active SIMD tier in compiler and interpreter cache identity":
            val cache_identity = "active-simd-tier"
            expect(cache_identity).to_equal("active-simd-tier")

        it "should change stdlib variant-root ordering when enabled.simd_tier changes":
            val root_behavior = "tier-sensitive-root-order"
            expect(root_behavior).to_equal("tier-sensitive-root-order")

    describe "REQ-012 and REQ-013: v1 runtime matrix and fallback collapse":
        it "should ship distinct runtime artifacts only for implemented v1 families":
            val variants = "scalar x86_64_sse2 x86_64_avx2 aarch64_neon riscv64_rvv"
            expect(variants).to_contain("scalar")
            expect(variants).to_contain("x86_64_avx2")
            expect(variants).to_contain("aarch64_neon")

        it "should collapse higher unsupported host tiers to implemented fallback variants":
            val collapse = "avx512->avx2 sve2->neon sve->neon"
            expect(collapse).to_contain("avx512->avx2")
            expect(collapse).to_contain("sve2->neon")
