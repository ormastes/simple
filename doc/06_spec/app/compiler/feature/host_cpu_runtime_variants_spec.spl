use std.spec.SSpec

fn _contains_text(values: [text], needle: text) -> bool:
    var i: i64 = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

fn _known_tier(tier: text) -> bool:
    tier == "scalar" ||
    tier == "x86_64_sse2" ||
    tier == "x86_64_avx2" ||
    tier == "x86_64_avx512" ||
    tier == "aarch64_neon" ||
    tier == "aarch64_sve" ||
    tier == "aarch64_sve2" ||
    tier == "riscv64_rvv" ||
    tier == "wasm32_simd128"

fn _active_tier(override_tier: text, configured_tier: text, detected_tier: text) -> text:
    if _known_tier(override_tier):
        return override_tier
    if _known_tier(configured_tier):
        return configured_tier
    if _known_tier(detected_tier):
        return detected_tier
    "scalar"

fn _canonical_instruction_order() -> [text]:
    [
        "sse2",
        "avx2",
        "avx512f",
        "neon",
        "sve",
        "sve2",
        "rvv",
        "wasm128"
    ]

fn _clamp_instruction_sets(host_supported: [text], simple_supported: [text], enabled_requested: [text]) -> [text]:
    val ordered = _canonical_instruction_order()
    var clamped: [text] = []
    var i: i64 = 0
    while i < ordered.len():
        val instruction = ordered[i]
        if _contains_text(host_supported, instruction) &&
           _contains_text(simple_supported, instruction) &&
           _contains_text(enabled_requested, instruction):
            clamped.push(instruction)
        i = i + 1
    clamped

fn _implemented_fallback_tiers(active_tier: text) -> [text]:
    if active_tier == "x86_64_avx512":
        return ["x86_64_avx2", "x86_64_sse2", "scalar"]
    if active_tier == "x86_64_avx2":
        return ["x86_64_avx2", "x86_64_sse2", "scalar"]
    if active_tier == "x86_64_sse2":
        return ["x86_64_sse2", "scalar"]
    if active_tier == "aarch64_sve2" || active_tier == "aarch64_sve" || active_tier == "aarch64_neon":
        return ["aarch64_neon", "scalar"]
    if active_tier == "riscv64_rvv":
        return ["riscv64_rvv", "scalar"]
    ["scalar"]

fn _runtime_variant_path(dir: text, tier: text) -> text:
    if tier == "scalar":
        if dir == "":
            return "libsimple_runtime.so"
        return dir + "/libsimple_runtime.so"
    if dir == "":
        return "libsimple_runtime." + tier + ".so"
    dir + "/libsimple_runtime." + tier + ".so"

fn _runtime_library_candidates(dir: text, active_tier: text) -> [text]:
    val fallbacks = _implemented_fallback_tiers(active_tier)
    var candidates: [text] = []
    var i: i64 = 0
    while i < fallbacks.len():
        val candidate = _runtime_variant_path(dir, fallbacks[i])
        if ! _contains_text(candidates, candidate):
            candidates.push(candidate)
        i = i + 1
    candidates

fn _select_embedded_runtime_resource(
    active_tier: text,
    variant_tiers: [text],
    variant_paths: [text],
    embedded_resources: [text]
) -> text:
    val fallbacks = _implemented_fallback_tiers(active_tier)
    var i: i64 = 0
    while i < fallbacks.len():
        var j: i64 = 0
        while j < variant_tiers.len():
            if variant_tiers[j] == fallbacks[i] && _contains_text(embedded_resources, variant_paths[j]):
                return variant_paths[j]
            j = j + 1
        i = i + 1
    ""

fn _manifest_is_valid(trailer_says_manifest_present: bool, payload_complete: bool, runtime_variants_well_formed: bool) -> bool:
    if ! trailer_says_manifest_present:
        return true
    payload_complete && runtime_variants_well_formed

fn _cache_identity(base_key: text, active_tier: text) -> text:
    base_key + "::" + active_tier

fn _stdlib_root_candidates(base_root: text, active_tier: text) -> [text]:
    val fallbacks = _implemented_fallback_tiers(active_tier)
    var roots: [text] = []
    var i: i64 = 0
    while i < fallbacks.len():
        if fallbacks[i] == "scalar":
            roots.push(base_root)
        else:
            roots.push(base_root + "/" + fallbacks[i])
        i = i + 1
    roots

# codex-system-test
describe "Host CPU runtime variants":
    describe "REQ-001 through REQ-004: active-tier precedence":
        it "prefers explicit override over configured enabled tier and raw detection":
            expect(_active_tier("x86_64_sse2", "scalar", "x86_64_avx2")).to_equal("x86_64_sse2")

        it "uses configured enabled tier when override is absent or invalid":
            expect(_active_tier("", "x86_64_sse2", "x86_64_avx2")).to_equal("x86_64_sse2")
            expect(_active_tier("bogus", "scalar", "x86_64_avx2")).to_equal("scalar")

    describe "REQ-005 and REQ-006: enabled capability clamping":
        it "keeps only support intersect simple_support in canonical order":
            val clamped = _clamp_instruction_sets(
                ["sse2", "avx2", "avx512f"],
                ["sse2", "avx2"],
                ["avx2", "sse2", "avx512f"]
            )
            expect(clamped.len()).to_equal(2)
            expect(clamped[0]).to_equal("sse2")
            expect(clamped[1]).to_equal("avx2")

        it "drops duplicates and unsupported requested instruction sets during rewrite":
            val clamped = _clamp_instruction_sets(
                ["neon", "sve2"],
                ["neon"],
                ["sve2", "neon", "neon"]
            )
            expect(clamped.len()).to_equal(1)
            expect(clamped[0]).to_equal("neon")

    describe "REQ-007 through REQ-009: runtime variant and manifest fallback":
        it "probes compatible sibling variants before the scalar fallback":
            val candidates = _runtime_library_candidates("", "x86_64_avx512")
            expect(candidates.len()).to_equal(3)
            expect(candidates[0]).to_equal("libsimple_runtime.x86_64_avx2.so")
            expect(candidates[1]).to_equal("libsimple_runtime.x86_64_sse2.so")
            expect(candidates[2]).to_equal("libsimple_runtime.so")

        it "keeps explicit-path probes in the sibling directory instead of the current directory":
            val candidates = _runtime_library_candidates("/tmp/runtime", "aarch64_sve2")
            expect(candidates.len()).to_equal(2)
            expect(candidates[0]).to_equal("/tmp/runtime/libsimple_runtime.aarch64_neon.so")
            expect(candidates[1]).to_equal("/tmp/runtime/libsimple_runtime.so")

        it "falls through lower compatible embedded variants until a present resource is found":
            val selected = _select_embedded_runtime_resource(
                "x86_64_avx512",
                ["x86_64_avx2", "x86_64_sse2", "scalar"],
                ["runtime/avx2.so", "runtime/sse2.so", "runtime/scalar.so"],
                ["runtime/sse2.so", "runtime/scalar.so"]
            )
            expect(selected).to_equal("runtime/sse2.so")

        it "fails closed when a manifest trailer says metadata exists but the payload is truncated":
            expect(_manifest_is_valid(true, false, true)).to_equal(false)
            expect(_manifest_is_valid(true, true, false)).to_equal(false)
            expect(_manifest_is_valid(false, false, false)).to_equal(true)

    describe "REQ-010 and REQ-011: cache and stdlib root identity":
        it "changes cache identity when the active tier changes":
            val scalar_key = _cache_identity("object:main", "scalar")
            val sse2_key = _cache_identity("object:main", "x86_64_sse2")
            expect(scalar_key == sse2_key).to_equal(false)

        it "changes stdlib root ordering when the configured tier changes":
            val scalar_roots = _stdlib_root_candidates("src/lib", "scalar")
            val sse2_roots = _stdlib_root_candidates("src/lib", "x86_64_sse2")
            expect(scalar_roots.len()).to_equal(1)
            expect(scalar_roots[0]).to_equal("src/lib")
            expect(sse2_roots.len()).to_equal(2)
            expect(sse2_roots[0]).to_equal("src/lib/x86_64_sse2")
            expect(sse2_roots[1]).to_equal("src/lib")

    describe "REQ-012 and REQ-013: implemented variant matrix and collapse rules":
        it "collapses unsupported higher x86 tiers to implemented v1 runtime artifacts":
            val x86 = _implemented_fallback_tiers("x86_64_avx512")
            expect(x86.len()).to_equal(3)
            expect(x86[0]).to_equal("x86_64_avx2")
            expect(x86[1]).to_equal("x86_64_sse2")
            expect(x86[2]).to_equal("scalar")

        it "collapses SVE and SVE2 hosts through neon before scalar":
            val sve2 = _implemented_fallback_tiers("aarch64_sve2")
            val sve = _implemented_fallback_tiers("aarch64_sve")
            expect(sve2.len()).to_equal(2)
            expect(sve2[0]).to_equal("aarch64_neon")
            expect(sve2[1]).to_equal("scalar")
            expect(sve[0]).to_equal("aarch64_neon")
