# System-level spec for SimpleOS Wine/Proton/Steam Implementation.
#
# Covers all 10 ACs from the sstack feature wine-proton-steam-impl.
# Each AC has at least one it-block. These are design-level invariants
# and surface-presence checks. Real behavior specs live in the per-module
# specs under test/os/kernel/wine/.
#
# Tests are in the red phase: implementations do not yet exist.
# Run with:
#   bin/simple test doc/06_spec/app/simpleos/feature/simpleos_wine_proton_steam_impl_spec.spl
#
# @cover src/lib/nogc_async_mut_noalloc/baremetal/process_table.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/vm_fault.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/kernel_thread.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/kevent.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/kfutex.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/namespace.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/tss_syscall.spl
# @cover src/lib/nogc_async_mut/thread_sffi.spl
# @cover src/lib/nogc_async_mut/posix/fd_table.spl
# @cover src/lib/nogc_sync_mut/ffi/pe_section_mapper.spl
# @cover src/lib/nogc_sync_mut/ffi/guest_dlopen.spl
# @cover src/lib/nogc_async_mut/wm/service.spl
# @cover src/lib/nogc_async_mut/gpu/vulkan_loader.spl
# @cover src/lib/nogc_async_mut/esync/esync.spl
# @cover src/lib/nogc_async_mut/fsync/fsync.spl
# @cover src/lib/nogc_async_mut/steam/proton_launcher.spl

use std.spec
use std.nogc_async_mut_noalloc.baremetal.process_table.{
    process_table_alloc_pid,
    process_table_register,
    process_table_lookup
}
use std.nogc_async_mut_noalloc.baremetal.namespace.{
    namespace_create,
    namespace_clone,
    NsFlags
}
use std.nogc_async_mut_noalloc.baremetal.kernel_thread.{
    kernel_thread_create,
    kernel_thread_tls_set,
    kernel_thread_tls_get
}
use std.nogc_async_mut_noalloc.baremetal.kevent.{kevent_create, kevent_set, kevent_wait}
use std.nogc_async_mut_noalloc.baremetal.kfutex.{kfutex_wake}
use std.nogc_async_mut_noalloc.baremetal.tss_syscall.{
    tss_write_rsp0,
    msr_lstar_install,
    msr_star_install,
    msr_sfmask_install
}
use std.nogc_async_mut.thread_sffi.{
    tls_key_alloc,
    tls_key_set,
    tls_key_get,
    semaphore_create,
    semaphore_post,
    semaphore_wait,
    event_wait_create,
    event_wait_set,
    event_wait_wait
}
use std.nogc_async_mut.posix.fd_table.{
    fd_table_new,
    fd_open,
    fd_write,
    fd_read,
    fd_close
}
use std.nogc_sync_mut.ffi.pe_section_mapper.{pe_map_image}
use std.nogc_sync_mut.ffi.guest_dlopen.{guest_dlopen, guest_dlsym}
use std.nogc_async_mut.wm.service.{wm_port_open, wm_window_create}
use std.nogc_async_mut.gpu.vulkan_loader.{vulkan_loader_init}
use std.nogc_async_mut.esync.esync.{esync_create, esync_signal, esync_wait}
use std.nogc_async_mut.fsync.fsync.{fsync_mutex_lock, fsync_mutex_unlock}
use std.nogc_async_mut.steam.proton_launcher.{proton_launcher_plan}

describe "SimpleOS Wine/Proton/Steam Implementation — System Spec":

    describe "AC-1: Process Baseline — scheduler-owned PIDs":
        it "AC-1: process_table_alloc_pid returns a real non-zero PID (no fallback markers)":
            val pid = process_table_alloc_pid()
            expect(pid).to_be_greater_than(0)

        it "AC-1: registering a process produces a visible table entry with running state":
            val pid = process_table_alloc_pid()
            process_table_register(pid, 1, 1)
            val entry = process_table_lookup(pid)
            expect(entry.is_some).to_equal(true)
            expect(entry.value.state).to_equal("running")

        it "AC-1: five distinct PIDs can be allocated (one per desktop app)":
            val pids = [
                process_table_alloc_pid(),
                process_table_alloc_pid(),
                process_table_alloc_pid(),
                process_table_alloc_pid(),
                process_table_alloc_pid()
            ]
            expect(pids[0]).to_be_greater_than(0)
            expect(pids[1]).to_be_greater_than(0)
            expect(pids[4]).to_be_greater_than(0)
            expect(pids[0] == pids[1]).to_equal(false)
            expect(pids[0] == pids[4]).to_equal(false)

    describe "AC-2: POSIX Host ABI — fd table":
        it "AC-2: fd_table_new creates a usable fd table":
            val fdt = fd_table_new()
            expect(fdt.is_valid).to_equal(true)

        it "AC-2: fd_open returns a valid file descriptor":
            val fdt = fd_table_new()
            val fd = fd_open(fdt, "/dev/null", 0)
            expect(fd).to_be_greater_than(-1)

        it "AC-2: fd_write on a valid fd returns bytes written":
            val fdt = fd_table_new()
            val fd = fd_open(fdt, "/dev/null", 1)
            val n = fd_write(fdt, fd, "hello", 5)
            expect(n).to_equal(5)

        it "AC-2: fd_close releases the file descriptor":
            val fdt = fd_table_new()
            val fd = fd_open(fdt, "/dev/null", 0)
            val ok = fd_close(fdt, fd)
            expect(ok).to_equal(true)

    describe "AC-3: Threads/TLS — real threading primitives":
        it "AC-3: tls_key_alloc returns a positive key":
            fn no_dtor(p: *void) -> void:
                val _ = 0
            val key = tls_key_alloc(no_dtor)
            expect(key).to_be_greater_than(0)

        it "AC-3: tls_key_set and tls_key_get are consistent":
            fn no_dtor(p: *void) -> void:
                val _ = 0
            val key = tls_key_alloc(no_dtor)
            tls_key_set(key, 0xCAFE)
            expect(tls_key_get(key)).to_equal(0xCAFE)

        it "AC-3: semaphore post/wait cycle works end-to-end":
            val h = semaphore_create(0)
            semaphore_post(h)
            val result = semaphore_wait(h, 0)
            expect(result).to_equal("signaled")

        it "AC-3: event_wait set/wait cycle works end-to-end":
            val h = event_wait_create(false)
            event_wait_set(h)
            val result = event_wait_wait(h, 0)
            expect(result).to_equal("signaled")

        it "AC-3: kernel_thread_create returns a positive Tid":
            fn noop() -> void:
                val _ = 0
            val tid = kernel_thread_create(noop, 4096)
            expect(tid).to_be_greater_than(0)

        it "AC-3: kevent set/wait produces signaled result":
            val h = kevent_create(false)
            kevent_set(h)
            val result = kevent_wait(h, 0)
            expect(result).to_equal("signaled")

    describe "AC-4: VM/Containers — isolation primitives":
        it "AC-4: tss_write_rsp0 is callable with a valid kernel stack address":
            # Sentinel value — a non-zero RSP0 (actual value would be real stack PA)
            tss_write_rsp0(0x100000)
            # No panic means success
            expect(1).to_equal(1)

        it "AC-4: msr_lstar_install is callable (installs SYSCALL entry)":
            msr_lstar_install(0x200000)
            expect(1).to_equal(1)

        it "AC-4: msr_star_install encodes kernel/user CS pair":
            msr_star_install(0x0008, 0x0018)
            expect(1).to_equal(1)

        it "AC-4: msr_sfmask_install sets interrupt flag mask":
            # SFMASK_IF = 0x200
            msr_sfmask_install(0x200)
            expect(1).to_equal(1)

        it "AC-4: namespace_create produces isolation facets for all five types":
            val pid_ns = namespace_create(NsFlags.pid)
            val fs_ns  = namespace_create(NsFlags.fs)
            val ipc_ns = namespace_create(NsFlags.ipc)
            val net_ns = namespace_create(NsFlags.net)
            val cap_ns = namespace_create(NsFlags.capability)
            expect(pid_ns).to_be_greater_than(0)
            expect(cap_ns).to_be_greater_than(0)

        it "AC-4: namespace_clone creates an isolated child namespace":
            val parent = namespace_create(NsFlags.pid)
            val child  = namespace_clone(parent, NsFlags.pid)
            expect(child).to_be_greater_than(0)
            expect(child == parent).to_equal(false)

    describe "AC-5: Renderer/WM — window protocol surface":
        it "AC-5: wm_port_open returns a valid port handle":
            val port = wm_port_open()
            expect(port).to_be_greater_than(0)

        it "AC-5: wm_window_create on an open port returns a window handle":
            val port = wm_port_open()
            val win  = wm_window_create(port, "wine-test", 800, 600)
            expect(win).to_be_greater_than(0)

    describe "AC-6: Dynamic Loading — dlopen/dlsym surface":
        it "AC-6: guest_dlopen with a known module path returns a non-zero handle":
            # Interpreter-mode stub: the loader must at least return a handle record
            val h = guest_dlopen("kernel32.dll")
            expect(h.is_some).to_equal(true)

        it "AC-6: guest_dlsym on a valid handle returns a non-zero symbol address":
            val h = guest_dlopen("kernel32.dll")
            expect(h.is_some).to_equal(true)
            val sym = guest_dlsym(h.value, "WriteFile")
            expect(sym).to_be_greater_than(0)

    describe "AC-7: Real hello.exe execution — PE loader surface":
        it "AC-7: pe_map_image on valid PE bytes returns a non-error result":
            # Minimal 512-byte buffer representing a stub PE; implementation maps real sections
            val stub_bytes: [u8] = [0x4D, 0x5A]  # MZ magic
            val result = pe_map_image(stub_bytes)
            # Either ok (full impl) or error with a structured code (no crash/panic)
            expect(result.is_ok).to_equal(false)
            expect(result.error).to_equal("too-small")

    describe "AC-8: Async Substrate — IoDriver surface":
        it "AC-8: fd_table supports open/write/close cycle (async fd registration path)":
            val fdt = fd_table_new()
            val fd = fd_open(fdt, "/dev/null", 1)
            val n = fd_write(fdt, fd, "test", 4)
            val ok = fd_close(fdt, fd)
            expect(n).to_be_greater_than(-1)
            expect(ok).to_equal(true)

    describe "AC-9: Vulkan/Graphics — loader surface":
        it "AC-9: vulkan_loader_init returns a loader handle or a structured error":
            val result = vulkan_loader_init()
            # In interpreter/stub mode: either ok or error — must not panic
            val is_structured = result.is_ok == true || result.error != ""
            expect(is_structured).to_equal(true)

    describe "AC-10: Steam/Proton — launcher surface":
        it "AC-10: esync_create returns a valid handle":
            val h = esync_create()
            expect(h).to_be_greater_than(0)

        it "AC-10: esync signal/wait produces signaled result":
            val h = esync_create()
            esync_signal(h)
            val result = esync_wait(h, 0)
            expect(result).to_equal("signaled")

        it "AC-10: fsync mutex lock/unlock pair completes without error":
            val addr: u32 = 0
            fsync_mutex_lock(addr)
            fsync_mutex_unlock(addr)
            expect(1).to_equal(1)

        it "AC-10: proton_launcher_plan returns a structured plan record":
            val plan = proton_launcher_plan("480", "hl2.exe", ["-novid"])
            expect(plan.status).to_equal("planned")
            expect(plan.app_id).to_equal("480")
