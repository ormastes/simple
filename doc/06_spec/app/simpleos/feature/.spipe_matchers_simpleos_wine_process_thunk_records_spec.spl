use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_process_session.{
    wine_process_plan_known_kernel32_thunk_patch_records,
    wine_process_session_plan,
    wine_process_session_request_new
}

fn _full_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified user32=verified " +
        "gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified " +
        "pthread=verified dynload=verified audio=verified fonts=verified input=verified " +
        "pe_loader=verified async=verified nt_bridge=verified"

describe "SimpleOS Wine thunk patch records":
    describe "REQ-024: bounded thunk patch record planning":
        it "should plan concrete records for the known KERNEL32 import thunk slots":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_plan_known_kernel32_thunk_patch_records(plan, wine_known_hello_exe_fixture_bytes(), 8)
            expect result.ok == true
            expect result.records.len() == 3
            expect result.records[0].symbol == "GetStdHandle"
            expect result.records[0].thunk_rva == 0x2060
            expect result.records[0].name_rva == 0x2080
            expect result.records[1].symbol == "WriteFile"
            expect result.records[1].thunk_rva == 0x2068
            expect result.records[2].symbol == "ExitProcess"
            expect result.records[2].thunk_rva == 0x2070
            expect result.status == "thunk-records-planned"

        it "should reject thunk record planning before load-and-bind passes":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_plan_known_kernel32_thunk_patch_records(plan, wine_known_hello_exe_fixture_bytes(), 0)
            expect result.ok == false
            expect result.error == "invalid-symbol-limit"
            expect result.records.len() == 0