# codex-system-test
# Design-level system spec for the native tmux_simpleos feature.

use std.spec
use os.apps.smux.contract.{
    MuxBackendKind
}
use os.apps.smux.api.{
    smux_reset_for_test,
    smux_is_deferred_feature,
    smux_metrics,
    smux_create_session,
    smux_attach,
    smux_detach,
    smux_new_window,
    smux_split_pane,
    smux_focus_pane,
    smux_resize,
    smux_send_text,
    smux_send_command,
    smux_capture,
    smux_list_sessions,
    smux_list_windows,
    smux_list_panes,
    smux_backend_contract_name
}

describe "tmux_simpleos feature spec":
    describe "REQ-001 session model":
        it "should create a persistent session with an initial window and pane":
            smux_reset_for_test()
            val session = smux_create_session("dev")
            expect session.name == "dev"

            val windows = smux_list_windows(session.id)
            expect windows.len() > 0

            val panes = smux_list_panes(session.id, windows[0].id)
            expect panes.len() > 0

    describe "REQ-002 pane-backed shells":
        it "should start panes on the native backend":
            smux_reset_for_test()
            val session = smux_create_session("shells")
            val windows = smux_list_windows(session.id)
            val panes = smux_list_panes(session.id, windows[0].id)

            expect panes[0].backend_kind == MuxBackendKind.NativeShell
            expect panes[0].state == "running"

    describe "REQ-003 attach and detach":
        it "should detach a client without destroying the session":
            smux_reset_for_test()
            val session = smux_create_session("attach")
            expect smux_attach(session.id, "client-a", 120, 40).attached == true
            expect smux_detach("client-a") == true

            val sessions = smux_list_sessions()
            expect sessions[0].name == "attach"

    describe "REQ-004 split and layout":
        it "should split the active pane and create a second pane":
            smux_reset_for_test()
            val session = smux_create_session("split")
            val window = smux_list_windows(session.id)[0]
            val first = smux_list_panes(session.id, window.id)[0]

            expect smux_split_pane(session.id, window.id, first.id, "horizontal").is_ok() == true

            val panes = smux_list_panes(session.id, window.id)
            expect panes.len() == 2

    describe "REQ-005 input and output routing":
        it "should route sent text and commands to the selected pane":
            smux_reset_for_test()
            val session = smux_create_session("io")
            val window = smux_list_windows(session.id)[0]
            val pane = smux_list_panes(session.id, window.id)[0]

            expect smux_focus_pane(session.id, window.id, pane.id) == true
            expect smux_send_text(session.id, window.id, pane.id, "echo hi") == true
            expect smux_send_command(session.id, window.id, pane.id, "pwd") == true

            val metrics = smux_metrics()
            expect metrics.send_text_count == 1
            expect metrics.send_command_count == 1

    describe "REQ-006 state query API":
        it "should list sessions windows and panes with stable metadata":
            smux_reset_for_test()
            val session = smux_create_session("query")
            val sessions = smux_list_sessions()
            expect sessions[0].name == "query"

            val windows = smux_list_windows(session.id)
            expect windows[0].session_id == session.id

            val panes = smux_list_panes(session.id, windows[0].id)
            expect panes[0].window_id == windows[0].id

    describe "REQ-007 capture api":
        it "should capture pane output and preserve pane identity":
            smux_reset_for_test()
            val session = smux_create_session("capture")
            val window = smux_list_windows(session.id)[0]
            val pane = smux_list_panes(session.id, window.id)[0]

            val capture = smux_capture(session.id, window.id, pane.id, 50)
            expect capture.pane_id == pane.id
            expect capture.rows > 0

    describe "REQ-008 compatibility facing api shape":
        it "should expose tmux-shaped session window pane operations over the native backend":
            smux_reset_for_test()
            val session = smux_create_session("compat")
            val window = smux_new_window(session.id, "build")
            expect window.name == "build"

            val panes = smux_list_panes(session.id, window.id)
            expect panes.len() > 0

    describe "REQ-009 native first backend":
        it "should identify the backend as native rather than host tmux":
            smux_reset_for_test()
            expect smux_backend_contract_name() == "smux-native"

    describe "REQ-010 backend swap readiness":
        it "should keep backend identity behind a named contract boundary":
            smux_reset_for_test()
            expect (smux_backend_contract_name()).starts_with("smux-")

    describe "REQ-011 explicit non fatal failure handling":
        it "should return an error for an invalid pane target":
            smux_reset_for_test()
            val session = smux_create_session("errors")
            val window = smux_list_windows(session.id)[0]

            val result = smux_resize(session.id, window.id, "missing-pane", 80, 24)
            expect result.is_err() == true
            expect (result.err().unwrap()).contains("pane")

        it "should return an error when split target is invalid":
            smux_reset_for_test()
            val session = smux_create_session("split-errors")
            val window = smux_list_windows(session.id)[0]
            val result = smux_split_pane(session.id, window.id, "missing-pane", "vertical")
            expect result.is_err() == true

    describe "REQ-012 initial scope boundary":
        it "should expose deferred parity features explicitly":
            smux_reset_for_test()
            expect smux_is_deferred_feature("copy-mode") == true
            expect smux_is_deferred_feature("mouse") == true
            expect smux_is_deferred_feature("key-table-compat") == true
            expect smux_is_deferred_feature("tmux-conf") == true
            expect smux_is_deferred_feature("control-mode") == true
            expect smux_is_deferred_feature("split-pane") == false

    describe "NFR-007 observability":
        it "should expose observable startup and operation counters":
            smux_reset_for_test()
            val session = smux_create_session("obs")
            val window = smux_list_windows(session.id)[0]
            val pane = smux_list_panes(session.id, window.id)[0]

            expect smux_resize(session.id, window.id, pane.id, 90, 25).is_ok() == true
            val _capture = smux_capture(session.id, window.id, pane.id, 10)
            val metrics = smux_metrics()

            expect metrics.startup_count > 0
            expect metrics.last_startup_ns > 0u64
            expect metrics.resize_count == 1
            expect metrics.capture_count == 1