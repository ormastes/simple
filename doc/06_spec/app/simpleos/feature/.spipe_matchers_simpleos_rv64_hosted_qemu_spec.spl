use std.spec
use os.qemu_runner.{
    get_scenario,
    scenario_riscv64_hosted,
    scenario_target,
    scenario_test_timeout_ms,
    build_scenario_command,
}
use os.kernel.arch.arch_context.{Architecture}

describe "SimpleOS RV64 hosted QEMU":
    describe "REQ-RV64-HOSTED-001/002: scenario shape":
        it "registers the hosted RV64 scenario with disk and forwarded network":
            val scenario = scenario_riscv64_hosted()
            expect scenario.name == "riscv64-hosted"
            expect scenario.arch == Architecture.Riscv64
            expect (scenario.qemu_extra).contains("virtio-blk-device,drive=rvdisk")
            expect (scenario.qemu_extra).contains("user,id=n0,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:80")
            expect (scenario.qemu_extra).contains("virtio-net-pci,netdev=n0,disable-legacy=on")
            expect scenario_test_timeout_ms(scenario) == 120000

        it "resolves the scenario and target by name":
            if val resolved = get_scenario("riscv64-hosted"):
                expect resolved.name == "riscv64-hosted"
            else:
                expect "missing" == "riscv64-hosted"
            val target = scenario_target(scenario_riscv64_hosted())
            expect target.entry == "examples/simple_os/arch/riscv64/hosted_entry.spl"
            expect target.output == "build/os/simpleos_riscv64_hosted.elf"

        it "builds a QEMU command with host-forwarded SSH and HTTP":
            val cmd = build_scenario_command(scenario_riscv64_hosted(), "build/os/simpleos_riscv64_hosted.elf")
            expect cmd[0] == "qemu-system-riscv64"
            expect (cmd).contains("user,id=n0,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:80")
            expect (cmd).contains("virtio-net-pci,netdev=n0,disable-legacy=on")