use common.wine_dll_file_probe.{wine_dll_probe_file}
use common.wine_dll_view_relocation.{wine_dll_apply_file_view_relocations}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn _put_u64_le(data: [u8], offset: i64, value: i64) -> [u8]:
    var remaining = value
    var i = 0
    while i < 8:
        data[offset + i] = remaining % 256
        remaining = remaining / 256
        i = i + 1
    data

fn _dll_with_relocation() -> [u8]:
    var data = _zero_bytes(1024)
    data[0] = 0x4d
    data[1] = 0x5a
    data = _put_u32_le(data, 0x3c, 0x80)
    data[0x80] = 0x50
    data[0x81] = 0x45
    data = _put_u16_le(data, 0x84, 0x8664)
    data = _put_u16_le(data, 0x86, 1)
    data = _put_u16_le(data, 0x94, 0xf0)
    data = _put_u16_le(data, 0x96, 0x2022)
    data = _put_u16_le(data, 0x98, 0x20b)
    data = _put_u32_le(data, 0x98 + 0x10, 0x1200)
    data = _put_u32_le(data, 0x98 + 0x38, 0x5000)
    data = _put_u32_le(data, 0x98 + 0x3c, 0x200)
    data = _put_u16_le(data, 0x98 + 0x5c, 3)
    data = _put_u32_le(data, 0x98 + 0x6c, 16)
    data = _put_u32_le(data, 0x98 + 0x70 + 8, 0x2020)
    data = _put_u32_le(data, 0x98 + 0x70 + 12, 0x40)
    data = _put_u32_le(data, 0x98 + 0x70 + 40, 0x2160)
    data = _put_u32_le(data, 0x98 + 0x70 + 44, 0x0a)
    data = _put_u32_le(data, 0x98 + 0x70 + 72, 0x2170)
    data = _put_u32_le(data, 0x98 + 0x70 + 76, 0x28)
    val section_offset = 0x98 + 0xf0
    data = _put_u32_le(data, section_offset + 8, 0x300)
    data = _put_u32_le(data, section_offset + 12, 0x2000)
    data = _put_u32_le(data, section_offset + 16, 0x200)
    data = _put_u32_le(data, section_offset + 20, 0x200)
    data = _put_u32_le(data, section_offset + 36, 0x60000020)
    data = _put_u32_le(data, 0x360, 0x2000)
    data = _put_u32_le(data, 0x364, 0x0a)
    data = _put_u16_le(data, 0x368, 0xa100)
    data = _put_u64_le(data, 0x300, 0x401234)
    data

describe "REQ-048 SimpleOS Wine DLL view relocations":
    it "applies DLL view relocations without executing DLL startup code":
        val data = _dll_with_relocation()
        val files = [wine_dll_probe_file("\\KnownDlls\\kernel32.dll", data)]
        val result = wine_dll_apply_file_view_relocations("kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], files, data, 0x400000, 0x500000, 91, 92, "pid fs ipc net capability")
        expect(result.ok).to_equal(true)
        expect(result.status).to_equal("dll-view-relocations-applied")
        expect(result.relocation_count).to_equal(1)
        expect(result.target_rva).to_equal(0x2100)
        expect(result.evidence).to_contain("file-backed-dll-view-persistent")
        expect(result.evidence).to_contain("relocation-applied")
        expect(result.evidence).to_contain("dll-view-write-window")
        expect(result.evidence).to_contain("no-dll-entrypoint-executed")
        expect(result.evidence).to_contain("no-tls-callback-executed")
