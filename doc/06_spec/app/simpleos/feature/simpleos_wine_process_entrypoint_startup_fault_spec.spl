use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_process_entrypoint_startup_fault.{wine_process_record_imported_entrypoint_handoff_startup_fault_with_peb_teb_vm_writes, wine_process_record_imported_entrypoint_startup_fault}
use common.wine_peb_teb.{wine_peb_teb_apply_layout_byte_writes, wine_peb_teb_init_default, wine_peb_teb_layout_byte_writes, wine_peb_teb_layout_write_plan, wine_peb_teb_memory_write_gate}
use common.wine_process_session.{WineProcessImportedEntrypointHandoff, wine_process_session_plan, wine_process_session_request_new}
use common.wine_vm_adapter.{WineVmFault, WineVmSpace, wine_vm_commit, wine_vm_process_space_new, wine_vm_reserve_fixed}

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn _put_ascii_z(data: [u8], offset: i64, value: text) -> [u8]:
    var i = 0
    while i < value.len():
        data[offset + i] = value[i] as u8
        i = i + 1
    data[offset + value.len()] = 0
    data

fn _put_import_name(data: [u8], offset: i64, value: text) -> [u8]:
    data[offset] = 0
    data[offset + 1] = 0
    _put_ascii_z(data, offset + 2, value)

fn _clear_bytes(data: [u8], offset: i64, count: i64) -> [u8]:
    var i = 0
    while i < count:
        data[offset + i] = 0
        i = i + 1
    data

fn _commit_fixed(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineVmSpace:
    val reserved = wine_vm_reserve_fixed(space, base, size)
    if not reserved.ok:
        return reserved.space
    val committed = wine_vm_commit(reserved.space, reserved.region.base, perms)
    committed.space

fn _startup_write_space() -> WineVmSpace:
    var space = wine_vm_process_space_new(10, 30, "pid fs ipc net capability")
    space = _commit_fixed(space, 0x7ffdc000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffdd000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffde000, 0x1000, "rw")
    _commit_fixed(space, 0x7ffdf000, 0x1000, "rw")

fn _full_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified user32=verified " +
        "gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified " +
        "pthread=verified dynload=verified audio=verified fonts=verified input=verified " +
        "pe_loader=verified async=verified nt_bridge=verified"

fn _known_hello_with_second_import_descriptor() -> [u8]:
    var data = wine_known_hello_exe_fixture_bytes()
    data = _clear_bytes(data, 0x250, 16)
    data = _put_u32_le(data, 0x220 + 12, 0x21d0)
    data = _put_u32_le(data, 0x220 + 20, 0x2190)
    data = _put_u32_le(data, 0x220 + 20 + 12, 0x21e0)
    data = _put_u32_le(data, 0x220 + 20 + 16, 0x21a0)
    data = _put_u32_le(data, 0x390, 0x21f0)
    data = _put_u32_le(data, 0x3a0, 0x21f0)
    data = _put_ascii_z(data, 0x3d0, "KERNEL32.dll")
    data = _put_ascii_z(data, 0x3e0, "USER32.dll")
    data = _put_import_name(data, 0x3f0, "MessageBoxW")
    data

fn _ready_handoff() -> WineProcessImportedEntrypointHandoff:
    WineProcessImportedEntrypointHandoff(
        ok: true,
        error: "",
        command: "game.exe",
        patched_image: [],
        mapped_base: 0x400000,
        mapped_size: 0x5000,
        entry_address: 0x402000,
        module_count: 2,
        patched_count: 4,
        evidence: "imported-entrypoint-handoff-ready no-arbitrary-execution",
        status: "imported-entrypoint-handoff-ready"
    )

describe "REQ-045: process imported entrypoint startup fault rollback":
    it "records SEH rollback after import-bound entrypoint handoff while keeping PE code non-executing":
        val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
        val fault = WineVmFault(process_id: 77, thread_id: 12, address: 0x402000, access: "execute", policy: "deliver-seh")
        val result = wine_process_record_imported_entrypoint_startup_fault(plan, _known_hello_with_second_import_descriptor(), 4, 8, fault)
        expect(result.ok).to_equal(true)
        expect(result.status).to_equal("imported-entrypoint-startup-fault-rollback-recorded")
        expect(result.rollback_count).to_equal(2)
        expect(result.evidence).to_contain("imported-entrypoint-handoff-ready")
        expect(result.evidence).to_contain("seh-dispatch-recorded")
        expect(result.evidence).to_contain("no-arbitrary-execution")

    it "requires PEB/TEB VM byte-write readback before import-bound entrypoint rollback":
        val fault = WineVmFault(process_id: 77, thread_id: 12, address: 0x402000, access: "execute", policy: "deliver-seh")
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
        val layout = wine_peb_teb_layout_write_plan(init, writes)
        val bytes = wine_peb_teb_layout_byte_writes(layout)
        val vm_writes = wine_peb_teb_apply_layout_byte_writes(_startup_write_space(), bytes)
        val result = wine_process_record_imported_entrypoint_handoff_startup_fault_with_peb_teb_vm_writes(_ready_handoff(), fault, vm_writes)

        expect(result.ok).to_equal(true)
        expect(result.status).to_equal("imported-entrypoint-startup-fault-rollback-recorded")
        expect(result.evidence).to_contain("peb-teb-vm-writes-ready")
        expect(result.evidence).to_contain("VMWriteReadback:PEBTEBLayoutBytes")
        expect(result.evidence).to_contain("no-arbitrary-execution")
