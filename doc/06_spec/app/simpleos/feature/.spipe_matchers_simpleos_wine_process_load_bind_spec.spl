use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_process_session.{
    wine_process_load_and_bind_known_kernel32_imports,
    wine_process_session_plan,
    wine_process_session_request_new
}

fn _full_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified user32=verified " +
        "gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified " +
        "pthread=verified dynload=verified audio=verified fonts=verified input=verified " +
        "pe_loader=verified async=verified nt_bridge=verified"

describe "SimpleOS Wine process load and bind":
    describe "REQ-022: load then bind known KERNEL32 imports":
        it "should resolve the first import module before accepting known import bindings":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_load_and_bind_known_kernel32_imports(plan, wine_known_hello_exe_fixture_bytes(), 8)
            expect result.ok == true
            expect result.dll_name == "kernel32.dll"
            expect result.module_handle == 0x120
            expect result.call_sequence == "GetStdHandle WriteFile ExitProcess"
            expect result.binding_count == 3
            expect result.status == "imports-loaded-bound"

        it "should reject load-and-bind before module resolution passes":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_load_and_bind_known_kernel32_imports(plan, wine_known_hello_exe_fixture_bytes(), 0)
            expect result.ok == false
            expect result.error == "invalid-symbol-limit"
            expect result.status == "blocked"