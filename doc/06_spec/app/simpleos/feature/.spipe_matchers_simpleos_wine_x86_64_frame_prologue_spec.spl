use common.wine_x86_64_decode.{wine_x86_64_instruction_at, wine_x86_64_instruction_len_at, wine_x86_64_scan_window}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _frame_prologue_bytes() -> [u8]:
    var data = _zero_bytes(14)
    data[0] = 0x55
    data[1] = 0x48
    data[2] = 0x89
    data[3] = 0xe5
    data[4] = 0x48
    data[5] = 0x83
    data[6] = 0xec
    data[7] = 0x28
    data[8] = 0x48
    data[9] = 0x83
    data[10] = 0xc4
    data[11] = 0x28
    data[12] = 0x5d
    data[13] = 0xc3
    data

describe "SimpleOS Wine x86_64 frame prologue decode":
    describe "REQ-018: bounded known-console process dispatch plan":
        it "should classify frame-pointer prologue and epilogue forms before dispatch handoff":
            val data = _frame_prologue_bytes()
            expect wine_x86_64_instruction_at(data, 0) == "push-rbp"
            expect wine_x86_64_instruction_len_at(data, 0) == 1
            expect wine_x86_64_instruction_at(data, 1) == "mov-rbp-rsp"
            expect wine_x86_64_instruction_len_at(data, 1) == 3
            expect wine_x86_64_instruction_at(data, 12) == "pop-rbp"
            expect wine_x86_64_instruction_len_at(data, 12) == 1
            val scan = wine_x86_64_scan_window(data, 0, 14, 8)
            expect scan.ok == true
            expect scan.state == "ready"
            expect scan.end_offset == 14
            expect scan.instruction_count == 6
            expect scan.last_offset == 13
            expect scan.last_instruction == "ret"