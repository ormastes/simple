use common.wine_substrate.{
    wine_substrate_capability_matrix,
    wine_substrate_capability_row,
    wine_substrate_capability_state,
    wine_substrate_capability_state_from_gates,
    wine_substrate_verify_capability,
    wine_substrate_check_process_evidence,
    wine_substrate_exec_env_gate,
    wine_substrate_exec_env_gate_from_serial_log,
    wine_substrate_vm_gate,
    wine_substrate_renderer_gate,
    wine_substrate_hello_exe_gate,
    wine_substrate_full_wine_gate,
    wine_substrate_host_gate,
    wine_substrate_pe_gate,
    wine_substrate_async_gate
}
use common.wine_hello_exe.{wine_hello_exe_probe}
use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_cpu_exec.{wine_cpu_execution_evidence_all_ready, wine_cpu_execution_evidence_text}
use common.wine_process_session.{
    wine_process_bind_known_kernel32_imports,
    wine_process_cpu_dispatch_preflight,
    wine_process_execute_controlled_hello,
    wine_process_inspect_full_imports,
    wine_process_launch_handoff,
    wine_process_plan_import_thunk_patches,
    wine_process_validate_full_image,
    wine_process_session_plan,
    wine_process_session_request_new
}

fn _zero_pe_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

describe "SimpleOS Wine Substrate":
    describe "REQ-001: capability matrix":
        it "should classify missing Wine substrate capability rows explicitly":
            val state = wine_substrate_capability_state("pthread")
            expect state == "partial"
            expect wine_substrate_capability_state("audio") == "missing"
            expect wine_substrate_capability_state("fonts") == "missing"
            expect wine_substrate_capability_state("input") == "missing"
            expect wine_substrate_capability_state("registry") == "partial"
            expect wine_substrate_capability_state("user32") == "partial"
            expect wine_substrate_capability_state("gdi32") == "partial"
            expect wine_substrate_capability_state("kernel32_core") == "partial"

        it "should require evidence before a row can be verified":
            val state = wine_substrate_verify_capability("pthread", "")
            expect state == "partial"

        it "should link verified capability rows to implementation paths and evidence commands":
            val gates = "process=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified pthread=verified dynload=verified registry=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val row = wine_substrate_capability_row("nt_bridge", gates)
            expect row.state == "verified"
            expect row.implementation_path == "src/lib/common/wine_nt_bridge.spl"
            expect (row.evidence_command).contains("wine_nt_bridge_spec")
            val exec_env = wine_substrate_capability_row("exec_env", gates + " exec_env=verified")
            expect exec_env.state == "verified"
            expect (exec_env.evidence_command).contains("wine_simpleos_exec_env_gate_spec")
            val registry = wine_substrate_capability_row("registry", gates)
            expect registry.state == "verified"
            expect (registry.evidence_command).contains("wine_advapi32_registry_spec")
            val user32 = wine_substrate_capability_row("user32", gates)
            expect user32.state == "verified"
            expect (user32.evidence_command).contains("wine_user32_window_spec")
            val gdi32 = wine_substrate_capability_row("gdi32", gates)
            expect gdi32.state == "verified"
            expect (gdi32.evidence_command).contains("wine_gdi32_drawing_spec")
            val kernel32_core = wine_substrate_capability_row("kernel32_core", gates)
            expect kernel32_core.state == "verified"
            expect (kernel32_core.evidence_command).contains("wine_kernel32_heap_spec")
            expect wine_substrate_capability_state_from_gates("audio", gates) == "verified"
            expect wine_substrate_capability_state_from_gates("audio", "host=verified") == "missing"
            val matrix = wine_substrate_capability_matrix(gates)
            expect matrix.len() == 21
            expect matrix[1].capability == "exec_env"
            expect matrix[5].capability == "user32"
            expect matrix[6].capability == "gdi32"
            expect matrix[7].capability == "kernel32_core"
            expect matrix[9].capability == "fs_semantics"
            expect matrix[10].capability == "ipc_wait"
            expect matrix[11].capability == "registry"
            expect matrix[15].capability == "fonts"
            expect matrix[20].capability == "hello_exe"

    describe "REQ-002: process-backed app baseline":
        it "should reject resident fallback as complete evidence":
            val result = wine_substrate_check_process_evidence("[desktop-e2e] process-backed:resident")
            expect result == "resident-fallback"

        it "should require Browser Demo, Hello World, Editor, Terminal, and File Manager process markers":
            val partial = "[desktop-e2e] process-backed:ok app=browser_demo pid=1\n" +
                "[desktop-e2e] process-backed:ok app=hello_world pid=2\n" +
                "[desktop-e2e] process-backed:ok app=editor pid=3"
            expect wine_substrate_check_process_evidence(partial) == "insufficient-evidence"

    describe "REQ-005: VM and container support":
        it "should require full SimpleOS executable-environment evidence":
            val partial = "simpleos-qemu-vm simpleos-full-os-boot simpleos-user-process"
            expect wine_substrate_exec_env_gate(partial) == "missing-simpleos-vmspace"
            val serial_log = "QEMU x86_64 desktop lane\n" +
                "[phase-3-mount] fat32 ok\n" +
                "[vfs] mounted fat32 device=nvme0 volume=simpleos\n" +
                "[fs-exec] spawn:image path=/sys/apps/wine_hello entry=0 segments=1 stub_bytes=128\n" +
                "[desktop-e2e] process-backed:ok app=wine_hello pid=42\n" +
                "[desktop-e2e] wm:ok pid=42 wid=1001\n" +
                "[desktop-e2e] network-smoke:bounded ok packets=1\n" +
                "[desktop-e2e] container-namespace:ok pid fs ipc net capability\n" +
                "[desktop-e2e] container-rootfs:ok rootfs=/containers/wine rootfs_backend=nvfs\n" +
                "[desktop-e2e] mdsoc-capsule:ok owner=process-container-wm\n" +
                "[desktop-e2e] mdsoc-public-port:ok facade=exec-env\n" +
                "[desktop-e2e] mdsoc-resident-state-owner:ok ecs=wm,process,container\n" +
                "TEST PASSED"
            expect wine_substrate_exec_env_gate_from_serial_log(serial_log) == "ready"

        it "should require fixed mappings, guard pages, and permission changes":
            val result = wine_substrate_vm_gate("reserve commit unmap fixed-map")
            expect result == "missing-mprotect"

    describe "REQ-006: X11-class renderer and WM backend":
        it "should require window lifecycle, expose, input, and clipboard coverage":
            val features = "display screen window map-unmap configure surface damage clip expose present input focus cursor"
            val result = wine_substrate_renderer_gate(features)
            expect result == "missing-atom"

    describe "REQ-003 and REQ-004: host ABI, thread, and dynamic loading":
        it "should require the remaining Wine host substrate features":
            val features = "fd-table stdio pipes sockets poll-wait timers errno cwd-env-argv spawn fs-paths"
            val result = wine_substrate_host_gate(features)
            expect result == "missing-fs-attrs"

    describe "REQ-007: PE/COFF loader preparation":
        it "should require safe PE validation before execution":
            val result = wine_substrate_pe_gate("mz pe-signature machine-x86_64 pe32plus")
            expect result == "missing-section-bounds"

    describe "REQ-009: nogc async substrate":
        it "should require the existing nogc_async_mut completion and event-loop primitives":
            val features = "nogc-future poll waker io-driver submit-open submit-read"
            val result = wine_substrate_async_gate(features)
            expect result == "missing-submit-write"

    describe "REQ-008: non-GUI hello.exe milestone":
        it "should keep hello.exe blocked until substrate gates are verified":
            val gate_state = wine_substrate_hello_exe_gate("process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified")
            expect gate_state == "blocked"

        it "should keep hello.exe blocked until the modeled NT bridge is verified":
            val gate_state = wine_substrate_hello_exe_gate("process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified async=verified")
            expect gate_state == "blocked"

        it "should not execute malformed hello.exe bytes even when gates are declared verified":
            val gates = "process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified async=verified nt_bridge=verified"
            val result = wine_hello_exe_probe(_zero_pe_bytes(0), gates)
            expect result.status == "rejected"
            expect result.error == "too-small"

    describe "REQ-010: full Wine readiness boundary":
        it "should distinguish controlled hello.exe readiness from full Wine readiness":
            val hello_gates = "process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified async=verified nt_bridge=verified"
            expect wine_substrate_hello_exe_gate(hello_gates) == "ready"
            expect wine_substrate_full_wine_gate(hello_gates) == "blocked-missing-renderer"

        it "should require all tracked Wine substrate rows for the full Wine gate":
            val gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            expect wine_substrate_full_wine_gate(gates) == "ready"

    describe "REQ-011: Wine process-session handoff":
        it "should keep arbitrary exe sessions blocked until full Wine readiness":
            val hello_gates = "process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified async=verified nt_bridge=verified"
            val arbitrary = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\"), hello_gates)
            expect arbitrary.ok == false
            expect arbitrary.error == "blocked-missing-renderer"

        it "should emit a dry-run handoff for the controlled hello path":
            val hello_gates = "process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("hello.exe", [], "C:\\"), hello_gates)
            val handoff = wine_process_launch_handoff(plan, true)
            expect handoff.ok == true
            expect handoff.substrate_readiness == "controlled-hello-ready"
            expect handoff.status == "dry-run-ready"

    describe "REQ-012: controlled Wine process-session execution":
        it "should execute only the verified hello.exe process session":
            val hello_gates = "process=verified exec_env=verified vm=verified host=verified posix=verified pthread=verified dynload=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("hello.exe", [], "C:\\"), hello_gates)
            val execution = wine_process_execute_controlled_hello(plan)
            expect execution.ok == true
            expect execution.stdout == "Hello from SimpleOS Wine\n"
            expect execution.exit_code == 0
            expect execution.status == "executed"

        it "should not treat full-Wine planning as arbitrary executable support":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val execution = wine_process_execute_controlled_hello(plan)
            expect execution.ok == false
            expect execution.error == "unsupported-process-session"

    describe "REQ-013: arbitrary process image validation boundary":
        it "should validate PE image structure before future arbitrary execution":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val image = wine_process_validate_full_image(plan, wine_known_hello_exe_fixture_bytes())
            expect image.ok == true
            expect image.machine == "x86_64"
            expect image.subsystem == "console"
            expect image.status == "image-validated"

        it "should reject malformed images at the process-session boundary":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val image = wine_process_validate_full_image(plan, _zero_pe_bytes(0))
            expect image.ok == false
            expect image.error == "too-small"

    describe "REQ-014: arbitrary process import inspection boundary":
        it "should inspect bounded first-import DLL and symbols before future binding":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val imports = wine_process_inspect_full_imports(plan, wine_known_hello_exe_fixture_bytes(), 8)
            expect imports.ok == true
            expect imports.dll_name == "KERNEL32.dll"
            expect imports.symbol_count == 3
            expect imports.symbols[0] == "GetStdHandle"
            expect imports.symbols[1] == "WriteFile"
            expect imports.symbols[2] == "ExitProcess"
            expect imports.status == "imports-inspected"

        it "should keep import inspection bounded":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val imports = wine_process_inspect_full_imports(plan, wine_known_hello_exe_fixture_bytes(), 0)
            expect imports.ok == false
            expect imports.error == "invalid-symbol-limit"

    describe "REQ-015: bounded process import binding plan":
        it "should plan supported KERNEL32 import bindings before execution":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val bindings = wine_process_bind_known_kernel32_imports(plan, wine_known_hello_exe_fixture_bytes(), 8)
            expect bindings.ok == true
            expect bindings.dll_name == "kernel32.dll"
            expect bindings.call_sequence == "GetStdHandle WriteFile ExitProcess"
            expect bindings.binding_count == 3
            expect bindings.status == "imports-bound"

        it "should reject unbounded or incomplete import binding attempts":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val bindings = wine_process_bind_known_kernel32_imports(plan, wine_known_hello_exe_fixture_bytes(), 1)
            expect bindings.ok == false
            expect bindings.error == "import-thunk-limit-exceeded"

    describe "REQ-016: guarded process import thunk patch plan":
        it "should produce import-thunk evidence only after supported binding":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val patches = wine_process_plan_import_thunk_patches(plan, wine_known_hello_exe_fixture_bytes(), 8)
            expect patches.ok == true
            expect patches.patch_count == 3
            expect (patches.evidence).contains("import-thunks-bound")
            expect (patches.evidence).contains("import-thunk-table-valid")
            expect (patches.evidence).contains("import-thunk-symbols-resolved")
            expect (patches.evidence).contains("import-thunk-bindings-match")
            expect (patches.evidence).contains("import-thunk-iat-guarded")
            expect patches.status == "thunk-patch-planned"

        it "should reject thunk patch planning when binding is rejected":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val patches = wine_process_plan_import_thunk_patches(plan, wine_known_hello_exe_fixture_bytes(), 1)
            expect patches.ok == false
            expect patches.error == "import-thunk-limit-exceeded"

    describe "REQ-017: process CPU dispatch preflight":
        it "should require process loader evidence and CPU dispatch evidence before future execution":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val preflight = wine_process_cpu_dispatch_preflight(plan, wine_known_hello_exe_fixture_bytes(), 8, wine_cpu_execution_evidence_text(wine_cpu_execution_evidence_all_ready()))
            expect preflight.ok == true
            expect (preflight.evidence).contains("import-thunk-bytes-written")
            expect (preflight.evidence).contains("import-thunk-iat-guarded")
            expect (preflight.evidence).contains("x86_64-dispatch")
            expect (preflight.evidence).contains("process-image-mapped")
            expect (preflight.evidence).contains("os-vma")
            expect (preflight.evidence).contains("process-vma-write-window")
            expect (preflight.evidence).contains("process-vma-rx-restored")
            expect (preflight.evidence).contains("no-host-code-jump")
            expect preflight.status == "cpu-preflight-ready"

        it "should block process CPU dispatch preflight when CPU evidence is missing":
            val full_gates = "process=verified exec_env=verified vm=verified renderer=verified user32=verified gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified pthread=verified dynload=verified audio=verified fonts=verified input=verified pe_loader=verified async=verified nt_bridge=verified"
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), full_gates)
            val preflight = wine_process_cpu_dispatch_preflight(plan, wine_known_hello_exe_fixture_bytes(), 8, "")
            expect preflight.ok == false
            expect preflight.error == "missing-thread-context"
