use common.wine_ntdll_process_info.{wine_ntdll_execute_process_info_with_peb_teb, wine_ntdll_execute_process_info_with_peb_teb_writes}
use common.wine_kernel32_critical_section.{wine_kernel32_critical_section_table_new}
use common.wine_peb_teb.{wine_peb_teb_init_default, wine_peb_teb_init_gate, wine_peb_teb_init_with_loader_lock, wine_peb_teb_layout_write_plan, wine_peb_teb_memory_write_gate}
use common.wine_vm_adapter.{WineVmSpace, wine_vm_commit, wine_vm_process_space_new, wine_vm_reserve_fixed}

fn _classes() -> [text]:
    ["ProcessBasicInformation", "ProcessImageInformation", "ThreadBasicInformation"]

fn _loader_lock_symbols() -> [text]:
    ["InitializeCriticalSection", "EnterCriticalSection", "LeaveCriticalSection", "DeleteCriticalSection"]

fn _commit_fixed(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineVmSpace:
    val reserved = wine_vm_reserve_fixed(space, base, size)
    if not reserved.ok:
        return reserved.space
    val committed = wine_vm_commit(reserved.space, reserved.region.base, perms)
    committed.space

fn _startup_write_space() -> WineVmSpace:
    var space = wine_vm_process_space_new(10, 30, "pid fs ipc net capability")
    space = _commit_fixed(space, 0x7ffdc000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffdd000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffde000, 0x1000, "rw")
    _commit_fixed(space, 0x7ffdf000, 0x1000, "rw")

describe "SimpleOS Wine PEB/TEB startup evidence":
    describe "REQ-018: bounded known-console process dispatch plan":
        it "should validate PEB/TEB/TLS evidence before NTDLL process-info handoff":
            val init = wine_peb_teb_init_gate(wine_peb_teb_init_default())
            expect init.ok == true
            expect init.operations == "PEB TEB TLS ProcessParameters"

            val result = wine_ntdll_execute_process_info_with_peb_teb(["NtQueryInformationProcess", "NtQueryInformationThread"], _classes(), wine_peb_teb_init_default())
            expect result.ok == true
            expect result.classes == "ProcessBasicInformation ProcessImageInformation ThreadBasicInformation"
            expect result.peb_address == 0x7ffdf000
            expect result.teb_address == 0x7ffde000

        it "should require loader-lock sequencing around PEB/TEB startup evidence":
            val result = wine_peb_teb_init_with_loader_lock(wine_peb_teb_init_default(), _loader_lock_symbols(), wine_kernel32_critical_section_table_new())
            expect result.ok == true
            expect result.operations == "PEB TEB TLS ProcessParameters LoaderLock"

        it "should require writable VM mappings before PEB/TEB startup mutation":
            val result = wine_peb_teb_memory_write_gate(wine_peb_teb_init_default(), _startup_write_space())
            expect result.ok == true
            expect result.state == "ready"
            expect result.write_count == 4
            expect (result.operations).contains("PEBWrite")
            expect (result.operations).contains("ProcessParametersWrite")

        it "should compose PEB/TEB memory-write readiness before NTDLL process-info handoff":
            val init = wine_peb_teb_init_default()
            val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
            val result = wine_ntdll_execute_process_info_with_peb_teb_writes(["NtQueryInformationProcess", "NtQueryInformationThread"], _classes(), init, writes)
            expect result.ok == true
            expect (result.operations).contains("PEBWrite")
            expect (result.operations).contains("NtQueryInformationProcess")
            expect result.peb_address == 0x7ffdf000

        it "should plan concrete x64 PEB/TEB startup layout writes":
            val init = wine_peb_teb_init_default()
            val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
            val plan = wine_peb_teb_layout_write_plan(init, writes)
            expect plan.ok == true
            expect plan.record_count == 6
            expect plan.records[3].field_name == "ProcessEnvironmentBlock"
            expect plan.records[3].address == 0x7ffde060
            expect plan.records[4].field_name == "ImageBaseAddress"
            expect plan.records[5].field_name == "ProcessParameters"