use common.pe_coff_header.{pe_rva_to_file_offset}
use common.wine_hello_fixture.{wine_known_hello_exe_fixture_bytes}
use common.wine_peb_teb.{wine_peb_teb_apply_layout_byte_writes, wine_peb_teb_init_default, wine_peb_teb_layout_byte_writes, wine_peb_teb_layout_write_plan, wine_peb_teb_memory_write_gate}
use common.wine_process_session.{
    wine_process_apply_known_kernel32_thunk_patches_in_vma,
    wine_process_apply_known_kernel32_thunk_patches_in_vma_with_peb_teb_vm_writes,
    wine_process_session_plan,
    wine_process_session_request_new
}
use common.wine_vm_adapter.{WineVmSpace, wine_vm_commit, wine_vm_process_space_new, wine_vm_reserve_fixed}

fn _full_gates() -> text:
    "process=verified exec_env=verified vm=verified renderer=verified user32=verified " +
        "gdi32=verified kernel32_core=verified host=verified posix=verified registry=verified " +
        "pthread=verified dynload=verified audio=verified fonts=verified input=verified " +
        "pe_loader=verified async=verified nt_bridge=verified"

fn _read_u64_le(data: [u8], offset: i64) -> i64:
    var value = 0
    var multiplier = 1
    var i = 0
    while i < 8:
        value = value + (data[offset + i] * multiplier)
        multiplier = multiplier * 256
        i = i + 1
    value

fn _commit_fixed(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineVmSpace:
    val reserved = wine_vm_reserve_fixed(space, base, size)
    if not reserved.ok:
        return reserved.space
    val committed = wine_vm_commit(reserved.space, reserved.region.base, perms)
    committed.space

fn _startup_write_space() -> WineVmSpace:
    var space = wine_vm_process_space_new(10, 30, "pid fs ipc net capability")
    space = _commit_fixed(space, 0x7ffdc000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffdd000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffde000, 0x1000, "rw")
    _commit_fixed(space, 0x7ffdf000, 0x1000, "rw")

fn _ready_vm_writes():
    val init = wine_peb_teb_init_default()
    val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
    val layout = wine_peb_teb_layout_write_plan(init, writes)
    val bytes = wine_peb_teb_layout_byte_writes(layout)
    wine_peb_teb_apply_layout_byte_writes(_startup_write_space(), bytes)

describe "SimpleOS Wine VMA thunk writes":
    describe "REQ-027: bounded process VMA thunk patch window":
        it "should patch known thunk slots through a bounded process VMA write window":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_apply_known_kernel32_thunk_patches_in_vma(plan, wine_known_hello_exe_fixture_bytes(), 8)
            val get_std_handle_offset = pe_rva_to_file_offset(result.patched_image, 0x2060)
            val write_file_offset = pe_rva_to_file_offset(result.patched_image, 0x2068)
            val exit_process_offset = pe_rva_to_file_offset(result.patched_image, 0x2070)
            expect result.ok == true
            expect result.patched_count == 3
            expect _read_u64_le(result.patched_image, get_std_handle_offset) == 0x120000 + 5
            expect _read_u64_le(result.patched_image, write_file_offset) == 0x120000 + 6
            expect _read_u64_le(result.patched_image, exit_process_offset) == 0x120000 + 7
            expect (result.evidence).contains("process-image-mapped")
            expect (result.evidence).contains("process-vma-write-window")
            expect (result.evidence).contains("process-vma-write-enabled")
            expect (result.evidence).contains("process-vma-rx-restored")
            expect (result.evidence).contains("no-host-code-jump")
            expect result.status == "vma-thunk-patches-applied"

        it "should reject VMA thunk writes before record planning passes":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_apply_known_kernel32_thunk_patches_in_vma(plan, wine_known_hello_exe_fixture_bytes(), 0)
            expect result.ok == false
            expect result.error == "invalid-symbol-limit"
            expect result.patched_image.len() == 0
            expect result.mapped_base == 0
            expect result.mapped_size == 0
            expect result.patched_count == 0
            expect (result.evidence).contains("vma-thunk-patches-blocked")
            expect (result.evidence).contains("no-vma-thunk-written")
            expect (result.evidence).contains("no-arbitrary-execution")

        it "should require PEB/TEB VM byte-write readback before VMA thunk writes":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val init = wine_peb_teb_init_default()
            val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
            val layout = wine_peb_teb_layout_write_plan(init, writes)
            val bytes = wine_peb_teb_layout_byte_writes(layout)
            val vm_writes = wine_peb_teb_apply_layout_byte_writes(_startup_write_space(), bytes)
            val result = wine_process_apply_known_kernel32_thunk_patches_in_vma_with_peb_teb_vm_writes(plan, wine_known_hello_exe_fixture_bytes(), 0x400000, 0x400000, "native-module-open tls-callback", 8, vm_writes)

            expect result.ok == true
            expect result.patched_count == 3
            expect (result.evidence).contains("peb-teb-vm-writes-ready")
            expect (result.evidence).contains("tls-callback-dispatch-empty")
            expect (result.evidence).contains("process-vma-write-window")
            expect (result.evidence).contains("no-host-code-jump")
            expect result.status == "vma-thunk-patches-applied"

        it "should reject VM-gated VMA thunk writes before record planning passes without patched image":
            val plan = wine_process_session_plan(wine_process_session_request_new("game.exe", [], "C:\\Games"), _full_gates())
            val result = wine_process_apply_known_kernel32_thunk_patches_in_vma_with_peb_teb_vm_writes(plan, wine_known_hello_exe_fixture_bytes(), 0x400000, 0x400000, "native-module-open tls-callback", 0, _ready_vm_writes())

            expect result.ok == false
            expect result.error == "invalid-symbol-limit"
            expect result.patched_image.len() == 0
            expect result.mapped_base == 0
            expect result.mapped_size == 0
            expect result.patched_count == 0
            expect (result.evidence).contains("peb-teb-vm-writes-ready")
            expect (result.evidence).contains("vma-thunk-patches-blocked")
            expect (result.evidence).contains("no-vma-thunk-written")
            expect (result.evidence).contains("no-arbitrary-execution")
            expect result.status == "blocked"