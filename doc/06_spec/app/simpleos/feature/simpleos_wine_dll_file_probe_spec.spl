use common.wine_dll_file_probe.{wine_dll_probe_candidate_bytes, wine_dll_probe_file}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn _dll_bytes() -> [u8]:
    var data = _zero_bytes(1024)
    data[0] = 0x4d
    data[1] = 0x5a
    data = _put_u32_le(data, 0x3c, 0x80)
    data[0x80] = 0x50
    data[0x81] = 0x45
    data = _put_u16_le(data, 0x84, 0x8664)
    data = _put_u16_le(data, 0x86, 1)
    data = _put_u16_le(data, 0x94, 0xf0)
    data = _put_u16_le(data, 0x96, 0x2022)
    data = _put_u16_le(data, 0x98, 0x20b)
    data = _put_u32_le(data, 0x98 + 0x10, 0x1200)
    data = _put_u32_le(data, 0x98 + 0x38, 0x5000)
    data = _put_u32_le(data, 0x98 + 0x3c, 0x200)
    data

describe "REQ-046 SimpleOS Wine DLL file probe":
    it "probes DLL search candidates and validates file-backed bytes before mapping":
        val files = [
            wine_dll_probe_file("D:\\GameBin\\gameaudio.dll", _dll_bytes()),
            wine_dll_probe_file("C:\\Games\\other.dll", _dll_bytes())
        ]
        val result = wine_dll_probe_candidate_bytes("gameaudio.dll", "C:\\Games", "C:\\Users\\Player", ["D:\\GameBin"], ["kernel32.dll"], files)
        expect(result.ok).to_equal(true)
        expect(result.selected_path).to_equal("D:\\GameBin\\gameaudio.dll")
        expect(result.status).to_equal("dll-file-probe-validated")
        expect(result.evidence).to_contain("dll-search-order-modeled")
        expect(result.evidence).to_contain("dll-file-probe-validated")
        expect(result.evidence).to_contain("file-backed-dll-bytes")
        expect(result.evidence).to_contain("no-persistent-dll-view")
        expect(result.evidence).to_contain("no-arbitrary-execution")
