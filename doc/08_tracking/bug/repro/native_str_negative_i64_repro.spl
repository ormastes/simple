# native-build codegen bug: str() of a negative i64 corrupts the value.
#
#   bin/simple native-build --runtime-bundle core-c-bootstrap \
#       --entry doc/08_tracking/bug/repro/native_str_negative_i64_repro.spl \
#       --output /tmp/r && /tmp/r
#   bin/simple run doc/08_tracking/bug/repro/native_str_negative_i64_repro.spl   # baseline
#
# native-build (buggy): every negative prints as 0x1FFFFFFFFFFFFFFF-masked
#   -1 -> 2305843009213693951, -5 -> ...3947, -7 -> ...3945
# interpreter: correct (-1, -5, -7).
# NOTE: `idx < 0` still branches correctly, so the corruption is display/str-only.
fn ret_neg() -> i64:
    return -1

fn sub_to_neg(a: i64, b: i64) -> i64:
    return a - b

fn main():
    val lit: i64 = -1
    println("literal_local=" + str(lit))
    println("ret_neg=" + str(ret_neg()))
    println("sub_3_minus_10=" + str(sub_to_neg(3, 10)))
    var idx = -1
    if idx < 0:
        println("idx<0 branch=TAKEN (comparison OK)")
    else:
        println("idx<0 branch=NOT taken (BUG)")
