# Rendering Divergence Normalization Report
#
# Generated documentation: rendering divergence root causes and normalization
# strategies for pixel-level WM visual consistency across backends.
#
# This file is referenced by the wm-pixel-consistency pipeline and provides
# the research findings (AC-1, AC-7) as structured Simple code documentation.
#
# To regenerate: run wm_consistency_runner.consistency_report_to_markdown()
# with a fresh ConsistencyReport and write the output to this path.

use os.compositor.wm_consistency_runner.{run_consistency_check, consistency_report_to_markdown}
use os.compositor.wm_scene.{standard_wm_scene}
use os.compositor.tolerance_profile.{profile_wm_default}

# ============================================================================
# Report Generation
# ============================================================================

fn generate_divergence_report() -> text:
    """Generate the rendering divergence normalization report.

    Renders a standard WM scene through both backends, runs the
    consistency check, and produces a comprehensive markdown report
    documenting:
    - Industry comparison methodology (YIQ, pixelmatch, Chromium, Playwright)
    - Rendering divergence root causes (font, AA, color space, blur, gradient)
    - Normalization strategies (disable LCD text, force sRGB, tolerance profiles)
    """
    val scene = standard_wm_scene(800, 600)
    val profile = profile_wm_default()
    val report = run_consistency_check(scene, profile)
    consistency_report_to_markdown(report)

fn generate_and_save_report(output_path: text) -> bool:
    """Generate and save the divergence report to a file."""
    val md = generate_divergence_report()
    extern fn rt_file_write_text(path: text, content: text) -> bool
    rt_file_write_text(output_path, md)

# ============================================================================
# Divergence Categories (Structured Data)
# ============================================================================

struct DivergenceCategory:
    """A category of rendering divergence between backends."""
    name: text
    severity: text    # "high", "medium", "low"
    description: text
    normalization: text

fn known_divergence_categories() -> [DivergenceCategory]:
    """Return all known rendering divergence categories with normalization strategies."""
    [
        DivergenceCategory(
            name: "Font Rasterization",
            severity: "high",
            description: "Different font engines (Skia vs bitmap) produce different glyph shapes, AA patterns, and subpixel positioning.",
            normalization: "Use identical font rasterizer in both paths, or use tolerance profiles with relaxed text region thresholds (threshold=10, yiq=0.35)."
        ),
        DivergenceCategory(
            name: "Anti-Aliasing",
            severity: "medium",
            description: "Chromium uses multi-sample AA via Skia with optional subpixel (LCD) rendering. Compositor uses simple alpha blending.",
            normalization: "Disable LCD text in Electron (--disable-lcd-text), exclude AA pixels from mismatch count using Vyshniauskas detector."
        ),
        DivergenceCategory(
            name: "Color Space",
            severity: "medium",
            description: "Electron renders in host display profile (Display P3 on macOS). Compositor uses raw sRGB ARGB.",
            normalization: "Force sRGB in Electron (--force-color-profile=srgb) to match compositor color space."
        ),
        DivergenceCategory(
            name: "Blur Quality",
            severity: "low",
            description: "Compositor uses 5-pass HVHVH box blur approximation. Chromium uses true Gaussian blur via Skia.",
            normalization: "Use tolerance profiles with relaxed blur region thresholds (threshold=14, yiq=0.45)."
        ),
        DivergenceCategory(
            name: "Gradient Interpolation",
            severity: "low",
            description: "Compositor uses integer arithmetic for gradients. Chromium uses floating-point. Causes +/-1 rounding differences.",
            normalization: "Use gradient region tolerance (threshold=6) to absorb integer rounding differences."
        ),
        DivergenceCategory(
            name: "Geometry Snapping",
            severity: "low",
            description: "Chromium snaps sub-pixel geometry to device pixels differently than compositor's integer coordinates.",
            normalization: "Render at 2x DPI where subpixel differences are less visible."
        )
    ]
