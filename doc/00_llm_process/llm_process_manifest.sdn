# Canonical LLM process inventory for `bin/simple llm-process-gen`.

skills:
  - id: codex_architecture
    owner: codex
    path: .codex/skills/architecture/SKILL.md
  - id: codex_coding
    owner: codex
    path: .codex/skills/coding/SKILL.md
  - id: codex_design
    owner: codex
    path: .codex/skills/design/SKILL.md
  - id: codex_impl
    owner: codex
    path: .codex/skills/impl/SKILL.md
  - id: codex_mdsoc_architecture_writing
    owner: codex
    path: .codex/skills/mdsoc-architecture-writing/SKILL.md
  - id: codex_refactor
    owner: codex
    path: .codex/skills/refactor/SKILL.md
  - id: codex_release
    owner: codex
    path: .codex/skills/release/SKILL.md
  - id: codex_research
    owner: codex
    path: .codex/skills/research/SKILL.md
  - id: codex_simple_ui
    owner: codex
    path: .codex/skills/simple-ui/SKILL.md
  - id: codex_sync
    owner: codex
    path: .codex/skills/sync/SKILL.md
  - id: codex_system_test
    owner: codex
    path: .codex/skills/system_test/SKILL.md
  - id: codex_t32q
    owner: codex
    path: .codex/skills/t32q/SKILL.md
  - id: codex_verify
    owner: codex
    path: .codex/skills/verify/SKILL.md
  - id: gemini_sync
    owner: gemini
    path: .gemini/commands/sync.toml

commands:
  - id: research
    owner: claude
    command: /research
  - id: design
    owner: claude
    command: /design
  - id: impl
    owner: claude
    command: /impl
  - id: verify
    owner: claude
    command: /verify
  - id: release
    owner: claude
    command: /release
  - id: sync
    owner: all
    command: /sync

subagents:
  - id: pipeline_lead
    owner: llm_process
    purpose: request refinement and final synthesis

tools:
  - id: simple_cli
    type: cli
    name: bin/simple
    purpose: local command execution
  - id: llm_process_gen
    type: cli
    name: bin/simple llm-process-gen
    purpose: managed LLM process generation

expert_routes:
  - id: feature_expert
    kind: feature
    template: doc/00_llm_process/template/feature_skill.md
  - id: layer_expert
    kind: layer
    template: doc/00_llm_process/template/layer_skill.md

# generated_files record fields:
# - id, kind, owner, stage, source_path, target_path, mode
#
# Allowed mode values:
# - managed: copy source text as marker-managed output
# - gemini_toml_skill: render a Gemini TOML command/skill as markdown
# - tools_sdn: render standard skill tools metadata from the manifest
# - claude_lib_tools_sdn: render Claude helper skill tools metadata
# - skeleton: create the target only when missing; existing targets are durable
generated_files:
  - id: codex_architecture_skill
    kind: skill
    owner: codex
    stage: architecture
    source_path: .codex/skills/architecture/SKILL.md
    target_path: doc/00_llm_process/skill_command/skills/codex/architecture/skill.md
    mode: managed
  - id: codex_coding_skill
