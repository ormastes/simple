extern fn stdout_write(data: text)
extern fn stdout_flush()

use app.mcp_t32.json_helpers
use app.mcp_t32.protocol

fn say(s: text):
    stdout_write(s + "\n")
    stdout_flush()

fn main():
    val msg = t32_read_stdin_message()
    say("msg-len=" + str(msg.len()))
    say("msg=" + msg)
    say("method=" + t32_extract_field(msg, "method"))
    say("id=" + t32_extract_id(msg))
