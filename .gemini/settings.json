{
  "context": {
    "fileName": ["GEMINI.md", "CLAUDE.md"]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "simple-mcp": {
      "command": "bin/simple_mcp_server",
      "args": [],
      "env": {
        "SIMPLE_LIB": "src",
        "SIMPLE_LOG": "error"
      }
    },
    "simple-lsp-mcp": {
      "command": "bin/simple_lsp_mcp_server",
      "args": [],
      "env": {
        "SIMPLE_LIB": "src",
        "SIMPLE_LOG": "error"
      }
    },
    "chrome-mcp": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/chrome-mcp"]
    },
    "stitch-mcp": {
      "command": "npx",
      "args": ["-y", "stitch-mcp"]
    }
  }
}
