{
  "context": {
    "fileName": ["GEMINI.md", "CLAUDE.md"]
  },
  "hooks": {
  },
  "mcpServers": {
    "simple-mcp": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/home/ormastes/dev/pub/simple' && exec node '/home/ormastes/dev/pub/simple/bin/mcp_stdio_bridge.js' -- '/home/ormastes/dev/pub/simple/build/bootstrap/mcp-package/simple_mcp_server'"],
      "env": {
