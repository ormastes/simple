{
  "context": {
    "fileName": ["GEMINI.md", "CLAUDE.md"]
  },
  "hooks": {
  },
  "mcpServers": {
    "simple-pipe-mcp": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/Users/ormastes/simple' && exec node '/Users/ormastes/simple/bin/mcp_stdio_bridge.js' -- '/Users/ormastes/simple/bin/simple' run '/Users/ormastes/simple/src/app/mcp/main.spl'"],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error",
        "SIMPLE_LIB": "/Users/ormastes/simple/src"
      }
    },
    "simple-mcp": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/Users/ormastes/simple' && exec node '/Users/ormastes/simple/bin/mcp_stdio_bridge.js' -- '/Users/ormastes/simple/bin/simple' run '/Users/ormastes/simple/src/app/mcp/main.spl'"],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error",
        "SIMPLE_LIB": "/Users/ormastes/simple/src"
      }
    },
    "simple-lsp-mcp": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/Users/ormastes/simple' && SIMPLE_EXECUTION_MODE=interpreter exec node '/Users/ormastes/simple/bin/mcp_stdio_bridge.js' -- '/Users/ormastes/simple/bin/simple' run '/Users/ormastes/simple/src/app/simple_lsp_mcp/main.spl'"],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error",
        "SIMPLE_LIB": "/Users/ormastes/simple/src"
      }
    },
    "stitch": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/Users/ormastes/simple' && exec node '/Users/ormastes/simple/bin/mcp_stdio_bridge.js' -- node '/Users/ormastes/simple/bin/codex_stitch_mcp.js'"]
    }
  }
}
