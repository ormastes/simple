{
  "context": {
    "fileName": ["GEMINI.md", "CLAUDE.md"]
  },
  "hooks": {
  },
  "mcpServers": {
    "simple-mcp": {
      "command": "bin/simple_mcp_server",
      "args": [],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error"
      }
    },
    "simple-lsp-mcp": {
      "command": "bin/simple_lsp_mcp_server",
      "args": [],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error"
      }
    },
    "stitch": {
      "command": "bash",
      "args": ["-lc", "if [ -f ~/.security/env.sh ]; then . ~/.security/env.sh; fi; exec npx -y @_davideast/stitch-mcp proxy"]
    }
  }
}
