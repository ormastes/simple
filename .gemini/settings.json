        "RUST_LOG": "error",
        "SIMPLE_LIB": "/home/ormastes/dev/pub/simple/src"
      }
    },
    "simple-lsp-mcp": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/home/ormastes/dev/pub/simple' && exec node '/home/ormastes/dev/pub/simple/bin/mcp_stdio_bridge.js' -- '/home/ormastes/dev/pub/simple/bin/release/linux-x86_64/simple_lsp_mcp_server'"],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error",
        "SIMPLE_LIB": "/home/ormastes/dev/pub/simple/src"
      }
    },
    "stitch": {
      "command": "/bin/sh",
      "args": ["-lc", "cd '/home/ormastes/dev/pub/simple' && exec node '/home/ormastes/dev/pub/simple/bin/mcp_stdio_bridge.js' -- node '/home/ormastes/dev/pub/simple/bin/codex_stitch_mcp.js'"]
    }
