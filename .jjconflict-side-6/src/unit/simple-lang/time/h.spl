# Unit: H
# Kind: Time
# Symbol: h
# Canonical scale: 3600.0 s

class H:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: H) -> H: H(value: self.value + other.value)
    fn sub(other: H) -> H: H(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "h"
    static fn scale_to_base() -> f64: 3600.0
    static fn base_unit() -> text: "s"
    static fn zero() -> H: H(value: 0.0)

export H
