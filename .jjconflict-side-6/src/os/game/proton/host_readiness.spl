# Proton Host Readiness
# Tracks readiness of Proton stack components for SimpleOS game compatibility.

class ProtonComponent:
    name: text
    version: text
    status: text
    blocker: text

impl ProtonComponent:
    static fn ready(name: text, ver: text) -> ProtonComponent:
        ProtonComponent(
            name: name,
            version: ver,
            status: "ready",
            blocker: ""
        )

    static fn partial(name: text, ver: text, blocker: text) -> ProtonComponent:
        ProtonComponent(
            name: name,
            version: ver,
            status: "partial",
            blocker: blocker
        )

    static fn missing(name: text) -> ProtonComponent:
        ProtonComponent(
            name: name,
            version: "",
            status: "missing",
            blocker: name + " not found"
        )

    static fn blocked(name: text, reason: text) -> ProtonComponent:
        ProtonComponent(
            name: name,
            version: "",
            status: "blocked",
            blocker: reason
        )

    me is_usable() -> bool:
        self.status == "ready" or self.status == "partial"

    me is_blocked() -> bool:
        self.status == "blocked"

    me summary() -> text:
        self.name + " status=" + self.status + " ver=" + self.version + " blocker=" + self.blocker


class ProtonHostReport:
    wine_status: text
    wine_version: text
    wine_blocker: text
    dxvk_status: text
    dxvk_version: text
    dxvk_blocker: text
    vkd3d_status: text
    vkd3d_version: text
    vkd3d_blocker: text
    faudio_status: text
    faudio_version: text
    faudio_blocker: text
    media_foundation_status: text
    media_foundation_blocker: text
    steam_api_status: text
    steam_api_version: text
    steam_api_blocker: text
    overlay_status: text
    overlay_blocker: text

impl ProtonHostReport:
    static fn create() -> ProtonHostReport:
        ProtonHostReport(
            wine_status: "missing",
            wine_version: "",
            wine_blocker: "wine not found",
            dxvk_status: "missing",
            dxvk_version: "",
            dxvk_blocker: "dxvk not found",
            vkd3d_status: "missing",
            vkd3d_version: "",
            vkd3d_blocker: "vkd3d not found",
            faudio_status: "missing",
            faudio_version: "",
            faudio_blocker: "faudio not found",
            media_foundation_status: "missing",
            media_foundation_blocker: "media foundation not found",
            steam_api_status: "missing",
            steam_api_version: "",
            steam_api_blocker: "steam api not found",
            overlay_status: "missing",
            overlay_blocker: "overlay not found"
        )

    me set_wine(status: text, ver: text, blocker: text) -> text:
        self.wine_status = status
        self.wine_version = ver
        self.wine_blocker = blocker
        "ok"

    me set_dxvk(status: text, ver: text, blocker: text) -> text:
        self.dxvk_status = status
        self.dxvk_version = ver
        self.dxvk_blocker = blocker
        "ok"

    me set_vkd3d(status: text, ver: text, blocker: text) -> text:
        self.vkd3d_status = status
        self.vkd3d_version = ver
        self.vkd3d_blocker = blocker
        "ok"

    me set_faudio(status: text, ver: text, blocker: text) -> text:
        self.faudio_status = status
        self.faudio_version = ver
        self.faudio_blocker = blocker
        "ok"

    me set_media_foundation(status: text, blocker: text) -> text:
        self.media_foundation_status = status
        self.media_foundation_blocker = blocker
        "ok"

    me set_steam_api(status: text, ver: text, blocker: text) -> text:
        self.steam_api_status = status
        self.steam_api_version = ver
        self.steam_api_blocker = blocker
        "ok"

    me set_overlay(status: text, blocker: text) -> text:
        self.overlay_status = status
        self.overlay_blocker = blocker
        "ok"

    me ready_count() -> i64:
        var count: i64 = 0
        if self.wine_status == "ready":
            count = count + 1
        if self.dxvk_status == "ready":
            count = count + 1
        if self.vkd3d_status == "ready":
            count = count + 1
        if self.faudio_status == "ready":
            count = count + 1
        if self.media_foundation_status == "ready":
            count = count + 1
        if self.steam_api_status == "ready":
            count = count + 1
        if self.overlay_status == "ready":
            count = count + 1
        count

    me blocked_count() -> i64:
        var count: i64 = 0
        if self.wine_status == "blocked":
            count = count + 1
        if self.dxvk_status == "blocked":
            count = count + 1
        if self.vkd3d_status == "blocked":
            count = count + 1
        if self.faudio_status == "blocked":
            count = count + 1
        if self.media_foundation_status == "blocked":
            count = count + 1
        if self.steam_api_status == "blocked":
            count = count + 1
        if self.overlay_status == "blocked":
            count = count + 1
        count

    me is_game_viable() -> bool:
        val wine_ok = self.wine_status == "ready" or self.wine_status == "partial"
        val dxvk_ok = self.dxvk_status == "ready" or self.dxvk_status == "partial"
        wine_ok and dxvk_ok

    me report() -> text:
        "wine=" + self.wine_status + " dxvk=" + self.dxvk_status +
            " vkd3d=" + self.vkd3d_status + " faudio=" + self.faudio_status +
            " mf=" + self.media_foundation_status + " steam_api=" + self.steam_api_status +
            " overlay=" + self.overlay_status +
            " ready=" + self.ready_count().to_text() +
            " viable=" + self.is_game_viable().to_text()


class MultilibReadiness:
    has_32bit_loader: bool
    has_32bit_libc: bool
    has_32bit_vulkan: bool
    has_32bit_opengl: bool
    has_32bit_audio: bool
    has_32bit_input: bool
    wow64_mode: text
    blocker: text

impl MultilibReadiness:
    static fn create() -> MultilibReadiness:
        MultilibReadiness(
            has_32bit_loader: false,
            has_32bit_libc: false,
            has_32bit_vulkan: false,
            has_32bit_opengl: false,
            has_32bit_audio: false,
            has_32bit_input: false,
            wow64_mode: "unsupported",
            blocker: "32-bit userland not configured"
        )

    static fn wow64() -> MultilibReadiness:
        MultilibReadiness(
            has_32bit_loader: true,
            has_32bit_libc: true,
            has_32bit_vulkan: false,
            has_32bit_opengl: false,
            has_32bit_audio: false,
            has_32bit_input: false,
            wow64_mode: "wow64",
            blocker: ""
        )

    static fn unsupported(reason: text) -> MultilibReadiness:
        MultilibReadiness(
            has_32bit_loader: false,
            has_32bit_libc: false,
            has_32bit_vulkan: false,
            has_32bit_opengl: false,
            has_32bit_audio: false,
            has_32bit_input: false,
            wow64_mode: "unsupported",
            blocker: reason
        )

    me is_usable() -> bool:
        self.has_32bit_loader and self.has_32bit_libc

    me coverage_count() -> i64:
        var count: i64 = 0
        if self.has_32bit_loader:
            count = count + 1
        if self.has_32bit_libc:
            count = count + 1
        if self.has_32bit_vulkan:
            count = count + 1
        if self.has_32bit_opengl:
            count = count + 1
        if self.has_32bit_audio:
            count = count + 1
        if self.has_32bit_input:
            count = count + 1
        count

    me summary() -> text:
        "wow64_mode=" + self.wow64_mode +
            " loader=" + self.has_32bit_loader.to_text() +
            " libc=" + self.has_32bit_libc.to_text() +
            " vulkan=" + self.has_32bit_vulkan.to_text() +
            " opengl=" + self.has_32bit_opengl.to_text() +
            " audio=" + self.has_32bit_audio.to_text() +
            " input=" + self.has_32bit_input.to_text() +
            " coverage=" + self.coverage_count().to_text() +
            " blocker=" + self.blocker


class CrashLogContract:
    enabled: bool
    log_path: text
    max_size_mb: i64
    capture_minidump: bool
    capture_stdout: bool
    capture_stderr: bool
    last_crash_timestamp: i64
    total_crashes: i64

impl CrashLogContract:
    static fn create(path: text, max_mb: i64) -> CrashLogContract:
        CrashLogContract(
            enabled: path != "",
            log_path: path,
            max_size_mb: max_mb,
            capture_minidump: false,
            capture_stdout: false,
            capture_stderr: false,
            last_crash_timestamp: 0,
            total_crashes: 0
        )

    me record_crash(ts: i64) -> i64:
        self.total_crashes = self.total_crashes + 1
        self.last_crash_timestamp = ts
        self.total_crashes

    me is_configured() -> bool:
        self.enabled and self.log_path != "" and self.max_size_mb > 0

    me summary() -> text:
        "enabled=" + self.enabled.to_text() +
            " path=" + self.log_path +
            " max_mb=" + self.max_size_mb.to_text() +
            " crashes=" + self.total_crashes.to_text() +
            " last_ts=" + self.last_crash_timestamp.to_text()


class DxPrefixReadiness:
    prefix_path:           text
    system_libvulkan_path: text
    vkd3d_lib_path:        text
    dxvk_d3d11_lib_path:   text
    vkd3d_ready:           bool
    dxvk_ready:            bool
    leaf:                  text

impl DxPrefixReadiness:
    static fn create() -> DxPrefixReadiness:
        DxPrefixReadiness(
            prefix_path: "",
            system_libvulkan_path: "",
            vkd3d_lib_path: "",
            dxvk_d3d11_lib_path: "",
            vkd3d_ready: false,
            dxvk_ready: false,
            leaf: "structured"
        )

    static fn from_prefix(prefix: text, syslib: text, vkd3d_lib: text, dxvk_lib: text, vkd3d_ok: bool, dxvk_ok: bool) -> DxPrefixReadiness:
        val any_lib = dxvk_lib != "" or vkd3d_lib != "" or syslib != ""
        DxPrefixReadiness(
            prefix_path: prefix,
            system_libvulkan_path: syslib,
            vkd3d_lib_path: vkd3d_lib,
            dxvk_d3d11_lib_path: dxvk_lib,
            vkd3d_ready: vkd3d_ok,
            dxvk_ready: dxvk_ok,
            leaf: if any_lib: "dlopen" else: "structured"
        )

    me is_dlopen_available() -> bool:
        self.leaf == "dlopen"

    me summary() -> text:
        "dx_prefix=" + self.prefix_path +
            " syslib=" + self.system_libvulkan_path +
            " vkd3d=" + self.vkd3d_ready.to_text() +
            " dxvk=" + self.dxvk_ready.to_text() +
            " leaf=" + self.leaf

extern fn rt_file_exists(path: text) -> bool

pub fn dx_prefix_probe() -> DxPrefixReadiness:
    """Probe the local DirectX prefix for build artifacts.

    Uses rt_file_exists (interpreter-safe) to check for prefix libs written
    by scripts/setup/setup-directx-linux.shs. Returns a structured report
    with leaf evidence string ('dlopen' or 'structured').
    """
    val vkd3d_candidate = "build/dx/prefix/lib/libvkd3d.so"
    val dxvk_candidate = "build/dx/prefix/lib/libdxvk_d3d11.so"
    val vkd3d_ok = rt_file_exists(vkd3d_candidate)
    val dxvk_ok = rt_file_exists(dxvk_candidate)
    var syslib = ""
    if syslib == "":
        if rt_file_exists("/usr/lib/x86_64-linux-gnu/libvulkan.so.1"):
            syslib = "/usr/lib/x86_64-linux-gnu/libvulkan.so.1"
    if syslib == "":
        if rt_file_exists("/usr/lib/libvulkan.so.1"):
            syslib = "/usr/lib/libvulkan.so.1"
    if syslib == "":
        if rt_file_exists("/usr/local/lib/libvulkan.so.1"):
            syslib = "/usr/local/lib/libvulkan.so.1"
    val vkd3d_path = if vkd3d_ok: vkd3d_candidate else: ""
    val dxvk_path = if dxvk_ok: dxvk_candidate else: ""
    DxPrefixReadiness.from_prefix(
        "build/dx/prefix",
        syslib,
        vkd3d_path,
        dxvk_path,
        vkd3d_ok,
        dxvk_ok
    )

export DxPrefixReadiness
export dx_prefix_probe


class ProtonPlatformGate:
    host_report: ProtonHostReport
    multilib: MultilibReadiness
    crash_log: CrashLogContract
    dx_prefix: DxPrefixReadiness

impl ProtonPlatformGate:
    static fn create() -> ProtonPlatformGate:
        ProtonPlatformGate(
            host_report: ProtonHostReport.create(),
            multilib: MultilibReadiness.create(),
            crash_log: CrashLogContract.create("", 0),
            dx_prefix: DxPrefixReadiness.create()
        )

    me evaluate() -> text:
        if self.host_report.blocked_count() > 0:
            return "blocked"
        if self.host_report.is_game_viable() and self.multilib.is_usable():
            return "ready"
        "partial"

    me blocker_summary() -> text:
        var parts = ""
        if self.host_report.wine_blocker != "":
            parts = parts + "wine:" + self.host_report.wine_blocker + " "
        if self.host_report.dxvk_blocker != "":
            parts = parts + "dxvk:" + self.host_report.dxvk_blocker + " "
        if self.host_report.vkd3d_blocker != "":
            parts = parts + "vkd3d:" + self.host_report.vkd3d_blocker + " "
        if self.host_report.faudio_blocker != "":
            parts = parts + "faudio:" + self.host_report.faudio_blocker + " "
        if self.host_report.media_foundation_blocker != "":
            parts = parts + "mf:" + self.host_report.media_foundation_blocker + " "
        if self.host_report.steam_api_blocker != "":
            parts = parts + "steam_api:" + self.host_report.steam_api_blocker + " "
        if self.host_report.overlay_blocker != "":
            parts = parts + "overlay:" + self.host_report.overlay_blocker + " "
        if self.multilib.blocker != "":
            parts = parts + "multilib:" + self.multilib.blocker + " "
        parts

    me full_report() -> text:
        "gate=" + self.evaluate() +
            " " + self.host_report.report() +
            " multilib=" + self.multilib.summary() +
            " crash_log=" + self.crash_log.summary() +
            " dx=" + self.dx_prefix.summary() +
            " blockers=[" + self.blocker_summary() + "]"
