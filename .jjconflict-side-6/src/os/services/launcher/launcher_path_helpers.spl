# Launcher Path Helpers — filesystem path utilities and app identity canonicalization
#
# MDSOC: feature dimension, desktop layer
#
# Pure utility functions: no registry state.
# Imported by launcher_registry.spl and launcher.spl.

use os.services.vfs.vfs_init.{g_vfs_file_size}
extern fn rt_file_exists(path: text) -> bool

pub fn launcher_path_exists(path: text) -> bool:
    if path == "":
        return false
    val file_size = g_vfs_file_size(path)
    if file_size.? and file_size.unwrap().to_i64() > 0:
        return true
    # `/sys/apps` is SimpleOS-managed storage. On baremetal the host
    # filesystem SFFI is a trap stub, so do not probe it for guest app paths.
    if text_has_prefix(path, "/sys/apps/"):
        return false
    rt_file_exists(path)

pub fn text_has_prefix(source: text, prefix: text) -> bool:
    if prefix.len() > source.len():
        return false
    var idx = 0
    while idx < prefix.len():
        if source.char_at(idx) != prefix.char_at(idx):
            return false
        idx = idx + 1
    true

pub fn canonical_sys_app_name(name: text) -> text:
    val raw = if name.ends_with(".smf"): name.slice(0, name.len() - 4) else: name
    match raw:
        case "sbrowser": "simple_browser"
        case "SBROWSER": "simple_browser"
        case "SIMPLE_B": "simple_browser"
        case "scompiler": "simple_compiler"
        case "SCOMPILE": "simple_compiler"
        case "SIMPLE_C": "simple_compiler"
        case "sinterp": "simple_interpreter"
        case "SINTERP": "simple_interpreter"
        case "SIMPLE_I": "simple_interpreter"
        case "sloader": "simple_loader"
        case "SLOADER": "simple_loader"
        case "SIMPLE_L": "simple_loader"
        case "SIMPLSTC": "simple"
        case "SIMPLE": "simple"
        case _:
            raw

pub fn canonical_sys_app_identity(path: text) -> text:
    match path:
        case "/SYS/APPS/SBROWSMF.SMF": "/sys/apps/simple_browser"
        case "/SYS/APPS/SBROWSER.SMF": "/sys/apps/simple_browser"
        case "/SYS/APPS/SIMPLE_B": "/sys/apps/simple_browser"
        case "/SYS/APPS/SIMPLE_B.SMF": "/sys/apps/simple_browser"
        case "/SYS/APPS/SCOMPSMF.SMF": "/sys/apps/simple_compiler"
        case "/SYS/APPS/SCOMPILE.SMF": "/sys/apps/simple_compiler"
        case "/SYS/APPS/SIMPLE_C": "/sys/apps/simple_compiler"
        case "/SYS/APPS/SIMPLE_C.SMF": "/sys/apps/simple_compiler"
        case "/SYS/APPS/SINTSMF.SMF": "/sys/apps/simple_interpreter"
        case "/SYS/APPS/SINTERP.SMF": "/sys/apps/simple_interpreter"
        case "/SYS/APPS/SIMPLE_I": "/sys/apps/simple_interpreter"
        case "/SYS/APPS/SIMPLE_I.SMF": "/sys/apps/simple_interpreter"
        case "/SYS/APPS/SLOADSMF.SMF": "/sys/apps/simple_loader"
        case "/SYS/APPS/SLOADER.SMF": "/sys/apps/simple_loader"
        case "/SYS/APPS/SIMPLE_L": "/sys/apps/simple_loader"
        case "/SYS/APPS/SIMPLE_L.SMF": "/sys/apps/simple_loader"
        case "/SYS/APPS/SIMPLSTC.SMF": "/sys/apps/simple"
        case "/SYS/APPS/SIMPLE": "/sys/apps/simple"
        case "/SYS/APPS/SIMPLE.SMF": "/sys/apps/simple"
        case "/SYS/APPS/LLVMSMF.SMF": "/sys/apps/llvm"
        case "/SYS/APPS/LLVM": "/sys/apps/llvm"
        case "/SYS/APPS/LLVM.SMF": "/sys/apps/llvm"
        case "/SYS/APPS/CLANGSMF.SMF": "/sys/apps/clang"
        case "/SYS/APPS/CLANG": "/sys/apps/clang"
        case "/SYS/APPS/CLANG.SMF": "/sys/apps/clang"
        case "/SYS/APPS/RUSTSMF.SMF": "/sys/apps/rust"
        case "/SYS/APPS/RUST": "/sys/apps/rust"
        case "/SYS/APPS/RUST.SMF": "/sys/apps/rust"
        case "/SBROWSER.SMF": "/sys/apps/simple_browser"
        case "/SIMPLE_B": "/sys/apps/simple_browser"
        case "/SIMPLE_B.SMF": "/sys/apps/simple_browser"
        case "/SCOMPILE.SMF": "/sys/apps/simple_compiler"
        case "/SIMPLE_C": "/sys/apps/simple_compiler"
        case "/SIMPLE_C.SMF": "/sys/apps/simple_compiler"
        case "/SINTERP.SMF": "/sys/apps/simple_interpreter"
        case "/SIMPLE_I": "/sys/apps/simple_interpreter"
        case "/SIMPLE_I.SMF": "/sys/apps/simple_interpreter"
        case "/SLOADER.SMF": "/sys/apps/simple_loader"
        case "/SIMPLE_L": "/sys/apps/simple_loader"
        case "/SIMPLE_L.SMF": "/sys/apps/simple_loader"
        case "/SIMPLSTC.SMF": "/sys/apps/simple"
        case "/SIMPLE": "/sys/apps/simple"
        case "/SIMPLE.SMF": "/sys/apps/simple"
        case "/LLVM": "/sys/apps/llvm"
        case "/LLVM.SMF": "/sys/apps/llvm"
        case "/CLANG": "/sys/apps/clang"
        case "/CLANG.SMF": "/sys/apps/clang"
        case "/RUST": "/sys/apps/rust"
        case "/RUST.SMF": "/sys/apps/rust"
        case _:
            if not text_has_prefix(path, "/sys/apps/"):
                return ""
            val raw = path.slice("/sys/apps/".len(), path.len())
            if raw == "":
                return ""
            val name = canonical_sys_app_name(raw)
            "/sys/apps/{name}"
