# Material2D — Surface appearance description
#
# Combines color, texture, and blend mode into a single material
# for the 2D render pipeline.
#
# Usage:
#   val mat = Material2D.solid(EngineColor.red())
#   val tex_mat = Material2D.textured(my_texture_id)
#   val tinted = Material2D.tinted(my_texture_id, EngineColor.yellow())

use std.common.engine.color.{EngineColor}
use std.common.engine.ids.{TextureId}
use std.nogc_sync_mut.engine.render.types.{BlendMode}

# ============================================================================
# Material2D
# ============================================================================

class Material2D:
    color: EngineColor
    texture_id: TextureId
    blend_mode: BlendMode

impl Material2D:
    static fn solid(color: EngineColor) -> Material2D:
        """Create a solid-color material with no texture."""
        Material2D(
            color: color,
            texture_id: TextureId.invalid(),
            blend_mode: BlendMode.Alpha
        )

    static fn textured(texture_id: TextureId) -> Material2D:
        """Create a textured material with white tint (no color modulation)."""
        Material2D(
            color: EngineColor.white(),
            texture_id: texture_id,
            blend_mode: BlendMode.Alpha
        )

    static fn tinted(texture_id: TextureId, tint: EngineColor) -> Material2D:
        """Create a textured material with a color tint applied."""
        Material2D(
            color: tint,
            texture_id: texture_id,
            blend_mode: BlendMode.Alpha
        )

    fn has_texture() -> bool:
        """Check whether this material references a valid texture."""
        self.texture_id.is_valid()
