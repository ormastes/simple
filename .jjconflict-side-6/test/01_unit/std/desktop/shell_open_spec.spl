# Desktop shell integration API specification

use std.nogc_sync_mut.desktop.shell_open.{open_url, open_path, show_in_folder, move_to_trash, beep}

extern fn rt_file_read_text(path: text) -> text

fn shell_open_source() -> text:
    rt_file_read_text("src/lib/nogc_sync_mut/desktop/shell_open.spl") ?? ""

describe "Desktop Shell Integration":
    it "exposes open_url function":
        expect(shell_open_source()).to_contain("fn open_url(url: text)")

    it "exposes show_in_folder function":
        expect(shell_open_source()).to_contain("fn show_in_folder(path: text)")

    it "exposes move_to_trash function":
        expect(shell_open_source()).to_contain("fn move_to_trash(path: text)")
