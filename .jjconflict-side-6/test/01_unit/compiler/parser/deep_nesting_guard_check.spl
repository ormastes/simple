# Parser deep-nesting recursion-guard regression harness.
#
# Standalone (`bin/simple run`) rather than a *_spec.spl: driving the full
# parser through the test daemon exceeds its per-spec timeout (see
# doc/08_tracking/bug/simple_test_nested_runner_timeout_2026-06-28.md). Run via:
#
#     bin/simple run test/01_unit/compiler/parser/deep_nesting_guard_check.spl
#
# Regression: before the parse_expr depth guard, parsing ~175+ nested parens
# overflowed the native stack and aborted the process. If this harness prints
# PASS and exits 0, the guard returned a graceful error instead of crashing.

use compiler.frontend.core.parser.{parse_module}

fn nested_parens(n: i64) -> text:
    var s = "fn main():\n  print("
    for i in 0..n:
        s = s + "("
    s = s + "1"
    for i in 0..n:
        s = s + ")"
    s = s + ")\n"
    s

fn main() -> i64:
    val deep = nested_parens(300)
    val _m = parse_module(deep, "deep_noise.spl")
    # Reaching here means parse_module returned instead of stack-overflowing.
    print("PASS: deep-nesting guard prevented stack-overflow crash")
    0
