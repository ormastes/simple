# Editor Refactor Panel
#
# Panel for previewing and confirming rename, extract, and other
# refactoring operations.

struct RefactorPanelChange:
    path: text
    line: i64
    col: i64
    old_text: text
    new_text: text

struct RefactorPanel:
    title: text
    operation: text
    changes: [RefactorPanelChange]
    selected: i64
    confirmed: bool

fn refactor_panel_new(operation: text) -> RefactorPanel:
    RefactorPanel(
        title: "Refactor",
        operation: operation,
        changes: [],
        selected: 0,
        confirmed: false
    )

fn refactor_panel_with_changes(operation: text, changes: [RefactorPanelChange]) -> RefactorPanel:
    RefactorPanel(
        title: "Refactor: " + operation,
        operation: operation,
        changes: changes,
        selected: 0,
        confirmed: false
    )

fn refactor_panel_select(panel: RefactorPanel, index: i64) -> RefactorPanel:
    var idx = index
    if idx < 0:
        idx = 0
    if panel.changes.len() > 0 and idx >= panel.changes.len():
        idx = panel.changes.len() - 1
    RefactorPanel(
        title: panel.title,
        operation: panel.operation,
        changes: panel.changes,
        selected: idx,
        confirmed: panel.confirmed
    )

fn refactor_panel_render(panel: RefactorPanel, height: i64) -> [text]:
    var lines: [text] = []
    lines.push(panel.title + " (" + panel.changes.len().to_text() + " changes)")
    var i = 0
    while i < panel.changes.len() and lines.len() < height:
        val c = panel.changes[i]
        val prefix = if i == panel.selected then "> " else: "  "
        lines.push(prefix + c.path + ":" + (c.line + 1).to_text() + "  " + c.old_text + " -> " + c.new_text)
        i = i + 1
    lines
