# Per-backend compute-algorithm kernel emission for std.compute.
#
# Emits REAL CUDA / HIP / OpenCL / Metal / WebGPU kernel source for the elementwise
# compute algorithms (transform-scale, saxpy). Consistent with the existing
# gpu_portable_compute emitters: one logical kernel -> per-backend source, verified
# by backend-marker specs (no GPU hardware needed to verify emission). This is the
# "cuda/metal/vulkan backed" layer for the container/algorithm stdlib.

use compiler.backend.gpu_portable_compute.{PortableComputeTarget}

class ComputeKernelArtifact:
    backend: text          # cuda | hip | opencl | metal | webgpu
    entry_name: text
    source: text           # backend kernel source code
    binary_format: text    # ptx | hsaco | spirv | metallib | wgsl

    static fn make(backend: text, entry_name: text, source: text, binary_format: text) -> ComputeKernelArtifact:
        ComputeKernelArtifact(backend: backend, entry_name: entry_name, source: source, binary_format: binary_format)

fn ck_backend_name(t: PortableComputeTarget) -> text:
    if t == PortableComputeTarget.Cuda:
        return "cuda"
    if t == PortableComputeTarget.Hip:
        return "hip"
    if t == PortableComputeTarget.OpenCl:
        return "opencl"
    if t == PortableComputeTarget.Metal:
        return "metal"
    return "webgpu"

fn ck_binary_format(t: PortableComputeTarget) -> text:
    if t == PortableComputeTarget.Cuda:
        return "ptx"
    if t == PortableComputeTarget.Hip:
        return "hsaco"
    if t == PortableComputeTarget.OpenCl:
        return "spirv"
    if t == PortableComputeTarget.Metal:
        return "metallib"
    return "wgsl"

# out[i] = in[i] * factor   (transform / map)
fn emit_compute_transform_scale_kernel(t: PortableComputeTarget, name: text) -> ComputeKernelArtifact:
    var src = ""
    if t == PortableComputeTarget.Cuda or t == PortableComputeTarget.Hip:
        src = "extern \"C\" __global__ void {name}(unsigned int* out, const unsigned int* in, unsigned int factor, unsigned int count) {\n    unsigned int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= count) {\n        return;\n    }\n    out[i] = in[i] * factor;\n}\n"
    if t == PortableComputeTarget.OpenCl:
        src = "__kernel void {name}(__global uint* out, __global const uint* in, uint factor, uint count) {\n    uint i = get_global_id(0);\n    if (i >= count) {\n        return;\n    }\n    out[i] = in[i] * factor;\n}\n"
    if t == PortableComputeTarget.Metal:
        src = "#include <metal_stdlib>\nusing namespace metal;\nkernel void {name}(device uint* out [[buffer(0)]], const device uint* in [[buffer(1)]], constant uint& factor [[buffer(2)]], constant uint& count [[buffer(3)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) {\n        return;\n    }\n    out[gid] = in[gid] * factor;\n}\n"
    if t == PortableComputeTarget.WebGpu:
        src = "@group(0) @binding(0) var<storage, read_write> out: array<u32>;\n@group(0) @binding(1) var<storage, read> in: array<u32>;\n@group(0) @binding(2) var<uniform> factor: u32;\n\n@compute @workgroup_size(64)\nfn {name}(@builtin(global_invocation_id) global_id: vec3<u32>) {\n    let i = global_id.x;\n    if (i >= arrayLength(&out)) {\n        return;\n    }\n    out[i] = in[i] * factor;\n}\n"
    ComputeKernelArtifact.make(ck_backend_name(t), name, src, ck_binary_format(t))

# out[i] = a[i] * alpha + b[i]   (saxpy / fused multiply-add transform)
fn emit_compute_saxpy_kernel(t: PortableComputeTarget, name: text) -> ComputeKernelArtifact:
    var src = ""
    if t == PortableComputeTarget.Cuda or t == PortableComputeTarget.Hip:
        src = "extern \"C\" __global__ void {name}(unsigned int* out, const unsigned int* a, const unsigned int* b, unsigned int alpha, unsigned int count) {\n    unsigned int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= count) {\n        return;\n    }\n    out[i] = a[i] * alpha + b[i];\n}\n"
    if t == PortableComputeTarget.OpenCl:
        src = "__kernel void {name}(__global uint* out, __global const uint* a, __global const uint* b, uint alpha, uint count) {\n    uint i = get_global_id(0);\n    if (i >= count) {\n        return;\n    }\n    out[i] = a[i] * alpha + b[i];\n}\n"
    if t == PortableComputeTarget.Metal:
        src = "#include <metal_stdlib>\nusing namespace metal;\nkernel void {name}(device uint* out [[buffer(0)]], const device uint* a [[buffer(1)]], const device uint* b [[buffer(2)]], constant uint& alpha [[buffer(3)]], constant uint& count [[buffer(4)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) {\n        return;\n    }\n    out[gid] = a[gid] * alpha + b[gid];\n}\n"
    if t == PortableComputeTarget.WebGpu:
        src = "@group(0) @binding(0) var<storage, read_write> out: array<u32>;\n@group(0) @binding(1) var<storage, read> a: array<u32>;\n@group(0) @binding(2) var<storage, read> b: array<u32>;\n@group(0) @binding(3) var<uniform> alpha: u32;\n\n@compute @workgroup_size(64)\nfn {name}(@builtin(global_invocation_id) global_id: vec3<u32>) {\n    let i = global_id.x;\n    if (i >= arrayLength(&out)) {\n        return;\n    }\n    out[i] = a[i] * alpha + b[i];\n}\n"
    ComputeKernelArtifact.make(ck_backend_name(t), name, src, ck_binary_format(t))

export ComputeKernelArtifact, ck_backend_name, ck_binary_format
export emit_compute_transform_scale_kernel, emit_compute_saxpy_kernel
