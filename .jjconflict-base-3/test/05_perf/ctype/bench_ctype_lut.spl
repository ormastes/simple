    val ftable = build_flag_table()
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if (ftable[ch] & 6) != 0:
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_alpha", iters * range, elapsed, chk)
    chk

fn bench_is_alnum() -> i64:
    val ftable = build_flag_table()
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if (ftable[ch] & 7) != 0:
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_alnum", iters * range, elapsed, chk)
    chk

fn bench_is_xdigit() -> i64:
    val ftable = build_flag_table()
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if (ftable[ch] & 9) != 0:
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_xdigit", iters * range, elapsed, chk)
    chk

fn bench_is_space() -> i64:
    val ftable = build_flag_table()
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if (ftable[ch] & 16) != 0:
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_space", iters * range, elapsed, chk)
    chk

fn bench_to_lower() -> i64:
    val ltable = build_to_lower_table()
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            chk = chk + ltable[ch]
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("to_lower", iters * range, elapsed, chk)
    chk

fn bench_to_upper() -> i64:
    val utable = build_to_upper_table()
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            chk = chk + utable[ch]
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("to_upper", iters * range, elapsed, chk)
    chk

fn main():
    val total_iters = iters_count()
    val total_range = ascii_range()
    val total_ops = total_iters * total_range
    print "=== ctype microbenchmark: Simple native (lookup-table, same-file) ==="
    print "iters={total_iters} x ascii_range={total_range} = {total_ops} calls per function"
    print ""
    bench_is_digit()
    bench_is_upper()
    bench_is_lower()
    bench_is_alpha()
    bench_is_alnum()
    bench_is_xdigit()
    bench_is_space()
    bench_to_lower()
    bench_to_upper()
    print ""
    print "Done."
