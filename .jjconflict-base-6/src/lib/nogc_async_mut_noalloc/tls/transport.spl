# TLS 1.3 Baremetal Transport Trait
#
# Pluggable byte-stream transport for the no-alloc TLS 1.3 client.
# The caller provides a concrete implementation (UART, SPI, memory buffer, etc.)
# via a struct that conforms to this trait.
#
# All operations are synchronous; async wrappers are the caller's concern.
# Buffer ownership: send() borrows data; recv() writes into caller-supplied buf.

# ============================================================================
# Transport Trait
# ============================================================================

trait BaremetalTransport:
    """Byte-stream transport for baremetal TLS.

    Implementors must provide send and recv. recv fills buf[0..max-1] and
    returns the number of bytes actually received, or an error.
    """

    fn send(data: [u8]) -> Result<i64, text>
    """Send all bytes in data. Returns byte count sent or error."""

    fn recv(buf: [u8], max: i64) -> Result<i64, text>
    """Receive up to max bytes into buf. Returns byte count received or error."""

# ============================================================================
# UART Transport Adapter
# ============================================================================

extern fn rt_uart_write_byte(b: u8)
extern fn rt_uart_read_byte() -> i64   # -1 if no data available
extern fn rt_uart_bytes_available() -> i64

class UartTransport:
    """Adapter from UART primitives to BaremetalTransport."""
    pass_dn

impl BaremetalTransport for UartTransport:
    fn send(data: [u8]) -> Result<i64, text>:
        var i: i64 = 0
        while i < data.len():
            rt_uart_write_byte(data[i.to_i64()])
            i = i + 1
        Result.Ok(i)

    fn recv(buf: [u8], max: i64) -> Result<i64, text>:
        var count: i64 = 0
        while count < max:
            val b = rt_uart_read_byte()
            if b < 0:
                break
            buf[count] = b.to_u8()
            count = count + 1
        Result.Ok(count)

# ============================================================================
# Memory Buffer Transport (for testing / loopback)
# ============================================================================

class MemTransport:
    """In-memory loopback transport for unit testing."""
    recv_buf: [u8]
    recv_len: i64
    recv_pos: i64
    send_buf: [u8]
    send_len: i64

    static fn new(recv_data: [u8], recv_data_len: i64) -> MemTransport:
        var sb: [u8] = []
        var i: i64 = 0
        while i < 65536:
            sb.push(0u8)
            i = i + 1
        MemTransport(
            recv_buf: recv_data,
            recv_len: recv_data_len,
            recv_pos: 0,
            send_buf: sb,
            send_len: 0
        )

impl BaremetalTransport for MemTransport:
    fn send(data: [u8]) -> Result<i64, text>:
        var i: i64 = 0
        while i < data.len():
            if self.send_len < 65536:
                self.send_buf[self.send_len] = data[i]
                self.send_len = self.send_len + 1
            i = i + 1
        Result.Ok(i)

    fn recv(buf: [u8], max: i64) -> Result<i64, text>:
        var count: i64 = 0
        while count < max and self.recv_pos < self.recv_len:
            buf[count] = self.recv_buf[self.recv_pos]
            self.recv_pos = self.recv_pos + 1
            count = count + 1
        Result.Ok(count)
