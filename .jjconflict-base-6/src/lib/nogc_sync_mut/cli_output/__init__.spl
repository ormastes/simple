# CLI Output Library
#
# Shared output formatting, progress display, logging, and summary
# functions for all CLI commands (build, test, lint, etc.).
#
# Usage:
#   use std.cli_output.{OutputMode, progress_start, progress_update}
#   use std.cli_output.{format_summary, print_error_now, log_open}

from types import {
    OutputMode
}

from progress import {
    progress_start,
    progress_update,
    progress_finish,
    progress_erase
}

from log_writer import {
    log_open,
    log_line,
    log_close,
    log_show
}

from summary import {
    format_summary,
    format_duration,
    print_error_now,
    print_warning_now,
    print_log_hint
}

from buffer import {
    buffer_start,
    buffer_capture,
    buffer_flush,
    buffer_discard,
    buffer_is_active,
    buffer_line_count,
    log_point_start,
    log_point_flush,
    log_point_discard,
    log_point_clear,
    log_point_set_max,
    log_point_set_stale_count,
    log_point_has_active,
    log_print
}

# Re-exported from types.spl
export OutputMode

# Re-exported from progress.spl
export progress_start, progress_update, progress_finish, progress_erase

# Re-exported from log_writer.spl
export log_open, log_line, log_close, log_show

# Re-exported from summary.spl
export format_summary, format_duration, print_error_now, print_warning_now, print_log_hint

# Re-exported from buffer.spl
export buffer_start, buffer_capture, buffer_flush, buffer_discard, buffer_is_active, buffer_line_count
export log_point_start, log_point_flush, log_point_discard, log_point_clear, log_point_set_max, log_point_set_stale_count, log_point_has_active, log_print
