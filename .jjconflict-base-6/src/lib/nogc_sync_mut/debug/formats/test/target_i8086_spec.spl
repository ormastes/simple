#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.target.i8086.I8086Target

fn main():
    describe("I8086Target"):
        var target = I8086Target.create()

        it("has 14 registers"):
            expect(target.register_count()).to_equal(14)

        it("returns correct name"):
            expect(target.name()).to_equal("Intel 8086")

        it("returns ax at index 0"):
            expect(target.register_name(0)).to_equal("ax")

        it("returns bx at index 1"):
            expect(target.register_name(1)).to_equal("bx")

        it("returns ip at index 8"):
            expect(target.register_name(8)).to_equal("ip")

        it("returns flags at index 9"):
            expect(target.register_name(9)).to_equal("flags")

        it("returns cs at index 10"):
            expect(target.register_name(10)).to_equal("cs")

        it("returns ds at index 11"):
            expect(target.register_name(11)).to_equal("ds")

        it("returns es at index 12"):
            expect(target.register_name(12)).to_equal("es")

        it("returns ss at index 13"):
            expect(target.register_name(13)).to_equal("ss")

        it("maps ax name to index 0"):
            expect(target.register_index("ax")).to_equal(0)

        it("maps ip name to index 8"):
            expect(target.register_index("ip")).to_equal(8)

        it("returns -1 for unknown register"):
            expect(target.register_index("eax")).to_equal(-1)

        it("has 2-byte registers"):
            expect(target.register_size(0)).to_equal(2)

        it("has I8086 architecture"):
            expect(target.arch().to_string()).to_equal("i8086")

        it("has empty arg registers"):
            val t = I8086Target.create()
            val args = t.arg_registers()
            expect(args.len()).to_equal(0)

        it("has correct callee saved registers"):
            val t = I8086Target.create()
            val saved = t.callee_saved_registers()
            expect(saved.len()).to_equal(4)
            expect(saved[0]).to_equal(1)
            expect(saved[1]).to_equal(4)
            expect(saved[2]).to_equal(5)
            expect(saved[3]).to_equal(6)

        it("has 0 hw breakpoints"):
            expect(target.hw_breakpoint_count()).to_equal(0)

        it("has 0 hw watchpoints"):
            expect(target.hw_watchpoint_count()).to_equal(0)

        it("has INT3 breakpoint instruction"):
            val t = I8086Target.create()
            val bp = t.breakpoint_instruction()
            expect(bp.len()).to_equal(1)
            expect(bp[0]).to_equal(0xCC)

        it("supports single step"):
            expect(target.supports_single_step()).to_equal(true)

        it("has pc register at index 8"):
            expect(target.pc_register_index()).to_equal(8)

        it("has sp register at index 7"):
            expect(target.sp_register_index()).to_equal(7)

        it("has fp register at index 6"):
            expect(target.fp_register_index()).to_equal(6)

        it("has return register at index 0"):
            expect(target.return_register_index()).to_equal(0)
