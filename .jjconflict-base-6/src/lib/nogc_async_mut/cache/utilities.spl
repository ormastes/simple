@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# Cache Utility Functions
#
# Purpose: Statistics, helpers, and convenience functions
#
# Contains:
# - Cache statistics (hits, misses, hit rate)
# - Helper functions (is_empty, is_full)
# - Get-or-default, get-or-compute patterns
# - Memoization call function
# - Example usage functions

# ============================================================================
# Statistics Functions
# ============================================================================

fn cache_lru_stats(cache):
    """Get LRU cache statistics.

    Returns dictionary with:
    - hits: Number of cache hits
    - misses: Number of cache misses
    - hit_rate: Hit rate as percentage (0.0 to 100.0)
    - size: Current number of entries
    - capacity: Maximum capacity
    """
    val hits = _cache_i64(cache: cache, key: 'hits', default_value: 0)
    val misses = _cache_i64(cache: cache, key: 'misses', default_value: 0)
    val total = hits + misses

    var hit_rate = 0.0
    if total > 0:
        hit_rate = (hits * 100.0) / total

    {
        'hits': hits,
        'misses': misses,
        'hit_rate': hit_rate,
        'size': cache_lru_size(cache),
        'capacity': _cache_i64(cache: cache, key: 'capacity', default_value: 0)
    }

fn cache_fifo_stats(cache):
    """Get FIFO cache statistics."""
    val hits = _cache_i64(cache: cache, key: 'hits', default_value: 0)
    val misses = _cache_i64(cache: cache, key: 'misses', default_value: 0)
    val total = hits + misses

    var hit_rate = 0.0
    if total > 0:
        hit_rate = (hits * 100.0) / total

    {
        'hits': hits,
        'misses': misses,
        'hit_rate': hit_rate,
        'size': cache_fifo_size(cache),
        'capacity': _cache_i64(cache: cache, key: 'capacity', default_value: 0)
    }

fn cache_lfu_stats(cache):
    """Get LFU cache statistics."""
    val hits = _cache_i64(cache: cache, key: 'hits', default_value: 0)
    val misses = _cache_i64(cache: cache, key: 'misses', default_value: 0)
    val total = hits + misses

    var hit_rate = 0.0
    if total > 0:
        hit_rate = (hits * 100.0) / total

    {
        'hits': hits,
        'misses': misses,
        'hit_rate': hit_rate,
        'size': cache_lfu_size(cache),
        'capacity': _cache_i64(cache: cache, key: 'capacity', default_value: 0)
    }

fn cache_ttl_stats(cache):
    """Get TTL cache statistics."""
    val hits = _cache_i64(cache: cache, key: 'hits', default_value: 0)
    val misses = _cache_i64(cache: cache, key: 'misses', default_value: 0)
    val total = hits + misses

    var hit_rate = 0.0
    if total > 0:
        hit_rate = (hits * 100.0) / total

    {
        'hits': hits,
        'misses': misses,
        'hit_rate': hit_rate,
        'size': cache_ttl_size(cache),
        'capacity': _cache_i64(cache: cache, key: 'capacity', default_value: 0),
        'ttl': _cache_i64(cache: cache, key: 'ttl', default_value: 0)
    }

fn cache_stats(cache):
    """Generic cache stats operation. Works with any cache type."""
    val cache_type = if cache.has('type'): cache['type'] else: ''
    if cache_type == 'lru':
        cache_lru_stats(cache: cache)
    elif cache_type == 'fifo':
        cache_fifo_stats(cache: cache)
    elif cache_type == 'lfu':
        cache_lfu_stats(cache: cache)
    elif cache_type == 'ttl':
        cache_ttl_stats(cache: cache)
    else:
        {'hits': 0, 'misses': 0, 'hit_rate': 0.0, 'size': 0, 'capacity': 0}

fn memo_stats(memo_cache):
    """Get memoization cache statistics."""
    cache_lru_stats(cache: memo_cache)

# ============================================================================
# Helper Functions
# ============================================================================

fn cache_hit_rate(cache) -> f64:
    """Calculate hit rate for cache."""
    val stats = cache_stats(cache: cache)
    stats['hit_rate']

fn cache_miss_rate(cache) -> f64:
    """Calculate miss rate for cache."""
    100.0 - cache_hit_rate(cache: cache)

fn cache_is_empty(cache) -> bool:
    """Check if cache is empty."""
    cache_size(cache) == 0

fn cache_is_full(cache) -> bool:
    """Check if cache is at capacity."""
    cache_size(cache) >= _cache_i64(cache: cache, key: 'capacity', default_value: 0)

fn cache_get_or_default(cache, key: text, default_value):
    """Get value from cache or return default if not found."""
    val value = cache_get(cache: cache, key: key)
    if value == nil:
        default_value
    else:
        value

fn cache_get_or_compute(cache, key: text, compute_fn):
    """Get value from cache or compute and cache if not found."""
    val value = cache_get(cache: cache, key: key)
    if value == nil:
        val computed = compute_fn()
        cache_put(cache: cache, key: key, value: computed)
        return computed
    else:
        return value

# ============================================================================
# Memoization
# ============================================================================

fn memo_call(memo_cache, key: text, compute_fn):
    """Call function with memoization.

    Args:
    - memo_cache: Memoization cache created with memo_create
    - key: String key for this computation
    - compute_fn: Function to call if result not cached (takes no args)

    Returns: Cached or computed result.
    """
    val cached = cache_lru_get(cache: memo_cache, key: key)
    if cached != nil:
        return cached

    # Not cached - compute and store
    val result = compute_fn()
    cache_lru_put(cache: memo_cache, key: key, value: result)
    result

# ============================================================================
# Example Usage Functions
# ============================================================================

fn cache_example_lru():
    """Example of using LRU cache."""
    val cache = cache_lru_new(capacity: 3)

    # Add entries
    cache_lru_put(cache: cache, key: "a", value: 1)
    cache_lru_put(cache: cache, key: "b", value: 2)
    cache_lru_put(cache: cache, key: "c", value: 3)

    # Access to update order
    val val_a = cache_lru_get(cache: cache, key: "a")

    # Add one more - should evict "b" (least recently used)
    cache_lru_put(cache: cache, key: "d", value: 4)

    # Get stats
    cache_lru_stats(cache: cache)

fn cache_example_fifo():
    """Example of using FIFO cache."""
    val cache = cache_fifo_new(capacity: 3)

    cache_fifo_put(cache: cache, key: "a", value: 1)
    cache_fifo_put(cache: cache, key: "b", value: 2)
    cache_fifo_put(cache: cache, key: "c", value: 3)

    # Add one more - should evict "a" (first in)
    cache_fifo_put(cache: cache, key: "d", value: 4)

    cache_fifo_stats(cache: cache)

fn cache_example_lfu():
    """Example of using LFU cache."""
    val cache = cache_lfu_new(capacity: 3)

    cache_lfu_put(cache: cache, key: "a", value: 1)
    cache_lfu_put(cache: cache, key: "b", value: 2)
    cache_lfu_put(cache: cache, key: "c", value: 3)

    # Access "a" multiple times
    cache_lfu_get(cache: cache, key: "a")
    cache_lfu_get(cache: cache, key: "a")
    cache_lfu_get(cache: cache, key: "a")

    # Add one more - should evict "b" or "c" (least frequently used)
    cache_lfu_put(cache: cache, key: "d", value: 4)

    cache_lfu_stats(cache: cache)

fn cache_example_ttl():
    """Example of using TTL cache."""
    val cache = cache_ttl_new(capacity: 10, ttl_seconds: 60)

    cache_ttl_put(cache: cache, key: "session_123", value: "user_data")
    cache_ttl_put(cache: cache, key: "session_456", value: "admin_data")

    # Get value (within TTL)
    val session = cache_ttl_get(cache: cache, key: "session_123")

    # Clean up expired entries
    cache_ttl_cleanup(cache)

    cache_ttl_stats(cache: cache)

fn cache_example_memo():
    """Example of using memoization."""
    val memo = memo_create(100)

    # Expensive computation
    fn expensive_computation():
        var sum = 0
        var i = 0
        while i < 1000:
            sum = sum + i
            i = i + 1
        sum

    # First call - computes
    val result1 = memo_call(memo, "sum_1000", expensive_computation)

    # Second call - cached
    val result2 = memo_call(memo, "sum_1000", expensive_computation)

    memo_stats(memo)

# ============================================================================
# Helper stub functions
# ============================================================================

fn cache_lru_size(cache) -> i64:
    _cache_keys_len(cache: cache)

fn cache_fifo_size(cache) -> i64:
    _cache_keys_len(cache: cache)

fn cache_lfu_size(cache) -> i64:
    _cache_keys_len(cache: cache)

fn cache_ttl_size(cache) -> i64:
    _cache_keys_len(cache: cache)

fn cache_size(cache) -> i64:
    _cache_keys_len(cache: cache)

fn _cache_i64(cache, key: text, default_value: i64) -> i64:
    if cache.has(key):
        return cache[key]
    default_value

fn _cache_keys_len(cache) -> i64:
    if not cache.has('keys'):
        return 0
    val keys = cache['keys']
    keys.len()

fn cache_get(cache, key: text):
    val _ = cache
    val _ = key
    nil

fn cache_put(cache, key: text, value):
    cache

fn cache_lru_get(cache, key: text):
    val _ = cache
    val _ = key
    nil

fn cache_lru_put(cache, key: text, value):
    cache

fn cache_fifo_new(capacity: i64):
    val safe_capacity = _nonnegative_i64(capacity)
    {'type': 'fifo', 'keys': [], 'values': [], 'capacity': safe_capacity, 'hits': 0, 'misses': 0}

fn cache_fifo_put(cache, key: text, value):
    cache

fn cache_fifo_get(cache, key: text):
    val _ = cache
    val _ = key
    nil

fn cache_lfu_new(capacity: i64):
    val safe_capacity = _nonnegative_i64(capacity)
    {'type': 'lfu', 'keys': [], 'values': [], 'frequencies': [], 'capacity': safe_capacity, 'hits': 0, 'misses': 0}

fn cache_lfu_put(cache, key: text, value):
    cache

fn cache_lfu_get(cache, key: text):
    val _ = cache
    val _ = key
    nil

fn cache_ttl_new(capacity: i64, ttl_seconds: i64):
    val safe_capacity = _nonnegative_i64(capacity)
    val safe_ttl = _nonnegative_i64(ttl_seconds)
    {'type': 'ttl', 'keys': [], 'values': [], 'expiry_times': [], 'capacity': safe_capacity, 'ttl': safe_ttl, 'hits': 0, 'misses': 0}

fn cache_ttl_put(cache, key: text, value):
    cache

fn cache_ttl_get(cache, key: text):
    val _ = cache
    val _ = key
    nil

fn cache_ttl_cleanup(cache):
    cache

fn cache_lru_new(capacity: i64):
    val safe_capacity = _nonnegative_i64(capacity)
    {'type': 'lru', 'keys': [], 'values': [], 'capacity': safe_capacity, 'hits': 0, 'misses': 0}

fn memo_create(capacity: i64):
    cache_lru_new(capacity: capacity)

fn _nonnegative_i64(value: i64) -> i64:
    if value < 0:
        return 0
    value
