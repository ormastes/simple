# Unit: Lux
# Kind: Illuminance
# Symbol: lx
# Canonical scale: 1.0 lx

class Lux:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Lux) -> Lux: Lux(value: self.value + other.value)
    fn sub(other: Lux) -> Lux: Lux(value: self.value - other.value)

    static fn kind() -> text: "Illuminance"
    static fn symbol() -> text: "lx"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "lx"
    static fn zero() -> Lux: Lux(value: 0.0)

export Lux
