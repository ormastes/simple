# Composite Unit: Mpg
# Kind: FuelEconomy
# Symbol: mpg
# Scale to SI base: 1.0 mi/gal

class Mpg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mpg) -> Mpg: Mpg(value: self.value + other.value)
    fn sub(other: Mpg) -> Mpg: Mpg(value: self.value - other.value)

    static fn kind() -> text: "FuelEconomy"
    static fn symbol() -> text: "mpg"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "mi/gal"
    static fn numerator() -> [text]: ["mi"]
    static fn denominator() -> [text]: ["gal_us"]
    static fn zero() -> Mpg: Mpg(value: 0.0)

export Mpg
