use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.zstd_types.{append_self_overlap_copy}

describe "Zstd overlap copy bounds validation":
    it "rejects negative copy counts":
        val result = append_self_overlap_copy([0x41u8, 0x42u8], 1, -1)
        expect(result.is_err()).to_equal(true)
        val err = result.unwrap_err()
        match err:
            CompressionError.CorruptStream(message):
                expect(message).to_contain("copy count")
            _:
                expect(false).to_equal(true)
