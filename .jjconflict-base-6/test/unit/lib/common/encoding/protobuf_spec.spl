# Protobuf wire-format encoder/decoder spec
#
# @covers src/lib/common/encoding/protobuf.spl
#
# NOTE: All payload-building is done in module-level helper functions to avoid
# the it-block var-mutation footgun
# (see .claude/memory/feedback_it_block_var_mutation.md).

use std.common.encoding.protobuf.{pb_encode_varint, pb_decode_varint, pb_encode_zigzag, pb_decode_zigzag, pb_encode_tag, pb_encode_field_varint, pb_encode_field_bytes, pb_encode_field_string, pb_encode_fixed32, pb_encode_fixed64, pb_decode_field}

# ============================================================================
# Helper functions (module-level to avoid it-block var-mutation bug)
# ============================================================================

fn _varint_1() -> [u8]:
    pb_encode_varint(1)

fn _varint_127() -> [u8]:
    pb_encode_varint(127)

fn _varint_128() -> [u8]:
    pb_encode_varint(128)

fn _varint_300() -> [u8]:
    pb_encode_varint(300)

fn _varint_150() -> [u8]:
    pb_encode_varint(150)

fn _varint_2097151() -> [u8]:
    # 3-byte varint: 0x7FFFFF = 2097151
    pb_encode_varint(2097151)

fn _varint_268435455() -> [u8]:
    # 4-byte max before 5-byte: 0xFFFFFFF
    pb_encode_varint(268435455)

fn _varint_2147483647() -> [u8]:
    # 5-byte: i32 max = 2147483647 = 0x7FFFFFFF
    pb_encode_varint(2147483647)

fn _decode_varint_1() -> list:
    val bytes = _varint_1()
    pb_decode_varint(bytes, 0)

fn _decode_varint_128() -> list:
    val bytes = _varint_128()
    pb_decode_varint(bytes, 0)

fn _decode_varint_300() -> list:
    val bytes = _varint_300()
    pb_decode_varint(bytes, 0)

fn _decode_varint_2147483647() -> list:
    val bytes = _varint_2147483647()
    pb_decode_varint(bytes, 0)

fn _zigzag_0() -> i64:
    pb_encode_zigzag(0)

fn _zigzag_1() -> i64:
    pb_encode_zigzag(1)

fn _zigzag_neg1() -> i64:
    pb_encode_zigzag(-1)

fn _zigzag_neg2() -> i64:
    pb_encode_zigzag(-2)

fn _zigzag_2147483647() -> i64:
    pb_encode_zigzag(2147483647)

fn _decode_zigzag_0() -> i64:
    pb_decode_zigzag(0)

fn _decode_zigzag_1() -> i64:
    pb_decode_zigzag(1)

fn _decode_zigzag_2() -> i64:
    pb_decode_zigzag(2)

fn _decode_zigzag_3() -> i64:
    pb_decode_zigzag(3)

fn _tag_field1_varint() -> [u8]:
    pb_encode_tag(1, 0)

fn _tag_field2_len() -> [u8]:
    pb_encode_tag(2, 2)

fn _fixed32_300() -> [u8]:
    pb_encode_fixed32(300)

fn _fixed64_1000000000000() -> [u8]:
    pb_encode_fixed64(1000000000000)

fn _decode_fixed32_300() -> list:
    val encoded = _fixed32_300()
    val data = pb_encode_field_varint(99, 0)  # dummy to trigger field decode
    pb_decode_field(_fixed32_300_as_field(), 0)

fn _fixed32_300_as_field() -> [u8]:
    # Wire type 5 = 32-bit, field_num=3 => tag = (3<<3)|5 = 29
    var tag_bytes = pb_encode_tag(3, 5)
    var vbytes = pb_encode_fixed32(300)
    var out: [u8] = []
    var i = 0
    while i < tag_bytes.len():
        var bv: u8 = tag_bytes[i].to_i64().to_u8()
        out.push(bv)
        i = i + 1
    i = 0
    while i < vbytes.len():
        var bv: u8 = vbytes[i].to_i64().to_u8()
        out.push(bv)
        i = i + 1
    out

fn _fixed64_as_field() -> [u8]:
    # Wire type 1 = 64-bit, field_num=4 => tag = (4<<3)|1 = 33
    var tag_bytes = pb_encode_tag(4, 1)
    var vbytes = pb_encode_fixed64(1000000000000)
    var out: [u8] = []
    var i = 0
    while i < tag_bytes.len():
        var bv: u8 = tag_bytes[i].to_i64().to_u8()
        out.push(bv)
        i = i + 1
    i = 0
    while i < vbytes.len():
        var bv: u8 = vbytes[i].to_i64().to_u8()
        out.push(bv)
        i = i + 1
    out

fn _roundtrip_message() -> [u8]:
    # Encode: field1=varint(150), field2=string("testing")
    var out: [u8] = []
    var f1 = pb_encode_field_varint(1, 150)
    var f2 = pb_encode_field_string(2, "testing")
    var i = 0
    while i < f1.len():
        var bv: u8 = f1[i].to_i64().to_u8()
        out.push(bv)
        i = i + 1
    i = 0
    while i < f2.len():
        var bv: u8 = f2[i].to_i64().to_u8()
        out.push(bv)
        i = i + 1
    out

fn _roundtrip_field1_value() -> i64:
    val msg = _roundtrip_message()
    val r = pb_decode_field(msg, 0)
    r[2]

fn _roundtrip_field1_wire_type() -> i64:
    val msg = _roundtrip_message()
    val r = pb_decode_field(msg, 0)
    r[1]

fn _roundtrip_field1_new_pos() -> i64:
    val msg = _roundtrip_message()
    val r = pb_decode_field(msg, 0)
    r[3]

fn _roundtrip_field2_field_num() -> i64:
    val msg = _roundtrip_message()
    val r1 = pb_decode_field(msg, 0)
    val pos2 = r1[3]
    val r2 = pb_decode_field(msg, pos2)
    r2[0]

fn _roundtrip_field2_wire_type() -> i64:
    val msg = _roundtrip_message()
    val r1 = pb_decode_field(msg, 0)
    val pos2 = r1[3]
    val r2 = pb_decode_field(msg, pos2)
    r2[1]

fn _roundtrip_field2_bytes_len() -> i64:
    val msg = _roundtrip_message()
    val r1 = pb_decode_field(msg, 0)
    val pos2 = r1[3]
    val r2 = pb_decode_field(msg, pos2)
    val body = r2[2]
    body.len()

fn _roundtrip_field2_first_byte() -> i64:
    val msg = _roundtrip_message()
    val r1 = pb_decode_field(msg, 0)
    val pos2 = r1[3]
    val r2 = pb_decode_field(msg, pos2)
    val body = r2[2]
    body[0].to_i64()

# ============================================================================
# Varint encoding specs
# ============================================================================

describe "pb_encode_varint":
    context "1-byte cases":
        it "encodes 1 as single byte 0x01":
            val enc = _varint_1()
            expect(enc.len()).to_equal(1)
            expect(enc[0].to_i64()).to_equal(1)

        it "encodes 127 as single byte 0x7F":
            val enc = _varint_127()
            expect(enc.len()).to_equal(1)
            expect(enc[0].to_i64()).to_equal(127)

    context "2-byte cases":
        it "encodes 128 as two bytes 0x80 0x01":
            val enc = _varint_128()
            expect(enc.len()).to_equal(2)
            expect(enc[0].to_i64()).to_equal(0x80)
            expect(enc[1].to_i64()).to_equal(0x01)

        it "encodes 150 as two bytes 0x96 0x01":
            val enc = _varint_150()
            expect(enc.len()).to_equal(2)
            expect(enc[0].to_i64()).to_equal(0x96)
            expect(enc[1].to_i64()).to_equal(0x01)

        it "encodes 300 as two bytes 0xAC 0x02":
            val enc = _varint_300()
            expect(enc.len()).to_equal(2)
            expect(enc[0].to_i64()).to_equal(0xAC)
            expect(enc[1].to_i64()).to_equal(0x02)

    context "5-byte case":
        it "encodes 2147483647 (i32 max) in 5 bytes":
            val enc = _varint_2147483647()
            expect(enc.len()).to_equal(5)

# ============================================================================
# Varint decoding specs
# ============================================================================

describe "pb_decode_varint":
    context "1-byte decode":
        it "decodes 1 back to 1":
            val r = _decode_varint_1()
            expect(r[0]).to_equal(1)

        it "returns new_pos = 1 for 1-byte varint":
            val r = _decode_varint_1()
            expect(r[1]).to_equal(1)

    context "2-byte decode":
        it "decodes 128 back to 128":
            val r = _decode_varint_128()
            expect(r[0]).to_equal(128)

        it "returns new_pos = 2 for 2-byte varint":
            val r = _decode_varint_128()
            expect(r[1]).to_equal(2)

        it "decodes 300 back to 300":
            val r = _decode_varint_300()
            expect(r[0]).to_equal(300)

    context "5-byte decode":
        it "decodes i32 max (2147483647) back correctly":
            val r = _decode_varint_2147483647()
            expect(r[0]).to_equal(2147483647)

        it "returns new_pos = 5 for 5-byte varint":
            val r = _decode_varint_2147483647()
            expect(r[1]).to_equal(5)

# ============================================================================
# ZigZag specs
# ============================================================================

describe "pb_encode_zigzag":
    it "encodes 0 to 0":
        expect(_zigzag_0()).to_equal(0)

    it "encodes -1 to 1":
        expect(_zigzag_neg1()).to_equal(1)

    it "encodes 1 to 2":
        expect(_zigzag_1()).to_equal(2)

    it "encodes -2 to 3":
        expect(_zigzag_neg2()).to_equal(3)

    it "encodes large positive to even number":
        expect(_zigzag_2147483647()).to_equal(4294967294)

describe "pb_decode_zigzag":
    it "decodes 0 to 0":
        expect(_decode_zigzag_0()).to_equal(0)

    it "decodes 1 to -1":
        expect(_decode_zigzag_1()).to_equal(-1)

    it "decodes 2 to 1":
        expect(_decode_zigzag_2()).to_equal(1)

    it "decodes 3 to -2":
        expect(_decode_zigzag_3()).to_equal(-2)

describe "pb_encode_zigzag / pb_decode_zigzag round-trip":
    it "round-trips 0":
        expect(pb_decode_zigzag(pb_encode_zigzag(0))).to_equal(0)

    it "round-trips -1":
        expect(pb_decode_zigzag(pb_encode_zigzag(-1))).to_equal(-1)

    it "round-trips 1":
        expect(pb_decode_zigzag(pb_encode_zigzag(1))).to_equal(1)

    it "round-trips large negative":
        expect(pb_decode_zigzag(pb_encode_zigzag(-100000))).to_equal(-100000)

# ============================================================================
# Tag encoding specs
# ============================================================================

describe "pb_encode_tag":
    it "encodes field 1, wire_type 0 (varint) as single byte 0x08":
        val enc = _tag_field1_varint()
        expect(enc.len()).to_equal(1)
        expect(enc[0].to_i64()).to_equal(0x08)

    it "encodes field 2, wire_type 2 (length-delimited) as single byte 0x12":
        val enc = _tag_field2_len()
        expect(enc.len()).to_equal(1)
        expect(enc[0].to_i64()).to_equal(0x12)

# ============================================================================
# Fixed32 / Fixed64 specs
# ============================================================================

describe "pb_encode_fixed32":
    it "encodes 300 as 4 little-endian bytes":
        val enc = _fixed32_300()
        expect(enc.len()).to_equal(4)
        expect(enc[0].to_i64()).to_equal(44)
        expect(enc[1].to_i64()).to_equal(1)
        expect(enc[2].to_i64()).to_equal(0)
        expect(enc[3].to_i64()).to_equal(0)

describe "pb_encode_fixed64":
    it "encodes 1000000000000 as 8 little-endian bytes":
        val enc = _fixed64_as_field()
        # Just verify the tag+value field is 9 bytes (1 tag byte + 8 data bytes)
        expect(enc.len()).to_equal(9)

# ============================================================================
# Full message round-trip spec
# ============================================================================

describe "protobuf message round-trip":
    context "field1 = varint 150":
        it "decodes field_num = 1":
            val r = pb_decode_field(_roundtrip_message(), 0)
            expect(r[0]).to_equal(1)

        it "decodes wire_type = 0 (varint)":
            expect(_roundtrip_field1_wire_type()).to_equal(0)

        it "decodes value = 150":
            expect(_roundtrip_field1_value()).to_equal(150)

    context "field2 = string testing":
        it "decodes field_num = 2":
            expect(_roundtrip_field2_field_num()).to_equal(2)

        it "decodes wire_type = 2 (length-delimited)":
            expect(_roundtrip_field2_wire_type()).to_equal(2)

        it "decodes 7 bytes for 'testing'":
            expect(_roundtrip_field2_bytes_len()).to_equal(7)

        it "first decoded byte = ord('t') = 116":
            expect(_roundtrip_field2_first_byte()).to_equal(116)

# ============================================================================
# Fixed field decode round-trip
# ============================================================================

describe "pb_decode_field fixed32":
    it "decodes field_num = 3":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect(r[0]).to_equal(3)

    it "decodes wire_type = 5":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect(r[1]).to_equal(5)

    it "decodes value = 300":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect(r[2]).to_equal(300)

    it "advances pos by 5 (1 tag + 4 data)":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect(r[3]).to_equal(5)

describe "pb_decode_field fixed64":
    it "decodes field_num = 4":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect(r[0]).to_equal(4)

    it "decodes wire_type = 1":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect(r[1]).to_equal(1)

    it "decodes value = 1000000000000":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect(r[2]).to_equal(1000000000000)

    it "advances pos by 9 (1 tag + 8 data)":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect(r[3]).to_equal(9)
