# smux_dashboard_spec.spl — Unit tests for the smux dashboard adapter.
#
# Tests for session overview, pane layout info, status bar data, attach/detach
# helpers, and resize hint generation.
#
# Pattern: plain fn test_X() with print("PASS:...") / print("FAIL:...").
# Text-grep verifiable: grep "PASS:" output to confirm each AC.
# No imports from smux — all types are replicated at module level to avoid
# import resolution issues in interpreter mode.

# =========================================================================
# Module-level replicas of dashboard types (no imports needed)
# =========================================================================

class DashSessionRow:
    session_id: text
    session_name: text
    window_count: int
    pane_count: int
    is_attached: bool

    me to_text() -> text:
        val att = if self.is_attached: "attached" else: "detached"
        return self.session_name + " (" + att + ") w=" + self.window_count.to_text() + " p=" + self.pane_count.to_text()

    static fn make(sid: text, name: text, wc: int, pc: int, att: bool) -> DashSessionRow:
        return DashSessionRow(session_id: sid, session_name: name, window_count: wc, pane_count: pc, is_attached: att)

class DashPaneInfo:
    pane_id: text
    window_id: text
    session_id: text
    width: int
    height: int
    is_active: bool
    preview_line: text

    me geometry_text() -> text:
        return self.width.to_text() + "x" + self.height.to_text()

    me to_text() -> text:
        val active_flag = if self.is_active: "*" else: " "
        return active_flag + "pane[" + self.pane_id + "] " + self.geometry_text() + " > " + self.preview_line

    static fn make(pid: text, wid: text, sid: text, w: int, h: int, active: bool, preview: text) -> DashPaneInfo:
        return DashPaneInfo(pane_id: pid, window_id: wid, session_id: sid, width: w, height: h, is_active: active, preview_line: preview)

class DashStatusBar:
    session_count: int
    active_session_name: text
    active_window_name: text
    active_pane_geometry: text
    has_attached: bool

    me to_text() -> text:
        return "[smux " + self.session_count.to_text() + "s] " + self.active_session_name + ":" + self.active_window_name + " " + self.active_pane_geometry

    static fn empty() -> DashStatusBar:
        return DashStatusBar(session_count: 0, active_session_name: "", active_window_name: "", active_pane_geometry: "", has_attached: false)

    static fn build(sc: int, sname: text, wname: text, geom: text, att: bool) -> DashStatusBar:
        return DashStatusBar(session_count: sc, active_session_name: sname, active_window_name: wname, active_pane_geometry: geom, has_attached: att)

class DashAttachResult:
    ok: bool
    session_id: text
    error_msg: text

    me to_text() -> text:
        if self.ok:
            return "attached:" + self.session_id
        return "error:" + self.error_msg

    static fn success(sid: text) -> DashAttachResult:
        return DashAttachResult(ok: true, session_id: sid, error_msg: "")

    static fn failure(msg: text) -> DashAttachResult:
        return DashAttachResult(ok: false, session_id: "", error_msg: msg)

# =========================================================================
# Resize hint helper (replicated)
# =========================================================================

fn dashboard_resize_hint(session_id: text, window_id: text, pane_id: text, cols: int, rows: int) -> text:
    return "resize " + session_id + "/" + window_id + "/" + pane_id + " -> " + cols.to_text() + "x" + rows.to_text()

# =========================================================================
# DashSessionRow tests
# =========================================================================

fn test_session_row_to_text_attached():
    val row = DashSessionRow.make("s0", "dev", 3, 5, true)
    val t = row.to_text()
    if t == "dev (attached) w=3 p=5":
        print("PASS: test_session_row_to_text_attached")
    else:
        print("FAIL: test_session_row_to_text_attached got=" + t)

fn test_session_row_to_text_detached():
    val row = DashSessionRow.make("s1", "ci", 1, 2, false)
    val t = row.to_text()
    if t == "ci (detached) w=1 p=2":
        print("PASS: test_session_row_to_text_detached")
    else:
        print("FAIL: test_session_row_to_text_detached got=" + t)

fn test_session_row_fields():
    val row = DashSessionRow.make("sid99", "prod", 4, 8, true)
    if row.session_id == "sid99":
        if row.window_count == 4:
            if row.pane_count == 8:
                print("PASS: test_session_row_fields")
                return
    print("FAIL: test_session_row_fields")

fn test_session_row_window_count_zero():
    val row = DashSessionRow.make("s2", "empty", 0, 0, false)
    if row.window_count == 0:
        print("PASS: test_session_row_window_count_zero")
    else:
        print("FAIL: test_session_row_window_count_zero")

# =========================================================================
# DashPaneInfo tests
# =========================================================================

fn test_pane_info_geometry_text():
    val info = DashPaneInfo.make("p0", "w0", "s0", 80, 24, false, "")
    val g = info.geometry_text()
    if g == "80x24":
        print("PASS: test_pane_info_geometry_text")
    else:
        print("FAIL: test_pane_info_geometry_text got=" + g)

fn test_pane_info_to_text_active():
    val info = DashPaneInfo.make("p1", "w0", "s0", 120, 40, true, "$ ls")
    val t = info.to_text()
    if t == "*pane[p1] 120x40 > $ ls":
        print("PASS: test_pane_info_to_text_active")
    else:
        print("FAIL: test_pane_info_to_text_active got=" + t)

fn test_pane_info_to_text_inactive():
    val info = DashPaneInfo.make("p2", "w0", "s0", 80, 24, false, "")
    val t = info.to_text()
    if t == " pane[p2] 80x24 > ":
        print("PASS: test_pane_info_to_text_inactive")
    else:
        print("FAIL: test_pane_info_to_text_inactive got=" + t)

fn test_pane_info_preview_stored():
    val info = DashPaneInfo.make("p3", "w1", "s1", 80, 24, false, "hello world")
    if info.preview_line == "hello world":
        print("PASS: test_pane_info_preview_stored")
    else:
        print("FAIL: test_pane_info_preview_stored")

fn test_pane_info_width_height():
    val info = DashPaneInfo.make("p4", "w2", "s2", 160, 50, true, "")
    if info.width == 160:
        if info.height == 50:
            print("PASS: test_pane_info_width_height")
            return
    print("FAIL: test_pane_info_width_height")

# =========================================================================
# DashStatusBar tests
# =========================================================================

fn test_status_bar_empty():
    val sb = DashStatusBar.empty()
    if sb.session_count == 0:
        if sb.active_session_name == "":
            print("PASS: test_status_bar_empty")
            return
    print("FAIL: test_status_bar_empty")

fn test_status_bar_to_text():
    val sb = DashStatusBar.build(2, "dev", "main", "80x24", true)
    val t = sb.to_text()
    if t == "[smux 2s] dev:main 80x24":
        print("PASS: test_status_bar_to_text")
    else:
        print("FAIL: test_status_bar_to_text got=" + t)

fn test_status_bar_no_session():
    val sb = DashStatusBar.empty()
    val t = sb.to_text()
    if t == "[smux 0s] : ":
        print("PASS: test_status_bar_no_session")
    else:
        print("FAIL: test_status_bar_no_session got=" + t)

fn test_status_bar_has_attached():
    val sb = DashStatusBar.build(1, "work", "editor", "100x30", true)
    if sb.has_attached:
        print("PASS: test_status_bar_has_attached")
    else:
        print("FAIL: test_status_bar_has_attached")

fn test_status_bar_detached():
    val sb = DashStatusBar.build(1, "ci", "build", "80x24", false)
    if sb.has_attached == false:
        print("PASS: test_status_bar_detached")
    else:
        print("FAIL: test_status_bar_detached")

# =========================================================================
# DashAttachResult tests
# =========================================================================

fn test_attach_result_success():
    val r = DashAttachResult.success("s42")
    if r.ok:
        if r.session_id == "s42":
            print("PASS: test_attach_result_success")
            return
    print("FAIL: test_attach_result_success")

fn test_attach_result_failure():
    val r = DashAttachResult.failure("session not found: ghost")
    if r.ok == false:
        if r.error_msg == "session not found: ghost":
            print("PASS: test_attach_result_failure")
            return
    print("FAIL: test_attach_result_failure")

fn test_attach_result_to_text_ok():
    val r = DashAttachResult.success("sid1")
    val t = r.to_text()
    if t == "attached:sid1":
        print("PASS: test_attach_result_to_text_ok")
    else:
        print("FAIL: test_attach_result_to_text_ok got=" + t)

fn test_attach_result_to_text_err():
    val r = DashAttachResult.failure("not found")
    val t = r.to_text()
    if t == "error:not found":
        print("PASS: test_attach_result_to_text_err")
    else:
        print("FAIL: test_attach_result_to_text_err got=" + t)

# =========================================================================
# Resize hint tests
# =========================================================================

fn test_resize_hint_format():
    val h = dashboard_resize_hint("s0", "w0", "p0", 120, 40)
    if h == "resize s0/w0/p0 -> 120x40":
        print("PASS: test_resize_hint_format")
    else:
        print("FAIL: test_resize_hint_format got=" + h)

fn test_resize_hint_small():
    val h = dashboard_resize_hint("sid", "wid", "pid", 80, 24)
    if h == "resize sid/wid/pid -> 80x24":
        print("PASS: test_resize_hint_small")
    else:
        print("FAIL: test_resize_hint_small got=" + h)

fn test_resize_hint_ids_preserved():
    val h = dashboard_resize_hint("my-session", "win-3", "pane-7", 200, 60)
    val expected = "resize my-session/win-3/pane-7 -> 200x60"
    if h == expected:
        print("PASS: test_resize_hint_ids_preserved")
    else:
        print("FAIL: test_resize_hint_ids_preserved got=" + h)

# =========================================================================
# Entry point
# =========================================================================

fn main():
    test_session_row_to_text_attached()
    test_session_row_to_text_detached()
    test_session_row_fields()
    test_session_row_window_count_zero()
    test_pane_info_geometry_text()
    test_pane_info_to_text_active()
    test_pane_info_to_text_inactive()
    test_pane_info_preview_stored()
    test_pane_info_width_height()
    test_status_bar_empty()
    test_status_bar_to_text()
    test_status_bar_no_session()
    test_status_bar_has_attached()
    test_status_bar_detached()
    test_attach_result_success()
    test_attach_result_failure()
    test_attach_result_to_text_ok()
    test_attach_result_to_text_err()
    test_resize_hint_format()
    test_resize_hint_small()
    test_resize_hint_ids_preserved()
    print("DONE")
