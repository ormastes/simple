# SDN Report Formatter for nginx-vs-Simple benchmark results
#
# Produces SDN-format (Simple Data Notation) output compatible with
# doc/10_metrics/ dashboard tables.
#
# Depends on: harness.spl (BenchmarkResult)

use std.io_runtime.{write_file, print}
use test.perf.web_server_nginx_compare.harness.{BenchmarkResult}

# ============================================================================
# Internal helpers
# ============================================================================

fn _f64_fmt(v: f64, decimals: i64) -> text:
    """Format a float to `decimals` decimal places."""
    if decimals == 0:
        return (v as i64).to_text()
    val scale: i64 = if decimals == 1: 10 else: if decimals == 2: 100 else: 1000
    val int_part = v as i64
    val frac_part = ((v - (int_part as f64)) * (scale as f64)) as i64
    var frac_text = frac_part.to_text()
    while frac_text.len() < decimals:
        frac_text = "0" + frac_text
    "{int_part}.{frac_text}"

fn _size_label(sz: i64) -> text:
    """Human-readable label for a byte size."""
    if sz >= 1048576:
        return "{sz / 1048576}MB"
    if sz >= 1024:
        return "{sz / 1024}KB"
    "{sz}B"

# ============================================================================
# Public API
# ============================================================================

pub fn format_sdn(results: [BenchmarkResult]) -> text:
    """Format benchmark results as an SDN table string.

    Table name: nginx_compare
    Columns: id, server, file_size, file_label, rps, p99_latency_ms,
             throughput_mbps, failure_count, timestamp
    """
    var out = "nginx_compare |id, server, file_size, file_label, rps, p99_latency_ms, throughput_mbps, failure_count, timestamp|\n"

    var idx = 0
    while idx < results.len():
        val r = results[idx]
        val row_id = idx + 1
        val label = _size_label(r.file_size)
        val rps_text = _f64_fmt(r.rps, 1)
        val p99_text = _f64_fmt(r.p99_latency_ms, 2)
        val tp_text = _f64_fmt(r.throughput_mbps, 3)
        out = out + "    {row_id}, \"{r.server}\", {r.file_size}, \"{label}\", {rps_text}, {p99_text}, {tp_text}, {r.failure_count}, \"{r.timestamp}\"\n"
        idx = idx + 1
    out

pub fn write_sdn_report(path: text, results: [BenchmarkResult]):
    """Write benchmark results as an SDN file at the given path."""
    val content = format_sdn(results)
    write_file(path, content)
    print("wrote SDN report: {path}")
