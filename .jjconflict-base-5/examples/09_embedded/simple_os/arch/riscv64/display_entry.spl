extern fn log_raw_println(msg: text)
extern fn rt_riscv_qemu_ram_base() -> u64
extern fn rt_riscv_qemu_ram_size() -> u64
extern fn rt_riscv_qemu_reserved_end() -> u64
extern fn rt_riscv_qemu_heap_start() -> u64
extern fn rt_riscv_noalloc_pmm_init(ram_base: u64, ram_size: u64, reserved_end: u64, heap_start: u64) -> bool
extern fn rt_display_init() -> i64
extern fn rt_display_flush_test() -> i64
extern fn rt_riscv_wfi_forever()

fn boot_main(hart_id: u64, dtb_addr: u64):
    val _hart_id = hart_id
    val _dtb_addr = dtb_addr
    log_raw_println("=== SimpleOS RV64 display smoke boot ===")
    rt_riscv_noalloc_pmm_init(
        rt_riscv_qemu_ram_base(),
        rt_riscv_qemu_ram_size(),
        rt_riscv_qemu_reserved_end(),
        rt_riscv_qemu_heap_start()
    )
    rt_display_init()
    rt_display_flush_test()
    log_raw_println("SIMPLEOS_RISCV_DISPLAY_SMOKE_READY")
    rt_riscv_wfi_forever()
