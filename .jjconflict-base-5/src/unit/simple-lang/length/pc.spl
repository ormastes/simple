# Unit: Pc
# Kind: Length
# Symbol: pc
# Canonical scale: 3.0857e+16 m

class Pc:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Pc) -> Pc: Pc(value: self.value + other.value)
    fn sub(other: Pc) -> Pc: Pc(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "pc"
    static fn scale_to_base() -> f64: 3.0857e+16
    static fn base_unit() -> text: "m"
    static fn zero() -> Pc: Pc(value: 0.0)

export Pc
