"""
# No-GC Async Config Loader

Compatibility facade over the no-GC sync config backend. Config file loading is
a synchronous file operation, so the async family reuses the shared no-GC
declaration owner.
"""

export use std.nogc_sync_mut.conf.{
    Conf, conf_from_sdn, conf_from_file, conf_empty, conf_get, conf_get_or,
    conf_get_int, conf_get_bool, conf_has, conf_parse_kv_line
}
