# Mime Type Lookup
#
# Maps file extensions to Content-Type strings for HTTP response headers.
# Used by SWA web server and static file serving.

"""Get Content-Type string from file extension.

Args:
    ext: File extension without dot (e.g. "html", "css", "js")

Returns:
    Content-Type string (e.g. "text/html")

sdoctest:
    expect(mime_from_extension("html")).to_equal("text/html")
    expect(mime_from_extension("css")).to_equal("text/css")
    expect(mime_from_extension("unknown")).to_equal("application/octet-stream")
"""
fn mime_from_extension(ext: text) -> text:
    var result = "application/octet-stream"

    if ext == "html":
        result = "text/html"
    elif ext == "htm":
        result = "text/html"
    elif ext == "css":
        result = "text/css"
    elif ext == "js":
        result = "application/javascript"
    elif ext == "mjs":
        result = "application/javascript"
    elif ext == "json":
        result = "application/json"
    elif ext == "png":
        result = "image/png"
    elif ext == "jpg":
        result = "image/jpeg"
    elif ext == "jpeg":
        result = "image/jpeg"
    elif ext == "gif":
        result = "image/gif"
    elif ext == "svg":
        result = "image/svg+xml"
    elif ext == "ico":
        result = "image/x-icon"
    elif ext == "woff":
        result = "font/woff"
    elif ext == "woff2":
        result = "font/woff2"
    elif ext == "ttf":
        result = "font/ttf"
    elif ext == "eot":
        result = "application/vnd.ms-fontobject"
    elif ext == "txt":
        result = "text/plain"
    elif ext == "xml":
        result = "text/xml"
    elif ext == "pdf":
        result = "application/pdf"
    elif ext == "zip":
        result = "application/zip"
    elif ext == "wasm":
        result = "application/wasm"
    elif ext == "mp3":
        result = "audio/mpeg"
    elif ext == "mp4":
        result = "video/mp4"
    elif ext == "webp":
        result = "image/webp"
    elif ext == "webm":
        result = "video/webm"

    result

"""Get Content-Type string from file path.

Extracts the extension from the path and looks up the mime type.

Args:
    path: File path (e.g. "public/css/style.css")

Returns:
    Content-Type string

sdoctest:
    expect(mime_from_path("style.css")).to_equal("text/css")
    expect(mime_from_path("images/logo.png")).to_equal("image/png")
    expect(mime_from_path("noext")).to_equal("application/octet-stream")
"""
fn mime_from_path(path: text) -> text:
    val dot_idx = path.last_index_of(".")
    if dot_idx == nil:
        return "application/octet-stream"

    val ext = path[(dot_idx + 1):]
    mime_from_extension(ext)
