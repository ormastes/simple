use std.db.dbfs_engine.schema.{InodeRow, DentryRow, InodeTable, DentryTable, InodeKey, DentryKey}
use std.database.atomic.{get_timestamp}

val PERM_READ: u32  = 4
val PERM_WRITE: u32 = 2
val PERM_EXEC: u32  = 1

# POSIX inode type bits (top 4 bits of mode)
val S_IFDIR: u32 = 16384   # 0o040000
val S_IFREG: u32 = 32768   # 0o100000
val S_IFMT:  u32 = 61440   # 0xF000

struct FileMeta:
    ino_id: i64
    path: text
    name: text
    parent_ino: i64
    mode: u32
    uid: u32
    gid: u32
    size: i64
    mtime: i64
    ctime: i64
    link_count: i64
    gen: i64
    flags: u32
    is_dir: bool
    is_file: bool

fn file_meta_from_inode(inode: InodeRow, path: text, name: text, parent_ino: i64) -> FileMeta:
    val type_bits = inode.mode & S_IFMT
    FileMeta(
        ino_id: inode.ino_id,
        path: path,
        name: name,
        parent_ino: parent_ino,
        mode: inode.mode,
        uid: inode.uid,
        gid: inode.gid,
        size: inode.size,
        mtime: inode.mtime,
        ctime: inode.ctime,
        link_count: inode.link_count,
        gen: inode.gen,
        flags: inode.flags,
        is_dir: type_bits == S_IFDIR,
        is_file: type_bits == S_IFREG
    )

struct HintEntry:
    path: text
    ino_id: i64
    gen: i64
    cached_at: i64
    access_count: i64

struct InodeHintsCache:
    entries: Dict<text, HintEntry>
    max_entries: i64
    hit_count: i64
    miss_count: i64

impl InodeHintsCache:
    static fn new(capacity: i64) -> InodeHintsCache:
        InodeHintsCache(entries: {}, max_entries: capacity, hit_count: 0, miss_count: 0)

    me fn put(path: text, ino_id: i64, generation: i64):
        val existing = self.entries.get(path)
        val count = match existing:
            Some(entry): entry.access_count
            None: 0
        if not existing.? and self.entries.keys().len() as i64 >= self.max_entries:
            self.evict_lru()
        self.entries[path] = HintEntry(
            path: path,
            ino_id: ino_id,
            gen: generation,
            cached_at: get_timestamp(),
            access_count: count
        )

    me fn get(path: text) -> HintEntry?:
        val entry = self.entries.get(path)
        if entry.?:
            self.hit_count = self.hit_count + 1
            val e = match entry:
                Some(value): value
                None: return nil
            self.entries[path] = HintEntry(
                path: e.path,
                ino_id: e.ino_id,
                gen: e.gen,
                cached_at: e.cached_at,
                access_count: e.access_count + 1
            )
            return self.entries.get(path)
        self.miss_count = self.miss_count + 1
        nil

    me fn invalidate(path: text):
        self.entries.remove(path)

    me fn invalidate_prefix(prefix: text):
        var to_remove: [text] = []
        for key in self.entries.keys():
            if key.starts_with(prefix):
                to_remove.push(key)
        var i: i32 = 0
        while i < to_remove.len() as i32:
            self.entries.remove(to_remove[i])
            i = i + 1

    me fn evict_lru():
        var min_count: i64 = -1
        var min_key: text = ""
        for key in self.entries.keys():
            val entry = self.entries.get(key)
            if entry.?:
                val e = match entry:
                    Some(value): value
                    None: continue
                if min_count < 0 or e.access_count < min_count:
                    min_count = e.access_count
                    min_key = key
        if min_key.len() > 0:
            self.entries.remove(min_key)

    fn hit_rate() -> f64:
        val total = self.hit_count + self.miss_count
        if total == 0:
            return 0.0
        self.hit_count as f64 / total as f64

    me fn clear():
        self.entries = {}

fn resolve_path(path: text, dentries: DentryTable, inodes: InodeTable, cache: InodeHintsCache) -> Result<FileMeta, text>:
    val cached = cache.get(path)
    if cached.?:
        val hint = match cached:
            Some(value): value
            None: HintEntry(path: "", ino_id: -1, gen: -1, cached_at: 0, access_count: 0)
        val inode_result = inodes.get(InodeKey(ino_id: hint.ino_id))
        if inode_result.is_ok():
            val inode = match inode_result:
                Ok(value): value
                Err(_): return Err("resolve_path: cached inode not found: {hint.ino_id}")
            if inode.gen == hint.gen:
                val parts = path.split("/")
                val name = if parts.len() > 0: parts[parts.len() - 1] else: ""
                val parent_path_parts_len = parts.len() - 1
                var parent_path: text = ""
                var pi: i32 = 0
                while pi < parent_path_parts_len as i32:
                    if pi > 0:
                        parent_path = parent_path + "/"
                    parent_path = parent_path + parts[pi]
                    pi = pi + 1
                val parent_dentry = dentries.find_child_accel(1, name)
                val parent_ino = match parent_dentry:
                    Ok(value): value.child_ino
                    Err(_): 1
                return Ok(file_meta_from_inode(inode, path, name, parent_ino))

    # Cache miss: walk dentry chain from root (ino=1)
    val components = path.split("/")
    var cur_ino: i64 = 1
    var prev_ino: i64 = 1
    var i: i32 = 0
    while i < components.len() as i32:
        val component = components[i]
        if component.len() == 0:
            i = i + 1
            continue
        val dentry_result = dentries.find_child_accel(cur_ino, component)
        if not dentry_result.is_ok():
            return Err("resolve_path: component not found: {component}")
        prev_ino = cur_ino
        val dentry = match dentry_result:
            Ok(value): value
            Err(_): return Err("resolve_path: component not found: {component}")
        cur_ino = dentry.child_ino
        i = i + 1

    val inode_result = inodes.get(InodeKey(ino_id: cur_ino))
    if not inode_result.is_ok():
        return Err("resolve_path: inode not found: {cur_ino}")
    val inode = match inode_result:
        Ok(value): value
        Err(_): return Err("resolve_path: inode not found: {cur_ino}")
    cache.put(path, cur_ino, inode.gen)

    val parts = path.split("/")
    val name = if parts.len() > 0: parts[parts.len() - 1] else: ""
    Ok(file_meta_from_inode(inode, path, name, prev_ino))

struct DirEntry:
    name: text
    meta: FileMeta

fn batch_stat(parent_ino: i64, parent_path: text, dentries: DentryTable, inodes: InodeTable) -> [DirEntry]:
    val children = dentries.list_children(parent_ino)
    var result: [DirEntry] = []
    var i: i32 = 0
    while i < children.len() as i32:
        val child = children[i]
        val inode_result = inodes.get(InodeKey(ino_id: child.child_ino))
        if inode_result.is_ok():
            val inode = match inode_result:
                Ok(value): value
                Err(_):
                    i = i + 1
                    continue
            val child_path = if parent_path == "/" or parent_path.len() == 0:
                "/{child.name}"
            else:
                "{parent_path}/{child.name}"
            val meta = file_meta_from_inode(inode, child_path, child.name, parent_ino)
            result.push(DirEntry(name: child.name, meta: meta))
        i = i + 1
    result

fn check_permission(meta: FileMeta, request_uid: u32, request_gid: u32, perm: u32) -> bool:
    if request_uid == 0:
        return true
    if request_uid == meta.uid:
        return ((meta.mode >> 6) & perm) != 0
    if request_gid == meta.gid:
        return ((meta.mode >> 3) & perm) != 0
    (meta.mode & perm) != 0

fn check_read(meta: FileMeta, uid: u32, gid: u32) -> bool:
    check_permission(meta, uid, gid, PERM_READ)

fn check_write(meta: FileMeta, uid: u32, gid: u32) -> bool:
    check_permission(meta, uid, gid, PERM_WRITE)

fn check_exec(meta: FileMeta, uid: u32, gid: u32) -> bool:
    check_permission(meta, uid, gid, PERM_EXEC)
