# Lua C API SFFI Bindings
#
# Minimal extern declarations for building a luaopen_<name> C module and
# a plain C-ABI function accessible via LuaJIT ffi.cdef/ffi.load.
#
# Pattern: opaque lua_State pointer represented as i64.
# Only the symbols needed for the demo (register one function into a table).
#
# Usage in a luaopen_* function:
#   1. lua_createtable(L, 0, 1)
#   2. lua_pushcfunction(L, <fn ptr>)   -- fn ptr via @export("C") wrapper
#   3. lua_setfield(L, -2, "square")
#   4. return 1  (returns the table on the Lua stack)
#
# Or use luaL_newlib / luaL_setfuncs for the structured registration path.
# Those require a luaL_Reg array (pointer) which Simple cannot construct
# without C-level struct support; use the manual push+setfield approach.

# ============================================================================
# Stack / state manipulation
# ============================================================================

extern fn lua_gettop(L: i64) -> i64
# lua_settop(L, idx) — resize stack to idx elements
extern fn lua_settop(L: i64, idx: i64)

# ============================================================================
# Push values
# ============================================================================

extern fn lua_pushnumber(L: i64, n: f64)
extern fn lua_pushinteger(L: i64, n: i64)
# lua_pushcfunction — pushes a C function pointer (i64 in Simple ABI)
extern fn lua_pushcfunction(L: i64, fn_ptr: i64)

# ============================================================================
# Read values
# ============================================================================

extern fn lua_tonumber(L: i64, idx: i64) -> f64
extern fn lua_tointeger(L: i64, idx: i64) -> i64

# ============================================================================
# Table operations
# ============================================================================

# lua_createtable(L, narr, nrec) — creates a new empty table
extern fn lua_createtable(L: i64, narr: i64, nrec: i64)
# lua_setfield(L, idx, k) — t[k] = v where v is TOS
extern fn lua_setfield(L: i64, idx: i64, k: text)
