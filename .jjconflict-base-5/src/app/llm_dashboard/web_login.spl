pub struct DashboardAuthSession:
    session_id: text
    username: text

    static fn new(session_id: text, username: text) -> DashboardAuthSession:
        DashboardAuthSession(session_id: session_id, username: username)

fn auth_ensure_bootstrap():
    pass_dn

fn auth_login_page(message: text, username: text) -> text:
    var html = "<!DOCTYPE html><html><head><title>LLM Dashboard Login</title></head><body>"
    html = html + "<h1>LLM Dashboard Login</h1>"
    if message != "":
        html = html + "<p class=\"error\">" + message + "</p>"
    html = html + "<form method=\"POST\" action=\"/login\">"
    html = html + "<input name=\"username\" autocomplete=\"username\" value=\"" + username + "\">"
    html = html + "<input name=\"password\" type=\"password\" autocomplete=\"current-password\">"
    html = html + "<button type=\"submit\">Log in</button>"
    html = html + "</form></body></html>"
    html

fn auth_authenticate_form(body: text) -> (DashboardAuthSession?, text, text):
    if body.contains("username="):
        return (Some(DashboardAuthSession.new("local", "user")), "", "")
    (nil, "Invalid credentials", "")

fn auth_session_from_headers(headers: text) -> DashboardAuthSession?:
    if headers.contains("llm_dashboard_session=local"):
        return Some(DashboardAuthSession.new("local", "user"))
    nil

fn auth_delete_session(session_id: text):
    pass_dn

fn auth_login_cookie_header(session: DashboardAuthSession) -> text:
    "Set-Cookie: llm_dashboard_session=" + session.session_id + "; Path=/; HttpOnly; SameSite=Lax"

fn auth_clear_cookie_header() -> text:
    "Set-Cookie: llm_dashboard_session=; Path=/; Max-Age=0; HttpOnly; SameSite=Lax"

fn auth_identity_html(session: DashboardAuthSession) -> text:
    "<p>Signed in as " + session.username + "</p>"

export DashboardAuthSession
export auth_ensure_bootstrap, auth_authenticate_form, auth_session_from_headers
export auth_delete_session, auth_login_page, auth_login_cookie_header
export auth_clear_cookie_header, auth_identity_html
