use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.abi.syscall_shim.{g_shim_scheduler, g_shim_ipc, _make_args}

# ===========================================================================
# syscall 30 — file_open   [IMPLEMENTED]
#
# a0 = pointer to path string (user VA)
# a1 = path length in bytes
# a2 = flags (O_RDONLY / O_WRONLY / O_RDWR / O_CREAT ...)
# a3..a5 unused
# returns file descriptor (non-negative) on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_file_open")
fn spl_handle_file_open(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_file_open stub.

    Forwards to _handle_file_open() in syscall.spl.
    Syscall number 30: open a file by path and return a file descriptor.
    """
    val args = _make_args(30, a0, a1, a2, a3, a4, a5)
    val result = _handle_file_open(args, g_shim_scheduler, g_shim_ipc)
    result.value

# ===========================================================================
