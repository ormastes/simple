# File syscall shims — split from syscall_shim.spl (Wave 10F).
# Contains spl_handle_* for file syscalls 30–48 and POSIX process shims 57–69.

use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}
use os.kernel.ipc.syscall.{_handle_file_open}
