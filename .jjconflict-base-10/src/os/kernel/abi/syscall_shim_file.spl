# ===========================================================================
@export("C", name: "spl_handle_file_read")
fn spl_handle_file_read(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_file_read stub.

