@export("C", name: "spl_handle_fork")
fn spl_handle_fork(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_fork stub.

    Syscall number 57: clone the calling task into a new child.
    Forwards to the scheduler-backed fork handler.
    """
    val args = _make_args(57, a0, a1, a2, a3, a4, a5)
    val result = _handle_fork(args, g_shim_scheduler)
    result.value

