extern fn spl_dlopen(path: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64
extern fn rt_env_get(name: text) -> text
extern fn rt_file_exists(path: text) -> bool

use os.game.steam.support_api.{
    steam_api_backend_required_os_capabilities,
    steam_api_backend_required_symbols,
    steam_api_probe_backend
}

class SteamSffiBackendPlan:
    env_var: text
    bridge_abi: text
    candidates: [text]
    required_symbols: [text]
    required_os_capabilities: [text]

class SteamSffiBackendStatus:
    path: text
    handle: i64
    client_present: bool
    required_symbol_count: i64
    matched_symbol_count: i64
    required_os_capability_count: i64
    matched_os_capability_count: i64
    mock_bridge: bool
    real_backend_ready: bool
    ready: bool
    blocker: text

pub fn steam_sffi_bridge_env_var() -> text:
    "SIMPLE_STEAM_BRIDGE_PATH"

pub fn steam_sffi_bridge_abi() -> text:
    "simple-steam-sffi-v1"

pub fn steam_sffi_bridge_candidates() -> [text]:
    [
        "build/os/game/steam/libsimple_steam_bridge.so",
        "build/os/game/steam/libsimple_steam_bridge.dylib",
        "build/os/game/steam/simple_steam_bridge.dll",
        "build/os/game/steam/libsteam_api.so",
        "build/os/game/steam/steam_api64.dll",
        "third_party/steamworks/redistributable_bin/linux64/libsteam_api.so",
        "third_party/steamworks/redistributable_bin/win64/steam_api64.dll",
        "sdk/steamworks/redistributable_bin/linux64/libsteam_api.so"
    ]

pub fn steam_sffi_bridge_health_symbols() -> [text]:
    [
        "simple_steam_bridge_is_mock",
        "simple_steam_bridge_real_backend_ready"
    ]

pub fn steam_sffi_backend_plan() -> SteamSffiBackendPlan:
    SteamSffiBackendPlan(
        env_var: steam_sffi_bridge_env_var(),
        bridge_abi: steam_sffi_bridge_abi(),
        candidates: steam_sffi_bridge_candidates(),
        required_symbols: steam_api_backend_required_symbols(),
        required_os_capabilities: steam_api_backend_required_os_capabilities()
    )

pub fn steam_sffi_find_bridge_path_from_candidates(env_path: text, existing_candidates: [text]) -> text:
    if env_path != "":
        return env_path
    for candidate in steam_sffi_bridge_candidates():
        for existing in existing_candidates:
            if candidate == existing:
                return candidate
    ""

pub fn steam_sffi_find_bridge_path() -> text:
    val env_path = rt_env_get(steam_sffi_bridge_env_var())
    if env_path != "" and rt_file_exists(env_path):
        return env_path
    for candidate in steam_sffi_bridge_candidates():
        if rt_file_exists(candidate):
            return candidate
    ""

fn _steam_sffi_contains(items: [text], expected: text) -> bool:
    for item in items:
        if item == expected:
            return true
    false

fn _steam_sffi_symbols_from_handle(handle: i64) -> [text]:
    var symbols: [text] = []
    if handle == 0:
        return symbols
    for symbol in steam_api_backend_required_symbols():
        if spl_dlsym(handle, symbol) != 0:
            symbols.push(symbol)
    symbols

fn _steam_sffi_call0_bool(handle: i64, symbol: text) -> bool:
    if handle == 0:
        return false
    val fptr = spl_dlsym(handle, symbol)
    if fptr == 0:
        return false
    var args: [i64] = []
    spl_wffi_call_i64(fptr, args, 0) != 0

pub fn steam_sffi_probe_from_evidence_with_health(path: text, handle: i64, client_present: bool, available_symbols: [text], available_os_capabilities: [text], mock_bridge: bool, real_backend_ready: bool) -> SteamSffiBackendStatus:
    val probe = steam_api_probe_backend(client_present, available_symbols, available_os_capabilities)
    var blocker = probe.blocker
    if path == "":
        blocker = "missing Steam SFFI bridge path"
    else if handle == 0:
        blocker = "failed to load Steam SFFI bridge"
    else if mock_bridge:
        blocker = "Steam SFFI bridge is a mock fixture"
    else if real_backend_ready == false:
        blocker = "Steam SFFI bridge has no real Valve backend"
    SteamSffiBackendStatus(
        path: path,
        handle: handle,
        client_present: client_present,
        required_symbol_count: probe.required_symbol_count,
        matched_symbol_count: probe.matched_symbol_count,
        required_os_capability_count: probe.required_os_capability_count,
        matched_os_capability_count: probe.matched_os_capability_count,
        mock_bridge: mock_bridge,
        real_backend_ready: real_backend_ready,
        ready: blocker == "" and probe.ready and mock_bridge == false and real_backend_ready,
        blocker: blocker
    )

pub fn steam_sffi_probe_from_evidence(path: text, handle: i64, client_present: bool, available_symbols: [text], available_os_capabilities: [text]) -> SteamSffiBackendStatus:
    steam_sffi_probe_from_evidence_with_health(path, handle, client_present, available_symbols, available_os_capabilities, false, true)

pub fn steam_sffi_probe_handle(path: text, handle: i64, client_present: bool, available_os_capabilities: [text]) -> SteamSffiBackendStatus:
    val mock_bridge = _steam_sffi_call0_bool(handle, "simple_steam_bridge_is_mock")
    val real_backend_ready = _steam_sffi_call0_bool(handle, "simple_steam_bridge_real_backend_ready")
    steam_sffi_probe_from_evidence_with_health(path, handle, client_present, _steam_sffi_symbols_from_handle(handle), available_os_capabilities, mock_bridge, real_backend_ready)

pub fn steam_sffi_probe_bridge(path: text, client_present: bool, available_os_capabilities: [text]) -> SteamSffiBackendStatus:
    if path == "":
        return steam_sffi_probe_from_evidence("", 0, client_present, [], available_os_capabilities)
    val handle = spl_dlopen(path)
    steam_sffi_probe_handle(path, handle, client_present, available_os_capabilities)

pub fn steam_sffi_probe_configured_bridge(client_present: bool, available_os_capabilities: [text]) -> SteamSffiBackendStatus:
    steam_sffi_probe_bridge(steam_sffi_find_bridge_path(), client_present, available_os_capabilities)

pub fn steam_sffi_missing_symbols(available_symbols: [text]) -> [text]:
    var missing: [text] = []
    for symbol in steam_api_backend_required_symbols():
        if _steam_sffi_contains(available_symbols, symbol) == false:
            missing.push(symbol)
    missing

pub fn steam_sffi_missing_os_capabilities(available_os_capabilities: [text]) -> [text]:
    var missing: [text] = []
    for capability in steam_api_backend_required_os_capabilities():
        if _steam_sffi_contains(available_os_capabilities, capability) == false:
            missing.push(capability)
    missing
