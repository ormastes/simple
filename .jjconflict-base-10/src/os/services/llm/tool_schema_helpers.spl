# Shared JSON schema helpers for OS MCP tool definitions.

fn _llm_js(s: text) -> text:
    "\"" + s + "\""

fn _llm_jp(key: text, value: text) -> text:
    "\"" + key + "\":" + value

fn llm_tool_property(kind: text, description: text) -> text:
    var result = "{"
    result = result + _llm_jp("type", _llm_js(kind))
    result = result + "," + _llm_jp("description", _llm_js(description))
    result = result + "}"
    result

fn llm_tool_props0() -> text:
    "{}"

fn llm_tool_props1(name: text, value: text) -> text:
    "{" + _llm_jp(name, value) + "}"

fn llm_tool_props2(name1: text, value1: text, name2: text, value2: text) -> text:
    "{" + _llm_jp(name1, value1) + "," + _llm_jp(name2, value2) + "}"

fn llm_tool_props3(name1: text, value1: text, name2: text, value2: text, name3: text, value3: text) -> text:
    var result = "{"
    result = result + _llm_jp(name1, value1)
    result = result + "," + _llm_jp(name2, value2)
    result = result + "," + _llm_jp(name3, value3)
    result = result + "}"
    result

fn llm_tool_required0() -> text:
    "[]"

fn llm_tool_required1(name: text) -> text:
    "[" + _llm_js(name) + "]"

fn llm_tool_required2(name1: text, name2: text) -> text:
    "[" + _llm_js(name1) + "," + _llm_js(name2) + "]"

fn llm_tool_input_schema(props: text, required: text) -> text:
    var result = "{"
    result = result + _llm_jp("type", _llm_js("object"))
    result = result + "," + _llm_jp("properties", props)
    result = result + "," + _llm_jp("required", required)
    result = result + "}"
    result

fn llm_tool_annotations(read_only: text, destructive: text, idempotent: text) -> text:
    var result = "{"
    result = result + _llm_jp("readOnlyHint", read_only)
    result = result + "," + _llm_jp("destructiveHint", destructive)
    result = result + "," + _llm_jp("idempotentHint", idempotent)
    result = result + "}"
    result

fn llm_tool_schema(name: text, description: text, input_schema: text, annotations: text) -> text:
    var result = "{"
    result = result + _llm_jp("name", _llm_js(name))
    result = result + "," + _llm_jp("description", _llm_js(description))
    result = result + "," + _llm_jp("inputSchema", input_schema)
    result = result + "," + _llm_jp("annotations", annotations)
    result = result + "}"
    result
