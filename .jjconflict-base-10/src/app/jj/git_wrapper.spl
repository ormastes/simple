# Git-to-JJ Wrapper
#
# Simple (.spl) replacement for scripts/jj-wrappers/git.bat
# Redirects git commands to jj equivalents
# Helps LLMs use jj instead of git

use app.io.mod.{get_args, exit}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn forward_args(args: [text], start_idx: i64) -> text:
    """Build argument string from args starting at index"""
    var result = ""
    var idx = 0
    for arg in args:
        if idx >= start_idx:
            if result != "":
                result = result + " "
            result = result + arg
        idx = idx + 1
    result

fn main():
    val args = get_args()

    if args.len() < 2:
        print "Usage: simple run src/app/jj/git_wrapper.spl <git-command> [args...]"
        exit(1)

    val cmd = args[1]
    val rest = forward_args(args, 2)

    print "NOTE: This project now routes repository workflows through sj."
    print "      Translating 'git {cmd}' -> sj equivalent..."
    print ""

    var sj_args: [text] = []

    if cmd == "status":
        sj_args = ["git", "status"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "diff":
        sj_args = ["git", "diff"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "log":
        sj_args = ["git", "log"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "add":
        print "Note: jj auto-tracks files, no need to add"
        sj_args = ["git", "status"]
    elif cmd == "commit":
        sj_args = ["git", "commit"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "push":
        sj_args = ["git", "push"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "pull":
        sj_args = ["git", "pull"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "fetch":
        sj_args = ["raw", "jj", "git", "fetch"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "checkout":
        sj_args = ["git", "checkout"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "branch":
        sj_args = ["raw", "jj", "bookmark"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "stash":
        sj_args = ["git", "stash"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "init":
        sj_args = ["raw", "jj", "git", "init"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "clone":
        sj_args = ["raw", "jj", "git", "clone"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "show":
        sj_args = ["raw", "jj", "show"] + if rest == "": [] else: rest.split(" ")
    elif cmd == "reset":
        sj_args = ["git", "reset"] + if rest == "": [] else: rest.split(" ")
    else:
        print "Unknown git command: {cmd}"
        print "Use sj directly. Common commands:"
        print "  sj git status, sj git diff, sj git log, sj git commit -m ..."
        print "  sj git push --bookmark main, sj raw jj git fetch, sj git checkout <rev>"
        exit(1)

    val (stdout, stderr, code) = rt_process_run("bin/simple", ["run", "src/app/sj/main.spl"] + sj_args)
    if stdout != "":
        print stdout
    if stderr != "":
        print stderr
    exit(code)

main()
