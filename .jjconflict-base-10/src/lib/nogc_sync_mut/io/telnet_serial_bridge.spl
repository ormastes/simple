# Telnet-over-Serial Bridge (ser2net-style)
#
# Exposes a serial console (e.g. FPGA PL UART, SimpleOS/RISC-V boot console)
# as a telnet server so system tests can drive it from any telnet client.
#
#   serial device --dd--> rx capture file --> bridge --RFC 854--> TCP client
#   serial device <------- append writes <--- bridge <----------- TCP client
#
# Transport note: the interpreter has no serial extern dispatch (rt_serial_*
# resolves only in compiled code — see
# doc/08_tracking/bug/interpreter_serial_net_sffi_dispatch_gap.md), so the
# serial side is file-based: an external `stty + dd` reader appends device
# bytes to `rx_path`, and the bridge appends client bytes directly to
# `tx_path` (the device node). This uses only interpreter-verified
# primitives: native_tcp_*, rt_file_read_bytes, rt_file_append_text.
#
# Server negotiation policy: advertises WILL ECHO + WILL SGA (character-at-a-
# time console mode), refuses every option requested of it (DO -> WONT,
# WILL -> DONT), unescapes IAC IAC, and strips subnegotiation blocks.
#
# Byte-cliff note: client->device writes go through a text-typed append.
# Fine for ASCII consoles; do not use for binary transfer (xmodem etc.).

extern fn native_tcp_bind(addr: text) -> (i64, i64)
extern fn native_tcp_accept(handle: i64) -> Result<[i64], text>
extern fn native_tcp_read(handle: i64, max: i64) -> Result<[i64], text>
extern fn native_tcp_write(handle: i64, data: [i64]) -> Result<i64, text>
extern fn native_tcp_set_read_timeout(handle: i64, ms: i64) -> Result<i64, text>
extern fn native_tcp_set_nodelay(handle: i64, nodelay: bool) -> Result<i64, text>
extern fn native_tcp_close(handle: i64) -> i64
extern fn rt_file_read_bytes(path: text) -> [i64]?
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_bytes_to_text(data: [i64]) -> text
extern fn rt_sleep_ms(ms: i64)
extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Telnet protocol constants (RFC 854) — BRIDGE_ prefix avoids colliding with
# the client-side constants in net/telnet.spl when both are imported.
# ============================================================================

val BRIDGE_IAC = 255
val BRIDGE_DONT = 254
val BRIDGE_DO = 253
val BRIDGE_WONT = 252
val BRIDGE_WILL = 251
val BRIDGE_SB = 250
val BRIDGE_SE = 240
val BRIDGE_OPT_ECHO = 1
val BRIDGE_OPT_SGA = 3

# Poll interval for the relay loop (TCP read timeout doubles as the tick).
val BRIDGE_POLL_MS = 20

# ============================================================================
# Pure protocol helpers (spec-tested) — byte values carried as i64
# ============================================================================

struct TelnetFilterResult:
    """Result of filtering client bytes: console-clean data + protocol replies."""
    clean: [i64]
    replies: [i64]

fn bridge_initial_negotiation() -> [i64]:
    """Server greeting: WILL ECHO + WILL SGA puts clients in character mode."""
    var out: [i64] = []
    out.push(BRIDGE_IAC)
    out.push(BRIDGE_WILL)
    out.push(BRIDGE_OPT_ECHO)
    out.push(BRIDGE_IAC)
    out.push(BRIDGE_WILL)
    out.push(BRIDGE_OPT_SGA)
    out

fn bridge_filter_client_bytes(data: [i64]) -> TelnetFilterResult:
    """Strip IAC sequences from client bytes; build refusal replies.

    Policy:
    - IAC IAC        -> literal 255 data byte
    - IAC DO opt     -> reply IAC WONT opt (refuse), strip
    - IAC WILL opt   -> reply IAC DONT opt (refuse), strip
    - IAC DONT/WONT  -> strip silently (we never insisted)
    - IAC SB .. IAC SE -> strip whole subnegotiation
    - other IAC cmd  -> strip (NOP, AYT, BREAK, ...)
    """
    var clean: [i64] = []
    var replies: [i64] = []
    val len = data.length()
    var i = 0

    while i < len:
        val byte = data[i]
        if byte != BRIDGE_IAC:
            clean.push(byte)
            i = i + 1
        else:
            if i + 1 >= len:
                # Lone IAC at buffer end — drop
                i = i + 1
            else:
                val cmd = data[i + 1]
                if cmd == BRIDGE_IAC:
                    clean.push(BRIDGE_IAC)
                    i = i + 2
                else:
                    if cmd == BRIDGE_SB:
                        # Skip until IAC SE
                        i = i + 2
                        var sb_done = false
                        while (i < len and
                               not sb_done):
                            val sb_byte = data[i]
                            if sb_byte == BRIDGE_IAC and i + 1 < len:
                                val next = data[i + 1]
                                if next == BRIDGE_SE:
                                    i = i + 2
                                    sb_done = true
                                else:
                                    i = i + 1
                            else:
                                i = i + 1
                    else:
                        if (cmd == BRIDGE_DO or cmd == BRIDGE_DONT or
                            cmd == BRIDGE_WILL or cmd == BRIDGE_WONT):
                            if i + 2 < len:
                                val option = data[i + 2]
                                if cmd == BRIDGE_DO:
                                    replies.push(BRIDGE_IAC)
                                    replies.push(BRIDGE_WONT)
                                    replies.push(option)
                                if cmd == BRIDGE_WILL:
                                    replies.push(BRIDGE_IAC)
                                    replies.push(BRIDGE_DONT)
                                    replies.push(option)
                                i = i + 3
                            else:
                                # Truncated negotiation — drop remainder
                                i = i + 2
                        else:
                            # NOP / AYT / BREAK / other 2-byte command
                            i = i + 2

    TelnetFilterResult(clean: clean, replies: replies)

# ============================================================================
# Bridge runtime
# ============================================================================

struct BridgeConfig:
    """Bridge runtime configuration.

    rx_path:       file an external reader (stty + dd) appends device bytes to
    tx_path:       where client bytes go (the serial device node, or a file)
    max_sessions:  stop after serving N sessions (0 = serve forever)
    idle_limit_ms: close a session after this long with no traffic (0 = never)
    """
    rx_path: text
    tx_path: text
    bind_addr: text
    max_sessions: i64
    idle_limit_ms: i64

fn bridge_rx_pending(rx_path: text, rx_offset: i64) -> [i64]:
    """Return capture-file bytes past rx_offset (empty if none/missing)."""
    var fresh: [i64] = []
    val maybe = rt_file_read_bytes(rx_path)
    match maybe:
        Some(all):
            val total = all.length()
            var i = rx_offset
            while i < total:
                fresh.push(all[i])
                i = i + 1
        None:
            pass_do_nothing
    fresh

fn bridge_relay_session(stream: i64, cfg: BridgeConfig, rx_start: i64) -> (i64, i64):
    """Relay bytes between one telnet client and the serial transport.

    Returns (payload bytes relayed both directions, final rx offset).
    """
    var relayed = 0
    var rx_offset = rx_start
    # Wall-clock idle tracking: read timeouts on accepted sockets fire
    # instantly in the interpreter (SO_RCVTIMEO not honored), so tick
    # counting would expire idle limits ~1000x too fast. Pace explicitly
    # with rt_sleep_ms and measure idle by clock.
    var last_traffic_us = rt_time_now_unix_micros()
    var done = false

    while not done:
        var traffic = 0

        # Client -> serial device
        val r = native_tcp_read(stream, 4096)
        match r:
            Ok(res):
                val count = res[0]
                if count == 0:
                    # Orderly client disconnect
                    done = true
                else:
                    val payload = res[1]
                    val filtered = bridge_filter_client_bytes(payload)
                    if filtered.replies.length() > 0:
                        native_tcp_write(stream, filtered.replies)
                    if filtered.clean.length() > 0:
                        rt_file_append_text(cfg.tx_path, rt_bytes_to_text(filtered.clean))
                        traffic = traffic + filtered.clean.length()
            Err(e):
                # Read timeout — no client bytes this tick
                pass_do_nothing

        # Serial capture file -> client
        if not done:
            val fresh = bridge_rx_pending(cfg.rx_path, rx_offset)
            val fresh_len = fresh.length()
            if fresh_len > 0:
                native_tcp_write(stream, fresh)
                rx_offset = rx_offset + fresh_len
                traffic = traffic + fresh_len

        if traffic == 0:
            if not done:
                rt_sleep_ms(BRIDGE_POLL_MS)
                val now = rt_time_now_unix_micros()
                val idle_ms = (now - last_traffic_us) / 1000
                if cfg.idle_limit_ms > 0 and idle_ms >= cfg.idle_limit_ms:
                    done = true
        else:
            relayed = relayed + traffic
            last_traffic_us = rt_time_now_unix_micros()

    (relayed, rx_offset)

fn bridge_serve(cfg: BridgeConfig) -> i64:
    """Bind the telnet port and serve sessions per config.

    Accept blocks, so bound the whole process externally with `timeout`.
    Returns 0 if at least one session was served, 1 on setup failure.
    """
    val bind_addr = cfg.bind_addr
    val rx_path = cfg.rx_path
    val tx_path = cfg.tx_path

    val (listener, bind_err) = native_tcp_bind(bind_addr)
    if listener < 0:
        print("BRIDGE_ERROR=bind_failed addr={bind_addr} code={bind_err}")
        return 1

    print("BRIDGE_LISTENING addr={bind_addr} rx={rx_path} tx={tx_path}")
    var sessions = 0
    var rx_offset = 0
    var serving = true

    while serving:
        val accepted = native_tcp_accept(listener)
        match accepted:
            Ok(pair):
                val stream = pair[0]
                native_tcp_set_nodelay(stream, true)
                native_tcp_set_read_timeout(stream, BRIDGE_POLL_MS)
                native_tcp_write(stream, bridge_initial_negotiation())
                val (relayed, next_offset) = bridge_relay_session(stream, cfg, rx_offset)
                rx_offset = next_offset
                native_tcp_close(stream)
                sessions = sessions + 1
                print("BRIDGE_SESSION_DONE bytes={relayed} sessions={sessions}")
                if cfg.max_sessions > 0 and sessions >= cfg.max_sessions:
                    serving = false
            Err(e):
                print("BRIDGE_ERROR=accept_failed")
                serving = false

    native_tcp_close(listener)
    if sessions > 0:
        print("BRIDGE_DONE sessions={sessions}")
        return 0
    return 1

export TelnetFilterResult, BridgeConfig
export BRIDGE_IAC, BRIDGE_DONT, BRIDGE_DO, BRIDGE_WONT, BRIDGE_WILL, BRIDGE_SB, BRIDGE_SE
export BRIDGE_OPT_ECHO, BRIDGE_OPT_SGA
export bridge_initial_negotiation, bridge_filter_client_bytes
export bridge_rx_pending, bridge_relay_session, bridge_serve
