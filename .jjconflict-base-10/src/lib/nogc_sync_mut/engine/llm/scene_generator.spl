# Scene Generator
#
# Generates scene SDN data from natural language descriptions.
# This is the template/parser side — actual LLM call is external.
#
# Usage:
#   var gen = SceneGenerator.new()
#   gen.add_template("tree")
#   gen.add_template("player")
#   var obj = SceneObject.new("tree", "oak1", 10.0, 20.0)
#   obj.add_property("height: tall")
#   val scene = gen.generate_from_objects("forest", [obj])
#   val sdn = scene.to_sdn()

# ============================================================================
# SceneObject — single object in a generated scene
# ============================================================================

struct SceneObject:
    obj_type: text
    name: text
    x: f64
    y: f64
    properties: [text]

impl SceneObject:
    static fn new(obj_type: text, name: text, x: f64, y: f64) -> SceneObject:
        """Create a scene object at position."""
        SceneObject(obj_type: obj_type, name: name, x: x, y: y, properties: [])

    me add_property(prop: text):
        """Add a property string to this object."""
        self.properties.push(prop)

# ============================================================================
# GeneratedScene — collection of scene objects
# ============================================================================

struct GeneratedScene:
    name: text
    objects: [SceneObject]

impl GeneratedScene:
    static fn new(name: text) -> GeneratedScene:
        """Create an empty generated scene."""
        GeneratedScene(name: name, objects: [])

    me add_object(obj: SceneObject):
        """Add an object to the scene."""
        self.objects.push(obj)

    fn object_count() -> i32:
        """Return number of objects."""
        self.objects.len().to_i32()

    fn to_sdn() -> text:
        """Serialize scene to SDN-like text format."""
        var result = "scene: " + self.name + "\n"
        result = result + "objects:\n"
        var i = 0
        while i < self.objects.len():
            val obj = self.objects[i]
            result = result + "  - type: " + obj.obj_type + "\n"
            result = result + "    name: " + obj.name + "\n"
            result = result + "    position: (" + obj.x.to_text() + ", " + obj.y.to_text() + ")\n"
            var pi = 0
            while pi < obj.properties.len():
                result = result + "    " + obj.properties[pi] + "\n"
                pi = pi + 1
            i = i + 1
        result

# ============================================================================
# SceneGenerator — builds scenes from templates and objects
# ============================================================================

class SceneGenerator:
    templates: [text]

impl SceneGenerator:
    static fn new() -> SceneGenerator:
        """Create an empty scene generator."""
        SceneGenerator(templates: [])

    me add_template(template_name: text):
        """Register a known object template."""
        self.templates.push(template_name)

    fn has_template(name: text) -> bool:
        """Check if a template is registered."""
        var i = 0
        while i < self.templates.len():
            if self.templates[i] == name:
                return true
            i = i + 1
        false

    fn generate_from_objects(scene_name: text, objects: [SceneObject]) -> GeneratedScene:
        """Build a GeneratedScene from explicit objects."""
        var scene = GeneratedScene.new(scene_name)
        var i = 0
        while i < objects.len():
            scene.add_object(objects[i])
            i = i + 1
        scene

    fn template_count() -> i32:
        """Return number of registered templates."""
        self.templates.len().to_i32()
