# SCV core constants and path helpers.

fn scv_repo_dir(root: text) -> text:
    "{root}/.scv"

fn scv_meta_dir(root: text) -> text:
    "{scv_repo_dir(root)}/meta"

fn scv_objects_dir(root: text) -> text:
    "{scv_repo_dir(root)}/objects"

fn scv_parsers_dir(root: text) -> text:
    "{scv_repo_dir(root)}/parsers"

fn scv_head_path(root: text) -> text:
    "{scv_repo_dir(root)}/HEAD_OP"

fn scv_status_index_path(root: text) -> text:
    "{scv_meta_dir(root)}/status_index.sdn"

fn scv_workspace_path(root: text) -> text:
    "{scv_meta_dir(root)}/workspaces.sdn"

fn scv_bookmarks_path(root: text) -> text:
    "{scv_meta_dir(root)}/bookmarks.sdn"

fn scv_parser_lock_path(root: text) -> text:
    "{scv_meta_dir(root)}/parsers.sdn"

fn scv_langmap_path(root: text) -> text:
    "{scv_meta_dir(root)}/langmap.sdn"

fn scv_parser_index_path(root: text) -> text:
    "{scv_meta_dir(root)}/parser_index.sdn"

fn scv_object_index_path(root: text) -> text:
    "{scv_meta_dir(root)}/object_index.sdn"

fn scv_object_path(root: text, kind: text, id: text) -> text:
    "{scv_objects_dir(root)}/{kind}/{id}.sdn"

fn scv_chunk_path(root: text, id: text) -> text:
    "{scv_objects_dir(root)}/chunks/{id}.blob"

fn scv_rel_path(root: text, path: text) -> text:
    if path.starts_with("{root}/"):
        path[root.len() + 1:]
    else:
        path

fn scv_is_repo_path(path: text) -> bool:
    path.contains("/.scv/") or path.ends_with("/.scv")

fn scv_state_private() -> text:
    "private_dirty"

fn scv_state_parsed_error() -> text:
    "parsed_error"

fn scv_state_parsed_ok() -> text:
    "parsed_ok"

fn scv_state_compile_ok() -> text:
    "compile_ok"

fn scv_state_test_ok() -> text:
    "test_ok"

fn scv_state_public_ready() -> text:
    "public_ready"

fn scv_state_valid(state: text) -> bool:
    state == scv_state_private() or state == scv_state_parsed_error() or state == scv_state_parsed_ok() or state == scv_state_compile_ok() or state == scv_state_test_ok() or state == scv_state_public_ready()

fn scv_line_set_contains(lines: text, value: text) -> bool:
    ("\n" + lines).contains("\n{value}\n")

fn scv_metadata_path_safe(path: text) -> bool:
    path != "" and not path.contains("|") and not path.contains("\n") and not path.contains("\r")

fn scv_object_ref_safe(id: text, prefix: text) -> bool:
    id.starts_with(prefix) and scv_metadata_path_safe(id) and not id.contains("/") and not id.contains("\\") and not id.contains(" ")

fn scv_worktree_path_safe(path: text) -> bool:
    if not scv_metadata_path_safe(path):
        return false
    if path.starts_with("/") or path == "..":
        return false
    if path.contains("../") or path.contains("/.."):
        return false
    for reserved in [".scv", ".git", ".jj", ".simple"]:
        if path == reserved or path.starts_with("{reserved}/"):
            return false
    true

export scv_object_path
