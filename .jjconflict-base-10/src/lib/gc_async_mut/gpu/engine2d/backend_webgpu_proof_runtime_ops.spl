#[runtime_intrinsics]
extern fn rt_webgpu_create_device() -> i64
extern fn rt_webgpu_adapter_name(handle: i64) -> text
extern fn rt_webgpu_adapter_backend(handle: i64) -> text
extern fn rt_webgpu_is_stub(handle: i64) -> bool
extern fn rt_webgpu_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_webgpu_present(handle: i64) -> text
extern fn rt_webgpu_cleanup(handle: i64) -> i64

pub fn backend_webgpu_proof_create_device() -> i64:
    rt_webgpu_create_device()

pub fn backend_webgpu_proof_adapter_name(handle: i64) -> text:
    rt_webgpu_adapter_name(handle)

pub fn backend_webgpu_proof_adapter_backend(handle: i64) -> text:
    rt_webgpu_adapter_backend(handle)

pub fn backend_webgpu_proof_is_stub(handle: i64) -> bool:
    rt_webgpu_is_stub(handle)

pub fn backend_webgpu_proof_submit(handle: i64, cmd_count: i64) -> text:
    rt_webgpu_submit(handle, cmd_count)

pub fn backend_webgpu_proof_present(handle: i64) -> text:
    rt_webgpu_present(handle)

pub fn backend_webgpu_proof_cleanup(handle: i64) -> i64:
    rt_webgpu_cleanup(handle)
