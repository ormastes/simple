# CIE XYZ and CIELAB helpers for GUI color/image pipeline planning.
#
# Values use the common graphics convention where XYZ Y=100.0 for diffuse
# white. The default white point is D65, matching sRGB display surfaces.

use std.common.math.{math_abs, math_cbrt, math_pow}

pub val COLOR_WHITE_POINT_D65: text = "D65"
pub val COLOR_WHITE_POINT_D50: text = "D50"
pub val COLOR_SEMANTIC_DEFAULT_SPACE: text = "cielab"
pub val COLOR_CONNECTION_SPACE_XYZ: text = "cie_xyz"

pub class CieXyz:
    x: f64
    y: f64
    z: f64
    white_point: text

pub class CieLab:
    l: f64
    a: f64
    b: f64
    white_point: text

pub class PackedSurfacePlan:
    width: i64
    height: i64
    bytes_per_pixel: i64
    framebuffer_bytes: i64
    lab_xyz_full_frame_bytes: i64
    uses_packed_hot_path: bool
    initializes_color_transforms: bool
    initializes_tiff_decoder: bool
    initializes_jpegxl_decoder: bool
    default_semantic_space: text
    connection_space: text

pub fn cie_xyz_d65_white() -> CieXyz:
    CieXyz(x: 95.047, y: 100.0, z: 108.883, white_point: COLOR_WHITE_POINT_D65)

pub fn cie_xyz_d50_white() -> CieXyz:
    CieXyz(x: 96.422, y: 100.0, z: 82.521, white_point: COLOR_WHITE_POINT_D50)

fn _clamp_f64(v: f64, lo: f64, hi: f64) -> f64:
    if v < lo:
        return lo
    if v > hi:
        return hi
    v

fn _srgb_channel_to_linear(c: f64) -> f64:
    val n = _clamp_f64(c, 0.0, 255.0) / 255.0
    if n <= 0.04045:
        return n / 12.92
    math_pow((n + 0.055) / 1.055, 2.4)

fn _linear_channel_to_srgb(c: f64) -> i64:
    var n = 0.0
    if c <= 0.0031308:
        n = 12.92 * c
    else:
        n = (1.055 * math_pow(c, 1.0 / 2.4)) - 0.055
    val scaled = (_clamp_f64(n, 0.0, 1.0) * 255.0) + 0.5
    scaled.to_i64()

pub fn srgb_to_cie_xyz_d65(r: i64, g: i64, b: i64) -> CieXyz:
    val rl = _srgb_channel_to_linear(r as f64)
    val gl = _srgb_channel_to_linear(g as f64)
    val bl = _srgb_channel_to_linear(b as f64)
    CieXyz(
        x: (rl * 0.4124564 + gl * 0.3575761 + bl * 0.1804375) * 100.0,
        y: (rl * 0.2126729 + gl * 0.7151522 + bl * 0.0721750) * 100.0,
        z: (rl * 0.0193339 + gl * 0.1191920 + bl * 0.9503041) * 100.0,
        white_point: COLOR_WHITE_POINT_D65
    )

fn _lab_f(t: f64) -> f64:
    val delta = 6.0 / 29.0
    val delta3 = delta * delta * delta
    if t > delta3:
        return math_cbrt(t)
    (t / (3.0 * delta * delta)) + (4.0 / 29.0)

fn _lab_inv_f(t: f64) -> f64:
    val delta = 6.0 / 29.0
    if t > delta:
        return t * t * t
    3.0 * delta * delta * (t - (4.0 / 29.0))

pub fn cie_xyz_to_lab(xyz: CieXyz, white: CieXyz) -> CieLab:
    val fx = _lab_f(xyz.x / white.x)
    val fy = _lab_f(xyz.y / white.y)
    val fz = _lab_f(xyz.z / white.z)
    CieLab(
        l: (116.0 * fy) - 16.0,
        a: 500.0 * (fx - fy),
        b: 200.0 * (fy - fz),
        white_point: white.white_point
    )

pub fn lab_to_cie_xyz(lab: CieLab, white: CieXyz) -> CieXyz:
    val fy = (lab.l + 16.0) / 116.0
    val fx = fy + (lab.a / 500.0)
    val fz = fy - (lab.b / 200.0)
    CieXyz(
        x: white.x * _lab_inv_f(fx),
        y: white.y * _lab_inv_f(fy),
        z: white.z * _lab_inv_f(fz),
        white_point: white.white_point
    )

pub fn cie_xyz_d50_to_d65(xyz: CieXyz) -> CieXyz:
    CieXyz(
        x: (xyz.x * 0.9554734) + (xyz.y * (0.0 - 0.0230985)) + (xyz.z * 0.0632593),
        y: (xyz.x * (0.0 - 0.0283697)) + (xyz.y * 1.0099956) + (xyz.z * 0.0210414),
        z: (xyz.x * 0.0123140) + (xyz.y * (0.0 - 0.0205077)) + (xyz.z * 1.3303659),
        white_point: COLOR_WHITE_POINT_D65
    )

pub fn srgb_to_lab_d65(r: i64, g: i64, b: i64) -> CieLab:
    cie_xyz_to_lab(srgb_to_cie_xyz_d65(r, g, b), cie_xyz_d65_white())

pub fn cie_xyz_d65_to_srgb_packed_argb(xyz: CieXyz, alpha: i64) -> i64:
    val x = xyz.x / 100.0
    val y = xyz.y / 100.0
    val z = xyz.z / 100.0
    val r = _linear_channel_to_srgb((x * 3.2404542) + (y * (0.0 - 1.5371385)) + (z * (0.0 - 0.4985314)))
    val g = _linear_channel_to_srgb((x * (0.0 - 0.9692660)) + (y * 1.8760108) + (z * 0.0415560))
    val b = _linear_channel_to_srgb((x * 0.0556434) + (y * (0.0 - 0.2040259)) + (z * 1.0572252))
    var a = alpha
    if a < 0:
        a = 0
    if a > 255:
        a = 255
    (a * 16777216) + (r * 65536) + (g * 256) + b

pub fn cie_lab_d50_to_srgb_packed_argb(lab: CieLab, alpha: i64) -> i64:
    cie_xyz_d65_to_srgb_packed_argb(cie_xyz_d50_to_d65(lab_to_cie_xyz(lab, cie_xyz_d50_white())), alpha)

pub fn packed_argb_to_lab_d65(argb: i64) -> CieLab:
    val r = (argb / 65536) & 255
    val g = (argb / 256) & 255
    val b = argb & 255
    srgb_to_lab_d65(r, g, b)

pub fn plan_packed_8k_surface(width: i64, height: i64) -> PackedSurfacePlan:
    val pixels = width * height
    val framebuffer_bytes = pixels * 4
    PackedSurfacePlan(
        width: width,
        height: height,
        bytes_per_pixel: 4,
        framebuffer_bytes: framebuffer_bytes,
        lab_xyz_full_frame_bytes: pixels * 24,
        uses_packed_hot_path: true,
        initializes_color_transforms: false,
        initializes_tiff_decoder: false,
        initializes_jpegxl_decoder: false,
        default_semantic_space: COLOR_SEMANTIC_DEFAULT_SPACE,
        connection_space: COLOR_CONNECTION_SPACE_XYZ
    )

pub fn plan_8k_uhd_surface() -> PackedSurfacePlan:
    plan_packed_8k_surface(7680, 4320)

pub fn color_nearly_equal(a: f64, b: f64, tolerance: f64) -> bool:
    math_abs(a - b) <= tolerance
