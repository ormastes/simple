# Editor Buffer Undo Manager
#
# Undo/redo stack for buffer edits. Stores edit operations and
# supports stepping backward and forward through history.

struct UndoEntry:
    description: text
    inverse_op: text
    cursor_before_row: i64
    cursor_before_col: i64
    cursor_after_row: i64
    cursor_after_col: i64

struct UndoManager:
    undo_stack: [UndoEntry]
    redo_stack: [UndoEntry]
    max_depth: i64

fn undo_manager_new() -> UndoManager:
    UndoManager(undo_stack: [], redo_stack: [], max_depth: 200)

fn undo_manager_push(manager: UndoManager, entry: UndoEntry) -> UndoManager:
    var stack = manager.undo_stack
    stack.push(entry)
    if stack.len() > manager.max_depth:
        var trimmed: [UndoEntry] = []
        var i = stack.len() - manager.max_depth
        while i < stack.len():
            trimmed.push(stack[i])
            i = i + 1
        stack = trimmed
    UndoManager(undo_stack: stack, redo_stack: [], max_depth: manager.max_depth)

fn undo_manager_can_undo(manager: UndoManager) -> bool:
    manager.undo_stack.len() > 0

fn undo_manager_can_redo(manager: UndoManager) -> bool:
    manager.redo_stack.len() > 0

fn undo_manager_undo(manager: UndoManager) -> UndoManager:
    if manager.undo_stack.len() == 0:
        return manager
    val top = manager.undo_stack[manager.undo_stack.len() - 1]
    var undo_stack: [UndoEntry] = []
    var i = 0
    while i < manager.undo_stack.len() - 1:
        undo_stack.push(manager.undo_stack[i])
        i = i + 1
    var redo_stack = manager.redo_stack
    redo_stack.push(top)
    UndoManager(undo_stack: undo_stack, redo_stack: redo_stack, max_depth: manager.max_depth)

fn undo_manager_redo(manager: UndoManager) -> UndoManager:
    if manager.redo_stack.len() == 0:
        return manager
    val top = manager.redo_stack[manager.redo_stack.len() - 1]
    var redo_stack: [UndoEntry] = []
    var i = 0
    while i < manager.redo_stack.len() - 1:
        redo_stack.push(manager.redo_stack[i])
        i = i + 1
    var undo_stack = manager.undo_stack
    undo_stack.push(top)
    UndoManager(undo_stack: undo_stack, redo_stack: redo_stack, max_depth: manager.max_depth)
