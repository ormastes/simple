# ============================================================================
# Spec: RISC-V Common — Platform Contract & Dual-Arch Status
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv_common.platform.{RiscvPlatform, DualArchStatus, PLATFORM_QEMU_VIRT, PLATFORM_SIFIVE_U}

describe "RiscvPlatform":
    it "creates QEMU virt RV32 with correct defaults":
        val p = RiscvPlatform.qemu_virt_rv32()
        expect p.name == PLATFORM_QEMU_VIRT
        expect p.is_rv32() == true
        expect p.is_rv64() == false
        expect p.xlen() == 32
        expect p.isa_string == "rv32imac"
        expect p.ram_base == 0x80000000
        expect p.uart_base == 0x10000000
        expect p.plic_base == 0x0C000000

    it "creates QEMU virt RV64 with correct defaults":
        val p = RiscvPlatform.qemu_virt_rv64()
        expect p.name == PLATFORM_QEMU_VIRT
        expect p.is_rv32() == false
        expect p.is_rv64() == true
        expect p.xlen() == 64
        expect p.isa_string == "rv64gc"
        expect p.ram_base == 0x80000000

    it "creates SiFive U RV64":
        val p = RiscvPlatform.sifive_u_rv64()
        expect p.name == PLATFORM_SIFIVE_U
        expect p.is_rv64() == true
        expect p.hart_count == 5
        expect p.uart_base == 0x10010000

    it "summary contains platform name":
        val p = RiscvPlatform.qemu_virt_rv32()
        val s = p.summary()
        expect s.len() > 0

describe "DualArchStatus":
    it "starts with both arches not ready":
        val status = DualArchStatus.create()
        expect status.rv32_ready == false
        expect status.rv64_ready == false
        expect status.is_dual_ready() == false

    it "becomes dual-ready when both marked":
        var status = DualArchStatus.create()
        status.mark_rv32(PLATFORM_QEMU_VIRT)
        expect status.is_dual_ready() == false
        status.mark_rv64(PLATFORM_QEMU_VIRT)
        expect status.is_dual_ready() == true

    it "tracks platform names":
        var status = DualArchStatus.create()
        status.mark_rv32("qemu-virt")
        status.mark_rv64("sifive-u")
        expect status.rv32_platform == "qemu-virt"
        expect status.rv64_platform == "sifive-u"

    it "accumulates notes":
        var status = DualArchStatus.create()
        status.add_note("RV32 PLIC tested")
        status.add_note("RV64 SBI tested")
        expect status.notes.len() == 2

    it "summary reports readiness":
        var status = DualArchStatus.create()
        status.mark_rv32("qemu-virt")
        val s = status.summary()
        expect s.len() > 0
