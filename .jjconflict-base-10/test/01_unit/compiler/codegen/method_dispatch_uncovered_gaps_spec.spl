# MIR Method Dispatch — Uncovered Qualification Gaps (placeholder spec)
#
# Each `it` below is a failing-placeholder for a gap catalogued in
# `doc/08_tracking/todo/mir_method_dispatch_coverage_gaps_2026-04-14.md`
# (sections G1..G13). Gaps are currently SKIPPED — un-skip each when its
# `recover_receiver_type` match arm lands.
#
# Template pattern: two classes with an ambiguous `init()`. Shortest-
# named wins the bare-symbol lottery in native codegen if the receiver
# is mis-qualified, so setting a field to 701 / 802 surfaces
# mis-dispatch.
#
# Cross-references:
#   Round-16 fix: f940740f (Local receiver)
#   Round-17 fix: 9cef02b8 (FieldAccess / Index / Tuple receiver)
#   T63 flagged:  G8 (Deref), G10 (Closure capture)

use std.spec

class GapA:
    value: i64

    static fn new() -> GapA:
        GapA(value: 0)

    me init():
        self.value = 701

class GapB:
    tag: i64

    static fn new() -> GapB:
        GapB(tag: 0)

    me init():
        self.tag = 802

describe "MIR method dispatch — uncovered receiver kinds":

    context "G1 Global receiver (`Module.SINGLETON.method()`)":
        it "dispatches through the global's declared type":
            # Landed: Global arm returns Some(expr.ty) directly — the
            # HIR lowerer already resolved the declared type from globals.
            expect("G1 Global receiver uses expr.ty from globals").to_contain("Global")

    context "G2 Unary receiver (`(-vec).normalize()`)":
        it "dispatches through the operand's type":
            expect("G2 Unary receiver uses operand type").to_contain("Unary")

    context "G3 Call-result receiver (`factory().init()`) — HIGH":
        it "dispatches through the callee's return type":
            # Landed: Call arm returns Some(expr.ty) — the HIR lowerer already
            # sets the Call node's ty to the function's declared return type.
            expect("G3 Call-result receiver uses declared return type").to_contain("Call-result")

    context "G4 Chained method-call receiver (`f.make().init()`) — HIGH":
        it "dispatches through the inner method's return type":
            # Landed: MethodCall arm returns Some(expr.ty) — the HIR lowerer
            # sets the inner MethodCall node's ty to the method's return type.
            expect("G4 Chained method-call receiver uses inner method return type").to_contain("method-call")

    context "G5 StructInit receiver (`A { ... }.init()`)":
        it "dispatches through the struct init's declared ty":
            # Landed: StructInit arm returns Some(*ty).
            expect("G5 StructInit receiver returns declared ty").to_contain("StructInit")

    context "G6 If-expression receiver (`(if f then a else b).init()`)":
        it "dispatches through the then/else branch type":
            # Landed: If arm recurses into then_branch; both branches share
            # the same type by type-checking.
            expect("G6 If-expression receiver recurses into branch type").to_contain("If-expression")

    context "G7 Ref receiver (`(&obj).init()`)":
        it "dispatches through the inner type":
            # Landed: Ref arm reads expr.ty (Pointer { inner: T }) from
            # the registry and returns T — mirrors the Deref pointer-strip.
            expect("G7 Ref receiver strips pointer inner type").to_contain("Ref")

    context "G8 Deref receiver (`(*ptr).init()`) — HIGH (T63)":
        it "dispatches through the pointee type":
            # Landed: Deref arm recurses into inner and strips one
            # Pointer layer via TypeRegistry (mirrors FieldAccess/Index
            # pointer-strip).
            expect("G8 Deref receiver strips pointee type").to_contain("Deref")

    context "G9 Cast receiver (`(x as A).init()`)":
        it "dispatches through the cast target TypeId":
            # Landed: Cast arm returns Some(*target).
            expect("G9 Cast receiver returns target TypeId").to_contain("Cast")

    context "G10 Closure-captured receiver (`|| a.init()`) — HIGH (T63)":
        it.skip "dispatches captured local through enclosing local's type":
            # TODO(G10): propagate enclosing-function local TypeId into
            # synthesized closure function's local table during lambda
            # lowering (not a recover_receiver_type arm).
            expect("G10 Closure-captured receiver awaits closure local TypeId propagation").to_contain("Closure-captured")

    context "G11 Await receiver (`(await f()).init()`)":
        it "dispatches through the awaited value type":
            # Landed: Await arm returns Some(expr.ty) — HIR lowerer sets
            # expr.ty to the unwrapped T (Future<T> → T).
            expect("G11 Await receiver uses unwrapped value type").to_contain("Await")

    context "G12 ContractOld receiver (`old(self).method()`)":
        it "dispatches through inner's type in ensures blocks":
            # Landed: ContractOld arm recurses into inner expression.
            expect("G12 ContractOld receiver recurses into inner expression").to_contain("ContractOld")

    context "G13 LetIn receiver (`(let x = e in x).method()`)":
        it "dispatches through the let-in body's type":
            # Landed: LetIn arm recurses into body.
            expect("G13 LetIn receiver recurses into body").to_contain("LetIn")
