use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_spawn_sliced, multicore_green_set_parallelism, multicore_green_parallelism, MulticoreGreenSliceResult}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_thread_sleep(ms: i64)
extern fn rt_exit(code: i32)

fn step_counter(state: i64) -> MulticoreGreenSliceResult:
    val start = rt_time_now_unix_micros()
    var x = state
    while rt_time_now_unix_micros() - start < 1000:
        x = x + 1
    if state >= 50:
        return MulticoreGreenSliceResult.completed(2)
    MulticoreGreenSliceResult.continue_with(state + 1)

fn main() -> i64:
    multicore_green_set_parallelism(1)
    println("parallelism_before={multicore_green_parallelism()}")
    val sliced = multicore_green_spawn_sliced(0, step_counter)
    val sliced_used_pool = sliced.used_runtime_pool()
    println("sliced_used_runtime_pool={sliced_used_pool}")
    rt_thread_sleep(2)
    val quick = multicore_green_spawn(\: 7)
    rt_thread_sleep(20)
    val quick_done_during_slices = quick.is_done()
    println("quick_done_during_slices={quick_done_during_slices}")
    val total = sliced.join() + quick.join()
    println("parallelism_after_join={multicore_green_parallelism()}")
    println("total={total}")
    if total != 9:
        rt_exit(71)
    if !quick_done_during_slices:
        rt_exit(72)
    if multicore_green_parallelism() != 1:
        rt_exit(73)
    if !sliced_used_pool:
        rt_exit(74)
    0
