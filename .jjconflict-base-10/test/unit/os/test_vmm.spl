fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn shr(x: i64, n: i64) -> i64:
    x / (1 << n)

fn pml4i(addr: i64) -> i64:
    shr(addr, 39) & 0x1FF

fn main():
    print "=== VMM ==="
    check("pml4_0", pml4i(0) == 0)
    check("pml4_1", pml4i(0x8000000000) == 1)
    check("pg_off", (0xDEADBEEF & 0xFFF) == 0xEEF)
    check("pg_align", (0xDEAD0000 & 0xFFF) == 0)
    print "=== DONE ==="
