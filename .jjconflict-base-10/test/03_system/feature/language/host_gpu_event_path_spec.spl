"""
# Host/GPU Event Path Spec

## Overview

These scenarios prove the Engine2D evidence adapter can move from a host event
decision to queue submit and receipt evidence without requiring real GPU
hardware. They cover the production routing rule: unresolved, stale-cache, and
host-semantic events remain on host; coarse Draw IR batches can be queued to the
GPU lane.

The runtime scenarios also prove the bridge can emit real host/GPU queue
packets, expose an in-flight `submitted` state through the explicit
submit/complete phase API, and preserve the one-step drain compatibility path
used by existing callers.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** doc/03_plan/agent_tasks/real_host_gpu_runtime_queue_emission.md

## Design

**Design:** doc/04_architecture/ui/simple_gui_stack.md

## Research

**Research:** N/A

## Examples

The `should expose submitted state before runtime queue completion` scenario
emits one GPU packet, submits it without completing it, asserts
`status=submitted` and `in_flight_count=1`, then completes the packet and
asserts terminal `completed` status.
"""

use std.spec.*
use std.gpu.engine2d.backend_lane.{
    ENGINE2D_HOST_GPU_LANE_GPU,
    ENGINE2D_HOST_GPU_LANE_HOST,
    engine2d_host_gpu_lane_schedule
}
use std.gpu.engine2d.host_gpu_event_queue.{
    engine2d_host_gpu_event,
    engine2d_host_gpu_event_handler_decision,
    engine2d_host_gpu_event_submit,
    engine2d_host_gpu_submit_summary,
    engine2d_host_gpu_event_receipt,
    engine2d_host_gpu_receipt_summary,
    engine2d_host_gpu_runtime_queue,
    engine2d_host_gpu_runtime_queue_with_backend_handle,
    engine2d_host_gpu_event_submit_to_runtime,
    engine2d_host_gpu_runtime_submit_summary,
    engine2d_host_gpu_runtime_reset,
    engine2d_host_gpu_runtime_emit_packet,
    engine2d_host_gpu_runtime_submit_pending,
    engine2d_host_gpu_runtime_complete_pending,
    engine2d_host_gpu_runtime_drain,
    engine2d_host_gpu_runtime_drain_summary
}
use std.gpu.engine2d.host_gpu_draw_ir_event_flow.{
    engine2d_host_gpu_draw_ir_event_flow,
    engine2d_host_gpu_draw_ir_event_flow_summary
}

describe "host/GPU event path evidence":

    it "should submit a coarse GPU Draw IR batch as a queue packet":
        step("Create a host event with a GPU batch decision")
        val lane_result = engine2d_host_gpu_lane_schedule(
            ENGINE2D_HOST_GPU_LANE_HOST,
            ENGINE2D_HOST_GPU_LANE_GPU,
            "draw_ir_delta",
            256,
            4096,
            false,
            false,
            true,
            12
        )
        val event = engine2d_host_gpu_event("evt-gpu", ENGINE2D_HOST_GPU_LANE_GPU, "draw_ir_delta", 256, 4096, false, false, false, true)
        val decision = engine2d_host_gpu_event_handler_decision(event, lane_result)
        val submit = engine2d_host_gpu_event_submit(decision, lane_result)
        val receipt = engine2d_host_gpu_event_receipt(submit, lane_result)

        expect(decision.target_lane).to_equal(ENGINE2D_HOST_GPU_LANE_GPU)
        expect(decision.queue_required).to_be(true)
        expect(submit.queued).to_be(true)
        expect(receipt.gpu_batched).to_be(true)
        expect(engine2d_host_gpu_submit_summary(submit)).to_contain("kind=queue_packet")
        expect(engine2d_host_gpu_receipt_summary(receipt)).to_contain("gpu_batched=true")

    it "should keep unresolved or stale event targets on the host":
        step("Reject unsafe GPU routing before queue submission")
        val lane_result = engine2d_host_gpu_lane_schedule(
            ENGINE2D_HOST_GPU_LANE_HOST,
            ENGINE2D_HOST_GPU_LANE_GPU,
            "draw_ir_delta",
            128,
            4096,
            false,
            false,
            true,
            12
        )
        val unresolved = engine2d_host_gpu_event("evt-unresolved", ENGINE2D_HOST_GPU_LANE_GPU, "draw_ir_delta", 128, 4096, false, false, true, true)
        val stale = engine2d_host_gpu_event("evt-stale", ENGINE2D_HOST_GPU_LANE_GPU, "draw_ir_delta", 128, 4096, false, true, false, true)
        val unresolved_decision = engine2d_host_gpu_event_handler_decision(unresolved, lane_result)
        val stale_decision = engine2d_host_gpu_event_handler_decision(stale, lane_result)

        expect(unresolved_decision.target_lane).to_equal(ENGINE2D_HOST_GPU_LANE_HOST)
        expect(unresolved_decision.queue_required).to_be(false)
        expect(unresolved_decision.reason).to_contain("unresolved")
        expect(stale_decision.target_lane).to_equal(ENGINE2D_HOST_GPU_LANE_HOST)
        expect(stale_decision.queue_required).to_be(false)
        expect(stale_decision.reason).to_contain("stale")

    it "should route Draw IR event flow to GPU only for coarse non-semantic batches":
        step("Compare coarse GPU batch and host-semantic event routing")
        val gpu_flow = engine2d_host_gpu_draw_ir_event_flow("evt-flow-gpu", "draw_ir_delta", 512, 4096, true, false, false, false, true, 16)
        val host_flow = engine2d_host_gpu_draw_ir_event_flow("evt-flow-host", "draw_ir_delta", 512, 4096, true, true, false, false, true, 16)

        expect(gpu_flow.decision.target_lane).to_equal(ENGINE2D_HOST_GPU_LANE_GPU)
        expect(gpu_flow.submit.queued).to_be(true)
        expect(gpu_flow.receipt.gpu_batched).to_be(true)
        expect(engine2d_host_gpu_draw_ir_event_flow_summary(gpu_flow)).to_contain("queued=true")
        expect(host_flow.decision.target_lane).to_equal(ENGINE2D_HOST_GPU_LANE_HOST)
        expect(host_flow.submit.queued).to_be(false)
        expect(host_flow.receipt.committed_on_host).to_be(true)

    it "should emit and drain a runtime GPU queue packet with typed unavailable status":
        step("Emit a runtime queue packet for a GPU Draw IR batch")
        engine2d_host_gpu_runtime_reset()
        engine2d_host_gpu_runtime_emit_packet(2, 1, 512, 0)

        step("Drain without a backend and keep the unavailable status typed")
        val queue = engine2d_host_gpu_runtime_queue("typed-unavailable", 1, true, 4096)
        val drain = engine2d_host_gpu_runtime_drain(queue, 4)
        expect(drain.drained).to_equal(1)
        expect(drain.submitted_count).to_equal(1)
        expect(drain.completed_count).to_equal(1)
        expect(drain.last_status_code).to_equal(4)
        expect(drain.status).to_equal("typed_unavailable")
        expect(engine2d_host_gpu_runtime_drain_summary(drain)).to_contain("status=typed_unavailable")

    it "should expose submitted state before runtime queue completion":
        step("Emit a runtime queue packet and submit it without completion")
        engine2d_host_gpu_runtime_reset()
        engine2d_host_gpu_runtime_emit_packet(2, 1, 512, 7)
        val queue = engine2d_host_gpu_runtime_queue("vulkan", 7, true, 4096)
        val submitted = engine2d_host_gpu_runtime_submit_pending(queue, 1)

        expect(submitted.count).to_equal(1)
        expect(submitted.status).to_equal("submitted")
        expect(submitted.in_flight_count).to_equal(1)
        expect(submitted.submitted_count).to_equal(1)
        expect(submitted.completed_count).to_equal(0)
        expect(submitted.last_status_code).to_equal(2)

        step("Complete the in-flight packet and observe terminal completion")
        val completed = engine2d_host_gpu_runtime_complete_pending(queue, 1)
        expect(completed.count).to_equal(1)
        expect(completed.status).to_equal("completed")
        expect(completed.in_flight_count).to_equal(0)
        expect(completed.submitted_count).to_equal(1)
        expect(completed.completed_count).to_equal(1)
        expect(completed.last_status_code).to_equal(3)

    it "should distinguish runtime submission from evidence-only queueing":
        step("Submit only accepted GPU packet decisions to the runtime queue")
        engine2d_host_gpu_runtime_reset()
        val lane_result = engine2d_host_gpu_lane_schedule(
            ENGINE2D_HOST_GPU_LANE_HOST,
            ENGINE2D_HOST_GPU_LANE_GPU,
            "draw_ir_delta",
            512,
            4096,
            false,
            false,
            true,
            16
        )
        val event = engine2d_host_gpu_event("evt-runtime-gpu", ENGINE2D_HOST_GPU_LANE_GPU, "draw_ir_delta", 512, 4096, false, false, false, true)
        val decision = engine2d_host_gpu_event_handler_decision(event, lane_result)
        # A real runtime submission needs a positive backend handle (the GPU
        # backend the Draw IR packet dispatches to); evidence-only queueing uses
        # the plain constructor with backend_handle=0.
        val queue = engine2d_host_gpu_runtime_queue_with_backend_handle("vulkan", 7, 7, true, 4096)
        val runtime_submit = engine2d_host_gpu_event_submit_to_runtime(queue, decision, lane_result)

        expect(runtime_submit.submitted).to_be(true)
        expect(runtime_submit.packet_id).to_equal(1)
        expect(engine2d_host_gpu_runtime_submit_summary(runtime_submit)).to_contain("status=submitted")

        step("Refuse runtime submission when the queue is unavailable or packet is too large")
        val unavailable_queue = engine2d_host_gpu_runtime_queue("vulkan", 0, false, 4096)
        val unavailable_submit = engine2d_host_gpu_event_submit_to_runtime(unavailable_queue, decision, lane_result)
        val oversized_queue = engine2d_host_gpu_runtime_queue_with_backend_handle("vulkan", 7, 7, true, 128)
        val oversized_submit = engine2d_host_gpu_event_submit_to_runtime(oversized_queue, decision, lane_result)
        val runtime_drain = engine2d_host_gpu_runtime_drain(queue, 4)

        expect(unavailable_submit.submitted).to_be(false)
        expect(unavailable_submit.status).to_equal("runtime_unavailable")
        expect(oversized_submit.submitted).to_be(false)
        expect(oversized_submit.status).to_equal("packet_too_large")
        # The one accepted runtime submission emitted a real packet that drains to
        # completion on its backend handle; the rejected (unavailable / oversized)
        # submissions are evidence-only and emit nothing drainable.
        expect(runtime_drain.drained).to_equal(1)
        expect(runtime_drain.status).to_equal("completed")
        expect(runtime_drain.last_backend_handle).to_equal(7)
