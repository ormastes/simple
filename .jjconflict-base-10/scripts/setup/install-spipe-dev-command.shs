#!/bin/sh
# Install/check the Codex SPipe dev command wiring.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

MODE="${1:---apply}"

usage() {
    cat <<'EOF'
Usage: sh scripts/install-spipe-dev-command.shs [--apply|--check]

Ensures Codex development work routes through `.codex/skills/sp_dev/SKILL.md`
and the SPipe dev agent at `.claude/agents/spipe/dev.md`.

The retired standalone `.codex/skills/dev` command is removed in --apply mode
and reported as an error in --check mode.
EOF
}

case "$MODE" in
    --apply|--check) ;;
    -h|--help) usage; exit 0 ;;
    *) usage >&2; exit 2 ;;
esac

fail() {
    echo "spipe-dev-install: $1" >&2
    exit 1
}

require_file() {
    [ -f "$1" ] || fail "missing required file: $1"
}

require_file ".codex/skills/sp_dev/SKILL.md"
require_file ".claude/agents/spipe/dev.md"
require_file ".claude/skills/spipe.md"
require_file "scripts/check/check-spipe-submodule-gitlinks.shs"

if [ -e ".codex/skills/dev" ]; then
    if [ "$MODE" = "--apply" ]; then
        if [ -f ".codex/skills/dev/SKILL.md" ]; then
            rm -f ".codex/skills/dev/SKILL.md"
        fi
        rmdir ".codex/skills/dev" 2>/dev/null \
            || fail ".codex/skills/dev contains unexpected files; remove them manually"
        echo "removed retired .codex/skills/dev"
    else
        fail "retired .codex/skills/dev still exists"
    fi
fi

grep -q '^name: sp_dev$' .codex/skills/sp_dev/SKILL.md \
    || fail ".codex/skills/sp_dev/SKILL.md must declare name: sp_dev"
grep -q '.claude/agents/spipe/dev.md' .codex/skills/sp_dev/SKILL.md \
    || fail "sp_dev skill must link to .claude/agents/spipe/dev.md"
grep -q '.claude/skills/spipe.md' .codex/skills/sp_dev/SKILL.md \
    || fail "sp_dev skill must link to .claude/skills/spipe.md"

sh scripts/check/check-spipe-submodule-gitlinks.shs --check >/dev/null

echo "STATUS: PASS spipe-dev-command wiring"
