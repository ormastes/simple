#!/bin/sh
set -eu

ELECTRON_BITMAP_SCENE="${ELECTRON_BITMAP_SCENE:-simple-web-layout-image-text-command-taskbar}"
BUILD_DIR="${BUILD_DIR:-build/electron_simple_web_layout_image_text_command_taskbar_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/electron_simple_web_layout_image_text_command_taskbar_bitmap_evidence_$(date -u +%F).md}"
export ELECTRON_BITMAP_SCENE BUILD_DIR REPORT_PATH

exec sh scripts/check/check-electron-simple-web-layout-bitmap-evidence.shs
