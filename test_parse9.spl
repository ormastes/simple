use common.ui.parse.sdn.{parse_ui_file_inner, read_file, parse_to_flat, build_ui_tree}

fn main():
    print "Reading..."
    val source = read_file("examples/ui/demo.ui.sdn")
    print "Parsing flat..."
    val entries = parse_to_flat(source)
    print "Got entries, building tree..."
    val result = build_ui_tree(entries)
    print "Result: {result}"
