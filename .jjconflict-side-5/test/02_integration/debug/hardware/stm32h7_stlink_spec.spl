# STM32H7 via ST-Link Tools Integration Test (Combo 1)
# Requires: STM32H7 board connected via built-in STLINK-V3
# Serial: 002600213137510833333639
# NOTE: Uses local data-only validation since hardware may not be available.

# --- Local copies ---

class StLinkProbeConfig:
    serial: text
    chip_id: text
    flash_size_bytes: i64
    sram_min_bytes: i64
    description: text

impl StLinkProbeConfig:
    static fn stm32h7() -> StLinkProbeConfig:
        StLinkProbeConfig(
            serial: "002600213137510833333639",
            chip_id: "0x0480",
            flash_size_bytes: 2097152,
            sram_min_bytes: 131072,
            description: "STM32H7 via STLINK-V3"
        )

    fn flash_size_hex() -> text:
        "0x200000"

    fn flash_size_mb() -> i64:
        self.flash_size_bytes / (1024 * 1024)

    fn sram_min_kb() -> i64:
        self.sram_min_bytes / 1024

# --- Tests ---

describe "STM32H7 via ST-Link tools":
    it "probe config has correct serial":
        val cfg = StLinkProbeConfig.stm32h7()
        expect(cfg.serial).to_equal("002600213137510833333639")

    it "chip_id is 0x0480":
        val cfg = StLinkProbeConfig.stm32h7()
        expect(cfg.chip_id).to_equal("0x0480")

    it "flash size is 2MB":
        val cfg = StLinkProbeConfig.stm32h7()
        expect(cfg.flash_size_bytes).to_equal(2097152)
        expect(cfg.flash_size_hex()).to_equal("0x200000")
        expect(cfg.flash_size_mb()).to_equal(2)

    it "sram minimum is 128KB":
        val cfg = StLinkProbeConfig.stm32h7()
        expect(cfg.sram_min_kb()).to_equal(128)
        expect(cfg.sram_min_bytes).to_equal(131072)

    it "description includes board name":
        val cfg = StLinkProbeConfig.stm32h7()
        expect(cfg.description.contains("STM32H7")).to_equal(true)
