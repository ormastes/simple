# JIT Optimization Test: x86_64/x86_32 Mixed + I32 Narrowing
#
# Tests:
#   1. I32NarrowPass identifies safe operations (loop counters, arithmetic)
#   2. X86MixedJit compiles for x86_64 (Cranelift) — PASS/FAIL
#   3. X86MixedJit compiles for x86_32 (LLVM) — PASS or SKIP if no LLVM
#   4. Compile time with vs without i32 narrowing

use std.io
use std.jit.opt_i32_narrow.{I32NarrowPass}
use std.jit.jit_x86_mixed.{X86MixedJit}

extern fn rt_time_now_micros() -> i64

fn test_should_narrow():
    print("--- Test: should_narrow ---")
    val narrow = I32NarrowPass.create()

    # Safe ops within i32 range
    val ok_add = narrow.should_narrow("add", 1000)
    if ok_add:
        print("PASS: add with small range -> narrow=true")
    else:
        print("FAIL: add with small range should be narrowable")

    val ok_sub = narrow.should_narrow("sub", 2147483647)
    if ok_sub:
        print("PASS: sub at i32 max -> narrow=true")
    else:
        print("FAIL: sub at i32 max should be narrowable")

    val ok_loop = narrow.should_narrow("loop_counter", 10000)
    if ok_loop:
        print("PASS: loop_counter with small range -> narrow=true")
    else:
        print("FAIL: loop_counter should be narrowable")

    val ok_cmp = narrow.should_narrow("cmp", 100)
    if ok_cmp:
        print("PASS: cmp with small range -> narrow=true")
    else:
        print("FAIL: cmp should be narrowable")

    val ok_mul = narrow.should_narrow("mul", 50000)
    if ok_mul:
        print("PASS: mul with small range -> narrow=true")
    else:
        print("FAIL: mul should be narrowable")

    # Unsafe: exceeds i32 range
    val no_big = narrow.should_narrow("add", 3000000000)
    if no_big == false:
        print("PASS: add with large range -> narrow=false")
    else:
        print("FAIL: add with value > i32 max should NOT be narrowable")

    # Unsafe: unknown op
    val no_op = narrow.should_narrow("unknown_op", 100)
    if no_op == false:
        print("PASS: unknown op -> narrow=false")
    else:
        print("FAIL: unknown op should NOT be narrowable")

fn test_analyze():
    print("--- Test: analyze ---")
    val narrow = I32NarrowPass.create()

    val src = "fn counter(n: i64) -> i64:\n    var s: i64 = 0\n    var i: i64 = 0\n    while i < n:\n        s = s + i\n        i = i + 1\n    return s\n"
    val annotated = narrow.analyze(src)

    # Annotated output should mention i32-narrow hints
    if annotated.contains("@i32-narrow"):
        print("PASS: analyze found narrowable ops and annotated source")
    else:
        print("FAIL: analyze should annotate source with @i32-narrow hints")

    # Stats should reflect detected ops
    if narrow.total_ops > 0:
        print("PASS: total_ops=" + narrow.total_ops.to_text())
    else:
        print("FAIL: total_ops should be > 0 for arithmetic source")

    if narrow.narrowed_ops > 0:
        print("PASS: narrowed_ops=" + narrow.narrowed_ops.to_text())
    else:
        print("FAIL: narrowed_ops should be > 0")

    if narrow.estimated_savings_bytes > 0:
        print("PASS: estimated_savings_bytes=" + narrow.estimated_savings_bytes.to_text())
    else:
        print("FAIL: estimated_savings_bytes should be > 0")

    print(narrow.stats())

fn test_x86_64_compile(jit: X86MixedJit):
    print("--- Test: x86_64 compile (Cranelift) ---")

    if jit.handle_64 < 1:
        print("SKIP: x86_64 JIT not available")
        return

    val src = "fn loop_sum(n: i64) -> i64:\n    var s: i64 = 0\n    var i: i64 = 0\n    while i < n:\n        s = s + i\n        i = i + 1\n    return s\n"

    val result = jit.compile_for_64("loop_sum", src)
    if result.err == "":
        print("PASS: x86_64 compile succeeded, backend=" + result.backend)
    else:
        print("FAIL: x86_64 compile error: " + result.err)
        return

    val compiled = jit.is_compiled_64("loop_sum")
    if compiled:
        print("PASS: is_compiled_64 = true")
    else:
        print("FAIL: is_compiled_64 should be true after successful compile")

    val r = jit.call_i64_on_64("loop_sum", 100)
    val expected: i64 = 4950
    if r == expected:
        print("PASS: loop_sum(100) = " + r.to_text())
    else:
        print("FAIL: loop_sum(100) = " + r.to_text() + " expected " + expected.to_text())

fn test_x86_32_compile(jit: X86MixedJit):
    print("--- Test: x86_32 compile (LLVM) ---")

    if jit.handle_32 < 1:
        print("SKIP: x86_32 JIT not available (need --features llvm)")
        return

    print("Backend: " + jit.backend_32)

    val src = "fn add_pair(n: i64) -> i64:\n    return n + 1\n"
    val result = jit.compile_for_32("add_pair", src)
    if result.err == "":
        print("PASS: x86_32 compile succeeded, backend=" + result.backend)
    else:
        print("FAIL: x86_32 compile error: " + result.err)
        return

    val r = jit.call_i64_on_32("add_pair", 41)
    val expected: i64 = 42
    if r == expected:
        print("PASS: add_pair(41) = " + r.to_text())
    else:
        print("FAIL: add_pair(41) = " + r.to_text() + " expected " + expected.to_text())

fn test_optimized_vs_plain(jit: X86MixedJit):
    print("--- Test: compile_optimized vs compile_for_64 (timing) ---")

    if jit.handle_64 < 1:
        print("SKIP: x86_64 JIT not available")
        return

    val src = "fn bench_fn(n: i64) -> i64:\n    var s: i64 = 0\n    var i: i64 = 0\n    while i < n:\n        s = s + i\n        i = i + 1\n    return s\n"

    val t0_plain = rt_time_now_micros()
    val plain = jit.compile_for_64("bench_fn_plain", src)
    val t1_plain = rt_time_now_micros()

    val t0_opt = rt_time_now_micros()
    val opt = jit.compile_optimized("bench_fn_opt", src)
    val t1_opt = rt_time_now_micros()

    val plain_us = t1_plain - t0_plain
    val opt_us = t1_opt - t0_opt

    print("Plain compile: " + plain_us.to_text() + " us, err=" + plain.err)
    print("Optimized compile: " + opt_us.to_text() + " us, err=" + opt.err)

    if plain.err == "":
        print("PASS: plain compile succeeded")
    else:
        print("FAIL: plain compile error: " + plain.err)

    if opt.err == "":
        print("PASS: optimized compile succeeded, narrowed=true")
    else:
        print("FAIL: optimized compile error: " + opt.err)

fn main():
    print("=== JIT Optimization Test: x86_64/x86_32 Mixed + I32 Narrowing ===")

    test_should_narrow()
    test_analyze()

    val jit = X86MixedJit.create()
    print("Backends: 64bit=" + jit.backend_64 + " 32bit=" + jit.backend_32)

    test_x86_64_compile(jit)
    test_x86_32_compile(jit)
    test_optimized_vs_plain(jit)

    print(jit.stats())
    jit.cleanup()
    print("DONE")
