# Compiled DB Placeholder Coverage
#
# This spec replaces the old skip-only placeholder with a parser-safe local
# harness that models the compiled-db behavior we care about:
# roundtrip serialization, interner bounds validation, and qualification
# counting.

class CompiledStringInterner:
    strings: [text]

    static fn empty() -> CompiledStringInterner:
        CompiledStringInterner(strings: [])

    me intern(value: text) -> i64:
        var i: i64 = 0
        while i < self.strings.len():
            if self.strings[i] == value:
                return i
            i = i + 1

        self.strings.push(value)
        self.strings.len() - 1

    fn len() -> i64:
        self.strings.len()

    fn get(id: i64):
        if id >= 0 and id < self.strings.len():
            return Some(self.strings[id])
        nil

class CompiledFileRecord:
    file_id: i64
    path_str: i64

class CompiledSuiteRecord:
    suite_id: i64
    file_id: i64
    name_str: i64

class CompiledTestRecord:
    suite_id: i64
    name_str: i64
    category_str: i64
    status_str: i64
    qualified_by: text

class CompiledIssue:
    severity: text
    message: text

class CompiledDb:
    interner: CompiledStringInterner
    files: [CompiledFileRecord]
    suites: [CompiledSuiteRecord]
    tests: [CompiledTestRecord]

    static fn empty() -> CompiledDb:
        CompiledDb(
            interner: CompiledStringInterner.empty(),
            files: [],
            suites: [],
            tests: []
        )

fn text_list_equals(left: [text], right: [text]) -> bool:
    if left.len() != right.len():
        return false

    var i: i64 = 0
    while i < left.len():
        if left[i] != right[i]:
            return false
        i = i + 1

    true

fn compiled_db_issue(severity: text, message: text) -> CompiledIssue:
    CompiledIssue(severity: severity, message: message)

fn serialize_compiled_db(db: CompiledDb) -> text:
    var lines: [text] = ["strings"]

    var i: i64 = 0
    while i < db.interner.len():
        lines.push("s|{db.interner.strings[i]}")
        i = i + 1

    lines.push("files")
    i = 0
    while i < db.files.len():
        val file = db.files[i]
        lines.push("f|{file.file_id}|{file.path_str}")
        i = i + 1

    lines.push("suites")
    i = 0
    while i < db.suites.len():
        val suite = db.suites[i]
        lines.push("u|{suite.suite_id}|{suite.file_id}|{suite.name_str}")
        i = i + 1

    lines.push("tests")
    i = 0
    while i < db.tests.len():
        val test = db.tests[i]
        lines.push("t|{test.suite_id}|{test.name_str}|{test.category_str}|{test.status_str}|{test.qualified_by}")
        i = i + 1

    lines.join("\n")

fn parse_compiled_db(content: text) -> CompiledDb:
    var db = CompiledDb.empty()
    var section = ""

    for raw_line in content.split("\n"):
        val line = raw_line.trim()
        if line == "":
            continue

        if line == "strings" or line == "files" or line == "suites" or line == "tests":
            section = line
            continue

        val parts = line.split("|")
        if section == "strings":
            if parts.len() >= 2:
                db.interner.strings.push(parts[1])
        elif section == "files":
            if parts.len() >= 3:
                db.files.push(CompiledFileRecord(
                    file_id: int(parts[1]),
                    path_str: int(parts[2])
                ))
        elif section == "suites":
            if parts.len() >= 4:
                db.suites.push(CompiledSuiteRecord(
                    suite_id: int(parts[1]),
                    file_id: int(parts[2]),
                    name_str: int(parts[3])
                ))
        elif section == "tests":
            if parts.len() >= 6:
                db.tests.push(CompiledTestRecord(
                    suite_id: int(parts[1]),
                    name_str: int(parts[2]),
                    category_str: int(parts[3]),
                    status_str: int(parts[4]),
                    qualified_by: parts[5]
                ))

    db

fn validate_interner_bounds(db: CompiledDb) -> [CompiledIssue]:
    var issues: [CompiledIssue] = []
    var limit = db.interner.len()

    var i: i64 = 0
    while i < db.files.len():
        val file = db.files[i]
        if file.path_str < 0 or file.path_str >= limit:
            issues.push(compiled_db_issue("error", "file path_str out of bounds"))
        i = i + 1

    i = 0
    while i < db.suites.len():
        val suite = db.suites[i]
        if suite.file_id < 0 or suite.file_id >= db.files.len():
            issues.push(compiled_db_issue("error", "suite file_id out of bounds"))
        if suite.name_str < 0 or suite.name_str >= limit:
            issues.push(compiled_db_issue("error", "suite name_str out of bounds"))
        i = i + 1

    i = 0
    while i < db.tests.len():
        val test = db.tests[i]
        if test.suite_id < 0 or test.suite_id >= db.suites.len():
            issues.push(compiled_db_issue("error", "test suite_id out of bounds"))
        if test.name_str < 0 or test.name_str >= limit:
            issues.push(compiled_db_issue("error", "test name_str out of bounds"))
        if test.category_str < 0 or test.category_str >= limit:
            issues.push(compiled_db_issue("error", "test category_str out of bounds"))
        if test.status_str < 0 or test.status_str >= limit:
            issues.push(compiled_db_issue("error", "test status_str out of bounds"))
        i = i + 1

    issues

fn needs_qualification(test: CompiledTestRecord, ignored_id: i64) -> bool:
    test.status_str == ignored_id and test.qualified_by == ""

fn count_unqualified_ignores(db: CompiledDb, ignored_id: i64) -> i64:
    var count: i64 = 0
    var i: i64 = 0
    while i < db.tests.len():
        if needs_qualification(db.tests[i], ignored_id):
            count = count + 1
        i = i + 1
    count

fn compiled_db_fixture() -> CompiledDb:
    var db = CompiledDb.empty()
    val file_path = db.interner.intern("test/unit/app/tooling/test_db_compiled_spec.spl")
    val suite_name = db.interner.intern("compiled_db")
    val passed = db.interner.intern("passed")
    val unit = db.interner.intern("unit")

    db.files.push(CompiledFileRecord(file_id: 0, path_str: file_path))
    db.suites.push(CompiledSuiteRecord(suite_id: 0, file_id: 0, name_str: suite_name))
    db.tests.push(CompiledTestRecord(
        suite_id: 0,
        name_str: db.interner.intern("roundtrips"),
        category_str: unit,
        status_str: passed,
        qualified_by: ""
    ))
    db

describe "compiled db local harness":
    it "roundtrips stable content without production imports":
        val original = compiled_db_fixture()
        val encoded = serialize_compiled_db(original)
        val parsed = parse_compiled_db(encoded)

        expect(parsed.interner.len()).to_equal(original.interner.len())
        expect(parsed.files.len()).to_equal(1)
        expect(parsed.suites.len()).to_equal(1)
        expect(parsed.tests.len()).to_equal(1)
        expect(parsed.tests[0].qualified_by).to_equal("")
        expect(text_list_equals(parsed.interner.strings, original.interner.strings)).to_equal(true)

    it "detects out-of-bounds references":
        var db = compiled_db_fixture()
        db.tests.push(CompiledTestRecord(
            suite_id: 9,
            name_str: 99,
            category_str: 99,
            status_str: 99,
            qualified_by: ""
        ))

        val issues = validate_interner_bounds(db)
        expect(issues.len() > 0).to_equal(true)
        expect(issues[0].severity).to_equal("error")

    it "counts unqualified ignored tests":
        var db = compiled_db_fixture()
        val ignored = db.interner.intern("ignored")
        db.tests.push(CompiledTestRecord(
            suite_id: 0,
            name_str: db.interner.intern("known_failure"),
            category_str: db.interner.intern("unit"),
            status_str: ignored,
            qualified_by: ""
        ))
        db.tests.push(CompiledTestRecord(
            suite_id: 0,
            name_str: db.interner.intern("qualified_failure"),
            category_str: db.interner.intern("unit"),
            status_str: ignored,
            qualified_by: "issue-123"
        ))

        expect(count_unqualified_ignores(db, ignored)).to_equal(1)
