"""
DOM Event Types

Core event types for browser DOM: DomEvent and EventPhase.
Consumed by ui.browser.dom_bridge for event routing.
"""

# ============================================================================
# EventPhase
# ============================================================================

enum EventPhase:
    """DOM event propagation phase."""
    None_
    Capturing
    AtTarget
    Bubbling

# ============================================================================
# DomEvent
# ============================================================================

class DomEvent:
    """A DOM event dispatched through the browser event system."""
    event_type: text        # e.g. "click", "keydown", "input"
    target_id: i64          # node_id of the original target
    current_target_id: i64  # node_id of the current dispatch target
    phase: EventPhase
    bubbles: bool
    cancelable: bool
    default_prevented: bool
    propagation_stopped: bool
    # Mouse
    client_x: f64
    client_y: f64
    button: i64
    # Keyboard
    key: text
    key_code: i64
    modifiers: i64  # bitmask: 0x01=Shift, 0x02=Ctrl, 0x04=Alt, 0x08=Meta

impl DomEvent:
    static fn click(target_id: i64, x: f64, y: f64, button: i64) -> DomEvent:
        """Construct a mouse click event."""
        DomEvent(
            event_type: "click",
            target_id: target_id,
            current_target_id: target_id,
            phase: EventPhase.AtTarget,
            bubbles: true,
            cancelable: true,
            default_prevented: false,
            propagation_stopped: false,
            client_x: x,
            client_y: y,
            button: button,
            key: "",
            key_code: 0,
            modifiers: 0
        )

    static fn keydown(target_id: i64, key: text, key_code: i64, modifiers: i64) -> DomEvent:
        """Construct a keydown event."""
        DomEvent(
            event_type: "keydown",
            target_id: target_id,
            current_target_id: target_id,
            phase: EventPhase.AtTarget,
            bubbles: true,
            cancelable: true,
            default_prevented: false,
            propagation_stopped: false,
            client_x: 0.0,
            client_y: 0.0,
            button: 0,
            key: key,
            key_code: key_code,
            modifiers: modifiers
        )

    fn prevent_default():
        self.default_prevented = true

    fn stop_propagation():
        self.propagation_stopped = true

    fn is_default_prevented() -> bool:
        self.default_prevented

    fn is_propagation_stopped() -> bool:
        self.propagation_stopped
