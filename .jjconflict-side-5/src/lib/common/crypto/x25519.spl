# X25519 Key Exchange — Pure Simple, No Externs
#
# Port of src/lib/nogc_async_mut_noalloc/tls/x25519.spl with the C extern
# fast-path removed.  All field arithmetic is pure Simple; no SFFI calls.
#
# Uses a 10-limb radix-2^25/2^26 representation to avoid checked-overflow
# paths on the interpreter.  All intermediate state lives in [u64].
#
# Public API:
#   x25519(scalar: [u8], u_coord: [u8]) -> [u8]   — general DH step
#   x25519_pubkey(scalar: [u8]) -> [u8]             — derive pubkey from private key

val _X25519_MASK26: u64 = 0x3FFFFFF
val _X25519_MASK25: u64 = 0x1FFFFFF
val _X25519_BASE26: u64 = 0x4000000
val _X25519_BASE25: u64 = 0x2000000

# ============================================================================
# Field element helpers
# ============================================================================

fn _fe_zero() -> [u64]:
    [0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64]

fn _fe_one() -> [u64]:
    [1u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64, 0u64]

fn _fe_carry(a: [u64]) -> [u64]:
    var h0 = a[0]
    var h1 = a[1]
    var h2 = a[2]
    var h3 = a[3]
    var h4 = a[4]
    var h5 = a[5]
    var h6 = a[6]
    var h7 = a[7]
    var h8 = a[8]
    var h9 = a[9]

    var c: u64 = 0
    c = h0 / _X25519_BASE26
    h0 = h0 & _X25519_MASK26
    h1 = h1 + c

    c = h1 / _X25519_BASE25
    h1 = h1 & _X25519_MASK25
    h2 = h2 + c

    c = h2 / _X25519_BASE26
    h2 = h2 & _X25519_MASK26
    h3 = h3 + c

    c = h3 / _X25519_BASE25
    h3 = h3 & _X25519_MASK25
    h4 = h4 + c

    c = h4 / _X25519_BASE26
    h4 = h4 & _X25519_MASK26
    h5 = h5 + c

    c = h5 / _X25519_BASE25
    h5 = h5 & _X25519_MASK25
    h6 = h6 + c

    c = h6 / _X25519_BASE26
    h6 = h6 & _X25519_MASK26
    h7 = h7 + c

    c = h7 / _X25519_BASE25
    h7 = h7 & _X25519_MASK25
    h8 = h8 + c

    c = h8 / _X25519_BASE26
    h8 = h8 & _X25519_MASK26
    h9 = h9 + c

    c = h9 / _X25519_BASE25
    h9 = h9 & _X25519_MASK25
    h0 = h0 + c * 19

    c = h0 / _X25519_BASE26
    h0 = h0 & _X25519_MASK26
    h1 = h1 + c

    c = h1 / _X25519_BASE25
    h1 = h1 & _X25519_MASK25
    h2 = h2 + c

    c = h2 / _X25519_BASE26
    h2 = h2 & _X25519_MASK26
    h3 = h3 + c

    c = h3 / _X25519_BASE25
    h3 = h3 & _X25519_MASK25
    h4 = h4 + c

    c = h4 / _X25519_BASE26
    h4 = h4 & _X25519_MASK26
    h5 = h5 + c

    c = h5 / _X25519_BASE25
    h5 = h5 & _X25519_MASK25
    h6 = h6 + c

    c = h6 / _X25519_BASE26
    h6 = h6 & _X25519_MASK26
    h7 = h7 + c

    c = h7 / _X25519_BASE25
    h7 = h7 & _X25519_MASK25
    h8 = h8 + c

    c = h8 / _X25519_BASE26
    h8 = h8 & _X25519_MASK26
    h9 = h9 + c

    c = h9 / _X25519_BASE25
    h9 = h9 & _X25519_MASK25
    h0 = h0 + c * 19

    c = h0 / _X25519_BASE26
    h0 = h0 & _X25519_MASK26
    h1 = h1 + c

    [h0, h1, h2, h3, h4, h5, h6, h7, h8, h9]

fn _fe_add(a: [u64], b: [u64]) -> [u64]:
    _fe_carry([
        a[0] + b[0], a[1] + b[1], a[2] + b[2], a[3] + b[3], a[4] + b[4],
        a[5] + b[5], a[6] + b[6], a[7] + b[7], a[8] + b[8], a[9] + b[9]
    ])

fn _fe_sub(a: [u64], b: [u64]) -> [u64]:
    _fe_carry([
        a[0] + 134217690 - b[0],
        a[1] + 67108862 - b[1],
        a[2] + 134217726 - b[2],
        a[3] + 67108862 - b[3],
        a[4] + 134217726 - b[4],
        a[5] + 67108862 - b[5],
        a[6] + 134217726 - b[6],
        a[7] + 67108862 - b[7],
        a[8] + 134217726 - b[8],
        a[9] + 67108862 - b[9]
    ])

fn _fe_neg(a: [u64]) -> [u64]:
    _fe_sub(_fe_zero(), a)

fn _fe_mul_scalar(a: [u64], s: u64) -> [u64]:
    _fe_carry([
        a[0] * s, a[1] * s, a[2] * s, a[3] * s, a[4] * s,
        a[5] * s, a[6] * s, a[7] * s, a[8] * s, a[9] * s
    ])

fn _fe_mul(a: [u64], b: [u64]) -> [u64]:
    # ref10 radix-2^25.5 multiply. Odd-indexed limbs carry weight 2^(25.5*i)
    # with a half-bit offset, so cross-products of two ODD limbs land one bit
    # above their target limb and must be doubled (f1_2, f3_2, ...). The high
    # cross terms (j+k >= 10) fold back via 2^255 == 19 (g*_19).
    val f0 = a[0]
    val f1 = a[1]
    val f2 = a[2]
    val f3 = a[3]
    val f4 = a[4]
    val f5 = a[5]
    val f6 = a[6]
    val f7 = a[7]
    val f8 = a[8]
    val f9 = a[9]
    val g0 = b[0]
    val g1 = b[1]
    val g2 = b[2]
    val g3 = b[3]
    val g4 = b[4]
    val g5 = b[5]
    val g6 = b[6]
    val g7 = b[7]
    val g8 = b[8]
    val g9 = b[9]
    val g1_19 = 19 * g1
    val g2_19 = 19 * g2
    val g3_19 = 19 * g3
    val g4_19 = 19 * g4
    val g5_19 = 19 * g5
    val g6_19 = 19 * g6
    val g7_19 = 19 * g7
    val g8_19 = 19 * g8
    val g9_19 = 19 * g9
    val f1_2 = 2 * f1
    val f3_2 = 2 * f3
    val f5_2 = 2 * f5
    val f7_2 = 2 * f7
    val f9_2 = 2 * f9
    val r0 = f0*g0 + f1_2*g9_19 + f2*g8_19 + f3_2*g7_19 + f4*g6_19 + f5_2*g5_19 + f6*g4_19 + f7_2*g3_19 + f8*g2_19 + f9_2*g1_19
    val r1 = f0*g1 + f1*g0 + f2*g9_19 + f3*g8_19 + f4*g7_19 + f5*g6_19 + f6*g5_19 + f7*g4_19 + f8*g3_19 + f9*g2_19
    val r2 = f0*g2 + f1_2*g1 + f2*g0 + f3_2*g9_19 + f4*g8_19 + f5_2*g7_19 + f6*g6_19 + f7_2*g5_19 + f8*g4_19 + f9_2*g3_19
    val r3 = f0*g3 + f1*g2 + f2*g1 + f3*g0 + f4*g9_19 + f5*g8_19 + f6*g7_19 + f7*g6_19 + f8*g5_19 + f9*g4_19
    val r4 = f0*g4 + f1_2*g3 + f2*g2 + f3_2*g1 + f4*g0 + f5_2*g9_19 + f6*g8_19 + f7_2*g7_19 + f8*g6_19 + f9_2*g5_19
    val r5 = f0*g5 + f1*g4 + f2*g3 + f3*g2 + f4*g1 + f5*g0 + f6*g9_19 + f7*g8_19 + f8*g7_19 + f9*g6_19
    val r6 = f0*g6 + f1_2*g5 + f2*g4 + f3_2*g3 + f4*g2 + f5_2*g1 + f6*g0 + f7_2*g9_19 + f8*g8_19 + f9_2*g7_19
    val r7 = f0*g7 + f1*g6 + f2*g5 + f3*g4 + f4*g3 + f5*g2 + f6*g1 + f7*g0 + f8*g9_19 + f9*g8_19
    val r8 = f0*g8 + f1_2*g7 + f2*g6 + f3_2*g5 + f4*g4 + f5_2*g3 + f6*g2 + f7_2*g1 + f8*g0 + f9_2*g9_19
    val r9 = f0*g9 + f1*g8 + f2*g7 + f3*g6 + f4*g5 + f5*g4 + f6*g3 + f7*g2 + f8*g1 + f9*g0
    _fe_carry([r0, r1, r2, r3, r4, r5, r6, r7, r8, r9])

fn _fe_sq(a: [u64]) -> [u64]:
    _fe_mul(a, a)

# Read `count` bits (count <= 26) starting at little-endian bit offset `start`
# from the byte array, zero-extending past the end (bounds-safe).
fn _fe_bits(b: [u8], start: i64, count: i64) -> u64:
    val byte0 = start / 8
    val shift = start % 8
    var acc: u64 = 0
    var i: i64 = 0
    while i < 5:
        val idx = byte0 + i
        if idx < b.len():
            acc = acc | (b[idx].to_u64() << (8 * i))
        i = i + 1
    val mask: u64 = (1u64 << count) - 1
    (acc >> shift) & mask

# Decode 32 little-endian bytes into 10 limbs at radix-2^25.5 boundaries
# (limb i occupies bits [w_i, w_{i+1}); even limbs 26-bit, odd 25-bit).
fn _fe_from_bytes(b: [u8]) -> [u64]:
    val h0 = _fe_bits(b, 0, 26)
    val h1 = _fe_bits(b, 26, 25)
    val h2 = _fe_bits(b, 51, 26)
    val h3 = _fe_bits(b, 77, 25)
    val h4 = _fe_bits(b, 102, 26)
    val h5 = _fe_bits(b, 128, 25)
    val h6 = _fe_bits(b, 153, 26)
    val h7 = _fe_bits(b, 179, 25)
    val h8 = _fe_bits(b, 204, 26)
    val h9 = _fe_bits(b, 230, 25)
    [h0, h1, h2, h3, h4, h5, h6, h7, h8, h9]

fn _fe_to_bytes(a: [u64]) -> [u8]:
    val n = _fe_carry(a)
    val h0 = n[0]
    val h1 = n[1]
    val h2 = n[2]
    val h3 = n[3]
    val h4 = n[4]
    val h5 = n[5]
    val h6 = n[6]
    val h7 = n[7]
    val h8 = n[8]
    val h9 = n[9]

    # Canonical reduction: value V is in [0, 2p). Compute t = V + 19 with carry
    # propagation; bit 255 of t is set iff V >= p (since p = 2^255 - 19). If so,
    # t mod 2^255 == V - p is the canonical residue; otherwise keep V.
    var t0 = h0 + 19
    var c: u64 = t0 / _X25519_BASE26
    t0 = t0 & _X25519_MASK26
    var t1 = h1 + c
    c = t1 / _X25519_BASE25
    t1 = t1 & _X25519_MASK25
    var t2 = h2 + c
    c = t2 / _X25519_BASE26
    t2 = t2 & _X25519_MASK26
    var t3 = h3 + c
    c = t3 / _X25519_BASE25
    t3 = t3 & _X25519_MASK25
    var t4 = h4 + c
    c = t4 / _X25519_BASE26
    t4 = t4 & _X25519_MASK26
    var t5 = h5 + c
    c = t5 / _X25519_BASE25
    t5 = t5 & _X25519_MASK25
    var t6 = h6 + c
    c = t6 / _X25519_BASE26
    t6 = t6 & _X25519_MASK26
    var t7 = h7 + c
    c = t7 / _X25519_BASE25
    t7 = t7 & _X25519_MASK25
    var t8 = h8 + c
    c = t8 / _X25519_BASE26
    t8 = t8 & _X25519_MASK26
    var t9 = h9 + c
    val ge_p = t9 / _X25519_BASE25

    var r: [u64] = [h0, h1, h2, h3, h4, h5, h6, h7, h8, h9]
    if ge_p >= 1:
        r = [t0, t1, t2, t3, t4, t5, t6, t7, t8, t9 & _X25519_MASK25]

    val widths: [i64] = [26, 25, 26, 25, 26, 25, 26, 25, 26, 25]
    var out: [u8] = []
    var bi: i64 = 0
    while bi < 32:
        out.push(0u8)
        bi = bi + 1

    var bitpos: i64 = 0
    var li: i64 = 0
    while li < 10:
        var v = r[li]
        val w = widths[li]
        var nb: i64 = 0
        while nb < w:
            if (v & 1) == 1:
                val byteidx = bitpos / 8
                val bitidx = bitpos % 8
                out[byteidx] = (out[byteidx].to_u64() | (1u64 << bitidx)).to_u8()
            v = v >> 1
            bitpos = bitpos + 1
            nb = nb + 1
        li = li + 1
    out

fn _fe_invert(z: [u64]) -> [u64]:
    """Compute z^(p-2) mod p = z^(-1) via Fermat's little theorem."""
    var t = _fe_sq(z)
    t = _fe_sq(t)
    t = _fe_sq(t)
    val z9 = _fe_mul(t, z)
    val z11 = _fe_mul(z9, _fe_sq(z))
    t = _fe_sq(z11)
    val z_2_5_0 = _fe_mul(t, z9)

    t = _fe_sq(z_2_5_0)
    var i: i64 = 1
    while i < 5:
        t = _fe_sq(t)
        i = i + 1
    val z_2_10_0 = _fe_mul(t, z_2_5_0)

    t = _fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = _fe_sq(t)
        i = i + 1
    val z_2_20_0 = _fe_mul(t, z_2_10_0)

    t = _fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = _fe_sq(t)
        i = i + 1
    t = _fe_mul(t, z_2_20_0)

    i = 0
    while i < 10:
        t = _fe_sq(t)
        i = i + 1
    val z_2_50_0 = _fe_mul(t, z_2_10_0)

    t = _fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = _fe_sq(t)
        i = i + 1
    val z_2_100_0 = _fe_mul(t, z_2_50_0)

    t = _fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = _fe_sq(t)
        i = i + 1
    t = _fe_mul(t, z_2_100_0)

    i = 0
    while i < 50:
        t = _fe_sq(t)
        i = i + 1
    t = _fe_mul(t, z_2_50_0)

    t = _fe_sq(t)
    t = _fe_sq(t)
    t = _fe_sq(t)
    t = _fe_sq(t)
    t = _fe_sq(t)
    _fe_mul(t, z11)

# ============================================================================
# Montgomery Ladder
# ============================================================================

fn _x25519_cswap(x1: [u64], x2: [u64], z1: [u64], z2: [u64], swap: i64) -> [list]:
    if swap == 0:
        return [x1, x2, z1, z2]
    [x2, x1, z2, z1]

fn _x25519_ladder_step(x2: [u64], z2: [u64], x3: [u64], z3: [u64], x1: [u64]) -> [list]:
    val a = _fe_add(x2, z2)
    val aa = _fe_sq(a)
    val b = _fe_sub(x2, z2)
    val bb = _fe_sq(b)
    val e = _fe_sub(aa, bb)
    val c = _fe_add(x3, z3)
    val d = _fe_sub(x3, z3)
    val da = _fe_mul(d, a)
    val cb = _fe_mul(c, b)
    val sum_dc = _fe_add(da, cb)
    val new_x3 = _fe_sq(sum_dc)
    val diff_dc = _fe_sub(da, cb)
    val diff_sq = _fe_sq(diff_dc)
    val new_z3 = _fe_mul(x1, diff_sq)
    val new_x2 = _fe_mul(aa, bb)
    val a24_e = _fe_mul_scalar(e, 121665)
    val aa_plus = _fe_add(aa, a24_e)
    val new_z2 = _fe_mul(e, aa_plus)
    [new_x2, new_z2, new_x3, new_z3]

fn _x25519_clamp(scalar: [u8]) -> [u8]:
    var clamped: [u8] = []
    var i: i64 = 0
    while i < 32:
        clamped.push(scalar[i])
        i = i + 1
    clamped[0] = clamped[0] & 0xF8
    clamped[31] = clamped[31] & 0x7F
    clamped[31] = clamped[31] | 0x40
    clamped

fn _x25519_bit_div(bit_idx: i64) -> i64:
    if bit_idx == 0: 1
    elif bit_idx == 1: 2
    elif bit_idx == 2: 4
    elif bit_idx == 3: 8
    elif bit_idx == 4: 16
    elif bit_idx == 5: 32
    elif bit_idx == 6: 64
    else: 128

# ============================================================================
# Public API
# ============================================================================

fn x25519(scalar: [u8], u_coord: [u8]) -> [u8]:
    """X25519 Diffie-Hellman: compute scalar * u_coord.

    scalar: 32-byte private key (clamped internally)
    u_coord: 32-byte peer public key (u coordinate)
    Returns: 32-byte shared secret
    """
    val k = _x25519_clamp(scalar)
    # Mask high bit of u coordinate
    var u_masked: [u8] = []
    var i: i64 = 0
    while i < 32:
        u_masked.push(u_coord[i])
        i = i + 1
    u_masked[31] = u_masked[31] & 0x7F

    val u = _fe_from_bytes(u_masked)

    var x_2 = _fe_one()
    var z_2 = _fe_zero()
    var x_3 = u
    var z_3 = _fe_one()

    var prev_bit: i64 = 0
    var bit_pos: i64 = 254
    while bit_pos >= 0:
        val byte_idx = bit_pos / 8
        val bit_idx = bit_pos % 8
        val k_bit: i64 = (k[byte_idx].to_i64() / _x25519_bit_div(bit_idx)) & 1
        val swap_bit = k_bit ^ prev_bit
        prev_bit = k_bit

        val swapped = _x25519_cswap(x_2, x_3, z_2, z_3, swap_bit)
        x_2 = swapped[0]
        x_3 = swapped[1]
        z_2 = swapped[2]
        z_3 = swapped[3]

        val step = _x25519_ladder_step(x_2, z_2, x_3, z_3, u)
        x_2 = step[0]
        z_2 = step[1]
        x_3 = step[2]
        z_3 = step[3]

        if bit_pos == 0:
            val fs = _x25519_cswap(x_2, x_3, z_2, z_3, prev_bit)
            x_2 = fs[0]
            z_2 = fs[2]
            val z_inv = _fe_invert(z_2)
            val result = _fe_mul(x_2, z_inv)
            return _fe_to_bytes(result)

        bit_pos = bit_pos - 1

    val z_inv = _fe_invert(z_2)
    val result = _fe_mul(x_2, z_inv)
    _fe_to_bytes(result)

fn x25519_pubkey(scalar: [u8]) -> [u8]:
    """Derive X25519 public key from private key (multiply with base point 9)."""
    val base_point: [u8] = [9u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                             0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                             0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                             0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]
    x25519(scalar, base_point)
