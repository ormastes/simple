# ============================================================================
# common/search/prefilter.spl — literal/trigram prefilter (AC-4)
#
# Core rule proven here:  prefilter -> candidate set -> verify -> result.
#
# A prefilter takes a *required gram* of the pattern: a contiguous byte run
# that MUST appear in every true match (for a pure-literal pattern, the whole
# pattern; for a regex with a mandatory literal factor, that factor's bytes,
# e.g. a trigram). It scans the Haystack for occurrences of that gram and emits
# CANDIDATE window start positions (gram position minus the gram's offset inside
# the pattern). Each candidate is then VERIFIED.
#
# CRITICAL INVARIANT (no false negatives): the prefilter must never drop a true
# match. Because every true match of width plen contains the required gram at a
# fixed offset `gram_off`, the candidate `gram_index - gram_off` is always
# produced. The prefilter may OVER-produce (false positives) — those are removed
# by the verify step, never by the prefilter.
#
# VERIFY API NOTE (language/lib friction): the directory-level regex engines
# (src/lib/common/regex_engine/, src/lib/common/regex/) ship only compiled
# `.smf` artifacts with no importable `.spl` candidate-verify entry point, so a
# regex factor cannot be cleanly re-verified here. For the literal/trigram path
# this phase covers, the exact verify is a byte-equality check at the candidate
# offset (Haystack.matches_at). Filed:
#   doc/08_tracking/bug/regex_engine_no_spl_candidate_verify_api_2026-06-15.md
#
# Foundation: src/lib/common/bytes/ (ByteSpan).
# Plan: doc/03_plan/lib/search/custom_type_alpha_search_team_plan_2026-06-15.md
#
# KNOWN BUG designed around: `for x in <custom struct>` iterates zero times
# (for_in_custom_struct_no_iterator_protocol_2026-06-15). All iteration here is
# index/counter loops or `for b in span.to_bytes()`, never for-in over a struct.
# ============================================================================

use std.common.search.types.{Haystack, Pattern, MatchSpan}
use std.common.bytes.span.{ByteSpan}

# ----------------------------------------------------------------------------
# Prefilter -- a required-gram screen over a Haystack
# ----------------------------------------------------------------------------
struct Prefilter:
    """A literal/trigram screen. `gram` is a byte run guaranteed present in every
    true match of `pattern`; `gram_off` is where the gram begins inside the
    pattern. Candidates are derived as `gram_index - gram_off`. Carries the
    full pattern so it can run the verify step itself, keeping the
    prefilter -> candidate -> verify -> result pipeline behind one type."""
    pattern: Pattern
    gram: [u8]
    gram_off: i64

impl Prefilter:
    static fn literal(pattern: Pattern) -> Prefilter:
        """Pure-literal prefilter: the required gram IS the whole pattern at
        offset 0. Selective for any pattern of length >= 1."""
        Prefilter(pattern: pattern, gram: pattern.to_bytes(), gram_off: 0)

    static fn with_gram(pattern: Pattern, gram_off: i64, gram_len: i64) -> Prefilter:
        """Build a prefilter from a required sub-run of the pattern: the bytes
        [gram_off, gram_off + gram_len) of `pattern`. For a trigram screen pass
        gram_len = 3. The chosen run MUST be a mandatory literal factor of the
        pattern (it is here, being a contiguous slice of a literal pattern), so
        the no-false-negative invariant holds."""
        var g: [u8] = []
        var i = 0
        while i < gram_len:
            g.push(pattern.get(gram_off + i))
            i = i + 1
        Prefilter(pattern: pattern, gram: g, gram_off: gram_off)

    static fn trigram(pattern: Pattern, gram_off: i64) -> Prefilter:
        """Convenience: a 3-byte trigram screen at `gram_off`."""
        Prefilter.with_gram(pattern, gram_off, 3)

    fn gram_len() -> i64:
        self.gram.len()

    fn gram_at(i: i64) -> u8:
        if i < 0:
            return 0u8
        if i >= self.gram.len():
            return 0u8
        self.gram[i]

    # ---- gram occurrence test (the screen predicate) -----------------------
    fn gram_matches_at(hay: Haystack, pos: i64) -> bool:
        """True if the required gram occurs at `pos` in the haystack."""
        val glen = self.gram.len()
        if pos < 0:
            return false
        if pos + glen > hay.len():
            return false
        var j = 0
        while j < glen:
            if hay.get(pos + j) != self.gram[j]:
                return false
            j = j + 1
        true

    # ---- step 1: prefilter -> candidate set --------------------------------
    fn candidates(hay: Haystack) -> [i64]:
        """Scan the haystack for the required gram and emit candidate window
        START positions (`gram_index - gram_off`). May over-produce; never
        drops a position where the gram (hence a possible true match) sits.

        Empty gram degenerates to "every position is a candidate" (no screen),
        which still satisfies the superset property."""
        var out: [i64] = []
        val n = hay.len()
        val glen = self.gram.len()
        if glen == 0:
            var p = 0
            while p < n:
                out.push(p)
                p = p + 1
            return out
        # Use the Haystack first-byte seam to leap to gram[0], then confirm the
        # rest of the gram — this is the literal/trigram screen.
        val first = self.gram[0]
        var cursor = 0
        while cursor < n:
            val hit = hay.find_from(cursor, first)
            if hit < 0:
                cursor = n
            else:
                if self.gram_matches_at(hay, hit):
                    val cand = hit - self.gram_off
                    if cand >= 0:
                        out.push(cand)
                cursor = hit + 1
        out

    # ---- step 2: verify -> result ------------------------------------------
    fn verify_one(hay: Haystack, cand: i64) -> bool:
        """Exact byte-equality verify of the FULL pattern at a candidate start.
        (Stand-in for the regex re-verify; see file header verify-API note.)"""
        hay.matches_at(cand, self.pattern)

    fn verify(hay: Haystack, cands: [i64]) -> [MatchSpan]:
        """Verify each candidate, producing the final MatchSpan result set.
        Order follows the candidate order, which is ascending by construction."""
        var out: [MatchSpan] = []
        val plen = self.pattern.len()
        var i = 0
        while i < cands.len():
            val c = cands[i]
            if self.verify_one(hay, c):
                out.push(MatchSpan.at_len(c, plen))
            i = i + 1
        out

    # ---- whole pipeline: prefilter -> candidate -> verify -> result --------
    fn run(hay: Haystack) -> [MatchSpan]:
        """The full pipeline as one call. Equals the true match set."""
        val cands = self.candidates(hay)
        self.verify(hay, cands)
