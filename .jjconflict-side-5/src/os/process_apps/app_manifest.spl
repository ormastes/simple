"""AppManifest — describes a packaged SimpleOS application.

Manifests live under /sys/apps/<app_id>/manifest and describe the
executable path, launch mode, and capability requirements.
"""

# Launch mode values: "gui" | "cli" | "service"

class AppManifest:
    app_id: text
    exec_path: text
    launch_mode: text
    needs_window: bool
    needs_net: bool

    static fn gui_app(app_id: text, exec_path: text) -> AppManifest:
        AppManifest(
            app_id: app_id,
            exec_path: exec_path,
            launch_mode: "gui",
            needs_window: true,
            needs_net: false
        )

    static fn cli_app(app_id: text, exec_path: text) -> AppManifest:
        AppManifest(
            app_id: app_id,
            exec_path: exec_path,
            launch_mode: "cli",
            needs_window: false,
            needs_net: false
        )

    static fn service_app(app_id: text, exec_path: text) -> AppManifest:
        AppManifest(
            app_id: app_id,
            exec_path: exec_path,
            launch_mode: "service",
            needs_window: false,
            needs_net: false
        )

    me is_gui() -> bool:
        self.launch_mode == "gui"

    me is_cli() -> bool:
        self.launch_mode == "cli"

    me is_service() -> bool:
        self.launch_mode == "service"

    me is_valid() -> bool:
        val has_id = self.app_id.len() > 0
        val has_path = self.exec_path.len() > 0
        has_id and has_path

    me with_net() -> AppManifest:
        AppManifest(
            app_id: self.app_id,
            exec_path: self.exec_path,
            launch_mode: self.launch_mode,
            needs_window: self.needs_window,
            needs_net: true
        )
