"""
# API Token Model

API authentication tokens for programmatic access.
Each token has a name, scoped permissions, and an expiry.
Implements DbCodec<ApiToken> for repository operations.
"""

use std.database.sql.types.{DbValue, DbRow, DbError}
use std.database.sql.schema.{TableSchema}
use std.database.sql.codec.{DbCodec}

# ============================================================================
# ApiToken Entity
# ============================================================================

class ApiToken:
    """An API authentication token for a user."""
    id: i64
    user_id: i64
    name: text
    token_hash: text
    scopes: text
    last_used_at: text
    expires_at: text
    created_at: text

fn new_api_token(user_id: i64, name: text, token_hash: text, scopes: text) -> ApiToken:
    """Create a new ApiToken."""
    ApiToken(
        id: 0,
        user_id: user_id,
        name: name,
        token_hash: token_hash,
        scopes: scopes,
        last_used_at: "",
        expires_at: "",
        created_at: ""
    )

# ============================================================================
# ApiTokenCodec — DbCodec<ApiToken> implementation
# ============================================================================

class ApiTokenCodec with DbCodec<ApiToken>:
    """Codec for encoding/decoding ApiToken entities."""

    fn table_name() -> text:
        "api_tokens"

    fn schema() -> TableSchema:
        var s = TableSchema.new("api_tokens")
        s = s.id_col()
        s = s.int_col("user_id")
        s = s.text_col("name")
        s = s.text_col("token_hash")
        s = s.text_col("scopes")
        s = s.nullable_text("last_used_at")
        s = s.nullable_text("expires_at")
        s = s.text_col("created_at")
        s

    fn columns() -> [text]:
        ["user_id", "name", "token_hash", "scopes"]

    fn encode(entity: ApiToken) -> [DbValue]:
        [
            DbValue.Integer(value: entity.user_id),
            DbValue.Text(value: entity.name),
            DbValue.Text(value: entity.token_hash),
            DbValue.Text(value: entity.scopes)
        ]

    fn decode(row: DbRow) -> Result<ApiToken, DbError>:
        val id = row.get_int("id") ?? 0
        val user_id = row.get_int("user_id") ?? 0
        val name = row.get_text("name")
        val token_hash = row.get_text("token_hash")
        val scopes = row.get_text("scopes")
        val last_used_at = row.get_text("last_used_at")
        val expires_at = row.get_text("expires_at")
        val created_at = row.get_text("created_at")

        Ok(ApiToken(
            id: id,
            user_id: user_id,
            name: name ?? "",
            token_hash: token_hash ?? "",
            scopes: scopes ?? "read",
            last_used_at: last_used_at ?? "",
            expires_at: expires_at ?? "",
            created_at: created_at ?? ""
        ))
