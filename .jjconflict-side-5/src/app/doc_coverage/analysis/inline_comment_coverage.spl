# Inline comment and docstring coverage helpers.

use std.nogc_sync_mut.io.file_ops.{file_exists, file_read}

struct InlineCommentResult:
    item_name: text
    item_kind: text
    file_path: text
    line: i64
    has_inline_comment: bool
    has_docstring: bool
    has_sdoctest: bool
    warning_level: text

    static fn create(name: text, kind: text, path: text, line_no: i64) -> InlineCommentResult:
        InlineCommentResult(
            item_name: name,
            item_kind: kind,
            file_path: path,
            line: line_no,
            has_inline_comment: false,
            has_docstring: false,
            has_sdoctest: false,
            warning_level: "none"
        )

fn _decl_kind(line: text) -> text:
    val trimmed = line.trim()
    if trimmed.starts_with("pub fn ") or trimmed.starts_with("fn "):
        return "function"
    if trimmed.starts_with("class "):
        return "class"
    if trimmed.starts_with("struct "):
        return "struct"
    if trimmed.starts_with("enum "):
        return "enum"
    ""

fn _decl_name(line: text, kind: text) -> text:
    var rest = line.trim()
    if rest.starts_with("pub fn "):
        rest = rest[7:]
    elif rest.starts_with("fn "):
        rest = rest[3:]
    elif kind == "class":
        rest = rest[6:]
    elif kind == "struct":
        rest = rest[7:]
    elif kind == "enum":
        rest = rest[5:]
    val paren = rest.index_of("(") ?? -1
    val colon = rest.index_of(":") ?? -1
    var end = rest.len()
    if paren >= 0 and paren < end:
        end = paren
    if colon >= 0 and colon < end:
        end = colon
    rest[0:end].trim()

fn _has_comment_before(lines: [text], index: i64) -> bool:
    if index <= 0:
        return false
    var i = index - 1
    while i >= 0:
        val trimmed = lines[i].trim()
        if trimmed == "":
            return false
        if trimmed.starts_with("#"):
            return true
        return false
    false

fn _has_docstring_after(lines: [text], index: i64) -> bool:
    if index + 1 >= lines.len():
        return false
    val trimmed = lines[index + 1].trim()
    trimmed.starts_with("\"\"\"") or trimmed.starts_with("'''")

fn _has_sdoctest_after(lines: [text], index: i64) -> bool:
    var i = index + 1
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed.starts_with("fn ") or trimmed.starts_with("class ") or trimmed.starts_with("struct ") or trimmed.starts_with("enum "):
            return false
        if trimmed.starts_with(">>>"):
            return true
        i = i + 1
    false

fn _warning_level(path: text, has_inline: bool, has_docstring: bool) -> text:
    if has_inline and has_docstring:
        return "none"
    if has_inline or has_docstring:
        return "warn"
    "error"

fn compute_inline_comment_coverage(files: [text]) -> [InlineCommentResult]:
    var results: [InlineCommentResult] = []
    for path in files:
        if not file_exists(path):
            continue
        val content = file_read(path)
        val lines = content.split("\n")
        var i = 0
        for line in lines:
            val kind = _decl_kind(line)
            if kind != "":
                val has_inline = _has_comment_before(lines, i)
                val has_docstring = _has_docstring_after(lines, i)
                val has_sdoctest = _has_sdoctest_after(lines, i)
                results.push(InlineCommentResult(
                    item_name: _decl_name(line, kind),
                    item_kind: kind,
                    file_path: path,
                    line: i + 1,
                    has_inline_comment: has_inline,
                    has_docstring: has_docstring,
                    has_sdoctest: has_sdoctest,
                    warning_level: _warning_level(path, has_inline, has_docstring)
                ))
            i = i + 1
    results

fn emit_missing_comment_warnings(results: [InlineCommentResult]) -> [text]:
    var warnings: [text] = []
    for result in results:
        if result.warning_level == "error":
            warnings.push("ERROR {result.file_path}:{result.line}: {result.item_kind} {result.item_name} is missing inline comment and docstring")
        elif result.warning_level == "warn":
            warnings.push("WARN {result.file_path}:{result.line}: {result.item_kind} {result.item_name} is partially documented")
    warnings

fn _percent(part: i64, total: i64) -> i64:
    if total == 0:
        return 0
    (part * 100) / total

fn generate_coverage_report(results: [InlineCommentResult]) -> text:
    val total = results.len() as i64
    var inline_count = 0
    var docstring_count = 0
    var both_count = 0
    var neither_count = 0
    var errors: [text] = []
    var warnings: [text] = []
    for result in results:
        if result.has_inline_comment:
            inline_count = inline_count + 1
        if result.has_docstring:
            docstring_count = docstring_count + 1
        if result.has_inline_comment and result.has_docstring:
            both_count = both_count + 1
        if not result.has_inline_comment and not result.has_docstring:
            neither_count = neither_count + 1
        if result.warning_level == "error":
            errors.push(result.item_name)
        elif result.warning_level == "warn":
            warnings.push(result.item_name)
    var lines: [text] = []
    lines.push("# Inline Comment Coverage Report")
    lines.push("")
    lines.push("Total Items:** {total}")
    lines.push("With Inline Comments:** {inline_count} ({_percent(inline_count, total)}%)")
    lines.push("With Docstrings:** {docstring_count} ({_percent(docstring_count, total)}%)")
    lines.push("With Both:** {both_count}")
    lines.push("With Neither:** {neither_count}")
    if errors.len() > 0:
        lines.push("")
        lines.push("### Errors")
        for name in errors:
            lines.push("- {name}")
    if warnings.len() > 0:
        lines.push("")
        lines.push("### Warnings")
        for name in warnings:
            lines.push("- {name}")
    lines.join("\n")
