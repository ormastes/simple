# Candidate model research evidence for SPipe LLM fine-tune attempts.

model_research:
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license; production and clinical use require explicit review"
    context_length: "deployment context window must be reverified before serving"
    fit: "medical-domain base model with prior Korean MedGemma project evidence"
    constraints: "retry2 only proves fixed-format data-quality gate; no accepted model yet"
    decision: "continue-with-medgemma-after-format-gate"
  - attempt_id: "llm_backed_app_server_dry_run"
    candidate_model: "not-selected"
    license: "pending-user-selection"
    context_length: "pending-user-selection"
    fit: "pending-user-selection"
    constraints: "pending-user-selection"
    decision: "pending-requirements-selection"
  - attempt_id: "llm_backed_app_server_dry_run"
    candidate_model: "Qwen/Qwen2.5-0.5B-Instruct"
    license: "open-weight"
    context_length: "32768"
    fit: "small instruct model for local QLoRA smoke and app/server tool behavior"
    constraints: "local GPU/VRAM availability and model license review required before production training"
    decision: "selected"
  - attempt_id: "llm_backed_app_server_dry_run"
    candidate_model: "gpt-4.1-nano-2025-04-14"
    license: "provider"
    context_length: "1047576"
    fit: "provider fallback for hosted supervised fine-tuning path"
    constraints: "requires provider credentials, cost guardrails, and provider model availability"
    decision: "fallback"
  - attempt_id: "llm_backed_app_server_dry_run"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license; distribution and clinical use require explicit review"
    context_length: "8192-ish transformer context; exact serving window must be verified in deployment"
    fit: "Existing Korean MedGemma project has trained/evaluated artifacts; best available trained artifact is 03_english_reasoning at 54.6 percent on 604 samples"
    constraints: "Medical safety risk; below 90 percent target; external repo dirty; baseline google model scored 57.78 percent on English-translated set"
    decision: "selected-as-evidence-not-final"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license; production and clinical use require explicit review"
    context_length: "deployment context window must be reverified before serving"
    fit: "medical-domain base model with existing Korean MedGemma project evidence"
    constraints: "existing artifact is below target; medical safety and data quality retry required"
    decision: "selected-as-retry-evidence-not-final"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license; production and clinical use require explicit review"
    context_length: "deployment context window must be reverified before serving"
    fit: "medical-domain base model with prior Korean MedGemma project evidence"
    constraints: "retry3 creates local artifact/eval evidence only; no accepted clinical model"
    decision: "continue-with-medgemma-for-implementation-dry-run"
  - attempt_id: "llm_backed_app_server_dry_run_retry4"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license plus dataset license review required before training"
    context_length: "deployment context window must be reverified before serving"
    fit: "medical-domain base model remains candidate after retry3 dry-run handoff"
    constraints: "retry4 blocks real QLoRA until licensed fixed-format data and license approval exist"
    decision: "hold-medgemma-candidate-behind-license-gate"
  - attempt_id: "llm_backed_app_server_dry_run_retry5"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license plus dataset license review required before training"
    context_length: "deployment context window must be reverified before serving"
    fit: "medical-domain base model remains candidate after retry4 license gate"
    constraints: "retry5 blocks real QLoRA until licensed fixed-format data, cache/checksum evidence, and license approval exist"
    decision: "hold-medgemma-candidate-behind-data-access-gate"
  - attempt_id: "llm_backed_app_server_dry_run_retry6"
    research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license plus dataset license review required before training"
    context_length: "deployment context window must be reverified before serving"
    fit: "medical-domain base model remains candidate, but retry6 cannot start before retry5 licensed cache review passes"
    constraints: "retry6 blocks real QLoRA until retry5 review is PASS and still blocks acceptance until target eval plus app handoff evidence exist"
    decision: "hold-training-behind-retry5-cache-review"
  - attempt_id: "llm_backed_app_server_dry_run_retry7"
    research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
    candidate_model: "google/medgemma-4b-it"
    license: "Health AI community license plus dataset license review required before training and deployment"
    context_length: "deployment context window must be reverified before serving"
    fit: "normal acceptance review only after retry6 target eval and handoff evidence exist"
    constraints: "retry7 cannot accept placeholder artifacts, missing safety review, missing license constraints, or missing deployment evidence"
    decision: "hold-acceptance-behind-retry6-target-eval-review"
