# Shell Dir Module - Directory operations namespace
#
# Provides a `dir` namespace object with common directory operations.
# Backed by io_runtime extern fn wrappers.
#
# Usage (via mod.spl):
#   use std.shell.{dir}
#   dir.exist(path)              -> bool
#   dir.create(path)             -> bool
#   dir.create_recursive(path)   -> bool
#   dir.remove(path)             -> bool
#   dir.remove_recursive(path)   -> bool
#   dir.list(path)               -> [text]

extern fn rt_dir_create(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_remove(path: text) -> bool
extern fn rt_dir_remove_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn exist(path: text) -> bool:
    val (out, err, code) = rt_process_run("/bin/sh", ["-c", "test -d '{path}' && echo 1 || echo 0"])
    code == 0 and out.trim() == "1"

fn create(path: text) -> bool:
    rt_dir_create(path)

fn create_recursive(path: text) -> bool:
    rt_dir_create_all(path)

fn remove(path: text) -> bool:
    rt_dir_remove(path)

fn remove_recursive(path: text) -> bool:
    rt_dir_remove_all(path)

fn list(path: text) -> [text]:
    rt_dir_list(path)
