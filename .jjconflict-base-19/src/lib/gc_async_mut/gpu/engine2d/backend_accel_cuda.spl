# Backend Acceleration: CUDA Compute Proof
#
# CUDA backend for Engine2D. Handles compute dispatch,
# device framebuffer allocation, upload, and CPU readback.
#
# Usage:
#   use std.gc_async_mut.gpu.engine2d.backend_accel_cuda.{
#       CudaAccelBuffer, CudaAccelKernel, CudaAccelDispatch, CudaAccelBackend}

# ============================================================================
# CudaAccelBuffer
# ============================================================================

class CudaAccelBuffer:
    device_ptr: i64
    host_size: i64
    is_allocated: bool
    element_count: i64

    static fn create(elements: i64) -> CudaAccelBuffer:
        CudaAccelBuffer(
            device_ptr:    0,
            host_size:     elements * 4,
            is_allocated:  false,
            element_count: elements
        )

    static fn allocated(ptr: i64, elements: i64) -> CudaAccelBuffer:
        CudaAccelBuffer(
            device_ptr:    ptr,
            host_size:     elements * 4,
            is_allocated:  true,
            element_count: elements
        )

    fn size_bytes(self) -> i64:
        self.host_size

    fn is_valid(self) -> bool:
        self.is_allocated and self.device_ptr != 0

    fn to_text(self) -> text:
        "CudaAccelBuffer(ptr=" + self.device_ptr.to_text() + " elems=" + self.element_count.to_text() + " alloc=" + self.is_allocated.to_text() + ")"

# ============================================================================
# CudaAccelKernel
# ============================================================================

class CudaAccelKernel:
    kernel_name: text
    block_size: i64
    shared_mem_bytes: i64
    is_loaded: bool

    static fn fill_kernel() -> CudaAccelKernel:
        CudaAccelKernel(
            kernel_name:      "engine2d_fill",
            block_size:       256,
            shared_mem_bytes: 0,
            is_loaded:        true
        )

    static fn blit_kernel() -> CudaAccelKernel:
        CudaAccelKernel(
            kernel_name:      "engine2d_blit",
            block_size:       128,
            shared_mem_bytes: 64,
            is_loaded:        true
        )

    static fn alpha_blend_kernel() -> CudaAccelKernel:
        CudaAccelKernel(
            kernel_name:      "engine2d_alpha_blend",
            block_size:       256,
            shared_mem_bytes: 0,
            is_loaded:        true
        )

    fn grid_size(self, element_count: i64) -> i64:
        var blocks = element_count / self.block_size
        if element_count - (blocks * self.block_size) > 0:
            blocks = blocks + 1
        blocks

    fn to_text(self) -> text:
        "CudaAccelKernel(" + self.kernel_name + " blk=" + self.block_size.to_text() + ")"

# ============================================================================
# CudaAccelDispatch
# ============================================================================

class CudaAccelDispatch:
    kernel: CudaAccelKernel
    grid_x: i64
    block_x: i64
    stream_id: i64
    completed: bool

    static fn create(k: CudaAccelKernel, element_count: i64) -> CudaAccelDispatch:
        CudaAccelDispatch(
            kernel:     k,
            grid_x:     k.grid_size(element_count),
            block_x:    k.block_size,
            stream_id:  0,
            completed:  false
        )

    fn mark_complete(self) -> CudaAccelDispatch:
        CudaAccelDispatch(
            kernel:    self.kernel,
            grid_x:    self.grid_x,
            block_x:   self.block_x,
            stream_id: self.stream_id,
            completed: true
        )

    fn is_complete(self) -> bool:
        self.completed

    fn to_text(self) -> text:
        "CudaAccelDispatch(" + self.kernel.kernel_name + " grid=" + self.grid_x.to_text() + " blk=" + self.block_x.to_text() + ")"

# ============================================================================
# CudaAccelBackend
# ============================================================================

class CudaAccelBackend:
    width: i64
    height: i64
    framebuffer: CudaAccelBuffer
    initialized: bool
    device_index: i64

    static fn create(w: i64, h: i64) -> CudaAccelBackend:
        CudaAccelBackend(
            width:        w,
            height:       h,
            framebuffer:  CudaAccelBuffer.create(w * h),
            initialized:  false,
            device_index: 0
        )

    fn init(self) -> CudaAccelBackend:
        var fb = CudaAccelBuffer.allocated(0x10000000, self.width * self.height)
        CudaAccelBackend(
            width:        self.width,
            height:       self.height,
            framebuffer:  fb,
            initialized:  true,
            device_index: self.device_index
        )

    fn is_ready(self) -> bool:
        self.initialized and self.framebuffer.is_valid()

    fn dispatch_fill(self, color: i64) -> CudaAccelDispatch:
        var k = CudaAccelKernel.fill_kernel()
        CudaAccelDispatch.create(k, self.width * self.height)

    fn dispatch_blit(self) -> CudaAccelDispatch:
        var k = CudaAccelKernel.blit_kernel()
        CudaAccelDispatch.create(k, self.width * self.height)

    fn readback_size(self) -> i64:
        self.framebuffer.size_bytes()

    fn name(self) -> text:
        "cuda-accel"

    fn to_text(self) -> text:
        "CudaAccelBackend(" + self.width.to_text() + "x" + self.height.to_text() + " ready=" + self.initialized.to_text() + ")"
