# YAML multi-document parsing plus anchor/alias support.
#
# anchor: ("anchor", [name, value])   alias: ("alias", name)

use lib.yaml.parse.{yaml_parse}

fn _yaml_lines(input: text) -> [text]:
    var out = []
    var cur = ""
    var i = 0
    while i < input.length():
        val ch = input.substring(i, i + 1)
        if ch == "\n":
            out.push(cur)
            cur = ""
        else:
            cur = cur + ch
        i = i + 1
    out.push(cur)
    out

fn yaml_parse_documents(input: text) -> [any]:
    val lines = _yaml_lines(input)
    var docs = []
    var cur = ""
    var i = 0
    while i < lines.length():
        val ln = lines[i]
        if ln.trim() == "---":
            docs.push(cur)
            cur = ""
        else:
            if cur == "":
                cur = ln
            else:
                cur = cur + "\n" + ln
        i = i + 1
    docs.push(cur)
    var out = []
    var j = 0
    while j < docs.length():
        out.push(yaml_parse(docs[j].trim()))
        j = j + 1
    out

fn yaml_create_anchor(name: text, value: any) -> any:
    ("anchor", [name, value])

fn yaml_create_alias(name: text) -> any:
    ("alias", name)

fn yaml_is_anchor(v: any) -> bool:
    v != nil and v.0 == "anchor"

fn yaml_is_alias(v: any) -> bool:
    v != nil and v.0 == "alias"

fn yaml_get_anchor_name(v: any) -> text:
    "{v.1[0]}"

fn yaml_get_anchor_value(v: any) -> any:
    v.1[1]

fn yaml_get_alias_name(v: any) -> text:
    "{v.1}"

fn yaml_resolve_aliases(v: any, anchors: [any]) -> any:
    if not yaml_is_alias(v):
        return v
    val name = yaml_get_alias_name(v)
    var i = 0
    while i < anchors.length():
        if yaml_get_anchor_name(anchors[i]) == name:
            return yaml_get_anchor_value(anchors[i])
        i = i + 1
    v
