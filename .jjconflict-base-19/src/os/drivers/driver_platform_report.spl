# Aggregated readiness report for SimpleOS driver platform lanes.

use os.drivers.driver_platform_contract.{
    AudioCodecProbe,
    CpuAccelFeatures,
    DriverTeamPlan,
    ExokernelDeviceGrant,
    GpuVendorProbe,
    InputProbe,
    audio_codec_reason,
    cpu_audio_kernel,
    cpu_pixel_kernel,
    driver_team_plan_blocker,
    driver_team_plan_ready,
    exokernel_grant_reason,
    gpu_probe_reason,
    input_probe_reason
}

struct DriverPlatformReport:
    gpu: GpuVendorProbe
    cpu: CpuAccelFeatures
    audio_primary: AudioCodecProbe
    audio_secondary: AudioCodecProbe
    keyboard_mouse: InputProbe
    exokernel: ExokernelDeviceGrant
    team: DriverTeamPlan

fn driver_platform_report(gpu: GpuVendorProbe, cpu: CpuAccelFeatures, audio_primary: AudioCodecProbe, audio_secondary: AudioCodecProbe, keyboard_mouse: InputProbe, exokernel: ExokernelDeviceGrant, team: DriverTeamPlan) -> DriverPlatformReport:
    DriverPlatformReport(gpu: gpu, cpu: cpu, audio_primary: audio_primary, audio_secondary: audio_secondary, keyboard_mouse: keyboard_mouse, exokernel: exokernel, team: team)

fn driver_platform_report_ready(r: DriverPlatformReport) -> bool:
    gpu_probe_reason(r.gpu) == "supported" and
        cpu_pixel_kernel(r.cpu) != "scalar" and
        cpu_audio_kernel(r.cpu) != "scalar-audio" and
        audio_codec_reason(r.audio_primary).contains("supported:") and
        audio_codec_reason(r.audio_secondary).contains("supported:") and
        input_probe_reason(r.keyboard_mouse).contains("supported:") and
        exokernel_grant_reason(r.exokernel) == "supported" and
        driver_team_plan_ready(r.team)

fn driver_platform_report_blocker(r: DriverPlatformReport) -> text:
    val gpu_reason = gpu_probe_reason(r.gpu)
    if gpu_reason != "supported":
        return "gpu:" + gpu_reason
    if cpu_pixel_kernel(r.cpu) == "scalar":
        return "cpu-pixel:missing-accel"
    if cpu_audio_kernel(r.cpu) == "scalar-audio":
        return "cpu-audio:missing-accel"
    val primary_audio = audio_codec_reason(r.audio_primary)
    if not primary_audio.contains("supported:"):
        return "audio-primary:" + primary_audio
    val secondary_audio = audio_codec_reason(r.audio_secondary)
    if not secondary_audio.contains("supported:"):
        return "audio-secondary:" + secondary_audio
    val input_reason = input_probe_reason(r.keyboard_mouse)
    if not input_reason.contains("supported:"):
        return "input:" + input_reason
    val exokernel_reason = exokernel_grant_reason(r.exokernel)
    if exokernel_reason != "supported":
        return "exokernel:" + exokernel_reason
    if not driver_team_plan_ready(r.team):
        return "team:" + driver_team_plan_blocker(r.team)
    "ready"

fn driver_platform_report_marker(r: DriverPlatformReport) -> text:
    "[driver-platform-report] " +
        "status=" + driver_platform_report_blocker(r) +
        " gpu=" + gpu_probe_reason(r.gpu) +
        " cpu_pixel=" + cpu_pixel_kernel(r.cpu) +
        " cpu_audio=" + cpu_audio_kernel(r.cpu) +
        " audio_primary=" + audio_codec_reason(r.audio_primary) +
        " audio_secondary=" + audio_codec_reason(r.audio_secondary) +
        " input=" + input_probe_reason(r.keyboard_mouse) +
        " exokernel=" + exokernel_grant_reason(r.exokernel) +
        " team=" + driver_team_plan_blocker(r.team)
