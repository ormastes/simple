# String operations diagnostic for compiled mode
#
# Tests: text.slice(), text.len(), text == text, text.starts_with()
# Goal: determine which string operations work in LLVM compiled mode

fn main() -> i64:
    print "=== String Operations Diagnostic ==="

    val s = "hello>world"
    print "s = '{s}'"
    print "s.len() = {s.len()}"

    # Test slice
    print "\n--- Slice test ---"
    val ch0 = s.slice(0, 1)
    print "s.slice(0,1) = '{ch0}'"
    val ch5 = s.slice(5, 6)
    print "s.slice(5,6) = '{ch5}'"

    # Test equality
    print "\n--- Equality test ---"
    val gt = ">"
    print "gt = '{gt}'"
    print "ch5 == gt: {ch5 == gt}"
    print "'>' literal: {'>'}"

    # Test with direct comparison
    val a = "hello"
    val b = "hello"
    val c = "world"
    print "a==b (same): {a == b}"
    print "a==c (diff): {a == c}"

    # Test starts_with
    print "\n--- starts_with test ---"
    print "s.starts_with('h'): {s.starts_with("h")}"
    print "s.starts_with('x'): {s.starts_with("x")}"

    # Test character-by-character
    print "\n--- Char loop ---"
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        print "  [{i}] = '{ch}' (== '>': {ch == ">"})"
        i = i + 1

    print "\n=== Done ==="
    return 0

main()
