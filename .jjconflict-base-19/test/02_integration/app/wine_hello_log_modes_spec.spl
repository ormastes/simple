use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_app(app_path: text, args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/" + app_path + "\" " + joined
    ])

describe "wine hello log mode CLI options":
    it "shows shared log options in wine-hello help":
        val (out, err, code) = _run_app("src/app/wine_hello/main.spl", ["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "rejects invalid wine-hello log mode":
        val (out, err, code) = _run_app("src/app/wine_hello/main.spl", ["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "shows shared log options in wine-gui-hello help":
        val (out, err, code) = _run_app("src/app/wine_gui_hello/main.spl", ["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "rejects invalid wine-gui-hello log mode":
        val (out, err, code) = _run_app("src/app/wine_gui_hello/main.spl", ["--log-mode=noisy"])
        expect(code).to_equal(1)
