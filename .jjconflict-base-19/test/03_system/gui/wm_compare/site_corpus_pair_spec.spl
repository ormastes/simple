# @tag: sys, wm_compare, html_compat, corpus, comparison

use std.spec.{describe, it, expect}
use app.wm_compare.html_compat.{CaptureResult}
use app.wm_compare.site_corpus.{build_famous_site_sample_corpus}
use app.wm_compare.site_corpus_compat.{SiteCorpusCompatOpts, compare_site_sample}

fn _opts(width: i32, height: i32) -> SiteCorpusCompatOpts:
    SiteCorpusCompatOpts(
        only: "",
        from_id: "",
        limit: 0,
        update_baseline: false,
        skip_simple: false,
        skip_simple_watchdog: false,
        simple_timeout_ms: 60000,
        width: width,
        height: height,
        continue_on_fail: false,
        stale_only: false,
        production_renderer: false,
        help: false
    )

describe "famous-site corpus pair comparison":

    it "does not accept captures with mismatched viewport metadata":
        val sample = build_famous_site_sample_corpus()[0]
        val pixels = [0xFF000000u32, 0xFFFFFFFFu32]
        val chrome = CaptureResult(
            pixels: pixels,
            width: 1, height: 2,
            backend_name: "chrome", success: true, error: ""
        )
        val simple = CaptureResult(
            pixels: pixels,
            width: 2, height: 1,
            backend_name: "simple", success: true, error: ""
        )
        val pair = compare_site_sample(sample, chrome, simple, _opts(2, 1))
        expect(pair.exact).to_equal(false)
        expect(pair.accepted).to_equal(false)
        expect(pair.chrome_ok).to_equal(false)
        expect(pair.chrome_error).to_contain("viewport metadata mismatch")
