# DB Accel Phase 3 — Query Planner + ML Cost Model Regression Tests
#
# Self-contained: all structs and helpers are defined inline.
# Tests cover CostModel, PlanCost, estimate_cost, plan_query, pick_best, choose_plan.
#
# =============================================================================
# Inline definitions (replicate logic without imports)
# =============================================================================

# ── Tuning knobs ──────────────────────────────────────────────────────────────

val COST_IO_WEIGHT_DEFAULT: f64 = 1.0
val COST_CPU_WEIGHT_DEFAULT: f64 = 0.1
val COST_SELECTIVITY_DEFAULT: f64 = 0.1
val COST_SELECTIVITY_PREFIX: f64 = 0.05
val COST_SELECTIVITY_RANGE: f64 = 0.2
val COST_SELECTIVITY_FULL: f64 = 1.0
val COST_JOIN_FACTOR: f64 = 0.8

# ── Data types ────────────────────────────────────────────────────────────────

struct CostModel:
    row_count: i64
    io_weight: f64
    cpu_weight: f64
    selectivity_default: f64

fn cost_model_new(row_count: i64) -> CostModel:
    CostModel(
        row_count: row_count,
        io_weight: COST_IO_WEIGHT_DEFAULT,
        cpu_weight: COST_CPU_WEIGHT_DEFAULT,
        selectivity_default: COST_SELECTIVITY_DEFAULT
    )

fn cost_model_with_weights(row_count: i64, io_weight: f64, cpu_weight: f64) -> CostModel:
    CostModel(
        row_count: row_count,
        io_weight: io_weight,
        cpu_weight: cpu_weight,
        selectivity_default: COST_SELECTIVITY_DEFAULT
    )

struct PlanCost:
    estimated_rows: i64
    io_cost: f64
    cpu_cost: f64
    total_cost: f64

fn plan_cost_total(c: PlanCost) -> f64:
    c.total_cost

fn plan_cost_rows(c: PlanCost) -> i64:
    c.estimated_rows

# ── Row estimation ────────────────────────────────────────────────────────────

fn estimate_rows_full_scan(model: CostModel) -> i64:
    model.row_count

fn estimate_rows_index_lookup(model: CostModel) -> i64:
    val sel = model.selectivity_default
    val est = (model.row_count.to_float() * sel) as i64
    if est < 1:
        return 1
    est

fn estimate_rows_index_range(model: CostModel) -> i64:
    val sel = COST_SELECTIVITY_RANGE
    val est = (model.row_count.to_float() * sel) as i64
    if est < 1:
        return 1
    est

fn estimate_rows_index_prefix(model: CostModel) -> i64:
    val sel = COST_SELECTIVITY_PREFIX
    val est = (model.row_count.to_float() * sel) as i64
    if est < 1:
        return 1
    est

fn estimate_rows_for_kind(model: CostModel, kind: text) -> i64:
    if kind == "FullScan":
        return estimate_rows_full_scan(model)
    if kind == "IndexLookup":
        return estimate_rows_index_lookup(model)
    if kind == "IndexRange":
        return estimate_rows_index_range(model)
    if kind == "IndexPrefix":
        return estimate_rows_index_prefix(model)
    if kind == "Join":
        val half = model.row_count / 2
        val est = (half.to_float() * COST_JOIN_FACTOR) as i64
        if est < 1:
            return 1
        return est
    estimate_rows_full_scan(model)

# ── Cost estimation ───────────────────────────────────────────────────────────

fn estimate_cost_full_scan(model: CostModel) -> PlanCost:
    val rows = estimate_rows_full_scan(model)
    val io = rows.to_float() * model.io_weight
    val cpu = rows.to_float() * model.cpu_weight
    PlanCost(estimated_rows: rows, io_cost: io, cpu_cost: cpu, total_cost: io + cpu)

fn estimate_cost_index_lookup(model: CostModel) -> PlanCost:
    val rows = estimate_rows_index_lookup(model)
    val io = rows.to_float() * model.io_weight + 1.0
    val cpu = rows.to_float() * model.cpu_weight
    PlanCost(estimated_rows: rows, io_cost: io, cpu_cost: cpu, total_cost: io + cpu)

fn estimate_cost_index_range(model: CostModel) -> PlanCost:
    val rows = estimate_rows_index_range(model)
    val io = rows.to_float() * model.io_weight + 1.0
    val cpu = rows.to_float() * model.cpu_weight
    PlanCost(estimated_rows: rows, io_cost: io, cpu_cost: cpu, total_cost: io + cpu)

fn estimate_cost_index_prefix(model: CostModel) -> PlanCost:
    val rows = estimate_rows_index_prefix(model)
    val io = rows.to_float() * model.io_weight + 1.0
    val cpu = rows.to_float() * model.cpu_weight
    PlanCost(estimated_rows: rows, io_cost: io, cpu_cost: cpu, total_cost: io + cpu)

fn estimate_cost_join(model: CostModel) -> PlanCost:
    val rows = estimate_rows_for_kind(model, "Join")
    val io = rows.to_float() * model.io_weight * 2.0
    val cpu = rows.to_float() * model.cpu_weight * COST_JOIN_FACTOR
    PlanCost(estimated_rows: rows, io_cost: io, cpu_cost: cpu, total_cost: io + cpu)

fn estimate_cost(plan_kind: text, model: CostModel) -> PlanCost:
    if plan_kind == "FullScan":
        return estimate_cost_full_scan(model)
    if plan_kind == "IndexLookup":
        return estimate_cost_index_lookup(model)
    if plan_kind == "IndexRange":
        return estimate_cost_index_range(model)
    if plan_kind == "IndexPrefix":
        return estimate_cost_index_prefix(model)
    if plan_kind == "Join":
        return estimate_cost_join(model)
    estimate_cost_full_scan(model)

# ── Predicate tree ────────────────────────────────────────────────────────────

enum PredicateKind:
    Eq
    Range
    Prefix
    And
    Or

struct Predicate:
    kind: PredicateKind
    column: text
    value: text
    range_lo: text
    range_hi: text
    children: [Predicate]

fn predicate_eq(column: text, value: text) -> Predicate:
    Predicate(
        kind: PredicateKind.Eq,
        column: column,
        value: value,
        range_lo: "",
        range_hi: "",
        children: []
    )

fn predicate_range(column: text, lo: text, hi: text) -> Predicate:
    Predicate(
        kind: PredicateKind.Range,
        column: column,
        value: "",
        range_lo: lo,
        range_hi: hi,
        children: []
    )

fn predicate_prefix(column: text, pfx: text) -> Predicate:
    Predicate(
        kind: PredicateKind.Prefix,
        column: column,
        value: pfx,
        range_lo: "",
        range_hi: "",
        children: []
    )

fn predicate_and(children: [Predicate]) -> Predicate:
    Predicate(
        kind: PredicateKind.And,
        column: "",
        value: "",
        range_lo: "",
        range_hi: "",
        children: children
    )

fn predicate_or(children: [Predicate]) -> Predicate:
    Predicate(
        kind: PredicateKind.Or,
        column: "",
        value: "",
        range_lo: "",
        range_hi: "",
        children: children
    )

# ── Index descriptor ──────────────────────────────────────────────────────────

enum IndexKind:
    BTree
    Hash
    Prefix

struct IndexDescriptor:
    name: text
    column: text
    kind: IndexKind

fn index_descriptor_new(name: text, column: text, kind: IndexKind) -> IndexDescriptor:
    IndexDescriptor(name: name, column: column, kind: kind)

fn index_covers_column(idx: IndexDescriptor, column: text) -> bool:
    idx.column == column

# ── Plan nodes ────────────────────────────────────────────────────────────────

enum PlanNodeKind:
    FullScan
    IndexLookup
    IndexRange
    IndexPrefix
    Join

struct PlanNode:
    kind: PlanNodeKind
    index_name: text
    predicate_column: text
    left_node: text
    right_node: text

fn plan_node_full_scan() -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.FullScan,
        index_name: "",
        predicate_column: "",
        left_node: "",
        right_node: ""
    )

fn plan_node_index_lookup(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexLookup,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_index_range(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexRange,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_index_prefix(index_name: text, column: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.IndexPrefix,
        index_name: index_name,
        predicate_column: column,
        left_node: "",
        right_node: ""
    )

fn plan_node_join(left: text, right: text) -> PlanNode:
    PlanNode(
        kind: PlanNodeKind.Join,
        index_name: "",
        predicate_column: "",
        left_node: left,
        right_node: right
    )

# ── Plan candidate ────────────────────────────────────────────────────────────

struct PlanCandidate:
    node: PlanNode
    cost: PlanCost

# ── Candidate enumeration ─────────────────────────────────────────────────────

fn find_index_for_predicate(pred: Predicate, indexes: [IndexDescriptor]) -> [IndexDescriptor]:
    var result: [IndexDescriptor] = []
    var i = 0
    while i < indexes.len():
        if index_covers_column(indexes[i as i32], pred.column):
            result.push(indexes[i as i32])
        i = i + 1
    result

fn candidates_for_predicate(pred: Predicate, indexes: [IndexDescriptor], model: CostModel) -> [PlanCandidate]:
    var candidates: [PlanCandidate] = []
    val full_scan_node = plan_node_full_scan()
    val full_scan_cost = estimate_cost("FullScan", model)
    candidates.push(PlanCandidate(node: full_scan_node, cost: full_scan_cost))

    val covering = find_index_for_predicate(pred, indexes)
    var ci = 0
    while ci < covering.len():
        val idx = covering[ci as i32]
        match pred.kind:
            case PredicateKind.Eq:
                if idx.kind == IndexKind.Hash or idx.kind == IndexKind.BTree:
                    val nd = plan_node_index_lookup(idx.name, pred.column)
                    val co = estimate_cost("IndexLookup", model)
                    candidates.push(PlanCandidate(node: nd, cost: co))
            case PredicateKind.Range:
                if idx.kind == IndexKind.BTree:
                    val nd = plan_node_index_range(idx.name, pred.column)
                    val co = estimate_cost("IndexRange", model)
                    candidates.push(PlanCandidate(node: nd, cost: co))
            case PredicateKind.Prefix:
                if idx.kind == IndexKind.Prefix or idx.kind == IndexKind.BTree:
                    val nd = plan_node_index_prefix(idx.name, pred.column)
                    val co = estimate_cost("IndexPrefix", model)
                    candidates.push(PlanCandidate(node: nd, cost: co))
            case PredicateKind.And:
                pass_do_nothing
            case PredicateKind.Or:
                pass_do_nothing
        ci = ci + 1

    candidates

fn plan_query(pred: Predicate, indexes: [IndexDescriptor], model: CostModel) -> [PlanCandidate]:
    match pred.kind:
        case PredicateKind.And:
            var all: [PlanCandidate] = []
            var ci = 0
            while ci < pred.children.len():
                val child_candidates = candidates_for_predicate(pred.children[ci as i32], indexes, model)
                var ki = 0
                while ki < child_candidates.len():
                    all.push(child_candidates[ki as i32])
                    ki = ki + 1
                ci = ci + 1
            if pred.children.len() >= 2:
                val jn = plan_node_join("child_0", "child_1")
                val jc = estimate_cost("Join", model)
                all.push(PlanCandidate(node: jn, cost: jc))
            all
        case PredicateKind.Or:
            var all: [PlanCandidate] = []
            val fsn = plan_node_full_scan()
            val fsc = estimate_cost("FullScan", model)
            all.push(PlanCandidate(node: fsn, cost: fsc))
            all
        case PredicateKind.Eq:
            candidates_for_predicate(pred, indexes, model)
        case PredicateKind.Range:
            candidates_for_predicate(pred, indexes, model)
        case PredicateKind.Prefix:
            candidates_for_predicate(pred, indexes, model)

fn pick_best(candidates: [PlanCandidate]) -> PlanNode:
    if candidates.len() == 0:
        return plan_node_full_scan()
    var best_idx = 0
    var best_cost = plan_cost_total(candidates[0].cost)
    var i = 1
    while i < candidates.len():
        val c = plan_cost_total(candidates[i as i32].cost)
        if c < best_cost:
            best_cost = c
            best_idx = i
        i = i + 1
    candidates[best_idx as i32].node

fn choose_plan(pred: Predicate, indexes: [IndexDescriptor], row_count: i64) -> PlanNode:
    val model = cost_model_new(row_count)
    val candidates = plan_query(pred, indexes, model)
    pick_best(candidates)

# =============================================================================
# CostModel Tests
# =============================================================================

describe "CostModel":
    it "cost_model_new sets row_count":
        val m = cost_model_new(1000)
        expect(m.row_count).to_equal(1000)

    it "cost_model_new defaults io_weight to 1.0":
        val m = cost_model_new(500)
        expect(m.io_weight).to_equal(1.0)

    it "cost_model_new defaults cpu_weight to 0.1":
        val m = cost_model_new(500)
        expect(m.cpu_weight).to_equal(0.1)

    it "cost_model_new defaults selectivity to 0.1":
        val m = cost_model_new(500)
        expect(m.selectivity_default).to_equal(0.1)

    it "cost_model_with_weights uses supplied weights":
        val m = cost_model_with_weights(100, 2.0, 0.5)
        expect(m.io_weight).to_equal(2.0)

# =============================================================================
# PlanCost Accessor Tests
# =============================================================================

describe "PlanCost accessors":
    it "plan_cost_total returns total_cost field":
        val c = PlanCost(estimated_rows: 10, io_cost: 5.0, cpu_cost: 1.0, total_cost: 6.0)
        expect(plan_cost_total(c)).to_equal(6.0)

    it "plan_cost_rows returns estimated_rows field":
        val c = PlanCost(estimated_rows: 42, io_cost: 1.0, cpu_cost: 0.5, total_cost: 1.5)
        expect(plan_cost_rows(c)).to_equal(42)

# =============================================================================
# estimate_cost Tests
# =============================================================================

describe "estimate_cost":
    it "FullScan rows equals row_count":
        val m = cost_model_new(1000)
        val pc = estimate_cost("FullScan", m)
        expect(plan_cost_rows(pc)).to_equal(1000)

    it "IndexLookup rows less than FullScan for large table":
        val m = cost_model_new(1000)
        val full = estimate_cost("FullScan", m)
        val lookup = estimate_cost("IndexLookup", m)
        expect(plan_cost_rows(lookup) < plan_cost_rows(full)).to_equal(true)

    it "IndexLookup total_cost less than FullScan total_cost for large table":
        val m = cost_model_new(1000)
        val full = estimate_cost("FullScan", m)
        val lookup = estimate_cost("IndexLookup", m)
        expect(plan_cost_total(lookup) < plan_cost_total(full)).to_equal(true)

    it "IndexRange rows less than FullScan for large table":
        val m = cost_model_new(1000)
        val full = estimate_cost("FullScan", m)
        val rng = estimate_cost("IndexRange", m)
        expect(plan_cost_rows(rng) < plan_cost_rows(full)).to_equal(true)

    it "IndexPrefix rows less than IndexRange for large table":
        val m = cost_model_new(1000)
        val rng = estimate_cost("IndexRange", m)
        val pfx = estimate_cost("IndexPrefix", m)
        expect(plan_cost_rows(pfx) < plan_cost_rows(rng)).to_equal(true)

    it "Join rows positive for any table":
        val m = cost_model_new(100)
        val jn = estimate_cost("Join", m)
        expect(plan_cost_rows(jn) > 0).to_equal(true)

    it "unknown kind falls back to FullScan rows":
        val m = cost_model_new(200)
        val unk = estimate_cost("Unknown", m)
        val full = estimate_cost("FullScan", m)
        expect(plan_cost_rows(unk)).to_equal(plan_cost_rows(full))

    it "IndexLookup at min (1 row) returns 1":
        val m = cost_model_new(1)
        val lookup = estimate_cost("IndexLookup", m)
        expect(plan_cost_rows(lookup)).to_equal(1)

# =============================================================================
# plan_query Tests
# =============================================================================

describe "plan_query":
    it "Eq predicate with no indexes returns FullScan only":
        val pred = predicate_eq("col_a", "val1")
        val indexes: [IndexDescriptor] = []
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        expect(candidates.len()).to_equal(1)

    it "Eq predicate with matching BTree index returns two candidates":
        val pred = predicate_eq("col_a", "val1")
        val idx = index_descriptor_new("idx_a", "col_a", IndexKind.BTree)
        val indexes = [idx]
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        expect(candidates.len()).to_equal(2)

    it "Range predicate with BTree index includes IndexRange candidate":
        val pred = predicate_range("col_b", "a", "z")
        val idx = index_descriptor_new("idx_b", "col_b", IndexKind.BTree)
        val indexes = [idx]
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        expect(candidates.len() >= 2).to_equal(true)

    it "Prefix predicate with Prefix index includes IndexPrefix candidate":
        val pred = predicate_prefix("col_c", "ns/")
        val idx = index_descriptor_new("idx_c", "col_c", IndexKind.Prefix)
        val indexes = [idx]
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        expect(candidates.len() >= 2).to_equal(true)

    it "Or predicate returns exactly one FullScan candidate":
        val p1 = predicate_eq("col_a", "x")
        val p2 = predicate_eq("col_a", "y")
        val pred = predicate_or([p1, p2])
        val indexes: [IndexDescriptor] = []
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        expect(candidates.len()).to_equal(1)

    it "And predicate with two children includes Join candidate":
        val p1 = predicate_eq("col_a", "x")
        val p2 = predicate_eq("col_b", "y")
        val pred = predicate_and([p1, p2])
        val indexes: [IndexDescriptor] = []
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        # Two FullScans (one per child) + one Join
        expect(candidates.len()).to_equal(3)

    it "index on wrong column is not used for Eq predicate":
        val pred = predicate_eq("col_a", "val1")
        val idx = index_descriptor_new("idx_b", "col_b", IndexKind.BTree)
        val indexes = [idx]
        val m = cost_model_new(500)
        val candidates = plan_query(pred, indexes, m)
        # Only FullScan since index is on col_b, not col_a
        expect(candidates.len()).to_equal(1)

# =============================================================================
# pick_best Tests
# =============================================================================

describe "pick_best":
    it "empty candidates returns FullScan node":
        val candidates: [PlanCandidate] = []
        val nd = pick_best(candidates)
        expect(nd.kind == PlanNodeKind.FullScan).to_equal(true)

    it "single candidate is returned":
        val nd = plan_node_index_lookup("idx_x", "col_x")
        val co = PlanCost(estimated_rows: 5, io_cost: 6.0, cpu_cost: 0.5, total_cost: 6.5)
        val candidates = [PlanCandidate(node: nd, cost: co)]
        val result = pick_best(candidates)
        expect(result.kind == PlanNodeKind.IndexLookup).to_equal(true)

    it "picks candidate with lower total_cost":
        val nd1 = plan_node_full_scan()
        val co1 = PlanCost(estimated_rows: 1000, io_cost: 1000.0, cpu_cost: 100.0, total_cost: 1100.0)
        val nd2 = plan_node_index_lookup("idx_x", "col_x")
        val co2 = PlanCost(estimated_rows: 10, io_cost: 11.0, cpu_cost: 1.0, total_cost: 12.0)
        val candidates = [PlanCandidate(node: nd1, cost: co1), PlanCandidate(node: nd2, cost: co2)]
        val result = pick_best(candidates)
        expect(result.kind == PlanNodeKind.IndexLookup).to_equal(true)

    it "first wins on tie":
        val nd1 = plan_node_full_scan()
        val co1 = PlanCost(estimated_rows: 100, io_cost: 50.0, cpu_cost: 5.0, total_cost: 55.0)
        val nd2 = plan_node_index_lookup("idx_x", "col_x")
        val co2 = PlanCost(estimated_rows: 100, io_cost: 50.0, cpu_cost: 5.0, total_cost: 55.0)
        val candidates = [PlanCandidate(node: nd1, cost: co1), PlanCandidate(node: nd2, cost: co2)]
        val result = pick_best(candidates)
        expect(result.kind == PlanNodeKind.FullScan).to_equal(true)

# =============================================================================
# choose_plan End-to-End Tests
# =============================================================================

describe "choose_plan":
    it "Eq with BTree index chooses IndexLookup over FullScan":
        val pred = predicate_eq("col_a", "42")
        val idx = index_descriptor_new("idx_a", "col_a", IndexKind.BTree)
        val indexes = [idx]
        val nd = choose_plan(pred, indexes, 10000)
        expect(nd.kind == PlanNodeKind.IndexLookup).to_equal(true)

    it "Prefix with Prefix index chooses IndexPrefix":
        val pred = predicate_prefix("col_b", "ns/")
        val idx = index_descriptor_new("idx_b", "col_b", IndexKind.Prefix)
        val indexes = [idx]
        val nd = choose_plan(pred, indexes, 10000)
        expect(nd.kind == PlanNodeKind.IndexPrefix).to_equal(true)

    it "Range with BTree index chooses IndexRange":
        val pred = predicate_range("col_c", "a", "m")
        val idx = index_descriptor_new("idx_c", "col_c", IndexKind.BTree)
        val indexes = [idx]
        val nd = choose_plan(pred, indexes, 10000)
        expect(nd.kind == PlanNodeKind.IndexRange).to_equal(true)

    it "Eq with no indexes returns FullScan":
        val pred = predicate_eq("col_a", "x")
        val indexes: [IndexDescriptor] = []
        val nd = choose_plan(pred, indexes, 500)
        expect(nd.kind == PlanNodeKind.FullScan).to_equal(true)

    it "Or predicate always returns FullScan":
        val p1 = predicate_eq("col_a", "x")
        val p2 = predicate_eq("col_a", "y")
        val pred = predicate_or([p1, p2])
        val idx = index_descriptor_new("idx_a", "col_a", IndexKind.Hash)
        val indexes = [idx]
        val nd = choose_plan(pred, indexes, 1000)
        expect(nd.kind == PlanNodeKind.FullScan).to_equal(true)

    it "index_name populated on IndexLookup result":
        val pred = predicate_eq("col_a", "42")
        val idx = index_descriptor_new("my_idx", "col_a", IndexKind.Hash)
        val indexes = [idx]
        val nd = choose_plan(pred, indexes, 10000)
        expect(nd.index_name).to_equal("my_idx")

    it "predicate_column populated on IndexRange result":
        val pred = predicate_range("col_d", "0", "9")
        val idx = index_descriptor_new("idx_d", "col_d", IndexKind.BTree)
        val indexes = [idx]
        val nd = choose_plan(pred, indexes, 10000)
        expect(nd.predicate_column).to_equal("col_d")
