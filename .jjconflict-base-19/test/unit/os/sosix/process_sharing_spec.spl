"""
SOSIX Process Sharing — self-contained unit tests.

All logic is replicated inline so no OS or syscall imports are required.
Tests cover: process-request constant contracts, dataset/queue constant
contracts, queue-notify syscall ID range, dataset-VFS stub contracts, and
compat-alias integer identities.
"""

# ============================================================================
# Inline constant replicas (no imports needed)
# ============================================================================

val _PROC_MAX_REQUESTS: u64 = 64
val _PROC_REQ_FREE: u8 = 0
val _PROC_REQ_PENDING: u8 = 1
val _PROC_REQ_COMPLETE: u8 = 2
val _PROC_REQ_ERROR: u8 = 3

val _PROC_OP_NONE: u8 = 0
val _PROC_OP_FORK: u8 = 1
val _PROC_OP_EXECVE: u8 = 2
val _PROC_OP_SPAWN: u8 = 3
val _PROC_OP_WAITPID: u8 = 4
val _PROC_OP_EXIT: u8 = 5
val _PROC_OP_GETPID: u8 = 6
val _PROC_OP_SIGNAL: u8 = 7

val _MAX_DATASETS: u64 = 64
val _DATASET_MAX_BYTES: u64 = 4096
val _MAX_QUEUES: u64 = 32
val _QUEUE_MAX_CAPACITY: u64 = 32
val _QUEUE_MAX_MSG_BYTES: u64 = 128
val _NO_DATASET_HIGH_BIT: u64 = 9223372036854775807

val _POLL_READ: u32 = 1
val _POLL_WRITE: u32 = 4
val _POLL_HUP: u32 = 16

val _QUEUE_CLOSE_SEND: u32 = 1
val _QUEUE_CLOSE_RECV: u32 = 2

val _ASYNC_FREE: u8 = 0
val _ASYNC_PENDING: u8 = 1
val _ASYNC_COMPLETE: u8 = 2
val _ASYNC_ERROR: u8 = 3
val _IO_BACKEND_INVALID: u8 = 0
val _IO_BACKEND_SERIAL: u8 = 1
val _IO_BACKEND_VFS: u8 = 2
val _MAX_ASYNC_REQUESTS: u64 = 128

val _SYS_DATASET_CREATE: u64 = 120
val _SYS_DATASET_WRITE: u64 = 121
val _SYS_DATASET_SEAL: u64 = 122
val _SYS_DATASET_READ: u64 = 123
val _SYS_DATASET_CLOSE: u64 = 124
val _SYS_QUEUE_CREATE: u64 = 125
val _SYS_QUEUE_SEND: u64 = 126
val _SYS_QUEUE_RECV: u64 = 127
val _SYS_QUEUE_POLL: u64 = 128
val _SYS_QUEUE_CLOSE: u64 = 129
val _SYS_QUEUE_WAIT_RECV: u64 = 130
val _SYS_QUEUE_WAIT_SEND: u64 = 131

# ============================================================================
# Process request state constants
# ============================================================================

describe "SOSIX process request state constants":
    it "REQ_FREE is 0":
        val s = _PROC_REQ_FREE
        expect(s).to_equal(0u8)

    it "REQ_PENDING is 1":
        val s = _PROC_REQ_PENDING
        expect(s).to_equal(1u8)

    it "REQ_COMPLETE is 2":
        val s = _PROC_REQ_COMPLETE
        expect(s).to_equal(2u8)

    it "REQ_ERROR is 3":
        val s = _PROC_REQ_ERROR
        expect(s).to_equal(3u8)

    it "MAX_REQUESTS is 64":
        val n = _PROC_MAX_REQUESTS
        expect(n).to_equal(64u64)

# ============================================================================
# Process operation code constants
# ============================================================================

describe "SOSIX process operation codes":
    it "OP_NONE is 0":
        expect(_PROC_OP_NONE).to_equal(0u8)

    it "OP_FORK is 1":
        expect(_PROC_OP_FORK).to_equal(1u8)

    it "OP_SPAWN is 3":
        expect(_PROC_OP_SPAWN).to_equal(3u8)

    it "OP_EXIT is 5":
        expect(_PROC_OP_EXIT).to_equal(5u8)

    it "OP_SIGNAL is 7":
        expect(_PROC_OP_SIGNAL).to_equal(7u8)

# ============================================================================
# Dataset and queue sharing constants
# ============================================================================

describe "SOSIX dataset constants":
    it "MAX_DATASETS is 64":
        expect(_MAX_DATASETS).to_equal(64u64)

    it "DATASET_MAX_BYTES is 4096":
        expect(_DATASET_MAX_BYTES).to_equal(4096u64)

    it "NO_DATASET high-bit value is large positive u64":
        val high_bit = _NO_DATASET_HIGH_BIT
        expect(high_bit).to_be_greater_than(1000000000u64)

describe "SOSIX queue constants":
    it "MAX_QUEUES is 32":
        expect(_MAX_QUEUES).to_equal(32u64)

    it "QUEUE_MAX_CAPACITY is 32":
        expect(_QUEUE_MAX_CAPACITY).to_equal(32u64)

    it "QUEUE_MAX_MSG_BYTES is 128":
        expect(_QUEUE_MAX_MSG_BYTES).to_equal(128u64)

    it "POLL_READ bit is 1":
        expect(_POLL_READ).to_equal(1u32)

    it "POLL_WRITE bit is 4":
        expect(_POLL_WRITE).to_equal(4u32)

    it "POLL_HUP bit is 16":
        expect(_POLL_HUP).to_equal(16u32)

# ============================================================================
# Queue-notify syscall ID range
# ============================================================================

describe "SOSIX queue-notify syscall IDs 120-131":
    it "SYS_DATASET_CREATE is 120":
        expect(_SYS_DATASET_CREATE).to_equal(120u64)

    it "SYS_QUEUE_WAIT_SEND is 131":
        expect(_SYS_QUEUE_WAIT_SEND).to_equal(131u64)

    it "dataset syscalls are contiguous 120-124":
        val spread = _SYS_DATASET_CLOSE - _SYS_DATASET_CREATE
        expect(spread).to_equal(4u64)

    it "queue syscalls are contiguous 125-131":
        val spread = _SYS_QUEUE_WAIT_SEND - _SYS_QUEUE_CREATE
        expect(spread).to_equal(6u64)
