use std.common.crypto.x25519.{x25519, x25519_pubkey}

fn hexb(b: [u8]) -> text:
    val digits = "0123456789abcdef"
    var s = ""
    var i: i64 = 0
    while i < b.len():
        val v = b[i].to_i64()
        s = s + digits.char_at(v / 16) + digits.char_at(v % 16)
        i = i + 1
    s

fn main():
    val alice: [u8] = [0x77u8,0x07u8,0x6du8,0x0au8,0x73u8,0x18u8,0xa5u8,0x7du8,
                       0x3cu8,0x16u8,0xc1u8,0x72u8,0x51u8,0xb2u8,0x66u8,0x45u8,
                       0xdfu8,0x4cu8,0x2fu8,0x87u8,0xebu8,0xc0u8,0x99u8,0x2au8,
                       0xb1u8,0x77u8,0xfbu8,0xa5u8,0x1du8,0xb9u8,0x2cu8,0x2au8]
    val bobpub: [u8] = [0xdeu8,0x9eu8,0xdbu8,0x7du8,0x7bu8,0x7du8,0xc1u8,0xb4u8,
                        0xd3u8,0x5bu8,0x61u8,0xc2u8,0xecu8,0xe4u8,0x35u8,0x37u8,
                        0x3fu8,0x83u8,0x43u8,0xc8u8,0x5bu8,0x78u8,0x67u8,0x4du8,
                        0xadu8,0xfcu8,0x7eu8,0x14u8,0x6fu8,0x88u8,0x2bu8,0x4fu8]
    val pk = x25519_pubkey(alice)
    print("pub    =" + hexb(pk))
    print("expect =8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a")
    val sh = x25519(alice, bobpub)
    print("shared =" + hexb(sh))
    print("expect =4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742")
