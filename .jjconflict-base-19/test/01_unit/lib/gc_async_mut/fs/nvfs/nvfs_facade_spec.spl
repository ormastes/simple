use std.spec
use std.gc_async_mut.fs.nvfs.extent_map.{ExtentMapEntry}
use std.gc_async_mut.fs.nvfs.superblock_if.{SuperblockHeader}
use std.gc_async_mut.fs.nvfs.api.{ArenaHandle}

describe "gc_async_mut fs nvfs facade":

    it "re-exports NVFS extent, superblock, and arena contract records":
        val handle = ArenaHandle(id: 7)
        expect(handle.id).to_equal(7)
        val extent = ExtentMapEntry(logical_off: 0, arena_id: handle.id, phys_off: 4096, length: 8192, generation: 3)
        expect(extent.arena_id).to_equal(7)
        expect(extent.length).to_equal(8192)
        val header = SuperblockHeader(
            magic: 0x4e564653,
            version_major: 1,
            version_minor: 0,
            fs_uuid_lo: 11,
            fs_uuid_hi: 22,
            checkpoint_gen: 5,
            created_unix_ns: 123456
        )
        expect(header.version_major).to_equal(1)
        expect(header.checkpoint_gen).to_equal(5)
