# @cover src/lib/nogc_sync_mut/qemu/qmp_client.spl 60%
# @tag: qemu, qmp, screendump
#
# QMP Client Screendump Extension Specification
#
# Verifies the new qmp_screendump() function added to the existing QMP client
# module. This enables framebuffer capture from a running QEMU VM for the
# pixel consistency pipeline.

use std.spec.{describe, context, it, expect}
use std.nogc_sync_mut.qemu.qmp_client.{QmpClient, qmp_screendump}

# ============================================================================
# Test Group 1: qmp_screendump Function (AC-3)
# ============================================================================

describe "QmpClient — qmp_screendump":

    context "invalid connection":

        it "AC-3: screendump with non-existent socket returns false":
            val client = QmpClient(socket_path: "/nonexistent/qmp.sock")
            val result = qmp_screendump(client, "/tmp/test_screendump.png", "png")
            expect(result).to_equal(false)

        it "AC-3: screendump with empty socket path returns false":
            val client = QmpClient(socket_path: "")
            val result = qmp_screendump(client, "/tmp/test_screendump.png", "png")
            expect(result).to_equal(false)

    context "format parameter":

        it "AC-3: screendump accepts 'png' format":
            val client = QmpClient(socket_path: "/nonexistent/qmp.sock")
            val result = qmp_screendump(client, "/tmp/test.png", "png")
            # Will fail due to missing socket, but format is accepted
            expect(result).to_equal(false)

        it "AC-3: screendump accepts 'ppm' format":
            val client = QmpClient(socket_path: "/nonexistent/qmp.sock")
            val result = qmp_screendump(client, "/tmp/test.ppm", "ppm")
            expect(result).to_equal(false)

    context "output path":

        it "AC-3: screendump with valid format but bad socket returns false":
            val client = QmpClient(socket_path: "/tmp/nonexistent_qmp_socket")
            val result = qmp_screendump(client, "/tmp/qemu_fb_capture.png", "png")
            expect(result).to_equal(false)
