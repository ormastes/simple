# # Search Unit Tests
#
# **Feature ID:** #APP-SEARCH-001
# **Category:** App | Search
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Text Search":
    it "exact match":
        val text = "hello world"
        check(text.contains("hello"))

    it "case sensitive match":
        val text = "Hello"
        check(text != "hello")

    it "case insensitive match":
        val text = "Hello"
        val lower = "hello"
        check(text.len() == lower.len())

    it "no match returns empty":
        val text = "hello"
        check(not text.contains("xyz"))

    it "match at start":
        val text = "hello world"
        check(text.starts_with("hello"))

    it "match at end":
        val text = "hello world"
        check(text.ends_with("world"))

describe "Pattern Search":
    it "wildcard pattern":
        val pattern = "*.spl"
        check(pattern.contains("*"))

    it "recursive pattern":
        val pattern = "**/*.spl"
        check(pattern.contains("**"))

    it "directory filter":
        val dir = "src/"
        check(dir.ends_with("/"))

    it "extension filter":
        val ext = ".spl"
        check(ext.starts_with("."))

describe "Symbol Search":
    it "find function by name":
        val query = "fn main"
        check(query.starts_with("fn"))

    it "find class by name":
        val query = "class Point"
        check(query.starts_with("class"))

    it "find trait by name":
        val query = "trait Display"
        check(query.starts_with("trait"))

    it "find enum by name":
        val query = "enum Color"
        check(query.starts_with("enum"))

describe "Search Results":
    it "result has file path":
        val path = "src/main.spl"
        check(path.ends_with(".spl"))

    it "result has line number":
        val line = 42
        check(line > 0)

    it "result has column number":
        val col = 10
        check(col > 0)

    it "result has context":
        val context = "fn main():"
        check(context.len() > 0)

    it "results are sorted by relevance":
        val scores = [100, 80, 60, 40]
        check(scores[0] > scores[1])
        check(scores[1] > scores[2])
