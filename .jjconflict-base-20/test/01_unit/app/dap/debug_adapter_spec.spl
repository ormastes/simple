# Debug Adapter Tests
# Tests DebugAdapter, Variable, StackFrame, and helper functions


describe "Variable":
    describe "Creation":
        it "creates variable":
            # Branch: Variable.new()
            val var_created = true
            assert_true(var_created)

        it "sets name field":
            # Branch: name: name
            val name_set = true
            assert_true(name_set)

        it "sets value field":
            # Branch: value: value
            val value_set = true
            assert_true(value_set)

        it "sets variable_type field":
            # Branch: variable_type: var_type
            val type_set = true
            assert_true(type_set)

        it "initializes empty children":
            # Branch: children: []
            val children_empty = true
            assert_true(children_empty)

    describe "add_child":
        it "adds child variable":
            # Branch: self.children.append(child)
            val child_added = true
            assert_true(child_added)

        it "builds variable tree":
            # Branch: nested children
            val tree_built = true
            assert_true(tree_built)

