"""
QEMU Systest Contract — Pure Classifier Unit Tests.

**Feature IDs:** #QEMU-SYSTEST-MULTIARCH-AC1
**Category:** OS system test infrastructure

Verifies classify_serial logic with no QEMU needed.
Tests all four classification outcomes:
  pass, boot-fail:fallback, boot-fail:<marker>, missing-media is not tested
  here (that requires file system — tested in system specs).
"""
use std.spec.*
use os.qemu_systest_contract.{
    classify_serial,
    SYSTEST_PASS,
    SYSTEST_BOOT_FAIL_FALLBACK,
    riscv64_markers,
    x86_32_markers
}

fn _clean_serial() -> text:
    "ELF_LOAD_OK\nSMF_CLI_LAUNCH_OK\nSMF_WM_GUI_LAUNCH_OK\nNATIVE_GUI_PROCESS_RENDER_OK\nTEST PASSED\n"

fn _fallback_serial_resident_active() -> text:
    "ELF_LOAD_OK\nSMF_CLI_LAUNCH_OK\n[desktop-e2e] resident-fallback:active\nTEST PASSED\n"

fn _fallback_serial_launcher() -> text:
    "ELF_LOAD_OK\n[launcher] fallback=resident-manifest\nSMF_WM_GUI_LAUNCH_OK\nTEST PASSED\n"

fn _missing_marker_serial() -> text:
    "ELF_LOAD_OK\nSMF_CLI_LAUNCH_OK\nSMF_WM_GUI_LAUNCH_OK\n"

fn _x86_32_clean_serial() -> text:
    "[x86_32 fs] initrd fat32 ok\n[x86_32 fs] hello_world smf ok\n[x86_32 fs] browser smf ok\n[x86_32 fs] x86_32 payload ok\n[x86_32 fs] app execution ok\n"

fn _x86_32_partial_serial() -> text:
    "[x86_32 fs] initrd fat32 ok\n[x86_32 fs] hello_world smf ok\n"

# ---------------------------------------------------------------------------
# classify_serial — pass cases
# ---------------------------------------------------------------------------

describe "classify_serial — pass":

    it "returns pass when all riscv64 markers present and no fallback":
        val markers = riscv64_markers()
        val result = classify_serial(_clean_serial(), markers)
        expect(result).to_equal(SYSTEST_PASS)

    it "returns pass when all x86_32 markers present and no fallback":
        val markers = x86_32_markers()
        val result = classify_serial(_x86_32_clean_serial(), markers)
        expect(result).to_equal(SYSTEST_PASS)

    it "returns pass for minimal one-marker list when marker present":
        val markers = ["ELF_LOAD_OK"]
        val result = classify_serial("ELF_LOAD_OK\nTEST PASSED\n", markers)
        expect(result).to_equal(SYSTEST_PASS)

# ---------------------------------------------------------------------------
# classify_serial — fallback detection
# ---------------------------------------------------------------------------

describe "classify_serial — fallback":

    it "returns boot-fail:fallback when resident-fallback:active pattern present":
        val markers = riscv64_markers()
        val result = classify_serial(_fallback_serial_resident_active(), markers)
        expect(result).to_equal(SYSTEST_BOOT_FAIL_FALLBACK)

    it "returns boot-fail:fallback when launcher fallback=resident-manifest present":
        val markers = riscv64_markers()
        val result = classify_serial(_fallback_serial_launcher(), markers)
        expect(result).to_equal(SYSTEST_BOOT_FAIL_FALLBACK)

    it "fallback check precedes marker check":
        # serial has fallback pattern but also missing markers
        val markers = riscv64_markers()
        val serial = "[desktop-e2e] resident-fallback:active\nELF_LOAD_OK\n"
        val result = classify_serial(serial, markers)
        expect(result).to_equal(SYSTEST_BOOT_FAIL_FALLBACK)

# ---------------------------------------------------------------------------
# classify_serial — missing marker
# ---------------------------------------------------------------------------

describe "classify_serial — missing marker":

    it "returns boot-fail:<marker> for first missing riscv64 marker":
        val markers = riscv64_markers()
        val result = classify_serial(_missing_marker_serial(), markers)
        expect(result).to_equal("boot-fail:NATIVE_GUI_PROCESS_RENDER_OK")

    it "returns boot-fail:<marker> for first missing x86_32 marker":
        val markers = x86_32_markers()
        val result = classify_serial(_x86_32_partial_serial(), markers)
        expect(result).to_equal("boot-fail:[x86_32 fs] browser smf ok")

    it "returns boot-fail:<marker> when no markers present":
        val markers = ["MARKER_A", "MARKER_B"]
        val result = classify_serial("", markers)
        expect(result).to_equal("boot-fail:MARKER_A")

    it "returns boot-fail:<marker> for empty serial with riscv64 markers":
        val markers = riscv64_markers()
        val result = classify_serial("", markers)
        expect(result).to_equal("boot-fail:ELF_LOAD_OK")

# ---------------------------------------------------------------------------
# classify_serial — edge cases
# ---------------------------------------------------------------------------

describe "classify_serial — edge cases":

    it "empty marker list with clean serial returns pass":
        val markers: [text] = []
        val result = classify_serial(_clean_serial(), markers)
        expect(result).to_equal(SYSTEST_PASS)

    it "empty marker list with fallback serial returns boot-fail:fallback":
        val markers: [text] = []
        val result = classify_serial(_fallback_serial_resident_active(), markers)
        expect(result).to_equal(SYSTEST_BOOT_FAIL_FALLBACK)

    it "partial marker match returns fail for first missing":
        val markers = ["A", "B", "C"]
        val result = classify_serial("A\nB\n", markers)
        expect(result).to_equal("boot-fail:C")
