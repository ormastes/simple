# Unit: Ns
# Kind: Time
# Symbol: ns
# Canonical scale: 1e-09 s

class Ns:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ns) -> Ns: Ns(value: self.value + other.value)
    fn sub(other: Ns) -> Ns: Ns(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "ns"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "s"
    static fn zero() -> Ns: Ns(value: 0.0)

export Ns
