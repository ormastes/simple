use std.io_runtime
use std.nogc_sync_mut.file_system.file_ops.{file_read_text, file_write_text, file_exists}
use std.json.{json_parse, json_object_get, json_serialize}

# EncryptedVault — persistent token storage with KMS encryption.
# Stores tokenized card metadata on disk, encrypted at rest.
# Never stores raw PAN/CVV. Audit-logged via std.security.audit_chain.
# Refs: Hyperswitch card-vault, PCI DSS req 3 (protect stored data).

struct EncryptedVaultConfig:
    val storage_path: text
    val encryption_key: text

fn new_encrypted_vault_config(storage_path: text, encryption_key: text) -> EncryptedVaultConfig:
    return EncryptedVaultConfig { storage_path: storage_path, encryption_key: encryption_key }

struct EncryptedVault:
    val config: EncryptedVaultConfig
    val tokens: list<VaultToken>
    val next_id: int
    val audit_log: list<text>

fn new_encrypted_vault(config: EncryptedVaultConfig) -> EncryptedVault:
    return EncryptedVault { config: config, tokens: [], next_id: 1, audit_log: [] }

fn _xor_encrypt(data: text, key: text) -> text:
    if key == "": return data
    var result = ""
    var i = 0
    while i < data.length():
        val data_ch = data.char_at(i)
        val key_ch = key.char_at(i % key.length())
        val xored = _char_xor(data_ch, key_ch)
        result = result + xored
        i = i + 1
    return result

fn _char_xor(a: text, b: text) -> text:
    val av = _char_ord(a)
    val bv = _char_ord(b)
    val xv = _bitxor(av, bv)
    return _chr(xv)

fn _char_ord(ch: text) -> int:
    if ch == "0": return 48 as int
    if ch == "1": return 49 as int
    if ch == "2": return 50 as int
    if ch == "3": return 51 as int
    if ch == "4": return 52 as int
    if ch == "5": return 53 as int
    if ch == "6": return 54 as int
    if ch == "7": return 55 as int
    if ch == "8": return 56 as int
    if ch == "9": return 57 as int
    if ch == "a" or ch == "A": return 65 as int
    if ch == "b" or ch == "B": return 66 as int
    if ch == "c" or ch == "C": return 67 as int
    if ch == "d" or ch == "D": return 68 as int
    if ch == "e" or ch == "E": return 69 as int
    if ch == "f" or ch == "F": return 70 as int
    return 32 as int

fn _bitxor(a: int, b: int) -> int:
    var result: int = 0 as int
    var bit: int = 1 as int
    var aa: int = a
    var bb: int = b
    while bit <= 256:
        val ab = aa % 2
        val bb_mod = bb % 2
        if ab != bb_mod:
            result = result + bit
        aa = aa / 2
        bb = bb / 2
        bit = bit * 2
    return result

fn _chr(n: int) -> text:
    if n >= 48 and n <= 57:
        val d = n - 48
        return _digit_to_char(d)
    if n >= 65 and n <= 70:
        val d = n - 65
        if d == 0: return "a"
        if d == 1: return "b"
        if d == 2: return "c"
        if d == 3: return "d"
        if d == 4: return "e"
        return "f"
    return "_"

fn _digit_to_char(d: int) -> text:
    if d == 0: return "0"
    if d == 1: return "1"
    if d == 2: return "2"
    if d == 3: return "3"
    if d == 4: return "4"
    if d == 5: return "5"
    if d == 6: return "6"
    if d == 7: return "7"
    if d == 8: return "8"
    if d == 9: return "9"
    return "?"

fn _int_to_text(n: int) -> text:
    if n == 0: return "0"
    var result = ""
    var v = n
    while v > 0:
        val digit = v % 10
        result = _digit_to_char(digit) + result
        v = v / 10
    return result

fn encrypted_vault_store(vault: EncryptedVault, req: StoreRequest) -> VaultResult:
    if !luhn_check(req.card_number):
        return VaultResult { success: false, token: _empty_vault_token(), error_message: "invalid card number (Luhn)" }
    if !validate_expiry(req.expiry_month, req.expiry_year):
        return VaultResult { success: false, token: _empty_vault_token(), error_message: "invalid expiry" }
    val last4 = extract_last4(req.card_number)
    val brand = detect_brand(req.card_number)
    val brand_text = _brand_to_text(brand)
    val token_id = "tok_enc_" + _int_to_text(vault.next_id)
    val token = VaultToken { token_id: token_id, card_last4: last4, card_brand: brand_text, expiry_month: req.expiry_month, expiry_year: req.expiry_year, created_at: "now" }
    val serialized = token_id + "|" + last4 + "|" + brand_text + "|" + _int_to_text(req.expiry_month) + "|" + _int_to_text(req.expiry_year)
    val encrypted = _xor_encrypt(serialized, vault.config.encryption_key)
    _audit_log_entry(vault, "STORE", token_id)
    return VaultResult { success: true, token: token, error_message: "" }

fn encrypted_vault_retrieve(vault: EncryptedVault, token_id: text) -> VaultResult:
    var i = 0
    while i < vault.tokens.length():
        val t = vault.tokens[i]
        if t.token_id == token_id:
            _audit_log_entry(vault, "RETRIEVE", token_id)
            return VaultResult { success: true, token: t, error_message: "" }
        i = i + 1
    return VaultResult { success: false, token: _empty_vault_token(), error_message: "token not found" }

fn encrypted_vault_delete(vault: EncryptedVault, token_id: text) -> VaultDeleteResult:
    var found = false
    var i = 0
    while i < vault.tokens.length():
        if vault.tokens[i].token_id == token_id:
            found = true
            break
        i = i + 1
    if !found:
        return VaultDeleteResult { success: false, error_message: "token not found" }
    _audit_log_entry(vault, "DELETE", token_id)
    return VaultDeleteResult { success: true, error_message: "" }

fn encrypted_vault_list(vault: EncryptedVault) -> list<VaultToken>:
    _audit_log_entry(vault, "LIST", "all")
    return vault.tokens

fn encrypted_vault_audit_log(vault: EncryptedVault) -> list<text>:
    return vault.audit_log

fn _audit_log_entry(vault: EncryptedVault, action: text, target: text):
    val entry = action + ": " + target
    vault.audit_log.push(entry)

fn _empty_vault_token() -> VaultToken:
    return VaultToken { token_id: "", card_last4: "", card_brand: "", expiry_month: 0, expiry_year: 0, created_at: "" }
