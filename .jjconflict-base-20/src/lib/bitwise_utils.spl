# Byte and bit-slice helpers — B4 acceptance contract.
#
# Provides std.bitwise_utils.{get_byte, set_byte, extract_bits, insert_bits}.
# These are pure arithmetic wrappers; no externs, no allocations.

# Returns the byte at position `pos` (0 = least-significant byte).
fn get_byte(n: i64, pos: i64) -> i64:
    if pos < 0 or pos > 7:
        return 0
    (n >> (pos * 8)) & 0xff

# Writes `val_byte` into byte position `pos`, clearing the existing byte.
fn set_byte(n: i64, pos: i64, val_byte: i64) -> i64:
    if pos < 0 or pos > 7:
        return n
    val mask = 0xff << (pos * 8)
    (n & (mask ^ -1)) | ((val_byte & 0xff) << (pos * 8))

# Extracts `width` bits starting at bit `lo`.
fn extract_bits(n: i64, lo: i64, width: i64) -> i64:
    if lo < 0 or lo > 63 or width < 1 or width > 64 or lo + width > 64:
        return 0
    if lo == 0 and width == 64:
        return n
    val mask = (1 << width) - 1
    (n >> lo) & mask

# Inserts `width` bits of `v` starting at bit `lo` in `n`.
fn insert_bits(n: i64, v: i64, lo: i64, width: i64) -> i64:
    if lo < 0 or lo > 63 or width < 1 or width > 64 or lo + width > 64:
        return n
    if lo == 0 and width == 64:
        return v
    val mask = ((1 << width) - 1) << lo
    (n & (mask ^ -1)) | ((v << lo) & mask)
