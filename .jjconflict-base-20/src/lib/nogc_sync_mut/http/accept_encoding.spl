# HTTP Accept-Encoding parsing and codec negotiation (RFC 7231 §5.3.4).
#
# Parses an `Accept-Encoding` request header into (codec, q-value) pairs and
# selects the best server-supported codec for a response. Identity ("") is
# always allowed unless explicitly forbidden by `identity;q=0` or `*;q=0`.
#
# This module is a pure helper — it does not perform compression itself. The
# server response path uses the negotiated codec name to dispatch into the
# compress façade or the gzip module.

# Parsed entry from an Accept-Encoding list.
class AcceptEncodingEntry:
    coding: text   # lowercased token: "gzip", "br", "zstd", "deflate", "identity", "*", or unknown
    q: i64         # quality * 1000; 0..1000. 1000 = q=1.0, 0 = forbidden.

# Parse an Accept-Encoding header value into a list of entries.
#
# - Tokens are lowercased.
# - Default q is 1000 (q=1.0).
# - Bad q-values clamp to 0..1000.
# - Empty header returns [].
# - Whitespace around commas, equals, and tokens is tolerated.
fn parse_accept_encoding(header_value: text) -> [AcceptEncodingEntry]:
    var entries: [AcceptEncodingEntry] = []
    val trimmed = header_value.trim()
    if trimmed.len() == 0:
        return entries

    val parts = trimmed.split(",")
    for raw_part in parts:
        val part = raw_part.trim()
        if part.len() == 0:
            continue
        val semi = part.index_of(";")
        var coding_text: text = ""
        var q_value: i64 = 1000
        if semi.? and semi >= 0:
            coding_text = part.slice(0, semi).trim().lower()
            val params = part.slice(semi + 1, part.len())
            q_value = _extract_q(params)
        else:
            coding_text = part.lower()
        if coding_text.len() == 0:
            continue
        entries.push(AcceptEncodingEntry(coding: coding_text, q: q_value))
    entries

# Pick the highest-quality codec from `accept_header` that the server supports.
#
# `supported` is an ordered list of server-preferred codec names (lowercase),
# e.g. `["zstd", "gzip"]`. Returned value is one of those entries, or "" for
# identity (no Content-Encoding).
#
# Rules (RFC 7231 §5.3.4):
# - Highest q wins. Ties broken by `supported` order (server preference).
# - q=0 forbids the coding.
# - Missing header is equivalent to "*" with q=1, so the first supported codec
#   is returned. Callers wanting strict identity-on-missing should check ""
#   before calling.
# - "identity;q=0" or "*;q=0" with no q>0 entry covering identity returns ""
#   only when identity is forbidden — but per RFC, identity-with-q=0 is
#   allowed to mean "anything but identity"; callers preferring strict
#   compliance must inspect the parsed entries directly.
fn negotiate_encoding(accept_header: text, supported: [text]) -> text:
    if accept_header.trim().len() == 0:
        # No header: server may use identity. Returning "" preserves caller
        # control (server can default to its preferred codec if it wants).
        return ""

    val entries = parse_accept_encoding(accept_header)
    val star_q = _q_for(entries, "*")
    var best_name: text = ""
    var best_q: i64 = -1

    var pref_index: i64 = 0
    for codec in supported:
        val codec_lower = codec.lower()
        var q = _q_for(entries, codec_lower)
        if q < 0:
            # Codec not listed explicitly; fall back to "*" if present.
            if star_q >= 0:
                q = star_q
            else:
                q = -1
        if q > 0 and q > best_q:
            best_q = q
            best_name = codec_lower
        pref_index = pref_index + 1
    best_name

# ----------------------------------------------------------------------------
# Internal helpers
# ----------------------------------------------------------------------------

# Look up the q-value for a coding. Returns -1 if absent.
fn _q_for(entries: [AcceptEncodingEntry], coding: text) -> i64:
    for entry in entries:
        if entry.coding == coding:
            return entry.q
    -1

# Extract q=N.NNN from the params segment after the ';'. Returns q*1000 in
# 0..1000. Defaults to 1000 if no q parameter is present. Malformed q clamps
# to 0..1000.
fn _extract_q(params: text) -> i64:
    val parts = params.split(";")
    for raw in parts:
        val seg = raw.trim()
        val eq = seg.index_of("=")
        if eq.? and eq > 0:
            val name = seg.slice(0, eq).trim().lower()
            if name == "q":
                val raw_value = seg.slice(eq + 1, seg.len()).trim()
                return _parse_q_value(raw_value)
    1000

# Parse "1", "1.0", "0", "0.5", "0.123" into an integer q*1000 clamped to
# [0, 1000]. Anything unparseable returns 0.
fn _parse_q_value(s: text) -> i64:
    if s.len() == 0:
        return 0
    val dot = s.index_of(".")
    var int_part: text = ""
    var frac_part: text = ""
    if dot.? and dot >= 0:
        int_part = s.slice(0, dot)
        frac_part = s.slice(dot + 1, s.len())
    else:
        int_part = s
    val int_v = _digits_to_i64(int_part)
    if int_v < 0:
        return 0
    if int_v >= 1:
        return 1000
    # int_v is 0; frac contributes up to 3 digits worth of millis.
    var millis: i64 = 0
    var i: i64 = 0
    var place: i64 = 100
    while i < frac_part.len() and i < 3:
        val ch = frac_part.char_at(i)
        if ch < "0" or ch > "9":
            return 0
        val d = _digit_value(ch)
        millis = millis + d * place
        place = place / 10
        i = i + 1
    if millis < 0:
        return 0
    if millis > 1000:
        return 1000
    millis

fn _digits_to_i64(s: text) -> i64:
    if s.len() == 0:
        return -1
    var n: i64 = 0
    var i: i64 = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch < "0" or ch > "9":
            return -1
        n = n * 10 + _digit_value(ch)
        i = i + 1
    n

fn _digit_value(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    0
