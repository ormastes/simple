# Lightweight Embedded HTTP Server
#
# Sync, pure-Simple HTTP server for embedding in any application.
# Provides request parsing, response building, routing, and a
# threaded accept loop on top of std.nogc_sync_mut.io.tcp.
#
# Usage:
#   use std.nogc_sync_mut.http_server.{SimpleHttpServer, HttpRequest, HttpResponse, Router}
#
# Full standalone example: examples/06_io/simple_web_server/
# Async full-featured alternative: std.nogc_async_mut.http_server
# Design: doc/05_design/simple_web_server_lib_api.md

use std.nogc_sync_mut.http_server.types.{
    HttpMethod,
    HttpStatus,
    HttpRequest,
    HttpResponse,
    http_method_from_text,
    http_method_to_text,
    http_status_code,
    http_status_reason,
    http_status_from_code
}

use std.nogc_sync_mut.http_server.parser.{
    parse_request, parse_request_with_limits, parse_request_line,
    to_i32_safe, content_length_from_text, headers_decision,
    MAX_REQUEST_LINE, MAX_HEADER_COUNT, MAX_HEADER_LINE, MAX_BODY_SIZE
}

use std.nogc_sync_mut.http_server.response.{
    write_response,
    write_error
}

use std.nogc_sync_mut.http_server.router.{
    Router,
    Route,
    path_is_safe
}

use std.nogc_sync_mut.http_server.server.{
    SimpleHttpServer
}
