# VirtIO-GPU 2D Command Types and Structures
#
# MDSOC: feature dimension, drivers layer
# VirtIO-GPU protocol uses request/response pairs sent via controlq.
# Each request starts with a VirtioGpuCtrlHdr (24 bytes).
#
# Reference: VirtIO specification v1.1, section 5.7

# ============================================================================
# Command Types — 2D commands
# ============================================================================

val VIRTIO_GPU_CMD_GET_DISPLAY_INFO: u32 = 0x0100
val VIRTIO_GPU_CMD_RESOURCE_CREATE_2D: u32 = 0x0101
val VIRTIO_GPU_CMD_RESOURCE_UNREF: u32 = 0x0102
val VIRTIO_GPU_CMD_SET_SCANOUT: u32 = 0x0103
val VIRTIO_GPU_CMD_RESOURCE_FLUSH: u32 = 0x0104
val VIRTIO_GPU_CMD_TRANSFER_TO_HOST_2D: u32 = 0x0105
val VIRTIO_GPU_CMD_RESOURCE_ATTACH_BACKING: u32 = 0x0106
val VIRTIO_GPU_CMD_RESOURCE_DETACH_BACKING: u32 = 0x0107

# ============================================================================
# Command Types — Cursor commands
# ============================================================================

val VIRTIO_GPU_CMD_UPDATE_CURSOR: u32 = 0x0300
val VIRTIO_GPU_CMD_MOVE_CURSOR: u32 = 0x0301

# ============================================================================
# Response Types
# ============================================================================

val VIRTIO_GPU_RESP_OK_NODATA: u32 = 0x1100
val VIRTIO_GPU_RESP_OK_DISPLAY_INFO: u32 = 0x1101
val VIRTIO_GPU_RESP_ERR_UNSPEC: u32 = 0x1200
val VIRTIO_GPU_RESP_ERR_OUT_OF_MEMORY: u32 = 0x1201
val VIRTIO_GPU_RESP_ERR_INVALID_SCANOUT_ID: u32 = 0x1202
val VIRTIO_GPU_RESP_ERR_INVALID_RESOURCE_ID: u32 = 0x1203

# ============================================================================
# Pixel Formats
# ============================================================================

val VIRTIO_GPU_FORMAT_B8G8R8A8_UNORM: u32 = 1
val VIRTIO_GPU_FORMAT_B8G8R8X8_UNORM: u32 = 2
val VIRTIO_GPU_FORMAT_A8R8G8B8_UNORM: u32 = 3
val VIRTIO_GPU_FORMAT_X8R8G8B8_UNORM: u32 = 4
val VIRTIO_GPU_FORMAT_R8G8B8A8_UNORM: u32 = 67
val VIRTIO_GPU_FORMAT_X8B8G8R8_UNORM: u32 = 68
val VIRTIO_GPU_FORMAT_A8B8G8R8_UNORM: u32 = 121
val VIRTIO_GPU_FORMAT_R8G8B8X8_UNORM: u32 = 134

# ============================================================================
# Struct Sizes (for DMA buffer layout)
# ============================================================================
#
# VirtioGpuCtrlHdr:          24 bytes (type:u32, flags:u32, fence_id:u64, ctx_id:u32, padding:u32)
# VirtioGpuRect:             16 bytes (x:u32, y:u32, width:u32, height:u32)
# VirtioGpuMemEntry:         16 bytes (addr:u64, length:u32, padding:u32)

val CTRL_HDR_SIZE: u64 = 24
val RECT_SIZE: u64 = 16
val MEM_ENTRY_SIZE: u64 = 16

# GET_DISPLAY_INFO response: hdr(24) + 16 displays * (rect(16) + enabled:u32 + flags:u32) = 24 + 16*24 = 408
val DISPLAY_INFO_RESP_SIZE: u64 = 408

# RESOURCE_CREATE_2D: hdr(24) + resource_id(4) + format(4) + width(4) + height(4) = 40
val RESOURCE_CREATE_SIZE: u64 = 40

# SET_SCANOUT: hdr(24) + rect(16) + scanout_id(4) + resource_id(4) = 48
val SET_SCANOUT_SIZE: u64 = 48

# TRANSFER_TO_HOST_2D: hdr(24) + rect(16) + offset(8) + resource_id(4) + padding(4) = 56
val TRANSFER_SIZE: u64 = 56

# RESOURCE_ATTACH_BACKING: hdr(24) + resource_id(4) + nr_entries(4) = 32
# Followed by nr_entries * MEM_ENTRY (16 each)
val ATTACH_BACKING_HDR_SIZE: u64 = 32
val ATTACH_BACKING_TOTAL_SIZE: u64 = 48  # hdr(32) + 1 mem_entry(16)

# RESOURCE_FLUSH: hdr(24) + rect(16) + resource_id(4) + padding(4) = 48
val FLUSH_SIZE: u64 = 48

# RESOURCE_DETACH_BACKING: hdr(24) + resource_id(4) + padding(4) = 32
val DETACH_BACKING_SIZE: u64 = 32

# RESOURCE_UNREF: hdr(24) + resource_id(4) + padding(4) = 32
val RESOURCE_UNREF_SIZE: u64 = 32
