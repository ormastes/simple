# Traceability checker configuration
#
# Source/test enforcement is opt-in for existing code. Feature/system spec and
# documentation checks always run.

traceability:
  generated_spec_root: doc/spec
  legacy_requirement_root: doc/requirement

  # Enable source/test warning roots gradually as directories are normalized.
  # warn_source_root: src/compiler
  # warn_source_root: src/app
  # warn_source_root: src/lib
