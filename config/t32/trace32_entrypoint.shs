#!/usr/bin/env bash
set -eu

T32_CONFIG="${T32_CONFIG:-/workspace/config/t32/t32_stm_headless.t32}"
T32_BIN="/opt/t32/bin/pc_linux64"
DISPLAY="${DISPLAY:-:99}"
export DISPLAY HOME XAPPLRESDIR

# Start Xvfb in background
Xvfb :99 -screen 0 1280x1024x24 &
XVFB_PID=$!

# Wait for X display to be ready
for i in $(seq 1 20); do
    if xdpyinfo -display :99 >/dev/null 2>&1; then
        break
    fi
    sleep 0.25
done

if ! xdpyinfo -display :99 >/dev/null 2>&1; then
    echo "ERROR: Xvfb failed to start" >&2
    exit 1
fi

# Register T32 bitmap fonts
if [ -d /opt/t32/fonts ]; then
    xset +fp /opt/t32/fonts/ 2>/dev/null || true
    xset fp rehash 2>/dev/null || true
fi

# Try t32marm first, fall back to t32marm-qt
if [ -x "$T32_BIN/t32marm" ]; then
    "$T32_BIN/t32marm" -c "$T32_CONFIG" &
    T32_PID=$!
    # Give it a moment to see if it crashes immediately
    sleep 2
    if kill -0 "$T32_PID" 2>/dev/null; then
        wait "$T32_PID"
        exit $?
    fi
    echo "t32marm exited quickly, trying t32marm-qt..." >&2
fi

if [ -x "$T32_BIN/t32marm-qt" ]; then
    exec "$T32_BIN/t32marm-qt" -c "$T32_CONFIG"
fi

echo "ERROR: no working t32marm binary found" >&2
exit 1
