; Minimal RCL-only config — no PBI section
; Purpose: test whether t32marm can bind port 20000 without USB probe access
; This isolates X11/Xt startup failures from probe connectivity failures.
;
; Usage:
;   xvfb-run -a /opt/t32/bin/pc_linux64/t32marm -c config/t32/t32_rcl_only.t32

OS=
SYS=/opt/t32/bin/pc_linux64
TMP=/tmp

SCREEN=
INVISIBLE

RCL=
NETTCP
PORT=20000
