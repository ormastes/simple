#!/bin/sh
# Install platform-specific MCP configs for Claude Code and Codex CLI.
# Usage: sh config/mcp/install.shs

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

OS="$(uname -s)"

shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

case "$OS" in
    MINGW*|MSYS*|CYGWIN*|Windows_NT)
        SRC="$SCRIPT_DIR/win/.mcp.json"
        EXT=".cmd"
        ;;
    *)
        SRC="$SCRIPT_DIR/common/.mcp.json"
        EXT=""
        ;;
esac

# --- Claude Code (.mcp.json) ---
cp "$SRC" "$PROJECT_ROOT/.mcp.json"
echo "Installed .mcp.json for $OS"

# --- Codex CLI (global ~/.codex/config.toml) ---
if command -v codex >/dev/null 2>&1; then
    SERVERS="simple-mcp simple-lsp-mcp"
    for NAME in $SERVERS; do
        CMD="$PROJECT_ROOT/bin/${NAME}${EXT}"
        # Convert server name to wrapper name (simple-mcp -> simple_mcp_server)
        WRAPPER=$(echo "$NAME" | sed 's/-/_/g')_server
        CMD="$PROJECT_ROOT/bin/${WRAPPER}${EXT}"
        if [ -e "$CMD" ] || [ -L "$CMD" ]; then
            codex mcp remove "$NAME" 2>/dev/null || true
            LAUNCH="cd $(shell_quote "$PROJECT_ROOT") && exec $(shell_quote "$CMD")"
            codex mcp add "$NAME" --env SIMPLE_LOG=error --env RUST_LOG=error --env SIMPLE_LIB="$PROJECT_ROOT/src" -- /bin/sh -lc "$LAUNCH"
        else
            echo "Warning: $CMD not found, skipping $NAME"
        fi
    done
    # Retire old optional browser MCP registrations that are no longer part of
    # the default Codex setup.
    codex mcp remove "chrome-devtools" 2>/dev/null || true
    if command -v node >/dev/null 2>&1; then
        STITCH_CMD="$PROJECT_ROOT/bin/codex_stitch_mcp.js"
        if [ -f "$STITCH_CMD" ]; then
            codex mcp remove "stitch-mcp" 2>/dev/null || true
            codex mcp remove "stitch" 2>/dev/null || true
            codex mcp add "stitch" -- node "$STITCH_CMD"
        else
            echo "Warning: $STITCH_CMD not found, skipping stitch"
        fi
    else
        echo "Warning: node not found, skipping stitch"
    fi
    echo "Installed Codex MCP servers for $OS"
else
    echo "Codex CLI not found, skipping Codex MCP setup"
fi
