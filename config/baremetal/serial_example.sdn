# Baremetal Host Communication - Serial/UART Example
# Connect to a baremetal device via serial port.

connection:
    transport: serial
    timeout_ms: 5000

serial:
    port: /dev/ttyUSB0
    baud_rate: 115200
    data_bits: 8
    stop_bits: 1
    parity: none

options:
    echo_commands: true
    line_ending: "\r\n"
