# The Simple RV64 Linux product implements integer IMA only.
# NONPORTABLE disables the generic PORTABLE profile, whose EFI selection
# otherwise forces compressed instructions back into the kernel.
CONFIG_NONPORTABLE=y
# CONFIG_RISCV_ISA_C is not set
# CONFIG_RISCV_ISA_V is not set
# CONFIG_FPU is not set
# CONFIG_EFI is not set
# CONFIG_RISCV_ISA_VENDOR_EXT is not set
# CONFIG_RISCV_ISA_VENDOR_EXT_ANDES is not set
# CONFIG_RISCV_ISA_VENDOR_EXT_MIPS is not set
# CONFIG_RISCV_ISA_VENDOR_EXT_SIFIVE is not set
# CONFIG_RISCV_ISA_VENDOR_EXT_THEAD is not set
