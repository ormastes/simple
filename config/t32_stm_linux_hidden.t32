; TRACE32 hidden Linux config for STM32 via Power Debug II USB
; Shared by both native and GDB bridge lanes
; Enables Remote API on port 20000 for t32rem / automation
; Requires: Xvfb, PCF bitmap fonts enabled, udev rules installed

OS=
SYS=/opt/t32/bin/pc_linux64
TMP=/tmp

PBI=
USB

SCREEN=
INVISIBLE

RCL=
NETTCP
PORT=20000
