# VHDL Simulation Environment
# Configures the test runner to use VHDL simulation for hardware tests.

environment:
    name: vhdl-sim
    description: "VHDL simulation via GHDL or ModelSim"

runner:
    type: vhdl_sim
    config_path: config/baremetal/ghdl_example.sdn

tags:
    include: [vhdl]
    exclude: []

timeouts:
    default_ms: 30000
    slow_ms: 120000

paths:
    work_dir: build/vhdl
    output_dir: build/vhdl/output
    waveform_dir: build/vhdl/waves
