# Simple Test Configuration
# Configure test execution and coverage requirements
# SDN (Simple Data Notation) format

test:
  # Test directories
  unit_dir: test/unit
  integration_dir: test/integration
  system_dir: test/system

  # Coverage requirements by test type
  unit_coverage: branch           # branch/condition coverage for unit tests
  integration_coverage: function  # public function touch for integration tests
  system_coverage: method         # class/struct method coverage for system tests

  # Coverage thresholds (percentage)
  unit_threshold: 90.0
  integration_threshold: 100.0  # 100% of public API must be tested
  system_threshold: 100.0       # 100% of class/struct methods

  # Test execution
  parallel: false          # Default: single-threaded (use --parallel or -p to enable parallel)
  max_threads: 0           # 0 = auto (use all available cores when parallel=true)
  fail_fast: false         # Continue after first failure
  timeout: 120             # Default timeout in seconds per test
  slow_timeout: 600        # Timeout for slow tests (10 minutes)

  # Resource-aware throttling (for shared servers with multiple users)
  cpu_throttle:
    enabled: true            # Enable resource-aware thread throttling
    threshold: 70            # CPU usage % threshold to trigger throttling (0-100)
    memory_threshold: 70     # Memory usage % threshold to trigger throttling (0-100)
    throttled_threads: 1     # Number of threads when throttled
    check_interval: 5        # Seconds between resource checks during test run

  # Output
  default_format: progress  # progress, doc, json
  show_colors: true
  verbose: false

  # Filtering
  exclude_tags: []        # Tags to exclude by default
  include_tags: []        # Tags to include (empty = all)
  run_slow_tests: false   # Skip slow tests by default

  # Test modes - what runs with plain `bin/simple test`
  run_spec_tests: true    # Run .spl spec files (SPipe/it/describe tests)
  run_sdoctests: true     # Run documentation tests from docstrings
  run_spl_doctests: false  # Run doctests from .spl source file /// comments (opt-in)

  # CI mode overrides (activated by --ci flag or CI=true env var)
  # When CI mode is active:
  #   - run_slow_tests: true  (includes long-running tests)
  #   - fail_fast: false      (continue after failures)
  #   - verbose: true         (detailed output)

  # Session sharing — opt-in reuse of long-lived test environments
  session_share: false          # Enable session sharing (--session-share)
  session_daemon: false         # Route session tests through daemon (--session-daemon)
  session_idle_timeout_ms: 300000   # 5 minutes idle before cleanup
  session_startup_timeout_ms: 60000 # 1 minute max to start a session
  session_debug: false          # Print session routing debug info
  session_max_sessions:
    qemu_vm: 4
    container_instance: 2
    service_process: 8
    openocd_board: 1
    trace32_board: 1
    simulator_process: 2
  session_defaults:
    qemu_vm:
      reuse: shared_with_snapshot
      reset: snapshot_restore
    container_instance:
      reuse: exclusive_reused
      reset: recreate
    service_process:
      reuse: shared_read_only
      reset: none

coverage:
  # Coverage reporting
  enabled: true
  output_dir: coverage
  generate_html: true
  generate_json: true
  export_codecov: false
  export_coveralls: false

  # Coverage calculation
  public_only: true       # Only track public functions/methods
  include_private: false  # Include private in coverage

  # HTML report options
  html_title: Simple Test Coverage
  html_with_source: false  # Include source code in HTML

rtos:
  # Realtime OS test configuration (--profile=fast|session|fuzz|verify)
  default_profile: fast

  # Profile presets (overridable per-test via @rtos_config annotation)
  profiles:
    fast:
      replay: off
      session_mode: reset
      timeout_ms: 5000
      fuzz_enabled: false
    session:
      replay: record
      session_mode: checkpoint
      timeout_ms: 10000
      checkpoint_id: 1
      fuzz_enabled: false
    fuzz:
      replay: chaos
      session_mode: checkpoint
      timeout_ms: 60000
      fuzz_enabled: true
      fuzz_iterations: 100
      fuzz_seed: 42
    verify:
      replay: verify
      session_mode: checkpoint
      timeout_ms: 10000
      fuzz_enabled: false

  # JTAG probe configuration
  jtag:
    default_probe: openocd          # openocd | trace32
    openocd:
      host: localhost
      port: 6666
      gdb_port: 3333
    trace32:
      host: localhost
      port: 20000
      # Hang recovery
      ping_timeout_ms: 3000         # Max wait for T32_Ping response
      operation_timeout_ms: 10000   # Max wait for any T32 operation
      max_retries: 3                # Retry count before disconnect/reconnect
      auto_reconnect: true          # Auto-reconnect after hang detected
      kill_on_hang: false           # Kill T32 process if unrecoverable

  # Architecture defaults for QEMU-based RTOS tests
  qemu:
    arm:
      machine: lm3s6965evb
      cpu: cortex-m3
    riscv32:
      machine: virt
      cpu: rv32
    x86_64:
      machine: q35
      cpu: qemu64

reports:
  # Test result reports
  output_dir: test-results
  json_output: test-results/results.json
  html_output: test-results/results.html
  junit_output: test-results/junit.xml  # For CI integration
