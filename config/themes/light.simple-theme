/*
@stitch.display_name: Celestial Ether (Light)
@stitch.color_mode: LIGHT
@stitch.roundness: ROUND_EIGHT
*/

:root {
  /* Core UI Variables */
  --ui-bg: #F0ECF5;
  --ui-fg: #1D1D1F;
  --ui-accent: #7C69A3;
  --ui-border-radius: 8px;

  /* Glassmorphism Variables */
  --glass-surface: rgba(255, 255, 255, 0.78);
  --glass-blur: 20px;
  --glass-border: rgba(74, 69, 77, 0.15);
}
