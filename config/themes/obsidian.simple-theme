/*
@stitch.display_name: SimpleOS Obsidian
@stitch.color_mode: DARK
@stitch.roundness: ROUND_EIGHT
*/

:root {
  /* Core UI Variables */
  --ui-bg: #12121f;
  --ui-fg: #e3e0f3;
  --ui-accent: #c6c6c8;
  --ui-border-radius: 8px;

  /* Glassmorphism Variables */
  --glass-surface: rgba(18, 18, 31, 0.72);
  --glass-blur: 20px;
  --glass-border: rgba(149, 142, 152, 0.15);
}
