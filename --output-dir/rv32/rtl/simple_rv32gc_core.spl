"""
# simple_rv32gc_core Hardware Source Contract

Pure Simple source-of-truth sketch for the generated VHDL lane. The
current bundle writes this next to RTL so backend work can replace the
temporary emitter without inventing a RISC-V-specific bitfield language.
platform: qemu_virt_rv32
proof_lane: generated_rv32_baremetal
scope: repo-native RV32GC generated-core baremetal lane
"""

bitfield Rv32Instruction(u32):
    opcode: 7
    rd: 5
    funct3: 3
    rs1: 5
    rs2: 5
    funct7: 7

bitfield RiscvBranchImmediate(u32):
    low: 4
    high: 6
    bit11: 1
    bit12: 1
    _: 20

bitfield RiscvBranchEncoding(u32):
    opcode: 7
    bit11: 1
    low: 4
    funct3: 3
    rs1: 5
    rs2: 5
    high: 6
    bit12: 1

bitfield RiscvStoreImmediate(u32):
    low: 5
    high: 7
    _: 20

bitfield RiscvStoreEncoding(u32):
    opcode: 7
    low: 5
    funct3: 3
    rs1: 5
    rs2: 5
    high: 7

bitfield RiscvIImmediate(u32):
    value: 12
    _: 20

bitfield RiscvIImmediateEncoding(u32):
    opcode: 7
    rd: 5
    funct3: 3
    rs1: 5
    value: 12

bitfield RiscvUpperImmediate(u32):
    _: 12
    high20: 20

bitfield RiscvUpperImmediateEncoding(u32):
    opcode: 7
    rd: 5
    high20: 20

bitfield RiscvExecuteControl(u32):
    funct3: 3
    bit30: 1
    shamt6: 6
    _: 22

bitfield RiscvExecuteControlEncoding(u32):
    opcode: 7
    rd: 5
    funct3: 3
    rs1: 5
    shamt_low5: 5
    shamt_bit5: 1
    bit30: 1
    _: 5

bitfield RiscvExecuteDatapath(u32):
    operation_kind: 1
    alu_op: 4
    _: 27

bitfield RiscvExecuteDatapathEncoding(u32):
    opcode: 7
    _: 5
    funct3: 3
    _: 15
    bit30: 1
    _: 1

bitfield RiscvBranchDatapath(u32):
    branch_op: 3
    _: 29

bitfield RiscvBranchDatapathEncoding(u32):
    opcode: 7
    _: 5
    funct3: 3
    _: 17

bitfield RiscvControlFlowDatapath(u32):
    next_pc_op: 2
    writes_link: 1
    _: 29

bitfield RiscvControlFlowDatapathEncoding(u32):
    opcode: 7
    _: 25

bitfield RiscvMemoryAccessControl(u32):
    funct3: 3
    _: 29

bitfield RiscvMemoryAccessControlEncoding(u32):
    opcode: 7
    low5: 5
    funct3: 3
    high17: 17

bitfield RiscvJumpImmediate(u32):
    low10: 10
    bit11: 1
    high8: 8
    bit20: 1
    _: 12

bitfield RiscvJumpEncoding(u32):
    opcode: 7
    rd: 5
    high8: 8
    bit11: 1
    low10: 10
    bit20: 1

bitfield RiscvDispatchClass(u32):
    class_code: 4
    _: 28

bitfield RiscvDispatchClassEncoding(u32):
    opcode: 7
    _: 25

bitfield RiscvTrapHaltControl(u32):
    continue_exec: 1
    trap: 1
    halt: 1
    _: 29

bitfield RiscvTrapHaltControlEncoding(u32):
    opcode: 7
    _: 25

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_writeback(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    val funct3 = inst.funct3 as u32
    val funct7 = inst.funct7 as u32
    var writeback = Rv32Instruction.new(imem_rdata)
    if opcode == 19 as u32:
        writeback.rd = inst.rs1 as u32
        writeback
    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:
        writeback.rd = inst.rs2 as u32
        writeback
    else:
        imem_rdata

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_branch_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 99 as u32:
        val branch_inst = RiscvBranchEncoding.new(imem_rdata)
        var branch_imm = RiscvBranchImmediate.new(0 as u32)
        branch_imm.low = branch_inst.low as u32
        branch_imm.high = branch_inst.high as u32
        branch_imm.bit11 = branch_inst.bit11 as u32
        branch_imm.bit12 = branch_inst.bit12 as u32
        branch_imm
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_store_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 35 as u32:
        val store_inst = RiscvStoreEncoding.new(imem_rdata)
        var store_imm = RiscvStoreImmediate.new(0 as u32)
        store_imm.low = store_inst.low as u32
        store_imm.high = store_inst.high as u32
        store_imm
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_i_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 19 as u32 or opcode == 3 as u32:
        val imm_inst = RiscvIImmediateEncoding.new(imem_rdata)
        var imm = RiscvIImmediate.new(0 as u32)
        imm.value = imm_inst.value as u32
        imm
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_upper_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 55 as u32 or opcode == 23 as u32:
        val upper_inst = RiscvUpperImmediateEncoding.new(imem_rdata)
        var upper_imm = RiscvUpperImmediate.new(0 as u32)
        upper_imm.high20 = upper_inst.high20 as u32
        upper_imm
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_execute_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 19 as u32 or opcode == 51 as u32 or opcode == 99 as u32:
        val control_inst = RiscvExecuteControlEncoding.new(imem_rdata)
        var control = RiscvExecuteControl.new(0 as u32)
        control.funct3 = control_inst.funct3 as u32
        control.bit30 = control_inst.bit30 as u32
        control.shamt6 = ((control_inst.shamt_bit5 as u32) << 5) | (control_inst.shamt_low5 as u32)
        control
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_execute_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val datapath_inst = RiscvExecuteDatapathEncoding.new(imem_rdata)
    val opcode = datapath_inst.opcode as u32
    val funct3 = datapath_inst.funct3 as u32
    val bit30 = datapath_inst.bit30 as u32
    var datapath = RiscvExecuteDatapath.new(0 as u32)
    if opcode == 19 as u32:
        datapath.operation_kind = 0 as u32
        if funct3 == 0 as u32:
            datapath.alu_op = 0 as u32
            datapath
        elif funct3 == 1 as u32:
            datapath.alu_op = 2 as u32
            datapath
        elif funct3 == 2 as u32:
            datapath.alu_op = 3 as u32
            datapath
        elif funct3 == 3 as u32:
            datapath.alu_op = 4 as u32
            datapath
        elif funct3 == 4 as u32:
            datapath.alu_op = 5 as u32
            datapath
        elif funct3 == 5 as u32 and bit30 == 0 as u32:
            datapath.alu_op = 6 as u32
            datapath
        elif funct3 == 5 as u32 and bit30 == 1 as u32:
            datapath.alu_op = 7 as u32
            datapath
        elif funct3 == 6 as u32:
            datapath.alu_op = 8 as u32
            datapath
        elif funct3 == 7 as u32:
            datapath.alu_op = 9 as u32
            datapath
        else:
            0 as u32
    elif opcode == 51 as u32:
        datapath.operation_kind = 1 as u32
        if funct3 == 0 as u32 and bit30 == 0 as u32:
            datapath.alu_op = 0 as u32
            datapath
        elif funct3 == 0 as u32 and bit30 == 1 as u32:
            datapath.alu_op = 1 as u32
            datapath
        elif funct3 == 1 as u32:
            datapath.alu_op = 2 as u32
            datapath
        elif funct3 == 2 as u32:
            datapath.alu_op = 3 as u32
            datapath
        elif funct3 == 3 as u32:
            datapath.alu_op = 4 as u32
            datapath
        elif funct3 == 4 as u32:
            datapath.alu_op = 5 as u32
            datapath
        elif funct3 == 5 as u32 and bit30 == 0 as u32:
            datapath.alu_op = 6 as u32
            datapath
        elif funct3 == 5 as u32 and bit30 == 1 as u32:
            datapath.alu_op = 7 as u32
            datapath
        elif funct3 == 6 as u32:
            datapath.alu_op = 8 as u32
            datapath
        elif funct3 == 7 as u32:
            datapath.alu_op = 9 as u32
            datapath
        else:
            0 as u32
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_branch_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val datapath_inst = RiscvBranchDatapathEncoding.new(imem_rdata)
    val opcode = datapath_inst.opcode as u32
    val funct3 = datapath_inst.funct3 as u32
    var datapath = RiscvBranchDatapath.new(0 as u32)
    if opcode == 99 as u32:
        if funct3 == 0 as u32:
            datapath.branch_op = 0 as u32
            datapath
        elif funct3 == 1 as u32:
            datapath.branch_op = 1 as u32
            datapath
        elif funct3 == 4 as u32:
            datapath.branch_op = 2 as u32
            datapath
        elif funct3 == 5 as u32:
            datapath.branch_op = 3 as u32
            datapath
        elif funct3 == 6 as u32:
            datapath.branch_op = 4 as u32
            datapath
        elif funct3 == 7 as u32:
            datapath.branch_op = 5 as u32
            datapath
        else:
            0 as u32
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_control_flow_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val datapath_inst = RiscvControlFlowDatapathEncoding.new(imem_rdata)
    val opcode = datapath_inst.opcode as u32
    var datapath = RiscvControlFlowDatapath.new(0 as u32)
    if opcode == 99 as u32:
        datapath.next_pc_op = 1 as u32
        datapath.writes_link = 0 as u32
        datapath
    elif opcode == 103 as u32:
        datapath.next_pc_op = 2 as u32
        datapath.writes_link = 1 as u32
        datapath
    elif opcode == 111 as u32:
        datapath.next_pc_op = 3 as u32
        datapath.writes_link = 1 as u32
        datapath
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_memory_access_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 3 as u32 or opcode == 35 as u32:
        val access_inst = RiscvMemoryAccessControlEncoding.new(imem_rdata)
        var access = RiscvMemoryAccessControl.new(0 as u32)
        access.funct3 = access_inst.funct3 as u32
        access
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_jump_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    if opcode == 111 as u32:
        val jump_inst = RiscvJumpEncoding.new(imem_rdata)
        var jump_imm = RiscvJumpImmediate.new(0 as u32)
        jump_imm.low10 = jump_inst.low10 as u32
        jump_imm.bit11 = jump_inst.bit11 as u32
        jump_imm.high8 = jump_inst.high8 as u32
        jump_imm.bit20 = jump_inst.bit20 as u32
        jump_imm
    else:
        0 as u32

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_dispatch_class(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val dispatch_inst = RiscvDispatchClassEncoding.new(imem_rdata)
    val opcode = dispatch_inst.opcode as u32
    var dispatch = RiscvDispatchClass.new(0 as u32)
    if opcode == 55 as u32:
        dispatch.class_code = 1 as u32
        dispatch
    elif opcode == 23 as u32:
        dispatch.class_code = 2 as u32
        dispatch
    elif opcode == 19 as u32:
        dispatch.class_code = 3 as u32
        dispatch
    elif opcode == 51 as u32:
        dispatch.class_code = 4 as u32
        dispatch
    elif opcode == 3 as u32:
        dispatch.class_code = 5 as u32
        dispatch
    elif opcode == 35 as u32:
        dispatch.class_code = 6 as u32
        dispatch
    elif opcode == 99 as u32:
        dispatch.class_code = 7 as u32
        dispatch
    elif opcode == 103 as u32:
        dispatch.class_code = 8 as u32
        dispatch
    elif opcode == 111 as u32:
        dispatch.class_code = 9 as u32
        dispatch
    elif opcode == 15 as u32:
        dispatch.class_code = 10 as u32
        dispatch
    elif opcode == 115 as u32:
        dispatch.class_code = 11 as u32
        dispatch
    else:
        dispatch

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core_decode_trap_halt_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val control_inst = RiscvTrapHaltControlEncoding.new(imem_rdata)
    val opcode = control_inst.opcode as u32
    var control = RiscvTrapHaltControl.new(0 as u32)
    if opcode == 55 as u32 or opcode == 23 as u32 or opcode == 19 as u32 or opcode == 51 as u32 or opcode == 3 as u32 or opcode == 35 as u32 or opcode == 99 as u32 or opcode == 103 as u32 or opcode == 111 as u32 or opcode == 15 as u32:
        control.continue_exec = 1 as u32
        control
    elif opcode == 115 as u32:
        control.halt = 1 as u32
        control
    else:
        control.trap = 1 as u32
        control

@hardware
@clocked(clk, reset_n)
fn simple_rv32gc_core(clk: bool, reset_n: bool, imem_rdata: u32, dmem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    val opcode = inst.opcode as u32
    val funct3 = inst.funct3 as u32
    val funct7 = inst.funct7 as u32
    val rd = inst.rd as u32
    # VHDL lowering owns these bitfield reads as slices:
    # inst.opcode -> imem_rdata(6 downto 0)
    # inst.rd -> imem_rdata(11 downto 7)
    # inst.funct3 -> imem_rdata(14 downto 12)
    # inst.rs1 -> imem_rdata(19 downto 15)
    # inst.rs2 -> imem_rdata(24 downto 20)
    # inst.funct7 -> imem_rdata(31 downto 25)
    # RiscvBranchEncoding.bit11 -> imem_rdata(7 downto 7)
    # RiscvBranchEncoding.low -> imem_rdata(11 downto 8)
    # RiscvBranchEncoding.high -> imem_rdata(30 downto 25)
    # RiscvBranchEncoding.bit12 -> imem_rdata(31 downto 31)
    # RiscvStoreEncoding.low -> imem_rdata(11 downto 7)
    # RiscvStoreEncoding.high -> imem_rdata(31 downto 25)
    # RiscvIImmediateEncoding.value -> imem_rdata(31 downto 20)
    # RiscvUpperImmediateEncoding.high20 -> imem_rdata(31 downto 12)
    # RiscvExecuteControlEncoding.funct3 -> imem_rdata(14 downto 12)
    # RiscvExecuteControlEncoding.shamt_low5 -> imem_rdata(24 downto 20)
    # RiscvExecuteControlEncoding.shamt_bit5 -> imem_rdata(25 downto 25)
    # RiscvExecuteControlEncoding.bit30 -> imem_rdata(30 downto 30)
    # RiscvExecuteDatapathEncoding.opcode -> imem_rdata(6 downto 0)
    # RiscvExecuteDatapathEncoding.funct3 -> imem_rdata(14 downto 12)
    # RiscvExecuteDatapathEncoding.bit30 -> imem_rdata(30 downto 30)
    # RiscvBranchDatapathEncoding.opcode -> imem_rdata(6 downto 0)
    # RiscvBranchDatapathEncoding.funct3 -> imem_rdata(14 downto 12)
    # RiscvControlFlowDatapathEncoding.opcode -> imem_rdata(6 downto 0)
    # RiscvMemoryAccessControlEncoding.funct3 -> imem_rdata(14 downto 12)
    # RiscvJumpEncoding.high8 -> imem_rdata(19 downto 12)
    # RiscvJumpEncoding.bit11 -> imem_rdata(20 downto 20)
    # RiscvJumpEncoding.low10 -> imem_rdata(30 downto 21)
    # RiscvJumpEncoding.bit20 -> imem_rdata(31 downto 31)
    # RiscvDispatchClassEncoding.opcode -> imem_rdata(6 downto 0)
    # RiscvTrapHaltControlEncoding.opcode -> imem_rdata(6 downto 0)
    # base integer instructions: lui,auipc,jal,jalr,beq,bne,blt,bge,bltu,bgeu,lb,lh,lw,lbu,lhu,sb,sh,sw,addi,slti,sltiu,xori,ori,andi,slli,srli,srai,add,sub,sll,slt,sltu,xor,srl,sra,or,and,fence,ecall,ebreak
    if opcode == 19 as u32:
        rd as u32
    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:
        rd as u32
    else:
        imem_rdata as u32
