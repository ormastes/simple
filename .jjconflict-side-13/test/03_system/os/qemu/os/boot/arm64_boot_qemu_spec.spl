# ARM64 Boot QEMU Tests — Architecture-Specific
#
# Detailed ARM64 boot verification: PL011 UART, GICv2, DTB, MMU.
#
# @tag: os,qemu,boot,arm64

use os.qemu_runner.{get_target, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 10000
val ARCH = Architecture.Arm64
var g_arm64_output: text = ""

fn _can_run() -> bool:
    val target = get_target(ARCH)
    val qemu_check = rt_process_run_timeout("which", [target.qemu_system], 5000)
    if qemu_check[2] != 0:
        print "SKIP: {target.qemu_system} not found"
        return false
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false
    true

fn _run_qemu() -> text:
    val target = get_target(ARCH)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    args.push("5s")
    args.push(qemu_bin)
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    val result = rt_process_run_timeout("timeout", args, TIMEOUT_MS)
    result[0] + result[1]

fn _run_qemu_cached() -> text:
    if g_arm64_output == "":
        g_arm64_output = _run_qemu()
    g_arm64_output

describe "ARM64 Architecture Boot":
    slow_it "PL011 UART initialized at 0x09000000":
        if _can_run():
            val output = _run_qemu_cached()
            expect(output).to_contain("PL011")

    slow_it "prints ARM64 architecture identifier":
        if _can_run():
            val output = _run_qemu_cached()
            expect(output).to_contain("ARM64")

    slow_it "QEMU virt machine memory map detected":
        if _can_run():
            val output = _run_qemu_cached()
            expect(output).to_contain("Memory map parsed")

    slow_it "kernel region at 0x40000000":
        if _can_run():
            val output = _run_qemu_cached()
            expect(output).to_contain("0x40000000")

    slow_it "GICv2 region reserved":
        if _can_run():
            val output = _run_qemu_cached()
            expect(output).to_contain("device")
