use std.spipe.*
use os.crypto.curve25519.{fe_one, fe_add, fe_mul, fe_sq, fe_invert, fe_to_bytes}
use os.crypto.ed25519_ops.{_ed25519_base_point, ed_point_identity, ed_point_add, ed_scalar_mul, ed_point_encode}

fn _one_bytes() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        if i == 0:
            out.push(1u8)
        else:
            out.push(0u8)
        i = i + 1
    out

fn _two_pow_64_bytes() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        if i == 8:
            out.push(1u8)
        else:
            out.push(0u8)
        i = i + 1
    out

describe "Ed25519 field and base-point primitives":
    it "encodes the field identity as canonical little-endian one":
        expect(fe_to_bytes(fe_one())).to_equal(_one_bytes())

    it "squares across the 64-bit boundary without collapsing to zero":
        var x = fe_add(fe_one(), fe_one())
        var i: u64 = 0
        while i < 6:
            x = fe_sq(x)
            i = i + 1
        expect(fe_to_bytes(x)).to_equal(_two_pow_64_bytes())

    it "inverts two so two times inverse two is one":
        val two = fe_add(fe_one(), fe_one())
        expect(fe_to_bytes(fe_mul(two, fe_invert(two)))).to_equal(_one_bytes())

    it "adds the Ed25519 identity point without changing the base point":
        val base = _ed25519_base_point()
        val sum = ed_point_add(ed_point_identity(), base)
        expect(ed_point_encode(sum)).to_equal(ed_point_encode(base))

    it "scalar-multiplies the base point by one":
        val base = _ed25519_base_point()
        val one = _one_bytes()
        expect(ed_point_encode(ed_scalar_mul(one, base))).to_equal(ed_point_encode(base))
