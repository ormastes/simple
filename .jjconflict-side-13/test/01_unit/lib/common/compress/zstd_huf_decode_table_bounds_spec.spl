use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.zstd_huf.{ZstdHufCanonicalEntry, ZstdHufDecodeEntry, zstd_huf_expand_decode_table}

fn expect_corrupt(result: Result<[ZstdHufDecodeEntry], CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.CorruptStream(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

describe "Zstd Huffman decode table bounds validation":
    it "rejects symbols outside the byte alphabet":
        val entries = [
            ZstdHufCanonicalEntry(symbol: 256, weight: 1, bits: 1, code: 0u32),
            ZstdHufCanonicalEntry(symbol: 0, weight: 1, bits: 1, code: 1u32)
        ]
        expect_corrupt(zstd_huf_expand_decode_table(entries, 1), "symbol")

    it "rejects codes wider than their declared bit width":
        val entries = [
            ZstdHufCanonicalEntry(symbol: 0, weight: 1, bits: 1, code: 2u32),
            ZstdHufCanonicalEntry(symbol: 1, weight: 1, bits: 1, code: 1u32)
        ]
        expect_corrupt(zstd_huf_expand_decode_table(entries, 1), "code width")
