# ann_spec.spl — exact kNN ORACLE + approximate IVF index (fixed-point) (AC-7)
#
# Proves, against HAND-PLACED absolute-oracle fixtures (integer 2D/3D points
# with a KNOWN nearest neighbor):
#   * exact brute-force kNN returns the KNOWN ids in the KNOWN nearest-first
#     order, with deterministic id tie-breaking on equidistant points;
#   * the approximate IVF index achieves RECALL >= a stated threshold measured
#     against the exact oracle on the SAME fixture (oracle is independent —
#     ANN is never compared to itself).
#
# All distances are integer squared-L2 over Embedding.fixed ([i64]); f64 is
# never on the path (MEMORY: f64 Unreliable All Backends).
use std.spec
use lib.common.search.types.{Embedding, Score}
use lib.common.search.ann.{ExactKnn, IvfIndex, Neighbor, l2_sq_distance, recall_permille}

# Hand-built integer 2D embeddings.
fn vec2(x: i64, y: i64) -> Embedding<D>:
    var v: [i64] = []
    v.push(x)
    v.push(y)
    Embedding.from_fixed(v)

fn vec3(x: i64, y: i64, z: i64) -> Embedding<D>:
    var v: [i64] = []
    v.push(x)
    v.push(y)
    v.push(z)
    Embedding.from_fixed(v)

# A reusable 2D fixture. Ids and coordinates with a KNOWN layout:
#   id 0 (0,0)  id 1 (10,0)  id 2 (0,10)  id 3 (10,10)
#   id 4 (3,3)  id 5 (7,7)   id 6 (1,0)   id 7 (0,1)
# Query (1,1): nearest by squared-L2 are id0 (2), then ids 6&7 (1+0? -> (1-1)^2+(1-0)^2=1)
# Recompute distances to q=(1,1):
#   id0 (0,0): 1+1 = 2
#   id6 (1,0): 0+1 = 1
#   id7 (0,1): 1+0 = 1     <- ids 6 and 7 are EQUIDISTANT (the tie case)
#   id4 (3,3): 4+4 = 8
fn build_fixture() -> ExactKnn:
    var idx = ExactKnn.new()
    idx.add(0, vec2(0, 0))
    idx.add(1, vec2(10, 0))
    idx.add(2, vec2(0, 10))
    idx.add(3, vec2(10, 10))
    idx.add(4, vec2(3, 3))
    idx.add(5, vec2(7, 7))
    idx.add(6, vec2(1, 0))
    idx.add(7, vec2(0, 1))
    idx

describe "l2_sq_distance (integer, exact)":
    it "computes squared Euclidean distance over fixed-point components":
        val a = vec2(1, 1)
        val b = vec2(4, 5)
        # (4-1)^2 + (5-1)^2 = 9 + 16 = 25
        expect(l2_sq_distance(a, b)).to_equal(25)

    it "is zero for identical vectors":
        val a = vec3(2, 3, 4)
        expect(l2_sq_distance(a, a)).to_equal(0)

    it "is symmetric":
        val a = vec3(1, 2, 3)
        val b = vec3(4, 0, 1)
        expect(l2_sq_distance(a, b)).to_equal(l2_sq_distance(b, a))

describe "ExactKnn ORACLE — known nearest neighbor":
    it "returns the single KNOWN nearest id for query (1,1)":
        val idx = build_fixture()
        # ids 6 (1,0) and 7 (0,1) both at distance 1; tie-break picks smaller id 6.
        expect(idx.nearest_id(vec2(1, 1))).to_equal(6)

    it "returns top-3 in KNOWN nearest-first order with id tie-break":
        val idx = build_fixture()
        val top = idx.query(vec2(1, 1), 3)
        expect(top.len()).to_equal(3)
        # distance 1: id6, id7 (tie -> id6 first); distance 2: id0
        expect(top[0].doc_id()).to_equal(6)
        expect(top[0].distance()).to_equal(1)
        expect(top[1].doc_id()).to_equal(7)
        expect(top[1].distance()).to_equal(1)
        expect(top[2].doc_id()).to_equal(0)
        expect(top[2].distance()).to_equal(2)

    it "equidistant points are ordered by ascending id (tie case)":
        val idx = build_fixture()
        val top = idx.query(vec2(1, 1), 2)
        # Both id6 and id7 sit at distance 1; deterministic order is 6 then 7.
        expect(top[0].doc_id()).to_equal(6)
        expect(top[1].doc_id()).to_equal(7)

    it "finds the far corner for a far query":
        val idx = build_fixture()
        # Query (11,11) is nearest to id3 (10,10): distance 1+1 = 2.
        expect(idx.nearest_id(vec2(11, 11))).to_equal(3)

    it "3D oracle picks the known nearest":
        var idx = ExactKnn.new()
        idx.add(0, vec3(0, 0, 0))
        idx.add(1, vec3(5, 5, 5))
        idx.add(2, vec3(1, 0, 0))
        # Query (0,0,1): id0 dist 1, id2 dist 2, id1 dist 75 -> nearest id0.
        expect(idx.nearest_id(vec3(0, 0, 1))).to_equal(0)

describe "Neighbor typed result":
    it "carries id and distance and a closer=higher Score":
        val n = Neighbor.of(7, 25)
        expect(n.doc_id()).to_equal(7)
        expect(n.distance()).to_equal(25)
        # score is -distance so nearer ranks higher
        expect(n.score().raw_value()).to_equal(0 - 25)

    is_nearer = Neighbor.of(3, 4).is_nearer_than(Neighbor.of(9, 10))
    it "is_nearer_than orders by smaller distance":
        expect(is_nearer).to_equal(true)

describe "IvfIndex APPROXIMATE — recall vs exact oracle":
    it "achieves recall@3 >= 0.8 against the independent exact oracle":
        # Build the SAME fixture into both the oracle and the IVF index.
        val oracle = build_fixture()
        var ivf = IvfIndex.new(3, 2)
        ivf.add(0, vec2(0, 0))
        ivf.add(1, vec2(10, 0))
        ivf.add(2, vec2(0, 10))
        ivf.add(3, vec2(10, 10))
        ivf.add(4, vec2(3, 3))
        ivf.add(5, vec2(7, 7))
        ivf.add(6, vec2(1, 0))
        ivf.add(7, vec2(0, 1))

        val q = vec2(1, 1)
        val exact = oracle.query(q, 3)
        val approx = ivf.query(q, 3)
        val r = recall_permille(approx, exact)
        # Stated threshold: >= 0.8 (800 per-mille) of the true top-3.
        expect(r).to_be_greater_than(799)

    it "finds the true top-1 via the approximate index":
        val oracle = build_fixture()
        var ivf = IvfIndex.new(3, 2)
        ivf.add(0, vec2(0, 0))
        ivf.add(1, vec2(10, 0))
        ivf.add(2, vec2(0, 10))
        ivf.add(3, vec2(10, 10))
        ivf.add(4, vec2(3, 3))
        ivf.add(5, vec2(7, 7))
        ivf.add(6, vec2(1, 0))
        ivf.add(7, vec2(0, 1))

        val q = vec2(1, 1)
        val true_top1 = oracle.nearest_id(q)
        val approx_top1 = ivf.nearest_id(q)
        expect(approx_top1).to_equal(true_top1)

    it "with nprobe = nlist the IVF index degenerates to exact (recall 1.0)":
        # Probing every cluster must reproduce the exact oracle exactly.
        val oracle = build_fixture()
        var ivf = IvfIndex.new(3, 3)
        ivf.add(0, vec2(0, 0))
        ivf.add(1, vec2(10, 0))
        ivf.add(2, vec2(0, 10))
        ivf.add(3, vec2(10, 10))
        ivf.add(4, vec2(3, 3))
        ivf.add(5, vec2(7, 7))
        ivf.add(6, vec2(1, 0))
        ivf.add(7, vec2(0, 1))

        val q = vec2(1, 1)
        val exact = oracle.query(q, 3)
        val approx = ivf.query(q, 3)
        expect(recall_permille(approx, exact)).to_equal(1000)

    it "assigns every point to a cluster and seeds nlist centroids":
        var ivf = IvfIndex.new(3, 2)
        ivf.add(0, vec2(0, 0))
        ivf.add(1, vec2(10, 0))
        ivf.add(2, vec2(0, 10))
        ivf.add(3, vec2(10, 10))
        ivf.add(4, vec2(3, 3))
        expect(ivf.size()).to_equal(5)
        expect(ivf.cluster_count()).to_equal(3)
