# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl 40%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_helpers.spl 40%
# @tag: unit, gpu, engine2d, vulkan, text

use std.gpu.engine2d.backend_vulkan.{VulkanBackend}

describe "Engine2D Vulkan text fallback":

    it "skips foreground glyph upload when Vulkan is uninitialized":
        var backend = VulkanBackend.create()

        backend.draw_text(0, 0, "A", 0xff112233u32, 7)

        expect(backend.initialized).to_equal(false)
        expect(backend.dirty).to_equal(true)

        backend.shutdown()

    it "skips background glyph staging when Vulkan is uninitialized":
        var backend = VulkanBackend.create()

        backend.draw_text_bg(0, 0, "A", 0xff112233u32, 0xff445566u32, 7)

        expect(backend.initialized).to_equal(false)
        expect(backend.dirty).to_equal(true)

        backend.shutdown()
