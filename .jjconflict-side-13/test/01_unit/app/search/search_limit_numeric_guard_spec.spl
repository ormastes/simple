extern fn rt_file_read_text(path: text) -> text?

describe "search limit numeric guard":
    it "defaults malformed limit values":
        val source = rt_file_read_text("src/app/search/main.spl") ?? ""

        expect(source).to_contain("fn parse_limit_or_default(value: text) -> i64")
        expect(source).to_contain("val parsed = trimmed.to_int() ?? 20")
        expect(source.contains("val parsed = trimmed.to_int()\n")).to_equal(false)
