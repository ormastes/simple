use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_os(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/os/main.spl\" " + joined
    ])

describe "os log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_os(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_os(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"os\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for usage output":
        val (out, err, code) = _run_os(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("SimpleOS")

    it "rejects invalid log mode":
        val (out, err, code) = _run_os(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for deterministic targets output":
        val (out, err, code) = _run_os(["--log-mode=json", "targets"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"os\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"action\":\"targets\"")
