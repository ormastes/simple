# Easing Functions — Integer-based animation curves
#
# Ported from QEMU ARM64/x86_64 wm_entry.spl.
# All functions use i32 with 0-100 range for both input and output.
# Shared between all window manager implementations.

# ============================================================================
# Easing Curves
# ============================================================================

fn bounce_offset(progress: i32) -> i32:
    """Vertical bounce easing for focus animation.

    Returns a y-offset that starts high, drops to 0, and stays there.
    progress: 0-100
    """
    if progress < 40:
        (8 * (40 - progress)) / 40
    else:
        0

fn ease_out_cubic(t: i32) -> i32:
    """Smooth deceleration curve (fast start, slow end).

    t: 0-100 → result: 0-100
    Formula: 1 - (1-t)^3
    """
    val inv = 100 - t
    val inv2 = inv * inv / 100
    val inv3 = inv2 * inv / 100
    100 - inv3

fn ease_in_cubic(t: i32) -> i32:
    """Smooth acceleration curve (slow start, fast end).

    t: 0-100 → result: 0-100
    Formula: t^3
    """
    t * t * t / 10000

fn ease_in_out_quad(t: i32) -> i32:
    """Smooth acceleration + deceleration (slow-fast-slow).

    t: 0-100 → result: 0-100
    """
    if t < 50:
        t * t * 2 / 100
    else:
        val inv = 100 - t
        100 - inv * inv * 2 / 100

fn spring_ease(t: i32) -> i32:
    """Spring physics easing — overshoots then settles.

    t: 0-100 → result: 0-100 (can overshoot to ~110)
    Three phases: fast rise to 110, settle back to 95, ease to 100.
    """
    if t < 60:
        t * 110 / 60
    else if t < 80:
        110 - (t - 60) * 15 / 20
    else:
        95 + (t - 80) * 5 / 20

# ============================================================================
# Interpolation
# ============================================================================

fn lerp_i32(start: i32, end_: i32, progress: i32) -> i32:
    """Linear interpolation between two i32 values.

    progress: 0-100 → result: start..end_
    """
    if end_ >= start:
        start + (end_ - start) * progress / 100
    else:
        start - (start - end_) * progress / 100
