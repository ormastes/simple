# Check Layers CLI Command
#
# Standalone invocation of layer dependency checking.
# Usage: simple check-layers [--strict]

use compiler.driver.build.layer_check.{run_layer_check, print_layer_check_result}

fn run_check_layers(args: [text]) -> i64:
    var strict = false
    for arg in args:
        if arg == "--strict" or arg == "--strict-layers":
            strict = true

    val result = run_layer_check(strict)
    print_layer_check_result(result, strict)

    if strict and result.has_violations():
        return 1
    0
