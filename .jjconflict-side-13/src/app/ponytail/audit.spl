use std.io_runtime.{file_read}
use std.common.ponytail.audit.{ponytail_audit_source, ponytail_simplification_report_source}

fn ponytail_audit(path: text) -> text:
    val source = file_read(path)
    if source == "":
        return "Ponytail Audit\nsource: " + path + "\nstatus: missing\nreason: source unavailable"
    ponytail_audit_source(path, source)

fn ponytail_simplification_report(path: text) -> text:
    val source = file_read(path)
    if source == "":
        return "Ponytail Simplification Report\nsource: " + path + "\nstatus: missing\nreason: source unavailable\ntotal_suggestions: 0"
    ponytail_simplification_report_source(path, source)
