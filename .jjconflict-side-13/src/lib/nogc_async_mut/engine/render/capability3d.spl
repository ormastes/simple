# std.nogc_async_mut.engine.render.capability3d — RenderCapability3D
#
# Describes what a 3D render backend can do.
# Factory functions return pre-populated capability structs for each backend.
# detect_best_backend_3d() selects the highest-capability backend available.

# ============================================================================
# RenderBackendKind3D
# ============================================================================

enum RenderBackendKind3D:
    Software
    Vulkan
    WebGpu

# ============================================================================
# RenderCapability3D — feature flags for a 3D backend
# ============================================================================

class RenderCapability3D:
    backend: RenderBackendKind3D
    supports_compute_shaders: bool
    supports_msaa: bool
    supports_mip_maps: bool
    max_texture_size: i64
    max_color_attachments: i64
    supports_wgsl: bool

fn capability_software_3d() -> RenderCapability3D:
    RenderCapability3D(
        backend: RenderBackendKind3D.Software,
        supports_compute_shaders: false,
        supports_msaa: false,
        supports_mip_maps: false,
        max_texture_size: 8192,
        max_color_attachments: 1,
        supports_wgsl: false
    )

fn capability_vulkan_3d() -> RenderCapability3D:
    RenderCapability3D(
        backend: RenderBackendKind3D.Vulkan,
        supports_compute_shaders: true,
        supports_msaa: true,
        supports_mip_maps: true,
        max_texture_size: 16384,
        max_color_attachments: 8,
        supports_wgsl: false
    )

fn capability_webgpu_3d() -> RenderCapability3D:
    RenderCapability3D(
        backend: RenderBackendKind3D.WebGpu,
        supports_compute_shaders: true,
        supports_msaa: true,
        supports_mip_maps: true,
        max_texture_size: 8192,
        max_color_attachments: 8,
        supports_wgsl: true
    )

fn detect_best_backend_3d() -> RenderBackendKind3D:
    # Software is always available. Vulkan/WebGpu require runtime detection
    # which is not yet implemented. Return Software as safe default.
    RenderBackendKind3D.Software
