# Scene Format — scene graph data model for the node-based editor.
#
# Provides: SceneNodeData, SceneFile.

class SceneNodeData:
    node_id: i32
    name: text
    parent_id: i32
    transform_x: f64
    transform_y: f64
    transform_z: f64
    visible: bool
    locked: bool

    static fn new(node_id: i32, name: text, parent_id: i32) -> SceneNodeData:
        SceneNodeData(
            node_id: node_id,
            name: name,
            parent_id: parent_id,
            transform_x: 0.0,
            transform_y: 0.0,
            transform_z: 0.0,
            visible: true,
            locked: false
        )

class SceneFile:
    name: text
    nodes: [SceneNodeData]
    next_id: i32

    static fn new(name: text) -> SceneFile:
        SceneFile(name: name, nodes: [], next_id: 1)

    me add_node(name: text, parent_id: i32) -> SceneNodeData:
        val node = SceneNodeData.new(me.next_id, name, parent_id)
        me.nodes.push(node)
        me.next_id = me.next_id + 1
        node

    me remove_node(node_id: i32):
        var new_nodes: [SceneNodeData] = []
        for n in me.nodes:
            if n.node_id != node_id:
                new_nodes.push(n)
        me.nodes = new_nodes

    fn find_node(node_id: i32) -> Option<SceneNodeData>:
        for n in me.nodes:
            if n.node_id == node_id:
                return Option.Some(n)
        Option.None

    fn node_count() -> i64:
        me.nodes.len()
