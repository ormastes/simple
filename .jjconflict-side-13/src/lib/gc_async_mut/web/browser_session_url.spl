# Browser session — URL utility functions.
#
# Free functions for:
# - normalize_browser_url: normalise any user-supplied URL string
# - resolve_relative_url: resolve href against a base URL
# - url_protocol / url_pathname / url_origin / url_host / url_search / url_hash
# - without_fragment / without_query / base_dir
# - normalize_runtime_request_url: fix up JS runtime fetch URLs
# - find_text: low-level substring search used by many helpers

fn find_text(haystack: text, needle: text, start: i64) -> i64:
    if start < 0 or start > haystack.len() or needle.len() == 0:
        return -1
    var idx = start
    val last = haystack.len() - needle.len()
    val first = needle.slice(0, 1)
    while idx <= last:
        if haystack.slice(idx, idx + 1) == first:
            if haystack.slice(idx, idx + needle.len()) == needle:
                return idx
        idx = idx + 1
    -1

fn normalize_browser_url(input: text) -> text:
    if input.len() == 0:
        return "about:blank"
    if input.starts_with("about:") or
       input.starts_with("file://") or
       input.starts_with("http://") or
       input.starts_with("https://"):
        return input
    if input.starts_with("/"):
        return "file://{input}"
    if input.contains(".") and not input.contains(" "):
        return "https://{input}"
    "https://search.example.com/?q={input}"

fn resolve_relative_url(base_url: text, href: text) -> text:
    if href == "":
        return base_url
    if href.starts_with("http://") or href.starts_with("https://") or href.starts_with("file://") or href.starts_with("about:"):
        return href
    if href.starts_with("//"):
        return url_protocol(base_url).slice(0, url_protocol(base_url).len() - 1) + href
    if href.starts_with("#"):
        return without_fragment(base_url) + href
    if href.starts_with("?"):
        return without_query(base_url) + href
    if href.starts_with("/"):
        val origin = url_origin(base_url)
        if origin != "":
            return origin + href
        return href
    base_dir(base_url) + href

# Collapse "." and ".." segments in a URL's path per RFC 3986 remove_dot_segments,
# leaving scheme/host (origin) and any query/fragment tail untouched.
# Applied selectively by callers (e.g. CSS @import resolution) that want
# normalised URLs; resolve_relative_url itself preserves raw joins because
# other consumers (JS module dependency extraction) assert on the unnormalised
# form.
fn collapse_url_dot_segments(url: text) -> text:
    val origin = url_origin(url)
    val rest = url.slice(origin.len(), url.len())
    # Split off query/fragment so we only normalise the path portion.
    var cut = rest.len()
    val q = find_text(rest, "?", 0)
    if q >= 0 and q < cut:
        cut = q
    val h = find_text(rest, "#", 0)
    if h >= 0 and h < cut:
        cut = h
    val path = rest.slice(0, cut)
    val tail = rest.slice(cut, rest.len())
    origin + remove_dot_segments(path) + tail

# RFC 3986 §5.2.4 remove_dot_segments operating on a path string.
fn remove_dot_segments(path: text) -> text:
    var input = path
    var output = ""
    while input.len() > 0:
        if input.starts_with("../"):
            input = input.slice(3, input.len())
        elif input.starts_with("./"):
            input = input.slice(2, input.len())
        elif input.starts_with("/./"):
            input = "/" + input.slice(3, input.len())
        elif input == "/.":
            input = "/"
        elif input.starts_with("/../"):
            input = "/" + input.slice(4, input.len())
            output = _drop_last_segment(output)
        elif input == "/..":
            input = "/"
            output = _drop_last_segment(output)
        elif input == "." or input == "..":
            input = ""
        else:
            # Move the first path segment (leading "/" plus chars up to next "/").
            var seg_end = input.len()
            var i = 0
            if input.starts_with("/"):
                i = 1
            while i < input.len():
                if input.slice(i, i + 1) == "/":
                    seg_end = i
                    i = input.len()
                else:
                    i = i + 1
            output = output + input.slice(0, seg_end)
            input = input.slice(seg_end, input.len())
    output

fn _drop_last_segment(output: text) -> text:
    var idx = output.len() - 1
    while idx >= 0:
        if output.slice(idx, idx + 1) == "/":
            return output.slice(0, idx)
        idx = idx - 1
    ""

# Collapse "." and ".." segments in a URL's path per RFC 3986 remove_dot_segments,
# leaving scheme/host (origin) and any query/fragment tail untouched.
# Applied selectively by callers (e.g. CSS @import resolution) that want
# normalised URLs; resolve_relative_url itself preserves raw joins because
# other consumers (JS module dependency extraction) assert on the unnormalised
# form.
fn collapse_url_dot_segments(url: text) -> text:
    val origin = url_origin(url)
    val rest = url.slice(origin.len(), url.len())
    # Split off query/fragment so we only normalise the path portion.
    var cut = rest.len()
    val q = find_text(rest, "?", 0)
    if q >= 0 and q < cut:
        cut = q
    val h = find_text(rest, "#", 0)
    if h >= 0 and h < cut:
        cut = h
    val path = rest.slice(0, cut)
    val tail = rest.slice(cut, rest.len())
    origin + remove_dot_segments(path) + tail

# RFC 3986 §5.2.4 remove_dot_segments operating on a path string.
fn remove_dot_segments(path: text) -> text:
    var input = path
    var output = ""
    while input.len() > 0:
        if input.starts_with("../"):
            input = input.slice(3, input.len())
        elif input.starts_with("./"):
            input = input.slice(2, input.len())
        elif input.starts_with("/./"):
            input = "/" + input.slice(3, input.len())
        elif input == "/.":
            input = "/"
        elif input.starts_with("/../"):
            input = "/" + input.slice(4, input.len())
            output = _drop_last_segment(output)
        elif input == "/..":
            input = "/"
            output = _drop_last_segment(output)
        elif input == "." or input == "..":
            input = ""
        else:
            # Move the first path segment (leading "/" plus chars up to next "/").
            var seg_end = input.len()
            var i = 0
            if input.starts_with("/"):
                i = 1
            while i < input.len():
                if input.slice(i, i + 1) == "/":
                    seg_end = i
                    i = input.len()
                else:
                    i = i + 1
            output = output + input.slice(0, seg_end)
            input = input.slice(seg_end, input.len())
    output

fn _drop_last_segment(output: text) -> text:
    var idx = output.len() - 1
    while idx >= 0:
        if output.slice(idx, idx + 1) == "/":
            return output.slice(0, idx)
        idx = idx - 1
    ""

fn url_protocol(url: text) -> text:
    if url.starts_with("https://"):
        return "https:"
    if url.starts_with("http://"):
        return "http:"
    if url.starts_with("file://"):
        return "file:"
    if url.starts_with("about:"):
        return "about:"
    ""

fn url_pathname(url: text) -> text:
    if url.starts_with("file://"):
        return without_query(url.slice(7, url.len()))
    if url.starts_with("about:"):
        return url
    val scheme_pos = find_text(url, "://", 0)
    if scheme_pos < 0:
        return "/"
    val path_start = find_text(url, "/", scheme_pos + 3)
    if path_start < 0:
        return "/"
    without_query(url.slice(path_start, url.len()))

fn url_origin(url: text) -> text:
    val scheme_pos = find_text(url, "://", 0)
    if scheme_pos < 0:
        return ""
    val host_start = scheme_pos + 3
    val path_start = find_text(url, "/", host_start)
    if path_start < 0:
        return url
    url.slice(0, path_start)

fn without_fragment(url: text) -> text:
    val idx = find_text(url, "#", 0)
    if idx < 0:
        return url
    url.slice(0, idx)

fn without_query(url: text) -> text:
    val clean = without_fragment(url)
    val idx = find_text(clean, "?", 0)
    if idx < 0:
        return clean
    clean.slice(0, idx)

fn base_dir(url: text) -> text:
    val clean = without_query(url)
    val origin = url_origin(clean)
    if origin == "":
        return ""
    if clean == origin:
        return origin + "/"
    val rel = clean.slice(origin.len(), clean.len())
    var idx = rel.len() - 1
    while idx >= 0:
        if rel.slice(idx, idx + 1) == "/":
            return origin + rel.slice(0, idx + 1)
        idx = idx - 1
    origin + "/"

fn url_host(url: text) -> text:
    val scheme_pos = find_text(url, "://", 0)
    if scheme_pos < 0:
        return ""
    val host_start = scheme_pos + 3
    val path_start = find_text(url, "/", host_start)
    if path_start < 0:
        return url.slice(host_start, url.len())
    url.slice(host_start, path_start)

fn url_search(url: text) -> text:
    val clean = without_fragment(url)
    val idx = find_text(clean, "?", 0)
    if idx < 0:
        return ""
    clean.slice(idx, clean.len())

fn url_hash(url: text) -> text:
    val idx = find_text(url, "#", 0)
    if idx < 0:
        return ""
    url.slice(idx, url.len())

fn normalize_runtime_request_url(base_url: text, request_url: text) -> text:
    if request_url.starts_with("http://") or
       request_url.starts_with("https://") or
       request_url.starts_with("file://") or
       request_url.starts_with("about:"):
        return request_url
    if request_url.starts_with("nil/"):
        return resolve_relative_url(base_url, request_url.slice(3, request_url.len()))
    resolve_relative_url(base_url, request_url)
