# Shared generated Engine2D kernel argument packers.
#
# Glyph raster kernels use the same logical argument layout across generated
# CUDA/HIP/OpenCL/Metal metadata: glyph_plan,dst,width,height,font_size.

val GENERATED_2D_GLYPH_ARG_BYTES: i64 = 40

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64, size: i64)
extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64) -> i64

class GeneratedGlyphRasterArgs:
    args_ptr: i64
    glyph_plan: i64
    dst: i64
    width: i64
    height: i64
    font_size: i64
    ready: bool
    reason: text

    static fn invalid(reason: text) -> GeneratedGlyphRasterArgs:
        GeneratedGlyphRasterArgs(
            args_ptr: 0,
            glyph_plan: 0,
            dst: 0,
            width: 0,
            height: 0,
            font_size: 0,
            ready: false,
            reason: reason
        )

    static fn ready(args_ptr: i64, glyph_plan: i64, dst: i64, width: i64, height: i64, font_size: i64) -> GeneratedGlyphRasterArgs:
        GeneratedGlyphRasterArgs(
            args_ptr: args_ptr,
            glyph_plan: glyph_plan,
            dst: dst,
            width: width,
            height: height,
            font_size: font_size,
            ready: true,
            reason: "ready"
        )

    fn summary() -> text:
        "GeneratedGlyphRasterArgs[args_ptr={self.args_ptr} glyph_plan={self.glyph_plan} dst={self.dst} width={self.width} height={self.height} font_size={self.font_size} ready={self.ready.to_text()} reason={self.reason}]"

class GeneratedGlyphRasterStaging:
    args: GeneratedGlyphRasterArgs
    enabled: bool
    dst_bytes: i64

    static fn disabled(reason: text) -> GeneratedGlyphRasterStaging:
        GeneratedGlyphRasterStaging(
            args: GeneratedGlyphRasterArgs.invalid(reason),
            enabled: false,
            dst_bytes: 0
        )

    static fn create(width: i64, height: i64, font_size: i64, enabled: bool) -> GeneratedGlyphRasterStaging:
        if not enabled:
            return GeneratedGlyphRasterStaging.disabled("generated-glyph-args-disabled")
        if width <= 0 or height <= 0:
            return GeneratedGlyphRasterStaging.disabled("invalid-generated-glyph-dimensions")
        val glyph_plan = rt_alloc(8)
        if glyph_plan == 0:
            return GeneratedGlyphRasterStaging.disabled("alloc-glyph-plan-failed")
        val dst_bytes = width * height * 4
        val dst = rt_alloc(dst_bytes)
        if dst == 0:
            rt_free(glyph_plan, 8)
            return GeneratedGlyphRasterStaging.disabled("alloc-glyph-dst-failed")
        val args = generated_glyph_raster_args_pack(glyph_plan, dst, width, height, font_size)
        if not args.ready:
            rt_free(glyph_plan, 8)
            rt_free(dst, dst_bytes)
            return GeneratedGlyphRasterStaging(args: args, enabled: enabled, dst_bytes: 0)
        GeneratedGlyphRasterStaging(args: args, enabled: enabled, dst_bytes: dst_bytes)

    fn ready() -> bool:
        self.args.ready

    fn reason() -> text:
        self.args.reason

    fn args_ptr() -> i64:
        self.args.args_ptr

fn generated_glyph_raster_args_reason(glyph_plan: i64, dst: i64, width: i64, height: i64, font_size: i64) -> text:
    if glyph_plan == 0:
        return "missing-glyph-plan"
    if dst == 0:
        return "missing-dst"
    if width <= 0 or height <= 0:
        return "invalid-dimensions"
    if font_size <= 0:
        return "invalid-font-size"
    "ready"

fn generated_glyph_raster_args_pack(glyph_plan: i64, dst: i64, width: i64, height: i64, font_size: i64) -> GeneratedGlyphRasterArgs:
    val reason = generated_glyph_raster_args_reason(glyph_plan, dst, width, height, font_size)
    if reason != "ready":
        return GeneratedGlyphRasterArgs.invalid(reason)
    val args_ptr = rt_alloc(GENERATED_2D_GLYPH_ARG_BYTES)
    if args_ptr == 0:
        return GeneratedGlyphRasterArgs.invalid("alloc-failed")
    rt_ptr_write_i64(args_ptr, 0, glyph_plan)
    rt_ptr_write_i64(args_ptr, 8, dst)
    rt_ptr_write_i64(args_ptr, 16, width)
    rt_ptr_write_i64(args_ptr, 24, height)
    rt_ptr_write_i64(args_ptr, 32, font_size)
    GeneratedGlyphRasterArgs.ready(args_ptr, glyph_plan, dst, width, height, font_size)

fn generated_glyph_raster_args_from_ptr(args_ptr: i64) -> GeneratedGlyphRasterArgs:
    if args_ptr == 0:
        return GeneratedGlyphRasterArgs.invalid("missing-args-pointer")
    val glyph_plan = rt_ptr_read_i64(args_ptr, 0)
    val dst = rt_ptr_read_i64(args_ptr, 8)
    val width = rt_ptr_read_i64(args_ptr, 16)
    val height = rt_ptr_read_i64(args_ptr, 24)
    val font_size = rt_ptr_read_i64(args_ptr, 32)
    val reason = generated_glyph_raster_args_reason(glyph_plan, dst, width, height, font_size)
    if reason != "ready":
        return GeneratedGlyphRasterArgs(
            args_ptr: args_ptr,
            glyph_plan: glyph_plan,
            dst: dst,
            width: width,
            height: height,
            font_size: font_size,
            ready: false,
            reason: reason
        )
    GeneratedGlyphRasterArgs.ready(args_ptr, glyph_plan, dst, width, height, font_size)

fn generated_glyph_raster_args_launch_reason(backend: text, args_ptr: i64, width: i64, height: i64) -> text:
    if args_ptr == 0:
        return "missing-generated-2d-args-pointer"
    if width <= 0 or height <= 0:
        return "invalid-generated-glyph-dimensions"
    val args = generated_glyph_raster_args_from_ptr(args_ptr)
    if args.reason == "missing-glyph-plan":
        return "missing-{backend}-glyph-plan"
    if args.reason == "missing-dst":
        return "missing-{backend}-glyph-dst"
    if args.reason == "invalid-font-size":
        return "invalid-{backend}-glyph-font-size"
    if not args.ready:
        return args.reason
    if args.width != width or args.height != height:
        return "{backend}-glyph-dimensions-mismatch"
    "ready"

fn generated_glyph_raster_args_free(args: GeneratedGlyphRasterArgs):
    if args.args_ptr != 0:
        rt_free(args.args_ptr, GENERATED_2D_GLYPH_ARG_BYTES)

fn generated_glyph_raster_staging_create(width: i64, height: i64, font_size: i64, enabled: bool) -> GeneratedGlyphRasterStaging:
    GeneratedGlyphRasterStaging.create(width, height, font_size, enabled)

fn generated_glyph_raster_staging_free(staging: GeneratedGlyphRasterStaging):
    val args = staging.args
    if args.args_ptr != 0:
        generated_glyph_raster_args_free(args)
    if args.glyph_plan != 0:
        rt_free(args.glyph_plan, 8)
    if args.dst != 0 and staging.dst_bytes > 0:
        rt_free(args.dst, staging.dst_bytes)
