    verify, verify

tools |id, type, name, purpose|
    simple_cli, cli, "bin/simple test", "Run focused and broad test verification"
    smoke_core, cli, "bin/simple check src/compiler && bin/simple check src/lib", "Verify compiler/core/lib check paths"
