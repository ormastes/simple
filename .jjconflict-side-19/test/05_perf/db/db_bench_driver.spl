# db_bench_driver.spl — DB benchmark driver (AC-3 / AC-5).
#
# Runs a FIXED workload (N=100 inserts + row-count oracle) against three DB
# configurations and emits benchmark docs.
#
# Writes:
#   doc/09_report/perf/perf_baseline_db_2026-06-13.md   — dated run report
#   doc/10_metrics/perf/perf_baseline_db_table.md        — persistent table
#
# Modes (AC-5 — three distinct rows when all run):
#   "ram"        — PureDatabase.memory()
#   "persistent" — PureDatabase.open_deferred(path) + checkpoint()
#   "wal"        — MvccTable (in-process MVCC core)
#
# N=100: persistent deferred+checkpoint safe within interpreter limits.
#
# INTERPRETER LIMITATIONS (bin/simple run):
#   All three DB modes rely on cross-module struct mutation/return which is
#   broken in interpreter mode:
#   - ram/persistent: PureDatabase.memory() struct return yields None
#     (interp_cross_module_struct_return_unit_2026-06-13)
#   - wal: MvccTable.insert/commit mutations are lost across module boundary
#     (interp_cross_module_struct_mutation_loss)
#   All three run correctly via bin/simple test (compiled mode: 13/13 pass).
#   Rows are OMITTED with explanations; numbers are NOT fabricated.
#
# Run:  bin/simple run test/05_perf/db/db_bench_driver.spl

use std.io_runtime
use std.database.sql.types.{DbValue, DbRow, DbError}
use nogc_sync_mut.database.pure_sql.database.{PureDatabase}
use nogc_sync_mut.db.dbfs_engine.mvcc.{
    MvccTable, MvccTxnManager, MvccSnapshot
}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# ============================================================================
# Constants
# ============================================================================

val BENCH_N: i64 = 100

# ============================================================================
# Integer-to-text helper (no import to avoid cycle)
# ============================================================================

fn _i64_to_text_local(n: i64) -> text:
    if n == 0:
        return "0"
    var digits: [text] = []
    var v = n
    val negative = v < 0
    if negative:
        v = 0 - v
    while v > 0:
        val d = v % 10
        val ch: text = if d == 0: "0"
            elif d == 1: "1"
            elif d == 2: "2"
            elif d == 3: "3"
            elif d == 4: "4"
            elif d == 5: "5"
            elif d == 6: "6"
            elif d == 7: "7"
            elif d == 8: "8"
            else: "9"
        digits.push(ch)
        v = v / 10
    var result = if negative: "-" else: ""
    var di: i64 = digits.len() - 1
    while di >= 0:
        result = result + digits[di]
        di = di - 1
    result

# ============================================================================
# Inline markdown emit
# ============================================================================

fn _join_lines(lines: [text]) -> text:
    var result = ""
    var i: i64 = 0
    while i < lines.len():
        if i > 0:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result

fn _emit_docs(names: [text], modes: [text], metrics: [text], values: [i64], units: [text], arch: text, date_str: text, report_path: text, table_path: text) -> bool:
    rt_dir_create_all("doc/09_report/perf")
    rt_dir_create_all("doc/10_metrics/perf")

    var table_lines: [text] = []
    table_lines.push("| name | mode | metric | value | unit | arch |")
    table_lines.push("|------|------|--------|------:|------|------|")
    var ti: i64 = 0
    while ti < names.len():
        val row = "| " + names[ti] + " | " + modes[ti] + " | " + metrics[ti] + " | " + _i64_to_text_local(values[ti]) + " | " + units[ti] + " | " + arch + " |"
        table_lines.push(row)
        ti = ti + 1
    val table_block = _join_lines(table_lines)

    var report_parts: [text] = []
    report_parts.push("# DB Benchmark Run")
    report_parts.push("")
    report_parts.push("Date: " + date_str)
    report_parts.push("")
    report_parts.push("## Results")
    report_parts.push("")
    report_parts.push(table_block)
    report_parts.push("")
    report_parts.push("## Omitted rows (interpreter mode limitations)")
    report_parts.push("")
    report_parts.push("- **ram**: OMITTED — interp_cross_module_struct_return_unit_2026-06-13: PureDatabase.memory() struct return is None in interpreter; passes compiled (bin/simple test 13/13).")
    report_parts.push("- **persistent**: OMITTED — same interp_cross_module_struct_return_unit_2026-06-13 bug.")
    report_parts.push("- **wal**: OMITTED — interp_cross_module_struct_mutation_loss: MvccTable.insert/commit mutations are lost across module boundary in interpreter; count_visible returns 0 instead of N. Passes compiled (bin/simple test 13/13).")
    report_parts.push("")
    report_parts.push("All three modes pass via `bin/simple test` (compiled mode). Numbers will be recorded when interpreter cross-module struct bugs are fixed.")
    report_parts.push("")
    report_parts.push("---")
    report_parts.push("*Generated by db_bench_driver.spl*")
    val report_md = _join_lines(report_parts)

    val report_ok = rt_file_write_text(report_path, report_md)
    if report_ok:
        print("db_bench_driver: wrote report -> " + report_path)
    else:
        print("db_bench_driver: ERROR writing report -> " + report_path)

    var append_parts: [text] = []
    append_parts.push("## Run: " + date_str)
    append_parts.push("")
    append_parts.push(table_block)
    append_parts.push("")
    val append_block = _join_lines(append_parts)

    var existing = ""
    val tbl_exists = rt_file_exists(table_path)
    if tbl_exists:
        existing = rt_file_read_text(table_path)
    val new_content = existing + "\n" + append_block
    val table_ok = rt_file_write_text(table_path, new_content)
    if table_ok:
        print("db_bench_driver: updated metrics -> " + table_path)
    else:
        print("db_bench_driver: ERROR writing metrics -> " + table_path)

    report_ok and table_ok

# ============================================================================
# Helpers — RAM config (PureDatabase.memory)
# NOTE: omitted in interpreter mode — kept for compiled/future use
# ============================================================================

fn run_ram_insert_count() -> i64:
    val r = PureDatabase.memory()
    if r.is_err():
        return -1
    var db = r.unwrap()
    val cr = db.exec_sql("CREATE TABLE bench (id INTEGER, val TEXT)")
    if cr.is_err():
        return -2
    var i: i64 = 0
    while i < BENCH_N:
        val v = "val_" + (i * 10).to_text()
        val sql = "INSERT INTO bench (id, val) VALUES (" + i.to_text() + ", '" + v + "')"
        val ir = db.exec_sql(sql)
        if ir.is_err():
            return -3
        i = i + 1
    val qr = db.query("SELECT * FROM bench", [])
    if qr.is_err():
        return -4
    val rows = qr.unwrap()
    rows.len()

fn run_ram_timing_us() -> i64:
    val t0 = rt_time_now_unix_micros()
    val n = run_ram_insert_count()
    val t1 = rt_time_now_unix_micros()
    if n < 0:
        return -1
    t1 - t0

# ============================================================================
# Helpers — persistent config (PureDatabase.open_deferred + checkpoint)
# NOTE: omitted in interpreter mode — kept for compiled/future use
# ============================================================================

fn run_persistent_insert_count(db_path: text) -> i64:
    val r = PureDatabase.open_deferred(db_path)
    if r.is_err():
        return -1
    var db = r.unwrap()
    val cr = db.exec_sql("CREATE TABLE bench (id INTEGER, val TEXT)")
    if cr.is_err():
        return -2
    var i: i64 = 0
    while i < BENCH_N:
        val v = "val_" + (i * 10).to_text()
        val sql = "INSERT INTO bench (id, val) VALUES (" + i.to_text() + ", '" + v + "')"
        val ir = db.exec_sql(sql)
        if ir.is_err():
            return -3
        i = i + 1
    val ck = db.checkpoint()
    if ck.is_err():
        return -4
    val qr = db.query("SELECT * FROM bench", [])
    if qr.is_err():
        return -5
    val rows = qr.unwrap()
    rows.len()

fn run_persistent_timing_us(db_path: text) -> i64:
    val t0 = rt_time_now_unix_micros()
    val n = run_persistent_insert_count(db_path)
    val t1 = rt_time_now_unix_micros()
    if n < 0:
        return -1
    t1 - t0

# ============================================================================
# Helpers — WAL config (MvccTable in-process MVCC core)
# NOTE: omitted in interpreter mode — cross-module mutation loss
# Disk-WAL replay also has P0 blank-row bug (simple-db-hardening).
# ============================================================================

fn run_wal_insert_count() -> i64:
    var tbl = MvccTable.new()
    var mgr = MvccTxnManager.new()
    var i: i64 = 0
    while i < BENCH_N:
        val h = mgr.begin()
        val tid = h.txn_id
        val data = i.to_text() + "|val_" + (i * 10).to_text()
        tbl.insert(tid, data)
        mgr.commit(tid)
        i = i + 1
    val snap = mgr.snapshot()
    tbl.count_visible(snap)

fn run_wal_timing_us() -> i64:
    val t0 = rt_time_now_unix_micros()
    val n = run_wal_insert_count()
    val t1 = rt_time_now_unix_micros()
    if n < 0:
        return -1
    t1 - t0

# ============================================================================
# main
# ============================================================================

fn main():
    val date_str = "2026-06-13"
    val arch = "x86_64"

    val report_path = "doc/09_report/perf/perf_baseline_db_2026-06-13.md"
    val table_path  = "doc/10_metrics/perf/perf_baseline_db_table.md"

    rt_dir_create_all("/tmp/bench_db")

    var names:   [text] = []
    var modes:   [text] = []
    var metrics: [text] = []
    var values:  [i64]  = []
    var units:   [text] = []

    # --- Mode: ram ---
    # FIXED: interp_run_cross_module_db_option_mutation_2026-06-13 (interpreter
    # `==`/`!=` now bridge the nil literal and Option::None). PureDatabase.memory()
    # + insert + scan now run in interpreter/script mode.
    val ram_us = run_ram_timing_us()
    if ram_us >= 0:
        names.push("db_ram_insert100")
        modes.push("script")
        metrics.push("insert+scan")
        values.push(ram_us)
        units.push("us")
        print("ram: {ram_us} us (100 inserts + scan)")
    else:
        print("ram: OMITTED — run_ram_timing_us() returned {ram_us}")

    # --- Mode: persistent ---
    # FIXED by interp_run_cross_module_db_option_mutation_2026-06-13 (same
    # exec_sql/sql_parser path as ram). open_deferred + insert + scan run in
    # interpreter/script mode.
    val pdb_path = "/tmp/db_bench_persistent.db"
    val persist_us = run_persistent_timing_us(pdb_path)
    if persist_us >= 0:
        names.push("db_persistent_insert100")
        modes.push("script")
        metrics.push("insert+scan")
        values.push(persist_us)
        units.push("us")
        print("persistent: {persist_us} us (100 inserts + scan)")
    else:
        print("persistent: OMITTED — run_persistent_timing_us() returned {persist_us}")

    # --- Mode: wal ---
    # OMITTED: SEPARATE bug — the in-process MVCC core hits "Function
    # 'Array.remove' not found" in the interpreter (a missing builtin method),
    # so count_visible returns 0 (not 100). This is NOT the nil/Option bug fixed
    # above; it is a distinct missing-interpreter-method issue.
    # WAL tests pass under bin/simple test (compiled mode).
    print("wal: OMITTED — interpreter lacks Array.remove (MvccTable count_visible returns 0; separate from the now-fixed nil/Option bug)")
    print("  Note: all three modes pass via bin/simple test compiled mode (13/13)")

    # Emit doc even with zero rows — records the omission reasons
    print("Writing benchmark docs ...")
    val ok = _emit_docs(names, modes, metrics, values, units, arch, date_str, report_path, table_path)
    if ok:
        print("Done. Both docs written.")
    else:
        print("ERROR: one or both docs failed to write.")
