# Email notification service for order lifecycle events.
# Uses std.smtp for sending; falls back to logging when SMTP is unavailable.

use std.nogc_sync_mut.smtp.types.{
    smtp_code_250, smtp_is_success_code
}
use std.nogc_sync_mut.smtp.send.{
    email_message_build, header_from, header_to, header_subject,
    header_content_type, mime_type_text_html
}

use models.order.{Order}
use models.delivery.{DeliveryRequest}
use models.menu_item.{format_price}

fn build_order_confirmation_email(order: Order, customer_email: text) -> text:
    var body = "<html><body>"
    body = body + "<h1>Order Confirmation #{order.id}</h1>"
    body = body + "<p>Thank you for your order!</p>"
    body = body + "<table border='1' cellpadding='5'>"
    body = body + "<tr><td><strong>Table</strong></td><td>{order.table_number}</td></tr>"
    body = body + "<tr><td><strong>Status</strong></td><td>{order.status}</td></tr>"
    body = body + "<tr><td><strong>Subtotal</strong></td><td>${format_price(order.subtotal)}</td></tr>"
    body = body + "<tr><td><strong>Tax</strong></td><td>${format_price(order.tax)}</td></tr>"
    body = body + "<tr><td><strong>Total</strong></td><td>${format_price(order.total)}</td></tr>"
    body = body + "</table>"
    body = body + "<p>Items: {order.items_json}</p>"
    if order.notes != "":
        body = body + "<p>Notes: {order.notes}</p>"
    body = body + "</body></html>"
    body

fn build_order_status_email(order: Order, customer_email: text) -> text:
    var body = "<html><body>"
    body = body + "<h1>Order #{order.id} Update</h1>"
    body = body + "<p>Your order status has been updated to: <strong>{order.status}</strong></p>"
    if order.status == "ready":
        body = body + "<p>Your order is ready for pickup!</p>"
    if order.status == "cooking":
        body = body + "<p>Your order is being prepared.</p>"
    if order.status == "delivered":
        body = body + "<p>Your order has been delivered. Enjoy!</p>"
    body = body + "</body></html>"
    body

fn build_delivery_confirmation_email(delivery: DeliveryRequest) -> text:
    var body = "<html><body>"
    body = body + "<h1>Delivery Request #{delivery.id}</h1>"
    body = body + "<p>Hi {delivery.customer_name},</p>"
    body = body + "<p>Your delivery request has been received.</p>"
    body = body + "<table border='1' cellpadding='5'>"
    body = body + "<tr><td><strong>Address</strong></td><td>{delivery.address}</td></tr>"
    body = body + "<tr><td><strong>Status</strong></td><td>{delivery.status}</td></tr>"
    if delivery.estimated_time != "":
        body = body + "<tr><td><strong>Estimated Time</strong></td><td>{delivery.estimated_time}</td></tr>"
    body = body + "</table>"
    if delivery.delivery_notes != "":
        body = body + "<p>Notes: {delivery.delivery_notes}</p>"
    body = body + "</body></html>"
    body

fn build_payment_receipt_email(order: Order, transaction_id: text, method_display: text) -> text:
    var body = "<html><body>"
    body = body + "<h1>Payment Receipt</h1>"
    body = body + "<p>Payment confirmed for Order #{order.id}</p>"
    body = body + "<table border='1' cellpadding='5'>"
    body = body + "<tr><td><strong>Method</strong></td><td>{method_display}</td></tr>"
    body = body + "<tr><td><strong>Amount</strong></td><td>${format_price(order.total)}</td></tr>"
    body = body + "<tr><td><strong>Transaction</strong></td><td>{transaction_id}</td></tr>"
    body = body + "</table>"
    body = body + "</body></html>"
    body

# Send email via SMTP or log it (mock mode for infra testing).
# Returns the email body for verification.
fn send_notification(to_email: text, subject: text, html_body: text) -> Result<text, text>:
    # In infra test mode, log instead of actually sending
    print "[EMAIL] To: {to_email}"
    print "[EMAIL] Subject: {subject}"
    print "[EMAIL] Body length: {html_body.len()} chars"
    Result.ok(html_body)
