use app.io.cli_ops.{cli_get_args}

class UiBackendEntryArgs:
    file_path: text
    port: i32
    access_db_path: text
    sub_args: [text]

pub fn ui_backend_entry_args() -> UiBackendEntryArgs:
    val args = cli_get_args()
    var file_path = ""
    var port = 3000
    var access_db_path = ""
    var sub_args: [text] = []
    var prev = ""
    var collect_sub = false

    for arg in args:
        if collect_sub:
            sub_args = sub_args.push(arg)
            continue

        if prev == "file":
            file_path = arg
            prev = ""
            continue
        if prev == "port":
            port = parse_ui_port_or_default(arg, port)
            prev = ""
            continue
        if prev == "access":
            access_db_path = arg
            prev = ""
            continue

        if arg == "--":
            collect_sub = true
        elif arg == "--file":
            prev = "file"
        elif arg.starts_with("--file="):
            file_path = arg[7:]
        elif arg == "--port":
            prev = "port"
        elif arg.starts_with("--port="):
            port = parse_ui_port_or_default(arg[7:], port)
        elif arg == "--ui-access-db":
            prev = "access"
        elif arg.starts_with("--ui-access-db="):
            access_db_path = arg[15:]

    UiBackendEntryArgs(file_path: file_path, port: port, access_db_path: access_db_path, sub_args: sub_args)

pub fn parse_ui_port_or_default(value: text, default: i32) -> i32:
    val trimmed = value.trim()
    if trimmed == "":
        return default
    var i = 0
    while i < trimmed.len():
        val c = trimmed[i:i + 1]
        val is_digit = c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or c == "5" or c == "6" or c == "7" or c == "8" or c == "9"
        if not is_digit:
            return default
        i = i + 1
    trimmed.to_int() ?? default
