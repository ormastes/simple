# x86_64 Boot Adapter
#
# Thin wrapper layer over the concrete x86_64 Limine boot module.

use os.kernel.boot.ports.{BootOutputPort}
use os.kernel.arch.x86_64.boot.{X86Boot}

fn boot_parse_boot_info() -> BootOutputPort:
    """Parse x86_64 bootloader state into BootOutputPort."""
    var boot = X86Boot()
    boot.parse_hhdm()
    boot.build_boot_output()

