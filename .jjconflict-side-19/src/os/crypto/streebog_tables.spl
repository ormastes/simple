# ---------------------------------------------------------------------------
# Round constants C[0..11] — GOST R 34.11-2012 §A.2.1.
# These are fixed 64-byte constants (not derived at runtime).
# Taken from gostcrypto reference implementation _C table.
# ---------------------------------------------------------------------------

fn _round_key_byte(round: i64, byte_idx: i64) -> i64:
    # Returns byte `byte_idx` of round constant C[round].
    # Tables stored in forward (little-endian) byte order matching gostcrypto.
    val idx = byte_idx
    # C[0]:
    if round == 0:
        if idx == 0: 0x07  else if idx == 1: 0x45  else if idx == 2: 0xA6  else if idx == 3: 0xF2
        else if idx == 4: 0x59  else if idx == 5: 0x65  else if idx == 6: 0x80  else if idx == 7: 0xDD
        else if idx == 8: 0x23  else if idx == 9: 0x4D  else if idx == 10: 0x74  else if idx == 11: 0xCC
        else if idx == 12: 0x36  else if idx == 13: 0x74  else if idx == 14: 0x76  else if idx == 15: 0x05
        else if idx == 16: 0x15  else if idx == 17: 0xD3  else if idx == 18: 0x60  else if idx == 19: 0xA4
        else if idx == 20: 0x08  else if idx == 21: 0x2A  else if idx == 22: 0x42  else if idx == 23: 0xA2
        else if idx == 24: 0x01  else if idx == 25: 0x69  else if idx == 26: 0x67  else if idx == 27: 0x92
        else if idx == 28: 0x91  else if idx == 29: 0xE0  else if idx == 30: 0x7C  else if idx == 31: 0x4B
        else if idx == 32: 0xFC  else if idx == 33: 0xC4  else if idx == 34: 0x85  else if idx == 35: 0x75
        else if idx == 36: 0x8D  else if idx == 37: 0xB8  else if idx == 38: 0x4E  else if idx == 39: 0x71
        else if idx == 40: 0x16  else if idx == 41: 0xD0  else if idx == 42: 0x45  else if idx == 43: 0x2E
        else if idx == 44: 0x43  else if idx == 45: 0x76  else if idx == 46: 0x6A  else if idx == 47: 0x2F
        else if idx == 48: 0x1F  else if idx == 49: 0x7C  else if idx == 50: 0x65  else if idx == 51: 0xC0
        else if idx == 52: 0x81  else if idx == 53: 0x2F  else if idx == 54: 0xCB  else if idx == 55: 0xEB
        else if idx == 56: 0xE9  else if idx == 57: 0xDA  else if idx == 58: 0xCA  else if idx == 59: 0x1E
        else if idx == 60: 0xDA  else if idx == 61: 0x5B  else if idx == 62: 0x08  else: 0xB1
    # C[1]:
    else if round == 1:
        if idx == 0: 0xB7  else if idx == 1: 0x9B  else if idx == 2: 0xB1  else if idx == 3: 0x21
        else if idx == 4: 0x70  else if idx == 5: 0x04  else if idx == 6: 0x79  else if idx == 7: 0xE6
        else if idx == 8: 0x56  else if idx == 9: 0xCD  else if idx == 10: 0xCB  else if idx == 11: 0xD7
