        else if idx == 24: 0x37  else if idx == 25: 0x2C  else if idx == 26: 0x82  else if idx == 27: 0x2D
        else if idx == 28: 0xC5  else if idx == 29: 0xAB  else if idx == 30: 0x92  else if idx == 31: 0x09
