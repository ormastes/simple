        else if idx == 56: 0xC7  else if idx == 57: 0x2F  else if idx == 58: 0xCE  else if idx == 59: 0x2B
        else if idx == 60: 0xAC  else if idx == 61: 0xDC  else if idx == 62: 0x74  else: 0xF5
    # C[3]:
    else if round == 3:
        if idx == 0: 0x2E  else if idx == 1: 0xD1  else if idx == 2: 0xE3  else if idx == 3: 0x84
        else if idx == 4: 0xBC  else if idx == 5: 0xBE  else if idx == 6: 0x0C  else if idx == 7: 0x22
        else if idx == 8: 0xF1  else if idx == 9: 0x37  else if idx == 10: 0xE8  else if idx == 11: 0x93
