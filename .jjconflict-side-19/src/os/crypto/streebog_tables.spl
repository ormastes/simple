        else if idx == 20: 0xC2  else if idx == 21: 0x61  else if idx == 22: 0xB5  else if idx == 23: 0x5C
        else if idx == 24: 0x58  else if idx == 25: 0x99  else if idx == 26: 0xD6  else if idx == 27: 0x12
        else if idx == 28: 0x6B  else if idx == 29: 0x17  else if idx == 30: 0xB5  else if idx == 31: 0x9A
        else if idx == 32: 0x31  else if idx == 33: 0x01  else if idx == 34: 0xB5  else if idx == 35: 0x16
        else if idx == 36: 0x0F  else if idx == 37: 0x5E  else if idx == 38: 0xD5  else if idx == 39: 0x61
        else if idx == 40: 0x98  else if idx == 41: 0x2B  else if idx == 42: 0x23  else if idx == 43: 0x0A
        else if idx == 44: 0x72  else if idx == 45: 0xEA  else if idx == 46: 0xFE  else if idx == 47: 0xF3
        else if idx == 48: 0xD7  else if idx == 49: 0xB5  else if idx == 50: 0x70  else if idx == 51: 0x0F
        else if idx == 52: 0x46  else if idx == 53: 0x9D  else if idx == 54: 0xE3  else if idx == 55: 0x4F
        else if idx == 56: 0x1A  else if idx == 57: 0x2F  else if idx == 58: 0x9D  else if idx == 59: 0xA9
        else if idx == 60: 0x8A  else if idx == 61: 0xB5  else if idx == 62: 0xA3  else: 0x6F
    # C[2]:
    else if round == 2:
        if idx == 0: 0xB2  else if idx == 1: 0x0A  else if idx == 2: 0xBA  else if idx == 3: 0x0A
