        else if idx == 32: 0x3F  else if idx == 33: 0x35  else if idx == 34: 0x5E  else if idx == 35: 0x68
        else if idx == 36: 0xAD  else if idx == 37: 0x1C  else if idx == 38: 0x72  else if idx == 39: 0x9D
        else if idx == 40: 0x7D  else if idx == 41: 0x3C  else if idx == 42: 0x5C  else if idx == 43: 0x33
        else if idx == 44: 0x7E  else if idx == 45: 0x85  else if idx == 46: 0x8E  else if idx == 47: 0x48
        else if idx == 48: 0xDD  else if idx == 49: 0xE4  else if idx == 50: 0x71  else if idx == 51: 0x5D
        else if idx == 52: 0xA0  else if idx == 53: 0xE1  else if idx == 54: 0x48  else if idx == 55: 0xF9
        else if idx == 56: 0xD2  else if idx == 57: 0x66  else if idx == 58: 0x15  else if idx == 59: 0xE8
        else if idx == 60: 0xB3  else if idx == 61: 0xDF  else if idx == 62: 0x1F  else: 0xEF
    # C[4]:
    else if round == 4:
        if idx == 0: 0x57  else if idx == 1: 0xFE  else if idx == 2: 0x6C  else if idx == 3: 0x7C
        else if idx == 4: 0xFD  else if idx == 5: 0x58  else if idx == 6: 0x17  else if idx == 7: 0x60
        else if idx == 8: 0xF5  else if idx == 9: 0x63  else if idx == 10: 0xEA  else if idx == 11: 0xA9
        else if idx == 12: 0x7E  else if idx == 13: 0xA2  else if idx == 14: 0x56  else if idx == 15: 0x7A
        else if idx == 16: 0x16  else if idx == 17: 0x1A  else if idx == 18: 0x27  else if idx == 19: 0x23
        else if idx == 20: 0xB7  else if idx == 21: 0x00  else if idx == 22: 0xFF  else if idx == 23: 0xDF
        else if idx == 24: 0xA3  else if idx == 25: 0xF5  else if idx == 26: 0x3A  else if idx == 27: 0x25
        else if idx == 28: 0x47  else if idx == 29: 0x17  else if idx == 30: 0xCD  else if idx == 31: 0xBF
        else if idx == 32: 0xBD  else if idx == 33: 0xFF  else if idx == 34: 0x0F  else if idx == 35: 0x80
        else if idx == 36: 0xD7  else if idx == 37: 0x35  else if idx == 38: 0x9E  else if idx == 39: 0x35
        else if idx == 40: 0x4A  else if idx == 41: 0x10  else if idx == 42: 0x86  else if idx == 43: 0x16
        else if idx == 44: 0x1F  else if idx == 45: 0x1C  else if idx == 46: 0x15  else if idx == 47: 0x7F
        else if idx == 48: 0x63  else if idx == 49: 0x23  else if idx == 50: 0xA9  else if idx == 51: 0x6C
        else if idx == 52: 0x0C  else if idx == 53: 0x41  else if idx == 54: 0x3F  else if idx == 55: 0x9A
        else if idx == 56: 0x99  else if idx == 57: 0x47  else if idx == 58: 0x47  else if idx == 59: 0xAD
        else if idx == 60: 0xAC  else if idx == 61: 0x6B  else if idx == 62: 0xEA  else: 0x4B
    # C[5]:
    else if round == 5:
        if idx == 0: 0x6E  else if idx == 1: 0x7D  else if idx == 2: 0x64  else if idx == 3: 0x46
