# Visual Scripting — node-based execution graph

struct VisualPort:
    name: text
    port_type: text
    direction: text
    value: text

struct VisualNode:
    id: i32
    node_type: text
    name: text
    inputs: [VisualPort]
    outputs: [VisualPort]
    position_x: f64
    position_y: f64

impl VisualNode:
    static fn new(id: i32, node_type: text, name: text) -> VisualNode:
        VisualNode(
            id: id, node_type: node_type, name: name,
            inputs: [], outputs: [],
            position_x: 0.0, position_y: 0.0
        )

    me add_input(name: text, port_type: text):
        val p = VisualPort(name: name, port_type: port_type, direction: "input", value: "")
        self.inputs.push(p)

    me add_output(name: text, port_type: text):
        val p = VisualPort(name: name, port_type: port_type, direction: "output", value: "")
        self.outputs.push(p)

    fn input_count() -> i32:
        self.inputs.len().to_i32()

    fn output_count() -> i32:
        self.outputs.len().to_i32()

struct VisualConnection:
    from_node: i32
    from_port: text
    to_node: i32
    to_port: text

class VisualGraph:
    name: text
    nodes: [VisualNode]
    connections: [VisualConnection]
    next_id: i32

impl VisualGraph:
    static fn new(name: text) -> VisualGraph:
        VisualGraph(name: name, nodes: [], connections: [], next_id: 1)

    me add_node(node_type: text, name: text) -> i32:
        val nid = self.next_id
        self.next_id = self.next_id + 1
        var node = VisualNode.new(nid, node_type, name)
        self.nodes.push(node)
        nid

    me connect(from_node: i32, from_port: text, to_node: i32, to_port: text) -> bool:
        val conn = VisualConnection(
            from_node: from_node, from_port: from_port,
            to_node: to_node, to_port: to_port
        )
        self.connections.push(conn)
        true

    me disconnect(from_node: i32, to_node: i32) -> bool:
        var new_conns: [VisualConnection] = []
        var removed = false
        var i = 0
        while i < self.connections.len():
            val c = self.connections[i]
            if c.from_node == from_node and c.to_node == to_node:
                removed = true
            else:
                new_conns.push(c)
            i = i + 1
        self.connections = new_conns
        removed

    fn get_node(node_id: i32) -> VisualNode?:
        var i = 0
        while i < self.nodes.len():
            if self.nodes[i].id == node_id:
                return self.nodes[i]
            i = i + 1
        nil

    fn node_count() -> i32:
        self.nodes.len().to_i32()

    fn connection_count() -> i32:
        self.connections.len().to_i32()

    fn get_connections_to(node_id: i32) -> [VisualConnection]:
        var result: [VisualConnection] = []
        var i = 0
        while i < self.connections.len():
            if self.connections[i].to_node == node_id:
                result.push(self.connections[i])
            i = i + 1
        result

    me clear():
        self.nodes = []
        self.connections = []
        self.next_id = 1
