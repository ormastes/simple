#[runtime_intrinsics]
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text?
extern fn rt_file_read_bytes(path: text) -> [u8]?

pub fn browser_file_write_text(path: text, content: text) -> bool:
    browser_file_runtime_write_text(path, content)

pub fn browser_file_read_text(path: text) -> text?:
    browser_file_runtime_read_text(path)

pub fn browser_file_read_bytes(path: text) -> [u8]?:
    browser_file_runtime_read_bytes(path)

fn browser_file_runtime_write_text(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn browser_file_runtime_read_text(path: text) -> text?:
    rt_file_read_text(path)

fn browser_file_runtime_read_bytes(path: text) -> [u8]?:
    rt_file_read_bytes(path)
