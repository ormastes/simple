"""
# JS AST Types

JavaScript AST node types for the browser engine JS parser.
Based on ESTree/SpiderMonkey spec, covering the ES5 subset:
expressions, statements, and function declarations.
"""

#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

# =========================================================================
# Unary / Binary / Assignment operator tags
# =========================================================================

pub enum JsUnaryOp:
    """Unary operators."""
    Neg        # -x
    Pos        # +x
    Not        # !x
    BitNot     # ~x
    TypeOf     # typeof x
    Void       # void x

pub enum JsBinOp:
    """Binary operators."""
    Add        # +
    Sub        # -
    Mul        # *
    Div        # /
    Mod        # %
    Eq         # ==
    Neq        # !=
    StrictEq   # ===
    StrictNeq  # !==
    Lt         # <
    Gt         # >
    Le         # <=
    Ge         # >=
    And        # &&
    Or         # ||
    BitAnd     # &
    BitOr      # |
    BitXor     # ^
    Shl        # <<
    Shr        # >>
    UShr       # >>>
    In         # in
    InstanceOf # instanceof

pub enum JsAssignOp:
    """Assignment operators."""
    Assign     # =
    AddAssign  # +=
    SubAssign  # -=
    MulAssign  # *=
    DivAssign  # /=
    ModAssign  # %=

# =========================================================================
# Expressions
# =========================================================================

pub enum JsExpr:
    """A JavaScript expression node."""
    NumLit(value: f64)
    StrLit(value: text)
    BoolLit(value: bool)
    NullLit
    UndefinedLit
    Ident(name: text)
    This
    Unary(op: JsUnaryOp, operand: JsExpr)
    Binary(op: JsBinOp, left: JsExpr, right: JsExpr)
    Assign(op: JsAssignOp, target: JsExpr, value: JsExpr)
    Conditional(test: JsExpr, consequent: JsExpr, alternate: JsExpr)
    Call(callee: JsExpr, args: [JsExpr])
    MemberDot(object: JsExpr, property: text)
    MemberBracket(object: JsExpr, property: JsExpr)
    NewExpr(callee: JsExpr, args: [JsExpr])
    Array(elements: [JsExpr])
    ObjectExpr(keys: [text], values: [JsExpr])
    FuncExpr(name: text, params: [text], body: [JsStmt])
    Sequence(exprs: [JsExpr])
    Update(op: text, prefix: bool, argument: JsExpr)
    Typeof(argument: JsExpr)

# =========================================================================
# Statements
# =========================================================================

pub enum JsStmt:
    """A JavaScript statement node."""
    ExprStmt(expr: JsExpr)
    VarDecl(kind: text, name: text, init: JsExpr?)
    Block(body: [JsStmt])
    IfStmt(test: JsExpr, consequent: JsStmt, alternate: JsStmt?)
    WhileStmt(test: JsExpr, body: JsStmt)
    DoWhileStmt(test: JsExpr, body: JsStmt)
    ForStmt(init: JsStmt?, test: JsExpr?, update: JsExpr?, body: JsStmt)
    ForInStmt(left: text, right: JsExpr, body: JsStmt)
    ReturnStmt(value: JsExpr?)
    BreakStmt
    ContinueStmt
    ThrowStmt(value: JsExpr)
    TryCatch(body: JsStmt, catch_param: text, catch_body: JsStmt, finally_body: JsStmt?)
    SwitchStmt(discriminant: JsExpr, cases: [JsSwitchCase])
    FuncDecl(name: text, params: [text], body: [JsStmt])
    EmptyStmt
    DebuggerStmt

# =========================================================================
# Switch case
# =========================================================================

pub class JsSwitchCase:
    """A single case clause in a switch statement."""
    test: JsExpr?
    body: [JsStmt]

    static fn new(test: JsExpr?, body: [JsStmt]) -> JsSwitchCase:
        """Create a switch case. test=nil means default case."""
        JsSwitchCase(test: test, body: body)

# =========================================================================
# Program (top-level)
# =========================================================================

pub class JsProgram:
    """A parsed JavaScript program — a list of statements."""
    body: [JsStmt]

    static fn new(body: [JsStmt]) -> JsProgram:
        """Create a program from a list of statements."""
        JsProgram(body: body)

    static fn empty() -> JsProgram:
        """Create an empty program."""
        JsProgram(body: [])
