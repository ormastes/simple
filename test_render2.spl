use common.ui.parse.sdn.{read_file, parse_to_flat, parse_and_render, flat_get}

fn main():
    val source = read_file("examples/ui/demo.ui.sdn")
    val entries = parse_to_flat(source)
    val title = flat_get(entries, "app.title")
    print "Title: {title}"
    print "Entries count: {entries.len()}"
