use common.ui.widget.{WidgetNode, UITree}

fn main():
    var node = WidgetNode.new("test", "panel")
    print "Node created"
    node = node.set_layout("vbox")
    print "Layout set"
    node = node.set_prop("title", "Hello")
    print "Prop set"
    val child = WidgetNode.new("child1", "text")
    node = node.add_child(child)
    print "Child added"
    var tree = UITree.new(node)
    print "Tree: {tree}"
    tree = tree.with_title("My App")
    print "Title set: {tree}"
