#!/bin/bash
# Simple MCP Server — npm wrapper
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/simple"
if [ ! -x "$RUNTIME" ]; then
    echo "Error: Simple compiler binary not found. Run 'npm rebuild @simple-lang/mcp-server'" >&2
    exit 1
fi
SIMPLE_LOG=error RUST_LOG=error exec "$RUNTIME" run "$(dirname "$SCRIPT_DIR")/../src/app/mcp/main.spl" "$@"
