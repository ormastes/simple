#!/bin/bash
# T32 LSP MCP Server — npm wrapper
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="${SCRIPT_DIR}/simple"
if [ ! -x "$RUNTIME" ]; then
    echo "Error: Simple compiler binary not found. Run 'npm rebuild @simple-lang/t32-lsp-mcp-server'" >&2
    exit 1
fi
PKG_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SIMPLE_LOG=error RUST_LOG=error exec "$RUNTIME" run "${PKG_ROOT}/t32_lsp_mcp/main.spl" "$@"
