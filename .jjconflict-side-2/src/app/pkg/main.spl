# Package Manager - CLI Entry Point
#
# Subcommands:
#   pkg install     Install all dependencies from package.sdn
#   pkg add <name>  Add a dependency
#   pkg remove <n>  Remove a dependency
#   pkg init        Create a new package.sdn
#
# Usage: simple pkg <subcommand> [options]

use app.pkg.install.{do_install, do_add, do_remove}
use app.pkg.manifest.{generate_manifest}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# Get current working directory
fn pkg_cwd() -> text:
    val os = rt_env_get("OS")
    var is_windows = false
    if os != nil and os != "":
        is_windows = os.lower().contains("windows")
    var cmd = "pwd"
    if is_windows:
        cmd = "cd"
    val (out, _, _) = if is_windows:
        rt_process_run("cmd.exe", ["/c", cmd])
    else:
        rt_process_run("/bin/sh", ["-c", cmd])
    out.trim()

fn print_help():
    print "Simple Package Manager"
    print ""
    print "Usage: simple pkg <command> [options]"
    print ""
    print "Commands:"
    print "  init                  Create a new package.sdn"
    print "  install               Install all dependencies"
    print "  add <package>         Add a dependency"
    print "  remove <package>      Remove a dependency"
    print ""
    print "Install options:"
    print "  --json               Output as JSON"
    print "  --frozen              Only install from lock file"
    print "  --dry-run             Show what would be installed"
    print "  --dev                 Include dev dependencies"
    for line in log_options_help():
        print "  {line}"
    print ""
    print "Add options:"
    print "  --git=<url>           Add as git dependency"
    print "  --branch=<name>       Git branch (default: main)"
    print "  --tag=<name>          Git tag"
    print "  --path=<dir>          Add as path dependency"
    print "  --dev                 Add as dev dependency"
    print ""
    print "Examples:"
    print "  simple pkg init"
    print "  simple pkg add mylib --git=https://github.com/user/mylib"
    print "  simple pkg add mylib --git=https://github.com/user/mylib --tag=v1.0.0"
    print "  simple pkg add utils --path=../utils"
    print "  simple pkg install"
    print "  simple pkg remove mylib"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _project_name(project_dir: text, name: text) -> text:
    if name != "":
        return name
    val parts = project_dir.split("/")
    if parts.len() > 0 and parts[parts.len() - 1] != "":
        return parts[parts.len() - 1]
    "my-project"

fn _write_manifest(path: text, content: text) -> bool:
    val escaped = content.replace("'", "'\"'\"'")
    val (_, _, code) = shell_run("cat > \"{path}\" <<'SIMPLE_PKG_MANIFEST'\n{escaped}\nSIMPLE_PKG_MANIFEST")
    code == 0

fn _do_init_json(project_dir: text, name: text) -> i64:
    val manifest_path = "{project_dir}/package.sdn"
    if rt_file_exists(manifest_path):
        error("pkg", "pkg init: package.sdn already exists")
        return 1
    val project_name = _project_name(project_dir, name)
    val content = generate_manifest(project_name, "0.1.0", "", "", "MIT")
    if not _write_manifest(manifest_path, content):
        error("pkg", "pkg init: failed to write package.sdn")
        return 1
    print "{\"command\":\"pkg init\",\"status\":\"ok\",\"name\":\"{project_name}\"}"
    0

fn _do_init_human(project_dir: text, name: text) -> i64:
    val manifest_path = "{project_dir}/package.sdn"
    if rt_file_exists(manifest_path):
        error("pkg", "pkg init: package.sdn already exists")
        return 1
    val project_name = _project_name(project_dir, name)
    val content = generate_manifest(project_name, "0.1.0", "", "", "MIT")
    if not _write_manifest(manifest_path, content):
        error("pkg", "pkg init: failed to write package.sdn")
        return 1
    print "Created package.sdn for '{project_name}'"
    0

fn _count_manifest_section(source: text, section: text) -> i64:
    val lines = source.split("\n")
    var in_section = false
    var count: i64 = 0
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "{section}:":
            in_section = true
        elif in_section and trimmed.ends_with(":") and not line.starts_with(" ") and not line.starts_with("\t"):
            in_section = false
        elif in_section and trimmed != "" and line.starts_with("    ") and trimmed.contains(":"):
            count = count + 1
    count

fn _print_install_dry_run_json(project_dir: text, include_dev: bool) -> i64:
    val manifest_path = "{project_dir}/package.sdn"
    if not rt_file_exists(manifest_path):
        error("pkg", "pkg install: no package.sdn found in {project_dir}")
        return 1

    val source = rt_file_read_text(manifest_path)
    val dep_count = _count_manifest_section(source, "dependencies")
    val dev_count = if include_dev: _count_manifest_section(source, "dev_dependencies") else: 0
    val total = dep_count + dev_count
    print "{\"command\":\"pkg install\",\"status\":\"ok\",\"dry_run\":true,\"dependencies\":{dep_count},\"dev_dependencies\":{dev_count},\"total\":{total}}"
    0

fn main() -> i64:
    # Parse args -- skip "pkg" command name
    # When invoked as `simple pkg ...`, the runtime passes args like:
    #   [binary, scriptpath, pkg, subcommand, ...]
    # cli_run_file gives us [pkg, subcommand, ...] in filtered_args
    # We need to extract subcommand from what we receive.

    # Use extern directly since we're an app entry point
    extern fn rt_cli_get_args() -> [text]
    val all_args = rt_cli_get_args()

    # Find "pkg" in args and get everything after it
    var args: [text] = []
    var found_pkg = false
    var i = 0
    while i < all_args.len():
        if found_pkg:
            args.push(all_args[i])
        elif all_args[i] == "pkg":
            found_pkg = true
        i = i + 1

    # If we didn't find "pkg" (e.g., called directly), take args after script path
    if not found_pkg:
        var start_idx = 1
        var scan_idx = 0
        while scan_idx < all_args.len():
            if all_args[scan_idx].ends_with("/app/pkg/main.spl") or all_args[scan_idx] == "src/app/pkg/main.spl":
                start_idx = scan_idx + 1
            scan_idx = scan_idx + 1
        i = start_idx
        while i < all_args.len():
            args.push(all_args[i])
            i = i + 1

    if args.len() == 0:
        print_help()
        return 0

    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("pkg", log_opts.error)
        return 1

    val subcommand = args[0]
    val sub_args = if args.len() > 1: args[1:] else: []
    var as_json = log_opts.log_mode == "json"

    val project_dir = pkg_cwd()

    match subcommand:
        case "help" | "-h" | "--help":
            print_help()
            return 0

        case "init":
            var name = ""
            var ai = 0
            while ai < sub_args.len():
                val arg = sub_args[ai]
                if not arg.starts_with("-"):
                    name = arg
                elif arg == "--json" or arg == "--log-mode=json":
                    as_json = true
                elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                    ai = ai + 1
                elif _is_log_option(arg):
                    pass
                ai = ai + 1
            if as_json:
                return _do_init_json(project_dir, name)
            if log_opts.progress != "summary":
                val progress_line = render_progress(log_opts.progress, 1, 1, "pkg init")
                if progress_line != "":
                    print progress_line
            return _do_init_human(project_dir, name)

        case "install" | "i":
            var frozen = false
            var dry_run = false
            var include_dev = false
            var ai = 0
            while ai < sub_args.len():
                val arg = sub_args[ai]
                if arg == "--frozen":
                    frozen = true
                elif arg == "--dry-run":
                    dry_run = true
                elif arg == "--dev":
                    include_dev = true
                elif arg == "--json" or arg == "--log-mode=json":
                    as_json = true
                elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                    ai = ai + 1
                elif _is_log_option(arg):
                    pass
                ai = ai + 1
            if as_json and dry_run:
                return _print_install_dry_run_json(project_dir, include_dev)
            if log_opts.progress != "summary":
                val progress_line = render_progress(log_opts.progress, 1, 1, "pkg install")
                if progress_line != "":
                    print progress_line
            return do_install(project_dir, frozen, dry_run, include_dev)

        case "add" | "a":
            var package_spec = ""
            var git_url = ""
            var git_branch = "main"
            var git_tag = ""
            var path_dep = ""
            var is_dev = false

            var ai = 0
            while ai < sub_args.len():
                val arg = sub_args[ai]
                if arg == "--dev":
                    is_dev = true
                elif arg.starts_with("--git="):
                    git_url = arg[6:]
                elif arg.starts_with("--branch="):
                    git_branch = arg[9:]
                elif arg.starts_with("--tag="):
                    git_tag = arg[6:]
                elif arg.starts_with("--path="):
                    path_dep = arg[7:]
                elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                    ai = ai + 1
                elif _is_log_option(arg):
                    pass
                elif not arg.starts_with("-"):
                    package_spec = arg
                ai = ai + 1

            if package_spec == "":
                print "pkg add: missing package name"
                print ""
                print "Usage: simple pkg add <package> [--git=<url>] [--tag=<tag>] [--path=<dir>] [--dev]"
                return 1

            return do_add(project_dir, package_spec, git_url, git_branch, git_tag, path_dep, is_dev)

        case "remove" | "rm":
            var package_name = ""
            var dev_only = false

            var ai = 0
            while ai < sub_args.len():
                val arg = sub_args[ai]
                if arg == "--dev":
                    dev_only = true
                elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                    ai = ai + 1
                elif _is_log_option(arg):
                    pass
                elif not arg.starts_with("-"):
                    package_name = arg
                ai = ai + 1

            if package_name == "":
                print "pkg remove: missing package name"
                print ""
                print "Usage: simple pkg remove <package> [--dev]"
                return 1

            return do_remove(project_dir, package_name, dev_only)

        case _:
            print "pkg: unknown command '{subcommand}'"
            print ""
            print_help()
            return 1
