# Export deterministic famous-site corpus HTML fixtures and manifest.

use std.nogc_sync_mut.ffi.io.{dir_create_all, file_write_text}
use app.wm_compare.site_corpus.{
    build_famous_site_sample_corpus,
    build_famous_site_sample_manifest_sdn,
    famous_site_sample_html_path,
    famous_site_sample_baseline_dir}

fn main() -> i64:
    val samples = build_famous_site_sample_corpus()
    dir_create_all("test/fixtures/famous_site_corpus")
    dir_create_all("test/baselines/famous_site_corpus")

    var written: i32 = 0
    for sample in samples:
        dir_create_all(famous_site_sample_baseline_dir(sample.id))
        if file_write_text(famous_site_sample_html_path(sample.id), sample.html):
            written = written + 1

    val manifest_path = "test/fixtures/famous_site_corpus/manifest.sdn"
    val manifest_ok = file_write_text(manifest_path, build_famous_site_sample_manifest_sdn())
    if not manifest_ok:
        print "[export_site_corpus] failed to write manifest"
        return 2
    if written != samples.len():
        print "[export_site_corpus] wrote {written}/{samples.len()} HTML fixtures"
        return 2
    print "[export_site_corpus] wrote {written} HTML fixtures and {manifest_path}"
    0
