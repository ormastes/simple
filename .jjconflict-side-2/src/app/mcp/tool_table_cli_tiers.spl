use .tool_registry

fn append_tool_table_cli_tiers(t: [McpToolEntry]) -> [McpToolEntry]:
    var out = t
    var e = tool_entry("", "", "", "", "", 0)

    e = tool_entry("simple_add", "[cli] Add dependency to project", "cli", "cli", "add", 30)
    e.props_json = build_props(["package", prop_str("package", "Package name to add"), "version", prop_str("version", "Version constraint"), "dev", prop_str("dev", "Add as dev dependency (true/false)")])
    e.required_json = build_required(["package"])
    e.open_world = true
    out.push(e)

    e = tool_entry("simple_remove", "[cli] Remove dependency from project", "cli", "cli", "remove", 30)
    e.props_json = build_props(["package", prop_str("package", "Package name to remove")])
    e.required_json = build_required(["package"])
    e.destructive = true
    out.push(e)

    e = tool_entry("simple_install", "[cli] Install project dependencies", "cli", "cli", "install", 120)
    e.open_world = true
    out.push(e)

    e = tool_entry("simple_info", "[cli] Show project or file info", "cli", "cli", "info", 30)
    e.props_json = build_props(["path", prop_str("path", "File or module path")])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_check_arch", "[cli] Check architecture constraints", "cli", "cli", "check-arch", 60)
    e.props_json = build_props(["path", prop_str("path", "Path to check")])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_todo_scan", "[cli] Scan and update TODO tracking", "cli", "cli", "todo-scan", 60)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_stats", "[cli] Show project statistics", "cli", "cli", "stats", 30)
    e.props_json = build_props(["format", prop_str("format", "Output format: text, json")])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_env", "[cli] Show environment info", "cli", "cli", "env", 10)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_duplicate_check", "[cli] Check for code duplication", "cli", "cli", "duplicate-check", 120)
    e.props_json = build_props(["path", prop_str("path", "Path to check")])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_desugar", "[cli] Show desugared source", "cli", "cli", "desugar", 30)
    e.props_json = build_props(["path", prop_str("path", "Source file to desugar")])
    e.required_json = build_required(["path"])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_spec_coverage", "[cli] Show feature spec coverage from feature_db.sdn", "cli", "cli", "spec-coverage", 60)
    e.props_json = build_props(["missing", prop_str("missing", "Pass 'true' to show only incomplete/missing features")])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_feature_gen", "[cli] Regenerate feature.md from feature_db.sdn", "cli", "cli", "feature-gen", 60)
    out.push(e)

    e = tool_entry("simple_task_gen", "[cli] Regenerate task.md from task_db.sdn", "cli", "cli", "task-gen", 60)
    out.push(e)

    e = tool_entry("simple_spec_gen", "[cli] Generate spec file for a source file", "cli", "cli", "spec-gen", 60)
    e.props_json = build_props(["path", prop_str("path", "Source file to generate spec for")])
    e.required_json = build_required(["path"])
    out.push(e)

    e = tool_entry("simple_todo_gen", "[cli] Generate TODO report", "cli", "cli", "todo-gen", 60)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_brief", "[cli] Show project brief summary", "cli", "cli", "brief", 30)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_ffi_gen", "[cli] Generate FFI bindings", "cli", "cli", "ffi-gen", 60)
    e.props_json = build_props(["path", prop_str("path", "Source file for FFI generation")])
    e.required_json = build_required(["path"])
    out.push(e)

    e = tool_entry("simple_wrapper_gen", "[cli] Generate wrapper code", "cli", "cli", "wrapper-gen", 60)
    e.props_json = build_props(["path", prop_str("path", "Source file for wrapper generation")])
    e.required_json = build_required(["path"])
    out.push(e)

    e = tool_entry("simple_spipe_docgen", "[cli] Generate SPipe documentation", "cli", "cli", "spipe-docgen", 60)
    e.props_json = build_props(["path", prop_str("path", "Spec file path")])
    e.required_json = build_required(["path"])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_feature_doc", "[cli] Generate feature documentation", "cli", "cli", "feature-doc", 60)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_grammar_doc", "[cli] Generate grammar documentation", "cli", "cli", "grammar-doc", 60)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_gen_lean", "[cli] Generate Lean proofs", "cli", "cli", "gen-lean", 60)
    e.props_json = build_props(["path", prop_str("path", "Source file")])
    e.required_json = build_required(["path"])
    out.push(e)

    e = tool_entry("simple_lex", "[cli] Lex source file into tokens", "cli", "cli", "lex", 30)
    e.props_json = build_props(["path", prop_str("path", "Source file to lex")])
    e.required_json = build_required(["path"])
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_i18n", "[cli] Internationalization management", "cli", "cli", "i18n", 30)
    e.props_json = build_props(["action", prop_str("action", "i18n action")])
    out.push(e)

    e = tool_entry("simple_init", "[cli] Initialize new project", "cli", "cli", "init", 30)
    e.props_json = build_props(["name", prop_str("name", "Project name"), "path", prop_str("path", "Project directory")])
    out.push(e)

    e = tool_entry("simple_verify", "[cli] Verify project integrity", "cli", "cli", "verify", 60)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_cache", "[cli] Manage package cache", "cli", "cli", "cache", 30)
    e.props_json = build_props(["action", prop_str("action", "Cache action: clean, list, size")])
    out.push(e)

    e = tool_entry("simple_list", "[cli] List installed packages", "cli", "cli", "list", 30)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_lock", "[cli] Lock file operations", "cli", "cli", "lock", 30)
    out.push(e)

    e = tool_entry("simple_tree", "[cli] Show dependency tree", "cli", "cli", "tree", 30)
    e.read_only = true
    out.push(e)

    e = tool_entry("simple_update", "[cli] Update dependencies", "cli", "cli", "update", 120)
    e.open_world = true
    out.push(e)

    e = tool_entry("debug_ui_widget_tree", "[debug-ui] Inspect widget tree with theme assignments", "debug", "in_process", "", 10)
    e.props_json = build_props(["theme", prop_str("theme", "Theme name: glass_dark, glass_light, glass_obsidian_dark")])
    e.read_only = true
    out.push(e)

    e = tool_entry("debug_ui_theme_tokens", "[debug-ui] Dump all theme token values", "debug", "in_process", "", 10)
    e.props_json = build_props(["theme", prop_str("theme", "Theme name: glass_dark, glass_light, glass_obsidian_dark")])
    e.read_only = true
    out.push(e)

    e = tool_entry("debug_ui_css_dump", "[debug-ui] Generate full CSS output for a theme", "debug", "in_process", "", 10)
    e.props_json = build_props(["theme", prop_str("theme", "Theme name: glass_dark, glass_light, glass_obsidian_dark")])
    e.read_only = true
    out.push(e)

    out
