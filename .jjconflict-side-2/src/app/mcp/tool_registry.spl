# MCP Tool Registry — table-driven tool metadata
#
# McpToolEntry holds all metadata for a single MCP tool:
#   - name, description, category
#   - schema (properties JSON, required JSON)
#   - annotations (readOnly, destructive, idempotent, openWorld)
#   - handler_kind: how dispatch routes the call
#   - cli_command: for cli_passthrough tools, the bin/simple subcommand
#   - timeout_s: default timeout in seconds

struct McpToolEntry:
    tool_name: text
    name: text
    description: text
    category: text
    props_json: text
    required_json: text
    read_only: bool
    destructive: bool
    idempotent: bool
    open_world: bool
    handler_kind: text
    cli_command: text
    timeout_s: i64

fn tool_entry(name: text, desc: text, cat: text, handler: text, cli_cmd: text, timeout: i64) -> McpToolEntry:
    McpToolEntry(
        tool_name: name,
        name: name,
        description: desc,
        category: cat,
        props_json: "{}",
        required_json: "[]",
        read_only: false,
        destructive: false,
        idempotent: true,
        open_world: false,
        handler_kind: handler,
        cli_command: cli_cmd,
        timeout_s: timeout
    )

fn prop_str(name: text, desc: text) -> text:
    val Q = "\""
    "{" + Q + "type" + Q + ":" + Q + "string" + Q + "," + Q + "description" + Q + ":" + Q + desc + Q + "}"

fn prop_str_nodesc(name: text) -> text:
    val Q = "\""
    "{" + Q + "type" + Q + ":" + Q + "string" + Q + "}"

fn prop_int(name: text, desc: text) -> text:
    val Q = "\""
    "{" + Q + "type" + Q + ":" + Q + "integer" + Q + "," + Q + "description" + Q + ":" + Q + desc + Q + "}"

fn prop_bool(name: text, desc: text) -> text:
    val Q = "\""
    "{" + Q + "type" + Q + ":" + Q + "boolean" + Q + "," + Q + "description" + Q + ":" + Q + desc + Q + "}"

fn build_props(pairs: [text]) -> text:
    val Q = "\""
    if pairs.len() == 0:
        return "{}"
    var parts: [text] = []
    var i = 0
    while i < pairs.len():
        if i + 1 < pairs.len():
            parts.push(Q + pairs[i] + Q + ":" + pairs[i + 1])
        i = i + 2
    "{" + parts.join(",") + "}"

fn build_required(names: [text]) -> text:
    val Q = "\""
    if names.len() == 0:
        return "[]"
    var parts: [text] = []
    for n in names:
        parts.push(Q + n + Q)
    "[" + parts.join(",") + "]"
