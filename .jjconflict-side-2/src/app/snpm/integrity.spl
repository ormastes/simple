# snpm integrity — SHA-256 checksum verification

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

fn compute_integrity(path: text) -> text:
    """Compute SHA-256 hash of a file, return 'sha256:hex' string."""
    if not rt_file_exists(path):
        return ""
    # Use shasum on macOS or sha256sum on Linux
    val result = rt_process_run("shasum", ["-a", "256", path])
    if result.2 == 0:
        val output = result.0.trim()
        # Output format: "hash  filename"
        val hash_parts = output.split(" ")
        val hash = if hash_parts.len() > 0: hash_parts[0] else: ""
        return "sha256:{hash}"
    # Fallback to sha256sum
    val result2 = rt_process_run("sha256sum", [path])
    if result2.2 == 0:
        val output2 = result2.0.trim()
        val hash2_parts = output2.split(" ")
        val hash2 = if hash2_parts.len() > 0: hash2_parts[0] else: ""
        return "sha256:{hash2}"
    ""

fn verify_integrity(path: text, expected: text) -> bool:
    """Verify file integrity against expected hash."""
    if expected == "":
        return true  # No integrity check requested
    val actual = compute_integrity(path)
    actual == expected
