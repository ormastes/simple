# Test Daemon QEMU Broker — Session pooling for QEMU-based tests
#
# Manages a pool of QEMU sessions, allowing tests to share sessions
# instead of booting fresh instances for each test.


extern fn rt_time_now_unix_micros() -> i64
extern fn rt_hash_text(s: text) -> i64

# ============================================================================
# Session Status
# ============================================================================

val QEMU_IDLE: i64 = 0
val QEMU_IN_USE: i64 = 1
val QEMU_STALE: i64 = 2

# ============================================================================
# Session Entry
# ============================================================================

struct QemuSessionEntry:
    session_key: text
    arch: text
    binary_hash: i64
    status: i64
    test_count: i64
    last_used: i64
    qmp_socket: text
    golden_snapshot_ready: bool
    pid: i64

# ============================================================================
# Broker
# ============================================================================

class QemuBroker:
    sessions: [QemuSessionEntry]
    max_sessions: i64

fn qemu_broker_new(max_sessions: i64) -> QemuBroker:
    QemuBroker(sessions: [], max_sessions: max_sessions)

impl QemuBroker:
    # Acquire a session for the given arch and binary
    me acquire(arch: text, binary_path: text) -> QemuSessionEntry:
        val binary_hash = rt_hash_text(binary_path)
        val session_key = "{arch}_{binary_hash}"

        # Look for existing idle session with same key
        var i = 0
        while i < self.sessions.len():
            val session = self.sessions[i]
            if session.session_key == session_key and session.status == QEMU_IDLE:
                self.sessions[i] = QemuSessionEntry(
                    session_key: session.session_key,
                    arch: session.arch,
                    binary_hash: session.binary_hash,
                    status: QEMU_IN_USE,
                    test_count: session.test_count + 1,
                    last_used: rt_time_now_unix_micros(),
                    qmp_socket: session.qmp_socket,
                    golden_snapshot_ready: session.golden_snapshot_ready,
                    pid: session.pid
                )
                return self.sessions[i]
            i = i + 1

        # No existing session — create new one
        if self.sessions.len() >= self.max_sessions:
            self.evict_oldest_idle()

        val new_session = QemuSessionEntry(
            session_key: session_key,
            arch: arch,
            binary_hash: binary_hash,
            status: QEMU_IN_USE,
            test_count: 1,
            last_used: rt_time_now_unix_micros(),
            qmp_socket: "",
            golden_snapshot_ready: false,
            pid: 0
        )
        self.sessions.push(new_session)
        new_session

    me release(session_key: text):
        var i = 0
        while i < self.sessions.len():
            if self.sessions[i].session_key == session_key:
                self.sessions[i] = QemuSessionEntry(
                    session_key: self.sessions[i].session_key,
                    arch: self.sessions[i].arch,
                    binary_hash: self.sessions[i].binary_hash,
                    status: QEMU_IDLE,
                    test_count: self.sessions[i].test_count,
                    last_used: rt_time_now_unix_micros(),
                    qmp_socket: self.sessions[i].qmp_socket,
                    golden_snapshot_ready: self.sessions[i].golden_snapshot_ready,
                    pid: self.sessions[i].pid
                )
                return
            i = i + 1

    me cleanup_idle(timeout_ms: i64):
        val now = rt_time_now_unix_micros()
        val timeout_us = timeout_ms * 1000
        var new_sessions: [QemuSessionEntry] = []
        var i = 0
        while i < self.sessions.len():
            val session = self.sessions[i]
            if session.status == QEMU_IDLE and (now - session.last_used) > timeout_us:
                # Session expired — skip it (don't add to new list)
                pass_dn
            else:
                new_sessions.push(session)
            i = i + 1
        self.sessions = new_sessions

    me shutdown_session(session_key: text):
        var new_sessions: [QemuSessionEntry] = []
        var i = 0
        while i < self.sessions.len():
            val s = self.sessions[i]
            if s.session_key == session_key:
                # Kill QEMU process if we have a PID
                if s.pid > 0:
                    val kill_cmd = "kill {s.pid} 2>/dev/null"
                    # Can't call shell directly here without import; use extern
                    pass_dn
            else:
                new_sessions.push(s)
            i = i + 1
        self.sessions = new_sessions

    me shutdown_all():
        self.sessions = []

    fn active_count() -> i64:
        var count: i64 = 0
        var i = 0
        while i < self.sessions.len():
            if self.sessions[i].status == QEMU_IN_USE:
                count = count + 1
            i = i + 1
        count

    fn idle_count() -> i64:
        var count: i64 = 0
        var i = 0
        while i < self.sessions.len():
            if self.sessions[i].status == QEMU_IDLE:
                count = count + 1
            i = i + 1
        count

    # --- Private ---

    me evict_oldest_idle():
        var oldest_idx = -1
        var oldest_time: i64 = 9999999999999999
        var i = 0
        while i < self.sessions.len():
            val session = self.sessions[i]
            if session.status == QEMU_IDLE and session.last_used < oldest_time:
                oldest_idx = i
                oldest_time = session.last_used
            i = i + 1

        if oldest_idx >= 0:
            # Remove by rebuilding list without the oldest
            var new_sessions: [QemuSessionEntry] = []
            var j = 0
            while j < self.sessions.len():
                if j != oldest_idx:
                    new_sessions.push(self.sessions[j])
                j = j + 1
            self.sessions = new_sessions
