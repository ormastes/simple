# Stats Render Adapter
#
# Bridges the stats app to the shared UI render contract.
# Produces RenderResult (text and/or html) from ProjectStats,
# showing project statistics with metric cards and tables.

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.ansi.{RESET, BOLD, DIM, RED, GREEN, YELLOW, CYAN}
use app.ui.render.fmt.{fmt_number, fmt_percent, fmt_bytes}
use app.ui.render.table.{TableBuilder, ALIGN_LEFT, ALIGN_RIGHT}
use app.ui.render.progress.{progress_bar, progress_bar_html}
use app.ui.render.html.{html_metric_card}

use compiler.tools.stats.types.{ProjectStats, FileStats, LineCount, TestStats,
    CoverageStats, FeatureStats, BugStats}

# =========================================================================
# Main Render Entry Point
# =========================================================================

fn render_stats(config: RenderConfig, stats: ProjectStats) -> RenderResult:
    """Render project statistics via the shared render contract.

    config.mode selects view: "summary", "files", "tests", "full".
    config.format selects output: "text", "html", or "both".
    """
    val mode = if config.mode == "render": "full" else: config.mode
    val fmt = config.format

    var text_out = ""
    var html_out = ""

    if fmt == "text" or fmt == "both":
        text_out = render_text(stats, mode)

    if fmt == "html" or fmt == "both":
        html_out = render_html(stats, mode, config)

    val cov_pct = stats.coverage_stats.percent
    val meta: Dict<text, text> = {
        "adapter": "stats",
        "mode": mode,
        "format": fmt,
        "total_files": "{stats.file_stats.total_files}",
        "total_lines": "{stats.line_stats.total}",
        "tests_total": "{stats.test_stats.total}",
        "coverage_pct": "{cov_pct}"
    }

    return RenderResult(
        format: fmt,
        text_output: text_out,
        html_output: html_out,
        metadata: meta,
        warnings: []
    )

# =========================================================================
# Text Rendering
# =========================================================================

fn render_text(stats: ProjectStats, mode: text) -> text:
    """Render stats as formatted text with ANSI colors and tables."""
    var lines: [text] = []

    lines.push("{BOLD}Project Statistics{RESET}")
    lines.push("")

    # Files summary
    if mode == "summary" or mode == "files" or mode == "full":
        lines.push("{BOLD}{CYAN}Files{RESET}")
        var ft = TableBuilder.new()
        ft = ft.add_column("Category", ALIGN_LEFT)
        ft = ft.add_column("Count", ALIGN_RIGHT)
        ft = ft.add_row(["Total", fmt_number(stats.file_stats.total_files)])
        ft = ft.add_row(["App", fmt_number(stats.file_stats.app_files)])
        ft = ft.add_row(["Lib", fmt_number(stats.file_stats.lib_files)])
        ft = ft.add_row(["Compiler", fmt_number(stats.file_stats.compiler_files)])
        ft = ft.add_row(["Test", fmt_number(stats.file_stats.test_files)])
        ft = ft.add_row(["Doc", fmt_number(stats.file_stats.doc_files)])
        lines.push(ft.render())
        lines.push("")

    # Lines summary
    if mode == "summary" or mode == "full":
        lines.push("{BOLD}{CYAN}Lines{RESET}")
        var lt = TableBuilder.new()
        lt = lt.add_column("Type", ALIGN_LEFT)
        lt = lt.add_column("Count", ALIGN_RIGHT)
        lt = lt.add_row(["Total", fmt_number(stats.line_stats.total)])
        lt = lt.add_row(["Code", fmt_number(stats.line_stats.code)])
        lt = lt.add_row(["Comment", fmt_number(stats.line_stats.comment)])
        lt = lt.add_row(["Blank", fmt_number(stats.line_stats.blank)])
        lines.push(lt.render())
        lines.push("")

    # Tests summary
    if mode == "tests" or mode == "full":
        lines.push("{BOLD}{CYAN}Tests{RESET}")
        val test_color = if stats.test_stats.failed > 0: RED else: GREEN
        lines.push("  Total:   {BOLD}{fmt_number(stats.test_stats.total)}{RESET}")
        lines.push("  Passed:  {GREEN}{fmt_number(stats.test_stats.passed)}{RESET}")
        if stats.test_stats.failed > 0:
            lines.push("  Failed:  {RED}{fmt_number(stats.test_stats.failed)}{RESET}")
        if stats.test_stats.skipped > 0:
            lines.push("  Skipped: {YELLOW}{fmt_number(stats.test_stats.skipped)}{RESET}")
        lines.push("")

        var tt = TableBuilder.new()
        tt = tt.add_column("Test Type", ALIGN_LEFT)
        tt = tt.add_column("Count", ALIGN_RIGHT)
        tt = tt.add_row(["SPipe", fmt_number(stats.test_stats.spipe_count)])
        tt = tt.add_row(["SDoc", fmt_number(stats.test_stats.sdoc_count)])
        tt = tt.add_row(["System", fmt_number(stats.test_stats.system_count)])
        tt = tt.add_row(["Integration", fmt_number(stats.test_stats.integration_count)])
        tt = tt.add_row(["Unit", fmt_number(stats.test_stats.unit_count)])
        lines.push(tt.render())
        lines.push("")

    # Coverage
    if mode == "summary" or mode == "full":
        lines.push("{BOLD}{CYAN}Coverage{RESET}")
        val cov_pct = stats.coverage_stats.percent
        val cov_color = _threshold_color(cov_pct)
        val cov_bar = progress_bar(cov_pct / 100.0, 30)
        lines.push("  {cov_color}{cov_bar} {fmt_percent(cov_pct)}{RESET}  ({stats.coverage_stats.lines_covered}/{stats.coverage_stats.lines_total} lines)")
        lines.push("")

    # Features
    if mode == "summary" or mode == "full":
        lines.push("{BOLD}{CYAN}Features{RESET}")
        val feat_pct = if stats.feature_stats.total > 0: (stats.feature_stats.complete * 100) as f64 / stats.feature_stats.total as f64 else: 0.0
        val feat_bar = progress_bar(feat_pct / 100.0, 30)
        val feat_color = _threshold_color(feat_pct)
        lines.push("  {feat_color}{feat_bar} {fmt_percent(feat_pct)}{RESET}  ({stats.feature_stats.complete}/{stats.feature_stats.total} complete)")
        lines.push("  In progress: {stats.feature_stats.in_progress}  Planned: {stats.feature_stats.planned}")
        lines.push("")

    # Bugs
    if mode == "summary" or mode == "full":
        lines.push("{BOLD}{CYAN}Bugs{RESET}")
        val bug_color = if stats.bug_stats.critical > 0: RED elif stats.bug_stats.open > 0: YELLOW else: GREEN
        lines.push("  Total: {stats.bug_stats.total}  Open: {bug_color}{stats.bug_stats.open}{RESET}  Critical: {RED}{stats.bug_stats.critical}{RESET}  Fixed: {GREEN}{stats.bug_stats.fixed}{RESET}")
        lines.push("")

    lines.join("\n")

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_html(stats: ProjectStats, mode: text, config: RenderConfig) -> text:
    """Render stats as styled HTML dashboard with metric cards."""
    val cov_pct = stats.coverage_stats.percent
    val cov_css = _threshold_css_color(cov_pct)
    val feat_pct = if stats.feature_stats.total > 0: (stats.feature_stats.complete * 100) as f64 / stats.feature_stats.total as f64 else: 0.0
    val feat_css = _threshold_css_color(feat_pct)
    val test_css = if stats.test_stats.failed > 0: "#f85149" else: "#3fb950"
    val bug_css = if stats.bug_stats.critical > 0: "#f85149" elif stats.bug_stats.open > 0: "#d29922" else: "#3fb950"

    var h = ""
    h = "{h}{_html_head("Project Statistics")}"
    h = "{h}<body>\n<div class=\"container\">\n"
    h = "{h}<h1>Project Statistics</h1>\n"

    # Metric cards row
    h = "{h}<div class=\"card-grid\">\n"

    h = "{h}<div class=\"card\"><h3>Files</h3>"
    h = "{h}<div class=\"value\">{fmt_number(stats.file_stats.total_files)}</div>"
    h = "{h}<div class=\"sub\">app: {stats.file_stats.app_files} | lib: {stats.file_stats.lib_files} | compiler: {stats.file_stats.compiler_files} | test: {stats.file_stats.test_files}</div></div>\n"

    h = "{h}<div class=\"card\"><h3>Lines</h3>"
    h = "{h}<div class=\"value\">{fmt_number(stats.line_stats.total)}</div>"
    h = "{h}<div class=\"sub\">code: {fmt_number(stats.line_stats.code)} | comment: {fmt_number(stats.line_stats.comment)} | blank: {fmt_number(stats.line_stats.blank)}</div></div>\n"

    h = "{h}<div class=\"card\"><h3>Tests</h3>"
    h = "{h}<div class=\"value\" style=\"color:{test_css}\">{fmt_number(stats.test_stats.total)}</div>"
    h = "{h}<div class=\"sub\">passed: {stats.test_stats.passed} | failed: {stats.test_stats.failed} | skipped: {stats.test_stats.skipped}</div></div>\n"

    h = "{h}<div class=\"card\"><h3>Coverage</h3>"
    h = "{h}<div class=\"value\" style=\"color:{cov_css}\">{fmt_percent(cov_pct)}</div>"
    h = "{h}{progress_bar_html(cov_pct / 100.0, cov_css)}"
    h = "{h}<div class=\"sub\">{stats.coverage_stats.lines_covered} / {stats.coverage_stats.lines_total} lines</div></div>\n"

    h = "{h}<div class=\"card\"><h3>Features</h3>"
    h = "{h}<div class=\"value\" style=\"color:{feat_css}\">{stats.feature_stats.complete}/{stats.feature_stats.total}</div>"
    h = "{h}{progress_bar_html(feat_pct / 100.0, feat_css)}"
    h = "{h}<div class=\"sub\">in progress: {stats.feature_stats.in_progress} | planned: {stats.feature_stats.planned}</div></div>\n"

    h = "{h}<div class=\"card\"><h3>Bugs</h3>"
    h = "{h}<div class=\"value\" style=\"color:{bug_css}\">{stats.bug_stats.open} open</div>"
    h = "{h}<div class=\"sub\">total: {stats.bug_stats.total} | critical: {stats.bug_stats.critical} | fixed: {stats.bug_stats.fixed}</div></div>\n"

    h = "{h}</div>\n"

    # Detailed tables for full mode
    if mode == "full":
        # File breakdown table
        h = "{h}<div class=\"card\" style=\"margin-top:16px\">\n"
        h = "{h}<h3>File Breakdown</h3>\n"
        h = "{h}<table>\n"
        h = "{h}<tr><th>Category</th><th>Count</th></tr>\n"
        h = "{h}<tr><td>App</td><td>{fmt_number(stats.file_stats.app_files)}</td></tr>\n"
        h = "{h}<tr><td>Lib / Std</td><td>{fmt_number(stats.file_stats.lib_files)}</td></tr>\n"
        h = "{h}<tr><td>Core</td><td>{fmt_number(stats.file_stats.core_files)}</td></tr>\n"
        h = "{h}<tr><td>Compiler</td><td>{fmt_number(stats.file_stats.compiler_files)}</td></tr>\n"
        h = "{h}<tr><td>Test</td><td>{fmt_number(stats.file_stats.test_files)}</td></tr>\n"
        h = "{h}<tr><td>Doc</td><td>{fmt_number(stats.file_stats.doc_files)}</td></tr>\n"
        h = "{h}</table>\n</div>\n"

        # Test type breakdown
        h = "{h}<div class=\"card\" style=\"margin-top:16px\">\n"
        h = "{h}<h3>Test Breakdown</h3>\n"
        h = "{h}<table>\n"
        h = "{h}<tr><th>Type</th><th>Count</th></tr>\n"
        h = "{h}<tr><td>SPipe</td><td>{fmt_number(stats.test_stats.spipe_count)}</td></tr>\n"
        h = "{h}<tr><td>SDoc</td><td>{fmt_number(stats.test_stats.sdoc_count)}</td></tr>\n"
        h = "{h}<tr><td>System</td><td>{fmt_number(stats.test_stats.system_count)}</td></tr>\n"
        h = "{h}<tr><td>Integration</td><td>{fmt_number(stats.test_stats.integration_count)}</td></tr>\n"
        h = "{h}<tr><td>Unit</td><td>{fmt_number(stats.test_stats.unit_count)}</td></tr>\n"
        h = "{h}</table>\n</div>\n"

    h = "{h}</div>\n</body>\n</html>\n"
    h

# =========================================================================
# Helpers
# =========================================================================

fn _threshold_color(pct: f64) -> text:
    if pct >= 80.0: return GREEN
    if pct >= 50.0: return YELLOW
    return RED

fn _threshold_css_color(pct: f64) -> text:
    if pct >= 80.0: return "#3fb950"
    if pct >= 50.0: return "#d29922"
    return "#f85149"

fn _html_head(title: text) -> text:
    var h = ""
    h = "{h}<!DOCTYPE html>\n<html>\n<head>\n"
    h = "{h}  <meta charset=\"utf-8\">\n"
    h = "{h}  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
    h = "{h}  <title>{title}</title>\n"
    h = "{h}  <style>\n"
    h = "{h}    body { font-family: system-ui, sans-serif; margin: 0; padding: 20px; background: #0d1117; color: #c9d1d9; }\n"
    h = "{h}    .container { max-width: 1200px; margin: 0 auto; }\n"
    h = "{h}    h1 { color: #58a6ff; }\n"
    h = "{h}    .card { background: #161b22; padding: 20px; margin: 10px 0; border-radius: 8px; border: 1px solid #30363d; }\n"
    h = "{h}    .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }\n"
    h = "{h}    .value { font-size: 28px; font-weight: bold; }\n"
    h = "{h}    .sub { font-size: 13px; color: #8b949e; margin-top: 4px; }\n"
    h = "{h}    table { border-collapse: collapse; width: 100%; margin-top: 8px; }\n"
    h = "{h}    th, td { border: 1px solid #30363d; padding: 8px 12px; font-size: 13px; }\n"
    h = "{h}    th { background: #21262d; text-align: left; color: #c9d1d9; }\n"
    h = "{h}    td { color: #c9d1d9; }\n"
    h = "{h}  </style>\n"
    h = "{h}</head>\n"
    h
