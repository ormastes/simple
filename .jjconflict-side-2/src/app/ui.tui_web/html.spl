# TUI Web HTML Page Generation
#
# Generates a full HTML5 page that displays TUI-style rendered output
# in a browser. Includes a WebSocket client for live updates and
# keyboard event forwarding.

# =========================================================================
# Full HTML Page
# =========================================================================

fn generate_tui_html_page(tui_html: text, port: i32) -> text:
    """Generate a complete HTML5 page wrapping TUI HTML output.

    Features:
    - Dark background with monospace font
    - WebSocket client for live render updates
    - Keyboard event forwarding to the server
    - Connection status bar
    """
    val css = _generate_tui_css()
    val js = _generate_tui_js(port)

    var html = "<!DOCTYPE html>\n"
    html = "{html}<html lang=\"en\">\n"
    html = "{html}<head>\n"
    html = "{html}  <meta charset=\"UTF-8\">\n"
    html = "{html}  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n"
    html = "{html}  <title>TUI Web Proxy</title>\n"
    html = "{html}  <style>{css}</style>\n"
    html = "{html}</head>\n"
    html = "{html}<body>\n"
    html = "{html}  <div id=\"tui-view\">{tui_html}</div>\n"
    html = "{html}  <div id=\"status-bar\">Connecting...</div>\n"
    html = "{html}  <script>{js}</script>\n"
    html = "{html}</body>\n"
    html = "{html}</html>"
    return html

# =========================================================================
# CSS
# =========================================================================

fn _generate_tui_css() -> text:
    """Generate CSS for the TUI web proxy page."""
    var css = "* { margin: 0; padding: 0; box-sizing: border-box; }\n"
    css = "{css}html, body { height: 100%; overflow: hidden; }\n"
    css = "{css}body { background: #1e1e1e; color: #d4d4d4; font-family: 'Fira Code', 'Cascadia Code', 'Consolas', monospace; font-size: 14px; display: flex; flex-direction: column; }\n"
    css = "{css}#tui-view { flex: 1; overflow: auto; padding: 4px; display: flex; justify-content: center; align-items: flex-start; }\n"
    css = "{css}#tui-view .tui-screen { max-width: 100%; }\n"
    css = "{css}#status-bar { height: 24px; line-height: 24px; padding: 0 12px; font-size: 12px; background: #333; color: #999; border-top: 1px solid #444; flex-shrink: 0; display: flex; justify-content: space-between; }\n"
    css = "{css}#status-bar.connected { background: #1a3a1a; color: #6a6; }\n"
    css = "{css}#status-bar.disconnected { background: #3a1a1a; color: #a66; }\n"
    return css

# =========================================================================
# JavaScript
# =========================================================================

fn _generate_tui_js(port: i32) -> text:
    """Generate JavaScript for WebSocket communication and keyboard events."""
    var js = "var ws = null;\n"
    js = "{js}var statusBar = document.getElementById('status-bar');\n"

    # WebSocket connection with auto-reconnect
    js = "{js}function connect() {\n"
    js = "{js}  var wsUrl = 'ws://' + location.host;\n"
    js = "{js}  ws = new WebSocket(wsUrl);\n"
    js = "{js}  ws.onopen = function() {\n"
    js = "{js}    statusBar.textContent = 'Connected';\n"
    js = "{js}    statusBar.className = 'connected';\n"
    js = "{js}  };\n"
    js = "{js}  ws.onmessage = function(e) {\n"
    js = "{js}    var data = JSON.parse(e.data);\n"
    js = "{js}    if (data.type === 'render') {\n"
    js = "{js}      document.getElementById('tui-view').innerHTML = data.html;\n"
    js = "{js}    }\n"
    js = "{js}  };\n"
    js = "{js}  ws.onclose = function() {\n"
    js = "{js}    statusBar.textContent = 'Disconnected - reconnecting...';\n"
    js = "{js}    statusBar.className = 'disconnected';\n"
    js = "{js}    setTimeout(connect, 2000);\n"
    js = "{js}  };\n"
    js = "{js}  ws.onerror = function() {\n"
    js = "{js}    statusBar.textContent = 'Connection error';\n"
    js = "{js}    statusBar.className = 'disconnected';\n"
    js = "{js}  };\n"
    js = "{js}}\n"
    js = "{js}connect();\n"

    # Send event helper
    js = "{js}function sendEvent(evt) {\n"
    js = "{js}  if (ws && ws.readyState === WebSocket.OPEN) {\n"
    js = "{js}    ws.send(JSON.stringify(evt));\n"
    js = "{js}  }\n"
    js = "{js}}\n"

    # Keyboard event capture
    js = "{js}document.addEventListener('keydown', function(e) {\n"
    js = "{js}  var tag = e.target.tagName.toLowerCase();\n"
    js = "{js}  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;\n"
    js = "{js}  sendEvent({type: 'key', key: e.key});\n"
    js = "{js}  e.preventDefault();\n"
    js = "{js}});\n"

    return js
