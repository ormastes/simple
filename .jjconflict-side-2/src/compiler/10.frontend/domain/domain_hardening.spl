class DomainHardenEntry:
    kind: text
    parse_status: text
    known_limitations: text
    validation_level: text
    export_capable: bool

    me is_stable():
        return parse_status == "stable"

    me is_experimental():
        return parse_status == "experimental"

    me needs_work():
        return known_limitations != "" and known_limitations != "none"

    static fn stable_domain(kind: text) -> DomainHardenEntry:
        return DomainHardenEntry(kind: kind, parse_status: "stable", known_limitations: "none", validation_level: "full", export_capable: true)

    static fn experimental_domain(kind: text, limitations: text) -> DomainHardenEntry:
        return DomainHardenEntry(kind: kind, parse_status: "experimental", known_limitations: limitations, validation_level: "basic", export_capable: false)


class HardenReport:
    total: i32
    stable_count: i32
    experimental_count: i32
    d0_kind: text
    d0_status: text
    d1_kind: text
    d1_status: text
    d2_kind: text
    d2_status: text
    d3_kind: text
    d3_status: text
    d4_kind: text
    d4_status: text

    me all_stable():
        return stable_count == total

    me stability_pct():
        if total > 0:
            return stable_count * 100 / total
        return 0

    static fn empty() -> HardenReport:
        return HardenReport(total: 0, stable_count: 0, experimental_count: 0, d0_kind: "", d0_status: "", d1_kind: "", d1_status: "", d2_kind: "", d2_status: "", d3_kind: "", d3_status: "", d4_kind: "", d4_status: "")


class DomainKindRegistry:
    kind: text
    handler_name: text
    validation_level: text
    export_formats: text
    enabled: bool

    me supports_export():
        return export_formats != "" and export_formats != "none"

    me is_enabled():
        return enabled

    static fn register(kind: text, handler: text, level: text, exports: text) -> DomainKindRegistry:
        return DomainKindRegistry(kind: kind, handler_name: handler, validation_level: level, export_formats: exports, enabled: true)

    static fn schema_registry() -> DomainKindRegistry:
        return DomainKindRegistry(kind: "schema", handler_name: "schema_handler", validation_level: "full", export_formats: "json_schema,protobuf", enabled: true)

    static fn style_registry() -> DomainKindRegistry:
        return DomainKindRegistry(kind: "style", handler_name: "style_handler", validation_level: "full", export_formats: "css,theme_json", enabled: true)

    static fn rtl_registry() -> DomainKindRegistry:
        return DomainKindRegistry(kind: "rtl", handler_name: "rtl_handler", validation_level: "basic", export_formats: "vhdl,verilog", enabled: true)


class DomainRegistryReport:
    total_registered: i32
    enabled_count: i32
    export_capable_count: i32
    full_validation_count: i32
    basic_validation_count: i32

    me all_enabled():
        return enabled_count == total_registered

    me coverage_text():
        return enabled_count.to_text() + "/" + total_registered.to_text() + " enabled"

    static fn from_counts(total: i32, enabled: i32, exportable: i32, full_val: i32, basic_val: i32) -> DomainRegistryReport:
        return DomainRegistryReport(total_registered: total, enabled_count: enabled, export_capable_count: exportable, full_validation_count: full_val, basic_validation_count: basic_val)


fn main():
    print("domain_hardening loaded")
