# SReplay — Binary Event Codec
#
# Serializes/deserializes ReplayEntry structs for trace files.
# Each entry is a fixed 80-byte record.

use os.kernel.replay.event_kinds.{ReplayEntry, EventKind}

# ============================================================================
# Serialization
# ============================================================================

fn concat_bytes(a: [i32], b: [i32]) -> [i32]:
    var result: [i32] = []
    for x in a:
        result.push(x)
    for x in b:
        result.push(x)
    result

fn encode_entry(entry: ReplayEntry) -> [i32]:
    var bytes: [i32] = []
    bytes = concat_bytes(bytes, encode_i64(entry.event_id))
    bytes = concat_bytes(bytes, encode_i64(entry.logical_time))
    bytes = concat_bytes(bytes, encode_i64(entry.thread_id))
    bytes = concat_bytes(bytes, encode_i64(entry.process_id))
    bytes = concat_bytes(bytes, encode_i32_bytes(entry.cpu_id))
    bytes = concat_bytes(bytes, encode_i32_bytes(entry.kind))
    bytes = concat_bytes(bytes, encode_i32_bytes(entry.flags))
    bytes = concat_bytes(bytes, encode_i64(entry.payload_a))
    bytes = concat_bytes(bytes, encode_i64(entry.payload_b))
    bytes = concat_bytes(bytes, encode_i64(entry.payload_c))
    bytes = concat_bytes(bytes, encode_i64(entry.payload_d))
    bytes = concat_bytes(bytes, encode_i32_bytes(entry.crc32))
    bytes

fn decode_entry(bytes: [i32], offset: i64) -> Result<ReplayEntry, text>:
    if bytes.len() - offset < 80:
        return Err("insufficient bytes for ReplayEntry")
    var pos = offset
    val event_id = decode_i64(bytes, pos)
    pos = pos + 8
    val logical_time = decode_i64(bytes, pos)
    pos = pos + 8
    val thread_id = decode_i64(bytes, pos)
    pos = pos + 8
    val process_id = decode_i64(bytes, pos)
    pos = pos + 8
    val cpu_id = decode_i32(bytes, pos)
    pos = pos + 4
    val kind = decode_i32(bytes, pos)
    pos = pos + 4
    val flags = decode_i32(bytes, pos)
    pos = pos + 4
    val payload_a = decode_i64(bytes, pos)
    pos = pos + 8
    val payload_b = decode_i64(bytes, pos)
    pos = pos + 8
    val payload_c = decode_i64(bytes, pos)
    pos = pos + 8
    val payload_d = decode_i64(bytes, pos)
    pos = pos + 8
    val crc32 = decode_i32(bytes, pos)

    Ok(ReplayEntry(
        event_id: event_id,
        logical_time: logical_time,
        thread_id: thread_id,
        process_id: process_id,
        cpu_id: cpu_id,
        kind: kind,
        flags: flags,
        payload_a: payload_a,
        payload_b: payload_b,
        payload_c: payload_c,
        payload_d: payload_d,
        crc32: crc32
    ))

# ============================================================================
# Encode batch
# ============================================================================

fn encode_entries(entries: [ReplayEntry]) -> [i32]:
    var bytes: [i32] = []
    for entry in entries:
        val encoded = encode_entry(entry)
        bytes = concat_bytes(bytes, encoded)
    bytes

fn decode_entries(bytes: [i32]) -> [ReplayEntry]:
    var entries: [ReplayEntry] = []
    var offset: i64 = 0
    while offset + 80 <= bytes.len():
        match decode_entry(bytes, offset):
            case Ok(entry):
                entries.push(entry)
            case Err(_):
                break
        offset = offset + 80
    entries

# ============================================================================
# Primitive Encoders (little-endian)
# ============================================================================

fn encode_i64(value: i64) -> [i32]:
    [(value % 256) as i32,
     ((value / 256) % 256) as i32,
     ((value / 65536) % 256) as i32,
     ((value / 16777216) % 256) as i32,
     ((value / 4294967296) % 256) as i32,
     ((value / 1099511627776) % 256) as i32,
     ((value / 281474976710656) % 256) as i32,
     ((value / 72057594037927936) % 256) as i32]

fn encode_i32_bytes(value: i32) -> [i32]:
    [value % 256,
     (value / 256) % 256,
     (value / 65536) % 256,
     (value / 16777216) % 256]

fn decode_i64(bytes: [i32], offset: i64) -> i64:
    var result: i64 = 0
    result = result + bytes[offset] as i64
    result = result + (bytes[offset + 1] as i64) * 256
    result = result + (bytes[offset + 2] as i64) * 65536
    result = result + (bytes[offset + 3] as i64) * 16777216
    result = result + (bytes[offset + 4] as i64) * 4294967296
    result = result + (bytes[offset + 5] as i64) * 1099511627776
    result = result + (bytes[offset + 6] as i64) * 281474976710656
    result = result + (bytes[offset + 7] as i64) * 72057594037927936
    result

fn decode_i32(bytes: [i32], offset: i64) -> i32:
    var result: i32 = 0
    result = result + bytes[offset]
    result = result + bytes[offset + 1] * 256
    result = result + bytes[offset + 2] * 65536
    result = result + bytes[offset + 3] * 16777216
    result
