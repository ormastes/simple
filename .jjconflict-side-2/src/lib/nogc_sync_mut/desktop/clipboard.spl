# Host-OS system clipboard access via SDL2.

use common.ui.capability.{Capability, NotSupported}
use std.nogc_sync_mut.io.window_ffi.{window_clipboard_get, window_clipboard_set, window_clipboard_has_text}

fn clipboard_read() -> Result<text, NotSupported>:
    val content = window_clipboard_get()
    Ok(content)

fn clipboard_write(content: text) -> Result<bool, NotSupported>:
    val ok = window_clipboard_set(content)
    Ok(ok)

fn clipboard_has_text() -> bool:
    window_clipboard_has_text()
