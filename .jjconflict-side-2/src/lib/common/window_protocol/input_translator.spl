# Input Translator — shared helpers for converting raw key/mouse data into WmInputEvent.
#
# Pure functions only. No driver or OS dependencies.
# Callers resolve key_char (text?) from their InputBackend before calling here.

use common.window_protocol.window_protocol.{WmInputEvent, wm_input_event, WM_EVENT_KEY_PRESS}

# ============================================================================
# Key → WmInputEvent
# ============================================================================

fn key_char_to_wm_key_event(window_id: u64, key_char: text?) -> WmInputEvent:
    """Build a WM_EVENT_KEY_PRESS event from a resolved character (or nil).

    If key_char is nil (non-printable / no mapping), key_code is 0.
    """
    var key_code: u32 = 0
    if key_char != nil:
        key_code = key_char.to_u32()
    wm_input_event(window_id, WM_EVENT_KEY_PRESS, key_code, 0, 0)
