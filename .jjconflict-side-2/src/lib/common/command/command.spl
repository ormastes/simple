# Command — entry types for the unified undo/redo system
#
# Each mutation is recorded as a CommandEntry with SDN-serialized
# before/after state deltas. Tools tag entries with their origin
# so the history can filter or group by tool.

# ============================================================================
# CommandMeta — metadata for a single command entry
# ============================================================================

struct CommandMeta:
    id: i64
    description: text
    timestamp_ms: i64
    tool_origin: text

# ============================================================================
# CommandEntry — a single undoable operation
# ============================================================================

struct CommandEntry:
    meta: CommandMeta
    before_snapshot: text
    after_snapshot: text
    merged_count: i32

impl CommandEntry:
    static fn create(id: i64, description: text, tool_origin: text, before: text, after: text) -> CommandEntry:
        CommandEntry(
            meta: CommandMeta(
                id: id,
                description: description,
                timestamp_ms: 0,
                tool_origin: tool_origin
            ),
            before_snapshot: before,
            after_snapshot: after,
            merged_count: 1
        )

    fn is_mergeable_with(self, other: CommandEntry, window_ms: i64) -> bool:
        val same_tool = self.meta.tool_origin == other.meta.tool_origin
        val same_desc = self.meta.description == other.meta.description
        val within_window = (other.meta.timestamp_ms - self.meta.timestamp_ms) < window_ms
        same_tool and same_desc and within_window
