# Pure Simple Layout Engine — Flexbox-style HStack/VStack
#
# Portable layout computation without C dependency.
# For baremetal OS: mirrors rt_layout_* C API but in Pure Simple.
# For compiled targets: LLVM-compiled Simple produces identical code to C after -O2.
#
# Usage:
#   var engine = LayoutEngine.new()
#   val root = engine.add_node(LayoutType.VStack, -1)
#   val bar = engine.add_node(LayoutType.HStack, root)
#   engine.set_fixed_size(bar, 0, 28)  # w=fill(0 means auto), h=28
#   engine.set_padding(bar, 8, 8, 4, 4)
#   val logo = engine.add_node(LayoutType.None, bar)
#   engine.set_fixed_size(logo, 24, 18)
#   engine.compute(1024, 768)
#   val bar_rect = engine.get_rect(bar)  # returns LayoutRect

# Layout types
val LAYOUT_NONE: i64 = 0
val LAYOUT_HSTACK: i64 = 1
val LAYOUT_VSTACK: i64 = 2
val LAYOUT_ZSTACK: i64 = 3

# Sizing modes
val SIZE_FIXED: i64 = 0
val SIZE_FILL: i64 = 1
val SIZE_AUTO: i64 = 2

# Alignment
val ALIGN_START: i64 = 0
val ALIGN_CENTER: i64 = 1
val ALIGN_END: i64 = 2

class LayoutRect:
    x: i64
    y: i64
    w: i64
    h: i64

class LayoutNode:
    id: i64
    parent_id: i64
    layout_type: i64
    w_mode: i64
    w_value: i64
    h_mode: i64
    h_value: i64
    pad_left: i64
    pad_right: i64
    pad_top: i64
    pad_bottom: i64
    spacing: i64
    h_align: i64
    v_align: i64
    # Computed
    cx: i64
    cy: i64
    cw: i64
    ch: i64
    intrinsic_w: i64
    intrinsic_h: i64

class LayoutEngine:
    nodes: [LayoutNode]
    children_map: [[i64]]

    static fn new() -> LayoutEngine:
        LayoutEngine(nodes: [], children_map: [])

    me add_node(layout_type: i64, parent_id: i64) -> i64:
        val id = self.nodes.len().to_i64()
        val node = LayoutNode(
            id: id, parent_id: parent_id, layout_type: layout_type,
            w_mode: SIZE_AUTO, w_value: 0, h_mode: SIZE_AUTO, h_value: 0,
            pad_left: 0, pad_right: 0, pad_top: 0, pad_bottom: 0,
            spacing: 0, h_align: ALIGN_START, v_align: ALIGN_START,
            cx: 0, cy: 0, cw: 0, ch: 0, intrinsic_w: 0, intrinsic_h: 0
        )
        self.nodes = self.nodes.push(node)
        # Ensure children_map has entry for this node
        while self.children_map.len().to_i64() <= id:
            var empty: [i64] = []
            self.children_map = self.children_map.push(empty)
        # Register as child of parent
        if parent_id >= 0 and parent_id < self.children_map.len().to_i64():
            var kids = self.children_map[parent_id.to_u64()]
            kids = kids.push(id)
            self.children_map = self.children_map.set(parent_id.to_u64(), kids)
        id

    me set_fixed_size(id: i64, w: i64, h: i64):
        if id < 0 or id >= self.nodes.len().to_i64():
            return
        var node = self.nodes[id.to_u64()]
        if w > 0:
            node = LayoutNode(
                id: node.id, parent_id: node.parent_id, layout_type: node.layout_type,
                w_mode: SIZE_FIXED, w_value: w, h_mode: node.h_mode, h_value: node.h_value,
                pad_left: node.pad_left, pad_right: node.pad_right,
                pad_top: node.pad_top, pad_bottom: node.pad_bottom,
                spacing: node.spacing, h_align: node.h_align, v_align: node.v_align,
                cx: node.cx, cy: node.cy, cw: node.cw, ch: node.ch,
                intrinsic_w: node.intrinsic_w, intrinsic_h: node.intrinsic_h
            )
        if h > 0:
            node = LayoutNode(
                id: node.id, parent_id: node.parent_id, layout_type: node.layout_type,
                w_mode: node.w_mode, w_value: node.w_value,
                h_mode: SIZE_FIXED, h_value: h,
                pad_left: node.pad_left, pad_right: node.pad_right,
                pad_top: node.pad_top, pad_bottom: node.pad_bottom,
                spacing: node.spacing, h_align: node.h_align, v_align: node.v_align,
                cx: node.cx, cy: node.cy, cw: node.cw, ch: node.ch,
                intrinsic_w: node.intrinsic_w, intrinsic_h: node.intrinsic_h
            )
        self.nodes = self.nodes.set(id.to_u64(), node)

    me set_fill(id: i64, w_weight: i64, h_weight: i64):
        if id < 0 or id >= self.nodes.len().to_i64():
            return
        var node = self.nodes[id.to_u64()]
        node = LayoutNode(
            id: node.id, parent_id: node.parent_id, layout_type: node.layout_type,
            w_mode: SIZE_FILL, w_value: if w_weight > 0: w_weight else: 1,
            h_mode: SIZE_FILL, h_value: if h_weight > 0: h_weight else: 1,
            pad_left: node.pad_left, pad_right: node.pad_right,
            pad_top: node.pad_top, pad_bottom: node.pad_bottom,
            spacing: node.spacing, h_align: node.h_align, v_align: node.v_align,
            cx: node.cx, cy: node.cy, cw: node.cw, ch: node.ch,
            intrinsic_w: node.intrinsic_w, intrinsic_h: node.intrinsic_h
        )
        self.nodes = self.nodes.set(id.to_u64(), node)

    me set_padding(id: i64, left: i64, right: i64, top: i64, bottom: i64):
        if id < 0 or id >= self.nodes.len().to_i64():
            return
        var node = self.nodes[id.to_u64()]
        node = LayoutNode(
            id: node.id, parent_id: node.parent_id, layout_type: node.layout_type,
            w_mode: node.w_mode, w_value: node.w_value,
            h_mode: node.h_mode, h_value: node.h_value,
            pad_left: left, pad_right: right, pad_top: top, pad_bottom: bottom,
            spacing: node.spacing, h_align: node.h_align, v_align: node.v_align,
            cx: node.cx, cy: node.cy, cw: node.cw, ch: node.ch,
            intrinsic_w: node.intrinsic_w, intrinsic_h: node.intrinsic_h
        )
        self.nodes = self.nodes.set(id.to_u64(), node)

    me set_spacing(id: i64, spacing: i64):
        if id < 0 or id >= self.nodes.len().to_i64():
            return
        var node = self.nodes[id.to_u64()]
        node = LayoutNode(
            id: node.id, parent_id: node.parent_id, layout_type: node.layout_type,
            w_mode: node.w_mode, w_value: node.w_value,
            h_mode: node.h_mode, h_value: node.h_value,
            pad_left: node.pad_left, pad_right: node.pad_right,
            pad_top: node.pad_top, pad_bottom: node.pad_bottom,
            spacing: spacing, h_align: node.h_align, v_align: node.v_align,
            cx: node.cx, cy: node.cy, cw: node.cw, ch: node.ch,
            intrinsic_w: node.intrinsic_w, intrinsic_h: node.intrinsic_h
        )
        self.nodes = self.nodes.set(id.to_u64(), node)

    me set_align(id: i64, h_align: i64, v_align: i64):
        if id < 0 or id >= self.nodes.len().to_i64():
            return
        var node = self.nodes[id.to_u64()]
        node = LayoutNode(
            id: node.id, parent_id: node.parent_id, layout_type: node.layout_type,
            w_mode: node.w_mode, w_value: node.w_value,
            h_mode: node.h_mode, h_value: node.h_value,
            pad_left: node.pad_left, pad_right: node.pad_right,
            pad_top: node.pad_top, pad_bottom: node.pad_bottom,
            spacing: node.spacing, h_align: h_align, v_align: v_align,
            cx: node.cx, cy: node.cy, cw: node.cw, ch: node.ch,
            intrinsic_w: node.intrinsic_w, intrinsic_h: node.intrinsic_h
        )
        self.nodes = self.nodes.set(id.to_u64(), node)

    me compute(screen_w: i64, screen_h: i64):
        if self.nodes.len() == 0:
            return
        # Find root (parent_id == -1)
        var root_id: i64 = -1
        var i: i64 = 0
        while i < self.nodes.len().to_i64():
            if self.nodes[i.to_u64()].parent_id == -1:
                root_id = i
            i = i + 1
        if root_id < 0:
            return
        self.measure(root_id)
        self.arrange(root_id, 0, 0, screen_w, screen_h)

    fn get_rect(id: i64) -> LayoutRect:
        if id < 0 or id >= self.nodes.len().to_i64():
            return LayoutRect(x: 0, y: 0, w: 0, h: 0)
        val n = self.nodes[id.to_u64()]
        LayoutRect(x: n.cx, y: n.cy, w: n.cw, h: n.ch)

    # --- Internal: Measure pass (bottom-up) ---
    me measure(id: i64):
        val n = self.nodes[id.to_u64()]
        val kids = if id < self.children_map.len().to_i64(): self.children_map[id.to_u64()] else: []
        # Measure children first
        var ki: i64 = 0
        while ki < kids.len().to_i64():
            self.measure(kids[ki.to_u64()])
            ki = ki + 1
        # Compute intrinsic size
        var cw: i64 = 0
        var ch: i64 = 0
        if n.layout_type == LAYOUT_HSTACK:
            ki = 0
            while ki < kids.len().to_i64():
                val c = self.nodes[kids[ki.to_u64()].to_u64()]
                val child_w = if c.w_mode == SIZE_FIXED: c.w_value else: c.intrinsic_w
                cw = cw + child_w
                val child_h = if c.h_mode == SIZE_FIXED: c.h_value else: c.intrinsic_h
                if child_h > ch:
                    ch = child_h
                ki = ki + 1
            if kids.len().to_i64() > 1:
                cw = cw + (kids.len().to_i64() - 1) * n.spacing
        else:
            if n.layout_type == LAYOUT_VSTACK:
                ki = 0
                while ki < kids.len().to_i64():
                    val c = self.nodes[kids[ki.to_u64()].to_u64()]
                    val child_h = if c.h_mode == SIZE_FIXED: c.h_value else: c.intrinsic_h
                    ch = ch + child_h
                    val child_w = if c.w_mode == SIZE_FIXED: c.w_value else: c.intrinsic_w
                    if child_w > cw:
                        cw = child_w
                    ki = ki + 1
                if kids.len().to_i64() > 1:
                    ch = ch + (kids.len().to_i64() - 1) * n.spacing
        # Update intrinsic
        var updated = self.nodes[id.to_u64()]
        updated = LayoutNode(
            id: updated.id, parent_id: updated.parent_id, layout_type: updated.layout_type,
            w_mode: updated.w_mode, w_value: updated.w_value,
            h_mode: updated.h_mode, h_value: updated.h_value,
            pad_left: updated.pad_left, pad_right: updated.pad_right,
            pad_top: updated.pad_top, pad_bottom: updated.pad_bottom,
            spacing: updated.spacing, h_align: updated.h_align, v_align: updated.v_align,
            cx: updated.cx, cy: updated.cy, cw: updated.cw, ch: updated.ch,
            intrinsic_w: cw + n.pad_left + n.pad_right,
            intrinsic_h: ch + n.pad_top + n.pad_bottom
        )
        self.nodes = self.nodes.set(id.to_u64(), updated)

    # --- Internal: Arrange pass (top-down) ---
    me arrange(id: i64, x: i64, y: i64, w: i64, h: i64):
        var n = self.nodes[id.to_u64()]
        n = LayoutNode(
            id: n.id, parent_id: n.parent_id, layout_type: n.layout_type,
            w_mode: n.w_mode, w_value: n.w_value,
            h_mode: n.h_mode, h_value: n.h_value,
            pad_left: n.pad_left, pad_right: n.pad_right,
            pad_top: n.pad_top, pad_bottom: n.pad_bottom,
            spacing: n.spacing, h_align: n.h_align, v_align: n.v_align,
            cx: x, cy: y, cw: w, ch: h,
            intrinsic_w: n.intrinsic_w, intrinsic_h: n.intrinsic_h
        )
        self.nodes = self.nodes.set(id.to_u64(), n)

        val kids = if id < self.children_map.len().to_i64(): self.children_map[id.to_u64()] else: []
        if kids.len() == 0:
            return

        val content_w = w - n.pad_left - n.pad_right
        val content_h = h - n.pad_top - n.pad_bottom
        val start_x = x + n.pad_left
        val start_y = y + n.pad_top

        if n.layout_type == LAYOUT_HSTACK:
            # Calculate fixed vs fill
            var fixed_total: i64 = 0
            var fill_weight: i64 = 0
            var ki: i64 = 0
            while ki < kids.len().to_i64():
                val c = self.nodes[kids[ki.to_u64()].to_u64()]
                if c.w_mode == SIZE_FIXED:
                    fixed_total = fixed_total + c.w_value
                else:
                    if c.w_mode == SIZE_FILL:
                        fill_weight = fill_weight + (if c.w_value > 0: c.w_value else: 1)
                    else:
                        fixed_total = fixed_total + c.intrinsic_w
                ki = ki + 1
            if kids.len().to_i64() > 1:
                fixed_total = fixed_total + (kids.len().to_i64() - 1) * n.spacing
            val free = if content_w > fixed_total: content_w - fixed_total else: 0

            var cx = start_x
            ki = 0
            while ki < kids.len().to_i64():
                val c = self.nodes[kids[ki.to_u64()].to_u64()]
                var child_w: i64 = 0
                if c.w_mode == SIZE_FIXED:
                    child_w = c.w_value
                else:
                    if c.w_mode == SIZE_FILL:
                        val wt = if c.w_value > 0: c.w_value else: 1
                        child_w = if fill_weight > 0: free * wt / fill_weight else: 0
                    else:
                        child_w = c.intrinsic_w
                val child_h = if c.h_mode == SIZE_FIXED: c.h_value else: content_h
                var cy = start_y
                if n.v_align == ALIGN_CENTER:
                    cy = start_y + (content_h - child_h) / 2
                self.arrange(kids[ki.to_u64()], cx, cy, child_w, child_h)
                cx = cx + child_w + n.spacing
                ki = ki + 1

        else:
            if n.layout_type == LAYOUT_VSTACK:
                var fixed_total: i64 = 0
                var fill_weight: i64 = 0
                var ki: i64 = 0
                while ki < kids.len().to_i64():
                    val c = self.nodes[kids[ki.to_u64()].to_u64()]
                    if c.h_mode == SIZE_FIXED:
                        fixed_total = fixed_total + c.h_value
                    else:
                        if c.h_mode == SIZE_FILL:
                            fill_weight = fill_weight + (if c.h_value > 0: c.h_value else: 1)
                        else:
                            fixed_total = fixed_total + c.intrinsic_h
                    ki = ki + 1
                if kids.len().to_i64() > 1:
                    fixed_total = fixed_total + (kids.len().to_i64() - 1) * n.spacing
                val free = if content_h > fixed_total: content_h - fixed_total else: 0

                var cy = start_y
                ki = 0
                while ki < kids.len().to_i64():
                    val c = self.nodes[kids[ki.to_u64()].to_u64()]
                    var child_h: i64 = 0
                    if c.h_mode == SIZE_FIXED:
                        child_h = c.h_value
                    else:
                        if c.h_mode == SIZE_FILL:
                            val wt = if c.h_value > 0: c.h_value else: 1
                            child_h = if fill_weight > 0: free * wt / fill_weight else: 0
                        else:
                            child_h = c.intrinsic_h
                    val child_w = if c.w_mode == SIZE_FIXED: c.w_value else: content_w
                    var cx = start_x
                    if n.h_align == ALIGN_CENTER:
                        cx = start_x + (content_w - child_w) / 2
                    self.arrange(kids[ki.to_u64()], cx, cy, child_w, child_h)
                    cy = cy + child_h + n.spacing
                    ki = ki + 1
            else:
                # ZStack: all children fill parent
                var ki: i64 = 0
                while ki < kids.len().to_i64():
                    val c = self.nodes[kids[ki.to_u64()].to_u64()]
                    val child_w = if c.w_mode == SIZE_FIXED: c.w_value else: content_w
                    val child_h = if c.h_mode == SIZE_FIXED: c.h_value else: content_h
                    var cx = start_x
                    var cy = start_y
                    if n.h_align == ALIGN_CENTER:
                        cx = start_x + (content_w - child_w) / 2
                    if n.v_align == ALIGN_CENTER:
                        cy = start_y + (content_h - child_h) / 2
                    self.arrange(kids[ki.to_u64()], cx, cy, child_w, child_h)
                    ki = ki + 1
