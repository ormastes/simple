# Signal/Event System - Types
#
# Core types for the signal/event system used by the 2D game engine.
# Provides connection identifiers and connection records.

# ============================================================================
# Signal Connection Identifier
# ============================================================================

struct SignalConnectionId:
    id: i64

impl SignalConnectionId:
    fn equals(other: SignalConnectionId) -> bool:
        self.id == other.id

    fn to_string() -> text:
        "SignalConnectionId({self.id})"

# ============================================================================
# Signal Connection Record
# ============================================================================

struct SignalConnection:
    id: SignalConnectionId
    callback: fn(text)
    once: bool           # If true, auto-disconnect after first emit
