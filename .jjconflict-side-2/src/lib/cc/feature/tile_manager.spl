# cc::TileManager — schedules and tracks tile raster work

use std.cc.entity.tile.{Tile, TileKey, TilePriority}
use std.cc.feature.raster_buffer_provider.{RasterBufferProvider, RasterBuffer}

class TileManager:
    tiles: [Tile]
    raster_provider: RasterBufferProvider

    static fn new(rp: RasterBufferProvider) -> TileManager:
        TileManager(tiles: [], raster_provider: rp)

    me add_tile(t: Tile):
        me.tiles.push(t)

    me schedule_tasks():
        var i = 0
        while i < me.tiles.len():
            val t = me.tiles[i]
            match t.priority:
                | TilePriority.NowBin ->
                    if not t.is_ready:
                        val buf = me.raster_provider.acquire_buffer_for_raster(t)
                        me.tiles[i].set_ready(buf.handle)
                | _ -> ()
            i = i + 1

    me invalidate_tile(key: TileKey):
        var i = 0
        while i < me.tiles.len():
            if me.tiles[i].key.matches(key):
                me.tiles[i].invalidate()
            i = i + 1

    fn ready_count() -> i32:
        var count = 0
        for t in me.tiles:
            if t.is_ready:
                count = count + 1
        count

    fn pending_count() -> i32:
        var count = 0
        for t in me.tiles:
            if not t.is_ready:
                count = count + 1
        count
