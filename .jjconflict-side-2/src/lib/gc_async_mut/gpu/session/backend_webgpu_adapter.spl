# WebGPU portable backend adapter.
# Cross-platform: graphics, compute, and canvas present supported.

use std.io

extern fn rt_webgpu_create_device() -> i64
extern fn rt_webgpu_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_webgpu_present(handle: i64) -> text
extern fn rt_webgpu_cleanup(handle: i64) -> i64

class BackendWebgpuAdapter:
    handle: i64
    device_name: text
    initialized: bool
    session_mode: text

    static fn create(mode: text) -> BackendWebgpuAdapter:
        BackendWebgpuAdapter(
            handle: 0,
            device_name: "webgpu",
            initialized: false,
            session_mode: mode,
        )

    me init_device() -> text:
        val h = rt_webgpu_create_device()
        if h <= 0:
            return "webgpu: device creation failed"
        self.handle = h
        self.initialized = true
        ""

    me submit_commands(cmd_count: i64) -> text:
        if self.initialized == false:
            return "webgpu: device not initialized"
        if cmd_count < 0:
            return "webgpu: invalid cmd_count"
        rt_webgpu_submit(self.handle, cmd_count)

    me present() -> text:
        if self.initialized == false:
            return "webgpu: device not initialized"
        rt_webgpu_present(self.handle)

    me readback(x: i64, y: i64, w: i64, h: i64) -> text:
        if self.initialized == false:
            return "webgpu: device not initialized"
        if w <= 0 or h <= 0:
            return "webgpu: invalid readback dimensions"
        ""

    me supports_compute() -> bool:
        true

    me supports_graphics() -> bool:
        true

    me supports_present() -> bool:
        true

    me device_info() -> text:
        "webgpu handle=" + self.handle.to_text() + " mode=" + self.session_mode + " initialized=" + self.initialized.to_text()

    me cleanup() -> text:
        if self.initialized:
            rt_webgpu_cleanup(self.handle)
        self.initialized = false
        self.handle = 0
        ""
