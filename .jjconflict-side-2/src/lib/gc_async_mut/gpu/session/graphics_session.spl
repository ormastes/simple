# GraphicsSession — Main session handle for the graphics backend API
#
# Manages session lifecycle (retain/release), frame sequencing, and enforces
# mode conflict rules (perf_exclusive sessions block managed borrows).

use std.io
use std.gpu.session.graphics_session_policy.{GraphicsSessionPolicy}
use std.gpu.session.graphics_capabilities.{GraphicsCapabilities}
use std.gpu.session.graphics_error.{GraphicsError}

# Session mode constants
val SESSION_MODE_LEGACY: text = "legacy_no_session"
val SESSION_MODE_MANAGED: text = "managed_shared"
val SESSION_MODE_PERF: text = "perf_exclusive"

class GraphicsSession:
    """Top-level session handle unifying policy, capabilities, and frame tracking."""

    session_id: i64
    mode: text
    backend_kind: text
    policy: GraphicsSessionPolicy
    capabilities: GraphicsCapabilities
    handle: i64
    frame_count: i64
    active: bool

    # -------------------------------------------------------------------------
    # Constructors
    # -------------------------------------------------------------------------

    static fn create(policy: GraphicsSessionPolicy) -> GraphicsSession:
        val caps = GraphicsCapabilities.probe(
            policy.backend_kind,
            policy.target_arch,
            policy.target_bits
        )
        return GraphicsSession(
            session_id: 1,
            mode: policy.mode,
            backend_kind: policy.backend_kind,
            policy: policy,
            capabilities: caps,
            handle: 0,
            frame_count: 0,
            active: false
        )

    static fn create_legacy() -> GraphicsSession:
        val policy = GraphicsSessionPolicy.legacy_no_session()
        val caps = GraphicsCapabilities.cpu_only()
        return GraphicsSession(
            session_id: 0,
            mode: SESSION_MODE_LEGACY,
            backend_kind: "none",
            policy: policy,
            capabilities: caps,
            handle: 0,
            frame_count: 0,
            active: false
        )

    # -------------------------------------------------------------------------
    # Lifecycle
    # -------------------------------------------------------------------------

    me retain() -> text:
        if self.active:
            if self.mode == SESSION_MODE_PERF:
                val err = GraphicsError.mode_conflict(
                    "perf_exclusive session cannot be retained while active"
                )
                return err.to_text()
            return "already_active"
        self.active = true
        self.handle = self.session_id + 1000
        return ""

    me release() -> text:
        if self.active == false:
            return "not_active"
        self.active = false
        self.handle = 0
        return ""

    # -------------------------------------------------------------------------
    # Frame sequencing
    # -------------------------------------------------------------------------

    me begin_frame() -> i64:
        if self.active == false:
            return -1
        self.frame_count = self.frame_count + 1
        return self.frame_count

    me end_frame(frame_id: i64) -> text:
        if self.active == false:
            return GraphicsError.invalid_state("session not active").to_text()
        if frame_id != self.frame_count:
            return GraphicsError.invalid_state("frame_id mismatch").to_text()
        return ""

    # -------------------------------------------------------------------------
    # Queries
    # -------------------------------------------------------------------------

    me is_active() -> bool:
        return self.active

    me stats() -> text:
        var s = "session_id=" + self.session_id.to_text()
        s = s + " mode=" + self.mode
        s = s + " backend=" + self.backend_kind
        s = s + " frames=" + self.frame_count.to_text()
        s = s + " active=" + self.active.to_text()
        return s
