# Editor Block Model
#
# Block-level document model for Obsidian-like markdown rendering.
# Each block maps a range of source lines to rendered output.
# Active block reveals raw source; inactive blocks show rendered output.

struct RenderBlock:
    id: i64
    kind: text
    from_line: i64
    to_line: i64
    content: text
    rendered_lines: [text]
    status: text

class BlockModel:
    blocks: [RenderBlock]
    active_block: i64
    next_id: i64

impl BlockModel:

    static fn new() -> BlockModel:
        BlockModel(blocks: [], active_block: -1, next_id: 1)

    static fn from_markdown(content: text) -> BlockModel:
        var model = BlockModel.new()
        val lines_arr = split_lines(content)
        val ranged_ast = parse_blocks_with_ranges(lines_arr)
        val typed_lines = _bm_split_lines(content)
        model.blocks = md_ast_to_render_blocks(ranged_ast, typed_lines)
        model.next_id = model.blocks.len() + 1
        model

    fn block_count() -> i64:
        self.blocks.len()

    fn block_at(index: i64) -> RenderBlock:
        if index < 0 or index >= self.blocks.len():
            return RenderBlock(id: 0, kind: "empty", from_line: 0, to_line: 0, content: "", rendered_lines: [], status: "error")
        self.blocks[index]

    fn block_for_line(line: i64) -> i64:
        var i = 0
        while i < self.blocks.len():
            if line >= self.blocks[i].from_line and line <= self.blocks[i].to_line:
                return i
            i = i + 1
        -1

    me activate_block(index: i64):
        self.active_block = index

    me deactivate_block():
        self.active_block = -1

    fn is_active(index: i64) -> bool:
        self.active_block == index

    me rebuild(content: text):
        val old_active = self.active_block
        val lines_arr = split_lines(content)
        val ranged_ast = parse_blocks_with_ranges(lines_arr)
        val typed_lines = _bm_split_lines(content)
        self.blocks = md_ast_to_render_blocks(ranged_ast, typed_lines)
        self.next_id = self.blocks.len() + 1
        if old_active >= 0 and old_active < self.blocks.len():
            self.active_block = old_active
        else:
            self.active_block = -1



fn _bm_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < content.len():
        if content.char_at(i) == "\n":
            lines.push(content.slice(start, i))
            start = i + 1
        i = i + 1
    if start <= content.len():
        lines.push(content.slice(start, content.len()))
    lines

fn _bm_join_lines(lines: [text], start: i64, end: i64) -> text:
    var result = ""
    var i = start
    while i < end and i < lines.len():
        if i > start:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result

fn _bm_split_range(lines: [text], start: i64, end: i64) -> [text]:
    var result: [text] = []
    var i = start
    while i < end and i < lines.len():
        result.push(lines[i])
        i = i + 1
    result


fn bm_cursor_block_index(model: BlockModel, cursor_row: i64) -> i64:
    model.block_for_line(cursor_row)

fn bm_cursor_block_changed(model: BlockModel, cursor_row: i64) -> bool:
    val current = model.block_for_line(cursor_row)
    current != model.active_block

fn bm_active_block_range(model: BlockModel) -> i64:
    val idx = model.active_block
    if idx < 0 or idx >= model.blocks.len():
        return -1
    model.blocks[idx].from_line


