# Split Compute
#
# Converts a SplitTree into positioned rectangles for rendering.
# Recursively bisects the available area at each split node.

struct SplitRect:
    group_id: i64
    x: i64
    y: i64
    w: i64
    h: i64

fn split_compute_rects(tree: SplitTree, x: i64, y: i64, w: i64, h: i64) -> [SplitRect]:
    var result: [SplitRect] = []
    _split_compute_node(tree.nodes, tree.root_id, x, y, w, h, result)
    result

fn split_find_rect(rects: [SplitRect], group_id: i64) -> SplitRect:
    var i = 0
    while i < rects.len():
        if rects[i].group_id == group_id:
            return rects[i]
        i = i + 1
    SplitRect(group_id: -1, x: 0, y: 0, w: 0, h: 0)

fn split_find_neighbor(rects: [SplitRect], group_id: i64, direction: text) -> i64:
    val src = split_find_rect(rects, group_id)
    if src.group_id < 0:
        return -1
    val src_cx = src.x + src.w / 2
    val src_cy = src.y + src.h / 2
    var best_id: i64 = -1
    var best_dist: i64 = 999999
    var i = 0
    while i < rects.len():
        val r = rects[i]
        if r.group_id != group_id:
            val valid = _split_is_valid_neighbor(src, r, direction)
            if valid:
                val dist = _split_neighbor_dist(src, r, direction)
                if dist < best_dist:
                    best_dist = dist
                    best_id = r.group_id
        i = i + 1
    best_id

fn _split_is_valid_neighbor(src: SplitRect, candidate: SplitRect, direction: text) -> bool:
    val c_cx = candidate.x + candidate.w / 2
    val c_cy = candidate.y + candidate.h / 2
    val s_cx = src.x + src.w / 2
    val s_cy = src.y + src.h / 2
    if direction == "left":
        return c_cx < s_cx
    if direction == "right":
        return c_cx > s_cx
    if direction == "up":
        return c_cy < s_cy
    if direction == "down":
        return c_cy > s_cy
    false

fn _split_neighbor_dist(src: SplitRect, candidate: SplitRect, direction: text) -> i64:
    val dx = (candidate.x + candidate.w / 2) - (src.x + src.w / 2)
    val dy = (candidate.y + candidate.h / 2) - (src.y + src.h / 2)
    val abs_dx = if dx < 0 then 0 - dx else: dx
    val abs_dy = if dy < 0 then 0 - dy else: dy
    if direction == "left" or direction == "right":
        return abs_dx * 10 + abs_dy
    abs_dy * 10 + abs_dx

fn _split_compute_node(nodes: [SplitNode], node_id: i64, x: i64, y: i64, w: i64, h: i64, result: [SplitRect]):
    if node_id < 0 or node_id >= nodes.len():
        return
    val node = nodes[node_id]
    if node.kind == NODE_LEAF:
        result.push(SplitRect(group_id: node.group_id, x: x, y: y, w: w, h: h))
        return
    if node.direction == SPLIT_VERTICAL:
        val left_w = (w * node.ratio) / 100
        val border = 1
        var right_w = w - left_w - border
        if right_w < 1:
            right_w = 1
        _split_compute_node(nodes, node.left_id, x, y, left_w, h, result)
        _split_compute_node(nodes, node.right_id, x + left_w + border, y, right_w, h, result)
    else:
        val top_h = (h * node.ratio) / 100
        val border = 1
        var bottom_h = h - top_h - border
        if bottom_h < 1:
            bottom_h = 1
        _split_compute_node(nodes, node.left_id, x, y, w, top_h, result)
        _split_compute_node(nodes, node.right_id, x, y + top_h + border, w, bottom_h, result)
