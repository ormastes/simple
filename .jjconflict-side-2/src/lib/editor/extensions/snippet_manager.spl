# Editor Snippet Manager Extension
#
# Manages code snippets: storage, lookup by prefix, and variable expansion.

struct Snippet:
    prefix: text
    body: text
    description: text
    language_id: text

struct SnippetManager:
    snippets: [Snippet]

fn snippet_manager_new() -> SnippetManager:
    SnippetManager(snippets: [])

fn snippet_manager_with_snippets(snippets: [Snippet]) -> SnippetManager:
    SnippetManager(snippets: snippets)

fn snippet_manager_register(manager: SnippetManager, snippet: Snippet) -> SnippetManager:
    var snips = manager.snippets
    snips.push(snippet)
    SnippetManager(snippets: snips)

fn snippet_manager_find(manager: SnippetManager, prefix: text, language_id: text) -> Snippet:
    for s in manager.snippets:
        val lang_match = s.language_id == "" or s.language_id == language_id
        if s.prefix == prefix and lang_match:
            return s
    Snippet(prefix: "", body: "", description: "", language_id: "")

fn snippet_manager_completions(manager: SnippetManager, prefix: text, language_id: text) -> [text]:
    var result: [text] = []
    for s in manager.snippets:
        val lang_match = s.language_id == "" or s.language_id == language_id
        if lang_match and s.prefix.starts_with(prefix):
            result.push(s.prefix)
    result

fn snippet_expand(snippet: Snippet, tab_stop: i64) -> text:
    # Replace tab-stop markers $0..$9 with empty text; return the expanded body.
    var result = snippet.body
    var i = 0
    while i <= 9:
        result = result.replace("${i}", "")
        i = i + 1
    result
