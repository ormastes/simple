# blink::PaintArtifact — DisplayItemList + PaintChunks, mirroring Chromium's paint artifact model.

use examples.browser.entity.dom.paint_types.{DisplayList, DisplayItem, PaintOp}

# Properties triple that identifies a PaintChunk's place in the four property trees.
class PaintChunkProperties:
    transform_id: i32
    clip_id: i32
    effect_id: i32

    static fn root() -> PaintChunkProperties:
        PaintChunkProperties(transform_id: 0, clip_id: 0, effect_id: 0)

# A contiguous range of DisplayItems sharing the same PaintChunkProperties.
class PaintChunk:
    begin_index: i32
    end_index: i32
    properties: PaintChunkProperties
    bounds_x: f32
    bounds_y: f32
    bounds_w: f32
    bounds_h: f32
    known_to_be_opaque: bool

    static fn create(
        begin_index: i32,
        end_index: i32,
        properties: PaintChunkProperties
    ) -> PaintChunk:
        PaintChunk(
            begin_index: begin_index,
            end_index: end_index,
            properties: properties,
            bounds_x: 0.0,
            bounds_y: 0.0,
            bounds_w: 0.0,
            bounds_h: 0.0,
            known_to_be_opaque: false
        )

# PaintArtifact bundles a DisplayList with the PaintChunks that index into it.
class PaintArtifact:
    display_items: DisplayList
    chunks: [PaintChunk]

    static fn empty() -> PaintArtifact:
        PaintArtifact(
            display_items: DisplayList.empty(),
            chunks: [PaintChunk]()
        )

    me chunk_count() -> i32:
        self.chunks.len().to_i32()

    me item_count() -> i32:
        self.display_items.ops.len().to_i32()
