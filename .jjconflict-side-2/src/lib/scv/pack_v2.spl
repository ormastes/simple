# SCV pack v2: delta-compressed packs.

use app.io.mod (file_exists, file_read, dir_create, dir_walk)
use std.nogc_sync_mut.io.file_ops.{file_read_bytes, file_write_bytes}
use std.common.compress.gzip.{gzip_compress, gzip_decompress}
use std.scv.core.{scv_objects_dir, scv_chunk_path, scv_line_set_contains}
use std.scv.maintenance.{scv_object_id_from_path}
use std.scv.store.{scv_repo_exists, scv_i64_bytes_to_u8, scv_hash_text, scv_write_text}
use std.scv.delta.{scv_delta_encode, scv_delta_decode, SCV_DELTA_MAX_DEPTH}
use std.scv.pack.{scv_append_bytes, scv_append_text_bytes, scv_pack_bytes_line, scv_pack_id_from_gzip_path, scv_pack_manifest_for_kind, scv_pack_payload_for_kind, scv_pack_payload_matches_manifest_bytes}

# Collect all chunk ids in a directory as a list
fn scv_pack_collect_chunk_ids(root: text) -> [text]:
    val dir = "{scv_objects_dir(root)}/chunks"
    if not file_exists(dir):
        return []
    var ids: [text] = []
    for path in dir_walk(dir):
        ids.push(scv_object_id_from_path(path))
    ids

# Try to find a good base chunk for delta encoding target_id among candidate ids.
# Returns (base_id, delta_bytes) or ("", []) if no useful delta found.
fn scv_pack_find_delta_base(root: text, target_id: text, candidate_ids: [text]) -> (text, [u8]):
    val target_path = scv_chunk_path(root, target_id)
    if not file_exists(target_path):
        return ("", [])
    val target_raw = scv_i64_bytes_to_u8(file_read_bytes(target_path) ?? [])
    if target_raw.len() == 0:
        return ("", [])

    var best_base_id = ""
    var best_delta: [u8] = []
    var best_size = target_raw.len()

    for cand_id in candidate_ids:
        if cand_id == target_id:
            continue
        val cand_path = scv_chunk_path(root, cand_id)
        if not file_exists(cand_path):
            continue
        val base_raw = scv_i64_bytes_to_u8(file_read_bytes(cand_path) ?? [])
        if base_raw.len() == 0:
            continue
        val (delta, err) = scv_delta_encode(base_raw, target_raw)
        if err != "":
            continue
        if delta.len() < best_size:
            best_base_id = cand_id
            best_delta = delta
            best_size = delta.len()

    (best_base_id, best_delta)

# Build v2 payload: full entries for all object kinds, delta entries for chunks.
# Single-pass greedy: each chunk is classified as full XOR delta, never both.
# A chunk gets a delta entry only if it can compress against an already-committed
# full-entry chunk. Otherwise it becomes a full entry (and can serve as base for
# later chunks in the same pass).
fn scv_pack_payload_v2(root: text) -> [u8]:
    var payload: [u8] = []
    payload = scv_append_text_bytes(payload, "format: scv-pack-payload-v2\n")

    # Collect all chunk ids
    val chunk_ids = scv_pack_collect_chunk_ids(root)

    # full_ids: newline-separated set of chunk IDs committed as full entries so far
    var full_ids = ""
    # full_id_list: ordered list of IDs for candidate lookup
    var full_id_list: [text] = []

    # Deferred delta entries (emitted after all full entries)
    var delta_target_ids: [text] = []
    var delta_base_ids_list: [text] = []
    var delta_depths: [i64] = []
    var delta_bytes_list: [[u8]] = []

    # Pass 1: classify each chunk as full or delta
    for target_id in chunk_ids:
        val (base_id, delta) = scv_pack_find_delta_base(root, target_id, full_id_list)
        if base_id != "" and delta.len() > 0:
            # Goes into delta list; base is already in full_ids
            delta_target_ids.push(target_id)
            delta_base_ids_list.push(base_id)
            delta_depths.push(1)
            delta_bytes_list.push(delta)
        else:
            # No useful delta against existing full entries: emit as full entry now
            full_ids = full_ids + target_id + "\n"
            full_id_list.push(target_id)
            val path = scv_chunk_path(root, target_id)
            val raw = scv_i64_bytes_to_u8(file_read_bytes(path) ?? [])
            payload = scv_append_text_bytes(payload, "entry chunks {target_id} {raw.len()}\n")
            payload = scv_append_bytes(payload, raw)
            payload = scv_append_text_bytes(payload, "\nendentry\n")

    # Pass 2: emit all delta entries
    var di = 0
    while di < delta_target_ids.len():
        val target_id = delta_target_ids[di]
        val base_id = delta_base_ids_list[di]
        val depth = delta_depths[di]
        val delta = delta_bytes_list[di]
        payload = scv_append_text_bytes(payload, "entry-delta chunks {target_id} {base_id} {depth} {delta.len()}\n")
        payload = scv_append_bytes(payload, delta)
        payload = scv_append_text_bytes(payload, "\nendentry\n")
        di = di + 1

    # Non-chunk object kinds: always full entries
    for kind in ["files", "trees", "commits", "changes", "operations", "conflicts", "syntax"]:
        payload = scv_pack_payload_for_kind(root, kind, payload)

    payload

fn scv_pack_write_v2(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val pack_dir = "{scv_objects_dir(root)}/packs"
    dir_create(pack_dir, true)
    var manifest = "format: scv-pack-v1\n"
    for kind in ["chunks", "files", "trees", "commits", "changes", "operations", "conflicts", "syntax"]:
        manifest = manifest + scv_pack_manifest_for_kind(root, kind)
    val pack_id = scv_hash_text("pack", manifest)
    val manifest_path = "{pack_dir}/{pack_id}.manifest"
    val gzip_path = "{pack_dir}/{pack_id}.pack.gz"
    val payload = scv_pack_payload_v2(root)
    val compressed = gzip_compress(payload)
    scv_write_text(manifest_path, manifest)
    file_write_bytes(gzip_path, compressed)
    "pack-write-v2 {pack_id} manifest={manifest_path} gzip={gzip_path} compression=gzip payload_bytes={payload.len()} compressed_bytes={compressed.len()}\n"

# Verify a v2 payload: check entry-delta base references and chain depths
fn scv_pack_v2_verify_payload(payload: [u8]) -> text:
    val header = "format: scv-pack-payload-v2\n".bytes()
    if payload.len() < header.len() or payload[0:header.len()] != header:
        return "ERROR unsupported pack payload v2 header\n"

    # First pass: collect all full-entry ids (these are valid base candidates)
    var full_ids = ""
    var delta_entries_text = ""
    var pos = header.len()

    while pos < payload.len():
        val (line, line_end) = scv_pack_bytes_line(payload, pos)
        val trimmed = line.trim()
        if trimmed == "":
            pos = line_end + 1
            continue
        if trimmed.starts_with("entry "):
            val parts = trimmed.split(" ")
            if parts.len() >= 3:
                full_ids = full_ids + parts[2] + "\n"
            val size = if parts.len() >= 4: (parts[3].to_i64() ?? -1) else: -1
            if size < 0:
                return "ERROR bad entry size in v2 payload\n"
            val data_start = line_end + 1
            val data_end = data_start + size
            if data_end > payload.len():
                return "ERROR truncated entry in v2 payload\n"
            pos = data_end + "\nendentry\n".bytes().len()
        elif trimmed.starts_with("entry-delta "):
            # entry-delta <kind> <id> <base_id> <chain_depth> <delta_byte_size>
            delta_entries_text = delta_entries_text + trimmed + "\n"
            val parts = trimmed.split(" ")
            if parts.len() < 6:
                return "ERROR malformed entry-delta in v2 payload\n"
            val size = parts[5].to_i64() ?? -1
            if size < 0:
                return "ERROR bad entry-delta size in v2 payload\n"
            val data_start = line_end + 1
            val data_end = data_start + size
            if data_end > payload.len():
                return "ERROR truncated entry-delta in v2 payload\n"
            pos = data_end + "\nendentry\n".bytes().len()
        else:
            pos = line_end + 1

    # Second pass: verify entry-delta base references and chain depths
    for entry_line in delta_entries_text.split("\n"):
        val trimmed = entry_line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split(" ")
        if parts.len() < 6:
            continue
        val base_id = parts[3]
        val chain_depth = parts[4].to_i64() ?? -1
        if chain_depth < 0:
            return "ERROR bad chain depth in entry-delta\n"
        if chain_depth > SCV_DELTA_MAX_DEPTH:
            return "ERROR chain depth {chain_depth} exceeds maximum {SCV_DELTA_MAX_DEPTH} in entry-delta\n"
        # base_id must exist as a full entry or another delta entry in this pack
        if not scv_line_set_contains(full_ids, base_id):
            if not scv_pack_v2_delta_id_exists(delta_entries_text, base_id):
                return "ERROR entry-delta references unknown base object: {base_id}\n"
    ""

fn scv_pack_v2_delta_id_exists(delta_entries_text: text, target_id: text) -> bool:
    for other_line in delta_entries_text.split("\n"):
        val other = other_line.trim()
        if other == "":
            continue
        val other_parts = other.split(" ")
        if other_parts.len() >= 3 and other_parts[2] == target_id:
            return true
    false

fn scv_pack_verify_v2(root: text, requested_pack: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val pack_dir = "{scv_objects_dir(root)}/packs"
    if not file_exists(pack_dir):
        return "ERROR missing packs directory\n"
    var checked = 0
    var entries = 0
    var delta_entries = 0
    var payload_bytes = 0
    var compressed_bytes = 0
    for path in dir_walk(pack_dir):
        if not path.ends_with(".pack.gz"):
            continue
        val pack_id = scv_pack_id_from_gzip_path(path)
        if requested_pack != "" and requested_pack != pack_id:
            continue
        val manifest_path = "{pack_dir}/{pack_id}.manifest"
        if not file_exists(manifest_path):
            return "ERROR missing pack manifest: {pack_id}\n"
        val compressed = scv_i64_bytes_to_u8(file_read_bytes(path) ?? [])
        val payload = gzip_decompress(compressed)
        if payload.len() == 0:
            return "ERROR corrupt pack payload: {pack_id}\n"
        val v2_header = "format: scv-pack-payload-v2\n".bytes()
        val v1_header = "format: scv-pack-payload-v1\n".bytes()
        if payload.len() >= v2_header.len() and payload[0:v2_header.len()] == v2_header:
            val verify_err = scv_pack_v2_verify_payload(payload)
            if verify_err != "":
                return verify_err
            # Count entries and delta entries
            var pp = v2_header.len()
            var e = 0
            var de = 0
            while pp < payload.len():
                val (line, line_end) = scv_pack_bytes_line(payload, pp)
                val t = line.trim()
                if t == "":
                    pp = line_end + 1
                    continue
                if t.starts_with("entry "):
                    val parts = t.split(" ")
                    val size = if parts.len() >= 4: (parts[3].to_i64() ?? -1) else: -1
                    if size < 0:
                        return "ERROR bad entry size in v2 pack\n"
                    e = e + 1
                    pp = line_end + 1 + size + "\nendentry\n".bytes().len()
                elif t.starts_with("entry-delta "):
                    val parts = t.split(" ")
                    val size = if parts.len() >= 6: (parts[5].to_i64() ?? -1) else: -1
                    if size < 0:
                        return "ERROR bad delta size in v2 pack\n"
                    de = de + 1
                    pp = line_end + 1 + size + "\nendentry\n".bytes().len()
                else:
                    pp = line_end + 1
            checked = checked + 1
            entries = entries + e
            delta_entries = delta_entries + de
            payload_bytes = payload_bytes + payload.len()
            compressed_bytes = compressed_bytes + compressed.len()
        elif payload.len() >= v1_header.len() and payload[0:v1_header.len()] == v1_header:
            # Fall back to v1 verify for v1 packs
            val manifest_text = file_read(manifest_path)
            val (payload_ok, payload_entries) = scv_pack_payload_matches_manifest_bytes(payload, manifest_text)
            if not payload_ok:
                return "ERROR pack manifest payload mismatch: {pack_id}\n"
            checked = checked + 1
            entries = entries + payload_entries
            payload_bytes = payload_bytes + payload.len()
            compressed_bytes = compressed_bytes + compressed.len()
        else:
            return "ERROR unsupported pack payload format: {pack_id}\n"
    if checked == 0:
        if requested_pack != "":
            return "ERROR pack not found: {requested_pack}\n"
        return "ERROR no packs found\n"
    "pack-verify-v2 packs={checked} entries={entries} delta_entries={delta_entries} payload_bytes={payload_bytes} compressed_bytes={compressed_bytes}\n"

# Resolve a delta chain and return the raw bytes of an object.
# Returns (bytes, error_text)
fn scv_pack_resolve_object(payload: [u8], target_id: text) -> ([u8], text):
    val v2_header = "format: scv-pack-payload-v2\n".bytes()
    if payload.len() < v2_header.len() or payload[0:v2_header.len()] != v2_header:
        return ([], "ERROR not a v2 payload\n")

    # Scan payload for target_id as full entry or delta entry
    var pos = v2_header.len()
    var found_full = false
    var found_full_data: [u8] = []
    var found_delta = false
    var found_base_id = ""
    var found_delta_data: [u8] = []

    while pos < payload.len():
        val (line, line_end) = scv_pack_bytes_line(payload, pos)
        val trimmed = line.trim()
        if trimmed == "":
            pos = line_end + 1
            continue
        if trimmed.starts_with("entry "):
            val parts = trimmed.split(" ")
            val size = if parts.len() >= 4: (parts[3].to_i64() ?? -1) else: -1
            if size < 0:
                return ([], "ERROR bad entry size\n")
            val data_start = line_end + 1
            val data_end = data_start + size
            if parts.len() >= 3 and parts[2] == target_id:
                found_full = true
                found_full_data = payload[data_start:data_end]
            pos = data_end + "\nendentry\n".bytes().len()
        elif trimmed.starts_with("entry-delta "):
            val parts = trimmed.split(" ")
            val size = if parts.len() >= 6: (parts[5].to_i64() ?? -1) else: -1
            if size < 0:
                return ([], "ERROR bad delta size\n")
            val data_start = line_end + 1
            val data_end = data_start + size
            if parts.len() >= 4 and parts[2] == target_id:
                found_delta = true
                found_base_id = parts[3]
                found_delta_data = payload[data_start:data_end]
            pos = data_end + "\nendentry\n".bytes().len()
        else:
            pos = line_end + 1

    if found_full:
        return (found_full_data, "")

    if found_delta:
        val (base_bytes, base_err) = scv_pack_resolve_object(payload, found_base_id)
        if base_err != "":
            return ([], base_err)
        val (result, decode_err) = scv_delta_decode(base_bytes, found_delta_data)
        if decode_err != "":
            return ([], decode_err)
        return (result, "")

    ([], "ERROR object not found in pack: {target_id}\n")

fn scv_pack_read_object(root: text, pack_id: text, object_id: text) -> [u8]:
    val pack_dir = "{scv_objects_dir(root)}/packs"
    for path in dir_walk(pack_dir):
        if not path.ends_with(".pack.gz"):
            continue
        val pid = scv_pack_id_from_gzip_path(path)
        if pack_id != "" and pack_id != pid:
            continue
        val compressed = scv_i64_bytes_to_u8(file_read_bytes(path) ?? [])
        val payload = gzip_decompress(compressed)
        val v2_header = "format: scv-pack-payload-v2\n".bytes()
        if payload.len() >= v2_header.len() and payload[0:v2_header.len()] == v2_header:
            val (data, err) = scv_pack_resolve_object(payload, object_id)
            if err == "":
                return data
    []
