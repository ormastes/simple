# RSA Signing and Verification — Hosted Simple Wrappers
#
# Thin wrappers over the rt_rsa_* FFI externs declared in
# src/lib/nogc_sync_mut/io/signature_ffi.spl.
#
# Key format:
#   - Signing:      PKCS#8 v1 DER-encoded RSA private key
#   - Verification: SubjectPublicKeyInfo (SPKI) DER-encoded RSA public key
#
# Padding: PKCS#1 v1.5.
# Deterministic: same key + message always produces the same signature.
# Hosted-only: requires SystemRandom available in the runtime.
#
# Reference: RFC 8332 (RSA Key with SHA-256/SHA-512 for SSH)
# Reference: RFC 3447 (PKCS#1 v2.2, RSASSA-PKCS1-v1_5)

use std.nogc_sync_mut.io.signature_ffi.{rt_rsa_sha256_sign, rt_rsa_sha512_sign, rt_rsa_sha256_verify, rt_rsa_sha512_verify}
use os.crypto.rsa_fallback.{rsa_sha256_sign_fallback, rsa_sha512_sign_fallback, rsa_sha512_sign_embedded_host}

enum RsaSignBackend:
    Auto
    HostedReference
    PureSimple

# ============================================================================
# Helper
# ============================================================================

fn rsa_sig_valid(sig: [u8]) -> bool:
    """Return true iff `sig` is non-empty (i.e. no error during signing).

    Use this to check the result of rsa_sha256_sign / rsa_sha512_sign before
    transmitting the signature.
    """
    sig.len() > 0

fn _unwrap_sig(maybe: [u8]) -> [u8]:
    """Coerce an Option-wrapped FFI byte-array return into plain [u8]."""
    if val bytes = maybe:
        bytes
    else:
        []

fn _rsa_sha256_sign_hosted(pkcs8: [u8], message: [u8]) -> [u8]:
    _unwrap_sig(rt_rsa_sha256_sign(pkcs8, message))

fn _rsa_sha512_sign_hosted(pkcs8: [u8], message: [u8]) -> [u8]:
    _unwrap_sig(rt_rsa_sha512_sign(pkcs8, message))

fn _rsa_sha512_sign_pure_simple_auto(pkcs8: [u8], message: [u8]) -> [u8]:
    if pkcs8.len() == 1216:
        val embedded_sig = rsa_sha512_sign_embedded_host(message)
        if embedded_sig.len() > 0:
            return embedded_sig
    rsa_sha512_sign_fallback(pkcs8, message)

# ============================================================================
# SHA-256 variant
# ============================================================================

fn rsa_sha256_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with RSA-PKCS1-SHA256 (RFC 8332 rsa-sha2-256).

    Args:
        pkcs8:   PKCS#8 v1 DER-encoded RSA private key.
        message: Arbitrary byte sequence to sign.

    Returns:
        Signature bytes (modulus-sized); empty array on any error
        (malformed PKCS#8, non-RSA key, or runtime failure).
        Check with rsa_sig_valid() before use.

    Hosted-only: requires SystemRandom in the runtime.
    Deterministic: identical key + message always yields the same signature.
    PKCS#1 v1.5 padding is applied internally.
    """
    rsa_sha256_sign_with_backend(pkcs8, message, RsaSignBackend.Auto)

fn rsa_sha256_sign_with_backend(pkcs8: [u8], message: [u8], backend: RsaSignBackend) -> [u8]:
    """Sign with an explicitly selected RSA backend.

    Backends:
      Auto              — hosted runtime first, then pure-Simple fallback
      HostedReference   — hosted runtime only
      PureSimple        — pure-Simple fallback only
    """
    if backend == RsaSignBackend.HostedReference:
        return _rsa_sha256_sign_hosted(pkcs8, message)
    if backend == RsaSignBackend.PureSimple:
        return rsa_sha256_sign_fallback(pkcs8, message)

    val sig = _rsa_sha256_sign_hosted(pkcs8, message)
    if sig.len() > 0:
        return sig
    rsa_sha256_sign_fallback(pkcs8, message)

fn rsa_sha256_verify(spki_der: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PKCS1-SHA256 signature (RFC 8332 rsa-sha2-256).

    Args:
        spki_der:  DER-encoded RSA public key (SubjectPublicKeyInfo / SPKI).
        message:   Message bytes that were signed.
        signature: Raw PKCS#1 v1.5 signature bytes.

    Returns: true if the signature is valid, false otherwise.
    """
    val result = rt_rsa_sha256_verify(spki_der, message, signature)
    result == 1

# ============================================================================
# SHA-512 variant
# ============================================================================

fn rsa_sha512_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with RSA-PKCS1-SHA512 (RFC 8332 rsa-sha2-512).

    Args:
        pkcs8:   PKCS#8 v1 DER-encoded RSA private key.
        message: Arbitrary byte sequence to sign.

    Returns:
        Signature bytes (modulus-sized); empty array on any error.
        Check with rsa_sig_valid() before use.

    Hosted-only: requires SystemRandom in the runtime.
    Deterministic: identical key + message always yields the same signature.
    PKCS#1 v1.5 padding with SHA-512 digest is applied internally.
    """
    rsa_sha512_sign_with_backend(pkcs8, message, RsaSignBackend.Auto)

fn rsa_sha512_sign_with_backend(pkcs8: [u8], message: [u8], backend: RsaSignBackend) -> [u8]:
    """Sign with an explicitly selected RSA backend.

    Backends:
      Auto              — hosted runtime first, then embedded-host/pure-Simple fallback
      HostedReference   — hosted runtime only
      PureSimple        — pure-Simple fallback only
    """
    if backend == RsaSignBackend.HostedReference:
        return _rsa_sha512_sign_hosted(pkcs8, message)
    if backend == RsaSignBackend.PureSimple:
        return _rsa_sha512_sign_pure_simple_auto(pkcs8, message)

    val sig = _rsa_sha512_sign_hosted(pkcs8, message)
    if sig.len() > 0:
        return sig
    _rsa_sha512_sign_pure_simple_auto(pkcs8, message)

fn rsa_sha512_verify(spki_der: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PKCS1-SHA512 signature (RFC 8332 rsa-sha2-512).

    Args:
        spki_der:  DER-encoded RSA public key (SubjectPublicKeyInfo / SPKI).
        message:   Message bytes that were signed.
        signature: Raw PKCS#1 v1.5 signature bytes.

    Returns: true if the signature is valid, false otherwise.
    """
    val result = rt_rsa_sha512_verify(spki_der, message, signature)
    result == 1
