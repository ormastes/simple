# x86_64 Arch Adapter Root
#
# Aggregates the x86_64 adapter surface under one module namespace.

use os.kernel.arch.x86_64.console.{X86Console}
use os.kernel.arch.x86_64.boot.{X86Boot}
use os.kernel.arch.x86_64.cpu.{X86Cpu}
use os.kernel.arch.x86_64.paging.{X86Paging}
use os.kernel.arch.x86_64.interrupt.{X86Interrupt}
use os.kernel.arch.x86_64.timer.{X86Timer}
use os.kernel.arch.x86_64.context.{X86ContextSwitch}

struct X86_64HalAdapter:
    """x86_64 adapter aggregate for portable kernel HAL call sites."""
    console: X86Console
    boot: X86Boot
    cpu: X86Cpu
    paging: X86Paging
    interrupt: X86Interrupt
    timer: X86Timer
    context: X86ContextSwitch

fn create_x86_64_hal_adapter() -> X86_64HalAdapter:
    """Create an x86_64 adapter aggregate."""
    X86_64HalAdapter(
        console: X86Console(),
        boot: X86Boot(),
        cpu: X86Cpu(),
        paging: X86Paging(),
        interrupt: X86Interrupt(),
        timer: X86Timer(),
        context: X86ContextSwitch()
    )

