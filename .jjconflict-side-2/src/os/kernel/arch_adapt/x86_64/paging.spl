# x86_64 Paging Adapter
#
# Thin wrapper layer over the concrete x86_64 paging module.

use os.kernel.boot.ports.{BootOutputPort}
use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}
use os.kernel.memory.pmm.{PhysMemManager}
use os.kernel.arch.x86_64.paging.{X86Paging}

fn paging_init(boot_info: BootOutputPort):
    """Initialize the x86_64 paging subsystem."""
    var paging = X86Paging()
    paging.init(PhysMemManager(), boot_info.hhdm_offset)

fn paging_map(virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    """Map one x86_64 page."""
    var paging = X86Paging()
    paging.map_page(virt, phys, flags)

fn paging_unmap(virt: VirtAddr) -> bool:
    """Unmap one x86_64 page."""
    var paging = X86Paging()
    paging.unmap_page(virt)

fn paging_translate(virt: VirtAddr) -> PhysAddr?:
    """Translate one x86_64 virtual address."""
    var paging = X86Paging()
    paging.translate(virt)

fn paging_create_address_space() -> u64:
    """Create a new x86_64 address-space root."""
    var paging = X86Paging()
    paging.create_address_space()

fn paging_switch_address_space(root_phys: u64):
    """Switch the active x86_64 address space."""
    var paging = X86Paging()
    paging.switch_address_space(root_phys)

fn paging_levels() -> u32:
    """Return the number of x86_64 paging levels."""
    var paging = X86Paging()
    paging.address_levels() as u32

