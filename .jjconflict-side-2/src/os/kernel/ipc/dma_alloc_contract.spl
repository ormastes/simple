# DMA allocation syscall ABI contract.
#
# Syscall 84 returns the CPU virtual address as the syscall result. The caller's
# result buffer keeps device-facing metadata: word 0 is physical/device address,
# word 1 is allocation id. NVMe and VFS adapters must not read word 1 as a
# virtual address.

struct DmaAllocSyscallView:
    virt_addr: u64
    phys_addr: u64
    allocation_id: u64

fn dma_alloc_syscall_view(syscall_return: i64, result_phys: u64, result_allocation_id: u64) -> Result<DmaAllocSyscallView, text>:
    if syscall_return <= 0:
        return Err("dma-alloc-syscall-failed")
    if result_phys == 0u64:
        return Err("dma-alloc-missing-phys")
    if result_allocation_id == 0u64:
        return Err("dma-alloc-missing-allocation-id")
    Ok(DmaAllocSyscallView(
        virt_addr: syscall_return as u64,
        phys_addr: result_phys,
        allocation_id: result_allocation_id
    ))
