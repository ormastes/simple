# x86_32 Trap Runtime Bundle
#
# Owns the kernel runtime objects needed by the i386 int 0x80 bridge.

use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}

struct X86_32TrapRuntime:
    scheduler: Scheduler
    ipc: IpcManager
    klog: KernelLog

impl X86_32TrapRuntime:
    static fn new(scheduler: Scheduler, ipc: IpcManager, klog: KernelLog) -> X86_32TrapRuntime:
        X86_32TrapRuntime(
            scheduler: scheduler,
            ipc: ipc,
            klog: klog
        )

    static fn bootstrap(log_capacity: u64) -> X86_32TrapRuntime:
        X86_32TrapRuntime(
            scheduler: Scheduler.new_bootstrap(),
            ipc: IpcManager.new(),
            klog: KernelLog.new(log_capacity)
        )
