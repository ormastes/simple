# HRR P-256 connect helper — extracted from tls13_part3.spl
# Handles the GROUP_SECP256R1 branch of a HelloRetryRequest.
# All paths in this function return Tls13ConnectResult.Failed (AC-5 deferred).
use os.tls13.tls13.*
use os.tls13.transcript.*
use os.tls13.key_schedule.*
use os.tls13.hkdf.*
use os.tls13.handshake13.*
use os.crypto.ecdh_p256.*

fn _hrr_p256_connect(io: Tls13Io, value: HrrFlowOk, p256_scalar: [u8]) -> Tls13ConnectResult:
    """Handle the P-256 HRR branch: send CH2, receive SH2, run P-256 ECDHE,
    derive handshake_secret + traffic keys. Returns Failed (AC-5 deferred)."""
    # Send CH2 with the P-256 share.
    val ch2_record_p = _build_plaintext_record(0x16, value.client_hello2_bytes)
    if not _io_send(io, ch2_record_p):
        return Tls13ConnectResult.Failed(reason: "ClientHello2 send failed")
    # §4.4.1 transcript replacement: synthetic message_hash
    # || HRR-handshake-bytes || CH2.
    var transcript = transcript_new()
    transcript = transcript_add(transcript, value.transcript_seed)
    transcript = transcript_add(transcript, value.client_hello2_bytes)
    # Receive SH2 (the real ServerHello after HRR).
    val sh2_raw = _io_recv_record(io)
    if sh2_raw.len() < 5:
        return Tls13ConnectResult.Failed(reason: "ServerHello2: short read")
    val sh2_pay_len_i = rt_tls13_record_payload_len(sh2_raw)
    if sh2_pay_len_i <= 0:
        return Tls13ConnectResult.Failed(reason: "ServerHello2: invalid record length")
    val sh2_pay_len = sh2_pay_len_i.to_u64()
    val sh2_hs_bytes = _copy_range(sh2_raw, 5, sh2_pay_len)
    val sh2_body_bytes = _copy_range(sh2_hs_bytes, 4, sh2_pay_len - 4)
    val sh2: ServerHello13 = parse_server_hello(sh2_body_bytes)
    # §4.1.4: a second HRR is illegal.
    if is_hello_retry_request(sh2):
        return Tls13ConnectResult.Failed(reason: "unexpected_message: second HRR in connection")
    # Cipher-suite scope: connect flow only advertises 0x1301
    # (TLS_AES_128_GCM_SHA256). Reject anything else — SHA-384
    # (0x1302) wiring is a follow-up.
    if sh2.cipher_suite != 0x1301u16:
        return Tls13ConnectResult.Failed(reason: "ServerHello2: unsupported cipher_suite for P-256 path")
    # Server MUST send a P-256 key_share since HRR picked it.
    val server_p256_pub = sh2.p256_pub
    if server_p256_pub.len() != 65:
        return Tls13ConnectResult.Failed(reason: "ServerHello2: missing or malformed P-256 key_share")
    # Add SH2 handshake bytes to the transcript.
    transcript = transcript_add_with_len(transcript, sh2_hs_bytes, sh2_pay_len)
    # P-256 ECDHE → 32-byte shared X (RFC 8446 §7.4.2 / RFC 8422
    # §5.4: shared secret is the X-coordinate of scalar*peer).
    val p256_shared = p256_ecdh_shared_x(p256_scalar, server_p256_pub)
    if p256_shared.len() != 32:
        return Tls13ConnectResult.Failed(reason: "P-256 ECDHE: shared_x compute failed")
    # Drive the SHA-256 key schedule with the P-256 shared X.
    val secrets_p = tls13_compute_handshake_secrets(p256_shared, transcript)
    # Derive AES-128 traffic key + IV for both directions.
    # Deferred (AC-5): server Finished MAC verify, client
    # Finished, application traffic secrets. Surfaced as a
    # typed Failed so callers see the milestone.
    val client_hs_tk_p = tls13_traffic_keys(secrets_p.client_hs_traffic)
    val server_hs_tk_p = tls13_traffic_keys(secrets_p.server_hs_traffic)
    _tls_debug("P-256 ECDHE done shared={p256_shared.len()} hs={secrets_p.handshake_secret.len()} c_key={client_hs_tk_p.key.len()} s_key={server_hs_tk_p.key.len()}")
    Tls13ConnectResult.Failed(reason: "HRR P-256 handshake-secret derived; Finished MAC verify deferred — see crypto_recovery_status.md Wave 6")
