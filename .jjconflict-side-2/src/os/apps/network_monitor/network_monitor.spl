use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class NetworkMonitorApp:

    static fn new() -> NetworkMonitorApp:
        NetworkMonitorApp()

    me build_ui() -> UISession:
        val iface_eth0 = row("iface_eth0", [
            label("lbl_eth0", "eth0"),
            text_widget("eth0_ip", "192.168.1.42"),
            text_widget("eth0_mask", "255.255.255.0"),
            text_widget("eth0_state", "UP")
        ])

        val iface_lo = row("iface_lo", [
            label("lbl_lo", "lo"),
            text_widget("lo_ip", "127.0.0.1"),
            text_widget("lo_mask", "255.0.0.0"),
            text_widget("lo_state", "UP")
        ])

        val interfaces = panel("interfaces_panel", "Network Interfaces", [
            row("iface_header", [
                label("hdr_name", "Name"),
                label("hdr_ip", "IP Address"),
                label("hdr_mask", "Netmask"),
                label("hdr_state", "State")
            ]),
            iface_eth0,
            iface_lo
        ])

        val traffic = panel("traffic_panel", "Traffic Statistics", [
            row("traffic_eth0", [
                label("lbl_eth0_traffic", "eth0"),
                text_widget("eth0_rx", "RX: 142.3 MB"),
                text_widget("eth0_tx", "TX: 28.7 MB"),
                text_widget("eth0_pkt", "Packets: 98,432")
            ]),
            row("traffic_lo", [
                label("lbl_lo_traffic", "lo"),
                text_widget("lo_rx", "RX: 0.5 MB"),
                text_widget("lo_tx", "TX: 0.5 MB"),
                text_widget("lo_pkt", "Packets: 1,204")
            ])
        ])

        val conn1 = row("conn1", [
            text_widget("c1_local", "192.168.1.42:45231"),
            text_widget("c1_remote", "93.184.216.34:443"),
            text_widget("c1_state", "ESTABLISHED")
        ])

        val conn2 = row("conn2", [
            text_widget("c2_local", "192.168.1.42:58902"),
            text_widget("c2_remote", "172.217.14.78:80"),
            text_widget("c2_state", "TIME_WAIT")
        ])

        val conn3 = row("conn3", [
            text_widget("c3_local", "0.0.0.0:22"),
            text_widget("c3_remote", "0.0.0.0:*"),
            text_widget("c3_state", "LISTEN")
        ])

        val connections = panel("connections_panel", "Active Connections", [
            row("conn_header", [
                label("hdr_local", "Local Address"),
                label("hdr_remote", "Remote Address"),
                label("hdr_cstate", "State")
            ]),
            conn1,
            conn2,
            conn3
        ])

        val actions = row("netmon_actions", [
            button("btn_refresh", "Refresh", "netmon.refresh"),
            button("btn_reset_stats", "Reset Stats", "netmon.reset_stats"),
            button("btn_export", "Export", "netmon.export")
        ])

        val status = statusbar("netmon_status", "eth0: 192.168.1.42  lo: 127.0.0.1", "Last refresh: just now")

        val root = column("netmon_root", [
            interfaces,
            traffic,
            connections,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "Network Monitor", "dark")
        UISession.new(tree)
