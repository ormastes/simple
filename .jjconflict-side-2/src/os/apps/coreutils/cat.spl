# coreutils/cat — concatenate and print files
#
# Pure library module. Entry point: main_cat(args).
# Filesystem access via VFS extern shims resolved at link time.
#
# MDSOC: feature dimension, apps/coreutils layer

use os.userlib.log.{log_info, log_error}

extern fn vfs_open(path: text, flags: i32) -> i64
extern fn vfs_read_line(handle: i64) -> text
extern fn vfs_close(handle: i64) -> i32

val _O_RDONLY: i32 = 0

fn cat_one(path: text) -> i32:
    """Print one file's contents. Returns 0 on success, -errno on failure."""
    val handle = vfs_open(path, _O_RDONLY)
    if handle < 0:
        log_error("[cat] cannot open: {path}")
        return handle as i32
    var line = vfs_read_line(handle)
    while line != "":
        log_info("{line}")
        line = vfs_read_line(handle)
    vfs_close(handle)
    0

fn main_cat(args: [text]) -> i32:
    """Print the concatenation of each file.

    Usage: cat path [path...]
    """
    if args.len() == 0:
        log_error("cat: expected at least one path")
        return 1
    var i: i32 = 0
    while i < args.len() as i32:
        val r = cat_one(args[i as u64])
        if r != 0:
            return r
        i = i + 1
    0
