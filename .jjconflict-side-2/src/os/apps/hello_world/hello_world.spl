# Hello World App — MDSOC+ capsule with ECS inner state
#
# MDSOC+: capsule outer + ECS business layer.
# Demo app showing the MDSOC+ pattern with minimal components.

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}
use std.ecs.entity.{Entity}
use os.apps.hello_world.ecs.world.{HelloWorldWorld}
use os.apps.hello_world.ecs.systems.{sys_update_greeting}

class HelloWorldApp:
    world: HelloWorldWorld
    greeting_entity: Entity

    static fn new() -> HelloWorldApp:
        var w = HelloWorldWorld.new()
        val ge = w.spawn_greeting()
        w.spawn_sys_info("OS", "SimpleOS 0.1.0")
        w.spawn_sys_info("Architecture", "x86_64")
        w.spawn_sys_info("Kernel", "Simple Kernel 0.1.0")
        w.spawn_sys_info("Language", "Simple 1.0")
        HelloWorldApp(world: w, greeting_entity: ge)

    me build_ui() -> UISession:
        val greeting = panel("greeting_panel", "Welcome", [
            text_widget("hello_title", "Hello, SimpleOS!"),
            text_widget("hello_version", "Version 0.1.0 - Alpha"),
            text_widget("hello_desc", "A modern operating system written in the Simple language.")
        ])

        val info = panel("info_panel", "System Info", [
            row("info_row_os", [
                label("lbl_os", "OS:"),
                text_widget("val_os", "SimpleOS 0.1.0")
            ]),
            row("info_row_arch", [
                label("lbl_arch", "Architecture:"),
                text_widget("val_arch", "x86_64")
            ]),
            row("info_row_kernel", [
                label("lbl_kernel", "Kernel:"),
                text_widget("val_kernel", "Simple Kernel 0.1.0")
            ]),
            row("info_row_lang", [
                label("lbl_lang", "Language:"),
                text_widget("val_lang", "Simple 1.0")
            ])
        ])

        val actions = row("actions_row", [
            button("btn_tour", "Take a Tour", "hello.tour"),
            button("btn_docs", "Open Docs", "hello.docs"),
            button("btn_close", "Close", "hello.close")
        ])

        val status = statusbar("hello_status", "SimpleOS ready", "May 2026")

        val root = column("hello_root", [
            greeting,
            info,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "Hello, SimpleOS!", "dark")
        UISession.new(tree)
