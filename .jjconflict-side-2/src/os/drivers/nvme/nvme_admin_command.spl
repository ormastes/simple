# Syscall-free NVMe admin command construction shared by hosted and freestanding drivers.

use os.drivers.nvme.nvme_types.{
    NVME_ADMIN_IDENTIFY,
    NVME_ADMIN_SET_FEATURES,
    NVME_ADMIN_CREATE_IOCQ,
    NVME_ADMIN_CREATE_IOSQ,
    IDENTIFY_CNS_NAMESPACE,
    IDENTIFY_CNS_CONTROLLER
}

struct NvmeAdminCommand:
    opcode: u8
    nsid: u32
    prp1: u64
    prp2: u64
    cdw10: u32
    cdw11: u32
    cdw12: u32

fn nvme_admin_identify_controller(buf_phys: u64) -> Result<NvmeAdminCommand, text>:
    if buf_phys == 0u64:
        return Err("nvme-admin-identify-buffer-zero")
    Ok(NvmeAdminCommand(
        opcode: NVME_ADMIN_IDENTIFY,
        nsid: 0u32,
        prp1: buf_phys,
        prp2: 0u64,
        cdw10: IDENTIFY_CNS_CONTROLLER,
        cdw11: 0u32,
        cdw12: 0u32
    ))

fn nvme_admin_identify_namespace(nsid: u32, buf_phys: u64) -> Result<NvmeAdminCommand, text>:
    if nsid == 0u32:
        return Err("nvme-admin-identify-namespace-zero")
    if buf_phys == 0u64:
        return Err("nvme-admin-identify-buffer-zero")
    Ok(NvmeAdminCommand(
        opcode: NVME_ADMIN_IDENTIFY,
        nsid: nsid,
        prp1: buf_phys,
        prp2: 0u64,
        cdw10: IDENTIFY_CNS_NAMESPACE,
        cdw11: 0u32,
        cdw12: 0u32
    ))

fn nvme_admin_set_num_queues(nsq: u16, ncq: u16) -> Result<NvmeAdminCommand, text>:
    if nsq == 0u16 or ncq == 0u16:
        return Err("nvme-admin-queue-count-zero")
    val nsqr = (nsq - 1u16).to_u32()
    val ncqr = (ncq - 1u16).to_u32()
    Ok(NvmeAdminCommand(
        opcode: NVME_ADMIN_SET_FEATURES,
        nsid: 0u32,
        prp1: 0u64,
        prp2: 0u64,
        cdw10: 0x07u32,
        cdw11: nsqr | (ncqr << 16),
        cdw12: 0u32
    ))

fn nvme_admin_create_io_completion_queue(qid: u16, depth: u16, cq_phys: u64) -> Result<NvmeAdminCommand, text>:
    if qid == 0u16:
        return Err("nvme-admin-iocq-qid-zero")
    if depth == 0u16:
        return Err("nvme-admin-iocq-depth-zero")
    if cq_phys == 0u64:
        return Err("nvme-admin-iocq-phys-zero")
    Ok(NvmeAdminCommand(
        opcode: NVME_ADMIN_CREATE_IOCQ,
        nsid: 0u32,
        prp1: cq_phys,
        prp2: 0u64,
        cdw10: qid.to_u32() | ((depth - 1u16).to_u32() << 16),
        cdw11: 0x01u32,
        cdw12: 0u32
    ))

fn nvme_admin_create_io_submission_queue(qid: u16, depth: u16, cqid: u16, sq_phys: u64) -> Result<NvmeAdminCommand, text>:
    if qid == 0u16:
        return Err("nvme-admin-iosq-qid-zero")
    if cqid == 0u16:
        return Err("nvme-admin-iosq-cqid-zero")
    if depth == 0u16:
        return Err("nvme-admin-iosq-depth-zero")
    if sq_phys == 0u64:
        return Err("nvme-admin-iosq-phys-zero")
    Ok(NvmeAdminCommand(
        opcode: NVME_ADMIN_CREATE_IOSQ,
        nsid: 0u32,
        prp1: sq_phys,
        prp2: 0u64,
        cdw10: qid.to_u32() | ((depth - 1u16).to_u32() << 16),
        cdw11: 0x01u32 | (cqid.to_u32() << 16),
        cdw12: 0u32
    ))
