# Game prefix manifest, sandbox capability, policy, and enforcer
# for SimpleOS Game Compatibility Platform — Task 3.

# ---------------------------------------------------------------------------
# PrefixManifest — parsed game Wine/Proton prefix manifest
# ---------------------------------------------------------------------------

class PrefixManifest:
    app_id: text
    app_name: text
    install_path: text
    wine_prefix: text
    proton_version: text
    lib_override_count: i64
    lo0_name: text
    lo1_name: text
    lo2_name: text
    lo3_name: text
    lo4_name: text
    lo5_name: text
    lo6_name: text
    lo7_name: text
    lo0_path: text
    lo1_path: text
    lo2_path: text
    lo3_path: text
    lo4_path: text
    lo5_path: text
    lo6_path: text
    lo7_path: text
    env_count: i64
    ev0_key: text
    ev1_key: text
    ev2_key: text
    ev3_key: text
    ev4_key: text
    ev5_key: text
    ev6_key: text
    ev7_key: text
    ev0_val: text
    ev1_val: text
    ev2_val: text
    ev3_val: text
    ev4_val: text
    ev5_val: text
    ev6_val: text
    ev7_val: text

impl PrefixManifest:

    static fn create(id: text, name: text, path: text) -> PrefixManifest:
        PrefixManifest(
            app_id: id,
            app_name: name,
            install_path: path,
            wine_prefix: "",
            proton_version: "",
            lib_override_count: 0,
            lo0_name: "", lo1_name: "", lo2_name: "", lo3_name: "",
            lo4_name: "", lo5_name: "", lo6_name: "", lo7_name: "",
            lo0_path: "", lo1_path: "", lo2_path: "", lo3_path: "",
            lo4_path: "", lo5_path: "", lo6_path: "", lo7_path: "",
            env_count: 0,
            ev0_key: "", ev1_key: "", ev2_key: "", ev3_key: "",
            ev4_key: "", ev5_key: "", ev6_key: "", ev7_key: "",
            ev0_val: "", ev1_val: "", ev2_val: "", ev3_val: "",
            ev4_val: "", ev5_val: "", ev6_val: "", ev7_val: ""
        )

    me set_proton(prefix: text, version: text) -> text:
        self.wine_prefix = prefix
        self.proton_version = version
        ""

    me add_lib_override(name: text, path: text) -> text:
        val idx = self.lib_override_count
        if idx >= 8:
            return "full"
        if idx == 0:
            self.lo0_name = name
            self.lo0_path = path
        if idx == 1:
            self.lo1_name = name
            self.lo1_path = path
        if idx == 2:
            self.lo2_name = name
            self.lo2_path = path
        if idx == 3:
            self.lo3_name = name
            self.lo3_path = path
        if idx == 4:
            self.lo4_name = name
            self.lo4_path = path
        if idx == 5:
            self.lo5_name = name
            self.lo5_path = path
        if idx == 6:
            self.lo6_name = name
            self.lo6_path = path
        if idx == 7:
            self.lo7_name = name
            self.lo7_path = path
        self.lib_override_count = idx + 1
        ""

    me add_env(key: text, val: text) -> text:
        val idx = self.env_count
        if idx >= 8:
            return "full"
        if idx == 0:
            self.ev0_key = key
            self.ev0_val = val
        if idx == 1:
            self.ev1_key = key
            self.ev1_val = val
        if idx == 2:
            self.ev2_key = key
            self.ev2_val = val
        if idx == 3:
            self.ev3_key = key
            self.ev3_val = val
        if idx == 4:
            self.ev4_key = key
            self.ev4_val = val
        if idx == 5:
            self.ev5_key = key
            self.ev5_val = val
        if idx == 6:
            self.ev6_key = key
            self.ev6_val = val
        if idx == 7:
            self.ev7_key = key
            self.ev7_val = val
        self.env_count = idx + 1
        ""

    fn has_proton() -> bool:
        self.proton_version != ""

    fn summary() -> text:
        "app=" + self.app_id + " name=" + self.app_name +
        " proton=" + self.proton_version +
        " lib_overrides=" + self.lib_override_count.to_text() +
        " envs=" + self.env_count.to_text()

# ---------------------------------------------------------------------------
# SandboxCapability — a single capability grant
# ---------------------------------------------------------------------------

class SandboxCapability:
    name: text
    granted: bool
    restricted: bool
    restriction_detail: text

impl SandboxCapability:

    static fn allow(name: text) -> SandboxCapability:
        SandboxCapability(name: name, granted: true, restricted: false, restriction_detail: "")

    static fn deny(name: text) -> SandboxCapability:
        SandboxCapability(name: name, granted: false, restricted: false, restriction_detail: "")

    static fn restrict(name: text, detail: text) -> SandboxCapability:
        SandboxCapability(name: name, granted: true, restricted: true, restriction_detail: detail)

    fn is_allowed() -> bool:
        self.granted

    fn summary() -> text:
        if self.granted == false:
            return "cap=" + self.name + " denied"
        if self.restricted:
            return "cap=" + self.name + " restricted:" + self.restriction_detail
        "cap=" + self.name + " allowed"

# ---------------------------------------------------------------------------
# SandboxPolicy — deny-by-default policy with flat max 8 capabilities
# ---------------------------------------------------------------------------

class SandboxPolicy:
    app_id: text
    cap_count: i64
    c0_name: text
    c1_name: text
    c2_name: text
    c3_name: text
    c4_name: text
    c5_name: text
    c6_name: text
    c7_name: text
    c0_granted: bool
    c1_granted: bool
    c2_granted: bool
    c3_granted: bool
    c4_granted: bool
    c5_granted: bool
    c6_granted: bool
    c7_granted: bool
    c0_restricted: bool
    c1_restricted: bool
    c2_restricted: bool
    c3_restricted: bool
    c4_restricted: bool
    c5_restricted: bool
    c6_restricted: bool
    c7_restricted: bool
    c0_detail: text
    c1_detail: text
    c2_detail: text
    c3_detail: text
    c4_detail: text
    c5_detail: text
    c6_detail: text
    c7_detail: text

impl SandboxPolicy:

    static fn create(id: text) -> SandboxPolicy:
        SandboxPolicy(
            app_id: id,
            cap_count: 0,
            c0_name: "", c1_name: "", c2_name: "", c3_name: "",
            c4_name: "", c5_name: "", c6_name: "", c7_name: "",
            c0_granted: false, c1_granted: false, c2_granted: false, c3_granted: false,
            c4_granted: false, c5_granted: false, c6_granted: false, c7_granted: false,
            c0_restricted: false, c1_restricted: false, c2_restricted: false, c3_restricted: false,
            c4_restricted: false, c5_restricted: false, c6_restricted: false, c7_restricted: false,
            c0_detail: "", c1_detail: "", c2_detail: "", c3_detail: "",
            c4_detail: "", c5_detail: "", c6_detail: "", c7_detail: ""
        )

    static fn default_game(id: text) -> SandboxPolicy:
        var p = SandboxPolicy.create(id)
        p.grant("gpu")
        p.grant("audio")
        p.grant("input")
        p.restrict("filesystem", "read-write within prefix only")
        p.deny("network")
        p.deny("ipc")
        p.deny("camera")
        p.deny("clipboard")
        p

    me _set_slot(idx: i64, name: text, granted: bool, restricted: bool, detail: text) -> text:
        if idx == 0:
            self.c0_name = name
            self.c0_granted = granted
            self.c0_restricted = restricted
            self.c0_detail = detail
        if idx == 1:
            self.c1_name = name
            self.c1_granted = granted
            self.c1_restricted = restricted
            self.c1_detail = detail
        if idx == 2:
            self.c2_name = name
            self.c2_granted = granted
            self.c2_restricted = restricted
            self.c2_detail = detail
        if idx == 3:
            self.c3_name = name
            self.c3_granted = granted
            self.c3_restricted = restricted
            self.c3_detail = detail
        if idx == 4:
            self.c4_name = name
            self.c4_granted = granted
            self.c4_restricted = restricted
            self.c4_detail = detail
        if idx == 5:
            self.c5_name = name
            self.c5_granted = granted
            self.c5_restricted = restricted
            self.c5_detail = detail
        if idx == 6:
            self.c6_name = name
            self.c6_granted = granted
            self.c6_restricted = restricted
            self.c6_detail = detail
        if idx == 7:
            self.c7_name = name
            self.c7_granted = granted
            self.c7_restricted = restricted
            self.c7_detail = detail
        ""

    me _find_slot(name: text) -> i64:
        if self.c0_name == name:
            return 0
        if self.c1_name == name:
            return 1
        if self.c2_name == name:
            return 2
        if self.c3_name == name:
            return 3
        if self.c4_name == name:
            return 4
        if self.c5_name == name:
            return 5
        if self.c6_name == name:
            return 6
        if self.c7_name == name:
            return 7
        -1

    me grant(name: text) -> text:
        val existing = self._find_slot(name)
        if existing >= 0:
            self._set_slot(existing, name, true, false, "")
            return ""
        val idx = self.cap_count
        if idx >= 8:
            return "full"
        self._set_slot(idx, name, true, false, "")
        self.cap_count = idx + 1
        ""

    me deny(name: text) -> text:
        val existing = self._find_slot(name)
        if existing >= 0:
            self._set_slot(existing, name, false, false, "")
            return ""
        val idx = self.cap_count
        if idx >= 8:
            return "full"
        self._set_slot(idx, name, false, false, "")
        self.cap_count = idx + 1
        ""

    me restrict(name: text, detail: text) -> text:
        val existing = self._find_slot(name)
        if existing >= 0:
            self._set_slot(existing, name, true, true, detail)
            return ""
        val idx = self.cap_count
        if idx >= 8:
            return "full"
        self._set_slot(idx, name, true, true, detail)
        self.cap_count = idx + 1
        ""

    fn _slot_granted(idx: i64) -> bool:
        if idx == 0: return self.c0_granted
        if idx == 1: return self.c1_granted
        if idx == 2: return self.c2_granted
        if idx == 3: return self.c3_granted
        if idx == 4: return self.c4_granted
        if idx == 5: return self.c5_granted
        if idx == 6: return self.c6_granted
        if idx == 7: return self.c7_granted
        false

    fn is_allowed(name: text) -> bool:
        val idx = self._find_slot(name)
        if idx < 0:
            return false
        self._slot_granted(idx)

    fn granted_count() -> i64:
        var count: i64 = 0
        var i: i64 = 0
        while i < self.cap_count:
            if self._slot_granted(i):
                count = count + 1
            i = i + 1
        count

    fn denied_count() -> i64:
        var count: i64 = 0
        var i: i64 = 0
        while i < self.cap_count:
            if self._slot_granted(i) == false:
                count = count + 1
            i = i + 1
        count

    fn report() -> text:
        "policy app=" + self.app_id +
        " caps=" + self.cap_count.to_text() +
        " granted=" + self.granted_count().to_text() +
        " denied=" + self.denied_count().to_text()

# ---------------------------------------------------------------------------
# SandboxEnforcer — enforcement check result tracker
# ---------------------------------------------------------------------------

class SandboxEnforcer:
    app_id: text
    policy: SandboxPolicy
    violation_count: i64
    last_violation_cap: text
    last_violation_action: text

impl SandboxEnforcer:

    static fn create(id: text, policy: SandboxPolicy) -> SandboxEnforcer:
        SandboxEnforcer(
            app_id: id,
            policy: policy,
            violation_count: 0,
            last_violation_cap: "",
            last_violation_action: ""
        )

    me check_access(capability: text, action: text) -> text:
        if self.policy.is_allowed(capability):
            return ""
        self.record_violation(capability, action)
        "denied:" + capability + ":" + action

    me record_violation(cap: text, action: text) -> i64:
        self.violation_count = self.violation_count + 1
        self.last_violation_cap = cap
        self.last_violation_action = action
        self.violation_count

    fn stats() -> text:
        "enforcer app=" + self.app_id +
        " violations=" + self.violation_count.to_text() +
        " last_cap=" + self.last_violation_cap +
        " last_action=" + self.last_violation_action
