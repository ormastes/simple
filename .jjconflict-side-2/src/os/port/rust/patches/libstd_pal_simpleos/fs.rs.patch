//! Target: `library/std/src/sys/pal/simpleos/fs.rs`
//!
//! `File` backed by libsimpleos_c `open`/`close`/`read`/`write`/`lseek`/
//! `ftruncate` (syscall 43). Directory iteration via
//! `opendir`/`readdir`/`closedir`. `rename`/`unlink`/`symlink` are wired
//! where libc exposes them, and `Unsupported` otherwise.

use crate::ffi::{CStr, CString, OsStr, OsString};
use crate::fmt;
use crate::hash::Hash;
use crate::io::{self, BorrowedCursor, IoSlice, IoSliceMut, SeekFrom};
use crate::os::simpleos::ffi::OsStrExt;
use crate::path::{Path, PathBuf};
use crate::sys::time::SystemTime;
use crate::sys_common::{AsInner, FromInner, IntoInner};

unsafe extern "C" {
    fn open(path: *const i8, flags: i32, mode: i32) -> i32;
    fn close(fd: i32) -> i32;
    fn read(fd: i32, buf: *mut u8, count: usize) -> isize;
    fn write(fd: i32, buf: *const u8, count: usize) -> isize;
    fn lseek(fd: i32, offset: i64, whence: i32) -> i64;
    fn ftruncate(fd: i32, length: i64) -> i32;
    fn stat(path: *const i8, buf: *mut RawStat) -> i32;
    fn fstat(fd: i32, buf: *mut RawStat) -> i32;
    fn unlink(path: *const i8) -> i32;
    fn rmdir(path: *const i8) -> i32;
    fn mkdir(path: *const i8, mode: i32) -> i32;
    fn rename(from: *const i8, to: *const i8) -> i32;

    // Directory iteration — SimpleOS libc wrappers around VFS readdir.
    fn opendir(path: *const i8) -> *mut DIR;
    fn readdir(dir: *mut DIR) -> *mut RawDirent;
    fn closedir(dir: *mut DIR) -> i32;
}

// Opaque DIR handle.
#[repr(C)] pub struct DIR { _priv: [u8; 0] }

#[repr(C)]
pub struct RawDirent {
    pub d_ino: u64,
    pub d_type: u8,
    pub d_namlen: u16,
    pub d_name: [u8; 256],
}

#[repr(C)]
#[derive(Default, Copy, Clone)]
pub struct RawStat {
    pub st_mode: u32,
    pub st_size: i64,
    pub st_mtime: i64,
    pub st_atime: i64,
    pub st_ctime: i64,
    pub st_ino: u64,
    pub st_nlink: u32,
    pub st_uid: u32,
    pub st_gid: u32,
}

// <fcntl.h> flags from libsimpleos_c.
const O_RDONLY: i32  = 0;
const O_WRONLY: i32  = 1;
const O_RDWR:   i32  = 2;
const O_CREAT:  i32  = 0o100;
const O_TRUNC:  i32  = 0o1000;
const O_APPEND: i32  = 0o2000;
const SEEK_SET: i32  = 0;
const SEEK_CUR: i32  = 1;
const SEEK_END: i32  = 2;

// <sys/stat.h> mode bits — same layout as Linux.
const S_IFMT:  u32 = 0o170000;
const S_IFDIR: u32 = 0o040000;
const S_IFREG: u32 = 0o100000;
const S_IFLNK: u32 = 0o120000;

fn err_other<T>() -> io::Result<T> { Err(io::Error::from(io::ErrorKind::Other)) }
fn unsup<T>()     -> io::Result<T> { Err(io::Error::from(io::ErrorKind::Unsupported)) }

fn cstring(p: &Path) -> io::Result<CString> {
    CString::new(p.as_os_str().as_bytes())
        .map_err(|_| io::Error::from(io::ErrorKind::InvalidInput))
}

pub struct File(i32);

#[derive(Clone, Default)]
pub struct OpenOptions {
    read: bool,
    write: bool,
    append: bool,
    truncate: bool,
    create: bool,
    create_new: bool,
    mode: i32,
}

#[derive(Clone, Copy, PartialEq, Eq, Hash)]
pub struct FilePermissions(u32);

#[derive(Clone, Copy, PartialEq, Eq, Hash)]
pub struct FileType(u32);

#[derive(Clone)]
pub struct FileAttr(RawStat);

#[derive(Clone, Default)]
pub struct DirBuilder { mode: i32 }

pub struct ReadDir {
    handle: *mut DIR,
    root: PathBuf,
}

pub struct DirEntry {
    name: OsString,
    path: PathBuf,
    file_type: FileType,
}

impl fmt::Debug for File {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        f.debug_struct("File").field("fd", &self.0).finish()
    }
}

impl OpenOptions {
    pub fn new() -> Self { Self { mode: 0o666, ..Default::default() } }
    pub fn read(&mut self, v: bool)       { self.read = v; }
    pub fn write(&mut self, v: bool)      { self.write = v; }
    pub fn append(&mut self, v: bool)     { self.append = v; }
    pub fn truncate(&mut self, v: bool)   { self.truncate = v; }
    pub fn create(&mut self, v: bool)     { self.create = v; }
    pub fn create_new(&mut self, v: bool) { self.create_new = v; if v { self.create = true; } }
    pub fn mode(&mut self, m: u32)        { self.mode = m as i32; }
    pub fn custom_flags(&mut self, _f: i32) {}

    fn as_flags(&self) -> i32 {
        let mut f = match (self.read, self.write | self.append) {
            (true,  true) => O_RDWR,
            (false, true) => O_WRONLY,
            _             => O_RDONLY,
        };
        if self.create   { f |= O_CREAT; }
        if self.truncate { f |= O_TRUNC; }
        if self.append   { f |= O_APPEND; }
        f
    }
}

impl File {
    pub fn open(p: &Path, o: &OpenOptions) -> io::Result<File> {
        let c = cstring(p)?;
        let fd = unsafe { open(c.as_ptr(), o.as_flags(), o.mode) };
        if fd < 0 { err_other() } else { Ok(File(fd)) }
    }

    pub fn file_attr(&self) -> io::Result<FileAttr> {
        let mut raw = RawStat::default();
        let r = unsafe { fstat(self.0, &mut raw) };
        if r < 0 { err_other() } else { Ok(FileAttr(raw)) }
    }

    pub fn fsync(&self) -> io::Result<()> { Ok(()) } // TODO: libc fsync
    pub fn datasync(&self) -> io::Result<()> { Ok(()) } // TODO: libc fdatasync
    pub fn lock(&self) -> io::Result<()> { unsup() }
    pub fn lock_shared(&self) -> io::Result<()> { unsup() }
    pub fn try_lock(&self) -> io::Result<bool> { Ok(true) }
    pub fn try_lock_shared(&self) -> io::Result<bool> { Ok(true) }
    pub fn unlock(&self) -> io::Result<()> { Ok(()) }

    pub fn truncate(&self, size: u64) -> io::Result<()> {
        let r = unsafe { ftruncate(self.0, size as i64) };
        if r < 0 { err_other() } else { Ok(()) }
    }

    pub fn read(&self, buf: &mut [u8]) -> io::Result<usize> {
        let n = unsafe { read(self.0, buf.as_mut_ptr(), buf.len()) };
        if n < 0 { err_other() } else { Ok(n as usize) }
    }

    pub fn read_vectored(&self, bufs: &mut [IoSliceMut<'_>]) -> io::Result<usize> {
        let mut total = 0;
        for b in bufs {
            let got = self.read(b)?;
            total += got;
            if got < b.len() { break; }
        }
        Ok(total)
    }

    pub fn is_read_vectored(&self) -> bool { false }

    pub fn read_buf(&self, mut cursor: BorrowedCursor<'_>) -> io::Result<()> {
        let n = unsafe {
            read(self.0, cursor.as_mut().as_mut_ptr() as *mut u8, cursor.capacity())
        };
        if n < 0 { return err_other(); }
        unsafe { cursor.advance_unchecked(n as usize) };
        Ok(())
    }

    pub fn write(&self, buf: &[u8]) -> io::Result<usize> {
        let n = unsafe { write(self.0, buf.as_ptr(), buf.len()) };
        if n < 0 { err_other() } else { Ok(n as usize) }
    }

    pub fn write_vectored(&self, bufs: &[IoSlice<'_>]) -> io::Result<usize> {
        let mut total = 0;
        for b in bufs {
            let put = self.write(b)?;
            total += put;
            if put < b.len() { break; }
        }
        Ok(total)
    }

    pub fn is_write_vectored(&self) -> bool { false }

    pub fn flush(&self) -> io::Result<()> { Ok(()) }

    pub fn seek(&self, pos: SeekFrom) -> io::Result<u64> {
        let (off, w) = match pos {
            SeekFrom::Start(n)   => (n as i64, SEEK_SET),
            SeekFrom::End(n)     => (n, SEEK_END),
            SeekFrom::Current(n) => (n, SEEK_CUR),
        };
        let r = unsafe { lseek(self.0, off, w) };
        if r < 0 { err_other() } else { Ok(r as u64) }
    }

    pub fn duplicate(&self) -> io::Result<File> { unsup() } // TODO: libc dup
    pub fn set_permissions(&self, _perm: FilePermissions) -> io::Result<()> { unsup() } // TODO: libc fchmod
    pub fn set_times(&self, _times: FileTimes) -> io::Result<()> { unsup() } // TODO: libc futimens
}

#[derive(Clone, Default)]
pub struct FileTimes;

impl FileTimes {
    pub fn set_accessed(&mut self, _t: SystemTime) {}
    pub fn set_modified(&mut self, _t: SystemTime) {}
}

impl Drop for File {
    fn drop(&mut self) { unsafe { let _ = close(self.0); } }
}

impl FileAttr {
    pub fn size(&self) -> u64 { self.0.st_size as u64 }
    pub fn perm(&self) -> FilePermissions { FilePermissions(self.0.st_mode) }
    pub fn file_type(&self) -> FileType { FileType(self.0.st_mode) }
    pub fn modified(&self) -> io::Result<SystemTime> {
        Ok(SystemTime::from_secs(self.0.st_mtime))
    }
    pub fn accessed(&self) -> io::Result<SystemTime> {
        Ok(SystemTime::from_secs(self.0.st_atime))
    }
    pub fn created(&self) -> io::Result<SystemTime> {
        Ok(SystemTime::from_secs(self.0.st_ctime))
    }
}

impl FilePermissions {
    pub fn readonly(&self) -> bool { (self.0 & 0o200) == 0 }
    pub fn set_readonly(&mut self, r: bool) {
        if r { self.0 &= !0o222; } else { self.0 |= 0o200; }
    }
}

impl FileType {
    pub fn is_dir(&self)     -> bool { (self.0 & S_IFMT) == S_IFDIR }
    pub fn is_file(&self)    -> bool { (self.0 & S_IFMT) == S_IFREG }
    pub fn is_symlink(&self) -> bool { (self.0 & S_IFMT) == S_IFLNK }
}

impl fmt::Debug for FilePermissions {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "FilePermissions({:o})", self.0)
    }
}
impl fmt::Debug for FileType {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "FileType({:o})", self.0)
    }
}

impl DirBuilder {
    pub fn new() -> Self { DirBuilder { mode: 0o777 } }
    pub fn mkdir(&self, p: &Path) -> io::Result<()> {
        let c = cstring(p)?;
        let r = unsafe { mkdir(c.as_ptr(), self.mode) };
        if r < 0 { err_other() } else { Ok(()) }
    }
    pub fn set_mode(&mut self, m: u32) { self.mode = m as i32; }
}

impl Iterator for ReadDir {
    type Item = io::Result<DirEntry>;
    fn next(&mut self) -> Option<Self::Item> {
        if self.handle.is_null() { return None; }
        unsafe {
            let e = readdir(self.handle);
            if e.is_null() { return None; }
            let raw = &*e;
            let namlen = raw.d_namlen as usize;
            let bytes = &raw.d_name[..namlen.min(raw.d_name.len())];
            // Skip "." and "..".
            if bytes == b"." || bytes == b".." {
                return self.next();
            }
            let os = OsStr::from_bytes(bytes).to_owned();
            let path = self.root.join(&os);
            let ftype = match raw.d_type {
                4 => FileType(S_IFDIR),
                8 => FileType(S_IFREG),
                10 => FileType(S_IFLNK),
                _ => FileType(0),
            };
            Some(Ok(DirEntry { name: os, path, file_type: ftype }))
        }
    }
}

impl Drop for ReadDir {
    fn drop(&mut self) {
        if !self.handle.is_null() {
            unsafe { let _ = closedir(self.handle); }
        }
    }
}

impl DirEntry {
    pub fn file_name(&self) -> OsString { self.name.clone() }
    pub fn path(&self) -> PathBuf { self.path.clone() }
    pub fn metadata(&self) -> io::Result<FileAttr> { stat(&self.path) }
    pub fn file_type(&self) -> io::Result<FileType> { Ok(self.file_type) }
    pub fn ino(&self) -> u64 { 0 } // TODO: plumb d_ino up through FileType
}

impl FromInner<i32> for File { fn from_inner(fd: i32) -> File { File(fd) } }
impl IntoInner<i32> for File { fn into_inner(self) -> i32 { let fd = self.0; core::mem::forget(self); fd } }
impl AsInner<i32>   for File { fn as_inner(&self) -> &i32 { &self.0 } }

pub fn readdir(p: &Path) -> io::Result<ReadDir> {
    let c = cstring(p)?;
    let h = unsafe { opendir(c.as_ptr()) };
    if h.is_null() { err_other() } else { Ok(ReadDir { handle: h, root: p.to_path_buf() }) }
}

pub fn unlink(p: &Path) -> io::Result<()> {
    let c = cstring(p)?;
    let r = unsafe { unlink(c.as_ptr()) };
    if r < 0 { err_other() } else { Ok(()) }
}

pub fn rename(from: &Path, to: &Path) -> io::Result<()> {
    let a = cstring(from)?;
    let b = cstring(to)?;
    let r = unsafe { rename(a.as_ptr(), b.as_ptr()) };
    if r < 0 { err_other() } else { Ok(()) }
}

pub fn rmdir(p: &Path) -> io::Result<()> {
    let c = cstring(p)?;
    let r = unsafe { rmdir(c.as_ptr()) };
    if r < 0 { err_other() } else { Ok(()) }
}

pub fn remove_dir_all(_p: &Path) -> io::Result<()> { unsup() }
pub fn try_exists(p: &Path) -> io::Result<bool> { Ok(stat(p).is_ok()) }
pub fn readlink(_p: &Path) -> io::Result<PathBuf> { unsup() } // TODO: libc readlink
pub fn symlink(_src: &Path, _dst: &Path) -> io::Result<()> { unsup() } // TODO: libc symlink
pub fn link(_src: &Path, _dst: &Path) -> io::Result<()> { unsup() } // TODO: libc link
pub fn set_perm(_p: &Path, _perm: FilePermissions) -> io::Result<()> { unsup() } // TODO: libc chmod
pub fn canonicalize(_p: &Path) -> io::Result<PathBuf> { unsup() } // TODO: libc realpath
pub fn copy(_from: &Path, _to: &Path) -> io::Result<u64> { unsup() }

pub fn stat(p: &Path) -> io::Result<FileAttr> {
    let c = cstring(p)?;
    let mut raw = RawStat::default();
    let r = unsafe { stat(c.as_ptr(), &mut raw) };
    if r < 0 { Err(io::Error::from(io::ErrorKind::NotFound)) } else { Ok(FileAttr(raw)) }
}

pub fn lstat(p: &Path) -> io::Result<FileAttr> {
    // TODO: libsimpleos_c lstat once gap-fill lands; for now alias stat.
    stat(p)
}
