# Composite Unit: M3perS
# Kind: FlowRate
# Symbol: m3_per_s
# Scale to SI base: 1.0 m^3/s

class M3perS:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: M3perS) -> M3perS: M3perS(value: self.value + other.value)
    fn sub(other: M3perS) -> M3perS: M3perS(value: self.value - other.value)

    static fn kind() -> text: "FlowRate"
    static fn symbol() -> text: "m3_per_s"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m^3/s"
    static fn numerator() -> [text]: ["m", "m", "m"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> M3perS: M3perS(value: 0.0)

export M3perS
