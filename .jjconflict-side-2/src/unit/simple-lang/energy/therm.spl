# Unit: Therm
# Kind: Energy
# Symbol: therm
# Canonical scale: 105505590.0 J

class Therm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Therm) -> Therm: Therm(value: self.value + other.value)
    fn sub(other: Therm) -> Therm: Therm(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "therm"
    static fn scale_to_base() -> f64: 105505590.0
    static fn base_unit() -> text: "J"
    static fn zero() -> Therm: Therm(value: 0.0)

export Therm
