# Unit: MilliAmp
# Kind: ElectricCurrent
# Symbol: mA
# Canonical scale: 0.001 A

class MilliAmp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MilliAmp) -> MilliAmp: MilliAmp(value: self.value + other.value)
    fn sub(other: MilliAmp) -> MilliAmp: MilliAmp(value: self.value - other.value)

    static fn kind() -> text: "ElectricCurrent"
    static fn symbol() -> text: "mA"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "A"
    static fn zero() -> MilliAmp: MilliAmp(value: 0.0)

export MilliAmp
