#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-}"
BUILD_DIR="build/size_audit"
REPORT_PATH="doc/09_report/tui_app_size_reduction_2026-05-03.md"
TMP_TUI_ENTRY="$BUILD_DIR/minimal_tui_entry.spl"
REPORT_DATE="$(date -u +%F)"
MAX_HELLO_SIMPLE_BYTES="${MAX_HELLO_SIMPLE_BYTES:-}"
MAX_MINIMAL_TUI_BYTES="${MAX_MINIMAL_TUI_BYTES:-}"

if [ -z "$SIMPLE_BINARY" ]; then
    if [ -x "src/compiler_rust/target/bootstrap/simple" ]; then
        SIMPLE_BINARY="src/compiler_rust/target/bootstrap/simple"
    elif [ -x "src/compiler_rust/target/release/simple" ]; then
        SIMPLE_BINARY="src/compiler_rust/target/release/simple"
    else
        SIMPLE_BINARY="bin/simple"
    fi
fi

if [ ! -x "$SIMPLE_BINARY" ]; then
    echo "size_audit_ready=false"
    echo "error=missing_simple_binary:$SIMPLE_BINARY"
    exit 1
fi

mkdir -p "$BUILD_DIR" "$(dirname "$REPORT_PATH")"

cat >"$TMP_TUI_ENTRY" <<'EOF'
use app.ui.tui.standalone.{run_standalone_tui}

fn main() -> i64:
    return run_standalone_tui("examples/ui/minimal.ui.sdn")
EOF

build_simple() {
    entry="$1"
    output="$2"
    SIMPLE_LIB="$ROOT_DIR/src" "$SIMPLE_BINARY" native-build \
        --runtime-bundle core-c-bootstrap \
        --source src/lib \
        --source src/app \
        --entry-closure \
        --entry "$entry" \
        -o "$output" \
        --strip \
        --opt-level=aggressive >/tmp/simple_size_audit.$$ 2>&1
}

build_simple "examples/01_getting_started/hello_native.spl" "$BUILD_DIR/hello_simple"
build_simple "$TMP_TUI_ENTRY" "$BUILD_DIR/minimal_tui_simple"

cat >"$BUILD_DIR/hello.c" <<'EOF'
#include <stdio.h>
int main(void) {
    puts("Hello World");
    return 0;
}
EOF
cc -Os -s "$BUILD_DIR/hello.c" -o "$BUILD_DIR/hello_c"

NCURSES_BUILT=false
NCURSES_FLAGS=""
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists ncursesw; then
    NCURSES_FLAGS="$(pkg-config --cflags --libs ncursesw)"
elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists ncurses; then
    NCURSES_FLAGS="$(pkg-config --cflags --libs ncurses)"
fi

if [ -n "$NCURSES_FLAGS" ]; then
    cat >"$BUILD_DIR/hello_ncurses.c" <<'EOF'
#include <curses.h>
int main(void) {
    initscr();
    printw("Hello ncurses");
    refresh();
    endwin();
    return 0;
}
EOF
    # shellcheck disable=SC2086
    cc -Os -s "$BUILD_DIR/hello_ncurses.c" -o "$BUILD_DIR/hello_ncurses" $NCURSES_FLAGS
    NCURSES_BUILT=true
fi

section_summary() {
    path="$1"
    if command -v readelf >/dev/null 2>&1; then
        readelf -SW "$path" | rg ' \.(text|rodata|eh_frame|gcc_except_table|data|bss) ' | awk '{print "- " $2 ": " $6}'
    else
        echo "- readelf unavailable"
    fi
}

size_summary() {
    path="$1"
    if command -v size >/dev/null 2>&1; then
        size "$path" | tail -n 1 | awk '{print "- text=" $1 ", data=" $2 ", bss=" $3 ", dec=" $4}'
    else
        echo "- size unavailable"
    fi
}

anchor_summary() {
    path="$1"
    anchors="$(strings "$path" | rg -o 'rustls|ureq|regex|sha1|sha256|tauri|electron|browser|render_html_tree|run_standalone_tui' | sort | uniq -c || true)"
    if [ -n "$anchors" ]; then
        printf '%s\n' "$anchors" | awk '{print "- " $2 ": " $1}'
    else
        echo "- none"
    fi
}

bytes_of() {
    wc -c <"$1" | tr -d ' '
}

HELLO_SIMPLE_BYTES="$(bytes_of "$BUILD_DIR/hello_simple")"
MINIMAL_TUI_BYTES="$(bytes_of "$BUILD_DIR/minimal_tui_simple")"
HELLO_C_BYTES="$(bytes_of "$BUILD_DIR/hello_c")"
NCURSES_BYTES=""
if [ "$NCURSES_BUILT" = true ]; then
    NCURSES_BYTES="$(bytes_of "$BUILD_DIR/hello_ncurses")"
fi

if [ -n "$MAX_HELLO_SIMPLE_BYTES" ] && [ "$HELLO_SIMPLE_BYTES" -gt "$MAX_HELLO_SIMPLE_BYTES" ]; then
    echo "size_audit_ready=false"
    echo "error=hello_simple_exceeds_budget:$HELLO_SIMPLE_BYTES>$MAX_HELLO_SIMPLE_BYTES"
    exit 1
fi

if [ -n "$MAX_MINIMAL_TUI_BYTES" ] && [ "$MINIMAL_TUI_BYTES" -gt "$MAX_MINIMAL_TUI_BYTES" ]; then
    echo "size_audit_ready=false"
    echo "error=minimal_tui_exceeds_budget:$MINIMAL_TUI_BYTES>$MAX_MINIMAL_TUI_BYTES"
    exit 1
fi

{
    echo "# TUI App Size Reduction Verification"
    echo
    echo "Date: $REPORT_DATE"
    echo
    echo "## Build Inputs"
    echo
    echo "- Simple hello: \`examples/01_getting_started/hello_native.spl\`"
    echo "- Simple minimal TUI: generated standalone entry -> \`examples/ui/minimal.ui.sdn\`"
    echo "- C hello: \`build/size_audit/hello.c\`"
    if [ "$NCURSES_BUILT" = true ]; then
        echo "- C ncurses hello: \`build/size_audit/hello_ncurses.c\`"
    else
        echo "- C ncurses hello: not built on this host"
    fi
    echo
    echo "## Byte Sizes"
    echo
    echo "| Artifact | Bytes | Approx |"
    echo "|---|---:|---:|"
    echo "| Simple hello | $HELLO_SIMPLE_BYTES | $(awk "BEGIN {printf \"%.1f MB\", $HELLO_SIMPLE_BYTES/1024/1024}") |"
    echo "| Simple minimal TUI | $MINIMAL_TUI_BYTES | $(awk "BEGIN {printf \"%.1f MB\", $MINIMAL_TUI_BYTES/1024/1024}") |"
    echo "| C hello | $HELLO_C_BYTES | $(awk "BEGIN {printf \"%.1f KB\", $HELLO_C_BYTES/1024}") |"
    if [ "$NCURSES_BUILT" = true ]; then
        echo "| C ncurses hello | $NCURSES_BYTES | $(awk "BEGIN {printf \"%.1f KB\", $NCURSES_BYTES/1024}") |"
    fi
    echo
    echo "## Simple Hello Sections"
    echo
    size_summary "$BUILD_DIR/hello_simple"
    section_summary "$BUILD_DIR/hello_simple"
    echo
    echo "## Simple Minimal TUI Sections"
    echo
    size_summary "$BUILD_DIR/minimal_tui_simple"
    section_summary "$BUILD_DIR/minimal_tui_simple"
    echo
    echo "## Anchor Strings"
    echo
    echo "### Simple hello"
    anchor_summary "$BUILD_DIR/hello_simple"
    echo
    echo "### Simple minimal TUI"
    anchor_summary "$BUILD_DIR/minimal_tui_simple"
    echo
    echo "## Notes"
    echo
    echo "- The generated TUI entry uses \`app.ui.tui.standalone.run_standalone_tui\`."
    echo "- The Simple artifacts are built on the explicit bootstrap-floor lane: \`--runtime-bundle core-c-bootstrap\`."
    echo "- This audit measures the bootstrap core floor, not the default \`auto\` lane once \`simple-core\` is available."
    echo "- The audit intentionally records anchor strings instead of claiming full transitive Rust crate closure proof."
    echo "- Set \`MAX_HELLO_SIMPLE_BYTES\` and/or \`MAX_MINIMAL_TUI_BYTES\` to turn the audit into a size-budget gate."
    echo "- Use \`scripts/check-tui-standalone-closure.shs\` alongside this report for the import-surface guard."
} >"$REPORT_PATH"

echo "size_audit_ready=true"
echo "report_path=$REPORT_PATH"
echo "hello_simple_bytes=$HELLO_SIMPLE_BYTES"
echo "minimal_tui_bytes=$MINIMAL_TUI_BYTES"
echo "hello_c_bytes=$HELLO_C_BYTES"
if [ "$NCURSES_BUILT" = true ]; then
    echo "hello_ncurses_bytes=$NCURSES_BYTES"
else
    echo "hello_ncurses_bytes=unavailable"
fi
