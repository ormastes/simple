# Shell Tool Registration — Register coreutils with ToolRegistry
# MDSOC: feature dimension, shell layer
#
# Registers all shell/coreutils tools so external dispatchers can find them.
# Note: Most shell tools require VFS/Terminal context and are dispatched
# directly by shell_app.spl. This registration covers tools that can
# also run standalone via the ToolRegistry (print-based output).

use os.tools.tool_registry.{ToolRegistry, ToolEntry}

# Standalone wrappers (print-based, no Terminal needed)

fn _run_basename(args: [text]) -> i32:
    if args.len() == 0:
        print "basename: missing operand"
        return 1
    val path = args[0]
    val suffix = if args.len() > 1: args[1] else: ""
    var name = path
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash >= 0:
        name = path.slice(last_slash + 1, path.len())
    if suffix != "" and name.ends_with(suffix):
        name = name.slice(0, name.len() - suffix.len())
    print name
    return 0

fn _run_dirname(args: [text]) -> i32:
    if args.len() == 0:
        print "dirname: missing operand"
        return 1
    val path = args[0]
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash < 0:
        print "."
    elif last_slash == 0:
        print "/"
    else:
        print path.slice(0, last_slash)
    return 0

fn _run_seq(args: [text]) -> i32:
    if args.len() == 0:
        print "seq: missing operand"
        return 1
    var first: i64 = 1
    var increment: i64 = 1
    var last: i64 = 0
    if args.len() == 1:
        last = args[0].parse_i64() ?? 0
    elif args.len() == 2:
        first = args[0].parse_i64() ?? 1
        last = args[1].parse_i64() ?? 0
    else:
        first = args[0].parse_i64() ?? 1
        increment = args[1].parse_i64() ?? 1
        last = args[2].parse_i64() ?? 0
    if increment == 0:
        print "seq: zero increment"
        return 1
    var current = first
    if increment > 0:
        while current <= last:
            print "{current}"
            current = current + increment
    else:
        while current >= last:
            print "{current}"
            current = current + increment
    return 0

fn _run_expr(args: [text]) -> i32:
    if args.len() < 3:
        print "expr: syntax error"
        return 2
    val left = args[0].parse_i64() ?? 0
    val op = args[1]
    val right = args[2].parse_i64() ?? 0
    match op:
        "+":
            print "{left + right}"
            return 0
        "-":
            print "{left - right}"
            return 0
        "*":
            print "{left * right}"
            return 0
        "/":
            if right == 0:
                print "expr: division by zero"
                return 2
            print "{left / right}"
            return 0
        "%":
            if right == 0:
                print "expr: division by zero"
                return 2
            print "{left % right}"
            return 0
        _:
            print "expr: unknown operator: {op}"
            return 2

fn _run_true(args: [text]) -> i32:
    return 0

fn _run_false(args: [text]) -> i32:
    return 1

fn _run_yes(args: [text]) -> i32:
    val msg = if args.len() > 0: args[0] else: "y"
    var count = 0
    while count < 1000:
        print msg
        count = count + 1
    return 0

fn register_shell_tools(registry: ToolRegistry):
    """Register shell/coreutils tools with the ToolRegistry."""

    registry.register(ToolEntry(
        name: "basename",
        description: "Strip directory from path",
        category: "shell",
        run_fn: _run_basename,
        capabilities: ["read"]
    ))

    registry.register(ToolEntry(
        name: "dirname",
        description: "Strip filename from path",
        category: "shell",
        run_fn: _run_dirname,
        capabilities: ["read"]
    ))

    registry.register(ToolEntry(
        name: "seq",
        description: "Print number sequence",
        category: "shell",
        run_fn: _run_seq,
        capabilities: ["read"]
    ))

    registry.register(ToolEntry(
        name: "expr",
        description: "Evaluate arithmetic expression",
        category: "shell",
        run_fn: _run_expr,
        capabilities: ["read"]
    ))

    registry.register(ToolEntry(
        name: "true",
        description: "Exit with code 0",
        category: "shell",
        run_fn: _run_true,
        capabilities: []
    ))

    registry.register(ToolEntry(
        name: "false",
        description: "Exit with code 1",
        category: "shell",
        run_fn: _run_false,
        capabilities: []
    ))

    registry.register(ToolEntry(
        name: "yes",
        description: "Repeatedly output a string",
        category: "shell",
        run_fn: _run_yes,
        capabilities: ["read"]
    ))
