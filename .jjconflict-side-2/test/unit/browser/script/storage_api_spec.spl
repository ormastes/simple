"""
# Storage API Spec

Unit tests for the Simple browser engine Storage API.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.script.storage_api.{
    BrowserStorage,
    storage_get_item, storage_set_item, storage_remove_item,
    storage_clear, storage_length, storage_key
}

describe "Storage API - Get/Set":
    it "stores and retrieves a value":
        val store = BrowserStorage.new()
        storage_set_item(store, "name", "alice")
        val v = storage_get_item(store, "name")
        expect(v != nil).to_equal(true)

    it "returns nil for missing key":
        val store = BrowserStorage.new()
        val v = storage_get_item(store, "missing")
        expect(v == nil).to_equal(true)

    it "updates an existing key":
        val store = BrowserStorage.new()
        storage_set_item(store, "x", "1")
        storage_set_item(store, "x", "2")
        expect(storage_length(store)).to_equal(1)

describe "Storage API - Remove":
    it "removes an item":
        val store = BrowserStorage.new()
        storage_set_item(store, "a", "1")
        storage_remove_item(store, "a")
        val v = storage_get_item(store, "a")
        expect(v == nil).to_equal(true)

describe "Storage API - Clear":
    it "clears all items":
        val store = BrowserStorage.new()
        storage_set_item(store, "a", "1")
        storage_set_item(store, "b", "2")
        storage_clear(store)
        expect(storage_length(store)).to_equal(0)

describe "Storage API - Length":
    it "returns zero for empty store":
        val store = BrowserStorage.new()
        expect(storage_length(store)).to_equal(0)

    it "returns correct count":
        val store = BrowserStorage.new()
        storage_set_item(store, "a", "1")
        storage_set_item(store, "b", "2")
        expect(storage_length(store)).to_equal(2)

describe "Storage API - Key":
    it "returns key at index":
        val store = BrowserStorage.new()
        storage_set_item(store, "first", "1")
        storage_set_item(store, "second", "2")
        val k = storage_key(store, 0)
        expect(k != nil).to_equal(true)

    it "returns nil for out-of-bounds index":
        val store = BrowserStorage.new()
        val k = storage_key(store, 5)
        expect(k == nil).to_equal(true)
