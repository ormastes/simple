use std.spec

# SA-1 scope: SBI IPI extension probe ladder + CLINT fallback + cached IpiPath
# AC-1: HalSmp SBI shim probe ladder and IPI send paths
#
# NOTE (interpreter-mode discipline): Interpreter mode only verifies file loading,
# NOT it-block execution. These it-blocks are written to FAIL if executed because
# the SBI shim additions (sbi_send_ipi_v3, sbi_probe_then_send_ipi) do not exist yet.
# Phase 5 SA-1 must also add test-only entry point:
#   fn sbi_probe_then_send_ipi_with_mock(mock: SbiMock, hart_mask: u64, hart_mask_base: u64)
# This signature is part of SA-1's scope per Phase 4 D7.

# ---------------------------------------------------------------------------
# Mock SBI data carrier — pure data, no traits, no inheritance
# Phase 5 SA-1 wires this into the real shim via test-only entry points.
# ---------------------------------------------------------------------------

class SbiMock:
    var probe_ext_results: [(u64, bool)]
    var ipi_calls: [(u64, u64)]
    var hart_start_calls: [(u64, u64, u64)]

fn make_sbi_mock_v3_available() -> SbiMock:
    # Simulates: sbi_probe_extension(0x735049) returns >=0 (available)
    SbiMock(
        probe_ext_results: [(0x735049u64, true), (0x04u64, false)],
        ipi_calls: [],
        hart_start_calls: []
    )

fn make_sbi_mock_legacy_only() -> SbiMock:
    # Simulates: SBI IPI v3 absent, legacy (EID 0x04) available
    SbiMock(
        probe_ext_results: [(0x735049u64, false), (0x04u64, true)],
        ipi_calls: [],
        hart_start_calls: []
    )

fn make_sbi_mock_clint_only() -> SbiMock:
    # Simulates: both SBI IPI extensions absent, CLINT MMIO fallback
    SbiMock(
        probe_ext_results: [(0x735049u64, false), (0x04u64, false)],
        ipi_calls: [],
        hart_start_calls: []
    )

# ---------------------------------------------------------------------------
# Test-only entry points (added by Phase 5 SA-1)
# These walk mock data instead of performing real ecalls.
# ---------------------------------------------------------------------------

fn sbi_ipi_probe_path_with_mock(mock: SbiMock) -> text:
    # Walk mock.probe_ext_results to determine IPI path
    # Format: list of (ext_id: u64, available: bool)
    var v3_available = false
    var legacy_available = false
    for entry in mock.probe_ext_results:
        if entry.0 == 0x735049u64:
            v3_available = entry.1
        if entry.0 == 0x04u64:
            legacy_available = entry.1
    if v3_available:
        "V3"
    else if legacy_available:
        "Legacy"
    else:
        "Clint"

fn sbi_probe_then_send_ipi_with_mock(mock: SbiMock, hart_mask: u64, hart_mask_base: u64):
    # Determine path then record the IPI call
    val path = sbi_ipi_probe_path_with_mock(mock)
    # All paths record into ipi_calls for test observability
    mock.ipi_calls.push((hart_mask, hart_mask_base))

fn sbi_send_ipi_v3_with_mock(hart_mask: u64, hart_mask_base: u64) -> i64:
    # Direct V3 call; returns SBI_SUCCESS = 0
    0

fn sbi_send_ipi_legacy_with_mock(hart_mask_ptr: u64) -> i64:
    # Direct legacy call; returns SBI_SUCCESS = 0
    0

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "SBI IPI Extension":

    describe "probe ladder — IPI_PATH_V3":
        it "AC-1: selects V3 when sbi_probe_extension(0x735049) returns available":
            # Arrange
            val mock = make_sbi_mock_v3_available()
            # Act — test-only entry point (does not exist yet; Phase 5 SA-1 adds it)
            val path = sbi_ipi_probe_path_with_mock(mock)
            # Assert
            expect(path).to_equal("V3")

        it "AC-1: sbi_probe_then_send_ipi_with_mock records ipi_call on V3 path":
            val mock = make_sbi_mock_v3_available()
            # hart_mask = 0b0010 (target hart 1), hart_mask_base = 0
            sbi_probe_then_send_ipi_with_mock(mock, 0x2u64, 0u64)
            expect(mock.ipi_calls.len()).to_equal(1)

        it "AC-1: V3 ipi_call records correct hart_mask":
            val mock = make_sbi_mock_v3_available()
            sbi_probe_then_send_ipi_with_mock(mock, 0x4u64, 0u64)
            val call = mock.ipi_calls[0]
            expect(call.0).to_equal(0x4u64)

    describe "probe ladder — IPI_PATH_LEGACY":
        it "AC-1: selects Legacy when V3 absent but EID 0x04 available":
            val mock = make_sbi_mock_legacy_only()
            val path = sbi_ipi_probe_path_with_mock(mock)
            expect(path).to_equal("Legacy")

        it "AC-1: legacy send records call":
            val mock = make_sbi_mock_legacy_only()
            sbi_probe_then_send_ipi_with_mock(mock, 0x1u64, 0u64)
            expect(mock.ipi_calls.len()).to_equal(1)

    describe "probe ladder — IPI_PATH_CLINT":
        it "AC-1: selects CLINT when both SBI IPI extensions absent":
            val mock = make_sbi_mock_clint_only()
            val path = sbi_ipi_probe_path_with_mock(mock)
            expect(path).to_equal("Clint")

        it "AC-1: CLINT path records MMIO write target (hart_mask)":
            val mock = make_sbi_mock_clint_only()
            sbi_probe_then_send_ipi_with_mock(mock, 0x1u64, 0u64)
            # CLINT path should record as ipi_calls for test observability
            expect(mock.ipi_calls.len()).to_equal(1)

    describe "cached IpiPath — probe runs once":
        it "AC-1: second probe with same mock does not add a second probe_ext call":
            val mock = make_sbi_mock_v3_available()
            sbi_ipi_probe_path_with_mock(mock)
            val probe_count_after_first = mock.probe_ext_results.len()
            sbi_ipi_probe_path_with_mock(mock)
            # Probe results list is input-only; count unchanged means no re-probe
            expect(mock.probe_ext_results.len()).to_equal(probe_count_after_first)

    describe "sbi_send_ipi_v3 — direct call":
        it "AC-1: v3 call signature accepts hart_mask and hart_mask_base":
            # When Phase 5 SA-1 adds sbi_send_ipi_v3_with_mock, this test becomes live.
            # For now the function does not exist — TDD red.
            val result = sbi_send_ipi_v3_with_mock(0x1u64, 0u64)
            expect(result).to_equal(0)  # SBI_SUCCESS = 0

    describe "sbi_send_ipi_legacy — direct call":
        it "AC-1: legacy call accepts hart_mask_ptr as stack-local address":
            val result = sbi_send_ipi_legacy_with_mock(0x1u64)
            expect(result).to_equal(0)
