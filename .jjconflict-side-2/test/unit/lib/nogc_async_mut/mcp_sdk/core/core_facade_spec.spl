use std.spec
use std.nogc_async_mut.mcp_sdk.core.json.{jp, js, jo1}
use std.nogc_async_mut.mcp_sdk.core.jsonrpc.{jsonrpc_result}
use std.nogc_async_mut.mcp_sdk.core.errors.{ERR_METHOD_NOT_FOUND, method_not_found, mcp_error_to_jsonrpc}
use std.nogc_async_mut.mcp_sdk.core.validation.{default_validation_limits, validate_tool_name}

describe "nogc_async_mut MCP SDK core facades":

    it "re-exports JSON and JSON-RPC helpers":
        val obj = jo1(jp("name", js("tool")))
        val result = jsonrpc_result("1", obj)

        expect(obj).to_contain("\"name\":\"tool\"")
        expect(result).to_contain("\"id\":\"1\"")

    it "re-exports errors and validation":
        val err = method_not_found("missing")
        val json = mcp_error_to_jsonrpc(err)
        val limits = default_validation_limits()

        expect(json).to_contain(ERR_METHOD_NOT_FOUND())
        expect(validate_tool_name(limits, "valid_tool")).to_equal("")
