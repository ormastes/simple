"""
# Syscall Number Consistency Specification

**Feature IDs:** #OS-006
**Category:** Runtime
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** doc/01_research/local/ipc_error_38_2026-04-13.md

## Overview

Drift detector for the `SYS_IPC_*` constants duplicated across the kernel
syscall dispatcher (`src/os/kernel/ipc/syscall.spl`) and every userland
service that dispatches IPC syscalls (`wm_service`, `launcher`, `vfs`,
`driver_supervisor`, `device_registry`, `netstack`, `userlib/window`, etc.).

The kernel dispatcher in `src/os/kernel/ipc/syscall.spl` is the canonical
source of truth:

    case 20: IpcSend         -> _handle_ipc_send
    case 21: IpcRecv         -> _handle_ipc_recv
    case 22: IpcCreatePort   -> _handle_ipc_create_port
    case 23: IpcConnect      -> _handle_ipc_connect

Historically several service modules declared `SYS_IPC_SEND = 23`, which
actually routed send traffic to the kernel's `IpcConnect` handler. This
spec asserts the canonical values and exists purely to prevent future
drift — if you change a `SYS_IPC_*` constant in any service, you must
update this spec (and the kernel dispatcher) to match.
"""

use std.spec.{describe, it, expect}


# ============================================================================
# Canonical values — must match src/os/kernel/ipc/syscall.spl dispatcher
# ============================================================================

val CANONICAL_SYS_IPC_SEND: u64 = 20
val CANONICAL_SYS_IPC_RECV: u64 = 21
val CANONICAL_SYS_IPC_CREATE_PORT: u64 = 22
val CANONICAL_SYS_IPC_CONNECT: u64 = 23
val CANONICAL_SYS_BRK: u64 = 15
val CANONICAL_SYS_REBOOT: u64 = 16
val CANONICAL_SYS_SLEEP: u64 = 51


# ============================================================================
# Mirrors of the per-service constant declarations. Any service added to
# the kernel/service boundary must be represented here. A mismatch on any
# assertion below indicates the service's local constants have drifted
# from the kernel dispatcher.
# ============================================================================

# src/os/services/wm/wm_service.spl
val WM_SEND: u64 = 20
val WM_RECV: u64 = 21
val WM_CREATE_PORT: u64 = 22
val WM_CONNECT: u64 = 23

# src/os/services/launcher/launcher.spl
val LAUNCHER_SEND: u64 = 20
val LAUNCHER_RECV: u64 = 21
val LAUNCHER_CREATE_PORT: u64 = 22
val LAUNCHER_CONNECT: u64 = 23

# src/os/services/vfs/vfs_service.spl
val VFS_SEND: u64 = 20
val VFS_RECV: u64 = 21
val VFS_CREATE_PORT: u64 = 22
val VFS_CONNECT: u64 = 23

# src/os/services/netstack/netstack_service.spl
val NETSTACK_SEND: u64 = 20
val NETSTACK_RECV: u64 = 21
val NETSTACK_CREATE_PORT: u64 = 22

# src/os/services/driver_supervisor/supervisor.spl
val SUPERVISOR_SEND: u64 = 20
val SUPERVISOR_RECV: u64 = 21
val SUPERVISOR_CREATE_PORT: u64 = 22
val SUPERVISOR_SLEEP: u64 = 51

# src/os/services/device_registry/registry.spl
val REGISTRY_RECV: u64 = 21
val REGISTRY_CREATE_PORT: u64 = 22

# src/os/userlib/window.spl
val USERLIB_SEND: u64 = 20
val USERLIB_RECV: u64 = 21
val USERLIB_CREATE_PORT: u64 = 22
val USERLIB_CONNECT: u64 = 23

# src/os/lib/driver_runtime/ipc_service.spl + event_loop.spl
val DRV_SEND: u64 = 20
val DRV_RECV: u64 = 21
val DRV_CREATE_PORT: u64 = 22

# src/os/posix/async_io.spl + fd_io.spl
val POSIX_SEND: u64 = 20
val POSIX_RECV: u64 = 21


# ============================================================================
# Assertions
# ============================================================================

describe "SYS_IPC_* constant consistency across kernel and services":

    describe "kernel canonical values":
        it "SYS_IPC_SEND is 20":
            expect(CANONICAL_SYS_IPC_SEND).to_equal(20 as u64)
        it "SYS_IPC_RECV is 21":
            expect(CANONICAL_SYS_IPC_RECV).to_equal(21 as u64)
        it "SYS_IPC_CREATE_PORT is 22":
            expect(CANONICAL_SYS_IPC_CREATE_PORT).to_equal(22 as u64)
        it "SYS_IPC_CONNECT is 23":
            expect(CANONICAL_SYS_IPC_CONNECT).to_equal(23 as u64)
        it "SYS_BRK is 15":
            expect(CANONICAL_SYS_BRK).to_equal(15 as u64)
        it "SYS_REBOOT is 16":
            expect(CANONICAL_SYS_REBOOT).to_equal(16 as u64)
        it "SYS_SLEEP is 51":
            expect(CANONICAL_SYS_SLEEP).to_equal(51 as u64)

    describe "wm_service matches kernel":
        it "wm SYS_IPC_SEND == canonical":
            expect(WM_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "wm SYS_IPC_RECV == canonical":
            expect(WM_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "wm SYS_IPC_CREATE_PORT == canonical":
            expect(WM_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)
        it "wm SYS_IPC_CONNECT == canonical":
            expect(WM_CONNECT).to_equal(CANONICAL_SYS_IPC_CONNECT)

    describe "launcher matches kernel":
        it "launcher SYS_IPC_SEND == canonical":
            expect(LAUNCHER_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "launcher SYS_IPC_RECV == canonical":
            expect(LAUNCHER_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "launcher SYS_IPC_CREATE_PORT == canonical":
            expect(LAUNCHER_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)
        it "launcher SYS_IPC_CONNECT == canonical":
            expect(LAUNCHER_CONNECT).to_equal(CANONICAL_SYS_IPC_CONNECT)

    describe "vfs_service matches kernel":
        it "vfs SYS_IPC_SEND == canonical":
            expect(VFS_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "vfs SYS_IPC_RECV == canonical":
            expect(VFS_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "vfs SYS_IPC_CREATE_PORT == canonical":
            expect(VFS_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)
        it "vfs SYS_IPC_CONNECT == canonical":
            expect(VFS_CONNECT).to_equal(CANONICAL_SYS_IPC_CONNECT)

    describe "netstack matches kernel":
        it "netstack SYS_IPC_SEND == canonical":
            expect(NETSTACK_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "netstack SYS_IPC_RECV == canonical":
            expect(NETSTACK_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "netstack SYS_IPC_CREATE_PORT == canonical":
            expect(NETSTACK_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)

    describe "driver_supervisor matches kernel":
        it "supervisor SYS_IPC_SEND == canonical":
            expect(SUPERVISOR_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "supervisor SYS_IPC_RECV == canonical":
            expect(SUPERVISOR_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "supervisor SYS_IPC_CREATE_PORT == canonical":
            expect(SUPERVISOR_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)
        it "supervisor SYS_SLEEP == canonical":
            expect(SUPERVISOR_SLEEP).to_equal(CANONICAL_SYS_SLEEP)

    describe "device_registry matches kernel":
        it "registry SYS_IPC_RECV == canonical":
            expect(REGISTRY_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "registry SYS_IPC_CREATE_PORT == canonical":
            expect(REGISTRY_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)

    describe "userlib/window matches kernel":
        it "userlib SYS_IPC_SEND == canonical":
            expect(USERLIB_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "userlib SYS_IPC_RECV == canonical":
            expect(USERLIB_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "userlib SYS_IPC_CREATE_PORT == canonical":
            expect(USERLIB_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)
        it "userlib SYS_IPC_CONNECT == canonical":
            expect(USERLIB_CONNECT).to_equal(CANONICAL_SYS_IPC_CONNECT)

    describe "driver_runtime matches kernel":
        it "driver runtime SYS_IPC_SEND == canonical":
            expect(DRV_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "driver runtime SYS_IPC_RECV == canonical":
            expect(DRV_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
        it "driver runtime SYS_IPC_CREATE_PORT == canonical":
            expect(DRV_CREATE_PORT).to_equal(CANONICAL_SYS_IPC_CREATE_PORT)

    describe "posix layer matches kernel":
        it "posix _SYS_IPC_SEND == canonical":
            expect(POSIX_SEND).to_equal(CANONICAL_SYS_IPC_SEND)
        it "posix _SYS_IPC_RECV == canonical":
            expect(POSIX_RECV).to_equal(CANONICAL_SYS_IPC_RECV)
