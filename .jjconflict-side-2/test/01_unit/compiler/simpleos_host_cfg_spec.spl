use std.spec.*
use compiler.core.cfg_platform.{cfg_normalize_os}
use compiler.types.platform_attr_parser.{PlatformAttrValue}

describe "SimpleOS host-OS cfg recognition":

    it "cfg_normalize_os normalizes 'simpleos' to 'simpleos'":
        expect(cfg_normalize_os("simpleos")).to_equal("simpleos")

    it "cfg_normalize_os normalizes 'SimpleOS' to 'simpleos'":
        expect(cfg_normalize_os("SimpleOS")).to_equal("simpleos")

    it "cfg_normalize_os regression: linux still normalizes to 'linux'":
        expect(cfg_normalize_os("linux")).to_equal("linux")

    it "cfg_normalize_os regression: freebsd still normalizes to 'freebsd'":
        expect(cfg_normalize_os("freebsd")).to_equal("freebsd")

    it "PlatformAttrValue.create marks os=simpleos as valid":
        val result = PlatformAttrValue.create("os", "simpleos")
        expect(result.is_valid).to_equal(true)
