# Daemon SDK Protocol Specification
#
# Tests file-based IPC: request/response serialization, atomic writes,
# field extraction, and cleanup.
#
# **Feature IDs:** #DSDK-021 to #DSDK-030
# **Category:** Infrastructure

# ============================================================================
# Module-level mock filesystem
# ============================================================================

var fs_paths: [text] = []
var fs_contents: [text] = []

fn fs_reset():
    fs_paths = []
    fs_contents = []

fn fs_find(path: text) -> i64:
    var i = 0
    while i < fs_paths.len():
        if fs_paths[i] == path:
            return i
        i = i + 1
    -1

fn fs_write(path: text, content: text):
    val idx = fs_find(path)
    if idx >= 0:
        fs_contents[idx] = content
    else:
        fs_paths = fs_paths + [path]
        fs_contents = fs_contents + [content]

fn fs_read(path: text) -> text:
    val idx = fs_find(path)
    if idx >= 0:
        return fs_contents[idx]
    ""

fn fs_exists(path: text) -> bool:
    fs_find(path) >= 0

fn fs_delete(path: text):
    val idx = fs_find(path)
    if idx < 0:
        return
    var np: [text] = []
    var nc: [text] = []
    var i = 0
    while i < fs_paths.len():
        if i != idx:
            np = np + [fs_paths[i]]
            nc = nc + [fs_contents[i]]
        i = i + 1
    fs_paths = np
    fs_contents = nc

fn fs_list_ext(ext: text) -> [text]:
    var result: [text] = []
    var i = 0
    while i < fs_paths.len():
        if fs_paths[i].ends_with(ext):
            result = result + [fs_paths[i]]
        i = i + 1
    result

fn fs_count() -> i64:
    fs_paths.len()

# ============================================================================
# Mock protocol implementation
# ============================================================================

fn mock_write_request(req_id: text, kind: i64, fields_keys: [text], fields_vals: [text], request_dir: text) -> text:
    var content = "id={req_id}\n"
    content = content + "kind={kind}\n"
    content = content + "timestamp=1000000\n"
    var i = 0
    while i < fields_keys.len():
        content = content + "field.{fields_keys[i]}={fields_vals[i]}\n"
        i = i + 1
    val req_path = "{request_dir}/{req_id}.req"
    fs_write(req_path, content)
    req_path

fn mock_write_response(request_id: text, status: i64, fields_keys: [text], fields_vals: [text], response_dir: text) -> bool:
    var content = "request_id={request_id}\n"
    content = content + "status={status}\n"
    content = content + "timestamp=2000000\n"
    var i = 0
    while i < fields_keys.len():
        content = content + "field.{fields_keys[i]}={fields_vals[i]}\n"
        i = i + 1
    val resp_path = "{response_dir}/{request_id}.resp"
    fs_write(resp_path, content)
    true

fn mock_read_requests(request_dir: text) -> [(text, i64)]:
    var results: [(text, i64)] = []
    val files = fs_list_ext(".req")
    var i = 0
    while i < files.len():
        val path = files[i]
        val content = fs_read(path)
        val id = extract_kv(content, "id=")
        val kind_str = extract_kv(content, "kind=")
        val kind = kind_str.to_i64() ?? 0
        results = results + [(id, kind)]
        i = i + 1
    results

fn mock_read_response(request_id: text, response_dir: text) -> (text, i64):
    val resp_path = "{response_dir}/{request_id}.resp"
    if not fs_exists(resp_path):
        return ("", -1)
    val content = fs_read(resp_path)
    val status_str = extract_kv(content, "status=")
    val status = status_str.to_i64() ?? -1
    (request_id, status)

fn extract_kv(content: text, prefix: text) -> text:
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        if lines[i].starts_with(prefix):
            return lines[i].substring(prefix.len())
        i = i + 1
    ""

fn extract_field_kv(content: text, field_name: text) -> text:
    extract_kv(content, "field.{field_name}=")

# Getters
fn fs_get_count() -> i64:
    fs_paths.len()

# ============================================================================
# Tests
# ============================================================================

describe "DaemonProtocol":
    describe "write_request":
        it "creates .req file in request directory":
            fs_reset()
            val path = mock_write_request("pid_100", 1, [], [], ".build/daemon/requests")
            expect(path).to_end_with(".req")
            expect(fs_exists(path)).to_equal(true)

        it "serializes id and kind":
            fs_reset()
            val path = mock_write_request("pid_200", 3, [], [], ".build/daemon/requests")
            val content = fs_read(path)
            expect(content).to_contain("id=pid_200")
            expect(content).to_contain("kind=3")

        it "serializes arbitrary fields":
            fs_reset()
            val path = mock_write_request("pid_300", 1, ["test_path", "filter"], ["test/foo_spec.spl", "unit"], ".build/daemon/requests")
            val content = fs_read(path)
            expect(content).to_contain("field.test_path=test/foo_spec.spl")
            expect(content).to_contain("field.filter=unit")

        it "includes timestamp":
            fs_reset()
            val path = mock_write_request("pid_400", 1, [], [], ".build/daemon/requests")
            val content = fs_read(path)
            expect(content).to_contain("timestamp=")

    describe "write_response":
        it "creates .resp file":
            fs_reset()
            mock_write_response("pid_100", 2, [], [], ".build/daemon/responses")
            expect(fs_exists(".build/daemon/responses/pid_100.resp")).to_equal(true)

        it "serializes request_id and status":
            fs_reset()
            mock_write_response("pid_200", 3, [], [], ".build/daemon/responses")
            val content = fs_read(".build/daemon/responses/pid_200.resp")
            expect(content).to_contain("request_id=pid_200")
            expect(content).to_contain("status=3")

        it "serializes response fields":
            fs_reset()
            mock_write_response("pid_300", 2, ["passed", "failed"], ["5", "0"], ".build/daemon/responses")
            val content = fs_read(".build/daemon/responses/pid_300.resp")
            expect(content).to_contain("field.passed=5")
            expect(content).to_contain("field.failed=0")

    describe "read_requests":
        it "reads all pending requests":
            fs_reset()
            mock_write_request("r1", 1, [], [], ".build/daemon/requests")
            mock_write_request("r2", 2, [], [], ".build/daemon/requests")
            mock_write_request("r3", 3, [], [], ".build/daemon/requests")
            val reqs = mock_read_requests(".build/daemon/requests")
            expect(reqs.len()).to_equal(3)

        it "returns empty when no requests":
            fs_reset()
            val reqs = mock_read_requests(".build/daemon/requests")
            expect(reqs.len()).to_equal(0)

        it "parses id and kind correctly":
            fs_reset()
            mock_write_request("req_abc", 5, [], [], ".build/daemon/requests")
            val reqs = mock_read_requests(".build/daemon/requests")
            expect(reqs[0][0]).to_equal("req_abc")
            expect(reqs[0][1]).to_equal(5)

    describe "read_response":
        it "reads existing response":
            fs_reset()
            mock_write_response("req_1", 2, [], [], ".build/daemon/responses")
            val resp = mock_read_response("req_1", ".build/daemon/responses")
            expect(resp[0]).to_equal("req_1")
            expect(resp[1]).to_equal(2)

        it "returns empty for missing response":
            fs_reset()
            val resp = mock_read_response("nonexistent", ".build/daemon/responses")
            expect(resp[0]).to_equal("")
            expect(resp[1]).to_equal(-1)

    describe "field extraction":
        it "extracts named fields from response":
            fs_reset()
            mock_write_response("r1", 2, ["output", "duration_ms"], ["OK", "150"], ".build/daemon/responses")
            val content = fs_read(".build/daemon/responses/r1.resp")
            expect(extract_field_kv(content, "output")).to_equal("OK")
            expect(extract_field_kv(content, "duration_ms")).to_equal("150")

        it "returns empty for missing fields":
            fs_reset()
            mock_write_response("r1", 2, [], [], ".build/daemon/responses")
            val content = fs_read(".build/daemon/responses/r1.resp")
            expect(extract_field_kv(content, "nonexistent")).to_equal("")

    describe "cleanup":
        it "deletes processed request files":
            fs_reset()
            val p1 = mock_write_request("r1", 1, [], [], ".build/requests")
            val p2 = mock_write_request("r2", 1, [], [], ".build/requests")
            expect(fs_get_count()).to_equal(2)
            fs_delete(p1)
            expect(fs_get_count()).to_equal(1)
            expect(fs_exists(p1)).to_equal(false)
            expect(fs_exists(p2)).to_equal(true)
