extern fn rt_file_read_text(path: text) -> text

describe "redis client negative offset guard":
    it "guards RESP parser cursors before indexed reads":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/redis/client.spl") ?? ""
        expect(source).to_contain("fn try_parse_resp(buf: [u8], start: i64) -> Option<ParseResult>:")
        expect(source).to_contain("if start < 0:\n        return nil")
        expect(source).to_contain("fn try_read_line_from(buf: [u8], start: i64) -> Option<LineResult>:")

    it "keeps async Redis families as facades over the guarded implementation":
        val nogc_async = rt_file_read_text("src/lib/nogc_async_mut/redis/client.spl") ?? ""
        val gc_async = rt_file_read_text("src/lib/gc_async_mut/redis/client.spl") ?? ""
        val gc_sync = rt_file_read_text("src/lib/gc_sync_mut/redis/client.spl") ?? ""
        expect(nogc_async).to_contain("export use std.nogc_sync_mut.redis.client.")
        expect(nogc_async).to_contain("RedisClient")
        expect(gc_async).to_contain("export use std.nogc_sync_mut.redis.client.")
        expect(gc_async).to_contain("RedisClient")
        expect(gc_sync).to_contain("export use std.gc_async_mut.redis.client.*")
