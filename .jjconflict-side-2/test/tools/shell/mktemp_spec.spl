# Test: mktemp tool
# Feature: TOOL-MKTEMP - Create temporary files
# @cover tools/shell/mktemp/mktemp_tool.spl

describe "mktemp tool":
    context "temp file creation":
        it "generates unique names":
            val ts1: i64 = 1000
            val ts2: i64 = 1001
            val name1 = "tmp.{ts1}"
            val name2 = "tmp.{ts2}"
            expect(name1 != name2).to_equal(true)

        it "uses /tmp prefix":
            val name = "tmp.12345"
            val path = "/tmp/{name}"
            expect(path).to_start_with("/tmp/")
