use std.spec
use std.nogc_sync_mut.engine.render.shader_compile.{
    ShaderArtifact, ShaderCache, ShaderCompiler,
    shader_compiler_new, shader_compiler_get_or_compile_spirv,
    shader_compiler_get_or_compile_wgsl
}
use std.nogc_sync_mut.engine.render.wgsl_emitter.{wgsl_emit_vertex, wgsl_emit_fragment}
use std.gc_async_mut.engine.render.shader.{ShaderSource}

# ============================================================================
# Module-level helpers
# ============================================================================

fn make_simple_shader_source() -> ShaderSource:
    ShaderSource(
        glsl_vertex: "void main() { gl_Position = vec4(0.0, 0.0, 0.0, 1.0); }",
        glsl_fragment: "void main() { gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0); }"
    )

fn make_phong_shader_source() -> ShaderSource:
    ShaderSource(
        glsl_vertex: "uniform mat4 mvp; void main() { gl_Position = mvp * vec4(0.0, 0.0, 0.0, 1.0); }",
        glsl_fragment: "uniform sampler2D albedo; void main() { gl_FragColor = texture2D(albedo, vec2(0.0)); }"
    )

fn make_empty_artifact() -> ShaderArtifact:
    ShaderArtifact(
        spirv_vertex: [],
        spirv_fragment: [],
        wgsl_vertex: "",
        wgsl_fragment: "",
        is_compiled: false,
        error_msg: ""
    )

# ============================================================================
# Stream E — shader_compile.spl specs
# AC-5
# ============================================================================

describe "Stream E: ShaderArtifact construction":

    describe "empty artifact":
        it "AC-5: is_compiled is false when not compiled":
            val art = make_empty_artifact()
            expect(art.is_compiled).to_equal(false)

        it "AC-5: error_msg is empty string when no error":
            val art = make_empty_artifact()
            expect(art.error_msg).to_equal("")

        it "AC-5: spirv_vertex is empty slice when not compiled":
            val art = make_empty_artifact()
            expect(art.spirv_vertex.length).to_equal(0)

        it "AC-5: wgsl_vertex is empty when not compiled":
            val art = make_empty_artifact()
            expect(art.wgsl_vertex).to_equal("")

describe "Stream E: ShaderCompiler caching":

    describe "shader_compiler_new":
        it "AC-5: creates compiler with empty cache":
            val compiler = shader_compiler_new()
            expect(compiler.cache.keys.length).to_equal(0)

    describe "get_or_compile_wgsl caching":
        it "AC-5: first compile call returns an artifact":
            var compiler = shader_compiler_new()
            val src = make_simple_shader_source()
            val art = shader_compiler_get_or_compile_wgsl(compiler, src)
            val got_something = art.is_compiled or art.error_msg.length >= 0
            expect(got_something).to_equal(true)

        it "AC-5: second call with same source returns cached result (cache grows by 1 total)":
            var compiler = shader_compiler_new()
            val src = make_simple_shader_source()
            val _ = shader_compiler_get_or_compile_wgsl(compiler, src)
            val cache_size_after_first = compiler.cache.keys.length
            val _ = shader_compiler_get_or_compile_wgsl(compiler, src)
            val cache_size_after_second = compiler.cache.keys.length
            expect(cache_size_after_second).to_equal(cache_size_after_first)

        it "AC-5: different sources produce separate cache entries":
            var compiler = shader_compiler_new()
            val src1 = make_simple_shader_source()
            val src2 = make_phong_shader_source()
            val _ = shader_compiler_get_or_compile_wgsl(compiler, src1)
            val _ = shader_compiler_get_or_compile_wgsl(compiler, src2)
            expect(compiler.cache.keys.length).to_equal(2)

    describe "get_or_compile_spirv caching":
        it "AC-5: second call with same source does not grow spirv cache":
            var compiler = shader_compiler_new()
            val src = make_simple_shader_source()
            val _ = shader_compiler_get_or_compile_spirv(compiler, src)
            val cache_size = compiler.cache.keys.length
            val _ = shader_compiler_get_or_compile_spirv(compiler, src)
            expect(compiler.cache.keys.length).to_equal(cache_size)

# ============================================================================
# Stream E — wgsl_emitter.spl specs
# AC-5
# ============================================================================

describe "Stream E: WgslEmitter basic GLSL to WGSL transformation":

    describe "wgsl_emit_vertex":
        it "AC-5: output is non-empty text":
            val glsl = "void main() { gl_Position = vec4(0.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_vertex(glsl)
            expect(wgsl.length).to_be_greater_than(0)

        it "AC-5: output does not contain void main() (GLSL form)":
            val glsl = "void main() { gl_Position = vec4(0.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_vertex(glsl)
            val has_glsl_main = wgsl.contains("void main()")
            expect(has_glsl_main).to_equal(false)

        it "AC-5: output contains @vertex (WGSL entry point marker)":
            val glsl = "void main() { gl_Position = vec4(0.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_vertex(glsl)
            expect(wgsl).to_contain("@vertex")

        it "AC-5: gl_Position is replaced by builtin position annotation":
            val glsl = "void main() { gl_Position = vec4(0.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_vertex(glsl)
            val has_builtin = wgsl.contains("position") or wgsl.contains("builtin")
            expect(has_builtin).to_equal(true)

    describe "wgsl_emit_fragment":
        it "AC-5: output is non-empty text":
            val glsl = "void main() { gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_fragment(glsl)
            expect(wgsl.length).to_be_greater_than(0)

        it "AC-5: output contains @fragment (WGSL entry point marker)":
            val glsl = "void main() { gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_fragment(glsl)
            expect(wgsl).to_contain("@fragment")

        it "AC-5: gl_FragColor is replaced by location annotation":
            val glsl = "void main() { gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_fragment(glsl)
            val has_location = wgsl.contains("location") or wgsl.contains("@location")
            expect(has_location).to_equal(true)

        it "AC-5: output does not contain gl_FragColor":
            val glsl = "void main() { gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0); }"
            val wgsl = wgsl_emit_fragment(glsl)
            val still_has_fragcolor = wgsl.contains("gl_FragColor")
            expect(still_has_fragcolor).to_equal(false)
