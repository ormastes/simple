use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val SESSION_TOKEN_PATH = "src/app/ui.web/session_token.spl"
val WS_HANDLER_PATH = "src/app/ui.web/ws_handler.spl"
val ORIGIN_GUARD_PATH = "src/app/ui.web/origin_guard.spl"

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "WSS smoke source contracts":
    it "session tokens keep the issue/serialize/parse/verify surface":
        val source = read_source(SESSION_TOKEN_PATH)
        expect(source).to_contain("static fn issue(")
        expect(source).to_contain("fn serialize(self) -> text")
        expect(source).to_contain("static fn parse(s: text)")
        expect(source).to_contain("fn verify(serialized: text, origin: text, secret: text, now_ms: u64)")
        expect(source).to_contain("_parse_u64(exp_str)")

    it "websocket handshake helpers remain exposed":
        val source = read_source(WS_HANDLER_PATH)
        expect(source).to_contain("fn compute_ws_accept(key: text) -> text")
        expect(source).to_contain("fn is_ws_upgrade_request(headers: text) -> bool")

    it "origin guard still exposes dev-mode construction and checking":
        val source = read_source(ORIGIN_GUARD_PATH)
        expect(source).to_contain("class OriginGuard")
        expect(source).to_contain("static fn from_env() -> OriginGuard")
        expect(source).to_contain("fn check(self, headers: text) -> Result<text, AuthError>")
