# editor_gui_sdl2_spec.spl
#
# System tests: verify gui_sdl2_bridge.spl exists with the expected
# function and extern declarations, and that gui_shell.spl exposes
# the SDL2-backed present helper.
#
# tag: system

extern fn rt_file_read_text(path: text) -> text

describe "Editor GUI SDL2 Bridge":
    it "gui_sdl2_bridge.spl exists and is non-empty":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("gui_sdl2_bridge")

    it "gui_sdl2_init function declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("fn gui_sdl2_init(")

    it "gui_sdl2_render_text_block function declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("fn gui_sdl2_render_text_block(")

    it "gui_sdl2_present_frame function declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("fn gui_sdl2_present_frame(")

    it "gui_sdl2_poll function declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("fn gui_sdl2_poll(")

    it "rt_sdl2_create_window extern declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("extern fn rt_sdl2_create_window(")

    it "rt_sdl2_present_rgba extern declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("extern fn rt_sdl2_present_rgba(")

    it "rt_sdl2_poll_event extern declared":
        val src = rt_file_read_text("src/lib/editor/70.backend/gui_sdl2_bridge.spl") ?? ""
        expect (src).contains("extern fn rt_sdl2_poll_event(")

    it "gui_shell_present_frame_sdl2 added to gui_shell.spl":
        val src = rt_file_read_text("src/app/editor/gui_shell.spl") ?? ""
        expect (src).contains("fn gui_shell_present_frame_sdl2(")

    it "gui_shell_present_frame_sdl2 delegates to gui_sdl2_present_frame":
        val src = rt_file_read_text("src/app/editor/gui_shell.spl") ?? ""
        expect (src).contains("gui_sdl2_present_frame(window, frame)")
