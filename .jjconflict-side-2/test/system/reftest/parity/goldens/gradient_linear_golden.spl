# Golden fixture: gradient_linear — DrawRect filled with gradient-approximating solid (red→blue heuristic)
# Approximates a linear gradient with a midpoint purple solid over a red-to-blue split.

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{SkColor, sk_color_argb, sk_color_red, sk_color_blue}

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    # Left half: red
    val rect_red = SkRect(left: 0.0, top: 0.0, right: 128.0, bottom: 256.0)
    val paint_red = sk_paint_fill(sk_color_red())
    val op_red = sk_picture_op_draw_rect(rect_red, paint_red)
    # Right half: blue
    val rect_blue = SkRect(left: 128.0, top: 0.0, right: 256.0, bottom: 256.0)
    val paint_blue = sk_paint_fill(sk_color_blue())
    val op_blue = sk_picture_op_draw_rect(rect_blue, paint_blue)
    val ops = [op_red, op_blue]
    val picture = SkPicture(cull_rect: cull, op_count: 2, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
