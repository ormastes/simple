# Golden fixture: backdrop_filter — background rect, SaveLayer(Multiply), foreground rect, Restore
# SaveLayer/Restore are recorded as ops but fall through to pass_do_nothing in the CPU backend.
# The rasterised result captures background + foreground as a deterministic fixture.

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_red, sk_color_blue, sk_color_argb}
use std.skia.entity.enums.{SkBlendMode}

fn _save_layer_op(paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.SaveLayer,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn _restore_op(paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.Restore,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    # Background rect — red
    val bg_rect = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    val bg_paint = sk_paint_fill(sk_color_red())
    val op_bg = sk_picture_op_draw_rect(bg_rect, bg_paint)
    # SaveLayer with Multiply blend
    val layer_paint_base = sk_paint_fill(sk_color_argb(128, 0, 0, 255))
    val layer_paint = layer_paint_base.with_blend_mode(SkBlendMode.Multiply)
    val op_save_layer = _save_layer_op(layer_paint)
    # Foreground rect — semi-transparent blue
    val fg_rect = SkRect(left: 64.0, top: 64.0, right: 192.0, bottom: 192.0)
    val fg_paint = sk_paint_fill(sk_color_blue())
    val op_fg = sk_picture_op_draw_rect(fg_rect, fg_paint)
    # Restore
    val restore_paint = sk_paint_fill(sk_color_argb(255, 0, 0, 0))
    val op_restore = _restore_op(restore_paint)
    val ops = [op_bg, op_save_layer, op_fg, op_restore]
    val picture = SkPicture(cull_rect: cull, op_count: 4, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
