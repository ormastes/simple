use std.spec

describe "ZipReader":
    it "should parse a local file header signature":
        # PK\x03\x04 magic bytes at offset 0
        val magic_0 = 80
        val magic_1 = 75
        val magic_2 = 3
        val magic_3 = 4
        val sig = magic_0 + magic_1 + magic_2 + magic_3
        expect(sig).to_equal(162)

    it "should calculate central directory end signature":
        # EOCD signature: PK\x05\x06 = 0x06054b50
        val eocd_sig = 101010256
        expect(eocd_sig).to_equal(101010256)

    it "should compute zip64 extra field marker":
        # zip64 extra field tag = 0x0001
        val zip64_tag = 1
        expect(zip64_tag).to_equal(1)

    it "should validate CRC32 of empty content":
        # CRC32 of empty byte sequence is 0x00000000
        val crc_empty = 0
        expect(crc_empty).to_equal(0)

    it "should identify deflate compression method":
        # compression method 8 = deflate in ZIP spec
        val method_deflate = 8
        val method_stored = 0
        expect(method_deflate).to_equal(8)
        expect(method_stored).to_equal(0)

    it "should calculate minimum local file header size":
        # local file header fixed portion: 30 bytes (signature 4 + fields 26)
        val lfh_fixed_size = 30
        expect(lfh_fixed_size).to_equal(30)

    it "should validate zip64 compressed size placeholder":
        # zip64: compressed_size field = 0xFFFFFFFF when actual size in extra
        val zip64_marker = 4294967295
        expect(zip64_marker).to_be_greater_than(0)
