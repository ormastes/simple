#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Acid Test Runner — renders Acid1/Acid2 through Simple browser engine
#
# Renders the Acid test HTML files and exports as PPM images for visual inspection.
# Also renders a simple reference box to verify the engine is working.
#
# Usage:
#   bin/simple run examples/browser/test/compat/acid_test_runner.spl

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use examples.browser.test.compat.image_export.{export_ppm_text}

fn main() -> i64:
    print "=========================================="
    print "  Acid Test Runner — Simple Browser"
    print "=========================================="

    val output_dir = "examples/browser/test/compat/external"

    # --- Sanity check: render a simple colored div ---
    print "\n--- Sanity Check ---"
    val sanity_html = "<div style=\"width: 100px; height: 100px; background-color: red;\"></div>"
    val renderer0 = BrowserRenderer.create(200, 200)
    val sanity = renderer0.render_html_to_pixels(sanity_html)
    if sanity.pixel_data.len() > 0:
        val ppm = export_ppm_text("{output_dir}/sanity_check.ppm", sanity.pixel_data, 200, 200)
        rt_file_write_text("{output_dir}/sanity_check.ppm", ppm)
        # Check if there's any non-white pixel (red div should produce colored pixels)
        var non_white = 0
        for px in sanity.pixel_data:
            if px != 0xFFFFFFFF:
                non_white = non_white + 1
        print "  Sanity: {sanity.pixel_data.len()} pixels, {non_white} non-white"
        if non_white > 0:
            print "  PASS: Renderer is producing colored output"
        else:
            print "  WARN: All pixels white — renderer may not be applying styles"
    else:
        print "  FAIL: No pixels produced"
        return 1

    # --- Test with <style> block ---
    print "\n--- Style Block Test ---"
    val style_html = "<!DOCTYPE html><html><head><style>div { background-color: blue; width: 100px; height: 100px; }</style></head><body><div></div></body></html>"
    val renderer1 = BrowserRenderer.create(200, 200)
    val style_test = renderer1.render_html_to_pixels(style_html)
    if style_test.pixel_data.len() > 0:
        val ppm = export_ppm_text("{output_dir}/style_block_test.ppm", style_test.pixel_data, 200, 200)
        rt_file_write_text("{output_dir}/style_block_test.ppm", ppm)
        var non_white = 0
        for px in style_test.pixel_data:
            if px != 0xFFFFFFFF:
                non_white = non_white + 1
        print "  Style block: {non_white} non-white pixels"
        if non_white > 100:
            print "  PASS: <style> block CSS rules are being applied"
        else:
            print "  FAIL: <style> block rules not applied (only {non_white} colored pixels)"
    else:
        print "  FAIL: No pixels produced"

    # --- Acid1 ---
    print "\n--- Acid1 Test ---"
    val acid1_html = rt_file_read_text("{output_dir}/acid1.html") ?? ""
    if acid1_html.len() == 0:
        print "  SKIP: acid1.html not found"
    else:
        val renderer2 = BrowserRenderer.create(800, 600)
        val acid1 = renderer2.render_html_to_pixels(acid1_html)
        if acid1.pixel_data.len() > 0:
            val ppm = export_ppm_text("{output_dir}/acid1_rendered.ppm", acid1.pixel_data, 800, 600)
            rt_file_write_text("{output_dir}/acid1_rendered.ppm", ppm)
            var non_white = 0
            for px in acid1.pixel_data:
                if px != 0xFFFFFFFF:
                    non_white = non_white + 1
            val total = acid1.pixel_data.len()
            val pct = if total > 0: (non_white.to_f64() / total.to_f64()) * 100.0 else: 0.0
            print "  Acid1: {non_white}/{total} non-white pixels ({pct}%)"
            print "  Rendered to {output_dir}/acid1_rendered.ppm"
            print "  NOTE: Visual inspection needed — compare with reference rendering"
        else:
            print "  FAIL: No pixels produced"

    # --- Acid2 ---
    print "\n--- Acid2 Test ---"
    val acid2_html = rt_file_read_text("{output_dir}/acid2.html") ?? ""
    if acid2_html.len() == 0:
        print "  SKIP: acid2.html not found"
    else:
        val renderer3 = BrowserRenderer.create(800, 600)
        val acid2 = renderer3.render_html_to_pixels(acid2_html)
        if acid2.pixel_data.len() > 0:
            val ppm = export_ppm_text("{output_dir}/acid2_rendered.ppm", acid2.pixel_data, 800, 600)
            rt_file_write_text("{output_dir}/acid2_rendered.ppm", ppm)
            var non_white = 0
            for px in acid2.pixel_data:
                if px != 0xFFFFFFFF:
                    non_white = non_white + 1
            val total = acid2.pixel_data.len()
            val pct = if total > 0: (non_white.to_f64() / total.to_f64()) * 100.0 else: 0.0
            print "  Acid2: {non_white}/{total} non-white pixels ({pct}%)"
            print "  Rendered to {output_dir}/acid2_rendered.ppm"
            print "  NOTE: Visual inspection needed — should show a smiley face"
        else:
            print "  FAIL: No pixels produced"

    print "\n=========================================="
    print "  Done"
    print "=========================================="
    0
