# IR_TC Binary Format — .irtc constants and encoding helpers
#
# Binary format for serializing IrTcModule to/from a byte stream.
#
# Layout:
#   Header (4 bytes):  Magic "IRTC" + Version(u8) + Flags(u8) + Width(u8) + Reserved(u8)
#   [TypeTable]        Indexed type definitions
#   [StringTable]      Indexed strings (null-separated)
#   [GlobalTable]      Global variables
#   [FunctionTable]    Functions with blocks and instructions
#   [GuestStateTable]  Optional guest CPU definitions

use core.types.{IrTcTypeKind, IrTcCond, CallConv, GuestArch}
use core.ops.{IrTcOp}
use core.mem_op.{Endian, BarrierKind}
use core.block.{IrTcModuleMode}

# ============================================================================
# Magic and Version
# ============================================================================

val IRTC_MAGIC_0: i64 = 0x49   # 'I'
val IRTC_MAGIC_1: i64 = 0x52   # 'R'
val IRTC_MAGIC_2: i64 = 0x54   # 'T'
val IRTC_MAGIC_3: i64 = 0x43   # 'C'

val IRTC_VERSION: i64 = 1

# ============================================================================
# Header Flags (bit positions)
# ============================================================================

val FLAG_HAS_GUEST_STATE: i64 = 1    # bit 0
val FLAG_COMPRESSED: i64 = 2         # bit 1
val FLAG_HAS_BC_METADATA: i64 = 4    # bit 2

# ============================================================================
# Width Encoding
# ============================================================================

val WIDTH_GENERIC: i64 = 0
val WIDTH_8: i64 = 8
val WIDTH_16: i64 = 16
val WIDTH_32: i64 = 32
val WIDTH_64: i64 = 64

# ============================================================================
# Section IDs
# ============================================================================

val SECTION_TYPE_TABLE: i64 = 0x01
val SECTION_STRING_TABLE: i64 = 0x02
val SECTION_GLOBAL_TABLE: i64 = 0x03
val SECTION_FUNCTION_TABLE: i64 = 0x04
val SECTION_GUEST_STATE_TABLE: i64 = 0x05
val SECTION_END: i64 = 0xFF

# ============================================================================
# Type Tag Encoding — one byte identifying IrTcTypeKind variant
# ============================================================================

val TYPE_TAG_I1: i64 = 0x01
val TYPE_TAG_I8: i64 = 0x02
val TYPE_TAG_I16: i64 = 0x03
val TYPE_TAG_I32: i64 = 0x04
val TYPE_TAG_I64: i64 = 0x05
val TYPE_TAG_F32: i64 = 0x06
val TYPE_TAG_F64: i64 = 0x07
val TYPE_TAG_PTR: i64 = 0x08
val TYPE_TAG_VEC: i64 = 0x09
val TYPE_TAG_STRUCT: i64 = 0x0A
val TYPE_TAG_ARRAY: i64 = 0x0B
val TYPE_TAG_VOID: i64 = 0x0C
val TYPE_TAG_FLAG: i64 = 0x0D

# ============================================================================
# Opcode Encoding — map IrTcOp variant to u8 opcode
# ============================================================================

# Arithmetic (0x01 – 0x06)
val OP_ADD: i64 = 0x01
val OP_SUB: i64 = 0x02
val OP_MUL: i64 = 0x03
val OP_DIV: i64 = 0x04
val OP_REM: i64 = 0x05
val OP_NEG: i64 = 0x06

# Bitwise (0x10 – 0x18)
val OP_AND: i64 = 0x10
val OP_OR: i64 = 0x11
val OP_XOR: i64 = 0x12
val OP_NOT: i64 = 0x13
val OP_SHL: i64 = 0x14
val OP_SHR: i64 = 0x15
val OP_SAR: i64 = 0x16
val OP_ROTL: i64 = 0x17
val OP_ROTR: i64 = 0x18

# Comparison (0x20)
val OP_CMP: i64 = 0x20

# Width Conversion (0x28 – 0x2A)
val OP_EXT: i64 = 0x28
val OP_TRUNC: i64 = 0x29
val OP_BITCAST: i64 = 0x2A

# Memory — Compilation (0x30 – 0x32)
val OP_LOAD: i64 = 0x30
val OP_STORE: i64 = 0x31
val OP_ALLOCA: i64 = 0x32

# Memory — Emulation (0x38 – 0x39)
val OP_GUEST_LOAD: i64 = 0x38
val OP_GUEST_STORE: i64 = 0x39

# Control Flow (0x40 – 0x43)
val OP_BR: i64 = 0x40
val OP_BR_COND: i64 = 0x41
val OP_SWITCH: i64 = 0x42
val OP_RET: i64 = 0x43

# Function Calls (0x48 – 0x49)
val OP_CALL: i64 = 0x48
val OP_CALL_HELPER: i64 = 0x49

# Guest State (0x50 – 0x51)
val OP_READ_GUEST_REG: i64 = 0x50
val OP_WRITE_GUEST_REG: i64 = 0x51

# Translation Block Control (0x58 – 0x5A)
val OP_EXIT_TB: i64 = 0x58
val OP_GOTO_TB: i64 = 0x59
val OP_LOOKUP_GOTO_TB: i64 = 0x5A

# Aggregates (0x60 – 0x62)
val OP_GET_ELEMENT_PTR: i64 = 0x60
val OP_EXTRACT_VALUE: i64 = 0x61
val OP_INSERT_VALUE: i64 = 0x62

# SSA (0x68)
val OP_PHI: i64 = 0x68

# Special (0x70 – 0x73)
val OP_SYNC_GUEST_PC: i64 = 0x70
val OP_BARRIER: i64 = 0x71
val OP_NOP: i64 = 0x72
val OP_UNREACHABLE: i64 = 0x73

# ============================================================================
# Condition Code Encoding
# ============================================================================

val COND_EQ: i64 = 0
val COND_NE: i64 = 1
val COND_LT: i64 = 2
val COND_LE: i64 = 3
val COND_GT: i64 = 4
val COND_GE: i64 = 5
val COND_LTU: i64 = 6
val COND_LEU: i64 = 7
val COND_GTU: i64 = 8
val COND_GEU: i64 = 9

# ============================================================================
# Calling Convention Encoding
# ============================================================================

val CC_DEFAULT: i64 = 0
val CC_C: i64 = 1
val CC_FAST: i64 = 2
val CC_COLD: i64 = 3
val CC_AVR_INTERRUPT: i64 = 4
val CC_X86_STDCALL: i64 = 5
val CC_X86_FASTCALL: i64 = 6
val CC_HELPER: i64 = 7

# ============================================================================
# Endian Encoding
# ============================================================================

val ENDIAN_LITTLE: i64 = 0
val ENDIAN_BIG: i64 = 1
val ENDIAN_HOST: i64 = 2
val ENDIAN_GUEST: i64 = 3

# ============================================================================
# Barrier Kind Encoding
# ============================================================================

val BARRIER_FULL: i64 = 0
val BARRIER_LOAD_LOAD: i64 = 1
val BARRIER_STORE_STORE: i64 = 2
val BARRIER_LOAD_STORE: i64 = 3
val BARRIER_STORE_LOAD: i64 = 4

# ============================================================================
# Guest Architecture Encoding
# ============================================================================

val ARCH_AVR: i64 = 0
val ARCH_I8086: i64 = 1
val ARCH_ARM: i64 = 2
val ARCH_RISCV32: i64 = 3
val ARCH_X86: i64 = 4
val ARCH_AARCH64: i64 = 5
val ARCH_RISCV64: i64 = 6
val ARCH_X86_64: i64 = 7

# ============================================================================
# Module Mode Encoding
# ============================================================================

val MODE_COMPILATION: i64 = 0
val MODE_EMULATION: i64 = 1
val MODE_MIXED: i64 = 2

# ============================================================================
# Encoding Helpers
# ============================================================================

fn encode_cond(cond: IrTcCond) -> i64:
    """Encode IrTcCond to byte."""
    match cond:
        Eq: COND_EQ
        Ne: COND_NE
        Lt: COND_LT
        Le: COND_LE
        Gt: COND_GT
        Ge: COND_GE
        Ltu: COND_LTU
        Leu: COND_LEU
        Gtu: COND_GTU
        Geu: COND_GEU

fn decode_cond(byte: i64) -> IrTcCond?:
    """Decode byte to IrTcCond."""
    match byte:
        0: Some(IrTcCond.Eq)
        1: Some(IrTcCond.Ne)
        2: Some(IrTcCond.Lt)
        3: Some(IrTcCond.Le)
        4: Some(IrTcCond.Gt)
        5: Some(IrTcCond.Ge)
        6: Some(IrTcCond.Ltu)
        7: Some(IrTcCond.Leu)
        8: Some(IrTcCond.Gtu)
        9: Some(IrTcCond.Geu)
        _: nil

fn encode_call_conv(cc: CallConv) -> i64:
    """Encode CallConv to byte."""
    match cc:
        Default: CC_DEFAULT
        C: CC_C
        Fast: CC_FAST
        Cold: CC_COLD
        AvrInterrupt: CC_AVR_INTERRUPT
        X86Stdcall: CC_X86_STDCALL
        X86Fastcall: CC_X86_FASTCALL
        Helper: CC_HELPER

fn decode_call_conv(byte: i64) -> CallConv?:
    """Decode byte to CallConv."""
    match byte:
        0: Some(CallConv.Default)
        1: Some(CallConv.C)
        2: Some(CallConv.Fast)
        3: Some(CallConv.Cold)
        4: Some(CallConv.AvrInterrupt)
        5: Some(CallConv.X86Stdcall)
        6: Some(CallConv.X86Fastcall)
        7: Some(CallConv.Helper)
        _: nil

fn encode_endian(endian: Endian) -> i64:
    """Encode Endian to byte."""
    match endian:
        Little: ENDIAN_LITTLE
        Big: ENDIAN_BIG
        Host: ENDIAN_HOST
        Guest: ENDIAN_GUEST

fn decode_endian(byte: i64) -> Endian?:
    """Decode byte to Endian."""
    match byte:
        0: Some(Endian.Little)
        1: Some(Endian.Big)
        2: Some(Endian.Host)
        3: Some(Endian.Guest)
        _: nil

fn encode_barrier(kind: BarrierKind) -> i64:
    """Encode BarrierKind to byte."""
    match kind:
        Full: BARRIER_FULL
        LoadLoad: BARRIER_LOAD_LOAD
        StoreStore: BARRIER_STORE_STORE
        LoadStore: BARRIER_LOAD_STORE
        StoreLoad: BARRIER_STORE_LOAD

fn decode_barrier(byte: i64) -> BarrierKind?:
    """Decode byte to BarrierKind."""
    match byte:
        0: Some(BarrierKind.Full)
        1: Some(BarrierKind.LoadLoad)
        2: Some(BarrierKind.StoreStore)
        3: Some(BarrierKind.LoadStore)
        4: Some(BarrierKind.StoreLoad)
        _: nil

fn encode_guest_arch(arch: GuestArch) -> i64:
    """Encode GuestArch to byte."""
    match arch:
        Avr: ARCH_AVR
        I8086: ARCH_I8086
        Arm: ARCH_ARM
        Riscv32: ARCH_RISCV32
        X86: ARCH_X86
        AArch64: ARCH_AARCH64
        Riscv64: ARCH_RISCV64
        X86_64: ARCH_X86_64

fn decode_guest_arch(byte: i64) -> GuestArch?:
    """Decode byte to GuestArch."""
    match byte:
        0: Some(GuestArch.Avr)
        1: Some(GuestArch.I8086)
        2: Some(GuestArch.Arm)
        3: Some(GuestArch.Riscv32)
        4: Some(GuestArch.X86)
        5: Some(GuestArch.AArch64)
        6: Some(GuestArch.Riscv64)
        7: Some(GuestArch.X86_64)
        _: nil

fn encode_module_mode(mode: IrTcModuleMode) -> i64:
    """Encode IrTcModuleMode to byte."""
    match mode:
        Compilation: MODE_COMPILATION
        Emulation: MODE_EMULATION
        Mixed: MODE_MIXED

fn decode_module_mode(byte: i64) -> IrTcModuleMode?:
    """Decode byte to IrTcModuleMode."""
    match byte:
        0: Some(IrTcModuleMode.Compilation)
        1: Some(IrTcModuleMode.Emulation)
        2: Some(IrTcModuleMode.Mixed)
        _: nil

fn encode_type_tag(type_: IrTcTypeKind) -> i64:
    """Encode IrTcTypeKind variant to type tag byte."""
    match type_:
        I1: TYPE_TAG_I1
        I8: TYPE_TAG_I8
        I16: TYPE_TAG_I16
        I32: TYPE_TAG_I32
        I64: TYPE_TAG_I64
        F32: TYPE_TAG_F32
        F64: TYPE_TAG_F64
        Ptr(_): TYPE_TAG_PTR
        Vec(_, _): TYPE_TAG_VEC
        Struct(_): TYPE_TAG_STRUCT
        Array(_, _): TYPE_TAG_ARRAY
        Void: TYPE_TAG_VOID
        Flag: TYPE_TAG_FLAG

# ============================================================================
# Byte Stream Helpers — little-endian encoding
# ============================================================================

fn encode_u16_le(value: i64) -> [i64]:
    """Encode a 16-bit value as two bytes in little-endian order."""
    [value % 256, (value / 256) % 256]

fn encode_u32_le(value: i64) -> [i64]:
    """Encode a 32-bit value as four bytes in little-endian order."""
    [value % 256, (value / 256) % 256, (value / 65536) % 256, (value / 16777216) % 256]

fn encode_u64_le(value: i64) -> [i64]:
    """Encode a 64-bit value as eight bytes in little-endian order."""
    var result: [i64] = []
    var v = value
    for _ in 0..8:
        result.push(v % 256)
        v = v / 256
    result

fn decode_u16_le(bytes: [i64], offset: i64) -> i64:
    """Decode a 16-bit little-endian value from bytes at offset."""
    bytes[offset] + bytes[offset + 1] * 256

fn decode_u32_le(bytes: [i64], offset: i64) -> i64:
    """Decode a 32-bit little-endian value from bytes at offset."""
    bytes[offset] + bytes[offset + 1] * 256 + bytes[offset + 2] * 65536 + bytes[offset + 3] * 16777216

fn decode_u64_le(bytes: [i64], offset: i64) -> i64:
    """Decode a 64-bit little-endian value from bytes at offset."""
    var result: i64 = 0
    var multiplier: i64 = 1
    for i in 0..8:
        result = result + bytes[offset + i] * multiplier
        multiplier = multiplier * 256
    result
