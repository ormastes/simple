# Hazard Detection
#
# Detects and reports data hazards (RAW, WAW, WAR) and control hazards
# (branch mispredictions) for the timing overlay model (REQ-SIM-009).

# ============================================================================
# Hazard Kinds
# ============================================================================

enum HazardKind:
    """Types of pipeline data hazards."""
    RAW     # Read After Write — true dependency
    WAW     # Write After Write — output dependency
    WAR     # Write After Read — anti-dependency

impl HazardKind:
    fn to_text() -> text:
        match self:
            RAW: "RAW"
            WAW: "WAW"
            WAR: "WAR"

# ============================================================================
# Data Hazard
# ============================================================================

struct DataHazard:
    """A detected data hazard at a specific instruction."""
    pc: i64
    kind: HazardKind
    src_reg: i64        # Register causing the hazard
    stall_cycles: i64   # Number of stall cycles inserted

impl DataHazard:
    fn to_text() -> text:
        "{self.kind.to_text()} at PC=0x{self.pc}: x{self.src_reg} stall {self.stall_cycles}cy"

# ============================================================================
# Control Hazard
# ============================================================================

struct ControlHazard:
    """A detected control hazard (branch/jump misprediction)."""
    pc: i64
    penalty_cycles: i64
    was_taken: bool
    predicted_taken: bool

impl ControlHazard:
    fn to_text() -> text:
        "Branch at PC=0x{self.pc}: penalty {self.penalty_cycles}cy taken={self.was_taken} predicted={self.predicted_taken}"

# ============================================================================
# Hazard Report
# ============================================================================

struct HazardReport:
    """Aggregated hazard report for a simulation run."""
    data_hazards: [DataHazard]
    control_hazards: [ControlHazard]
    total_data_stalls: i64
    total_control_stalls: i64
    raw_count: i64
    waw_count: i64
    war_count: i64

impl HazardReport:
    static fn empty() -> HazardReport:
        HazardReport(
            data_hazards: [],
            control_hazards: [],
            total_data_stalls: 0,
            total_control_stalls: 0,
            raw_count: 0,
            waw_count: 0,
            war_count: 0
        )

    fn to_text() -> text:
        var out = "Hazard Report:\n"
        out = out + "  Data hazards: {self.data_hazards.len()} (RAW={self.raw_count} WAW={self.waw_count} WAR={self.war_count})\n"
        out = out + "  Control hazards: {self.control_hazards.len()}\n"
        out = out + "  Total data stalls: {self.total_data_stalls} cycles\n"
        out = out + "  Total control stalls: {self.total_control_stalls} cycles"
        out

# ============================================================================
# Hazard Detector
# ============================================================================

class HazardDetector:
    """Accumulates hazard events during simulation."""
    data_hazards: [DataHazard]
    control_hazards: [ControlHazard]

impl HazardDetector:
    static fn new() -> HazardDetector:
        HazardDetector(data_hazards: [], control_hazards: [])

    me record_data_hazard(hazard: DataHazard):
        self.data_hazards.push(hazard)

    me record_control_hazard(hazard: ControlHazard):
        self.control_hazards.push(hazard)

    fn report() -> HazardReport:
        """Generate a summary report of all detected hazards."""
        var total_data_stalls: i64 = 0
        var total_control_stalls: i64 = 0
        var raw_count: i64 = 0
        var waw_count: i64 = 0
        var war_count: i64 = 0

        for h in self.data_hazards:
            total_data_stalls = total_data_stalls + h.stall_cycles
            match h.kind:
                HazardKind.RAW: raw_count = raw_count + 1
                HazardKind.WAW: waw_count = waw_count + 1
                HazardKind.WAR: war_count = war_count + 1

        for h in self.control_hazards:
            total_control_stalls = total_control_stalls + h.penalty_cycles

        HazardReport(
            data_hazards: self.data_hazards,
            control_hazards: self.control_hazards,
            total_data_stalls: total_data_stalls,
            total_control_stalls: total_control_stalls,
            raw_count: raw_count,
            waw_count: waw_count,
            war_count: war_count
        )
