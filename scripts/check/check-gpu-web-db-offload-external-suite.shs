if [ "${1:-}" = "--self-test-allow-partial" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    stub="$tmpdir/stub-step.sh"
    missing="$tmpdir/missing.env"
    missing_source="$tmpdir/source.env"
    cat > "$stub" <<'EOF'
#!/usr/bin/env sh
echo "stub-step:$0:$*"
EOF
    chmod +x "$stub"
    output="$(
        READINESS="$stub" \
        WEB_REPORT="$stub" \
        NGINX_LIVE="$stub" \
        STATIC_EXTERNAL="$stub" \
        PROXY_EXTERNAL="$stub" \
        DYNAMIC_ROUTE="$stub" \
        DB_BASELINES="$stub" \
        DB_REPORT="$stub" \
        RECOVERY="$stub" \
        MISSING_BY_CATEGORY="$missing" \
        MISSING_BY_CATEGORY_SOURCE="$missing_source" \
        FIXTURE_ENV_FILE="$tmpdir/absent.env" \
        STATUS_JSON_PATH="$tmpdir/external-suite-status.json" \
        POLICY_JSON_PATH="$tmpdir/external-suite-readiness-policy.json" \
        REQUIRED_ENV_MISSING_PATH="$tmpdir/external-suite-required-env-missing.env" \
        REQUIRED_ENV_HINTS_PATH="$tmpdir/external-suite-required-env-hints.md" \
        REQUIRED_BLOCKERS_PATH="$tmpdir/external-suite-required-blockers.tsv" \
        COMPLETION_AUDIT_PATH="$tmpdir/external-suite-completion-audit.md" \
        REQUIRED_NEXT_ACTIONS_PATH="$tmpdir/external-suite-required-next-actions.md" \
        sh "$0" --allow-partial
    )"
    printf '%s\n' "$output" | grep -q '^STATUS: WARN gpu web/db external suite allow-partial$'
    printf '%s\n' "$output" | grep -q '^RUN: write-env-template$'
    printf '%s\n' "$output" | grep -q '^RUN: write-docker-compose-template$'
    printf '%s\n' "$output" | grep -q '^RUN: write-docker-run-template$'
    printf '%s\n' "$output" | grep -q '^RUN: write-proxy-config-templates$'
    printf '%s\n' "$output" | grep -q '^RUN: write-env-fields$'
    printf '%s\n' "$output" | grep -q '^RUN: write-blocker-manifest$'
    printf '%s\n' "$output" | grep -q '^RUN: write-env-hints$'
    printf '%s\n' "$output" | grep -q '^RUN: write-runbook$'
    printf '%s\n' "$output" | grep -q '^RUN: write-next-actions$'
    printf '%s\n' "$output" | grep -q '^RUN: write-status-json$'
    printf '%s\n' "$output" | grep -q '^RUN: write-policy-json$'
    printf '%s\n' "$output" | grep -q '^RUN: write-required-env-missing$'
    printf '%s\n' "$output" | grep -q '^RUN: write-required-env-hints$'
    printf '%s\n' "$output" | grep -q '^RUN: write-required-blockers$'
    printf '%s\n' "$output" | grep -q '^RUN: write-completion-audit$'
    printf '%s\n' "$output" | grep -q '^RUN: write-required-next-actions$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_data_source|ambient-environment$'
    printf '%s\n' "$output" | grep -q '^STATUS: PASS gpu web/db external suite refresh status$'
    grep -q '^missing_data_source=ambient-environment$' "$missing_source"
    test -f "$tmpdir/external-suite-status.json"
    test -f "$tmpdir/external-suite-readiness-policy.json"
    test -f "$tmpdir/external-suite-required-env-missing.env"
    test -f "$tmpdir/external-suite-required-env-hints.md"
    test -f "$tmpdir/external-suite-required-blockers.tsv"
    test -f "$tmpdir/external-suite-completion-audit.md"
    test -f "$tmpdir/external-suite-required-next-actions.md"
    printf '%s\n' "$output" | grep -q '^RUN: artifact-consistency$'
    printf '%s\n' "$output" | grep -q '^STATUS: WARN gpu web/db external suite partial$'
    if printf '%s\n' "$output" | grep -q '^STATUS: PASS gpu web/db external suite$'; then
        echo "ERROR: allow-partial ended with full-suite PASS" >&2
        exit 1
    fi
    echo "STATUS: PASS gpu web/db external suite allow-partial self-test"
    exit 0
fi

run_step() {
    label="$1"
    shift
    echo "RUN: $label"
    "$@"
}

ALLOW_PARTIAL=0
if [ "${1:-}" != "--allow-partial" ]; then
    preflight_output="$(emit_preflight)"
    printf '%s\n' "$preflight_output"
    missing_count="$(printf '%s\n' "$preflight_output" | awk -F'|' '/^external-suite-status=missing_fixture_items/ { print $2 }')"
    if [ "${missing_count:-0}" != "0" ]; then
        exit 0
    fi
else
    ALLOW_PARTIAL=1
    echo "STATUS: WARN gpu web/db external suite allow-partial"
fi

run_step "write-env-template" sh "$READINESS" --write-env-template
run_step "write-setup-checklist" sh "$READINESS" --write-setup-checklist
run_step "bootstrap-status" sh "$READINESS" --bootstrap-status
run_step "write-bootstrap-manifest" sh "$READINESS" --write-bootstrap-manifest
run_step "write-docker-compose-template" sh "$READINESS" --write-docker-compose-template
run_step "write-docker-run-template" sh "$READINESS" --write-docker-run-template
run_step "write-proxy-config-templates" sh "$READINESS" --write-proxy-config-templates
run_step "write-env-fields" sh "$READINESS" --write-env-fields
run_step "write-blocker-manifest" env NEXT_ACTIONS_ENV_FILE="$FIXTURE_ENV_FILE" sh "$READINESS" --write-blocker-manifest
run_step "write-env-hints" sh "$READINESS" --write-env-hints
run_step "write-runbook" sh "$READINESS" --write-runbook
run_step "write-next-actions" env NEXT_ACTIONS_ENV_FILE="$FIXTURE_ENV_FILE" sh "$READINESS" --write-next-actions
run_step "write-missing-by-category" sh "$0" --refresh-status
run_step "write-status-json" sh "$0" --write-status-json
run_step "write-policy-json" sh "$0" --write-policy-json
run_step "write-required-env-missing" sh "$0" --write-required-env-missing
run_step "write-required-env-hints" sh "$0" --write-required-env-hints
run_step "write-required-blockers" sh "$0" --write-required-blockers
run_step "write-completion-audit" sh "$0" --write-completion-audit
run_step "write-required-next-actions" sh "$0" --write-required-next-actions
run_step "readiness" sh "$READINESS"
run_step "nginx-live" sh "$NGINX_LIVE"
run_step "static-external" sh "$STATIC_EXTERNAL"
run_step "proxy-external" sh "$PROXY_EXTERNAL"
run_step "dynamic-route" sh "$DYNAMIC_ROUTE"
run_step "web-report" sh "$WEB_REPORT"
run_step "db-baselines" sh "$DB_BASELINES"
run_step "db-report" sh "$DB_REPORT"
run_step "artifact-consistency" sh "$RECOVERY" --check-current-artifacts

if [ "$ALLOW_PARTIAL" -eq 1 ]; then
    echo "STATUS: WARN gpu web/db external suite partial"
else
    echo "STATUS: PASS gpu web/db external suite"
fi
