import os

data = json.loads(os.environ["STATUS_JSON_OUTPUT"])
assert data["suite_steps"] == 31
assert data["missing_fixture_items"] == 0
assert data["required_missing_fixture_items"] == 0
assert data["optional_missing_fixture_items"] == 0
