#!/usr/bin/env sh
set -eu

READINESS="${READINESS:-scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs}"
WEB_REPORT="${WEB_REPORT:-scripts/check/check-web-server-nginx-compare-report.shs}"
NGINX_LIVE="${NGINX_LIVE:-scripts/check/check-web-server-nginx-live-compare.shs}"
STATIC_EXTERNAL="${STATIC_EXTERNAL:-scripts/check/check-web-server-static-external-live-compare.shs}"
PROXY_EXTERNAL="${PROXY_EXTERNAL:-scripts/check/check-web-server-proxy-external-live-compare.shs}"
DYNAMIC_ROUTE="${DYNAMIC_ROUTE:-scripts/check/check-web-server-dynamic-gpu-route-compare.shs}"
DB_BASELINES="${DB_BASELINES:-scripts/check/check-gpu-web-db-offload-external-db-baselines.shs}"
DB_REPORT="${DB_REPORT:-scripts/check/check-gpu-web-db-offload-benchmark-report.shs}"
RECOVERY="${RECOVERY:-scripts/check/check-gpu-web-db-offload-recovery-harness-self-tests.shs}"
REPORT="${REPORT:-doc/09_report/perf/gpu_web_db_offload_external_suite_2026-06-17.md}"
TABLE="${TABLE:-doc/10_metrics/perf/gpu_web_db_offload_external_suite.md}"
MISSING_BY_CATEGORY="${MISSING_BY_CATEGORY:-build/perf/gpu_web_db_offload/external-fixture-missing-by-category.env}"
MISSING_BY_CATEGORY_SOURCE="${MISSING_BY_CATEGORY_SOURCE:-build/perf/gpu_web_db_offload/external-fixture-missing-by-category-source.env}"
FIXTURE_ENV_FILE="${FIXTURE_ENV_FILE:-build/perf/gpu_web_db_offload/external-fixtures.env}"
STATUS_JSON_PATH="${STATUS_JSON_PATH:-build/perf/gpu_web_db_offload/external-suite-status.json}"
POLICY_JSON_PATH="${POLICY_JSON_PATH:-build/perf/gpu_web_db_offload/external-suite-readiness-policy.json}"
REQUIRED_ENV_MISSING_PATH="${REQUIRED_ENV_MISSING_PATH:-build/perf/gpu_web_db_offload/external-suite-required-env-missing.env}"
REQUIRED_ENV_HINTS_PATH="${REQUIRED_ENV_HINTS_PATH:-build/perf/gpu_web_db_offload/external-suite-required-env-hints.md}"
REQUIRED_BLOCKERS_PATH="${REQUIRED_BLOCKERS_PATH:-build/perf/gpu_web_db_offload/external-suite-required-blockers.tsv}"
COMPLETION_AUDIT_PATH="${COMPLETION_AUDIT_PATH:-build/perf/gpu_web_db_offload/external-suite-completion-audit.md}"
REQUIRED_NEXT_ACTIONS_PATH="${REQUIRED_NEXT_ACTIONS_PATH:-build/perf/gpu_web_db_offload/external-suite-required-next-actions.md}"

emit_plan() {
    cat <<EOF
external-suite-step=preflight|$0 --preflight
external-suite-step=write-env-template|$READINESS --write-env-template
external-suite-step=write-setup-checklist|$READINESS --write-setup-checklist
external-suite-step=bootstrap-status|$READINESS --bootstrap-status
external-suite-step=write-bootstrap-manifest|$READINESS --write-bootstrap-manifest
external-suite-step=write-docker-compose-template|$READINESS --write-docker-compose-template
external-suite-step=write-docker-run-template|$READINESS --write-docker-run-template
external-suite-step=write-proxy-config-templates|$READINESS --write-proxy-config-templates
external-suite-step=write-env-fields|$READINESS --write-env-fields
external-suite-step=write-blocker-manifest|NEXT_ACTIONS_ENV_FILE=$FIXTURE_ENV_FILE $READINESS --write-blocker-manifest
external-suite-step=write-env-hints|$READINESS --write-env-hints
external-suite-step=write-local-env-candidates|$READINESS --write-local-env-candidates
external-suite-step=write-runbook|$READINESS --write-runbook
external-suite-step=write-next-actions|NEXT_ACTIONS_ENV_FILE=$FIXTURE_ENV_FILE $READINESS --write-next-actions
external-suite-step=write-missing-by-category|$0 --refresh-status
external-suite-step=write-status-json|$0 --write-status-json
external-suite-step=write-policy-json|$0 --write-policy-json
external-suite-step=write-required-env-missing|$0 --write-required-env-missing
external-suite-step=write-required-env-hints|$0 --write-required-env-hints
external-suite-step=write-required-blockers|$0 --write-required-blockers
external-suite-step=write-completion-audit|$0 --write-completion-audit
external-suite-step=write-required-next-actions|$0 --write-required-next-actions
external-suite-step=readiness|$READINESS
external-suite-step=nginx-live|$NGINX_LIVE
external-suite-step=static-external|$STATIC_EXTERNAL
external-suite-step=proxy-external|$PROXY_EXTERNAL
external-suite-step=dynamic-route|$DYNAMIC_ROUTE
external-suite-step=web-report|$WEB_REPORT
external-suite-step=db-baselines|$DB_BASELINES
external-suite-step=db-report|$DB_REPORT
external-suite-step=artifact-consistency|$RECOVERY --check-current-artifacts
EOF
}

emit_handoff_artifacts() {
    cat <<'EOF'
fixture_env_file=build/perf/gpu_web_db_offload/external-fixtures.env
setup_checklist=build/perf/gpu_web_db_offload/external-fixture-setup-checklist.md
bootstrap_manifest=build/perf/gpu_web_db_offload/external-fixture-bootstrap-manifest.tsv
docker_compose_template=build/perf/gpu_web_db_offload/external-fixture-compose.yaml
docker_run_template=build/perf/gpu_web_db_offload/external-fixture-docker-run.shs
env_fields=build/perf/gpu_web_db_offload/external-fixture-env-fields.tsv
blocker_manifest=build/perf/gpu_web_db_offload/external-fixture-blockers.tsv
env_hints=build/perf/gpu_web_db_offload/external-fixture-env-hints.md
local_env_candidates=build/perf/gpu_web_db_offload/external-fixture-local-env-candidates.env
runbook=build/perf/gpu_web_db_offload/external-fixture-runbook.md
next_actions=build/perf/gpu_web_db_offload/external-fixture-next-actions.md
missing_by_category=build/perf/gpu_web_db_offload/external-fixture-missing-by-category.env
missing_by_category_source=build/perf/gpu_web_db_offload/external-fixture-missing-by-category-source.env
status_json=build/perf/gpu_web_db_offload/external-suite-status.json
policy_json=build/perf/gpu_web_db_offload/external-suite-readiness-policy.json
required_env_missing=build/perf/gpu_web_db_offload/external-suite-required-env-missing.env
required_env_hints=build/perf/gpu_web_db_offload/external-suite-required-env-hints.md
required_blockers=build/perf/gpu_web_db_offload/external-suite-required-blockers.tsv
completion_audit=build/perf/gpu_web_db_offload/external-suite-completion-audit.md
required_next_actions=build/perf/gpu_web_db_offload/external-suite-required-next-actions.md
EOF
}

if [ "${1:-}" = "--dry-run" ]; then
    emit_plan
    echo "STATUS: PASS gpu web/db external suite dry run"
    exit 0
fi

emit_status() {
    plan="$(emit_plan)"
    missing="missing-by-category-unavailable"
    if [ -f "$MISSING_BY_CATEGORY" ]; then
        missing="$(cat "$MISSING_BY_CATEGORY")"
    fi
    missing_source="missing-data-source-unavailable"
    if [ -f "$MISSING_BY_CATEGORY_SOURCE" ]; then
        missing_source="$(sed -n 's/^missing_data_source=//p' "$MISSING_BY_CATEGORY_SOURCE" | tail -n 1)"
    fi
    export EXTERNAL_SUITE_PLAN="$plan"
    export EXTERNAL_SUITE_MISSING="$missing"
    export EXTERNAL_SUITE_MISSING_SOURCE="$missing_source"
    export EXTERNAL_SUITE_HANDOFF_ARTIFACTS="$(emit_handoff_artifacts)"
    python3 - <<'PY'
import os

steps = [
    line for line in os.environ["EXTERNAL_SUITE_PLAN"].splitlines()
    if line.startswith("external-suite-step=") and "|" in line
]
missing_items = []
missing_categories = []
for line in os.environ["EXTERNAL_SUITE_MISSING"].splitlines():
    if "=" not in line:
        continue
    category, items = line.split("=", 1)
    missing_categories.append((category, items))
    if items:
        missing_items.extend(item for item in items.split(",") if item)
missing_count = len(missing_items)
optional_categories = {"reference_fixture_urls"}
required_items = []
optional_items = []
for category, items in missing_categories:
    values = [item for item in items.split(",") if item]
    if category in optional_categories:
        optional_items.extend(values)
    else:
        required_items.extend(values)
verdict = "READY" if missing_count == 0 else "WAITING_ON_FIXTURES"
print(f"external-suite-status=suite_steps|{len(steps)}")
print(f"external-suite-status=missing_fixture_items|{missing_count}")
print(f"external-suite-status=required_missing_fixture_items|{len(required_items)}")
print(f"external-suite-status=optional_missing_fixture_items|{len(optional_items)}")
print(f"external-suite-status=verdict|{verdict}")
print(f"external-suite-status=required_verdict|{'READY' if len(required_items) == 0 else 'WAITING_ON_REQUIRED_FIXTURES'}")
print(f"external-suite-status=missing_data_source|{os.environ['EXTERNAL_SUITE_MISSING_SOURCE']}")
print("external-suite-status=strict_readiness_command|scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready")
for category, items in missing_categories:
    print(f"external-suite-missing={category}|{items}")
handoff_rows = []
for line in os.environ["EXTERNAL_SUITE_HANDOFF_ARTIFACTS"].splitlines():
    if "=" not in line:
        continue
    handoff_rows.append(line.split("=", 1))
for name, path in handoff_rows:
    print(f"external-suite-handoff={name}|{path}")
PY
}

emit_status_json() {
    plan="$(emit_plan)"
    missing="missing-by-category-unavailable"
    if [ -f "$MISSING_BY_CATEGORY" ]; then
        missing="$(cat "$MISSING_BY_CATEGORY")"
    fi
    missing_source="missing-data-source-unavailable"
    if [ -f "$MISSING_BY_CATEGORY_SOURCE" ]; then
        missing_source="$(sed -n 's/^missing_data_source=//p' "$MISSING_BY_CATEGORY_SOURCE" | tail -n 1)"
    fi
    export EXTERNAL_SUITE_PLAN="$plan"
    export EXTERNAL_SUITE_MISSING="$missing"
    export EXTERNAL_SUITE_MISSING_SOURCE="$missing_source"
    export EXTERNAL_SUITE_HANDOFF_ARTIFACTS="$(emit_handoff_artifacts)"
    python3 - <<'PY'
import json
import os

steps = []
for line in os.environ["EXTERNAL_SUITE_PLAN"].splitlines():
    if not line.startswith("external-suite-step=") or "|" not in line:
        continue
    name, command = line.split("=", 1)[1].split("|", 1)
    steps.append({"name": name, "command": command})

missing = {}
missing_items = []
optional_categories = {"reference_fixture_urls"}
required_missing = {}
optional_missing = {}
for line in os.environ["EXTERNAL_SUITE_MISSING"].splitlines():
    if "=" not in line:
        continue
    category, items = line.split("=", 1)
    values = [item for item in items.split(",") if item]
    missing[category] = values
    missing_items.extend(values)
    if category in optional_categories:
        optional_missing[category] = values
    else:
        required_missing[category] = values

handoff = {}
for line in os.environ["EXTERNAL_SUITE_HANDOFF_ARTIFACTS"].splitlines():
    if "=" not in line:
        continue
    name, path = line.split("=", 1)
    handoff[name] = path

missing_count = len(missing_items)
required_missing_items = [item for values in required_missing.values() for item in values]
optional_missing_items = [item for values in optional_missing.values() for item in values]
status = {
    "suite_steps": len(steps),
    "missing_fixture_items": missing_count,
    "required_missing_fixture_items": len(required_missing_items),
    "optional_missing_fixture_items": len(optional_missing_items),
    "verdict": "READY" if missing_count == 0 else "WAITING_ON_FIXTURES",
    "required_verdict": "READY" if len(required_missing_items) == 0 else "WAITING_ON_REQUIRED_FIXTURES",
    "missing_data_source": os.environ["EXTERNAL_SUITE_MISSING_SOURCE"],
    "strict_readiness_command": "scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready",
    "missing": missing,
    "required_missing": required_missing,
    "optional_missing": optional_missing,
    "optional_categories": sorted(optional_categories),
    "handoff": handoff,
    "steps": steps,
}
print(json.dumps(status, sort_keys=True, separators=(",", ":")))
PY
}

emit_policy_json() {
    emit_status_json | python3 -c 'import json,sys; data=json.load(sys.stdin); print(json.dumps({"policy":"strict-suite-requires-all-fixtures","required_categories":sorted(data["required_missing"].keys()),"optional_categories":data["optional_categories"],"required_missing_fixture_items":data["required_missing_fixture_items"],"optional_missing_fixture_items":data["optional_missing_fixture_items"],"required_missing":data["required_missing"],"optional_missing":data["optional_missing"],"strict_readiness_command":data["strict_readiness_command"],"required_verdict":data["required_verdict"],"verdict":data["verdict"]}, sort_keys=True, separators=(",", ":")))'
}

write_status_json() {
    path="${1:-$STATUS_JSON_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_status_json > "$path"
    printf '%s\n' "$path"
}

write_policy_json() {
    path="${1:-$POLICY_JSON_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_policy_json > "$path"
    printf '%s\n' "$path"
}

write_required_artifact() {
    kind="$1"
    path="$2"
    mkdir -p "$(dirname "$path")"
    status_json="$(emit_status_json)"
    STATUS_JSON_INPUT="$status_json" ARTIFACT_KIND="$kind" python3 - "$path" <<'PY'
import json
import os
import sys

path = sys.argv[1]
kind = os.environ["ARTIFACT_KIND"]
data = json.loads(os.environ["STATUS_JSON_INPUT"])

env_by_item = {
    "simple_cached_proxy_url": "SIMPLE_CACHED_PROXY_URL",
    "haproxy_cached_proxy_url": "HAPROXY_CACHED_PROXY_URL",
    "envoy_cached_proxy_url": "ENVOY_CACHED_PROXY_URL",
    "simple_upload_proxy_url": "SIMPLE_UPLOAD_PROXY_URL",
    "haproxy_upload_proxy_url": "HAPROXY_UPLOAD_PROXY_URL",
    "simple_tunnel_proxy_url": "SIMPLE_TUNNEL_PROXY_URL",
    "haproxy_tunnel_proxy_url": "HAPROXY_TUNNEL_PROXY_URL",
    "dynamic_gpu_plaintext_url": "DYNAMIC_GPU_PLAINTEXT_URL",
    "dynamic_cpu_plaintext_url": "DYNAMIC_CPU_PLAINTEXT_URL",
    "dynamic_gpu_json_url": "DYNAMIC_GPU_JSON_URL",
    "dynamic_cpu_json_url": "DYNAMIC_CPU_JSON_URL",
    "clickhouse_url": "CLICKHOUSE_URL",
    "postgres_url": "POSTGRES_URL",
    "mongo_url": "MONGO_URL",
    "redis_url": "REDIS_URL",
}

action_by_category = {
    "core_load_tools": "Install wrk and nginx before measuring required web rows.",
    "web_proxy_tools": "Install or start Caddy, H2O, HAProxy, and Envoy baseline tools.",
    "db_tools": "Install ClickHouse, DuckDB, PostgreSQL psql/pgbench, Mongo shell tooling, Redis/Valkey CLI tooling, and redis-benchmark.",
    "proxy_fixture_urls": "Start Simple, HAProxy, and Envoy proxy fixtures and fill their URLs.",
    "dynamic_route_urls": "Start paired CPU/GPU plaintext and JSON route fixtures and fill their URLs.",
    "db_service_urls": "Start or point to ClickHouse, PostgreSQL, MongoDB, and Redis/Valkey services.",
}

required = data["required_missing"]
required_items = [(category, item) for category, values in required.items() for item in values]

if kind == "env_missing":
    lines = [
        f"required_missing_fixture_items={data['required_missing_fixture_items']}",
        f"required_verdict={data['required_verdict']}",
        f"missing_data_source={data['missing_data_source']}",
    ]
    for category, values in sorted(required.items()):
        lines.append(f"required_{category}={','.join(values)}")
    env_names = [env_by_item[item] for _, item in required_items if item in env_by_item]
    lines.append(f"required_env_vars={','.join(env_names)}")
    text = "\n".join(lines) + "\n"
elif kind == "env_hints":
    rows = [
        "| missing item | env variable | hint |",
        "|---|---|---|",
    ]
    for category, item in required_items:
        env = env_by_item.get(item, "")
        hint = "Set this in external-fixtures.env." if env else action_by_category.get(category, "Resolve this required blocker.")
        rows.append(f"| {item} | `{env}` | {hint} |")
    if not required_items:
        rows.append("| ready |  | Required fixtures are ready. |")
    text = (
        "# GPU Web/DB Required Fixture Env Hints\n\n"
        f"- Required verdict: `{data['required_verdict']}`\n"
        f"- Required missing fixture items: `{data['required_missing_fixture_items']}`\n"
        f"- Missing data source: `{data['missing_data_source']}`\n\n"
        + "\n".join(rows)
        + "\n"
    )
elif kind == "blockers":
    rows = ["category\titem\tenv_variable\tnext_action"]
    for category, item in required_items:
        rows.append(f"{category}\t{item}\t{env_by_item.get(item, '')}\t{action_by_category.get(category, 'Resolve this required blocker.')}")
    text = "\n".join(rows) + "\n"
elif kind == "completion_audit":
    done = data["required_missing_fixture_items"] == 0 and data["optional_missing_fixture_items"] == 0
    required_done = data["required_missing_fixture_items"] == 0
    rows = [
        "| check | evidence | result |",
        "|---|---|---|",
        f"| Required fixtures | `{data['required_missing_fixture_items']}` missing | {'PASS' if required_done else 'FAIL'} |",
        f"| Optional reference fixtures | `{data['optional_missing_fixture_items']}` missing | {'PASS' if data['optional_missing_fixture_items'] == 0 else 'WARN'} |",
        f"| Strict suite readiness | `{data['verdict']}` | {'PASS' if done else 'FAIL'} |",
        "| Measured external rows | Reports must contain reproducible web/proxy and DB rows | BLOCKED until fixtures are ready |",
    ]
    text = (
        "# GPU Web/DB External Suite Completion Audit\n\n"
        f"- Verdict: `{data['verdict']}`\n"
        f"- Required verdict: `{data['required_verdict']}`\n"
        f"- Strict readiness command: `{data['strict_readiness_command']}`\n"
        "- Required readiness command: `scripts/check/check-gpu-web-db-offload-external-suite.shs --require-required-ready`\n\n"
        + "\n".join(rows)
        + "\n"
    )
elif kind == "next_actions":
    rows = ["| category | required missing items | next action |", "|---|---|---|"]
    for category, values in sorted(required.items()):
        rows.append(f"| {category} | {', '.join(values) if values else 'ready'} | {action_by_category.get(category, 'Resolve this required blocker.')} |")
    text = (
        "# GPU Web/DB Required Fixture Next Actions\n\n"
        f"- Required missing fixture items: `{data['required_missing_fixture_items']}`\n"
        f"- Required verdict: `{data['required_verdict']}`\n"
        "- Required readiness command: `scripts/check/check-gpu-web-db-offload-external-suite.shs --require-required-ready`\n"
        "- Strict readiness command: `scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready`\n\n"
        + "\n".join(rows)
        + "\n\n## Refresh Commands\n\n"
        "```sh\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-env-missing\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-env-hints\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-blockers\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --write-completion-audit\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-next-actions\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --preflight\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --require-required-ready\n"
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready\n"
        "```\n"
    )
else:
    raise SystemExit(f"unknown artifact kind: {kind}")

with open(path, "w", encoding="utf-8") as handle:
    handle.write(text)
PY
    printf '%s\n' "$path"
}

if [ "${1:-}" = "--status" ]; then
    emit_status
    echo "STATUS: PASS gpu web/db external suite status"
    exit 0
fi

if [ "${1:-}" = "--status-json" ]; then
    emit_status_json
    exit 0
fi

if [ "${1:-}" = "--write-status-json" ]; then
    write_status_json "${2:-$STATUS_JSON_PATH}"
    exit 0
fi

if [ "${1:-}" = "--policy-json" ]; then
    emit_policy_json
    exit 0
fi

if [ "${1:-}" = "--write-policy-json" ]; then
    write_policy_json "${2:-$POLICY_JSON_PATH}"
    exit 0
fi

if [ "${1:-}" = "--write-required-env-missing" ]; then
    write_required_artifact env_missing "${2:-$REQUIRED_ENV_MISSING_PATH}"
    exit 0
fi

if [ "${1:-}" = "--write-required-env-hints" ]; then
    write_required_artifact env_hints "${2:-$REQUIRED_ENV_HINTS_PATH}"
    exit 0
fi

if [ "${1:-}" = "--write-required-blockers" ]; then
    write_required_artifact blockers "${2:-$REQUIRED_BLOCKERS_PATH}"
    exit 0
fi

if [ "${1:-}" = "--write-completion-audit" ]; then
    write_required_artifact completion_audit "${2:-$COMPLETION_AUDIT_PATH}"
    exit 0
fi

if [ "${1:-}" = "--write-required-next-actions" ]; then
    write_required_artifact next_actions "${2:-$REQUIRED_NEXT_ACTIONS_PATH}"
    exit 0
fi

missing_source_label() {
    if [ -f "$FIXTURE_ENV_FILE" ]; then
        printf 'fixture-env-file:%s\n' "$FIXTURE_ENV_FILE"
    else
        printf 'ambient-environment\n'
    fi
}

refresh_missing_by_category() {
    if [ -f "$FIXTURE_ENV_FILE" ]; then
        sh "$READINESS" --write-missing-by-category-from-env-file "$MISSING_BY_CATEGORY" "$FIXTURE_ENV_FILE" >/dev/null
    else
        sh "$READINESS" --write-missing-by-category "$MISSING_BY_CATEGORY" >/dev/null
    fi
    mkdir -p "$(dirname "$MISSING_BY_CATEGORY_SOURCE")"
    printf 'missing_data_source=%s\n' "$(missing_source_label)" > "$MISSING_BY_CATEGORY_SOURCE"
}

if [ "${1:-}" = "--refresh-status" ]; then
    refresh_missing_by_category
    emit_status
    echo "STATUS: PASS gpu web/db external suite refresh status"
    exit 0
fi

emit_preflight() {
    if [ "${EXTERNAL_SUITE_SKIP_REFRESH:-0}" != "1" ]; then
        refresh_missing_by_category
    fi
    status="$(emit_status)"
    printf '%s\n' "$status"
    missing_count="$(printf '%s\n' "$status" | awk -F'|' '/^external-suite-status=missing_fixture_items/ { print $2 }')"
    if [ "${missing_count:-0}" = "0" ]; then
        echo "STATUS: PASS gpu web/db external suite preflight ready"
    else
        echo "STATUS: WARN gpu web/db external suite preflight missing:$missing_count"
    fi
}

if [ "${1:-}" = "--preflight" ]; then
    emit_preflight
    exit 0
fi

if [ "${1:-}" = "--require-ready" ]; then
    output="$(emit_preflight)"
    printf '%s\n' "$output"
    missing_count="$(printf '%s\n' "$output" | awk -F'|' '/^external-suite-status=missing_fixture_items/ { print $2 }')"
    if [ "${missing_count:-0}" = "0" ]; then
        echo "STATUS: PASS gpu web/db external suite require-ready"
        exit 0
    fi
    echo "STATUS: FAIL gpu web/db external suite require-ready missing:$missing_count"
    exit 1
fi

if [ "${1:-}" = "--require-required-ready" ]; then
    output="$(emit_preflight)"
    printf '%s\n' "$output"
    missing_count="$(printf '%s\n' "$output" | awk -F'|' '/^external-suite-status=required_missing_fixture_items/ { print $2 }')"
    if [ "${missing_count:-0}" = "0" ]; then
        echo "STATUS: PASS gpu web/db external suite require-required-ready"
        exit 0
    fi
    echo "STATUS: FAIL gpu web/db external suite require-required-ready missing:$missing_count"
    exit 1
fi

write_plan_artifacts() {
    mkdir -p "$(dirname "$REPORT")" "$(dirname "$TABLE")"
    if [ "${EXTERNAL_SUITE_SKIP_REFRESH:-0}" != "1" ]; then
        refresh_missing_by_category
    fi
    missing_source="$(missing_source_label)"
    plan="$(emit_plan)"
    missing="missing-by-category-unavailable"
    if [ -f "$MISSING_BY_CATEGORY" ]; then
        missing="$(cat "$MISSING_BY_CATEGORY")"
    fi
    bootstrap_status="$(sh "$READINESS" --bootstrap-status)"
    export EXTERNAL_SUITE_PLAN="$plan"
    export EXTERNAL_SUITE_MISSING="$missing"
    export EXTERNAL_SUITE_BOOTSTRAP_STATUS="$bootstrap_status"
    export EXTERNAL_SUITE_HANDOFF_ARTIFACTS="$(emit_handoff_artifacts)"
    export EXTERNAL_SUITE_MISSING_SOURCE="$missing_source"
    export EXTERNAL_SUITE_STRICT_READINESS_COMMAND="$0 --require-ready"
    export REPORT TABLE
    python3 - <<'PY'
import os
from pathlib import Path

plan_rows = []
for line in os.environ["EXTERNAL_SUITE_PLAN"].splitlines():
    if not line.startswith("external-suite-step=") or "|" not in line:
        continue
    step, command = line.split("=", 1)[1].split("|", 1)
    plan_rows.append((step, command))

missing_rows = []
for line in os.environ["EXTERNAL_SUITE_MISSING"].splitlines():
    if "=" not in line:
        continue
    category, items = line.split("=", 1)
    missing_rows.append((category, items or ""))

bootstrap_rows = []
for line in os.environ["EXTERNAL_SUITE_BOOTSTRAP_STATUS"].splitlines():
    if "=" not in line or "|" not in line:
        continue
    key, rest = line.split("=", 1)
    status, reason = rest.split("|", 1)
    bootstrap_rows.append((key, status, reason))

missing_item_count = 0
for _, items in missing_rows:
    if items:
        missing_item_count += len([item for item in items.split(",") if item])
verdict = "READY" if missing_item_count == 0 else "WAITING_ON_FIXTURES"
step_header = "| step | command |\n"
step_sep = "|---|---|\n"
step_body = "".join(f"| {step} | `{command}` |\n" for step, command in plan_rows)
missing_header = "| category | missing_items |\n"
missing_sep = "|---|---|\n"
missing_body = "".join(f"| {category} | {items} |\n" for category, items in missing_rows)
bootstrap_header = "| bootstrap check | status | reason |\n"
bootstrap_sep = "|---|---|---|\n"
bootstrap_body = "".join(
    f"| {key} | {status} | {reason} |\n" for key, status, reason in bootstrap_rows
)
handoff_header = "| artifact | path |\n"
handoff_sep = "|---|---|\n"
handoff_rows = []
for line in os.environ["EXTERNAL_SUITE_HANDOFF_ARTIFACTS"].splitlines():
    if "=" not in line:
        continue
    handoff_rows.append(line.split("=", 1))
handoff_body = "".join(f"| {name} | `{path}` |\n" for name, path in handoff_rows)
summary = (
    "## Summary\n\n"
    f"- Suite steps: `{len(plan_rows)}`\n"
    f"- Missing fixture items: `{missing_item_count}`\n"
    f"- Verdict: `{verdict}`\n\n"
    f"- Missing data source: `{os.environ['EXTERNAL_SUITE_MISSING_SOURCE']}`\n\n"
    f"- Strict readiness command: `{os.environ['EXTERNAL_SUITE_STRICT_READINESS_COMMAND']}`\n\n"
)

report = (
    "# GPU Web/DB External Suite Plan\n\n"
    "This report is generated by `scripts/check/check-gpu-web-db-offload-external-suite.shs --write-plan-artifacts`.\n"
    "It records the ordered external-fixture suite and the current missing fixture categories. "
    "It does not run live benchmark producers.\n\n"
    + summary
    + "## Handoff Artifacts\n\n"
    + handoff_header + handoff_sep + handoff_body
    + "\n## Suite Steps\n\n"
    + step_header + step_sep + step_body
    + "\n## Bootstrap Status\n\n"
    + bootstrap_header + bootstrap_sep + bootstrap_body
    + "\n## Missing By Category\n\n"
    + missing_header + missing_sep + missing_body
)
metrics = (
    "# GPU Web/DB External Suite Metrics\n\n"
    "| metric | value |\n"
    "|---|---:|\n"
    f"| suite_steps | {len(plan_rows)} |\n"
    f"| missing_fixture_items | {missing_item_count} |\n"
    f"| missing_data_source | {os.environ['EXTERNAL_SUITE_MISSING_SOURCE']} |\n"
    f"| strict_readiness_command | {os.environ['EXTERNAL_SUITE_STRICT_READINESS_COMMAND']} |\n"
    + "\n## Handoff Artifacts\n\n"
    + handoff_header + handoff_sep + handoff_body
    + "\n## Bootstrap Status\n\n"
    + bootstrap_header + bootstrap_sep + bootstrap_body
    + "\n## Steps\n\n"
    + step_header + step_sep + step_body
)
Path(os.environ["REPORT"]).write_text(report, encoding="utf-8")
Path(os.environ["TABLE"]).write_text(metrics, encoding="utf-8")
PY
    printf '%s\n' "$REPORT"
    printf '%s\n' "$TABLE"
}

if [ "${1:-}" = "--write-plan-artifacts" ]; then
    write_plan_artifacts
    echo "STATUS: PASS gpu web/db external suite plan artifacts"
    exit 0
fi

if [ "${1:-}" = "--self-test-plan" ]; then
    plan="$(emit_plan)"
    printf '%s\n' "$plan" | grep -q '^external-suite-step=preflight|scripts/check/check-gpu-web-db-offload-external-suite.shs --preflight$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-env-template|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-template$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=bootstrap-status|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --bootstrap-status$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-bootstrap-manifest|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-bootstrap-manifest$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-docker-compose-template|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-docker-compose-template$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-docker-run-template|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-docker-run-template$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-proxy-config-templates|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-proxy-config-templates$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-env-fields|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-fields$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-blocker-manifest|NEXT_ACTIONS_ENV_FILE=build/perf/gpu_web_db_offload/external-fixtures.env scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-blocker-manifest$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-env-hints|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-hints$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-local-env-candidates|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-local-env-candidates$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-runbook|scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-runbook$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-next-actions|NEXT_ACTIONS_ENV_FILE=build/perf/gpu_web_db_offload/external-fixtures.env scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-next-actions$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-missing-by-category|scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-status-json|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-status-json$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-policy-json|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-policy-json$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-required-env-missing|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-env-missing$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-required-env-hints|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-env-hints$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-required-blockers|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-blockers$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-completion-audit|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-completion-audit$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=write-required-next-actions|scripts/check/check-gpu-web-db-offload-external-suite.shs --write-required-next-actions$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=nginx-live|scripts/check/check-web-server-nginx-live-compare.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=static-external|scripts/check/check-web-server-static-external-live-compare.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=proxy-external|scripts/check/check-web-server-proxy-external-live-compare.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=dynamic-route|scripts/check/check-web-server-dynamic-gpu-route-compare.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=web-report|scripts/check/check-web-server-nginx-compare-report.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=db-baselines|scripts/check/check-gpu-web-db-offload-external-db-baselines.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=db-report|scripts/check/check-gpu-web-db-offload-benchmark-report.shs$'
    printf '%s\n' "$plan" | grep -q '^external-suite-step=artifact-consistency|scripts/check/check-gpu-web-db-offload-recovery-harness-self-tests.shs --check-current-artifacts$'
    echo "STATUS: PASS gpu web/db external suite plan self-test"
    exit 0
fi

