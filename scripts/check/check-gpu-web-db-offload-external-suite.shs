fi

if [ "${1:-}" = "--self-test-refresh-status" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    missing="$tmpdir/missing.env"
    source_file="$tmpdir/source.env"
    output="$(MISSING_BY_CATEGORY="$missing" MISSING_BY_CATEGORY_SOURCE="$source_file" FIXTURE_ENV_FILE="$tmpdir/absent.env" sh "$0" --refresh-status)"
    test -f "$missing"
    test -f "$source_file"
    grep -q '^missing_data_source=ambient-environment$' "$source_file"
    printf '%s\n' "$output" | grep -q '^external-suite-status=suite_steps|31$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_fixture_items|'
    printf '%s\n' "$output" | grep -q '^external-suite-status=verdict|'
    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_data_source|ambient-environment$'
    printf '%s\n' "$output" | grep -q '^external-suite-missing=web_proxy_tools|'
    printf '%s\n' "$output" | grep -q '^STATUS: PASS gpu web/db external suite refresh status$'
    echo "STATUS: PASS gpu web/db external suite refresh status self-test"
    exit 0
fi

