db_service_urls=postgres_url,mongo_url
EOF
    output="$(MISSING_BY_CATEGORY="$missing" MISSING_BY_CATEGORY_SOURCE="$missing_source" emit_status)"
    printf '%s\n' "$output" | grep -q '^external-suite-status=suite_steps|31$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_fixture_items|6$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=required_missing_fixture_items|6$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=optional_missing_fixture_items|0$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=required_verdict|WAITING_ON_REQUIRED_FIXTURES$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=verdict|WAITING_ON_FIXTURES$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_data_source|missing-data-source-unavailable$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=strict_readiness_command|scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready$'
    printf '%s\n' "$output" | grep -q '^external-suite-missing=web_proxy_tools|caddy,h2o$'
    printf '%s\n' "$output" | grep -q '^external-suite-missing=db_service_urls|postgres_url,mongo_url$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=next_actions|build/perf/gpu_web_db_offload/external-fixture-next-actions.md$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=env_fields|build/perf/gpu_web_db_offload/external-fixture-env-fields.tsv$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=blocker_manifest|build/perf/gpu_web_db_offload/external-fixture-blockers.tsv$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=local_env_candidates|build/perf/gpu_web_db_offload/external-fixture-local-env-candidates.env$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=status_json|build/perf/gpu_web_db_offload/external-suite-status.json$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=policy_json|build/perf/gpu_web_db_offload/external-suite-readiness-policy.json$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=required_env_missing|build/perf/gpu_web_db_offload/external-suite-required-env-missing.env$'
    printf '%s\n' "$output" | grep -q '^external-suite-handoff=required_env_hints|build/perf/gpu_web_db_offload/external-suite-required-env-hints.md$'
