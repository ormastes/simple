assert data["missing"]["db_service_urls"] == ["postgres_url", "mongo_url"]
assert data["handoff"]["blocker_manifest"] == "build/perf/gpu_web_db_offload/external-fixture-blockers.tsv"
assert data["handoff"]["local_env_candidates"] == "build/perf/gpu_web_db_offload/external-fixture-local-env-candidates.env"
assert data["handoff"]["status_json"] == "build/perf/gpu_web_db_offload/external-suite-status.json"
assert data["handoff"]["policy_json"] == "build/perf/gpu_web_db_offload/external-suite-readiness-policy.json"
assert data["handoff"]["next_actions"] == "build/perf/gpu_web_db_offload/external-fixture-next-actions.md"
assert data["handoff"]["required_env_missing"] == "build/perf/gpu_web_db_offload/external-suite-required-env-missing.env"
assert data["handoff"]["required_env_hints"] == "build/perf/gpu_web_db_offload/external-suite-required-env-hints.md"
assert data["handoff"]["required_blockers"] == "build/perf/gpu_web_db_offload/external-suite-required-blockers.tsv"
assert data["handoff"]["completion_audit"] == "build/perf/gpu_web_db_offload/external-suite-completion-audit.md"
assert data["handoff"]["required_next_actions"] == "build/perf/gpu_web_db_offload/external-suite-required-next-actions.md"
assert data["optional_categories"] == ["reference_fixture_urls"]
assert any(step["name"] == "write-blocker-manifest" for step in data["steps"])
assert any(step["name"] == "write-local-env-candidates" for step in data["steps"])
assert any(step["name"] == "write-required-next-actions" for step in data["steps"])
PY
    ready="$tmpdir/ready.env"
    cat > "$ready" <<'EOF'
core_load_tools=
web_proxy_tools=
db_tools=
proxy_fixture_urls=
dynamic_route_urls=
db_service_urls=
EOF
    ready_output="$(MISSING_BY_CATEGORY="$ready" MISSING_BY_CATEGORY_SOURCE="$missing_source" emit_status_json)"
    STATUS_JSON_OUTPUT="$ready_output" python3 - <<'PY'
