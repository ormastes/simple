    printf '%s\n' "$output" | grep -q '^external-suite-missing=db_service_urls|$'
    grep -q '^proxy_fixture_urls=$' "$missing"
    grep -q '^dynamic_route_urls=$' "$missing"
    grep -q '^reference_fixture_urls=$' "$missing"
    grep -q '^db_service_urls=$' "$missing"
    echo "STATUS: PASS gpu web/db external suite refresh status env-file self-test"
    exit 0
