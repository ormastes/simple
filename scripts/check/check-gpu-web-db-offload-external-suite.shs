    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_fixture_items|1$'
    printf '%s\n' "$output" | grep -q '^external-suite-status=missing_data_source|missing-data-source-unavailable$'
    printf '%s\n' "$output" | grep -q '^STATUS: WARN gpu web/db external suite preflight missing:1$'
