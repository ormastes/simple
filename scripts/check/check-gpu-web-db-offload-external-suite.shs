proxy_fixture_urls=simple_cached_proxy_url
dynamic_route_urls=
db_service_urls=postgres_url,mongo_url
EOF
    output="$(MISSING_BY_CATEGORY="$missing" MISSING_BY_CATEGORY_SOURCE="$missing_source" emit_status_json)"
    STATUS_JSON_OUTPUT="$output" python3 - <<'PY'
import json
import os
import sys

data = json.loads(os.environ["STATUS_JSON_OUTPUT"])
assert data["suite_steps"] == 31
assert data["missing_fixture_items"] == 6
assert data["required_missing_fixture_items"] == 6
assert data["optional_missing_fixture_items"] == 0
assert data["verdict"] == "WAITING_ON_FIXTURES"
assert data["required_verdict"] == "WAITING_ON_REQUIRED_FIXTURES"
assert data["missing_data_source"] == "missing-data-source-unavailable"
