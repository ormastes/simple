#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/portable_compute_toolchains}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/portable_compute_toolchains_$(date -u +%F).md}"
SIMPLE_BIN="${SIMPLE_BIN:-bin/simple}"
if [ "$SIMPLE_BIN" = "bin/simple" ] && [ ! -e "$SIMPLE_BIN" ] && [ -e "bin/release/simple" ]; then
    SIMPLE_BIN="bin/release/simple"
fi
SIMPLE_RUNTIME_BIN="${SIMPLE_RUNTIME_BIN:-}"
PORTABLE_COMPUTE_EMITTER_BIN="${PORTABLE_COMPUTE_EMITTER_BIN:-}"
NVCC_TOOL="${NVCC_TOOL:-nvcc}"
HIPCC_TOOL="${HIPCC_TOOL:-hipcc}"
OPENCL_SPIRV_TOOL="${OPENCL_SPIRV_TOOL:-opencl-c-to-spirv}"
METAL_TOOL="${METAL_TOOL:-metal}"
METALLIB_TOOL="${METALLIB_TOOL:-metallib}"
VULKAN_GLSL_TOOL="${VULKAN_GLSL_TOOL:-glslangValidator}"
VULKAN_GLSLC_TOOL="${VULKAN_GLSLC_TOOL:-glslc}"
VULKAN_GLSLC_LIBRARY_PATH="${VULKAN_GLSLC_LIBRARY_PATH:-}"
SPIRV_VAL_TOOL="${SPIRV_VAL_TOOL:-spirv-val}"
CUDA_ARCH="${CUDA_ARCH:-}"
HIP_ARCH="${HIP_ARCH:-gfx1100}"
PORTABLE_COMPUTE_TARGETS="${PORTABLE_COMPUTE_TARGETS:-cuda,hip,opencl,metal,vulkan}"
PORTABLE_COMPUTE_EXPECTED_SEMANTICS="${PORTABLE_COMPUTE_EXPECTED_SEMANTICS:-2}"
PORTABLE_COMPUTE_REQUIRE_VERIFIED="${PORTABLE_COMPUTE_REQUIRE_VERIFIED:-0}"
TIMEOUT_SECS="${PORTABLE_COMPUTE_TOOLCHAIN_TIMEOUT_SECS:-180}"
KILL_SECS="${PORTABLE_COMPUTE_TOOLCHAIN_TIMEOUT_KILL_SECS:-10}"
PINNED_VULKAN_FONT_SOURCE_SHA256="c94b13736bdf7022835c008c09d714507da4cd0b6ef4607a5eadc9a23549cd2c"
PINNED_VULKAN_FONT_ARTIFACT_SHA256="e25d25b8157fc2554822637603471a442f678eb58e20da167bfb023d7577880a"
PINNED_CUDA_FONT_SOURCE_SHA256="bf34912f7e1bad76e9178d5ac39640a60f1075d7b017708688aa8efa2dad8291"
PINNED_CUDA_FONT_VERSION_SHA256="e1f58dd9ee7237bc5cc556dda8563f596ccc2e1a1f61ffdd824b90d90ccec68a"
PINNED_CUDA_FONT_ARTIFACT_SHA256="40afab945e6c40c239a6859d63723e76599758ea50e120e0edf7a058aa6922b4"

portable_compute_tuple_verified() {
    [ "$1" = true ] && [ "$2" = true ]
}

portable_compute_strict_result() {
    [ "$1" != 1 ] || portable_compute_tuple_verified "$2" "$3"
}

if [ "${1:-}" = "--strict-result-self-test" ]; then
    portable_compute_strict_result 0 false false
    portable_compute_strict_result 1 true true
    if portable_compute_strict_result 1 false true ||
       portable_compute_strict_result 1 true false ||
       portable_compute_strict_result 1 false false; then
        echo "portable compute strict-result self-test failed" >&2
        exit 1
    fi
    echo "portable compute strict-result self-test passed"
    exit 0
fi

case "$PORTABLE_COMPUTE_REQUIRE_VERIFIED" in
    0|1) ;;
    *)
        echo "PORTABLE_COMPUTE_REQUIRE_VERIFIED must be 0 or 1" >&2
        exit 2
        ;;
esac

case "$PORTABLE_COMPUTE_EXPECTED_SEMANTICS" in
    ''|*[!0-9]*)
        echo "PORTABLE_COMPUTE_EXPECTED_SEMANTICS must be a nonnegative integer" >&2
        exit 2
        ;;
esac

PORTABLE_COMPUTE_TARGETS="$(printf '%s' "$PORTABLE_COMPUTE_TARGETS" | tr -d '[:space:]')"
case "$PORTABLE_COMPUTE_TARGETS" in
    ''|,*|*,|*,,*)
        echo "PORTABLE_COMPUTE_TARGETS must be a nonempty comma-separated target list" >&2
        exit 2
        ;;
esac
for requested_target in $(printf '%s' "$PORTABLE_COMPUTE_TARGETS" | tr ',' ' '); do
    case "$requested_target" in
        cuda|hip|opencl|metal|vulkan) ;;
        *)
            echo "unsupported PORTABLE_COMPUTE_TARGETS entry: $requested_target" >&2
            exit 2
            ;;
    esac
done

mkdir -p "$BUILD_DIR" "$(dirname "$REPORT_PATH")"

have() {
    command -v "$1" >/dev/null 2>&1
}

target_requested() {
    case ",$PORTABLE_COMPUTE_TARGETS," in
        *,"$1",*) return 0 ;;
        *) return 1 ;;
    esac
}

sha256_file() {
    if have sha256sum; then
        sha256sum "$1" | awk '{ print $1 }'
    elif have shasum; then
        shasum -a 256 "$1" | awk '{ print $1 }'
    else
        return 1
    fi
}

sha256_valid() {
    printf '%s\n' "$1" | grep -Eq '^[0-9a-f]{64}$'
}

one_line() {
    tr '\r\n=' '   ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

tool_path() {
    found="$(command -v "$1" 2>/dev/null)" || return 1
    case "$found" in
        /*) printf '%s\n' "$found" ;;
        ./*) printf '%s/%s\n' "$ROOT_DIR" "${found#./}" ;;
        *) printf '%s/%s\n' "$ROOT_DIR" "$found" ;;
    esac
}

resolve_symlink_path() {
    current="$1"
    [ "$current" != "" ] || return 1
    depth=0
    while [ -L "$current" ]; do
        depth=$((depth + 1))
        if [ "$depth" -gt 40 ]; then
            return 1
        fi
        link="$(readlink "$current")" || return 1
        case "$link" in
            /*) current="$link" ;;
            *) current="$(dirname "$current")/$link" ;;
        esac
    done
    [ -e "$current" ] || return 1
    directory="$(CDPATH= cd -- "$(dirname -- "$current")" && pwd -P)" || return 1
    printf '%s/%s\n' "$directory" "$(basename -- "$current")"
}

native_executable_format() {
    [ -f "$1" ] || return 1
    magic="$(od -An -tx1 -N4 "$1" 2>/dev/null | tr -d ' \n')"
    case "$magic" in
        7f454c46) echo elf ;;
        feedface|cefaedfe|feedfacf|cffaedfe) echo mach-o ;;
        cafebabe|bebafeca|cafebabf|bfbafeca) echo mach-o-fat ;;
        *) return 1 ;;
    esac
}

canonical_wrapper_runtime() {
    wrapper="$1"
    wrapper_dir="$(dirname -- "$wrapper")"
    arch="$(uname -m)"
    case "$arch" in
        amd64) arch=x86_64 ;;
        arm64) arch=aarch64 ;;
    esac
    case "$(uname -s)" in
        Linux) triples="$arch-unknown-linux-gnu" ;;
        Darwin) triples="$arch-apple-darwin-macho $arch-apple-darwin" ;;
        FreeBSD) triples="$arch-unknown-freebsd" ;;
        *) triples="" ;;
    esac
    for triple in $triples; do
        for candidate in \
            "$wrapper_dir/$triple/simple" \
            "$ROOT_DIR/release/$triple/simple" \
            "$ROOT_DIR/bin/release/$triple/simple"; do
            if [ -x "$candidate" ] && native_executable_format "$candidate" >/dev/null 2>&1; then
                resolve_symlink_path "$candidate"
                return
            fi
        done
    done
    literal_candidates="$(awk '
        {
            rest = $0
            while (match(rest, /(bin\/)?release\/[A-Za-z0-9_.-]+\/simple/)) {
                print substr(rest, RSTART, RLENGTH)
                rest = substr(rest, RSTART + RLENGTH)
            }
        }
    ' "$wrapper")"
    for relative in $literal_candidates; do
        case "$relative" in
            bin/release/*) candidate="$(dirname -- "$wrapper_dir")/$relative" ;;
            *) candidate="$wrapper_dir/$relative" ;;
        esac
        if [ -x "$candidate" ] && native_executable_format "$candidate" >/dev/null 2>&1; then
            resolve_symlink_path "$candidate"
            return
        fi
    done
    candidate="$wrapper_dir/release/simple"
    if [ -x "$candidate" ] && native_executable_format "$candidate" >/dev/null 2>&1; then
        resolve_symlink_path "$candidate"
        return
    fi
    return 1
}

tool_version() {
    tool="$1"
    if version="$(run_with_timeout "$tool" --version 2>&1)"; then
        :
    elif version="$(run_with_timeout "$tool" -v 2>&1)"; then
        :
    else
        return 1
    fi
    printf '%s\n' "$version" | sed -n '/[^[:space:]]/ { p; q; }' | one_line
}

record_tool_provenance() {
    target="$1"
    role="$2"
    tool="$3"
    path="$(tool_path "$tool" || true)"
    version=""
    if [ "$path" != "" ]; then
        version="$(tool_version "$path" || true)"
    fi
    tool_sha=""
    if [ "$path" != "" ]; then
        tool_sha="$(sha256_file "$path" || true)"
    fi
    {
        echo "${target}_${role}_requested=$(printf '%s' "$tool" | one_line)"
        echo "${target}_${role}_path=$(printf '%s' "$path" | one_line)"
        echo "${target}_${role}_version=$version"
        echo "${target}_${role}_sha256=$tool_sha"
    } >>"$BUILD_DIR/evidence.env"
    [ "$path" != "" ] && [ "$version" != "" ] && sha256_valid "$tool_sha"
}

record_simple_provenance() {
    invocation_path="$(tool_path "$SIMPLE_BIN" || true)"
    if [ "$invocation_path" = "" ] && [ -f "$SIMPLE_BIN" ]; then
        invocation_path="$(resolve_symlink_path "$SIMPLE_BIN" || true)"
    fi
    if [ "$invocation_path" = "" ] || [ ! -f "$invocation_path" ]; then
        echo "Simple compiler binary is unavailable: $SIMPLE_BIN" >&2
        return 1
    fi
    invocation_sha="$(sha256_file "$invocation_path" || true)"
    resolved_invocation="$(resolve_symlink_path "$invocation_path" || true)"
    if [ "$SIMPLE_RUNTIME_BIN" != "" ]; then
        runtime_path="$(tool_path "$SIMPLE_RUNTIME_BIN" || true)"
        if [ "$runtime_path" = "" ] && [ -f "$SIMPLE_RUNTIME_BIN" ]; then
            runtime_path="$(resolve_symlink_path "$SIMPLE_RUNTIME_BIN" || true)"
        fi
        runtime_path="$(resolve_symlink_path "$runtime_path" || true)"
    elif native_executable_format "$resolved_invocation" >/dev/null 2>&1; then
        runtime_path="$resolved_invocation"
    else
        runtime_path="$(canonical_wrapper_runtime "$invocation_path" || true)"
    fi
    runtime_format="$(native_executable_format "$runtime_path" || true)"
    runtime_sha="$(sha256_file "$runtime_path" || true)"
    if [ "${#invocation_sha}" -ne 64 ] || [ "${#runtime_sha}" -ne 64 ] || [ "$runtime_format" = "" ]; then
        echo "Cannot resolve a native Simple runtime from $invocation_path; set SIMPLE_RUNTIME_BIN to an ELF or Mach-O binary" >&2
        return 1
    fi
    SIMPLE_EXEC_BIN="$runtime_path"
    {
        echo "simple_invocation_path=$(printf '%s' "$invocation_path" | one_line)"
        echo "simple_invocation_sha256=$invocation_sha"
        echo "simple_runtime_path=$(printf '%s' "$runtime_path" | one_line)"
        echo "simple_runtime_sha256=$runtime_sha"
        echo "simple_runtime_format=$runtime_format"
        echo "simple_bin_path=$(printf '%s' "$runtime_path" | one_line)"
        echo "simple_bin_sha256=$runtime_sha"
    } >>"$BUILD_DIR/evidence.env"
}

record_portable_compute_emitter_provenance() {
    PORTABLE_COMPUTE_EMITTER_EXEC=""
    if [ "$PORTABLE_COMPUTE_EMITTER_BIN" = "" ]; then
        emitter_source="$ROOT_DIR/src/app/portable_compute_emit/main.spl"
        emitter_source_sha="$(sha256_file "$emitter_source" || true)"
        if ! sha256_valid "$emitter_source_sha"; then
            echo "Portable compute emitter source provenance is unavailable" >&2
            return 1
        fi
        {
            echo "portable_compute_emitter_mode=source-cli"
            echo "portable_compute_emitter_requested=$emitter_source"
            echo "portable_compute_emitter_path=$emitter_source"
            echo "portable_compute_emitter_sha256=$emitter_source_sha"
            echo "portable_compute_emitter_format=source"
        } >>"$BUILD_DIR/evidence.env"
        record_simple_provenance
        return
    fi
    emitter_path="$(tool_path "$PORTABLE_COMPUTE_EMITTER_BIN" || true)"
    emitter_path="$(resolve_symlink_path "$emitter_path" || true)"
    if [ "$emitter_path" = "" ]; then
        echo "Cached portable compute emitter is unavailable or non-native: $PORTABLE_COMPUTE_EMITTER_BIN" >&2
        return 1
    fi
    emitter_format="$(native_executable_format "$emitter_path" || true)"
    emitter_sha="$(sha256_file "$emitter_path" || true)"
    if [ "$emitter_format" = "" ] || ! sha256_valid "$emitter_sha"; then
        echo "Cached portable compute emitter is unavailable or non-native: $PORTABLE_COMPUTE_EMITTER_BIN" >&2
        return 1
    fi
    PORTABLE_COMPUTE_EMITTER_EXEC="$emitter_path"
    {
        echo "portable_compute_emitter_mode=cached-native"
        echo "portable_compute_emitter_requested=$(printf '%s' "$PORTABLE_COMPUTE_EMITTER_BIN" | one_line)"
        echo "portable_compute_emitter_path=$(printf '%s' "$emitter_path" | one_line)"
        echo "portable_compute_emitter_sha256=$emitter_sha"
        echo "portable_compute_emitter_format=$emitter_format"
    } >>"$BUILD_DIR/evidence.env"
}

portable_compute_emitter_command() {
    target="$1"
    if [ "$PORTABLE_COMPUTE_EMITTER_EXEC" != "" ]; then
        printf '%s %s\n' "$PORTABLE_COMPUTE_EMITTER_EXEC" "$target"
    else
        printf '%s run src/app/portable_compute_emit/main.spl %s\n' "$SIMPLE_EXEC_BIN" "$target"
    fi
}

run_portable_compute_emitter() {
    program="$1"
    target="$2"
    if [ "$PORTABLE_COMPUTE_EMITTER_EXEC" != "" ]; then
        run_with_timeout "$PORTABLE_COMPUTE_EMITTER_EXEC" "$target"
    else
        SIMPLE_LIB="${SIMPLE_LIB:-src}" run_with_timeout "$SIMPLE_EXEC_BIN" run "$program" "$target"
    fi
}

record_portable_compute_emitter_command() {
    target="$1"
    field="$2"
    command_line="$(portable_compute_emitter_command "$target")"
    printf '%s=%s\n' "$field" "$(printf '%s' "$command_line" | one_line)" >>"$BUILD_DIR/evidence.env"
}

fail_if_explicit_emitter_rejected() {
    error_path="$1"
    if [ "$PORTABLE_COMPUTE_EMITTER_EXEC" = "" ]; then
        return
    fi
    echo "Explicit cached portable compute emitter failed protocol validation: $PORTABLE_COMPUTE_EMITTER_EXEC" >&2
    if [ -s "$error_path" ]; then
        sed -n '1,20p' "$error_path" >&2
    fi
    exit 1
}

field_from_stream() {
    key="$1"
    awk -v k="$key" 'index($0, k "=") == 1 { print substr($0, length(k) + 2); exit }'
}

field_of() {
    field_from_stream "$1" <"$2"
}

assert_evidence_parser_contract() {
    fixture="vulkan_font_command=glslc --target-env=vulkan1.1 -DNAME=value"
    parsed="$(printf '%s\n' "$fixture" | field_from_stream vulkan_font_command)"
    [ "$parsed" = "glslc --target-env=vulkan1.1 -DNAME=value" ]
}

run_with_timeout() {
    if have timeout; then
        timeout -k "$KILL_SECS" "$TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

vulkan_glslc_provenance_result() {
    vulkan_provenance_initial="$1"
    vulkan_provenance_version="$2"
    vulkan_provenance_compiler_sha="$3"
    vulkan_provenance_loaded_path="$4"
    vulkan_provenance_loaded_sha="$5"
    vulkan_provenance_loader_sha="$6"
    vulkan_provenance_expected_path="$7"
    if [ "$vulkan_provenance_initial" != pass ]; then
        echo "$vulkan_provenance_initial"
    elif [ "$vulkan_provenance_version" = "" ] || ! sha256_valid "$vulkan_provenance_compiler_sha" ||
         [ "$vulkan_provenance_loaded_path" = "" ] || ! sha256_valid "$vulkan_provenance_loaded_sha" ||
         ! sha256_valid "$vulkan_provenance_loader_sha"; then
        echo missing-loaded-library-provenance
    elif [ "$vulkan_provenance_expected_path" != "" ] &&
         [ "$vulkan_provenance_loaded_path" != "$vulkan_provenance_expected_path" ]; then
        echo loaded-library-path-mismatch
    else
        echo pass
    fi
}

vulkan_artifact_tuple_deterministic() {
    sha256_valid "$1" && [ "$1" = "$2" ] && [ "$3" = true ]
}

font_artifact_evidence_matches() {
    [ "$1" = "" ] || [ "$1" = "$2" ]
}

vulkan_glslc_compiler_status() {
    if [ "$1" = "" ]; then
        echo missing-compiler-path
    elif [ "$2" != elf ]; then
        echo non-elf-compiler
    else
        echo pass
    fi
}

vulkan_glslc_loaded_library_path() {
    log_path="$1"
    [ -f "$log_path" ] || return 1
    raw_paths="$(awk '/calling init: .*libshaderc.*\.so/ { sub(/^.*calling init: /, ""); sub(/[[:space:]]*$/, ""); print }' "$log_path" | sort -u)"
    [ "$raw_paths" != "" ] || return 1
    resolved_paths=""
    resolved_count=0
    old_ifs="$IFS"
    IFS='
'
    for raw_path in $raw_paths; do
        resolved_path="$(resolve_symlink_path "$raw_path" || true)"
        if [ "$resolved_path" = "" ] || [ ! -f "$resolved_path" ]; then
            IFS="$old_ifs"
            return 1
        fi
        if ! printf '%s\n' "$resolved_paths" | grep -F -x -e "$resolved_path" >/dev/null 2>&1; then
            if [ "$resolved_paths" = "" ]; then
                resolved_paths="$resolved_path"
            else
                resolved_paths="$resolved_paths
$resolved_path"
            fi
            resolved_count=$((resolved_count + 1))
        fi
    done
    IFS="$old_ifs"
    [ "$resolved_count" -eq 1 ] || return 2
    printf '%s\n' "$resolved_paths"
}

write_vulkan_glslc_provenance_evidence() {
    {
        echo "vulkan_font_compiler_requested=$(printf '%s' "$VULKAN_GLSLC_REQUESTED" | one_line)"
        echo "vulkan_font_compiler_path=$(printf '%s' "$VULKAN_GLSLC_EXEC_PATH" | one_line)"
        echo "vulkan_font_compiler_version=$VULKAN_GLSLC_VERSION"
        echo "vulkan_font_compiler_sha256=$VULKAN_GLSLC_COMPILER_SHA_BEFORE"
        echo "vulkan_font_compiler_sha256_after_a=$VULKAN_GLSLC_COMPILER_SHA_A"
        echo "vulkan_font_compiler_sha256_after_b=$VULKAN_GLSLC_COMPILER_SHA_B"
        echo "vulkan_font_compiler_format=$VULKAN_GLSLC_COMPILER_FORMAT"
        echo "vulkan_font_compiler_loader_host=$(printf '%s' "$VULKAN_GLSLC_HOST_LIBC" | one_line)"
        echo "vulkan_font_compiler_clean_home=$(printf '%s' "$VULKAN_GLSLC_CLEAN_HOME" | one_line)"
        echo "vulkan_font_compiler_library_expected_path=$(printf '%s' "$VULKAN_GLSLC_EXPECTED_PATH" | one_line)"
        echo "vulkan_font_compiler_library_path=$(printf '%s' "$VULKAN_GLSLC_LIBRARY_PATH_A" | one_line)"
        echo "vulkan_font_compiler_library_path_repro=$(printf '%s' "$VULKAN_GLSLC_LIBRARY_PATH_B" | one_line)"
        echo "vulkan_font_compiler_library_sha256=$VULKAN_GLSLC_LIBRARY_SHA_A"
        echo "vulkan_font_compiler_library_sha256_repro=$VULKAN_GLSLC_LIBRARY_SHA_B"
        echo "vulkan_font_compiler_loader_log=$(printf '%s' "$VULKAN_GLSLC_LOADER_LOG_A" | one_line)"
        echo "vulkan_font_compiler_loader_log_sha256=$VULKAN_GLSLC_LOADER_SHA_A"
        echo "vulkan_font_compiler_loader_log_repro=$(printf '%s' "$VULKAN_GLSLC_LOADER_LOG_B" | one_line)"
        echo "vulkan_font_compiler_loader_log_repro_sha256=$VULKAN_GLSLC_LOADER_SHA_B"
        echo "vulkan_font_compiler_library_provenance_status=$VULKAN_GLSLC_PROVENANCE_STATUS"
    } >>"$BUILD_DIR/evidence.env"
}

record_vulkan_glslc_library_provenance() {
    VULKAN_GLSLC_REQUESTED="$1"
    VULKAN_GLSLC_EXEC_PATH="$(tool_path "$1" || true)"
    VULKAN_GLSLC_EXEC_PATH="$(resolve_symlink_path "$VULKAN_GLSLC_EXEC_PATH" || true)"
    VULKAN_GLSLC_COMPILER_FORMAT="$(native_executable_format "$VULKAN_GLSLC_EXEC_PATH" || true)"
    VULKAN_GLSLC_EXPECTED_PATH=""
    VULKAN_GLSLC_LIBDIR=""
    VULKAN_GLSLC_VERSION=""
    VULKAN_GLSLC_COMPILER_SHA_BEFORE=""
    VULKAN_GLSLC_COMPILER_SHA_A=""
    VULKAN_GLSLC_COMPILER_SHA_B=""
    VULKAN_GLSLC_LIBRARY_PATH_A=""
    VULKAN_GLSLC_LIBRARY_PATH_B=""
    VULKAN_GLSLC_LIBRARY_SHA_A=""
    VULKAN_GLSLC_LIBRARY_SHA_B=""
    VULKAN_GLSLC_LOADER_LOG_A="$BUILD_DIR/vulkan_font_compiler_loader_a.log"
    VULKAN_GLSLC_LOADER_LOG_B="$BUILD_DIR/vulkan_font_compiler_loader_b.log"
    VULKAN_GLSLC_LOADER_SHA_A=""
    VULKAN_GLSLC_LOADER_SHA_B=""
    VULKAN_GLSLC_HOST_LIBC="$(getconf GNU_LIBC_VERSION 2>/dev/null || true)"
    VULKAN_GLSLC_CLEAN_HOME="$BUILD_DIR/vulkan_glslc_home"
    VULKAN_GLSLC_PROVENANCE_STATUS=pass
    if [ "$VULKAN_GLSLC_LIBRARY_PATH" != "" ]; then
        VULKAN_GLSLC_EXPECTED_PATH="$(resolve_symlink_path "$VULKAN_GLSLC_LIBRARY_PATH" || true)"
        if [ "$VULKAN_GLSLC_EXPECTED_PATH" = "" ]; then
            VULKAN_GLSLC_PROVENANCE_STATUS=expected-path-invalid
        else
            VULKAN_GLSLC_LIBDIR="$(dirname -- "$VULKAN_GLSLC_EXPECTED_PATH")"
        fi
    fi
    rm -rf "$VULKAN_GLSLC_CLEAN_HOME"
    mkdir -p "$VULKAN_GLSLC_CLEAN_HOME"
    chmod 700 "$VULKAN_GLSLC_CLEAN_HOME"
    vulkan_glslc_version_out="$BUILD_DIR/vulkan_font_compiler_version.out"
    rm -f "$vulkan_glslc_version_out" "$VULKAN_GLSLC_LOADER_LOG_A" "$VULKAN_GLSLC_LOADER_LOG_B"
    if [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = pass ]; then
        VULKAN_GLSLC_PROVENANCE_STATUS="$(vulkan_glslc_compiler_status "$VULKAN_GLSLC_EXEC_PATH" "$VULKAN_GLSLC_COMPILER_FORMAT")"
    fi
    if [ "$VULKAN_GLSLC_PROVENANCE_STATUS" != pass ]; then
        :
    elif [ "${VULKAN_GLSLC_HOST_LIBC#glibc }" = "$VULKAN_GLSLC_HOST_LIBC" ]; then
        VULKAN_GLSLC_PROVENANCE_STATUS=unsupported-loader-provenance-host
    elif ! run_with_timeout env -i PATH=/usr/bin:/bin:/usr/sbin:/sbin HOME="$VULKAN_GLSLC_CLEAN_HOME" LC_ALL=C \
             LD_LIBRARY_PATH="$VULKAN_GLSLC_LIBDIR" "$VULKAN_GLSLC_EXEC_PATH" --version \
             >"$vulkan_glslc_version_out" 2>/dev/null; then
        VULKAN_GLSLC_PROVENANCE_STATUS=version-probe-failed
    fi
    if [ -f "$vulkan_glslc_version_out" ]; then
        VULKAN_GLSLC_VERSION="$(sed -n '/[^[:space:]]/ { p; q; }' "$vulkan_glslc_version_out" | one_line)"
    fi
    VULKAN_GLSLC_COMPILER_SHA_BEFORE="$(sha256_file "$VULKAN_GLSLC_EXEC_PATH" || true)"
    if [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = pass ] &&
       { [ "$VULKAN_GLSLC_VERSION" = "" ] || ! sha256_valid "$VULKAN_GLSLC_COMPILER_SHA_BEFORE"; }; then
        VULKAN_GLSLC_PROVENANCE_STATUS=missing-compiler-provenance
    fi
    if [ "$VULKAN_GLSLC_PROVENANCE_STATUS" != pass ]; then
        write_vulkan_glslc_provenance_evidence || true
        return 1
    fi
}

run_vulkan_glslc_compile() {
    output="$1"
    source="$2"
    stdout_log="$3"
    loader_log="$4"
    run_with_timeout env -i PATH=/usr/bin:/bin:/usr/sbin:/sbin HOME="$VULKAN_GLSLC_CLEAN_HOME" LC_ALL=C \
        LD_LIBRARY_PATH="$VULKAN_GLSLC_LIBDIR" LD_DEBUG=libs "$VULKAN_GLSLC_EXEC_PATH" \
        --target-env=vulkan1.1 -fshader-stage=compute -o "$output" "$source" \
        >"$stdout_log" 2>"$loader_log"
}

capture_vulkan_glslc_compile_provenance() {
    capture_label="$1"
    capture_log="$2"
    capture_path=""
    if capture_path="$(vulkan_glslc_loaded_library_path "$capture_log")"; then
        :
    else
        capture_status=$?
        if [ "$capture_status" -eq 2 ]; then
            VULKAN_GLSLC_PROVENANCE_STATUS=multiple-loaded-library-provenance
        else
            VULKAN_GLSLC_PROVENANCE_STATUS=missing-loaded-library-provenance
        fi
        return 1
    fi
    capture_compiler_sha="$(sha256_file "$VULKAN_GLSLC_EXEC_PATH" || true)"
    capture_library_sha="$(sha256_file "$capture_path" || true)"
    capture_loader_sha="$(sha256_file "$capture_log" || true)"
    if ! sha256_valid "$capture_compiler_sha" || ! sha256_valid "$capture_library_sha" ||
       ! sha256_valid "$capture_loader_sha"; then
        VULKAN_GLSLC_PROVENANCE_STATUS=missing-loaded-library-provenance
        return 1
    fi
    if [ "$capture_label" = a ]; then
        VULKAN_GLSLC_COMPILER_SHA_A="$capture_compiler_sha"
        VULKAN_GLSLC_LIBRARY_PATH_A="$capture_path"
        VULKAN_GLSLC_LIBRARY_SHA_A="$capture_library_sha"
        VULKAN_GLSLC_LOADER_SHA_A="$capture_loader_sha"
    else
        VULKAN_GLSLC_COMPILER_SHA_B="$capture_compiler_sha"
        VULKAN_GLSLC_LIBRARY_PATH_B="$capture_path"
        VULKAN_GLSLC_LIBRARY_SHA_B="$capture_library_sha"
        VULKAN_GLSLC_LOADER_SHA_B="$capture_loader_sha"
    fi
}

finalize_vulkan_glslc_compile_provenance() {
    if [ "$VULKAN_GLSLC_COMPILER_SHA_BEFORE" != "$VULKAN_GLSLC_COMPILER_SHA_A" ] ||
       [ "$VULKAN_GLSLC_COMPILER_SHA_A" != "$VULKAN_GLSLC_COMPILER_SHA_B" ]; then
        VULKAN_GLSLC_PROVENANCE_STATUS=compiler-changed-during-compile
    elif [ "$VULKAN_GLSLC_LIBRARY_PATH_A" != "$VULKAN_GLSLC_LIBRARY_PATH_B" ]; then
        VULKAN_GLSLC_PROVENANCE_STATUS=producer-library-path-mismatch
    elif [ "$VULKAN_GLSLC_LIBRARY_SHA_A" != "$VULKAN_GLSLC_LIBRARY_SHA_B" ]; then
        VULKAN_GLSLC_PROVENANCE_STATUS=producer-library-changed-during-compile
    else
        VULKAN_GLSLC_PROVENANCE_STATUS="$(vulkan_glslc_provenance_result pass \
            "$VULKAN_GLSLC_VERSION" "$VULKAN_GLSLC_COMPILER_SHA_B" \
            "$VULKAN_GLSLC_LIBRARY_PATH_B" "$VULKAN_GLSLC_LIBRARY_SHA_B" \
            "$VULKAN_GLSLC_LOADER_SHA_B" "$VULKAN_GLSLC_EXPECTED_PATH")"
    fi
    write_vulkan_glslc_provenance_evidence || {
        VULKAN_GLSLC_PROVENANCE_STATUS=evidence-write-failed
        return 1
    }
    [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = pass ]
}

if [ "${1:-}" = "--vulkan-provenance-self-test" ]; then
    vulkan_self_test_sha="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    [ "$(vulkan_glslc_compiler_status /tmp/compiler script)" = non-elf-compiler ]
    [ "$(vulkan_glslc_compiler_status /tmp/compiler elf)" = pass ]
    [ "$(vulkan_glslc_provenance_result pass v "$vulkan_self_test_sha" "" "" "$vulkan_self_test_sha" "")" = missing-loaded-library-provenance ]
    [ "$(vulkan_glslc_provenance_result pass v "$vulkan_self_test_sha" /actual/libshaderc.so.1 "$vulkan_self_test_sha" "$vulkan_self_test_sha" /expected/libshaderc.so.1)" = loaded-library-path-mismatch ]
    [ "$(vulkan_glslc_provenance_result pass v "$vulkan_self_test_sha" /actual/libshaderc.so.1 "$vulkan_self_test_sha" "$vulkan_self_test_sha" /actual/libshaderc.so.1)" = pass ]
    vulkan_self_test_root="${TMPDIR:-/tmp}/simple-vulkan-provenance-self-test-$$"
    rm -rf "$vulkan_self_test_root"
    mkdir -p "$vulkan_self_test_root/real" "$vulkan_self_test_root/clean-home"
    trap 'rm -rf "$vulkan_self_test_root"' EXIT HUP INT TERM
    printf 'shaderc-a\n' >"$vulkan_self_test_root/real/libshaderc-a.so.1"
    printf 'shaderc-b\n' >"$vulkan_self_test_root/real/libshaderc-b.so.1"
    ln -s "real/libshaderc-a.so.1" "$vulkan_self_test_root/libshaderc.so.1"
    printf '1: calling init: %s\n' "$vulkan_self_test_root/libshaderc.so.1" >"$vulkan_self_test_root/one.log"
    [ "$(vulkan_glslc_loaded_library_path "$vulkan_self_test_root/one.log")" = "$vulkan_self_test_root/real/libshaderc-a.so.1" ]
    printf '1: calling init: %s\n2: calling init: %s\n' \
        "$vulkan_self_test_root/real/libshaderc-a.so.1" \
        "$vulkan_self_test_root/real/libshaderc-b.so.1" >"$vulkan_self_test_root/multiple.log"
    if vulkan_glslc_loaded_library_path "$vulkan_self_test_root/multiple.log" >/dev/null 2>&1; then
        echo "Vulkan provenance self-test accepted multiple shaderc libraries" >&2
        exit 1
    fi
    printf '1: calling init: %s\n' "$vulkan_self_test_root/libshaderc-missing.so.1" >"$vulkan_self_test_root/dangling.log"
    if vulkan_glslc_loaded_library_path "$vulkan_self_test_root/dangling.log" >/dev/null 2>&1; then
        echo "Vulkan provenance self-test accepted a missing shaderc library" >&2
        exit 1
    fi
    vulkan_self_test_home_out="$vulkan_self_test_root/home.out"
    cat >"$vulkan_self_test_root/fake-glslc" <<EOF
#!/bin/sh
printf '%s\n' "\$HOME" >"$vulkan_self_test_home_out"
exit 0
EOF
    chmod +x "$vulkan_self_test_root/fake-glslc"
    VULKAN_GLSLC_EXEC_PATH="$vulkan_self_test_root/fake-glslc"
    VULKAN_GLSLC_LIBDIR=""
    VULKAN_GLSLC_CLEAN_HOME="$vulkan_self_test_root/clean-home"
    run_vulkan_glslc_compile "$vulkan_self_test_root/out.spv" "$vulkan_self_test_root/in.comp" \
        "$vulkan_self_test_root/fake.out" "$vulkan_self_test_root/fake.loader"
    [ "$(cat "$vulkan_self_test_home_out")" = "$VULKAN_GLSLC_CLEAN_HOME" ]

    BUILD_DIR="$vulkan_self_test_root/build"
    mkdir -p "$BUILD_DIR"
    vulkan_self_test_reset_finalize_state() {
        : >"$BUILD_DIR/evidence.env"
        VULKAN_GLSLC_REQUESTED=glslc
        VULKAN_GLSLC_EXEC_PATH="$vulkan_self_test_root/fake-glslc"
        VULKAN_GLSLC_VERSION=test-version
        VULKAN_GLSLC_COMPILER_FORMAT=elf
        VULKAN_GLSLC_HOST_LIBC="glibc test"
        VULKAN_GLSLC_CLEAN_HOME="$vulkan_self_test_root/clean-home"
        VULKAN_GLSLC_EXPECTED_PATH=""
        VULKAN_GLSLC_LOADER_LOG_A="$vulkan_self_test_root/one.log"
        VULKAN_GLSLC_LOADER_LOG_B="$vulkan_self_test_root/one.log"
        VULKAN_GLSLC_LOADER_SHA_A="$vulkan_self_test_sha"
        VULKAN_GLSLC_LOADER_SHA_B="$vulkan_self_test_sha"
        VULKAN_GLSLC_LIBRARY_PATH_A="$vulkan_self_test_root/real/libshaderc-a.so.1"
        VULKAN_GLSLC_LIBRARY_PATH_B="$VULKAN_GLSLC_LIBRARY_PATH_A"
        VULKAN_GLSLC_LIBRARY_SHA_A="$vulkan_self_test_sha"
        VULKAN_GLSLC_LIBRARY_SHA_B="$vulkan_self_test_sha"
        VULKAN_GLSLC_COMPILER_SHA_BEFORE="$vulkan_self_test_sha"
        VULKAN_GLSLC_COMPILER_SHA_A="$vulkan_self_test_sha"
        VULKAN_GLSLC_COMPILER_SHA_B="$vulkan_self_test_sha"
        VULKAN_GLSLC_PROVENANCE_STATUS=pass
    }
    vulkan_self_test_reset_finalize_state
    finalize_vulkan_glslc_compile_provenance
    [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = pass ]
    vulkan_self_test_reset_finalize_state
    VULKAN_GLSLC_COMPILER_SHA_B="bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    if finalize_vulkan_glslc_compile_provenance; then
        echo "Vulkan provenance self-test accepted compiler drift" >&2
        exit 1
    fi
    [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = compiler-changed-during-compile ]
    vulkan_self_test_reset_finalize_state
    VULKAN_GLSLC_LIBRARY_PATH_B="$vulkan_self_test_root/real/libshaderc-b.so.1"
    if finalize_vulkan_glslc_compile_provenance; then
        echo "Vulkan provenance self-test accepted producer library path drift" >&2
        exit 1
    fi
    [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = producer-library-path-mismatch ]
    vulkan_self_test_reset_finalize_state
    VULKAN_GLSLC_LIBRARY_SHA_B="bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    if finalize_vulkan_glslc_compile_provenance; then
        echo "Vulkan provenance self-test accepted producer library content drift" >&2
        exit 1
    fi
    [ "$VULKAN_GLSLC_PROVENANCE_STATUS" = producer-library-changed-during-compile ]

    vulkan_artifact_tuple_deterministic "$vulkan_self_test_sha" "$vulkan_self_test_sha" true
    font_artifact_evidence_matches "$vulkan_self_test_sha" "$vulkan_self_test_sha"
    if font_artifact_evidence_matches "$vulkan_self_test_sha" \
       "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"; then
        echo "Vulkan provenance self-test accepted final artifact drift" >&2
        exit 1
    fi
    if vulkan_artifact_tuple_deterministic "$vulkan_self_test_sha" "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb" true ||
       vulkan_artifact_tuple_deterministic "$vulkan_self_test_sha" "$vulkan_self_test_sha" false; then
        echo "Vulkan provenance self-test failed" >&2
        exit 1
    fi
    echo "Vulkan provenance self-test passed"
    exit 0
fi

bytes_of() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

contains_symbol() {
    path="$1"
    symbol="$2"
    if [ ! -f "$path" ]; then
        return 1
    fi
    if have strings; then
        strings "$path" | grep -F "$symbol" >/dev/null 2>&1
    else
        grep -a -F "$symbol" "$path" >/dev/null 2>&1
    fi
}

write_generated_sources() {
    target="$1"
    path="$2"
    font_path="$3"
    program="src/app/portable_compute_emit/main.spl"
    raw_output="$BUILD_DIR/${target}_source.raw"
    rm -f "$raw_output" "$BUILD_DIR/${target}_source.err"
    record_portable_compute_emitter_command "$target" "${target}_emitter_command"
    if ! run_portable_compute_emitter "$program" "$target" >"$raw_output" 2>"$BUILD_DIR/${target}_source.err"; then
        return 1
    fi
    rm -f "$path"
    awk '/^__PORTABLE_COMPUTE_SOURCE_BEGIN__$/ { emit = 1; next } /^__PORTABLE_COMPUTE_SOURCE_END__$/ { emit = 0 } emit { print }' "$raw_output" >"$path"
    rm -f "$font_path"
    awk '/^__PORTABLE_FONT_SOURCE_BEGIN__$/ { emit = 1; next } /^__PORTABLE_FONT_SOURCE_END__$/ { emit = 0 } emit { print }' "$raw_output" >"$font_path"
    if [ ! -s "$path" ] || [ ! -s "$font_path" ]; then
        echo "generated source is empty" >>"$BUILD_DIR/${target}_source.err"
        return 1
    fi
    emitter_source_sha="$(awk -F= '$1 == "__PORTABLE_COMPUTE_EMITTER_SOURCE_SHA256__" { print $2 }' "$raw_output")"
    emitter_version_sha="$(awk -F= '$1 == "__PORTABLE_COMPUTE_EMITTER_VERSION_SHA256__" { print $2 }' "$raw_output")"
    font_emitter_source_sha="$(awk -F= '$1 == "__PORTABLE_FONT_EMITTER_SOURCE_SHA256__" { print $2 }' "$raw_output")"
    font_emitter_version_sha="$(awk -F= '$1 == "__PORTABLE_FONT_EMITTER_VERSION_SHA256__" { print $2 }' "$raw_output")"
    font_semantics_revision="$(awk -F= '$1 == "__PORTABLE_FONT_SEMANTICS_REVISION__" { print $2 }' "$raw_output")"
    generated_source_sha="$(sha256_file "$path" || true)"
    generated_font_source_sha="$(sha256_file "$font_path" || true)"
    for sha in "$emitter_source_sha" "$emitter_version_sha" "$font_emitter_source_sha" "$font_emitter_version_sha" "$generated_source_sha" "$generated_font_source_sha"; do
        if ! sha256_valid "$sha"; then
            echo "generated source provenance is missing or malformed" >>"$BUILD_DIR/${target}_source.err"
            return 1
        fi
    done
    if [ "$generated_source_sha" != "$emitter_source_sha" ] || [ "$generated_font_source_sha" != "$font_emitter_source_sha" ]; then
        echo "generated source bytes do not match emitter provenance" >>"$BUILD_DIR/${target}_source.err"
        return 1
    fi
    {
        echo "${target}_emitter_source_sha256=$emitter_source_sha"
        echo "${target}_emitter_version_sha256=$emitter_version_sha"
        echo "${target}_generated_source_sha256=$generated_source_sha"
        echo "${target}_font_emitter_source_sha256=$font_emitter_source_sha"
        echo "${target}_font_emitter_version_sha256=$font_emitter_version_sha"
        echo "${target}_font_generated_source_sha256=$generated_font_source_sha"
        echo "${target}_font_semantics_revision=$font_semantics_revision"
    } >>"$BUILD_DIR/evidence.env"
    if [ "$font_semantics_revision" != "$PORTABLE_COMPUTE_EXPECTED_SEMANTICS" ]; then
        echo "generated font semantics revision mismatch: expected $PORTABLE_COMPUTE_EXPECTED_SEMANTICS, got $font_semantics_revision" >>"$BUILD_DIR/${target}_source.err"
        return 1
    fi
    for symbol in simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32 simple_2d_bitmap_glyph_raster_u32; do
        if ! grep -F "$symbol" "$path" >/dev/null 2>&1; then
            echo "generated source is missing entry symbol: $symbol" >>"$BUILD_DIR/${target}_source.err"
            return 1
        fi
    done
    if ! grep -F "simple_font_atlas_composite_v1_u32" "$font_path" >/dev/null 2>&1; then
        echo "generated font source is missing entry symbol: simple_font_atlas_composite_v1_u32" >>"$BUILD_DIR/${target}_source.err"
        return 1
    fi
}

write_generated_vulkan_font_source() {
    path="$1"
    program="src/app/portable_compute_emit/main.spl"
    raw_output="$BUILD_DIR/vulkan_font_source.raw"
    rm -f "$raw_output" "$BUILD_DIR/vulkan_font_source.err"
    record_portable_compute_emitter_command vulkan vulkan_font_emitter_command
    if ! run_portable_compute_emitter "$program" vulkan >"$raw_output" 2>"$BUILD_DIR/vulkan_font_source.err"; then
        return 1
    fi
    rm -f "$path"
    awk '/^__PORTABLE_FONT_SOURCE_BEGIN__$/ { emit = 1; next } /^__PORTABLE_FONT_SOURCE_END__$/ { emit = 0 } emit { print }' "$raw_output" >"$path"
    if [ ! -s "$path" ] || ! grep -F "void main()" "$path" >/dev/null 2>&1; then
        echo "generated Vulkan font source is empty or missing main" >>"$BUILD_DIR/vulkan_font_source.err"
        return 1
    fi
    emitter_source_sha="$(awk -F= '$1 == "__VULKAN_FONT_EMITTER_SOURCE_SHA256__" { print $2 }' "$raw_output")"
    font_semantics_revision="$(awk -F= '$1 == "__PORTABLE_FONT_SEMANTICS_REVISION__" { print $2 }' "$raw_output")"
    generated_source_sha="$(sha256_file "$path" || true)"
    {
        echo "vulkan_font_emitter_source_sha256=$emitter_source_sha"
        echo "vulkan_font_generated_source_sha256=$generated_source_sha"
        echo "vulkan_font_pinned_source_sha256=$PINNED_VULKAN_FONT_SOURCE_SHA256"
        echo "vulkan_font_semantics_revision=$font_semantics_revision"
    } >>"$BUILD_DIR/evidence.env"
    if [ "$font_semantics_revision" != "$PORTABLE_COMPUTE_EXPECTED_SEMANTICS" ]; then
        echo "vulkan_font_source_equivalent=false" >>"$BUILD_DIR/evidence.env"
        echo "generated Vulkan font semantics revision mismatch: expected $PORTABLE_COMPUTE_EXPECTED_SEMANTICS, got $font_semantics_revision" >>"$BUILD_DIR/vulkan_font_source.err"
        return 1
    fi
    if ! sha256_valid "$emitter_source_sha" || ! sha256_valid "$generated_source_sha"; then
        echo "vulkan_font_source_equivalent=false" >>"$BUILD_DIR/evidence.env"
        echo "generated Vulkan font source provenance is missing or malformed" >>"$BUILD_DIR/vulkan_font_source.err"
        return 1
    fi
    if [ "$generated_source_sha" != "$emitter_source_sha" ]; then
        echo "vulkan_font_source_equivalent=false" >>"$BUILD_DIR/evidence.env"
        echo "generated Vulkan font source bytes do not match emitter provenance" >>"$BUILD_DIR/vulkan_font_source.err"
        return 1
    fi
    if [ "$emitter_source_sha" != "$PINNED_VULKAN_FONT_SOURCE_SHA256" ]; then
        echo "vulkan_font_source_equivalent=false" >>"$BUILD_DIR/evidence.env"
        {
            echo "generated Vulkan font source identity mismatch"
            echo "expected emitter source SHA-256: $PINNED_VULKAN_FONT_SOURCE_SHA256"
            echo "actual emitter source SHA-256: $emitter_source_sha"
        } >>"$BUILD_DIR/vulkan_font_source.err"
    else
        VULKAN_FONT_SOURCE_EQUIVALENT=true
        echo "vulkan_font_source_equivalent=true" >>"$BUILD_DIR/evidence.env"
    fi
}

status_for_artifact() {
    target="$1"
    artifact="$2"
    shift 2
    bytes="$(bytes_of "$artifact")"
    if [ "$bytes" -le 0 ]; then
        echo "invalid:missing-artifact-bytes:0"
        return
    fi
    case "$target" in
        cuda)
            if ! grep -a -F ".version" "$artifact" >/dev/null 2>&1; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        hip)
            magic="$(od -An -tx1 -N4 "$artifact" 2>/dev/null | tr -d ' \n')"
            if [ "$magic" != "7f454c46" ]; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        opencl)
            magic="$(od -An -tx1 -N4 "$artifact" 2>/dev/null | tr -d ' \n')"
            if [ "$magic" != "03022307" ] && [ "$magic" != "07230203" ]; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        vulkan)
            magic="$(od -An -tx1 -N4 "$artifact" 2>/dev/null | tr -d ' \n')"
            if [ "$magic" != "03022307" ] && [ "$magic" != "07230203" ]; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        metal)
            if ! grep -a -F "MTLB" "$artifact" >/dev/null 2>&1; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
    esac
    for symbol in "$@"; do
        if ! contains_symbol "$artifact" "$symbol"; then
            echo "invalid:missing-entry-symbol:$bytes"
            return
        fi
    done
    echo "valid:pass:$bytes"
}

emit_result() {
    target="$1"
    status="$2"
    reason="$3"
    bytes="$4"
    command_line="$5"
    artifact="$6"
    artifact_sha=""
    if [ -f "$artifact" ]; then
        artifact_sha="$(sha256_file "$artifact" || true)"
    fi
    case "$status" in
        compiled_artifact_verified|candidate_compiled)
            if [ "${#artifact_sha}" -ne 64 ]; then
                status="invalid"
                reason="artifact-sha256-unavailable"
            fi
            ;;
    esac
    candidate_compiled=false
    artifact_validated=false
    case "$status" in
        compiled_artifact_verified|candidate_compiled)
            candidate_compiled=true
            artifact_validated=true
            ;;
        invalid)
            if [ -s "$artifact" ]; then candidate_compiled=true; fi
            ;;
    esac
    {
        echo "${target}_status=$status"
        echo "${target}_reason=$reason"
        echo "${target}_bytes=$bytes"
        echo "${target}_artifact=$artifact"
        echo "${target}_artifact_sha256=$artifact_sha"
        echo "${target}_required_symbols=simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32 simple_2d_bitmap_glyph_raster_u32"
        echo "${target}_command=$command_line"
        echo "${target}_candidate_compiled=$candidate_compiled"
        echo "${target}_artifact_validated=$artifact_validated"
    } >>"$BUILD_DIR/evidence.env"
}

emit_font_result() {
    target="$1"
    status="$2"
    reason="$3"
    bytes="$4"
    command_line="$5"
    artifact="$6"
    pinned_verified="${7:-false}"
    expected_artifact_sha="${8:-}"
    artifact_sha=""
    required_symbols="simple_font_atlas_composite_v1_u32"
    if [ "$target" = "vulkan" ]; then
        required_symbols="main"
    fi
    if [ -f "$artifact" ]; then
        artifact_sha="$(sha256_file "$artifact" || true)"
    fi
    case "$status" in
        compiled_artifact_verified|candidate_compiled)
            if [ "${#artifact_sha}" -ne 64 ]; then
                status="invalid"
                reason="artifact-sha256-unavailable"
                pinned_verified=false
            elif ! font_artifact_evidence_matches "$expected_artifact_sha" "$artifact_sha"; then
                status="invalid"
                reason="artifact-changed-before-evidence"
                pinned_verified=false
            fi
            ;;
    esac
    candidate_compiled=false
    artifact_validated=false
    case "$status" in
        compiled_artifact_verified|candidate_compiled)
            candidate_compiled=true
            artifact_validated=true
            ;;
        invalid)
            if [ -s "$artifact" ]; then candidate_compiled=true; fi
            ;;
    esac
    if [ "$artifact_validated" != true ]; then
        pinned_verified=false
    fi
    if [ "$target" = vulkan ] && ! grep -q '^vulkan_font_validator_result=' "$BUILD_DIR/evidence.env"; then
        echo "vulkan_font_validator_result=not-run" >>"$BUILD_DIR/evidence.env"
    fi
    {
        echo "${target}_font_status=$status"
        echo "${target}_font_reason=$reason"
        echo "${target}_font_bytes=$bytes"
        echo "${target}_font_artifact=$artifact"
        echo "${target}_font_artifact_sha256=$artifact_sha"
        echo "${target}_font_required_symbols=$required_symbols"
        echo "${target}_font_command=$command_line"
        echo "${target}_font_candidate_compiled=$candidate_compiled"
        echo "${target}_font_artifact_validated=$artifact_validated"
        echo "${target}_font_pinned_verified=$pinned_verified"
    } >>"$BUILD_DIR/evidence.env"
}

run_cuda() {
    src="$BUILD_DIR/simple_2d_optimization.cu"
    out="$BUILD_DIR/simple_2d_optimization.ptx"
    font_src="$BUILD_DIR/simple_2d_optimization_font_atlas.cu"
    font_out="$BUILD_DIR/simple_2d_optimization_font_atlas.ptx"
    rm -f "$out" "$font_out"
    if ! write_generated_sources cuda "$src" "$font_src"; then
        fail_if_explicit_emitter_rejected "$BUILD_DIR/cuda_source.err"
        cmd="$(portable_compute_emitter_command cuda)"
        emit_result cuda generated_source_failed generated-source-failed 0 "$cmd" "$out"
        emit_font_result cuda generated_source_failed generated-source-failed 0 "$cmd" "$font_out"
        return
    fi
    cuda_compiler_provenance=true
    record_tool_provenance cuda compiler "$NVCC_TOOL" || cuda_compiler_provenance=false
    if ! have "$NVCC_TOOL"; then
        cmd="$NVCC_TOOL --ptx -arch=<auto> -o $out $src"
        emit_result cuda unavailable missing-primary-tool 0 "$cmd" "$out"
        emit_font_result cuda unavailable missing-primary-tool 0 "$NVCC_TOOL --ptx -arch=<auto> -o $font_out $font_src" "$font_out"
        return
    fi
    if [ "$cuda_compiler_provenance" != "true" ]; then
        cmd="$NVCC_TOOL --ptx -arch=<auto> -o $out $src"
        emit_result cuda unavailable missing-compiler-provenance 0 "$cmd" "$out"
        emit_font_result cuda unavailable missing-compiler-provenance 0 "$cmd" "$font_out"
        return
    fi
    cuda_arch="$CUDA_ARCH"
    if [ "$cuda_arch" = "" ]; then
        cuda_arch="$(run_with_timeout "$NVCC_TOOL" --list-gpu-arch 2>/dev/null | sed -n '1p')"
    fi
    if [ "$cuda_arch" = "" ]; then
        cmd="$NVCC_TOOL --ptx -arch=<auto> -o $out $src"
        emit_result cuda unavailable missing-cuda-arch 0 "$cmd" "$out"
        emit_font_result cuda unavailable missing-cuda-arch 0 "$NVCC_TOOL --ptx -arch=<auto> -o $font_out $font_src" "$font_out"
        return
    fi
    cmd="$NVCC_TOOL --ptx -arch=$cuda_arch -o $out $src"
    font_cmd="$NVCC_TOOL --ptx -arch=$cuda_arch -o $font_out $font_src"
    if rm -f "$out" "$BUILD_DIR/cuda.out" "$BUILD_DIR/cuda.err" &&
       run_with_timeout "$NVCC_TOOL" --ptx "-arch=$cuda_arch" -o "$out" "$src" >"$BUILD_DIR/cuda.out" 2>"$BUILD_DIR/cuda.err" &&
       rm -f "$font_out" "$BUILD_DIR/cuda_font.out" "$BUILD_DIR/cuda_font.err" &&
       run_with_timeout "$NVCC_TOOL" --ptx "-arch=$cuda_arch" -o "$font_out" "$font_src" >"$BUILD_DIR/cuda_font.out" 2>"$BUILD_DIR/cuda_font.err"; then
        IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact cuda "$out" simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32 simple_2d_bitmap_glyph_raster_u32)
EOF
        IFS=: read -r font_valid font_reason font_bytes <<EOF
$(status_for_artifact cuda "$font_out" simple_font_atlas_composite_v1_u32)
EOF
        font_artifact_sha="$(sha256_file "$font_out" || true)"
        cuda_font_pinned_equivalent=false
        if [ "$font_valid" = "valid" ] &&
           [ "$font_emitter_source_sha" = "$PINNED_CUDA_FONT_SOURCE_SHA256" ] &&
           [ "$font_emitter_version_sha" = "$PINNED_CUDA_FONT_VERSION_SHA256" ] &&
           [ "$font_artifact_sha" = "$PINNED_CUDA_FONT_ARTIFACT_SHA256" ]; then
            cuda_font_pinned_equivalent=true
        fi
        {
            echo "cuda_font_pinned_source_sha256=$PINNED_CUDA_FONT_SOURCE_SHA256"
            echo "cuda_font_pinned_version_sha256=$PINNED_CUDA_FONT_VERSION_SHA256"
            echo "cuda_font_pinned_artifact_sha256=$PINNED_CUDA_FONT_ARTIFACT_SHA256"
            echo "cuda_font_pinned_equivalent=$cuda_font_pinned_equivalent"
        } >>"$BUILD_DIR/evidence.env"
        if [ "$valid" = "valid" ]; then
            emit_result cuda compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out"
        else
            emit_result cuda invalid "$reason" "$bytes" "$cmd" "$out"
        fi
        if [ "$font_valid" != "valid" ]; then
            emit_font_result cuda "$font_valid" "$font_reason" "$font_bytes" "$font_cmd" "$font_out"
        elif [ "$cuda_font_pinned_equivalent" = true ]; then
            emit_font_result cuda compiled_artifact_verified "$font_reason" "$font_bytes" "$font_cmd" "$font_out" true
        else
            emit_font_result cuda candidate_compiled pinned-artifact-identity-mismatch "$font_bytes" "$font_cmd" "$font_out" false
        fi
    else
        emit_result cuda toolchain_failed "toolchain_failed" 0 "$cmd" "$out"
        emit_font_result cuda toolchain_failed "toolchain_failed" 0 "$font_cmd" "$font_out"
    fi
}

run_hip() {
