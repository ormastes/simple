}

run_metal() {
    src="$BUILD_DIR/simple_2d_optimization.metal"
    air="$BUILD_DIR/simple_2d_optimization.air"
    out="$BUILD_DIR/simple_2d_optimization.metallib"
    font_src="$BUILD_DIR/simple_2d_optimization_font_atlas.metal"
    font_air="$BUILD_DIR/simple_2d_optimization_font_atlas.air"
    font_out="$BUILD_DIR/simple_2d_optimization_font_atlas.metallib"
    rm -f "$air" "$out" "$font_air" "$font_out"
    if ! write_generated_sources metal "$src" "$font_src"; then
        fail_if_explicit_emitter_rejected "$BUILD_DIR/metal_source.err"
        cmd="$(portable_compute_emitter_command metal)"
        emit_result metal generated_source_failed generated-source-failed 0 "$cmd" "$out"
        emit_font_result metal generated_source_failed generated-source-failed 0 "$cmd" "$font_out"
        return
    fi
    cmd="$METAL_TOOL -c $src -o $air && $METALLIB_TOOL $air -o $out"
    font_cmd="$METAL_TOOL -c $font_src -o $font_air && $METALLIB_TOOL $font_air -o $font_out"
    metal_compiler_provenance=true
    record_tool_provenance metal compiler "$METAL_TOOL" || metal_compiler_provenance=false
    record_tool_provenance metal linker "$METALLIB_TOOL" || metal_compiler_provenance=false
    if ! have "$METAL_TOOL"; then
        emit_result metal unavailable missing-primary-tool 0 "$cmd" "$out"
        emit_font_result metal unavailable missing-primary-tool 0 "$font_cmd" "$font_out"
        return
    fi
    if ! have "$METALLIB_TOOL"; then
        emit_result metal unavailable missing-metallib-tool 0 "$cmd" "$out"
        emit_font_result metal unavailable missing-metallib-tool 0 "$font_cmd" "$font_out"
        return
    fi
    if [ "$metal_compiler_provenance" != "true" ]; then
        emit_result metal unavailable missing-compiler-provenance 0 "$cmd" "$out"
        emit_font_result metal unavailable missing-compiler-provenance 0 "$font_cmd" "$font_out"
        return
    fi
    if rm -f "$air" "$BUILD_DIR/metal.out" "$BUILD_DIR/metal.err" &&
       $METAL_TOOL -c "$src" -o "$air" >"$BUILD_DIR/metal.out" 2>"$BUILD_DIR/metal.err" &&
       rm -f "$out" &&
       $METALLIB_TOOL "$air" -o "$out" >>"$BUILD_DIR/metal.out" 2>>"$BUILD_DIR/metal.err" &&
       rm -f "$font_air" "$BUILD_DIR/metal_font.out" "$BUILD_DIR/metal_font.err" &&
       $METAL_TOOL -c "$font_src" -o "$font_air" >"$BUILD_DIR/metal_font.out" 2>"$BUILD_DIR/metal_font.err" &&
       rm -f "$font_out" &&
       $METALLIB_TOOL "$font_air" -o "$font_out" >>"$BUILD_DIR/metal_font.out" 2>>"$BUILD_DIR/metal_font.err"; then
        IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact metal "$out" simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32 simple_2d_bitmap_glyph_raster_u32)
EOF
        IFS=: read -r font_valid font_reason font_bytes <<EOF
$(status_for_artifact metal "$font_out" simple_font_atlas_composite_v1_u32)
EOF
        if [ "$valid" = "valid" ] && [ "$font_valid" = "valid" ]; then
            emit_result metal compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out"
            emit_font_result metal compiled_artifact_verified "$font_reason" "$font_bytes" "$font_cmd" "$font_out"
        else
            emit_result metal invalid "${reason};font=${font_reason}" "$bytes" "$cmd" "$out"
            emit_font_result metal "$font_valid" "$font_reason" "$font_bytes" "$font_cmd" "$font_out"
        fi
    else
        emit_result metal toolchain_failed "toolchain_failed" 0 "$cmd" "$out"
        emit_font_result metal toolchain_failed "toolchain_failed" 0 "$font_cmd" "$font_out"
    fi
}

run_vulkan_font() {
    src="$BUILD_DIR/simple_2d_optimization_font_atlas.comp"
    out="$BUILD_DIR/simple_2d_optimization_font_atlas.spv"
    out_repro="$BUILD_DIR/simple_2d_optimization_font_atlas.repro.spv"
    VULKAN_FONT_SOURCE_EQUIVALENT=false
    rm -f "$out" "$out_repro"
    if ! write_generated_vulkan_font_source "$src"; then
        fail_if_explicit_emitter_rejected "$BUILD_DIR/vulkan_font_source.err"
        cmd="$(portable_compute_emitter_command vulkan)"
        emit_font_result vulkan generated_source_failed generated-source-failed 0 "$cmd" "$out"
        return
    fi
    echo "vulkan_font_pinned_artifact_sha256=$PINNED_VULKAN_FONT_ARTIFACT_SHA256" >>"$BUILD_DIR/evidence.env"
    if have "$VULKAN_GLSLC_TOOL"; then
        if ! record_vulkan_glslc_library_provenance "$VULKAN_GLSLC_TOOL"; then
            emit_font_result vulkan unavailable "$VULKAN_GLSLC_PROVENANCE_STATUS" 0 "$VULKAN_GLSLC_TOOL --target-env=vulkan1.1 -fshader-stage=compute -o $out $src" "$out"
            return
        fi
        cmd="env -i HOME=$VULKAN_GLSLC_CLEAN_HOME PATH=/usr/bin:/bin:/usr/sbin:/sbin LC_ALL=C LD_LIBRARY_PATH=$VULKAN_GLSLC_LIBDIR LD_DEBUG=libs $VULKAN_GLSLC_EXEC_PATH --target-env=vulkan1.1 -fshader-stage=compute -o $out $src"
        rm -f "$out" "$out_repro" "$BUILD_DIR/vulkan_font.out" "$BUILD_DIR/vulkan_font_repro.out" \
            "$VULKAN_GLSLC_LOADER_LOG_A" "$VULKAN_GLSLC_LOADER_LOG_B"
        if ! run_vulkan_glslc_compile "$out" "$src" "$BUILD_DIR/vulkan_font.out" "$VULKAN_GLSLC_LOADER_LOG_A"; then
            VULKAN_GLSLC_PROVENANCE_STATUS=compile-a-failed
            write_vulkan_glslc_provenance_evidence || true
            emit_font_result vulkan toolchain_failed toolchain_failed 0 "$cmd" "$out"
            return
        fi
        if ! capture_vulkan_glslc_compile_provenance a "$VULKAN_GLSLC_LOADER_LOG_A"; then
            write_vulkan_glslc_provenance_evidence || true
            emit_font_result vulkan unavailable "$VULKAN_GLSLC_PROVENANCE_STATUS" 0 "$cmd" "$out"
            return
        fi
        if ! run_vulkan_glslc_compile "$out_repro" "$src" "$BUILD_DIR/vulkan_font_repro.out" "$VULKAN_GLSLC_LOADER_LOG_B"; then
            VULKAN_GLSLC_PROVENANCE_STATUS=compile-b-failed
            write_vulkan_glslc_provenance_evidence || true
            emit_font_result vulkan toolchain_failed toolchain_failed 0 "$cmd" "$out"
            return
        fi
        if ! capture_vulkan_glslc_compile_provenance b "$VULKAN_GLSLC_LOADER_LOG_B" ||
           ! finalize_vulkan_glslc_compile_provenance; then
            if [ "$VULKAN_GLSLC_LOADER_SHA_B" = "" ]; then
                write_vulkan_glslc_provenance_evidence || true
            fi
            emit_font_result vulkan unavailable "$VULKAN_GLSLC_PROVENANCE_STATUS" 0 "$cmd" "$out"
            return
        fi
    elif have "$VULKAN_GLSL_TOOL"; then
        record_tool_provenance vulkan_font compiler "$VULKAN_GLSL_TOOL" || true
        {
            echo "vulkan_font_compiler_library_expected_path="
            echo "vulkan_font_compiler_library_path="
            echo "vulkan_font_compiler_library_sha256="
            echo "vulkan_font_compiler_loader_log="
            echo "vulkan_font_compiler_loader_log_sha256="
            echo "vulkan_font_compiler_library_provenance_status=glslang-diagnostic-only"
        } >>"$BUILD_DIR/evidence.env"
        cmd="$VULKAN_GLSL_TOOL --target-env vulkan1.1 -V -S comp -o $out $src"
        emit_font_result vulkan unavailable glslang-diagnostic-only-missing-clean-loader-provenance 0 "$cmd" "$out"
        return
    else
        record_tool_provenance vulkan_font compiler "$VULKAN_GLSL_TOOL" || true
        record_tool_provenance vulkan_font fallback_compiler "$VULKAN_GLSLC_TOOL" || true
        cmd="$VULKAN_GLSL_TOOL --target-env vulkan1.1 -V -S comp -o $out $src"
        emit_font_result vulkan unavailable missing-primary-tool 0 "$cmd" "$out"
        return
    fi
    if ! have cmp; then
        echo "vulkan_font_compile_deterministic=false" >>"$BUILD_DIR/evidence.env"
        emit_font_result vulkan unavailable missing-byte-comparator "$(bytes_of "$out")" "$cmd" "$out" false
        return
    fi
    artifact_sha_a="$(sha256_file "$out" || true)"
    artifact_sha_b="$(sha256_file "$out_repro" || true)"
    compile_bytes_equal=false
    if cmp -s "$out" "$out_repro"; then
        compile_bytes_equal=true
    fi
    compile_deterministic=false
    if vulkan_artifact_tuple_deterministic "$artifact_sha_a" "$artifact_sha_b" "$compile_bytes_equal"; then
        compile_deterministic=true
    fi
    {
        echo "vulkan_font_repro_artifact=$out_repro"
        echo "vulkan_font_repro_artifact_sha256=$artifact_sha_b"
        echo "vulkan_font_repro_artifact_bytes=$(bytes_of "$out_repro")"
        echo "vulkan_font_compile_deterministic=$compile_deterministic"
    } >>"$BUILD_DIR/evidence.env"
    if [ "$compile_deterministic" != true ]; then
        emit_font_result vulkan invalid nondeterministic-compiler-output "$(bytes_of "$out")" "$cmd" "$out" false
        return
    fi
    IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact vulkan "$out" main)
EOF
    if [ "$valid" != "valid" ]; then
        emit_font_result vulkan invalid "$reason" "$bytes" "$cmd" "$out" false
        return
    fi
    artifact_sha_before_validation="$(sha256_file "$out" || true)"
    echo "vulkan_font_validated_input_sha256=$artifact_sha_before_validation" >>"$BUILD_DIR/evidence.env"
    if [ "$artifact_sha_before_validation" != "$artifact_sha_a" ]; then
        emit_font_result vulkan invalid artifact-changed-before-validation "$bytes" "$cmd" "$out" false
        return
    fi
    if ! have "$SPIRV_VAL_TOOL"; then
        record_tool_provenance vulkan_font validator "$SPIRV_VAL_TOOL" || true
        echo "vulkan_font_validator_result=missing-tool" >>"$BUILD_DIR/evidence.env"
        emit_font_result vulkan invalid missing-validator-tool "$bytes" "$cmd" "$out" false
        return
    fi
    if ! record_tool_provenance vulkan_font validator "$SPIRV_VAL_TOOL"; then
        echo "vulkan_font_validator_result=missing-provenance" >>"$BUILD_DIR/evidence.env"
        emit_font_result vulkan invalid missing-validator-provenance "$bytes" "$cmd" "$out" false
        return
    fi
    rm -f "$BUILD_DIR/vulkan_font_validator.out" "$BUILD_DIR/vulkan_font_validator.err"
    if ! run_with_timeout "$SPIRV_VAL_TOOL" --target-env vulkan1.1 "$out" >"$BUILD_DIR/vulkan_font_validator.out" 2>"$BUILD_DIR/vulkan_font_validator.err"; then
        echo "vulkan_font_validator_result=failed" >>"$BUILD_DIR/evidence.env"
        emit_font_result vulkan invalid validator-failed "$bytes" "$cmd" "$out" false
        return
    fi
    echo "vulkan_font_validator_result=pass" >>"$BUILD_DIR/evidence.env"
    artifact_sha="$(sha256_file "$out" || true)"
    echo "vulkan_font_final_artifact_sha256=$artifact_sha" >>"$BUILD_DIR/evidence.env"
    if [ "$artifact_sha" != "$artifact_sha_a" ]; then
        emit_font_result vulkan invalid artifact-changed-during-validation "$(bytes_of "$out")" "$cmd" "$out" false
        return
    fi
    vulkan_font_pinned_verified=false
    if [ "$artifact_sha" = "$PINNED_VULKAN_FONT_ARTIFACT_SHA256" ]; then
        echo "vulkan_font_artifact_equivalent=true" >>"$BUILD_DIR/evidence.env"
    else
        echo "vulkan_font_artifact_equivalent=false" >>"$BUILD_DIR/evidence.env"
        :
    fi
    if [ "$artifact_sha" = "$PINNED_VULKAN_FONT_ARTIFACT_SHA256" ] && [ "$VULKAN_FONT_SOURCE_EQUIVALENT" = true ]; then
        vulkan_font_pinned_verified=true
    fi
    if [ "$vulkan_font_pinned_verified" = true ]; then
        emit_font_result vulkan compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out" true "$artifact_sha"
    elif [ "$artifact_sha" != "$PINNED_VULKAN_FONT_ARTIFACT_SHA256" ]; then
        emit_font_result vulkan candidate_compiled pinned-artifact-hash-mismatch "$bytes" "$cmd" "$out" false "$artifact_sha"
    else
        emit_font_result vulkan candidate_compiled pinned-source-hash-mismatch "$bytes" "$cmd" "$out" false "$artifact_sha"
    fi
}

if [ "${1:-}" = "--explicit-emitter-self-test" ]; then
    self_build="$BUILD_DIR/explicit-emitter-self-test"
    self_report="$self_build/report.md"
    self_stderr="$self_build/stderr.log"
    mkdir -p "$self_build"
    if PORTABLE_COMPUTE_TARGETS=cuda \
        PORTABLE_COMPUTE_REQUIRE_VERIFIED=0 \
        PORTABLE_COMPUTE_EMITTER_BIN=/bin/true \
        BUILD_DIR="$self_build/run" \
        REPORT_PATH="$self_report" \
        sh "$ROOT_DIR/scripts/check/check-portable-compute-toolchains.shs" \
        >"$self_build/stdout.log" 2>"$self_stderr"; then
        echo "explicit cached emitter self-test accepted a non-emitter executable" >&2
        exit 1
    fi
    if ! grep -F "Explicit cached portable compute emitter failed protocol validation:" "$self_stderr" >/dev/null 2>&1; then
        echo "explicit cached emitter self-test missed the fail-closed diagnostic" >&2
        exit 1
    fi
    echo "explicit cached emitter self-test passed"
    exit 0
fi

rm -f "$BUILD_DIR/evidence.env"
{
    echo "portable_compute_targets=$PORTABLE_COMPUTE_TARGETS"
    echo "portable_compute_expected_semantics=$PORTABLE_COMPUTE_EXPECTED_SEMANTICS"
} >"$BUILD_DIR/evidence.env"
assert_evidence_parser_contract
record_portable_compute_emitter_provenance
if target_requested cuda; then run_cuda; fi
if target_requested hip; then run_hip; fi
if target_requested opencl; then run_opencl; fi
if target_requested metal; then run_metal; fi
if target_requested vulkan; then run_vulkan_font; fi

rm -f "$REPORT_PATH"
{
    echo "# Portable Compute Toolchain Evidence"
    echo
    echo "Date: $(date -u +%F)"
    echo
    echo "| Target | Kind | Status | Reason | Bytes | Artifact |"
    echo "|---|---|---|---|---:|---|"
    for target in cuda hip opencl metal; do
        if ! target_requested "$target"; then continue; fi
        status="$(field_of "${target}_status" "$BUILD_DIR/evidence.env")"
        reason="$(field_of "${target}_reason" "$BUILD_DIR/evidence.env")"
        bytes="$(field_of "${target}_bytes" "$BUILD_DIR/evidence.env")"
        artifact="$(field_of "${target}_artifact" "$BUILD_DIR/evidence.env")"
        font_status="$(field_of "${target}_font_status" "$BUILD_DIR/evidence.env")"
        font_reason="$(field_of "${target}_font_reason" "$BUILD_DIR/evidence.env")"
        font_bytes="$(field_of "${target}_font_bytes" "$BUILD_DIR/evidence.env")"
        font_artifact="$(field_of "${target}_font_artifact" "$BUILD_DIR/evidence.env")"
        echo "| $target | optimization | $status | $reason | $bytes | $artifact |"
        echo "| $target | font-atlas | $font_status | $font_reason | $font_bytes | $font_artifact |"
    done
    if target_requested vulkan; then
        vulkan_font_status="$(field_of vulkan_font_status "$BUILD_DIR/evidence.env")"
        vulkan_font_reason="$(field_of vulkan_font_reason "$BUILD_DIR/evidence.env")"
        vulkan_font_bytes="$(field_of vulkan_font_bytes "$BUILD_DIR/evidence.env")"
        vulkan_font_artifact="$(field_of vulkan_font_artifact "$BUILD_DIR/evidence.env")"
        echo "| vulkan | font-atlas | $vulkan_font_status | $vulkan_font_reason | $vulkan_font_bytes | $vulkan_font_artifact |"
    fi
    echo
    echo "## Commands"
    echo
    for target in cuda hip opencl metal; do
        if ! target_requested "$target"; then continue; fi
        emitter_command="$(field_of "${target}_emitter_command" "$BUILD_DIR/evidence.env")"
        command_line="$(field_of "${target}_command" "$BUILD_DIR/evidence.env")"
        font_command="$(field_of "${target}_font_command" "$BUILD_DIR/evidence.env")"
        echo "- $target source emitter: \`$emitter_command\`"
        echo "- $target optimization: \`$command_line\`"
        echo "- $target font-atlas: \`$font_command\`"
    done
    if target_requested vulkan; then
        vulkan_font_emitter_command="$(field_of vulkan_font_emitter_command "$BUILD_DIR/evidence.env")"
        vulkan_font_command="$(field_of vulkan_font_command "$BUILD_DIR/evidence.env")"
        echo "- vulkan font source emitter: \`$vulkan_font_emitter_command\`"
        echo "- vulkan font-atlas: \`$vulkan_font_command\`"
    fi
} >"$REPORT_PATH"

all_portable_compute_candidates_validated=true
all_portable_compute_pins_verified=true
for target in cuda hip opencl metal; do
    if ! target_requested "$target"; then continue; fi
    candidate_compiled="$(field_of "${target}_candidate_compiled" "$BUILD_DIR/evidence.env")"
    artifact_validated="$(field_of "${target}_artifact_validated" "$BUILD_DIR/evidence.env")"
    font_candidate_compiled="$(field_of "${target}_font_candidate_compiled" "$BUILD_DIR/evidence.env")"
    font_artifact_validated="$(field_of "${target}_font_artifact_validated" "$BUILD_DIR/evidence.env")"
    if [ "$candidate_compiled" != true ] || [ "$artifact_validated" != true ] ||
       [ "$font_candidate_compiled" != true ] || [ "$font_artifact_validated" != true ]; then
        all_portable_compute_candidates_validated=false
        all_portable_compute_pins_verified=false
    fi
    if [ "$target" = cuda ] && [ "$(field_of cuda_font_pinned_verified "$BUILD_DIR/evidence.env")" != true ]; then
        all_portable_compute_pins_verified=false
    fi
done
if target_requested vulkan; then
    if [ "$(field_of vulkan_font_candidate_compiled "$BUILD_DIR/evidence.env")" != true ] ||
       [ "$(field_of vulkan_font_artifact_validated "$BUILD_DIR/evidence.env")" != true ]; then
        all_portable_compute_candidates_validated=false
        all_portable_compute_pins_verified=false
    fi
    if [ "$(field_of vulkan_font_pinned_verified "$BUILD_DIR/evidence.env")" != true ]; then
        all_portable_compute_pins_verified=false
    fi
fi
{
    echo "all_portable_compute_candidates_validated=$all_portable_compute_candidates_validated"
    echo "all_portable_compute_pins_verified=$all_portable_compute_pins_verified"
    echo "all_portable_compute_toolchains_verified=$all_portable_compute_pins_verified"
} >>"$BUILD_DIR/evidence.env"
echo "all_portable_compute_candidates_validated=$all_portable_compute_candidates_validated"
echo "all_portable_compute_pins_verified=$all_portable_compute_pins_verified"
echo "all_portable_compute_toolchains_verified=$all_portable_compute_pins_verified"
echo "report_path=$REPORT_PATH"
cat "$BUILD_DIR/evidence.env"
if ! portable_compute_strict_result "$PORTABLE_COMPUTE_REQUIRE_VERIFIED" "$all_portable_compute_candidates_validated" "$all_portable_compute_pins_verified"; then
    echo "portable compute strict admission failed; inspect $BUILD_DIR/evidence.env" >&2
    exit 1
fi
