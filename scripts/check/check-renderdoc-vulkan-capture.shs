#!/usr/bin/env sh
# RenderDoc capture test of the Vulkan-backed GUI rendering.
#
# Runs src/app/test/renderdoc_vulkan_capture.spl under `renderdoccmd capture`.
# The program marks a frame with the RenderDoc in-application API
# (rt_renderdoc_start_capture / rt_renderdoc_end_capture, implemented in the
# interpreter via librenderdoc) around a real Vulkan-backed Engine2D frame, so a
# headless compute workload still produces a persisted .rdc capture file. The
# capture is then validated by its "RDOC" magic header.
#
# Requires: build/tools/renderdoc (renderdoccmd + librenderdoc.so), a
# Vulkan-capable host, and the interpreter binary built WITH the rt_renderdoc_*
# externs. Exits 0 on a valid capture; skips cleanly if RenderDoc is absent.
set -e

ROOT=$(cd "$(dirname "$0")/../.." && pwd)
cd "$ROOT"

RDDIR="$ROOT/build/tools/renderdoc"
RDC="$RDDIR/bin/renderdoccmd"
FRESH="$ROOT/src/compiler_rust/target/release/simple"
PROG="$ROOT/src/app/test/renderdoc_vulkan_capture.spl"
OUT=${RDVC_OUT:-/tmp/renderdoc_vulkan_capture}

if [ ! -x "$RDC" ]; then
  echo "SKIP: renderdoccmd not present at $RDC"
  exit 0
fi

# Build the interpreter binary carrying the rt_renderdoc_* externs (incremental;
# fast no-op when already up to date). This binary is used directly and does NOT
# replace the self-hosted bin/release/<triple>/simple.
echo "[1/3] Ensuring interpreter binary has rt_renderdoc_* externs..."
( cd "$ROOT/src/compiler_rust" \
  && unset MAKEFLAGS CARGO_MAKEFLAGS MFLAGS \
  && cargo build --release --bin simple >/dev/null 2>&1 )

if [ ! -x "$FRESH" ]; then
  echo "FAIL: interpreter binary not built at $FRESH"
  exit 1
fi

rm -rf "$OUT"; mkdir -p "$OUT"

echo "[2/3] Capturing a Vulkan-backed GUI frame through RenderDoc..."
LD_LIBRARY_PATH="$RDDIR/lib" SIMPLE_EXECUTION_MODE=interpret \
  "$RDC" capture -d "$ROOT" -c "$OUT/simple_gui" -w \
  "$FRESH" run "$PROG" 2>&1 | grep -aiE 'renderdoc_|backend=|VULKAN_UNAVAILABLE' || true

RDC_FILE=$(find "$OUT" -name '*.rdc' 2>/dev/null | head -1)
echo "[3/3] Validating capture..."
if [ -z "$RDC_FILE" ]; then
  echo "FAIL: no .rdc capture file was produced"
  exit 1
fi

MAGIC=$(dd if="$RDC_FILE" bs=4 count=1 2>/dev/null)
SIZE=$(wc -c < "$RDC_FILE")
if [ "$MAGIC" = "RDOC" ]; then
  echo "PASS: valid RenderDoc capture of the Vulkan-backed GUI frame"
  echo "      file=$RDC_FILE size=${SIZE}B magic=RDOC"
  exit 0
fi
echo "FAIL: $RDC_FILE is not a valid RenderDoc capture (magic='$MAGIC')"
exit 1
