#!/bin/sh
# Compatibility wrapper for the canonical RenderDoc evidence CLI.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

RDOC_OUTPUT_DIR="${RDVC_OUT:-${RDOC_OUTPUT_DIR:-build/renderdoc/vulkan-capture}}" \
    scripts/tool/renderdoc-evidence.shs capture-simple
