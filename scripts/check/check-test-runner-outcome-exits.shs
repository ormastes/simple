#!/bin/sh
set -eu

SIMPLE_BIN=${SIMPLE_BIN:-bin/simple}
ROOT="build/test-runner-outcome-exits.$$"
BATCH_ROOT=".simple/test-batches/outcome-exits-$$"
EMPTY_DIR="$ROOT/empty"
SLEEP_SPEC="$ROOT/timeout_spec.spl"
GREEN_SPEC="$ROOT/green_spec.spl"
MANIFEST="$BATCH_ROOT/contract.manifest"
RESULT="$BATCH_ROOT/contract.result"

cleanup() {
    rm -rf "$ROOT" "$BATCH_ROOT"
}
trap cleanup EXIT HUP INT TERM

mkdir -p "$EMPTY_DIR" "$BATCH_ROOT"

cat >"$SLEEP_SPEC" <<'EOF'
use std.spec.*
extern fn rt_thread_sleep(ms: i64)

describe "timeout outcome":
    it "exceeds the one-second runner deadline":
        rt_thread_sleep(2000)
        expect(1).to_equal(1)
EOF

cat >"$GREEN_SPEC" <<'EOF'
use std.spec.*

describe "internal outcome setup":
    it "passes before result persistence fails":
        expect(1).to_equal(1)
EOF

expect_exit() {
    expected=$1
    label=$2
    shift 2
    if "$@" >"$ROOT/$label.log" 2>&1; then
        actual=0
    else
        actual=$?
    fi
    if [ "$actual" -ne "$expected" ]; then
        echo "check-test-runner-outcome-exits: $label expected $expected, got $actual" >&2
        tail -n 40 "$ROOT/$label.log" >&2
        exit 1
    fi
}

expect_exit 4 empty timeout -k 2s 30s env SIMPLE_TEST_DEPTH=0 \
    "$SIMPLE_BIN" test "$EMPTY_DIR" --no-cache --no-db --no-session-daemon
grep -q "Outcome: empty_discovery" "$ROOT/empty.log"

expect_exit 124 timeout timeout -k 2s 30s env SIMPLE_TEST_DEPTH=0 \
    "$SIMPLE_BIN" test "$SLEEP_SPEC" --timeout=1 --no-cache --no-db --no-session-daemon --assert-ran
grep -q "Outcome: timeout_resource" "$ROOT/timeout.log"

printf '%s\n' "$GREEN_SPEC" >"$MANIFEST"
mkdir -p "$RESULT"
expect_exit 3 internal timeout -k 2s 30s env SIMPLE_TEST_DEPTH=0 \
    "$SIMPLE_BIN" test \
    "--batch-manifest=$MANIFEST" "--batch-result=$RESULT" \
    --no-cache --no-db --no-session-daemon

echo "check-test-runner-outcome-exits: PASS"
