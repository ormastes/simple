# Native SPipe regression: fail() in a return-valued helper must exit 1 before
# the compiler's default nil return can reach the field access below.

use std.spec.*

class FailFastValue:
    value: text

fn missing_value() -> FailFastValue:
    fail("deliberate return-valued helper failure")

describe "font evidence runner fail-fast helper":
    it "does not turn a failed helper into a nil-field trap":
        val missing = missing_value()
        expect(missing.value).to_equal("unreachable")
