#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

REPORT_PATH="${REPORT_PATH:-doc/09_report/simpleos_host_configuration_matrix_$(date -u +%F).md}"
SSH_EXEC="${SSH_EXEC:-build/os/x64-ssh-live.session-exec.txt}"

contains() {
    file="$1"
    needle="$2"
    [ -f "$file" ] && grep -Fq -- "$needle" "$file"
}

latest_gui_dir() {
    find build/tmp -maxdepth 1 -type d -name 'gui_entry_engine2d_wm_simple_web_spec_*' -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -1 | cut -d' ' -f2-
}

file_size() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

status_fpga_serial=fail
status_qemu_network_gui=fail
status_qemu_riscv64_network_ports=fail
status_qemu_riscv64_smf_gui_serial=missing
status_qemu_riscv64_display_smoke=missing
status_qemu_riscv64_wm_anchor=missing
status_qemu_riscv64_canonical_desktop=missing
status_qemu_riscv64_wm_live=missing
status_qemu_simpleos_wm_live=fail
status_fpga_network_capacity=planned
status_simpleos_host_launch=fail
status_wm_mode_policy=fail
reason_qemu_network_gui="RV64 network is represented; RV64 live WM framebuffer evidence is still missing"
reason_qemu_riscv64_wm="RV64 live WM framebuffer evidence is missing"
RV64_SMF_SERIAL_LOG="${RV64_SMF_SERIAL_LOG:-build/os/simpleos_riscv64_smf_fs.serial.log}"
RV64_DISPLAY_SMOKE_SERIAL_LOG="${RV64_DISPLAY_SMOKE_SERIAL_LOG:-build/os/rv64_display_smoke_evidence/serial.log}"
RV64_DISPLAY_SMOKE_PPM="${RV64_DISPLAY_SMOKE_PPM:-build/os/rv64_display_smoke_evidence/screendump.ppm}"
RV64_DISPLAY_SMOKE_REPORT="${RV64_DISPLAY_SMOKE_REPORT:-doc/09_report/rv64_display_smoke_qmp_evidence_$(date -u +%F).md}"
RV64_DISPLAY_SMOKE_CONTRACT_VERSION=0
RV64_DISPLAY_SMOKE_REPORT_SERIAL=
RV64_DISPLAY_SMOKE_REPORT_PPM=
RV64_DISPLAY_SMOKE_WIDTH=0
RV64_DISPLAY_SMOKE_HEIGHT=0
RV64_DISPLAY_SMOKE_STRIDE=0
RV64_DISPLAY_SMOKE_REVISION=0
RV64_DISPLAY_SMOKE_NONBLACK=0
RV64_DISPLAY_SMOKE_PALETTE=0
if [ -f "$RV64_DISPLAY_SMOKE_REPORT" ]; then
    RV64_DISPLAY_SMOKE_CONTRACT_VERSION="$(sed -n 's/^- contract_version: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_REPORT_SERIAL="$(sed -n 's/^- serial_log: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_REPORT_PPM="$(sed -n 's/^- screendump_ppm: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_WIDTH="$(sed -n 's/^- width: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_HEIGHT="$(sed -n 's/^- height: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_STRIDE="$(sed -n 's/^- stride: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_REVISION="$(sed -n 's/^- present_revision: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_NONBLACK="$(sed -n 's/^- nonblack: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    RV64_DISPLAY_SMOKE_PALETTE="$(sed -n 's/^- canonical_palette_witnesses: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
fi

GUI_DIR="$(latest_gui_dir)"
gui_mdi_ready=fail
if [ -n "$GUI_DIR" ] \
    && [ "$(file_size "$GUI_DIR/capture.ppm")" -eq 2359312 ] \
    && [ "$(file_size "$GUI_DIR/capture.ppm.raw")" -eq 3145728 ] \
    && contains "$GUI_DIR/capture.ppm.qmp_result.txt" "checks=[probe=True,header=True,bodyA=True,bodyB=True,top=True,taskbar=True]"; then
    gui_mdi_ready=pass
    status_qemu_simpleos_wm_live=pass
fi

if contains doc/07_guide/platform/simpleos/riscv_fpga_simpleos_guide.md "UART console | Required" \
    && contains doc/07_guide/platform/simpleos/riscv_fpga_simpleos_guide.md "Network stack | Not applicable" \
    && contains doc/07_guide/platform/simpleos/qemu_system_tests.md "Telnet-over-Serial Observation" \
    && contains doc/07_guide/platform/simpleos/qemu_system_tests.md "point \`QEMU_RX\`/\`SERIAL_PORT\` at a real tty"; then
    status_fpga_serial=pass
fi

if contains test/03_system/os/rv64_ssh_live_login_in_qemu_spec.spl "hostfwd=tcp::2222-:22" \
    && contains scripts/qemu/qemu_rv64_http_test.shs 'hostfwd=tcp::${HTTP_PORT}-:${HTTP_PORT}' \
    && contains scripts/qemu/qemu_rv64_http_test.shs "printf 'POST /db HTTP/1.0" \
    && contains test/03_system/os/simpleos_riscv_network_gate_spec.spl "GET /health (HTTP)... PASS (200)" \
    && contains scripts/qemu/qemu_rv64_http_test.shs "DB CREATE/INSERT/SELECT... "; then
    status_qemu_riscv64_network_ports=pass
fi

if [ "$status_qemu_riscv64_network_ports" = pass ] \
    && contains doc/09_report/gui_web_2d_linux_vulkan_refresh_2026-06-27.md "| \`gui_web_2d_vulkan_simple_backend_status\` | \`pass\` |" \
    && contains doc/09_report/gui_web_2d_linux_vulkan_refresh_2026-06-27.md "| \`gui_web_2d_vulkan_browser_backing_status\` | \`pass\` |" \
    && [ "$status_qemu_simpleos_wm_live" = pass ]; then
    status_qemu_network_gui=partial-rv64-wm-missing
fi

if contains "$RV64_SMF_SERIAL_LOG" "SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf" \
    && contains "$RV64_SMF_SERIAL_LOG" "NATIVE_GUI_PROCESS_RENDER_OK app=/sys/apps/browser_demo.smf" \
    && contains "$RV64_SMF_SERIAL_LOG" "SIMPLEOS_RISCV_SMF_FS_PASS" \
    && contains "$RV64_SMF_SERIAL_LOG" "TEST PASSED"; then
    status_qemu_riscv64_smf_gui_serial=pass
    reason_qemu_network_gui="RV64 network, RV64 SMF GUI serial launch, and x86_64 SimpleOS WM framebuffer are represented; RV64 live WM framebuffer capture is still missing"
    reason_qemu_riscv64_wm="RV64 SMF GUI serial proof exists, but no RV64 QMP/framebuffer capture proves live WM pixels"
fi

if [ "$RV64_DISPLAY_SMOKE_CONTRACT_VERSION" -eq 2 ] 2>/dev/null \
    && contains "$RV64_DISPLAY_SMOKE_REPORT" "- status: pass" \
    && contains "$RV64_DISPLAY_SMOKE_REPORT" "- reason: rv64-canonical-desktop-qmp-pass" \
    && contains "$RV64_DISPLAY_SMOKE_REPORT" "- ready: 1" \
    && contains "$RV64_DISPLAY_SMOKE_REPORT" "- lifecycle_markers: 1" \
    && [ "$RV64_DISPLAY_SMOKE_WIDTH" -gt 0 ] 2>/dev/null \
    && [ "$RV64_DISPLAY_SMOKE_HEIGHT" -gt 0 ] 2>/dev/null \
    && [ "$RV64_DISPLAY_SMOKE_STRIDE" -ge "$((RV64_DISPLAY_SMOKE_WIDTH * 4))" ] 2>/dev/null \
    && [ "$RV64_DISPLAY_SMOKE_REVISION" -gt 0 ] 2>/dev/null \
    && [ "$RV64_DISPLAY_SMOKE_NONBLACK" -gt 0 ] 2>/dev/null \
    && [ "$RV64_DISPLAY_SMOKE_PALETTE" -ge 4 ] 2>/dev/null \
    && [ "$RV64_DISPLAY_SMOKE_REPORT_SERIAL" = "$RV64_DISPLAY_SMOKE_SERIAL_LOG" ] \
    && [ "$RV64_DISPLAY_SMOKE_REPORT_PPM" = "$RV64_DISPLAY_SMOKE_PPM" ] \
    && contains "$RV64_DISPLAY_SMOKE_SERIAL_LOG" "[desktop-gui-riscv64] scanout-ready width=$RV64_DISPLAY_SMOKE_WIDTH height=$RV64_DISPLAY_SMOKE_HEIGHT stride=$RV64_DISPLAY_SMOKE_STRIDE" \
    && contains "$RV64_DISPLAY_SMOKE_SERIAL_LOG" "[desktop-gui] first-frame-rendered scene_revision=$RV64_DISPLAY_SMOKE_REVISION" \
    && contains "$RV64_DISPLAY_SMOKE_SERIAL_LOG" "[desktop-gui-riscv64] present-ok revision=$RV64_DISPLAY_SMOKE_REVISION" \
    && contains "$RV64_DISPLAY_SMOKE_SERIAL_LOG" "[desktop-gui-riscv64] desktop-ready revision=$RV64_DISPLAY_SMOKE_REVISION" \
    && contains "$RV64_DISPLAY_SMOKE_SERIAL_LOG" "TEST PASSED" \
    && contains "$RV64_DISPLAY_SMOKE_SERIAL_LOG" "SIMPLEOS_RISCV_DISPLAY_SMOKE_READY"; then
    status_qemu_riscv64_display_smoke=pass
    status_qemu_riscv64_canonical_desktop=pass
    status_qemu_riscv64_wm_live=pass
    reason_qemu_riscv64_wm="RV64 contract-v2 canonical Shared WM/Draw IR/Engine2D lifecycle and QMP palette evidence are present"
fi

if [ "$status_qemu_network_gui" = partial-rv64-wm-missing ] \
    && [ "$status_qemu_riscv64_wm_live" = pass ]; then
    status_qemu_network_gui=pass
    reason_qemu_network_gui="RV64 network, Vulkan-backed GUI evidence, x86_64 SimpleOS WM framebuffer, and RV64 canonical desktop QMP capture are represented"
fi

if contains doc/07_guide/platform/simpleos/riscv_fpga_simpleos_guide.md "Future Network-Capable FPGA Configuration" \
    && contains test/03_system/os/simpleos_riscv_network_gate_spec.spl "requires packet TX and RX readiness" \
    && contains scripts/qemu/qemu_rv64_http_test.shs "--with-db" \
    && contains scripts/qemu/qemu_rv64_http_test.shs "DB CREATE/INSERT/SELECT... "; then
    status_fpga_network_capacity=planned
else
    status_fpga_network_capacity=missing-plan
fi

if contains "$SSH_EXEC" "SESSION OK shell simple path=/usr/bin/simple alias=/SYS/APPS/SIMPLSTC.SMF" \
    && contains doc/07_guide/platform/simpleos/simpleos_dev_guide.md "SimpleOS, an additional cross-compilation step produces the seed" \
    && contains doc/07_guide/platform/simpleos/simpleos_dev_guide.md "Live guest toolchain proof"; then
    status_simpleos_host_launch=pass
fi

if contains doc/07_guide/platform/simpleos/simpleos_dev_guide.md "WM Host Mode Policy" \
    && contains scripts/check/check-wm-launch-capture-evidence.shs "host_wm_package_ready" \
    && contains scripts/check/check-wm-launch-capture-evidence.shs "simpleos_wm_package_ready"; then
    status_wm_mode_policy=pass
fi

overall=pass
for s in "$status_fpga_serial" "$status_qemu_network_gui" "$status_simpleos_host_launch" "$status_wm_mode_policy"; do
    if [ "$s" != pass ]; then
        overall=fail
    fi
done
if [ "$status_fpga_network_capacity" != planned ]; then
    overall=fail
fi

{
    echo "# SimpleOS Host Configuration Matrix"
    echo
    echo "- status: $overall"
    echo "- fpga_serial_only_config: $status_fpga_serial"
    echo "- qemu_network_gui_config: $status_qemu_network_gui"
    echo "- qemu_riscv64_network_ports: $status_qemu_riscv64_network_ports"
    echo "- qemu_riscv64_smf_gui_serial: $status_qemu_riscv64_smf_gui_serial"
    echo "- qemu_riscv64_display_smoke: $status_qemu_riscv64_display_smoke"
    echo "- qemu_riscv64_wm_anchor: $status_qemu_riscv64_wm_anchor"
    echo "- qemu_riscv64_canonical_desktop: $status_qemu_riscv64_canonical_desktop"
    echo "- qemu_riscv64_wm_live: $status_qemu_riscv64_wm_live"
    echo "- qemu_simpleos_wm_live: $status_qemu_simpleos_wm_live"
    echo "- fpga_network_capacity_config: $status_fpga_network_capacity"
    echo "- simpleos_host_launch_config: $status_simpleos_host_launch"
    echo "- wm_host_mode_policy: $status_wm_mode_policy"
    echo "- qemu_network_ports: ssh=2222->22, web/db covered by RISC-V HTTP/DBFS gate"
    echo "- qemu_gui_backend: Vulkan-backed host/browser evidence plus x86_64 SimpleOS QMP MDI framebuffer evidence"
    echo "- qemu_network_gui_reason: $reason_qemu_network_gui"
    echo "- qemu_riscv64_wm_reason: $reason_qemu_riscv64_wm"
    echo "- qemu_riscv64_wm_tracking: doc/08_tracking/bug/simpleos_rv64_wm_live_framebuffer_gate_2026-06-30.md"
    echo "- qemu_riscv64_smf_gui_serial_log: $RV64_SMF_SERIAL_LOG"
    echo "- qemu_riscv64_display_smoke_serial_log: $RV64_DISPLAY_SMOKE_SERIAL_LOG"
    echo "- qemu_riscv64_display_smoke_ppm: $RV64_DISPLAY_SMOKE_PPM"
    echo "- qemu_riscv64_display_smoke_report: $RV64_DISPLAY_SMOKE_REPORT"
    echo "- qemu_riscv64_display_smoke_contract_version: $RV64_DISPLAY_SMOKE_CONTRACT_VERSION"
    echo "- qemu_riscv64_display_smoke_stride: $RV64_DISPLAY_SMOKE_STRIDE"
    echo "- qemu_riscv64_display_smoke_present_revision: $RV64_DISPLAY_SMOKE_REVISION"
    echo "- qemu_riscv64_display_smoke_nonblack: $RV64_DISPLAY_SMOKE_NONBLACK"
    echo "- qemu_riscv64_display_smoke_canonical_palette_witnesses: $RV64_DISPLAY_SMOKE_PALETTE"
    echo "- qemu_riscv64_display_smoke_wrapper: scripts/check/check-rv64-display-smoke-qmp-evidence.shs"
    echo "- fpga_serial_transport: UART console, telnet/ssh-compatible serial bridge harness"
    echo "- fpga_network_capacity_reason: explicit future lane; not claimed as live silicon evidence"
    echo "- gui_entry_latest_dir: $GUI_DIR"
} >"$REPORT_PATH"

echo "simpleos_host_configuration_matrix_status=$overall"
echo "simpleos_host_configuration_fpga_serial_only_status=$status_fpga_serial"
echo "simpleos_host_configuration_qemu_network_gui_status=$status_qemu_network_gui"
echo "simpleos_host_configuration_qemu_riscv64_network_ports_status=$status_qemu_riscv64_network_ports"
echo "simpleos_host_configuration_qemu_riscv64_smf_gui_serial_status=$status_qemu_riscv64_smf_gui_serial"
echo "simpleos_host_configuration_qemu_riscv64_smf_gui_serial_log=$RV64_SMF_SERIAL_LOG"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_status=$status_qemu_riscv64_display_smoke"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_serial_log=$RV64_DISPLAY_SMOKE_SERIAL_LOG"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_ppm=$RV64_DISPLAY_SMOKE_PPM"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_report=$RV64_DISPLAY_SMOKE_REPORT"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_contract_version=$RV64_DISPLAY_SMOKE_CONTRACT_VERSION"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_stride=$RV64_DISPLAY_SMOKE_STRIDE"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_present_revision=$RV64_DISPLAY_SMOKE_REVISION"
echo "simpleos_host_configuration_qemu_riscv64_display_smoke_nonblack=$RV64_DISPLAY_SMOKE_NONBLACK"
echo "simpleos_host_configuration_qemu_riscv64_wm_anchor_status=$status_qemu_riscv64_wm_anchor"
echo "simpleos_host_configuration_qemu_riscv64_canonical_desktop_status=$status_qemu_riscv64_canonical_desktop"
echo "simpleos_host_configuration_qemu_riscv64_canonical_palette_witnesses=$RV64_DISPLAY_SMOKE_PALETTE"
echo "simpleos_host_configuration_qemu_riscv64_wm_live_status=$status_qemu_riscv64_wm_live"
echo "simpleos_host_configuration_qemu_riscv64_wm_live_reason=$reason_qemu_riscv64_wm"
echo "simpleos_host_configuration_qemu_simpleos_wm_live_status=$status_qemu_simpleos_wm_live"
echo "simpleos_host_configuration_fpga_network_capacity_status=$status_fpga_network_capacity"
echo "simpleos_host_configuration_simpleos_host_launch_status=$status_simpleos_host_launch"
echo "simpleos_host_configuration_wm_mode_policy_status=$status_wm_mode_policy"
echo "simpleos_host_configuration_report=$REPORT_PATH"

if [ "$overall" != pass ]; then
    exit 1
fi
