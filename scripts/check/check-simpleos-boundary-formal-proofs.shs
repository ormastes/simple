#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
CHECK_LEAN="$ROOT_DIR/scripts/check/check-lean-proofs.shs"

require_theorem() {
    file="$1"
    name="$2"
    if ! grep -Eq "^[[:space:]]*theorem[[:space:]]+$name([[:space:]]|:|\\(|$)" "$ROOT_DIR/$file"; then
        echo "FAIL: missing theorem $name in $file" >&2
        exit 1
    fi
}

sh "$CHECK_LEAN" --self-test >/dev/null
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/process_lifecycle" "verification/process_lifecycle"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/ffi_contract" "verification/ffi_contract"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/tls_isolation" "verification/tls_isolation"

require_theorem "src/verification/process_lifecycle/src/ProcessLifecycle.lean" "wait_returns_only_exited"
require_theorem "src/verification/process_lifecycle/src/ProcessLifecycle.lean" "wait_blocks_on_running"
require_theorem "src/verification/process_lifecycle/src/ProcessLifecycle.lean" "no_double_reap"
require_theorem "src/verification/process_lifecycle/src/ProcessLifecycle.lean" "reaped_terminal"
require_theorem "src/verification/process_lifecycle/src/ProcessLifecycle.lean" "no_zombie_persist_table"
require_theorem "src/verification/process_lifecycle/src/ProcessLifecycle.lean" "orphan_exited_reaped"
require_theorem "src/verification/ffi_contract/src/FfiContract.lean" "no_null_call"
require_theorem "src/verification/ffi_contract/src/FfiContract.lean" "undefined_rejects"
require_theorem "src/verification/ffi_contract/src/FfiContract.lean" "no_double_untag"
require_theorem "src/verification/ffi_contract/src/FfiContract.lean" "unbox_result_not_reboxable"
require_theorem "src/verification/ffi_contract/src/FfiContract.lean" "int_never_heap"
require_theorem "src/verification/tls_isolation/src/TlsIsolation.lean" "tls_read_own"
require_theorem "src/verification/tls_isolation/src/TlsIsolation.lean" "tls_thread_isolated"
require_theorem "src/verification/tls_isolation/src/TlsIsolation.lean" "tls_key_isolated"
require_theorem "src/verification/tls_isolation/src/TlsIsolation.lean" "tls_writes_commute"

echo "STATUS: PASS simpleos-boundary-formal-proofs"
