#!/usr/bin/env sh
set -eu

missing=
add_missing() {
    if [ -z "$missing" ]; then
        missing="$1"
    else
        missing="$missing,$1"
    fi
}

command -v sby >/dev/null 2>&1 || add_missing sby
command -v yosys >/dev/null 2>&1 || add_missing yosys
command -v boolector >/dev/null 2>&1 || command -v z3 >/dev/null 2>&1 || add_missing smt-solver

if [ -z "$missing" ]; then
    echo "simpleos_mission_critical_prereqs_status=ready"
    echo "simpleos_mission_critical_prereqs_missing=none"
    echo "STATUS: PASS simpleos-mission-critical-prereqs"
    exit 0
fi

echo "simpleos_mission_critical_prereqs_status=blocked"
echo "simpleos_mission_critical_prereqs_missing=$missing"
echo "simpleos_mission_critical_prereqs_next_action=install SymbiYosys stack, then rerun scripts/check/check-simpleos-mission-critical-release.shs"
echo "STATUS: FAIL simpleos-mission-critical-prereqs missing=$missing" >&2
exit 1
