#!/bin/sh
# Validate existing production GUI/web renderer parity evidence without launching
# Electron, Chrome, Tauri, or GPU checks.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/production_gui_web_renderer_parity_gate}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_web_renderer_parity_gate_$(date -u +%F).md}"
SOURCE_ENV="${PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV:-build/production_gui_web_renderer_parity_evidence/evidence.env}"
OUT_ENV="$BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH"

value_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" 2>/dev/null | tail -n 1
}

write_evidence() {
    status="$1"
    reason="$2"
    {
        echo "production_gui_web_renderer_parity_gate_status=$status"
        echo "production_gui_web_renderer_parity_gate_reason=$reason"
        echo "production_gui_web_renderer_parity_gate_source_env=$SOURCE_ENV"
        echo "production_gui_web_renderer_parity_gate_source_status=${source_status:-}"
        echo "production_gui_web_renderer_parity_gate_source_reason=${source_reason:-}"
        echo "production_gui_web_renderer_parity_gate_matrix_status=${matrix_status:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_status=${layout_status:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_case_count=${layout_count:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_pass_count=${layout_pass:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_tracked_count=${layout_tracked:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_fail_count=${layout_fail:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_status=${surface_status:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_electron_capture_status=${surface_electron_status:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_capture_status=${surface_tauri_status:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_capture_status=${surface_chrome_status:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_live_capture=${surface_tauri_live:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_live_capture=${surface_chrome_live:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_case_count=${surface_tauri_count:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_pass_count=${surface_tauri_pass:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_tracked_count=${surface_tauri_tracked:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_fail_count=${surface_tauri_fail:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_case_count=${surface_chrome_count:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_pass_count=${surface_chrome_pass:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_tracked_count=${surface_chrome_tracked:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_fail_count=${surface_chrome_fail:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_tauri_mismatch_count=${surface_tauri_mismatch:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_chrome_mismatch_count=${surface_chrome_mismatch:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_no_fake_capture=${surface_no_fake:-}"
        echo "production_gui_web_renderer_parity_gate_surface_manifest_blur_or_tolerance_used=${surface_tolerance:-}"
        echo "production_gui_web_renderer_parity_gate_backend_status=${backend_status:-}"
        echo "production_gui_web_renderer_parity_gate_font_offload_status=${font_status:-}"
        echo "production_gui_web_renderer_parity_gate_metal_readback_status=${metal_status:-}"
        echo "production_gui_web_renderer_parity_gate_required_source_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_matrix_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_layout_manifest_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_layout_manifest_case_count=50"
        echo "production_gui_web_renderer_parity_gate_required_layout_manifest_pass_count=36"
        echo "production_gui_web_renderer_parity_gate_required_layout_manifest_tracked_count=14"
        echo "production_gui_web_renderer_parity_gate_required_layout_manifest_fail_count=0"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_electron_capture_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_capture_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_capture_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_live_capture=true"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_live_capture=true"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_case_count=50"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_pass_count=36"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_tracked_count=14"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_fail_count=0"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_case_count=50"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_pass_count=36"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_tracked_count=14"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_fail_count=0"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_mismatch_count=0"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_mismatch_count=0"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_no_fake_capture=true"
        echo "production_gui_web_renderer_parity_gate_required_surface_manifest_blur_or_tolerance_used=false"
        echo "production_gui_web_renderer_parity_gate_required_backend_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_font_offload_status=pass"
        echo "production_gui_web_renderer_parity_gate_required_metal_readback_status=pass"
    } >"$OUT_ENV"
    {
        echo "# Production GUI Web Renderer Parity Gate"
        echo
        echo "- status: $status"
        echo "- reason: $reason"
        echo "- source evidence: $SOURCE_ENV"
        echo "- source status: ${source_status:-}"
        echo "- source reason: ${source_reason:-}"
        echo "- matrix: ${matrix_status:-}"
        echo "- layout manifest: ${layout_status:-} (${layout_pass:-}/${layout_count:-} pass, ${layout_tracked:-} tracked, ${layout_fail:-} fail)"
        echo "- surface manifest: ${surface_status:-} (Tauri ${surface_tauri_pass:-}/${surface_tauri_count:-} pass, ${surface_tauri_tracked:-} tracked, ${surface_tauri_fail:-} fail; Chrome ${surface_chrome_pass:-}/${surface_chrome_count:-} pass, ${surface_chrome_tracked:-} tracked, ${surface_chrome_fail:-} fail)"
        echo "- live captures: Tauri ${surface_tauri_live:-}, Chrome ${surface_chrome_live:-}; no fake capture: ${surface_no_fake:-}; blur/tolerance: ${surface_tolerance:-}"
        echo "- backend parity: ${backend_status:-}"
        echo "- font offload/readback: ${font_status:-}"
        echo "- raw Metal framebuffer readback: ${metal_status:-}"
        echo
        echo "## Raw Evidence"
        sed 's/^/- /' "$OUT_ENV"
    } >"$REPORT_PATH"
    cat "$OUT_ENV"
}

if [ ! -s "$SOURCE_ENV" ]; then
    source_status=""
    source_reason="missing-production-parity-evidence"
    matrix_status=""
    layout_status=""
    layout_count=""
    layout_pass=""
    layout_tracked=""
    layout_fail=""
    surface_status=""
    surface_electron_status=""
    surface_tauri_status=""
    surface_chrome_status=""
    surface_tauri_live=""
    surface_chrome_live=""
    surface_tauri_count=""
    surface_tauri_pass=""
    surface_tauri_tracked=""
    surface_tauri_fail=""
    surface_chrome_count=""
    surface_chrome_pass=""
    surface_chrome_tracked=""
    surface_chrome_fail=""
    surface_tauri_mismatch=""
    surface_chrome_mismatch=""
    surface_no_fake=""
    surface_tolerance=""
    backend_status=""
    font_status=""
    metal_status=""
    write_evidence "unavailable" "missing-production-parity-evidence"
    exit 1
fi

source_status="$(value_of production_gui_web_renderer_parity_status "$SOURCE_ENV")"
source_reason="$(value_of production_gui_web_renderer_parity_reason "$SOURCE_ENV")"
matrix_status="$(value_of production_gui_web_renderer_parity_matrix_status "$SOURCE_ENV")"
layout_status="$(value_of production_gui_web_renderer_parity_layout_manifest_status "$SOURCE_ENV")"
layout_count="$(value_of production_gui_web_renderer_parity_layout_manifest_case_count "$SOURCE_ENV")"
layout_pass="$(value_of production_gui_web_renderer_parity_layout_manifest_pass_count "$SOURCE_ENV")"
layout_tracked="$(value_of production_gui_web_renderer_parity_layout_manifest_tracked_count "$SOURCE_ENV")"
layout_fail="$(value_of production_gui_web_renderer_parity_layout_manifest_fail_count "$SOURCE_ENV")"
surface_status="$(value_of production_gui_web_renderer_parity_surface_manifest_status "$SOURCE_ENV")"
surface_electron_status="$(value_of production_gui_web_renderer_parity_surface_manifest_electron_capture_status "$SOURCE_ENV")"
surface_tauri_status="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_capture_status "$SOURCE_ENV")"
surface_chrome_status="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_capture_status "$SOURCE_ENV")"
surface_tauri_live="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_live_capture "$SOURCE_ENV")"
surface_chrome_live="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_live_capture "$SOURCE_ENV")"
surface_tauri_count="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_case_count "$SOURCE_ENV")"
surface_tauri_pass="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_pass_count "$SOURCE_ENV")"
surface_tauri_tracked="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_tracked_count "$SOURCE_ENV")"
surface_tauri_fail="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_fail_count "$SOURCE_ENV")"
surface_chrome_count="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_case_count "$SOURCE_ENV")"
surface_chrome_pass="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_pass_count "$SOURCE_ENV")"
surface_chrome_tracked="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_tracked_count "$SOURCE_ENV")"
surface_chrome_fail="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_fail_count "$SOURCE_ENV")"
surface_tauri_mismatch="$(value_of production_gui_web_renderer_parity_surface_manifest_tauri_mismatch_count "$SOURCE_ENV")"
surface_chrome_mismatch="$(value_of production_gui_web_renderer_parity_surface_manifest_chrome_mismatch_count "$SOURCE_ENV")"
surface_no_fake="$(value_of production_gui_web_renderer_parity_surface_manifest_no_fake_capture "$SOURCE_ENV")"
surface_tolerance="$(value_of production_gui_web_renderer_parity_surface_manifest_blur_or_tolerance_used "$SOURCE_ENV")"
backend_status="$(value_of production_gui_web_renderer_parity_backend_status "$SOURCE_ENV")"
font_status="$(value_of production_gui_web_renderer_parity_font_offload_status "$SOURCE_ENV")"
metal_status="$(value_of production_gui_web_renderer_parity_metal_readback_status "$SOURCE_ENV")"

if [ "$source_status" != "pass" ]; then
    write_evidence "fail" "${source_reason:-production-parity-not-pass}"
elif [ "$matrix_status" != "pass" ]; then
    write_evidence "fail" "matrix-not-pass"
elif [ "$layout_status" != "pass" ]; then
    write_evidence "fail" "layout-manifest-not-pass"
elif [ "$layout_count" != "50" ] || [ "$layout_pass" != "36" ] || [ "$layout_tracked" != "14" ] || [ "$layout_fail" != "0" ]; then
    write_evidence "fail" "layout-manifest-count-mismatch"
elif [ "$surface_status" != "pass" ]; then
    write_evidence "fail" "surface-manifest-not-pass"
elif [ "$surface_electron_status" != "pass" ] || [ "$surface_tauri_status" != "pass" ] || [ "$surface_chrome_status" != "pass" ]; then
    write_evidence "fail" "surface-manifest-capture-not-pass"
elif [ "$surface_tauri_live" != "true" ] || [ "$surface_chrome_live" != "true" ]; then
    write_evidence "fail" "surface-manifest-live-capture-missing"
elif [ "$surface_tauri_count" != "50" ] || [ "$surface_tauri_pass" != "36" ] || [ "$surface_tauri_tracked" != "14" ] || [ "$surface_tauri_fail" != "0" ] || \
    [ "$surface_chrome_count" != "50" ] || [ "$surface_chrome_pass" != "36" ] || [ "$surface_chrome_tracked" != "14" ] || [ "$surface_chrome_fail" != "0" ]; then
    write_evidence "fail" "surface-manifest-count-mismatch"
elif [ "$surface_tauri_mismatch" != "0" ] || [ "$surface_chrome_mismatch" != "0" ]; then
    write_evidence "fail" "surface-manifest-mismatch-count-nonzero"
elif [ "$surface_no_fake" != "true" ] || [ "$surface_tolerance" != "false" ]; then
    write_evidence "fail" "surface-manifest-fake-or-tolerance-used"
elif [ "$backend_status" != "pass" ]; then
    write_evidence "fail" "backend-parity-not-pass"
elif [ "$font_status" != "pass" ]; then
    write_evidence "fail" "font-offload-not-pass"
elif [ "$metal_status" != "pass" ]; then
    write_evidence "fail" "metal-readback-not-pass"
else
    write_evidence "pass" "pass"
    exit 0
fi
exit 1
