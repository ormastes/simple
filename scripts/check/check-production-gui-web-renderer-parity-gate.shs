        echo "production_gui_web_renderer_parity_gate_required_event_routing_min_title_input_width_px=142"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_title_input_height=24px"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_title_input_cursor=text"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_title_input_background=rgb(241, 245, 249)"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_close_button_background=rgb(239, 68, 68)"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_minimize_button_background=rgb(234, 179, 8)"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_maximize_button_background=rgb(34, 197, 94)"
        echo "production_gui_web_renderer_parity_gate_required_event_routing_blur_or_tolerance_used=false"
    } >"$OUT_ENV"
    {
        echo "# Production GUI Web Renderer Parity Gate"
        echo
        echo "- status: $status"
        echo "- reason: $reason"
        echo "- source evidence: $SOURCE_ENV"
        echo "- source status: ${source_status:-}"
        echo "- source reason: ${source_reason:-}"
        echo "- matrix: ${matrix_status:-} (${matrix_reason:-}; timed out: ${matrix_timed_out:-})"
        echo "- layout manifest: ${layout_status:-} (${layout_reason:-}; timed out: ${layout_timed_out:-}; ${layout_pass:-}/${layout_count:-} pass, ${layout_tracked:-} tracked, ${layout_fail:-} fail)"
        echo "- surface manifest: ${surface_status:-} (${surface_reason:-}; timed out: ${surface_timed_out:-}; Tauri ${surface_tauri_pass:-}/${surface_tauri_count:-} pass, ${surface_tauri_tracked:-} tracked, ${surface_tauri_fail:-} fail; Chrome ${surface_chrome_pass:-}/${surface_chrome_count:-} pass, ${surface_chrome_tracked:-} tracked, ${surface_chrome_fail:-} fail)"
        echo "- surface host: ${surface_host_uname_s:-}/${surface_host_uname_m:-}"
        echo "- Tauri surface capture backend: ${surface_tauri_backend:-}; missing commands: ${surface_tauri_missing_commands:-}; reason: ${surface_tauri_reason:-}"
        echo "- Chrome surface capture backend: ${surface_chrome_backend:-}; reason: ${surface_chrome_reason:-}"
        echo "- live captures: Tauri ${surface_tauri_live:-}, Chrome ${surface_chrome_live:-}; no fake capture: ${surface_no_fake:-}; blur/tolerance: ${surface_tolerance:-}"
        echo "- backend parity: ${backend_status:-}"
        echo "- backend timing: ${backend_timing_status:-} (${backend_sample_count:-} samples; elapsed us min/avg/max ${backend_elapsed_min:-}/${backend_elapsed_avg:-}/${backend_elapsed_max:-}; pixels/sec min/avg/max ${backend_throughput_min:-}/${backend_throughput_avg:-}/${backend_throughput_max:-})"
        echo "- font offload/readback: ${font_status:-}"
        echo "- raw Metal framebuffer readback: ${metal_status:-}"
        echo "- Electron event routing: ${event_status:-}"
        echo "- Electron event proof source: ${event_proof_source_file_status:-} / ${event_proof_source_file_reason:-} / ${event_proof_source_artifact_status:-}; source ${event_proof_source:-}"
        echo "- Electron browser runtime: engine=${event_browser_engine:-} electron=${event_electron_process_version:-} chrome=${event_chrome_process_version:-}"
        echo "- Electron event counts: focus=${event_focus_count:-} move=${event_move_count:-} maximize=${event_maximize_count:-} title_command=${event_title_command_count:-} text_input=${event_text_input_count:-} pointer=${event_pointer_down_count:-}/${event_pointer_up_count:-}"
        echo "- Electron event performance/animation: perf=${event_performance_now_available:-} delta_ms=${event_performance_now_delta_ms:-} input_to_paint_ms=${event_input_to_paint_ms:-} animation=${event_animation_frame_available:-} frames=${event_animation_frame_count:-} css=${event_css_animation_probe:-}"
        echo "- Electron event sequence: ${event_sequence:-}"
        echo "- Electron event UI target: title=${event_title_text:-}/${event_title_context_text:-} traffic=${event_traffic_button_count:-} input=${event_title_input_tag:-} titlebar=${event_titlebar_height:-}/${event_titlebar_display:-}/${event_titlebar_cursor:-} input_width_px=${event_title_input_width_px:-}"
        echo "- Electron event payload: move=${event_move_payload_x:-},${event_move_payload_y:-} expected=${event_expected_move_x:-},${event_expected_move_y:-} source=${event_move_payload_source:-} window=${event_move_payload_window_id_hint:-} title_command=${event_title_command_text:-} text_input=${event_text_input_text:-}"
        echo
        echo "## Raw Evidence"
        sed 's/^/- /' "$OUT_ENV"
    } >"$REPORT_PATH"
    cat "$OUT_ENV"
}

