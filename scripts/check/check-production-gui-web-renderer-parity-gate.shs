if [ "$source_status" = "" ] && grep -q '^production_gui_web_renderer_parity_' "$SOURCE_ENV" 2>/dev/null; then
    source_partial_status="partial"
    source_partial_reason="missing-top-level-production-parity-status"
fi

if [ "$source_status" = "" ]; then
    if [ "$source_partial_status" = "partial" ]; then
        write_evidence "fail" "partial-production-parity-source-status"
    else
        write_evidence "fail" "${source_reason:-missing-production-parity-source-status}"
    fi
elif [ "$source_status" != "pass" ]; then
    write_evidence "fail" "${source_reason:-production-parity-not-pass}"
elif [ -z "${source_env_age_hours:-}" ]; then
    write_evidence "fail" "production-parity-evidence-mtime-unreadable"
elif [ "$source_env_age_hours" -gt "$MAX_EVIDENCE_AGE_HOURS" ] 2>/dev/null; then
    write_evidence "fail" "stale-production-parity-evidence-${source_env_age_hours}h-exceeds-${MAX_EVIDENCE_AGE_HOURS}h"
elif [ "$matrix_status" != "pass" ]; then
    write_evidence "fail" "matrix-not-pass"
elif [ "$layout_status" != "pass" ]; then
    write_evidence "fail" "layout-manifest-not-pass"
elif [ "$layout_count" != "50" ] || [ "$layout_pass" != "36" ] || [ "$layout_tracked" != "14" ] || [ "$layout_fail" != "0" ]; then
    write_evidence "fail" "layout-manifest-count-mismatch"
elif [ "$surface_status" != "pass" ]; then
    write_evidence "fail" "surface-manifest-not-pass"
elif [ "$surface_electron_status" != "pass" ] || [ "$surface_tauri_status" != "pass" ] || [ "$surface_chrome_status" != "pass" ]; then
    write_evidence "fail" "surface-manifest-capture-not-pass"
elif [ "$surface_tauri_backend" = "" ] || [ "$surface_tauri_required_commands" = "" ] || [ "$surface_chrome_backend" = "" ]; then
    write_evidence "fail" "surface-manifest-capture-provenance-missing"
elif [ "$surface_tauri_missing_commands" != "" ]; then
    write_evidence "fail" "surface-manifest-required-commands-missing"
elif [ "$surface_tauri_live" != "true" ] || [ "$surface_chrome_live" != "true" ]; then
    write_evidence "fail" "surface-manifest-live-capture-missing"
elif [ "$surface_tauri_count" != "50" ] || [ "$surface_tauri_pass" != "36" ] || [ "$surface_tauri_tracked" != "14" ] || [ "$surface_tauri_fail" != "0" ] || \
    [ "$surface_chrome_count" != "50" ] || [ "$surface_chrome_pass" != "36" ] || [ "$surface_chrome_tracked" != "14" ] || [ "$surface_chrome_fail" != "0" ]; then
    write_evidence "fail" "surface-manifest-count-mismatch"
elif [ "$surface_tauri_mismatch" != "0" ] || [ "$surface_chrome_mismatch" != "0" ]; then
    write_evidence "fail" "surface-manifest-mismatch-count-nonzero"
elif [ "$surface_no_fake" != "true" ] || [ "$surface_tolerance" != "false" ]; then
    write_evidence "fail" "surface-manifest-fake-or-tolerance-used"
elif [ "$backend_status" != "pass" ]; then
    write_evidence "fail" "backend-parity-not-pass"
elif [ "$backend_exact" != "true" ] || [ "$backend_cpu_diff" != "0" ] || [ "$backend_metal_diff" != "0" ] || \
    [ "$backend_checksum_match" != "true" ] || [ "$backend_same_frame_readback" != "true" ] || [ "$backend_readback_source" != "device_readback" ] || \
    ! num_positive "$backend_software_checksum" || ! num_positive "$backend_cpu_simd_checksum" || ! num_positive "$backend_metal_checksum" || \
    [ "$backend_software_checksum" != "$backend_cpu_simd_checksum" ] || [ "$backend_software_checksum" != "$backend_metal_checksum" ] || \
    { [ "$backend_metal_resolved" = "metal" ] && { [ "$backend_metal_frame" != "true" ] || ! num_at_least "$backend_metal_command_queue_handle" 1; }; } || \
    [ "$backend_tolerance" != "false" ]; then
    write_evidence "fail" "backend-parity-contract-missing"
elif [ "$backend_metal_resolved" = "metal" ] && { ! num_positive "$backend_metal_gpu_checksum" || [ "$backend_software_checksum" != "$backend_metal_gpu_checksum" ]; }; then
    write_evidence "fail" "backend-parity-contract-missing"
elif [ "$backend_timing_status" != "pass" ] || ! num_at_least "$backend_sample_count" 1 || \
    ! num_positive "$backend_elapsed_min" || ! num_positive "$backend_elapsed_avg" || ! num_positive "$backend_elapsed_max" || \
    ! num_positive "$backend_throughput_min" || ! num_positive "$backend_throughput_avg" || ! num_positive "$backend_throughput_max"; then
    write_evidence "fail" "backend-timing-evidence-failed"
elif [ "$font_status" != "pass" ]; then
    write_evidence "fail" "font-offload-not-pass"
elif [ "$font_runtime_evidence_status" != "pass" ]; then
    write_evidence "fail" "font-offload-runtime-evidence-missing"
elif [ "$metal_status" != "pass" ] && [ "$metal_reason" != "metal-requires-macos" ]; then
    write_evidence "fail" "metal-readback-not-pass"
elif [ "$metal_status" = "pass" ] && { [ "$metal_spec_status" != "pass" ] || [ "$metal_available" != "true" ]; }; then
    write_evidence "fail" "metal-readback-contract-missing"
elif [ "$metal_tolerance" != "false" ]; then
    write_evidence "fail" "metal-readback-contract-missing"
elif [ "$metal_status" = "pass" ] && [ "$metal_log_status" != "" ] && { [ "$metal_log_status" != "pass" ] || [ "$metal_log_required_api" != "metal" ] || \
    [ "$metal_log_metal_readback_status" != "pass" ] || [ "$metal_log_generated_gate" != "pass" ] || \
    [ "$metal_log_framebuffer_gate" != "pass" ] || [ "$metal_log_browser_gate" != "pass" ] || \
    [ "$metal_log_pairwise_gate" != "pass" ] || [ "$metal_log_argb_source_gate" != "pass" ] || \
    { [ "$metal_log_gpu_capture_gate" != "pass" ] && [ "$metal_log_gpu_capture_gate" != "not-required" ]; } || \
    [ "$metal_log_blocked_gate_count" != "0" ] || [ "$metal_log_pairwise_status" != "pass" ]; }; then
    write_evidence "fail" "metal-render-log-contract-missing"
elif [ "$event_status" != "pass" ]; then
    write_evidence "fail" "event-routing-not-pass"
elif [ "$event_validation_status" != "pass" ]; then
    write_evidence "fail" "event-routing-validation-not-pass"
elif [ "$event_proof_symlink_status" != "pass" ]; then
    write_evidence "fail" "event-routing-proof-symlink-status-not-pass"
elif [ "$event_proof_source" != "tools/web-render-backend/wm_event_check.js" ]; then
    write_evidence "fail" "event-routing-proof-source-missing"
elif [ "$event_proof_source_file_status" != "pass" ] || ! num_positive "$event_proof_source_size_bytes"; then
    write_evidence "fail" "event-routing-proof-source-file-missing"
elif [ "$event_proof_source_file_reason" != "pass" ] || [ "$event_proof_source_artifact_status" != "pass" ]; then
    case "$event_proof_source_file_reason" in
        symlink) write_evidence "fail" "event-routing-proof-source-symlink" ;;
        hardlink) write_evidence "fail" "event-routing-proof-source-hardlink" ;;
        size-mismatch) write_evidence "fail" "event-routing-proof-source-size-mismatch" ;;
        *) write_evidence "fail" "event-routing-proof-source-artifact-missing" ;;
    esac
elif [ "$event_proof_source_actual_size_bytes" != "$event_proof_source_size_bytes" ]; then
    write_evidence "fail" "event-routing-proof-source-size-mismatch"
elif [ "$event_browser_engine" != "chromium" ] || \
    ! matches_regex "$event_electron_user_agent" 'Chrome/[0-9]' || \
    ! matches_regex "$event_electron_user_agent" 'Electron/[0-9]' || \
    ! matches_regex "$event_electron_process_version" '^[0-9]+(\.[0-9]+)*$' || \
    ! matches_regex "$event_chrome_process_version" '^[0-9]+(\.[0-9]+)*$'; then
    write_evidence "fail" "event-routing-browser-runtime-missing"
elif [ "$event_ready" != "true" ] || [ "$event_wm_found" != "true" ]; then
    write_evidence "fail" "event-routing-ready-missing"
elif ! num_at_least "$event_focus_count" 1 || ! num_at_least "$event_move_count" 1 || ! num_at_least "$event_maximize_count" 1 || \
    ! num_at_least "$event_title_command_count" 1 || ! num_at_least "$event_text_input_count" 1 || \
    ! num_at_least "$event_pointer_down_count" 1 || ! num_at_least "$event_pointer_up_count" 1; then
    write_evidence "fail" "event-routing-contract-missing"
elif [ "$event_performance_now_available" != "true" ] || ! num_positive "$event_performance_now_delta_ms" || \
    ! num_at_most_decimal "$event_performance_now_delta_ms" 1000 || \
    [ "$event_animation_frame_available" != "true" ] || \
    ! num_at_least "$event_animation_frame_count" 2 || [ "$event_css_animation_probe" != "true" ]; then
    write_evidence "fail" "event-routing-performance-animation-contract-missing"
elif ! num_positive "$event_input_to_paint_ms" || ! num_at_most_decimal "$event_input_to_paint_ms" 1000; then
    write_evidence "fail" "event-routing-interaction-latency-contract-missing"
elif [ "$event_sequence" != "host_wm_pointer:down,window_cmd:focus,window_cmd:move,window_cmd:title_command,window_cmd:maximize,input_event:text_input,input_event:pointer_down,input_event:pointer_up" ]; then
    write_evidence "fail" "event-routing-sequence-contract-missing"
elif [ "$event_title_text" != "Terminal" ] || [ "$event_title_context_text" != "terminal" ] || \
    ! num_at_least "$event_traffic_button_count" 3 || [ "$event_title_input_tag" != "input" ] || \
    [ "$event_titlebar_height" != "34px" ] || [ "$event_titlebar_display" != "flex" ] || \
    [ "$event_titlebar_cursor" != "grab" ] || [ "$event_titlebar_background" != "rgb(229, 231, 235)" ] || \
    [ "$event_title_color" != "rgb(17, 24, 39)" ] || ! num_at_least "$event_title_font_weight" 700 || \
    [ "$event_title_input_min_width" != "142px" ] || ! num_at_least_decimal "$event_title_input_width_px" 142 || \
    [ "$event_title_input_height" != "24px" ] || [ "$event_title_input_cursor" != "text" ] || \
    [ "$event_title_input_background" != "rgb(241, 245, 249)" ] || \
    [ "$event_close_button_background" != "rgb(239, 68, 68)" ] || \
    [ "$event_minimize_button_background" != "rgb(234, 179, 8)" ] || \
    [ "$event_maximize_button_background" != "rgb(34, 197, 94)" ]; then
    write_evidence "fail" "event-routing-ui-contract-missing"
elif [ "$event_expected_move_x" = "" ] || [ "$event_expected_move_y" = "" ] || \
    [ "$event_expected_move_x" != "$event_move_payload_x" ] || [ "$event_expected_move_y" != "$event_move_payload_y" ] || \
    [ "$event_move_payload_source" != "native_event" ] || [ "$event_move_payload_window_id_hint" != "win1" ] || \
    [ "$event_title_command_text" != "/tmp/project" ] || [ "$event_text_input_text" != "Hello Simple" ]; then
    write_evidence "fail" "event-routing-payload-contract-missing"
elif [ "$event_tolerance" != "false" ]; then
    write_evidence "fail" "event-routing-tolerance-used"
elif [ "$simple_bin_status" != "pass" ] || [ "$simple_bin" = "" ]; then
    write_evidence "fail" "simple-bin-provenance-missing"
else
    write_evidence "pass" "pass"
    exit 0
fi
exit 1
