#!/bin/sh
# Validate existing production GUI/web renderer parity evidence without launching
# Electron, Chrome, Tauri, or GPU checks.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/production_gui_web_renderer_parity_gate}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_web_renderer_parity_gate_$(date -u +%F).md}"
SOURCE_ENV="${PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV:-build/production_gui_web_renderer_parity_evidence/evidence.env}"
OUT_ENV="$BUILD_DIR/evidence.env"
# Honesty: upstream evidence is only trustworthy for a bounded window. A
# stale evidence.env (e.g. from a run days ago, before an unrelated code
# change) must not silently keep this meta-gate green.
MAX_EVIDENCE_AGE_HOURS="${MAX_EVIDENCE_AGE_HOURS:-72}"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH"

value_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" 2>/dev/null | tail -n 1
}

file_mtime_epoch() {
    file="$1"
    if stat -f %m "$file" >/dev/null 2>&1; then
        stat -f %m "$file"
    else
        stat -c %Y "$file" 2>/dev/null
    fi
}

missing_commands() {
    missing=""
    for cmd in "$@"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            if [ "$missing" = "" ]; then
                missing="$cmd"
            else
                missing="$missing,$cmd"
            fi
        fi
    done
    echo "$missing"
}

num_at_least() {
    value="$1"
    min="$2"
    case "$value" in
        ''|*[!0-9]*) return 1 ;;
    esac
    [ "$value" -ge "$min" ]
}

num_positive() {
    value="$1"
    awk -v value="$value" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 > 0) exit 0
        exit 1
    }'
}

num_at_least_decimal() {
    value="$1"
    min="$2"
    awk -v value="$value" -v min="$min" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 >= min + 0) exit 0
        exit 1
    }'
}

num_at_most_decimal() {
    value="$1"
    max="$2"
    awk -v value="$value" -v max="$max" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 <= max + 0) exit 0
        exit 1
    }'
}

matches_regex() {
    value="$1"
    pattern="$2"
    printf '%s\n' "$value" | grep -Eq "$pattern"
}

status_or_missing() {
    value="$1"
    if [ "$value" = "" ]; then
        echo "missing"
    else
        echo "$value"
    fi
}

reason_or_missing() {
    value="$1"
    fallback="$2"
    if [ "$value" = "" ]; then
        echo "$fallback"
    else
        echo "$value"
    fi
}

write_evidence() {
    status="$1"
    reason="$2"
    {
        echo "production_gui_web_renderer_parity_gate_status=$status"
        echo "production_gui_web_renderer_parity_gate_reason=$reason"
        echo "production_gui_web_renderer_parity_gate_source_env=$SOURCE_ENV"
        echo "production_gui_web_renderer_parity_gate_source_env_status=${source_env_status:-}"
        echo "production_gui_web_renderer_parity_gate_source_status=$(status_or_missing "${source_status:-}")"
        echo "production_gui_web_renderer_parity_gate_source_reason=$(reason_or_missing "${source_reason:-}" "missing-production-parity-source-status")"
        echo "production_gui_web_renderer_parity_gate_source_partial_status=${source_partial_status:-}"
        echo "production_gui_web_renderer_parity_gate_source_partial_reason=${source_partial_reason:-}"
        echo "production_gui_web_renderer_parity_gate_source_env_mtime_epoch=${source_env_mtime_epoch:-}"
        echo "production_gui_web_renderer_parity_gate_source_env_age_hours=${source_env_age_hours:-}"
        echo "production_gui_web_renderer_parity_gate_max_evidence_age_hours=$MAX_EVIDENCE_AGE_HOURS"
        echo "production_gui_web_renderer_parity_gate_simple_bin=${simple_bin:-}"
        echo "production_gui_web_renderer_parity_gate_simple_bin_source=${simple_bin_source:-}"
        echo "production_gui_web_renderer_parity_gate_simple_bin_status=$(status_or_missing "${simple_bin_status:-}")"
        echo "production_gui_web_renderer_parity_gate_refresh_command=sh scripts/check/check-production-gui-web-renderer-parity-evidence.shs"
        echo "production_gui_web_renderer_parity_gate_matrix_exit_code=${matrix_exit_code:-}"
        echo "production_gui_web_renderer_parity_gate_matrix_status=${matrix_status:-}"
        echo "production_gui_web_renderer_parity_gate_matrix_reason=${matrix_reason:-}"
        echo "production_gui_web_renderer_parity_gate_matrix_timed_out=${matrix_timed_out:-}"
        echo "production_gui_web_renderer_parity_gate_matrix_timeout_secs=${matrix_timeout_secs:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_exit_code=${layout_exit_code:-}"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_status=$(status_or_missing "${layout_status:-}")"
        echo "production_gui_web_renderer_parity_gate_layout_manifest_reason=$(reason_or_missing "${layout_reason:-}" "missing-layout-manifest-evidence")"
