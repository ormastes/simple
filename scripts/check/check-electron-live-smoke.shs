#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

PROOF_PATH="${SIMPLE_ELECTRON_PROOF_PATH:-build/electron_shell_envelope.json}"
WIDTH="${SIMPLE_ELECTRON_SMOKE_WIDTH:-1280}"
HEIGHT="${SIMPLE_ELECTRON_SMOKE_HEIGHT:-720}"
TIMEOUT_SECS="${SIMPLE_ELECTRON_SMOKE_TIMEOUT_SECS:-60}"
VALIDATOR="scripts/check/validate-electron-live-smoke-proof.js"
VALIDATION_ENV="${PROOF_PATH}.validation.env"

have() {
    command -v "$1" >/dev/null 2>&1
}

if [ "${SKIP_ELECTRON_LIVE_SMOKE:-0}" = "1" ]; then
    echo "electron_live_smoke=skipped"
    echo "reason=SKIP_ELECTRON_LIVE_SMOKE"
    echo "electron_live_smoke_validation_status=skipped"
    echo "electron_live_smoke_validation_reason=SKIP_ELECTRON_LIVE_SMOKE"
    echo "electron_live_smoke_proof_source="
    echo "electron_live_smoke_browser_engine="
    echo "electron_live_smoke_electron_user_agent="
    echo "electron_live_smoke_width="
    echo "electron_live_smoke_height="
    echo "electron_live_smoke_performance_now_delta_ms="
    echo "electron_live_smoke_animation_frame_count="
    exit 0
fi

for required in node npm xvfb-run; do
    if ! have "$required"; then
        echo "electron_live_smoke=unavailable"
        echo "error=missing_command:$required"
        echo "electron_live_smoke_validation_status=unavailable"
        echo "electron_live_smoke_validation_reason=missing_command:$required"
        echo "electron_live_smoke_proof_source="
        echo "electron_live_smoke_browser_engine="
        echo "electron_live_smoke_electron_user_agent="
        echo "electron_live_smoke_width="
        echo "electron_live_smoke_height="
        echo "electron_live_smoke_performance_now_delta_ms="
        echo "electron_live_smoke_animation_frame_count="
        exit 1
    fi
done

if [ ! -f "tools/electron-shell/package.json" ]; then
    echo "electron_live_smoke=unavailable"
    echo "error=missing_tools/electron-shell/package.json"
    echo "electron_live_smoke_validation_status=unavailable"
    echo "electron_live_smoke_validation_reason=missing_tools/electron-shell/package.json"
    echo "electron_live_smoke_proof_source="
    echo "electron_live_smoke_browser_engine="
    echo "electron_live_smoke_electron_user_agent="
    echo "electron_live_smoke_width="
    echo "electron_live_smoke_height="
    echo "electron_live_smoke_performance_now_delta_ms="
    echo "electron_live_smoke_animation_frame_count="
    exit 1
fi

if [ ! -f "$VALIDATOR" ]; then
    echo "electron_live_smoke=unavailable"
    echo "error=missing_validator:$VALIDATOR"
    echo "electron_live_smoke_validation_status=unavailable"
    echo "electron_live_smoke_validation_reason=missing_validator:$VALIDATOR"
    echo "electron_live_smoke_proof_source="
    echo "electron_live_smoke_browser_engine="
    echo "electron_live_smoke_electron_user_agent="
    echo "electron_live_smoke_width="
    echo "electron_live_smoke_height="
    echo "electron_live_smoke_performance_now_delta_ms="
    echo "electron_live_smoke_animation_frame_count="
    exit 1
fi

mkdir -p "$(dirname "$PROOF_PATH")"
rm -f "$PROOF_PATH" "$VALIDATION_ENV"

run_smoke() {
    SIMPLE_ELECTRON_PROOF_PATH="../../$PROOF_PATH" \
        xvfb-run -a --server-args="-screen 0 ${WIDTH}x${HEIGHT}x24" \
        npm --prefix tools/electron-shell run live-smoke
}

if have timeout; then
    timeout "$TIMEOUT_SECS" env SIMPLE_ELECTRON_PROOF_PATH="../../$PROOF_PATH" \
        xvfb-run -a --server-args="-screen 0 ${WIDTH}x${HEIGHT}x24" \
        npm --prefix tools/electron-shell run live-smoke
else
    run_smoke
fi

if [ ! -s "$PROOF_PATH" ]; then
    echo "electron_live_smoke=fail"
    echo "reason=missing-proof-file"
    echo "electron_live_smoke_validation_status=fail"
    echo "electron_live_smoke_validation_reason=missing-proof-file"
    echo "electron_live_smoke_proof_source="
    echo "electron_live_smoke_browser_engine="
    echo "electron_live_smoke_electron_user_agent="
    echo "electron_live_smoke_width="
    echo "electron_live_smoke_height="
    echo "electron_live_smoke_performance_now_delta_ms="
    echo "electron_live_smoke_animation_frame_count="
    exit 1
fi

node "$VALIDATOR" "$PROOF_PATH" "$WIDTH" "$HEIGHT" >"$VALIDATION_ENV"
cat "$VALIDATION_ENV"
echo "electron_live_smoke=pass proof=$PROOF_PATH validation=$VALIDATION_ENV"
