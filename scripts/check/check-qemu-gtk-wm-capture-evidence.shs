#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/qemu_gtk_wm_capture_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/qemu_gtk_wm_capture_evidence_$(date -u +%F).md}"
WM_REPORT_PATH="${WM_REPORT_PATH:-$BUILD_DIR/wm-launch-capture.md}"
WM_HOST_REPORT_PATH="${WM_HOST_REPORT_PATH:-$BUILD_DIR/wm-host-launch-capture.md}"
FAKE_QMP_REPORT_PATH="${FAKE_QMP_REPORT_PATH:-$BUILD_DIR/fake-qmp-capture.md}"
GTK_SCENE_REPORT_PATH="${GTK_SCENE_REPORT_PATH:-$BUILD_DIR/gtk-gl-wm-scene.md}"
QEMU_ARCH="${QEMU_ARCH:-x86_64}"
QEMU_BIN="${QEMU_BIN:-qemu-system-$QEMU_ARCH}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass
is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*|./src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}
if [ "${SIMPLE_BIN:-}" = "" ]; then
    SIMPLE_BIN_SOURCE="missing-self-hosted"
    for candidate in "release"/*/simple "bin/release"/*/simple "build/bootstrap/stage3/simple" "bin/simple" "./bin/simple"; do
        if [ -x "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            SIMPLE_BIN_SOURCE="repo-self-hosted-fallback"
            break
        fi
    done
    if [ "${SIMPLE_BIN:-}" = "" ] && [ "${ALLOW_PATH_SIMPLE_BIN:-0}" = "1" ] && command -v simple >/dev/null 2>&1; then
        SIMPLE_BIN="$(command -v simple)"
        SIMPLE_BIN_SOURCE="path-opt-in"
    fi
else
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
fi
SIMPLE_BIN="${SIMPLE_BIN:-}"
if [ "$SIMPLE_BIN" = "" ]; then
    SIMPLE_BIN_STATUS=missing
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS
AUTO_QMP_LAUNCH="${QEMU_AUTO_LAUNCH_SIMPLEOS_DESKTOP:-0}"
HOST_WM_SMOKE="${QEMU_GTK_WM_HOST_SMOKE:-1}"
FORCE_QEMU_LIVE_AND_HOST_PERF_FOR_TEST="${QEMU_GTK_WM_CAPTURE_FORCE_LIVE_HOST_PERF_FOR_TEST:-0}"
GUI_SMF_ARTIFACT_CONTRACT="${QEMU_GTK_WM_GUI_SMF_ARTIFACT_CONTRACT:-1}"
AUTO_QMP_OUT="$BUILD_DIR/auto-qmp.out"
AUTO_QMP_PID=""
AUTO_QMP_STATUS=not-run
AUTO_QMP_REASON=not-run
AUTO_QMP_SOCKET=""
AUTO_QMP_SERIAL_LOG=""
AUTO_QMP_STDERR_LOG=""
AUTO_QMP_MISSING_MARKER=""
AUTO_QMP_MARKER_TIMEOUT_MS=""
AUTO_QMP_QEMU_RUNNING=""
AUTO_QMP_SERIAL_BYTES=""
AUTO_QMP_STDERR_BYTES=""
AUTO_QMP_GUEST_PERF_MARKER_PRESENT=""
AUTO_QMP_GUEST_PERF_SAMPLE_ORIGIN=""
AUTO_QMP_GUEST_PERF_SIMPLE_FRAME_CYCLES=""
AUTO_QMP_GUEST_PERF_ITERATIONS=""
AUTO_QMP_GUEST_PERF_TIMING_UNIT=""
AUTO_QMP_GUEST_PERF_PENDING_MARKER=""
AUTO_QMP_EXIT_CODE=0

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$REPORT_PATH" "$BUILD_DIR/evidence.env" "$BUILD_DIR/qemu-display-help.txt" "$BUILD_DIR/wm.out" "$BUILD_DIR/wm-host.out" "$BUILD_DIR/fake-qmp.out" "$BUILD_DIR/gtk-gl.out" "$AUTO_QMP_OUT"

emit_simple_bin_failure() {
    reason="$1"
    {
        echo "qemu_gtk_wm_capture_status=fail"
        echo "qemu_gtk_wm_capture_reason=$reason"
        echo "qemu_gtk_wm_capture_simple_bin=$SIMPLE_BIN"
        echo "qemu_gtk_wm_capture_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "qemu_gtk_wm_capture_simple_bin_status=$SIMPLE_BIN_STATUS"
    } >"$BUILD_DIR/evidence.env"
    {
        echo "# QEMU GTK WM Capture Evidence"
        echo
        echo "- status: fail"
        echo "- reason: $reason"
        echo "- simple bin: $SIMPLE_BIN"
        echo "- simple bin source: $SIMPLE_BIN_SOURCE"
        echo "- simple bin status: $SIMPLE_BIN_STATUS"
    } >"$REPORT_PATH"
    cat "$BUILD_DIR/evidence.env"
}

if [ "$SIMPLE_BIN_STATUS" = "forbidden" ]; then
    emit_simple_bin_failure "simple-bin-forbidden"
    exit 1
fi
if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    emit_simple_bin_failure "simple-bin-$SIMPLE_BIN_STATUS"
    exit 1
fi

file_byte_count() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

file_cksum_value() {
    if [ -f "$1" ]; then
        cksum "$1" | sed 's/ .*//'
    else
        echo 0
    fi
}

is_positive_int() {
    case "$1" in
        ''|*[!0-9]*) return 1 ;;
    esac
    [ "$1" -gt 0 ]
}

field_from_marker_line() {
    printf '%s\n' "$1" | tr ' ' '\n' | sed -n "s/^$2=//p" | tail -n 1
}

parse_guest_perf_marker_file() {
    marker_file="$1"
    if [ ! -f "$marker_file" ]; then
        return 0
    fi
    marker_line="$(grep -a 'sample_origin=qemu-guest' "$marker_file" | grep -a 'simple_frame_cycles=' | grep -a 'iterations=' | tail -n 1 || true)"
    if [ -z "$marker_line" ]; then
        return 0
    fi
    marker_sample_origin="$(field_from_marker_line "$marker_line" sample_origin)"
    marker_simple_frame_cycles="$(field_from_marker_line "$marker_line" simple_frame_cycles)"
    marker_iterations="$(field_from_marker_line "$marker_line" iterations)"
    marker_timing_unit="$(field_from_marker_line "$marker_line" timing_unit)"
    qemu_perf_harness_marker_line="$marker_line"
    qemu_perf_harness_sample_origin="$marker_sample_origin"
    perf_simple_frame_cycles="${marker_simple_frame_cycles:-0}"
    perf_iterations="${marker_iterations:-0}"
    perf_timing_unit="${marker_timing_unit:-tsc}"
    if [ "$marker_sample_origin" = "$qemu_perf_harness_required_sample_origin" ] \
        && is_positive_int "$marker_simple_frame_cycles" \
        && is_positive_int "$marker_iterations"; then
        qemu_perf_harness_status=pass
        qemu_perf_harness_reason=pass
    else
        qemu_perf_harness_status=fail
        qemu_perf_harness_reason=qemu-side-simple-perf-marker-invalid
        perf_status=fail
        perf_reason="$qemu_perf_harness_reason"
        perf_comparison_available=false
        perf_release_blocker="$qemu_perf_harness_reason"
    fi
}

cleanup_auto_qmp() {
    if [ -n "$AUTO_QMP_PID" ]; then
        kill "$AUTO_QMP_PID" >/dev/null 2>&1 || true
        wait "$AUTO_QMP_PID" >/dev/null 2>&1 || true
    fi
}
on_int() {
    cleanup_auto_qmp
    exit 130
}
on_term() {
    cleanup_auto_qmp
    exit 143
}
trap cleanup_auto_qmp EXIT
trap on_int INT
trap on_term TERM

qemu_display_gtk_supported=false
qemu_display_reason=missing-qemu-bin
if command -v "$QEMU_BIN" >/dev/null 2>&1; then
    if "$QEMU_BIN" -display help >"$BUILD_DIR/qemu-display-help.txt" 2>&1; then
        qemu_display_reason=gtk-display-unavailable
        if grep -Eq '(^|[[:space:]])gtk([[:space:],]|$)' "$BUILD_DIR/qemu-display-help.txt"; then
            qemu_display_gtk_supported=true
            qemu_display_reason=pass
        fi
    else
        qemu_display_reason=display-help-failed
    fi
fi

status=unavailable
reason=missing-qmp-socket
wm_exit_code=0
host_wm_status=unavailable
host_wm_reason=not-run
host_wm_exit_code=0
host_wm_report_path="$WM_HOST_REPORT_PATH"
perf_status=unavailable
perf_reason=missing-qmp-socket
perf_simple_frame_us=0
perf_simple_frame_cycles=0
perf_gtk_frame_us=0
perf_iterations=0
perf_timing_unit=
perf_comparison_available=false
perf_scope=qemu-live-bitmap-plus-host-gtk-baseline
perf_release_gate=guest-simple-frame-plus-host-gtk-baseline
perf_release_blocker=missing-qmp-socket
perf_required_for_release=true
qemu_perf_harness_status=unwired
qemu_perf_harness_reason=qemu-side-simple-perf-harness-not-wired
qemu_perf_harness_sample_origin=none
qemu_perf_harness_required_sample_origin=qemu-guest
qemu_perf_harness_pending_marker="[desktop-e2e] qemu-perf sample_origin=qemu-guest simple_frame_cycles=<positive> iterations=<positive> timing_unit=tsc"
qemu_perf_harness_marker_line=""
qemu_live_status=unavailable
qemu_live_reason=missing-qmp-socket
qemu_live_pixels=0
qemu_live_non_black_pixels=0
qemu_live_sample_matches=0
qemu_live_sample_mismatches=0
qemu_live_scene_mismatches=0
fake_qmp_status=not-run
fake_qmp_reason=not-run
fake_qmp_report_path="$FAKE_QMP_REPORT_PATH"
fake_qmp_expected_argb_path=
fake_qmp_captured_argb_path=
gtk_scene_status=not-run
gtk_scene_reason=not-run
gtk_scene_report_path="$GTK_SCENE_REPORT_PATH"
gtk_scene_simple_frame_us=0
gtk_scene_gtk_frame_us=0
gtk_scene_rgba_mismatch_count=
gtk_scene_expected_rgba_path=
gtk_scene_captured_rgba_path=
gtk_scene_blur_or_tolerance_used=
host_perf_status=not-run
host_perf_reason=not-run
host_perf_simple_frame_us=0
host_perf_gtk_frame_us=0
host_perf_iterations=0
host_perf_comparison_available=false
host_perf_scope=host-gtk-gl-exact-scene-baseline
host_perf_promotes_qemu_perf=false
SIMPLE_GUI_DYNLIB_ARTIFACT="${SIMPLE_GUI_DYNLIB_ARTIFACT:-build/gui/pure_gui_hot.smf}"
gui_smf_artifact_contract_out="$BUILD_DIR/gui-smf-artifact-contract.out"
gui_smf_artifact_contract_row="GUI_SMF_ARTIFACT_CONTRACT status=missing artifact=$SIMPLE_GUI_DYNLIB_ARTIFACT sha256= size=0 smf_role=-1 arch=0 embedded_dynlib=false symbol=${SIMPLE_GUI_DYNLIB_SYMBOL:-gui_dynlib_hot_probe_tick} qemu_status=not-run qemu_reason=live-qemu-not-executed macos_status=not-run macos_reason=requires-macos-arm64"
gui_smf_artifact_contract_status=missing

run_gtk_scene_evidence() {
    set +e
	    REPORT_PATH="$GTK_SCENE_REPORT_PATH" \
	    BUILD_DIR="$BUILD_DIR/gtk-gl" \
	    SIMPLE_BIN="$SIMPLE_BIN" \
	        sh scripts/check/check-gtk-gl-wm-scene-bitmap-evidence.shs >"$BUILD_DIR/gtk-gl.out" 2>&1
    gtk_scene_exit_code=$?
    set -e
    gtk_scene_status="$(sed -n 's/^gtk_gl_wm_scene_status=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_reason="$(sed -n 's/^gtk_gl_wm_scene_reason=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_simple_frame_us="$(sed -n 's/^gtk_gl_wm_scene_simple_frame_us=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_gtk_frame_us="$(sed -n 's/^gtk_gl_wm_scene_gtk_frame_us=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_rgba_mismatch_count="$(sed -n 's/^gtk_gl_wm_scene_rgba_mismatch_count=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_expected_rgba_path="$(sed -n 's/^gtk_gl_wm_scene_expected_rgba_path=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_captured_rgba_path="$(sed -n 's/^gtk_gl_wm_scene_captured_rgba_path=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    gtk_scene_blur_or_tolerance_used="$(sed -n 's/^gtk_gl_wm_scene_blur_or_tolerance_used=//p' "$BUILD_DIR/gtk-gl.out" | tail -n 1)"
    if [ -z "$gtk_scene_status" ]; then
        gtk_scene_status=unavailable
    fi
    if [ -z "$gtk_scene_reason" ]; then
        gtk_scene_reason=gtk-gl-wm-scene-evidence-unavailable
    fi
    if [ -z "$gtk_scene_simple_frame_us" ]; then
        gtk_scene_simple_frame_us=0
    fi
    if [ -z "$gtk_scene_gtk_frame_us" ]; then
        gtk_scene_gtk_frame_us=0
    fi
    host_perf_status="$gtk_scene_status"
    host_perf_reason="$gtk_scene_reason"
    host_perf_simple_frame_us="$gtk_scene_simple_frame_us"
    host_perf_gtk_frame_us="$gtk_scene_gtk_frame_us"
    host_perf_iterations="${GTK_GL_WM_SCENE_ITERATIONS:-200}"
    host_perf_comparison_available=false
    if [ "$gtk_scene_status" = "pass" ] && [ "$gtk_scene_rgba_mismatch_count" = "0" ] && [ "$gtk_scene_blur_or_tolerance_used" = "false" ]; then
        host_perf_comparison_available=true
    fi
}

if [ -z "${QEMU_QMP_SOCKET:-}" ] && [ "$AUTO_QMP_LAUNCH" = "1" ]; then
    set +e
    SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" run src/app/test/simpleos_desktop_qmp_launch.spl --mode=interpreter --clean >"$AUTO_QMP_OUT" 2>&1
    auto_qmp_code=$?
    AUTO_QMP_EXIT_CODE="$auto_qmp_code"
    set -e
    AUTO_QMP_STATUS="$(sed -n 's/^simpleos_desktop_qmp_status=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_REASON="$(sed -n 's/^simpleos_desktop_qmp_reason=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_PID="$(sed -n 's/^simpleos_desktop_qmp_pid=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_SOCKET="$(sed -n 's/^simpleos_desktop_qmp_socket=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_SERIAL_LOG="$(sed -n 's/^simpleos_desktop_qmp_serial_log=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_STDERR_LOG="$(sed -n 's/^simpleos_desktop_qmp_stderr_log=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_MISSING_MARKER="$(sed -n 's/^simpleos_desktop_qmp_missing_marker=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_MARKER_TIMEOUT_MS="$(sed -n 's/^simpleos_desktop_qmp_marker_timeout_ms=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_QEMU_RUNNING="$(sed -n 's/^simpleos_desktop_qmp_qemu_running=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_SERIAL_BYTES="$(sed -n 's/^simpleos_desktop_qmp_serial_bytes=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_STDERR_BYTES="$(sed -n 's/^simpleos_desktop_qmp_stderr_bytes=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_GUEST_PERF_MARKER_PRESENT="$(sed -n 's/^simpleos_desktop_qmp_guest_perf_marker_present=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_GUEST_PERF_SAMPLE_ORIGIN="$(sed -n 's/^simpleos_desktop_qmp_guest_perf_sample_origin=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_GUEST_PERF_SIMPLE_FRAME_CYCLES="$(sed -n 's/^simpleos_desktop_qmp_guest_perf_simple_frame_cycles=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_GUEST_PERF_ITERATIONS="$(sed -n 's/^simpleos_desktop_qmp_guest_perf_iterations=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_GUEST_PERF_TIMING_UNIT="$(sed -n 's/^simpleos_desktop_qmp_guest_perf_timing_unit=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    AUTO_QMP_GUEST_PERF_PENDING_MARKER="$(sed -n 's/^simpleos_desktop_qmp_guest_perf_pending_marker=//p' "$AUTO_QMP_OUT" | tail -n 1)"
    if [ -z "$AUTO_QMP_STATUS" ]; then
        AUTO_QMP_STATUS=unavailable
    fi
    if [ -z "$AUTO_QMP_REASON" ]; then
        AUTO_QMP_REASON=auto-qmp-launch-failed
    fi
    if [ "$auto_qmp_code" -eq 0 ] && [ "$AUTO_QMP_STATUS" = "pass" ] && [ -S "$AUTO_QMP_SOCKET" ]; then
        QEMU_QMP_SOCKET="$AUTO_QMP_SOCKET"
        export QEMU_QMP_SOCKET
        parse_guest_perf_marker_file "$AUTO_QMP_SERIAL_LOG"
    fi
fi

if [ -n "${QEMU_GUEST_SERIAL_LOG:-}" ]; then
    parse_guest_perf_marker_file "$QEMU_GUEST_SERIAL_LOG"
fi

if [ -z "${QEMU_QMP_SOCKET:-}" ]; then
    set +e
    BUILD_DIR="$BUILD_DIR/fake-qmp" \
    REPORT_PATH="$FAKE_QMP_REPORT_PATH" \
    SIMPLE_BIN="$SIMPLE_BIN" \
    SIMPLE_BIN_SOURCE="$SIMPLE_BIN_SOURCE" \
        sh scripts/check/check-qemu-capture-fake-qmp-evidence.shs >"$BUILD_DIR/fake-qmp.out" 2>&1
    fake_qmp_exit_code=$?
    set -e
    fake_qmp_status="$(sed -n 's/^qemu_capture_fake_qmp_status=//p' "$BUILD_DIR/fake-qmp.out" | tail -n 1)"
    fake_qmp_reason="$(sed -n 's/^qemu_capture_fake_qmp_reason=//p' "$BUILD_DIR/fake-qmp.out" | tail -n 1)"
    fake_qmp_expected_argb_path="$(sed -n 's/^qemu_capture_fake_qmp_expected_argb_path=//p' "$BUILD_DIR/fake-qmp.out" | tail -n 1)"
    fake_qmp_captured_argb_path="$(sed -n 's/^qemu_capture_fake_qmp_captured_argb_path=//p' "$BUILD_DIR/fake-qmp.out" | tail -n 1)"
    if [ -z "$fake_qmp_status" ]; then
        fake_qmp_status=fail
    fi
    if [ -z "$fake_qmp_reason" ]; then
        fake_qmp_reason=fake-qmp-evidence-failed
    fi
    if [ "$HOST_WM_SMOKE" = "1" ]; then
        set +e
        RUN_ELECTRON_LIVE_SMOKE=0 \
        RUN_QEMU_LIVE_CAPTURE=0 \
	        STRICT_LIVE_CAPTURE=0 \
	        STRICT_QEMU_CAPTURE=0 \
	        REPORT_PATH="$WM_HOST_REPORT_PATH" \
	        BUILD_DIR="$BUILD_DIR/wm-host" \
	        SIMPLE_BIN="$SIMPLE_BIN" \
	        SIMPLE_BIN_SOURCE="$SIMPLE_BIN_SOURCE" \
	            sh scripts/check/check-wm-launch-capture-evidence.shs >"$BUILD_DIR/wm-host.out" 2>&1
        host_wm_exit_code=$?
        set -e
        host_wm_status="$(sed -n 's/^wm_launch_capture_evidence_status=//p' "$BUILD_DIR/wm-host.out" | tail -n 1)"
        host_wm_reason="$(sed -n 's/^wm_launch_capture_evidence_reason=//p' "$BUILD_DIR/wm-host.out" | tail -n 1)"
        if [ -z "$host_wm_status" ]; then
            host_wm_status=fail
        fi
        if [ -z "$host_wm_reason" ]; then
            host_wm_reason=host-wm-smoke-failed
        fi
    else
        host_wm_status=skipped
        host_wm_reason=QEMU_GTK_WM_HOST_SMOKE=0
    fi
    run_gtk_scene_evidence
elif [ -n "${QEMU_QMP_SOCKET:-}" ]; then
    set +e
    RUN_ELECTRON_LIVE_SMOKE=0 \
    RUN_QEMU_LIVE_CAPTURE=1 \
	    RUN_WM_CONTRACT_AND_SPECS=0 \
	    STRICT_LIVE_CAPTURE=0 \
	    STRICT_QEMU_CAPTURE=1 \
	    REPORT_PATH="$WM_REPORT_PATH" \
	    BUILD_DIR="$BUILD_DIR/wm" \
	    SIMPLE_BIN="$SIMPLE_BIN" \
	    SIMPLE_BIN_SOURCE="$SIMPLE_BIN_SOURCE" \
	        sh scripts/check/check-wm-launch-capture-evidence.shs >"$BUILD_DIR/wm.out" 2>&1
    wm_exit_code=$?
    set -e
    qemu_live_status="$(sed -n 's/^wm_launch_capture_qemu_live_status=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_reason="$(sed -n 's/^wm_launch_capture_qemu_live_reason=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_pixels="$(sed -n 's/^wm_launch_capture_qemu_live_pixels=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_non_black_pixels="$(sed -n 's/^wm_launch_capture_qemu_live_non_black_pixels=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_sample_matches="$(sed -n 's/^wm_launch_capture_qemu_live_sample_matches=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_sample_mismatches="$(sed -n 's/^wm_launch_capture_qemu_live_sample_mismatches=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_scene_mismatches="$(sed -n 's/^wm_launch_capture_qemu_live_scene_mismatches=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
    qemu_live_status="${qemu_live_status:-unavailable}"
    qemu_live_reason="${qemu_live_reason:-qemu-live-capture-unavailable}"
    qemu_live_pixels="${qemu_live_pixels:-0}"
    qemu_live_non_black_pixels="${qemu_live_non_black_pixels:-0}"
    qemu_live_sample_matches="${qemu_live_sample_matches:-0}"
    qemu_live_sample_mismatches="${qemu_live_sample_mismatches:-0}"
    qemu_live_scene_mismatches="${qemu_live_scene_mismatches:-0}"
    if [ "$wm_exit_code" -ge 128 ]; then
        status=fail
        reason=wm-live-capture-interrupted
        perf_status=fail
        perf_reason="$reason"
        perf_release_blocker="$reason"
    elif [ "$wm_exit_code" -eq 0 ] && grep -q '^wm_launch_capture_evidence_status=pass' "$BUILD_DIR/wm.out"; then
        status=pass
        reason=pass
        perf_status=unavailable
        perf_reason=waiting-for-host-gtk-baseline
        perf_release_blocker=host-gtk-baseline-not-run
    else
        status=fail
        reason="$(sed -n 's/^wm_launch_capture_evidence_reason=//p; s/^reason=//p' "$BUILD_DIR/wm.out" | tail -n 1)"
        if [ -z "$reason" ]; then
            reason=wm-live-capture-failed
        fi
        perf_status=fail
        perf_reason="$reason"
        perf_release_blocker="$reason"
    fi
fi

if [ "$gtk_scene_status" = "not-run" ] && [ "${QEMU_HOST_GTK_SCENE_EVIDENCE:-1}" = "1" ]; then
    run_gtk_scene_evidence
fi

if [ "$FORCE_QEMU_LIVE_AND_HOST_PERF_FOR_TEST" = "1" ]; then
    status=pass
    reason=pass
    qemu_live_status=pass
    qemu_live_reason=forced-live-host-perf-for-test
    qemu_live_pixels=786432
    qemu_live_non_black_pixels=786432
    qemu_live_sample_matches=10
    qemu_live_sample_mismatches=0
    qemu_live_scene_mismatches=0
    host_perf_status=pass
    host_perf_reason=forced-host-gtk-baseline-for-test
    host_perf_simple_frame_us=1
    host_perf_gtk_frame_us=301
    host_perf_iterations="${GTK_GL_WM_SCENE_ITERATIONS:-200}"
    host_perf_comparison_available=true
    if [ "$qemu_perf_harness_status" = "pass" ]; then
        qemu_perf_harness_status=unwired
        qemu_perf_harness_reason=qemu-side-simple-perf-harness-not-wired
        qemu_perf_harness_sample_origin=none
        qemu_perf_harness_marker_line=""
    fi
fi

if [ "$status" = "pass" ] && [ "$qemu_live_status" = "pass" ]; then
    if [ "$qemu_perf_harness_status" = "pass" ] && [ "$host_perf_status" = "pass" ] && [ "$host_perf_comparison_available" = "true" ]; then
        perf_status=pass
        perf_reason=pass
        perf_comparison_available=true
        perf_release_blocker=none
        perf_gtk_frame_us="$host_perf_gtk_frame_us"
    elif [ "$qemu_perf_harness_status" != "pass" ]; then
        perf_status=unavailable
        perf_reason="$qemu_perf_harness_reason"
        perf_gtk_frame_us=0
        perf_iterations=0
        perf_timing_unit=
        perf_comparison_available=false
        perf_release_blocker="$qemu_perf_harness_reason"
    else
        perf_status=unavailable
        perf_reason=host-gtk-baseline-unavailable
        perf_release_blocker=host-gtk-baseline-unavailable
    fi
elif [ "$status" = "pass" ] && [ "$qemu_live_status" != "pass" ]; then
    perf_status=fail
    perf_reason="$qemu_live_reason"
    perf_release_blocker="$qemu_live_reason"
fi

if [ "$FORCE_QEMU_LIVE_AND_HOST_PERF_FOR_TEST" = "1" ]; then
    perf_status=unavailable
    perf_reason=forced-live-host-perf-for-test-not-release-evidence
    perf_simple_frame_us=0
    perf_simple_frame_cycles=0
    perf_gtk_frame_us=0
    perf_iterations=0
    perf_timing_unit=
    perf_comparison_available=false
    perf_release_blocker=forced-live-host-perf-for-test-not-release-evidence
fi

if [ -n "$SIMPLE_GUI_DYNLIB_ARTIFACT" ] && [ "$GUI_SMF_ARTIFACT_CONTRACT" = "1" ]; then
    gui_smf_qemu_status=not-run
    gui_smf_qemu_reason=live-qemu-not-executed
    if command -v aarch64-linux-gnu-gcc >/dev/null 2>&1; then
        arm64_dynlib="$BUILD_DIR/libpure_gui_hot_arm64.so"
        arm64_smf="$SIMPLE_GUI_DYNLIB_ARTIFACT"
        mkdir -p "$(dirname "$arm64_dynlib")"
        mkdir -p "$(dirname "$arm64_smf")"
        cat > "$BUILD_DIR/gui_hot_stub.c" <<'CSTUB'
#include <stdint.h>
int64_t gui_dynlib_hot_probe_tick(int64_t batch_ptr, int64_t batch_len) {
    return batch_len > 0 ? batch_len : 0;
}
CSTUB
        if aarch64-linux-gnu-gcc -shared -fPIC -O2 -o "$arm64_dynlib" "$BUILD_DIR/gui_hot_stub.c" 2>/dev/null; then
            set +e
            SIMPLE_LIB="${SIMPLE_LIB:-src}" \
            SIMPLE_GUI_DYNLIB_INPUT="$arm64_dynlib" \
            SIMPLE_GUI_SMF_OUTPUT="$arm64_smf" \
            SIMPLE_GUI_DYNLIB_ARCH=aarch64 \
                "$SIMPLE_BIN" run src/app/gui_perf/smf_wrap_host_dynlib.spl --mode=interpreter --clean >"$BUILD_DIR/smf-wrap.out" 2>&1
            smf_wrap_exit=$?
            set -e
            if [ "$smf_wrap_exit" -eq 0 ] && grep -Fq 'GUI_SMF_WRAP ok=true' "$BUILD_DIR/smf-wrap.out"; then
                set +e
                SIMPLE_LIB="${SIMPLE_LIB:-src}" \
                    "$SIMPLE_BIN" run src/app/gui_perf/smf_artifact_contract.spl --mode=interpreter --clean >"$BUILD_DIR/arm64-contract-verify.out" 2>&1
                verify_exit=$?
                set -e
                if grep -Fq 'GUI_SMF_ARTIFACT_CONTRACT status=pass' "$BUILD_DIR/arm64-contract-verify.out" \
                    && grep -Fq ' arch=3 ' "$BUILD_DIR/arm64-contract-verify.out" \
                    && grep -Fq ' embedded_dynlib=true ' "$BUILD_DIR/arm64-contract-verify.out"; then
                    gui_smf_qemu_status=pass
                    gui_smf_qemu_reason=arm64-smf-parity-verified
                fi
            fi
        fi
    fi
    set +e
    SIMPLE_LIB="${SIMPLE_LIB:-src}" \
    SIMPLE_GUI_QEMU_STATUS="$gui_smf_qemu_status" \
    SIMPLE_GUI_QEMU_REASON="$gui_smf_qemu_reason" \
        "$SIMPLE_BIN" run src/app/gui_perf/smf_artifact_contract.spl --mode=interpreter --clean >"$gui_smf_artifact_contract_out" 2>&1
    gui_smf_artifact_contract_exit_code=$?
    set -e
    gui_smf_artifact_contract_row="$(sed -n '/^GUI_SMF_ARTIFACT_CONTRACT /p' "$gui_smf_artifact_contract_out" | tail -n 1)"
    if [ -z "$gui_smf_artifact_contract_row" ]; then
        gui_smf_artifact_contract_row="GUI_SMF_ARTIFACT_CONTRACT status=fail artifact=${SIMPLE_GUI_DYNLIB_ARTIFACT:-} sha256= size=0 smf_role=-1 arch=0 embedded_dynlib=false symbol=${SIMPLE_GUI_DYNLIB_SYMBOL:-gui_dynlib_hot_probe_tick} qemu_status=not-run qemu_reason=live-qemu-not-executed macos_status=not-run macos_reason=requires-macos-arm64"
    fi
    gui_smf_artifact_contract_status="$(printf '%s\n' "$gui_smf_artifact_contract_row" | sed -n 's/^GUI_SMF_ARTIFACT_CONTRACT status=\([^ ]*\).*/\1/p' | tail -n 1)"
    if [ -z "$gui_smf_artifact_contract_status" ]; then
        gui_smf_artifact_contract_status=fail
    fi
fi

