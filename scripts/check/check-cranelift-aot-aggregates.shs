#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-bin/release/x86_64-unknown-linux-gnu/simple}"
BUILD_DIR="${BUILD_DIR:-build/check/cranelift-aot-aggregates}"
FIXTURE_DIR="test/fixtures/compiler"
test -x "$SIMPLE_BIN"
for source in \
    src/compiler/10.frontend/_FlatAstBridge/convert_nodes.spl \
    src/compiler/20.hir/hir_lowering/expressions.spl \
    src/compiler/50.mir/mir_types.spl \
    src/compiler/50.mir/mir_data.spl \
    src/compiler/50.mir/mir_json.spl \
    src/compiler/50.mir/mir_lowering_types.spl \
    src/compiler/50.mir/mir_lowering_stmts.spl \
    src/compiler/50.mir/_MirLowering/module_lowering.spl \
    src/compiler/50.mir/_MirLowering/function_lowering.spl \
    src/compiler/50.mir/_MirLoweringExpr/expr_dispatch.spl \
    src/compiler/50.mir/_MirLoweringExpr/method_calls_literals.spl \
    src/compiler/50.mir/_MirLoweringExpr/switch_operators_calls.spl \
    src/compiler/60.mir_opt/mir_opt/mod.spl \
    src/compiler/70.backend/backend/cranelift_codegen_adapter.spl \
    src/compiler/70.backend/backend/mir_target_context_provider.spl \
    src/compiler/70.backend/backend/cranelift_runtime_imports.spl \
    src/compiler/70.backend/backend/cranelift_type_mapper.spl \
    src/compiler/70.backend/backend/llvm_lib_type_mapper.spl \
    src/compiler/70.backend/backend/_MirToLlvm/class_def.spl \
    src/compiler/70.backend/backend/c_type_mapper.spl \
    src/lib/nogc_sync_mut/ffi/codegen.spl \
    src/lib/nogc_sync_mut/sffi/codegen.spl \
    src/compiler/70.backend/codegen.spl \
    src/compiler_rust/compiler/src/codegen/common_backend.rs \
    src/compiler_rust/compiler/src/codegen/instr/calls.rs \
    src/compiler_rust/compiler/src/codegen/cranelift_sffi.rs \
    src/compiler_rust/compiler/src/codegen/runtime_sffi.rs \
    src/compiler_rust/compiler/src/elf_utils.rs \
    src/compiler_rust/compiler/src/interpreter_extern/cranelift.rs \
    src/compiler_rust/compiler/src/interpreter_extern/mod.rs \
    src/compiler_rust/runtime/src/value/collections.rs \
    src/runtime/simple_core/core_array.spl
do
    test "$SIMPLE_BIN" -nt "$source"
done
rm -rf "$BUILD_DIR/cache"
mkdir -p "$BUILD_DIR"

build_fixture() {
    env -u SIMPLE_BOOTSTRAP "$SIMPLE_BIN" native-build \
        --backend cranelift --source "$FIXTURE_DIR" --entry-closure \
        --entry "$1" --cache-dir "$BUILD_DIR/cache" -o "$2"
}

POSITIVE_BIN="$BUILD_DIR/aggregate-join"
build_fixture "$FIXTURE_DIR/stage4_struct_enum_array_probe.spl" "$POSITIVE_BIN"
"$POSITIVE_BIN" >"$BUILD_DIR/actual.txt" 2>"$BUILD_DIR/positive.stderr"
test ! -s "$BUILD_DIR/actual.txt"
test ! -s "$BUILD_DIR/positive.stderr"

COLLISION_BIN="$BUILD_DIR/runtime-local-name-collision"
build_fixture "$FIXTURE_DIR/native_runtime_local_name_collision.spl" "$COLLISION_BIN"
"$COLLISION_BIN" >"$BUILD_DIR/collision.actual" 2>"$BUILD_DIR/collision.stderr"
printf '4\n20\n25\n' >"$BUILD_DIR/collision.expected"
cmp "$BUILD_DIR/collision.expected" "$BUILD_DIR/collision.actual"
test ! -s "$BUILD_DIR/collision.stderr"

NON_GENERIC_COLLISION_BIN="$BUILD_DIR/runtime-local-name-collision-non-generic"
build_fixture "$FIXTURE_DIR/native_runtime_local_name_collision_non_generic.spl" "$NON_GENERIC_COLLISION_BIN"
"$NON_GENERIC_COLLISION_BIN" >"$BUILD_DIR/collision-non-generic.actual" 2>"$BUILD_DIR/collision-non-generic.stderr"
printf '3\n' >"$BUILD_DIR/collision-non-generic.expected"
cmp "$BUILD_DIR/collision-non-generic.expected" "$BUILD_DIR/collision-non-generic.actual"
test ! -s "$BUILD_DIR/collision-non-generic.stderr"

OOB_BIN="$BUILD_DIR/array-oob"
build_fixture "$FIXTURE_DIR/cranelift_array_oob.spl" "$OOB_BIN"
set +e
"$OOB_BIN" >"$BUILD_DIR/oob.stdout" 2>"$BUILD_DIR/oob.stderr"
oob_rc=$?
set -e
test "$oob_rc" -eq 1
printf 'PANIC: bounds_check intrinsic index=1 len=1\n' >"$BUILD_DIR/oob.expected.stderr"
cmp "$BUILD_DIR/oob.expected.stderr" "$BUILD_DIR/oob.stderr"

echo "cranelift-aot-aggregates: pass"
