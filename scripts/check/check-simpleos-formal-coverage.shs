require_file_text "scripts/check/check-simpleos-formal-setup-contract.shs" 'PATH="$partial_bin" /bin/sh "$PREREQ"'
require_file_text "scripts/check/check-riscv-rtl-sby-proof.shs" "reason=missing-formal-prereqs missing="
require_file_text "doc/07_guide/compiler/lean_verification_workflow.md" "strict RVFI/SymbiYosys proof lane"
