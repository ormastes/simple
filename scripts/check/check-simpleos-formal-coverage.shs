#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

GATE_FILES="
scripts/check/check-riscv-formal-dual-track.shs
scripts/check/check-simpleos-boundary-formal-proofs.shs
scripts/check/check-simpleos-compiler-language-formal-proofs.shs
scripts/check/check-simpleos-critical-formal-proofs.shs
scripts/check/check-simpleos-memory-safety-formal-proofs.shs
scripts/check/check-simpleos-storage-formal-proofs.shs
scripts/check/check-simpleos-ui-policy-formal-proofs.shs
"

tmp="${TMPDIR:-/tmp}/simpleos-formal-coverage.$$"
trap 'rm -f "$tmp"' EXIT

find src/verification -name lakefile.toml -printf '%h\n' | sed 's#^src/verification/##' | sort >"$tmp"

while IFS= read -r project; do
    [ -n "$project" ] || continue
    if ! grep -Fq "verification/$project" $GATE_FILES; then
        echo "FAIL: verification/$project is not covered by a focused SimpleOS formal gate" >&2
        exit 1
    fi
done <"$tmp"

echo "STATUS: PASS simpleos-formal-coverage"
