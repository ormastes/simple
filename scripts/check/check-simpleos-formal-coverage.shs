#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
MATRIX="$ROOT_DIR/scripts/check/check-simpleos-hardening-evidence-matrix.shs"

require_gate_file() {
    path="$1"
    if [ ! -f "$ROOT_DIR/$path" ]; then
        echo "FAIL: missing formal gate $path" >&2
        exit 1
    fi
}

require_matrix_text() {
    text="$1"
    if ! grep -Fq "$text" "$MATRIX"; then
        echo "FAIL: matrix missing formal coverage text: $text" >&2
        exit 1
    fi
}

require_gate_file "scripts/check/check-lean-proofs.shs"
require_gate_file "scripts/check/check-riscv-formal-dual-track.shs"
require_gate_file "scripts/check/check-simpleos-critical-formal-proofs.shs"
require_gate_file "scripts/check/check-simpleos-memory-safety-formal-proofs.shs"
require_gate_file "scripts/check/check-simpleos-storage-formal-proofs.shs"
require_gate_file "scripts/check/check-simpleos-boundary-formal-proofs.shs"
require_gate_file "scripts/check/check-simpleos-compiler-language-formal-proofs.shs"
require_gate_file "scripts/check/check-simpleos-ui-policy-formal-proofs.shs"
require_gate_file "scripts/check/check-simpleos-byl-sby-artifacts.shs"
require_gate_file "scripts/check/check-riscv-rtl-sby-proof.shs"
require_gate_file "scripts/check/check-simpleos-mission-critical-release.shs"

require_matrix_text "formal_riscv_dual_track_status=pass"
require_matrix_text "formal_critical_concurrency_gate=\"scripts/check/check-simpleos-critical-formal-proofs.shs\""
require_matrix_text "formal_memory_safety_gate=\"scripts/check/check-simpleos-memory-safety-formal-proofs.shs\""
require_matrix_text "formal_storage_integrity_gate=\"scripts/check/check-simpleos-storage-formal-proofs.shs\""
require_matrix_text "formal_boundary_integrity_gate=\"scripts/check/check-simpleos-boundary-formal-proofs.shs\""
require_matrix_text "formal_compiler_language_gate=\"scripts/check/check-simpleos-compiler-language-formal-proofs.shs\""
require_matrix_text "formal_ui_policy_gate=\"scripts/check/check-simpleos-ui-policy-formal-proofs.shs\""
require_matrix_text "byl_sby_artifact_audit_gate=\"scripts/check/check-simpleos-byl-sby-artifacts.shs\""
require_matrix_text "riscv_rtl_sby_proof_gate=\"scripts/check/check-riscv-rtl-sby-proof.shs\""
require_matrix_text "mission_critical_release_status=pass"

echo "STATUS: PASS simpleos-formal-coverage"
