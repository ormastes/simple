require_file_text "scripts/check/check-simpleos-formal-setup-contract.shs" "release gate accepted matrix pass with missing prereq status"
require_file_text "scripts/check/check-simpleos-formal-setup-contract.shs" "release gate fake missing-prereq failure missing none release blockers"
require_file_text "scripts/check/check-simpleos-formal-setup-contract.shs" "release gate fake missing-prereq failure missing none prereq blocker"
require_file_text "scripts/check/check-simpleos-formal-setup-contract.shs" "release gate fake missing-prereq failure missing none prereq next action"
require_file_text "scripts/check/check-simpleos-formal-setup-contract.shs" "release gate accepted matrix pass with missing prereq missing field"
