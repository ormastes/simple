require_matrix_text "riscv_rtl_sby_proof_blocker=sby,yosys,smt-solver"
require_matrix_text "without sby, yosys, and an SMT solver"
require_matrix_text "s/.* missing=//p"

echo "STATUS: PASS simpleos-formal-coverage"
