#!/bin/sh
# Non-launching status audit for GUI item rendering, HTML/CSS traceability, and
# RenderDoc gates. Heavy renderer/capture checks are referenced, not run here.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/gui_renderdoc_feature_coverage_status}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/gui_renderdoc_feature_coverage_status_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
export GUI_RENDERDOC_AGGREGATE_BUILD_DIR="$BUILD_DIR"

python3 - <<'PY' >"$OUT_ENV"
from pathlib import Path
import os
import re
import subprocess

ROOT = Path.cwd()
AGG_BUILD = Path(os.environ.get("GUI_RENDERDOC_AGGREGATE_BUILD_DIR", "build/gui_renderdoc_feature_coverage_status"))
if not AGG_BUILD.is_absolute():
    AGG_BUILD = ROOT / AGG_BUILD

def value_of(key: str, text: str) -> str:
    out = ""
    prefix = key + "="
    for line in text.splitlines():
        if line.startswith(prefix):
            out = line[len(prefix):]
    return out

def emit(key: str, value) -> None:
    value = "" if value is None else str(value)
    value = value.replace("\n", " ")
    print(f"{key}={value}")

def rel(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)

def rel_text_path(value: str) -> str:
    if not value:
        return ""
    path = Path(value)
    if path.is_absolute():
        return rel(path)
    return value

widget_kind_path = ROOT / "src/lib/common/ui/widget_kind.spl"
html_widgets_path = ROOT / "src/app/ui.render/html_widgets.spl"
manifest_path = ROOT / "tools/electron-live-bitmap/simple_web_layout_capture_manifest.txt"
production_env_path = Path(os.environ.get("PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV", "build/production_gui_web_renderer_parity_evidence/evidence.env"))
if not production_env_path.is_absolute():
    production_env_path = ROOT / production_env_path
electron_env_path = Path(os.environ.get("RDOC_ELECTRON_EVIDENCE_ENV", "build/renderdoc/canonical-probe/electron-html/evidence.env"))
if not electron_env_path.is_absolute():
    electron_env_path = ROOT / electron_env_path

widget_source = widget_kind_path.read_text(encoding="utf-8", errors="ignore")
html_source = html_widgets_path.read_text(encoding="utf-8", errors="ignore")

wire_pairs = re.findall(r"WidgetKind\.([A-Za-z0-9_]+)\s*=>\s*\"([^\"]+)\"", widget_source)
widget_wires = []
seen = set()
for _, wire in wire_pairs:
    if wire not in seen:
        widget_wires.append(wire)
        seen.add(wire)

match = re.search(r"fn render_html_widget\(.*?\n(.*?)\nfn render_html_tree_widget", html_source, re.S)
dispatch_block = match.group(1) if match else ""
dispatch_wires = sorted(set(re.findall(r"^\s*\"([^\"]+)\"\s*=>", dispatch_block, re.M)))
missing_dispatch = [wire for wire in widget_wires if wire not in dispatch_wires]
extra_dispatch = [wire for wire in dispatch_wires if wire not in widget_wires and wire not in {"vbox", "hbox"}]

manifest_cases = []
manifest_exact = 0
manifest_tracked = 0
manifest_opacity_rounding = 0
manifest_float_divergence = 0
manifest_selector_layer_divergence = 0
manifest_color_value_divergence = 0
manifest_percent_viewport_divergence = 0
manifest_auto_margin_divergence = 0
manifest_display_none_flow_divergence = 0
manifest_flex_justify_variants_divergence = 0
manifest_flex_column_divergence = 0
manifest_flex_wrap_reverse_divergence = 0
manifest_flex_safe_unsafe_center_divergence = 0
if manifest_path.exists():
    for line in manifest_path.read_text(encoding="utf-8", errors="ignore").splitlines():
        if not line or line.startswith("#"):
            continue
        parts = line.split("|", 5)
        if len(parts) < 5:
            continue
        case_id, scene, width, height, policy = parts[:5]
        manifest_cases.append(case_id)
        if policy == "exact":
            manifest_exact += 1
        elif policy == "track-text-divergence":
            manifest_tracked += 1
        elif policy == "track-compositor-opacity-rounding":
            manifest_opacity_rounding += 1
        elif policy == "track-float-layout-divergence":
            manifest_float_divergence += 1
        elif policy == "track-css-selector-layer-divergence":
            manifest_selector_layer_divergence += 1
        elif policy == "track-css-color-value-divergence":
            manifest_color_value_divergence += 1
        elif policy == "track-css-percent-viewport-divergence":
            manifest_percent_viewport_divergence += 1
        elif policy == "track-css-auto-margin-divergence":
            manifest_auto_margin_divergence += 1
        elif policy == "track-css-display-none-flow-divergence":
            manifest_display_none_flow_divergence += 1
        elif policy == "track-css-flex-justify-variants-divergence":
            manifest_flex_justify_variants_divergence += 1
        elif policy == "track-css-flex-column-divergence":
            manifest_flex_column_divergence += 1
        elif policy == "track-css-flex-wrap-reverse-divergence":
            manifest_flex_wrap_reverse_divergence += 1
        elif policy == "track-css-flex-safe-unsafe-center-divergence":
            manifest_flex_safe_unsafe_center_divergence += 1

traceability_status = "unavailable"
traceability_reason = "missing-html-css-sspec-traceability-check"
traceability_output = ""
traceability_code = 127
traceability_env_path = AGG_BUILD / "sspec-traceability/evidence.env"
if Path("scripts/check/check-html-css-sspec-traceability.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "sspec-traceability")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "sspec-traceability/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-html-css-sspec-traceability.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    traceability_output = proc.stdout
    traceability_code = proc.returncode
    traceability_env = traceability_env_path.read_text(encoding="utf-8", errors="ignore") if traceability_env_path.exists() else traceability_output
    traceability_status = value_of("html_css_sspec_traceability_status", traceability_env)
    traceability_reason = value_of("html_css_sspec_traceability_reason", traceability_env)
    traceability_html_count = value_of("html_css_sspec_traceability_html_tag_count", traceability_env)
    traceability_required_html_count = value_of("html_css_sspec_traceability_required_html_tag_count", traceability_env)
    traceability_css_count = value_of("html_css_sspec_traceability_css_property_count", traceability_env)
    traceability_required_css_min_count = value_of("html_css_sspec_traceability_required_css_property_min_count", traceability_env)
    traceability_implemented_css_count = value_of("html_css_sspec_traceability_implemented_css_property_count", traceability_env)
else:
    traceability_html_count = ""
    traceability_required_html_count = ""
    traceability_css_count = ""
    traceability_required_css_min_count = ""
    traceability_implemented_css_count = ""
if not traceability_status:
    traceability_status = "fail"
if not traceability_reason:
    traceability_reason = "html-css-sspec-traceability-check-failed"

widget_fixture_output = ""
widget_fixture_code = 127
if Path("scripts/check/check-gui-widget-rendering-fixture-coverage.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "widget-rendering-fixture-coverage")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "widget-rendering-fixture-coverage/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-gui-widget-rendering-fixture-coverage.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    widget_fixture_output = proc.stdout
    widget_fixture_code = proc.returncode

rendering_manifest_output = ""
rendering_manifest_code = 127
if Path("scripts/check/check-html-css-rendering-manifest-traceability.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "rendering-manifest-traceability")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "rendering-manifest-traceability/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-html-css-rendering-manifest-traceability.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    rendering_manifest_output = proc.stdout
    rendering_manifest_code = proc.returncode

goal_output = ""
goal_code = 127
if Path("scripts/check/check-html-css-renderdoc-goal-status.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "renderdoc-goal-status")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "renderdoc-goal-status/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-html-css-renderdoc-goal-status.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    goal_output = proc.stdout
    goal_code = proc.returncode

production_env = production_env_path.read_text(encoding="utf-8", errors="ignore") if production_env_path.exists() else ""
production_status = value_of("production_gui_web_renderer_parity_status", production_env)
production_reason = value_of("production_gui_web_renderer_parity_reason", production_env)
layout_count = value_of("production_gui_web_renderer_parity_layout_manifest_case_count", production_env)
layout_pass = value_of("production_gui_web_renderer_parity_layout_manifest_pass_count", production_env)
layout_tracked = value_of("production_gui_web_renderer_parity_layout_manifest_tracked_count", production_env)
layout_fail = value_of("production_gui_web_renderer_parity_layout_manifest_fail_count", production_env)
if production_env_path.exists() and not production_status:
    production_status = "missing-status"
    production_reason = "existing-evidence-env-missing-production-status"

production_gate_output = ""
production_gate_code = 127
if Path("scripts/check/check-production-gui-web-renderer-parity-gate.shs").exists():
    nested_env = os.environ.copy()
    nested_env["PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV"] = str(production_env_path)
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "production-parity-gate")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "production-parity-gate/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-production-gui-web-renderer-parity-gate.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    production_gate_output = proc.stdout
    production_gate_code = proc.returncode

production_gate_status = value_of("production_gui_web_renderer_parity_gate_status", production_gate_output)
production_gate_reason = value_of("production_gui_web_renderer_parity_gate_reason", production_gate_output)
production_gate_required_source_status = value_of("production_gui_web_renderer_parity_gate_required_source_status", production_gate_output)
production_gate_required_matrix_status = value_of("production_gui_web_renderer_parity_gate_required_matrix_status", production_gate_output)
production_gate_required_layout_status = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_status", production_gate_output)
production_gate_required_layout_count = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_case_count", production_gate_output)
production_gate_required_layout_pass = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_pass_count", production_gate_output)
production_gate_required_layout_tracked = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_tracked_count", production_gate_output)
production_gate_required_layout_fail = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_fail_count", production_gate_output)
production_gate_required_surface_status = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_status", production_gate_output)
production_gate_required_surface_electron_status = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_electron_capture_status", production_gate_output)
production_gate_required_surface_tauri_status = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_capture_status", production_gate_output)
production_gate_required_surface_chrome_status = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_capture_status", production_gate_output)
production_gate_required_surface_tauri_live = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_live_capture", production_gate_output)
production_gate_required_surface_chrome_live = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_live_capture", production_gate_output)
production_gate_required_surface_tauri_count = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_case_count", production_gate_output)
production_gate_required_surface_tauri_pass = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_pass_count", production_gate_output)
production_gate_required_surface_tauri_tracked = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_tracked_count", production_gate_output)
production_gate_required_surface_tauri_fail = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_fail_count", production_gate_output)
production_gate_required_surface_chrome_count = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_case_count", production_gate_output)
production_gate_required_surface_chrome_pass = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_pass_count", production_gate_output)
production_gate_required_surface_chrome_tracked = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_tracked_count", production_gate_output)
production_gate_required_surface_chrome_fail = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_fail_count", production_gate_output)
production_gate_required_surface_tauri_mismatch = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_tauri_mismatch_count", production_gate_output)
production_gate_required_surface_chrome_mismatch = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_chrome_mismatch_count", production_gate_output)
production_gate_required_surface_no_fake = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_no_fake_capture", production_gate_output)
production_gate_required_surface_tolerance = value_of("production_gui_web_renderer_parity_gate_required_surface_manifest_blur_or_tolerance_used", production_gate_output)
production_gate_required_backend_status = value_of("production_gui_web_renderer_parity_gate_required_backend_status", production_gate_output)
production_gate_required_font_status = value_of("production_gui_web_renderer_parity_gate_required_font_offload_status", production_gate_output)
production_gate_required_metal_status = value_of("production_gui_web_renderer_parity_gate_required_metal_readback_status", production_gate_output)
production_gate_source_status = value_of("production_gui_web_renderer_parity_gate_source_status", production_gate_output)
production_gate_matrix_status = value_of("production_gui_web_renderer_parity_gate_matrix_status", production_gate_output)
production_gate_layout_status = value_of("production_gui_web_renderer_parity_gate_layout_manifest_status", production_gate_output)
production_gate_layout_count = value_of("production_gui_web_renderer_parity_gate_layout_manifest_case_count", production_gate_output)
production_gate_layout_pass = value_of("production_gui_web_renderer_parity_gate_layout_manifest_pass_count", production_gate_output)
production_gate_layout_tracked = value_of("production_gui_web_renderer_parity_gate_layout_manifest_tracked_count", production_gate_output)
production_gate_layout_fail = value_of("production_gui_web_renderer_parity_gate_layout_manifest_fail_count", production_gate_output)
production_gate_surface_status = value_of("production_gui_web_renderer_parity_gate_surface_manifest_status", production_gate_output)
production_gate_surface_electron_status = value_of("production_gui_web_renderer_parity_gate_surface_manifest_electron_capture_status", production_gate_output)
production_gate_surface_tauri_status = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_capture_status", production_gate_output)
production_gate_surface_chrome_status = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_capture_status", production_gate_output)
production_gate_surface_tauri_live = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_live_capture", production_gate_output)
production_gate_surface_chrome_live = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_live_capture", production_gate_output)
production_gate_surface_tauri_count = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_case_count", production_gate_output)
production_gate_surface_tauri_pass = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_pass_count", production_gate_output)
production_gate_surface_tauri_tracked = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_tracked_count", production_gate_output)
production_gate_surface_tauri_fail = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_fail_count", production_gate_output)
production_gate_surface_chrome_count = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_case_count", production_gate_output)
production_gate_surface_chrome_pass = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_pass_count", production_gate_output)
production_gate_surface_chrome_tracked = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_tracked_count", production_gate_output)
production_gate_surface_chrome_fail = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_fail_count", production_gate_output)
production_gate_surface_tauri_mismatch = value_of("production_gui_web_renderer_parity_gate_surface_manifest_tauri_mismatch_count", production_gate_output)
production_gate_surface_chrome_mismatch = value_of("production_gui_web_renderer_parity_gate_surface_manifest_chrome_mismatch_count", production_gate_output)
production_gate_surface_no_fake = value_of("production_gui_web_renderer_parity_gate_surface_manifest_no_fake_capture", production_gate_output)
production_gate_surface_tolerance = value_of("production_gui_web_renderer_parity_gate_surface_manifest_blur_or_tolerance_used", production_gate_output)
production_gate_backend_status = value_of("production_gui_web_renderer_parity_gate_backend_status", production_gate_output)
production_gate_font_status = value_of("production_gui_web_renderer_parity_gate_font_offload_status", production_gate_output)
production_gate_metal_status = value_of("production_gui_web_renderer_parity_gate_metal_readback_status", production_gate_output)
if not production_gate_status:
    production_gate_status = "unavailable"
if not production_gate_reason:
    production_gate_reason = "missing-production-parity-gate-evidence"

electron_env = electron_env_path.read_text(encoding="utf-8", errors="ignore") if electron_env_path.exists() else ""
electron_capture_status = value_of("rdoc_capture_status", electron_env)
electron_capture_reason = value_of("rdoc_capture_reason", electron_env)
electron_capture_magic = value_of("rdoc_capture_magic", electron_env)
electron_scene = value_of("rdoc_scene", electron_env)
electron_requested_api = value_of("rdoc_chromium_requested_api", electron_env)
electron_requested_angle = value_of("rdoc_chromium_requested_angle", electron_env)
electron_requested_features = value_of("rdoc_chromium_requested_features", electron_env)
electron_launch_flags = value_of("rdoc_chromium_launch_flags", electron_env)
electron_capture_file = value_of("rdoc_capture_file", electron_env)
electron_html_path = value_of("rdoc_html_path", electron_env)
electron_bin = value_of("rdoc_electron", electron_env)
electron_capture_script = value_of("rdoc_electron_capture_script", electron_env)
electron_status = electron_capture_status or "unavailable"
electron_reason = electron_capture_reason or "missing-electron-rdoc"

electron_gate_output = ""
electron_gate_code = 127
if Path("scripts/check/check-renderdoc-electron-html-gate.shs").exists():
    nested_env = os.environ.copy()
    nested_env["RDOC_ELECTRON_HTML_EVIDENCE_ENV"] = str(electron_env_path)
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "electron-html-gate")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "electron-html-gate/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-renderdoc-electron-html-gate.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    electron_gate_output = proc.stdout
    electron_gate_code = proc.returncode

electron_gate_status = value_of("rdoc_electron_html_gate_status", electron_gate_output)
electron_gate_reason = value_of("rdoc_electron_html_gate_reason", electron_gate_output)
electron_gate_required_backend = value_of("rdoc_electron_html_gate_required_backend", electron_gate_output)
electron_gate_required_scene = value_of("rdoc_electron_html_gate_required_scene", electron_gate_output)
electron_gate_required_status = value_of("rdoc_electron_html_gate_required_status", electron_gate_output)
electron_gate_required_magic = value_of("rdoc_electron_html_gate_required_magic", electron_gate_output)
electron_gate_required_api = value_of("rdoc_electron_html_gate_required_api", electron_gate_output)
electron_gate_required_angle = value_of("rdoc_electron_html_gate_required_angle", electron_gate_output)
electron_gate_required_html_path_suffix = value_of("rdoc_electron_html_gate_required_html_path_suffix", electron_gate_output)
electron_gate_required_capture_script_suffix = value_of("rdoc_electron_html_gate_required_capture_script_suffix", electron_gate_output)
electron_gate_required_launch_flag_enable_features = value_of("rdoc_electron_html_gate_required_launch_flag_enable_features", electron_gate_output)
electron_gate_required_launch_flag_use_angle = value_of("rdoc_electron_html_gate_required_launch_flag_use_angle", electron_gate_output)
if not electron_gate_status:
    electron_gate_status = "unavailable"
if not electron_gate_reason:
    electron_gate_reason = "missing-electron-renderdoc-gate-evidence"

renderdoc_status = value_of("html_css_renderdoc_goal_status", goal_output)
renderdoc_reason = value_of("html_css_renderdoc_goal_reason", goal_output)
rendering_manifest_status = value_of("html_css_rendering_manifest_traceability_status", rendering_manifest_output)
rendering_manifest_reason = value_of("html_css_rendering_manifest_traceability_reason", rendering_manifest_output)
widget_fixture_status = value_of("gui_widget_rendering_fixture_coverage_status", widget_fixture_output)
widget_fixture_reason = value_of("gui_widget_rendering_fixture_coverage_reason", widget_fixture_output)
widget_fixture_count = value_of("gui_widget_rendering_fixture_coverage_widget_kind_count", widget_fixture_output)
widget_fixture_dispatch_count = value_of("gui_widget_rendering_fixture_coverage_dispatch_covered_count", widget_fixture_output)
widget_fixture_class_count = value_of("gui_widget_rendering_fixture_coverage_renderer_class_covered_count", widget_fixture_output)
widget_fixture_spec_count = value_of("gui_widget_rendering_fixture_coverage_spec_covered_count", widget_fixture_output)
widget_fixture_missing_specs = value_of("gui_widget_rendering_fixture_coverage_missing_spec_widgets", widget_fixture_output)
simple_status = value_of("simple_renderdoc_status", goal_output)
simple_reason = value_of("simple_renderdoc_reason", goal_output)
simple_evidence_env = value_of("simple_renderdoc_evidence_env", goal_output)
simple_capture_status = value_of("simple_renderdoc_capture_status", goal_output)
simple_capture_magic = value_of("simple_renderdoc_capture_magic", goal_output)
