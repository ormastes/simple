electron_capture_file = value_of("rdoc_capture_file", electron_env)
electron_capture_file_status = file_exists_status(electron_capture_file)
electron_capture_file_magic = file_magic_of(electron_capture_file)
electron_html_path = value_of("rdoc_html_path", electron_env)
electron_bin = value_of("rdoc_electron", electron_env)
