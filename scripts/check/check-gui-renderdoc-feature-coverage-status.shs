emit("macos_portability_run_captures", macos_run_captures)
emit("macos_portability_capture_simple_status", macos_capture_simple_status)
emit("macos_portability_capture_html_status", macos_capture_html_status)
emit("macos_portability_html_gate_status", macos_html_gate_status)
emit("macos_portability_capture_electron_status", macos_capture_electron_status)
emit("macos_portability_electron_gate_status", macos_electron_gate_status)
emit("renderdoc_evidence_tool", rel(renderdoc_evidence_tool))
emit("renderdoc_evidence_tool_status", "pass" if renderdoc_evidence_tool.is_file() and os.access(renderdoc_evidence_tool, os.X_OK) else "missing-or-not-executable")
emit("simple_renderdoc_capture_command", "RDOC_OUTPUT_DIR=build/renderdoc/canonical-probe scripts/tool/renderdoc-evidence.shs capture-simple")
emit("html_renderdoc_capture_command", "RDOC_EXTERNAL_RUN_CAPTURE=1 sh scripts/check/check-renderdoc-external-host-capture.shs")
emit("electron_renderdoc_capture_command", "RDOC_OUTPUT_DIR=build/renderdoc/canonical-probe scripts/tool/renderdoc-evidence.shs capture-electron-html")
blocked_gates = [gate for gate in renderdoc_blocked_gates.split("|") if gate]
if electron_status != "pass" or electron_gate_status != "pass":
    electron_blocker = "Electron Chromium-on-Vulkan RenderDoc .rdc with nonblank ARGB render proof"
    if electron_blocker not in blocked_gates:
        blocked_gates.append(electron_blocker)
if gui_web_2d_vulkan_comparison_artifact_status != "pass":
    comparison_blocker = "GUI/web/2D Vulkan comparison artifacts for Electron, Chrome, and Simple"
    if comparison_blocker not in blocked_gates:
        blocked_gates.append(comparison_blocker)
if gui_web_2d_vulkan_pixel_comparison_status != "pass":
    pixel_blocker = "Electron, Chrome, and Simple GUI/web/2D Vulkan pairwise pixel comparison"
    if pixel_blocker not in blocked_gates:
        blocked_gates.append(pixel_blocker)
if gui_web_2d_vulkan_browser_backing_status != "pass":
    browser_blocker = "Electron and Chrome Vulkan-backed browser RenderDoc proof"
    if browser_blocker not in blocked_gates:
        blocked_gates.append(browser_blocker)
if production_gate_required_font_status == "pass" and production_gate_font_status != "pass":
    font_blocker = "production GUI/web font offload readback evidence"
    if font_blocker not in blocked_gates:
        blocked_gates.append(font_blocker)
if production_gate_required_metal_status == "pass" and production_gate_metal_status != "pass":
    metal_blocker = "production GUI/web raw Metal readback evidence"
    if metal_blocker not in blocked_gates:
        blocked_gates.append(metal_blocker)
if production_core_status != "pass":
    blocked_gates.append("production GUI/web parity evidence with live Tauri and Chrome captures")
if showcase_8k_status != "pass":
    blocked_gates.append("retained 8K GUI/web/2D performance evidence with FPS, checksum, and RSS")
if rendering_manifest_unrendered_spec_css_property_count > 0:
    blocked_gates.append("full CSS specification rendering coverage beyond implemented Simple Web subset")
blocked_gate = blocked_gates[0] if blocked_gates else ""
emit("blocked_completion_gate", blocked_gate)
emit("blocked_completion_gate_count", len(blocked_gates))
emit("blocked_completion_gates", "|".join(blocked_gates))
PY

status="$(sed -n 's/^gui_renderdoc_feature_coverage_status=//p' "$OUT_ENV" | tail -n 1)"
reason="$(sed -n 's/^gui_renderdoc_feature_coverage_reason=//p' "$OUT_ENV" | tail -n 1)"

report_optional_detail_line() {
    report_label="$1"
    report_status="$2"
    report_reason="$3"
    report_detail_label="$4"
    report_detail="$5"
    report_tail=""
    if [ -n "$report_reason" ]; then
        report_tail="$report_reason"
    fi
    if [ -n "$report_detail" ]; then
        report_tail="${report_tail:+$report_tail; }$report_detail_label $report_detail"
    fi
    if [ -z "$report_status$report_tail" ]; then
        echo "- $report_label:"
    else
        echo "- $report_label:${report_status:+ $report_status}${report_tail:+ ($report_tail)}"
    fi
}

report_optional_pair_line() {
    report_label="$1"
    report_status="$2"
    report_left="$3"
    report_right="$4"
    report_tail=""
    if [ -n "$report_left" ]; then
        report_tail="$report_left"
    fi
    if [ -n "$report_right" ]; then
        report_tail="${report_tail:+$report_tail / }$report_right"
    fi
    if [ -z "$report_status$report_tail" ]; then
        echo "- $report_label:"
    else
        echo "- $report_label:${report_status:+ $report_status}${report_tail:+ ($report_tail)}"
    fi
}

{
    echo "# GUI RenderDoc Feature Coverage Status"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- widget HTML renderer dispatch: $(sed -n 's/^widget_html_renderer_dispatch_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget rendering fixture/spec coverage: $(sed -n 's/^gui_widget_rendering_fixture_coverage_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_widget_rendering_fixture_coverage_spec_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1))"
    echo "- widget renderer class coverage: $(sed -n 's/^gui_widget_rendering_fixture_coverage_renderer_class_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget render fixture witnesses: $(sed -n 's/^gui_widget_rendering_fixture_coverage_render_fixture_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget RenderDoc HTML fixture witnesses: $(sed -n 's/^gui_widget_rendering_fixture_coverage_renderdoc_fixture_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget RenderDoc goal: $(sed -n 's/^gui_widget_renderdoc_goal_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_widget_renderdoc_goal_reason=//p' "$OUT_ENV" | tail -n 1); blocked $(sed -n 's/^gui_widget_renderdoc_goal_blocked_gate_count=//p' "$OUT_ENV" | tail -n 1))"
    widget_goal_blocker_doc="$(sed -n 's/^gui_widget_renderdoc_goal_blocker_doc=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$widget_goal_blocker_doc" ]; then
        echo "- widget RenderDoc blocker: $widget_goal_blocker_doc"
    fi
    echo "- Electron layout manifest cases: $(sed -n 's/^electron_layout_manifest_case_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- HTML/CSS rendering manifest traceability: $(sed -n 's/^html_css_rendering_manifest_traceability_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^html_css_rendering_manifest_traceability_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- HTML/CSS rendered tags: $(sed -n 's/^html_css_rendering_manifest_traceability_html_tag_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^html_css_rendering_manifest_traceability_html_tag_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- HTML/CSS rendered implemented properties: $(sed -n 's/^html_css_rendering_manifest_traceability_css_property_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^html_css_rendering_manifest_traceability_css_property_count=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^html_css_rendering_manifest_traceability_css_property_scope=//p' "$OUT_ENV" | tail -n 1))"
    echo "- HTML/CSS full CSS spec render gap: $(sed -n 's/^html_css_rendering_manifest_traceability_unrendered_spec_css_property_count=//p' "$OUT_ENV" | tail -n 1) of $(sed -n 's/^html_css_rendering_manifest_traceability_total_css_property_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- HTML/CSS full rendering goal: $(sed -n 's/^html_css_full_rendering_goal_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^html_css_full_rendering_goal_reason=//p' "$OUT_ENV" | tail -n 1); full CSS $(sed -n 's/^html_css_full_rendering_goal_full_css_rendered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^html_css_full_rendering_goal_full_css_total_count=//p' "$OUT_ENV" | tail -n 1))"
    echo "- RenderDoc goal: $(sed -n 's/^renderdoc_goal_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^renderdoc_goal_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Simple RenderDoc: $(sed -n 's/^simple_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^simple_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- External Chrome/Vulkan RenderDoc: $(sed -n 's/^external_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^external_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Electron Chromium/Vulkan RenderDoc: $(sed -n 's/^electron_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^electron_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Electron Chromium/Vulkan gate: $(sed -n 's/^electron_renderdoc_gate_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^electron_renderdoc_gate_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- GUI/web/2D Vulkan setup source: $(sed -n 's/^gui_web_2d_vulkan_setup_source=//p' "$OUT_ENV" | tail -n 1)"
    echo "- GUI/web/2D Vulkan setup mode: $(sed -n 's/^gui_web_2d_vulkan_mode=//p' "$OUT_ENV" | tail -n 1)"
    report_optional_detail_line "GUI/web/2D Vulkan direct-run source" "$(sed -n 's/^gui_web_2d_vulkan_direct_run_source=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^gui_web_2d_vulkan_direct_run_mode=//p' "$OUT_ENV" | tail -n 1)" "evidence" "$(sed -n 's/^gui_web_2d_vulkan_direct_run_evidence_env=//p' "$OUT_ENV" | tail -n 1)"
    comparison_artifact_blocker_doc="$(sed -n 's/^gui_web_2d_vulkan_comparison_artifact_blocker_doc=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$comparison_artifact_blocker_doc" ]; then
        echo "- GUI/web/2D comparison artifact blocker: $comparison_artifact_blocker_doc"
    fi
    pixel_comparison_blocker_doc="$(sed -n 's/^gui_web_2d_vulkan_pixel_comparison_blocker_doc=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$pixel_comparison_blocker_doc" ]; then
        echo "- GUI/web/2D pixel comparison blocker: $pixel_comparison_blocker_doc"
    fi
    echo "- GUI/web/2D browser Vulkan backing: $(sed -n 's/^gui_web_2d_vulkan_browser_backing_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_web_2d_vulkan_browser_backing_mode=//p' "$OUT_ENV" | tail -n 1); $(sed -n 's/^gui_web_2d_vulkan_browser_backing_reason=//p' "$OUT_ENV" | tail -n 1))"
    browser_backing_blocker_doc="$(sed -n 's/^gui_web_2d_vulkan_browser_backing_blocker_doc=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$browser_backing_blocker_doc" ]; then
        echo "- GUI/web/2D browser backing blocker: $browser_backing_blocker_doc"
    fi
    echo "- GUI/web/2D Vulkan RenderDoc blockers: $(sed -n 's/^gui_web_2d_vulkan_renderdoc_blocker_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_web_2d_vulkan_renderdoc_blocker_gate_count=//p' "$OUT_ENV" | tail -n 1); $(sed -n 's/^gui_web_2d_vulkan_renderdoc_blocker_reason=//p' "$OUT_ENV" | tail -n 1))"
    renderdoc_blocker_doc="$(sed -n 's/^gui_web_2d_vulkan_renderdoc_blocker_doc=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$renderdoc_blocker_doc" ]; then
        echo "- GUI/web/2D RenderDoc blocker: $renderdoc_blocker_doc"
    fi
    echo "- GUI/web/2D Vulkan loader: $(sed -n 's/^gui_web_2d_vulkan_loader_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_web_2d_vulkan_device=//p' "$OUT_ENV" | tail -n 1) / $(sed -n 's/^gui_web_2d_vulkan_driver=//p' "$OUT_ENV" | tail -n 1))"
    echo "- GUI/web/2D Vulkan RenderDoc: $(sed -n 's/^gui_web_2d_vulkan_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_web_2d_vulkan_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- GUI/web/2D Vulkan RenderDoc macOS package: $(sed -n 's/^gui_web_2d_vulkan_renderdoc_macos_homebrew_package_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_web_2d_vulkan_renderdoc_macos_upstream_support_status=//p' "$OUT_ENV" | tail -n 1))"
    report_optional_detail_line "GUI/web/2D Electron direct Vulkan" "$(sed -n 's/^gui_web_2d_vulkan_electron_vulkan_status=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^gui_web_2d_vulkan_electron_vulkan_reason=//p' "$OUT_ENV" | tail -n 1)" "ARGB" "$(sed -n 's/^gui_web_2d_vulkan_electron_argb_status=//p' "$OUT_ENV" | tail -n 1)"
    report_optional_detail_line "GUI/web/2D Chrome direct Vulkan" "$(sed -n 's/^gui_web_2d_vulkan_chrome_vulkan_status=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^gui_web_2d_vulkan_chrome_vulkan_reason=//p' "$OUT_ENV" | tail -n 1)" "bitmap" "$(sed -n 's/^gui_web_2d_vulkan_chrome_bitmap_status=//p' "$OUT_ENV" | tail -n 1)"
    report_optional_detail_line "GUI/web/2D Simple Vulkan" "$(sed -n 's/^gui_web_2d_vulkan_simple_status=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^gui_web_2d_vulkan_simple_reason=//p' "$OUT_ENV" | tail -n 1)" "backend" "$(sed -n 's/^gui_web_2d_vulkan_simple_backend_name=//p' "$OUT_ENV" | tail -n 1)"
    report_optional_pair_line "macOS Vulkan" "$(sed -n 's/^macos_portability_vulkan_status=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^macos_portability_vulkan_device=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^macos_portability_vulkan_driver=//p' "$OUT_ENV" | tail -n 1)"
    macos_renderdoc_report_status="$(sed -n 's/^macos_portability_renderdoc_status=//p' "$OUT_ENV" | tail -n 1)"
    echo "- macOS RenderDoc:${macos_renderdoc_report_status:+ $macos_renderdoc_report_status}"
    echo "- Production GUI/web core parity: $(sed -n 's/^production_gui_web_renderer_parity_core_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^production_gui_web_renderer_parity_core_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Production GUI/web parity gate: $(sed -n 's/^production_gui_web_renderer_parity_gate_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^production_gui_web_renderer_parity_gate_reason=//p' "$OUT_ENV" | tail -n 1))"
    parity_font_blocker_doc="$(sed -n 's/^production_gui_web_renderer_parity_gate_font_offload_blocker_doc=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$parity_font_blocker_doc" ]; then
        echo "- Production GUI/web font blocker: $parity_font_blocker_doc"
    fi
    echo "- GUI/web/2D 8K retained perf: $(sed -n 's/^gui_showcase_8k_perf_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_showcase_8k_perf_reason=//p' "$OUT_ENV" | tail -n 1); fps_x1000 $(sed -n 's/^gui_showcase_8k_perf_fps_x1000=//p' "$OUT_ENV" | tail -n 1); rss $(sed -n 's/^gui_showcase_8k_perf_max_rss_kb=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_showcase_8k_perf_max_rss_budget_kb=//p' "$OUT_ENV" | tail -n 1) kB)"
    report_optional_pair_line "Production surface host" "" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_host_uname_s=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_host_uname_m=//p' "$OUT_ENV" | tail -n 1)"
    report_optional_detail_line "Production Tauri surface capture" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_tauri_capture_status=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_tauri_capture_reason=//p' "$OUT_ENV" | tail -n 1)" "backend" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_tauri_capture_backend=//p' "$OUT_ENV" | tail -n 1)"
    report_optional_detail_line "Production Chrome surface capture" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_chrome_capture_status=//p' "$OUT_ENV" | tail -n 1)" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_chrome_capture_reason=//p' "$OUT_ENV" | tail -n 1)" "backend" "$(sed -n 's/^production_gui_web_renderer_parity_gate_surface_manifest_chrome_capture_backend=//p' "$OUT_ENV" | tail -n 1)"
    echo "- blocked completion gates: $(sed -n 's/^blocked_completion_gate_count=//p' "$OUT_ENV" | tail -n 1)"
    blocked_completion_gates="$(sed -n 's/^blocked_completion_gates=//p' "$OUT_ENV" | tail -n 1)"
    if [ -n "$blocked_completion_gates" ]; then
        echo "- blocked gate list:"
        printf '%s\n' "$blocked_completion_gates" | tr '|' '\n' | sed 's/^/  - /'
    fi
    echo
    echo "## Commands"
    echo
    echo "- HTML/CSS traceability: \`$(sed -n 's/^html_css_traceability_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- GUI widget rendering fixture coverage: \`$(sed -n 's/^gui_widget_rendering_fixture_coverage_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- HTML/CSS rendering manifest traceability: \`$(sed -n 's/^html_css_rendering_manifest_traceability_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- GUI/web/2D Vulkan setup: \`$(sed -n 's/^gui_web_2d_vulkan_setup_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Production GUI/web parity: \`$(sed -n 's/^production_gui_web_renderer_parity_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Production GUI/web parity gate: \`$(sed -n 's/^production_gui_web_renderer_parity_gate_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- RenderDoc evidence CLI: $(sed -n 's/^renderdoc_evidence_tool_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^renderdoc_evidence_tool=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Simple RenderDoc: \`$(sed -n 's/^simple_renderdoc_capture_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Original Chrome/Vulkan RenderDoc: \`$(sed -n 's/^html_renderdoc_capture_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Electron Chromium RenderDoc: \`$(sed -n 's/^electron_renderdoc_capture_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Electron Chromium/Vulkan gate: \`$(sed -n 's/^electron_renderdoc_gate_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$OUT_ENV"
} >"$REPORT_PATH"

cat "$OUT_ENV"

if [ "$status" = "fail" ]; then
    exit 1
fi
if [ "${GUI_RENDERDOC_STATUS_STRICT:-0}" = "1" ] && [ "$status" != "pass" ]; then
    exit 1
fi
