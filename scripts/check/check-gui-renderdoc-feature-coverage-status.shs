        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    electron_gate_output = proc.stdout
    electron_gate_code = proc.returncode

