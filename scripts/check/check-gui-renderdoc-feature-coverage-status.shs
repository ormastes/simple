blocked_gate = "original Chrome-on-Vulkan RenderDoc .rdc with RDOC magic"
if renderdoc_status == "pass" and electron_gate_status != "pass":
    blocked_gate = "Electron Chromium/Vulkan RenderDoc .rdc with RDOC magic"
emit("blocked_completion_gate", blocked_gate)
PY

status="$(sed -n 's/^gui_renderdoc_feature_coverage_status=//p' "$OUT_ENV" | tail -n 1)"
reason="$(sed -n 's/^gui_renderdoc_feature_coverage_reason=//p' "$OUT_ENV" | tail -n 1)"

{
    echo "# GUI RenderDoc Feature Coverage Status"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- widget HTML renderer dispatch: $(sed -n 's/^widget_html_renderer_dispatch_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget rendering fixture/spec coverage: $(sed -n 's/^gui_widget_rendering_fixture_coverage_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_widget_rendering_fixture_coverage_spec_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Electron layout manifest cases: $(sed -n 's/^electron_layout_manifest_case_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- HTML/CSS rendering manifest traceability: $(sed -n 's/^html_css_rendering_manifest_traceability_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^html_css_rendering_manifest_traceability_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- RenderDoc goal: $(sed -n 's/^renderdoc_goal_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^renderdoc_goal_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Simple RenderDoc: $(sed -n 's/^simple_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^simple_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- External Chrome/Vulkan RenderDoc: $(sed -n 's/^external_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^external_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Electron Chromium/Vulkan RenderDoc: $(sed -n 's/^electron_renderdoc_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^electron_renderdoc_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Electron Chromium/Vulkan gate: $(sed -n 's/^electron_renderdoc_gate_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^electron_renderdoc_gate_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo "- Production GUI/web parity gate: $(sed -n 's/^production_gui_web_renderer_parity_gate_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^production_gui_web_renderer_parity_gate_reason=//p' "$OUT_ENV" | tail -n 1))"
    echo
    echo "## Commands"
    echo
    echo "- HTML/CSS traceability: \`$(sed -n 's/^html_css_traceability_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- GUI widget rendering fixture coverage: \`$(sed -n 's/^gui_widget_rendering_fixture_coverage_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- HTML/CSS rendering manifest traceability: \`$(sed -n 's/^html_css_rendering_manifest_traceability_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Production GUI/web parity: \`$(sed -n 's/^production_gui_web_renderer_parity_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Production GUI/web parity gate: \`$(sed -n 's/^production_gui_web_renderer_parity_gate_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Simple RenderDoc: \`$(sed -n 's/^simple_renderdoc_capture_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Original Chrome/Vulkan RenderDoc: \`$(sed -n 's/^html_renderdoc_capture_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Electron Chromium RenderDoc: \`$(sed -n 's/^electron_renderdoc_capture_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo "- Electron Chromium/Vulkan gate: \`$(sed -n 's/^electron_renderdoc_gate_command=//p' "$OUT_ENV" | tail -n 1)\`"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$OUT_ENV"
} >"$REPORT_PATH"

cat "$OUT_ENV"

if [ "$status" = "fail" ]; then
    exit 1
fi
if [ "${GUI_RENDERDOC_STATUS_STRICT:-0}" = "1" ] && [ "$status" != "pass" ]; then
    exit 1
fi
