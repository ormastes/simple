if gui_web_2d_vulkan_loader_status not in {"pass", "present"}:
    renderdoc_blocker_gates.append(status_reason("vulkan-loader", gui_web_2d_vulkan_loader_status, gui_web_2d_vulkan_driver))
if gui_web_2d_vulkan_renderdoc_status != "pass":
    renderdoc_blocker_gates.append(status_reason("renderdoc-command", gui_web_2d_vulkan_renderdoc_status, gui_web_2d_vulkan_renderdoc_reason))
