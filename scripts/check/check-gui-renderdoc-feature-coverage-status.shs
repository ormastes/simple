emit("simple_renderdoc_capture_command", "RDOC_OUTPUT_DIR=build/renderdoc/canonical-probe scripts/tool/renderdoc-evidence.shs capture-simple")
emit("html_renderdoc_capture_command", "RDOC_EXTERNAL_RUN_CAPTURE=1 sh scripts/check/check-renderdoc-external-host-capture.shs")
emit("electron_renderdoc_capture_command", "RDOC_OUTPUT_DIR=build/renderdoc/electron-implicit-layer-default-autocapture scripts/tool/renderdoc-evidence.shs capture-electron-html")
blocked_gates = [gate for gate in renderdoc_blocked_gates.split("|") if gate]
if widget_goal_status != "pass":
    for widget_blocker in [gate for gate in widget_goal_blocked_gates.split("|") if gate]:
        if widget_blocker not in blocked_gates:
            blocked_gates.append(widget_blocker)
if electron_status != "pass" or electron_gate_status != "pass":
    electron_blocker = "Electron Chromium-on-Vulkan RenderDoc .rdc with nonblank ARGB render proof"
    if electron_blocker not in blocked_gates:
        blocked_gates.append(electron_blocker)
if gui_web_2d_vulkan_comparison_artifact_status != "pass":
    comparison_blocker = "GUI/web/2D Vulkan comparison artifacts for Electron, Chrome, and Simple"
    if comparison_blocker not in blocked_gates:
        blocked_gates.append(comparison_blocker)
if vulkan_engine2d_readback_validation_status != "pass":
    readback_blocker = "Simple Vulkan Engine2D clear/rect readback parity evidence"
    if readback_blocker not in blocked_gates:
        blocked_gates.append(readback_blocker)
if gui_web_2d_vulkan_pixel_comparison_status != "pass":
    pixel_blocker = "Electron, Chrome, and Simple GUI/web/2D Vulkan pairwise pixel comparison"
    if pixel_blocker not in blocked_gates:
        blocked_gates.append(pixel_blocker)
if gui_web_2d_vulkan_browser_backing_status != "pass":
    browser_blocker = "Electron and Chrome Vulkan-backed browser RenderDoc proof"
    if browser_blocker not in blocked_gates:
        blocked_gates.append(browser_blocker)
if web_wm_modern_shell_status != "pass":
    web_wm_blocker = "modern Web WM Electron visual and interaction evidence"
    if web_wm_blocker not in blocked_gates:
        blocked_gates.append(web_wm_blocker)
if native_render_log_platform_matrix_status != "pass":
    native_log_platforms = ",".join(native_render_log_missing_platforms + native_render_log_failed_platforms)
    native_log_blocker = f"native render-log comparison for remaining platforms: {native_log_platforms}"
    if native_log_blocker not in blocked_gates:
        blocked_gates.append(native_log_blocker)
if production_gate_required_font_status == "pass" and production_gate_font_status != "pass":
    font_blocker = "production GUI/web font offload readback evidence"
    if font_blocker not in blocked_gates:
        blocked_gates.append(font_blocker)
if production_gate_required_metal_status == "pass" and production_gate_metal_status != "pass":
    metal_blocker = "production GUI/web raw Metal readback evidence"
    if metal_blocker not in blocked_gates:
        blocked_gates.append(metal_blocker)
if production_core_status != "pass":
    blocked_gates.append("production GUI/web parity evidence with live Tauri and Chrome captures")
if showcase_4k_status != "pass":
    blocked_gates.append("retained 4K GUI/web/2D 200fps performance evidence with FPS and checksum")
if showcase_8k_status != "pass":
    blocked_gates.append("retained 8K GUI/web/2D performance evidence with FPS, checksum, and RSS")
if rendering_manifest_unrendered_spec_css_property_count > 0:
    blocked_gates.append("full CSS specification rendering coverage beyond implemented Simple Web subset")
if full_rendering_goal_animation_css_status != "pass":
    blocked_gates.append("CSS animation/transition/transform rendering coverage")
blocked_gate = blocked_gates[0] if blocked_gates else ""
emit("blocked_completion_gate", blocked_gate)
emit("blocked_completion_gate_count", len(blocked_gates))
emit("blocked_completion_gates", "|".join(blocked_gates))
PY

status="$(sed -n 's/^gui_renderdoc_feature_coverage_status=//p' "$OUT_ENV" | tail -n 1)"
reason="$(sed -n 's/^gui_renderdoc_feature_coverage_reason=//p' "$OUT_ENV" | tail -n 1)"

report_optional_detail_line() {
    report_label="$1"
    report_status="$2"
    report_reason="$3"
    report_detail_label="$4"
    report_detail="$5"
    report_tail=""
    if [ -n "$report_reason" ]; then
        report_tail="$report_reason"
    fi
    if [ -n "$report_detail" ]; then
        report_tail="${report_tail:+$report_tail; }$report_detail_label $report_detail"
    fi
    if [ -z "$report_status$report_tail" ]; then
        echo "- $report_label:"
    else
        echo "- $report_label:${report_status:+ $report_status}${report_tail:+ ($report_tail)}"
    fi
}

report_optional_pair_line() {
    report_label="$1"
    report_status="$2"
    report_left="$3"
    report_right="$4"
    report_tail=""
    if [ -n "$report_left" ]; then
        report_tail="$report_left"
    fi
    if [ -n "$report_right" ]; then
        report_tail="${report_tail:+$report_tail / }$report_right"
    fi
    if [ -z "$report_status$report_tail" ]; then
        echo "- $report_label:"
    else
        echo "- $report_label:${report_status:+ $report_status}${report_tail:+ ($report_tail)}"
    fi
}

{
    echo "# GUI RenderDoc Feature Coverage Status"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- widget HTML renderer dispatch: $(sed -n 's/^widget_html_renderer_dispatch_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget rendering fixture/spec coverage: $(sed -n 's/^gui_widget_rendering_fixture_coverage_status=//p' "$OUT_ENV" | tail -n 1) ($(sed -n 's/^gui_widget_rendering_fixture_coverage_spec_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1))"
    echo "- widget renderer class coverage: $(sed -n 's/^gui_widget_rendering_fixture_coverage_renderer_class_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget render fixture witnesses: $(sed -n 's/^gui_widget_rendering_fixture_coverage_render_fixture_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
    echo "- widget RenderDoc HTML fixture witnesses: $(sed -n 's/^gui_widget_rendering_fixture_coverage_renderdoc_fixture_covered_count=//p' "$OUT_ENV" | tail -n 1)/$(sed -n 's/^gui_widget_rendering_fixture_coverage_widget_kind_count=//p' "$OUT_ENV" | tail -n 1)"
