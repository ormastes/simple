if not production_gate_status:
    production_gate_status = "unavailable"
if not production_gate_reason:
    production_gate_reason = "missing-production-parity-gate-evidence"

production_core_checks = [
    ("matrix", production_gate_matrix_status, "pass"),
    ("layout_manifest", production_gate_layout_status, "pass"),
    ("layout_manifest_case_count", production_gate_layout_count, "50"),
    ("layout_manifest_pass_count", production_gate_layout_pass, "36"),
    ("layout_manifest_tracked_count", production_gate_layout_tracked, "14"),
    ("layout_manifest_fail_count", production_gate_layout_fail, "0"),
    ("surface_manifest", production_gate_surface_status, "pass"),
    ("surface_manifest_electron_capture", production_gate_surface_electron_status, "pass"),
    ("surface_manifest_tauri_capture", production_gate_surface_tauri_status, "pass"),
    ("surface_manifest_chrome_capture", production_gate_surface_chrome_status, "pass"),
    ("surface_manifest_tauri_live_capture", production_gate_surface_tauri_live, "true"),
    ("surface_manifest_chrome_live_capture", production_gate_surface_chrome_live, "true"),
    ("surface_manifest_tauri_case_count", production_gate_surface_tauri_count, "50"),
    ("surface_manifest_tauri_pass_count", production_gate_surface_tauri_pass, "36"),
    ("surface_manifest_tauri_tracked_count", production_gate_surface_tauri_tracked, "14"),
    ("surface_manifest_tauri_fail_count", production_gate_surface_tauri_fail, "0"),
    ("surface_manifest_chrome_case_count", production_gate_surface_chrome_count, "50"),
    ("surface_manifest_chrome_pass_count", production_gate_surface_chrome_pass, "36"),
    ("surface_manifest_chrome_tracked_count", production_gate_surface_chrome_tracked, "14"),
    ("surface_manifest_chrome_fail_count", production_gate_surface_chrome_fail, "0"),
    ("surface_manifest_tauri_mismatch_count", production_gate_surface_tauri_mismatch, "0"),
    ("surface_manifest_chrome_mismatch_count", production_gate_surface_chrome_mismatch, "0"),
    ("surface_manifest_no_fake_capture", production_gate_surface_no_fake, "true"),
    ("surface_manifest_blur_or_tolerance_used", production_gate_surface_tolerance, "false"),
    ("backend", production_gate_backend_status, "pass"),
    ("backend_readback_source", production_gate_backend_readback_source, "device_readback"),
]
production_core_missing = [
    f"{name}:{actual or '<missing>'}!={expected}"
    for name, actual, expected in production_core_checks
    if actual != expected
]
if production_core_missing:
    production_core_status = "fail"
    if production_gate_status == "unavailable" and production_gate_reason:
        production_core_reason = production_gate_reason
    else:
        production_core_reason = "core-gui-web-parity-missing:" + ",".join(production_core_missing)
else:
    production_core_status = "pass"
    production_core_reason = "pass"

electron_env = electron_env_path.read_text(encoding="utf-8", errors="ignore") if electron_env_path.exists() else ""
electron_capture_status = value_of("rdoc_capture_status", electron_env)
electron_capture_reason = value_of("rdoc_capture_reason", electron_env)
electron_capture_magic = value_of("rdoc_capture_magic", electron_env)
