#!/bin/sh
# Non-launching status audit for GUI item rendering, HTML/CSS traceability, and
# RenderDoc gates. Heavy renderer/capture checks are referenced, not run here.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/gui_renderdoc_feature_coverage_status}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/gui_renderdoc_feature_coverage_status_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
export GUI_RENDERDOC_AGGREGATE_BUILD_DIR="$BUILD_DIR"

python3 - <<'PY' >"$OUT_ENV"
from pathlib import Path
import hashlib
import json
import os
import re
import shutil
import subprocess

ROOT = Path.cwd()
AGG_BUILD = Path(os.environ.get("GUI_RENDERDOC_AGGREGATE_BUILD_DIR", "build/gui_renderdoc_feature_coverage_status"))
if not AGG_BUILD.is_absolute():
    AGG_BUILD = ROOT / AGG_BUILD
STATIC_CACHE_DIR_TEXT = os.environ.get("GUI_RENDERDOC_AGGREGATE_STATIC_CACHE_DIR", "")
if not STATIC_CACHE_DIR_TEXT and os.environ.get("GUI_RENDERDOC_AGGREGATE_DISABLE_DEFAULT_STATIC_CACHE", "0") != "1":
    STATIC_CACHE_DIR_TEXT = "build/gui-renderdoc-feature-coverage-static-cache"
STATIC_CACHE_DIR = Path(STATIC_CACHE_DIR_TEXT) if STATIC_CACHE_DIR_TEXT else None
if STATIC_CACHE_DIR is not None and not STATIC_CACHE_DIR.is_absolute():
    STATIC_CACHE_DIR = ROOT / STATIC_CACHE_DIR
READONLY_STATIC_CACHE_DIR_TEXT = os.environ.get("GUI_RENDERDOC_AGGREGATE_READONLY_STATIC_CACHE_DIR", "")
READONLY_STATIC_CACHE_DIR = Path(READONLY_STATIC_CACHE_DIR_TEXT) if READONLY_STATIC_CACHE_DIR_TEXT else None
if READONLY_STATIC_CACHE_DIR is not None and not READONLY_STATIC_CACHE_DIR.is_absolute():
    READONLY_STATIC_CACHE_DIR = ROOT / READONLY_STATIC_CACHE_DIR
renderdoc_evidence_tool = ROOT / "scripts/tool/renderdoc-evidence.shs"

def value_of(key: str, text: str) -> str:
    out = ""
    prefix = key + "="
    for line in text.splitlines():
        line = line.lstrip("\ufeff")
        if line.startswith(prefix):
            out = line[len(prefix):]
    return out

def emit(key: str, value) -> None:
    value = "" if value is None else str(value)
    value = value.replace("\n", " ")
    print(f"{key}={value}")

def rel(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)

def rel_text_path(value: str) -> str:
    if not value:
        return ""
    path = Path(value)
    if path.is_absolute():
        return rel(path)
    return value

def path_from_text(value: str) -> Path:
    path = Path(value)
    if not path.is_absolute():
        path = ROOT / path
    return path

def file_exists_status(value: str) -> str:
    if not value:
        return "unavailable"
    return "pass" if path_from_text(value).is_file() else "missing"

def regular_file_status(value: str) -> str:
    if not value:
        return "unavailable"
    path = path_from_text(value)
    if path.is_symlink():
        return "symlink"
    if not path.is_file():
        return "missing"
    try:
        if path.stat().st_nlink > 1:
            return "hardlink"
    except OSError:
        return "missing"
    return "pass"

def regular_file_reason(value: str) -> str:
    if not value:
        return "missing-path"
    path = path_from_text(value)
    if path.is_symlink():
        return "symlink"
    if not path.exists():
        return "missing"
    if not path.is_file():
        return "not-regular"
    try:
        if path.stat().st_nlink > 1:
            return "hardlink"
    except OSError:
        return "missing"
    return "pass"

def chrome_argb_proof_json_status_reason(value: str):
    if not value:
        return ("unavailable", "missing-path")
    path = path_from_text(value)
    if path.is_symlink():
        return ("fail", "symlink")
    if not path.is_file():
        return ("missing", "missing-file")
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return ("fail", "invalid-json")
    aux = (((data.get("gpu_info") or {}).get("gpu") or {}).get("auxAttributes") or {})
    missing = []
    if aux.get("hardwareSupportsVulkan") is not True:
        missing.append("hardwareSupportsVulkan")
    marker = " ".join(
        str(aux.get(key) or "")
        for key in [
            "displayType",
            "glImplementationParts",
            "glRenderer",
            "skiaBackendType",
        ]
    ).lower()
    if "vulkan" not in marker:
        missing.append("vulkan-marker")
    return ("pass", "pass") if not missing else ("fail", "missing-" + ",".join(missing))

def file_executable_status(value: str) -> str:
    if not value:
        return "unavailable"
    path = path_from_text(value)
    return "pass" if path.is_file() and os.access(path, os.X_OK) else "missing"

def regular_executable_status(value: str) -> str:
    if not value:
        return "unavailable"
    path = path_from_text(value)
    if path.is_symlink():
        return "symlink"
    if not path.is_file() or not os.access(path, os.X_OK):
        return "missing"
    try:
        if path.stat().st_nlink > 1:
            return "hardlink"
    except OSError:
        return "missing"
    return "pass"

def native_bin_magic(value: str) -> str:
    if not value:
        return ""
    path = path_from_text(value)
    if path.is_symlink() or not path.is_file():
        return ""
    try:
        return path.read_bytes()[:4].hex()
    except Exception:
        return ""

def native_bin_format_from_magic(magic: str) -> str:
    if magic == "7f454c46":
        return "elf"
    if magic in {"cffaedfe", "feedfacf", "cefaedfe", "feedface", "cafebabe", "bebafeca"}:
        return "macho"
    if magic.startswith("4d5a"):
        return "pe"
    return "unknown"

def native_bin_format_status_from_format(fmt: str) -> str:
    return "pass" if fmt in {"elf", "macho", "pe"} else "fail"

def evidence_file_status(value: str, explicit_status: str) -> str:
    actual_status = file_exists_status(value)
    if explicit_status == "pass":
        return actual_status
    if explicit_status:
        return explicit_status
    return actual_status

def evidence_regular_file_status(value: str, explicit_status: str) -> str:
    actual_status = regular_file_status(value)
    if actual_status == "symlink":
        return actual_status
    if explicit_status == "pass":
        return actual_status
    if explicit_status:
        return explicit_status
    return actual_status

def evidence_executable_status(value: str, explicit_status: str) -> str:
    actual_status = file_executable_status(value)
    if explicit_status == "pass":
        return actual_status
    if explicit_status:
        return explicit_status
    return actual_status

def evidence_regular_executable_status(value: str, explicit_status: str) -> str:
    actual_status = regular_executable_status(value)
    if actual_status == "symlink":
        return actual_status
    if explicit_status == "pass":
        return actual_status
    if explicit_status:
        return explicit_status
    return actual_status

def evidence_native_bin_magic(value: str, explicit_magic: str) -> str:
    actual_magic = native_bin_magic(value)
    if actual_magic:
        return actual_magic
    if explicit_magic:
        return explicit_magic
    return ""

def evidence_native_bin_format(value: str, explicit_format: str, magic: str) -> str:
    actual_magic = native_bin_magic(value)
    if actual_magic:
        return native_bin_format_from_magic(actual_magic)
    if explicit_format:
        return explicit_format
    return native_bin_format_from_magic(magic or native_bin_magic(value))

def evidence_native_bin_format_status(value: str, explicit_status: str, fmt: str) -> str:
    actual_format = native_bin_format_from_magic(native_bin_magic(value))
    if actual_format != "unknown":
        return "pass"
    if explicit_status == "pass":
        return "fail"
    if explicit_status:
        return explicit_status
    return native_bin_format_status_from_format(fmt)

SHOWCASE_SOURCE_REVISION_FILES = [
    "scripts/check/check-widget-showcase-4k-200fps.shs",
    "examples/06_io/ui/widget_showcase_gui.spl",
    "examples/06_io/ui/showcase_8k_scroll_gui.spl",
    "src/lib/common/ui/scroll_surface.spl",
    "src/lib/common/ui/dirty_region.spl",
    "src/lib/gc_async_mut/gpu/browser_engine/simple_web_html_layout_renderer.spl",
]

def required_source_revision_files_text() -> str:
    return " ".join(SHOWCASE_SOURCE_REVISION_FILES)

def missing_source_revision_files(files_text: str):
    present = set(files_text.split())
    return [rel_path for rel_path in SHOWCASE_SOURCE_REVISION_FILES if rel_path not in present]

def source_revision_files_status(missing_files) -> str:
    return "pass" if not missing_files else "fail"

def current_source_revision() -> str:
    override = os.environ.get("GUI_SHOWCASE_CURRENT_SOURCE_REVISION")
    if override:
        return override
    files_text = os.environ.get(
        "GUI_SHOWCASE_SOURCE_REVISION_FILES",
        required_source_revision_files_text(),
    )
    digest = hashlib.sha256()
    try:
        for rel_path in files_text.split():
            path = ROOT / rel_path
            file_digest = hashlib.sha256(path.read_bytes()).hexdigest()
            digest.update(f"{file_digest}  {rel_path}\n".encode("utf-8"))
        return digest.hexdigest()[:12]
    except Exception:
        pass
    try:
        return subprocess.check_output(
            ["git", "rev-parse", "--short=12", "HEAD"],
            cwd=ROOT,
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
    except Exception:
        return "unknown"

def vcs_source_revision() -> str:
    override = os.environ.get("GUI_WEB_2D_SOURCE_REVISION", "")
    if override:
        return override
    if shutil.which("jj"):
        try:
            out = subprocess.check_output(
                ["jj", "log", "-r", "@", "--no-pager", "-T", "commit_id.short(12)"],
                cwd=ROOT,
                text=True,
                stderr=subprocess.DEVNULL,
            ).strip()
            if out:
                return out
        except Exception:
            pass
    if shutil.which("git"):
        try:
            out = subprocess.check_output(
                ["git", "rev-parse", "--short=12", "HEAD"],
                cwd=ROOT,
                text=True,
                stderr=subprocess.DEVNULL,
            ).strip()
            if out:
                return out
        except Exception:
            pass
    return current_source_revision()

def freshness_metadata_value(env_key: str) -> str:
    return os.environ.get(env_key, "").strip()

native_render_log_platform_matrix_runtime_build = freshness_metadata_value("GUI_WEB_2D_RUNTIME_BUILD")
native_render_log_platform_matrix_browser_webview_electron_revision = freshness_metadata_value("GUI_WEB_2D_BROWSER_WEBVIEW_ELECTRON_REVISION")
native_render_log_platform_matrix_graphics_sdk_driver = freshness_metadata_value("GUI_WEB_2D_GRAPHICS_SDK_DRIVER")
native_render_log_platform_matrix_runbook_version = freshness_metadata_value("GUI_WEB_2D_RUNBOOK_VERSION")

def source_revision_status(evidence_revision: str, current_revision: str) -> str:
    if not evidence_revision:
        return "missing"
    if not current_revision or current_revision == "unknown":
        return "unchecked"
    return "current" if evidence_revision == current_revision else "mismatch"

def simple_bin_provenance_reason(simple_bin: str, simple_bin_source: str, simple_bin_status: str = "") -> str:
    if not simple_bin:
        return "simple_bin=<missing>"
    if not simple_bin_source:
        return "simple_bin_source=<missing>"
    if not simple_bin_status:
        return "simple_bin_status=<missing>"
    if simple_bin_status != "pass":
        return "simple_bin_status=" + simple_bin_status
    normalized = simple_bin.replace("\\", "/")
    if "src/compiler_rust/" in normalized:
        return "simple_bin=rust-seed-forbidden"
    if simple_bin_source != "self-hosted-release":
        return "simple_bin_source=" + simple_bin_source
    release_path = normalized.lstrip("./")
    if not (
        release_path.startswith("release/")
        or release_path.startswith("bin/release/")
        or "/release/" in release_path
        or "/bin/release/" in release_path
    ):
        return "simple_bin=not-release-self-hosted"
    return ""

def status_reason(prefix: str, status: str, reason: str) -> str:
    safe_status = status or "unavailable"
    safe_reason = reason or f"missing-{prefix}-evidence"
    return f"{prefix}-{safe_status}-{safe_reason}"

def png_dimensions_status(value: str, expected_width: str, expected_height: str):
    if not value:
        return "", "", "unavailable"
    path = path_from_text(value)
    if not path.is_file():
        return "", "", "missing"
    try:
        data = path.read_bytes()[:24]
    except OSError:
        return "", "", "unreadable"
    if len(data) < 24 or data[:8] != b"\x89PNG\r\n\x1a\n" or data[12:16] != b"IHDR":
        return "", "", "not-png"
    width = int.from_bytes(data[16:20], "big")
    height = int.from_bytes(data[20:24], "big")
    status = "pass" if width == to_int(expected_width) and height == to_int(expected_height) else "fail"
    return str(width), str(height), status

def to_int(value: str) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0

def positive_int_status(value: str) -> str:
    return "pass" if to_int(value) > 0 else "fail"

def evidence_positive_int_status(explicit: str, value: str) -> str:
    if positive_int_status(value) != "pass":
        return "fail"
    if explicit and explicit != "pass":
        return explicit
    return "pass"

def positive_numeric_fields_status(fields) -> str:
    for value in fields:
        if positive_int_status(value) != "pass":
            return "fail"
    return "pass"

def frame_distribution_status(explicit: str, avg: str, p50: str, p95: str) -> str:
    derived = positive_numeric_fields_status([avg, p50, p95])
    if derived == "pass" and to_int(p95) < to_int(p50):
        derived = "fail"
    if explicit and explicit != "pass":
        return explicit
    return derived

def explicit_or_derived_status(explicit: str, derived: str) -> str:
    return explicit if explicit else derived

def nonempty_status(value: str) -> str:
    return "pass" if value else "fail"

def expected_value_status(value: str, expected: str) -> str:
    return "pass" if value == expected else "fail"

def evidence_expected_value_status(explicit: str, value: str, expected: str) -> str:
    if expected_value_status(value, expected) != "pass":
        return "fail"
    if explicit and explicit != "pass":
        return explicit
    return "pass"

def rss_budget_status(observed: str, budget: str) -> str:
    observed_i = to_int(observed)
    budget_i = to_int(budget)
    if observed_i <= 0 or budget_i <= 0:
        return "fail"
    return "pass" if observed_i <= budget_i else "fail"

def evidence_rss_budget_status(explicit: str, observed: str, budget: str) -> str:
    if rss_budget_status(observed, budget) != "pass":
        return "fail"
    if explicit and explicit != "pass":
        return explicit
    return "pass"

def derived_frame_timing(total_ns: str, frames: str) -> str:
    total = to_int(total_ns)
    count = to_int(frames)
    if total <= 0 or count <= 0:
        return ""
    return str(total // count)

def viewport_match_status(path: str, width: str, height: str, expected_width: str, expected_height: str) -> str:
    if not path and not width and not height:
        return "unavailable"
    if width == expected_width and height == expected_height:
        return "pass"
    return "fail"

def nonblank_status(path: str, nonblank: str) -> str:
    if to_int(nonblank) > 0:
        return "pass"
    if path:
        return "fail"
    return "unavailable"

def unsigned_int_text(value: str) -> bool:
    return bool(value) and value.isdigit()

def pairwise_diff_status(status: str, mismatch_count: str, file_status: str) -> str:
    if status == "pass" and mismatch_count == "0" and file_status == "pass":
        return "pass"
    if status == "pass" and not unsigned_int_text(mismatch_count):
        return "fail"
    if status == "fail" or to_int(mismatch_count) > 0:
        return "fail"
    return "unavailable"

def checksum_value_status(value: str) -> str:
    return "pass" if unsigned_int_text(value) else "fail"

def evidence_checksum_status(explicit: str, value: str) -> str:
    if checksum_value_status(value) != "pass":
        return "fail"
    if explicit and explicit != "pass":
        return explicit
    return "pass"

def retained_readback_mode(explicit: str) -> str:
    return explicit

def checksum_match_status(values) -> str:
    if any(checksum_value_status(value) != "pass" for value in values):
        return "fail"
    return "pass" if len(set(values)) == 1 else "fail"

def file_magic_of(value: str) -> str:
    if not value:
        return ""
    path = Path(value)
    if not path.is_absolute():
        path = ROOT / path
    if not path.is_file():
        return ""
    return path.read_bytes()[:4].decode("latin1", errors="ignore")

def path_fingerprint(value: str) -> str:
    if not value:
        return ""
    path = Path(value)
    if not path.is_absolute():
        path = ROOT / path
    try:
        data = path.read_bytes()
    except OSError:
        return f"{value}|missing"
    return f"{value}|{hashlib.sha256(data).hexdigest()}"

def paths_fingerprint(values) -> str:
    return "|".join(path_fingerprint(value) for value in values)

def env_text_from_path(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="ignore") if path.exists() else ""

def first_existing_path_from_env(env_key: str, candidates):
    configured = os.environ.get(env_key, "")
    if configured:
        path = Path(configured)
        if not path.is_absolute():
            path = ROOT / path
        return path
    for candidate in candidates:
        path = candidate if candidate.is_absolute() else ROOT / candidate
        if path.exists():
            return path
    path = candidates[0]
    return path if path.is_absolute() else ROOT / path

def newest_existing_path_from_env(env_key: str, candidates):
    configured = os.environ.get(env_key, "")
    if configured:
        path = Path(configured)
        if not path.is_absolute():
            path = ROOT / path
        return path
    existing = []
    for candidate in candidates:
        path = candidate if candidate.is_absolute() else ROOT / candidate
        if path.exists():
            existing.append(path)
    if existing:
        return sorted(existing, key=lambda path: path.stat().st_mtime, reverse=True)[0]
    path = candidates[0]
    return path if path.is_absolute() else ROOT / path

def current_refresh_candidates(pattern: str):
    return sorted(ROOT.glob(pattern), key=lambda path: path.stat().st_mtime if path.exists() else 0, reverse=True)

def copy_cached_gate(cache_dir: Path, target_dir: Path) -> None:
    if target_dir.exists():
        shutil.rmtree(target_dir)
    target_dir.mkdir(parents=True, exist_ok=True)
    for name in ("evidence.env", "report.md"):
        src = cache_dir / name
        if src.exists():
            shutil.copy2(src, target_dir / name)

def run_nested_gate(name: str, argv, build_subdir: str, report_name: str, timeout: int, extra_env=None, static_cache: bool = False, cache_key: str = ""):
    target_dir = AGG_BUILD / build_subdir
    target_env = target_dir / "evidence.env"
    cache_name = name
    if cache_key:
        cache_name = f"{name}-{hashlib.sha256(cache_key.encode('utf-8')).hexdigest()[:16]}"
    if static_cache and READONLY_STATIC_CACHE_DIR is not None:
        readonly_cache_dir = READONLY_STATIC_CACHE_DIR / cache_name
        readonly_cache_env = readonly_cache_dir / "evidence.env"
        if readonly_cache_env.exists():
            copy_cached_gate(readonly_cache_dir, target_dir)
            return target_env.read_text(encoding="utf-8", errors="ignore"), 0
    if static_cache and STATIC_CACHE_DIR is not None:
        cache_dir = STATIC_CACHE_DIR / cache_name
        cache_env = cache_dir / "evidence.env"
        if cache_env.exists():
            copy_cached_gate(cache_dir, target_dir)
            return target_env.read_text(encoding="utf-8", errors="ignore"), 0
        run_dir = cache_dir
    else:
        run_dir = target_dir

    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(run_dir)
    nested_env["REPORT_PATH"] = str(run_dir / report_name)
    if extra_env:
        nested_env.update(extra_env)
    proc = subprocess.run(
        argv,
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=timeout,
        check=False,
    )
    if static_cache and STATIC_CACHE_DIR is not None and run_dir != target_dir and run_dir.exists():
        copy_cached_gate(run_dir, target_dir)
    output = target_env.read_text(encoding="utf-8", errors="ignore") if target_env.exists() else proc.stdout
    return output, proc.returncode

def run_cache_selftest() -> None:
    status = "pass"
    reason = "pass"
    readonly_source = ""
    writable_source = ""
    writable_cache_status = "missing"
    if READONLY_STATIC_CACHE_DIR is None or STATIC_CACHE_DIR is None:
        status = "fail"
        reason = "cache-dirs-missing"
    else:
        readonly_cache_dir = READONLY_STATIC_CACHE_DIR / "cache-selftest-readonly"
        readonly_cache_dir.mkdir(parents=True, exist_ok=True)
        (readonly_cache_dir / "evidence.env").write_text(
            "aggregate_cache_selftest_readonly_source=readonly\n",
            encoding="utf-8",
        )
        readonly_output, readonly_code = run_nested_gate(
            "cache-selftest-readonly",
            ["sh", "-c", "mkdir -p \"$BUILD_DIR\" && printf 'aggregate_cache_selftest_readonly_source=writable\\n' > \"$BUILD_DIR/evidence.env\""],
            "cache-selftest-readonly",
            "report.md",
            10,
            static_cache=True,
        )
        writable_output, writable_code = run_nested_gate(
            "cache-selftest-writable",
            ["sh", "-c", "mkdir -p \"$BUILD_DIR\" && printf 'aggregate_cache_selftest_writable_source=writable\\n' > \"$BUILD_DIR/evidence.env\""],
            "cache-selftest-writable",
            "report.md",
            10,
            static_cache=True,
        )
        readonly_source = value_of("aggregate_cache_selftest_readonly_source", readonly_output)
        writable_source = value_of("aggregate_cache_selftest_writable_source", writable_output)
        writable_cache_env = STATIC_CACHE_DIR / "cache-selftest-writable" / "evidence.env"
        writable_cache_status = "pass" if writable_cache_env.exists() else "missing"
        if readonly_code != 0 or writable_code != 0:
            status = "fail"
            reason = "nested-gate-exit"
        elif readonly_source != "readonly":
            status = "fail"
            reason = "readonly-cache-not-preferred"
        elif writable_source != "writable" or writable_cache_status != "pass":
            status = "fail"
            reason = "writable-cache-miss-not-populated"
    print(f"aggregate_cache_selftest_status={status}")
    print(f"aggregate_cache_selftest_reason={reason}")
    print(f"aggregate_cache_selftest_readonly_source={readonly_source}")
    print(f"aggregate_cache_selftest_writable_source={writable_source}")
    print(f"aggregate_cache_selftest_writable_cache_file_status={writable_cache_status}")

if os.environ.get("GUI_RENDERDOC_AGGREGATE_CACHE_SELFTEST", "0") == "1":
    run_cache_selftest()
    raise SystemExit(0)

def run_cache_config_selftest() -> None:
    disable_default = os.environ.get("GUI_RENDERDOC_AGGREGATE_DISABLE_DEFAULT_STATIC_CACHE", "0")
    explicit_static = os.environ.get("GUI_RENDERDOC_AGGREGATE_STATIC_CACHE_DIR", "")
    explicit_readonly = os.environ.get("GUI_RENDERDOC_AGGREGATE_READONLY_STATIC_CACHE_DIR", "")
    if STATIC_CACHE_DIR is None:
        static_status = "unset"
        static_path = ""
    elif explicit_static:
        static_status = "explicit"
        static_path = str(STATIC_CACHE_DIR)
    else:
        static_status = "default"
        static_path = str(STATIC_CACHE_DIR)
    readonly_status = "explicit" if READONLY_STATIC_CACHE_DIR is not None else "unset"
    status = "pass"
    reason = "pass"
    if disable_default == "1" and not explicit_static and STATIC_CACHE_DIR is not None:
        status = "fail"
        reason = "default-cache-not-disabled"
    elif disable_default == "1" and explicit_static and static_status != "explicit":
        status = "fail"
        reason = "explicit-cache-not-preserved"
    print(f"aggregate_cache_config_selftest_status={status}")
    print(f"aggregate_cache_config_selftest_reason={reason}")
    print(f"aggregate_cache_config_disable_default={disable_default}")
    print(f"aggregate_cache_config_static_cache_status={static_status}")
    print(f"aggregate_cache_config_static_cache_path={static_path}")
    print(f"aggregate_cache_config_readonly_cache_status={readonly_status}")
    print(f"aggregate_cache_config_readonly_cache_explicit={1 if explicit_readonly else 0}")

if os.environ.get("GUI_RENDERDOC_AGGREGATE_CACHE_CONFIG_SELFTEST", "0") == "1":
    run_cache_config_selftest()
    raise SystemExit(0)

def is_gui_web_2d_direct_run_env(text: str) -> bool:
    mode = value_of("gui_web_2d_vulkan_mode", text)
    if mode not in {"--run", "--renderdoc", "--renderdoc-simple"}:
        return False
    runtime_keys = [
        "gui_web_2d_vulkan_electron_argb_status",
        "gui_web_2d_vulkan_chrome_argb_status",
        "gui_web_2d_vulkan_simple_argb_status",
        "gui_web_2d_vulkan_chrome_bitmap_status",
        "gui_web_2d_vulkan_simple_status",
        "gui_web_2d_vulkan_electron_chrome_diff_status",
        "gui_web_2d_vulkan_electron_simple_diff_status",
        "gui_web_2d_vulkan_chrome_simple_diff_status",
        "gui_web_2d_vulkan_renderdoc_simple_exit_code",
        "gui_web_2d_vulkan_renderdoc_html_exit_code",
        "gui_web_2d_vulkan_renderdoc_electron_exit_code",
    ]
    return any(value_of(key, text) for key in runtime_keys)

def is_gui_web_2d_browser_backing_env(text: str) -> bool:
    return (
        value_of("gui_web_2d_vulkan_mode", text) == "--browser-backing"
        and bool(value_of("gui_web_2d_vulkan_browser_backing_status", text))
    )

def first_existing_direct_run_env(configured_value: str, candidates):
    if configured_value:
        path = Path(configured_value)
        if not path.is_absolute():
            path = ROOT / path
        text = env_text_from_path(path)
        if is_gui_web_2d_direct_run_env(text):
            return path, text, "configured"
        return path, text, "configured-not-direct-run"
    for path in candidates:
        if not path.is_absolute():
            path = ROOT / path
        text = env_text_from_path(path)
        if is_gui_web_2d_direct_run_env(text):
            return path, text, "auto-existing"
    return None, "", "missing"

def first_existing_browser_backing_env(configured_value: str, candidates):
    if configured_value:
        path = Path(configured_value)
        if not path.is_absolute():
            path = ROOT / path
        text = env_text_from_path(path)
        if is_gui_web_2d_browser_backing_env(text):
            return path, text, "configured"
        return path, text, "configured-not-browser-backing"
    for path in candidates:
        if not path.is_absolute():
            path = ROOT / path
        text = env_text_from_path(path)
        if is_gui_web_2d_browser_backing_env(text):
            return path, text, "auto-existing"
    return None, "", "missing"


