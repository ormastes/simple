#!/bin/sh
# Non-launching status audit for GUI item rendering, HTML/CSS traceability, and
# RenderDoc gates. Heavy renderer/capture checks are referenced, not run here.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/gui_renderdoc_feature_coverage_status}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/gui_renderdoc_feature_coverage_status_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
export GUI_RENDERDOC_AGGREGATE_BUILD_DIR="$BUILD_DIR"

python3 - <<'PY' >"$OUT_ENV"
from pathlib import Path
import os
import re
import subprocess

ROOT = Path.cwd()
AGG_BUILD = Path(os.environ.get("GUI_RENDERDOC_AGGREGATE_BUILD_DIR", "build/gui_renderdoc_feature_coverage_status"))
if not AGG_BUILD.is_absolute():
    AGG_BUILD = ROOT / AGG_BUILD

def value_of(key: str, text: str) -> str:
    out = ""
    prefix = key + "="
    for line in text.splitlines():
        if line.startswith(prefix):
            out = line[len(prefix):]
    return out

def emit(key: str, value) -> None:
    value = "" if value is None else str(value)
    value = value.replace("\n", " ")
    print(f"{key}={value}")

def rel(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)

def rel_text_path(value: str) -> str:
    if not value:
        return ""
    path = Path(value)
    if path.is_absolute():
        return rel(path)
    return value

def to_int(value: str) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0

def file_magic_of(value: str) -> str:
    if not value:
        return ""
    path = Path(value)
    if not path.is_absolute():
        path = ROOT / path
    if not path.is_file():
        return ""
    return path.read_bytes()[:4].decode("latin1", errors="ignore")

def env_text_from_path(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="ignore") if path.exists() else ""

def is_gui_web_2d_direct_run_env(text: str) -> bool:
    mode = value_of("gui_web_2d_vulkan_mode", text)
    if mode not in {"--run", "--renderdoc", "--renderdoc-simple"}:
        return False
    runtime_keys = [
        "gui_web_2d_vulkan_electron_argb_status",
        "gui_web_2d_vulkan_chrome_bitmap_status",
        "gui_web_2d_vulkan_simple_status",
        "gui_web_2d_vulkan_renderdoc_simple_exit_code",
        "gui_web_2d_vulkan_renderdoc_html_exit_code",
        "gui_web_2d_vulkan_renderdoc_electron_exit_code",
    ]
    return any(value_of(key, text) for key in runtime_keys)

def first_existing_direct_run_env(configured_value: str, candidates):
    if configured_value:
        path = Path(configured_value)
        if not path.is_absolute():
            path = ROOT / path
        text = env_text_from_path(path)
        if is_gui_web_2d_direct_run_env(text):
            return path, text, "configured"
        return path, text, "configured-not-direct-run"
    for path in candidates:
        if not path.is_absolute():
            path = ROOT / path
        text = env_text_from_path(path)
        if is_gui_web_2d_direct_run_env(text):
            return path, text, "auto-existing"
    return None, "", "missing"

widget_kind_path = ROOT / "src/lib/common/ui/widget_kind.spl"
html_widgets_path = ROOT / "src/app/ui.render/html_widgets.spl"
manifest_path = ROOT / "tools/electron-live-bitmap/simple_web_layout_capture_manifest.txt"
production_env_path = Path(os.environ.get("PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV", "build/production_gui_web_renderer_parity_evidence/evidence.env"))
if not production_env_path.is_absolute():
    production_env_path = ROOT / production_env_path
electron_env_path = Path(os.environ.get("RDOC_ELECTRON_EVIDENCE_ENV", "build/renderdoc/canonical-probe/electron-html/evidence.env"))
if not electron_env_path.is_absolute():
    electron_env_path = ROOT / electron_env_path
gui_web_2d_vulkan_env_path = Path(os.environ.get("GUI_WEB_2D_VULKAN_ENV", "build/gui-web-2d-vulkan-env/evidence.env"))
if not gui_web_2d_vulkan_env_path.is_absolute():
    gui_web_2d_vulkan_env_path = ROOT / gui_web_2d_vulkan_env_path

widget_source = widget_kind_path.read_text(encoding="utf-8", errors="ignore")
html_source = html_widgets_path.read_text(encoding="utf-8", errors="ignore")

wire_pairs = re.findall(r"WidgetKind\.([A-Za-z0-9_]+)\s*=>\s*\"([^\"]+)\"", widget_source)
widget_wires = []
seen = set()
for _, wire in wire_pairs:
    if wire not in seen:
        widget_wires.append(wire)
        seen.add(wire)

match = re.search(r"fn render_html_widget\(.*?\n(.*?)\nfn render_html_tree_widget", html_source, re.S)
dispatch_block = match.group(1) if match else ""
dispatch_wires = sorted(set(re.findall(r"^\s*\"([^\"]+)\"\s*=>", dispatch_block, re.M)))
missing_dispatch = [wire for wire in widget_wires if wire not in dispatch_wires]
extra_dispatch = [wire for wire in dispatch_wires if wire not in widget_wires and wire not in {"vbox", "hbox"}]

manifest_cases = []
manifest_exact = 0
manifest_tracked = 0
manifest_opacity_rounding = 0
manifest_float_divergence = 0
manifest_selector_layer_divergence = 0
manifest_color_value_divergence = 0
manifest_percent_viewport_divergence = 0
manifest_auto_margin_divergence = 0
manifest_display_none_flow_divergence = 0
manifest_flex_justify_variants_divergence = 0
manifest_flex_column_divergence = 0
manifest_flex_wrap_reverse_divergence = 0
manifest_flex_safe_unsafe_center_divergence = 0
if manifest_path.exists():
    for line in manifest_path.read_text(encoding="utf-8", errors="ignore").splitlines():
        if not line or line.startswith("#"):
            continue
        parts = line.split("|", 5)
        if len(parts) < 5:
            continue
        case_id, scene, width, height, policy = parts[:5]
        manifest_cases.append(case_id)
        if policy == "exact":
            manifest_exact += 1
        elif policy == "track-text-divergence":
            manifest_tracked += 1
        elif policy == "track-compositor-opacity-rounding":
            manifest_opacity_rounding += 1
        elif policy == "track-float-layout-divergence":
            manifest_float_divergence += 1
        elif policy == "track-css-selector-layer-divergence":
            manifest_selector_layer_divergence += 1
        elif policy == "track-css-color-value-divergence":
            manifest_color_value_divergence += 1
        elif policy == "track-css-percent-viewport-divergence":
            manifest_percent_viewport_divergence += 1
        elif policy == "track-css-auto-margin-divergence":
            manifest_auto_margin_divergence += 1
        elif policy == "track-css-display-none-flow-divergence":
            manifest_display_none_flow_divergence += 1
        elif policy == "track-css-flex-justify-variants-divergence":
            manifest_flex_justify_variants_divergence += 1
        elif policy == "track-css-flex-column-divergence":
            manifest_flex_column_divergence += 1
        elif policy == "track-css-flex-wrap-reverse-divergence":
            manifest_flex_wrap_reverse_divergence += 1
        elif policy == "track-css-flex-safe-unsafe-center-divergence":
            manifest_flex_safe_unsafe_center_divergence += 1

traceability_status = "unavailable"
traceability_reason = "missing-html-css-sspec-traceability-check"
traceability_output = ""
traceability_code = 127
traceability_env_path = AGG_BUILD / "sspec-traceability/evidence.env"
if Path("scripts/check/check-html-css-sspec-traceability.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "sspec-traceability")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "sspec-traceability/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-html-css-sspec-traceability.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    traceability_output = proc.stdout
    traceability_code = proc.returncode
    traceability_env = traceability_env_path.read_text(encoding="utf-8", errors="ignore") if traceability_env_path.exists() else traceability_output
    traceability_status = value_of("html_css_sspec_traceability_status", traceability_env)
    traceability_reason = value_of("html_css_sspec_traceability_reason", traceability_env)
    traceability_html_count = value_of("html_css_sspec_traceability_html_tag_count", traceability_env)
    traceability_required_html_count = value_of("html_css_sspec_traceability_required_html_tag_count", traceability_env)
    traceability_css_count = value_of("html_css_sspec_traceability_css_property_count", traceability_env)
    traceability_required_css_min_count = value_of("html_css_sspec_traceability_required_css_property_min_count", traceability_env)
    traceability_implemented_css_count = value_of("html_css_sspec_traceability_implemented_css_property_count", traceability_env)
    traceability_implemented_css_indexed_count = value_of("html_css_sspec_traceability_implemented_css_property_indexed_count", traceability_env)
    traceability_unsupported_css_count = value_of("html_css_sspec_traceability_unsupported_css_property_count", traceability_env)
    traceability_unsupported_css_missing_count = value_of("html_css_sspec_traceability_unsupported_css_property_missing_count", traceability_env)
    traceability_implemented_css_subset_spec = value_of("html_css_sspec_traceability_implemented_css_subset_spec", traceability_env)
    traceability_unsupported_css_inventory_spec = value_of("html_css_sspec_traceability_unsupported_css_inventory_spec", traceability_env)
else:
    traceability_html_count = ""
    traceability_required_html_count = ""
    traceability_css_count = ""
    traceability_required_css_min_count = ""
    traceability_implemented_css_count = ""
    traceability_implemented_css_indexed_count = ""
    traceability_unsupported_css_count = ""
    traceability_unsupported_css_missing_count = ""
    traceability_implemented_css_subset_spec = ""
    traceability_unsupported_css_inventory_spec = ""
if not traceability_status:
    traceability_status = "fail"
if not traceability_reason:
    traceability_reason = "html-css-sspec-traceability-check-failed"

widget_fixture_output = ""
widget_fixture_code = 127
if Path("scripts/check/check-gui-widget-rendering-fixture-coverage.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "widget-rendering-fixture-coverage")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "widget-rendering-fixture-coverage/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-gui-widget-rendering-fixture-coverage.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    widget_fixture_output = proc.stdout
    widget_fixture_code = proc.returncode

rendering_manifest_output = ""
rendering_manifest_code = 127
if Path("scripts/check/check-html-css-rendering-manifest-traceability.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "rendering-manifest-traceability")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "rendering-manifest-traceability/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-html-css-rendering-manifest-traceability.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    rendering_manifest_output = proc.stdout
    rendering_manifest_code = proc.returncode

gui_web_2d_vulkan_output = ""
gui_web_2d_vulkan_code = ""
gui_web_2d_vulkan_setup_source = "existing-evidence"
if not gui_web_2d_vulkan_env_path.exists() and Path("scripts/setup/setup-gui-web-2d-vulkan-env.shs").exists():
    gui_web_2d_vulkan_setup_source = "generated-check"
    nested_env = os.environ.copy()
    nested_env["GUI_WEB_2D_VULKAN_BUILD_DIR"] = str(gui_web_2d_vulkan_env_path.parent)
    proc = subprocess.run(
        ["sh", "scripts/setup/setup-gui-web-2d-vulkan-env.shs", "--check"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    gui_web_2d_vulkan_output = proc.stdout
    gui_web_2d_vulkan_code = str(proc.returncode)

gui_web_2d_vulkan_env = (
    gui_web_2d_vulkan_env_path.read_text(encoding="utf-8", errors="ignore")
    if gui_web_2d_vulkan_env_path.exists()
    else gui_web_2d_vulkan_output
)
gui_web_2d_vulkan_direct_run_candidates = [
    ROOT / "build/gui-web-2d-vulkan-env-run-auto/evidence.env",
    ROOT / "build/gui-web-2d-vulkan-env-run-fresh/evidence.env",
    ROOT / "build/gui-web-2d-vulkan-env-latest/evidence.env",
    ROOT / "build/gui-web-2d-vulkan-env-post-rebase/evidence.env",
    ROOT / "build/gui-web-2d-vulkan-env-run/evidence.env",
]
gui_web_2d_vulkan_direct_run_env_path, gui_web_2d_vulkan_direct_run_env, gui_web_2d_vulkan_direct_run_source = first_existing_direct_run_env(
    os.environ.get("GUI_WEB_2D_VULKAN_RUN_EVIDENCE_ENV", os.environ.get("GUI_WEB_2D_VULKAN_RUN_ENV", "")),
    gui_web_2d_vulkan_direct_run_candidates,
)
gui_web_2d_vulkan_runtime_env = gui_web_2d_vulkan_direct_run_env if is_gui_web_2d_direct_run_env(gui_web_2d_vulkan_direct_run_env) else gui_web_2d_vulkan_env
gui_web_2d_vulkan_direct_run_evidence_env = rel(gui_web_2d_vulkan_direct_run_env_path) if gui_web_2d_vulkan_direct_run_env_path else ""
gui_web_2d_vulkan_direct_run_mode = value_of("gui_web_2d_vulkan_mode", gui_web_2d_vulkan_direct_run_env)
gui_web_2d_vulkan_mode = value_of("gui_web_2d_vulkan_mode", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_evidence_env = value_of("gui_web_2d_vulkan_evidence_env", gui_web_2d_vulkan_env) or rel(gui_web_2d_vulkan_env_path)
gui_web_2d_vulkan_uname_s = value_of("gui_web_2d_vulkan_uname_s", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_uname_m = value_of("gui_web_2d_vulkan_uname_m", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_loader_status = value_of("gui_web_2d_vulkan_loader_status", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_device = value_of("gui_web_2d_vulkan_device", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_driver = value_of("gui_web_2d_vulkan_driver", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_chrome = value_of("gui_web_2d_vulkan_chrome", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_electron = value_of("gui_web_2d_vulkan_electron", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_simple_bin = value_of("gui_web_2d_vulkan_simple_bin", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_simple_bin_selection_reason = value_of("gui_web_2d_vulkan_simple_bin_selection_reason", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_status = value_of("gui_web_2d_vulkan_renderdoc_status", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_reason = value_of("gui_web_2d_vulkan_renderdoc_reason", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_cmd = value_of("gui_web_2d_vulkan_renderdoc_cmd", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_search_paths = value_of("gui_web_2d_vulkan_renderdoc_search_paths", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_install_hint = value_of("gui_web_2d_vulkan_renderdoc_install_hint", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_setup_reason = value_of("gui_web_2d_vulkan_renderdoc_setup_reason", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_macos_homebrew_package_status = value_of("gui_web_2d_vulkan_renderdoc_macos_homebrew_package_status", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_macos_upstream_support_status = value_of("gui_web_2d_vulkan_renderdoc_macos_upstream_support_status", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_setup_macos_homebrew_package_status = value_of("gui_web_2d_vulkan_renderdoc_setup_macos_homebrew_package_status", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_renderdoc_setup_macos_upstream_support_status = value_of("gui_web_2d_vulkan_renderdoc_setup_macos_upstream_support_status", gui_web_2d_vulkan_env)
gui_web_2d_vulkan_electron_argb_status = value_of("gui_web_2d_vulkan_electron_argb_status", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_electron_argb_nonblank = value_of("gui_web_2d_vulkan_electron_argb_nonblank_pixel_count", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_electron_vulkan_status = value_of("gui_web_2d_vulkan_electron_vulkan_status", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_electron_vulkan_reason = value_of("gui_web_2d_vulkan_electron_vulkan_reason", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_chrome_bitmap_status = value_of("gui_web_2d_vulkan_chrome_bitmap_status", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_chrome_vulkan_status = value_of("gui_web_2d_vulkan_chrome_vulkan_status", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_chrome_vulkan_reason = value_of("gui_web_2d_vulkan_chrome_vulkan_reason", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_simple_status = value_of("gui_web_2d_vulkan_simple_status", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_simple_reason = value_of("gui_web_2d_vulkan_simple_reason", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_simple_probe_status = value_of("gui_web_2d_vulkan_simple_probe_status", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_simple_backend_name = value_of("gui_web_2d_vulkan_simple_backend_name", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_renderdoc_simple_exit_code = value_of("gui_web_2d_vulkan_renderdoc_simple_exit_code", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_renderdoc_html_exit_code = value_of("gui_web_2d_vulkan_renderdoc_html_exit_code", gui_web_2d_vulkan_runtime_env)
gui_web_2d_vulkan_renderdoc_electron_exit_code = value_of("gui_web_2d_vulkan_renderdoc_electron_exit_code", gui_web_2d_vulkan_runtime_env)

goal_output = ""
goal_code = 127
if Path("scripts/check/check-html-css-renderdoc-goal-status.shs").exists():
    nested_env = os.environ.copy()
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "renderdoc-goal-status")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "renderdoc-goal-status/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-html-css-renderdoc-goal-status.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    goal_output = proc.stdout
    goal_code = proc.returncode

production_env = production_env_path.read_text(encoding="utf-8", errors="ignore") if production_env_path.exists() else ""
production_status = value_of("production_gui_web_renderer_parity_status", production_env)
production_reason = value_of("production_gui_web_renderer_parity_reason", production_env)
layout_count = value_of("production_gui_web_renderer_parity_layout_manifest_case_count", production_env)
layout_pass = value_of("production_gui_web_renderer_parity_layout_manifest_pass_count", production_env)
layout_tracked = value_of("production_gui_web_renderer_parity_layout_manifest_tracked_count", production_env)
layout_fail = value_of("production_gui_web_renderer_parity_layout_manifest_fail_count", production_env)
if production_env_path.exists() and not production_status:
    production_status = "missing-status"
    production_reason = "existing-evidence-env-missing-production-status"

production_gate_output = ""
production_gate_code = 127
if Path("scripts/check/check-production-gui-web-renderer-parity-gate.shs").exists():
    nested_env = os.environ.copy()
    nested_env["PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV"] = str(production_env_path)
    nested_env["BUILD_DIR"] = str(AGG_BUILD / "production-parity-gate")
    nested_env["REPORT_PATH"] = str(AGG_BUILD / "production-parity-gate/report.md")
    proc = subprocess.run(
        ["sh", "scripts/check/check-production-gui-web-renderer-parity-gate.shs"],
        cwd=ROOT,
        env=nested_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=120,
        check=False,
    )
    production_gate_output = proc.stdout
    production_gate_code = proc.returncode

production_gate_status = value_of("production_gui_web_renderer_parity_gate_status", production_gate_output)
production_gate_reason = value_of("production_gui_web_renderer_parity_gate_reason", production_gate_output)
production_gate_required_source_status = value_of("production_gui_web_renderer_parity_gate_required_source_status", production_gate_output)
production_gate_required_matrix_status = value_of("production_gui_web_renderer_parity_gate_required_matrix_status", production_gate_output)
production_gate_required_layout_status = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_status", production_gate_output)
production_gate_required_layout_count = value_of("production_gui_web_renderer_parity_gate_required_layout_manifest_case_count", production_gate_output)
