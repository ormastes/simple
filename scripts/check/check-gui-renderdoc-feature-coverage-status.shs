coverage_status = "pass"
coverage_reason = "pass"
if missing_dispatch:
    coverage_status = "fail"
    coverage_reason = "missing-widget-html-renderer-dispatch"
elif traceability_status != "pass":
    coverage_status = "fail"
    coverage_reason = traceability_reason or "html-css-sspec-traceability-failed"
elif widget_fixture_status != "pass":
    coverage_status = "fail"
    coverage_reason = widget_fixture_reason or "gui-widget-rendering-fixture-coverage-failed"
elif not manifest_cases:
    coverage_status = "fail"
    coverage_reason = "missing-electron-layout-manifest"
elif rendering_manifest_status != "pass":
    coverage_status = "fail"
    coverage_reason = rendering_manifest_reason or "html-css-rendering-manifest-traceability-failed"
elif renderdoc_status != "pass":
    coverage_status = "incomplete"
    coverage_reason = renderdoc_reason or "renderdoc-goal-incomplete"
elif electron_gate_status != "pass":
    coverage_status = "incomplete"
    coverage_reason = electron_gate_reason or "missing-electron-rdoc"
elif production_core_status != "pass":
    coverage_status = "incomplete"
    coverage_reason = production_core_reason or "production-gui-web-renderer-core-parity-incomplete"

emit("gui_renderdoc_feature_coverage_status", coverage_status)
