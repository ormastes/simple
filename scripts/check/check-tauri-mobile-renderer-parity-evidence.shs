    status=fail
    reason=ios-mdi-proof-source-missing
elif [ "$ios_mdi_proof_status" != "pass" ] || [ "$ios_mdi_render_status" != "pass" ] || [ "$ios_mdi_event_status" != "pass" ] || [ "$ios_mdi_capture_status" != "pass" ] || [ "$ios_mdi_performance_status" != "pass" ] || [ "$ios_mdi_animation_status" != "pass" ]; then
