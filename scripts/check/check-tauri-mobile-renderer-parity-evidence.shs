elif [ "$android_mdi_proof_status" != "pass" ] || [ "$android_mdi_render_status" != "pass" ] || [ "$android_mdi_event_status" != "pass" ] || [ "$android_mdi_capture_status" != "pass" ] || [ "$android_mdi_performance_status" != "pass" ] || [ "$android_mdi_animation_status" != "pass" ]; then
    status=fail
    reason=android-mdi-render-event-capture-performance-animation-proof-missing
elif ! mobile_mdi_detail_pass "$android_mdi_proof_window_count" "$android_mdi_render_image_count" "$android_mdi_render_html_renderable" "$android_mdi_event_taskbar_item_count" "$android_mdi_event_taskbar_icon_count" "$android_mdi_capture_viewport_width" "$android_mdi_capture_viewport_height" "$android_mdi_performance_now_available" "$android_mdi_performance_now_delta_ms" "$android_mdi_animation_frame_available" "$android_mdi_animation_frame_count" "$android_mdi_css_animation_probe"; then
