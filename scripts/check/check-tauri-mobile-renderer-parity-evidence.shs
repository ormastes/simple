    reason=ios-mdi-render-event-capture-performance-animation-proof-missing
elif ! mobile_mdi_detail_pass "$ios_mdi_proof_window_count" "$ios_mdi_render_image_count" "$ios_mdi_render_html_renderable" "$ios_mdi_event_taskbar_item_count" "$ios_mdi_event_taskbar_icon_count" "$ios_mdi_capture_viewport_width" "$ios_mdi_capture_viewport_height" "$ios_mdi_performance_now_available" "$ios_mdi_performance_now_delta_ms" "$ios_mdi_animation_frame_available" "$ios_mdi_animation_frame_count" "$ios_mdi_css_animation_probe"; then
    status=fail
    reason=ios-mdi-render-event-capture-performance-animation-proof-incomplete
elif [ "$android_status" = "fail" ]; then
