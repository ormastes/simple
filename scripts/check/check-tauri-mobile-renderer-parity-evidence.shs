#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/tauri_mobile_renderer_parity_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/tauri_mobile_renderer_parity_evidence_$(date -u +%F).md}"
PRODUCTION_ENV="${PRODUCTION_GUI_WEB_RENDERER_PARITY_ENV:-build/production_gui_web_renderer_parity_evidence/evidence.env}"
IOS_SCRIPT="${TAURI_MOBILE_RENDERER_IOS_SCRIPT:-scripts/check/check-tauri-ios-mobile-renderer-evidence.shs}"
ANDROID_SCRIPT="${TAURI_MOBILE_RENDERER_ANDROID_SCRIPT:-scripts/check/check-tauri-android-mobile-renderer-evidence.shs}"
IOS_RENDER_LOG_VALIDATOR="${TAURI_MOBILE_RENDERER_IOS_RENDER_LOG_VALIDATOR:-scripts/check/validate-tauri-ios-render-log-proof.js}"
ANDROID_RENDER_LOG_VALIDATOR="${TAURI_MOBILE_RENDERER_ANDROID_RENDER_LOG_VALIDATOR:-scripts/check/validate-tauri-android-render-log-proof.js}"
IOS_LOG_EXTRA="${TAURI_MOBILE_RENDERER_IOS_LOG:-}"
ANDROID_LOG_EXTRA="${TAURI_MOBILE_RENDERER_ANDROID_LOG:-}"
OUT_ENV="$BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH"

value_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" 2>/dev/null | tail -n 1
}

num_at_least() {
    value="$1"
    min="$2"
    case "$value" in
        ''|*[!0-9]*) return 1 ;;
    esac
    [ "$value" -ge "$min" ]
}

num_positive() {
    value="$1"
    awk -v value="$value" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 > 0) exit 0
        exit 1
    }'
}

mobile_mdi_detail_pass() {
    window_count="$1"
    image_count="$2"
    html_renderable="$3"
    taskbar_item_count="$4"
    taskbar_icon_count="$5"
    width="$6"
    height="$7"
    performance_available="$8"
    performance_delta="$9"
    animation_available="${10}"
    animation_frames="${11}"
    css_animation="${12}"
    num_at_least "$window_count" 4 &&
        num_at_least "$image_count" 1 &&
        [ "$html_renderable" = "true" ] &&
        num_at_least "$taskbar_item_count" 4 &&
        num_at_least "$taskbar_icon_count" 4 &&
        num_at_least "$width" 300 &&
        num_at_least "$height" 300 &&
        [ "$performance_available" = "true" ] &&
        num_positive "$performance_delta" &&
        [ "$animation_available" = "true" ] &&
        num_at_least "$animation_frames" 2 &&
        [ "$css_animation" = "true" ]
}

production_backend_detail_pass() {
    backend_status="$1"
    backend_exact="$2"
    backend_cpu_diff="$3"
    backend_metal_resolved="$4"
    backend_metal_diff="$5"
    backend_metal_frame="$6"
    backend_tolerance="$7"
    [ "$backend_status" = "pass" ] &&
        [ "$backend_exact" = "true" ] &&
        [ "$backend_cpu_diff" = "0" ] &&
        [ "$backend_metal_diff" = "0" ] &&
        [ -n "$backend_metal_resolved" ] &&
        { [ "$backend_metal_resolved" != "metal" ] || [ "$backend_metal_frame" = "true" ]; } &&
        [ "$backend_tolerance" = "false" ]
}

grep_any_file() {
    pattern="$1"
    shift
    for file in "$@"; do
        if [ -n "$file" ] && [ -s "$file" ] && grep -Eiq "$pattern" "$file"; then
            return 0
        fi
    done
    return 1
}

artifact_file_status() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        echo pass
    else
        echo fail
    fi
}

png_file_status() {
    path="$1"
    if [ -z "$path" ] || [ ! -s "$path" ]; then
        echo fail
        return
    fi
    magic="$(od -An -tx1 -N8 "$path" 2>/dev/null | tr -d ' \n')"
    if [ "$magic" = "89504e470d0a1a0a" ]; then
        echo pass
    else
        echo fail
    fi
}

run_lane() {
    name="$1"
    script="$2"
    out="$BUILD_DIR/${name}.out"
    err="$BUILD_DIR/${name}.err"
    code_file="$BUILD_DIR/${name}.code"
    code=0
    sh "$script" >"$out" 2>"$err" || code=$?
    printf '%s\n' "$code" >"$code_file"
}

write_report() {
    {
        echo "# Tauri Mobile Renderer Parity Evidence"
        echo
        echo "- status: $status"
        echo "- reason: $reason"
        echo "- production parity source: $PRODUCTION_ENV"
        echo "- iOS: $ios_status ($ios_reason)"
        echo "- Android: $android_status ($android_reason)"
        echo "- iOS expected GPU/log contract: $ios_expected_gpu_backend / $ios_metal_log_status"
        echo "- Android expected GPU/log contract: $android_expected_gpu_backend / $android_vulkan_log_status"
        echo "- iOS MDI render/event/capture/perf/animation: $ios_mdi_render_status / $ios_mdi_event_status / $ios_mdi_capture_status / $ios_mdi_performance_status / $ios_mdi_animation_status"
        echo "- Android MDI render/event/capture/perf/animation: $android_mdi_render_status / $android_mdi_event_status / $android_mdi_capture_status / $android_mdi_performance_status / $android_mdi_animation_status"
        echo
        echo "## Raw Evidence"
        sed 's/^/- /' "$OUT_ENV"
    } >"$REPORT_PATH"
}

production_status="$(value_of production_gui_web_renderer_parity_status "$PRODUCTION_ENV")"
production_layout_status="$(value_of production_gui_web_renderer_parity_layout_manifest_status "$PRODUCTION_ENV")"
production_surface_status="$(value_of production_gui_web_renderer_parity_surface_manifest_status "$PRODUCTION_ENV")"
production_no_fake="$(value_of production_gui_web_renderer_parity_surface_manifest_no_fake_capture "$PRODUCTION_ENV")"
production_backend_status="$(value_of production_gui_web_renderer_parity_backend_status "$PRODUCTION_ENV")"
production_backend_exact="$(value_of production_gui_web_renderer_parity_backend_exact "$PRODUCTION_ENV")"
production_backend_cpu_diff="$(value_of production_gui_web_renderer_parity_backend_cpu_simd_different_pixels "$PRODUCTION_ENV")"
production_backend_metal_resolved="$(value_of production_gui_web_renderer_parity_backend_metal_resolved "$PRODUCTION_ENV")"
production_backend_metal_diff="$(value_of production_gui_web_renderer_parity_backend_metal_different_pixels "$PRODUCTION_ENV")"
production_backend_metal_frame="$(value_of production_gui_web_renderer_parity_backend_metal_gpu_frame_complete "$PRODUCTION_ENV")"
production_backend_tolerance="$(value_of production_gui_web_renderer_parity_backend_blur_or_tolerance_used "$PRODUCTION_ENV")"

tauri_v2_status=fail
tauri_v2_reason=missing-tauri-v2-contract
if grep -Eq 'tauri[[:space:]]*=[[:space:]]*\{[^\n]*version[[:space:]]*=[[:space:]]*"2' tools/tauri-shell/src-tauri/Cargo.toml 2>/dev/null &&
    grep -Eq '"@tauri-apps/cli"[[:space:]]*:[[:space:]]*"\^2' tools/tauri-shell/package.json 2>/dev/null; then
    tauri_v2_status=pass
    tauri_v2_reason=tauri-v2-configured
fi

ios_project_status=fail
ios_project_reason=missing-generated-ios-project
if [ -d tools/tauri-shell/src-tauri/gen/apple ] &&
    [ -f tools/tauri-shell/src-tauri/gen/apple/simple-tauri-shell.xcodeproj/project.pbxproj ] &&
    [ -f tools/tauri-shell/src-tauri/gen/apple/simple-tauri-shell_iOS/Info.plist ]; then
    ios_project_status=pass
    ios_project_reason=generated-ios-project-present
fi

android_project_status=fail
android_project_reason=missing-generated-android-project
if [ -d tools/tauri-shell/src-tauri/gen/android ] &&
    [ -f tools/tauri-shell/src-tauri/gen/android/app/src/main/AndroidManifest.xml ] &&
    [ -f tools/tauri-shell/src-tauri/gen/android/app/src/main/java/com/simple/ui/MainActivity.kt ]; then
    android_project_status=pass
    android_project_reason=generated-android-project-present
fi

ios_exit_code=""
ios_status=unavailable
ios_reason=not-run
ios_tooling=""
ios_screenshot=""
ios_log_stream=""
ios_dev_log=""
ios_render_log_status=unavailable
ios_render_log_validation_status=unavailable
ios_render_log_validation_reason=not-run
ios_render_log_requested_source_count=0
ios_render_log_source_count=0
ios_render_log_missing_source_count=0
ios_render_log_html_len=""
ios_render_log_source_coherence_status=unavailable
ios_render_log_marker_status=unavailable
ios_render_log_metal_marker_status=unavailable
ios_render_log_tauri_context_status=unavailable
ios_render_log_metal_context_status=unavailable
ios_render_log_failure_marker_status=unavailable
ios_layout_status=unavailable
ios_metal_log_status=unavailable
ios_mdi_proof_json=""
ios_mdi_proof_status=unavailable
ios_mdi_proof_requested_source_count=""
ios_mdi_proof_source_count=""
ios_mdi_proof_missing_source_count=""
ios_mdi_render_status=unavailable
ios_mdi_event_status=unavailable
ios_mdi_capture_status=unavailable
ios_mdi_performance_status=unavailable
ios_mdi_animation_status=unavailable
ios_mdi_proof_window_count=""
ios_mdi_render_image_count=""
ios_mdi_render_html_renderable=""
ios_mdi_event_taskbar_item_count=""
ios_mdi_event_taskbar_icon_count=""
ios_mdi_capture_viewport_width=""
ios_mdi_capture_viewport_height=""
ios_mdi_performance_now_available=""
ios_mdi_performance_now_delta_ms=""
ios_mdi_animation_frame_available=""
ios_mdi_animation_frame_count=""
ios_mdi_css_animation_probe=""
ios_screenshot_file_status=unavailable
ios_mdi_proof_file_status=unavailable
ios_expected_gpu_backend=metal
if [ -x "$IOS_SCRIPT" ] || [ -f "$IOS_SCRIPT" ]; then
    run_lane ios "$IOS_SCRIPT"
    ios_exit_code="$(cat "$BUILD_DIR/ios.code")"
    ios_status="$(value_of status "$BUILD_DIR/ios.out")"
    ios_reason="$(value_of reason "$BUILD_DIR/ios.out")"
    ios_tooling="$(value_of ios_tooling "$BUILD_DIR/ios.out")"
    ios_screenshot="$(value_of ios_screenshot "$BUILD_DIR/ios.out")"
    ios_log_stream="$(value_of ios_log_stream "$BUILD_DIR/ios.out")"
    ios_dev_log="$(value_of ios_dev_log "$BUILD_DIR/ios.out")"
    ios_render_log_status="$(value_of ios_render_log_status "$BUILD_DIR/ios.out")"
    ios_mdi_proof_json="$(value_of ios_mdi_proof_json "$BUILD_DIR/ios.out")"
    ios_mdi_proof_status="$(value_of ios_mdi_proof_status "$BUILD_DIR/ios.out")"
    ios_mdi_proof_requested_source_count="$(value_of ios_mdi_proof_requested_source_count "$BUILD_DIR/ios.out")"
    ios_mdi_proof_source_count="$(value_of ios_mdi_proof_source_count "$BUILD_DIR/ios.out")"
    ios_mdi_proof_missing_source_count="$(value_of ios_mdi_proof_missing_source_count "$BUILD_DIR/ios.out")"
    ios_mdi_render_status="$(value_of ios_mdi_render_status "$BUILD_DIR/ios.out")"
    ios_mdi_event_status="$(value_of ios_mdi_event_status "$BUILD_DIR/ios.out")"
    ios_mdi_capture_status="$(value_of ios_mdi_capture_status "$BUILD_DIR/ios.out")"
    ios_mdi_performance_status="$(value_of ios_mdi_performance_status "$BUILD_DIR/ios.out")"
    ios_mdi_animation_status="$(value_of ios_mdi_animation_status "$BUILD_DIR/ios.out")"
    ios_mdi_proof_window_count="$(value_of ios_mdi_proof_window_count "$BUILD_DIR/ios.out")"
    ios_mdi_render_image_count="$(value_of ios_mdi_render_image_count "$BUILD_DIR/ios.out")"
    ios_mdi_render_html_renderable="$(value_of ios_mdi_render_html_renderable "$BUILD_DIR/ios.out")"
    ios_mdi_event_taskbar_item_count="$(value_of ios_mdi_event_taskbar_item_count "$BUILD_DIR/ios.out")"
    ios_mdi_event_taskbar_icon_count="$(value_of ios_mdi_event_taskbar_icon_count "$BUILD_DIR/ios.out")"
    ios_mdi_capture_viewport_width="$(value_of ios_mdi_capture_viewport_width "$BUILD_DIR/ios.out")"
    ios_mdi_capture_viewport_height="$(value_of ios_mdi_capture_viewport_height "$BUILD_DIR/ios.out")"
    ios_mdi_performance_now_available="$(value_of ios_mdi_performance_now_available "$BUILD_DIR/ios.out")"
    ios_mdi_performance_now_delta_ms="$(value_of ios_mdi_performance_now_delta_ms "$BUILD_DIR/ios.out")"
    ios_mdi_animation_frame_available="$(value_of ios_mdi_animation_frame_available "$BUILD_DIR/ios.out")"
    ios_mdi_animation_frame_count="$(value_of ios_mdi_animation_frame_count "$BUILD_DIR/ios.out")"
    ios_mdi_css_animation_probe="$(value_of ios_mdi_css_animation_probe "$BUILD_DIR/ios.out")"
    ios_screenshot_file_status="$(png_file_status "$ios_screenshot")"
    ios_mdi_proof_file_status="$(artifact_file_status "$ios_mdi_proof_json")"
    ios_render_log_validation_env="$BUILD_DIR/ios_render_log.validation.env"
    if [ -f "$IOS_RENDER_LOG_VALIDATOR" ]; then
        ios_render_validation_code=0
        node "$IOS_RENDER_LOG_VALIDATOR" "$ios_log_stream" "$ios_dev_log" "$IOS_LOG_EXTRA" >"$ios_render_log_validation_env" \
            || ios_render_validation_code=$?
        ios_render_log_validation_status="$(value_of ios_render_log_validation_status "$ios_render_log_validation_env")"
        ios_render_log_validation_reason="$(value_of ios_render_log_validation_reason "$ios_render_log_validation_env")"
        ios_render_log_requested_source_count="$(value_of ios_render_log_requested_source_count "$ios_render_log_validation_env")"
        ios_render_log_source_count="$(value_of ios_render_log_source_count "$ios_render_log_validation_env")"
        ios_render_log_missing_source_count="$(value_of ios_render_log_missing_source_count "$ios_render_log_validation_env")"
        ios_render_log_html_len="$(value_of ios_render_log_html_len "$ios_render_log_validation_env")"
        ios_render_log_source_coherence_status="$(value_of ios_render_log_source_coherence_status "$ios_render_log_validation_env")"
        ios_render_log_marker_status="$(value_of ios_render_log_marker_status "$ios_render_log_validation_env")"
        ios_render_log_metal_marker_status="$(value_of ios_render_log_metal_marker_status "$ios_render_log_validation_env")"
        ios_render_log_tauri_context_status="$(value_of ios_render_log_tauri_context_status "$ios_render_log_validation_env")"
        ios_render_log_metal_context_status="$(value_of ios_render_log_metal_context_status "$ios_render_log_validation_env")"
        ios_render_log_failure_marker_status="$(value_of ios_render_log_failure_marker_status "$ios_render_log_validation_env")"
        if [ "$ios_render_validation_code" -eq 0 ] && [ "$ios_render_log_validation_status" = "pass" ]; then
            ios_render_log_status=pass
            ios_metal_log_status=pass
        elif [ "$ios_status" = "pass" ]; then
            ios_render_log_status="$ios_render_log_marker_status"
            ios_metal_log_status="$ios_render_log_metal_marker_status"
            if [ "$ios_render_log_failure_marker_status" = "fail" ]; then
                ios_reason=ios-render-log-failure-marker
            elif [ "$ios_render_log_marker_status" != "pass" ]; then
                ios_reason=ios-render-log-marker-missing
            elif [ "$ios_render_log_metal_marker_status" != "pass" ]; then
                ios_reason=ios-metal-log-marker-missing
            elif [ "$ios_render_log_tauri_context_status" != "pass" ]; then
                ios_reason=ios-tauri-wkwebview-context-missing
            elif [ "$ios_render_log_metal_context_status" != "pass" ]; then
                ios_reason=ios-metal-context-missing
            elif [ "$ios_render_log_source_coherence_status" != "pass" ]; then
                ios_reason=ios-render-log-source-mismatch
            elif [ "$ios_render_log_missing_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-missing
            else
                ios_reason="${ios_render_log_validation_reason:-ios-render-log-validation-failed}"
            fi
        fi
    elif [ "$ios_status" = "pass" ]; then
        ios_render_log_status=fail
        ios_metal_log_status=fail
        ios_render_log_validation_status=fail
        ios_render_log_validation_reason=ios-render-log-validator-missing
        ios_reason=ios-render-log-validator-missing
    fi
    if [ "$ios_status" = "pass" ] && [ "$ios_screenshot_file_status" = "pass" ]; then
        ios_layout_status=pass
    elif [ "$ios_status" = "pass" ]; then
        ios_layout_status=fail
        ios_reason=ios-screenshot-png-missing
    fi
else
    ios_reason=missing-ios-evidence-script
fi

android_exit_code=""
android_status=unavailable
android_reason=not-run
android_screenshot=""
android_logcat=""
android_gpu_log=""
android_render_log_status=unavailable
android_render_log_validation_status=unavailable
android_render_log_validation_reason=not-run
android_render_log_source_count=0
android_render_log_html_len=""
android_render_log_source_coherence_status=unavailable
android_render_log_marker_status=unavailable
android_render_log_vulkan_marker_status=unavailable
android_render_log_failure_marker_status=unavailable
android_layout_status=unavailable
android_vulkan_log_status=unavailable
android_mdi_proof_json=""
android_mdi_proof_status=unavailable
android_mdi_proof_requested_source_count=""
android_mdi_proof_source_count=""
android_mdi_proof_missing_source_count=""
android_mdi_render_status=unavailable
android_mdi_event_status=unavailable
android_mdi_capture_status=unavailable
android_mdi_performance_status=unavailable
android_mdi_animation_status=unavailable
android_mdi_proof_window_count=""
android_mdi_render_image_count=""
android_mdi_render_html_renderable=""
android_mdi_event_taskbar_item_count=""
android_mdi_event_taskbar_icon_count=""
android_mdi_capture_viewport_width=""
android_mdi_capture_viewport_height=""
android_mdi_performance_now_available=""
android_mdi_performance_now_delta_ms=""
android_mdi_animation_frame_available=""
android_mdi_animation_frame_count=""
android_mdi_css_animation_probe=""
android_screenshot_file_status=unavailable
android_mdi_proof_file_status=unavailable
android_expected_gpu_backend=vulkan
if [ -x "$ANDROID_SCRIPT" ] || [ -f "$ANDROID_SCRIPT" ]; then
    run_lane android "$ANDROID_SCRIPT"
    android_exit_code="$(cat "$BUILD_DIR/android.code")"
    android_status="$(value_of status "$BUILD_DIR/android.out")"
    android_reason="$(value_of reason "$BUILD_DIR/android.out")"
    android_screenshot="$(value_of android_screenshot "$BUILD_DIR/android.out")"
    android_logcat="$(value_of android_logcat "$BUILD_DIR/android.out")"
    android_gpu_log="$(value_of android_gpu_log "$BUILD_DIR/android.out")"
    android_render_log_status="$(value_of android_render_log_status "$BUILD_DIR/android.out")"
    android_render_log_validation_status="$(value_of android_render_log_validation_status "$BUILD_DIR/android.out")"
    android_render_log_validation_reason="$(value_of android_render_log_validation_reason "$BUILD_DIR/android.out")"
    android_render_log_source_count="$(value_of android_render_log_source_count "$BUILD_DIR/android.out")"
    android_render_log_html_len="$(value_of android_render_log_html_len "$BUILD_DIR/android.out")"
    android_render_log_source_coherence_status="$(value_of android_render_log_source_coherence_status "$BUILD_DIR/android.out")"
    android_render_log_marker_status="$(value_of android_render_log_marker_status "$BUILD_DIR/android.out")"
    android_render_log_vulkan_marker_status="$(value_of android_render_log_vulkan_marker_status "$BUILD_DIR/android.out")"
    android_render_log_failure_marker_status="$(value_of android_render_log_failure_marker_status "$BUILD_DIR/android.out")"
    android_mdi_proof_json="$(value_of android_mdi_proof_json "$BUILD_DIR/android.out")"
    android_mdi_proof_status="$(value_of android_mdi_proof_status "$BUILD_DIR/android.out")"
    android_mdi_proof_requested_source_count="$(value_of android_mdi_proof_requested_source_count "$BUILD_DIR/android.out")"
    android_mdi_proof_source_count="$(value_of android_mdi_proof_source_count "$BUILD_DIR/android.out")"
    android_mdi_proof_missing_source_count="$(value_of android_mdi_proof_missing_source_count "$BUILD_DIR/android.out")"
    android_mdi_render_status="$(value_of android_mdi_render_status "$BUILD_DIR/android.out")"
    android_mdi_event_status="$(value_of android_mdi_event_status "$BUILD_DIR/android.out")"
    android_mdi_capture_status="$(value_of android_mdi_capture_status "$BUILD_DIR/android.out")"
    android_mdi_performance_status="$(value_of android_mdi_performance_status "$BUILD_DIR/android.out")"
    android_mdi_animation_status="$(value_of android_mdi_animation_status "$BUILD_DIR/android.out")"
    android_mdi_proof_window_count="$(value_of android_mdi_proof_window_count "$BUILD_DIR/android.out")"
    android_mdi_render_image_count="$(value_of android_mdi_render_image_count "$BUILD_DIR/android.out")"
    android_mdi_render_html_renderable="$(value_of android_mdi_render_html_renderable "$BUILD_DIR/android.out")"
    android_mdi_event_taskbar_item_count="$(value_of android_mdi_event_taskbar_item_count "$BUILD_DIR/android.out")"
    android_mdi_event_taskbar_icon_count="$(value_of android_mdi_event_taskbar_icon_count "$BUILD_DIR/android.out")"
    android_mdi_capture_viewport_width="$(value_of android_mdi_capture_viewport_width "$BUILD_DIR/android.out")"
    android_mdi_capture_viewport_height="$(value_of android_mdi_capture_viewport_height "$BUILD_DIR/android.out")"
    android_mdi_performance_now_available="$(value_of android_mdi_performance_now_available "$BUILD_DIR/android.out")"
    android_mdi_performance_now_delta_ms="$(value_of android_mdi_performance_now_delta_ms "$BUILD_DIR/android.out")"
    android_mdi_animation_frame_available="$(value_of android_mdi_animation_frame_available "$BUILD_DIR/android.out")"
    android_mdi_animation_frame_count="$(value_of android_mdi_animation_frame_count "$BUILD_DIR/android.out")"
    android_mdi_css_animation_probe="$(value_of android_mdi_css_animation_probe "$BUILD_DIR/android.out")"
    android_screenshot_file_status="$(png_file_status "$android_screenshot")"
    android_mdi_proof_file_status="$(artifact_file_status "$android_mdi_proof_json")"
    android_render_log_validation_env="$BUILD_DIR/android_render_log.validation.env"
    if [ -f "$ANDROID_RENDER_LOG_VALIDATOR" ]; then
        android_render_validation_code=0
        node "$ANDROID_RENDER_LOG_VALIDATOR" "$android_logcat" "$android_gpu_log" "$ANDROID_LOG_EXTRA" >"$android_render_log_validation_env" \
            || android_render_validation_code=$?
        android_render_log_validation_status="$(value_of android_render_log_validation_status "$android_render_log_validation_env")"
        android_render_log_validation_reason="$(value_of android_render_log_validation_reason "$android_render_log_validation_env")"
        android_render_log_source_count="$(value_of android_render_log_source_count "$android_render_log_validation_env")"
        android_render_log_html_len="$(value_of android_render_log_html_len "$android_render_log_validation_env")"
        android_render_log_source_coherence_status="$(value_of android_render_log_source_coherence_status "$android_render_log_validation_env")"
        android_render_log_marker_status="$(value_of android_render_log_marker_status "$android_render_log_validation_env")"
        android_render_log_vulkan_marker_status="$(value_of android_render_log_vulkan_marker_status "$android_render_log_validation_env")"
        android_render_log_failure_marker_status="$(value_of android_render_log_failure_marker_status "$android_render_log_validation_env")"
        if [ "$android_render_validation_code" -eq 0 ] && [ "$android_render_log_validation_status" = "pass" ]; then
            android_render_log_status=pass
            android_vulkan_log_status=pass
        elif [ "$android_status" = "pass" ]; then
            android_render_log_status="$android_render_log_marker_status"
            android_vulkan_log_status="$android_render_log_vulkan_marker_status"
            if [ "$android_render_log_failure_marker_status" = "fail" ]; then
                android_reason=android-render-log-failure-marker
            elif [ "$android_render_log_marker_status" != "pass" ]; then
                android_reason="${android_render_log_validation_reason:-android-render-log-marker-missing}"
            elif [ "$android_render_log_vulkan_marker_status" != "pass" ]; then
                android_reason=android-vulkan-log-marker-missing
            elif [ "$android_render_log_source_coherence_status" != "pass" ]; then
                android_reason=android-render-log-source-mismatch
            else
                android_reason="${android_render_log_validation_reason:-android-render-log-validation-failed}"
            fi
        fi
    elif [ "$android_status" = "pass" ]; then
        android_render_log_status=fail
        android_vulkan_log_status=fail
        android_render_log_validation_status=fail
        android_render_log_validation_reason=android-render-log-validator-missing
        android_reason=android-render-log-validator-missing
    fi
    if [ "$android_status" = "pass" ] && [ "$android_screenshot_file_status" = "pass" ]; then
        android_layout_status=pass
    elif [ "$android_status" = "pass" ]; then
        android_layout_status=fail
        android_reason=android-screenshot-png-missing
    fi
    if [ "$android_render_log_validation_status" = "unavailable" ] && grep_any_file 'Vulkan|vulkan|VK_|ANGLE.*Vulkan|Renderer.*Vulkan|HWUI.*Vulkan|skiavk' "$android_logcat" "$android_gpu_log" "$ANDROID_LOG_EXTRA"; then
        android_vulkan_log_status=pass
    elif [ "$android_render_log_validation_status" = "unavailable" ] && [ "$android_status" = "pass" ]; then
        android_vulkan_log_status=fail
        android_reason=android-vulkan-log-marker-missing
    fi
else
    android_reason=missing-android-evidence-script
fi

status=pass
reason=pass
if [ "$production_status" != "pass" ] || [ "$production_layout_status" != "pass" ] || [ "$production_surface_status" != "pass" ] || [ "$production_no_fake" != "true" ]; then
    status=fail
    reason=desktop-production-parity-source-not-pass
elif ! production_backend_detail_pass "$production_backend_status" "$production_backend_exact" "$production_backend_cpu_diff" "$production_backend_metal_resolved" "$production_backend_metal_diff" "$production_backend_metal_frame" "$production_backend_tolerance"; then
