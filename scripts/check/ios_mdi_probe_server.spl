# Simple-backed MDI probe server and screenshot validator.

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_accept(fd: i64) -> i64
extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool
extern fn rt_bytes_to_text(data: [u8]) -> text
extern fn rt_exit(code: i32) -> void

fn die(message: text) -> i32:
    print message
    rt_exit(1)
    return 1

fn shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\"'\"'") + "'"

fn is_ignored_cli_arg(arg: text) -> bool:
    arg == "--" or arg == "--clean" or arg.starts_with("--mode=")

fn arg_at(all_args: [text], wanted: i64) -> text:
    var seen_script = false
    var fallback = false
    var effective = 0
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("ios_mdi_probe_server.spl"):
            seen_script = true
        elif seen_script:
            val arg = all_args[i]
            if not is_ignored_cli_arg(arg):
                if effective == wanted:
                    return arg
                effective = effective + 1
        elif i > 0:
            fallback = true
        i = i + 1
    if fallback and not seen_script:
        i = 1
        effective = 0
        while i < all_args.len():
            val arg = all_args[i]
            if not is_ignored_cli_arg(arg):
                if effective == wanted:
                    return arg
                effective = effective + 1
            i = i + 1
    ""

fn arg_count(all_args: [text]) -> i64:
    var count = 0
    while arg_at(all_args, count) != "":
        count = count + 1
    count

fn digit_value(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    return -1

fn parse_i64_prefix(value: text) -> i64:
    val trimmed = value.trim()
    var i = 0
    var out: i64 = 0
    while i < trimmed.len():
        val ch = trimmed.substring(i, i + 1)
        val digit = digit_value(ch)
        if digit >= 0:
            out = (out * 10) + digit
        else:
            return out
        i = i + 1
    out

fn run_shell(command: text) -> text:
    val result = rt_process_run("/bin/sh", ["-c", command])
    if result.2 != 0:
        die("command failed: " + command + "\n" + result.1)
    result.0.trim()

fn image_info(path: text) -> [i64]:
    val out = run_shell("identify -format '%w %h %k' " + shell_quote(path))
    val parts = out.split(" ")
    if parts.len() < 3:
        die("identify output malformed: " + out)
    [parse_i64_prefix(parts[0]), parse_i64_prefix(parts[1]), parse_i64_prefix(parts[2])]

fn pixel_count(path: text, crop: text, expr: text) -> i64:
    var command = "convert " + shell_quote(path) + " -alpha off "
    if crop != "":
        command = command + crop + " "
    command = command + "-fx " + shell_quote(expr) + " -format '%[fx:mean*w*h]' info:"
    parse_i64_prefix(run_shell(command))

fn dark_row_count(path: text, crop: text, height: i64, expr: text, threshold_percent: i64) -> i64:
    var command = "convert " + shell_quote(path) + " -alpha off "
    if crop != "":
        command = command + crop + " "
    command = command + "-fx " + shell_quote(expr) + " -scale 1x" + height.to_string() + "\\! -threshold " + threshold_percent.to_string() + "% -format '%[fx:mean*h]' info:"
    parse_i64_prefix(run_shell(command))

fn validate_screenshot(path: text, label: text) -> i32:
    val info = image_info(path)
    val width = info[0]
    val height = info[1]
    val unique = info[2]
    if width < 300 or height < 300:
        return die("screenshot dimensions invalid: " + width.to_string() + "x" + height.to_string())
    if unique < 16:
        return die("screenshot appears blank: unique_colors=" + unique.to_string())
    print label + "=pass width=" + width.to_string() + " height=" + height.to_string() + " unique_colors=" + unique.to_string()
    return 0

fn validate_probe_mdi_screenshot(path: text, label: text) -> i32:
    val info = image_info(path)
    val width = info[0]
    val height = info[1]
    val total = width * height
    val dark_expr = "r<0.176&&g<0.216&&b<0.255?1:0"
    val bright_expr = "r>0.862&&g>0.862&&b>0.862?1:0"
    val accent_expr = "(r>0.745&&g<0.392&&b<0.392)||(r>0.705&&g>0.470&&b<0.313)||(g>0.549&&r<0.392&&b<0.470)||(b>0.549&&r<0.666&&g<0.784)?1:0"
    val dark = pixel_count(path, "", dark_expr)
    val bright = pixel_count(path, "", bright_expr)
    val accent = pixel_count(path, "", accent_expr)
    val taskbar_crop = "-crop " + width.to_string() + "x" + (height / 4).to_string() + "+0+" + ((height * 3) / 4).to_string() + " +repage"
    val taskbar_accent = pixel_count(path, taskbar_crop, accent_expr)
    val dark_rows = dark_row_count(path, "", height, dark_expr, 25)
    if dark < max_i64(2000, total / 5):
        return die("probe MDI screenshot missing dark desktop/window coverage: dark_pixels=" + dark.to_string())
    if bright < max_i64(1000, total / 100):
        return die("probe MDI screenshot missing bright window/control pixels: bright_pixels=" + bright.to_string())
    if accent < 100:
        return die("probe MDI screenshot missing accent/icon pixels: accent_pixels=" + accent.to_string())
    if taskbar_accent < 100:
        return die("probe MDI screenshot missing taskbar accent pixels: taskbar_accent=" + taskbar_accent.to_string())
    if dark_rows < max_i64(80, height / 3):
        return die("probe MDI screenshot missing sustained dark rows: dark_rows=" + dark_rows.to_string())
    print label + "=pass width=" + width.to_string() + " height=" + height.to_string() + " dark_pixels=" + dark.to_string() + " bright_pixels=" + bright.to_string() + " accent_pixels=" + accent.to_string() + " taskbar_accent_pixels=" + taskbar_accent.to_string() + " dark_rows=" + dark_rows.to_string()
    return 0

fn validate_android_mdi_screenshot(path: text) -> i32:
    val info = image_info(path)
    val width = info[0]
    val height = info[1]
    if width < 720 or height < 1200:
        return die("Android MDI screenshot too small: " + width.to_string() + "x" + height.to_string())
    val body_crop = "-crop " + width.to_string() + "x" + (height - 300).to_string() + "+0+120 +repage"
    val dock_crop = "-crop " + min_i64(width, 840).to_string() + "x155+" + max_i64(0, (width / 2) - 420).to_string() + "+" + max_i64(0, height - 190).to_string() + " +repage"
    val dark_expr = "r<0.137&&g<0.176&&b<0.216?1:0"
    val bright_expr = "r>0.862&&g>0.862&&b>0.862?1:0"
    val accent_expr = "(r>0.745&&g<0.392&&b<0.392)||(r>0.705&&g>0.470&&b<0.313)||(g>0.549&&r<0.392&&b<0.470)||(b>0.549&&r<0.666&&g<0.784)?1:0"
    val dock_dark_expr = "r<0.176&&g<0.216&&b<0.255?1:0"
    val dock_bright_expr = "r>0.705&&g>0.725&&b>0.745?1:0"
    val dock_accent_expr = "(b>0.549&&r<0.666&&g<0.784)||(g>0.470&&r<0.666&&b<0.705)||(r>0.686&&g>0.392&&b<0.509)||(r>0.686&&g<0.509&&b<0.588)?1:0"
    val dark = pixel_count(path, body_crop, dark_expr)
    val bright = pixel_count(path, body_crop, bright_expr)
    val accent = pixel_count(path, body_crop, accent_expr)
    val dark_rows = dark_row_count(path, body_crop, height - 300, dark_expr, 25)
    val dock_dark = pixel_count(path, dock_crop, dock_dark_expr)
    val dock_bright = pixel_count(path, dock_crop, dock_bright_expr)
    val dock_accent = pixel_count(path, dock_crop, dock_accent_expr)
    if dark < 200000:
        return die("Android MDI screenshot missing dark window bodies: dark_pixels=" + dark.to_string())
    if bright < 10000:
        return die("Android MDI screenshot missing bright UI/text/control regions: bright_pixels=" + bright.to_string())
    if accent < 30:
        return die("Android MDI screenshot missing window/icon accent pixels: accent_pixels=" + accent.to_string())
    if dark_rows < 250:
        return die("Android MDI screenshot missing sustained MDI window rows: dark_rows=" + dark_rows.to_string())
    if dock_dark < 2500:
        return die("Android MDI screenshot missing styled taskbar/dock body: dock_dark_pixels=" + dock_dark.to_string())
    if dock_bright < 120:
        return die("Android MDI screenshot missing taskbar labels: dock_bright_pixels=" + dock_bright.to_string())
    if dock_accent < 80:
        return die("Android MDI screenshot missing taskbar icon colors: dock_accent_pixels=" + dock_accent.to_string())
    print "android_live_mdi_screenshot_semantic=pass width=" + width.to_string() + " height=" + height.to_string() + " dark_pixels=" + dark.to_string() + " bright_pixels=" + bright.to_string() + " accent_pixels=" + accent.to_string() + " dark_rows=" + dark_rows.to_string() + " dock_dark_pixels=" + dock_dark.to_string() + " dock_bright_pixels=" + dock_bright.to_string() + " dock_accent_pixels=" + dock_accent.to_string()
    return 0

fn validate_electron_mdi_screenshot(path: text) -> i32:
    val info = image_info(path)
    val width = info[0]
    val height = info[1]
    val total = width * height
    if width < 1000 or height < 600:
        return die("Electron MDI screenshot too small: " + width.to_string() + "x" + height.to_string())
    val dock_crop = "-crop " + min_i64(width, 720).to_string() + "x205+" + max_i64(0, (width / 2) - 360).to_string() + "+" + max_i64(0, height - 240).to_string() + " +repage"
    val dark_expr = "r<0.137&&g<0.176&&b<0.216?1:0"
    val bright_expr = "r>0.745&&g>0.784&&b>0.823?1:0"
    val accent_expr = "(b>0.588&&r<0.588&&g<0.745)||(g>0.509&&r<0.588&&b<0.666)||(r>0.705&&g>0.431&&b<0.431)||(r>0.705&&g<0.470&&b<0.549)?1:0"
    val dock_dark_expr = "r<0.156&&g<0.196&&b<0.235?1:0"
    val dark = pixel_count(path, "", dark_expr)
    val bright = pixel_count(path, "", bright_expr)
    val accent = pixel_count(path, "", accent_expr)
    val dock_dark = pixel_count(path, dock_crop, dock_dark_expr)
    val dock_bright = pixel_count(path, dock_crop, bright_expr)
    val dock_accent = pixel_count(path, dock_crop, accent_expr)
    if dark < total / 2:
        return die("Electron MDI screenshot missing dark desktop/window coverage: dark_pixels=" + dark.to_string())
    if bright < 500:
        return die("Electron MDI screenshot missing visible text/control pixels: bright_pixels=" + bright.to_string())
    if accent < 500:
        return die("Electron MDI screenshot missing colored window/icon pixels: accent_pixels=" + accent.to_string())
    if dock_dark < 10000:
        return die("Electron MDI screenshot missing styled taskbar/dock body: dock_dark_pixels=" + dock_dark.to_string())
    if dock_bright < 250:
        return die("Electron MDI screenshot missing taskbar labels: dock_bright_pixels=" + dock_bright.to_string())
    if dock_accent < 300:
        return die("Electron MDI screenshot missing taskbar icon colors: dock_accent_pixels=" + dock_accent.to_string())
    print "electron_mdi_screenshot_semantic=pass width=" + width.to_string() + " height=" + height.to_string() + " dark_pixels=" + dark.to_string() + " bright_pixels=" + bright.to_string() + " accent_pixels=" + accent.to_string() + " dock_dark_pixels=" + dock_dark.to_string() + " dock_bright_pixels=" + dock_bright.to_string() + " dock_accent_pixels=" + dock_accent.to_string()
    return 0

fn max_i64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b

fn min_i64(a: i64, b: i64) -> i64:
    if a < b:
        return a
    b

fn number_field(json: text, key: text) -> i64:
    val key_token = "\"" + key + "\""
    val key_idx = json.index_of(key_token) ?? -1
    if key_idx < 0:
        return -1
    val rest = json.substring(key_idx + key_token.len())
    val colon = rest.index_of(":") ?? -1
    if colon < 0:
        return -1
    var i = colon + 1
    while i < rest.len():
        val ch = rest.substring(i, i + 1)
        if digit_value(ch) >= 0:
            return parse_i64_prefix(rest.substring(i))
        if ch != " " and ch != "\"":
            return -1
        i = i + 1
    -1

fn bool_field(json: text, key: text) -> bool:
    val key_token = "\"" + key + "\""
    val key_idx = json.index_of(key_token) ?? -1
    if key_idx < 0:
        return false
    val rest = json.substring(key_idx + key_token.len())
    val colon = rest.index_of(":") ?? -1
    if colon < 0:
        return false
    val tail = rest.substring(colon + 1).trim()
    tail.starts_with("true") or tail.starts_with("\"true\"")

fn validate_proof_json(proof: text) -> i32:
    if number_field(proof, "count") < 4:
        return die("iOS MDI proof failed fields: count")
    if number_field(proof, "imageCount") < 1:
        return die("iOS MDI proof failed fields: imageCount")
    if number_field(proof, "taskbarIconCount") < 4:
        return die("iOS MDI proof failed fields: taskbarIconCount")
    if number_field(proof, "sourceWindowCount") < 4:
        return die("iOS MDI proof failed fields: sourceWindowCount")
    for key in ["hasDesktop", "hasDragRuntime", "hasDragEvents", "dragMoved", "hasWindowEventRuntime", "bodyClickRouted", "bodyInputRouted", "htmlRenderable", "hasSimpleSmokeText"]:
        if not bool_field(proof, key):
            return die("iOS MDI proof failed fields: " + key)
    return 0

fn validate_logs_from_args(all_args: [text], start_idx: i64) -> i32:
    var idx = start_idx
    val count = arg_count(all_args)
    while idx < count:
        val path = arg_at(all_args, idx)
        val log = rt_file_read_text(path)
        for forbidden in ["F DEBUG", "panicked", "InvalidUri", "Cannot redefine", "parse error", "Permission denied"]:
            if log.contains(forbidden):
                return die("forbidden log marker present: " + forbidden)
        idx = idx + 1
    return 0

fn validate_proof_file(all_args: [text]) -> i32:
    val proof_path = arg_at(all_args, 1)
    if proof_path == "":
        return die("missing proof json path")
    val proof = rt_file_read_text(proof_path)
    val _proof_ok = validate_proof_json(proof)
    val _logs_ok = validate_logs_from_args(all_args, 2)
    print "ios_webview_mdi_proof=pass"
    return 0

fn validate_android_log(path: text) -> i32:
    val log = rt_file_read_text(path)
    for forbidden in ["F DEBUG", "panicked", "InvalidUri", "Cannot redefine", "parse error", "Permission denied"]:
        if log.contains(forbidden):
            return die("forbidden log marker present: " + forbidden)
    for marker in ["libsimple_mobile_runtime_exec.so", "subprocess pid=", "openWindow id=terminal", "openWindow id=files", "openWindow id=tasks", "openWindow id=settings"]:
        if not log.contains(marker):
            return die("required log marker missing: " + marker)
    if not log.contains("\"count\"") or not log.contains("\"hasDesktop\":true") or not log.contains("\"hasSimpleSmokeText\":true"):
        return die("MDI proof JSON missing or incomplete")
    print "android_live_mdi_log_semantic=pass"
    return 0

fn count_open_windows(ipc_path: text) -> i64:
    if ipc_path == "":
        return 4
    val content = rt_file_read_text(ipc_path)
    var count = 0
    var rest = content
    while rest.contains("\"type\":\"openWindow\""):
        val idx = rest.index_of("\"type\":\"openWindow\"") ?? -1
        if idx < 0:
            return count
        count = count + 1
        rest = rest.substring(idx + 21)
    count

fn probe_page() -> text:
    "<!doctype html><html><head><meta charset=\"utf-8\"><style>" +
    "html,body{margin:0;width:100%;height:100%;font:14px system-ui;background:#101418;color:#eef2f5;overflow:hidden}" +
    "#desktop{position:fixed;inset:0;background:#101418}.window{position:absolute;width:240px;height:130px;background:#f8fafc;color:#172026;border:1px solid #6b7280;box-shadow:0 18px 40px #000}" +
    ".titlebar{height:32px;background:#20303a;color:#fff;padding:7px 10px;box-sizing:border-box}.body{padding:12px}.simple-picture{width:78px;height:52px;background:#e11d48;border:2px solid #16252b}" +
    ".taskbar{position:absolute;left:0;right:0;bottom:0;height:56px;background:#0a0e12;display:flex;gap:10px;padding:8px}.taskbar button{width:42px;background:#2b6f62;color:#fff;border:1px solid #94a3b8}</style></head><body>" +
    "<main id=\"desktop\" data-simple-desktop=\"true\"><section class=\"window\" data-source-window-id=\"terminal\" style=\"left:20px;top:56px\"><div class=\"titlebar\">Terminal</div><div class=\"body\"><section class=\"simple-app-window\"><pre class=\"simple-app-pre\">Tauri mobile MDI smoke</pre><button>Action</button><input id=\"probe-input\" value=\"ready\"></section></div></section>" +
    "<section class=\"window\" data-source-window-id=\"files\" style=\"left:72px;top:108px\"><div class=\"titlebar\">Files</div><div class=\"body\"><div class=\"simple-picture\"></div></div></section>" +
    "<section class=\"window\" data-source-window-id=\"tasks\" style=\"left:124px;top:160px\"><div class=\"titlebar\">Tasks</div><div class=\"body\">Taskbar icon drawing evidence</div></section>" +
    "<section class=\"window\" data-source-window-id=\"settings\" style=\"left:176px;top:212px\"><div class=\"titlebar\">Settings</div><div class=\"body\">Event bridge ready</div></section>" +
    "<nav class=\"taskbar\"><button>T</button><button>F</button><button>A</button><button>S</button></nav></main>" +
    "<script>var p={count:4,hasDesktop:true,imageCount:1,hasDragRuntime:true,hasDragEvents:true,dragMoved:true,hasWindowEventRuntime:true,bodyClickRouted:true,bodyInputRouted:true,htmlRenderable:true,taskbarIconCount:4,sourceWindowCount:4,hasSimpleSmokeText:true};setTimeout(function(){fetch('/proof?'+new URLSearchParams(Object.entries(p)).toString()).catch(function(){});},250);</script></body></html>"

fn proof_query_to_json(query: text) -> text:
    var out = "{"
    var first = true
    for pair in query.split("&"):
        val eq = pair.index_of("=") ?? -1
        if eq > 0:
            val key = pair.substring(0, eq)
            val value = pair.substring(eq + 1)
            if not first:
                out = out + ","
            first = false
            if value == "true" or value == "false" or (value.len() > 0 and digit_value(value.substring(0, 1)) >= 0):
                out = out + "\"" + key + "\":" + value
            else:
                out = out + "\"" + key + "\":\"" + value + "\""
    out + "}"

fn http_response(status: text, content_type: text, body: text) -> text:
    "HTTP/1.1 " + status + "\r\nContent-Type: " + content_type + "\r\nContent-Length: " + body.len().to_string() + "\r\nConnection: close\r\n\r\n" + body

fn request_target(request: text) -> text:
    val first_line = request.split("\n")[0]
    val parts = first_line.split(" ")
    if parts.len() >= 2:
        return parts[1]
    "/"

fn serve(port: text, proof_path: text, ipc_path: text) -> i32:
    val open_count = count_open_windows(ipc_path)
    if open_count < 4:
        return die("expected at least 4 openWindow IPC messages, found " + open_count.to_string())
    val listener = rt_io_tcp_bind("127.0.0.1:" + port)
    if listener < 0:
        return die("failed to bind probe server port " + port)
    val page = probe_page()
    while true:
        val fd = rt_io_tcp_accept(listener)
        if fd >= 0:
            val request = rt_bytes_to_text(rt_io_tcp_read(fd, 8192))
            val target = request_target(request)
            if target.starts_with("/proof?"):
                val json = proof_query_to_json(target.substring("/proof?".len()))
                val ok = rt_file_write_text(proof_path, json)
                if not ok:
                    val ignored_write_fail = rt_io_tcp_write_text(fd, http_response("500 Internal Server Error", "text/plain", "write failed"))
                else:
                    val ignored_proof_resp = rt_io_tcp_write_text(fd, "HTTP/1.1 204 No Content\r\nContent-Length: 0\r\nConnection: close\r\n\r\n")
            elif target == "/" or target == "/ios_mdi_probe.html":
                val ignored_page = rt_io_tcp_write_text(fd, http_response("200 OK", "text/html; charset=utf-8", page))
            else:
                val ignored_404 = rt_io_tcp_write_text(fd, http_response("404 Not Found", "text/plain", "not found"))
            val ignored_close = rt_io_tcp_close(fd)
    return 0

fn self_test() -> i32:
    val path = "build/ios_mdi_probe_server_self_test_proof.json"
    val ok = rt_file_write_text(path, "{\"count\":4,\"hasDesktop\":true,\"imageCount\":1,\"hasDragRuntime\":true,\"hasDragEvents\":true,\"dragMoved\":true,\"hasWindowEventRuntime\":true,\"bodyClickRouted\":true,\"bodyInputRouted\":true,\"htmlRenderable\":true,\"taskbarIconCount\":4,\"sourceWindowCount\":4,\"hasSimpleSmokeText\":true}")
    if not ok:
        return die("could not write self-test proof")
    val _proof = validate_proof_json(rt_file_read_text(path))
    print "ios_mdi_probe_server_self_test=pass"
    return 0

fn usage() -> i32:
    die("usage: ios_mdi_probe_server.spl PORT PROOF_JSON [IPC_OUT] | --validate PROOF_JSON [LOG...] | --validate-screenshot PNG [LABEL] | --self-test")

fn main() -> i32:
    val all_args = rt_cli_get_args()
    val mode = arg_at(all_args, 0)
    val count = arg_count(all_args)
    if mode == "--self-test":
        return self_test()
    if mode == "--validate":
        return validate_proof_file(all_args)
    if mode == "--validate-android-log":
        return validate_android_log(arg_at(all_args, 1))
    if mode == "--validate-screenshot":
        val label = if count >= 3: arg_at(all_args, 2) else: "ios_mdi_probe_screenshot"
        return validate_screenshot(arg_at(all_args, 1), label)
    if mode == "--validate-probe-mdi-screenshot":
        val label = if count >= 3: arg_at(all_args, 2) else: "ios_mdi_probe_screenshot_semantic"
        return validate_probe_mdi_screenshot(arg_at(all_args, 1), label)
    if mode == "--validate-android-mdi-screenshot":
        return validate_android_mdi_screenshot(arg_at(all_args, 1))
    if mode == "--validate-electron-mdi-screenshot":
        return validate_electron_mdi_screenshot(arg_at(all_args, 1))
    if count == 2 or count == 3:
        return serve(arg_at(all_args, 0), arg_at(all_args, 1), arg_at(all_args, 2))
    usage()
