use std.cli.cli_util (get_cli_args)
use std.nogc_sync_mut.io.file_ops.{file_read}
use lib.json.jsonl.{jsonl_content_is_valid}

fn main() -> i64:
    val args = get_cli_args()
    if args.len() != 1:
        print "usage: validate-jsonl <file>"
        return 2
    if jsonl_content_is_valid(file_read(args[0])): 0 else: 1
