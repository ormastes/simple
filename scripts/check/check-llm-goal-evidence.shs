#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_goal_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_goal_evidence_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
LANE_TIMEOUT_SECONDS="${LLM_GOAL_LANE_TIMEOUT_SECONDS:-180}"
SVLLM_LANE_TIMEOUT_SECONDS="${LLM_GOAL_SVLLM_LANE_TIMEOUT_SECONDS:-}"
STRICT_HOST=0
LANES="context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard public_absence feature_db_reference prereq_doctor_contract dashboard_http_setup_contract vllm_host_env_contract torch_setup_contract finetune_setup_contract svllm_setup_contract"
COMPLETION_LANES="context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard"

while [ "$#" -gt 0 ]; do
    case "$1" in
        --strict-host)
            STRICT_HOST=1
            ;;
        --help|-h)
            echo "usage: sh scripts/check/check-llm-goal-evidence.shs [--strict-host]"
            echo "  --strict-host  require full context/Ponytail replacement, live dashboard, live vLLM, native svLLM, fine-tune acceptance, and Simple/libtorch CUDA optimizer gates to pass"
            exit 0
            ;;
        *)
            echo "unknown option: $1" >&2
            exit 2
            ;;
    esac
    shift
done

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH"

lane_timeout_seconds() {
    key="$1"
    case "$key" in
        svllm_local)
            if [ -n "$SVLLM_LANE_TIMEOUT_SECONDS" ]; then
                printf '%s\n' "$SVLLM_LANE_TIMEOUT_SECONDS"
            elif [ "$LANE_TIMEOUT_SECONDS" -lt 120 ]; then
                printf '%s\n' "120"
            else
                printf '%s\n' "$LANE_TIMEOUT_SECONDS"
            fi
            ;;
        *)
            printf '%s\n' "$LANE_TIMEOUT_SECONDS"
            ;;
    esac
}

run_lane() {
    key="$1"
    expected="$2"
    shift 2
    log="$BUILD_DIR/$key.log"
    report_path="$BUILD_DIR/${key}_report.md"
    timeout_seconds="$(lane_timeout_seconds "$key")"
    exit_code=0
    if command -v timeout >/dev/null 2>&1; then
        if timeout "$timeout_seconds" env -u BUILD_DIR REPORT_PATH="$report_path" "$@" >"$log" 2>&1; then
            :
        else
            exit_code=$?
        fi
    elif env -u BUILD_DIR REPORT_PATH="$report_path" "$@" >"$log" 2>&1; then
        :
    else
        exit_code=$?
    fi
    if grep -F "STATUS: PASS" "$log" >/dev/null 2>&1; then
        status="pass"
    elif grep -F "STATUS: WARN" "$log" >/dev/null 2>&1; then
        status="warn"
    else
        status="fail"
    fi
    if [ "$exit_code" -ne 0 ]; then
        status="fail"
    fi
    eval "${key}_status=\$status"
    eval "${key}_exit=\$exit_code"
    eval "${key}_expected=\$expected"
    eval "${key}_timeout_seconds=\$timeout_seconds"
    if [ "$exit_code" -eq 124 ]; then
        printf '%s\n' "STATUS: FAIL llm-goal-evidence-lane-timeout lane=$key seconds=$timeout_seconds" >>"$log"
    fi
}

run_producer() {
    key="$1"
    log="$2"
    shift 2
    exit_code=0
    if command -v timeout >/dev/null 2>&1; then
        if timeout "$LANE_TIMEOUT_SECONDS" "$@" >"$log" 2>&1; then
            :
        else
            exit_code=$?
        fi
    elif "$@" >"$log" 2>&1; then
        :
    else
        exit_code=$?
    fi
    eval "${key}_producer_exit=\$exit_code"
    eval "${key}_producer_log=\$log"
    if [ "$exit_code" -eq 124 ]; then
        printf '%s\n' "STATUS: FAIL llm-goal-evidence-producer-timeout producer=$key seconds=$LANE_TIMEOUT_SECONDS" >>"$log"
    fi
}

clear_evidence_env() {
    env_path="$1"
    rm -f "$env_path"
}

gate_hint() {
    case "$1" in
        context_ponytail)
            echo "check-llm-tooling-context-ponytail-full-replacement.shs evidence with llm_tooling_context_ponytail_full_replacement_status=pass"
            ;;
        dashboard)
            echo "check-llm-dashboard-live-evidence.shs evidence with llm_dashboard_live_status=pass"
            ;;
        vllm_host)
            echo "local vLLM/GPU host evidence through check-llm-runtime-vllm-host-probe.shs --strict"
            ;;
        svllm_local)
            echo "check-llm-runtime-svllm-native-streaming-evidence.shs evidence with svllm_native_streaming_status=pass"
            ;;
        torch_optimizer)
            echo "Simple/libtorch CUDA optimizer evidence through check-llm-runtime-torch-cuda-optimizer-probe.shs --strict"
            ;;
        finetune_guard)
            echo "check-llm-finetune-acceptance-evidence.shs evidence with llm_finetune_acceptance_status=pass"
            ;;
        finetune_setup_contract)
            echo "check-llm-finetune-setup-contract.shs evidence with retry5/retry6/retry7 blocker diagnostics and next actions"
            ;;
        svllm_setup_contract)
            echo "check-llm-runtime-svllm-setup-contract.shs evidence with local readiness and native capability diagnostics"
            ;;
        public_absence)
            echo "public absence rendering guard must pass with manifest evidence"
            ;;
        feature_db_reference)
            echo "LLM feature database reference integrity guard must pass with path and stale-svLLM evidence"
            ;;
        *)
            echo "see lane log"
            ;;
    esac
}

env_value() {
    file="$1"
    key="$2"
    if [ -f "$file" ]; then
        sed -n "s/^${key}=//p" "$file" | tail -n 1
    fi
}

lane_required_gates() {
    case "$1" in
        context_ponytail)
            env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_required_gates
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_required_gates
            else
                printf '%s\n' "route_and_collector_evidence"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_required_gates
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -eq 1 ]; then
                printf '%s\n' "native_read_range,pinned_buffer,device_staging"
            else
                printf '%s\n' "local_readiness"
            fi
            ;;
        torch_optimizer)
            env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_required_gates
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_required_gates
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_required_gates
            fi
            ;;
        public_absence)
            env_value build/llm_tooling_public_absence_rendering/evidence.env llm_tooling_public_absence_rendering_required_gates
            ;;
        feature_db_reference)
            env_value build/llm_feature_db_reference_integrity/evidence.env llm_feature_db_reference_integrity_required_gates
            ;;
        prereq_doctor_contract)
            printf '%s\n' "dashboard_next_action,vllm_next_action,svllm_next_action,torch_next_action,finetune_next_action"
            ;;
        dashboard_http_setup_contract)
            printf '%s\n' "base_url,auth_configured,next_action"
            ;;
        vllm_host_env_contract)
            printf '%s\n' "llm_vllm_base_model,llm_vllm_endpoint"
            ;;
        torch_setup_contract)
            printf '%s\n' "python_torch,cuda_visibility,system_libtorch,surface_manifest,next_action"
            ;;
        finetune_setup_contract)
            printf '%s\n' "retry5_cache_manifest,retry6_training_eval,retry7_acceptance,next_action,surface_manifest"
            ;;
        svllm_setup_contract)
            printf '%s\n' "local_readiness,native_read_range,pinned_buffer,device_staging,capability_evidence,next_action"
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

lane_blocked_gates() {
    case "$1" in
        context_ponytail)
            env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_blocked_gates
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_blocked_gates
            else
                printf '%s\n' "none"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_blocked_gates
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -ne 1 ]; then
                printf '%s\n' "none"
                return
            fi
            blocked="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_blocked_gates)"
            printf '%s\n' "${blocked:-native_streaming_evidence}"
            ;;
        torch_optimizer)
            blocked="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_blocked_gates)"
            if [ -n "$blocked" ]; then
                printf '%s\n' "$blocked"
            else
                env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_blocked_gate
            fi
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_blocked_gates
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_blocked_gates
            fi
            ;;
        public_absence)
            env_value build/llm_tooling_public_absence_rendering/evidence.env llm_tooling_public_absence_rendering_blocked_gates
            ;;
        feature_db_reference)
            env_value build/llm_feature_db_reference_integrity/evidence.env llm_feature_db_reference_integrity_blocked_gates
            ;;
        prereq_doctor_contract)
            if [ "$(env_value build/llm_strict_host_prereq_doctor_contract/evidence.env llm_strict_host_prereq_doctor_contract_status)" = "pass" ]; then
                printf '%s\n' "none"
            else
                env_value build/llm_strict_host_prereq_doctor_contract/evidence.env llm_strict_host_prereq_doctor_contract_reason
            fi
            ;;
        dashboard_http_setup_contract)
            if [ "$(env_value build/llm_dashboard_live_http_setup_contract/evidence.env llm_dashboard_live_http_setup_contract_status)" = "pass" ]; then
                printf '%s\n' "none"
            else
                env_value build/llm_dashboard_live_http_setup_contract/evidence.env llm_dashboard_live_http_setup_contract_reason
            fi
            ;;
        vllm_host_env_contract)
            if [ "$(env_value build/llm_runtime_vllm_host_env_contract/evidence.env llm_runtime_vllm_host_env_contract_status)" = "pass" ]; then
                printf '%s\n' "none"
            else
                env_value build/llm_runtime_vllm_host_env_contract/evidence.env llm_runtime_vllm_host_env_contract_reason
            fi
            ;;
        torch_setup_contract)
            if [ "$(env_value build/llm_runtime_torch_setup_contract/evidence.env llm_runtime_torch_setup_contract_status)" = "pass" ]; then
                printf '%s\n' "none"
            else
                env_value build/llm_runtime_torch_setup_contract/evidence.env llm_runtime_torch_setup_contract_reason
            fi
            ;;
        finetune_setup_contract)
            if [ "$(env_value build/llm_finetune_setup_contract/evidence.env llm_finetune_setup_contract_status)" = "pass" ]; then
                printf '%s\n' "none"
            else
                env_value build/llm_finetune_setup_contract/evidence.env llm_finetune_setup_contract_reason
            fi
            ;;
        svllm_setup_contract)
            if [ "$(env_value build/llm_runtime_svllm_setup_contract/evidence.env llm_runtime_svllm_setup_contract_status)" = "pass" ]; then
                printf '%s\n' "none"
            else
                env_value build/llm_runtime_svllm_setup_contract/evidence.env llm_runtime_svllm_setup_contract_reason
            fi
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

lane_blocker_reason() {
    case "$1" in
        context_ponytail)
            env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_reason
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_reason
            else
                printf '%s\n' "default_route_and_collector_evidence_only"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_reason
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_reason
            else
                printf '%s\n' "default_local_readiness_only"
            fi
            ;;
        torch_optimizer)
            env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_reason
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_reason
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_blocker_reason
            fi
            ;;
        public_absence)
            env_value build/llm_tooling_public_absence_rendering/evidence.env llm_tooling_public_absence_rendering_reason
            ;;
        feature_db_reference)
            env_value build/llm_feature_db_reference_integrity/evidence.env llm_feature_db_reference_integrity_reason
            ;;
        prereq_doctor_contract)
            env_value build/llm_strict_host_prereq_doctor_contract/evidence.env llm_strict_host_prereq_doctor_contract_reason
            ;;
        dashboard_http_setup_contract)
            env_value build/llm_dashboard_live_http_setup_contract/evidence.env llm_dashboard_live_http_setup_contract_reason
            ;;
        vllm_host_env_contract)
            env_value build/llm_runtime_vllm_host_env_contract/evidence.env llm_runtime_vllm_host_env_contract_reason
            ;;
        torch_setup_contract)
            env_value build/llm_runtime_torch_setup_contract/evidence.env llm_runtime_torch_setup_contract_reason
            ;;
        finetune_setup_contract)
            env_value build/llm_finetune_setup_contract/evidence.env llm_finetune_setup_contract_reason
            ;;
        svllm_setup_contract)
            env_value build/llm_runtime_svllm_setup_contract/evidence.env llm_runtime_svllm_setup_contract_reason
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

primary_blocked_gate_for() {
    blocked="$1"
    case "${blocked:-}" in
        ""|none|n/a)
            printf '%s\n' "none"
            ;;
        *)
            printf '%s\n' "$blocked" | cut -d '|' -f 1 | cut -d ',' -f 1 | cut -d ':' -f 1
            ;;
    esac
}

lane_next_action() {
    case "$1" in
        context_ponytail)
            next_action="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_next_action)"
            if [ -n "$next_action" ]; then
                printf '%s\n' "$next_action"
            else
                printf '%s\n' "run $(gate_hint context_ponytail) and resolve replacement surface failures"
            fi
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                next_action="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_next_action)"
                if [ -n "$next_action" ]; then
                    printf '%s\n' "$next_action"
                else
                    printf '%s\n' "run $(gate_hint dashboard) and resolve live dashboard route or auth failures"
                fi
            else
                next_action="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_next_action)"
                printf '%s\n' "${next_action:-run --strict-host on a configured host when live authenticated dashboard completion evidence is required}"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_next_action
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -eq 1 ]; then
                next_action="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_next_action)"
                printf '%s\n' "${next_action:-collect strict svLLM native streaming evidence and resolve reported native blockers}"
            else
                next_action="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_next_action)"
                printf '%s\n' "${next_action:-run --strict-host on a configured native svLLM host when native streaming completion evidence is required}"
            fi
            ;;
        torch_optimizer)
            env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_next_action
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_next_action
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_next_action
            fi
            ;;
        public_absence)
            next_action="$(env_value build/llm_tooling_public_absence_rendering/evidence.env llm_tooling_public_absence_rendering_next_action)"
            printf '%s\n' "${next_action:-rerun the public absence rendering guard after public manual or dashboard wording changes}"
            ;;
        feature_db_reference)
            next_action="$(env_value build/llm_feature_db_reference_integrity/evidence.env llm_feature_db_reference_integrity_next_action)"
            printf '%s\n' "${next_action:-rerun the LLM feature database reference integrity guard after feature DB or generated-doc path changes}"
            ;;
        prereq_doctor_contract)
            status="$(env_value build/llm_strict_host_prereq_doctor_contract/evidence.env llm_strict_host_prereq_doctor_contract_status)"
            if [ "$status" = "pass" ]; then
                printf '%s\n' "strict host prereq doctor next-action contract is covered"
            else
                printf '%s\n' "run scripts/check/check-llm-strict-host-prereq-doctor-contract.shs and restore missing next-action fields"
            fi
            ;;
        dashboard_http_setup_contract)
            status="$(env_value build/llm_dashboard_live_http_setup_contract/evidence.env llm_dashboard_live_http_setup_contract_status)"
            if [ "$status" = "pass" ]; then
                printf '%s\n' "dashboard live HTTP setup contract is covered"
            else
                printf '%s\n' "run scripts/check/check-llm-dashboard-live-http-setup-contract.shs and restore missing setup blockers"
            fi
            ;;
        vllm_host_env_contract)
            status="$(env_value build/llm_runtime_vllm_host_env_contract/evidence.env llm_runtime_vllm_host_env_contract_status)"
            if [ "$status" = "pass" ]; then
                printf '%s\n' "vLLM host documented env contract is covered"
            else
                printf '%s\n' "run scripts/check/check-llm-runtime-vllm-host-env-contract.shs and restore documented env handling"
            fi
            ;;
        torch_setup_contract)
            status="$(env_value build/llm_runtime_torch_setup_contract/evidence.env llm_runtime_torch_setup_contract_status)"
            if [ "$status" = "pass" ]; then
                printf '%s\n' "Torch setup diagnostic contract is covered"
            else
                printf '%s\n' "run scripts/check/check-llm-runtime-torch-setup-contract.shs and restore setup diagnostic fields"
            fi
            ;;
        finetune_setup_contract)
            status="$(env_value build/llm_finetune_setup_contract/evidence.env llm_finetune_setup_contract_status)"
            if [ "$status" = "pass" ]; then
                printf '%s\n' "fine-tune setup diagnostic contract is covered"
            else
                printf '%s\n' "run scripts/check/check-llm-finetune-setup-contract.shs and restore retry blocker diagnostics"
            fi
            ;;
        svllm_setup_contract)
            status="$(env_value build/llm_runtime_svllm_setup_contract/evidence.env llm_runtime_svllm_setup_contract_status)"
            if [ "$status" = "pass" ]; then
                printf '%s\n' "svLLM setup diagnostic contract is covered"
            else
                printf '%s\n' "run scripts/check/check-llm-runtime-svllm-setup-contract.shs and restore local/native diagnostic fields"
            fi
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

lane_detail_values() {
    key="$1"
    case "$key" in
        context_ponytail)
            mimic_status="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_status)"
            full_replacement_status="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_full_replacement_status)"
            full_replacement_reason="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_full_replacement_reason)"
            mimic_surface_manifest_count="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_surface_manifest_count)"
            mimic_surface_manifest_size="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_surface_manifest_size)"
            mimic_surface_manifest_sha256="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_surface_manifest_sha256)"
            mimic_system_log_sha256="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_system_log_sha256)"
            mimic_context_unit_log_sha256="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_context_unit_log_sha256)"
            mimic_ponytail_unit_log_sha256="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_ponytail_unit_log_sha256)"
            replacement_status="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_status)"
            replacement_scope="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_scope)"
            replacement_failures="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_failures)"
            replacement_required="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_required_gates)"
            replacement_blocked="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_blocked_gates)"
            replacement_primary="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_primary_blocked_gate)"
            replacement_next_action="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_next_action)"
            replacement_manifest_count="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_surface_manifest_count)"
