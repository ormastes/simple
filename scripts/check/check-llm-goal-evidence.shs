#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_goal_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_goal_evidence_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
LANE_TIMEOUT_SECONDS="${LLM_GOAL_LANE_TIMEOUT_SECONDS:-180}"
SVLLM_LANE_TIMEOUT_SECONDS="${LLM_GOAL_SVLLM_LANE_TIMEOUT_SECONDS:-}"
STRICT_HOST=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --strict-host)
            STRICT_HOST=1
            ;;
        --help|-h)
            echo "usage: sh scripts/check/check-llm-goal-evidence.shs [--strict-host]"
            echo "  --strict-host  require full context/Ponytail replacement, live dashboard, live vLLM, native svLLM, fine-tune acceptance, and Simple/libtorch CUDA optimizer gates to pass"
            exit 0
            ;;
        *)
            echo "unknown option: $1" >&2
            exit 2
            ;;
    esac
    shift
done

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH"

lane_timeout_seconds() {
    key="$1"
    case "$key" in
        svllm_local)
            if [ -n "$SVLLM_LANE_TIMEOUT_SECONDS" ]; then
                printf '%s\n' "$SVLLM_LANE_TIMEOUT_SECONDS"
            elif [ "$LANE_TIMEOUT_SECONDS" -lt 120 ]; then
                printf '%s\n' "120"
            else
                printf '%s\n' "$LANE_TIMEOUT_SECONDS"
            fi
            ;;
        *)
            printf '%s\n' "$LANE_TIMEOUT_SECONDS"
            ;;
    esac
}

run_lane() {
    key="$1"
    expected="$2"
    shift 2
    log="$BUILD_DIR/$key.log"
    report_path="$BUILD_DIR/${key}_report.md"
    timeout_seconds="$(lane_timeout_seconds "$key")"
    exit_code=0
    if command -v timeout >/dev/null 2>&1; then
        if timeout "$timeout_seconds" env REPORT_PATH="$report_path" "$@" >"$log" 2>&1; then
            :
        else
            exit_code=$?
        fi
    elif env REPORT_PATH="$report_path" "$@" >"$log" 2>&1; then
        :
    else
        exit_code=$?
    fi
    if grep -F "STATUS: PASS" "$log" >/dev/null 2>&1; then
        status="pass"
    elif grep -F "STATUS: WARN" "$log" >/dev/null 2>&1; then
        status="warn"
    else
        status="fail"
    fi
    if [ "$exit_code" -ne 0 ]; then
        status="fail"
    fi
    eval "${key}_status=\$status"
    eval "${key}_exit=\$exit_code"
    eval "${key}_expected=\$expected"
    eval "${key}_timeout_seconds=\$timeout_seconds"
    if [ "$exit_code" -eq 124 ]; then
        printf '%s\n' "STATUS: FAIL llm-goal-evidence-lane-timeout lane=$key seconds=$timeout_seconds" >>"$log"
    fi
}

run_producer() {
    key="$1"
    log="$2"
    shift 2
    exit_code=0
    if command -v timeout >/dev/null 2>&1; then
        if timeout "$LANE_TIMEOUT_SECONDS" "$@" >"$log" 2>&1; then
            :
        else
            exit_code=$?
        fi
    elif "$@" >"$log" 2>&1; then
        :
    else
        exit_code=$?
    fi
    eval "${key}_producer_exit=\$exit_code"
    eval "${key}_producer_log=\$log"
    if [ "$exit_code" -eq 124 ]; then
        printf '%s\n' "STATUS: FAIL llm-goal-evidence-producer-timeout producer=$key seconds=$LANE_TIMEOUT_SECONDS" >>"$log"
    fi
}

clear_evidence_env() {
    env_path="$1"
    rm -f "$env_path"
}

gate_hint() {
    case "$1" in
        context_ponytail)
            echo "check-llm-tooling-context-ponytail-full-replacement.shs evidence with llm_tooling_context_ponytail_full_replacement_status=pass"
            ;;
        dashboard)
            echo "check-llm-dashboard-live-evidence.shs evidence with llm_dashboard_live_status=pass"
            ;;
        vllm_host)
            echo "local vLLM/GPU host evidence through check-llm-runtime-vllm-host-probe.shs --strict"
            ;;
        svllm_local)
            echo "check-llm-runtime-svllm-native-streaming-evidence.shs evidence with svllm_native_streaming_status=pass"
            ;;
        torch_optimizer)
            echo "Simple/libtorch CUDA optimizer evidence through check-llm-runtime-torch-cuda-optimizer-probe.shs --strict"
            ;;
        finetune_guard)
            echo "check-llm-finetune-acceptance-evidence.shs evidence with llm_finetune_acceptance_status=pass"
            ;;
        public_absence)
            echo "public absence rendering guard must pass"
            ;;
        *)
            echo "see lane log"
            ;;
    esac
}

env_value() {
    file="$1"
    key="$2"
    if [ -f "$file" ]; then
        sed -n "s/^${key}=//p" "$file" | tail -n 1
    fi
}

lane_required_gates() {
    case "$1" in
        context_ponytail)
            env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_required_gates
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_required_gates
            else
                printf '%s\n' "route_and_collector_evidence"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_required_gates
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -eq 1 ]; then
                printf '%s\n' "native_read_range,pinned_buffer,device_staging"
            else
                printf '%s\n' "local_readiness"
            fi
            ;;
        torch_optimizer)
            env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_required_gates
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_required_gates
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_required_gates
            fi
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

lane_blocked_gates() {
    case "$1" in
        context_ponytail)
            env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_blocked_gates
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_blocked_gates
            else
                printf '%s\n' "none"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_blocked_gates
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -ne 1 ]; then
                printf '%s\n' "none"
                return
            fi
            blocked="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_blocked_gates)"
            printf '%s\n' "${blocked:-native_streaming_evidence}"
            ;;
        torch_optimizer)
            blocked="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_blocked_gates)"
            if [ -n "$blocked" ]; then
                printf '%s\n' "$blocked"
            else
                env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_blocked_gate
            fi
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_blocked_gates
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_blocked_gates
            fi
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

lane_blocker_reason() {
    case "$1" in
        context_ponytail)
            env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_reason
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_reason
            else
                printf '%s\n' "default_route_and_collector_evidence_only"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_reason
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_reason
            else
                printf '%s\n' "default_local_readiness_only"
            fi
            ;;
        torch_optimizer)
            env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_reason
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_reason
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_blocker_reason
            fi
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

primary_blocked_gate_for() {
    blocked="$1"
    case "${blocked:-}" in
        ""|none|n/a)
            printf '%s\n' "none"
            ;;
        *)
            printf '%s\n' "$blocked" | cut -d '|' -f 1 | cut -d ',' -f 1 | cut -d ':' -f 1
            ;;
    esac
}

lane_next_action() {
    case "$1" in
        context_ponytail)
            next_action="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_next_action)"
            if [ -n "$next_action" ]; then
                printf '%s\n' "$next_action"
            else
                printf '%s\n' "run $(gate_hint context_ponytail) and resolve replacement surface failures"
            fi
            ;;
        dashboard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                next_action="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_next_action)"
                if [ -n "$next_action" ]; then
                    printf '%s\n' "$next_action"
                else
                    printf '%s\n' "run $(gate_hint dashboard) and resolve live dashboard route or auth failures"
                fi
            else
                printf '%s\n' "run --strict-host on a configured host when live authenticated dashboard completion evidence is required"
            fi
            ;;
        vllm_host)
            env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_next_action
            ;;
        svllm_local)
            if [ "$STRICT_HOST" -eq 1 ]; then
                next_action="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_next_action)"
                printf '%s\n' "${next_action:-collect strict svLLM native streaming evidence and resolve reported native blockers}"
            else
                printf '%s\n' "run --strict-host on a configured native svLLM host when native streaming completion evidence is required"
            fi
            ;;
        torch_optimizer)
            env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_next_action
            ;;
        finetune_guard)
            if [ "$STRICT_HOST" -eq 1 ]; then
                env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_next_action
            else
                env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_next_action
            fi
            ;;
        public_absence)
            printf '%s\n' "rerun the public absence rendering guard after public manual or dashboard wording changes"
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

lane_detail_values() {
    key="$1"
    case "$key" in
        context_ponytail)
            mimic_status="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_status)"
            full_replacement_status="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_full_replacement_status)"
            full_replacement_reason="$(env_value build/llm_tooling_context_ponytail_mimic/evidence.env llm_tooling_context_ponytail_mimic_full_replacement_reason)"
            replacement_status="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_status)"
            replacement_scope="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_scope)"
            replacement_failures="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_failures)"
            replacement_required="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_required_gates)"
            replacement_blocked="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_blocked_gates)"
            replacement_primary="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_primary_blocked_gate)"
            replacement_next_action="$(env_value build/llm_tooling_context_ponytail_full_replacement/evidence.env llm_tooling_context_ponytail_full_replacement_next_action)"
            printf '%s\n' "mimic_status=${mimic_status:-n/a};full_replacement_status=${full_replacement_status:-n/a};full_replacement_reason=${full_replacement_reason:-n/a};replacement_status=${replacement_status:-n/a};replacement_scope=${replacement_scope:-n/a};replacement_required_gates=${replacement_required:-n/a};replacement_blocked_gates=${replacement_blocked:-none};replacement_primary_blocked_gate=${replacement_primary:-n/a};replacement_failures=${replacement_failures:-none};next_action=${replacement_next_action:-n/a}"
            ;;
        dashboard)
            dashboard_status="$(env_value build/llm_dashboard_evidence/evidence.env llm_dashboard_evidence_status)"
            live_status="$(env_value build/llm_dashboard_evidence/evidence.env llm_dashboard_evidence_live_status)"
            live_reason="$(env_value build/llm_dashboard_evidence/evidence.env llm_dashboard_evidence_live_reason)"
            live_wrapper_status="not_collected"
            live_wrapper_scope="strict_host_only"
            live_wrapper_failures="not_collected"
            if [ "$STRICT_HOST" -eq 1 ]; then
                live_wrapper_status="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_status)"
                live_wrapper_scope="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_scope)"
                live_wrapper_failures="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_failures)"
            fi
            live_wrapper_required="not_collected"
            live_wrapper_blocked="not_collected"
            live_wrapper_primary="not_collected"
            live_wrapper_next_action="run --strict-host on a configured host when live authenticated dashboard completion evidence is required"
            live_http_status="not_collected"
            live_http_reason="not_collected"
            live_http_blocked="not_collected"
            live_http_primary="not_collected"
            live_http_next_action="not_collected"
            if [ "$STRICT_HOST" -eq 1 ]; then
                live_wrapper_required="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_required_gates)"
                live_wrapper_blocked="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_blocked_gates)"
                live_wrapper_primary="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_primary_blocked_gate)"
                live_wrapper_next_action="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_next_action)"
                if [ -z "$live_wrapper_next_action" ]; then
                    live_wrapper_next_action="run check-llm-dashboard-live-evidence.shs and resolve live dashboard route or auth failures"
                fi
                live_http_status="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_http_status)"
                live_http_reason="$(env_value build/llm_dashboard_live/evidence.env llm_dashboard_live_http_reason)"
                live_http_blocked="$(env_value build/llm_dashboard_live_http/evidence.env llm_dashboard_live_http_blocked_gates)"
                live_http_primary="$(env_value build/llm_dashboard_live_http/evidence.env llm_dashboard_live_http_primary_blocked_gate)"
                live_http_next_action="$(env_value build/llm_dashboard_live_http/evidence.env llm_dashboard_live_http_next_action)"
            fi
            printf '%s\n' "dashboard_status=${dashboard_status:-n/a};live_status=${live_status:-n/a};live_reason=${live_reason:-n/a};live_wrapper_status=${live_wrapper_status:-n/a};live_wrapper_scope=${live_wrapper_scope:-n/a};live_wrapper_required_gates=${live_wrapper_required:-n/a};live_wrapper_blocked_gates=${live_wrapper_blocked:-none};live_wrapper_primary_blocked_gate=${live_wrapper_primary:-n/a};live_wrapper_failures=${live_wrapper_failures:-none};live_http_status=${live_http_status:-n/a};live_http_reason=${live_http_reason:-n/a};live_http_blocked_gates=${live_http_blocked:-n/a};live_http_primary_blocked_gate=${live_http_primary:-n/a};live_http_next_action=${live_http_next_action:-n/a};next_action=${live_wrapper_next_action:-n/a}"
            ;;
        vllm_host)
            local_vllm_status="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_local_vllm_status)"
            local_gpu_status="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_local_gpu_status)"
            preflight_status="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_preflight_status)"
            readiness_status="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_readiness_status)"
            endpoint_status="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_endpoint_status)"
            models_status="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_models_status)"
            primary_blocked_gate="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_primary_blocked_gate)"
            next_action="$(env_value build/llm_runtime_vllm_host_probe/evidence.env llm_runtime_vllm_host_probe_next_action)"
            if [ -z "$readiness_status" ]; then
                readiness_status="$preflight_status"
            fi
            printf '%s\n' "local_vllm_status=${local_vllm_status:-n/a};local_gpu_status=${local_gpu_status:-n/a};readiness_status=${readiness_status:-n/a};preflight_status=${preflight_status:-n/a};endpoint_status=${endpoint_status:-n/a};models_status=${models_status:-n/a};primary_blocked_gate=${primary_blocked_gate:-n/a};next_action=${next_action:-n/a}"
            ;;
        svllm_local)
            native_status="not_required"
            native_reason="default_local_readiness_only"
            local_readiness_status="n/a"
            read_range_status="not_collected"
            pinned_buffer_status="not_collected"
            device_staging_status="not_collected"
            local_read_bytes_status="not_collected"
            capability_source="not_collected"
            if [ "$STRICT_HOST" -eq 1 ]; then
                native_status="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_status)"
                native_reason="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_reason)"
                native_blocked_gates="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_blocked_gates)"
                native_primary_blocked_gate="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_primary_blocked_gate)"
                native_next_action="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_next_action)"
                local_readiness_status="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_local_readiness_status)"
                capability_source="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_capability_source)"
                read_range_status="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_read_range_status)"
                pinned_buffer_status="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_pinned_buffer_status)"
                device_staging_status="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_device_staging_status)"
                local_read_bytes_status="$(env_value build/llm_runtime_svllm_native_streaming/evidence.env svllm_native_streaming_local_read_bytes_status)"
            fi
            default_readiness_status="$(env_value build/llm_runtime_svllm_local_readiness/evidence.env llm_runtime_svllm_local_readiness_status)"
            printf '%s\n' "native_status=${native_status:-not_collected};native_reason=${native_reason:-n/a};native_blocked_gates=${native_blocked_gates:-n/a};native_primary_blocked_gate=${native_primary_blocked_gate:-n/a};local_readiness_status=${local_readiness_status:-n/a};default_readiness_status=${default_readiness_status:-n/a};capability_source=${capability_source:-n/a};read_range_status=${read_range_status:-n/a};pinned_buffer_status=${pinned_buffer_status:-n/a};device_staging_status=${device_staging_status:-n/a};local_read_bytes_status=${local_read_bytes_status:-n/a};next_action=${native_next_action:-n/a}"
            ;;
        finetune_guard)
            acceptance_status="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_status)"
            acceptance_reason="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_reason)"
            gate_exit="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_gate_exit)"
            gate_status="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_gate_status)"
            blocked_gates="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_blocked_gates)"
            primary_blocked_gate="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_primary_blocked_gate)"
            training_allowed="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_training_allowed)"
            upstream_attempt_record="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_upstream_attempt_record)"
            upstream_cache_manifest="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_upstream_cache_manifest)"
            attempt_record="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_attempt_record)"
            model_manifest="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_model_manifest)"
            model_manifest_exists="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_model_manifest_exists)"
            model_manifest_deployable="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_model_manifest_deployable)"
            eval_result="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_eval_result)"
            eval_result_exists="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_eval_result_exists)"
            target_eval_reached="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_target_eval_reached)"
            required_accuracy="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_required_accuracy)"
            retry6_next_action="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_retry6_next_action)"
            decision_status="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_decision_status)"
            license_constraints="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_license_constraints)"
            safety_eval="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_safety_eval)"
            deployment_evidence="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_deployment_evidence)"
            app_handoff_doc_ready="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_app_handoff_doc_ready)"
            next_action="$(env_value build/llm_finetune_acceptance/evidence.env llm_finetune_acceptance_next_action)"
            guard_status="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_evidence_status)"
            guard_strict="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_strict_ready)"
            guard_blocked="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_blocked_gates)"
            guard_primary="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_primary_blocked_gate)"
            guard_reason="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_blocker_reason)"
            guard_next="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_next_action)"
            guard_acceptance_status="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_acceptance_status)"
            guard_acceptance_reason="$(env_value build/llm_finetune_guard_evidence/evidence.env llm_finetune_guard_acceptance_reason)"
            if [ "$STRICT_HOST" -eq 1 ]; then
                printf '%s\n' "guard_status=${guard_status:-n/a};guard_strict_ready=${guard_strict:-n/a};acceptance_status=${acceptance_status:-n/a};acceptance_reason=${acceptance_reason:-n/a};gate_exit=${gate_exit:-n/a};gate_status=${gate_status:-n/a};blocked_gates=${blocked_gates:-n/a};primary_blocked_gate=${primary_blocked_gate:-n/a};training_allowed=${training_allowed:-n/a};upstream_attempt_record=${upstream_attempt_record:-n/a};upstream_cache_manifest=${upstream_cache_manifest:-n/a};attempt_record=${attempt_record:-n/a};model_manifest=${model_manifest:-n/a};model_manifest_exists=${model_manifest_exists:-n/a};model_manifest_deployable=${model_manifest_deployable:-n/a};eval_result=${eval_result:-n/a};eval_result_exists=${eval_result_exists:-n/a};target_eval_reached=${target_eval_reached:-n/a};required_accuracy=${required_accuracy:-n/a};retry6_next_action=${retry6_next_action:-n/a};decision_status=${decision_status:-n/a};license_constraints=${license_constraints:-n/a};safety_eval=${safety_eval:-n/a};deployment_evidence=${deployment_evidence:-n/a};app_handoff_doc_ready=${app_handoff_doc_ready:-n/a};next_action=${next_action:-n/a}"
            else
                detail_next_action="${next_action:-}"
                if [ -z "$detail_next_action" ]; then
                    detail_next_action="${guard_next:-n/a}"
                fi
                printf '%s\n' "guard_status=${guard_status:-n/a};guard_strict_ready=${guard_strict:-n/a};guard_blocked_gates=${guard_blocked:-n/a};guard_primary_blocked_gate=${guard_primary:-n/a};guard_reason=${guard_reason:-n/a};acceptance_status=${acceptance_status:-n/a};acceptance_reason=${acceptance_reason:-n/a};acceptance_blocked_gates=${blocked_gates:-n/a};acceptance_primary_blocked_gate=${primary_blocked_gate:-n/a};training_allowed=${training_allowed:-n/a};upstream_attempt_record=${upstream_attempt_record:-n/a};upstream_cache_manifest=${upstream_cache_manifest:-n/a};attempt_record=${attempt_record:-n/a};model_manifest=${model_manifest:-n/a};model_manifest_exists=${model_manifest_exists:-n/a};model_manifest_deployable=${model_manifest_deployable:-n/a};eval_result=${eval_result:-n/a};eval_result_exists=${eval_result_exists:-n/a};target_eval_reached=${target_eval_reached:-n/a};required_accuracy=${required_accuracy:-n/a};retry6_next_action=${retry6_next_action:-n/a};decision_status=${decision_status:-n/a};license_constraints=${license_constraints:-n/a};safety_eval=${safety_eval:-n/a};deployment_evidence=${deployment_evidence:-n/a};app_handoff_doc_ready=${app_handoff_doc_ready:-n/a};next_action=$detail_next_action"
            fi
            ;;
        torch_optimizer)
            torch_status="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_normalized_status)"
            torch_reason="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_normalized_reason)"
            blocked_gates="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_blocked_gates)"
            primary_blocked_gate="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_primary_blocked_gate)"
            torch_available="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_torch_available_normalized)"
            cuda_available="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_cuda_available_normalized)"
            parameter_is_cuda="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_parameter_is_cuda_normalized)"
            grad_handle="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_grad_handle_normalized)"
            optimizer_step_attempted="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_optimizer_step_attempted_normalized)"
            before_sum="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_before_sum_normalized)"
            after_sum="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_after_sum_normalized)"
            wrapper_exit="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_wrapper_exit)"
            next_action="$(env_value build/llm_runtime_torch_cuda_optimizer_probe/evidence.env torch_cuda_optimizer_probe_next_action)"
            printf '%s\n' "torch_status=${torch_status:-n/a};torch_reason=${torch_reason:-n/a};blocked_gates=${blocked_gates:-n/a};primary_blocked_gate=${primary_blocked_gate:-n/a};torch_available=${torch_available:-n/a};cuda_available=${cuda_available:-n/a};parameter_is_cuda=${parameter_is_cuda:-n/a};grad_handle=${grad_handle:-n/a};optimizer_step_attempted=${optimizer_step_attempted:-n/a};before_sum=${before_sum:-n/a};after_sum=${after_sum:-n/a};wrapper_exit=${wrapper_exit:-n/a};next_action=${next_action:-n/a}"
            ;;
        *)
            printf '%s\n' "n/a"
            ;;
    esac
}

if [ "$STRICT_HOST" -eq 1 ]; then
    clear_evidence_env build/llm_tooling_context_ponytail_full_replacement/evidence.env
    run_producer context_ponytail "$BUILD_DIR/context_ponytail_full_replacement.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/context_ponytail_full_replacement_report.md" sh scripts/check/check-llm-tooling-context-ponytail-full-replacement.shs
    run_lane context_ponytail pass env CONTEXT_PONYTAIL_FULL_REPLACEMENT_EVIDENCE_ENV=build/llm_tooling_context_ponytail_full_replacement/evidence.env sh scripts/check/check-llm-tooling-context-ponytail-mimic.shs --strict-full-replacement
else
    clear_evidence_env build/llm_tooling_context_ponytail_full_replacement/evidence.env
    run_producer context_ponytail "$BUILD_DIR/context_ponytail_full_replacement.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/context_ponytail_full_replacement_report.md" sh scripts/check/check-llm-tooling-context-ponytail-full-replacement.shs
    run_lane context_ponytail pass env CONTEXT_PONYTAIL_FULL_REPLACEMENT_EVIDENCE_ENV=build/llm_tooling_context_ponytail_full_replacement/evidence.env sh scripts/check/check-llm-tooling-context-ponytail-mimic.shs --strict-full-replacement
fi
if [ "$STRICT_HOST" -eq 1 ]; then
    clear_evidence_env build/llm_dashboard_live_http/evidence.env
    run_producer dashboard_http "$BUILD_DIR/dashboard_live_http.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/dashboard_live_http_report.md" sh scripts/check/check-llm-dashboard-live-http-evidence.shs
    clear_evidence_env build/llm_dashboard_live/evidence.env
    run_producer dashboard "$BUILD_DIR/dashboard_live.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/dashboard_live_report.md" sh scripts/check/check-llm-dashboard-live-evidence.shs
    run_lane dashboard pass env LLM_DASHBOARD_LIVE_EVIDENCE_ENV=build/llm_dashboard_live/evidence.env sh scripts/check/check-llm-dashboard-evidence.shs --strict-live
else
    run_lane dashboard pass sh scripts/check/check-llm-dashboard-evidence.shs
fi
if [ "$STRICT_HOST" -eq 1 ]; then
    run_lane vllm_host pass sh scripts/check/check-llm-runtime-vllm-host-probe.shs --strict
else
    run_lane vllm_host warn sh scripts/check/check-llm-runtime-vllm-host-probe.shs
fi
if [ "$STRICT_HOST" -eq 1 ]; then
    clear_evidence_env build/llm_runtime_svllm_native_streaming/evidence.env
    run_producer svllm_local "$BUILD_DIR/svllm_native_streaming.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/svllm_native_streaming_report.md" sh scripts/check/check-llm-runtime-svllm-native-streaming-evidence.shs
    run_lane svllm_local pass env SVLLM_NATIVE_EVIDENCE_ENV=build/llm_runtime_svllm_native_streaming/evidence.env sh scripts/check/check-llm-runtime-svllm-local-readiness.shs --strict-native
else
    run_lane svllm_local pass sh scripts/check/check-llm-runtime-svllm-local-readiness.shs
fi
if [ "$STRICT_HOST" -eq 1 ]; then
    run_lane torch_optimizer pass sh scripts/check/check-llm-runtime-torch-cuda-optimizer-probe.shs --strict
else
    run_lane torch_optimizer warn sh scripts/check/check-llm-runtime-torch-cuda-optimizer-probe.shs
fi
if [ "$STRICT_HOST" -eq 1 ]; then
    clear_evidence_env build/llm_finetune_acceptance/evidence.env
    run_producer finetune_guard "$BUILD_DIR/finetune_acceptance.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/finetune_acceptance_report.md" sh scripts/check/check-llm-finetune-acceptance-evidence.shs
    run_lane finetune_guard pass env FINETUNE_ACCEPTANCE_EVIDENCE_ENV=build/llm_finetune_acceptance/evidence.env sh scripts/check/check-llm-finetune-guard-evidence.shs --strict-ready
else
    clear_evidence_env build/llm_finetune_acceptance/evidence.env
    run_producer finetune_guard "$BUILD_DIR/finetune_acceptance.log" env -u BUILD_DIR REPORT_PATH="$BUILD_DIR/finetune_acceptance_report.md" sh scripts/check/check-llm-finetune-acceptance-evidence.shs
    run_lane finetune_guard pass sh scripts/check/check-llm-finetune-guard-evidence.shs
fi
run_lane public_absence pass sh scripts/check/check-llm-tooling-public-absence-rendering.shs

status="pass"
warn_count=0
fail_count=0
warn_gates=""
failed_gates=""
failed_gate_hints=""
for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard public_absence; do
    eval "lane_status=\${${key}_status}"
    eval "expected=\${${key}_expected}"
    if [ "$lane_status" = "fail" ]; then
        status="fail"
        fail_count=$((fail_count + 1))
        if [ -z "$failed_gates" ]; then
            failed_gates="$key"
        else
            failed_gates="$failed_gates|$key"
        fi
        hint="$(gate_hint "$key")"
        if [ -z "$failed_gate_hints" ]; then
            failed_gate_hints="$key:$hint"
        else
            failed_gate_hints="$failed_gate_hints|$key:$hint"
        fi
    elif [ "$lane_status" = "warn" ]; then
        warn_count=$((warn_count + 1))
        if [ -z "$warn_gates" ]; then
            warn_gates="$key"
        else
            warn_gates="$warn_gates|$key"
        fi
        if [ "$expected" != "warn" ]; then
            status="fail"
            fail_count=$((fail_count + 1))
            if [ -z "$failed_gates" ]; then
                failed_gates="$key"
            else
                failed_gates="$failed_gates|$key"
            fi
            hint="$(gate_hint "$key")"
            if [ -z "$failed_gate_hints" ]; then
                failed_gate_hints="$key:$hint"
            else
                failed_gate_hints="$failed_gate_hints|$key:$hint"
            fi
        fi
    elif [ "$lane_status" != "$expected" ] && [ "$expected" != "warn" ]; then
        status="fail"
        fail_count=$((fail_count + 1))
        if [ -z "$failed_gates" ]; then
            failed_gates="$key"
        else
            failed_gates="$failed_gates|$key"
        fi
        hint="$(gate_hint "$key")"
        if [ -z "$failed_gate_hints" ]; then
            failed_gate_hints="$key:$hint"
        else
            failed_gate_hints="$failed_gate_hints|$key:$hint"
        fi
    fi
done

{
    printf '%s\n' "llm_goal_evidence_status=$status"
    printf '%s\n' "llm_goal_evidence_strict_host=$STRICT_HOST"
    printf '%s\n' "llm_goal_evidence_warn_count=$warn_count"
    printf '%s\n' "llm_goal_evidence_fail_count=$fail_count"
    printf '%s\n' "llm_goal_evidence_warn_gates=$warn_gates"
    printf '%s\n' "llm_goal_evidence_failed_gates=$failed_gates"
    printf '%s\n' "llm_goal_evidence_failed_gate_hints=$failed_gate_hints"
    printf '%s\n' "llm_goal_evidence_lane_timeout_seconds=$LANE_TIMEOUT_SECONDS"
    for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard public_absence; do
        eval "lane_status=\${${key}_status}"
        eval "exit_code=\${${key}_exit}"
        eval "expected=\${${key}_expected}"
        eval "timeout_seconds=\${${key}_timeout_seconds}"
        eval "producer_exit=\${${key}_producer_exit:-n/a}"
        eval "producer_log=\${${key}_producer_log:-n/a}"
        hint="$(gate_hint "$key")"
        printf '%s\n' "llm_goal_evidence_${key}_status=$lane_status"
        printf '%s\n' "llm_goal_evidence_${key}_expected=$expected"
        printf '%s\n' "llm_goal_evidence_${key}_exit=$exit_code"
        printf '%s\n' "llm_goal_evidence_${key}_producer_exit=$producer_exit"
        printf '%s\n' "llm_goal_evidence_${key}_producer_log=$producer_log"
        printf '%s\n' "llm_goal_evidence_${key}_timeout_seconds=$timeout_seconds"
        printf '%s\n' "llm_goal_evidence_${key}_hint=$hint"
        required="$(lane_required_gates "$key")"
        blocked="$(lane_blocked_gates "$key")"
        reason="$(lane_blocker_reason "$key")"
        if [ "$exit_code" -eq 124 ]; then
            blocked="lane_timeout"
            reason="lane_timeout_${timeout_seconds}s"
        fi
        primary_blocked="$(primary_blocked_gate_for "${blocked:-n/a}")"
        printf '%s\n' "llm_goal_evidence_${key}_required_gates=${required:-n/a}"
        printf '%s\n' "llm_goal_evidence_${key}_blocked_gates=${blocked:-n/a}"
        printf '%s\n' "llm_goal_evidence_${key}_primary_blocked_gate=$primary_blocked"
        printf '%s\n' "llm_goal_evidence_${key}_blocker_reason=${reason:-n/a}"
        printf '%s\n' "llm_goal_evidence_${key}_next_action=$(lane_next_action "$key")"
        printf '%s\n' "llm_goal_evidence_${key}_detail=$(lane_detail_values "$key")"
    done
} >"$OUT_ENV"

{
    printf '# LLM Goal Evidence\n\n'
    printf '%s\n' "- status: \`$status\`"
    if [ "$STRICT_HOST" -eq 1 ]; then
        printf '%s\n' "- strict_host: \`true\`"
    else
        printf '%s\n' "- strict_host: \`false\`"
    fi
    printf '%s\n' "- warn_count: \`$warn_count\`"
    printf '%s\n' "- fail_count: \`$fail_count\`"
    if [ -n "$warn_gates" ]; then
        printf '%s\n' "- warn_gates: \`$warn_gates\`"
    else
        printf '%s\n' "- warn_gates: \`none\`"
    fi
    if [ -n "$failed_gates" ]; then
        printf '%s\n' "- failed_gates: \`$failed_gates\`"
    else
        printf '%s\n' "- failed_gates: \`none\`"
    fi
    if [ -n "$failed_gate_hints" ]; then
        printf '%s\n' "- failed_gate_hints: \`$failed_gate_hints\`"
    else
        printf '%s\n' "- failed_gate_hints: \`none\`"
    fi
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '%s\n' "- lane_timeout_seconds: \`$LANE_TIMEOUT_SECONDS\`"
    printf '%s\n' "- svllm_lane_timeout_seconds: \`$(lane_timeout_seconds svllm_local)\`"
    printf '\n'
    printf '| lane | status | expected | exit | producer_exit | timeout | log | producer_log |\n'
    printf '|------|--------|----------|------|---------------|---------|-----|--------------|\n'
    for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard public_absence; do
        eval "lane_status=\${${key}_status}"
        eval "exit_code=\${${key}_exit}"
        eval "expected=\${${key}_expected}"
        eval "timeout_seconds=\${${key}_timeout_seconds}"
        eval "producer_exit=\${${key}_producer_exit:-n/a}"
        eval "producer_log=\${${key}_producer_log:-n/a}"
        printf '| %s | `%s` | `%s` | `%s` | `%s` | `%s` | `%s` | `%s` |\n' "$key" "$lane_status" "$expected" "$exit_code" "$producer_exit" "$timeout_seconds" "$BUILD_DIR/$key.log" "$producer_log"
    done
    printf '\n'
    printf '## Strict Evidence Hints\n\n'
    for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard public_absence; do
        printf '%s\n' "- $key: \`$(gate_hint "$key")\`"
    done
    printf '\n'
    printf '## Blocker Details\n\n'
    printf '| lane | required_gates | blocked_gates | primary_blocked_gate | reason |\n'
    printf '|------|----------------|---------------|----------------------|--------|\n'
    for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard; do
        eval "exit_code=\${${key}_exit}"
        required="$(lane_required_gates "$key")"
        blocked="$(lane_blocked_gates "$key")"
        reason="$(lane_blocker_reason "$key")"
        if [ "$exit_code" -eq 124 ]; then
            blocked="lane_timeout"
            reason="lane_timeout_$(lane_timeout_seconds "$key")s"
        fi
        primary_blocked="$(primary_blocked_gate_for "${blocked:-n/a}")"
        printf '| %s | `%s` | `%s` | `%s` | `%s` |\n' "$key" "${required:-n/a}" "${blocked:-n/a}" "$primary_blocked" "${reason:-n/a}"
    done
    printf '\n'
    printf '## Next Actions\n\n'
    printf '| lane | next_action |\n'
    printf '|------|-------------|\n'
    for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard public_absence; do
        printf '| %s | `%s` |\n' "$key" "$(lane_next_action "$key")"
    done
    printf '\n'
    printf '## Replacement, Dashboard, Host, svLLM, Torch, And Acceptance Details\n\n'
    printf '| lane | details |\n'
    printf '|------|---------|\n'
    for key in context_ponytail dashboard vllm_host svllm_local torch_optimizer finetune_guard; do
        printf '| %s | `%s` |\n' "$key" "$(lane_detail_values "$key")"
    done
    printf '\n'
    if [ "$STRICT_HOST" -eq 1 ]; then
        printf 'This aggregate is strict host evidence: full context/Ponytail replacement, live dashboard operation, live vLLM serving, native svLLM streaming, fine-tune acceptance, and Simple/libtorch CUDA optimizer execution must pass through their focused strict wrappers. Any WARN or FAIL lane keeps the aggregate failed.\n'
    else
        printf 'This aggregate proves the current local LLM tooling evidence lanes remain reproducible. WARN lanes are expected only for host-dependent gates that are still open on this machine: live vLLM serving and Simple/libtorch CUDA optimizer execution. The context/Ponytail lane includes repo-local full-replacement surface evidence, the dashboard lane is route/collector evidence only in default mode, the svLLM lane is local file-backed readiness only in default mode, and the fine-tune lane includes guard evidence plus non-blocking retry7 acceptance blocker details. This report is not release-completion evidence for live dashboard, live vLLM, native svLLM streaming, fine-tune acceptance, and Simple/libtorch CUDA optimizer gates; rerun with `--strict-host` on a configured host when those live gates must pass.\n'
    fi
} >"$REPORT_PATH"

if [ "$status" = "pass" ]; then
    echo "STATUS: PASS llm-goal-evidence warn_count=$warn_count"
else
    echo "STATUS: FAIL llm-goal-evidence warn_count=$warn_count fail_count=$fail_count"
    exit 1
fi
