#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
cd "$ROOT_DIR"

BUILD_DIR=${SIMPLEOS_HOST_GPU_BUILD_DIR:-build/simpleos_host_gpu_2d}
QEMU_TIMEOUT=${SIMPLEOS_HOST_GPU_QEMU_TIMEOUT:-20}
PRODUCTION_QEMU_TIMEOUT=${SIMPLEOS_HOST_GPU_PRODUCTION_QEMU_TIMEOUT:-120}
REQUIRE_CUDA=${SIMPLEOS_HOST_GPU_REQUIRE_CUDA:-0}
RSS_SAMPLE_INTERVAL=${SIMPLEOS_HOST_GPU_RSS_SAMPLE_INTERVAL:-0.1}
EXPECTED_PROTOCOL_VERSION=$(sed -n 's/^val SIMPLEOS_HOST_GPU_PROTOCOL_VERSION: i64 = \([0-9][0-9]*\)$/\1/p' src/lib/common/gpu/simpleos_host_gpu_protocol.spl)
[ -n "$EXPECTED_PROTOCOL_VERSION" ] || exit 2

case "$(uname -s)" in
    Linux) ACTIVE_HOST=linux ;;
    Darwin) ACTIVE_HOST=macos ;;
    MINGW*|MSYS*|CYGWIN*) ACTIVE_HOST=windows ;;
    *) ACTIVE_HOST=unknown ;;
esac

set_host_contract() {
    ACTIVE_HOST=$1
    case "$ACTIVE_HOST" in
        linux)
            BACKEND=vulkan
            PROCESSING_BACKEND=cuda-preferred-vulkan-fallback
            EXPECTED_RENDER_MASK=1
            EXPECTED_PROCESSING_MASK='(1|9)'
            EXPECTED_PROCESSING_RECEIPT='(cuda|vulkan)'
            ;;
        macos)
            BACKEND=metal
            PROCESSING_BACKEND=metal
            EXPECTED_RENDER_MASK=2
            EXPECTED_PROCESSING_MASK=2
            EXPECTED_PROCESSING_RECEIPT=metal
            ;;
        windows)
            BACKEND=directx
            PROCESSING_BACKEND=cuda-preferred-vulkan-fallback
            EXPECTED_RENDER_MASK=4
            EXPECTED_PROCESSING_MASK='(1|8|9)'
            EXPECTED_PROCESSING_RECEIPT='(cuda|vulkan)'
            ;;
        *)
            BACKEND=unsupported
            PROCESSING_BACKEND=unsupported
            EXPECTED_RENDER_MASK=0
            EXPECTED_PROCESSING_MASK=0
            EXPECTED_PROCESSING_RECEIPT=unsupported
            ;;
    esac
}

set_host_contract "$ACTIVE_HOST"
case "$ACTIVE_HOST" in
    macos) DEFAULT_RUNTIME_PATH=src/compiler_rust/target/bootstrap ;;
    windows) DEFAULT_RUNTIME_PATH= ;;
    *) DEFAULT_RUNTIME_PATH=build/simpleos_gpu_host/vulkan-cuda-runtime-target/bootstrap ;;
esac
RUNTIME_PATH=${SIMPLEOS_HOST_GPU_RUNTIME_PATH:-$DEFAULT_RUNTIME_PATH}

simple_binary_is_valid() {
    candidate=$1
    [ -x "$candidate" ] || return 1
    timeout_bin=$(find_timeout || true)
    [ -n "$timeout_bin" ] || return 1
    version=$("$timeout_bin" 5 "$candidate" --version 2>&1) || return 1
    [ -n "$version" ] || return 1
    case "$version" in
        *"bootstrap seed only"*) return 1 ;;
    esac
    if probe=$("$timeout_bin" 5 "$candidate" native-build --backend cranelift \
        --entry src/app/cli/main.spl --mode definitely-invalid-mode 2>&1)
    then
        return 1
    else
        probe_status=$?
    fi
    [ "$probe_status" -eq 1 ] || return 1
    case "$probe" in
        *"Error: invalid --mode 'definitely-invalid-mode' (expected dynload or one-binary)"*) ;;
        *) return 1 ;;
    esac
}

find_simple() {
    if [ -n "${SIMPLE_BIN:-}" ]; then
        simple_binary_is_valid "$SIMPLE_BIN" || return 1
        printf '%s\n' "$SIMPLE_BIN"
        return 0
    fi
    case "$ACTIVE_HOST" in
        macos)
            candidates="bin/release/$(uname -m)-apple-darwin/simple
bin/release/aarch64-apple-darwin/simple
bin/release/x86_64-apple-darwin/simple
build/bootstrap/stage3/$(uname -m)-apple-darwin/simple
build/bootstrap/stage2/$(uname -m)-apple-darwin/simple"
            ;;
        windows)
            candidates="bin/release/x86_64-pc-windows-msvc/simple.exe
bin/release/x86_64-pc-windows-gnu/simple.exe
bin/release/windows-x86_64/simple.exe"
            ;;
        *)
            candidates="bin/release/x86_64-unknown-linux-gnu/simple
build/bootstrap/stage3/x86_64-unknown-linux-gnu/simple
build/bootstrap/stage2/x86_64-unknown-linux-gnu/simple"
            ;;
    esac
    for candidate in $candidates
    do
        if simple_binary_is_valid "$candidate"; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

serial_has_pass() {
    log=$1
    isa=$2
    [ "$(grep -aEc "^HOST_GPU_MAP_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^HOST_GPU_HELLO_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    serial_render_receipt_valid "$log" "$isa" &&
    [ "$(grep -aEc "^HOST_GPU_DRAW_IR_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^HOST_GPU_PROCESS_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^SIMPLEOS_HOST_GPU_2D_PASS isa=$isa[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^TEST PASSED[[:space:]]*$" "$log")" -eq 1 ] &&
    serial_receipts_valid "$log" "$isa" &&
    serial_processing_pair_valid "$log" "$isa" &&
    { [ "$ACTIVE_HOST" != linux ] || [ "$REQUIRE_CUDA" != 1 ] || grep -aFq "HOST_GPU_PROCESS_OK isa=$isa backend=cuda " "$log"; } &&
    ! grep -aEq "^HOST_GPU_PROBE_FAIL isa=$isa " "$log" &&
    ! grep -aEq "^TEST FAILED[[:space:]]*$" "$log"
}

arm64_production_serial_has_correlated_frame() {
    log=$1
    [ -f "$log" ] || return 1
    ramfb_pattern='^\[WM\] ramfb configured successfully via fw_cfg DMA[[:space:]]*$'
    ready_pattern="^\\[wm-frame\\] host-gpu-ready backend=$BACKEND generation=[1-9][0-9]*[[:space:]]*$"
    presented_pattern="^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* checksum=[1-9][0-9]*[[:space:]]*$"
    first_frame_pattern='^\[desktop-gui\] first-frame-rendered scene_revision=[1-9][0-9]*[[:space:]]*$'
    desktop_ready_pattern='^\[desktop-gui-arm64\] desktop-ready revision=[1-9][0-9]*[[:space:]]*$'
    [ "$(grep -aEc "$ramfb_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc '^\[wm-frame\] host-gpu-ready ' "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc '^\[wm-frame\] host-gpu-presented ' "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$ready_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$presented_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$first_frame_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$desktop_ready_pattern" "$log")" -eq 1 ] || return 1
    ! grep -aEq '^\[desktop-gui-arm64\] fatal ' "$log" || return 1

    ready_generation=$(sed -n "s/^\\[wm-frame\\] host-gpu-ready backend=$BACKEND generation=\\([1-9][0-9]*\\)[[:space:]]*$/\\1/p" "$log")
    presented_generation=$(sed -n "s/^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=\\([1-9][0-9]*\\) run=.*/\\1/p" "$log")
    presented_run=$(sed -n "s/^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=[1-9][0-9]* run=\\([1-9][0-9]*\\) .*/\\1/p" "$log")
    presented_frame=$(sed -n "s/^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=\\([1-9][0-9]*\\) .*/\\1/p" "$log")
    first_revision=$(sed -n 's/^\[desktop-gui\] first-frame-rendered scene_revision=\([1-9][0-9]*\)[[:space:]]*$/\1/p' "$log")
    desktop_revision=$(sed -n 's/^\[desktop-gui-arm64\] desktop-ready revision=\([1-9][0-9]*\)[[:space:]]*$/\1/p' "$log")
    ramfb_line=$(grep -anE "$ramfb_pattern" "$log" | cut -d: -f1)
    ready_line=$(grep -anE "$ready_pattern" "$log" | cut -d: -f1)
    presented_line=$(grep -anE "$presented_pattern" "$log" | cut -d: -f1)
    first_frame_line=$(grep -anE "$first_frame_pattern" "$log" | cut -d: -f1)
    desktop_ready_line=$(grep -anE "$desktop_ready_pattern" "$log" | cut -d: -f1)

    [ "$presented_generation" -eq "$((ready_generation + 1))" ] &&
    [ "$presented_run" -eq "$ready_generation" ] &&
    [ "$presented_frame" -eq "$presented_generation" ] &&
    [ "$first_revision" -eq "$desktop_revision" ] &&
    [ "$ramfb_line" -lt "$ready_line" ] &&
    [ "$ready_line" -lt "$presented_line" ] &&
    [ "$presented_line" -lt "$first_frame_line" ] &&
    [ "$first_frame_line" -lt "$desktop_ready_line" ] &&
    awk -v ready="$ready_line" 'NR > ready && /^\[wm-frame\] host-gpu-fallback / { failed=1 } END { exit failed ? 1 : 0 }' "$log"
}

serial_render_receipt_valid() {
    log=$1
    isa=$2
    [ "$(grep -aEc "^HOST_GPU_RENDER_OK isa=$isa backend=$BACKEND .*[[:space:]]*$" "$log")" -eq 1 ]
}

serial_receipts_valid() {
    log=$1
    isa=$2
    grep -aEq "^HOST_GPU_MAP_OK isa=$isa device=[1-9][0-9]*[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_HELLO_OK isa=$isa generation=[1-9][0-9]* render_mask=$EXPECTED_RENDER_MASK processing_mask=$EXPECTED_PROCESSING_MASK protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]*[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_RENDER_OK isa=$isa backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=405589360 bg=2112 rect=960 other=0[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_DRAW_IR_OK isa=$isa backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=405589360 bg=2112 image=960 other=0[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=$EXPECTED_PROCESSING_RECEIPT generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=1792 mismatches=0[[:space:]]*$" "$log" || return 1
    hello_generation=$(sed -n "s/^HOST_GPU_HELLO_OK isa=$isa generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_generation=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa backend=$BACKEND generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    draw_ir_generation=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa backend=$BACKEND generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    process_generation=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa backend=.* generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_run=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    draw_ir_run=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    process_run=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_frame=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    draw_ir_frame=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    process_frame=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_identity=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa .* identity=\([1-9][0-9]*\) checksum=.*/\1/p" "$log")
    draw_ir_identity=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa .* identity=\([1-9][0-9]*\) checksum=.*/\1/p" "$log")
    case "$isa" in
        x86_64) expected_hello_generation=9 ;;
        aarch64) expected_hello_generation=19 ;;
        riscv64) expected_hello_generation=29 ;;
        *) return 1 ;;
    esac
    case "$ACTIVE_HOST" in
        windows) expected_hello_generation=$((expected_hello_generation + 1)) ;;
        linux) expected_hello_generation=$((expected_hello_generation + 2)) ;;
    esac
    [ "$hello_generation" -eq "$expected_hello_generation" ] &&
    [ "$render_generation" -eq "$((hello_generation + 1))" ] &&
    [ "$draw_ir_generation" -eq "$((render_generation + 1))" ] &&
    [ "$process_generation" -eq "$((draw_ir_generation + 1))" ] &&
    [ "$render_run" = "$draw_ir_run" ] && [ "$render_run" = "$process_run" ] &&
    [ "$render_frame" = "$render_generation" ] &&
    [ "$draw_ir_frame" = "$draw_ir_generation" ] &&
    [ "$process_frame" = "$process_generation" ] &&
    [ "$render_identity" = "$draw_ir_identity" ]
}

serial_processing_pair_valid() {
    log=$1
    isa=$2
    if [ "$ACTIVE_HOST" = macos ]; then
        grep -aEq "^HOST_GPU_HELLO_OK isa=$isa .* processing_mask=2 " "$log" &&
        grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=metal " "$log"
    elif grep -aEq "^HOST_GPU_HELLO_OK isa=$isa .* processing_mask=(8|9) " "$log"; then
        grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=cuda " "$log"
    elif grep -aEq "^HOST_GPU_HELLO_OK isa=$isa .* processing_mask=1 " "$log"; then
        grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=vulkan " "$log"
    else
        return 1
    fi
}

serial_processing_backend() {
    sed -n "s/.*HOST_GPU_PROCESS_OK isa=$2 backend=\(cuda\|vulkan\|metal\) .*/\1/p" "$1"
}

serial_reason() {
    log=$1
    isa=$2
    reason=$(sed -n "s/.*HOST_GPU_PROBE_FAIL isa=$isa reason=\([^[:space:]]*\).*/\1/p" "$log" | tail -n 1)
    if [ -n "$reason" ]; then
        printf '%s\n' "$reason"
    elif grep -aFq "TEST FAILED" "$log"; then
        printf '%s\n' guest-test-failed
    else
        printf '%s\n' missing-correlated-device-receipt
    fi
}

find_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        command -v timeout
    elif command -v gtimeout >/dev/null 2>&1; then
        command -v gtimeout
    else
        return 1
    fi
}

size_shared_file() {
    path=$1
    if command -v truncate >/dev/null 2>&1; then
        truncate -s 8388608 "$path"
    else
        dd if=/dev/zero of="$path" bs=1048576 count=8 >/dev/null 2>&1
    fi
}

daemon_rss_sample_kib() {
    pid=$1
    if [ -r "/proc/$pid/status" ]; then
        sed -n 's/^VmHWM:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "/proc/$pid/status"
    elif command -v ps >/dev/null 2>&1; then
        ps -o rss= -p "$pid" 2>/dev/null | sed -n 's/[[:space:]]*\([0-9][0-9]*\).*/\1/p'
    fi
}

monitor_daemon_max_rss() {
    monitored_pid=$1
    rss_output=$2
    max_rss_kib=0
    while kill -0 "$monitored_pid" 2>/dev/null; do
        sampled_rss_kib=$(daemon_rss_sample_kib "$monitored_pid" || true)
        case "$sampled_rss_kib" in ''|*[!0-9]*) sampled_rss_kib=0 ;; esac
        if [ "$sampled_rss_kib" -gt "$max_rss_kib" ]; then
            max_rss_kib=$sampled_rss_kib
            printf '%s\n' "$max_rss_kib" >"$rss_output"
        fi
        sleep "$RSS_SAMPLE_INTERVAL"
    done
    printf '%s\n' "$max_rss_kib" >"$rss_output"
}

qemu_bin_for_isa() {
    case "$1" in
        x86_64) printf '%s\n' "${QEMU_SYSTEM_X86_64:-qemu-system-x86_64}" ;;
        aarch64) printf '%s\n' "${QEMU_SYSTEM_AARCH64:-qemu-system-aarch64}" ;;
        riscv64) printf '%s\n' "${QEMU_SYSTEM_RISCV64:-qemu-system-riscv64}" ;;
    esac
}

qemu_capabilities_available() {
    isa=$1
    qemu_bin=$2
    machine=$3
    capability_dir="$BUILD_DIR/qemu-capabilities"
    mkdir -p "$capability_dir"
    "$qemu_bin" -machine help >"$capability_dir/$isa-machines.log" 2>&1 || return 1
    "$qemu_bin" -device help >"$capability_dir/$isa-devices.log" 2>&1 || return 1
    "$qemu_bin" -object help >"$capability_dir/$isa-objects.log" 2>&1 || return 1
    grep -Eq "(^|[[:space:],])$machine([[:space:],]|$)" "$capability_dir/$isa-machines.log" || return 1
    grep -Fq ivshmem-plain "$capability_dir/$isa-devices.log" || return 1
    [ "$isa" != aarch64 ] || grep -Fq ramfb "$capability_dir/$isa-devices.log" || return 1
    grep -Fq memory-backend-file "$capability_dir/$isa-objects.log" || return 1
}

metal_guest_contract_available() {
    probe=examples/09_embedded/simple_os/arch/common/host_gpu_ivshmem_probe_entry.spl
    [ -f "$probe" ] &&
    grep -Fq 'render_backend = "metal"' "$probe" &&
    grep -Eq 'host_gpu_ivshmem_negotiate\(.*render_backend' "$probe" &&
    grep -Fq 'HOST_GPU_RENDER_OK' "$probe" &&
    grep -Fq 'HOST_GPU_DRAW_IR_OK' "$probe" &&
    grep -Fq 'HOST_GPU_PROCESS_OK' "$probe"
}

core_c_bootstrap_runtime_available() {
    [ -f "$RUNTIME_PATH/core-c-bootstrap/libsimple_runtime.a" ] ||
    [ -f "$RUNTIME_PATH/core_c_bootstrap/libsimple_runtime.a" ] ||
    [ -f "$RUNTIME_PATH/libsimple_runtime.a" ]
}

emit_row() {
    row_host=$1
    row_isa=$2
    row_status=$3
    row_reason=$4
    row_log=$5
    row_processing_backend=${6:-}
    row_prefix="simpleos_qemu_host_gpu_2d_${row_host}_${row_isa}"
    case "$row_host" in
        macos) row_render_backend=metal; row_processing_backend=${row_processing_backend:-metal} ;;
        windows) row_render_backend=directx; row_processing_backend=${row_processing_backend:-cuda} ;;
        *) row_render_backend=vulkan; row_processing_backend=${row_processing_backend:-cuda-preferred-vulkan-fallback} ;;
    esac
    echo "${row_prefix}_status=$row_status"
    echo "${row_prefix}_reason=$row_reason"
    echo "${row_prefix}_render_backend=$row_render_backend"
    echo "${row_prefix}_processing_backend=$row_processing_backend"
    echo "${row_prefix}_serial_log=$row_log"
}

encode_argv_hex() {
    encoded_argv=hex:
    separator=
    for argument
    do
        encoded_argument=$(printf '%s' "$argument" | od -An -v -tx1 | tr -d ' \n')
        encoded_argv="${encoded_argv}${separator}${encoded_argument}"
        separator=,
    done
    printf '%s' "$encoded_argv"
}

kernel_for_isa() {
    case "$1" in
        x86_64) echo build/os/simpleos_x86_64_host_gpu_probe.elf ;;
        aarch64) echo build/os/simpleos_arm64_host_gpu_probe.elf ;;
        riscv64) echo build/os/simpleos_riscv64_host_gpu_probe.elf ;;
    esac
}

arm64_production_kernel() {
    echo build/os/simpleos_arm64_desktop_engine2d.elf
}

encoded_argv_valid() {
    printf '%s\n' "$1" | grep -Eq '^hex:([0-9a-f][0-9a-f])+(,([0-9a-f][0-9a-f])+)*$'
}

encoded_argv_field() (
    encoded=$1
    index=$2
    encoded_argv_valid "$encoded" || return 1
    IFS=,
    set -- ${encoded#hex:}
    while [ "$index" -gt 1 ]; do
        [ "$#" -gt 1 ] || return 1
        shift
        index=$((index - 1))
    done
    printf '%s\n' "$1"
)

encoded_arg() {
    encode_argv_hex "$1" | sed 's/^hex://'
}

encoded_arg_has_affixes() {
    encoded_prefix=$(encoded_arg "$2")
    encoded_suffix=$(encoded_arg "$3")
    case "$1" in
        "$encoded_prefix"?*"$encoded_suffix")
            encoded_middle=${1#"$encoded_prefix"}
            encoded_middle=${encoded_middle%"$encoded_suffix"}
            case "$encoded_middle" in *2c*) return 1 ;; esac
            return 0
            ;;
        *) return 1 ;;
    esac
}

encoded_kernel_path_valid() {
    case "$1" in
        "$2"|*2f"$2"|*5c"$2") return 0 ;;
        *) return 1 ;;
    esac
}

qemu_argv_evidence_valid() (
    isa=$1
    encoded=$2
    lane=${3:-probe}
    encoded_argv_valid "$encoded" || return 1
    old_ifs=$IFS
    IFS=,
    set -- ${encoded#hex:}
    IFS=$old_ifs
    if [ "$lane" = production ] && [ "$isa" = aarch64 ]; then
        kernel_suffix=$(encoded_arg "$(basename "$(arm64_production_kernel)")")
    else
        [ "$lane" = probe ] || return 1
        kernel_suffix=$(encoded_arg "$(basename "$(kernel_for_isa "$isa")")")
    fi
    object_prefix='memory-backend-file,id=hostgpu,share=on,mem-path='
    object_suffix=',size=8M'
    ivshmem=$(encoded_arg 'ivshmem-plain,memdev=hostgpu')
    case "$isa:$lane" in
        x86_64:probe)
            [ "$#" -eq 14 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg q35)" ] &&
            [ "$3" = "$(encoded_arg -m)" ] && [ "$4" = "$(encoded_arg 512M)" ] &&
            [ "$5" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$6" "$kernel_suffix" &&
            [ "$7" = "$(encoded_arg -nographic)" ] && [ "$8" = "$(encoded_arg -no-reboot)" ] &&
            [ "$9" = "$(encoded_arg -device)" ] && [ "${10}" = "$(encoded_arg virtio-net-pci)" ] &&
            [ "${11}" = "$(encoded_arg -object)" ] && encoded_arg_has_affixes "${12}" "$object_prefix" "$object_suffix" &&
            [ "${13}" = "$(encoded_arg -device)" ] && [ "${14}" = "$ivshmem" ]
            ;;
        aarch64:probe)
            [ "$#" -eq 15 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg virt)" ] &&
            [ "$3" = "$(encoded_arg -cpu)" ] && [ "$4" = "$(encoded_arg cortex-a72)" ] &&
            [ "$5" = "$(encoded_arg -m)" ] && [ "$6" = "$(encoded_arg 512M)" ] &&
            [ "$7" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$8" "$kernel_suffix" &&
            [ "$9" = "$(encoded_arg -nographic)" ] && [ "${10}" = "$(encoded_arg -device)" ] &&
            [ "${11}" = "$(encoded_arg virtio-net-pci)" ] && [ "${12}" = "$(encoded_arg -object)" ] &&
            encoded_arg_has_affixes "${13}" "$object_prefix" "$object_suffix" &&
            [ "${14}" = "$(encoded_arg -device)" ] && [ "${15}" = "$ivshmem" ]
            ;;
        aarch64:production)
            [ "$#" -eq 17 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg virt)" ] &&
            [ "$3" = "$(encoded_arg -cpu)" ] && [ "$4" = "$(encoded_arg cortex-a72)" ] &&
            [ "$5" = "$(encoded_arg -m)" ] && [ "$6" = "$(encoded_arg 512M)" ] &&
            [ "$7" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$8" "$kernel_suffix" &&
            [ "$9" = "$(encoded_arg -nographic)" ] && [ "${10}" = "$(encoded_arg -device)" ] &&
            [ "${11}" = "$(encoded_arg ramfb)" ] && [ "${12}" = "$(encoded_arg -device)" ] &&
            [ "${13}" = "$(encoded_arg virtio-net-pci)" ] && [ "${14}" = "$(encoded_arg -object)" ] &&
            encoded_arg_has_affixes "${15}" "$object_prefix" "$object_suffix" &&
            [ "${16}" = "$(encoded_arg -device)" ] && [ "${17}" = "$ivshmem" ]
            ;;
        riscv64:probe)
            [ "$#" -eq 11 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg virt)" ] &&
            [ "$3" = "$(encoded_arg -m)" ] && [ "$4" = "$(encoded_arg 512M)" ] &&
            [ "$5" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$6" "$kernel_suffix" &&
            [ "$7" = "$(encoded_arg -nographic)" ] && [ "$8" = "$(encoded_arg -object)" ] &&
            encoded_arg_has_affixes "$9" "$object_prefix" "$object_suffix" &&
            [ "${10}" = "$(encoded_arg -device)" ] && [ "${11}" = "$ivshmem" ]
            ;;
        *) return 1 ;;
    esac
)

arm64_production_evidence_valid() (
    probe_log=$1
    probe_args=$2
    production_log=$3
    production_args=$4
    arm64_production_serial_has_correlated_frame "$production_log" || return 1
    qemu_argv_evidence_valid aarch64 "$probe_args" || return 1
    qemu_argv_evidence_valid aarch64 "$production_args" production || return 1
    [ "$(encoded_argv_field "$probe_args" 13)" = "$(encoded_argv_field "$production_args" 15)" ] || return 1
    probe_generation=$(sed -n 's/^HOST_GPU_PROCESS_OK isa=aarch64 .* generation=\([1-9][0-9]*\) .*/\1/p' "$probe_log")
    production_ready_generation=$(sed -n "s/^\\[wm-frame\\] host-gpu-ready backend=$BACKEND generation=\\([1-9][0-9]*\\)[[:space:]]*$/\\1/p" "$production_log")
    case "$probe_generation:$production_ready_generation" in *[!0-9:]*|:*|*:) return 1 ;; esac
    case "$BACKEND" in
        metal) expected_ready_generation=$((probe_generation + 1)) ;;
        directx) expected_ready_generation=$((probe_generation + 2)) ;;
        vulkan) expected_ready_generation=$((probe_generation + 3)) ;;
        *) return 1 ;;
    esac
    [ "$production_ready_generation" -eq "$expected_ready_generation" ]
)

emit_row_execution_evidence() {
    evidence_prefix="simpleos_qemu_host_gpu_2d_$1_$2"
    printf '%s\n' "${evidence_prefix}_qemu_version=$3"
    printf '%s\n' "${evidence_prefix}_qemu_device_args=$4"
    printf '%s\n' "${evidence_prefix}_daemon_max_rss_kib=$5"
}

emit_arm64_production_evidence() {
    evidence_prefix="simpleos_qemu_host_gpu_2d_$1_aarch64"
    printf '%s\n' "${evidence_prefix}_production_serial_log=$2"
    printf '%s\n' "${evidence_prefix}_production_qemu_device_args=$3"
}

report_one() {
    report=$1
    key=$2
    [ "$(grep -ac "^${key}=" "$report" 2>/dev/null || true)" -eq 1 ] || return 1
    sed -n "s/^${key}=//p" "$report"
}

report_arm64_production_evidence_valid() {
    report=$1
    prefix=$2
    report_isa=$3
    row_log=$4
    row_qemu_device_args=$5
    row_production_serial_log=$(report_one "$report" "${prefix}_production_serial_log") || return 1
    row_production_qemu_device_args=$(report_one "$report" "${prefix}_production_qemu_device_args") || return 1
    [ "$report_isa" = aarch64 ] && [ -f "$row_production_serial_log" ] &&
    arm64_production_evidence_valid "$row_log" "$row_qemu_device_args" "$row_production_serial_log" "$row_production_qemu_device_args"
}

validate_report() {
    report=$1
    [ -f "$report" ] || return 1
    status=$(report_one "$report" simpleos_qemu_host_gpu_2d_status) || return 1
    reason=$(report_one "$report" simpleos_qemu_host_gpu_2d_reason) || return 1
    report_active_host=$(report_one "$report" simpleos_qemu_host_gpu_2d_host 2>/dev/null || true)
    [ -n "$report_active_host" ] || report_active_host=linux
    case "$report_active_host" in linux|macos|windows) ;; *) return 1 ;; esac
    [ -n "$reason" ] || return 1
    case "$status" in pass|blocked|fail|unsupported) ;; *) return 1 ;; esac

    for report_host in linux macos windows; do
        for report_isa in x86_64 aarch64 riscv64; do
            prefix="simpleos_qemu_host_gpu_2d_${report_host}_${report_isa}"
            row_status=$(report_one "$report" "${prefix}_status") || return 1
            row_reason=$(report_one "$report" "${prefix}_reason") || return 1
            row_render_backend=$(report_one "$report" "${prefix}_render_backend") || return 1
            row_processing_backend=$(report_one "$report" "${prefix}_processing_backend") || return 1
            row_log=$(report_one "$report" "${prefix}_serial_log") || return 1
            [ -n "$row_reason" ] && [ -n "$row_log" ] || return 1
            case "$row_status" in pass|blocked|fail|unsupported) ;; *) return 1 ;; esac
            case "$report_host:$row_render_backend:$row_processing_backend" in
                linux:vulkan:cuda-preferred-vulkan-fallback|linux:vulkan:cuda|linux:vulkan:vulkan) ;;
                macos:metal:metal|windows:directx:cuda-preferred-vulkan-fallback|windows:directx:cuda|windows:directx:vulkan) ;;
                *) return 1 ;;
            esac
            if [ "$row_status" = pass ]; then
                saved_row_host=$ACTIVE_HOST
                set_host_contract "$report_host"
                if ! {
                    [ "$row_reason" = ok ] &&
                    [ -f "$row_log" ] && serial_has_pass "$row_log" "$report_isa" &&
                    [ "$row_processing_backend" = "$(serial_processing_backend "$row_log" "$report_isa")" ] &&
                    row_qemu_version=$(report_one "$report" "${prefix}_qemu_version") &&
                    row_qemu_device_args=$(report_one "$report" "${prefix}_qemu_device_args") &&
                    row_daemon_rss=$(report_one "$report" "${prefix}_daemon_max_rss_kib") &&
                    [ -n "$row_qemu_version" ] &&
                    qemu_argv_evidence_valid "$report_isa" "$row_qemu_device_args" &&
                    case "$row_daemon_rss" in ''|*[!0-9]*) false ;; *) true ;; esac &&
                    [ "$row_daemon_rss" -gt 0 ] &&
                    { [ "$report_isa" != aarch64 ] || report_arm64_production_evidence_valid "$report" "$prefix" "$report_isa" "$row_log" "$row_qemu_device_args"; }
                }; then
                    set_host_contract "$saved_row_host"
                    return 1
                fi
                set_host_contract "$saved_row_host"
            fi
        done
    done

    if [ "$status" = pass ]; then
        saved_host=$ACTIVE_HOST
        set_host_contract "$report_active_host"
        [ "$reason" = "all-$report_active_host-host-gpu-rows-pass" ] || { set_host_contract "$saved_host"; return 1; }
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_backend)" = "$BACKEND" ] || { set_host_contract "$saved_host"; return 1; }
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_processing_backend)" = "$PROCESSING_BACKEND" ] || { set_host_contract "$saved_host"; return 1; }
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_rows)" -eq 3 ] || return 1
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_passed)" -eq 3 ] || return 1
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_blocked)" -eq 0 ] || return 1
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_failed)" -eq 0 ] || return 1
        for inactive_host in linux macos windows; do
            if [ "$inactive_host" != "$report_active_host" ]; then
                for report_isa in x86_64 aarch64 riscv64; do
                    [ "$(report_one "$report" "simpleos_qemu_host_gpu_2d_${inactive_host}_${report_isa}_status")" = unsupported ] || return 1
                done
            fi
        done
        for report_isa in x86_64 aarch64 riscv64; do
            prefix="simpleos_qemu_host_gpu_2d_${report_active_host}_${report_isa}"
            [ "$(report_one "$report" "${prefix}_status")" = pass ] || return 1
        done
        set_host_contract "$saved_host"
    fi

    echo "simpleos_qemu_host_gpu_2d_report_validation=pass"
    echo "simpleos_qemu_host_gpu_2d_report_status=$status"
    echo "simpleos_qemu_host_gpu_2d_report_reason=$reason"
}

self_test() {
    set_host_contract linux
    REQUIRE_CUDA=0
    temp_dir=$(mktemp -d)
    trap 'rm -rf "$temp_dir"' EXIT HUP INT TERM
    pass_log="$temp_dir/pass.log"
    fail_log="$temp_dir/fail.log"
    corrupt_log="$temp_dir/corrupt.log"
    corrupt_draw_ir_log="$temp_dir/corrupt-draw-ir.log"
    vulkan_log="$temp_dir/vulkan.log"
    wrong_backend_log="$temp_dir/wrong-backend.log"
    wrong_generation_log="$temp_dir/wrong-generation.log"
    stale_generation_log="$temp_dir/stale-generation.log"
    trailing_log="$temp_dir/trailing.log"
    contradictory_terminal_log="$temp_dir/contradictory-terminal.log"
    x86_log="$temp_dir/x86_64.log"
    riscv_log="$temp_dir/riscv64.log"
    metal_log="$temp_dir/metal-aarch64.log"
    metal_x86_log="$temp_dir/metal-x86_64.log"
    metal_riscv_log="$temp_dir/metal-riscv64.log"
    metal_wrong_mask_log="$temp_dir/metal-wrong-mask.log"
    metal_wrong_backend_log="$temp_dir/metal-wrong-backend.log"
    metal_wrong_generation_log="$temp_dir/metal-wrong-generation.log"
    directx_log="$temp_dir/directx-aarch64.log"
    directx_x86_log="$temp_dir/directx-x86_64.log"
    directx_riscv_log="$temp_dir/directx-riscv64.log"
    directx_vulkan_log="$temp_dir/directx-vulkan.log"
    directx_wrong_mask_log="$temp_dir/directx-wrong-mask.log"
    directx_wrong_backend_log="$temp_dir/directx-wrong-backend.log"
    directx_wrong_identity_log="$temp_dir/directx-wrong-identity.log"
    production_log="$temp_dir/arm64-production.log"
    production_wrong_backend_log="$temp_dir/arm64-production-wrong-backend.log"
    production_wrong_run_log="$temp_dir/arm64-production-wrong-run.log"
    production_wrong_frame_log="$temp_dir/arm64-production-wrong-frame.log"
    production_discontinuous_log="$temp_dir/arm64-production-discontinuous.log"
    production_duplicate_log="$temp_dir/arm64-production-duplicate.log"
    production_missing_log="$temp_dir/arm64-production-missing.log"
    metal_production_log="$temp_dir/metal-arm64-production.log"
    directx_production_log="$temp_dir/directx-arm64-production.log"
    pass_report="$temp_dir/pass.env"
    metal_pass_report="$temp_dir/metal-pass.env"
    directx_pass_report="$temp_dir/directx-pass.env"
    fake_report="$temp_dir/fake.env"
    bad_backend_report="$temp_dir/bad-backend.env"
    valid_simple="$temp_dir/simple-valid"
    seed_simple="$temp_dir/simple-seed"
    hanging_simple="$temp_dir/simple-hanging"
    failing_simple="$temp_dir/simple-probe-failing"
    x86_qemu_args=$(encode_argv_hex -machine q35 -m 512M -kernel "$(kernel_for_isa x86_64)" -nographic -no-reboot \
        -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/x86 host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    arm_qemu_args=$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "$(kernel_for_isa aarch64)" -nographic \
        -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/arm host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    arm_production_qemu_args=$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "$(arm64_production_kernel)" -nographic \
        -device ramfb -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/arm host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    arm_production_other_shm_args=$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "$(arm64_production_kernel)" -nographic \
        -device ramfb -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/other arm host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    rv_qemu_args=$(encode_argv_hex -machine virt -m 512M -kernel "$(kernel_for_isa riscv64)" -nographic \
        -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/rv host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    cat >"$valid_simple" <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo 'Simple v1.0.0-beta'
    exit 0
fi
echo "Error: invalid --mode 'definitely-invalid-mode' (expected dynload or one-binary)" >&2
exit 1
EOF
    cat >"$seed_simple" <<'EOF'
#!/bin/sh
echo 'Simple Language v1.0.0-beta'
echo 'WARNING: this Rust-built Simple binary is a bootstrap seed only' >&2
EOF
    cat >"$hanging_simple" <<'EOF'
#!/bin/sh
sleep 6
EOF
    cat >"$failing_simple" <<'EOF'
#!/bin/sh
if [ "$1" = "--version" ]; then
    echo 'Simple v1.0.0-beta'
    exit 0
fi
echo 'native-build probe failed without the expected parser contract' >&2
exit 1
EOF
    chmod +x "$valid_simple" "$seed_simple" "$hanging_simple" "$failing_simple"
    simple_binary_is_valid "$valid_simple"
    if simple_binary_is_valid "$seed_simple"; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if simple_binary_is_valid "$hanging_simple"; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if simple_binary_is_valid "$failing_simple"; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    cat >"$pass_log" <<'EOF'
HOST_GPU_MAP_OK isa=aarch64 device=3
HOST_GPU_HELLO_OK isa=aarch64 generation=21 render_mask=1 processing_mask=9 protocol=1 elapsed_us=40
HOST_GPU_RENDER_OK isa=aarch64 backend=vulkan generation=22 run=1022 frame=22 protocol=1 elapsed_us=100 handle=22 identity=22 checksum=405589360 bg=2112 rect=960 other=0
HOST_GPU_DRAW_IR_OK isa=aarch64 backend=vulkan generation=23 run=1022 frame=23 protocol=1 elapsed_us=110 handle=24 identity=22 checksum=405589360 bg=2112 image=960 other=0
HOST_GPU_PROCESS_OK isa=aarch64 backend=cuda generation=24 run=1022 frame=24 protocol=1 elapsed_us=80 handle=1 identity=23 checksum=1792 mismatches=0
SIMPLEOS_HOST_GPU_2D_PASS isa=aarch64
TEST PASSED
EOF
    cat >"$production_log" <<'EOF'
[WM] ramfb configured successfully via fw_cfg DMA
[wm-frame] host-gpu-fallback reason=negotiation status=2 detail=2
[wm-frame] host-gpu-ready backend=vulkan generation=27
[wm-frame] host-gpu-presented backend=vulkan generation=28 run=27 frame=28 checksum=123456
[desktop-gui] first-frame-rendered scene_revision=1
[desktop-gui-arm64] desktop-ready revision=1
EOF
    sed 's/backend=vulkan/backend=metal/g' "$production_log" >"$production_wrong_backend_log"
    sed 's/run=27/run=99/' "$production_log" >"$production_wrong_run_log"
    sed 's/frame=28/frame=99/' "$production_log" >"$production_wrong_frame_log"
    sed -e 's/generation=27$/generation=30/' \
        -e 's/generation=28 run=27 frame=28/generation=31 run=30 frame=31/' \
        "$production_log" >"$production_discontinuous_log"
    { cat "$production_log"; grep '^\[wm-frame\] host-gpu-presented ' "$production_log"; } >"$production_duplicate_log"
    grep -v '^\[desktop-gui-arm64\] desktop-ready ' "$production_log" >"$production_missing_log"
    sed -e 's/backend=vulkan/backend=metal/g' \
        -e 's/generation=27$/generation=23/' \
        -e 's/generation=28 run=27 frame=28/generation=24 run=23 frame=24/' \
        "$production_log" >"$metal_production_log"
    sed -e 's/backend=vulkan/backend=directx/g' \
        -e 's/generation=27$/generation=25/' \
        -e 's/generation=28 run=27 frame=28/generation=26 run=25 frame=26/' \
        "$production_log" >"$directx_production_log"
    sed 's/aarch64/x86_64/g; s/generation=21/generation=11/g; s/generation=22/generation=12/g; s/generation=23/generation=13/g; s/generation=24/generation=14/g; s/frame=22/frame=12/g; s/frame=23/frame=13/g; s/frame=24/frame=14/g' "$pass_log" >"$x86_log"
    sed 's/aarch64/riscv64/g; s/generation=21/generation=31/g; s/generation=22/generation=32/g; s/generation=23/generation=33/g; s/generation=24/generation=34/g; s/frame=22/frame=32/g; s/frame=23/frame=33/g; s/frame=24/frame=34/g' "$pass_log" >"$riscv_log"
    sed 's/checksum=1792/checksum=1793/' "$pass_log" >"$corrupt_log"
    sed '/^HOST_GPU_DRAW_IR_OK /s/checksum=405589360/checksum=405589361/' "$pass_log" >"$corrupt_draw_ir_log"
    sed 's/processing_mask=9/processing_mask=1/; s/backend=cuda/backend=vulkan/' "$pass_log" >"$vulkan_log"
    sed 's/backend=cuda/backend=vulkan/' "$pass_log" >"$wrong_backend_log"
    sed 's/backend=vulkan generation=22/backend=vulkan generation=999/' "$pass_log" >"$wrong_generation_log"
    sed 's/generation=21/generation=101/; s/generation=22/generation=102/; s/generation=23/generation=103/; s/generation=24/generation=104/' "$pass_log" >"$stale_generation_log"
    sed 's/mismatches=0/mismatches=0 contradictory=true/' "$pass_log" >"$trailing_log"
    { sed '$d' "$pass_log"; echo "TEST FAILED"; echo "TEST PASSED"; } >"$contradictory_terminal_log"
    cat >"$fail_log" <<'EOF'
HOST_GPU_MAP_OK isa=aarch64 device=3
HOST_GPU_HELLO_OK isa=aarch64 generation=21 render_mask=1 processing_mask=9 protocol=1 elapsed_us=40
HOST_GPU_RENDER_OK isa=aarch64 backend=vulkan generation=22 run=1022 frame=22 protocol=1 elapsed_us=100 handle=22 identity=22 checksum=405589360 bg=2112 rect=960 other=0
HOST_GPU_DRAW_IR_OK isa=aarch64 backend=vulkan generation=23 run=1022 frame=23 protocol=1 elapsed_us=110 handle=24 identity=22 checksum=405589360 bg=2112 image=960 other=0
HOST_GPU_PROCESS_OK isa=aarch64 backend=cuda generation=24 run=1022 frame=24 protocol=1 elapsed_us=80 handle=0 identity=0 checksum=1792 mismatches=0
TEST PASSED
EOF
    cat >"$metal_log" <<'EOF'
HOST_GPU_MAP_OK isa=aarch64 device=3
HOST_GPU_HELLO_OK isa=aarch64 generation=19 render_mask=2 processing_mask=2 protocol=1 elapsed_us=40
HOST_GPU_RENDER_OK isa=aarch64 backend=metal generation=20 run=1020 frame=20 protocol=1 elapsed_us=100 handle=22 identity=22 checksum=405589360 bg=2112 rect=960 other=0
HOST_GPU_DRAW_IR_OK isa=aarch64 backend=metal generation=21 run=1020 frame=21 protocol=1 elapsed_us=110 handle=24 identity=22 checksum=405589360 bg=2112 image=960 other=0
HOST_GPU_PROCESS_OK isa=aarch64 backend=metal generation=22 run=1020 frame=22 protocol=1 elapsed_us=80 handle=1 identity=23 checksum=1792 mismatches=0
SIMPLEOS_HOST_GPU_2D_PASS isa=aarch64
TEST PASSED
EOF
    sed 's/aarch64/x86_64/g; s/generation=19/generation=9/g; s/generation=20/generation=10/g; s/generation=21/generation=11/g; s/generation=22/generation=12/g; s/frame=20/frame=10/g; s/frame=21/frame=11/g; s/frame=22/frame=12/g' "$metal_log" >"$metal_x86_log"
    sed 's/aarch64/riscv64/g; s/generation=19/generation=29/g; s/generation=20/generation=30/g; s/generation=21/generation=31/g; s/generation=22/generation=32/g; s/frame=20/frame=30/g; s/frame=21/frame=31/g; s/frame=22/frame=32/g' "$metal_log" >"$metal_riscv_log"
    sed 's/render_mask=2/render_mask=1/' "$metal_log" >"$metal_wrong_mask_log"
    sed 's/backend=metal/backend=vulkan/g' "$metal_log" >"$metal_wrong_backend_log"
    sed 's/backend=metal generation=20/backend=metal generation=999/' "$metal_log" >"$metal_wrong_generation_log"
    cat >"$directx_log" <<'EOF'
HOST_GPU_MAP_OK isa=aarch64 device=3
HOST_GPU_HELLO_OK isa=aarch64 generation=20 render_mask=4 processing_mask=8 protocol=1 elapsed_us=40
HOST_GPU_RENDER_OK isa=aarch64 backend=directx generation=21 run=1021 frame=21 protocol=1 elapsed_us=100 handle=22 identity=22 checksum=405589360 bg=2112 rect=960 other=0
HOST_GPU_DRAW_IR_OK isa=aarch64 backend=directx generation=22 run=1021 frame=22 protocol=1 elapsed_us=110 handle=24 identity=22 checksum=405589360 bg=2112 image=960 other=0
HOST_GPU_PROCESS_OK isa=aarch64 backend=cuda generation=23 run=1021 frame=23 protocol=1 elapsed_us=80 handle=1 identity=23 checksum=1792 mismatches=0
SIMPLEOS_HOST_GPU_2D_PASS isa=aarch64
TEST PASSED
EOF
    sed 's/aarch64/x86_64/g; s/generation=20/generation=10/g; s/generation=21/generation=11/g; s/generation=22/generation=12/g; s/generation=23/generation=13/g; s/frame=21/frame=11/g; s/frame=22/frame=12/g; s/frame=23/frame=13/g' "$directx_log" >"$directx_x86_log"
    sed 's/aarch64/riscv64/g; s/generation=20/generation=30/g; s/generation=21/generation=31/g; s/generation=22/generation=32/g; s/generation=23/generation=33/g; s/frame=21/frame=31/g; s/frame=22/frame=32/g; s/frame=23/frame=33/g' "$directx_log" >"$directx_riscv_log"
    sed 's/processing_mask=8/processing_mask=1/; s/backend=cuda/backend=vulkan/' "$directx_log" >"$directx_vulkan_log"
    sed 's/render_mask=4/render_mask=1/' "$directx_log" >"$directx_wrong_mask_log"
    sed 's/backend=directx/backend=vulkan/g' "$directx_log" >"$directx_wrong_backend_log"
    sed '/^HOST_GPU_DRAW_IR_OK /s/identity=22/identity=99/' "$directx_log" >"$directx_wrong_identity_log"
    serial_has_pass "$pass_log" aarch64
    serial_has_pass "$vulkan_log" aarch64
    REQUIRE_CUDA=1
    if serial_has_pass "$vulkan_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    REQUIRE_CUDA=0
    if serial_has_pass "$fail_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$corrupt_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$corrupt_draw_ir_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$wrong_backend_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$wrong_generation_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$stale_generation_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$trailing_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if serial_has_pass "$contradictory_terminal_log" aarch64; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    arm64_production_serial_has_correlated_frame "$production_log"
    arm64_production_evidence_valid "$pass_log" "$arm_qemu_args" "$production_log" "$arm_production_qemu_args"
    arm64_production_serial_has_correlated_frame "$production_discontinuous_log"
    if arm64_production_evidence_valid "$pass_log" "$arm_qemu_args" "$production_log" "$arm_production_other_shm_args" ||
       arm64_production_evidence_valid "$pass_log" "$arm_qemu_args" "$production_discontinuous_log" "$arm_production_qemu_args"
    then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if arm64_production_serial_has_correlated_frame "$production_wrong_backend_log" ||
       arm64_production_serial_has_correlated_frame "$production_wrong_run_log" ||
       arm64_production_serial_has_correlated_frame "$production_wrong_frame_log" ||
       arm64_production_serial_has_correlated_frame "$production_duplicate_log" ||
       arm64_production_serial_has_correlated_frame "$production_missing_log"
    then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    {
        for report_host in macos windows; do
            for report_isa in x86_64 aarch64 riscv64; do
                emit_row "$report_host" "$report_isa" unsupported "requires-$report_host-host" none
            done
        done
        emit_row linux x86_64 pass ok "$x86_log" cuda
        emit_row_execution_evidence linux x86_64 "QEMU emulator version 9.0.0" "$x86_qemu_args" 65536
        emit_row linux aarch64 pass ok "$pass_log" cuda
        emit_row_execution_evidence linux aarch64 "QEMU emulator version 9.0.0" "$arm_qemu_args" 65536
        emit_arm64_production_evidence linux "$production_log" "$arm_production_qemu_args"
        emit_row linux riscv64 pass ok "$riscv_log" cuda
        emit_row_execution_evidence linux riscv64 "QEMU emulator version 9.0.0" "$rv_qemu_args" 65536
        echo simpleos_qemu_host_gpu_2d_host=linux
        echo simpleos_qemu_host_gpu_2d_status=pass
        echo simpleos_qemu_host_gpu_2d_reason=all-linux-host-gpu-rows-pass
        echo simpleos_qemu_host_gpu_2d_backend=vulkan
        echo simpleos_qemu_host_gpu_2d_processing_backend=cuda-preferred-vulkan-fallback
        echo simpleos_qemu_host_gpu_2d_rows=3
        echo simpleos_qemu_host_gpu_2d_passed=3
        echo simpleos_qemu_host_gpu_2d_blocked=0
        echo simpleos_qemu_host_gpu_2d_failed=0
    } >"$pass_report"
    validate_report "$pass_report" >/dev/null
    sed "s|simpleos_qemu_host_gpu_2d_linux_aarch64_production_serial_log=$production_log|simpleos_qemu_host_gpu_2d_linux_aarch64_production_serial_log=$production_discontinuous_log|" "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if [ "$(encode_argv_hex 'path with space' -device ivshmem-plain)" != hex:706174682077697468207370616365,2d646576696365,697673686d656d2d706c61696e ]; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    if encoded_argv_valid hex:,; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    qemu_argv_evidence_valid x86_64 "$x86_qemu_args"
    qemu_argv_evidence_valid aarch64 "$arm_qemu_args"
    qemu_argv_evidence_valid aarch64 "$arm_production_qemu_args" production
    qemu_argv_evidence_valid riscv64 "$rv_qemu_args"
    if qemu_argv_evidence_valid x86_64 "$(encode_argv_hex -machine virt -m 512M -kernel "$(kernel_for_isa x86_64)" -nographic -no-reboot -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path=x,size=8M -device ivshmem-plain,memdev=hostgpu)" ||
       qemu_argv_evidence_valid aarch64 "$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "$(kernel_for_isa x86_64)" -nographic -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path=x,size=8M -device ivshmem-plain,memdev=hostgpu)" ||
       qemu_argv_evidence_valid aarch64 "$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "evil$(basename "$(kernel_for_isa aarch64)")" -nographic -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path=x,size=8M -device ivshmem-plain,memdev=hostgpu)" ||
       qemu_argv_evidence_valid riscv64 "$(encode_argv_hex -machine virt -m 512M -kernel "$(kernel_for_isa riscv64)" -nographic -object memory-backend-file,id=hostgpu,share=on,mem-path=x,readonly=on,size=8M -device ivshmem-plain,memdev=hostgpu)" ||
       qemu_argv_evidence_valid riscv64 "$(encode_argv_hex -machine virt -m 512M -kernel "$(kernel_for_isa riscv64)" -nographic -object memory-backend-file,id=hostgpu,share=off,mem-path=x,size=8M -device ivshmem-plain,memdev=hostgpu)" ||
       qemu_argv_evidence_valid riscv64 "$(encode_argv_hex -machine virt -m 512M -kernel "$(kernel_for_isa riscv64)" -nographic -object memory-backend-file,id=hostgpu,share=on,mem-path=x,size=8M -device ivshmem-plain,memdev=wrong)" ||
       qemu_argv_evidence_valid aarch64 "$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "$(arm64_production_kernel)" -nographic -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path=x,size=8M -device ivshmem-plain,memdev=hostgpu)" production
    then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    wrong_machine_args=$(encode_argv_hex -machine virt -m 512M -kernel "$(kernel_for_isa x86_64)" -nographic -no-reboot -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path=x,size=8M -device ivshmem-plain,memdev=hostgpu)
    sed "s|simpleos_qemu_host_gpu_2d_linux_x86_64_qemu_device_args=$x86_qemu_args|simpleos_qemu_host_gpu_2d_linux_x86_64_qemu_device_args=$wrong_machine_args|" "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    sed 's/simpleos_qemu_host_gpu_2d_linux_aarch64_render_backend=vulkan/simpleos_qemu_host_gpu_2d_linux_aarch64_render_backend=metal/' "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    grep -v '^simpleos_qemu_host_gpu_2d_linux_aarch64_qemu_version=' "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    grep -v '^simpleos_qemu_host_gpu_2d_linux_aarch64_production_serial_log=' "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    sed 's/simpleos_qemu_host_gpu_2d_linux_aarch64_daemon_max_rss_kib=65536/simpleos_qemu_host_gpu_2d_linux_aarch64_daemon_max_rss_kib=0/' "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    sed -e 's/simpleos_qemu_host_gpu_2d_status=pass/simpleos_qemu_host_gpu_2d_status=fail/' \
        -e 's/simpleos_qemu_host_gpu_2d_reason=all-linux-host-gpu-rows-pass/simpleos_qemu_host_gpu_2d_reason=one-or-more-linux-host-gpu-rows-failed/' \
        -e '/^simpleos_qemu_host_gpu_2d_linux_aarch64_qemu_version=/d' "$pass_report" >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    { cat "$pass_report"; grep '^simpleos_qemu_host_gpu_2d_linux_aarch64_qemu_version=' "$pass_report"; } >"$bad_backend_report"
    if validate_report "$bad_backend_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    {
        echo simpleos_qemu_host_gpu_2d_host=linux
        echo simpleos_qemu_host_gpu_2d_status=pass
        echo simpleos_qemu_host_gpu_2d_reason=all-linux-host-gpu-rows-pass
    } >"$fake_report"
    if validate_report "$fake_report" >/dev/null 2>&1; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    set_host_contract macos
    serial_has_pass "$metal_log" aarch64
    arm64_production_serial_has_correlated_frame "$metal_production_log"
    if serial_has_pass "$metal_wrong_mask_log" aarch64 ||
       serial_has_pass "$metal_wrong_backend_log" aarch64 ||
       serial_has_pass "$metal_wrong_generation_log" aarch64
    then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    {
        for report_host in linux windows; do
            for report_isa in x86_64 aarch64 riscv64; do
                emit_row "$report_host" "$report_isa" unsupported "requires-$report_host-host" none
            done
        done
        emit_row macos x86_64 pass ok "$metal_x86_log" metal
        emit_row_execution_evidence macos x86_64 "QEMU emulator version 9.0.0" "$x86_qemu_args" 65536
        emit_row macos aarch64 pass ok "$metal_log" metal
        emit_row_execution_evidence macos aarch64 "QEMU emulator version 9.0.0" "$arm_qemu_args" 65536
        emit_arm64_production_evidence macos "$metal_production_log" "$arm_production_qemu_args"
        emit_row macos riscv64 pass ok "$metal_riscv_log" metal
        emit_row_execution_evidence macos riscv64 "QEMU emulator version 9.0.0" "$rv_qemu_args" 65536
        echo simpleos_qemu_host_gpu_2d_host=macos
        echo simpleos_qemu_host_gpu_2d_status=pass
        echo simpleos_qemu_host_gpu_2d_reason=all-macos-host-gpu-rows-pass
        echo simpleos_qemu_host_gpu_2d_backend=metal
        echo simpleos_qemu_host_gpu_2d_processing_backend=metal
        echo simpleos_qemu_host_gpu_2d_rows=3
        echo simpleos_qemu_host_gpu_2d_passed=3
        echo simpleos_qemu_host_gpu_2d_blocked=0
        echo simpleos_qemu_host_gpu_2d_failed=0
    } >"$metal_pass_report"
    validate_report "$metal_pass_report" >/dev/null
    set_host_contract windows
    serial_has_pass "$directx_log" aarch64
    serial_has_pass "$directx_vulkan_log" aarch64
    arm64_production_serial_has_correlated_frame "$directx_production_log"
    if serial_has_pass "$directx_wrong_mask_log" aarch64 ||
       serial_has_pass "$directx_wrong_backend_log" aarch64 ||
       serial_has_pass "$directx_wrong_identity_log" aarch64
    then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    {
        for report_host in linux macos; do
            for report_isa in x86_64 aarch64 riscv64; do
                emit_row "$report_host" "$report_isa" unsupported "requires-$report_host-host" none
            done
        done
        emit_row windows x86_64 pass ok "$directx_x86_log" cuda
        emit_row_execution_evidence windows x86_64 "QEMU emulator version 9.0.0" "$x86_qemu_args" 65536
        emit_row windows aarch64 pass ok "$directx_log" cuda
        emit_row_execution_evidence windows aarch64 "QEMU emulator version 9.0.0" "$arm_qemu_args" 65536
        emit_arm64_production_evidence windows "$directx_production_log" "$arm_production_qemu_args"
        emit_row windows riscv64 pass ok "$directx_riscv_log" cuda
        emit_row_execution_evidence windows riscv64 "QEMU emulator version 9.0.0" "$rv_qemu_args" 65536
        echo simpleos_qemu_host_gpu_2d_host=windows
        echo simpleos_qemu_host_gpu_2d_status=pass
        echo simpleos_qemu_host_gpu_2d_reason=all-windows-host-gpu-rows-pass
        echo simpleos_qemu_host_gpu_2d_backend=directx
        echo simpleos_qemu_host_gpu_2d_processing_backend=cuda-preferred-vulkan-fallback
        echo simpleos_qemu_host_gpu_2d_rows=3
        echo simpleos_qemu_host_gpu_2d_passed=3
        echo simpleos_qemu_host_gpu_2d_blocked=0
        echo simpleos_qemu_host_gpu_2d_failed=0
    } >"$directx_pass_report"
    validate_report "$directx_pass_report" >/dev/null
    set_host_contract linux
    echo "simpleos_qemu_host_gpu_2d_self_test=pass"
}

if [ "${1:-}" = --self-test ]; then
    self_test
    exit 0
fi
if [ "${1:-}" = --validate-report ]; then
    [ "$#" -eq 2 ] || exit 2
    validate_report "$2"
    exit $?
fi

cleanup_active_guest() {
    case ${daemon_pid:-} in ''|*[!0-9]*) ;; *)
        if [ "$daemon_pid" -gt 0 ]; then
            kill "$daemon_pid" 2>/dev/null || true
            wait "$daemon_pid" 2>/dev/null || true
        fi
        ;;
    esac
    daemon_pid=
    case ${rss_monitor_pid:-} in ''|*[!0-9]*) ;; *)
        if [ "$rss_monitor_pid" -gt 0 ]; then
            kill "$rss_monitor_pid" 2>/dev/null || true
            wait "$rss_monitor_pid" 2>/dev/null || true
        fi
        ;;
    esac
    rss_monitor_pid=
}

daemon_pid=
rss_monitor_pid=
trap 'cleanup_active_guest' EXIT
trap 'exit 130' HUP INT TERM

mkdir -p "$BUILD_DIR"

host=$ACTIVE_HOST

for other_host in linux macos windows; do
    if [ "$other_host" != "$host" ]; then
        for isa in x86_64 aarch64 riscv64; do
            emit_row "$other_host" "$isa" unsupported "requires-$other_host-host" none
        done
    fi
done

if [ "$host" != linux ] && [ "$host" != macos ] && [ "$host" != windows ]; then
    for isa in x86_64 aarch64 riscv64; do
        emit_row "$host" "$isa" unsupported host-daemon-backend-not-implemented none
    done
    echo "simpleos_qemu_host_gpu_2d_status=unsupported"
    echo "simpleos_qemu_host_gpu_2d_host=$host"
    echo "simpleos_qemu_host_gpu_2d_reason=host-daemon-backend-not-implemented"
    exit 0
fi

simple_bin=$(find_simple || true)
if [ -z "$simple_bin" ] && { [ -z "${SIMPLEOS_GPU_HOST_BIN:-}" ] || [ "${SIMPLEOS_HOST_GPU_USE_EXISTING_GUESTS:-0}" != 1 ]; }; then
    for isa in x86_64 aarch64 riscv64; do emit_row "$host" "$isa" blocked pure-simple-compiler-missing none; done
    echo "simpleos_qemu_host_gpu_2d_host=$host"
    echo "simpleos_qemu_host_gpu_2d_status=blocked"
    echo "simpleos_qemu_host_gpu_2d_reason=pure-simple-compiler-missing"
    exit 1
fi

default_daemon=$BUILD_DIR/simpleos_gpu_host
if [ "$host" = windows ]; then
    default_daemon=$BUILD_DIR/simpleos_gpu_host.exe
fi
daemon=${SIMPLEOS_GPU_HOST_BIN:-$default_daemon}
if [ -z "${SIMPLEOS_GPU_HOST_BIN:-}" ]; then
    runtime_reason=vulkan-cuda-runtime-artifact-missing
    if [ "$host" = macos ]; then
        runtime_reason=metal-runtime-artifact-missing
    elif [ "$host" = windows ]; then
        runtime_reason=directx-runtime-artifact-missing
    fi
    if [ ! -d "$RUNTIME_PATH" ] || { [ "$host" = macos ] && ! core_c_bootstrap_runtime_available; }; then
        for isa in x86_64 aarch64 riscv64; do emit_row "$host" "$isa" blocked "$runtime_reason" none; done
        echo "simpleos_qemu_host_gpu_2d_host=$host"
        echo "simpleos_qemu_host_gpu_2d_status=blocked"
        echo "simpleos_qemu_host_gpu_2d_reason=$runtime_reason"
        exit 1
    fi
    if ! SIMPLE_LIB="$ROOT_DIR/src" SIMPLE_NO_STUB_FALLBACK=1 "$simple_bin" native-build \
        --backend cranelift --source src/app --source src/lib --entry-closure \
        --entry src/app/simpleos_gpu_host/main.spl --runtime-bundle core-c-bootstrap \
        --runtime-path "$RUNTIME_PATH" --cache-dir "$BUILD_DIR/daemon-cache" \
        --timeout 90 --output "$daemon" >"$BUILD_DIR/daemon-build.log" 2>&1
    then
        for isa in x86_64 aarch64 riscv64; do emit_row "$host" "$isa" blocked host-daemon-build-failed "$BUILD_DIR/daemon-build.log"; done
        echo "simpleos_qemu_host_gpu_2d_host=$host"
        echo "simpleos_qemu_host_gpu_2d_status=blocked"
        echo "simpleos_qemu_host_gpu_2d_reason=host-daemon-build-failed"
        exit 1
    fi
elif [ ! -x "$daemon" ]; then
    for isa in x86_64 aarch64 riscv64; do emit_row "$host" "$isa" blocked provided-host-daemon-missing none; done
    echo "simpleos_qemu_host_gpu_2d_host=$host"
    echo "simpleos_qemu_host_gpu_2d_status=blocked"
    echo "simpleos_qemu_host_gpu_2d_reason=provided-host-daemon-missing"
    exit 1
fi

if [ "$host" = macos ] && ! metal_guest_contract_available; then
    for isa in x86_64 aarch64 riscv64; do emit_row macos "$isa" blocked metal-guest-probe-contract-missing none; done
    echo "simpleos_qemu_host_gpu_2d_host=macos"
    echo "simpleos_qemu_host_gpu_2d_status=blocked"
    echo "simpleos_qemu_host_gpu_2d_reason=metal-guest-probe-contract-missing"
    echo "simpleos_qemu_host_gpu_2d_backend=metal"
    echo "simpleos_qemu_host_gpu_2d_processing_backend=metal"
    echo "simpleos_qemu_host_gpu_2d_rows=3"
    echo "simpleos_qemu_host_gpu_2d_passed=0"
    echo "simpleos_qemu_host_gpu_2d_blocked=3"
    echo "simpleos_qemu_host_gpu_2d_failed=0"
    echo "simpleos_qemu_host_gpu_2d_daemon=$daemon"
    exit 1
fi

build_guest() {
    isa=$1
    GUEST_BUILD_REASON=guest-build-failed
    GUEST_BUILD_LOG="$BUILD_DIR/$isa-build.log"
    case "$isa" in
        x86_64) scenario=simpleos-host-gpu-x86_64 ;;
        aarch64) scenario=simpleos-host-gpu-aarch64 ;;
        riscv64) scenario=simpleos-host-gpu-riscv64 ;;
    esac
    if [ "${SIMPLEOS_HOST_GPU_USE_EXISTING_GUESTS:-0}" = 1 ]; then
        if [ ! -f "$(kernel_for_isa "$isa")" ]; then
            GUEST_BUILD_REASON=guest-artifact-missing
            GUEST_BUILD_LOG=$(kernel_for_isa "$isa")
            return 1
        fi
        if [ "$isa" = aarch64 ] && [ ! -f "$(arm64_production_kernel)" ]; then
            GUEST_BUILD_REASON=production-guest-artifact-missing
            GUEST_BUILD_LOG=$(arm64_production_kernel)
            return 1
        fi
        return 0
    fi
    if SIMPLE_LIB="$ROOT_DIR/src" SIMPLE_BIN="$simple_bin" SIMPLE_BINARY="$simple_bin" \
        "$simple_bin" os build --scenario="$scenario" >"$GUEST_BUILD_LOG" 2>&1
    then
        if [ "$isa" != aarch64 ]; then
            return 0
        fi
        GUEST_BUILD_REASON=production-guest-build-failed
        GUEST_BUILD_LOG="$BUILD_DIR/aarch64-production-build.log"
        if SIMPLE_LIB="$ROOT_DIR/src" SIMPLE_BIN="$simple_bin" SIMPLE_BINARY="$simple_bin" \
            "$simple_bin" os build --scenario=arm64-desktop-engine2d >"$GUEST_BUILD_LOG" 2>&1
        then
            return 0
        fi
    fi
    return 1
}

run_guest() {
    isa=$1
    qemu_bin=$(qemu_bin_for_isa "$isa")
    shm="$BUILD_DIR/$isa.shm"
    serial="$BUILD_DIR/$isa-serial.log"
    daemon_log="$BUILD_DIR/$isa-daemon.log"
    rss_file="$BUILD_DIR/$isa-daemon-max-rss-kib"
    kernel=$(kernel_for_isa "$isa")
    rm -f "$shm" "$serial" "$daemon_log" "$rss_file"
    size_shared_file "$shm"
    "$daemon" --shm="$shm" >"$daemon_log" 2>&1 &
    daemon_pid=$!
    monitor_daemon_max_rss "$daemon_pid" "$rss_file" &
    rss_monitor_pid=$!
    case "$isa" in
        x86_64)
            set -- -machine q35 -m 512M -kernel "$kernel" -nographic -no-reboot \
                -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path="$shm",size=8M \
                -device ivshmem-plain,memdev=hostgpu
            ;;
        aarch64)
            set -- -machine virt -cpu cortex-a72 -m 512M -kernel "$kernel" -nographic \
                -device virtio-net-pci -object memory-backend-file,id=hostgpu,share=on,mem-path="$shm",size=8M \
                -device ivshmem-plain,memdev=hostgpu
            ;;
        riscv64)
            set -- -machine virt -m 512M -kernel "$kernel" -nographic \
                -object memory-backend-file,id=hostgpu,share=on,mem-path="$shm",size=8M \
                -device ivshmem-plain,memdev=hostgpu
            ;;
    esac
    qemu_version=$("$qemu_bin" --version 2>&1 | sed -n '1p')
    qemu_device_args=$(encode_argv_hex "$@")
    "$TIMEOUT_BIN" "$QEMU_TIMEOUT" "$qemu_bin" "$@" >"$serial" 2>&1 || true
    if serial_has_pass "$serial" "$isa"; then probe_valid=1; else probe_valid=0; fi
    production_serial=
    production_qemu_args=
    if [ "$isa" = aarch64 ] && [ "$probe_valid" = 1 ]; then
        production_serial="$BUILD_DIR/aarch64-production-serial.log"
        rm -f "$production_serial"
        set -- -machine virt -cpu cortex-a72 -m 512M -kernel "$(arm64_production_kernel)" -nographic \
            -device ramfb -device virtio-net-pci \
            -object memory-backend-file,id=hostgpu,share=on,mem-path="$shm",size=8M \
            -device ivshmem-plain,memdev=hostgpu
        production_qemu_args=$(encode_argv_hex "$@")
        "$TIMEOUT_BIN" "$PRODUCTION_QEMU_TIMEOUT" "$qemu_bin" "$@" >"$production_serial" 2>&1 || true
    fi
    cleanup_active_guest
    rss_kib=$(sed -n '1p' "$rss_file" 2>/dev/null || true)
    if qemu_argv_evidence_valid "$isa" "$qemu_device_args"; then qemu_args_valid=1; else qemu_args_valid=0; fi
    case "$rss_kib" in ''|*[!0-9]*|0) execution_evidence_valid=0 ;; *) execution_evidence_valid=1 ;; esac
    if [ -z "$qemu_version" ] || [ "$qemu_args_valid" != 1 ]; then
        execution_evidence_valid=0
    fi
    production_valid=1
    production_args_valid=1
    if [ "$isa" = aarch64 ]; then
        production_valid=0
        production_args_valid=0
        if [ -n "$production_qemu_args" ] && qemu_argv_evidence_valid aarch64 "$production_qemu_args" production; then
            production_args_valid=1
        fi
        if [ "$production_args_valid" = 1 ] && arm64_production_evidence_valid "$serial" "$qemu_device_args" "$production_serial" "$production_qemu_args"; then
            production_valid=1
        fi
    fi
    if [ "$probe_valid" = 1 ] && [ "$execution_evidence_valid" = 1 ] && [ "$production_valid" = 1 ]; then
        emit_row "$host" "$isa" pass ok "$serial" "$(serial_processing_backend "$serial" "$isa")"
        row_result=0
    elif [ "$probe_valid" != 1 ]; then
        emit_row "$host" "$isa" fail "$(serial_reason "$serial" "$isa")" "$serial"
        row_result=1
    elif [ "$execution_evidence_valid" != 1 ]; then
        emit_row "$host" "$isa" fail execution-evidence-missing "$serial" "$(serial_processing_backend "$serial" "$isa")"
        row_result=1
    elif [ "$production_args_valid" != 1 ]; then
        emit_row "$host" "$isa" fail production-execution-evidence-missing "$production_serial" "$(serial_processing_backend "$serial" "$isa")"
        row_result=1
    else
        emit_row "$host" "$isa" fail production-frame-evidence-missing "$production_serial" "$(serial_processing_backend "$serial" "$isa")"
        row_result=1
    fi
    emit_row_execution_evidence "$host" "$isa" "$qemu_version" "$qemu_device_args" "${rss_kib:-unknown}"
    if [ "$isa" = aarch64 ] && [ -n "$production_qemu_args" ]; then
        emit_arm64_production_evidence "$host" "$production_serial" "$production_qemu_args"
    fi
    return "$row_result"
}

overall=pass
passed=0
blocked=0
failed=0
TIMEOUT_BIN=$(find_timeout || true)
for isa in x86_64 aarch64 riscv64; do
    qemu_bin=$(qemu_bin_for_isa "$isa")
    case "$isa" in x86_64) qemu_machine=q35 ;; *) qemu_machine=virt ;; esac
    if [ -z "$TIMEOUT_BIN" ]; then
        emit_row "$host" "$isa" blocked timeout-command-missing none
        overall=fail
        blocked=$((blocked + 1))
        continue
    fi
    if ! command -v "$qemu_bin" >/dev/null 2>&1; then
        emit_row "$host" "$isa" blocked qemu-binary-missing none
        overall=fail
        blocked=$((blocked + 1))
        continue
    fi
    if ! qemu_capabilities_available "$isa" "$qemu_bin" "$qemu_machine"; then
        emit_row "$host" "$isa" blocked qemu-host-gpu-capability-missing "$BUILD_DIR/qemu-capabilities/$isa-devices.log"
        overall=fail
        blocked=$((blocked + 1))
        continue
    fi
    if ! build_guest "$isa"; then
        emit_row "$host" "$isa" fail "$GUEST_BUILD_REASON" "$GUEST_BUILD_LOG"
        overall=fail
        failed=$((failed + 1))
        continue
    fi
    if ! run_guest "$isa"; then
        overall=fail
        failed=$((failed + 1))
    else
        passed=$((passed + 1))
    fi
done

echo "simpleos_qemu_host_gpu_2d_status=$overall"
echo "simpleos_qemu_host_gpu_2d_host=$host"
echo "simpleos_qemu_host_gpu_2d_reason=$(if [ "$overall" = pass ]; then echo "all-$host-host-gpu-rows-pass"; else echo "one-or-more-$host-host-gpu-rows-failed"; fi)"
echo "simpleos_qemu_host_gpu_2d_backend=$BACKEND"
echo "simpleos_qemu_host_gpu_2d_processing_backend=$PROCESSING_BACKEND"
echo "simpleos_qemu_host_gpu_2d_rows=3"
echo "simpleos_qemu_host_gpu_2d_passed=$passed"
echo "simpleos_qemu_host_gpu_2d_blocked=$blocked"
echo "simpleos_qemu_host_gpu_2d_failed=$failed"
echo "simpleos_qemu_host_gpu_2d_daemon=$daemon"
[ "$overall" = pass ]
