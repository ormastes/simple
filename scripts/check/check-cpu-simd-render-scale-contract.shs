#!/bin/sh
set -eu

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/bin/simple}"
OUT_DIR="${OUT_DIR:-$ROOT/build/check/cpu-simd-render-scale}"
TIMEOUT_SECS="${CPU_SIMD_RENDER_SCALE_TIMEOUT_SECS:-900}"
WIDTH_4K="${CPU_SIMD_RENDER_SCALE_4K_WIDTH:-3840}"
HEIGHT_4K="${CPU_SIMD_RENDER_SCALE_4K_HEIGHT:-2160}"
WIDTH_8K="${CPU_SIMD_RENDER_SCALE_8K_WIDTH:-7680}"
HEIGHT_8K="${CPU_SIMD_RENDER_SCALE_8K_HEIGHT:-4320}"
DPI="${CPU_SIMD_RENDER_SCALE_DPI:-300}"
SAMPLE_COUNT="${CPU_SIMD_RENDER_SCALE_SAMPLE_COUNT:-1}"
EXEC_MODE="${CPU_SIMD_RENDER_SCALE_MODE:-native}"

mkdir -p "$OUT_DIR"

run_with_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        timeout "$TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

run_export() {
    label="$1"
    width="$2"
    height="$3"
    backend="${4:-cpu_simd}"
    fixture_label="${5:-$label}"
    rm -f "$OUT_DIR/$label.sdn" "$OUT_DIR/$label.err"
    if [ "$DPI" = "300" ]; then
        SIMPLE_LIB="$ROOT/src" run_with_timeout "$SIMPLE_BIN" run "$ROOT/src/app/wm_compare/backend_measurement_software_export.spl" --mode="$EXEC_MODE" -- \
            --software-render-backend "$backend" \
            --width "$width" \
            --height "$height" \
            --warmup-count 1 \
            --sample-count "$SAMPLE_COUNT" \
            --fixture "cpu-simd-${fixture_label}" \
            --shell simple-web \
            --command "scale-${fixture_label}" \
            --host local \
            >"$OUT_DIR/$label.sdn" 2>"$OUT_DIR/$label.err"
    else
        SIMPLE_LIB="$ROOT/src" run_with_timeout "$SIMPLE_BIN" run "$ROOT/src/app/wm_compare/backend_measurement_software_export.spl" --mode="$EXEC_MODE" -- \
            --software-render-backend "$backend" \
            --width "$width" \
            --height "$height" \
            --dpi "$DPI" \
            --warmup-count 1 \
            --sample-count "$SAMPLE_COUNT" \
            --fixture "cpu-simd-${fixture_label}" \
            --shell simple-web \
            --command "scale-${fixture_label}" \
            --host local \
            >"$OUT_DIR/$label.sdn" 2>"$OUT_DIR/$label.err"
    fi
    if grep -q "falling back to interpreter" "$OUT_DIR/$label.err" 2>/dev/null; then
        return 97
    fi
}

field_value() {
    key="$1"
    file="$2"
    grep "^${key}=" "$file" | tail -1 | cut -d= -f2-
}

sdn_text_value() {
    key="$1"
    file="$2"
    grep -o "${key}: \"[^\"]*\"" "$file" | head -1 | sed "s/^${key}: \"//; s/\"$//"
}

sdn_bool_value() {
    key="$1"
    file="$2"
    grep -o "${key}: \\(true\\|false\\)" "$file" | head -1 | sed "s/^${key}: //"
}

sdn_i64_value() {
    key="$1"
    file="$2"
    grep -o "${key}: [0-9][0-9]*" "$file" | head -1 | sed "s/^${key}: //"
}

fail() {
    echo "cpu_simd_render_scale_contract_status=fail"
    echo "cpu_simd_render_scale_contract_reason=$1"
    exit 1
}

require_value() {
    require_label="$1"
    require_expected="$2"
    require_actual="$3"
    if [ "$require_actual" != "$require_expected" ]; then
        fail "${require_label}_expected_${require_expected}_got_${require_actual}"
    fi
}

require_positive() {
    positive_label="$1"
    positive_actual="$2"
    case "$positive_actual" in
        ''|*[!0-9]*) fail "${positive_label}_not_numeric_${positive_actual}" ;;
    esac
    if [ "$positive_actual" -le 0 ]; then
        fail "${positive_label}_not_positive_${positive_actual}"
    fi
}

ratio_permille() {
    numerator="$1"
    denominator="$2"
    case "$numerator:$denominator" in
        *[!0-9:]*|:*|*:) echo 0; return ;;
    esac
    if [ "$denominator" -le 0 ]; then
        echo 0
        return
    fi
    echo $((numerator * 1000 / denominator))
}

us_to_ms() {
    awk -v us="$1" 'BEGIN { printf "%.3f", us / 1000.0 }'
}

ratio_decimal() {
    awk -v numerator="$1" -v denominator="$2" 'BEGIN { if (denominator > 0) printf "%.3f", numerator / denominator; else print "0.000" }'
}

target_met() {
    awk -v simple="$1" -v baseline="$2" 'BEGIN { print (simple <= baseline) ? "yes" : "no" }'
}

expected_default_checksum() {
    label="$1"
    width="$2"
    height="$3"
    if [ "$DPI" != "300" ]; then
        echo ""
        return
    fi
    if [ "$label" = "4k" ] && [ "$width" = "3840" ] && [ "$height" = "2160" ]; then
        echo "${CPU_SIMD_RENDER_SCALE_4K_EXPECTED_CHECKSUM:-sum32:32105444634193792}"
        return
    fi
    if [ "$label" = "8k" ] && [ "$width" = "7680" ] && [ "$height" = "4320" ]; then
        echo "${CPU_SIMD_RENDER_SCALE_8K_EXPECTED_CHECKSUM:-sum32:135445232233405312}"
        return
    fi
    echo ""
}

check_export() {
    label="$1"
    width="$2"
    height="$3"
    file="$OUT_DIR/$label.sdn"
    pixels=$((width * height))

    require_value "${label}_dpi" "$DPI" "$(field_value gui_perf_benchmark_dpi "$file")"
    require_value "${label}_dpi_default" "300" "$(field_value gui_perf_benchmark_dpi_default "$file")"
    if [ "$DPI" = "300" ]; then
        require_value "${label}_dpi_source" "default" "$(field_value gui_perf_benchmark_dpi_source "$file")"
    else
        require_value "${label}_dpi_source" "override" "$(field_value gui_perf_benchmark_dpi_source "$file")"
    fi
    require_value "${label}_density" "retina" "$(field_value gui_perf_benchmark_density_profile "$file")"
    require_value "${label}_logical_pixels" "${width}x${height}" "$(field_value gui_perf_benchmark_logical_pixels "$file")"
    require_value "${label}_physical_pixels" "${width}x${height}" "$(field_value gui_perf_benchmark_physical_pixels "$file")"
    require_value "${label}_screen_size_reduced" "false" "$(field_value gui_perf_benchmark_screen_size_reduced "$file")"
    require_value "${label}_requested" "cpu_simd" "$(sdn_text_value requested "$file")"
    require_value "${label}_selected" "cpu_simd" "$(sdn_text_value selected "$file")"
    require_value "${label}_backend_family" "cpu_simd" "$(sdn_text_value backend_family "$file")"
    require_value "${label}_status" "Initialized" "$(sdn_text_value status "$file")"
    require_value "${label}_readback_scope" "software-render-loop" "$(sdn_text_value render_readback_scope "$file")"
    require_value "${label}_runtime_target" "cpu_simd" "$(sdn_text_value runtime_compute_target "$file")"
    require_value "${label}_runtime_path" "simple_web_layout_engine2d_cpu_simd" "$(sdn_text_value runtime_execution_path "$file")"
    require_value "${label}_runtime_status" "cpu-simd-render-loop-ready" "$(sdn_text_value runtime_status "$file")"
    require_value "${label}_scalar_baseline_compared" "true" "$(sdn_bool_value scalar_baseline_compared "$file")"
    require_value "${label}_fallback" "false" "$(sdn_bool_value fallback_used "$file")"
    require_value "${label}_fallback_reason" "" "$(sdn_text_value fallback_reason "$file")"
    require_value "${label}_unavailable_reason" "" "$(sdn_text_value unavailable_reason "$file")"
    require_value "${label}_pixel_proof" "nonzero_pixels:$pixels" "$(sdn_text_value pixel_proof "$file")"
    case "$(sdn_text_value checksum "$file")" in
        sum32:*) ;;
        *) fail "${label}_missing_checksum" ;;
    esac
    expected_checksum="$(expected_default_checksum "$label" "$width" "$height")"
    if [ "$expected_checksum" != "" ]; then
        require_value "${label}_retained_checksum" "$expected_checksum" "$(sdn_text_value checksum "$file")"
    fi
    require_positive "${label}_cold_start_us" "$(sdn_i64_value cold_start_us "$file")"
    require_positive "${label}_warm_start_us" "$(sdn_i64_value warm_start_us "$file")"
    require_positive "${label}_p50_frame_us" "$(sdn_i64_value p50_frame_us "$file")"
    require_positive "${label}_p95_frame_us" "$(sdn_i64_value p95_frame_us "$file")"
    require_positive "${label}_p95_input_to_paint_us" "$(sdn_i64_value p95_input_to_paint_us "$file")"
    require_positive "${label}_max_rss_kb" "$(sdn_i64_value max_rss_kb "$file")"
    require_positive "${label}_binary_size_bytes" "$(sdn_i64_value binary_size_bytes "$file")"
    require_positive "${label}_baseline_binary_size_bytes" "$(sdn_i64_value baseline_binary_size_bytes "$file")"
    require_positive "${label}_package_size_bytes" "$(sdn_i64_value package_size_bytes "$file")"
    require_positive "${label}_artifact_submit_us" "$(sdn_i64_value artifact_submit_us "$file")"
}

check_software_export() {
    label="$1"
    width="$2"
    height="$3"
    file="$OUT_DIR/${label}_software.sdn"
    pixels=$((width * height))

    require_value "${label}_software_dpi" "$DPI" "$(field_value gui_perf_benchmark_dpi "$file")"
    require_value "${label}_software_backend_family" "software" "$(sdn_text_value backend_family "$file")"
    require_value "${label}_software_requested" "software" "$(sdn_text_value requested "$file")"
    require_value "${label}_software_selected" "software" "$(sdn_text_value selected "$file")"
    require_value "${label}_software_runtime_target" "cpu_scalar" "$(sdn_text_value runtime_compute_target "$file")"
    require_value "${label}_software_runtime_path" "simple_web_layout_software" "$(sdn_text_value runtime_execution_path "$file")"
    require_value "${label}_software_fallback" "false" "$(sdn_bool_value fallback_used "$file")"
    require_value "${label}_software_pixel_proof" "nonzero_pixels:$pixels" "$(sdn_text_value pixel_proof "$file")"
    require_value "${label}_software_checksum_parity" "$(sdn_text_value checksum "$OUT_DIR/$label.sdn")" "$(sdn_text_value checksum "$file")"
}

if run_export 4k "$WIDTH_4K" "$HEIGHT_4K"; then
    :
else
    rc="$?"
    fail "4k_run_failed_exit_$rc"
fi
if run_export 8k "$WIDTH_8K" "$HEIGHT_8K"; then
    :
else
    rc="$?"
    fail "8k_run_failed_exit_$rc"
fi
if run_export 4k_software "$WIDTH_4K" "$HEIGHT_4K" software 4k; then
    :
else
    rc="$?"
    fail "4k_software_run_failed_exit_$rc"
fi
if run_export 8k_software "$WIDTH_8K" "$HEIGHT_8K" software 8k; then
    :
else
    rc="$?"
    fail "8k_software_run_failed_exit_$rc"
fi
check_export 4k "$WIDTH_4K" "$HEIGHT_4K"
check_export 8k "$WIDTH_8K" "$HEIGHT_8K"
check_software_export 4k "$WIDTH_4K" "$HEIGHT_4K"
check_software_export 8k "$WIDTH_8K" "$HEIGHT_8K"

echo "cpu_simd_render_scale_contract_status=pass"
echo "gui_perf_benchmark_backend=simple_web_cpu_simd"
echo "cpu_simd_render_scale_contract_mode=$EXEC_MODE"
echo "cpu_simd_render_scale_contract_dpi=$DPI"
echo "cpu_simd_render_scale_contract_dpi_source=$(field_value gui_perf_benchmark_dpi_source "$OUT_DIR/4k.sdn")"
echo "cpu_simd_render_scale_contract_sample_count=$SAMPLE_COUNT"
echo "cpu_simd_render_scale_4k_pixels=${WIDTH_4K}x${HEIGHT_4K}"
echo "cpu_simd_render_scale_4k_p50_frame_us=$(sdn_i64_value p50_frame_us "$OUT_DIR/4k.sdn")"
echo "cpu_simd_render_scale_4k_p95_frame_us=$(sdn_i64_value p95_frame_us "$OUT_DIR/4k.sdn")"
echo "cpu_simd_render_scale_4k_software_p50_frame_us=$(sdn_i64_value p50_frame_us "$OUT_DIR/4k_software.sdn")"
echo "cpu_simd_render_scale_4k_software_p95_frame_us=$(sdn_i64_value p95_frame_us "$OUT_DIR/4k_software.sdn")"
echo "cpu_simd_render_scale_4k_vs_software_p50_ratio_permille=$(ratio_permille "$(sdn_i64_value p50_frame_us "$OUT_DIR/4k_software.sdn")" "$(sdn_i64_value p50_frame_us "$OUT_DIR/4k.sdn")")"
echo "cpu_simd_render_scale_4k_checksum=$(sdn_text_value checksum "$OUT_DIR/4k.sdn")"
echo "cpu_simd_render_scale_4k_software_checksum=$(sdn_text_value checksum "$OUT_DIR/4k_software.sdn")"
echo "cpu_simd_render_scale_4k_software_checksum_parity=true"
echo "cpu_simd_render_scale_8k_pixels=${WIDTH_8K}x${HEIGHT_8K}"
echo "cpu_simd_render_scale_8k_p50_frame_us=$(sdn_i64_value p50_frame_us "$OUT_DIR/8k.sdn")"
echo "cpu_simd_render_scale_8k_p95_frame_us=$(sdn_i64_value p95_frame_us "$OUT_DIR/8k.sdn")"
echo "cpu_simd_render_scale_8k_software_p50_frame_us=$(sdn_i64_value p50_frame_us "$OUT_DIR/8k_software.sdn")"
echo "cpu_simd_render_scale_8k_software_p95_frame_us=$(sdn_i64_value p95_frame_us "$OUT_DIR/8k_software.sdn")"
echo "cpu_simd_render_scale_8k_vs_software_p50_ratio_permille=$(ratio_permille "$(sdn_i64_value p50_frame_us "$OUT_DIR/8k_software.sdn")" "$(sdn_i64_value p50_frame_us "$OUT_DIR/8k.sdn")")"
echo "cpu_simd_render_scale_8k_checksum=$(sdn_text_value checksum "$OUT_DIR/8k.sdn")"
echo "cpu_simd_render_scale_8k_software_checksum=$(sdn_text_value checksum "$OUT_DIR/8k_software.sdn")"
echo "cpu_simd_render_scale_8k_software_checksum_parity=true"
simple_8k_us="$(sdn_i64_value p50_frame_us "$OUT_DIR/8k.sdn")"
software_8k_us="$(sdn_i64_value p50_frame_us "$OUT_DIR/8k_software.sdn")"
simple_8k_ms="$(us_to_ms "$simple_8k_us")"
software_8k_ms="$(us_to_ms "$software_8k_us")"
echo "gui_perf_cpu_base_compare_status=measured"
echo "gui_perf_cpu_base_compare_source=cpu_simd_scale_contract"
echo "gui_perf_cpu_base_compare_pixels=${WIDTH_8K}x${HEIGHT_8K}"
echo "gui_perf_cpu_base_compare_simple_backend=simple_web_cpu_simd"
echo "gui_perf_cpu_base_compare_simple_p50_ms=$simple_8k_ms"
echo "gui_perf_cpu_base_compare_baseline_backend=simple_web_software"
echo "gui_perf_cpu_base_compare_baseline_metric=p50_frame_ms"
echo "gui_perf_cpu_base_compare_baseline_ms=$software_8k_ms"
echo "gui_perf_cpu_base_compare_baseline_over_simple_ratio=$(ratio_decimal "$software_8k_ms" "$simple_8k_ms")"
echo "gui_perf_cpu_base_compare_target_met=$(target_met "$simple_8k_ms" "$software_8k_ms")"
