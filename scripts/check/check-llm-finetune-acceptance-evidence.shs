#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_finetune_acceptance}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_finetune_acceptance_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
ATTEMPT="${FINETUNE_ACCEPTANCE_ATTEMPT:-llm_backed_app_server_dry_run_retry7}"
GATE_LOG="$BUILD_DIR/retry7_acceptance_gate.log"
SURFACE_MANIFEST="$BUILD_DIR/finetune_acceptance_surface_manifest.tsv"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$GATE_LOG" "$SURFACE_MANIFEST"

if .spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs "$ATTEMPT" >"$GATE_LOG" 2>&1; then
    gate_exit=0
else
    gate_exit=$?
fi

value_for() {
    key="$1"
    sed -n "s/^${key}=//p" "$GATE_LOG" | tail -n 1
}

resolve_local_path() {
    ref="$1"
    case "$ref" in
        ""|"missing"|"pending"|*://*)
            printf '%s\n' ""
            ;;
        /*)
            printf '%s\n' "$ref"
            ;;
        *)
            printf '%s\n' "$(pwd)/$ref"
            ;;
    esac
}

artifact_status() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        printf '%s\n' "ready"
    else
        printf '%s\n' "missing"
    fi
}

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "0"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

json_string_for() {
    key="$1"
    file="$2"
    if [ -n "$file" ] && [ -f "$file" ]; then
        sed -n "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" "$file" | tail -n 1
    fi
}

json_number_for() {
    key="$1"
    file="$2"
    if [ -n "$file" ] && [ -f "$file" ]; then
        sed -n "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\\([0-9][0-9.]*\\).*/\\1/p" "$file" | tail -n 1
    fi
}

gate_status="$(sed -n 's/^STATUS: //p' "$GATE_LOG" | tail -n 1)"
result="$(value_for result)"
acceptance_allowed="$(value_for acceptance_allowed)"
acceptance_reason="$(value_for acceptance_reason)"
upstream_retry6_result="$(value_for upstream_retry6_result)"
upstream_attempt_record="$(value_for upstream_attempt_record)"
upstream_cache_manifest="$(value_for upstream_cache_manifest)"
attempt_record="$(value_for attempt_record)"
training_allowed="$(value_for training_allowed)"
model_manifest="$(value_for model_manifest)"
model_manifest_exists="$(value_for model_manifest_exists)"
model_manifest_deployable="$(value_for model_manifest_deployable)"
eval_result="$(value_for eval_result)"
eval_result_exists="$(value_for eval_result_exists)"
target_eval_reached="$(value_for target_eval_reached)"
target_accuracy="$(value_for target_accuracy)"
required_accuracy="$(value_for required_accuracy)"
retry6_next_action="$(value_for retry6_next_action)"
attempt_record_status="$(value_for attempt_record_status)"
decision_status="$(value_for decision_status)"
license_constraints="$(value_for license_constraints)"
safety_eval="$(value_for safety_eval)"
deployment_evidence="$(value_for deployment_evidence)"
handoff_doc="$(value_for handoff_doc)"
handoff_usage="$(value_for handoff_usage)"
app_handoff_doc_ready="$(value_for app_handoff_doc_ready)"
next_action="$(value_for next_action)"

gate_log_artifact_status="$(artifact_status "$GATE_LOG")"
gate_log_sha256="$(artifact_sha256 "$GATE_LOG")"
gate_log_size="$(artifact_size "$GATE_LOG")"
upstream_attempt_record_path="$(resolve_local_path "$upstream_attempt_record")"
upstream_cache_manifest_path="$(resolve_local_path "$upstream_cache_manifest")"
upstream_attempt_record_artifact_status="$(artifact_status "$upstream_attempt_record_path")"
upstream_cache_manifest_artifact_status="$(artifact_status "$upstream_cache_manifest_path")"
upstream_attempt_record_sha256="$(artifact_sha256 "$upstream_attempt_record_path")"
upstream_cache_manifest_sha256="$(artifact_sha256 "$upstream_cache_manifest_path")"
upstream_attempt_record_size="$(artifact_size "$upstream_attempt_record_path")"
upstream_cache_manifest_size="$(artifact_size "$upstream_cache_manifest_path")"
attempt_record_path="$(resolve_local_path "$attempt_record")"
model_manifest_path="$(resolve_local_path "$model_manifest")"
eval_result_path="$(resolve_local_path "$eval_result")"
handoff_doc_path="$(resolve_local_path "$handoff_doc")"
attempt_record_artifact_status="$(artifact_status "$attempt_record_path")"
model_manifest_artifact_status="$(artifact_status "$model_manifest_path")"
eval_result_artifact_status="$(artifact_status "$eval_result_path")"
handoff_doc_artifact_status="$(artifact_status "$handoff_doc_path")"
attempt_record_sha256="$(artifact_sha256 "$attempt_record_path")"
model_manifest_sha256="$(artifact_sha256 "$model_manifest_path")"
eval_result_sha256="$(artifact_sha256 "$eval_result_path")"
handoff_doc_sha256="$(artifact_sha256 "$handoff_doc_path")"
attempt_record_size="$(artifact_size "$attempt_record_path")"
model_manifest_size="$(artifact_size "$model_manifest_path")"
eval_result_size="$(artifact_size "$eval_result_path")"
handoff_doc_size="$(artifact_size "$handoff_doc_path")"
{
    for path in \
        scripts/check/check-llm-finetune-acceptance-evidence.shs \
        scripts/check/check-llm-finetune-guard-evidence.shs \
        scripts/check/check-llm-finetune-setup-contract.shs \
        .spipe/llm-finetune-process/README.md \
        .spipe/llm-finetune-process/attempts.sdn \
        .spipe/llm-finetune-process/app_handoffs.sdn \
        .spipe/llm-finetune-process/data_checks.sdn \
        .spipe/llm-finetune-process/decisions.sdn \
        .spipe/llm-finetune-process/eval_results.sdn \
        .spipe/llm-finetune-process/models.sdn \
        .spipe/llm-finetune-process/retune_requests.sdn \
        .spipe/llm-finetune-process/scripts/check_retry6_training_eval_gate.shs \
        .spipe/llm-finetune-process/scripts/check_retry7_acceptance_gate.shs \
        test/03_system/tools/spipe/llm_finetune_retry6_training_eval_gate_spec.spl \
        test/03_system/tools/spipe/llm_finetune_retry7_acceptance_gate_spec.spl \
        doc/07_guide/app/llm/spipe_llm_finetune_process.md \
        doc/07_guide/app/llm/llm_runtime_vllm_torch_interface.md \
        doc/03_plan/agent_tasks/llm_runtime_vllm_torch_interface.md \
        "$GATE_LOG"
    do
        printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
    done
} >"$SURFACE_MANIFEST"
surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"
model_manifest_schema_version="$(json_string_for schema_version "$model_manifest_path")"
model_manifest_schema_version="${model_manifest_schema_version:-$(json_number_for schema_version "$model_manifest_path")}"
model_manifest_attempt_id="$(json_string_for attempt_id "$model_manifest_path")"
model_manifest_base_model="$(json_string_for base_model "$model_manifest_path")"
model_manifest_base_model_revision="$(json_string_for base_model_revision "$model_manifest_path")"
model_artifact_path="$(json_string_for model_artifact_path "$model_manifest_path")"
model_artifact_local_path="$(resolve_local_path "$model_artifact_path")"
model_artifact_status="$(artifact_status "$model_artifact_local_path")"
model_artifact_sha256="$(artifact_sha256 "$model_artifact_local_path")"
model_artifact_size="$(artifact_size "$model_artifact_local_path")"
eval_result_schema_version="$(json_string_for schema_version "$eval_result_path")"
eval_result_schema_version="${eval_result_schema_version:-$(json_number_for schema_version "$eval_result_path")}"
eval_result_status="$(json_string_for status "$eval_result_path")"
eval_metric_name="$(json_string_for metric_name "$eval_result_path")"
eval_metric_value="$(json_number_for target_accuracy "$eval_result_path")"
if [ -z "$eval_metric_value" ]; then
    eval_metric_value="$(json_number_for final_accuracy "$eval_result_path")"
fi
eval_metric_target="$(json_number_for required_accuracy "$eval_result_path")"
eval_dataset_id="$(json_string_for dataset_id "$eval_result_path")"
eval_dataset_split="$(json_string_for dataset_split "$eval_result_path")"
eval_dataset_checksum="$(json_string_for dataset_checksum "$eval_result_path")"
eval_samples="$(json_number_for samples "$eval_result_path")"
license_constraints_status="$license_constraints"
safety_eval_status="$safety_eval"
deployment_evidence_status="$deployment_evidence"
handoff_status="$app_handoff_doc_ready"
pass_integrity_status="not_applicable"
pass_integrity_reason="not_applicable"

required_gates="retry6_training_eval,training_allowed,model_manifest,eval_result,target_eval,decision,license,safety,deployment,app_handoff"
blocked_gates=""
append_blocked_gate() {
    gate="$1"
    if [ -z "$blocked_gates" ]; then
        blocked_gates="$gate"
    else
        blocked_gates="$blocked_gates|$gate"
    fi
}

if [ "${upstream_retry6_result:-}" != "READY" ] && [ "${upstream_retry6_result:-}" != "PASS" ]; then
    append_blocked_gate "retry6_training_eval"
fi
if [ "${training_allowed:-false}" != "true" ]; then
    append_blocked_gate "training_allowed"
fi
if [ "${model_manifest_exists:-false}" != "true" ]; then
    append_blocked_gate "model_manifest"
fi
if [ "${eval_result_exists:-false}" != "true" ]; then
    append_blocked_gate "eval_result"
fi
if [ "${target_eval_reached:-false}" != "true" ]; then
    append_blocked_gate "target_eval"
fi
if [ "${decision_status:-}" != "accepted" ]; then
    append_blocked_gate "decision"
fi
if [ "${license_constraints:-pending}" != "clear" ]; then
    append_blocked_gate "license"
fi
if [ "${safety_eval:-not-run}" != "pass" ]; then
    append_blocked_gate "safety"
fi
if [ "${deployment_evidence:-not-deployable}" != "deployable" ]; then
    append_blocked_gate "deployment"
fi
if [ "${app_handoff_doc_ready:-false}" != "true" ]; then
    append_blocked_gate "app_handoff"
fi
if [ -z "$blocked_gates" ]; then
    blocked_gates="none"
fi

primary_blocked_gate="none"
if [ "$blocked_gates" != "none" ]; then
    primary_blocked_gate="$(printf '%s\n' "$blocked_gates" | cut -d '|' -f 1)"
fi
case "$primary_blocked_gate" in
    retry6_training_eval)
        next_action="complete retry6 training/eval gate before normal acceptance review"
        ;;
    training_allowed)
        next_action="mark fine-tune training allowed only after retry6 training/eval prerequisites are concrete"
        ;;
    model_manifest)
        next_action="create or link the fine-tuned model manifest before retry7 acceptance"
        ;;
    eval_result)
        next_action="create or link the target eval result before retry7 acceptance"
        ;;
    target_eval)
        next_action="rerun or improve fine-tune eval until the target threshold is reached"
        ;;
    decision)
        next_action="record normal-review acceptance decision for retry7"
        ;;
    license)
        next_action="record clear license constraints before retry7 acceptance"
        ;;
    safety)
        next_action="run and record passing safety evaluation before retry7 acceptance"
        ;;
    deployment)
        next_action="record deployable deployment evidence before retry7 acceptance"
        ;;
    app_handoff)
        next_action="write concrete app handoff usage and handoff doc evidence before retry7 acceptance"
        ;;
    none)
        if [ "${acceptance_allowed:-false}" = "true" ]; then
            next_action="release handoff may cite accepted fine-tune evidence"
        fi
        ;;
esac

status="fail"
reason="${result:-acceptance_not_ready}"
if [ "$gate_exit" -eq 0 ] &&
   printf '%s\n' "$gate_status" | grep -F "PASS retry7-acceptance-gate" >/dev/null 2>&1 &&
   [ "$acceptance_allowed" = "true" ] &&
   [ "$blocked_gates" = "none" ]; then
    pass_integrity_status="pass"
    pass_integrity_reason="all_required_artifacts_present"
    for pair in \
        "attempt_record:$attempt_record_artifact_status" \
        "model_manifest:$model_manifest_artifact_status" \
        "eval_result:$eval_result_artifact_status" \
        "handoff_doc:$handoff_doc_artifact_status" \
        "model_manifest_schema:${model_manifest_schema_version:-missing}" \
        "model_manifest_attempt_id:${model_manifest_attempt_id:-missing}" \
        "model_manifest_base_model:${model_manifest_base_model:-missing}" \
        "model_artifact:$model_artifact_status" \
        "eval_result_schema:${eval_result_schema_version:-missing}" \
        "eval_result_status:${eval_result_status:-missing}" \
        "eval_metric_value:${eval_metric_value:-missing}" \
        "eval_metric_target:${eval_metric_target:-missing}" \
        "eval_dataset_id:${eval_dataset_id:-missing}"; do
        artifact_name="${pair%%:*}"
        artifact_state="${pair#*:}"
        if [ "$artifact_state" != "ready" ] &&
           [ "$artifact_state" = "missing" -o "$artifact_state" = "" ]; then
            pass_integrity_status="fail"
            pass_integrity_reason="${artifact_name}_artifact_missing"
            break
        fi
    done
    if [ "$pass_integrity_status" = "pass" ] && [ "${model_manifest_deployable:-missing}" != "true" ]; then
        pass_integrity_status="fail"
        pass_integrity_reason="model_manifest_not_deployable"
    elif [ "$pass_integrity_status" = "pass" ] && [ "${eval_result_status:-missing}" != "pass" ]; then
        pass_integrity_status="fail"
        pass_integrity_reason="eval_result_status_not_pass"
    elif [ "$pass_integrity_status" = "pass" ] && [ -z "${eval_dataset_checksum:-}" -o "${eval_dataset_checksum:-missing}" = "missing" ]; then
        pass_integrity_status="fail"
        pass_integrity_reason="eval_dataset_checksum_missing"
    elif [ "$pass_integrity_status" = "pass" ] && [ -z "${eval_samples:-}" -o "${eval_samples:-missing}" = "missing" ]; then
        pass_integrity_status="fail"
        pass_integrity_reason="eval_samples_missing"
    elif [ "$pass_integrity_status" = "pass" ] && [ -z "${handoff_usage:-}" -o "${handoff_usage:-missing}" = "missing" ]; then
        pass_integrity_status="fail"
        pass_integrity_reason="handoff_usage_missing"
    elif [ "$pass_integrity_status" = "pass" ] && printf '%s\n' "$handoff_usage" | grep -F "do not deploy" >/dev/null 2>&1; then
        pass_integrity_status="fail"
        pass_integrity_reason="handoff_usage_not_deployable"
    fi
    if [ "$pass_integrity_status" = "pass" ]; then
        status="pass"
        reason="retry7_acceptance_passed"
    else
        status="fail"
        reason="retry7_acceptance_pass_integrity_failed:${pass_integrity_reason}"
        blocked_gates="pass_integrity"
        primary_blocked_gate="pass_integrity"
        next_action="provide local non-empty attempt, model manifest, eval result, and handoff artifacts before retry7 acceptance can pass"
    fi
fi

{
    printf '%s\n' "llm_finetune_acceptance_status=$status"
    printf '%s\n' "llm_finetune_acceptance_reason=$reason"
    printf '%s\n' "llm_finetune_acceptance_attempt=$ATTEMPT"
    printf '%s\n' "llm_finetune_acceptance_required_gates=$required_gates"
    printf '%s\n' "llm_finetune_acceptance_blocked_gates=$blocked_gates"
    printf '%s\n' "llm_finetune_acceptance_primary_blocked_gate=$primary_blocked_gate"
    printf '%s\n' "llm_finetune_acceptance_gate_exit=$gate_exit"
    printf '%s\n' "llm_finetune_acceptance_gate_status=$gate_status"
    printf '%s\n' "llm_finetune_acceptance_gate_log=$GATE_LOG"
    printf '%s\n' "llm_finetune_acceptance_gate_log_artifact_status=$gate_log_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_gate_log_sha256=$gate_log_sha256"
    printf '%s\n' "llm_finetune_acceptance_gate_log_size=$gate_log_size"
    printf '%s\n' "llm_finetune_acceptance_surface_manifest=$SURFACE_MANIFEST"
    printf '%s\n' "llm_finetune_acceptance_surface_manifest_count=$surface_manifest_count"
    printf '%s\n' "llm_finetune_acceptance_surface_manifest_size=$surface_manifest_size"
    printf '%s\n' "llm_finetune_acceptance_surface_manifest_sha256=$surface_manifest_sha256"
    printf '%s\n' "llm_finetune_acceptance_result=$result"
    printf '%s\n' "llm_finetune_acceptance_allowed=${acceptance_allowed:-false}"
    printf '%s\n' "llm_finetune_acceptance_training_allowed=${training_allowed:-false}"
    printf '%s\n' "llm_finetune_acceptance_upstream_retry6_result=$upstream_retry6_result"
    printf '%s\n' "llm_finetune_acceptance_upstream_attempt_record=$upstream_attempt_record"
    printf '%s\n' "llm_finetune_acceptance_upstream_attempt_record_artifact_status=$upstream_attempt_record_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_upstream_attempt_record_sha256=$upstream_attempt_record_sha256"
    printf '%s\n' "llm_finetune_acceptance_upstream_attempt_record_size=$upstream_attempt_record_size"
    printf '%s\n' "llm_finetune_acceptance_upstream_cache_manifest=$upstream_cache_manifest"
    printf '%s\n' "llm_finetune_acceptance_upstream_cache_manifest_artifact_status=$upstream_cache_manifest_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_upstream_cache_manifest_sha256=$upstream_cache_manifest_sha256"
    printf '%s\n' "llm_finetune_acceptance_upstream_cache_manifest_size=$upstream_cache_manifest_size"
    printf '%s\n' "llm_finetune_acceptance_attempt_record=$attempt_record"
    printf '%s\n' "llm_finetune_acceptance_attempt_record_artifact_status=$attempt_record_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_attempt_record_sha256=$attempt_record_sha256"
    printf '%s\n' "llm_finetune_acceptance_attempt_record_size=$attempt_record_size"
    printf '%s\n' "llm_finetune_acceptance_model_manifest=$model_manifest"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_exists=${model_manifest_exists:-false}"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_artifact_status=$model_manifest_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_sha256=$model_manifest_sha256"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_size=$model_manifest_size"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_schema_version=${model_manifest_schema_version:-missing}"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_attempt_id=${model_manifest_attempt_id:-missing}"
    printf '%s\n' "llm_finetune_acceptance_base_model=${model_manifest_base_model:-missing}"
    printf '%s\n' "llm_finetune_acceptance_base_model_revision=${model_manifest_base_model_revision:-missing}"
    printf '%s\n' "llm_finetune_acceptance_model_artifact_path=${model_artifact_path:-missing}"
    printf '%s\n' "llm_finetune_acceptance_model_artifact_status=$model_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_model_artifact_sha256=$model_artifact_sha256"
    printf '%s\n' "llm_finetune_acceptance_model_artifact_size=$model_artifact_size"
    printf '%s\n' "llm_finetune_acceptance_model_manifest_deployable=$model_manifest_deployable"
    printf '%s\n' "llm_finetune_acceptance_eval_result=$eval_result"
    printf '%s\n' "llm_finetune_acceptance_eval_result_exists=${eval_result_exists:-false}"
    printf '%s\n' "llm_finetune_acceptance_eval_result_artifact_status=$eval_result_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_eval_result_sha256=$eval_result_sha256"
    printf '%s\n' "llm_finetune_acceptance_eval_result_size=$eval_result_size"
    printf '%s\n' "llm_finetune_acceptance_eval_result_schema_version=${eval_result_schema_version:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_result_status=${eval_result_status:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_metric_name=${eval_metric_name:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_metric_value=${eval_metric_value:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_metric_target=${eval_metric_target:-$required_accuracy}"
    printf '%s\n' "llm_finetune_acceptance_eval_dataset_id=${eval_dataset_id:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_dataset_split=${eval_dataset_split:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_dataset_checksum=${eval_dataset_checksum:-missing}"
    printf '%s\n' "llm_finetune_acceptance_eval_samples=${eval_samples:-missing}"
    printf '%s\n' "llm_finetune_acceptance_target_eval_reached=$target_eval_reached"
    printf '%s\n' "llm_finetune_acceptance_target_accuracy=$target_accuracy"
    printf '%s\n' "llm_finetune_acceptance_required_accuracy=$required_accuracy"
    printf '%s\n' "llm_finetune_acceptance_retry6_next_action=$retry6_next_action"
    printf '%s\n' "llm_finetune_acceptance_attempt_record_status=$attempt_record_status"
    printf '%s\n' "llm_finetune_acceptance_decision_status=$decision_status"
    printf '%s\n' "llm_finetune_acceptance_license_constraints=$license_constraints"
    printf '%s\n' "llm_finetune_acceptance_license_constraints_status=$license_constraints_status"
    printf '%s\n' "llm_finetune_acceptance_safety_eval=$safety_eval"
    printf '%s\n' "llm_finetune_acceptance_safety_eval_status=$safety_eval_status"
    printf '%s\n' "llm_finetune_acceptance_deployment_evidence=$deployment_evidence"
    printf '%s\n' "llm_finetune_acceptance_deployment_evidence_status=$deployment_evidence_status"
    printf '%s\n' "llm_finetune_acceptance_handoff_doc=$handoff_doc"
    printf '%s\n' "llm_finetune_acceptance_handoff_doc_artifact_status=$handoff_doc_artifact_status"
    printf '%s\n' "llm_finetune_acceptance_handoff_doc_sha256=$handoff_doc_sha256"
    printf '%s\n' "llm_finetune_acceptance_handoff_doc_size=$handoff_doc_size"
    printf '%s\n' "llm_finetune_acceptance_handoff_usage=$handoff_usage"
    printf '%s\n' "llm_finetune_acceptance_handoff_status=$handoff_status"
    printf '%s\n' "llm_finetune_acceptance_app_handoff_doc_ready=$app_handoff_doc_ready"
    printf '%s\n' "llm_finetune_acceptance_pass_integrity_status=$pass_integrity_status"
    printf '%s\n' "llm_finetune_acceptance_pass_integrity_reason=$pass_integrity_reason"
    printf '%s\n' "llm_finetune_acceptance_next_action=$next_action"
} >"$OUT_ENV"

{
    printf '# LLM Fine-Tune Acceptance Evidence\n\n'
    printf '%s\n' "- status: \`$status\`"
    printf '%s\n' "- reason: \`$reason\`"
    printf '%s\n' "- attempt: \`$ATTEMPT\`"
    printf '%s\n' "- required_gates: \`$required_gates\`"
    printf '%s\n' "- blocked_gates: \`$blocked_gates\`"
    printf '%s\n' "- primary_blocked_gate: \`$primary_blocked_gate\`"
    printf '%s\n' "- gate_status: \`$gate_status\`"
    printf '%s\n' "- gate_log: \`$GATE_LOG\`"
    printf '%s\n' "- gate_log_artifact_status: \`$gate_log_artifact_status\`"
    printf '%s\n' "- gate_log_sha256: \`$gate_log_sha256\`"
    printf '%s\n' "- gate_log_size: \`$gate_log_size\`"
    printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
    printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
    printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
    printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
    printf '%s\n' "- acceptance_allowed: \`${acceptance_allowed:-false}\`"
    printf '%s\n' "- training_allowed: \`${training_allowed:-false}\`"
    printf '%s\n' "- upstream_retry6_result: \`$upstream_retry6_result\`"
    printf '%s\n' "- upstream_attempt_record: \`$upstream_attempt_record\`"
    printf '%s\n' "- upstream_attempt_record_artifact_status: \`$upstream_attempt_record_artifact_status\`"
    printf '%s\n' "- upstream_attempt_record_sha256: \`$upstream_attempt_record_sha256\`"
    printf '%s\n' "- upstream_attempt_record_size: \`$upstream_attempt_record_size\`"
    printf '%s\n' "- upstream_cache_manifest: \`$upstream_cache_manifest\`"
    printf '%s\n' "- upstream_cache_manifest_artifact_status: \`$upstream_cache_manifest_artifact_status\`"
    printf '%s\n' "- upstream_cache_manifest_sha256: \`$upstream_cache_manifest_sha256\`"
    printf '%s\n' "- upstream_cache_manifest_size: \`$upstream_cache_manifest_size\`"
    printf '%s\n' "- attempt_record: \`$attempt_record\`"
    printf '%s\n' "- attempt_record_artifact_status: \`$attempt_record_artifact_status\`"
    printf '%s\n' "- attempt_record_sha256: \`$attempt_record_sha256\`"
    printf '%s\n' "- model_manifest: \`$model_manifest\`"
    printf '%s\n' "- model_manifest_exists: \`${model_manifest_exists:-false}\`"
    printf '%s\n' "- model_manifest_artifact_status: \`$model_manifest_artifact_status\`"
    printf '%s\n' "- model_manifest_sha256: \`$model_manifest_sha256\`"
    printf '%s\n' "- model_manifest_schema_version: \`${model_manifest_schema_version:-missing}\`"
    printf '%s\n' "- model_manifest_attempt_id: \`${model_manifest_attempt_id:-missing}\`"
    printf '%s\n' "- base_model: \`${model_manifest_base_model:-missing}\`"
    printf '%s\n' "- base_model_revision: \`${model_manifest_base_model_revision:-missing}\`"
    printf '%s\n' "- model_artifact_path: \`${model_artifact_path:-missing}\`"
    printf '%s\n' "- model_artifact_status: \`$model_artifact_status\`"
    printf '%s\n' "- model_artifact_sha256: \`$model_artifact_sha256\`"
    printf '%s\n' "- model_manifest_deployable: \`$model_manifest_deployable\`"
    printf '%s\n' "- eval_result: \`$eval_result\`"
    printf '%s\n' "- eval_result_exists: \`${eval_result_exists:-false}\`"
    printf '%s\n' "- eval_result_artifact_status: \`$eval_result_artifact_status\`"
    printf '%s\n' "- eval_result_sha256: \`$eval_result_sha256\`"
    printf '%s\n' "- eval_result_schema_version: \`${eval_result_schema_version:-missing}\`"
    printf '%s\n' "- eval_result_status: \`${eval_result_status:-missing}\`"
    printf '%s\n' "- eval_metric_name: \`${eval_metric_name:-missing}\`"
    printf '%s\n' "- eval_metric_value: \`${eval_metric_value:-missing}\`"
    printf '%s\n' "- eval_metric_target: \`${eval_metric_target:-$required_accuracy}\`"
    printf '%s\n' "- eval_dataset_id: \`${eval_dataset_id:-missing}\`"
    printf '%s\n' "- eval_dataset_split: \`${eval_dataset_split:-missing}\`"
    printf '%s\n' "- eval_dataset_checksum: \`${eval_dataset_checksum:-missing}\`"
    printf '%s\n' "- eval_samples: \`${eval_samples:-missing}\`"
    printf '%s\n' "- target_eval_reached: \`$target_eval_reached\`"
    printf '%s\n' "- target_accuracy: \`$target_accuracy\`"
    printf '%s\n' "- required_accuracy: \`$required_accuracy\`"
    printf '%s\n' "- retry6_next_action: \`$retry6_next_action\`"
    printf '%s\n' "- attempt_record_status: \`$attempt_record_status\`"
    printf '%s\n' "- decision_status: \`$decision_status\`"
    printf '%s\n' "- license_constraints: \`$license_constraints\`"
    printf '%s\n' "- safety_eval: \`$safety_eval\`"
    printf '%s\n' "- deployment_evidence: \`$deployment_evidence\`"
    printf '%s\n' "- handoff_doc: \`$handoff_doc\`"
    printf '%s\n' "- handoff_doc_artifact_status: \`$handoff_doc_artifact_status\`"
    printf '%s\n' "- handoff_doc_sha256: \`$handoff_doc_sha256\`"
    printf '%s\n' "- handoff_usage: \`$handoff_usage\`"
    printf '%s\n' "- app_handoff_doc_ready: \`$app_handoff_doc_ready\`"
    printf '%s\n' "- pass_integrity_status: \`$pass_integrity_status\`"
    printf '%s\n' "- pass_integrity_reason: \`$pass_integrity_reason\`"
    printf '%s\n' "- next_action: \`$next_action\`"
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '\n'
    printf 'This evidence consumes the retry7 normal acceptance gate. It only passes when retry7 itself passes with `acceptance_allowed=true`, every normalized required gate is unblocked, and local non-empty attempt, model manifest, model artifact, eval result, and handoff artifacts can be hashed for pass integrity. PASS integrity also requires a deployable model manifest, passing eval result, metric target, dataset checksum, eval sample count, and deployable handoff usage. Otherwise it records the required gate list, compact blocked-gates list, gate-log and upstream retry5 artifact provenance hashes, model/eval/license/safety/deployment/app-handoff fields, and next action while keeping strict fine-tune readiness failed.\n'
} >"$REPORT_PATH"

if [ "$status" = "pass" ]; then
    echo "STATUS: PASS llm-finetune-acceptance"
else
    echo "STATUS: FAIL llm-finetune-acceptance reason=$reason"
    exit 1
fi
