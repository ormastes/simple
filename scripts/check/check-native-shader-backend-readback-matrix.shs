#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT_DIR"

SPEC="test/02_integration/rendering/native_shader_backend_readback_matrix_spec.spl"
VULKAN_STRICT_SPEC="test/02_integration/rendering/vulkan_strict_spec.spl"
BACKEND_MATRIX_SPEC="test/02_integration/rendering/backend_matrix_spec.spl"
CPU_VULKAN_PARITY_SPEC="test/02_integration/rendering/engine2d_cpu_vulkan_parity_spec.spl"
METAL_SPEC="test/02_integration/rendering/metal_generated_compute_readback_spec.spl"
OS_NAME="$(uname -s)"

echo "[check] native shader backend readback matrix"
echo "[check] host=${OS_NAME}"
echo "[check] spec=${SPEC}"

bin/simple check "$SPEC"
bin/simple test "$SPEC" --clean

if [[ "$OS_NAME" == "Darwin" ]]; then
  echo "[check] macOS host detected; running Metal generated compute proof"
  bin/simple test "$METAL_SPEC" --clean
else
  echo "[check] non-macOS host; running Linux Vulkan proof set"
  bin/simple test "$VULKAN_STRICT_SPEC" --mode=interpreter --clean
  bin/simple test "$BACKEND_MATRIX_SPEC" --mode=interpreter --clean
  bin/simple test "$CPU_VULKAN_PARITY_SPEC" --mode=interpreter --clean
fi
