#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/linux-hosted-wm-live-window-evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/linux_hosted_wm_live_window_evidence_$(date -u +%F).md}"
LOG_PATH="$BUILD_DIR/stdout.log"
ERR_PATH="$BUILD_DIR/stderr.log"
PID_PATH="$BUILD_DIR/pid"
WINDOW_ENV="$BUILD_DIR/window.env"
CAPTURE_PATH="$BUILD_DIR/window.png"
CAPTURE_METRICS="$BUILD_DIR/capture.metrics"
TIMEOUT_SECS="${LINUX_HOSTED_WM_LIVE_TIMEOUT_SECS:-25}"
FORCE_X11="${LINUX_HOSTED_WM_FORCE_X11:-1}"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$LOG_PATH" "$ERR_PATH" "$PID_PATH" "$WINDOW_ENV" "$CAPTURE_PATH" "$CAPTURE_METRICS" "$REPORT_PATH"

GUI_BIN="${GUI_BIN:-}"
GUI_BIN_SOURCE="${GUI_BIN_SOURCE:-explicit-env}"
if [ "$GUI_BIN" = "" ]; then
    GUI_BIN_SOURCE="repo-gui-driver-fallback"
    for candidate in \
        "src/compiler_rust/target/gui/debug/simple" \
        "src/compiler_rust/target/gui/release/simple" \
        "src/compiler_rust/target/debug/simple" \
        "src/compiler_rust/target/release/simple"
    do
        if [ -x "$candidate" ] && LC_ALL=C grep -aq "rt_winit_event_loop_new" "$candidate"; then
            GUI_BIN="$candidate"
            break
        fi
    done
fi

emit_report() {
    status="$1"
    reason="$2"
    window_marker="$3"
    frame_marker="$4"
    capture_status="${5:-not-run}"
    event_status="${6:-not-run}"
    {
        echo "# Linux Hosted WM Live Window Evidence"
        echo
        echo "- status: $status"
        echo "- reason: $reason"
        echo "- gui_bin: $GUI_BIN"
        echo "- gui_bin_source: $GUI_BIN_SOURCE"
        echo "- entry: src/os/hosted/hosted_entry.spl"
        echo "- window_marker: $window_marker"
        echo "- frame_marker: $frame_marker"
        echo "- capture_status: $capture_status"
        echo "- event_status: $event_status"
        echo "- force_x11: $FORCE_X11"
        echo "- capture_png: $CAPTURE_PATH"
        echo "- capture_metrics: $CAPTURE_METRICS"
        echo "- stdout: $LOG_PATH"
        echo "- stderr: $ERR_PATH"
    } >"$REPORT_PATH"
    echo "linux_hosted_wm_live_window_status=$status"
    echo "linux_hosted_wm_live_window_reason=$reason"
    echo "linux_hosted_wm_live_window_gui_bin=$GUI_BIN"
    echo "linux_hosted_wm_live_window_gui_bin_source=$GUI_BIN_SOURCE"
    echo "linux_hosted_wm_live_window_entry=src/os/hosted/hosted_entry.spl"
    echo "linux_hosted_wm_live_window_window_marker=$window_marker"
    echo "linux_hosted_wm_live_window_frame_marker=$frame_marker"
    echo "linux_hosted_wm_live_window_capture_status=$capture_status"
    echo "linux_hosted_wm_live_window_event_status=$event_status"
    echo "linux_hosted_wm_live_window_force_x11=$FORCE_X11"
    echo "linux_hosted_wm_live_window_capture_png=$CAPTURE_PATH"
    echo "linux_hosted_wm_live_window_capture_metrics=$CAPTURE_METRICS"
    echo "linux_hosted_wm_live_window_report_path=$REPORT_PATH"
}

if [ "$GUI_BIN" = "" ]; then
    emit_report "unavailable" "missing-gui-enabled-driver" "fail" "fail" "not-run" "not-run"
    exit 1
fi

set +e
if [ "$FORCE_X11" = "1" ]; then
    env WAYLAND_DISPLAY= WINIT_UNIX_BACKEND=x11 SIMPLE_HOSTED_WM_LIVE_PROOF=1 SIMPLE_LIB="${SIMPLE_LIB:-src}" "$GUI_BIN" run src/os/hosted/hosted_entry.spl >"$LOG_PATH" 2>"$ERR_PATH" &
else
    SIMPLE_HOSTED_WM_LIVE_PROOF=1 SIMPLE_LIB="${SIMPLE_LIB:-src}" "$GUI_BIN" run src/os/hosted/hosted_entry.spl >"$LOG_PATH" 2>"$ERR_PATH" &
fi
run_pid=$!
echo "$run_pid" >"$PID_PATH"
deadline=$(($(date +%s) + TIMEOUT_SECS))
while kill -0 "$run_pid" >/dev/null 2>&1 && [ "$(date +%s)" -lt "$deadline" ]; do
    if grep -Fq "[hosted-wm] warmup-frames-presented count=12" "$LOG_PATH" 2>/dev/null; then
        break
    fi
    sleep 1
done
set -e

window_marker=fail
frame_marker=fail
if grep -Fq "[hosted-wm] window-created backend=winit mode=windowed fullscreen=false width=1024 height=720 title=SimpleOS Shared Hosted WM" "$LOG_PATH"; then
    window_marker=pass
fi
if grep -Fq "[hosted-wm] frame-presented renderer=simple-web host=linux-windowed width=1024 height=720" "$LOG_PATH"; then
    frame_marker=pass
fi

capture_status=unavailable
event_status=fail
if command -v xdotool >/dev/null 2>&1 && command -v import >/dev/null 2>&1 && command -v convert >/dev/null 2>&1; then
    window_id=""
    for _ in $(seq 1 20); do
        window_id="$(xdotool search --name 'SimpleOS Shared Hosted WM' 2>/dev/null | tail -n 1 || true)"
        [ "$window_id" != "" ] && break
        sleep 1
    done
    if [ "$window_id" != "" ]; then
        xdotool getwindowgeometry --shell "$window_id" >"$WINDOW_ENV" 2>/dev/null || true
        xdotool windowactivate --sync "$window_id" >/dev/null 2>&1 || true
        xdotool windowfocus --sync "$window_id" >/dev/null 2>&1 || true
        abs_x="$(sed -n 's/^X=//p' "$WINDOW_ENV" | tail -n 1)"
        abs_y="$(sed -n 's/^Y=//p' "$WINDOW_ENV" | tail -n 1)"
        event_x=$((${abs_x:-0} + 110))
        event_y=$((${abs_y:-0} + 95))
        xdotool mousemove "$event_x" "$event_y" >/dev/null 2>&1 || true
        xdotool click 1 >/dev/null 2>&1 || true
        xdotool mousedown 1 mouseup 1 >/dev/null 2>&1 || true
        xdotool key --clearmodifiers a >/dev/null 2>&1 || true
        xdotool key --clearmodifiers Tab >/dev/null 2>&1 || true
        for _ in $(seq 1 10); do
            if grep -Fq "[hosted-wm] event mouse_move" "$LOG_PATH" \
                && grep -Fq "[hosted-wm] event mouse_button" "$LOG_PATH" \
                && grep -Fq "[hosted-wm] event key" "$LOG_PATH"; then
                break
            fi
            sleep 0.5
        done
        import -window "$window_id" "$CAPTURE_PATH" >/dev/null 2>&1 || true
        sleep 1
        if grep -Fq "[hosted-wm] event mouse_move" "$LOG_PATH" \
            && grep -Fq "[hosted-wm] event focus" "$LOG_PATH"; then
            event_status=pass
        fi
        if [ -s "$CAPTURE_PATH" ]; then
            colors="$(convert "$CAPTURE_PATH" -format %k info: 2>/dev/null || echo 0)"
            blue="$(convert "$CAPTURE_PATH" -format '%[pixel:p{70,86}]' info: 2>/dev/null || echo none)"
            body="$(convert "$CAPTURE_PATH" -format '%[pixel:p{70,112}]' info: 2>/dev/null || echo none)"
            close="$(convert "$CAPTURE_PATH" -format '%[pixel:p{225,86}]' info: 2>/dev/null || echo none)"
            {
                echo "window_id=$window_id"
                cat "$WINDOW_ENV" 2>/dev/null || true
                echo "unique_colors=$colors"
                echo "sample_titlebar=$blue"
                echo "sample_body=$body"
                echo "sample_close=$close"
            } >"$CAPTURE_METRICS"
            if [ "${colors:-0}" -ge 8 ] \
                && grep -Fq "WIDTH=1024" "$WINDOW_ENV" \
                && grep -Fq "HEIGHT=720" "$WINDOW_ENV" \
                && [ "$blue" != "$body" ] \
                && [ "$blue" != "srgb(15,23,42)" ]; then
                capture_status=pass
            else
                capture_status=fail
            fi
        else
            capture_status=fail
        fi
    else
        capture_status=unavailable-no-x11-window
    fi
fi

kill "$run_pid" >/dev/null 2>&1 || true
wait "$run_pid" >/dev/null 2>&1 || true

if [ "$window_marker" = pass ] && [ "$frame_marker" = pass ] && [ "$capture_status" = pass ] && [ "$event_status" = pass ]; then
    emit_report "pass" "linux-windowed-real-capture-and-events" "$window_marker" "$frame_marker" "$capture_status" "$event_status"
    exit 0
fi

emit_report "fail" "missing-real-capture-or-event-evidence" "$window_marker" "$frame_marker" "$capture_status" "$event_status"
exit 1
