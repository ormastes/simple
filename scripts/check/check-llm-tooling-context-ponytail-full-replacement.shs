#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_tooling_context_ponytail_full_replacement}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_tooling_context_ponytail_full_replacement_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
MIMIC_BUILD_DIR="$BUILD_DIR/mimic"
MIMIC_REPORT="$BUILD_DIR/mimic_report.md"
MIMIC_ENV="$MIMIC_BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$MIMIC_REPORT"

status="pass"
reason="repo_local_replacement_surfaces_verified"
failures=""

record_failure() {
    if [ -z "$failures" ]; then
        failures="$1"
    else
        failures="$failures,$1"
    fi
    status="fail"
}

require_contains() {
    name="$1"
    path="$2"
    pattern="$3"
    if [ ! -f "$path" ]; then
        record_failure "$name:missing_file"
        return
    fi
    if ! grep -F "$pattern" "$path" >/dev/null 2>&1; then
        record_failure "$name:missing_pattern"
    fi
}

if BUILD_DIR="$MIMIC_BUILD_DIR" REPORT_PATH="$MIMIC_REPORT" sh scripts/check/check-llm-tooling-context-ponytail-mimic.shs >"$BUILD_DIR/mimic.log" 2>&1; then
    mimic_status="pass"
else
    mimic_status="fail"
    record_failure "mimic_evidence"
fi

require_contains guide_replacement doc/07_guide/app/llm/llm_tooling_context_ponytail_mimic.md "replaces parallel external context-mode and"
require_contains guide_context doc/07_guide/app/llm/llm_tooling_context_ponytail_mimic.md "simple_context"
require_contains guide_ponytail doc/07_guide/app/llm/llm_tooling_context_ponytail_mimic.md "simple_ponytail"
require_contains guide_sql doc/07_guide/app/llm/llm_tooling_context_ponytail_mimic.md "embedded-SQL"
require_contains architecture_contract doc/04_architecture/app/tools/llm_tooling_context_ponytail_mimic.md "The replacement contract is the shared"
require_contains architecture_no_parallel doc/04_architecture/app/tools/llm_tooling_context_ponytail_mimic.md "instead of a parallel context-mode or ponytail plugin path"
require_contains requirements_sql doc/02_requirements/feature/llm_tooling_context_ponytail_mimic.md "REQ-009"
require_contains requirements_mcp doc/02_requirements/feature/llm_tooling_context_ponytail_mimic.md "REQ-015"

require_contains app_context_table src/app/mcp/tool_table.spl "tool_entry(\"simple_context\""
require_contains app_context_sql src/app/mcp/tool_table.spl "Use Simple embedded SQLite for index/query"
require_contains app_context_filter src/app/mcp/tool_table.spl "source_filter"
require_contains app_ponytail_table src/app/mcp/tool_table.spl "tool_entry(\"simple_ponytail\""
require_contains app_context_dispatch src/app/mcp/main_dispatch.spl "return handle_simple_context(id, body)"
require_contains app_ponytail_dispatch src/app/mcp/main_dispatch.spl "return handle_simple_ponytail(id, body)"
require_contains app_context_sourceless src/app/mcp/main_lazy_query_tools.spl "sourceless_sql_query"
require_contains app_ponytail_handler src/app/mcp/main_lazy_query_tools.spl "ponytail_simplification_report"

require_contains lower_context_schema src/lib/nogc_async_mut/mcp/lazy_protocol_schemas.spl "make_tool_schema(name: \"simple_context\""
require_contains lower_context_sql src/lib/nogc_async_mut/mcp/lazy_protocol_schemas.spl "Use Simple embedded SQLite for index/query"
require_contains lower_context_filter src/lib/nogc_async_mut/mcp/lazy_protocol_schemas.spl "source_filter"
require_contains lower_ponytail_schema src/lib/nogc_async_mut/mcp/lazy_protocol_schemas.spl "make_tool_schema(name: \"simple_ponytail\""
require_contains lower_context_dispatch src/lib/nogc_async_mut/mcp/main_lazy.spl "return handle_simple_context(id, body)"
require_contains lower_ponytail_dispatch src/lib/nogc_async_mut/mcp/main_lazy.spl "return handle_simple_ponytail(id, body)"
require_contains lower_ponytail_handler src/lib/nogc_async_mut/mcp/main_lazy_query_tools.spl "ponytail_simplification_report_source"

if [ "$status" != "pass" ]; then
    reason="repo_local_replacement_surface_gap"
fi

{
    printf '%s\n' "llm_tooling_context_ponytail_full_replacement_status=$status"
    printf '%s\n' "llm_tooling_context_ponytail_full_replacement_reason=$reason"
    printf '%s\n' "llm_tooling_context_ponytail_full_replacement_scope=repo_local_simple_owned_surfaces"
    printf '%s\n' "llm_tooling_context_ponytail_full_replacement_mimic_status=$mimic_status"
    printf '%s\n' "llm_tooling_context_ponytail_full_replacement_mimic_env=$MIMIC_ENV"
    printf '%s\n' "llm_tooling_context_ponytail_full_replacement_failures=$failures"
} >"$OUT_ENV"

{
    printf '# LLM Tooling Context/Ponytail Full Replacement Evidence\n\n'
    printf '%s\n' "- status: \`$status\`"
    printf '%s\n' "- reason: \`$reason\`"
    printf '%s\n' "- scope: \`repo_local_simple_owned_surfaces\`"
    printf '%s\n' "- mimic_status: \`$mimic_status\`"
    printf '%s\n' "- mimic_env: \`$MIMIC_ENV\`"
    if [ -n "$failures" ]; then
        printf '%s\n' "- failures: \`$failures\`"
    else
        printf '%s\n' "- failures: \`none\`"
    fi
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '\n'
    printf 'This evidence proves the checked-in operator, CLI, app MCP, lower MCP, dashboard-adjacent, embedded-SQL, and Ponytail surfaces converge on Simple-owned `simple_context` and `simple_ponytail` contracts. It is repo-local replacement evidence; it does not claim internet fetch, external vector store, or third-party plugin parity.\n'
} >"$REPORT_PATH"

if [ "$status" = "pass" ]; then
    echo "STATUS: PASS llm-tooling-context-ponytail-full-replacement"
else
    echo "STATUS: FAIL llm-tooling-context-ponytail-full-replacement failures=$failures"
    exit 1
fi
