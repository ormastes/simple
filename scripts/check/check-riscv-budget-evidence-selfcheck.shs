#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
BASE_DIR="${RISCV_BUDGET_SELFCHECK_ROOT:-$ROOT_DIR/build/riscv_budget_evidence_selfcheck_$$}"
REPORT_DIR="$BASE_DIR/reports"
BUDGET_BUILD_ROOT="$BASE_DIR/bundle"

write_reports() {
    rv32_luts="$1"
    rv32_mhz="$2"
    rv64_luts="$3"
    rv64_mhz="$4"
    rm -rf "$REPORT_DIR"
    mkdir -p "$REPORT_DIR"
    printf 'actual_luts = %s\nactual_mhz = %s\n' "$rv32_luts" "$rv32_mhz" > "$REPORT_DIR/rv32_synth.sdn"
    printf 'actual_luts = %s\nactual_mhz = %s\n' "$rv64_luts" "$rv64_mhz" > "$REPORT_DIR/rv64_synth.sdn"
}

expect_fail() {
    if "$@"; then
        echo "FAIL: command unexpectedly passed: $*" >&2
        exit 1
    fi
}

write_reports 20000 60 40000 55
BUILD_ROOT="$BUDGET_BUILD_ROOT/pass" SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" --require-synth >/dev/null
expect_fail env BUILD_ROOT="$BUDGET_BUILD_ROOT/not_vivado" SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" --require-vivado >/dev/null 2>&1

write_reports 26000 60 40000 55
expect_fail env BUILD_ROOT="$BUDGET_BUILD_ROOT/over_luts" SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" --require-synth >/dev/null 2>&1

write_reports 20000 40 40000 55
expect_fail env BUILD_ROOT="$BUDGET_BUILD_ROOT/under_mhz" SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" --require-synth >/dev/null 2>&1

rm -rf "$REPORT_DIR"
mkdir -p "$BASE_DIR/vivado" "$REPORT_DIR"
cat > "$BASE_DIR/vivado/rv32_util.rpt" <<'EOF'
| CLB LUTs* | 20000 |
EOF
cat > "$BASE_DIR/vivado/rv64_util.rpt" <<'EOF'
| CLB LUTs* | 40000 |
EOF
cat > "$BASE_DIR/vivado/rv32_timing.rpt" <<'EOF'
| WNS(ns) | TNS(ns) |
| 3.334 | 0.000 |
EOF
cat > "$BASE_DIR/vivado/rv64_timing.rpt" <<'EOF'
| WNS(ns) | TNS(ns) |
| 1.818 | 0.000 |
EOF
sh "$ROOT_DIR/scripts/check/convert-riscv-vivado-reports.shs" rv32 "$BASE_DIR/vivado/rv32_util.rpt" "$BASE_DIR/vivado/rv32_timing.rpt" 50 "$REPORT_DIR" >/dev/null
sh "$ROOT_DIR/scripts/check/convert-riscv-vivado-reports.shs" rv64 "$BASE_DIR/vivado/rv64_util.rpt" "$BASE_DIR/vivado/rv64_timing.rpt" 50 "$REPORT_DIR" >/dev/null
BUILD_ROOT="$BUDGET_BUILD_ROOT/vivado" SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" --require-synth >/dev/null
BUILD_ROOT="$BUDGET_BUILD_ROOT/require_vivado" SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" --require-vivado >/dev/null

echo "STATUS: PASS riscv-budget-evidence-selfcheck"
