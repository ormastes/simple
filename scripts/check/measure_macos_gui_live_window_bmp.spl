# Measure visible content in a macOS GUI live-window BMP capture.

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

fn byte_at(data: [u8], idx: i64) -> i64:
    if idx < 0 or idx >= data.len():
        return 0
    data[idx] as i64

fn le16(data: [u8], off: i64) -> i64:
    byte_at(data, off) | (byte_at(data, off + 1) << 8)

fn le32u(data: [u8], off: i64) -> i64:
    byte_at(data, off) | (byte_at(data, off + 1) << 8) | (byte_at(data, off + 2) << 16) | (byte_at(data, off + 3) << 24)

fn le32s(data: [u8], off: i64) -> i64:
    val raw = le32u(data, off)
    if raw >= 2147483648:
        return raw - 4294967296
    raw

fn max3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b > m:
        m = b
    if c > m:
        m = c
    m

fn min3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b < m:
        m = b
    if c < m:
        m = c
    m

fn abs_i64(value: i64) -> i64:
    if value < 0:
        return 0 - value
    value

fn pad6(value: i64) -> text:
    var s = value.to_string()
    while s.len() < 6:
        s = "0" + s
    s

fn ratio6(count: i64, total: i64) -> text:
    if total <= 0:
        return "0.000000"
    val scaled = (count * 1000000) / total
    (scaled / 1000000).to_string() + "." + pad6(scaled % 1000000)

fn near_color(r: i64, g: i64, b: i64, target_r: i64, target_g: i64, target_b: i64, delta: i64) -> bool:
    abs_i64(r - target_r) <= delta and abs_i64(g - target_g) <= delta and abs_i64(b - target_b) <= delta

fn emit_zero():
    print "0 0 0 0 0.000000 0 0 0 0"

fn main() -> i32:
    val path = rt_env_get("MACOS_GUI_LIVE_WINDOW_BMP") ?? ""
    if path == "":
        emit_zero()
        return 0
    val data = rt_file_read_bytes(path) ?? []
    if data.len() < 54 or byte_at(data, 0) != 66 or byte_at(data, 1) != 77:
        emit_zero()
        return 0
    val offset = le32u(data, 10)
    val width = le32s(data, 18)
    val height_raw = le32s(data, 22)
    val bits = le16(data, 28)
    val compression = le32u(data, 30)
    if width <= 0 or height_raw == 0 or (bits != 24 and bits != 32) or (compression != 0 and compression != 3):
        emit_zero()
        return 0
    val height = abs_i64(height_raw)
    val bytes_per_pixel = bits / 8
    val stride = ((width * bits + 31) / 32) * 4
    var count: i64 = 0
    var titlebar_widget_fill_pixels: i64 = 0
    var titlebar_widget_accent_pixels: i64 = 0
    var titlebar_widget_text_pixels: i64 = 0
    var y: i64 = 0
    while y < height:
        val row = offset + y * stride
        var x: i64 = 0
        while x < width:
            val pos = row + x * bytes_per_pixel
            if pos + 2 < data.len():
                val b = byte_at(data, pos)
                val g = byte_at(data, pos + 1)
                val r = byte_at(data, pos + 2)
                val hi = max3(r, g, b)
                val lo = min3(r, g, b)
                if hi - lo > 12 or hi > 32:
                    count = count + 1
                if near_color(r, g, b, 18, 58, 52, 2):
                    titlebar_widget_fill_pixels = titlebar_widget_fill_pixels + 1
                if near_color(r, g, b, 52, 211, 153, 2):
                    titlebar_widget_accent_pixels = titlebar_widget_accent_pixels + 1
                if near_color(r, g, b, 236, 254, 255, 2):
                    titlebar_widget_text_pixels = titlebar_widget_text_pixels + 1
            x = x + 1
        y = y + 1
    val total = width * height
    val titlebar_css_pixels = titlebar_widget_fill_pixels + titlebar_widget_accent_pixels + titlebar_widget_text_pixels
    print width.to_string() + " " + height.to_string() + " " + total.to_string() + " " + count.to_string() + " " + ratio6(count, total) + " " + titlebar_css_pixels.to_string() + " " + titlebar_widget_fill_pixels.to_string() + " " + titlebar_widget_accent_pixels.to_string() + " " + titlebar_widget_text_pixels.to_string()
    0
