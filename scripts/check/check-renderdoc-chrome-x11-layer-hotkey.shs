#!/bin/sh
# Diagnostic Chrome-on-X11 RenderDoc Vulkan-layer hotkey capture probe.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"
. "$ROOT_DIR/scripts/lib/renderdoc-evidence-common.shs"

BUILD_DIR="${BUILD_DIR:-build/renderdoc/chrome-x11-layer-hotkey}"
OUT_ENV="$BUILD_DIR/evidence.env"
REPORT_PATH="${REPORT_PATH:-doc/09_report/renderdoc_chrome_x11_layer_hotkey_$(date -u +%F).md}"
HTML_PATH="${RDOC_HTML_PATH:-$ROOT_DIR/test/fixtures/html_css/generated_gui_vulkan_renderdoc_fixture.html}"
CHROME_BIN="${RDOC_CHROME:-/usr/bin/google-chrome}"
RENDERDOC_HOME="${RDOC_HOME:-/opt/renderdoc}"
WIDTH="${RDOC_CHROME_WIDTH:-900}"
HEIGHT="${RDOC_CHROME_HEIGHT:-700}"
WAIT_SECS="${RDOC_CHROME_HOTKEY_WAIT_SECS:-8}"
CAPOPTS="${RDOC_CAPOPTS:-}"
USE_GPU_LAUNCHER="${RDOC_CHROME_HOTKEY_GPU_LAUNCHER:-0}"

mkdir -p "$BUILD_DIR/vulkan-layer.d" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$BUILD_DIR/rdc.list"

status="fail"
reason="not-run"
capture_file=""
capture_magic=""
chosen_window=""
chosen_window_pid=""
chosen_window_pid_matches_gpu_pid=""
gpu_pid=""
gpu_env_has_layer=""
gpu_env_has_capfile=""
gpu_env_has_capopts=""
gpu_maps_has_renderdoc=""
gpu_maps_has_vulkan=""
gpu_process_exit_status=""
gpu_process_exit_count=""
gpu_process_exit_codes=""
gpu_process_exit_reason=""
chrome_launch_flags="$(rdoc_chrome_vulkan_flags)"
gpu_launcher_log="$BUILD_DIR/gpu-launcher.log"
gpu_launcher_invoked=""
gpu_launcher_pid=""
gpu_launcher_exec_pid=""
gpu_launcher_pid_matches_gpu_pid=""
gpu_launcher_layer_only=""
gpu_launcher_capfile=""
gpu_launcher_exported_capfile=""
gpu_launcher_exported_capopts=""
gpu_launcher_debug_log_file=""
gpu_launcher_exported_debug_log_file=""
renderdoc_debug_log_file_status=""
renderdoc_debug_log_reason=""
renderdoc_debug_log_loaded_status=""
renderdoc_debug_log_vulkan_hooks_status=""
gpu_launcher_flag=""
if [ "$USE_GPU_LAUNCHER" = "1" ]; then
    gpu_launcher_flag="--gpu-launcher=$ROOT_DIR/scripts/tool/renderdoc-gpu-launcher.shs"
fi

write_env() {
    {
        echo "rdoc_chrome_x11_hotkey_status=$status"
        echo "rdoc_chrome_x11_hotkey_reason=$reason"
        echo "rdoc_chrome_x11_hotkey_html_path=$HTML_PATH"
        echo "rdoc_chrome_x11_hotkey_chrome=$CHROME_BIN"
        echo "rdoc_chrome_x11_hotkey_renderdoc_home=$RENDERDOC_HOME"
        echo "rdoc_chrome_x11_hotkey_capopts=$CAPOPTS"
        echo "rdoc_chrome_x11_hotkey_launch_flags=$chrome_launch_flags"
        echo "rdoc_chrome_x11_hotkey_use_gpu_launcher=$USE_GPU_LAUNCHER"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher=$ROOT_DIR/scripts/tool/renderdoc-gpu-launcher.shs"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_log=$gpu_launcher_log"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_invoked=$gpu_launcher_invoked"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_pid=$gpu_launcher_pid"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_exec_pid=$gpu_launcher_exec_pid"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_pid_matches_gpu_pid=$gpu_launcher_pid_matches_gpu_pid"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_layer_only=$gpu_launcher_layer_only"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_capfile=$gpu_launcher_capfile"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_exported_capfile=$gpu_launcher_exported_capfile"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_exported_capopts=$gpu_launcher_exported_capopts"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_debug_log_file=$gpu_launcher_debug_log_file"
        echo "rdoc_chrome_x11_hotkey_gpu_launcher_exported_debug_log_file=$gpu_launcher_exported_debug_log_file"
        echo "rdoc_chrome_x11_hotkey_renderdoc_debug_log_file_status=$renderdoc_debug_log_file_status"
        echo "rdoc_chrome_x11_hotkey_renderdoc_debug_log_reason=$renderdoc_debug_log_reason"
        echo "rdoc_chrome_x11_hotkey_renderdoc_debug_log_loaded_status=$renderdoc_debug_log_loaded_status"
        echo "rdoc_chrome_x11_hotkey_renderdoc_debug_log_vulkan_hooks_status=$renderdoc_debug_log_vulkan_hooks_status"
        echo "rdoc_chrome_x11_hotkey_capture_file=$capture_file"
        echo "rdoc_chrome_x11_hotkey_capture_magic=$capture_magic"
        echo "rdoc_chrome_x11_hotkey_chosen_window=$chosen_window"
        echo "rdoc_chrome_x11_hotkey_chosen_window_pid=$chosen_window_pid"
        echo "rdoc_chrome_x11_hotkey_chosen_window_pid_matches_gpu_pid=$chosen_window_pid_matches_gpu_pid"
        echo "rdoc_chrome_x11_hotkey_gpu_pid=$gpu_pid"
        echo "rdoc_chrome_x11_hotkey_gpu_env_has_layer=$gpu_env_has_layer"
        echo "rdoc_chrome_x11_hotkey_gpu_env_has_capfile=$gpu_env_has_capfile"
        echo "rdoc_chrome_x11_hotkey_gpu_env_has_capopts=$gpu_env_has_capopts"
        echo "rdoc_chrome_x11_hotkey_gpu_maps_has_renderdoc=$gpu_maps_has_renderdoc"
        echo "rdoc_chrome_x11_hotkey_gpu_maps_has_vulkan=$gpu_maps_has_vulkan"
        echo "rdoc_chrome_x11_hotkey_gpu_process_exit_status=$gpu_process_exit_status"
        echo "rdoc_chrome_x11_hotkey_gpu_process_exit_count=$gpu_process_exit_count"
        echo "rdoc_chrome_x11_hotkey_gpu_process_exit_codes=$gpu_process_exit_codes"
        echo "rdoc_chrome_x11_hotkey_gpu_process_exit_reason=$gpu_process_exit_reason"
        echo "rdoc_chrome_x11_hotkey_discovery_log=$BUILD_DIR/discovery.log"
        echo "rdoc_chrome_x11_hotkey_chrome_log=$BUILD_DIR/chrome.log"
        echo "rdoc_chrome_x11_hotkey_xdotool_log=$BUILD_DIR/xdotool.log"
        echo "rdoc_chrome_x11_hotkey_required_magic=RDOC"
        echo "rdoc_chrome_x11_hotkey_required_api=vulkan"
        echo "rdoc_chrome_x11_hotkey_required_angle=vulkan"
    } >"$OUT_ENV"
    {
        echo "# Chrome X11 RenderDoc Layer Hotkey Probe"
        echo
        echo "- status: $status"
        echo "- reason: $reason"
        echo "- capture: $capture_file"
        echo "- magic: $capture_magic"
        echo "- window: $chosen_window"
        echo "- window pid: $chosen_window_pid"
        echo "- window pid matches gpu pid: $chosen_window_pid_matches_gpu_pid"
        echo "- gpu pid: $gpu_pid"
        echo "- gpu launcher invoked: $gpu_launcher_invoked"
        echo "- gpu launcher pid: $gpu_launcher_pid"
        echo "- gpu launcher exec pid: $gpu_launcher_exec_pid"
        echo "- gpu launcher pid matches gpu pid: $gpu_launcher_pid_matches_gpu_pid"
        echo "- gpu launcher layer only: $gpu_launcher_layer_only"
        echo "- gpu launcher capfile: $gpu_launcher_capfile"
        echo "- gpu launcher exported capfile: $gpu_launcher_exported_capfile"
        echo "- gpu launcher exported debug log: $gpu_launcher_exported_debug_log_file"
        echo "- RenderDoc debug log status: $renderdoc_debug_log_file_status"
        echo "- RenderDoc debug log reason: $renderdoc_debug_log_reason"
        echo "- RenderDoc loaded status: $renderdoc_debug_log_loaded_status"
        echo "- RenderDoc Vulkan hooks status: $renderdoc_debug_log_vulkan_hooks_status"
        echo "- gpu env capfile: $gpu_env_has_capfile"
        echo "- gpu maps renderdoc: $gpu_maps_has_renderdoc"
        echo "- gpu maps vulkan: $gpu_maps_has_vulkan"
        echo "- gpu process exits: $gpu_process_exit_status count=$gpu_process_exit_count codes=$gpu_process_exit_codes"
        echo
        echo "## Raw Evidence"
        sed 's/^/- /' "$OUT_ENV"
    } >"$REPORT_PATH"
}

if [ ! -x "$CHROME_BIN" ]; then
    reason="missing-chrome"
    write_env
    cat "$OUT_ENV"
    exit 1
fi
if [ ! -s "$HTML_PATH" ]; then
    reason="missing-html-fixture"
    write_env
    cat "$OUT_ENV"
    exit 1
fi
if [ ! -s "$RENDERDOC_HOME/etc/vulkan/implicit_layer.d/renderdoc_capture.json" ]; then
    reason="missing-renderdoc-vulkan-layer"
    write_env
    cat "$OUT_ENV"
    exit 1
fi
if ! command -v xdotool >/dev/null 2>&1; then
    reason="missing-xdotool"
    write_env
    cat "$OUT_ENV"
    exit 1
fi

sed "s#/io/dist/lib/librenderdoc.so#$RENDERDOC_HOME/lib/librenderdoc.so#g" \
    "$RENDERDOC_HOME/etc/vulkan/implicit_layer.d/renderdoc_capture.json" \
    >"$BUILD_DIR/vulkan-layer.d/renderdoc_capture.json"

url="file://$HTML_PATH"
LD_LIBRARY_PATH="$RENDERDOC_HOME/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
VK_LAYER_PATH="$ROOT_DIR/$BUILD_DIR/vulkan-layer.d" \
VK_IMPLICIT_LAYER_PATH="$ROOT_DIR/$BUILD_DIR/vulkan-layer.d" \
VK_INSTANCE_LAYERS=VK_LAYER_RENDERDOC_Capture \
ENABLE_VULKAN_RENDERDOC_CAPTURE=1 \
RENDERDOC_CAPFILE="$ROOT_DIR/$BUILD_DIR/chrome_x11_hotkey" \
RENDERDOC_CAPOPTS="$CAPOPTS" \
RDOC_GPU_LAUNCHER_CAPTURE_PREFIX="$ROOT_DIR/$BUILD_DIR/chrome_x11_hotkey_gpu" \
RDOC_GPU_LAUNCHER_LOG="$ROOT_DIR/$gpu_launcher_log" \
RDOC_GPU_LAUNCHER_DEBUG_LOG_FILE="$ROOT_DIR/$BUILD_DIR/renderdoc-layer.log" \
RDOC_GPU_LAUNCHER_LAYER_ONLY="$USE_GPU_LAUNCHER" \
RDOC_GPU_LAUNCHER_CAPOPTS="$CAPOPTS" \
"$CHROME_BIN" \
    $chrome_launch_flags \
    $gpu_launcher_flag \
    --no-first-run \
    --no-default-browser-check \
    --disable-search-engine-choice-screen \
    --disable-features=Translate,OptimizationHints,MediaRouter \
    --disable-crash-reporter \
    --disable-breakpad \
    --user-data-dir="$ROOT_DIR/$BUILD_DIR/profile" \
    --window-size="${WIDTH},${HEIGHT}" \
    --app="$url" >"$BUILD_DIR/chrome.log" 2>&1 &
chrome_pid=$!
echo "$chrome_pid" >"$BUILD_DIR/chrome.pid"

sleep "$WAIT_SECS"

{
    echo "parent=$chrome_pid"
    echo "children:"
    ps -o pid,ppid,stat,cmd --ppid "$chrome_pid" || true
    echo "windows-by-pid:"
    xdotool search --pid "$chrome_pid" 2>/dev/null | while read -r wid; do
        xdotool getwindowname "$wid" 2>/dev/null | sed "s/^/$wid /"
    done || true
} >"$BUILD_DIR/discovery.log"

chosen_window="$(xdotool search --pid "$chrome_pid" 2>/dev/null | tail -n 1 || true)"
if [ "$chosen_window" != "" ]; then
    chosen_window_pid="$(xdotool getwindowpid "$chosen_window" 2>/dev/null || true)"
fi
gpu_pid="$(pgrep -P "$chrome_pid" -af -- '--type=gpu-process' | awk 'NR==1 { print $1 }' || true)"
if [ "$chosen_window_pid" != "" ] && [ "$gpu_pid" != "" ]; then
    if [ "$chosen_window_pid" = "$gpu_pid" ]; then
        chosen_window_pid_matches_gpu_pid="1"
    else
        chosen_window_pid_matches_gpu_pid="0"
    fi
fi
if [ "$gpu_pid" != "" ] && [ -r "/proc/$gpu_pid/environ" ]; then
    tr '\0' '\n' <"/proc/$gpu_pid/environ" >"$BUILD_DIR/gpu.env" 2>/dev/null || true
    if grep -q '^VK_INSTANCE_LAYERS=VK_LAYER_RENDERDOC_Capture$' "$BUILD_DIR/gpu.env"; then
        gpu_env_has_layer="1"
    else
        gpu_env_has_layer="0"
    fi
    if grep -q '^RENDERDOC_CAPFILE=' "$BUILD_DIR/gpu.env"; then
        gpu_env_has_capfile="1"
    else
        gpu_env_has_capfile="0"
    fi
    if grep -q '^RENDERDOC_CAPOPTS=' "$BUILD_DIR/gpu.env"; then
        gpu_env_has_capopts="1"
    else
        gpu_env_has_capopts="0"
    fi
fi
if [ "$gpu_pid" != "" ] && [ -r "/proc/$gpu_pid/maps" ]; then
    if grep -q 'librenderdoc' "/proc/$gpu_pid/maps"; then
        gpu_maps_has_renderdoc="1"
    else
        gpu_maps_has_renderdoc="0"
    fi
    if grep -q 'libvulkan' "/proc/$gpu_pid/maps"; then
        gpu_maps_has_vulkan="1"
    else
        gpu_maps_has_vulkan="0"
    fi
    cp "/proc/$gpu_pid/maps" "$BUILD_DIR/gpu.maps" 2>/dev/null || true
fi

if [ "$chosen_window" != "" ]; then
    xdotool windowactivate --sync "$chosen_window" >>"$BUILD_DIR/xdotool.log" 2>&1 || true
    for key in F11 F12 Print F12; do
        xdotool keydown "$key" >>"$BUILD_DIR/xdotool.log" 2>&1 || true
        sleep 1
        xdotool keyup "$key" >>"$BUILD_DIR/xdotool.log" 2>&1 || true
        sleep 2
    done
fi

sleep 5
if [ -s "$gpu_launcher_log" ]; then
    gpu_launcher_invoked="1"
    gpu_launcher_pid="$(sed -n 's/^renderdoc_gpu_launcher_pid=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_exec_pid="$(sed -n 's/^renderdoc_gpu_launcher_layer_only_exec_pid=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_layer_only="$(sed -n 's/^renderdoc_gpu_launcher_layer_only=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_capfile="$(sed -n 's/^renderdoc_gpu_launcher_capfile=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_debug_log_file="$(sed -n 's/^renderdoc_gpu_launcher_debug_log_file=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_exported_capfile="$(sed -n 's/^renderdoc_gpu_launcher_layer_only_exported_capfile=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_exported_capopts="$(sed -n 's/^renderdoc_gpu_launcher_layer_only_exported_capopts=//p' "$gpu_launcher_log" | tail -n 1)"
    gpu_launcher_exported_debug_log_file="$(sed -n 's/^renderdoc_gpu_launcher_layer_only_exported_debug_log_file=//p' "$gpu_launcher_log" | tail -n 1)"
else
    gpu_launcher_invoked="0"
fi
if [ "$gpu_launcher_exported_debug_log_file" != "" ] && [ -s "$gpu_launcher_exported_debug_log_file" ]; then
    renderdoc_debug_log_file_status="pass"
    if grep -q 'Loading into /opt/google/chrome/chrome' "$gpu_launcher_exported_debug_log_file"; then
        renderdoc_debug_log_loaded_status="pass"
    else
        renderdoc_debug_log_loaded_status="missing"
    fi
    if grep -q 'Registering Vulkan hooks' "$gpu_launcher_exported_debug_log_file"; then
        renderdoc_debug_log_vulkan_hooks_status="pass"
    else
        renderdoc_debug_log_vulkan_hooks_status="missing"
    fi
    if grep -E 'RENDERDOC_CAPFILE|CAPFILE|capture|Capture|error|Error|failed|Failed' "$gpu_launcher_exported_debug_log_file" >/dev/null 2>&1; then
        renderdoc_debug_log_reason="$(grep -E 'RENDERDOC_CAPFILE|CAPFILE|capture|Capture|error|Error|failed|Failed' "$gpu_launcher_exported_debug_log_file" 2>/dev/null | head -1 | tr '=' ':' | tr -d '\r' | cut -c1-180)"
    else
        renderdoc_debug_log_reason="no-capture-or-error-lines"
    fi
elif [ "$gpu_launcher_exported_debug_log_file" != "" ]; then
    renderdoc_debug_log_file_status="missing"
    renderdoc_debug_log_reason="debug-log-not-written"
    renderdoc_debug_log_loaded_status="missing"
    renderdoc_debug_log_vulkan_hooks_status="missing"
else
    renderdoc_debug_log_file_status="not-configured"
    renderdoc_debug_log_reason="missing-debug-log-file-path"
    renderdoc_debug_log_loaded_status="not-configured"
    renderdoc_debug_log_vulkan_hooks_status="not-configured"
fi
if [ "$gpu_launcher_exec_pid" != "" ] && [ "$gpu_pid" != "" ]; then
    if [ "$gpu_launcher_exec_pid" = "$gpu_pid" ]; then
        gpu_launcher_pid_matches_gpu_pid="1"
    else
        gpu_launcher_pid_matches_gpu_pid="0"
    fi
fi
gpu_exit_env="$BUILD_DIR/gpu-process-exit.env"
rdoc_emit_chromium_gpu_process_exit_metadata "$BUILD_DIR/chrome.log" >"$gpu_exit_env"
gpu_process_exit_status="$(sed -n 's/^rdoc_chromium_gpu_process_exit_status=//p' "$gpu_exit_env" | tail -n 1)"
gpu_process_exit_count="$(sed -n 's/^rdoc_chromium_gpu_process_exit_count=//p' "$gpu_exit_env" | tail -n 1)"
gpu_process_exit_codes="$(sed -n 's/^rdoc_chromium_gpu_process_exit_codes=//p' "$gpu_exit_env" | tail -n 1)"
gpu_process_exit_reason="$(sed -n 's/^rdoc_chromium_gpu_process_exit_reason=//p' "$gpu_exit_env" | tail -n 1)"
find "$BUILD_DIR" -name '*.rdc' -print >"$BUILD_DIR/rdc.list"
capture_file="$(head -n 1 "$BUILD_DIR/rdc.list" || true)"
if [ -n "$capture_file" ] && [ -s "$capture_file" ]; then
    capture_magic="$(dd if="$capture_file" bs=4 count=1 2>/dev/null || true)"
fi

kill "$chrome_pid" 2>/dev/null || true
sleep 1

if [ "$capture_magic" = "RDOC" ]; then
    status="pass"
    reason="pass"
elif [ "$gpu_process_exit_status" = "fail" ]; then
    status="fail"
    reason="chromium-gpu-process-crashed-under-renderdoc-layer-hotkey"
elif [ "$chosen_window" = "" ]; then
    status="fail"
    reason="missing-x11-window"
elif [ "$gpu_pid" = "" ]; then
    status="fail"
    reason="missing-gpu-process"
elif [ "$gpu_maps_has_renderdoc" != "1" ]; then
    status="fail"
    reason="renderdoc-layer-not-mapped-in-gpu-process"
elif [ "$gpu_maps_has_vulkan" != "1" ]; then
    status="fail"
    reason="vulkan-not-mapped-in-gpu-process"
elif [ "$renderdoc_debug_log_loaded_status" = "pass" ] && [ "$chosen_window_pid_matches_gpu_pid" = "0" ]; then
    status="fail"
    reason="hotkey-window-owned-by-browser-not-renderdoc-gpu-process"
elif [ "$gpu_env_has_capfile" != "1" ]; then
    status="fail"
    if [ "$renderdoc_debug_log_loaded_status" = "pass" ] && [ "$renderdoc_debug_log_vulkan_hooks_status" = "pass" ]; then
        reason="renderdoc-layer-loaded-vulkan-hooks-but-hotkey-produced-no-rdc"
    elif [ "$USE_GPU_LAUNCHER" = "1" ] && [ "$gpu_launcher_pid_matches_gpu_pid" = "1" ] && [ "$gpu_launcher_exported_capfile" != "" ]; then
        reason="renderdoc-capfile-exported-before-exec-but-cleared-in-gpu-process"
    elif [ "$USE_GPU_LAUNCHER" = "1" ] && [ "$gpu_launcher_invoked" = "1" ]; then
        reason="renderdoc-gpu-launcher-capfile-not-visible-in-gpu-proc-env"
    else
        reason="renderdoc-capfile-env-not-propagated-to-gpu-process"
    fi
else
    status="fail"
    reason="renderdoc-layer-mapped-but-hotkey-produced-no-rdc"
fi

write_env
cat "$OUT_ENV"
[ "$status" = "pass" ]
