#!/bin/sh
# Diagnostic Chrome-on-X11 RenderDoc Vulkan-layer hotkey capture probe.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/renderdoc/chrome-x11-layer-hotkey}"
OUT_ENV="$BUILD_DIR/evidence.env"
REPORT_PATH="${REPORT_PATH:-doc/09_report/renderdoc_chrome_x11_layer_hotkey_$(date -u +%F).md}"
HTML_PATH="${RDOC_HTML_PATH:-$ROOT_DIR/test/fixtures/html_css/generated_gui_vulkan_renderdoc_fixture.html}"
CHROME_BIN="${RDOC_CHROME:-/usr/bin/google-chrome}"
RENDERDOC_HOME="${RDOC_HOME:-/opt/renderdoc}"
WIDTH="${RDOC_CHROME_WIDTH:-900}"
HEIGHT="${RDOC_CHROME_HEIGHT:-700}"
WAIT_SECS="${RDOC_CHROME_HOTKEY_WAIT_SECS:-8}"
CAPOPTS="${RDOC_CAPOPTS:-}"

mkdir -p "$BUILD_DIR/vulkan-layer.d" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$BUILD_DIR/rdc.list"

status="fail"
reason="not-run"
capture_file=""
capture_magic=""
chosen_window=""
gpu_pid=""
gpu_env_has_layer=""
gpu_maps_has_renderdoc=""
gpu_maps_has_vulkan=""

write_env() {
    {
        echo "rdoc_chrome_x11_hotkey_status=$status"
        echo "rdoc_chrome_x11_hotkey_reason=$reason"
        echo "rdoc_chrome_x11_hotkey_html_path=$HTML_PATH"
        echo "rdoc_chrome_x11_hotkey_chrome=$CHROME_BIN"
        echo "rdoc_chrome_x11_hotkey_renderdoc_home=$RENDERDOC_HOME"
        echo "rdoc_chrome_x11_hotkey_capopts=$CAPOPTS"
        echo "rdoc_chrome_x11_hotkey_capture_file=$capture_file"
        echo "rdoc_chrome_x11_hotkey_capture_magic=$capture_magic"
        echo "rdoc_chrome_x11_hotkey_chosen_window=$chosen_window"
        echo "rdoc_chrome_x11_hotkey_gpu_pid=$gpu_pid"
        echo "rdoc_chrome_x11_hotkey_gpu_env_has_layer=$gpu_env_has_layer"
        echo "rdoc_chrome_x11_hotkey_gpu_maps_has_renderdoc=$gpu_maps_has_renderdoc"
        echo "rdoc_chrome_x11_hotkey_gpu_maps_has_vulkan=$gpu_maps_has_vulkan"
        echo "rdoc_chrome_x11_hotkey_discovery_log=$BUILD_DIR/discovery.log"
        echo "rdoc_chrome_x11_hotkey_chrome_log=$BUILD_DIR/chrome.log"
        echo "rdoc_chrome_x11_hotkey_xdotool_log=$BUILD_DIR/xdotool.log"
        echo "rdoc_chrome_x11_hotkey_required_magic=RDOC"
        echo "rdoc_chrome_x11_hotkey_required_api=vulkan"
        echo "rdoc_chrome_x11_hotkey_required_angle=vulkan"
    } >"$OUT_ENV"
    {
        echo "# Chrome X11 RenderDoc Layer Hotkey Probe"
        echo
        echo "- status: $status"
        echo "- reason: $reason"
        echo "- capture: $capture_file"
        echo "- magic: $capture_magic"
        echo "- window: $chosen_window"
        echo "- gpu pid: $gpu_pid"
    } >"$REPORT_PATH"
}

if [ ! -x "$CHROME_BIN" ]; then
    reason="missing-chrome"
    write_env
    cat "$OUT_ENV"
    exit 1
fi
if [ ! -s "$HTML_PATH" ]; then
    reason="missing-html-fixture"
    write_env
    cat "$OUT_ENV"
    exit 1
fi
if [ ! -s "$RENDERDOC_HOME/etc/vulkan/implicit_layer.d/renderdoc_capture.json" ]; then
    reason="missing-renderdoc-vulkan-layer"
    write_env
    cat "$OUT_ENV"
    exit 1
fi
if ! command -v xdotool >/dev/null 2>&1; then
    reason="missing-xdotool"
    write_env
    cat "$OUT_ENV"
    exit 1
fi

sed "s#/io/dist/lib/librenderdoc.so#$RENDERDOC_HOME/lib/librenderdoc.so#g" \
    "$RENDERDOC_HOME/etc/vulkan/implicit_layer.d/renderdoc_capture.json" \
    >"$BUILD_DIR/vulkan-layer.d/renderdoc_capture.json"

url="file://$HTML_PATH"
LD_LIBRARY_PATH="$RENDERDOC_HOME/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
VK_LAYER_PATH="$ROOT_DIR/$BUILD_DIR/vulkan-layer.d" \
VK_INSTANCE_LAYERS=VK_LAYER_RENDERDOC_Capture \
ENABLE_VULKAN_RENDERDOC_CAPTURE=1 \
RENDERDOC_CAPFILE="$ROOT_DIR/$BUILD_DIR/chrome_x11_hotkey" \
RENDERDOC_CAPOPTS="$CAPOPTS" \
"$CHROME_BIN" \
    --ozone-platform=x11 \
    --no-first-run \
    --no-default-browser-check \
    --disable-search-engine-choice-screen \
    --disable-features=Translate,OptimizationHints,MediaRouter \
    --no-sandbox \
    --disable-gpu-sandbox \
    --disable-dev-shm-usage \
    --disable-crash-reporter \
    --disable-breakpad \
    --enable-features=Vulkan \
    --use-angle=vulkan \
    --user-data-dir="$ROOT_DIR/$BUILD_DIR/profile" \
    --window-size="${WIDTH},${HEIGHT}" \
    --app="$url" >"$BUILD_DIR/chrome.log" 2>&1 &
chrome_pid=$!
echo "$chrome_pid" >"$BUILD_DIR/chrome.pid"

sleep "$WAIT_SECS"

{
    echo "parent=$chrome_pid"
    echo "children:"
    ps -o pid,ppid,stat,cmd --ppid "$chrome_pid" || true
    echo "windows-by-pid:"
    xdotool search --pid "$chrome_pid" 2>/dev/null | while read -r wid; do
        xdotool getwindowname "$wid" 2>/dev/null | sed "s/^/$wid /"
    done || true
} >"$BUILD_DIR/discovery.log"

chosen_window="$(xdotool search --pid "$chrome_pid" 2>/dev/null | tail -n 1 || true)"
gpu_pid="$(pgrep -P "$chrome_pid" -af -- '--type=gpu-process' | awk 'NR==1 { print $1 }' || true)"
if [ "$gpu_pid" != "" ] && [ -r "/proc/$gpu_pid/environ" ]; then
    if tr '\0' '\n' <"/proc/$gpu_pid/environ" | grep -q '^VK_INSTANCE_LAYERS=VK_LAYER_RENDERDOC_Capture$'; then
        gpu_env_has_layer="1"
    else
        gpu_env_has_layer="0"
    fi
fi
if [ "$gpu_pid" != "" ] && [ -r "/proc/$gpu_pid/maps" ]; then
    if grep -q 'librenderdoc' "/proc/$gpu_pid/maps"; then
        gpu_maps_has_renderdoc="1"
    else
        gpu_maps_has_renderdoc="0"
    fi
    if grep -q 'libvulkan' "/proc/$gpu_pid/maps"; then
        gpu_maps_has_vulkan="1"
    else
        gpu_maps_has_vulkan="0"
    fi
    cp "/proc/$gpu_pid/maps" "$BUILD_DIR/gpu.maps" 2>/dev/null || true
fi

if [ "$chosen_window" != "" ]; then
    xdotool windowactivate --sync "$chosen_window" >>"$BUILD_DIR/xdotool.log" 2>&1 || true
    for key in F11 F12 Print F12; do
        xdotool keydown "$key" >>"$BUILD_DIR/xdotool.log" 2>&1 || true
        sleep 1
        xdotool keyup "$key" >>"$BUILD_DIR/xdotool.log" 2>&1 || true
        sleep 2
    done
fi

sleep 5
find "$BUILD_DIR" -name '*.rdc' -print >"$BUILD_DIR/rdc.list"
capture_file="$(head -n 1 "$BUILD_DIR/rdc.list" || true)"
if [ -n "$capture_file" ] && [ -s "$capture_file" ]; then
    capture_magic="$(dd if="$capture_file" bs=4 count=1 2>/dev/null || true)"
fi

kill "$chrome_pid" 2>/dev/null || true
sleep 1

if [ "$capture_magic" = "RDOC" ]; then
    status="pass"
    reason="pass"
else
    status="fail"
    reason="missing-rdc"
fi

write_env
cat "$OUT_ENV"
[ "$status" = "pass" ]
