#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/llm_dashboard_live_http}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_dashboard_live_http_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
BASE_URL="${LLM_DASHBOARD_LIVE_BASE_URL:-}"
TIMEOUT_SECONDS="${LLM_DASHBOARD_LIVE_HTTP_TIMEOUT_SECONDS:-10}"
SURFACE_MANIFEST="$BUILD_DIR/dashboard_live_http_surface_manifest.tsv"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH" "$SURFACE_MANIFEST"

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -f "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "missing"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -f "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

{
    for path in \
        scripts/check/check-llm-dashboard-live-http-evidence.shs \
        scripts/check/check-llm-dashboard-live-http-setup-contract.shs \
        scripts/check/check-llm-dashboard-live-evidence.shs \
        src/app/web_dashboard/server.spl \
        test/03_system/feature/app/web_dashboard/vllm_control_route_spec.spl \
        test/03_system/feature/app/web_dashboard/llm_agent_dashboard_spec.spl \
        doc/07_guide/app/dashboard.md \
        doc/07_guide/app/llm/llm_runtime_vllm_torch_interface.md
    do
        printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
    done
} >"$SURFACE_MANIFEST"
surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"

export LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST="$SURFACE_MANIFEST"
export LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_COUNT="$surface_manifest_count"
export LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_SIZE="$surface_manifest_size"
export LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_SHA256="$surface_manifest_sha256"

auth_source="missing"
auth_config_status="fail"
if [ -n "${LLM_DASHBOARD_LIVE_AUTH_HEADER:-}" ]; then
    if printf '%s\n' "$LLM_DASHBOARD_LIVE_AUTH_HEADER" | grep -F ':' >/dev/null 2>&1; then
        auth_source="auth_header"
        auth_config_status="pass"
    else
        auth_source="auth_header_invalid"
    fi
elif [ -n "${LLM_DASHBOARD_LIVE_AUTH_COOKIE:-}" ]; then
    auth_source="auth_cookie"
    auth_config_status="pass"
elif [ -n "${LLM_DASHBOARD_LIVE_COOKIE_NAME:-}" ] && [ -n "${LLM_DASHBOARD_LIVE_COOKIE_VALUE:-}" ]; then
    auth_source="cookie_pair"
    auth_config_status="pass"
fi

if [ -z "$BASE_URL" ]; then
    blocked_gates="base_url"
    if [ "$auth_config_status" != "pass" ]; then
        blocked_gates="base_url|auth_configured"
    fi
    next_action="set LLM_DASHBOARD_LIVE_BASE_URL and authentication env, then rerun this wrapper"
    {
        printf '%s\n' "llm_dashboard_live_http_status=fail"
        printf '%s\n' "llm_dashboard_live_http_reason=missing_base_url"
        printf '%s\n' "llm_dashboard_live_http_required_gates=base_url,auth_configured,unauth_api_rejected,authenticated_dashboard_html,authenticated_agents_html,authenticated_control_jsonl"
        printf '%s\n' "llm_dashboard_live_http_blocked_gates=$blocked_gates"
        printf '%s\n' "llm_dashboard_live_http_primary_blocked_gate=base_url"
        printf '%s\n' "llm_dashboard_live_http_base_url_status=missing"
        printf '%s\n' "llm_dashboard_live_http_base_url_scheme_status=not_collected"
        printf '%s\n' "llm_dashboard_live_http_auth_config_status=$auth_config_status"
        printf '%s\n' "llm_dashboard_live_http_auth_source=$auth_source"
        printf '%s\n' "llm_dashboard_live_http_timeout_seconds=$TIMEOUT_SECONDS"
        printf '%s\n' "llm_dashboard_live_http_dashboard_status=not_collected"
        printf '%s\n' "llm_dashboard_live_http_dashboard_code=not_collected"
        printf '%s\n' "llm_dashboard_live_http_dashboard_size=not_collected"
        printf '%s\n' "llm_dashboard_live_http_dashboard_sha256=not_collected"
        printf '%s\n' "llm_dashboard_live_http_agents_status=not_collected"
        printf '%s\n' "llm_dashboard_live_http_agents_code=not_collected"
        printf '%s\n' "llm_dashboard_live_http_agents_size=not_collected"
        printf '%s\n' "llm_dashboard_live_http_agents_sha256=not_collected"
        printf '%s\n' "llm_dashboard_live_http_control_status=not_collected"
        printf '%s\n' "llm_dashboard_live_http_control_code=not_collected"
        printf '%s\n' "llm_dashboard_live_http_control_size=not_collected"
        printf '%s\n' "llm_dashboard_live_http_control_sha256=not_collected"
        printf '%s\n' "llm_dashboard_live_http_unauth_api_status=not_collected"
        printf '%s\n' "llm_dashboard_live_http_unauth_api_code=not_collected"
        printf '%s\n' "llm_dashboard_live_http_unauth_api_size=not_collected"
        printf '%s\n' "llm_dashboard_live_http_unauth_api_sha256=not_collected"
        printf '%s\n' "llm_dashboard_live_http_surface_manifest=$SURFACE_MANIFEST"
        printf '%s\n' "llm_dashboard_live_http_surface_manifest_count=$surface_manifest_count"
        printf '%s\n' "llm_dashboard_live_http_surface_manifest_size=$surface_manifest_size"
        printf '%s\n' "llm_dashboard_live_http_surface_manifest_sha256=$surface_manifest_sha256"
        printf '%s\n' "llm_dashboard_live_http_pass_integrity_status=not_applicable"
        printf '%s\n' "llm_dashboard_live_http_pass_integrity_reason=missing_base_url"
        printf '%s\n' "llm_dashboard_live_http_next_action=$next_action"
    } >"$OUT_ENV"
    {
        printf '# LLM Dashboard Live HTTP Evidence\n\n'
        printf '%s\n' "- status: \`fail\`"
        printf '%s\n' "- reason: \`missing_base_url\`"
        printf '%s\n' "- required_gates: \`base_url,auth_configured,unauth_api_rejected,authenticated_dashboard_html,authenticated_agents_html,authenticated_control_jsonl\`"
        printf '%s\n' "- blocked_gates: \`$blocked_gates\`"
        printf '%s\n' "- primary_blocked_gate: \`base_url\`"
        printf '%s\n' "- base_url_status: \`missing\`"
        printf '%s\n' "- base_url_scheme_status: \`not_collected\`"
        printf '%s\n' "- auth_config_status: \`$auth_config_status\`"
        printf '%s\n' "- auth_source: \`$auth_source\`"
        printf '%s\n' "- timeout_seconds: \`$TIMEOUT_SECONDS\`"
        printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
        printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
        printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
        printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
        printf '%s\n' "- pass_integrity_status: \`not_applicable\`"
        printf '%s\n' "- pass_integrity_reason: \`missing_base_url\`"
        printf '%s\n' "- next_action: \`$next_action\`"
        printf '%s\n' "- env: \`$OUT_ENV\`"
        printf '\nSet `LLM_DASHBOARD_LIVE_BASE_URL` to the running dashboard origin and provide either `LLM_DASHBOARD_LIVE_AUTH_HEADER`, `LLM_DASHBOARD_LIVE_AUTH_COOKIE`, or `LLM_DASHBOARD_LIVE_COOKIE_NAME` plus `LLM_DASHBOARD_LIVE_COOKIE_VALUE`.\n'
    } >"$REPORT_PATH"
    echo "STATUS: FAIL llm-dashboard-live-http-evidence reason=missing_base_url"
    exit 1
fi

python3 - "$BASE_URL" "$TIMEOUT_SECONDS" "$OUT_ENV" "$REPORT_PATH" <<'PY'
import os
import hashlib
import sys
import urllib.error
import urllib.parse
import urllib.request

base_url, timeout_text, out_env, report_path = sys.argv[1:5]
timeout = float(timeout_text)
required = "base_url,auth_configured,unauth_api_rejected,authenticated_dashboard_html,authenticated_agents_html,authenticated_control_jsonl"
blocked = []
details = {}
parsed_base = urllib.parse.urlparse(base_url)
details["base_url_status"] = "configured" if base_url else "missing"
base_url_is_http = parsed_base.scheme in ("http", "https") and bool(parsed_base.netloc)
details["base_url_scheme_status"] = "configured" if base_url_is_http else "missing"
details["timeout_seconds"] = timeout_text


class NoRedirect(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


opener = urllib.request.build_opener(NoRedirect)


def env(name, default=""):
    return os.environ.get(name, default)


def join_url(path):
    return urllib.parse.urljoin(base_url.rstrip("/") + "/", path.lstrip("/"))


def auth_headers():
    headers = {}
    details["auth_source"] = "missing"
    raw_header = env("LLM_DASHBOARD_LIVE_AUTH_HEADER")
    if raw_header:
        if ":" not in raw_header:
            blocked.append("auth_configured")
            details["auth_header_reason"] = "missing_colon"
            details["auth_source"] = "auth_header_invalid"
            details["auth_config_status"] = "fail"
            return headers
        name, value = raw_header.split(":", 1)
        headers[name.strip()] = value.strip()
        details["auth_source"] = "auth_header"
        details["auth_config_status"] = "pass"
        return headers
    cookie = env("LLM_DASHBOARD_LIVE_AUTH_COOKIE")
    if cookie:
        headers["Cookie"] = cookie
        details["auth_source"] = "auth_cookie"
        details["auth_config_status"] = "pass"
        return headers
    if "LLM_DASHBOARD_LIVE_COOKIE_NAME" in os.environ and "LLM_DASHBOARD_LIVE_COOKIE_VALUE" in os.environ:
        name = env("LLM_DASHBOARD_LIVE_COOKIE_NAME")
        value = env("LLM_DASHBOARD_LIVE_COOKIE_VALUE")
        cookie = f"{name}={value}"
        headers["Cookie"] = cookie
        details["auth_source"] = "cookie_pair"
        details["auth_config_status"] = "pass"
        return headers
    blocked.append("auth_configured")
    details["auth_header_reason"] = "missing_auth_env"
    details["auth_config_status"] = "fail"
    return headers


def request(path, headers):
    req = urllib.request.Request(join_url(path), headers=headers, method="GET")
    try:
        with opener.open(req, timeout=timeout) as resp:
            body = resp.read(200000)
            return resp.getcode(), body, body.decode("utf-8", "replace")
    except urllib.error.HTTPError as exc:
        body = exc.read(200000)
        return exc.code, body, body.decode("utf-8", "replace")
    except Exception as exc:
        text = f"{type(exc).__name__}:{exc}"
        return -1, text.encode("utf-8"), text


def gate(name, ok, reason):
    details[f"{name}_status"] = "pass" if ok else "fail"
    details[f"{name}_reason"] = reason
    if not ok:
        blocked.append(name)


def record_response(name, code, body_bytes):
    details[f"{name}_code"] = str(code)
    details[f"{name}_size"] = str(len(body_bytes))
    details[f"{name}_sha256"] = hashlib.sha256(body_bytes).hexdigest() if body_bytes else "missing"


headers = {}
if not base_url_is_http:
    if "base_url" not in blocked:
        blocked.append("base_url")
    details["base_url_reason"] = "missing_or_invalid_http_scheme"
    details["base_url_scheme_status"] = "missing" if not parsed_base.scheme else "invalid"
    headers = auth_headers()
    for skipped_name in ("unauth_api", "dashboard", "agents", "control"):
        details[f"{skipped_name}_status"] = "not_collected"
        details[f"{skipped_name}_reason"] = "base_url_missing_scheme"
        details[f"{skipped_name}_code"] = "not_collected"
        details[f"{skipped_name}_size"] = "not_collected"
        details[f"{skipped_name}_sha256"] = "not_collected"
else:
    headers = auth_headers()
    unauth_code, unauth_bytes, unauth_body = request("/api/vllm/control?action=preflight", {})
    record_response("unauth_api", unauth_code, unauth_bytes)
    gate("unauth_api", unauth_code == 401 and "Authentication required" in unauth_body, f"http_{unauth_code}")

    dashboard_code, dashboard_bytes, dashboard_body = request("/", headers)
    record_response("dashboard", dashboard_code, dashboard_bytes)
    gate(
        "dashboard",
        dashboard_code == 200 and "llm-vllm-control-panel" in dashboard_body,
        f"http_{dashboard_code}",
    )

    agents_code, agents_bytes, agents_body = request("/agents", headers)
    record_response("agents", agents_code, agents_bytes)
    gate(
        "agents",
        agents_code == 200 and "agent-dashboard" in agents_body,
        f"http_{agents_code}",
    )

    control_code, control_bytes, control_body = request("/api/vllm/control?action=preflight", headers)
    record_response("control", control_code, control_bytes)
    gate(
        "control",
        control_code == 200 and "llm_runtime_vllm_dashboard_live_boundary" in control_body,
        f"http_{control_code}",
    )

status = "pass" if not blocked else "fail"
reason = "authenticated_live_http_passed" if status == "pass" else "dashboard_live_http_probe_failed"
blocked_gates = "none" if not blocked else "|".join(dict.fromkeys(blocked))
primary = "none" if blocked_gates == "none" else blocked_gates.split("|", 1)[0]
next_action = "strict live dashboard HTTP evidence is ready"
if status != "pass":
    next_action = f"fix live dashboard HTTP gate: {primary}"

pass_integrity_status = "not_applicable"
pass_integrity_reason = "not_applicable"
if status == "pass":
    pass_integrity_status = "pass"
    pass_integrity_reason = "all_live_http_proof_fields_present"
    expected = {
        "unauth_api": "401",
        "dashboard": "200",
        "agents": "200",
        "control": "200",
    }
    if details.get("auth_source", "missing") == "missing":
        pass_integrity_status = "fail"
        pass_integrity_reason = "auth_source_missing"
    for name, code in expected.items():
        if pass_integrity_status != "pass":
            break
        if details.get(f"{name}_status") != "pass":
            pass_integrity_status = "fail"
            pass_integrity_reason = f"{name}_gate_not_pass"
            break
        if details.get(f"{name}_code") != code:
            pass_integrity_status = "fail"
            pass_integrity_reason = f"{name}_code_not_{code}"
            break
        if int(details.get(f"{name}_size", "0") or "0") <= 0:
            pass_integrity_status = "fail"
            pass_integrity_reason = f"{name}_body_empty"
            break
        if details.get(f"{name}_sha256", "missing") == "missing":
            pass_integrity_status = "fail"
            pass_integrity_reason = f"{name}_sha256_missing"
            break
    if pass_integrity_status != "pass":
        status = "fail"
        reason = f"live_http_pass_integrity_failed:{pass_integrity_reason}"
        blocked_gates = "live_http_pass_integrity"
        primary = "live_http_pass_integrity"
        next_action = "fix live dashboard HTTP proof fields and rerun this wrapper"

with open(out_env, "w", encoding="utf-8") as f:
    f.write(f"llm_dashboard_live_http_status={status}\n")
    f.write(f"llm_dashboard_live_http_reason={reason}\n")
    f.write(f"llm_dashboard_live_http_required_gates={required}\n")
    f.write(f"llm_dashboard_live_http_blocked_gates={blocked_gates}\n")
    f.write(f"llm_dashboard_live_http_primary_blocked_gate={primary}\n")
    f.write(f"llm_dashboard_live_http_base_url_status={details.get('base_url_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_base_url_scheme_status={details.get('base_url_scheme_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_auth_config_status={details.get('auth_config_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_auth_source={details.get('auth_source', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_timeout_seconds={details.get('timeout_seconds', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_dashboard_status={details.get('dashboard_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_dashboard_reason={details.get('dashboard_reason', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_dashboard_code={details.get('dashboard_code', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_dashboard_size={details.get('dashboard_size', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_dashboard_sha256={details.get('dashboard_sha256', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_agents_status={details.get('agents_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_agents_reason={details.get('agents_reason', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_agents_code={details.get('agents_code', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_agents_size={details.get('agents_size', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_agents_sha256={details.get('agents_sha256', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_control_status={details.get('control_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_control_reason={details.get('control_reason', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_control_code={details.get('control_code', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_control_size={details.get('control_size', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_control_sha256={details.get('control_sha256', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_unauth_api_status={details.get('unauth_api_status', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_unauth_api_reason={details.get('unauth_api_reason', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_unauth_api_code={details.get('unauth_api_code', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_unauth_api_size={details.get('unauth_api_size', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_unauth_api_sha256={details.get('unauth_api_sha256', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_surface_manifest={os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_surface_manifest_count={os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_COUNT', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_surface_manifest_size={os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_SIZE', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_surface_manifest_sha256={os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_SHA256', 'not_collected')}\n")
    f.write(f"llm_dashboard_live_http_pass_integrity_status={pass_integrity_status}\n")
    f.write(f"llm_dashboard_live_http_pass_integrity_reason={pass_integrity_reason}\n")
    f.write(f"llm_dashboard_live_http_next_action={next_action}\n")

with open(report_path, "w", encoding="utf-8") as f:
    f.write("# LLM Dashboard Live HTTP Evidence\n\n")
    f.write(f"- status: `{status}`\n")
    f.write(f"- reason: `{reason}`\n")
    f.write(f"- required_gates: `{required}`\n")
    f.write(f"- blocked_gates: `{blocked_gates}`\n")
    f.write(f"- primary_blocked_gate: `{primary}`\n")
    f.write(f"- base_url_status: `{details.get('base_url_status', 'not_collected')}`\n")
    f.write(f"- base_url_scheme_status: `{details.get('base_url_scheme_status', 'not_collected')}`\n")
    f.write(f"- auth_config_status: `{details.get('auth_config_status', 'not_collected')}`\n")
    f.write(f"- auth_source: `{details.get('auth_source', 'not_collected')}`\n")
    f.write(f"- timeout_seconds: `{details.get('timeout_seconds', 'not_collected')}`\n")
    f.write(f"- dashboard_status: `{details.get('dashboard_status', 'not_collected')}`\n")
    f.write(f"- dashboard_code: `{details.get('dashboard_code', 'not_collected')}`\n")
    f.write(f"- dashboard_size: `{details.get('dashboard_size', 'not_collected')}`\n")
    f.write(f"- dashboard_sha256: `{details.get('dashboard_sha256', 'not_collected')}`\n")
    f.write(f"- agents_status: `{details.get('agents_status', 'not_collected')}`\n")
    f.write(f"- agents_code: `{details.get('agents_code', 'not_collected')}`\n")
    f.write(f"- agents_size: `{details.get('agents_size', 'not_collected')}`\n")
    f.write(f"- agents_sha256: `{details.get('agents_sha256', 'not_collected')}`\n")
    f.write(f"- control_status: `{details.get('control_status', 'not_collected')}`\n")
    f.write(f"- control_code: `{details.get('control_code', 'not_collected')}`\n")
    f.write(f"- control_size: `{details.get('control_size', 'not_collected')}`\n")
    f.write(f"- control_sha256: `{details.get('control_sha256', 'not_collected')}`\n")
    f.write(f"- unauth_api_status: `{details.get('unauth_api_status', 'not_collected')}`\n")
    f.write(f"- unauth_api_code: `{details.get('unauth_api_code', 'not_collected')}`\n")
    f.write(f"- unauth_api_size: `{details.get('unauth_api_size', 'not_collected')}`\n")
    f.write(f"- unauth_api_sha256: `{details.get('unauth_api_sha256', 'not_collected')}`\n")
    f.write(f"- surface_manifest: `{os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST', 'not_collected')}`\n")
    f.write(f"- surface_manifest_count: `{os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_COUNT', 'not_collected')}`\n")
    f.write(f"- surface_manifest_size: `{os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_SIZE', 'not_collected')}`\n")
    f.write(f"- surface_manifest_sha256: `{os.environ.get('LLM_DASHBOARD_LIVE_HTTP_SURFACE_MANIFEST_SHA256', 'not_collected')}`\n")
    f.write(f"- pass_integrity_status: `{pass_integrity_status}`\n")
    f.write(f"- pass_integrity_reason: `{pass_integrity_reason}`\n")
    f.write(f"- next_action: `{next_action}`\n")
    f.write(f"- env: `{out_env}`\n\n")
    f.write("This wrapper probes a configured running dashboard origin and writes the live HTTP env consumed by `check-llm-dashboard-live-evidence.shs`. A PASS requires an explicit authentication source, exact HTTP status codes, route markers, non-empty response bodies, and SHA-256 fingerprints for the unauthenticated API rejection, dashboard HTML, agents HTML, and authenticated control JSONL responses. It records only the authentication source type and does not print authentication secrets or claim live vLLM model serving.\n")

print(f"STATUS: {status.upper()} llm-dashboard-live-http-evidence reason={reason}")
sys.exit(0 if status == "pass" else 1)
PY
