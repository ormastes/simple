#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

PLAN_PATH="${GUI_WEB_2D_PARALLEL_AGENT_PLAN:-doc/03_plan/agent_tasks/gui_rendering_parallel_agent_plan_2026-06-27.md}"
BUILD_DIR="${BUILD_DIR:-build/gui_web_2d_parallel_agent_review_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/gui_web_2d_parallel_agent_review_evidence_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"

contains() {
    pattern="$1"
    file="$2"
    grep -F -- "$pattern" "$file" >/dev/null 2>&1
}

count_fixed() {
    pattern="$1"
    file="$2"
    grep -F -c -- "$pattern" "$file" 2>/dev/null || true
}

pass_fail() {
    if [ "$1" = "1" ]; then
        echo pass
    else
        echo fail
    fi
}

if [ ! -f "$PLAN_PATH" ]; then
    source_status=missing
    spark_attempt_status=fail
    fallback_sidecar_status=fail
    normal_review_status=fail
    accepted_split_status=fail
    anti_overclaim_status=fail
    reviewed_findings_status=fail
    status=fail
    reason=parallel-agent-plan-missing
    spark_attempt_count=0
else
    source_status=pass
    spark_attempt_count="$(count_fixed "gpt-5.3-codex-spark" "$PLAN_PATH")"

    spark_attempt_ok=0
    if [ "$spark_attempt_count" -ge 1 ] &&
        contains "quota error" "$PLAN_PATH" &&
        contains "usage limit reached" "$PLAN_PATH"; then
        spark_attempt_ok=1
    fi
    spark_attempt_status="$(pass_fail "$spark_attempt_ok")"

    fallback_sidecar_ok=0
    if contains "Erdos" "$PLAN_PATH" &&
        contains "Bohr" "$PLAN_PATH" &&
        contains "Feynman" "$PLAN_PATH" &&
        contains "Mill" "$PLAN_PATH" &&
        contains "gpt-5.4-mini" "$PLAN_PATH" &&
        contains "Fallback sidecar findings accepted for planning only" "$PLAN_PATH"; then
        fallback_sidecar_ok=1
    fi
    fallback_sidecar_status="$(pass_fail "$fallback_sidecar_ok")"

    normal_review_ok=0
    if contains "Ampere" "$PLAN_PATH" &&
        contains "Poincare" "$PLAN_PATH" &&
        contains "gpt-5.4" "$PLAN_PATH" &&
        contains "normal/high-capability review" "$PLAN_PATH"; then
        normal_review_ok=1
    fi
    normal_review_status="$(pass_fail "$normal_review_ok")"

    accepted_split_ok=0
    if contains "Accepted reviewed split" "$PLAN_PATH" &&
        contains "Linux Vulkan lane" "$PLAN_PATH" &&
        contains "macOS Metal lane" "$PLAN_PATH" &&
        contains "Windows D3D12 lane" "$PLAN_PATH"; then
        accepted_split_ok=1
    fi
    accepted_split_status="$(pass_fail "$accepted_split_ok")"

    anti_overclaim_ok=0
    if contains "Do not mark Spark work as completed from that failed start" "$PLAN_PATH" &&
        contains "fallback screenshots are not backend proof" "$PLAN_PATH" &&
        contains "completion gates remain advisory until Lane C verifies fresh host" "$PLAN_PATH"; then
        anti_overclaim_ok=1
    fi
    anti_overclaim_status="$(pass_fail "$anti_overclaim_ok")"

    reviewed_findings_ok=0
    if contains "Fallback sidecar findings accepted for planning only" "$PLAN_PATH" &&
        contains "Normal/high-capability review must accept ARGB equivalence" "$PLAN_PATH" &&
        contains "completion claims must come from fresh aggregate output" "$PLAN_PATH"; then
        reviewed_findings_ok=1
    fi
    reviewed_findings_status="$(pass_fail "$reviewed_findings_ok")"

    if [ "$spark_attempt_status" = "pass" ] &&
        [ "$fallback_sidecar_status" = "pass" ] &&
        [ "$normal_review_status" = "pass" ] &&
        [ "$accepted_split_status" = "pass" ] &&
        [ "$anti_overclaim_status" = "pass" ] &&
        [ "$reviewed_findings_status" = "pass" ]; then
        status=pass
        reason=pass
    else
        status=fail
        reason=parallel-agent-review-evidence-incomplete
    fi
fi

{
    echo "gui_web_2d_parallel_agent_review_status=$status"
    echo "gui_web_2d_parallel_agent_review_reason=$reason"
    echo "gui_web_2d_parallel_agent_review_plan=$PLAN_PATH"
    echo "gui_web_2d_parallel_agent_review_plan_file_status=$source_status"
    echo "gui_web_2d_parallel_agent_review_spark_attempt_status=$spark_attempt_status"
    echo "gui_web_2d_parallel_agent_review_spark_attempt_count=$spark_attempt_count"
    echo "gui_web_2d_parallel_agent_review_fallback_sidecar_status=$fallback_sidecar_status"
    echo "gui_web_2d_parallel_agent_review_normal_review_status=$normal_review_status"
    echo "gui_web_2d_parallel_agent_review_accepted_split_status=$accepted_split_status"
    echo "gui_web_2d_parallel_agent_review_anti_overclaim_status=$anti_overclaim_status"
    echo "gui_web_2d_parallel_agent_review_reviewed_findings_status=$reviewed_findings_status"
    echo "gui_web_2d_parallel_agent_review_report=$REPORT_PATH"
} >"$OUT_ENV"

{
    echo "# GUI/Web/2D Parallel Agent Review Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- plan: $PLAN_PATH"
    echo "- Spark attempt: $spark_attempt_status ($spark_attempt_count records)"
    echo "- fallback sidecars: $fallback_sidecar_status"
    echo "- normal/high-capability review: $normal_review_status"
    echo "- accepted platform split: $accepted_split_status"
    echo "- anti-overclaim rules: $anti_overclaim_status"
    echo "- reviewed findings: $reviewed_findings_status"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$OUT_ENV"
} >"$REPORT_PATH"

cat "$OUT_ENV"
[ "$status" = "pass" ]
