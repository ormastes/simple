#!/usr/bin/env sh
set -eu

REPORT="${REPORT:-doc/09_report/perf/gpu_web_db_offload_recovery_harness_self_tests_2026-06-17.md}"
TABLE="${TABLE:-doc/10_metrics/perf/gpu_web_db_offload_recovery_harness_self_tests.md}"
PASSED_COUNT=0
ARTIFACT_SELF_TEST=0

if [ "${1:-}" = "--self-test-artifacts" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    REPORT="$tmpdir/recovery-harness-report.md"
    TABLE="$tmpdir/recovery-harness-metrics.md"
    ARTIFACT_SELF_TEST=1
fi

if [ "${1:-}" = "--check-current-artifacts" ]; then
    WEB_TABLE="doc/10_metrics/perf/web_server_nginx_compare.md"
    DB_TABLE="doc/10_metrics/perf/gpu_web_db_offload_benchmark.md"
