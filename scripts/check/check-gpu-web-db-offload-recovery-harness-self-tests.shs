    grep -q '# POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres' "$FIXTURE_ENV_HINTS"
    grep -q '# REDIS_URL=redis://127.0.0.1:6379/0' "$FIXTURE_ENV_HINTS"
    grep -q 'GPU Web/DB External Fixture Runbook' "$FIXTURE_RUNBOOK"
    grep -q 'external-fixture-compose.yaml --profile needs-proxy-config up -d' "$FIXTURE_RUNBOOK"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --require-ready' "$FIXTURE_RUNBOOK"
    grep -q 'GPU Web/DB External Fixture Next Actions' "$FIXTURE_NEXT_ACTIONS"
    grep -q 'Missing data source: `fixture-env-file:build/perf/gpu_web_db_offload/external-fixtures.env`' "$FIXTURE_NEXT_ACTIONS"
    grep -q 'Missing Categories' "$FIXTURE_NEXT_ACTIONS"
    grep -q 'Fixture Env Fields' "$FIXTURE_NEXT_ACTIONS"
    grep -q '| dynamic_gpu_plaintext_url | `DYNAMIC_GPU_PLAINTEXT_URL` | GPU plaintext dynamic route URL |' "$FIXTURE_NEXT_ACTIONS"
    grep -q '| postgres_url | `POSTGRES_URL` | PostgreSQL service URL |' "$FIXTURE_NEXT_ACTIONS"
    grep -q '| redis_url | `REDIS_URL` | Redis/Valkey service URL |' "$FIXTURE_NEXT_ACTIONS"
    grep -q 'Action Map' "$FIXTURE_NEXT_ACTIONS"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --require-ready' "$FIXTURE_NEXT_ACTIONS"
    grep -q -- '--check-env-file' "$FIXTURE_CHECKLIST"
    grep -q -- '--bootstrap-status' "$FIXTURE_CHECKLIST"
    grep -q -- '--write-bootstrap-manifest' "$FIXTURE_CHECKLIST"
