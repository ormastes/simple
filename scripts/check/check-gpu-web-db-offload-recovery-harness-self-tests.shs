    grep -q 'check-gpu-web-db-offload-external-suite.shs --dry-run' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --refresh-status' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --status' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --status-json' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --preflight' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --require-ready' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs --allow-partial' "$FIXTURE_CHECKLIST"
    grep -q 'check-gpu-web-db-offload-external-suite.shs' "$FIXTURE_CHECKLIST"
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=missing_fixture_items|26$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=suite_steps|31$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=required_missing_fixture_items|23$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=optional_missing_fixture_items|3$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=required_verdict|WAITING_ON_REQUIRED_FIXTURES$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=missing_data_source|fixture-env-file:build/perf/gpu_web_db_offload/external-fixtures.env$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=strict_readiness_command|scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-status=verdict|WAITING_ON_FIXTURES$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-missing=web_proxy_tools|caddy,h2o,haproxy,envoy$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-missing=reference_fixture_urls|simple_reference_plaintext_url,uwebsockets_plaintext_url,seastar_plaintext_url$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-missing=db_service_urls|clickhouse_url,postgres_url,mongo_url$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=env_fields|build/perf/gpu_web_db_offload/external-fixture-env-fields.tsv$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=blocker_manifest|build/perf/gpu_web_db_offload/external-fixture-blockers.tsv$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=next_actions|build/perf/gpu_web_db_offload/external-fixture-next-actions.md$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=status_json|build/perf/gpu_web_db_offload/external-suite-status.json$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=policy_json|build/perf/gpu_web_db_offload/external-suite-readiness-policy.json$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=required_env_missing|build/perf/gpu_web_db_offload/external-suite-required-env-missing.env$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=required_env_hints|build/perf/gpu_web_db_offload/external-suite-required-env-hints.md$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=required_blockers|build/perf/gpu_web_db_offload/external-suite-required-blockers.tsv$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=completion_audit|build/perf/gpu_web_db_offload/external-suite-completion-audit.md$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=required_next_actions|build/perf/gpu_web_db_offload/external-suite-required-next-actions.md$'
    sh "$EXTERNAL_SUITE" --status | grep -q '^external-suite-handoff=missing_by_category_source|build/perf/gpu_web_db_offload/external-fixture-missing-by-category-source.env$'
    sh "$EXTERNAL_SUITE" --status-json | python3 -c 'import json,sys; data=json.load(sys.stdin); assert data["suite_steps"] == 31; assert data["missing_fixture_items"] == 26; assert data["required_missing_fixture_items"] == 23; assert data["optional_missing_fixture_items"] == 3; assert data["verdict"] == "WAITING_ON_FIXTURES"; assert data["required_verdict"] == "WAITING_ON_REQUIRED_FIXTURES"; assert data["missing"]["db_tools"] == ["clickhouse", "duckdb", "psql", "pgbench", "mongodb"]; assert data["missing"]["db_service_urls"] == ["clickhouse_url", "postgres_url", "mongo_url"]; assert data["missing"]["reference_fixture_urls"] == ["simple_reference_plaintext_url", "uwebsockets_plaintext_url", "seastar_plaintext_url"]; assert data["optional_missing"]["reference_fixture_urls"] == ["simple_reference_plaintext_url", "uwebsockets_plaintext_url", "seastar_plaintext_url"]; assert data["handoff"]["blocker_manifest"] == "build/perf/gpu_web_db_offload/external-fixture-blockers.tsv"; assert data["handoff"]["local_env_candidates"] == "build/perf/gpu_web_db_offload/external-fixture-local-env-candidates.env"; assert data["handoff"]["status_json"] == "build/perf/gpu_web_db_offload/external-suite-status.json"; assert data["handoff"]["policy_json"] == "build/perf/gpu_web_db_offload/external-suite-readiness-policy.json"; assert data["handoff"]["required_next_actions"] == "build/perf/gpu_web_db_offload/external-suite-required-next-actions.md"; assert data["handoff"]["completion_audit"] == "build/perf/gpu_web_db_offload/external-suite-completion-audit.md"'
    sh "$EXTERNAL_SUITE" --policy-json | python3 -c 'import json,sys; data=json.load(sys.stdin); assert data["required_missing_fixture_items"] == 23; assert data["optional_missing_fixture_items"] == 3; assert data["optional_missing"]["reference_fixture_urls"] == ["simple_reference_plaintext_url", "uwebsockets_plaintext_url", "seastar_plaintext_url"]'
    python3 - "$FIXTURE_STATUS_JSON" "$FIXTURE_POLICY_JSON" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    status = json.load(handle)
with open(sys.argv[2], encoding="utf-8") as handle:
    policy = json.load(handle)
assert status["suite_steps"] == 31
assert status["handoff"]["local_env_candidates"] == "build/perf/gpu_web_db_offload/external-fixture-local-env-candidates.env"
assert status["missing_fixture_items"] == 26
assert status["required_missing_fixture_items"] == 23
assert status["optional_missing_fixture_items"] == 3
assert status["handoff"]["policy_json"] == "build/perf/gpu_web_db_offload/external-suite-readiness-policy.json"
assert status["handoff"]["required_env_missing"] == "build/perf/gpu_web_db_offload/external-suite-required-env-missing.env"
assert status["handoff"]["required_env_hints"] == "build/perf/gpu_web_db_offload/external-suite-required-env-hints.md"
assert status["handoff"]["required_blockers"] == "build/perf/gpu_web_db_offload/external-suite-required-blockers.tsv"
assert status["handoff"]["completion_audit"] == "build/perf/gpu_web_db_offload/external-suite-completion-audit.md"
assert status["handoff"]["required_next_actions"] == "build/perf/gpu_web_db_offload/external-suite-required-next-actions.md"
assert not any("/tmp/" in step["command"] for step in status["steps"])
assert policy["required_missing_fixture_items"] == 23
assert policy["optional_missing_fixture_items"] == 3
assert policy["optional_missing"]["reference_fixture_urls"] == [
    "simple_reference_plaintext_url",
    "uwebsockets_plaintext_url",
    "seastar_plaintext_url",
]
PY
    sh "$EXTERNAL_SUITE" --refresh-status | grep -q '^STATUS: PASS gpu web/db external suite refresh status$'
    sh "$EXTERNAL_SUITE" --preflight | grep -q '^STATUS: WARN gpu web/db external suite preflight missing:26$'
    grep -q '^web_proxy_tools=caddy,h2o,haproxy,envoy$' "$FIXTURE_MISSING_BY_CATEGORY"
    grep -q '^proxy_fixture_urls=simple_cached_proxy_url,haproxy_cached_proxy_url,envoy_cached_proxy_url,simple_upload_proxy_url,haproxy_upload_proxy_url,simple_tunnel_proxy_url,haproxy_tunnel_proxy_url$' "$FIXTURE_MISSING_BY_CATEGORY"
    grep -q '^db_tools=clickhouse,duckdb,psql,pgbench,mongodb$' "$FIXTURE_MISSING_BY_CATEGORY"
    grep -q '^db_service_urls=clickhouse_url,postgres_url,mongo_url$' "$FIXTURE_MISSING_BY_CATEGORY"
    grep -q '^dynamic_route_urls=dynamic_gpu_plaintext_url,dynamic_cpu_plaintext_url,dynamic_gpu_json_url,dynamic_cpu_json_url$' "$FIXTURE_MISSING_BY_CATEGORY"
    grep -q '^reference_fixture_urls=simple_reference_plaintext_url,uwebsockets_plaintext_url,seastar_plaintext_url$' "$FIXTURE_MISSING_BY_CATEGORY"
    grep -q '^missing_data_source=fixture-env-file:build/perf/gpu_web_db_offload/external-fixtures.env$' "$FIXTURE_MISSING_BY_CATEGORY_SOURCE"
    echo "STATUS: PASS gpu web/db recovery artifact consistency"
    exit 0
fi

init_artifacts() {
    mkdir -p "$(dirname "$REPORT")" "$(dirname "$TABLE")"
    {
        echo "# GPU Web/DB Recovery Harness Self-Test Metrics"
        echo
        echo "| gate | status | category |"
        echo "|---|---|---|"
    } > "$TABLE"
}

run_gate() {
    label="$1"
    shift
    echo "RUN: $label"
    "$@"
    PASSED_COUNT=$((PASSED_COUNT + 1))
    printf '| %s | pass | host-safe-self-test |\n' "$label" >> "$TABLE"
}

write_report() {
    {
        echo "# GPU Web/DB Recovery Harness Self-Tests"
        echo
        echo "This report is generated by \`scripts/check/check-gpu-web-db-offload-recovery-harness-self-tests.shs\`."
        echo "It records syntax checks plus non-mutating parser, producer, and readiness self-tests."
        echo
        echo "## Summary"
        echo
        echo "- Passed gates: \`$PASSED_COUNT\`"
        echo "- Verdict: \`PASS\`"
        echo
        echo "## Gates"
        echo
        sed -n '3,$p' "$TABLE"
    } > "$REPORT"
}

