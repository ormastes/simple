#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT_DIR"

OS_NAME="$(uname -s)"
LINUX_RUNNER="scripts/check/check-native-shader-backend-readback-matrix.shs"
MACOS_RUNNER="scripts/check/check-native-shader-backend-readback-matrix-macos.shs"

echo "[check] native shader backend readback matrix (host-dispatch)"
echo "[check] host=${OS_NAME}"

if [[ "$OS_NAME" == "Darwin" ]]; then
  exec "$MACOS_RUNNER"
fi

exec "$LINUX_RUNNER"
