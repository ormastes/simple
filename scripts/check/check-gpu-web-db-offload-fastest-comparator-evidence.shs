#!/usr/bin/env sh
set -eu

WEB_TABLE="${WEB_TABLE:-doc/10_metrics/perf/web_server_nginx_compare.md}"
DB_TABLE="${DB_TABLE:-doc/10_metrics/perf/gpu_web_db_offload_benchmark.md}"
STATUS_JSON="${STATUS_JSON:-build/perf/gpu_web_db_offload/external-suite-status.json}"
ENV_CHECK_REPORT="${ENV_CHECK_REPORT:-build/perf/gpu_web_db_offload/reference-comparator-env-check.md}"
FASTEST_COMPARATOR_STATUS_JSON="${FASTEST_COMPARATOR_STATUS_JSON:-build/perf/gpu_web_db_offload/fastest-comparator-status.json}"
FASTEST_COMPARATOR_COVERAGE_TSV="${FASTEST_COMPARATOR_COVERAGE_TSV:-build/perf/gpu_web_db_offload/fastest-comparator-coverage.tsv}"
FASTEST_COMPARATOR_COVERAGE_MD="${FASTEST_COMPARATOR_COVERAGE_MD:-build/perf/gpu_web_db_offload/fastest-comparator-coverage.md}"
FASTEST_COMPARATOR_NEXT_ACTIONS="${FASTEST_COMPARATOR_NEXT_ACTIONS:-build/perf/gpu_web_db_offload/fastest-comparator-next-actions.md}"
FASTEST_COMPARATOR_NEXT_ACTIONS_TSV="${FASTEST_COMPARATOR_NEXT_ACTIONS_TSV:-build/perf/gpu_web_db_offload/fastest-comparator-next-actions.tsv}"

audit_json() {
    python3 - "$WEB_TABLE" "$DB_TABLE" "$STATUS_JSON" "$ENV_CHECK_REPORT" <<'PY'
import json
import sys
from pathlib import Path

web_table = Path(sys.argv[1])
db_table = Path(sys.argv[2])
status_json = Path(sys.argv[3])
env_check_report = Path(sys.argv[4])

requirements = [
    ("nginx_static_1024", "web", "nginx_static_1024", "measured"),
    ("nginx_static_1048576", "web", "nginx_static_1048576", "measured"),
    ("uwebsockets_plaintext", "web", "uwebsockets_plaintext", "measured"),
    ("seastar_plaintext", "web", "seastar_plaintext", "measured"),
    ("redis_valkey_key_value_getset", "db", "db_key_value_redis_valkey_external_measured", "external-db-measured"),
]

def table_text(path):
    if not path.exists():
        return ""
    return path.read_text(encoding="utf-8")

def row_cells(line):
    return [cell.strip() for cell in line.strip().strip("|").split("|")]

web = table_text(web_table)
db = table_text(db_table)
items = []
missing = []
for name, source, needle, status in requirements:
    text = web if source == "web" else db
    found = False
    for line in text.splitlines():
        if needle not in line:
            continue
        cells = row_cells(line)
        if status in cells:
            found = True
            break
    item = {"name": name, "source": source, "status": "ready" if found else "missing"}
    items.append(item)
    if not found:
        missing.append(name)

suite_ready = False
suite_status = "missing-status-json"
if status_json.exists():
    try:
        data = json.loads(status_json.read_text(encoding="utf-8"))
        suite_status = data.get("verdict", "unknown")
        suite_ready = data.get("verdict") == "READY" and data.get("optional_missing_fixture_items") == 0
    except json.JSONDecodeError:
        suite_status = "invalid-status-json"
if not suite_ready:
    missing.append("strict_external_suite_ready")

env_check_status = "missing-env-check-report"
env_check_ready = False
if env_check_report.exists():
    env_text = env_check_report.read_text(encoding="utf-8")
    for line in env_text.splitlines():
        if line.startswith("- Verdict: `") and line.endswith("`"):
            env_check_status = line.split("`", 2)[1]
            env_check_ready = env_check_status == "READY"
            break
    else:
        env_check_status = "missing-env-check-verdict"
if not env_check_ready:
    missing.append("reference_comparator_env_ready")

result = {
    "verdict": "READY" if not missing else "WAITING_ON_FASTEST_COMPARATORS",
    "missing": missing,
    "items": items,
    "strict_external_suite_status": suite_status,
    "reference_comparator_env_status": env_check_status,
    "web_table": str(web_table),
    "db_table": str(db_table),
    "status_json": str(status_json),
    "env_check_report": str(env_check_report),
}
print(json.dumps(result, sort_keys=True, separators=(",", ":")))
PY
}

emit_status() {
    json="$(audit_json)"
    AUDIT_JSON="$json" python3 - <<'PY'
import json
import os
import sys

data = json.loads(os.environ["AUDIT_JSON"])
print(f"fastest-comparator-status=verdict|{data['verdict']}")
print(f"fastest-comparator-status=strict_external_suite_status|{data['strict_external_suite_status']}")
print(f"fastest-comparator-status=reference_comparator_env_status|{data['reference_comparator_env_status']}")
print(f"fastest-comparator-status=missing|{','.join(data['missing'])}")
for item in data["items"]:
    print(f"fastest-comparator-item={item['name']}|{item['status']}|{item['source']}")
if data["verdict"] == "READY":
    print("STATUS: PASS gpu web/db fastest comparator evidence audit")
else:
    print(f"STATUS: WARN gpu web/db fastest comparator evidence missing:{len(data['missing'])}")
PY
}

if [ "${1:-}" = "--status-json" ]; then
    audit_json
    exit 0
fi

if [ "${1:-}" = "--write-status-json" ]; then
    mkdir -p "$(dirname "$FASTEST_COMPARATOR_STATUS_JSON")"
    audit_json > "$FASTEST_COMPARATOR_STATUS_JSON"
    printf '%s\n' "$FASTEST_COMPARATOR_STATUS_JSON"
    echo "STATUS: PASS gpu web/db fastest comparator evidence status json"
    exit 0
fi

if [ "${1:-}" = "--write-coverage-tsv" ]; then
    mkdir -p "$(dirname "$FASTEST_COMPARATOR_COVERAGE_TSV")"
    json="$(audit_json)"
    AUDIT_JSON="$json" python3 - "$FASTEST_COMPARATOR_COVERAGE_TSV" <<'PY'
import json
import os
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(os.environ["AUDIT_JSON"])
evidence = {
    "nginx_static_1024": "doc/10_metrics/perf/web_server_nginx_compare.md row nginx_static_1024 status measured",
    "nginx_static_1048576": "doc/10_metrics/perf/web_server_nginx_compare.md row nginx_static_1048576 status measured",
    "uwebsockets_plaintext": "doc/10_metrics/perf/web_server_nginx_compare.md row uwebsockets_plaintext status measured",
    "seastar_plaintext": "doc/10_metrics/perf/web_server_nginx_compare.md row seastar_plaintext status measured",
    "redis_valkey_key_value_getset": "doc/10_metrics/perf/gpu_web_db_offload_benchmark.md row db_key_value_redis_valkey_external_measured status external-db-measured",
}
lines = ["item\tsource\tstatus\tevidence"]
for item in data["items"]:
    lines.append(
        f"{item['name']}\t{item['source']}\t{item['status']}\t{evidence[item['name']]}"
    )
suite_status = "ready" if "strict_external_suite_ready" not in data["missing"] else "missing"
lines.append(
    "strict_external_suite_ready\texternal_suite\t"
    f"{suite_status}\t{data['status_json']} verdict {data['strict_external_suite_status']} with optional_missing_fixture_items=0 required"
)
env_status = "ready" if "reference_comparator_env_ready" not in data["missing"] else "missing"
lines.append(
    "reference_comparator_env_ready\treference_env\t"
    f"{env_status}\t{data['env_check_report']} verdict {data['reference_comparator_env_status']}"
)
path.write_text("\n".join(lines) + "\n", encoding="utf-8")
print(path)
PY
    echo "STATUS: PASS gpu web/db fastest comparator coverage tsv"
    exit 0
fi

if [ "${1:-}" = "--write-coverage-md" ]; then
    mkdir -p "$(dirname "$FASTEST_COMPARATOR_COVERAGE_MD")"
    json="$(audit_json)"
    AUDIT_JSON="$json" python3 - "$FASTEST_COMPARATOR_COVERAGE_MD" <<'PY'
import json
import os
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(os.environ["AUDIT_JSON"])
labels = {
    "nginx_static_1024": "NGINX static 1KB",
    "nginx_static_1048576": "NGINX static 1MB",
    "uwebsockets_plaintext": "uWebSockets plaintext",
    "seastar_plaintext": "Seastar plaintext",
    "redis_valkey_key_value_getset": "Redis/Valkey key/value",
}
evidence = {
    "nginx_static_1024": "`doc/10_metrics/perf/web_server_nginx_compare.md` measured row `nginx_static_1024`",
    "nginx_static_1048576": "`doc/10_metrics/perf/web_server_nginx_compare.md` measured row `nginx_static_1048576`",
    "uwebsockets_plaintext": "`doc/10_metrics/perf/web_server_nginx_compare.md` measured row `uwebsockets_plaintext`",
    "seastar_plaintext": "`doc/10_metrics/perf/web_server_nginx_compare.md` measured row `seastar_plaintext`",
    "redis_valkey_key_value_getset": "`doc/10_metrics/perf/gpu_web_db_offload_benchmark.md` measured row `db_key_value_redis_valkey_external_measured`",
}
lines = [
    "# GPU Web/DB Fastest Comparator Coverage",
    "",
    "This file is generated by `scripts/check/check-gpu-web-db-offload-fastest-comparator-evidence.shs --write-coverage-md`.",
    "It records evidence coverage only; it does not claim fastest-server readiness unless every row is ready.",
    "",
    f"- Verdict: `{data['verdict']}`",
    f"- Strict external suite status: `{data['strict_external_suite_status']}`",
    f"- Reference comparator env status: `{data['reference_comparator_env_status']}`",
    f"- Missing: `{', '.join(data['missing']) if data['missing'] else 'none'}`",
    "",
    "| comparator | source | status | evidence required |",
    "|---|---|---|---|",
]
for item in data["items"]:
    name = item["name"]
    lines.append(f"| {labels[name]} | {item['source']} | {item['status']} | {evidence[name]} |")
suite_status = "ready" if "strict_external_suite_ready" not in data["missing"] else "missing"
lines.append(
    f"| Strict external suite ready | external_suite | {suite_status} | "
    f"`{data['status_json']}` verdict `READY` with `optional_missing_fixture_items=0` |"
)
env_status = "ready" if "reference_comparator_env_ready" not in data["missing"] else "missing"
lines.append(
    f"| Reference comparator env ready | reference_env | {env_status} | "
    f"`{data['env_check_report']}` verdict `READY` |"
)
path.write_text("\n".join(lines) + "\n", encoding="utf-8")
print(path)
PY
    echo "STATUS: PASS gpu web/db fastest comparator coverage markdown"
    exit 0
fi

if [ "${1:-}" = "--write-next-actions" ]; then
    mkdir -p "$(dirname "$FASTEST_COMPARATOR_NEXT_ACTIONS")"
    json="$(audit_json)"
    AUDIT_JSON="$json" python3 - "$FASTEST_COMPARATOR_NEXT_ACTIONS" <<'PY'
import json
import os
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(os.environ["AUDIT_JSON"])
actions = {
    "uwebsockets_plaintext": (
        "`SIMPLE_REFERENCE_PLAINTEXT_URL`, `UWEBSOCKETS_PLAINTEXT_URL`, "
        "`UWEBSOCKETS_PLAINTEXT_PROVENANCE`",
        "Start the real uWebSockets plaintext reference with workload parity, fill URL and provenance, run the proxy external producer, then refresh web report.",
    ),
    "seastar_plaintext": (
        "`SIMPLE_REFERENCE_PLAINTEXT_URL`, `SEASTAR_PLAINTEXT_URL`, "
        "`SEASTAR_PLAINTEXT_PROVENANCE`",
        "Start the real Seastar plaintext reference with workload parity, fill URL and provenance, run the proxy external producer, then refresh web report.",
    ),
    "strict_external_suite_ready": (
        "`build/perf/gpu_web_db_offload/external-fixtures.env`",
        "Run external-suite `--refresh-status`, then `--require-ready`; all required and optional fixture rows must be ready.",
    ),
    "reference_comparator_env_ready": (
        "`build/perf/gpu_web_db_offload/reference-comparator-fixtures.env`",
        "Fill and validate Simple/uWebSockets/Seastar plaintext URLs and uWebSockets/Seastar provenance with `check-gpu-web-db-offload-reference-comparator-handoff.shs --check-env-file`, then regenerate the env check report.",
    ),
}
lines = [
    "# GPU Web/DB Fastest Comparator Next Actions",
    "",
    "This file is generated by `scripts/check/check-gpu-web-db-offload-fastest-comparator-evidence.shs --write-next-actions`.",
    "It is side-effect-free and does not claim fastest-server evidence.",
    "",
    f"- Verdict: `{data['verdict']}`",
    f"- Strict external suite status: `{data['strict_external_suite_status']}`",
    "",
    "| missing item | fields | next action |",
    "|---|---|---|",
]
missing = data.get("missing", [])
if missing:
    for item in missing:
        fields, action = actions.get(item, ("", "Inspect fastest-comparator status JSON and add a concrete action."))
        lines.append(f"| {item} | {fields} | {action} |")
else:
    lines.append("| none |  | Fastest comparator evidence is ready. |")
lines.extend([
    "",
    "Final proof command:",
    "",
    "```sh",
    "scripts/check/check-gpu-web-db-offload-fastest-comparator-evidence.shs --require-ready",
    "```",
])
path.write_text("\n".join(lines) + "\n", encoding="utf-8")
print(path)
PY
    echo "STATUS: PASS gpu web/db fastest comparator next actions"
    exit 0
fi

if [ "${1:-}" = "--write-next-actions-tsv" ]; then
    mkdir -p "$(dirname "$FASTEST_COMPARATOR_NEXT_ACTIONS_TSV")"
    json="$(audit_json)"
    AUDIT_JSON="$json" python3 - "$FASTEST_COMPARATOR_NEXT_ACTIONS_TSV" <<'PY'
import json
import os
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(os.environ["AUDIT_JSON"])
actions = {
    "uwebsockets_plaintext": (
        "SIMPLE_REFERENCE_PLAINTEXT_URL,UWEBSOCKETS_PLAINTEXT_URL,UWEBSOCKETS_PLAINTEXT_PROVENANCE",
        "scripts/check/check-web-server-proxy-external-live-compare.shs; scripts/check/check-web-server-nginx-compare-report.shs",
        "Start real uWebSockets plaintext reference with workload parity, fill URL and provenance, then refresh measured web rows.",
    ),
    "seastar_plaintext": (
        "SIMPLE_REFERENCE_PLAINTEXT_URL,SEASTAR_PLAINTEXT_URL,SEASTAR_PLAINTEXT_PROVENANCE",
        "scripts/check/check-web-server-proxy-external-live-compare.shs; scripts/check/check-web-server-nginx-compare-report.shs",
        "Start real Seastar plaintext reference with workload parity, fill URL and provenance, then refresh measured web rows.",
    ),
    "strict_external_suite_ready": (
        "build/perf/gpu_web_db_offload/external-fixtures.env",
        "scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status; scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready",
        "Make all required and optional external fixture rows ready before claiming fastest-comparator coverage.",
    ),
    "reference_comparator_env_ready": (
        "build/perf/gpu_web_db_offload/reference-comparator-fixtures.env",
        "scripts/check/check-gpu-web-db-offload-reference-comparator-handoff.shs --check-env-file build/perf/gpu_web_db_offload/reference-comparator-fixtures.env; scripts/check/check-gpu-web-db-offload-reference-comparator-handoff.shs --write-env-check-report",
        "Validate Simple/uWebSockets/Seastar plaintext URLs and uWebSockets/Seastar provenance before copying values into strict external fixtures.",
    ),
}
lines = ["missing_item\tfields\tcommands\tnext_action"]
missing = data.get("missing", [])
if missing:
    for item in missing:
        fields, commands, action = actions.get(item, ("", "", "Inspect fastest comparator status JSON."))
        lines.append(f"{item}\t{fields}\t{commands}\t{action}")
else:
    lines.append("none\t\t\tFastest comparator evidence is ready.")
path.write_text("\n".join(lines) + "\n", encoding="utf-8")
print(path)
PY
    echo "STATUS: PASS gpu web/db fastest comparator next actions tsv"
    exit 0
fi

if [ "${1:-}" = "--require-ready" ]; then
    json="$(audit_json)"
    AUDIT_JSON="$json" python3 - <<'PY'
import json
import os
import sys

data = json.loads(os.environ["AUDIT_JSON"])
if data["verdict"] != "READY":
    print(f"STATUS: FAIL gpu web/db fastest comparator evidence missing:{len(data['missing'])}")
    print("missing=" + ",".join(data["missing"]))
    raise SystemExit(1)
print("STATUS: PASS gpu web/db fastest comparator evidence require-ready")
PY
    exit 0
fi

if [ "${1:-}" = "--self-test" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    web="$tmpdir/web.md"
    db="$tmpdir/db.md"
    status="$tmpdir/status.json"
    env_check="$tmpdir/env-check.md"
    cat > "$web" <<'EOF'
| workload | simple_target | external_baseline | load_tool | status |
|---|---|---|---|---|
| static_1kb | native_simple_static_1024 | nginx_static_1024 | wrk | measured |
| static_1mb | native_simple_static_1048576 | nginx_static_1048576 | wrk | measured |
| reference_plaintext | native_simple_reference_plaintext | uwebsockets_plaintext | wrk | measured |
| reference_plaintext | native_simple_reference_plaintext | seastar_plaintext | wrk | measured |
EOF
    cat > "$db" <<'EOF'
| name | backend | dataset |
|---|---|---|
| db_key_value_redis_valkey_external_measured | external-db-measured | redis_valkey_getset_1024_key_match |
EOF
    printf '%s\n' '{"verdict":"READY","optional_missing_fixture_items":0}' > "$status"
    cat > "$env_check" <<'EOF'
# GPU Web/DB Reference Comparator Env Check

- Verdict: `READY`
- Missing fields: `0`
EOF
    WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --require-ready >/dev/null
    out="$tmpdir/fastest-status.json"
    FASTEST_COMPARATOR_STATUS_JSON="$out" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-status-json >/dev/null
    coverage="$tmpdir/fastest-coverage.tsv"
    coverage_md="$tmpdir/fastest-coverage.md"
    actions="$tmpdir/fastest-actions.md"
    actions_tsv="$tmpdir/fastest-actions.tsv"
    FASTEST_COMPARATOR_COVERAGE_TSV="$coverage" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-coverage-tsv >/dev/null
    FASTEST_COMPARATOR_COVERAGE_MD="$coverage_md" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-coverage-md >/dev/null
    FASTEST_COMPARATOR_NEXT_ACTIONS="$actions" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-next-actions >/dev/null
    FASTEST_COMPARATOR_NEXT_ACTIONS_TSV="$actions_tsv" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-next-actions-tsv >/dev/null
    python3 - "$out" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    data = json.load(handle)
assert data["verdict"] == "READY"
assert data["missing"] == []
PY
    grep -q '| none |' "$actions"
    grep -q '^none	' "$actions_tsv"
    grep -q '^item	source	status	evidence$' "$coverage"
    grep -q '^nginx_static_1024	web	ready	' "$coverage"
    grep -q '^nginx_static_1048576	web	ready	' "$coverage"
    grep -q '^redis_valkey_key_value_getset	db	ready	' "$coverage"
    grep -q '^strict_external_suite_ready	external_suite	ready	' "$coverage"
    grep -q '^reference_comparator_env_ready	reference_env	ready	' "$coverage"
    grep -q '| NGINX static 1KB | web | ready |' "$coverage_md"
    grep -q '| Redis/Valkey key/value | db | ready |' "$coverage_md"
    grep -q '| Strict external suite ready | external_suite | ready |' "$coverage_md"
    grep -q '| Reference comparator env ready | reference_env | ready |' "$coverage_md"
    printf '%s\n' '| reference_plaintext | native_simple_reference_plaintext | seastar_plaintext | wrk | live-fixture-unavailable |' >> "$web"
    sed -i '/uwebsockets_plaintext/d' "$web"
    output="$(WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0")"
    FASTEST_COMPARATOR_NEXT_ACTIONS="$actions" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-next-actions >/dev/null
    FASTEST_COMPARATOR_NEXT_ACTIONS_TSV="$actions_tsv" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-next-actions-tsv >/dev/null
    FASTEST_COMPARATOR_COVERAGE_TSV="$coverage" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-coverage-tsv >/dev/null
    FASTEST_COMPARATOR_COVERAGE_MD="$coverage_md" WEB_TABLE="$web" DB_TABLE="$db" STATUS_JSON="$status" ENV_CHECK_REPORT="$env_check" sh "$0" --write-coverage-md >/dev/null
    printf '%s\n' "$output" | grep -q '^fastest-comparator-item=uwebsockets_plaintext|missing|web$'
    printf '%s\n' "$output" | grep -q '^STATUS: WARN gpu web/db fastest comparator evidence missing:1$'
    grep -q '| uwebsockets_plaintext |' "$actions"
    grep -q 'UWEBSOCKETS_PLAINTEXT_PROVENANCE' "$actions"
    grep -q '^uwebsockets_plaintext	' "$actions_tsv"
    grep -q 'UWEBSOCKETS_PLAINTEXT_PROVENANCE' "$actions_tsv"
    grep -q '^uwebsockets_plaintext	web	missing	' "$coverage"
    grep -q '^seastar_plaintext	web	ready	' "$coverage"
    grep -q '| uWebSockets plaintext | web | missing |' "$coverage_md"
    grep -q '| Seastar plaintext | web | ready |' "$coverage_md"
    echo "STATUS: PASS gpu web/db fastest comparator evidence self-test"
    exit 0
fi

emit_status
