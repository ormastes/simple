#!/usr/bin/env sh
set -eu

SIMPLE_BIN="${SIMPLE_BIN:-${SIMPLE_BINARY:-bin/simple}}"
export SIMPLE_BIN

sh scripts/check/check-httpserver-live-static.shs
sh scripts/check/check-proxy-live-httpserver.shs
sh scripts/check/check-proxy-live-httpserver-pool.shs
sh scripts/check/check-proxy-live-httpserver-upload.shs

if [ "${PROXY_LIVE_TUNNEL_SKIP_BUILD:-1}" = "1" ]; then
  TUNNEL_BIN="build/perf/proxy_live_httpserver_tunnel/proxy_live_httpserver_proxy"
  if [ ! -x "$TUNNEL_BIN" ]; then
    SIMPLE_LIB=src "$SIMPLE_BIN" native-build \
      --clean \
      --no-incremental \
      --source src/lib \
      --source test/05_perf/web \
      --entry test/05_perf/web/proxy_live_httpserver_proxy.spl \
      --entry-closure \
      --strip \
      --output "$TUNNEL_BIN"
  fi
  PROXY_LIVE_SKIP_BUILD=1 sh scripts/check/check-proxy-live-httpserver-tunnel.shs
else
  sh scripts/check/check-proxy-live-httpserver-tunnel.shs
fi

echo "STATUS: PASS proxy live HttpServer reliable suite"
