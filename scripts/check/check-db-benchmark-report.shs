#!/usr/bin/env sh
set -eu

REPORT="doc/09_report/perf/perf_baseline_db_2026-06-13.md"
TABLE="doc/10_metrics/perf/perf_baseline_db_table.md"
WAL_REPORT="doc/09_report/perf/perf_baseline_db_wal_compiled_2026-06-16.md"
WAL_TABLE="doc/10_metrics/perf/perf_baseline_db_wal_compiled_table.md"

bin/simple check test/05_perf/db/db_bench_driver.spl
bin/simple run test/05_perf/db/db_bench_driver.spl
sh scripts/check/check-db-wal-compiled-benchmark-report.shs

test -f "$REPORT"
test -f "$TABLE"
test -f "$WAL_REPORT"
test -f "$WAL_TABLE"

grep -q '| db_ram_insert100 | ram | insert+scan |' "$REPORT"
grep -q '| db_persistent_insert100 | persistent | insert+scan |' "$REPORT"
grep -q '| db_wal_insert100 | wal | insert+count_visible |' "$REPORT"
grep -q '| db_ram_insert100 | ram | insert+scan |' "$TABLE"
grep -q '| db_persistent_insert100 | persistent | insert+scan |' "$TABLE"
grep -q '| db_wal_insert100 | wal | insert+count_visible |' "$TABLE"
grep -q 'perf_baseline_db_wal_compiled_2026-06-16.md' "$REPORT"
grep -q '| db_wal_insert100 | wal | insert+count_visible |' "$WAL_REPORT"
grep -q '| db_wal_insert100 | wal | insert+count_visible |' "$WAL_TABLE"

echo "STATUS: PASS db benchmark report"
