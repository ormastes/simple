#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/production_gui_font_offload_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_font_offload_evidence_$(date -u +%F).md}"
SIMPLE_BIN="${SIMPLE_BIN:-bin/simple}"
SIMPLE_SRC="$BUILD_DIR/production_gui_font_offload_evidence.spl"
SIMPLE_OUT="$BUILD_DIR/simple.out"
ENV_PATH="$BUILD_DIR/evidence.env"
TIMEOUT_SECS="${PRODUCTION_GUI_FONT_EVIDENCE_TIMEOUT_SECS:-60}"
KILL_SECS="${PRODUCTION_GUI_FONT_EVIDENCE_KILL_SECS:-5}"

VECTOR_RUNTIME_READY="${VECTOR_FONT_RUNTIME_READY:-false}"
VECTOR_MODULE_READY="${VECTOR_FONT_MODULE_READY:-false}"
VECTOR_BACKEND_SUBMIT_OK="${VECTOR_FONT_BACKEND_SUBMIT_OK:-false}"
VECTOR_READBACK_AVAILABLE="${VECTOR_FONT_READBACK_AVAILABLE:-false}"

BITMAP_RUNTIME_READY="${BITMAP_FONT_RUNTIME_READY:-false}"
BITMAP_MODULE_READY="${BITMAP_FONT_MODULE_READY:-false}"
BITMAP_BACKEND_SUBMIT_OK="${BITMAP_FONT_BACKEND_SUBMIT_OK:-false}"
BITMAP_READBACK_AVAILABLE="${BITMAP_FONT_READBACK_AVAILABLE:-false}"

if [ -n "${PRODUCTION_GUI_FONT_CANDIDATES_SIMPLE:-}" ]; then
    FONT_CANDIDATES_SIMPLE="$PRODUCTION_GUI_FONT_CANDIDATES_SIMPLE"
elif [ "$(uname -s 2>/dev/null || printf unknown)" = "Darwin" ]; then
    FONT_CANDIDATES_SIMPLE='["metal", "cuda", "rocm", "amd-hip", "qualcomm", "vulkan", "directx", "opencl", "opengl", "intel", "webgpu", "cpu_simd", "software", "cpu"]'
else
    FONT_CANDIDATES_SIMPLE='["cuda", "rocm", "amd-hip", "qualcomm", "vulkan", "directx", "opencl", "opengl", "intel", "webgpu", "cpu_simd", "software", "cpu"]'
fi

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$SIMPLE_SRC" "$SIMPLE_OUT" "$ENV_PATH" "$REPORT_PATH"

emit_unavailable() {
    reason="$1"
    {
        echo "production_gui_font_offload_status=unavailable"
        echo "production_gui_font_offload_reason=$reason"
        echo "production_gui_font_offload_vector_status=unavailable"
        echo "production_gui_font_offload_bitmap_status=unavailable"
        echo "production_gui_font_offload_report=$REPORT_PATH"
    } >"$ENV_PATH"
    {
        echo "# Production GUI Font Offload Evidence"
        echo
        echo "- status: unavailable"
        echo "- reason: $reason"
    } >"$REPORT_PATH"
    cat "$ENV_PATH"
}

if [ ! -x "$SIMPLE_BIN" ]; then
    emit_unavailable "missing-simple-bin"
    exit 1
fi

run_simple_with_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        timeout -k "$KILL_SECS" "$TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

cat >"$SIMPLE_SRC" <<SIMPLE_EOF
module production_gui_font_offload_evidence

use std.gpu.engine2d.vector_font_offload.{vector_font_glyph_pixels_checksum, vector_font_preferred_offload_evidence, vector_font_preferred_glyph_readback_evidence}
use std.gpu.engine2d.bitmap_font_offload.{bitmap_font_preferred_offload_evidence, bitmap_glyph_raster_mask_checksum, bitmap_glyph_raster_preferred_mask_readback_evidence}
use std.nogc_sync_mut.text_layout.font_rasterizer.{
    bitmap_font_accelerator_stats,
    rasterize_bitmap_accelerated,
    rasterize_vector_accelerated,
    reset_bitmap_font_raster_stats,
    reset_vector_font_raster_stats,
    vector_font_accelerator_stats
}
use std.nogc_sync_mut.text_layout.font_vector_data.{vf_glyph_commands}

fn bool_text(v: bool) -> text:
    if v:
        return "true"
    "false"

fn overall_status(vector_ready: bool, bitmap_ready: bool, vector_status: text, bitmap_status: text) -> text:
    if vector_ready and bitmap_ready:
        return "pass"
    if vector_status.contains("unavailable") or vector_status.contains("not-submitted") or bitmap_status.contains("unavailable") or bitmap_status.contains("not-submitted"):
        return "unavailable"
    "fail"

fn alpha_mask(pixels: [u8]) -> [u32]:
    var bits: [u32] = []
    var idx = 0
    while idx < pixels.len():
        if pixels[idx].to_i64() > 0:
            bits.push(1u32)
        else:
            bits.push(0u32)
        idx = idx + 1
    bits

fn main() -> i32:
    val candidates = $FONT_CANDIDATES_SIMPLE
    val vector_codepoint: i32 = 77
    val vector_font_size: i32 = 24
    reset_vector_font_raster_stats()
    val vector_glyph = rasterize_vector_accelerated(vf_glyph_commands(vector_codepoint), vector_codepoint, vector_font_size)
    val vector_pixels = vector_glyph.pixels
    val vector_checksum = vector_font_glyph_pixels_checksum(vector_pixels)
    val vector_accel = vector_font_accelerator_stats()
    val vector_gpu_ready = vector_accel.gpu_returned_glyphs > 0 and vector_accel.gpu_returned_glyph_pixels > 0
    val vector_runtime_ready = $VECTOR_RUNTIME_READY or vector_gpu_ready
    val vector_module_ready = $VECTOR_MODULE_READY or vector_gpu_ready
    val vector_submit_ok = $VECTOR_BACKEND_SUBMIT_OK or vector_gpu_ready
    val vector_readback_available = $VECTOR_READBACK_AVAILABLE or vector_gpu_ready
    val vector_offload = vector_font_preferred_offload_evidence(candidates, vector_glyph.width.to_i64(), vector_glyph.height.to_i64(), vector_runtime_ready, vector_module_ready, 4096, vector_accel)
    val vector_readback = vector_font_preferred_glyph_readback_evidence(candidates, vector_glyph.width.to_i64(), vector_glyph.height.to_i64(), 4096, 7, 11, vector_runtime_ready, vector_submit_ok, vector_readback_available, vector_accel, vector_pixels, vector_checksum)

    reset_bitmap_font_raster_stats()
    val bitmap_glyph = rasterize_bitmap_accelerated(vector_codepoint, vector_font_size)
    val bitmap_stats = bitmap_font_accelerator_stats()
    val bitmap_bits = alpha_mask(bitmap_glyph.pixels)
    val bitmap_color = 0xff224466u32
    val bitmap_checksum = bitmap_glyph_raster_mask_checksum(bitmap_bits, bitmap_glyph.width.to_i64(), bitmap_glyph.height.to_i64(), bitmap_color)
    val bitmap_gpu_ready = bitmap_stats.gpu_returned_glyphs > 0 and bitmap_stats.gpu_returned_glyph_pixels > 0
    val bitmap_runtime_ready = $BITMAP_RUNTIME_READY or bitmap_gpu_ready
    val bitmap_module_ready = $BITMAP_MODULE_READY or bitmap_gpu_ready
    val bitmap_submit_ok = $BITMAP_BACKEND_SUBMIT_OK or bitmap_gpu_ready
    val bitmap_readback_available = $BITMAP_READBACK_AVAILABLE or bitmap_gpu_ready
    val bitmap_offload = bitmap_font_preferred_offload_evidence(candidates, bitmap_glyph.width.to_i64(), bitmap_glyph.height.to_i64(), bitmap_runtime_ready, bitmap_module_ready, 4096)
    val bitmap_readback = bitmap_glyph_raster_preferred_mask_readback_evidence(candidates, bitmap_bits, bitmap_glyph.width.to_i64(), bitmap_glyph.height.to_i64(), bitmap_color, 4096, 7, 11, bitmap_runtime_ready, bitmap_submit_ok, bitmap_readback_available, bitmap_checksum)

    val status = overall_status(vector_readback.production_ready, bitmap_readback.production_ready, vector_readback.status_code, bitmap_readback.status_code)
    var reason = "font-device-readback-unavailable"
    if status == "pass":
        reason = "vector-and-bitmap-font-readback-matched"
    else:
        reason = vector_readback.reason + ";" + bitmap_readback.reason

    print "production_gui_font_offload_status={status}"
    print "production_gui_font_offload_reason={reason}"
    print "production_gui_font_offload_vector_backend={vector_offload.backend_name}"
    print "production_gui_font_offload_vector_status={vector_offload.status_code}"
    print "production_gui_font_offload_vector_reason={vector_offload.reason}"
    print "production_gui_font_offload_vector_accel_attempts={vector_accel.attempts}"
    print "production_gui_font_offload_vector_metal_hits={vector_accel.metal_hits}"
    print "production_gui_font_offload_vector_cuda_hits={vector_accel.cuda_hits}"
    print "production_gui_font_offload_vector_opencl_hits={vector_accel.opencl_hits}"
    print "production_gui_font_offload_vector_cpu_fallback_hits={vector_accel.cpu_fallback_hits}"
    print "production_gui_font_offload_vector_gpu_returned_glyphs={vector_accel.gpu_returned_glyphs}"
    print "production_gui_font_offload_vector_gpu_returned_glyph_pixels={vector_accel.gpu_returned_glyph_pixels}"
    print "production_gui_font_offload_vector_readback_status={vector_readback.status_code}"
    print "production_gui_font_offload_vector_readback_reason={vector_readback.reason}"
    print "production_gui_font_offload_vector_production_ready={bool_text(vector_readback.production_ready)}"
    print "production_gui_font_offload_vector_expected_checksum={vector_readback.execution.expected_checksum}"
    print "production_gui_font_offload_vector_actual_checksum={vector_readback.execution.actual_checksum}"
    print "production_gui_font_offload_bitmap_backend={bitmap_offload.backend_name}"
    print "production_gui_font_offload_bitmap_status={bitmap_offload.status_code}"
    print "production_gui_font_offload_bitmap_reason={bitmap_offload.reason}"
    print "production_gui_font_offload_bitmap_accel_attempts={bitmap_stats.attempts}"
    print "production_gui_font_offload_bitmap_metal_hits={bitmap_stats.metal_hits}"
    print "production_gui_font_offload_bitmap_cuda_hits={bitmap_stats.cuda_hits}"
    print "production_gui_font_offload_bitmap_opencl_hits={bitmap_stats.opencl_hits}"
    print "production_gui_font_offload_bitmap_cpu_fallback_hits={bitmap_stats.cpu_fallback_hits}"
    print "production_gui_font_offload_bitmap_gpu_returned_glyphs={bitmap_stats.gpu_returned_glyphs}"
    print "production_gui_font_offload_bitmap_gpu_returned_glyph_pixels={bitmap_stats.gpu_returned_glyph_pixels}"
    print "production_gui_font_offload_bitmap_readback_status={bitmap_readback.status_code}"
    print "production_gui_font_offload_bitmap_readback_reason={bitmap_readback.reason}"
    print "production_gui_font_offload_bitmap_production_ready={bool_text(bitmap_readback.production_ready)}"
    print "production_gui_font_offload_bitmap_expected_checksum={bitmap_readback.execution.expected_checksum}"
    print "production_gui_font_offload_bitmap_actual_checksum={bitmap_readback.execution.actual_checksum}"
    0
SIMPLE_EOF

set +e
SIMPLE_EXECUTION_MODE="${SIMPLE_EXECUTION_MODE:-interpret}" SIMPLE_LIB="${SIMPLE_LIB:-src}" run_simple_with_timeout "$SIMPLE_BIN" run "$SIMPLE_SRC" --mode=interpreter --clean >"$SIMPLE_OUT" 2>&1
simple_code=$?
set -e

if [ "$simple_code" -ne 0 ]; then
    if [ "$simple_code" -eq 124 ] || [ "$simple_code" -eq 137 ] || [ "$simple_code" -eq 143 ]; then
        emit_unavailable "simple-font-offload-evidence-timeout"
    else
        emit_unavailable "simple-font-offload-evidence-failed"
    fi
    {
        echo
        echo "## Simple Output"
        sed 's/^/- /' "$SIMPLE_OUT" 2>/dev/null || true
    } >>"$REPORT_PATH"
    exit 1
fi

value_of() {
    key="$1"
    sed -n "s/^${key}=//p" "$SIMPLE_OUT" | tail -n 1
}

status="$(value_of production_gui_font_offload_status)"
reason="$(value_of production_gui_font_offload_reason)"
vector_backend="$(value_of production_gui_font_offload_vector_backend)"
vector_status="$(value_of production_gui_font_offload_vector_status)"
vector_reason="$(value_of production_gui_font_offload_vector_reason)"
vector_accel_attempts="$(value_of production_gui_font_offload_vector_accel_attempts)"
vector_metal_hits="$(value_of production_gui_font_offload_vector_metal_hits)"
vector_cuda_hits="$(value_of production_gui_font_offload_vector_cuda_hits)"
vector_opencl_hits="$(value_of production_gui_font_offload_vector_opencl_hits)"
vector_cpu_fallback_hits="$(value_of production_gui_font_offload_vector_cpu_fallback_hits)"
vector_gpu_returned_glyphs="$(value_of production_gui_font_offload_vector_gpu_returned_glyphs)"
vector_gpu_returned_glyph_pixels="$(value_of production_gui_font_offload_vector_gpu_returned_glyph_pixels)"
vector_readback_status="$(value_of production_gui_font_offload_vector_readback_status)"
vector_readback_reason="$(value_of production_gui_font_offload_vector_readback_reason)"
vector_ready="$(value_of production_gui_font_offload_vector_production_ready)"
bitmap_backend="$(value_of production_gui_font_offload_bitmap_backend)"
bitmap_status="$(value_of production_gui_font_offload_bitmap_status)"
bitmap_reason="$(value_of production_gui_font_offload_bitmap_reason)"
bitmap_accel_attempts="$(value_of production_gui_font_offload_bitmap_accel_attempts)"
bitmap_metal_hits="$(value_of production_gui_font_offload_bitmap_metal_hits)"
bitmap_cuda_hits="$(value_of production_gui_font_offload_bitmap_cuda_hits)"
bitmap_opencl_hits="$(value_of production_gui_font_offload_bitmap_opencl_hits)"
bitmap_cpu_fallback_hits="$(value_of production_gui_font_offload_bitmap_cpu_fallback_hits)"
bitmap_gpu_returned_glyphs="$(value_of production_gui_font_offload_bitmap_gpu_returned_glyphs)"
bitmap_gpu_returned_glyph_pixels="$(value_of production_gui_font_offload_bitmap_gpu_returned_glyph_pixels)"
bitmap_readback_status="$(value_of production_gui_font_offload_bitmap_readback_status)"
bitmap_readback_reason="$(value_of production_gui_font_offload_bitmap_readback_reason)"
bitmap_ready="$(value_of production_gui_font_offload_bitmap_production_ready)"

{
    echo "production_gui_font_offload_status=$status"
    echo "production_gui_font_offload_reason=$reason"
    echo "production_gui_font_offload_vector_backend=$vector_backend"
    echo "production_gui_font_offload_vector_status=$vector_status"
    echo "production_gui_font_offload_vector_reason=$vector_reason"
    echo "production_gui_font_offload_vector_accel_attempts=$vector_accel_attempts"
    echo "production_gui_font_offload_vector_metal_hits=$vector_metal_hits"
    echo "production_gui_font_offload_vector_cuda_hits=$vector_cuda_hits"
    echo "production_gui_font_offload_vector_opencl_hits=$vector_opencl_hits"
    echo "production_gui_font_offload_vector_cpu_fallback_hits=$vector_cpu_fallback_hits"
    echo "production_gui_font_offload_vector_gpu_returned_glyphs=$vector_gpu_returned_glyphs"
    echo "production_gui_font_offload_vector_gpu_returned_glyph_pixels=$vector_gpu_returned_glyph_pixels"
    echo "production_gui_font_offload_vector_readback_status=$vector_readback_status"
    echo "production_gui_font_offload_vector_readback_reason=$vector_readback_reason"
    echo "production_gui_font_offload_vector_production_ready=$vector_ready"
    echo "production_gui_font_offload_vector_expected_checksum=$(value_of production_gui_font_offload_vector_expected_checksum)"
    echo "production_gui_font_offload_vector_actual_checksum=$(value_of production_gui_font_offload_vector_actual_checksum)"
    echo "production_gui_font_offload_bitmap_backend=$bitmap_backend"
    echo "production_gui_font_offload_bitmap_status=$bitmap_status"
    echo "production_gui_font_offload_bitmap_reason=$bitmap_reason"
    echo "production_gui_font_offload_bitmap_accel_attempts=$bitmap_accel_attempts"
    echo "production_gui_font_offload_bitmap_metal_hits=$bitmap_metal_hits"
    echo "production_gui_font_offload_bitmap_cuda_hits=$bitmap_cuda_hits"
    echo "production_gui_font_offload_bitmap_opencl_hits=$bitmap_opencl_hits"
    echo "production_gui_font_offload_bitmap_cpu_fallback_hits=$bitmap_cpu_fallback_hits"
    echo "production_gui_font_offload_bitmap_gpu_returned_glyphs=$bitmap_gpu_returned_glyphs"
    echo "production_gui_font_offload_bitmap_gpu_returned_glyph_pixels=$bitmap_gpu_returned_glyph_pixels"
    echo "production_gui_font_offload_bitmap_readback_status=$bitmap_readback_status"
    echo "production_gui_font_offload_bitmap_readback_reason=$bitmap_readback_reason"
    echo "production_gui_font_offload_bitmap_production_ready=$bitmap_ready"
    echo "production_gui_font_offload_bitmap_expected_checksum=$(value_of production_gui_font_offload_bitmap_expected_checksum)"
    echo "production_gui_font_offload_bitmap_actual_checksum=$(value_of production_gui_font_offload_bitmap_actual_checksum)"
    echo "production_gui_font_offload_report=$REPORT_PATH"
} >"$ENV_PATH"

{
    echo "# Production GUI Font Offload Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- vector backend: $vector_backend"
    echo "- vector offload status: $vector_status"
    echo "- vector offload reason: $vector_reason"
    echo "- vector accel attempts: $vector_accel_attempts"
    echo "- vector Metal hits: $vector_metal_hits"
    echo "- vector CUDA hits: $vector_cuda_hits"
    echo "- vector OpenCL hits: $vector_opencl_hits"
    echo "- vector CPU fallback hits: $vector_cpu_fallback_hits"
    echo "- vector GPU returned glyphs: $vector_gpu_returned_glyphs"
    echo "- vector GPU returned glyph pixels: $vector_gpu_returned_glyph_pixels"
    echo "- vector readback status: $vector_readback_status"
    echo "- vector readback reason: $vector_readback_reason"
    echo "- vector production ready: $vector_ready"
    echo "- bitmap backend: $bitmap_backend"
    echo "- bitmap offload status: $bitmap_status"
    echo "- bitmap offload reason: $bitmap_reason"
    echo "- bitmap accel attempts: $bitmap_accel_attempts"
    echo "- bitmap Metal hits: $bitmap_metal_hits"
    echo "- bitmap CUDA hits: $bitmap_cuda_hits"
    echo "- bitmap OpenCL hits: $bitmap_opencl_hits"
    echo "- bitmap CPU fallback hits: $bitmap_cpu_fallback_hits"
    echo "- bitmap GPU returned glyphs: $bitmap_gpu_returned_glyphs"
    echo "- bitmap GPU returned glyph pixels: $bitmap_gpu_returned_glyph_pixels"
    echo "- bitmap readback status: $bitmap_readback_status"
    echo "- bitmap readback reason: $bitmap_readback_reason"
    echo "- bitmap production ready: $bitmap_ready"
} >"$REPORT_PATH"

cat "$ENV_PATH"
