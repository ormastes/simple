#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/simpleos_wm_qmp_drag_delta_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/simpleos_wm_qmp_drag_delta_evidence_$(date -u +%F).md}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass
LAUNCH_OUT="$BUILD_DIR/launch.out"
DRAG_OUT="$BUILD_DIR/drag.out"
BEFORE_PPM="$BUILD_DIR/before-drag.ppm"
AFTER_PPM="$BUILD_DIR/after-drag.ppm"
BEFORE_RAW="$BEFORE_PPM.raw"
AFTER_RAW="$AFTER_PPM.raw"
PID=""

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$LAUNCH_OUT" "$DRAG_OUT" "$BEFORE_PPM" "$AFTER_PPM" "$BEFORE_PPM.raw" "$AFTER_PPM.raw" "$BUILD_DIR/evidence.env"

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*|./src/compiler_rust/*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

if [ -n "${SIMPLE_BIN:-}" ]; then
    if is_rust_seed_simple "$SIMPLE_BIN"; then
        SIMPLE_BIN_SOURCE="explicit-env-rust-seed-forbidden"
        SIMPLE_BIN_STATUS=forbidden
    fi
else
    SIMPLE_BIN=""
    SIMPLE_BIN_SOURCE=missing
    for candidate in \
        "$ROOT_DIR"/bin/release/*/simple \
        "$ROOT_DIR"/release/*/simple \
        "$ROOT_DIR"/build/bootstrap/stage3/simple \
        "$ROOT_DIR"/bin/simple
    do
        if [ -f "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            SIMPLE_BIN_SOURCE="self-hosted:$candidate"
            SIMPLE_BIN_STATUS=pass
            break
        fi
    done
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS

cleanup() {
    if [ -n "$PID" ]; then
        kill "$PID" >/dev/null 2>&1 || true
        wait "$PID" >/dev/null 2>&1 || true
    fi
}
trap cleanup EXIT INT TERM

file_byte_count() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

regular_file_status() {
    path="$1"
    if [ -z "$path" ]; then
        echo "missing-path"
    elif [ -L "$path" ]; then
        echo "symlink"
    elif [ ! -f "$path" ]; then
        echo "missing"
    elif [ ! -s "$path" ]; then
        echo "empty"
    else
        echo "pass"
    fi
}

ppm_magic_status() {
    path="$1"
    if [ "$(regular_file_status "$path")" != "pass" ]; then
        regular_file_status "$path"
    elif head -c 2 "$path" 2>/dev/null | grep -q '^P6$'; then
        echo "pass"
    else
        echo "invalid-magic"
    fi
}

field() {
    sed -n "s/^$1=//p" "$2" | tail -n 1
}

source_contains_any() {
    path="$1"
    shift
    if [ ! -f "$path" ]; then
        return 1
    fi
    for pattern in "$@"; do
        if grep -q "$pattern" "$path"; then
            return 0
        fi
    done
    return 1
}

classify_guest_input_contract() {
    entry_path="$1"
    guest_entry_mouse_poll_status=missing
    guest_entry_keyboard_poll_status=missing
    guest_input_contract_status=fail
    guest_input_contract_reason=guest-entry-mouse-contract-missing
    if [ -z "$entry_path" ]; then
        guest_input_contract_reason=guest-entry-not-reported
        return
    fi
    if [ ! -f "$entry_path" ]; then
        guest_input_contract_reason=guest-entry-source-missing
        return
    fi
    if source_contains_any "$entry_path" "_poll_qemu_mouse" "Ps2Mouse" "MOUSE_STATUS_AUX_DATA" "host-input"; then
        guest_entry_mouse_poll_status=pass
    fi
    if source_contains_any "$entry_path" "_poll_qemu_keyboard_input" "qemu-keyboard-repainted"; then
        guest_entry_keyboard_poll_status=pass
    fi
    if [ "$guest_entry_mouse_poll_status" = "pass" ]; then
        guest_input_contract_status=pass
        guest_input_contract_reason=pass
    elif [ "$guest_entry_keyboard_poll_status" = "pass" ]; then
        guest_input_contract_reason=guest-entry-keyboard-only-for-mouse-injection
    fi
}

status=unavailable
reason=not-run
changed_bytes=0
source_region_changed=0
target_region_changed=0
before_raw_bytes=0
after_raw_bytes=0
before_sha256=
after_sha256=
guest_input_contract_status=not-run
guest_input_contract_reason=not-run
guest_entry_mouse_poll_status=not-run
guest_entry_keyboard_poll_status=not-run
injection_protocol=hmp-mouse-events
guest_shared_pointer_event_status=not-run
guest_shared_pointer_event_reason=not-run
guest_mouse_packet_status=not-run
guest_mouse_packet_reason=not-run
framebuffer_delta_status=not-run
framebuffer_delta_reason=not-run
event_evidence_status=not-run
event_evidence_reason=not-run

emit_simple_bin_failure() {
    reason="$1"
    {
        echo "qemu_wm_drag_delta_status=fail"
        echo "qemu_wm_drag_delta_reason=$reason"
        echo "qemu_wm_drag_delta_simple_bin=$SIMPLE_BIN"
        echo "qemu_wm_drag_delta_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "qemu_wm_drag_delta_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "qemu_wm_drag_delta_launch_out=$LAUNCH_OUT"
        echo "qemu_wm_drag_delta_drag_out=$DRAG_OUT"
    } >"$BUILD_DIR/evidence.env"
    {
        echo "# SimpleOS WM QMP Drag Delta Evidence"
        echo
        echo "- status: fail"
        echo "- reason: $reason"
        echo "- simple bin: $SIMPLE_BIN"
        echo "- simple bin source: $SIMPLE_BIN_SOURCE"
        echo "- simple bin status: $SIMPLE_BIN_STATUS"
    } >"$REPORT_PATH"
    cat "$BUILD_DIR/evidence.env"
}

if [ "$SIMPLE_BIN_STATUS" = forbidden ]; then
    emit_simple_bin_failure "simple-bin-forbidden"
    exit 1
fi

if [ ! -f "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    emit_simple_bin_failure "simple-bin-missing"
    exit 1
fi

set +e
SIMPLE_LIB="${SIMPLE_LIB:-src}" \
SIMPLE_BINARY="$SIMPLE_BIN" \
SIMPLE_OS_LOG_MODE="${SIMPLE_OS_LOG_MODE:-off}" \
SIMPLEOS_DESKTOP_QMP_TARGET=wm-simple-web \
SIMPLEOS_DESKTOP_QMP_KEEPALIVE=1 \
SIMPLEOS_DESKTOP_QMP_LAUNCH_TIMEOUT_MS="${SIMPLEOS_WM_QMP_LAUNCH_TIMEOUT_MS:-90000}" \
    "$SIMPLE_BIN" run src/app/test/simpleos_desktop_qmp_launch.spl --mode=interpreter --clean >"$LAUNCH_OUT" 2>&1
launch_code=$?
set -e

launcher_status="$(field simpleos_desktop_qmp_status "$LAUNCH_OUT")"
launcher_reason="$(field simpleos_desktop_qmp_reason "$LAUNCH_OUT")"
launcher_target="$(field simpleos_desktop_qmp_target "$LAUNCH_OUT")"
launcher_entry="$(field simpleos_desktop_qmp_entry "$LAUNCH_OUT")"
if [ "${launcher_reason:-}" = "wm-simple-web-build-failed" ] && grep -q 'phase=native-build FAILED .*timeout_ms=' "$LAUNCH_OUT"; then
    launcher_reason=wm-simple-web-build-timeout
fi
PID="$(field simpleos_desktop_qmp_pid "$LAUNCH_OUT")"
qmp_socket="$(field simpleos_desktop_qmp_socket "$LAUNCH_OUT")"
serial_log="$(field simpleos_desktop_qmp_serial_log "$LAUNCH_OUT")"
stderr_log="$(field simpleos_desktop_qmp_stderr_log "$LAUNCH_OUT")"
marker_state="$(field simpleos_desktop_qmp_marker_state "$LAUNCH_OUT")"
classify_guest_input_contract "$launcher_entry"

if [ "$launch_code" -eq 0 ] && [ "$launcher_status" = "pass" ] && [ -S "$qmp_socket" ]; then
    set +e
    python3 - "$qmp_socket" "$BEFORE_PPM" "$AFTER_PPM" >"$DRAG_OUT" 2>&1 <<'PY'
import hashlib
import json
import os
import socket
import sys
import time

sock_path, before_ppm, after_ppm = sys.argv[1], sys.argv[2], sys.argv[3]
before_raw = before_ppm + ".raw"
after_raw = after_ppm + ".raw"

def write_qmp(f, obj):
    f.write(json.dumps(obj).encode() + b"\n")
    f.flush()
    return f.readline()

def hmp(f, cmd):
    return write_qmp(f, {"execute": "human-monitor-command", "arguments": {"command-line": cmd}})

def wait_raw(path):
    for _ in range(100):
        if os.path.exists(path) and os.path.getsize(path) >= 3145728:
            return True
        time.sleep(0.1)
    return False

def pmem(f, raw_path, ppm_path):
    hmp(f, 'pmemsave 0xfd000000 3145728 "%s"' % raw_path)
    ok = wait_raw(raw_path)
    data = open(raw_path, "rb").read() if ok else b""
    if len(data) == 3145728:
        pix = bytearray()
        for i in range(0, 1024 * 768 * 4, 4):
            pix.extend([data[i + 2], data[i + 1], data[i]])
        with open(ppm_path, "wb") as out:
            out.write(b"P6\n1024 768\n255\n" + bytes(pix))
    return data

def changed_pixels_in(mem0, mem1, x0, y0, x1, y1):
    total = 0
    for y in range(y0, y1):
        row = y * 1024 * 4
        for x in range(x0, x1):
            i = row + x * 4
            if mem0[i:i + 4] != mem1[i:i + 4]:
                total += 1
    return total

s = socket.socket(socket.AF_UNIX)
s.settimeout(5)
s.connect(sock_path)
f = s.makefile("rwb", buffering=0)
f.readline()
write_qmp(f, {"execute": "qmp_capabilities"})

mem0 = pmem(f, before_raw, before_ppm)
hmp(f, "mouse_move 360 132")
time.sleep(0.05)
hmp(f, "mouse_button 1")
time.sleep(0.08)
hmp(f, "mouse_move 160 80")
time.sleep(0.08)
hmp(f, "mouse_move 160 80")
time.sleep(0.08)
hmp(f, "mouse_button 0")
time.sleep(0.35)
mem1 = pmem(f, after_raw, after_ppm)

valid = len(mem0) == 3145728 and len(mem1) == 3145728
changed = sum(1 for a, b in zip(mem0, mem1) if a != b) if valid else 0
source_region = changed_pixels_in(mem0, mem1, 320, 140, 470, 240) if valid else 0
target_region = changed_pixels_in(mem0, mem1, 120, 60, 300, 190) if valid else 0
sha0 = hashlib.sha256(mem0).hexdigest() if mem0 else ""
sha1 = hashlib.sha256(mem1).hexdigest() if mem1 else ""
print("qemu_wm_drag_delta before_raw_bytes=%d after_raw_bytes=%d changed_bytes=%d source_region_changed=%d target_region_changed=%d before_sha256=%s after_sha256=%s before_ppm=%s after_ppm=%s" % (
    len(mem0), len(mem1), changed, source_region, target_region, sha0, sha1, before_ppm, after_ppm
))
sys.exit(0 if valid and changed > 2048 and source_region > 100 and target_region > 100 and sha0 != sha1 else 5)
PY
    drag_code=$?
    set -e
    drag_line="$(sed -n '/^qemu_wm_drag_delta /p' "$DRAG_OUT" | tail -n 1)"
    changed_bytes="$(printf '%s\n' "$drag_line" | sed -n 's/.* changed_bytes=\([0-9][0-9]*\).*/\1/p')"
    source_region_changed="$(printf '%s\n' "$drag_line" | sed -n 's/.* source_region_changed=\([0-9][0-9]*\).*/\1/p')"
    target_region_changed="$(printf '%s\n' "$drag_line" | sed -n 's/.* target_region_changed=\([0-9][0-9]*\).*/\1/p')"
    before_raw_bytes="$(printf '%s\n' "$drag_line" | sed -n 's/.* before_raw_bytes=\([0-9][0-9]*\).*/\1/p')"
    after_raw_bytes="$(printf '%s\n' "$drag_line" | sed -n 's/.* after_raw_bytes=\([0-9][0-9]*\).*/\1/p')"
    before_sha256="$(printf '%s\n' "$drag_line" | sed -n 's/.* before_sha256=\([^ ]*\).*/\1/p')"
    after_sha256="$(printf '%s\n' "$drag_line" | sed -n 's/.* after_sha256=\([^ ]*\).*/\1/p')"
    changed_bytes="${changed_bytes:-0}"
    source_region_changed="${source_region_changed:-0}"
    target_region_changed="${target_region_changed:-0}"
    before_raw_bytes="${before_raw_bytes:-0}"
    after_raw_bytes="${after_raw_bytes:-0}"
    if [ -f "$serial_log" ] && grep -Fq "[mdi-demo] qemu-shared-pointer-event source=wm_lifecycle_pointer_move action=drag" "$serial_log"; then
        guest_shared_pointer_event_status=pass
        guest_shared_pointer_event_reason=pass
    else
        guest_shared_pointer_event_status=fail
        guest_shared_pointer_event_reason=missing-shared-pointer-event-marker
    fi
    if [ -f "$serial_log" ] && grep -Fq "[mdi-demo] qemu-mouse-packet left=1" "$serial_log"; then
        guest_mouse_packet_status=pass
        guest_mouse_packet_reason=pass
    else
        guest_mouse_packet_status=fail
        guest_mouse_packet_reason=missing-decoded-left-mouse-packet
    fi
    if [ "$drag_code" -eq 0 ]; then
        framebuffer_delta_status=pass
        framebuffer_delta_reason=pass
    elif [ "$before_raw_bytes" -ne 3145728 ] || [ "$after_raw_bytes" -ne 3145728 ]; then
        framebuffer_delta_status=fail
        framebuffer_delta_reason=missing-framebuffer-captures
    elif [ "$changed_bytes" -le 2048 ]; then
        framebuffer_delta_status=fail
        framebuffer_delta_reason=insufficient-framebuffer-byte-delta
    elif [ "$source_region_changed" -le 100 ]; then
        framebuffer_delta_status=fail
        framebuffer_delta_reason=insufficient-source-region-delta
    elif [ "$target_region_changed" -le 100 ]; then
        framebuffer_delta_status=fail
        framebuffer_delta_reason=insufficient-target-region-delta
    elif [ -z "$before_sha256" ] || [ "$before_sha256" = "$after_sha256" ]; then
        framebuffer_delta_status=fail
        framebuffer_delta_reason=framebuffer-sha-unchanged
    else
        framebuffer_delta_status=fail
        framebuffer_delta_reason=qmp-drag-delta-not-proven
    fi
    if [ "$guest_mouse_packet_status" != "pass" ]; then
        event_evidence_status=fail
        event_evidence_reason="$guest_mouse_packet_reason"
    elif [ "$guest_shared_pointer_event_status" != "pass" ]; then
        event_evidence_status=fail
        event_evidence_reason="$guest_shared_pointer_event_reason"
    elif [ "$framebuffer_delta_status" != "pass" ]; then
        event_evidence_status=fail
        event_evidence_reason="$framebuffer_delta_reason"
    else
        event_evidence_status=pass
        event_evidence_reason=pass
    fi
    if [ "$event_evidence_status" = "pass" ]; then
        status=pass
        reason=pass
    elif [ "$guest_input_contract_status" != "pass" ] && [ "${changed_bytes:-0}" = "0" ]; then
        status=fail
        reason="$guest_input_contract_reason"
    else
        status=fail
        reason="$event_evidence_reason"
    fi
else
    reason="${launcher_reason:-wm-qmp-launch-failed}"
fi

{
    echo "qemu_wm_drag_delta_status=$status"
    echo "qemu_wm_drag_delta_reason=$reason"
    echo "qemu_wm_drag_delta_simple_bin=$SIMPLE_BIN"
    echo "qemu_wm_drag_delta_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "qemu_wm_drag_delta_simple_bin_status=$SIMPLE_BIN_STATUS"
    echo "qemu_wm_drag_delta_launcher_status=${launcher_status:-}"
    echo "qemu_wm_drag_delta_launcher_reason=${launcher_reason:-}"
    echo "qemu_wm_drag_delta_launcher_target=${launcher_target:-}"
    echo "qemu_wm_drag_delta_launcher_entry=${launcher_entry:-}"
    echo "qemu_wm_drag_delta_launcher_exit_code=$launch_code"
    echo "qemu_wm_drag_delta_qmp_socket=${qmp_socket:-}"
    echo "qemu_wm_drag_delta_serial_log=${serial_log:-}"
    echo "qemu_wm_drag_delta_serial_log_bytes=$(file_byte_count "${serial_log:-}")"
    echo "qemu_wm_drag_delta_stderr_log=${stderr_log:-}"
    echo "qemu_wm_drag_delta_stderr_log_bytes=$(file_byte_count "${stderr_log:-}")"
    echo "qemu_wm_drag_delta_marker_state=${marker_state:-}"
    echo "qemu_wm_drag_delta_injection_protocol=$injection_protocol"
    echo "qemu_wm_drag_delta_guest_input_contract_status=$guest_input_contract_status"
    echo "qemu_wm_drag_delta_guest_input_contract_reason=$guest_input_contract_reason"
    echo "qemu_wm_drag_delta_guest_entry_mouse_poll_status=$guest_entry_mouse_poll_status"
    echo "qemu_wm_drag_delta_guest_entry_keyboard_poll_status=$guest_entry_keyboard_poll_status"
    echo "qemu_wm_drag_delta_guest_shared_pointer_event_status=$guest_shared_pointer_event_status"
    echo "qemu_wm_drag_delta_guest_shared_pointer_event_reason=$guest_shared_pointer_event_reason"
    echo "qemu_wm_drag_delta_guest_mouse_packet_status=$guest_mouse_packet_status"
    echo "qemu_wm_drag_delta_guest_mouse_packet_reason=$guest_mouse_packet_reason"
    echo "qemu_wm_drag_delta_framebuffer_delta_status=$framebuffer_delta_status"
    echo "qemu_wm_drag_delta_framebuffer_delta_reason=$framebuffer_delta_reason"
    echo "qemu_wm_drag_delta_event_evidence_status=$event_evidence_status"
    echo "qemu_wm_drag_delta_event_evidence_reason=$event_evidence_reason"
    echo "qemu_wm_drag_delta_changed_bytes=${changed_bytes:-0}"
    echo "qemu_wm_drag_delta_source_region_changed=${source_region_changed:-0}"
    echo "qemu_wm_drag_delta_target_region_changed=${target_region_changed:-0}"
    echo "qemu_wm_drag_delta_before_sha256=$before_sha256"
    echo "qemu_wm_drag_delta_after_sha256=$after_sha256"
    echo "qemu_wm_drag_delta_before_ppm=$BEFORE_PPM"
    echo "qemu_wm_drag_delta_before_raw=$BEFORE_RAW"
    echo "qemu_wm_drag_delta_before_raw_file_status=$(regular_file_status "$BEFORE_RAW")"
    echo "qemu_wm_drag_delta_before_raw_bytes=$(file_byte_count "$BEFORE_RAW")"
    echo "qemu_wm_drag_delta_before_ppm_file_status=$(regular_file_status "$BEFORE_PPM")"
    echo "qemu_wm_drag_delta_before_ppm_magic_status=$(ppm_magic_status "$BEFORE_PPM")"
    echo "qemu_wm_drag_delta_before_ppm_bytes=$(file_byte_count "$BEFORE_PPM")"
    echo "qemu_wm_drag_delta_after_ppm=$AFTER_PPM"
    echo "qemu_wm_drag_delta_after_raw=$AFTER_RAW"
    echo "qemu_wm_drag_delta_after_raw_file_status=$(regular_file_status "$AFTER_RAW")"
    echo "qemu_wm_drag_delta_after_raw_bytes=$(file_byte_count "$AFTER_RAW")"
    echo "qemu_wm_drag_delta_after_ppm_file_status=$(regular_file_status "$AFTER_PPM")"
    echo "qemu_wm_drag_delta_after_ppm_magic_status=$(ppm_magic_status "$AFTER_PPM")"
    echo "qemu_wm_drag_delta_after_ppm_bytes=$(file_byte_count "$AFTER_PPM")"
    echo "qemu_wm_drag_delta_launch_out=$LAUNCH_OUT"
    echo "qemu_wm_drag_delta_drag_out=$DRAG_OUT"
} >"$BUILD_DIR/evidence.env"

{
    echo "# SimpleOS WM QMP Drag Delta Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- simple bin: $SIMPLE_BIN"
    echo "- simple bin source: $SIMPLE_BIN_SOURCE"
    echo "- simple bin status: $SIMPLE_BIN_STATUS"
    echo "- launcher status: ${launcher_status:-}"
    echo "- launcher reason: ${launcher_reason:-}"
    echo "- launcher target: ${launcher_target:-}"
    echo "- launcher entry: ${launcher_entry:-}"
    echo "- qmp socket: ${qmp_socket:--}"
    echo "- marker state: ${marker_state:--}"
    echo "- injection protocol: $injection_protocol"
    echo "- guest input contract: $guest_input_contract_status ($guest_input_contract_reason)"
    echo "- guest mouse polling: $guest_entry_mouse_poll_status"
    echo "- guest keyboard polling: $guest_entry_keyboard_poll_status"
    echo "- guest shared pointer event: $guest_shared_pointer_event_status ($guest_shared_pointer_event_reason)"
    echo "- guest decoded mouse packet: $guest_mouse_packet_status ($guest_mouse_packet_reason)"
    echo "- framebuffer delta: $framebuffer_delta_status ($framebuffer_delta_reason)"
    echo "- event evidence: $event_evidence_status ($event_evidence_reason)"
    echo "- changed bytes: ${changed_bytes:-0}"
    echo "- source region changed pixels: ${source_region_changed:-0}"
    echo "- target region changed pixels: ${target_region_changed:-0}"
    echo "- before sha256: ${before_sha256:--}"
    echo "- after sha256: ${after_sha256:--}"
    echo "- before ppm: $BEFORE_PPM ($(file_byte_count "$BEFORE_PPM") bytes)"
    echo "- before raw: $BEFORE_RAW ($(file_byte_count "$BEFORE_RAW") bytes; $(regular_file_status "$BEFORE_RAW"))"
    echo "- before ppm status: $(regular_file_status "$BEFORE_PPM"); magic $(ppm_magic_status "$BEFORE_PPM")"
    echo "- after ppm: $AFTER_PPM ($(file_byte_count "$AFTER_PPM") bytes)"
    echo "- after raw: $AFTER_RAW ($(file_byte_count "$AFTER_RAW") bytes; $(regular_file_status "$AFTER_RAW"))"
    echo "- after ppm status: $(regular_file_status "$AFTER_PPM"); magic $(ppm_magic_status "$AFTER_PPM")"
    echo "- serial log: ${serial_log:--} ($(file_byte_count "${serial_log:-}") bytes)"
    echo "- stderr log: ${stderr_log:--} ($(file_byte_count "${stderr_log:-}") bytes)"
    echo
    echo "This wrapper launches the exact WM + Simple Web + Engine2D target in a"
    echo "separate QEMU process, captures the BGA framebuffer with QMP"
    echo "\`pmemsave\`, injects HMP \`mouse_move\` / \`mouse_button\` events, and"
    echo "requires both global byte changes and drag-region-local changes. It does"
    echo "not use blur, downscaling, tolerance matching, or copied reference pixels."
} >"$REPORT_PATH"

cat "$BUILD_DIR/evidence.env"

[ "$status" = "pass" ]
