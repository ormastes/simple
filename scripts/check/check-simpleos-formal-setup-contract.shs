#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
SETUP="$ROOT_DIR/scripts/setup/setup-simpleos-formal-env.shs"
PREREQ="$ROOT_DIR/scripts/check/check-simpleos-mission-critical-prereqs.shs"
RELEASE="$ROOT_DIR/scripts/check/check-simpleos-mission-critical-release.shs"
RTL_PROOF="$ROOT_DIR/scripts/check/check-riscv-rtl-sby-proof.shs"

print_out="$(sh "$SETUP" --print-install)"
printf '%s\n' "$print_out" | grep -Fq "sudo apt-get install yosys symbiyosys boolector z3" || {
    echo "FAIL: setup helper missing package install guidance" >&2
    exit 1
}
printf '%s\n' "$print_out" | grep -Fq "scripts/check/check-simpleos-mission-critical-release.shs" || {
    echo "FAIL: setup helper missing release rerun guidance" >&2
    exit 1
}

if sh "$SETUP" --check >/tmp/simpleos-formal-setup-check.out 2>/tmp/simpleos-formal-setup-check.err; then
    grep -Fq "STATUS: PASS simpleos-mission-critical-prereqs" /tmp/simpleos-formal-setup-check.out || {
        echo "FAIL: setup --check passed without prereq PASS status" >&2
        exit 1
    }
else
    grep -Fq "simpleos_mission_critical_prereqs_status=blocked" /tmp/simpleos-formal-setup-check.out || {
        echo "FAIL: setup --check failed without blocked prereq status" >&2
        exit 1
    }
fi
expected_prereq_status="$(sed -n 's/^simpleos_mission_critical_prereqs_status=//p' /tmp/simpleos-formal-setup-check.out | tail -n 1)"
expected_prereq_missing="$(sed -n 's/^simpleos_mission_critical_prereqs_missing=//p' /tmp/simpleos-formal-setup-check.out | tail -n 1)"
expected_prereq_next_action="$(sed -n 's/^simpleos_mission_critical_prereqs_next_action=//p' /tmp/simpleos-formal-setup-check.out | tail -n 1)"
expected_prereq_status="${expected_prereq_status:-missing}"
expected_prereq_missing="${expected_prereq_missing:-missing}"
expected_prereq_next_action="${expected_prereq_next_action:-missing}"

grep -Fq "scripts/setup/setup-simpleos-formal-env.shs --print-install" "$PREREQ" || {
    echo "FAIL: prereq doctor missing setup helper next action" >&2
    exit 1
}

fake_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-bin"
mkdir -p "$fake_bin"
for tool in sby yosys boolector; do
    printf '#!/usr/bin/env sh\nexit 0\n' >"$fake_bin/$tool"
    chmod +x "$fake_bin/$tool"
done
PATH="$fake_bin:$PATH" sh "$PREREQ" >/tmp/simpleos-formal-prereq-ready.out 2>/tmp/simpleos-formal-prereq-ready.err
grep -Fq "simpleos_mission_critical_prereqs_status=ready" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing ready status" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_missing=none" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing none blocker" >&2
    exit 1
}
grep -Fq "simpleos_mission_critical_prereqs_next_action=none" /tmp/simpleos-formal-prereq-ready.out || {
    echo "FAIL: prereq doctor fake installed stack missing none next action" >&2
    exit 1
}

z3_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/z3-bin"
mkdir -p "$z3_bin"
for tool in sby yosys z3; do
    : >"$z3_bin/$tool"
    chmod +x "$z3_bin/$tool"
done
PATH="$z3_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-z3.out 2>/tmp/simpleos-formal-prereq-z3.err
grep -Fq "simpleos_mission_critical_prereqs_status=ready" /tmp/simpleos-formal-prereq-z3.out || {
    echo "FAIL: prereq doctor fake z3 stack missing ready status" >&2
    exit 1
}

missing_sby_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/missing-sby-bin"
mkdir -p "$missing_sby_bin"
for tool in yosys z3; do
    : >"$missing_sby_bin/$tool"
    chmod +x "$missing_sby_bin/$tool"
done
if PATH="$missing_sby_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-missing-sby.out 2>/tmp/simpleos-formal-prereq-missing-sby.err; then
    echo "FAIL: prereq doctor fake missing-sby stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_missing=sby" /tmp/simpleos-formal-prereq-missing-sby.out || {
    echo "FAIL: prereq doctor fake missing-sby stack missing sby blocker" >&2
    exit 1
}

missing_solver_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/missing-solver-bin"
mkdir -p "$missing_solver_bin"
for tool in sby yosys; do
    : >"$missing_solver_bin/$tool"
    chmod +x "$missing_solver_bin/$tool"
done
if PATH="$missing_solver_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-missing-solver.out 2>/tmp/simpleos-formal-prereq-missing-solver.err; then
    echo "FAIL: prereq doctor fake missing-solver stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_missing=smt-solver" /tmp/simpleos-formal-prereq-missing-solver.out || {
    echo "FAIL: prereq doctor fake missing-solver stack missing smt blocker" >&2
    exit 1
}

partial_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/partial-bin"
mkdir -p "$partial_bin"
printf '#!/usr/bin/env sh\nexit 0\n' >"$partial_bin/sby"
chmod +x "$partial_bin/sby"
if PATH="$partial_bin" /bin/sh "$PREREQ" >/tmp/simpleos-formal-prereq-partial.out 2>/tmp/simpleos-formal-prereq-partial.err; then
    echo "FAIL: prereq doctor fake partial stack passed" >&2
    exit 1
fi
grep -Fq "simpleos_mission_critical_prereqs_missing=yosys,smt-solver" /tmp/simpleos-formal-prereq-partial.out || {
    echo "FAIL: prereq doctor fake partial stack missing yosys/smt blocker" >&2
    exit 1
}

rtl_partial_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-partial-bin"
mkdir -p "$rtl_partial_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_partial_bin/dirname"
printf '#!/bin/sh\nexit 0\n' >"$rtl_partial_bin/sby"
chmod +x "$rtl_partial_bin/dirname" "$rtl_partial_bin/sby"
if PATH="$rtl_partial_bin" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-partial.out 2>/tmp/simpleos-formal-rtl-partial.err; then
    echo "FAIL: RISC-V SBY proof fake partial stack passed" >&2
    exit 1
fi
grep -Fq "reason=missing-formal-prereqs missing=yosys,smt-solver" /tmp/simpleos-formal-rtl-partial.err || {
    echo "FAIL: RISC-V SBY proof fake partial stack missing yosys/smt blocker" >&2
    exit 1
}

rtl_missing_sby_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-sby-bin"
mkdir -p "$rtl_missing_sby_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_missing_sby_bin/dirname"
for tool in yosys z3; do
    : >"$rtl_missing_sby_bin/$tool"
    chmod +x "$rtl_missing_sby_bin/$tool"
done
chmod +x "$rtl_missing_sby_bin/dirname"
if PATH="$rtl_missing_sby_bin" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-missing-sby.out 2>/tmp/simpleos-formal-rtl-missing-sby.err; then
    echo "FAIL: RISC-V SBY proof fake missing-sby stack passed" >&2
    exit 1
fi
grep -Fq "reason=missing-formal-prereqs missing=sby" /tmp/simpleos-formal-rtl-missing-sby.err || {
    echo "FAIL: RISC-V SBY proof fake missing-sby stack missing sby blocker" >&2
    exit 1
}

rtl_missing_solver_bin="$ROOT_DIR/build/simpleos_formal_setup_contract/rtl-missing-solver-bin"
mkdir -p "$rtl_missing_solver_bin"
printf '#!/bin/sh\nexec /usr/bin/dirname "$@"\n' >"$rtl_missing_solver_bin/dirname"
for tool in sby yosys; do
    : >"$rtl_missing_solver_bin/$tool"
    chmod +x "$rtl_missing_solver_bin/$tool"
done
chmod +x "$rtl_missing_solver_bin/dirname"
if PATH="$rtl_missing_solver_bin" /bin/sh "$RTL_PROOF" >/tmp/simpleos-formal-rtl-missing-solver.out 2>/tmp/simpleos-formal-rtl-missing-solver.err; then
    echo "FAIL: RISC-V SBY proof fake missing-solver stack passed" >&2
    exit 1
fi
grep -Fq "reason=missing-formal-prereqs missing=smt-solver" /tmp/simpleos-formal-rtl-missing-solver.err || {
    echo "FAIL: RISC-V SBY proof fake missing-solver stack missing smt blocker" >&2
    exit 1
}

fake_matrix="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-matrix-pass-prereq-blocked.shs"
cat >"$fake_matrix" <<'EOF'
#!/usr/bin/env sh
echo "simpleos_hardening_mission_critical_release_status=pass"
echo "simpleos_hardening_mission_critical_release_blockers=none"
echo "simpleos_hardening_mission_critical_prereqs_status=blocked"
echo "simpleos_hardening_mission_critical_prereqs_missing=sby"
echo "simpleos_hardening_mission_critical_prereqs_next_action=install-formal-stack"
EOF
chmod +x "$fake_matrix"
if MATRIX="$fake_matrix" BUILD_DIR="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-release" \
    REPORT_PATH="$ROOT_DIR/build/simpleos_formal_setup_contract/fake-release.md" \
    sh "$RELEASE" >/tmp/simpleos-formal-release-fake.out 2>/tmp/simpleos-formal-release-fake.err; then
    echo "FAIL: release gate accepted matrix pass with blocked prereqs" >&2
    exit 1
fi
grep -Fq "prereq_status=blocked" /tmp/simpleos-formal-release-fake.err || {
    echo "FAIL: release gate fake matrix failure missing blocked prereq status" >&2
    exit 1
}

if BUILD_DIR="$ROOT_DIR/build/simpleos_formal_setup_contract/release" \
    REPORT_PATH="$ROOT_DIR/build/simpleos_formal_setup_contract/release.md" \
    sh "$RELEASE" >/tmp/simpleos-formal-release-check.out 2>/tmp/simpleos-formal-release-check.err; then
    grep -Fq "STATUS: PASS simpleos-mission-critical-release" /tmp/simpleos-formal-release-check.out || {
        echo "FAIL: release gate passed without PASS status" >&2
        exit 1
    }
else
    grep -Fq "prereq_status=$expected_prereq_status" /tmp/simpleos-formal-release-check.err || {
        echo "FAIL: release gate failure missing prereq status" >&2
        exit 1
    }
    grep -Fq "prereq_missing=$expected_prereq_missing" /tmp/simpleos-formal-release-check.err || {
        echo "FAIL: release gate failure missing prereq blockers" >&2
        exit 1
    }
    grep -Fq "prereq_next_action=$expected_prereq_next_action" /tmp/simpleos-formal-release-check.err || {
        echo "FAIL: release gate failure missing prereq next action" >&2
        exit 1
    }
fi

echo "STATUS: PASS simpleos-formal-setup-contract"
