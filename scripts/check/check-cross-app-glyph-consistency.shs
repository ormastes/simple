#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

# Configuration
SIMPLE_BIN="${SIMPLE_BIN:-bin/simple}"
DRIVER="src/app/test/cross_app_glyph_capture.spl"
DRIVER_TIMEOUT_SECS="${SIMPLE_CROSS_APP_GLYPH_TIMEOUT_SECS:-180}"
WORK_DIR="${SIMPLE_CROSS_APP_GLYPH_WORK_DIR:-build/cross-app-glyph-consistency}"
EVIDENCE_LOG="$WORK_DIR/evidence.log"
ENV_PATH="$WORK_DIR/evidence.env"

have() {
    command -v "$1" >/dev/null 2>&1
}

run_with_timeout() {
    secs="$1"
    shift
    if have timeout; then
        timeout "$secs" "$@"
    else
        "$@"
    fi
}

mkdir -p "$WORK_DIR"
rm -f "$EVIDENCE_LOG" "$ENV_PATH"

echo "check=cross_app_glyph_consistency"
echo "simple_bin=$SIMPLE_BIN"
echo "driver=$DRIVER"

if [ ! -x "$SIMPLE_BIN" ]; then
    echo "overall=fail"
    echo "error=missing_executable:$SIMPLE_BIN"
    exit 1
fi
if [ ! -f "$DRIVER" ]; then
    echo "overall=fail"
    echo "error=missing_driver:$DRIVER"
    exit 1
fi

all_pass=true
{
    echo "check=cross_app_glyph_consistency"

    # Offscreen only — both text paths (Engine2D SoftwareBackend and the
    # pure-Simple web layout renderer) never open a display.
    set +e
    run_with_timeout "$DRIVER_TIMEOUT_SECS" env \
        DISPLAY="" \
        SIMPLE_GUI=0 \
        "$SIMPLE_BIN" run "$DRIVER" "$WORK_DIR" >"$WORK_DIR/capture.log" 2>&1
    driver_exit=$?
    set -e
    echo "driver_exit=$driver_exit"

    # Forward the driver's key=value evidence lines (drops compiler warnings).
    grep -E '^[a-zA-Z0-9_]+=' "$WORK_DIR/capture.log" || true

    if [ "$driver_exit" -ne 0 ]; then
        all_pass=false
        echo "driver_status=fail"
    elif ! grep -q '^capture_overall=pass$' "$WORK_DIR/capture.log"; then
        all_pass=false
        echo "driver_status=fail"
    else
        echo "driver_status=pass"
    fi

    # The gate this check exists to evaluate (G2.5: identical glyph
    # rasterization across apps) is a SEPARATE verdict from whether the
    # capture+compare infrastructure ran correctly. Today the two text paths
    # use independently authored 5x7 bitmap tables (Engine2D glyph.spl vs the
    # browser's simple_web_html_layout_renderer.spl FONT_ROWS_PACKED) that
    # diverge for most letters — recorded honestly, not gated into overall,
    # matching the link_click_status convention in check-browser-interaction.shs.
    if grep -q '^glyph_consistency_status=diverges$' "$WORK_DIR/capture.log"; then
        echo "glyph_consistency_gate=fail_recorded_not_gating_overall"
    elif grep -q '^glyph_consistency_status=identical$' "$WORK_DIR/capture.log"; then
        echo "glyph_consistency_gate=pass"
    else
        echo "glyph_consistency_gate=unknown"
    fi

    if [ "$all_pass" = "true" ]; then
        echo "overall=pass"
    else
        echo "overall=fail"
    fi
} 2>&1 | tee "$EVIDENCE_LOG"

cp "$EVIDENCE_LOG" "$ENV_PATH" || true
echo "evidence_log=$EVIDENCE_LOG"
grep -q '^overall=pass$' "$EVIDENCE_LOG"
