    proof_source_actual_size_bytes="$(file_size_bytes "$proof_source")"
    proof_source_file_reason="$(artifact_file_reason "$proof_source" "$proof_source_size_bytes")"
    proof_source_artifact_status="$(artifact_file_status "$proof_source_file_reason")"
    if [ "$code" -eq 124 ]; then
        event_status=timeout
        event_reason=event-routing-timeout
    fi
    {
        echo "production_gui_web_renderer_parity_event_routing_exit_code=$code"
        echo "production_gui_web_renderer_parity_event_routing_status=$event_status"
        echo "production_gui_web_renderer_parity_event_routing_reason=$event_reason"
        echo "production_gui_web_renderer_parity_event_routing_validation_status=$validation_status"
        echo "production_gui_web_renderer_parity_event_routing_validation_reason=$validation_reason"
        echo "production_gui_web_renderer_parity_event_routing_proof_symlink_status=$proof_symlink_status"
        echo "production_gui_web_renderer_parity_event_routing_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_event_routing_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_event_routing_ready=$ready"
        echo "production_gui_web_renderer_parity_event_routing_wm_found=$wm_found"
        echo "production_gui_web_renderer_parity_event_routing_focus_count=$focus_count"
        echo "production_gui_web_renderer_parity_event_routing_move_count=$move_count"
        echo "production_gui_web_renderer_parity_event_routing_maximize_count=$maximize_count"
        echo "production_gui_web_renderer_parity_event_routing_title_command_count=$title_command_count"
        echo "production_gui_web_renderer_parity_event_routing_text_input_count=$text_input_count"
        echo "production_gui_web_renderer_parity_event_routing_pointer_down_count=$pointer_down_count"
        echo "production_gui_web_renderer_parity_event_routing_pointer_up_count=$pointer_up_count"
        echo "production_gui_web_renderer_parity_event_routing_performance_now_available=$performance_now_available"
        echo "production_gui_web_renderer_parity_event_routing_performance_now_delta_ms=$performance_now_delta_ms"
        echo "production_gui_web_renderer_parity_event_routing_input_to_paint_ms=$input_to_paint_ms"
        echo "production_gui_web_renderer_parity_event_routing_animation_frame_available=$animation_frame_available"
        echo "production_gui_web_renderer_parity_event_routing_animation_frame_count=$animation_frame_count"
        echo "production_gui_web_renderer_parity_event_routing_css_animation_probe=$css_animation_probe"
        echo "production_gui_web_renderer_parity_event_routing_event_sequence=$event_sequence"
        echo "production_gui_web_renderer_parity_event_routing_title_text=$title_text"
        echo "production_gui_web_renderer_parity_event_routing_title_context_text=$title_context_text"
        echo "production_gui_web_renderer_parity_event_routing_traffic_button_count=$traffic_button_count"
        echo "production_gui_web_renderer_parity_event_routing_title_input_tag=$title_input_tag"
        echo "production_gui_web_renderer_parity_event_routing_titlebar_height=$titlebar_height"
        echo "production_gui_web_renderer_parity_event_routing_titlebar_display=$titlebar_display"
        echo "production_gui_web_renderer_parity_event_routing_titlebar_cursor=$titlebar_cursor"
        echo "production_gui_web_renderer_parity_event_routing_titlebar_background=$titlebar_background"
        echo "production_gui_web_renderer_parity_event_routing_title_color=$title_color"
        echo "production_gui_web_renderer_parity_event_routing_title_font_weight=$title_font_weight"
        echo "production_gui_web_renderer_parity_event_routing_title_input_min_width=$title_input_min_width"
        echo "production_gui_web_renderer_parity_event_routing_title_input_width=$title_input_width"
        echo "production_gui_web_renderer_parity_event_routing_title_input_width_px=$title_input_width_px"
        echo "production_gui_web_renderer_parity_event_routing_title_input_height=$title_input_height"
        echo "production_gui_web_renderer_parity_event_routing_title_input_cursor=$title_input_cursor"
        echo "production_gui_web_renderer_parity_event_routing_title_input_background=$title_input_background"
        echo "production_gui_web_renderer_parity_event_routing_close_button_background=$close_button_background"
        echo "production_gui_web_renderer_parity_event_routing_minimize_button_background=$minimize_button_background"
        echo "production_gui_web_renderer_parity_event_routing_maximize_button_background=$maximize_button_background"
        echo "production_gui_web_renderer_parity_event_routing_expected_move_x=$expected_move_x"
        echo "production_gui_web_renderer_parity_event_routing_expected_move_y=$expected_move_y"
        echo "production_gui_web_renderer_parity_event_routing_move_payload_x=$move_payload_x"
        echo "production_gui_web_renderer_parity_event_routing_move_payload_y=$move_payload_y"
        echo "production_gui_web_renderer_parity_event_routing_move_payload_source=$move_payload_source"
        echo "production_gui_web_renderer_parity_event_routing_move_payload_window_id_hint=$move_payload_window_id_hint"
        echo "production_gui_web_renderer_parity_event_routing_title_command_text=$title_command_text"
        echo "production_gui_web_renderer_parity_event_routing_text_input_text=$text_input_text"
        echo "production_gui_web_renderer_parity_event_routing_font_text=$font_text"
        echo "production_gui_web_renderer_parity_event_routing_font_composition_id=$font_composition_id"
        echo "production_gui_web_renderer_parity_event_routing_font_identity=$font_identity"
        echo "production_gui_web_renderer_parity_event_routing_font_loaded=$font_loaded"
        echo "production_gui_web_renderer_parity_event_routing_font_frame_event_count=$font_frame_event_count"
        echo "production_gui_web_renderer_parity_event_routing_font_frame_correlation_id=$font_frame_correlation_id"
        echo "production_gui_web_renderer_parity_event_routing_font_frame_path=$font_frame_path"
        echo "production_gui_web_renderer_parity_event_routing_font_frame_pixel_checksum=$font_frame_pixel_checksum"
        echo "production_gui_web_renderer_parity_event_routing_font_frame_nonbackground_pixels=$font_frame_nonbackground_pixels"
        echo "production_gui_web_renderer_parity_event_routing_font_frame_artifact_status=$font_frame_artifact_status"
        echo "production_gui_web_renderer_parity_event_routing_simple_composition_pixel_count=$simple_composition_pixel_count"
        echo "production_gui_web_renderer_parity_event_routing_simple_composition_run_id=$simple_composition_run_id"
        echo "production_gui_web_renderer_parity_event_routing_simple_composition_pixel_checksum=$simple_composition_pixel_checksum"
        echo "production_gui_web_renderer_parity_event_routing_simple_composition_artifact_size_bytes=$simple_composition_artifact_size_bytes"
        echo "production_gui_web_renderer_parity_event_routing_simple_composition_artifact_sha256=$simple_composition_artifact_sha256"
        echo "production_gui_web_renderer_parity_event_routing_simple_composition_artifact_status=$simple_composition_artifact_status"
        echo "production_gui_web_renderer_parity_event_routing_proof_source=$proof_source"
        echo "production_gui_web_renderer_parity_event_routing_proof_source_file_status=$proof_source_file_status"
        echo "production_gui_web_renderer_parity_event_routing_proof_source_size_bytes=$proof_source_size_bytes"
        echo "production_gui_web_renderer_parity_event_routing_proof_source_actual_size_bytes=$proof_source_actual_size_bytes"
        echo "production_gui_web_renderer_parity_event_routing_proof_source_file_reason=$proof_source_file_reason"
        echo "production_gui_web_renderer_parity_event_routing_proof_source_artifact_status=$proof_source_artifact_status"
        echo "production_gui_web_renderer_parity_event_routing_browser_engine=$browser_engine"
        echo "production_gui_web_renderer_parity_event_routing_electron_user_agent=$electron_user_agent"
        echo "production_gui_web_renderer_parity_event_routing_electron_process_version=$electron_process_version"
        echo "production_gui_web_renderer_parity_event_routing_chrome_process_version=$chrome_process_version"
        echo "production_gui_web_renderer_parity_event_routing_result_path=$result_path"
        echo "production_gui_web_renderer_parity_event_routing_blur_or_tolerance_used=$tolerance"
        echo "production_gui_web_renderer_parity_event_routing_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "event_" "$env_file"
    [ "$code" -eq 0 ] && [ "$event_status" = "pass" ] && [ "$validation_status" = "pass" ] && \
        [ "$proof_symlink_status" = "pass" ] && \
        [ "$proof_source_file_status" = "pass" ] && [ "$proof_source_artifact_status" = "pass" ] && \
        num_at_least "$proof_source_size_bytes" 1 && \
        [ "$ready" = "true" ] && [ "$wm_found" = "true" ] && \
        num_at_least "$focus_count" 1 && num_at_least "$move_count" 1 && num_at_least "$maximize_count" 1 && \
        num_at_least "$title_command_count" 1 && num_at_least "$text_input_count" 1 && \
        num_at_least "$pointer_down_count" 1 && num_at_least "$pointer_up_count" 1 && \
        [ "$performance_now_available" = "true" ] && num_positive_at_most "$performance_now_delta_ms" 1000 && \
        num_positive_at_most "$input_to_paint_ms" 1000 && \
        [ "$animation_frame_available" = "true" ] && num_at_least "$animation_frame_count" 2 && \
        [ "$css_animation_probe" = "true" ] && \
        [ "$browser_engine" = "chromium" ] && \
        electron_chromium_user_agent "$electron_user_agent" && version_text "$electron_process_version" && version_text "$chrome_process_version" && \
        [ "$event_sequence" = "host_wm_pointer:down,window_cmd:focus,window_cmd:move,window_cmd:title_command,window_cmd:maximize,input_event:text_input,input_event:pointer_down,input_event:pointer_up" ] && \
        [ "$title_text" = "Terminal" ] && [ "$title_context_text" = "terminal" ] && \
        num_at_least "$traffic_button_count" 3 && [ "$title_input_tag" = "input" ] && \
        [ "$titlebar_height" = "34px" ] && [ "$titlebar_display" = "flex" ] && [ "$titlebar_cursor" = "grab" ] && \
        [ "$titlebar_background" = "rgb(229, 231, 235)" ] && [ "$title_color" = "rgb(17, 24, 39)" ] && \
        num_at_least "$title_font_weight" 700 && [ "$title_input_min_width" = "142px" ] && \
        num_at_least_decimal "$title_input_width_px" 142 && [ "$title_input_height" = "24px" ] && \
        [ "$title_input_cursor" = "text" ] && [ "$title_input_background" = "rgb(241, 245, 249)" ] && \
        [ "$close_button_background" = "rgb(239, 68, 68)" ] && \
        [ "$minimize_button_background" = "rgb(234, 179, 8)" ] && \
        [ "$maximize_button_background" = "rgb(34, 197, 94)" ] && \
        [ "$expected_move_x" != "" ] && [ "$expected_move_y" != "" ] && \
        [ "$expected_move_x" = "$move_payload_x" ] && [ "$expected_move_y" = "$move_payload_y" ] && \
        [ "$move_payload_source" = "native_event" ] && [ "$move_payload_window_id_hint" = "win1" ] && \
        [ "$title_command_text" = "/tmp/project" ] && [ "$text_input_text" = "Hello Simple" ] && \
        [ "$font_text" = "WEB" ] && [ "$font_composition_id" = "html-layout" ] && \
        [ "$font_identity" = "sha256=2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081;axes=wght=400,wdth=100" ] && \
        [ "$font_loaded" = "true" ] && [ "$font_frame_event_count" = "8" ] && \
        num_at_least "$simple_composition_pixel_count" 1 && num_at_least "$simple_composition_pixel_checksum" 1 && \
        num_at_least "$simple_composition_artifact_size_bytes" 1 && [ "${#simple_composition_artifact_sha256}" -eq 64 ] && \
        [ "$simple_composition_artifact_status" = "pass" ] && \
        [ "$simple_composition_run_id" != "" ] && [ "$simple_composition_run_id" = "${SIMPLE_WEB_FONT_RUN_ID:-}" ] && \
        [ "$font_frame_correlation_id" = "wm-browser-event-routing|$simple_composition_run_id|html-layout|sha256=2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081;axes=wght=400,wdth=100|WEB|$simple_composition_pixel_checksum|8" ] && \
        [ "$font_frame_path" != "" ] && num_at_least "$font_frame_pixel_checksum" 1 && \
        num_at_least "$font_frame_nonbackground_pixels" 1 && [ "$font_frame_artifact_status" = "pass" ] && \
        [ "$tolerance" = "false" ]
}

status=pass
reason=pass

remember_failure() {
    if [ "$status" = "pass" ]; then
        status=fail
        reason="$1"
    fi
}

run_matrix || remember_failure "electron-generated-gui-matrix-failed"

if [ "$(field_of production_gui_web_renderer_parity_matrix_status "$BUILD_ROOT/evidence.env")" = "pass" ]; then
    run_layout_manifest || remember_failure "electron-layout-manifest-failed"
else
    remember_failure "electron-generated-gui-matrix-failed"
fi

if [ -s "$BUILD_ROOT/layout_manifest/evidence.env" ]; then
    run_surface_manifest || remember_failure "tauri-chrome-layout-manifest-failed"
else
    remember_failure "electron-layout-manifest-failed"
fi

run_backend || remember_failure "backend-executed-parity-failed"

run_font_offload || remember_failure "font-offload-evidence-failed"

run_metal_readback || {
    if [ "$reason" = "font-offload-evidence-failed" ]; then
        reason=font-offload-and-metal-framebuffer-readback-failed
    else
        remember_failure "metal-framebuffer-readback-failed"
    fi
}

run_metal_render_log_compare || remember_failure "metal-render-log-compare-failed"

matrix_status_for_event="$(field_of production_gui_web_renderer_parity_matrix_status "$BUILD_ROOT/evidence.env")"
layout_status_for_event="$(field_of production_gui_web_renderer_parity_layout_manifest_status "$BUILD_ROOT/evidence.env")"
surface_status_for_event="$(field_of production_gui_web_renderer_parity_surface_manifest_status "$BUILD_ROOT/evidence.env")"
backend_status_for_event="$(field_of production_gui_web_renderer_parity_backend_status "$BUILD_ROOT/evidence.env")"
font_status_for_event="$(field_of production_gui_web_renderer_parity_font_offload_status "$BUILD_ROOT/evidence.env")"
metal_status_for_event="$(field_of production_gui_web_renderer_parity_metal_readback_status "$BUILD_ROOT/evidence.env")"
metal_reason_for_event="$(field_of production_gui_web_renderer_parity_metal_readback_reason "$BUILD_ROOT/evidence.env")"
if [ "$matrix_status_for_event" = "pass" ] && [ "$layout_status_for_event" = "pass" ] && \
    [ "$surface_status_for_event" = "pass" ] && [ "$backend_status_for_event" = "pass" ] && \
    [ "$font_status_for_event" = "pass" ] && { [ "$metal_status_for_event" = "pass" ] || [ "$metal_reason_for_event" = "metal-requires-macos" ]; }; then
    run_event_routing || remember_failure "event-routing-evidence-failed"
fi

