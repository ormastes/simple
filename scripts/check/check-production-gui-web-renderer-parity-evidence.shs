#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_ROOT="${BUILD_ROOT:-build/production_gui_web_renderer_parity_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_web_renderer_parity_evidence_$(date -u +%F).md}"
TIMEOUT_SECS="${ELECTRON_BITMAP_TIMEOUT_SECS:-20}"

mkdir -p "$BUILD_ROOT" "$(dirname -- "$REPORT_PATH")"
rm -f "$BUILD_ROOT/evidence.env" "$REPORT_PATH"

field_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" | tail -n 1
}

append_prefixed_env() {
    prefix="$1"
    file="$2"
    if [ -s "$file" ]; then
        sed "s/^/${prefix}/" "$file" >>"$BUILD_ROOT/evidence.env"
    fi
}

run_matrix() {
    case_dir="$BUILD_ROOT/electron_matrix"
    mkdir -p "$case_dir"
    set +e
    BUILD_ROOT="$case_dir" REPORT_PATH="$case_dir/report.md" ELECTRON_BITMAP_TIMEOUT_SECS="$TIMEOUT_SECS" \
        sh scripts/check/check-electron-generated-gui-web-parity-matrix-evidence.shs >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    if [ -s "$env_file" ]; then
        status="$(field_of electron_generated_gui_web_matrix_status "$env_file")"
        reason="$(field_of electron_generated_gui_web_matrix_reason "$env_file")"
    fi
    {
        echo "production_gui_web_renderer_parity_matrix_exit_code=$code"
        echo "production_gui_web_renderer_parity_matrix_status=$status"
        echo "production_gui_web_renderer_parity_matrix_reason=$reason"
        echo "production_gui_web_renderer_parity_matrix_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "matrix_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ]
}

run_layout_manifest() {
    case_dir="$BUILD_ROOT/layout_manifest"
    mkdir -p "$case_dir"
    set +e
    BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" ELECTRON_BITMAP_TIMEOUT_SECS="$TIMEOUT_SECS" \
        sh scripts/check/check-electron-simple-web-layout-manifest-evidence.shs >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    case_count=""
    pass_count=""
    tracked_count=""
    fail_count=""
    if [ -s "$env_file" ]; then
        status="$(field_of electron_simple_web_layout_manifest_status "$env_file")"
        reason="$(field_of electron_simple_web_layout_manifest_reason "$env_file")"
        case_count="$(field_of electron_simple_web_layout_manifest_case_count "$env_file")"
        pass_count="$(field_of electron_simple_web_layout_manifest_pass_count "$env_file")"
        tracked_count="$(field_of electron_simple_web_layout_manifest_tracked_count "$env_file")"
        fail_count="$(field_of electron_simple_web_layout_manifest_fail_count "$env_file")"
    fi
    {
        echo "production_gui_web_renderer_parity_layout_manifest_exit_code=$code"
        echo "production_gui_web_renderer_parity_layout_manifest_status=$status"
        echo "production_gui_web_renderer_parity_layout_manifest_reason=$reason"
        echo "production_gui_web_renderer_parity_layout_manifest_case_count=$case_count"
        echo "production_gui_web_renderer_parity_layout_manifest_pass_count=$pass_count"
        echo "production_gui_web_renderer_parity_layout_manifest_tracked_count=$tracked_count"
        echo "production_gui_web_renderer_parity_layout_manifest_fail_count=$fail_count"
        echo "production_gui_web_renderer_parity_layout_manifest_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "layout_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ] && [ "$fail_count" = "0" ]
}

run_backend() {
    case_dir="$BUILD_ROOT/backend_executed"
    mkdir -p "$case_dir"
    set +e
    BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" \
        sh scripts/check/check-production-gui-web-backend-executed-evidence.shs >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    exact=""
    cpu_diff=""
    metal_diff=""
    metal_frame=""
    tolerance=""
    if [ -s "$env_file" ]; then
        status="$(field_of production_gui_backend_status "$env_file")"
        reason="$(field_of production_gui_backend_reason "$env_file")"
        exact="$(field_of production_gui_backend_exact_backend_parity "$env_file")"
        cpu_diff="$(field_of production_gui_backend_cpu_simd_different_pixels "$env_file")"
        metal_diff="$(field_of production_gui_backend_metal_different_pixels "$env_file")"
        metal_frame="$(field_of production_gui_backend_metal_gpu_frame_complete "$env_file")"
        tolerance="$(field_of production_gui_backend_blur_or_tolerance_used "$env_file")"
    fi
    {
        echo "production_gui_web_renderer_parity_backend_exit_code=$code"
        echo "production_gui_web_renderer_parity_backend_status=$status"
        echo "production_gui_web_renderer_parity_backend_reason=$reason"
        echo "production_gui_web_renderer_parity_backend_exact=$exact"
        echo "production_gui_web_renderer_parity_backend_cpu_simd_different_pixels=$cpu_diff"
        echo "production_gui_web_renderer_parity_backend_metal_different_pixels=$metal_diff"
        echo "production_gui_web_renderer_parity_backend_metal_gpu_frame_complete=$metal_frame"
        echo "production_gui_web_renderer_parity_backend_blur_or_tolerance_used=$tolerance"
        echo "production_gui_web_renderer_parity_backend_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "backend_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ] && [ "$exact" = "true" ] && [ "$cpu_diff" = "0" ] && [ "$metal_diff" = "0" ] && [ "$metal_frame" = "true" ] && [ "$tolerance" = "false" ]
}

run_metal_readback() {
    case_dir="$BUILD_ROOT/metal_readback"
    mkdir -p "$case_dir"
    set +e
    BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" \
        sh scripts/check/check-metal-engine2d-framebuffer-readback-evidence.shs >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    spec_status=""
    download=""
    tolerance=""
    if [ -s "$env_file" ]; then
        status="$(field_of metal_engine2d_framebuffer_readback_status "$env_file")"
        reason="$(field_of metal_engine2d_framebuffer_readback_reason "$env_file")"
        spec_status="$(field_of metal_engine2d_framebuffer_readback_spec_status "$env_file")"
        download="$(field_of metal_engine2d_framebuffer_gpu_readback_available "$env_file")"
        tolerance="$(field_of metal_engine2d_framebuffer_blur_or_tolerance_used "$env_file")"
    fi
    {
        echo "production_gui_web_renderer_parity_metal_readback_exit_code=$code"
        echo "production_gui_web_renderer_parity_metal_readback_status=$status"
        echo "production_gui_web_renderer_parity_metal_readback_reason=$reason"
        echo "production_gui_web_renderer_parity_metal_readback_spec_status=$spec_status"
        echo "production_gui_web_renderer_parity_metal_readback_available=$download"
        echo "production_gui_web_renderer_parity_metal_readback_blur_or_tolerance_used=$tolerance"
        echo "production_gui_web_renderer_parity_metal_readback_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "metal_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ] && [ "$spec_status" = "pass" ] && [ "$download" = "true" ] && [ "$tolerance" = "false" ]
}

status=pass
reason=pass

run_matrix || {
    status=fail
    reason=electron-generated-gui-matrix-failed
}
if [ "$status" = "pass" ]; then
    run_layout_manifest || {
        status=fail
        reason=electron-layout-manifest-failed
    }
fi
if [ "$status" = "pass" ]; then
    run_backend || {
        status=fail
        reason=backend-executed-parity-failed
    }
fi
if [ "$status" = "pass" ]; then
    run_metal_readback || {
        status=fail
        reason=metal-framebuffer-readback-failed
    }
fi

{
    echo "production_gui_web_renderer_parity_status=$status"
    echo "production_gui_web_renderer_parity_reason=$reason"
    cat "$BUILD_ROOT/evidence.env"
} >"$BUILD_ROOT/evidence.final.env"
mv "$BUILD_ROOT/evidence.final.env" "$BUILD_ROOT/evidence.env"

{
    echo "# Production GUI Web Renderer Parity Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- electron matrix: $(field_of production_gui_web_renderer_parity_matrix_status "$BUILD_ROOT/evidence.env")"
    echo "- electron CSS/layout manifest: $(field_of production_gui_web_renderer_parity_layout_manifest_status "$BUILD_ROOT/evidence.env")"
    echo "- backend-executed CPU SIMD/Metal parity: $(field_of production_gui_web_renderer_parity_backend_status "$BUILD_ROOT/evidence.env")"
    echo "- raw Metal framebuffer readback: $(field_of production_gui_web_renderer_parity_metal_readback_status "$BUILD_ROOT/evidence.env")"
    echo "- blur/tolerance used: false"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$BUILD_ROOT/evidence.env"
} >"$REPORT_PATH"

cat "$BUILD_ROOT/evidence.env"
[ "$status" = "pass" ]
