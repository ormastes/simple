num_at_least() {
    value="$1"
    min="$2"
    case "$value" in
        ''|*[!0-9]*) return 1 ;;
    esac
    [ "$value" -ge "$min" ]
}

num_positive() {
    value="$1"
    awk -v value="$value" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 > 0) exit 0
        exit 1
    }'
}

num_positive_at_most() {
    value="$1"
    max="$2"
    awk -v value="$value" -v max="$max" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 > 0 && value + 0 <= max + 0) exit 0
        exit 1
    }'
}

num_at_least_decimal() {
    value="$1"
    min="$2"
    awk -v value="$value" -v min="$min" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 >= min + 0) exit 0
        exit 1
    }'
}

version_text() {
    value="$1"
    awk -v value="$value" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)*$/) exit 0
        exit 1
    }'
}

electron_chromium_user_agent() {
    value="$1"
    case "$value" in
        *Chrome/[0-9]*Electron/[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

