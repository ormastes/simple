        vector_readback_status="$(field_of production_gui_font_offload_vector_readback_status "$env_file")"
        vector_readback_reason="$(field_of production_gui_font_offload_vector_readback_reason "$env_file")"
        vector_ready="$(field_of production_gui_font_offload_vector_production_ready "$env_file")"
        vector_expected_checksum="$(field_of production_gui_font_offload_vector_expected_checksum "$env_file")"
        vector_actual_checksum="$(field_of production_gui_font_offload_vector_actual_checksum "$env_file")"
        bitmap_backend="$(field_of production_gui_font_offload_bitmap_backend "$env_file")"
        bitmap_status="$(field_of production_gui_font_offload_bitmap_status "$env_file")"
