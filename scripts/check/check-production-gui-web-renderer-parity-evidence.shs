event_input_to_paint_ms_final="$(field_of production_gui_web_renderer_parity_event_routing_input_to_paint_ms "$BUILD_ROOT/evidence.env")"
event_animation_frame_available_final="$(field_of production_gui_web_renderer_parity_event_routing_animation_frame_available "$BUILD_ROOT/evidence.env")"
event_animation_frame_count_final="$(field_of production_gui_web_renderer_parity_event_routing_animation_frame_count "$BUILD_ROOT/evidence.env")"
event_css_animation_probe_final="$(field_of production_gui_web_renderer_parity_event_routing_css_animation_probe "$BUILD_ROOT/evidence.env")"
event_sequence_final="$(field_of production_gui_web_renderer_parity_event_routing_event_sequence "$BUILD_ROOT/evidence.env")"
event_title_text_final="$(field_of production_gui_web_renderer_parity_event_routing_title_text "$BUILD_ROOT/evidence.env")"
event_title_context_text_final="$(field_of production_gui_web_renderer_parity_event_routing_title_context_text "$BUILD_ROOT/evidence.env")"
event_traffic_button_count_final="$(field_of production_gui_web_renderer_parity_event_routing_traffic_button_count "$BUILD_ROOT/evidence.env")"
event_title_input_tag_final="$(field_of production_gui_web_renderer_parity_event_routing_title_input_tag "$BUILD_ROOT/evidence.env")"
event_titlebar_height_final="$(field_of production_gui_web_renderer_parity_event_routing_titlebar_height "$BUILD_ROOT/evidence.env")"
event_titlebar_display_final="$(field_of production_gui_web_renderer_parity_event_routing_titlebar_display "$BUILD_ROOT/evidence.env")"
event_titlebar_cursor_final="$(field_of production_gui_web_renderer_parity_event_routing_titlebar_cursor "$BUILD_ROOT/evidence.env")"
event_titlebar_background_final="$(field_of production_gui_web_renderer_parity_event_routing_titlebar_background "$BUILD_ROOT/evidence.env")"
event_title_color_final="$(field_of production_gui_web_renderer_parity_event_routing_title_color "$BUILD_ROOT/evidence.env")"
event_title_font_weight_final="$(field_of production_gui_web_renderer_parity_event_routing_title_font_weight "$BUILD_ROOT/evidence.env")"
event_title_input_min_width_final="$(field_of production_gui_web_renderer_parity_event_routing_title_input_min_width "$BUILD_ROOT/evidence.env")"
event_title_input_width_px_final="$(field_of production_gui_web_renderer_parity_event_routing_title_input_width_px "$BUILD_ROOT/evidence.env")"
event_title_input_height_final="$(field_of production_gui_web_renderer_parity_event_routing_title_input_height "$BUILD_ROOT/evidence.env")"
event_title_input_cursor_final="$(field_of production_gui_web_renderer_parity_event_routing_title_input_cursor "$BUILD_ROOT/evidence.env")"
event_title_input_background_final="$(field_of production_gui_web_renderer_parity_event_routing_title_input_background "$BUILD_ROOT/evidence.env")"
event_close_button_background_final="$(field_of production_gui_web_renderer_parity_event_routing_close_button_background "$BUILD_ROOT/evidence.env")"
event_minimize_button_background_final="$(field_of production_gui_web_renderer_parity_event_routing_minimize_button_background "$BUILD_ROOT/evidence.env")"
event_maximize_button_background_final="$(field_of production_gui_web_renderer_parity_event_routing_maximize_button_background "$BUILD_ROOT/evidence.env")"
event_expected_move_x_final="$(field_of production_gui_web_renderer_parity_event_routing_expected_move_x "$BUILD_ROOT/evidence.env")"
event_expected_move_y_final="$(field_of production_gui_web_renderer_parity_event_routing_expected_move_y "$BUILD_ROOT/evidence.env")"
event_move_payload_x_final="$(field_of production_gui_web_renderer_parity_event_routing_move_payload_x "$BUILD_ROOT/evidence.env")"
event_move_payload_y_final="$(field_of production_gui_web_renderer_parity_event_routing_move_payload_y "$BUILD_ROOT/evidence.env")"
event_move_payload_source_final="$(field_of production_gui_web_renderer_parity_event_routing_move_payload_source "$BUILD_ROOT/evidence.env")"
event_move_payload_window_id_hint_final="$(field_of production_gui_web_renderer_parity_event_routing_move_payload_window_id_hint "$BUILD_ROOT/evidence.env")"
event_title_command_text_final="$(field_of production_gui_web_renderer_parity_event_routing_title_command_text "$BUILD_ROOT/evidence.env")"
event_text_input_text_final="$(field_of production_gui_web_renderer_parity_event_routing_text_input_text "$BUILD_ROOT/evidence.env")"
event_font_text_final="$(field_of production_gui_web_renderer_parity_event_routing_font_text "$BUILD_ROOT/evidence.env")"
event_font_composition_id_final="$(field_of production_gui_web_renderer_parity_event_routing_font_composition_id "$BUILD_ROOT/evidence.env")"
event_font_identity_final="$(field_of production_gui_web_renderer_parity_event_routing_font_identity "$BUILD_ROOT/evidence.env")"
event_font_loaded_final="$(field_of production_gui_web_renderer_parity_event_routing_font_loaded "$BUILD_ROOT/evidence.env")"
event_font_frame_event_count_final="$(field_of production_gui_web_renderer_parity_event_routing_font_frame_event_count "$BUILD_ROOT/evidence.env")"
event_font_frame_correlation_id_final="$(field_of production_gui_web_renderer_parity_event_routing_font_frame_correlation_id "$BUILD_ROOT/evidence.env")"
event_font_frame_path_final="$(field_of production_gui_web_renderer_parity_event_routing_font_frame_path "$BUILD_ROOT/evidence.env")"
event_font_frame_pixel_checksum_final="$(field_of production_gui_web_renderer_parity_event_routing_font_frame_pixel_checksum "$BUILD_ROOT/evidence.env")"
event_font_frame_nonbackground_pixels_final="$(field_of production_gui_web_renderer_parity_event_routing_font_frame_nonbackground_pixels "$BUILD_ROOT/evidence.env")"
event_font_frame_artifact_status_final="$(field_of production_gui_web_renderer_parity_event_routing_font_frame_artifact_status "$BUILD_ROOT/evidence.env")"
event_simple_composition_pixel_count_final="$(field_of production_gui_web_renderer_parity_event_routing_simple_composition_pixel_count "$BUILD_ROOT/evidence.env")"
event_simple_composition_run_id_final="$(field_of production_gui_web_renderer_parity_event_routing_simple_composition_run_id "$BUILD_ROOT/evidence.env")"
event_simple_composition_pixel_checksum_final="$(field_of production_gui_web_renderer_parity_event_routing_simple_composition_pixel_checksum "$BUILD_ROOT/evidence.env")"
event_simple_composition_artifact_size_bytes_final="$(field_of production_gui_web_renderer_parity_event_routing_simple_composition_artifact_size_bytes "$BUILD_ROOT/evidence.env")"
event_simple_composition_artifact_sha256_final="$(field_of production_gui_web_renderer_parity_event_routing_simple_composition_artifact_sha256 "$BUILD_ROOT/evidence.env")"
event_simple_composition_artifact_status_final="$(field_of production_gui_web_renderer_parity_event_routing_simple_composition_artifact_status "$BUILD_ROOT/evidence.env")"
event_proof_source_file_status_final="$(field_of production_gui_web_renderer_parity_event_routing_proof_source_file_status "$BUILD_ROOT/evidence.env")"
event_proof_source_size_bytes_final="$(field_of production_gui_web_renderer_parity_event_routing_proof_source_size_bytes "$BUILD_ROOT/evidence.env")"
event_proof_source_actual_size_bytes_final="$(field_of production_gui_web_renderer_parity_event_routing_proof_source_actual_size_bytes "$BUILD_ROOT/evidence.env")"
event_proof_source_file_reason_final="$(field_of production_gui_web_renderer_parity_event_routing_proof_source_file_reason "$BUILD_ROOT/evidence.env")"
event_proof_source_artifact_status_final="$(field_of production_gui_web_renderer_parity_event_routing_proof_source_artifact_status "$BUILD_ROOT/evidence.env")"
event_tolerance_final="$(field_of production_gui_web_renderer_parity_event_routing_blur_or_tolerance_used "$BUILD_ROOT/evidence.env")"

surface_tauri_tracked_count_final="${surface_tauri_tracked_count_final:-0}"
surface_chrome_tracked_count_final="${surface_chrome_tracked_count_final:-0}"
surface_argb_artifact_status_final=fail
if num_at_least "$surface_tauri_case_count_final" 0 && num_at_least "$surface_tauri_pass_count_final" 0 && \
    num_at_least "$surface_tauri_tracked_count_final" 0 && num_at_least "$surface_tauri_fail_count_final" 0 && \
    num_at_least "$surface_tauri_argb_artifact_pass_count_final" 0 && num_at_least "$surface_tauri_argb_artifact_fail_count_final" 0 && \
    num_at_least "$surface_chrome_case_count_final" 0 && num_at_least "$surface_chrome_pass_count_final" 0 && \
    num_at_least "$surface_chrome_tracked_count_final" 0 && num_at_least "$surface_chrome_fail_count_final" 0 && \
    num_at_least "$surface_chrome_argb_artifact_pass_count_final" 0 && num_at_least "$surface_chrome_argb_artifact_fail_count_final" 0; then
    surface_tauri_accepted_count_final=$((surface_tauri_pass_count_final + surface_tauri_tracked_count_final))
    surface_chrome_accepted_count_final=$((surface_chrome_pass_count_final + surface_chrome_tracked_count_final))
    if [ "$surface_tauri_accepted_count_final" = "$surface_tauri_case_count_final" ] && \
        [ "$surface_tauri_fail_count_final" = "0" ] && \
        [ "$surface_tauri_argb_artifact_pass_count_final" = "$surface_tauri_accepted_count_final" ] && \
        [ "$surface_tauri_argb_artifact_fail_count_final" = "0" ] && \
        [ "$surface_chrome_accepted_count_final" = "$surface_chrome_case_count_final" ] && \
        [ "$surface_chrome_fail_count_final" = "0" ] && \
        [ "$surface_chrome_argb_artifact_pass_count_final" = "$surface_chrome_accepted_count_final" ] && \
        [ "$surface_chrome_argb_artifact_fail_count_final" = "0" ]; then
        surface_argb_artifact_status_final=pass
    fi
fi

if [ "$matrix_status_final" != "pass" ]; then
    status=fail
    reason=electron-generated-gui-matrix-failed
elif [ "$layout_status_final" != "pass" ]; then
    status=fail
    reason=electron-layout-manifest-failed
elif [ "$surface_status_final" != "pass" ] || [ "$surface_argb_artifact_status_final" != "pass" ]; then
    status=fail
    reason=tauri-chrome-layout-manifest-failed
elif [ "$backend_status_final" != "pass" ] || [ "$backend_timing_status_final" != "pass" ] || \
    [ "$backend_exact_final" != "true" ] || [ "$backend_cpu_diff_final" != "0" ] || [ "$backend_metal_diff_final" != "0" ] || \
    [ "$backend_checksum_match_final" != "true" ] || [ "$backend_same_frame_readback_final" != "true" ] || \
    ! num_positive "$backend_software_checksum_final" || ! num_positive "$backend_cpu_simd_checksum_final" || ! num_positive "$backend_metal_checksum_final" || \
    [ "$backend_software_checksum_final" != "$backend_cpu_simd_checksum_final" ] || [ "$backend_software_checksum_final" != "$backend_metal_checksum_final" ] || \
    { [ "$backend_metal_resolved_final" = "metal" ] && { [ "$backend_metal_frame_final" != "true" ] || [ "$backend_readback_source_final" != "device_readback" ] || ! num_at_least "$backend_metal_command_queue_handle_final" 1 || ! num_positive "$backend_metal_gpu_checksum_final" || [ "$backend_software_checksum_final" != "$backend_metal_gpu_checksum_final" ]; }; } || \
    [ "$backend_tolerance_final" != "false" ]; then
    status=fail
    reason=backend-executed-parity-failed
elif [ "$font_status_final" != "pass" ] && [ "$metal_status_final" != "pass" ] && [ "$metal_reason_final" != "metal-requires-macos" ]; then
    status=fail
    reason=font-offload-and-metal-framebuffer-readback-failed
elif [ "$font_status_final" != "pass" ]; then
    status=fail
    reason=font-offload-evidence-failed
elif [ "$font_runtime_evidence_status_final" != "pass" ]; then
    status=fail
    reason=font-offload-runtime-evidence-missing
elif [ "$metal_status_final" != "pass" ] && [ "$metal_reason_final" != "metal-requires-macos" ]; then
    status=fail
    reason=metal-framebuffer-readback-failed
elif [ "$event_exit_code_final" != "0" ] || [ "$event_status_final" != "pass" ]; then
    status=fail
    reason=event-routing-evidence-failed
elif [ "$event_proof_source_artifact_status_final" != "pass" ]; then
    status=fail
    case "$event_proof_source_file_reason_final" in
        symlink) reason=event-routing-proof-source-symlink ;;
        hardlink) reason=event-routing-proof-source-hardlink ;;
        size-mismatch) reason=event-routing-proof-source-size-mismatch ;;
        *) reason=event-routing-proof-source-artifact-missing ;;
    esac
elif [ "$event_validation_status_final" != "pass" ] || [ "$event_proof_symlink_status_final" != "pass" ] || \
    [ "$event_proof_source_file_status_final" != "pass" ] || ! num_at_least "$event_proof_source_size_bytes_final" 1 || \
    [ "$event_proof_source_actual_size_bytes_final" != "$event_proof_source_size_bytes_final" ] || \
    [ "$event_ready_final" != "true" ] || [ "$event_wm_found_final" != "true" ] || \
    ! num_at_least "$event_focus_count_final" 1 || ! num_at_least "$event_move_count_final" 1 || ! num_at_least "$event_maximize_count_final" 1 || \
    ! num_at_least "$event_title_command_count_final" 1 || ! num_at_least "$event_text_input_count_final" 1 || \
    ! num_at_least "$event_pointer_down_count_final" 1 || ! num_at_least "$event_pointer_up_count_final" 1 || \
    [ "$event_performance_now_available_final" != "true" ] || ! num_positive_at_most "$event_performance_now_delta_ms_final" 1000 || \
    ! num_positive_at_most "$event_input_to_paint_ms_final" 1000 || \
    [ "$event_animation_frame_available_final" != "true" ] || ! num_at_least "$event_animation_frame_count_final" 2 || \
    [ "$event_css_animation_probe_final" != "true" ] || \
    [ "$event_browser_engine_final" != "chromium" ] || ! electron_chromium_user_agent "$event_electron_user_agent_final" || \
    ! version_text "$event_electron_process_version_final" || ! version_text "$event_chrome_process_version_final" || \
    [ "$event_sequence_final" != "host_wm_pointer:down,window_cmd:focus,window_cmd:move,window_cmd:title_command,window_cmd:maximize,input_event:text_input,input_event:pointer_down,input_event:pointer_up" ] || \
    [ "$event_title_text_final" != "Terminal" ] || [ "$event_title_context_text_final" != "terminal" ] || \
    ! num_at_least "$event_traffic_button_count_final" 3 || [ "$event_title_input_tag_final" != "input" ] || \
    [ "$event_titlebar_height_final" != "34px" ] || [ "$event_titlebar_display_final" != "flex" ] || \
    [ "$event_titlebar_cursor_final" != "grab" ] || [ "$event_titlebar_background_final" != "rgb(229, 231, 235)" ] || \
    [ "$event_title_color_final" != "rgb(17, 24, 39)" ] || ! num_at_least "$event_title_font_weight_final" 700 || \
    [ "$event_title_input_min_width_final" != "142px" ] || ! num_at_least_decimal "$event_title_input_width_px_final" 142 || \
    [ "$event_title_input_height_final" != "24px" ] || [ "$event_title_input_cursor_final" != "text" ] || \
    [ "$event_title_input_background_final" != "rgb(241, 245, 249)" ] || \
    [ "$event_close_button_background_final" != "rgb(239, 68, 68)" ] || \
    [ "$event_minimize_button_background_final" != "rgb(234, 179, 8)" ] || \
    [ "$event_maximize_button_background_final" != "rgb(34, 197, 94)" ] || \
    [ "$event_expected_move_x_final" = "" ] || [ "$event_expected_move_y_final" = "" ] || \
    [ "$event_expected_move_x_final" != "$event_move_payload_x_final" ] || [ "$event_expected_move_y_final" != "$event_move_payload_y_final" ] || \
    [ "$event_move_payload_source_final" != "native_event" ] || [ "$event_move_payload_window_id_hint_final" != "win1" ] || \
    [ "$event_title_command_text_final" != "/tmp/project" ] || [ "$event_text_input_text_final" != "Hello Simple" ] || \
    [ "$event_font_text_final" != "WEB" ] || [ "$event_font_composition_id_final" != "html-layout" ] || \
    [ "$event_font_identity_final" != "sha256=2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081;axes=wght=400,wdth=100" ] || \
    [ "$event_font_loaded_final" != "true" ] || [ "$event_font_frame_event_count_final" != "8" ] || \
    [ "$event_simple_composition_run_id_final" = "" ] || [ "$event_simple_composition_run_id_final" != "${SIMPLE_WEB_FONT_RUN_ID:-}" ] || \
    ! num_at_least "$event_simple_composition_pixel_count_final" 1 || ! num_at_least "$event_simple_composition_pixel_checksum_final" 1 || \
    ! num_at_least "$event_simple_composition_artifact_size_bytes_final" 1 || [ "${#event_simple_composition_artifact_sha256_final}" -ne 64 ] || \
    [ "$event_simple_composition_artifact_status_final" != "pass" ] || \
    [ "$event_font_frame_correlation_id_final" != "wm-browser-event-routing|$event_simple_composition_run_id_final|html-layout|sha256=2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081;axes=wght=400,wdth=100|WEB|$event_simple_composition_pixel_checksum_final|8" ] || \
    [ "$event_font_frame_path_final" = "" ] || ! num_at_least "$event_font_frame_pixel_checksum_final" 1 || \
    ! num_at_least "$event_font_frame_nonbackground_pixels_final" 1 || [ "$event_font_frame_artifact_status_final" != "pass" ] || \
    [ "$event_tolerance_final" != "false" ]; then
    status=fail
    reason=event-routing-evidence-failed
elif [ "$backend_metal_resolved_final" = "metal" ] && { [ "$metal_render_log_status_final" != "pass" ] || \
    [ "$metal_render_log_required_api_final" != "metal" ] || \
    [ "$metal_render_log_generated_gate_final" != "pass" ] || \
    [ "$metal_render_log_framebuffer_gate_final" != "pass" ] || \
    [ "$metal_render_log_browser_gate_final" != "pass" ] || \
    [ "$metal_render_log_pairwise_gate_final" != "pass" ] || \
    [ "$metal_render_log_argb_source_gate_final" != "pass" ] || \
    { [ "$metal_render_log_gpu_capture_gate_final" != "pass" ] && [ "$metal_render_log_gpu_capture_gate_final" != "not-required" ]; } || \
    [ "$metal_render_log_blocked_gate_count_final" != "0" ]; }; then
    status=fail
    reason=metal-render-log-compare-failed
else
    status=pass
    reason=pass
fi

{
    echo "production_gui_web_renderer_parity_status=$status"
    echo "production_gui_web_renderer_parity_reason=$reason"
    echo "production_gui_web_renderer_parity_source_revision=$SOURCE_REVISION"
    echo "gui_web_2d_evidence_source_revision=$SOURCE_REVISION"
    cat "$BUILD_ROOT/evidence.env"
} >"$BUILD_ROOT/evidence.final.env"
mv "$BUILD_ROOT/evidence.final.env" "$BUILD_ROOT/evidence.env"
PARTIAL_FINALIZED=1

{
    echo "# Production GUI Web Renderer Parity Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- simple binary: $(field_of production_gui_web_renderer_parity_simple_bin "$BUILD_ROOT/evidence.env") ($(field_of production_gui_web_renderer_parity_simple_bin_source "$BUILD_ROOT/evidence.env"))"
    echo "- electron matrix: $(field_of production_gui_web_renderer_parity_matrix_status "$BUILD_ROOT/evidence.env")"
    echo "- electron CSS/layout manifest: $(field_of production_gui_web_renderer_parity_layout_manifest_status "$BUILD_ROOT/evidence.env")"
    echo "- Tauri/Chrome surface manifest: $(field_of production_gui_web_renderer_parity_surface_manifest_status "$BUILD_ROOT/evidence.env")"
    echo "- Surface ARGB artifacts: $surface_argb_artifact_status_final (tauri $surface_tauri_argb_artifact_pass_count_final/$surface_tauri_argb_artifact_fail_count_final; chrome $surface_chrome_argb_artifact_pass_count_final/$surface_chrome_argb_artifact_fail_count_final)"
    echo "- backend-executed CPU SIMD/Metal parity: $(field_of production_gui_web_renderer_parity_backend_status "$BUILD_ROOT/evidence.env")"
    echo "- backend sample count: $(field_of production_gui_web_renderer_parity_backend_sample_count "$BUILD_ROOT/evidence.env")"
    echo "- backend total elapsed us min/avg/max: $(field_of production_gui_web_renderer_parity_backend_total_elapsed_us_min "$BUILD_ROOT/evidence.env") / $(field_of production_gui_web_renderer_parity_backend_total_elapsed_us_avg "$BUILD_ROOT/evidence.env") / $(field_of production_gui_web_renderer_parity_backend_total_elapsed_us_max "$BUILD_ROOT/evidence.env")"
    echo "- backend total pixels/s min/avg/max: $(field_of production_gui_web_renderer_parity_backend_total_pixels_per_second_min "$BUILD_ROOT/evidence.env") / $(field_of production_gui_web_renderer_parity_backend_total_pixels_per_second_avg "$BUILD_ROOT/evidence.env") / $(field_of production_gui_web_renderer_parity_backend_total_pixels_per_second_max "$BUILD_ROOT/evidence.env")"
    echo "- font offload/readback: $(field_of production_gui_web_renderer_parity_font_offload_status "$BUILD_ROOT/evidence.env")"
    echo "- vector font readback: $(field_of production_gui_web_renderer_parity_font_offload_vector_readback_status "$BUILD_ROOT/evidence.env")"
    echo "- bitmap font readback: $(field_of production_gui_web_renderer_parity_font_offload_bitmap_readback_status "$BUILD_ROOT/evidence.env")"
    echo "- raw Metal framebuffer readback: $(field_of production_gui_web_renderer_parity_metal_readback_status "$BUILD_ROOT/evidence.env")"
    echo "- macOS Metal render-log compare: $(field_of production_gui_web_renderer_parity_metal_render_log_status "$BUILD_ROOT/evidence.env")"
    echo "- Metal render-log gates: generated=$metal_render_log_generated_gate_final framebuffer=$metal_render_log_framebuffer_gate_final browser=$metal_render_log_browser_gate_final pairwise=$metal_render_log_pairwise_gate_final argb_source=$metal_render_log_argb_source_gate_final gpu_capture=$metal_render_log_gpu_capture_gate_final blocked=$metal_render_log_blocked_gate_count_final"
    echo "- Electron event routing: $(field_of production_gui_web_renderer_parity_event_routing_status "$BUILD_ROOT/evidence.env")"
    echo "- Electron event proof source: $event_proof_source_file_status_final / $event_proof_source_file_reason_final / $event_proof_source_artifact_status_final"
    echo "- Electron performance/animation: performance.now $(field_of production_gui_web_renderer_parity_event_routing_performance_now_available "$BUILD_ROOT/evidence.env") / input-to-paint $(field_of production_gui_web_renderer_parity_event_routing_input_to_paint_ms "$BUILD_ROOT/evidence.env") ms / requestAnimationFrame $(field_of production_gui_web_renderer_parity_event_routing_animation_frame_count "$BUILD_ROOT/evidence.env") / CSS animation $(field_of production_gui_web_renderer_parity_event_routing_css_animation_probe "$BUILD_ROOT/evidence.env")"
    echo "- Electron performance/animation detail: perf=$event_performance_now_available_final delta_ms=$event_performance_now_delta_ms_final input_to_paint_ms=$event_input_to_paint_ms_final animation=$event_animation_frame_available_final frames=$event_animation_frame_count_final css=$event_css_animation_probe_final"
    echo "- blur/tolerance used: false"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$BUILD_ROOT/evidence.env"
} >"$REPORT_PATH"

emit_summary_env "$BUILD_ROOT/evidence.env"
[ "$status" = "pass" ]
