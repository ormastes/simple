        font_runtime_evidence_env="$(field_of production_gui_font_offload_runtime_evidence_env "$env_file")"
        font_runtime_evidence_status="$(field_of production_gui_font_offload_runtime_evidence_status "$env_file")"
        vector_backend="$(field_of production_gui_font_offload_vector_backend "$env_file")"
        vector_status="$(field_of production_gui_font_offload_vector_status "$env_file")"
