#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_ROOT="${BUILD_ROOT:-build/production_gui_web_renderer_parity_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_web_renderer_parity_evidence_$(date -u +%F).md}"
TIMEOUT_SECS="${ELECTRON_BITMAP_TIMEOUT_SECS:-20}"
CHROME_SURFACE_TIMEOUT_SECS="${CHROME_LAYOUT_TIMEOUT_SECS:-60}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass
SUBCHECK_TIMEOUT_SECS="${PRODUCTION_GUI_WEB_RENDERER_PARITY_SUBCHECK_TIMEOUT_SECS:-180}"
MATRIX_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_MATRIX_SCRIPT:-scripts/check/check-electron-generated-gui-web-parity-matrix-evidence.shs}"
LAYOUT_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_LAYOUT_SCRIPT:-scripts/check/check-electron-simple-web-layout-manifest-evidence.shs}"
SURFACE_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_SURFACE_SCRIPT:-scripts/check/check-tauri-chrome-simple-web-layout-manifest-evidence.shs}"
BACKEND_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_BACKEND_SCRIPT:-scripts/check/check-production-gui-web-backend-executed-evidence.shs}"
FONT_OFFLOAD_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_FONT_OFFLOAD_SCRIPT:-scripts/check/check-production-gui-font-offload-evidence.shs}"
METAL_READBACK_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_METAL_READBACK_SCRIPT:-scripts/check/check-metal-engine2d-framebuffer-readback-evidence.shs}"
EVENT_SCRIPT="${PRODUCTION_GUI_WEB_RENDERER_PARITY_EVENT_SCRIPT:-scripts/check/check-wm-browser-event-routing-evidence.shs}"
LAYOUT_MANIFEST_RESUME="${PRODUCTION_GUI_WEB_RENDERER_PARITY_LAYOUT_MANIFEST_RESUME:-0}"

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [ -z "${SIMPLE_BIN+x}" ]; then
    SIMPLE_BIN_SOURCE="default-missing"
    for candidate in \
        "release"/*/simple \
        "bin/release"/*/simple \
        "build/bootstrap/stage3/simple" \
        "bin/simple" \
        "./bin/simple"
    do
        if [ -x "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            SIMPLE_BIN_SOURCE="repo-self-hosted-fallback"
            break
        fi
    done
    if [ -z "${SIMPLE_BIN+x}" ] && command -v simple >/dev/null 2>&1; then
        SIMPLE_BIN="$(command -v simple)"
        SIMPLE_BIN_SOURCE="path-fallback"
    fi
fi
if [ -z "${SIMPLE_BIN+x}" ] || [ "$SIMPLE_BIN" = "" ]; then
    SIMPLE_BIN=""
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="missing-self-hosted"
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS

mkdir -p "$BUILD_ROOT" "$(dirname -- "$REPORT_PATH")"
rm -f "$BUILD_ROOT/evidence.env" "$REPORT_PATH"

if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    {
        echo "production_gui_web_renderer_parity_status=fail"
        echo "production_gui_web_renderer_parity_reason=simple-bin-$SIMPLE_BIN_STATUS"
        echo "production_gui_web_renderer_parity_simple_bin=$SIMPLE_BIN"
        echo "production_gui_web_renderer_parity_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "production_gui_web_renderer_parity_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "production_gui_web_renderer_parity_evidence_env=$BUILD_ROOT/evidence.env"
        echo "production_gui_web_renderer_parity_report=$REPORT_PATH"
    } >"$BUILD_ROOT/evidence.env"
    {
        echo "# Production GUI/Web Renderer Parity Evidence"
        echo
        echo "- Status: fail"
        echo "- Reason: simple-bin-$SIMPLE_BIN_STATUS"
        echo "- Simple binary: $SIMPLE_BIN"
        echo "- Simple binary source: $SIMPLE_BIN_SOURCE"
        echo "- Simple binary status: $SIMPLE_BIN_STATUS"
    } >"$REPORT_PATH"
    cat "$BUILD_ROOT/evidence.env"
    exit 0
fi

field_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" | tail -n 1
}

append_prefixed_env() {
    prefix="$1"
    file="$2"
    if [ -s "$file" ]; then
        sed "s/^/${prefix}/" "$file" >>"$BUILD_ROOT/evidence.env"
    fi
}

derive_layout_manifest_counts() {
    file="$1"
    derived_case_count=0
    derived_pass_count=0
    derived_tracked_count=0
    derived_fail_count=0
    if [ ! -s "$file" ]; then
        return 0
    fi
    sed -n 's/^electron_simple_web_layout_manifest_case=//p' "$file" | while IFS= read -r case_id; do
        policy="$(field_of "electron_simple_web_layout_manifest_${case_id}_policy" "$file")"
        case_status="$(field_of "electron_simple_web_layout_manifest_${case_id}_status" "$file")"
        mismatch_count="$(field_of "electron_simple_web_layout_manifest_${case_id}_mismatch_count" "$file")"
        blur_used="$(field_of "electron_simple_web_layout_manifest_${case_id}_blur_or_tolerance_used" "$file")"
        derived_case_count=$((derived_case_count + 1))
        if [ "$policy" = "exact" ] && [ "$case_status" = "pass" ] && [ "$mismatch_count" = "0" ] && [ "$blur_used" = "false" ]; then
            derived_pass_count=$((derived_pass_count + 1))
        elif [ "$policy" = "track-text-divergence" ] && [ "$blur_used" = "false" ]; then
            if [ "$case_status" = "divergent" ] && [ -n "$mismatch_count" ] && [ "$mismatch_count" != "0" ]; then
                derived_tracked_count=$((derived_tracked_count + 1))
            elif [ "$case_status" = "pass" ] && [ "$mismatch_count" = "0" ]; then
                derived_tracked_count=$((derived_tracked_count + 1))
            else
                derived_fail_count=$((derived_fail_count + 1))
            fi
        else
            derived_fail_count=$((derived_fail_count + 1))
        fi
        printf '%s %s %s %s\n' "$derived_case_count" "$derived_pass_count" "$derived_tracked_count" "$derived_fail_count"
    done | tail -n 1
}

run_subcheck() {
    if [ "$SUBCHECK_TIMEOUT_SECS" -gt 0 ] 2>/dev/null; then
        timeout "$SUBCHECK_TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

emit_summary_env() {
    file="$1"
    for key in \
        production_gui_web_renderer_parity_status \
        production_gui_web_renderer_parity_reason \
        production_gui_web_renderer_parity_matrix_status \
        production_gui_web_renderer_parity_layout_manifest_status \
        production_gui_web_renderer_parity_surface_manifest_status \
        production_gui_web_renderer_parity_backend_status \
        production_gui_web_renderer_parity_font_offload_status \
        production_gui_web_renderer_parity_metal_readback_status \
        production_gui_web_renderer_parity_event_routing_status
    do
        echo "$key=$(field_of "$key" "$file")"
    done
    echo "production_gui_web_renderer_parity_evidence_env=$file"
    echo "production_gui_web_renderer_parity_report=$REPORT_PATH"
}

run_matrix() {
    case_dir="$BUILD_ROOT/electron_matrix"
    mkdir -p "$case_dir"
    set +e
    run_subcheck env BUILD_ROOT="$case_dir" REPORT_PATH="$case_dir/report.md" ELECTRON_BITMAP_TIMEOUT_SECS="$TIMEOUT_SECS" \
        sh "$MATRIX_SCRIPT" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    if [ -s "$env_file" ]; then
        status="$(field_of electron_generated_gui_web_matrix_status "$env_file")"
        reason="$(field_of electron_generated_gui_web_matrix_reason "$env_file")"
    fi
    if [ "$code" -eq 124 ]; then
        status=timeout
        reason=matrix-timeout
    fi
    {
        echo "production_gui_web_renderer_parity_simple_bin=$SIMPLE_BIN"
        echo "production_gui_web_renderer_parity_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "production_gui_web_renderer_parity_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "production_gui_web_renderer_parity_matrix_exit_code=$code"
        echo "production_gui_web_renderer_parity_matrix_status=$status"
        echo "production_gui_web_renderer_parity_matrix_reason=$reason"
        echo "production_gui_web_renderer_parity_matrix_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_matrix_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_matrix_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "matrix_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ]
}

run_layout_manifest() {
    case_dir="$BUILD_ROOT/layout_manifest"
    mkdir -p "$case_dir"
    set +e
    run_subcheck env BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" ELECTRON_BITMAP_TIMEOUT_SECS="$TIMEOUT_SECS" ELECTRON_LAYOUT_MANIFEST_RESUME="$LAYOUT_MANIFEST_RESUME" \
        sh "$LAYOUT_SCRIPT" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    case_count=""
    pass_count=""
    tracked_count=""
    fail_count=""
    dependency_status=""
    dependency_reason=""
    dependency_missing_count=""
    simple_bin=""
    simple_bin_source=""
    simple_bin_status=""
    if [ -s "$env_file" ]; then
        status="$(field_of electron_simple_web_layout_manifest_status "$env_file")"
        reason="$(field_of electron_simple_web_layout_manifest_reason "$env_file")"
        case_count="$(field_of electron_simple_web_layout_manifest_case_count "$env_file")"
        pass_count="$(field_of electron_simple_web_layout_manifest_pass_count "$env_file")"
        tracked_count="$(field_of electron_simple_web_layout_manifest_tracked_count "$env_file")"
        fail_count="$(field_of electron_simple_web_layout_manifest_fail_count "$env_file")"
        dependency_status="$(field_of electron_simple_web_layout_manifest_dependency_status "$env_file")"
        dependency_reason="$(field_of electron_simple_web_layout_manifest_dependency_reason "$env_file")"
        dependency_missing_count="$(field_of electron_simple_web_layout_manifest_dependency_missing_count "$env_file")"
        simple_bin="$(field_of electron_simple_web_layout_manifest_simple_bin "$env_file")"
        simple_bin_source="$(field_of electron_simple_web_layout_manifest_simple_bin_source "$env_file")"
        simple_bin_status="$(field_of electron_simple_web_layout_manifest_simple_bin_status "$env_file")"
    fi
    if [ "$code" -eq 124 ]; then
        status=timeout
        reason=layout-manifest-timeout
        if [ "$case_count" = "" ] || [ "$pass_count" = "" ] || [ "$tracked_count" = "" ] || [ "$fail_count" = "" ]; then
            derived_counts="$(derive_layout_manifest_counts "$env_file")"
            if [ "$derived_counts" != "" ]; then
                set -- $derived_counts
                case_count="$1"
                pass_count="$2"
                tracked_count="$3"
                fail_count="$4"
            fi
        fi
    fi
    {
        echo "production_gui_web_renderer_parity_layout_manifest_exit_code=$code"
        echo "production_gui_web_renderer_parity_layout_manifest_status=$status"
        echo "production_gui_web_renderer_parity_layout_manifest_reason=$reason"
        echo "production_gui_web_renderer_parity_layout_manifest_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_layout_manifest_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_layout_manifest_case_count=$case_count"
        echo "production_gui_web_renderer_parity_layout_manifest_pass_count=$pass_count"
        echo "production_gui_web_renderer_parity_layout_manifest_tracked_count=$tracked_count"
        echo "production_gui_web_renderer_parity_layout_manifest_fail_count=$fail_count"
        echo "production_gui_web_renderer_parity_layout_manifest_dependency_status=$dependency_status"
        echo "production_gui_web_renderer_parity_layout_manifest_dependency_reason=$dependency_reason"
        echo "production_gui_web_renderer_parity_layout_manifest_dependency_missing_count=$dependency_missing_count"
        echo "production_gui_web_renderer_parity_layout_manifest_simple_bin=$simple_bin"
        echo "production_gui_web_renderer_parity_layout_manifest_simple_bin_source=$simple_bin_source"
        echo "production_gui_web_renderer_parity_layout_manifest_simple_bin_status=$simple_bin_status"
        echo "production_gui_web_renderer_parity_layout_manifest_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "layout_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ] && [ "$fail_count" = "0" ]
}

run_surface_manifest() {
    case_dir="$BUILD_ROOT/tauri_chrome_manifest"
    mkdir -p "$case_dir"
    layout_env="$BUILD_ROOT/layout_manifest/evidence.env"
    set +e
    run_subcheck env BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" LAYOUT_ENV="$layout_env" ELECTRON_BITMAP_TIMEOUT_SECS="$TIMEOUT_SECS" CHROME_LAYOUT_TIMEOUT_SECS="$CHROME_SURFACE_TIMEOUT_SECS" \
        sh "$SURFACE_SCRIPT" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    font_status=""
    font_reason=""
    electron_status=""
    tauri_status=""
    chrome_status=""
    host_uname_s=""
    host_uname_m=""
    tauri_reason=""
    tauri_backend=""
    tauri_required=""
    tauri_missing=""
    chrome_reason=""
    chrome_backend=""
    tauri_live=""
    chrome_live=""
    tauri_mismatch=""
    chrome_mismatch=""
    tauri_case_count=""
    tauri_pass_count=""
    tauri_tracked_count=""
    tauri_fail_count=""
    tauri_accepted_count=""
    chrome_case_count=""
    chrome_pass_count=""
    chrome_tracked_count=""
    chrome_fail_count=""
    chrome_accepted_count=""
    fake_capture=""
    tolerance=""
    if [ -s "$env_file" ]; then
        status="$(field_of tauri_chrome_simple_web_layout_manifest_status "$env_file")"
        reason="$(field_of tauri_chrome_simple_web_layout_manifest_reason "$env_file")"
        electron_status="$(field_of tauri_chrome_simple_web_layout_manifest_electron_capture_status "$env_file")"
        tauri_status="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_capture_status "$env_file")"
        chrome_status="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_capture_status "$env_file")"
        host_uname_s="$(field_of tauri_chrome_simple_web_layout_manifest_host_uname_s "$env_file")"
        host_uname_m="$(field_of tauri_chrome_simple_web_layout_manifest_host_uname_m "$env_file")"
        tauri_reason="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_capture_reason "$env_file")"
        tauri_backend="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_capture_backend "$env_file")"
        tauri_required="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_capture_required_commands "$env_file")"
        tauri_missing="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_capture_missing_commands "$env_file")"
        chrome_reason="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_capture_reason "$env_file")"
        chrome_backend="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_capture_backend "$env_file")"
        tauri_live="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_live_capture "$env_file")"
        chrome_live="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_live_capture "$env_file")"
        tauri_mismatch="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_mismatch_count "$env_file")"
        chrome_mismatch="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_mismatch_count "$env_file")"
        tauri_case_count="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_case_count "$env_file")"
        tauri_pass_count="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_pass_count "$env_file")"
        tauri_tracked_count="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_tracked_count "$env_file")"
        tauri_fail_count="$(field_of tauri_chrome_simple_web_layout_manifest_tauri_fail_count "$env_file")"
        chrome_case_count="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_case_count "$env_file")"
        chrome_pass_count="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_pass_count "$env_file")"
        chrome_tracked_count="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_tracked_count "$env_file")"
        chrome_fail_count="$(field_of tauri_chrome_simple_web_layout_manifest_chrome_fail_count "$env_file")"
        fake_capture="$(field_of tauri_chrome_simple_web_layout_manifest_no_fake_capture "$env_file")"
        tolerance="$(field_of tauri_chrome_simple_web_layout_manifest_blur_or_tolerance_used "$env_file")"
    fi
    if [ "$code" -eq 124 ]; then
        status=timeout
        reason=surface-manifest-timeout
    fi
    tauri_tracked_count="${tauri_tracked_count:-0}"
    chrome_tracked_count="${chrome_tracked_count:-0}"
    if [ -n "$tauri_case_count" ] && [ -n "$tauri_pass_count" ]; then
        tauri_accepted_count=$((tauri_pass_count + tauri_tracked_count))
    fi
    if [ -n "$chrome_case_count" ] && [ -n "$chrome_pass_count" ]; then
        chrome_accepted_count=$((chrome_pass_count + chrome_tracked_count))
    fi
    {
        echo "production_gui_web_renderer_parity_surface_manifest_exit_code=$code"
        echo "production_gui_web_renderer_parity_surface_manifest_status=$status"
        echo "production_gui_web_renderer_parity_surface_manifest_reason=$reason"
        echo "production_gui_web_renderer_parity_surface_manifest_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_surface_manifest_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_surface_manifest_host_uname_s=$host_uname_s"
        echo "production_gui_web_renderer_parity_surface_manifest_host_uname_m=$host_uname_m"
        echo "production_gui_web_renderer_parity_surface_manifest_electron_capture_status=$electron_status"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_capture_status=$tauri_status"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_capture_reason=$tauri_reason"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_capture_backend=$tauri_backend"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_capture_required_commands=$tauri_required"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_capture_missing_commands=$tauri_missing"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_capture_status=$chrome_status"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_capture_reason=$chrome_reason"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_capture_backend=$chrome_backend"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_live_capture=$tauri_live"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_live_capture=$chrome_live"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_case_count=$tauri_case_count"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_pass_count=$tauri_pass_count"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_tracked_count=$tauri_tracked_count"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_fail_count=$tauri_fail_count"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_case_count=$chrome_case_count"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_pass_count=$chrome_pass_count"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_tracked_count=$chrome_tracked_count"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_fail_count=$chrome_fail_count"
        echo "production_gui_web_renderer_parity_surface_manifest_tauri_mismatch_count=$tauri_mismatch"
        echo "production_gui_web_renderer_parity_surface_manifest_chrome_mismatch_count=$chrome_mismatch"
        echo "production_gui_web_renderer_parity_surface_manifest_no_fake_capture=$fake_capture"
        echo "production_gui_web_renderer_parity_surface_manifest_blur_or_tolerance_used=$tolerance"
        echo "production_gui_web_renderer_parity_surface_manifest_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "surface_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ] && [ "$electron_status" = "pass" ] && \
        [ "$tauri_status" = "pass" ] && [ "$tauri_live" = "true" ] && [ "$tauri_mismatch" = "0" ] && [ "$tauri_accepted_count" = "$tauri_case_count" ] && [ "$tauri_fail_count" = "0" ] && \
        [ "$chrome_status" = "pass" ] && [ "$chrome_live" = "true" ] && [ "$chrome_mismatch" = "0" ] && [ "$chrome_accepted_count" = "$chrome_case_count" ] && [ "$chrome_fail_count" = "0" ] && \
        [ "$fake_capture" = "true" ] && [ "$tolerance" = "false" ]
}

run_backend() {
    case_dir="$BUILD_ROOT/backend_executed"
    mkdir -p "$case_dir"
    set +e
    run_subcheck env BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" \
        sh "$BACKEND_SCRIPT" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    status=""
    reason=""
    exact=""
    cpu_diff=""
    metal_resolved=""
    metal_diff=""
    metal_frame=""
    metal_command_queue_handle=""
    software_checksum=""
    cpu_simd_checksum=""
    metal_checksum=""
    metal_gpu_checksum=""
    backend_checksum_match=""
    same_frame_readback=""
    tolerance=""
    sample_count=""
    elapsed_min=""
    elapsed_avg=""
    elapsed_max=""
    throughput_min=""
    throughput_avg=""
    throughput_max=""
    simple_bin=""
    simple_bin_source=""
    simple_bin_status=""
    if [ -s "$env_file" ]; then
        status="$(field_of production_gui_backend_status "$env_file")"
        reason="$(field_of production_gui_backend_reason "$env_file")"
        exact="$(field_of production_gui_backend_exact_backend_parity "$env_file")"
        cpu_diff="$(field_of production_gui_backend_cpu_simd_different_pixels "$env_file")"
        metal_resolved="$(field_of production_gui_backend_metal_resolved "$env_file")"
        metal_diff="$(field_of production_gui_backend_metal_different_pixels "$env_file")"
        metal_frame="$(field_of production_gui_backend_metal_gpu_frame_complete "$env_file")"
        metal_command_queue_handle="$(field_of production_gui_backend_metal_command_queue_handle "$env_file")"
        software_checksum="$(field_of production_gui_backend_software_checksum "$env_file")"
        cpu_simd_checksum="$(field_of production_gui_backend_cpu_simd_checksum "$env_file")"
        metal_checksum="$(field_of production_gui_backend_metal_checksum "$env_file")"
        metal_gpu_checksum="$(field_of production_gui_backend_metal_gpu_readback_checksum "$env_file")"
        backend_checksum_match="$(field_of production_gui_backend_backend_checksum_match "$env_file")"
        same_frame_readback="$(field_of production_gui_backend_same_frame_backend_readback "$env_file")"
        tolerance="$(field_of production_gui_backend_blur_or_tolerance_used "$env_file")"
        sample_count="$(field_of production_gui_backend_sample_count "$env_file")"
        elapsed_min="$(field_of production_gui_backend_total_elapsed_us_min "$env_file")"
        elapsed_avg="$(field_of production_gui_backend_total_elapsed_us_avg "$env_file")"
        elapsed_max="$(field_of production_gui_backend_total_elapsed_us_max "$env_file")"
        throughput_min="$(field_of production_gui_backend_total_pixels_per_second_min "$env_file")"
        throughput_avg="$(field_of production_gui_backend_total_pixels_per_second_avg "$env_file")"
        throughput_max="$(field_of production_gui_backend_total_pixels_per_second_max "$env_file")"
        simple_bin="$(field_of production_gui_backend_simple_bin "$env_file")"
        simple_bin_source="$(field_of production_gui_backend_simple_bin_source "$env_file")"
        simple_bin_status="$(field_of production_gui_backend_simple_bin_status "$env_file")"
    fi
    backend_timing_status=fail
    if num_at_least "$sample_count" 1 && \
        num_positive "$elapsed_min" && num_positive "$elapsed_avg" && num_positive "$elapsed_max" && \
        num_positive "$throughput_min" && num_positive "$throughput_avg" && num_positive "$throughput_max"; then
        backend_timing_status=pass
    fi
    if [ "$code" -eq 124 ]; then
        status=timeout
        reason=backend-timeout
    fi
    {
        echo "production_gui_web_renderer_parity_backend_exit_code=$code"
        echo "production_gui_web_renderer_parity_backend_status=$status"
        echo "production_gui_web_renderer_parity_backend_reason=$reason"
        echo "production_gui_web_renderer_parity_backend_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_backend_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_backend_exact=$exact"
        echo "production_gui_web_renderer_parity_backend_cpu_simd_different_pixels=$cpu_diff"
        echo "production_gui_web_renderer_parity_backend_metal_resolved=$metal_resolved"
        echo "production_gui_web_renderer_parity_backend_metal_different_pixels=$metal_diff"
        echo "production_gui_web_renderer_parity_backend_metal_gpu_frame_complete=$metal_frame"
        echo "production_gui_web_renderer_parity_backend_metal_command_queue_handle=$metal_command_queue_handle"
        echo "production_gui_web_renderer_parity_backend_software_checksum=$software_checksum"
        echo "production_gui_web_renderer_parity_backend_cpu_simd_checksum=$cpu_simd_checksum"
        echo "production_gui_web_renderer_parity_backend_metal_checksum=$metal_checksum"
        echo "production_gui_web_renderer_parity_backend_metal_gpu_readback_checksum=$metal_gpu_checksum"
        echo "production_gui_web_renderer_parity_backend_checksum_match=$backend_checksum_match"
        echo "production_gui_web_renderer_parity_backend_same_frame_readback=$same_frame_readback"
        echo "production_gui_web_renderer_parity_backend_blur_or_tolerance_used=$tolerance"
        echo "production_gui_web_renderer_parity_backend_sample_count=$sample_count"
        echo "production_gui_web_renderer_parity_backend_total_elapsed_us_min=$elapsed_min"
        echo "production_gui_web_renderer_parity_backend_total_elapsed_us_avg=$elapsed_avg"
        echo "production_gui_web_renderer_parity_backend_total_elapsed_us_max=$elapsed_max"
        echo "production_gui_web_renderer_parity_backend_total_pixels_per_second_min=$throughput_min"
        echo "production_gui_web_renderer_parity_backend_total_pixels_per_second_avg=$throughput_avg"
        echo "production_gui_web_renderer_parity_backend_total_pixels_per_second_max=$throughput_max"
        echo "production_gui_web_renderer_parity_backend_timing_status=$backend_timing_status"
        echo "production_gui_web_renderer_parity_backend_simple_bin=$simple_bin"
        echo "production_gui_web_renderer_parity_backend_simple_bin_source=$simple_bin_source"
        echo "production_gui_web_renderer_parity_backend_simple_bin_status=$simple_bin_status"
        echo "production_gui_web_renderer_parity_backend_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "backend_" "$env_file"
    [ "$code" -eq 0 ] && [ "$status" = "pass" ] && [ "$exact" = "true" ] && [ "$cpu_diff" = "0" ] && [ "$metal_diff" = "0" ] && \
        [ "$backend_checksum_match" = "true" ] && [ "$same_frame_readback" = "true" ] && \
        num_positive "$software_checksum" && num_positive "$cpu_simd_checksum" && num_positive "$metal_checksum" && \
        [ "$software_checksum" = "$cpu_simd_checksum" ] && [ "$software_checksum" = "$metal_checksum" ] && \
        { [ "$metal_resolved" != "metal" ] || { [ "$metal_frame" = "true" ] && num_at_least "$metal_command_queue_handle" 1 && num_positive "$metal_gpu_checksum" && [ "$software_checksum" = "$metal_gpu_checksum" ]; }; } && \
        [ "$tolerance" = "false" ] && [ "$backend_timing_status" = "pass" ]
}

