        bitmap_readback_status="$(field_of production_gui_font_offload_bitmap_readback_status "$env_file")"
        bitmap_readback_reason="$(field_of production_gui_font_offload_bitmap_readback_reason "$env_file")"
        bitmap_ready="$(field_of production_gui_font_offload_bitmap_production_ready "$env_file")"
        bitmap_expected_checksum="$(field_of production_gui_font_offload_bitmap_expected_checksum "$env_file")"
        bitmap_actual_checksum="$(field_of production_gui_font_offload_bitmap_actual_checksum "$env_file")"
        blocker_doc="$(field_of production_gui_font_offload_blocker_doc "$env_file")"
    fi
    if [ "$code" -eq 124 ]; then
        font_status=timeout
        font_reason=font-offload-timeout
    fi
    {
        echo "production_gui_web_renderer_parity_font_offload_exit_code=$code"
        echo "production_gui_web_renderer_parity_font_offload_status=$font_status"
        echo "production_gui_web_renderer_parity_font_offload_reason=$font_reason"
        echo "production_gui_web_renderer_parity_font_offload_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_font_offload_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_font_offload_simple_bin=$font_simple_bin"
        echo "production_gui_web_renderer_parity_font_offload_simple_bin_source=$font_simple_bin_source"
        echo "production_gui_web_renderer_parity_font_offload_simple_bin_status=$font_simple_bin_status"
        echo "production_gui_web_renderer_parity_font_offload_runtime_evidence_env=$font_runtime_evidence_env"
        echo "production_gui_web_renderer_parity_font_offload_runtime_evidence_status=$font_runtime_evidence_status"
        echo "production_gui_web_renderer_parity_font_offload_vector_backend=$vector_backend"
        echo "production_gui_web_renderer_parity_font_offload_vector_status=$vector_status"
        echo "production_gui_web_renderer_parity_font_offload_vector_reason=$vector_reason"
        echo "production_gui_web_renderer_parity_font_offload_vector_readback_status=$vector_readback_status"
        echo "production_gui_web_renderer_parity_font_offload_vector_readback_reason=$vector_readback_reason"
        echo "production_gui_web_renderer_parity_font_offload_vector_production_ready=$vector_ready"
        echo "production_gui_web_renderer_parity_font_offload_vector_expected_checksum=$vector_expected_checksum"
        echo "production_gui_web_renderer_parity_font_offload_vector_actual_checksum=$vector_actual_checksum"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_backend=$bitmap_backend"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_status=$bitmap_status"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_reason=$bitmap_reason"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_readback_status=$bitmap_readback_status"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_readback_reason=$bitmap_readback_reason"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_production_ready=$bitmap_ready"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_expected_checksum=$bitmap_expected_checksum"
        echo "production_gui_web_renderer_parity_font_offload_bitmap_actual_checksum=$bitmap_actual_checksum"
        echo "production_gui_web_renderer_parity_font_offload_report=$case_dir/report.md"
        echo "production_gui_web_renderer_parity_font_offload_blocker_doc=$blocker_doc"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "font_" "$env_file"
    [ "$code" -eq 0 ] && [ "$font_status" = "pass" ]
}

run_metal_readback() {
    case_dir="$BUILD_ROOT/metal_readback"
    mkdir -p "$case_dir"
    set +e
    run_subcheck env BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" \
        sh "$METAL_READBACK_SCRIPT" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    metal_status=""
    metal_reason=""
    spec_status=""
    download=""
    tolerance=""
    simple_bin=""
    simple_bin_source=""
    simple_bin_status=""
    if [ -s "$env_file" ]; then
        metal_status="$(field_of metal_engine2d_framebuffer_readback_status "$env_file")"
        metal_reason="$(field_of metal_engine2d_framebuffer_readback_reason "$env_file")"
        spec_status="$(field_of metal_engine2d_framebuffer_readback_spec_status "$env_file")"
        download="$(field_of metal_engine2d_framebuffer_gpu_readback_available "$env_file")"
        tolerance="$(field_of metal_engine2d_framebuffer_blur_or_tolerance_used "$env_file")"
        simple_bin="$(field_of metal_engine2d_framebuffer_readback_simple_bin "$env_file")"
        simple_bin_source="$(field_of metal_engine2d_framebuffer_readback_simple_bin_source "$env_file")"
        simple_bin_status="$(field_of metal_engine2d_framebuffer_readback_simple_bin_status "$env_file")"
    fi
    if [ "$code" -eq 124 ]; then
        metal_status=timeout
        metal_reason=metal-readback-timeout
    fi
    {
        echo "production_gui_web_renderer_parity_metal_readback_exit_code=$code"
        echo "production_gui_web_renderer_parity_metal_readback_status=$metal_status"
        echo "production_gui_web_renderer_parity_metal_readback_reason=$metal_reason"
        echo "production_gui_web_renderer_parity_metal_readback_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_metal_readback_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_metal_readback_spec_status=$spec_status"
        echo "production_gui_web_renderer_parity_metal_readback_available=$download"
        echo "production_gui_web_renderer_parity_metal_readback_blur_or_tolerance_used=$tolerance"
        echo "production_gui_web_renderer_parity_metal_readback_simple_bin=$simple_bin"
        echo "production_gui_web_renderer_parity_metal_readback_simple_bin_source=$simple_bin_source"
        echo "production_gui_web_renderer_parity_metal_readback_simple_bin_status=$simple_bin_status"
        echo "production_gui_web_renderer_parity_metal_readback_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "metal_" "$env_file"
    { [ "$code" -eq 0 ] && [ "$metal_status" = "pass" ] && [ "$spec_status" = "pass" ] && [ "$download" = "true" ] && [ "$tolerance" = "false" ]; } || \
        { [ "$code" -eq 0 ] && [ "$metal_status" = "unavailable" ] && [ "$metal_reason" = "metal-requires-macos" ] && [ "$tolerance" = "false" ]; }
}

run_metal_render_log_compare() {
    case_dir="$BUILD_ROOT/metal_render_log"
    mkdir -p "$case_dir"
    backend_metal="$(field_of production_gui_web_renderer_parity_backend_metal_resolved "$BUILD_ROOT/evidence.env")"
    metal_status="$(field_of production_gui_web_renderer_parity_metal_readback_status "$BUILD_ROOT/evidence.env")"
    if [ "$backend_metal" != "metal" ] && [ "$metal_status" != "pass" ]; then
        {
            echo "production_gui_web_renderer_parity_metal_render_log_exit_code=0"
            echo "production_gui_web_renderer_parity_metal_render_log_status=skipped"
            echo "production_gui_web_renderer_parity_metal_render_log_reason=backend-not-metal"
            echo "production_gui_web_renderer_parity_metal_render_log_timed_out=false"
            echo "production_gui_web_renderer_parity_metal_render_log_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
            echo "production_gui_web_renderer_parity_metal_render_log_required_api=metal"
            echo "production_gui_web_renderer_parity_metal_render_log_backend_resolved=$backend_metal"
            echo "production_gui_web_renderer_parity_metal_render_log_metal_readback_status=$metal_status"
            echo "production_gui_web_renderer_parity_metal_render_log_report=$case_dir/report.md"
        } >>"$BUILD_ROOT/evidence.env"
        return 0
    fi
    if [ "$metal_status" != "pass" ]; then
        {
            echo "production_gui_web_renderer_parity_metal_render_log_exit_code=0"
            echo "production_gui_web_renderer_parity_metal_render_log_status=skipped"
            echo "production_gui_web_renderer_parity_metal_render_log_reason=upstream-not-ready"
            echo "production_gui_web_renderer_parity_metal_render_log_timed_out=false"
            echo "production_gui_web_renderer_parity_metal_render_log_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
            echo "production_gui_web_renderer_parity_metal_render_log_required_api=metal"
            echo "production_gui_web_renderer_parity_metal_render_log_backend_resolved=$backend_metal"
            echo "production_gui_web_renderer_parity_metal_render_log_metal_readback_status=$metal_status"
            echo "production_gui_web_renderer_parity_metal_render_log_report=$case_dir/report.md"
        } >>"$BUILD_ROOT/evidence.env"
        return 0
    fi

    browser_case_dir="$case_dir/browser"
    set +e
    run_subcheck env BUILD_DIR="$browser_case_dir" REPORT_PATH="$browser_case_dir/report.md" \
        sh "$METAL_BROWSER_BACKING_SCRIPT" >"$browser_case_dir.stdout.env" 2>"$browser_case_dir.stderr.log"
    browser_code=$?
    set -e

    set +e
    run_subcheck env BUILD_DIR="$case_dir" REPORT_PATH="$case_dir/report.md" \
        MACOS_METAL_BROWSER_ENV="$browser_case_dir/evidence.env" \
        sh "$METAL_RENDER_LOG_SCRIPT" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    env_file="$case_dir/evidence.env"
    compare_status=""
    compare_reason=""
    required_api=""
    generated_gate=""
    framebuffer_gate=""
    browser_gate=""
    pairwise_gate=""
    argb_source_gate=""
    gpu_capture_gate=""
    blocked_gate_count=""
    blocked_gates=""
    pairwise_status=""
    gpu_capture_status=""
    gpu_capture_tool=""
    tauri_ios_gate_status=""
    tauri_ios_validation_status=""
    tauri_ios_validation_reason=""
    tauri_ios_backend=""
    tauri_ios_expected_gpu_backend=""
    tauri_ios_metal_log_status=""
    tauri_ios_env_file_status=""
    tauri_ios_env_artifact_status=""
    require_tauri_ios=""
    if [ -s "$env_file" ]; then
        compare_status="$(field_of macos_metal_render_log_compare_status "$env_file")"
        compare_reason="$(field_of macos_metal_render_log_compare_reason "$env_file")"
        required_api="$(field_of macos_metal_render_log_compare_required_api "$env_file")"
        generated_gate="$(field_of macos_metal_render_log_compare_generated_readback_gate_status "$env_file")"
        framebuffer_gate="$(field_of macos_metal_render_log_compare_framebuffer_readback_gate_status "$env_file")"
        browser_gate="$(field_of macos_metal_render_log_compare_browser_backing_gate_status "$env_file")"
        pairwise_gate="$(field_of macos_metal_render_log_compare_pairwise_gate_status "$env_file")"
        argb_source_gate="$(field_of macos_metal_render_log_compare_argb_source_gate_status "$env_file")"
        gpu_capture_gate="$(field_of macos_metal_render_log_compare_gpu_capture_gate_status "$env_file")"
        blocked_gate_count="$(field_of macos_metal_render_log_compare_blocked_gate_count "$env_file")"
        blocked_gates="$(field_of macos_metal_render_log_compare_blocked_gates "$env_file")"
        pairwise_status="$(field_of macos_metal_render_log_compare_pairwise_status "$env_file")"
        gpu_capture_status="$(field_of macos_metal_render_log_compare_gpu_capture_status "$env_file")"
        gpu_capture_tool="$(field_of macos_metal_render_log_compare_gpu_capture_tool "$env_file")"
        tauri_ios_gate_status="$(field_of macos_metal_render_log_compare_tauri_ios_gate_status "$env_file")"
        tauri_ios_validation_status="$(field_of macos_metal_render_log_compare_tauri_ios_render_log_validation_status "$env_file")"
        tauri_ios_validation_reason="$(field_of macos_metal_render_log_compare_tauri_ios_render_log_validation_reason "$env_file")"
        tauri_ios_backend="$(field_of macos_metal_render_log_compare_tauri_ios_backend "$env_file")"
        tauri_ios_expected_gpu_backend="$(field_of macos_metal_render_log_compare_tauri_ios_expected_gpu_backend "$env_file")"
        tauri_ios_metal_log_status="$(field_of macos_metal_render_log_compare_tauri_ios_metal_log_status "$env_file")"
        tauri_ios_env_file_status="$(field_of macos_metal_render_log_compare_tauri_ios_env_file_status "$env_file")"
        tauri_ios_env_artifact_status="$(field_of macos_metal_render_log_compare_tauri_ios_env_artifact_status "$env_file")"
        require_tauri_ios="$(field_of macos_metal_render_log_compare_require_tauri_ios "$env_file")"
    fi
    if [ "$code" -eq 124 ]; then
        compare_status=timeout
        compare_reason=metal-render-log-timeout
    fi
    {
        echo "production_gui_web_renderer_parity_metal_render_log_exit_code=$code"
        echo "production_gui_web_renderer_parity_metal_render_log_status=$compare_status"
        echo "production_gui_web_renderer_parity_metal_render_log_reason=$compare_reason"
        echo "production_gui_web_renderer_parity_metal_render_log_timed_out=$([ "$code" -eq 124 ] && echo true || echo false)"
        echo "production_gui_web_renderer_parity_metal_render_log_timeout_secs=$SUBCHECK_TIMEOUT_SECS"
        echo "production_gui_web_renderer_parity_metal_render_log_required_api=$required_api"
        echo "production_gui_web_renderer_parity_metal_render_log_backend_resolved=$backend_metal"
        echo "production_gui_web_renderer_parity_metal_render_log_metal_readback_status=$metal_status"
        echo "production_gui_web_renderer_parity_metal_render_log_generated_readback_gate_status=$generated_gate"
        echo "production_gui_web_renderer_parity_metal_render_log_framebuffer_readback_gate_status=$framebuffer_gate"
        echo "production_gui_web_renderer_parity_metal_render_log_browser_backing_gate_status=$browser_gate"
        echo "production_gui_web_renderer_parity_metal_render_log_pairwise_gate_status=$pairwise_gate"
        echo "production_gui_web_renderer_parity_metal_render_log_argb_source_gate_status=$argb_source_gate"
        echo "production_gui_web_renderer_parity_metal_render_log_gpu_capture_gate_status=$gpu_capture_gate"
        echo "production_gui_web_renderer_parity_metal_render_log_blocked_gate_count=$blocked_gate_count"
        echo "production_gui_web_renderer_parity_metal_render_log_blocked_gates=$blocked_gates"
        echo "production_gui_web_renderer_parity_metal_render_log_pairwise_status=$pairwise_status"
        echo "production_gui_web_renderer_parity_metal_render_log_gpu_capture_status=$gpu_capture_status"
        echo "production_gui_web_renderer_parity_metal_render_log_gpu_capture_tool=$gpu_capture_tool"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_gate_status=$tauri_ios_gate_status"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_render_log_validation_status=$tauri_ios_validation_status"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_render_log_validation_reason=$tauri_ios_validation_reason"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_backend=$tauri_ios_backend"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_expected_gpu_backend=$tauri_ios_expected_gpu_backend"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_metal_log_status=$tauri_ios_metal_log_status"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_env_file_status=$tauri_ios_env_file_status"
        echo "production_gui_web_renderer_parity_metal_render_log_tauri_ios_env_artifact_status=$tauri_ios_env_artifact_status"
        echo "production_gui_web_renderer_parity_metal_render_log_require_tauri_ios=$require_tauri_ios"
        echo "production_gui_web_renderer_parity_metal_render_log_report=$case_dir/report.md"
    } >>"$BUILD_ROOT/evidence.env"
    append_prefixed_env "metal_render_log_" "$env_file"
    [ "$code" -eq 0 ] && [ "$compare_status" = "pass" ] && [ "$required_api" = "metal" ] && \
        [ "$generated_gate" = "pass" ] && [ "$framebuffer_gate" = "pass" ] && \
        [ "$browser_gate" = "pass" ] && [ "$pairwise_gate" = "pass" ] && \
        [ "$argb_source_gate" = "pass" ] && [ "$blocked_gate_count" = "0" ] && \
        { [ "$gpu_capture_gate" = "pass" ] || [ "$gpu_capture_gate" = "not-required" ]; }
}

num_at_least() {
    value="$1"
    min="$2"
    case "$value" in
        ''|*[!0-9]*) return 1 ;;
    esac
    [ "$value" -ge "$min" ]
}

num_positive() {
    value="$1"
    awk -v value="$value" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 > 0) exit 0
        exit 1
    }'
}

num_positive_at_most() {
    value="$1"
    max="$2"
    awk -v value="$value" -v max="$max" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 > 0 && value + 0 <= max + 0) exit 0
        exit 1
    }'
}

num_at_least_decimal() {
    value="$1"
    min="$2"
    awk -v value="$value" -v min="$min" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)?$/ && value + 0 >= min + 0) exit 0
        exit 1
    }'
}

version_text() {
    value="$1"
    awk -v value="$value" 'BEGIN {
        if (value ~ /^[0-9]+([.][0-9]+)*$/) exit 0
        exit 1
    }'
}

electron_chromium_user_agent() {
    value="$1"
    case "$value" in
        *Chrome/[0-9]*Electron/[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

