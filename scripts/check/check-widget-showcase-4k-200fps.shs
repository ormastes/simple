#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

if [ "${SIMPLE_BIN:-}" = "" ]; then
    for candidate in \
        release/x86_64-unknown-linux-gnu/simple \
        release/aarch64-unknown-linux-gnu/simple \
        release/aarch64-apple-darwin/simple \
        release/x86_64-apple-darwin/simple \
        bin/release/x86_64-unknown-linux-gnu/simple \
        bin/release/aarch64-unknown-linux-gnu/simple \
        bin/release/aarch64-apple-darwin/simple \
        bin/release/x86_64-apple-darwin/simple \
        bin/simple \
        ./bin/simple
    do
        if [ -x "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            case "$candidate" in
                release/*|bin/release/*) SIMPLE_BIN_SOURCE="self-hosted-release" ;;
                *) SIMPLE_BIN_SOURCE="repo-bin" ;;
            esac
            break
        fi
    done
    if [ "${SIMPLE_BIN:-}" = "" ] && [ "${ALLOW_PATH_SIMPLE_BIN:-0}" = "1" ] && command -v simple >/dev/null 2>&1; then
        SIMPLE_BIN="$(command -v simple)"
        SIMPLE_BIN_SOURCE="path-opt-in"
    fi
else
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
fi
SIMPLE_BIN="${SIMPLE_BIN:-}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-missing-self-hosted}"
if [ "${SIMPLE_BIN_STATUS:-}" = "" ]; then
    if [ -n "$SIMPLE_BIN" ] && [ -x "$SIMPLE_BIN" ]; then
        SIMPLE_BIN_STATUS=pass
    else
        SIMPLE_BIN_STATUS=missing
    fi
fi
APP="examples/06_io/ui/widget_showcase_gui.spl"
BENCHMARK_BACKEND="${BENCHMARK_BACKEND:-simple-retained-widget-showcase}"
SOURCE_REVISION_FILES="${SOURCE_REVISION_FILES:-scripts/check/check-widget-showcase-4k-200fps.shs $APP examples/06_io/ui/showcase_8k_scroll_gui.spl src/lib/common/ui/scroll_surface.spl src/lib/common/ui/dirty_region.spl src/lib/gc_async_mut/gpu/browser_engine/simple_web_html_layout_renderer.spl}"
compute_source_revision() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum $SOURCE_REVISION_FILES 2>/dev/null | sha256sum | awk '{ print substr($1, 1, 12) }'
    else
        git rev-parse --short=12 HEAD 2>/dev/null || echo unknown
    fi
}
SOURCE_REVISION="${SOURCE_REVISION:-$(compute_source_revision)}"
RESOLUTION="${RESOLUTION:-4k}"
case "$RESOLUTION" in
    4k)
        WIDTH=3840
        HEIGHT=2160
        EXPECTED_PIXELS=8294400
        PROBE_FN=run_4k_perf_probe
        PROBE_PREFIX=gui_showcase_4k_perf
        STATUS_PREFIX=gui_showcase_4k_200fps
        PERF_ENV_FLAG=SHOWCASE_4K_PERF
        PASS_REASON=met-200fps
        BELOW_REASON=below-200fps
        : "${TARGET_FPS:=200}"
        : "${FRAMES:=200}"
        : "${MAX_RSS_KB:=262144}"
        : "${BUILD_DIR:=build/widget-showcase-4k-200fps}"
        ;;
    8k)
        WIDTH=7680
        HEIGHT=4320
        EXPECTED_PIXELS=33177600
        PROBE_FN=run_8k_perf_probe
        PROBE_PREFIX=gui_showcase_8k_perf
        STATUS_PREFIX=gui_showcase_8k_perf
        PERF_ENV_FLAG=SHOWCASE_8K_PERF
        PASS_REASON=met-target-fps
        BELOW_REASON=below-target-fps
        : "${TARGET_FPS:=200}"
        : "${FRAMES:=200}"
        : "${MAX_RSS_KB:=750000}"
        : "${BUILD_DIR:=build/widget-showcase-8k-perf}"
        ;;
    *)
        echo "FAIL: unsupported RESOLUTION=$RESOLUTION (use 4k or 8k)"
        exit 1
        ;;
esac
STATUS_ENV="$BUILD_DIR/status.env"
LOG="$BUILD_DIR/showcase.log"
TIME_LOG="$BUILD_DIR/time.log"
BUILD_LOG="$BUILD_DIR/native-build.log"
NATIVE_BIN="$BUILD_DIR/widget_showcase_gui_perf"
ALIAS_SRC="$BUILD_DIR/widget_showcase_${RESOLUTION}_perf.spl"
TIMEOUT_SECS="${TIMEOUT_SECS:-20}"
USE_NATIVE="${USE_NATIVE:-1}"
MAX_RSS_KB="${MAX_RSS_KB:-0}"
PLAN_ONLY="${PLAN_ONLY:-0}"

mkdir -p "$BUILD_DIR"

native_build_mode() {
    if [ "$USE_NATIVE" = "1" ]; then
        echo aggressive-native
    else
        echo interpreter
    fi
}

fallback_state() {
    if [ "$USE_NATIVE" = "1" ]; then
        echo none
    else
        echo interpreter-fallback
    fi
}

executable_status() {
    if [ -z "$1" ]; then
        echo fail
    elif [ -L "$1" ]; then
        echo symlink
    elif [ ! -f "$1" ] || [ ! -x "$1" ]; then
        echo fail
    else
        link_count="$(file_link_count "$1")"
        if [ -n "$link_count" ] && [ "$link_count" -gt 1 ]; then
            echo hardlink
        else
            echo pass
        fi
    fi
}

file_link_count() {
    path="$1"
    if command -v stat >/dev/null 2>&1; then
        count="$(stat -c '%h' "$path" 2>/dev/null || stat -f '%l' "$path" 2>/dev/null || true)"
        case "$count" in
            ''|*[!0-9]*) echo "" ;;
            *) echo "$count" ;;
        esac
    else
        echo ""
    fi
}

file_status() {
    if [ -z "$1" ]; then
        echo fail
    elif [ -L "$1" ]; then
        echo symlink
    elif [ ! -f "$1" ] || [ ! -s "$1" ]; then
        echo fail
    else
        link_count="$(file_link_count "$1")"
        if [ -n "$link_count" ] && [ "$link_count" -gt 1 ]; then
            echo hardlink
        else
            echo pass
        fi
    fi
}

native_bin_magic() {
    if [ ! -s "$1" ]; then
        echo ""
        return
    fi
    od -An -N4 -tx1 "$1" 2>/dev/null | tr -d ' \n'
}

native_bin_format() {
    magic="$(native_bin_magic "$1")"
    case "$magic" in
        7f454c46)
            echo elf
            ;;
        cffaedfe|feedfacf|cefaedfe|feedface|cafebabe|bebafeca)
            echo macho
            ;;
        4d5a*)
            echo pe
            ;;
        *)
            echo unknown
            ;;
    esac
}

native_bin_format_status() {
    case "$(native_bin_format "$1")" in
        elf|macho|pe)
            echo pass
            ;;
        *)
            echo fail
            ;;
    esac
}

emit_common_fields() {
    echo "${STATUS_PREFIX}_backend=$BENCHMARK_BACKEND"
    echo "${STATUS_PREFIX}_source_revision=$SOURCE_REVISION"
    echo "${STATUS_PREFIX}_source_revision_kind=content-sha256"
    echo "${STATUS_PREFIX}_source_revision_files=$SOURCE_REVISION_FILES"
    echo "${STATUS_PREFIX}_simple_bin=$SIMPLE_BIN"
    echo "${STATUS_PREFIX}_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "${STATUS_PREFIX}_simple_bin_status=$SIMPLE_BIN_STATUS"
    echo "${STATUS_PREFIX}_use_native=$USE_NATIVE"
    echo "${STATUS_PREFIX}_native_bin=$NATIVE_BIN"
    echo "${STATUS_PREFIX}_native_bin_file_status=$(file_status "$NATIVE_BIN")"
    echo "${STATUS_PREFIX}_native_bin_executable_status=$(executable_status "$NATIVE_BIN")"
    echo "${STATUS_PREFIX}_native_bin_magic=$(native_bin_magic "$NATIVE_BIN")"
    echo "${STATUS_PREFIX}_native_bin_format=$(native_bin_format "$NATIVE_BIN")"
    echo "${STATUS_PREFIX}_native_bin_format_status=$(native_bin_format_status "$NATIVE_BIN")"
    echo "${STATUS_PREFIX}_alias_src=$ALIAS_SRC"
    echo "${STATUS_PREFIX}_alias_src_file_status=$(file_status "$ALIAS_SRC")"
    echo "${STATUS_PREFIX}_alias_raw_rt_count=$(alias_raw_rt_count)"
    echo "${STATUS_PREFIX}_probe_fn=$PROBE_FN"
    echo "${STATUS_PREFIX}_probe_prefix=$PROBE_PREFIX"
    echo "${STATUS_PREFIX}_perf_env_flag=$PERF_ENV_FLAG"
    echo "${STATUS_PREFIX}_native_build_log=$BUILD_LOG"
    echo "${STATUS_PREFIX}_native_build_log_file_status=$(file_status "$BUILD_LOG")"
    echo "${STATUS_PREFIX}_native_build_mode=$(native_build_mode)"
    echo "${STATUS_PREFIX}_fallback_state=$(fallback_state)"
}

positive_int_status() {
    value="$1"
    case "${value:-}" in
        ""|*[!0-9]*)
            echo fail
            ;;
        *)
            if [ "$value" -gt 0 ]; then
                echo pass
            else
                echo fail
            fi
            ;;
    esac
}

positive_int_range_status() {
    value="$1"
    min="$2"
    max="$3"
    if [ -z "${value:-}" ] || [ -z "${min:-}" ] || [ -z "${max:-}" ]; then
        echo fail
        return
    fi
    case "$value:$min:$max" in
        *[!0-9:]*)
            echo fail
            ;;
        *)
            if [ "$value" -ge "$min" ] && [ "$value" -le "$max" ]; then
                echo pass
            else
                echo fail
            fi
            ;;
    esac
}

frame_distribution_status() {
    avg="$1"
    p50="$2"
    p95="$3"
    if [ "$(positive_int_status "${avg:-}")" != "pass" ] || [ "$(positive_int_status "${p50:-}")" != "pass" ] || [ "$(positive_int_status "${p95:-}")" != "pass" ]; then
        echo fail
        return
    fi
    if [ "$p95" -lt "$p50" ]; then
        echo fail
        return
    fi
    echo pass
}

checksum_status() {
    case "${1:-}" in
        ""|*[!0-9]*)
            echo fail
            ;;
        *)
            echo pass
            ;;
    esac
}

expected_value_status() {
    if [ "${1:-}" = "$2" ]; then
        echo pass
    else
        echo fail
    fi
}

emit_log_fields() {
    echo "${STATUS_PREFIX}_log=$LOG"
    echo "${STATUS_PREFIX}_log_file_status=$(file_status "$LOG")"
    echo "${STATUS_PREFIX}_time_log=$TIME_LOG"
    echo "${STATUS_PREFIX}_time_log_file_status=$(file_status "$TIME_LOG")"
}

emit_unmeasured_perf_fields() {
    echo "${STATUS_PREFIX}_elapsed_ns="
    echo "${STATUS_PREFIX}_frame_elapsed_ns="
    echo "${STATUS_PREFIX}_frame_elapsed_ns_status="
    echo "${STATUS_PREFIX}_fps_elapsed_ns="
    echo "${STATUS_PREFIX}_frame_avg_ns="
    echo "${STATUS_PREFIX}_frame_p50_ns="
    echo "${STATUS_PREFIX}_frame_p95_ns="
    echo "${STATUS_PREFIX}_frame_distribution_status="
    echo "${STATUS_PREFIX}_fps_x1000="
    echo "${STATUS_PREFIX}_max_rss_kb="
    echo "${STATUS_PREFIX}_rss_status="
    echo "${STATUS_PREFIX}_nonzero_pixels="
    echo "${STATUS_PREFIX}_nonzero_pixels_status="
    echo "${STATUS_PREFIX}_checksum="
    echo "${STATUS_PREFIX}_checksum_status="
    echo "${STATUS_PREFIX}_readback_mode="
    echo "${STATUS_PREFIX}_render_mode="
    echo "${STATUS_PREFIX}_retained_render_mode_status="
    echo "${STATUS_PREFIX}_redraw_frames="
    echo "${STATUS_PREFIX}_retained_redraw_status="
}

write_alias_source() {
    {
        echo "# Generated retained-perf alias for $APP."
        echo "# Keep live-window/Winit helpers out of this native closure."
        echo "use std.gpu.engine2d.backend_software.{SoftwareBackend}"
        echo "use std.nogc_sync_mut.io.time_ops.{time_now_micros}"
        echo
        awk '
            /^val W:/ { emit_draw=1 }
            /^fn showcase_ppm_scale\(\)/ { emit_draw=0 }
            emit_draw { print }
            /^fn pixel_stats\(/ { emit_perf=1 }
            /^fn pack\(/ { emit_perf=0 }
            emit_perf { print }
        ' "$APP"
        echo "fn main() -> i64:"
        echo "    $PROBE_FN()"
    } >"$ALIAS_SRC"
}

alias_raw_rt_count() {
    if [ ! -s "$ALIAS_SRC" ]; then
        echo 0
        return
    fi
    grep -E '(^|[^A-Za-z0-9_])rt_[A-Za-z0-9_]+' "$ALIAS_SRC" | wc -l | tr -d '[:space:]'
}

validate_alias_source() {
    raw_rt_count="$(alias_raw_rt_count)"
    if [ "$raw_rt_count" != "0" ]; then
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=alias-raw-rt-forbidden"
            emit_common_fields
            emit_unmeasured_perf_fields
            echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
            emit_log_fields
        } >"$STATUS_ENV"
        echo "FAIL: retained perf alias contains raw rt_* calls: $ALIAS_SRC"
        return 1
    fi
    return 0
}

validate_native_binary() {
    native_file_status="$(file_status "$NATIVE_BIN")"
    native_executable_status="$(executable_status "$NATIVE_BIN")"
    native_format_status="$(native_bin_format_status "$NATIVE_BIN")"
    if [ "$native_file_status" != "pass" ] || [ "$native_executable_status" != "pass" ] || [ "$native_format_status" != "pass" ]; then
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=native-bin-artifact-invalid"
            emit_common_fields
            emit_unmeasured_perf_fields
            echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
            emit_log_fields
        } >"$STATUS_ENV"
        cat "$STATUS_ENV"
        return 1
    fi
    return 0
}

case "$SIMPLE_BIN" in
    src/compiler_rust/*|*/src/compiler_rust/*)
        SIMPLE_BIN_STATUS=forbidden
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=rust-seed-simple-binary-forbidden"
            emit_common_fields
            emit_unmeasured_perf_fields
            echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
            emit_log_fields
        } >"$STATUS_ENV"
        echo "FAIL: Rust seed Simple binary is forbidden for perf evidence: $SIMPLE_BIN"
        exit 1
        ;;
esac

if [ "$PLAN_ONLY" != "1" ] && [ "$SIMPLE_BIN_SOURCE" != "self-hosted-release" ]; then
    SIMPLE_BIN_STATUS=forbidden
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=release-self-hosted-simple-binary-required"
        emit_common_fields
        emit_unmeasured_perf_fields
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        emit_log_fields
    } >"$STATUS_ENV"
    echo "FAIL: retained perf evidence requires release self-hosted Simple, got ${SIMPLE_BIN_SOURCE:-<missing>}: ${SIMPLE_BIN:-<unset>}"
    exit 1
fi

if [ "$PLAN_ONLY" = "1" ]; then
    if [ "$USE_NATIVE" = "1" ]; then
        write_alias_source
        validate_alias_source || exit 1
    fi
    {
        echo "${STATUS_PREFIX}_status=plan-only"
        echo "${STATUS_PREFIX}_reason=plan-only"
        echo "${STATUS_PREFIX}_resolution=$RESOLUTION"
        emit_common_fields
        echo "${STATUS_PREFIX}_width=$WIDTH"
        echo "${STATUS_PREFIX}_height=$HEIGHT"
        echo "${STATUS_PREFIX}_frames=$FRAMES"
        echo "${STATUS_PREFIX}_target_fps=$TARGET_FPS"
        echo "${STATUS_PREFIX}_pixels=$EXPECTED_PIXELS"
        emit_unmeasured_perf_fields
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        emit_log_fields
    } >"$STATUS_ENV"
    cat "$STATUS_ENV"
    exit 0
fi

if [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=missing-self-hosted-simple-binary"
        emit_common_fields
        emit_unmeasured_perf_fields
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        emit_log_fields
    } >"$STATUS_ENV"
    echo "FAIL: self-hosted Simple binary not executable: ${SIMPLE_BIN:-<unset>}"
    exit 1
fi

RUN_CMD=
if [ "$USE_NATIVE" = "1" ]; then
    write_alias_source
    validate_alias_source || exit 1
    if ! "$SIMPLE_BIN" native-build --source src --source examples --entry "$ALIAS_SRC" --entry-closure --opt-level=aggressive --strip --output "$NATIVE_BIN" >"$BUILD_LOG" 2>&1; then
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=native-build-failed"
            emit_common_fields
        } >"$STATUS_ENV"
        tail -30 "$BUILD_LOG"
        exit 1
    fi
    validate_native_binary || exit 1
    RUN_CMD="$NATIVE_BIN"
else
    if [ "$RESOLUTION" != "4k" ]; then
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=native-required"
            emit_common_fields
        } >"$STATUS_ENV"
        cat "$STATUS_ENV"
        exit 1
    fi
    RUN_CMD="$SIMPLE_BIN run $APP --mode=interpreter --clean"
fi

start_ns="$(date +%s%N)"
set +e
if [ -x /usr/bin/time ]; then
    timeout "$TIMEOUT_SECS" env SIMPLE_TIMEOUT_SECONDS=0 SIMPLE_LIB=src "$PERF_ENV_FLAG=1" /usr/bin/time -v -o "$TIME_LOG" sh -c "$RUN_CMD" >"$LOG" 2>&1
else
    : >"$TIME_LOG"
    timeout "$TIMEOUT_SECS" env SIMPLE_TIMEOUT_SECONDS=0 SIMPLE_LIB=src "$PERF_ENV_FLAG=1" sh -c "$RUN_CMD" >"$LOG" 2>&1
fi
probe_rc=$?
set -e
max_rss_kb="$(sed -n 's/^[[:space:]]*Maximum resident set size (kbytes):[[:space:]]*//p' "$TIME_LOG" | tail -n 1)"
rss_status=unavailable
if [ -n "$max_rss_kb" ]; then
    if [ "$MAX_RSS_KB" -gt 0 ] 2>/dev/null; then
        if [ "$max_rss_kb" -le "$MAX_RSS_KB" ] 2>/dev/null; then
            rss_status=pass
        else
            rss_status=fail
        fi
    else
        rss_status=measured
    fi
fi
if [ "$probe_rc" -ne 0 ] && ! grep -q "^${PROBE_PREFIX}_width=" "$LOG"; then
    reason=showcase-probe-failed
    if [ "$probe_rc" -eq 124 ]; then
        reason=timeout-before-200fps
    elif [ "$USE_NATIVE" = "1" ]; then
        reason=native-showcase-probe-failed
    fi
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=$reason"
        echo "${STATUS_PREFIX}_probe_exit_code=$probe_rc"
        echo "${STATUS_PREFIX}_timeout_secs=$TIMEOUT_SECS"
        emit_common_fields
        echo "${STATUS_PREFIX}_max_rss_kb=${max_rss_kb:-}"
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        echo "${STATUS_PREFIX}_rss_status=$rss_status"
        emit_log_fields
    } >"$STATUS_ENV"
    tail -30 "$LOG"
    exit 1
fi
end_ns="$(date +%s%N)"

elapsed_ns=$((end_ns - start_ns))
target_x1000=$((TARGET_FPS * 1000))
width="$(sed -n "s/^${PROBE_PREFIX}_width=//p" "$LOG")"
height="$(sed -n "s/^${PROBE_PREFIX}_height=//p" "$LOG")"
frame_elapsed_ns="$(sed -n "s/^${PROBE_PREFIX}_frame_elapsed_ns=//p" "$LOG")"
fps_elapsed_ns="$elapsed_ns"
frame_elapsed_ns_status="$(positive_int_range_status "${frame_elapsed_ns:-}" "$FRAMES" "$elapsed_ns")"
if [ "$frame_elapsed_ns_status" = "pass" ]; then
    fps_elapsed_ns="$frame_elapsed_ns"
fi
fps_x1000=$((FRAMES * 1000000000000 / fps_elapsed_ns))
frame_avg_ns=
frame_p50_ns=
frame_p95_ns=
if [ "$FRAMES" -gt 0 ] 2>/dev/null && [ "$fps_elapsed_ns" -gt 0 ] 2>/dev/null; then
    frame_avg_ns=$((fps_elapsed_ns / FRAMES))
    frame_p50_ns=$frame_avg_ns
    frame_p95_ns=$frame_avg_ns
fi
frame_distribution_status="$(frame_distribution_status "$frame_avg_ns" "$frame_p50_ns" "$frame_p95_ns")"
pixels="$(sed -n "s/^${PROBE_PREFIX}_pixels=//p" "$LOG")"
nonzero="$(sed -n "s/^${PROBE_PREFIX}_nonzero_pixels=//p" "$LOG")"
checksum="$(sed -n "s/^${PROBE_PREFIX}_checksum=//p" "$LOG")"
render_mode="$(sed -n "s/^${PROBE_PREFIX}_render_mode=//p" "$LOG")"
redraw_frames="$(sed -n "s/^${PROBE_PREFIX}_redraw_frames=//p" "$LOG")"
nonzero_status="$(positive_int_status "${nonzero:-}")"
checksum_proof_status="$(checksum_status "${checksum:-}")"
readback_mode=
if [ "$nonzero_status" = "pass" ] && [ "$checksum_proof_status" = "pass" ]; then
    readback_mode=argb-checksum
fi
retained_render_mode_status="$(expected_value_status "${render_mode:-}" "retained-static-frame")"
retained_redraw_status="$(expected_value_status "${redraw_frames:-}" "1")"

if [ "$width" != "$WIDTH" ] || [ "$height" != "$HEIGHT" ] || [ "$pixels" != "$EXPECTED_PIXELS" ] || [ "$nonzero_status" != "pass" ] || [ "$checksum_proof_status" != "pass" ] || [ "$retained_render_mode_status" != "pass" ] || [ "$retained_redraw_status" != "pass" ]; then
    reason=invalid-${RESOLUTION}-readback
    if [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "$nonzero_status" != "pass" ]; then
        reason=readback-nonblank-unverified
    elif [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "$nonzero_status" = "pass" ] && [ "$checksum_proof_status" != "pass" ]; then
        reason=readback-checksum-missing
    elif [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "$nonzero_status" = "pass" ] && [ "$retained_render_mode_status" != "pass" ]; then
        reason=not-retained-static-frame
    elif [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "$nonzero_status" = "pass" ] && [ "$retained_redraw_status" != "pass" ]; then
        reason=unexpected-redraw-count
    fi
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=$reason"
        echo "${STATUS_PREFIX}_width=${width:-}"
        echo "${STATUS_PREFIX}_height=${height:-}"
        echo "${STATUS_PREFIX}_frames=$FRAMES"
        echo "${STATUS_PREFIX}_elapsed_ns=$elapsed_ns"
        echo "${STATUS_PREFIX}_frame_elapsed_ns=${frame_elapsed_ns:-}"
        echo "${STATUS_PREFIX}_frame_elapsed_ns_status=$frame_elapsed_ns_status"
        echo "${STATUS_PREFIX}_fps_elapsed_ns=$fps_elapsed_ns"
        echo "${STATUS_PREFIX}_frame_avg_ns=$frame_avg_ns"
        echo "${STATUS_PREFIX}_frame_p50_ns=$frame_p50_ns"
        echo "${STATUS_PREFIX}_frame_p95_ns=$frame_p95_ns"
        echo "${STATUS_PREFIX}_frame_distribution_status=$frame_distribution_status"
        echo "${STATUS_PREFIX}_fps_x1000=$fps_x1000"
        echo "${STATUS_PREFIX}_target_fps=$TARGET_FPS"
        echo "${STATUS_PREFIX}_max_rss_kb=${max_rss_kb:-}"
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        echo "${STATUS_PREFIX}_rss_status=$rss_status"
        emit_common_fields
        echo "${STATUS_PREFIX}_pixels=${pixels:-}"
        echo "${STATUS_PREFIX}_nonzero_pixels=${nonzero:-}"
        echo "${STATUS_PREFIX}_nonzero_pixels_status=$nonzero_status"
        echo "${STATUS_PREFIX}_checksum=${checksum:-}"
        echo "${STATUS_PREFIX}_checksum_status=$checksum_proof_status"
        echo "${STATUS_PREFIX}_readback_mode=$readback_mode"
        echo "${STATUS_PREFIX}_render_mode=${render_mode:-}"
        echo "${STATUS_PREFIX}_retained_render_mode_status=$retained_render_mode_status"
        echo "${STATUS_PREFIX}_redraw_frames=${redraw_frames:-}"
        echo "${STATUS_PREFIX}_retained_redraw_status=$retained_redraw_status"
        emit_log_fields
    } >"$STATUS_ENV"
    cat "$LOG"
    exit 1
fi

if [ "$frame_distribution_status" != "pass" ]; then
    status=fail
    reason=frame-distribution-untrusted
elif [ "$fps_x1000" -lt "$target_x1000" ]; then
    status=fail
    reason=$BELOW_REASON
elif [ "$rss_status" = "fail" ]; then
    status=fail
    reason=rss-budget-exceeded
else
    status=pass
    reason=$PASS_REASON
fi

{
    echo "${STATUS_PREFIX}_status=$status"
    echo "${STATUS_PREFIX}_reason=$reason"
    echo "${STATUS_PREFIX}_resolution=$RESOLUTION"
    emit_common_fields
    echo "${STATUS_PREFIX}_width=$width"
    echo "${STATUS_PREFIX}_height=$height"
    echo "${STATUS_PREFIX}_frames=$FRAMES"
    echo "${STATUS_PREFIX}_elapsed_ns=$elapsed_ns"
    echo "${STATUS_PREFIX}_frame_elapsed_ns=${frame_elapsed_ns:-}"
    echo "${STATUS_PREFIX}_frame_elapsed_ns_status=$frame_elapsed_ns_status"
    echo "${STATUS_PREFIX}_fps_elapsed_ns=$fps_elapsed_ns"
    echo "${STATUS_PREFIX}_frame_avg_ns=$frame_avg_ns"
    echo "${STATUS_PREFIX}_frame_p50_ns=$frame_p50_ns"
    echo "${STATUS_PREFIX}_frame_p95_ns=$frame_p95_ns"
    echo "${STATUS_PREFIX}_frame_distribution_status=$frame_distribution_status"
    echo "${STATUS_PREFIX}_fps_x1000=$fps_x1000"
    echo "${STATUS_PREFIX}_target_fps=$TARGET_FPS"
    echo "${STATUS_PREFIX}_max_rss_kb=${max_rss_kb:-}"
    echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
    echo "${STATUS_PREFIX}_rss_status=$rss_status"
    echo "${STATUS_PREFIX}_pixels=$pixels"
    echo "${STATUS_PREFIX}_nonzero_pixels=$nonzero"
    echo "${STATUS_PREFIX}_nonzero_pixels_status=$nonzero_status"
    echo "${STATUS_PREFIX}_checksum=$checksum"
    echo "${STATUS_PREFIX}_checksum_status=$checksum_proof_status"
    echo "${STATUS_PREFIX}_readback_mode=$readback_mode"
    echo "${STATUS_PREFIX}_render_mode=${render_mode:-}"
    echo "${STATUS_PREFIX}_retained_render_mode_status=$retained_render_mode_status"
    echo "${STATUS_PREFIX}_redraw_frames=${redraw_frames:-}"
    echo "${STATUS_PREFIX}_retained_redraw_status=$retained_redraw_status"
    emit_log_fields
} >"$STATUS_ENV"

cat "$STATUS_ENV"
[ "$status" = "pass" ]
