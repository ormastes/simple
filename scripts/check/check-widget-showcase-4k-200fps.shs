#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-src/compiler_rust/target/release/simple}"
SOURCE_REVISION="${SOURCE_REVISION:-$(git rev-parse --short=12 HEAD 2>/dev/null || echo unknown)}"
RESOLUTION="${RESOLUTION:-4k}"
case "$RESOLUTION" in
    4k)
        WIDTH=3840
        HEIGHT=2160
        EXPECTED_PIXELS=8294400
        PROBE_FN=run_4k_perf_probe
        PROBE_PREFIX=gui_showcase_4k_perf
        STATUS_PREFIX=gui_showcase_4k_200fps
        PERF_ENV_FLAG=SHOWCASE_4K_PERF
        PASS_REASON=met-200fps
        BELOW_REASON=below-200fps
        : "${TARGET_FPS:=200}"
        : "${FRAMES:=200}"
        : "${MAX_RSS_KB:=262144}"
        : "${BUILD_DIR:=build/widget-showcase-4k-200fps}"
        ;;
    8k)
        WIDTH=7680
        HEIGHT=4320
        EXPECTED_PIXELS=33177600
        PROBE_FN=run_8k_perf_probe
        PROBE_PREFIX=gui_showcase_8k_perf
        STATUS_PREFIX=gui_showcase_8k_perf
        PERF_ENV_FLAG=SHOWCASE_8K_PERF
        PASS_REASON=met-target-fps
        BELOW_REASON=below-target-fps
        : "${TARGET_FPS:=200}"
        : "${FRAMES:=200}"
        : "${MAX_RSS_KB:=750000}"
        : "${BUILD_DIR:=build/widget-showcase-8k-perf}"
        ;;
    *)
        echo "FAIL: unsupported RESOLUTION=$RESOLUTION (use 4k or 8k)"
        exit 1
        ;;
esac
STATUS_ENV="$BUILD_DIR/status.env"
LOG="$BUILD_DIR/showcase.log"
TIME_LOG="$BUILD_DIR/time.log"
BUILD_LOG="$BUILD_DIR/native-build.log"
NATIVE_BIN="$BUILD_DIR/widget_showcase_gui_perf"
ALIAS_SRC="$BUILD_DIR/widget_showcase_${RESOLUTION}_perf.spl"
APP="examples/06_io/ui/widget_showcase_gui.spl"
TIMEOUT_SECS="${TIMEOUT_SECS:-20}"
USE_NATIVE="${USE_NATIVE:-1}"
MAX_RSS_KB="${MAX_RSS_KB:-0}"
PLAN_ONLY="${PLAN_ONLY:-0}"

mkdir -p "$BUILD_DIR"

native_build_mode() {
    if [ "$USE_NATIVE" = "1" ]; then
        echo aggressive-native
    else
        echo interpreter
    fi
}

fallback_state() {
    if [ "$USE_NATIVE" = "1" ]; then
        echo none
    else
        echo interpreter-fallback
    fi
}

emit_common_fields() {
    echo "${STATUS_PREFIX}_source_revision=$SOURCE_REVISION"
    echo "${STATUS_PREFIX}_simple_bin=$SIMPLE_BIN"
    echo "${STATUS_PREFIX}_use_native=$USE_NATIVE"
    echo "${STATUS_PREFIX}_native_bin=$NATIVE_BIN"
    echo "${STATUS_PREFIX}_alias_src=$ALIAS_SRC"
    echo "${STATUS_PREFIX}_probe_fn=$PROBE_FN"
    echo "${STATUS_PREFIX}_probe_prefix=$PROBE_PREFIX"
    echo "${STATUS_PREFIX}_perf_env_flag=$PERF_ENV_FLAG"
    echo "${STATUS_PREFIX}_native_build_log=$BUILD_LOG"
    echo "${STATUS_PREFIX}_native_build_mode=$(native_build_mode)"
    echo "${STATUS_PREFIX}_fallback_state=$(fallback_state)"
}

file_status() {
    if [ -s "$1" ]; then
        echo pass
    else
        echo fail
    fi
}

emit_log_fields() {
    echo "${STATUS_PREFIX}_log=$LOG"
    echo "${STATUS_PREFIX}_log_file_status=$(file_status "$LOG")"
    echo "${STATUS_PREFIX}_time_log=$TIME_LOG"
    echo "${STATUS_PREFIX}_time_log_file_status=$(file_status "$TIME_LOG")"
}

emit_unmeasured_perf_fields() {
    echo "${STATUS_PREFIX}_elapsed_ns="
    echo "${STATUS_PREFIX}_frame_elapsed_ns="
    echo "${STATUS_PREFIX}_fps_elapsed_ns="
    echo "${STATUS_PREFIX}_frame_avg_ns="
    echo "${STATUS_PREFIX}_frame_p50_ns="
    echo "${STATUS_PREFIX}_frame_p95_ns="
    echo "${STATUS_PREFIX}_fps_x1000="
    echo "${STATUS_PREFIX}_max_rss_kb="
    echo "${STATUS_PREFIX}_rss_status="
    echo "${STATUS_PREFIX}_nonzero_pixels="
    echo "${STATUS_PREFIX}_checksum="
    echo "${STATUS_PREFIX}_render_mode="
    echo "${STATUS_PREFIX}_redraw_frames="
}

write_alias_source() {
    awk '
        /^fn main\(\) -> i64:/ { stop=1 }
        !stop { print }
        END {
            print "fn main() -> i64:"
            print "    '"$PROBE_FN"'()"
        }
    ' "$APP" >"$ALIAS_SRC"
}

if [ "$PLAN_ONLY" = "1" ]; then
    if [ "$USE_NATIVE" = "1" ]; then
        write_alias_source
    fi
    {
        echo "${STATUS_PREFIX}_status=plan-only"
        echo "${STATUS_PREFIX}_reason=plan-only"
        echo "${STATUS_PREFIX}_resolution=$RESOLUTION"
        emit_common_fields
        echo "${STATUS_PREFIX}_width=$WIDTH"
        echo "${STATUS_PREFIX}_height=$HEIGHT"
        echo "${STATUS_PREFIX}_frames=$FRAMES"
        echo "${STATUS_PREFIX}_target_fps=$TARGET_FPS"
        echo "${STATUS_PREFIX}_pixels=$EXPECTED_PIXELS"
        emit_unmeasured_perf_fields
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        emit_log_fields
    } >"$STATUS_ENV"
    cat "$STATUS_ENV"
    exit 0
fi

if [ ! -x "$SIMPLE_BIN" ]; then
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=missing-simple-binary"
        emit_common_fields
    } >"$STATUS_ENV"
    echo "FAIL: $SIMPLE_BIN not executable"
    exit 1
fi

RUN_CMD=
if [ "$USE_NATIVE" = "1" ]; then
    write_alias_source
    if ! "$SIMPLE_BIN" native-build --source src --source examples --entry "$ALIAS_SRC" --entry-closure --opt-level=aggressive --strip --output "$NATIVE_BIN" >"$BUILD_LOG" 2>&1; then
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=native-build-failed"
            emit_common_fields
        } >"$STATUS_ENV"
        tail -30 "$BUILD_LOG"
        exit 1
    fi
    RUN_CMD="$NATIVE_BIN"
else
    if [ "$RESOLUTION" != "4k" ]; then
        {
            echo "${STATUS_PREFIX}_status=fail"
            echo "${STATUS_PREFIX}_reason=native-required"
            emit_common_fields
        } >"$STATUS_ENV"
        cat "$STATUS_ENV"
        exit 1
    fi
    RUN_CMD="$SIMPLE_BIN run $APP --mode=interpreter --clean"
fi

start_ns="$(date +%s%N)"
set +e
if [ -x /usr/bin/time ]; then
    timeout "$TIMEOUT_SECS" env SIMPLE_TIMEOUT_SECONDS=0 SIMPLE_LIB=src "$PERF_ENV_FLAG=1" /usr/bin/time -v -o "$TIME_LOG" sh -c "$RUN_CMD" >"$LOG" 2>&1
else
    : >"$TIME_LOG"
    timeout "$TIMEOUT_SECS" env SIMPLE_TIMEOUT_SECONDS=0 SIMPLE_LIB=src "$PERF_ENV_FLAG=1" sh -c "$RUN_CMD" >"$LOG" 2>&1
fi
probe_rc=$?
set -e
max_rss_kb="$(sed -n 's/^[[:space:]]*Maximum resident set size (kbytes):[[:space:]]*//p' "$TIME_LOG" | tail -n 1)"
rss_status=unavailable
if [ -n "$max_rss_kb" ]; then
    if [ "$MAX_RSS_KB" -gt 0 ] 2>/dev/null; then
        if [ "$max_rss_kb" -le "$MAX_RSS_KB" ] 2>/dev/null; then
            rss_status=pass
        else
            rss_status=fail
        fi
    else
        rss_status=measured
    fi
fi
if [ "$probe_rc" -ne 0 ] && ! grep -q "^${PROBE_PREFIX}_width=" "$LOG"; then
    reason=showcase-probe-failed
    if [ "$probe_rc" -eq 124 ]; then
        reason=timeout-before-200fps
    elif [ "$USE_NATIVE" = "1" ]; then
        reason=native-showcase-probe-failed
    fi
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=$reason"
        echo "${STATUS_PREFIX}_probe_exit_code=$probe_rc"
        echo "${STATUS_PREFIX}_timeout_secs=$TIMEOUT_SECS"
        emit_common_fields
        echo "${STATUS_PREFIX}_max_rss_kb=${max_rss_kb:-}"
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        echo "${STATUS_PREFIX}_rss_status=$rss_status"
        emit_log_fields
    } >"$STATUS_ENV"
    tail -30 "$LOG"
    exit 1
fi
end_ns="$(date +%s%N)"

elapsed_ns=$((end_ns - start_ns))
target_x1000=$((TARGET_FPS * 1000))
width="$(sed -n "s/^${PROBE_PREFIX}_width=//p" "$LOG")"
height="$(sed -n "s/^${PROBE_PREFIX}_height=//p" "$LOG")"
frame_elapsed_ns="$(sed -n "s/^${PROBE_PREFIX}_frame_elapsed_ns=//p" "$LOG")"
fps_elapsed_ns="$elapsed_ns"
if [ "${frame_elapsed_ns:-0}" -gt 0 ] 2>/dev/null; then
    fps_elapsed_ns="$frame_elapsed_ns"
fi
fps_x1000=$((FRAMES * 1000000000000 / fps_elapsed_ns))
frame_avg_ns=
frame_p50_ns=
frame_p95_ns=
if [ "$FRAMES" -gt 0 ] 2>/dev/null && [ "$fps_elapsed_ns" -gt 0 ] 2>/dev/null; then
    frame_avg_ns=$((fps_elapsed_ns / FRAMES))
    frame_p50_ns=$frame_avg_ns
    frame_p95_ns=$frame_avg_ns
fi
pixels="$(sed -n "s/^${PROBE_PREFIX}_pixels=//p" "$LOG")"
nonzero="$(sed -n "s/^${PROBE_PREFIX}_nonzero_pixels=//p" "$LOG")"
checksum="$(sed -n "s/^${PROBE_PREFIX}_checksum=//p" "$LOG")"
render_mode="$(sed -n "s/^${PROBE_PREFIX}_render_mode=//p" "$LOG")"
redraw_frames="$(sed -n "s/^${PROBE_PREFIX}_redraw_frames=//p" "$LOG")"

if [ "$width" != "$WIDTH" ] || [ "$height" != "$HEIGHT" ] || [ "$pixels" != "$EXPECTED_PIXELS" ] || [ "${nonzero:-0}" -le 0 ] || [ "$checksum" = "" ] || [ "$render_mode" != "retained-static-frame" ] || [ "${redraw_frames:-0}" -ne 1 ]; then
    reason=invalid-${RESOLUTION}-readback
    if [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "${nonzero:-0}" -le 0 ]; then
        reason=readback-nonblank-unverified
    elif [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "${nonzero:-0}" -gt 0 ] && [ "$checksum" = "" ]; then
        reason=readback-checksum-missing
    elif [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "${nonzero:-0}" -gt 0 ] && [ "$render_mode" != "retained-static-frame" ]; then
        reason=not-retained-static-frame
    elif [ "$width" = "$WIDTH" ] && [ "$height" = "$HEIGHT" ] && [ "$pixels" = "$EXPECTED_PIXELS" ] && [ "${nonzero:-0}" -gt 0 ] && [ "${redraw_frames:-0}" -ne 1 ]; then
        reason=unexpected-redraw-count
    fi
    {
        echo "${STATUS_PREFIX}_status=fail"
        echo "${STATUS_PREFIX}_reason=$reason"
        echo "${STATUS_PREFIX}_width=${width:-}"
        echo "${STATUS_PREFIX}_height=${height:-}"
        echo "${STATUS_PREFIX}_frames=$FRAMES"
        echo "${STATUS_PREFIX}_elapsed_ns=$elapsed_ns"
        echo "${STATUS_PREFIX}_frame_elapsed_ns=${frame_elapsed_ns:-}"
        echo "${STATUS_PREFIX}_fps_elapsed_ns=$fps_elapsed_ns"
        echo "${STATUS_PREFIX}_frame_avg_ns=$frame_avg_ns"
        echo "${STATUS_PREFIX}_frame_p50_ns=$frame_p50_ns"
        echo "${STATUS_PREFIX}_frame_p95_ns=$frame_p95_ns"
        echo "${STATUS_PREFIX}_fps_x1000=$fps_x1000"
        echo "${STATUS_PREFIX}_target_fps=$TARGET_FPS"
        echo "${STATUS_PREFIX}_max_rss_kb=${max_rss_kb:-}"
        echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
        echo "${STATUS_PREFIX}_rss_status=$rss_status"
        emit_common_fields
        echo "${STATUS_PREFIX}_pixels=${pixels:-}"
        echo "${STATUS_PREFIX}_nonzero_pixels=${nonzero:-}"
        echo "${STATUS_PREFIX}_checksum=${checksum:-}"
        echo "${STATUS_PREFIX}_render_mode=${render_mode:-}"
        echo "${STATUS_PREFIX}_redraw_frames=${redraw_frames:-}"
        emit_log_fields
    } >"$STATUS_ENV"
    cat "$LOG"
    exit 1
fi

if [ "$fps_x1000" -lt "$target_x1000" ]; then
    status=fail
    reason=$BELOW_REASON
elif [ "$rss_status" = "fail" ]; then
    status=fail
    reason=rss-budget-exceeded
else
    status=pass
    reason=$PASS_REASON
fi

{
    echo "${STATUS_PREFIX}_status=$status"
    echo "${STATUS_PREFIX}_reason=$reason"
    echo "${STATUS_PREFIX}_resolution=$RESOLUTION"
    emit_common_fields
    echo "${STATUS_PREFIX}_width=$width"
    echo "${STATUS_PREFIX}_height=$height"
    echo "${STATUS_PREFIX}_frames=$FRAMES"
    echo "${STATUS_PREFIX}_elapsed_ns=$elapsed_ns"
    echo "${STATUS_PREFIX}_frame_elapsed_ns=${frame_elapsed_ns:-}"
    echo "${STATUS_PREFIX}_fps_elapsed_ns=$fps_elapsed_ns"
    echo "${STATUS_PREFIX}_frame_avg_ns=$frame_avg_ns"
    echo "${STATUS_PREFIX}_frame_p50_ns=$frame_p50_ns"
    echo "${STATUS_PREFIX}_frame_p95_ns=$frame_p95_ns"
    echo "${STATUS_PREFIX}_fps_x1000=$fps_x1000"
    echo "${STATUS_PREFIX}_target_fps=$TARGET_FPS"
    echo "${STATUS_PREFIX}_max_rss_kb=${max_rss_kb:-}"
    echo "${STATUS_PREFIX}_max_rss_budget_kb=$MAX_RSS_KB"
    echo "${STATUS_PREFIX}_rss_status=$rss_status"
    echo "${STATUS_PREFIX}_pixels=$pixels"
    echo "${STATUS_PREFIX}_nonzero_pixels=$nonzero"
    echo "${STATUS_PREFIX}_checksum=$checksum"
    echo "${STATUS_PREFIX}_render_mode=${render_mode:-}"
    echo "${STATUS_PREFIX}_redraw_frames=${redraw_frames:-}"
    emit_log_fields
} >"$STATUS_ENV"

cat "$STATUS_ENV"
[ "$status" = "pass" ]
