#!/usr/bin/env sh
set -eu

BUILD_DIR="build/perf/httpserver_live_static"
SRC="test/05_perf/web/httpserver_live_static_fixture.spl"
BIN="$BUILD_DIR/httpserver_live_static_fixture"

mkdir -p "$BUILD_DIR" /tmp/simple-live-static
printf 'static-ok\n' > /tmp/simple-live-static/hello.txt

bin/simple check "$SRC"
SIMPLE_LIB=src bin/simple native-build \
  --source src/lib \
  --source test/05_perf/web \
  --entry "$SRC" \
  --entry-closure \
  --strip \
  --output "$BIN"

python3 - "$BIN" <<'PY'
import os, signal, socket, subprocess, sys, time

bin_path = sys.argv[1]
addr = ("127.0.0.1", 18195)

def wait_for_line(proc, marker, timeout=8):
    deadline = time.time() + timeout
    lines = []
    while time.time() < deadline:
        line = proc.stdout.readline()
        if line:
            lines.append(line.rstrip())
            if marker in line:
                return
        elif proc.poll() is not None:
            break
        else:
            time.sleep(0.02)
    raise RuntimeError(f"missing marker {marker}; lines={lines}; err={proc.stderr.read()!r}")

def stop_process(proc):
    if proc.poll() is None:
        try:
            proc.terminate()
            proc.wait(timeout=2)
        except Exception:
            try:
                os.kill(proc.pid, signal.SIGKILL)
            except Exception:
                pass

def request():
    deadline = time.time() + 8
    last = None
    while time.time() < deadline:
        try:
            with socket.create_connection(addr, timeout=1) as client:
                client.settimeout(2)
                client.sendall(b"GET /hello.txt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n")
                data = b""
                while True:
                    try:
                        chunk = client.recv(4096)
                    except (socket.timeout, ConnectionResetError):
                        break
                    if not chunk:
                        break
                    data += chunk
                return data.decode("latin1", "replace")
        except OSError as exc:
            last = exc
            time.sleep(0.05)
    raise RuntimeError(f"static request failed: {last}")

proc = subprocess.Popen([bin_path], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, bufsize=1)
try:
    wait_for_line(proc, "[SimpleServer] Listening")
    resp = request()
    if "HTTP/1.1 200 OK" not in resp or "static-ok" not in resp:
        raise RuntimeError(f"bad static response: {resp!r}")
    print("STATUS: PASS HttpServer live static")
except Exception as exc:
    stop_process(proc)
    print(f"STATUS: FAIL HttpServer live static: {exc}")
    print(f"stdout_tail={proc.stdout.read()!r}")
    print(f"stderr_tail={proc.stderr.read()!r}")
    raise
finally:
    stop_process(proc)
PY
