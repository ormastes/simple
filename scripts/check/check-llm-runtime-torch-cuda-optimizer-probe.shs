    printf '%s\n' "- log_sha256: \`$log_sha256\`"
    printf '%s\n' "- status_line_count: \`$status_line_count\`"
    printf '%s\n' "- required_gates_line_count: \`$required_gates_line_count\`"
    printf '%s\n' "- torch_available_line_count: \`$torch_available_line_count\`"
    printf '%s\n' "- cuda_available_line_count: \`$cuda_available_line_count\`"
    printf '%s\n' "- parameter_is_cuda_line_count: \`$parameter_is_cuda_line_count\`"
    printf '%s\n' "- grad_handle_line_count: \`$grad_handle_line_count\`"
    printf '%s\n' "- optimizer_step_line_count: \`$optimizer_step_line_count\`"
    printf '%s\n' "- before_sum_line_count: \`$before_sum_line_count\`"
    printf '%s\n' "- after_sum_line_count: \`$after_sum_line_count\`"
    printf '%s\n' "- python_torch_module_status: \`$python_torch_module_status\`"
    printf '%s\n' "- python_torch_version: \`$python_torch_version\`"
    printf '%s\n' "- python_torch_file: \`$python_torch_file\`"
    printf '%s\n' "- python_torch_package_dir: \`$python_torch_package_dir\`"
    printf '%s\n' "- python_torch_library_dir: \`$python_torch_library_dir\`"
    printf '%s\n' "- python_torch_cmake_prefix_path: \`$python_torch_cmake_prefix_path\`"
    printf '%s\n' "- python_torch_library_paths: \`$python_torch_library_paths\`"
    printf '%s\n' "- python_torch_library_count: \`${python_torch_library_count:-0}\`"
    printf '%s\n' "- python_torch_libtorch_bundle_status: \`${python_torch_libtorch_bundle_status:-missing}\`"
    printf '%s\n' "- python_torch_libtorch_status: \`${python_torch_libtorch_status:-missing}\`"
    printf '%s\n' "- python_torch_libtorch_cuda_status: \`${python_torch_libtorch_cuda_status:-missing}\`"
    printf '%s\n' "- python_torch_libc10_status: \`${python_torch_libc10_status:-missing}\`"
    printf '%s\n' "- python_torch_libc10_cuda_status: \`${python_torch_libc10_cuda_status:-missing}\`"
    printf '%s\n' "- python_torch_cuda_library_bundle_status: \`${python_torch_cuda_library_bundle_status:-missing}\`"
    printf '%s\n' "- python_torch_cuda_available: \`$python_torch_cuda_available\`"
    printf '%s\n' "- python_torch_cuda_device_count: \`$python_torch_cuda_device_count\`"
    printf '%s\n' "- python_torch_env: \`$PYTHON_TORCH_ENV\`"
    printf '%s\n' "- python_torch_env_size: \`$python_torch_env_size\`"
    printf '%s\n' "- python_torch_env_sha256: \`$python_torch_env_sha256\`"
    printf '%s\n' "- system_libtorch_status: \`$system_libtorch_status\`"
    printf '%s\n' "- system_libtorch_probe_log: \`$LIBTORCH_PROBE_LOG\`"
    printf '%s\n' "- system_libtorch_probe_log_size: \`$system_libtorch_probe_log_size\`"
    printf '%s\n' "- system_libtorch_probe_log_sha256: \`$system_libtorch_probe_log_sha256\`"
    printf '%s\n' "- libtorch_env_status: \`$libtorch_env_status\`"
    printf '%s\n' "- auto_libtorch_env_source: \`$auto_libtorch_env_source\`"
    printf '%s\n' "- auto_ld_library_path_source: \`$auto_ld_library_path_source\`"
