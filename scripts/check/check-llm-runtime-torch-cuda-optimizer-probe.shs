    printf '%s\n' "- auto_simple_runtime_path_source: \`$auto_simple_runtime_path_source\`"
    printf '%s\n' "- scilib_torch_root_status: \`$scilib_torch_root_status\`"
    printf '%s\n' "- simple_sffi_path_status: \`$simple_sffi_path_status\`"
    printf '%s\n' "- simple_sffi_libtorch_bridge_status: \`$simple_sffi_libtorch_bridge_status\`"
    printf '%s\n' "- ld_library_path_libtorch_status: \`$ld_library_path_libtorch_status\`"
    printf '%s\n' "- simple_runtime_torch_link_status: \`$simple_runtime_torch_link_status\`"
    printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
    printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
    printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
    printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
    printf '%s\n' "- torch_available: \`$torch_available\`"
    printf '%s\n' "- cuda_available: \`$cuda_available\`"
    printf '%s\n' "- parameter_is_cuda: \`$parameter_is_cuda\`"
    printf '%s\n' "- dyn_tensor_status: \`$dyn_tensor_status\`"
    printf '%s\n' "- dyn_tensor_reason: \`$dyn_tensor_reason\`"
    printf '%s\n' "- dyn_tensor_handle: \`$dyn_tensor_handle\`"
    printf '%s\n' "- grad_handle: \`$grad_handle\`"
    printf '%s\n' "- optimizer_step_attempted: \`$optimizer_step_attempted\`"
    printf '%s\n' "- before_sum: \`$before_sum\`"
    printf '%s\n' "- after_sum: \`$after_sum\`"
    printf '%s\n' "- sum_decreased_status: \`$sum_decreased_status\`"
    printf '%s\n' "- pass_integrity_status: \`$pass_integrity_status\`"
    printf '%s\n' "- pass_integrity_reason: \`$pass_integrity_reason\`"
    printf '%s\n' "- next_action: \`$next_action\`"
    printf '%s\n' "- exit_code: \`$exit_code\`"
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '%s\n' "- log: \`$OUT_LOG\`"
    printf '\n'
    printf 'This wrapper proves the Simple/libtorch CUDA optimizer lane only when all required gates pass. A `status=pass` probe log must be non-empty, hashed, exit with code 0, and include exactly one complete proof record for status, required gates, libtorch/CUDA availability, CUDA parameter placement, gradient handle, optimizer step, and before/after sums. The normalized fields must show libtorch and CUDA availability, CUDA parameter placement, a nonzero gradient handle, an attempted optimizer step, and numeric `after_sum < before_sum`. `unavailable` records the exact missing host/runtime gate, plus hashed Python Torch discovery, system libtorch probe, and wrapper/source/spec/doc surface logs, and remains a strict-host failure.\n'
} >"$REPORT_PATH"

case "$status" in
    pass)
        echo "STATUS: PASS llm-runtime-torch-cuda-optimizer-probe"
        ;;
    unavailable)
        echo "STATUS: WARN llm-runtime-torch-cuda-optimizer-probe reason=$reason"
        if [ "$STRICT" -eq 1 ]; then
            exit 1
        fi
        ;;
    *)
        echo "STATUS: FAIL llm-runtime-torch-cuda-optimizer-probe reason=$reason"
        exit 1
        ;;
esac
