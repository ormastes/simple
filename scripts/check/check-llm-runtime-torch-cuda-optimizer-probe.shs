    printf '%s\n' "torch_cuda_optimizer_probe_after_sum_line_count=$after_sum_line_count"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_module_status=$python_torch_module_status"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_version=$python_torch_version"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_file=$python_torch_file"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_package_dir=$python_torch_package_dir"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_library_dir=$python_torch_library_dir"
