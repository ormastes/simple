    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_env_sha256=$python_torch_env_sha256"
    printf '%s\n' "torch_cuda_optimizer_probe_system_libtorch_status=$system_libtorch_status"
    printf '%s\n' "torch_cuda_optimizer_probe_system_libtorch_probe_log=$LIBTORCH_PROBE_LOG"
    printf '%s\n' "torch_cuda_optimizer_probe_system_libtorch_probe_log_size=$system_libtorch_probe_log_size"
    printf '%s\n' "torch_cuda_optimizer_probe_system_libtorch_probe_log_sha256=$system_libtorch_probe_log_sha256"
    printf '%s\n' "torch_cuda_optimizer_probe_libtorch_env_status=$libtorch_env_status"
    printf '%s\n' "torch_cuda_optimizer_probe_auto_libtorch_env_source=$auto_libtorch_env_source"
    printf '%s\n' "torch_cuda_optimizer_probe_auto_ld_library_path_source=$auto_ld_library_path_source"
    printf '%s\n' "torch_cuda_optimizer_probe_auto_simple_sffi_path_source=$auto_simple_sffi_path_source"
    printf '%s\n' "torch_cuda_optimizer_probe_auto_simple_runtime_path_source=$auto_simple_runtime_path_source"
    printf '%s\n' "torch_cuda_optimizer_probe_scilib_torch_root_status=$scilib_torch_root_status"
    printf '%s\n' "torch_cuda_optimizer_probe_simple_sffi_path_status=$simple_sffi_path_status"
    printf '%s\n' "torch_cuda_optimizer_probe_simple_sffi_libtorch_bridge_status=$simple_sffi_libtorch_bridge_status"
    printf '%s\n' "torch_cuda_optimizer_probe_ld_library_path_libtorch_status=$ld_library_path_libtorch_status"
    printf '%s\n' "torch_cuda_optimizer_probe_simple_runtime_torch_link_status=$simple_runtime_torch_link_status"
    printf '%s\n' "torch_cuda_optimizer_probe_surface_manifest=$SURFACE_MANIFEST"
    printf '%s\n' "torch_cuda_optimizer_probe_surface_manifest_count=$surface_manifest_count"
    printf '%s\n' "torch_cuda_optimizer_probe_surface_manifest_size=$surface_manifest_size"
    printf '%s\n' "torch_cuda_optimizer_probe_surface_manifest_sha256=$surface_manifest_sha256"
    printf '%s\n' "torch_cuda_optimizer_probe_normalized_status=$status"
    printf '%s\n' "torch_cuda_optimizer_probe_normalized_reason=$reason"
    printf '%s\n' "torch_cuda_optimizer_probe_torch_available_normalized=$torch_available"
    printf '%s\n' "torch_cuda_optimizer_probe_cuda_available_normalized=$cuda_available"
    printf '%s\n' "torch_cuda_optimizer_probe_parameter_is_cuda_normalized=$parameter_is_cuda"
    printf '%s\n' "torch_cuda_optimizer_probe_dyn_tensor_status_normalized=$dyn_tensor_status"
    printf '%s\n' "torch_cuda_optimizer_probe_dyn_tensor_reason_normalized=$dyn_tensor_reason"
    printf '%s\n' "torch_cuda_optimizer_probe_dyn_tensor_handle_normalized=$dyn_tensor_handle"
    printf '%s\n' "torch_cuda_optimizer_probe_grad_handle_normalized=$grad_handle"
    printf '%s\n' "torch_cuda_optimizer_probe_optimizer_step_attempted_normalized=$optimizer_step_attempted"
    printf '%s\n' "torch_cuda_optimizer_probe_before_sum_normalized=$before_sum"
    printf '%s\n' "torch_cuda_optimizer_probe_after_sum_normalized=$after_sum"
    printf '%s\n' "torch_cuda_optimizer_probe_sum_decreased_status=$sum_decreased_status"
    printf '%s\n' "torch_cuda_optimizer_probe_pass_integrity_status=$pass_integrity_status"
    printf '%s\n' "torch_cuda_optimizer_probe_pass_integrity_reason=$pass_integrity_reason"
    printf '%s\n' "torch_cuda_optimizer_probe_next_action=$next_action"
} >>"$OUT_ENV"

{
    printf '# LLM Runtime Torch CUDA Optimizer Probe\n\n'
    printf '%s\n' "- command: \`$PROBE_COMMAND\`"
    printf '%s\n' "- wrapper_path: \`$WRAPPER_PATH\`"
    printf '%s\n' "- wrapper_sha256: \`$wrapper_sha256\`"
    printf '%s\n' "- probe_path: \`$PROBE\`"
    printf '%s\n' "- probe_sha256: \`$probe_sha256\`"
    printf '%s\n' "- probe_command_sha256: \`$probe_command_sha256\`"
    printf '%s\n' "- status: \`$status\`"
    printf '%s\n' "- reason: \`$reason\`"
    printf '%s\n' "- required_gates: \`$required_gates\`"
    printf '%s\n' "- blocked_gate: \`$blocked_gate\`"
    printf '%s\n' "- blocked_gates: \`$blocked_gates\`"
    printf '%s\n' "- primary_blocked_gate: \`$primary_blocked_gate\`"
