    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_library_paths=$python_torch_library_paths"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_library_count=${python_torch_library_count:-0}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_libtorch_bundle_status=${python_torch_libtorch_bundle_status:-missing}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_libtorch_status=${python_torch_libtorch_status:-missing}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_libtorch_cuda_status=${python_torch_libtorch_cuda_status:-missing}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_libc10_status=${python_torch_libc10_status:-missing}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_libc10_cuda_status=${python_torch_libc10_cuda_status:-missing}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_cuda_library_bundle_status=${python_torch_cuda_library_bundle_status:-missing}"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_cuda_available=$python_torch_cuda_available"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_cuda_device_count=$python_torch_cuda_device_count"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_error=$python_torch_error"
    printf '%s\n' "torch_cuda_optimizer_probe_python_torch_env=$PYTHON_TORCH_ENV"
