#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-release/x86_64-unknown-linux-gnu/simple}"
BUILD_DIR="${BUILD_DIR:-build/llm_runtime_torch_cuda_optimizer_probe}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_runtime_torch_cuda_optimizer_probe_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
OUT_LOG="$BUILD_DIR/probe.log"
PROBE="src/app/test/torch_cuda_optimizer_probe.spl"
STRICT=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --strict)
            STRICT=1
            ;;
        *)
            echo "unknown argument: $1" >&2
            exit 2
            ;;
    esac
    shift
done

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$OUT_LOG" "$REPORT_PATH"

status="fail"
reason="probe_failed"
exit_code=0
if "$SIMPLE_BIN" run "$PROBE" --mode=interpreter --clean >"$OUT_LOG" 2>&1; then
    :
else
    exit_code=$?
fi

grep '^torch_cuda_optimizer_probe_' "$OUT_LOG" >"$OUT_ENV" 2>/dev/null || true
status="$(sed -n 's/^torch_cuda_optimizer_probe_status=//p' "$OUT_ENV" | tail -n 1)"
reason="$(sed -n 's/^torch_cuda_optimizer_probe_reason=//p' "$OUT_ENV" | tail -n 1)"
required_gates="$(sed -n 's/^torch_cuda_optimizer_probe_required_gates=//p' "$OUT_ENV" | tail -n 1)"
blocked_gate="$(sed -n 's/^torch_cuda_optimizer_probe_blocked_gate=//p' "$OUT_ENV" | tail -n 1)"
torch_available="$(sed -n 's/^torch_cuda_optimizer_probe_torch_available=//p' "$OUT_ENV" | tail -n 1)"
cuda_available="$(sed -n 's/^torch_cuda_optimizer_probe_cuda_available=//p' "$OUT_ENV" | tail -n 1)"
parameter_is_cuda="$(sed -n 's/^torch_cuda_optimizer_probe_parameter_is_cuda=//p' "$OUT_ENV" | tail -n 1)"
grad_handle="$(sed -n 's/^torch_cuda_optimizer_probe_grad_handle=//p' "$OUT_ENV" | tail -n 1)"
optimizer_step_attempted="$(sed -n 's/^torch_cuda_optimizer_probe_optimizer_step_attempted=//p' "$OUT_ENV" | tail -n 1)"
before_sum="$(sed -n 's/^torch_cuda_optimizer_probe_before_sum=//p' "$OUT_ENV" | tail -n 1)"
after_sum="$(sed -n 's/^torch_cuda_optimizer_probe_after_sum=//p' "$OUT_ENV" | tail -n 1)"

if [ -z "$status" ]; then
    status="fail"
    reason="missing_probe_status"
fi
if [ -z "$reason" ]; then
    reason="not_reported"
fi
if [ -z "$required_gates" ]; then
    required_gates="libtorch,cuda,parameter_cuda,autograd_gradient,optimizer_step_decreases_parameter_sum"
fi
if [ -z "$blocked_gate" ]; then
    case "$status" in
        pass) blocked_gate="none" ;;
        *) blocked_gate="$reason" ;;
    esac
fi
if [ -z "$torch_available" ]; then
    torch_available="missing"
fi
if [ -z "$cuda_available" ]; then
    cuda_available="missing"
fi
if [ -z "$parameter_is_cuda" ]; then
    parameter_is_cuda="missing"
fi
if [ -z "$grad_handle" ]; then
    grad_handle="missing"
fi
if [ -z "$optimizer_step_attempted" ]; then
    optimizer_step_attempted="false"
fi
if [ -z "$before_sum" ]; then
    before_sum="missing"
fi
if [ -z "$after_sum" ]; then
    after_sum="missing"
fi

next_action="verify Simple/libtorch CUDA optimizer execution and parameter-sum decrease"
case "$blocked_gate" in
    libtorch|libtorch_unavailable)
        next_action="build or install the Simple runtime with libtorch symbols available, then rerun the strict Torch optimizer probe"
        ;;
    cuda|cuda_unavailable)
        next_action="make CUDA visible to the Simple/libtorch runtime, then rerun the strict Torch optimizer probe"
        ;;
    parameter_cuda|parameter_not_cuda)
        next_action="fix CUDA parameter placement in the Simple Torch optimizer path, then rerun the strict Torch optimizer probe"
        ;;
    autograd_gradient|gradient_missing)
        next_action="fix autograd gradient production for the probe parameter, then rerun the strict Torch optimizer probe"
        ;;
    optimizer_step_decreases_parameter_sum|optimizer_step_failed)
        next_action="fix optimizer step execution until parameter sum decreases, then rerun the strict Torch optimizer probe"
        ;;
    none)
        next_action="strict Torch optimizer probe is ready"
        ;;
esac

{
    printf '%s\n' "torch_cuda_optimizer_probe_required_gates=$required_gates"
    printf '%s\n' "torch_cuda_optimizer_probe_blocked_gate=$blocked_gate"
    printf '%s\n' "torch_cuda_optimizer_probe_wrapper_exit=$exit_code"
    printf '%s\n' "torch_cuda_optimizer_probe_normalized_status=$status"
    printf '%s\n' "torch_cuda_optimizer_probe_normalized_reason=$reason"
    printf '%s\n' "torch_cuda_optimizer_probe_torch_available_normalized=$torch_available"
    printf '%s\n' "torch_cuda_optimizer_probe_cuda_available_normalized=$cuda_available"
    printf '%s\n' "torch_cuda_optimizer_probe_parameter_is_cuda_normalized=$parameter_is_cuda"
    printf '%s\n' "torch_cuda_optimizer_probe_grad_handle_normalized=$grad_handle"
    printf '%s\n' "torch_cuda_optimizer_probe_optimizer_step_attempted_normalized=$optimizer_step_attempted"
    printf '%s\n' "torch_cuda_optimizer_probe_before_sum_normalized=$before_sum"
    printf '%s\n' "torch_cuda_optimizer_probe_after_sum_normalized=$after_sum"
    printf '%s\n' "torch_cuda_optimizer_probe_next_action=$next_action"
} >>"$OUT_ENV"

{
    printf '# LLM Runtime Torch CUDA Optimizer Probe\n\n'
    printf '%s\n' "- command: \`$SIMPLE_BIN run $PROBE --mode=interpreter --clean\`"
    printf '%s\n' "- status: \`$status\`"
    printf '%s\n' "- reason: \`$reason\`"
    printf '%s\n' "- required_gates: \`$required_gates\`"
    printf '%s\n' "- blocked_gate: \`$blocked_gate\`"
    printf '%s\n' "- torch_available: \`$torch_available\`"
    printf '%s\n' "- cuda_available: \`$cuda_available\`"
    printf '%s\n' "- parameter_is_cuda: \`$parameter_is_cuda\`"
    printf '%s\n' "- grad_handle: \`$grad_handle\`"
    printf '%s\n' "- optimizer_step_attempted: \`$optimizer_step_attempted\`"
    printf '%s\n' "- before_sum: \`$before_sum\`"
    printf '%s\n' "- after_sum: \`$after_sum\`"
    printf '%s\n' "- next_action: \`$next_action\`"
    printf '%s\n' "- exit_code: \`$exit_code\`"
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '%s\n' "- log: \`$OUT_LOG\`"
    printf '\n'
    printf 'This wrapper proves the Simple/libtorch CUDA optimizer lane only when all required gates pass. `unavailable` records the exact missing host/runtime gate and remains a strict-host failure.\n'
} >"$REPORT_PATH"

case "$status" in
    pass)
        echo "STATUS: PASS llm-runtime-torch-cuda-optimizer-probe"
        ;;
    unavailable)
        echo "STATUS: WARN llm-runtime-torch-cuda-optimizer-probe reason=$reason"
        if [ "$STRICT" -eq 1 ]; then
            exit 1
        fi
        ;;
    *)
        echo "STATUS: FAIL llm-runtime-torch-cuda-optimizer-probe reason=$reason"
        exit 1
        ;;
esac
