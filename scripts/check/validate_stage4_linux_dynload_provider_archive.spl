use std.nogc_sync_mut.io_runtime.{env_get}
use compiler.backend.backend.llvm_native_link.{llvm_stage4_candidate_archive_inventory}
use compiler.backend.backend.stage4_symbol_closure.{stage4_validate_dynload_provider_symbol_contract}

fn fail_validation(message: text) -> i64:
    print "stage4_dynload_provider_error=" + message
    return 1

fn main() -> i64:
    val paths = [
        env_get("SIMPLE_STAGE4_DYNLOAD_ARCHIVE_A"),
        env_get("SIMPLE_STAGE4_DYNLOAD_ARCHIVE_B")
    ]
    match llvm_stage4_candidate_archive_inventory(["dynload-a", "dynload-b"], paths):
        case Err(err):
            return fail_validation(err)
        case Ok(scans):
            if scans.len() != 2 or scans[0].trim() == "" or scans[1].trim() == "":
                return fail_validation("expected two nonempty archive scans")
            match stage4_validate_dynload_provider_symbol_contract(scans[0], "elf"):
                case Err(err): return fail_validation("archive A: " + err)
                case Ok(()): ()
            match stage4_validate_dynload_provider_symbol_contract(scans[1], "elf"):
                case Err(err): return fail_validation("archive B: " + err)
                case Ok(()): ()
            print "stage4_dynload_provider_archive=true"
            return 0
