# Measure + validate a live-window capture of the Simple WM multi-app taskbar
# demo (scripts/check/check-wm-multiapp-taskbar-evidence.shs drives this).
#
# Input: a BMP screencapture of the SimpleGui window plus the demo's logged
# LOGICAL window geometries. The capture is physical pixels (Retina 2x) and may
# include an OS titlebar band above the content, so this self-calibrates the
# content rectangle from the capture dimensions and derives a logical->physical
# scale, independent of any titlebar/scale offset.
#
# Binding checks (each emitted as a machine-readable line; the shell gate
# classifies pass/fail): every window's titlebar band differs from the desktop
# background, and the bottom taskbar shows >= N colored item segments. Also
# writes per-window crop PPMs for the gate to convert to app_<name>.png.

use std.common.image.ppm_decode.{encode_ppm_p6}
use os.compositor.host_compositor_entry.{host_taskbar_item_x, host_taskbar_item_width, host_taskbar_dock_width}

extern fn rt_env_get(key: text) -> text?
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

struct BmpView:
    data: [u8]
    offset: i64
    width: i64
    height: i64
    bpp: i64
    stride: i64
    top_down: bool

fn byte_at(data: [u8], idx: i64) -> i64:
    if idx < 0 or idx >= data.len():
        return 0
    data[idx] as i64

fn le16(data: [u8], off: i64) -> i64:
    byte_at(data, off) | (byte_at(data, off + 1) << 8)

fn le32u(data: [u8], off: i64) -> i64:
    byte_at(data, off) | (byte_at(data, off + 1) << 8) | (byte_at(data, off + 2) << 16) | (byte_at(data, off + 3) << 24)

fn le32s(data: [u8], off: i64) -> i64:
    val raw = le32u(data, off)
    if raw >= 2147483648:
        return raw - 4294967296
    raw

fn abs_i64(v: i64) -> i64:
    if v < 0: return 0 - v
    v

fn map_axis(base: i64, scale: f64, lv: i64) -> i64:
    base + (lv.to_f64() * scale).to_i64()

# (r,g,b) of image pixel (ix, iy) with iy measured from the TOP; handles the
# bottom-up BMP row order.
fn view_rgb(v: BmpView, ix: i64, iy: i64) -> (i64, i64, i64):
    if ix < 0 or iy < 0 or ix >= v.width or iy >= v.height:
        return (0, 0, 0)
    var file_row = iy
    if not v.top_down:
        file_row = v.height - 1 - iy
    val pos = v.offset + file_row * v.stride + ix * v.bpp
    val b = byte_at(v.data, pos)
    val g = byte_at(v.data, pos + 1)
    val r = byte_at(v.data, pos + 2)
    (r, g, b)

# Older captures used a magenta locator frame. Real WM evidence no longer draws
# synthetic markers, but we keep this recognizer for backward-compatible
# artifacts and fall back to the full captured client width when no locator is
# present.
fn is_locator(r: i64, g: i64, b: i64) -> bool:
    (r > 185 and b > 185 and g < 95)

# Manhattan channel distance from a reference color.
fn color_diff(r: i64, g: i64, b: i64, rr: i64, rg: i64, rb: i64) -> i64:
    abs_i64(r - rr) + abs_i64(g - rg) + abs_i64(b - rb)

fn parse_geoms(raw: text) -> [[i64]]:
    # Format: "id,app_token,x,y,w,h;..." (app_token has no spaces). app name is
    # returned separately via parse_apps; here we keep the numeric fields.
    var out: [[i64]] = []
    if raw == "":
        return out
    val recs = raw.split(";")
    var i = 0
    while i < recs.len():
        val rec = recs[i]
        if rec.len() > 0:
            val f = rec.split(",")
            if f.len() >= 6:
                out.push([f[0].to_i64(), f[2].to_i64(), f[3].to_i64(), f[4].to_i64(), f[5].to_i64()])
        i = i + 1
    out

fn parse_apps(raw: text) -> [text]:
    var out: [text] = []
    if raw == "":
        return out
    val recs = raw.split(";")
    var i = 0
    while i < recs.len():
        val rec = recs[i]
        if rec.len() > 0:
            val f = rec.split(",")
            if f.len() >= 6:
                out.push(f[1])
        i = i + 1
    out

fn main() -> i32:
    val path = rt_env_get("WM_MULTIAPP_BMP") ?? ""
    val out_dir = rt_env_get("WM_MULTIAPP_OUT_DIR") ?? "build/wm_multiapp_taskbar"
    val geoms_raw = rt_env_get("WM_MULTIAPP_GEOMS") ?? ""
    val logical_w = (rt_env_get("WM_MULTIAPP_LOGICAL_W") ?? "1024").to_i64()
    val logical_h = (rt_env_get("WM_MULTIAPP_LOGICAL_H") ?? "768").to_i64()
    val taskbar_count = (rt_env_get("WM_MULTIAPP_TASKBAR_COUNT") ?? "0").to_i64()

    if path == "":
        print "measure_error=no-bmp-path"
        return 1
    val data = rt_file_read_bytes(path) ?? []
    if data.len() < 54 or byte_at(data, 0) != 66 or byte_at(data, 1) != 77:
        print "measure_error=not-a-bmp len={data.len()}"
        return 1
    val offset = le32u(data, 10)
    val width = le32s(data, 18)
    val height_raw = le32s(data, 22)
    val bits = le16(data, 28)
    val compression = le32u(data, 30)
    if width <= 0 or height_raw == 0 or (bits != 24 and bits != 32) or (compression != 0 and compression != 3):
        print "measure_error=unsupported-bmp width={width} bits={bits} comp={compression}"
        return 1
    val height = abs_i64(height_raw)
    val bpp = bits / 8
    val stride = ((width * bits + 31) / 32) * 4
    val top_down = height_raw < 0
    val v = BmpView(data: data, offset: offset, width: width, height: height, bpp: bpp, stride: stride, top_down: top_down)
    print "capture_dims={width}x{height} bpp={bits}"

    # --- locate an optional legacy magenta locator frame. Modern real-WM
    # captures do not draw one; when absent, use the captured client width as the
    # scale source and place the content at the bottom of the captured window so
    # an OS titlebar band above the client area is tolerated. ---
    val scan_stride = 6
    var left = width
    var right = -1
    var top = height
    var bot = -1
    var found = 0
    var yy = 0
    while yy < height:
        var xx = 0
        while xx < width:
            val (r, g, b) = view_rgb(v, xx, yy)
            if is_locator(r, g, b):
                found = found + 1
                if xx < left: left = xx
                if xx > right: right = xx
                if yy < top: top = yy
                if yy > bot: bot = yy
            xx = xx + scan_stride
        yy = yy + scan_stride
    if found < 100 or right <= left or bot <= top:
        left = 0
        right = width - 1
        val inferred_scale = width.to_f64() / logical_w.to_f64()
        val inferred_h = (logical_h.to_f64() * inferred_scale).to_i64()
        top = if height > inferred_h: height - inferred_h else: 0
        bot = height - 1
    val content_w = right - left + 1
    val content_h = bot - top + 1
    val scale_x = content_w.to_f64() / logical_w.to_f64()
    val scale_y = content_h.to_f64() / logical_h.to_f64()
    print "calib content_origin={left},{top} content_size={content_w}x{content_h} scale_x={scale_x} scale_y={scale_y} locator_px={found}"

    # Reference desktop bg color, sampled above all windows (top-center desktop,
    # just inside the locator frame).
    val (bgr, bgg, bgb) = view_rgb(v, left + content_w / 2, map_axis(top, scale_y, 10))
    print "bg_ref={bgr},{bgg},{bgb}"

    # --- per-window titlebar-band check + crop ---
    val geoms = parse_geoms(geoms_raw)
    val apps = parse_apps(geoms_raw)
    var wi = 0
    var windows_ok = 0
    var title_text_ok_count = 0
    var buttons_ok_count = 0
    while wi < geoms.len():
        val g = geoms[wi]
        val id = g[0]
        val gx = g[1]
        val gy = g[2]
        val gw = g[3]
        val gh = g[4]
        val app = if wi < apps.len(): apps[wi] else: "app{id}"
        val px0 = map_axis(left, scale_x, gx)
        val py0 = map_axis(top, scale_y, gy)
        val px1 = map_axis(left, scale_x, gx + gw)
        val py1 = map_axis(top, scale_y, gy + gh)
        # Titlebar band = top 24 logical px of the window.
        val band_bot = map_axis(top, scale_y, gy + 24)
        # Sample the titlebar band on a stride (representative fraction — the band
        # is a solid accent fill, so a subsample gives the same non-bg ratio at a
        # fraction of the interpreter cost).
        var band_total = 0
        var band_nonbg = 0
        var by = py0
        while by < band_bot:
            var bx = px0
            while bx < px1:
                val (r, gg, b) = view_rgb(v, bx, by)
                band_total = band_total + 1
                if color_diff(r, gg, b, bgr, bgg, bgb) > 40:
                    band_nonbg = band_nonbg + 1
                bx = bx + 2
            by = by + 2
        val frac_num = if band_total > 0: band_nonbg * 100 / band_total else: 0
        val ok = band_total > 0 and frac_num >= 25
        if ok: windows_ok = windows_ok + 1
        val (tr, tg, tb) = view_rgb(v, px0 + 3, py0 + 3)
        val text_left = map_axis(left, scale_x, gx + 66)
        val text_top = map_axis(top, scale_y, gy + 6)
        val text_right = map_axis(left, scale_x, gx + gw - 30)
        val text_bot = map_axis(top, scale_y, gy + 22)
        var text_total = 0
        var text_ink = 0
        var ty2 = text_top
        while ty2 < text_bot:
            var tx2 = text_left
            while tx2 < text_right:
                val (rr, rg, rb) = view_rgb(v, tx2, ty2)
                text_total = text_total + 1
                if color_diff(rr, rg, rb, tr, tg, tb) > 80:
                    text_ink = text_ink + 1
                tx2 = tx2 + 1
            ty2 = ty2 + 1
        val text_ok = text_total > 0 and text_ink > 10
        if text_ok: title_text_ok_count = title_text_ok_count + 1
        val btn_left = map_axis(left, scale_x, gx + gw - 24)
        val btn_top = map_axis(top, scale_y, gy + 2)
        val btn_right = map_axis(left, scale_x, gx + gw - 4)
        val btn_bot = map_axis(top, scale_y, gy + 22)
        var btn_total = 0
        var btn_distinct = 0
        var by2 = btn_top
        while by2 < btn_bot:
            var bx2 = btn_left
            while bx2 < btn_right:
                val (br, bg2, bb) = view_rgb(v, bx2, by2)
                btn_total = btn_total + 1
                if color_diff(br, bg2, bb, tr, tg, tb) > 60:
                    btn_distinct = btn_distinct + 1
                bx2 = bx2 + 1
            by2 = by2 + 1
        val button_ok = btn_total > 0 and btn_distinct * 100 / btn_total >= 50
        if button_ok: buttons_ok_count = buttons_ok_count + 1
        print "window app={app} id={id} phys={px0},{py0},{px1},{py1} titlebar_band_total={band_total} titlebar_nonbg={band_nonbg} nonbg_pct={frac_num} titlebar_ok={ok} title_text_ink={text_ink} title_text_ok={text_ok} close_button_distinct={btn_distinct} close_button_ok={button_ok}"
        # Crop the window rect to a PPM the gate converts to app_<name>.png.
        # Downsampled (cstride) so the extraction stays affordable under the
        # interpreter; the crop is evidence of the window, not a pixel reference.
        val cstride = 3
        val cw = px1 - px0
        val ch = py1 - py0
        val ow = cw / cstride
        val oh = ch / cstride
        if ow > 0 and oh > 0:
            var crop: [u32] = []
            var ry = 0
            while ry < oh:
                var rx = 0
                while rx < ow:
                    val (r, gg, b) = view_rgb(v, px0 + rx * cstride, py0 + ry * cstride)
                    crop.push(((r << 16) | (gg << 8) | b).to_u32())
                    rx = rx + 1
                ry = ry + 1
            val ppm = encode_ppm_p6(ow.to_u32(), oh.to_u32(), crop)
            val cpath = "{out_dir}/app_{app}.ppm"
            val wrote = rt_file_write_bytes(cpath, ppm)
            print "window_crop app={app} path={cpath} size={ow}x{oh} src={cw}x{ch} wrote={wrote}"
        wi = wi + 1

    # --- taskbar: count lit colored item segments ---
    val n = taskbar_count.to_i32()
    val dock_y_logical = logical_h - 62 + 22
    val ty = map_axis(top, scale_y, dock_y_logical)
    val item_w = host_taskbar_item_width(logical_w.to_i32(), n)
    var lit = 0
    var ii = 0
    while ii < n:
        val item_cx_logical = host_taskbar_item_x(logical_w.to_i32(), n, ii) + item_w / 2
        val tx = map_axis(left, scale_x, item_cx_logical.to_i64())
        # Average a small box around the item center.
        var sr = 0
        var sg = 0
        var sb = 0
        var cnt = 0
        var oy = -4
        while oy <= 4:
            var ox = -4
            while ox <= 4:
                val (r, gg, b) = view_rgb(v, tx + ox, ty + oy)
                sr = sr + r
                sg = sg + gg
                sb = sb + b
                cnt = cnt + 1
                ox = ox + 1
            oy = oy + 1
        val ar = sr / cnt
        val ag = sg / cnt
        val ab = sb / cnt
        val diff_bg = color_diff(ar, ag, ab, bgr, bgg, bgb)
        val colored = diff_bg > 40
        if colored: lit = lit + 1
        print "taskbar_item index={ii} phys={tx},{ty} avg={ar},{ag},{ab} diff_bg={diff_bg} colored={colored}"
        ii = ii + 1
    print "taskbar_lit_segments={lit} expected={n}"
    print "windows_ok={windows_ok} windows_total={geoms.len()}"
    print "title_text_ok={title_text_ok_count} expected={geoms.len()}"
    print "close_buttons_ok={buttons_ok_count} expected={geoms.len()}"
    0
