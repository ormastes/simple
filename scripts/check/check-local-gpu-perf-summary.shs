#!/bin/sh
set -eu

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/bin/simple}"

run_self_test() {
    runner="$1"
    out="$("$SIMPLE_BIN" run "$ROOT/$runner" --self-test)"
    printf '%s\n' "$out"
    printf '%s\n' "$out" | grep -q '^gpu_perf_summary_self_test=pass$'
}

run_self_test test/05_perf/local_gpu_check/run_gpu_check.spl
run_self_test test/perf/local_gpu_check/run_gpu_check.spl

echo "local_gpu_perf_summary_status=pass"
