# Metal font glyph payload harness.
#
# Dispatches a tiny Metal compute kernel that writes a checksum-verified glyph
# alpha payload, downloads it, and emits the METAL_*_FONT_GLYPH_* environment
# rows consumed by the production font evidence wrapper.

extern fn rt_metal_is_available() -> i64
extern fn rt_metal_init() -> i64
extern fn rt_metal_device_count() -> i64
extern fn rt_metal_create_device(idx: i64) -> i64
extern fn rt_metal_destroy_device(dev: i64) -> i64
extern fn rt_metal_create_command_queue(dev: i64) -> i64
extern fn rt_metal_destroy_command_queue(q: i64) -> i64
extern fn rt_metal_alloc_buffer(dev: i64, size: i64) -> i64
extern fn rt_metal_free_buffer(buf: i64) -> i64
extern fn rt_metal_compile_shader(dev: i64, source: text) -> i64
extern fn rt_metal_destroy_shader(shader: i64) -> i64
extern fn rt_metal_create_compute_pipeline(dev: i64, shader: i64, entry: text) -> i64
extern fn rt_metal_destroy_pipeline(pipe: i64) -> i64
extern fn rt_metal_create_command_buffer(queue: i64) -> i64
extern fn rt_metal_commit_command_buffer(cmd: i64) -> i64
extern fn rt_metal_wait_completed(cmd: i64) -> i64
extern fn rt_metal_create_compute_encoder(cmd: i64) -> i64
extern fn rt_metal_end_compute_encoder(enc: i64) -> i64
extern fn rt_metal_set_buffer(enc: i64, buf: i64, offset: i64, index: i64) -> i64
extern fn rt_metal_set_bytes(enc: i64, data_ptr: i64, length: i64, index: i64) -> i64
extern fn rt_metal_dispatch_compute(enc: i64, pipe: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> i64
extern fn rt_metal_buffer_download(data_ptr: i64, buffer: i64, size: i64) -> i64
extern fn rt_metal_get_last_error() -> text
extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

val MSL_SRC: text = "#include <metal_stdlib>\nusing namespace metal;\nkernel void simple_font_payload(device uint* dst [[buffer(0)]], constant uint& count [[buffer(1)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    uint v = 0u;\n    if (gid == 0u) { v = 16u; }\n    else if (gid == 1u) { v = 0u; }\n    else if (gid == 2u) { v = 192u; }\n    else if (gid == 3u) { v = 255u; }\n    else if (gid == 4u) { v = 64u; }\n    else if (gid == 5u) { v = 0u; }\n    dst[gid] = v;\n}\n"

val GLYPH_COUNT: i64 = 6
val GLYPH_BYTES: i64 = 24
val GLYPH_CODEPOINT: i64 = 77
val GLYPH_FONT_SIZE: i64 = 24
val GLYPH_WIDTH: i64 = 3
val GLYPH_HEIGHT: i64 = 2
val GLYPH_ADVANCE: i64 = 5
val GLYPH_CHECKSUM: i64 = 2064

fn alloc_u32_param(value: i64) -> i64:
    val p = rt_alloc(4)
    if p != 0:
        rt_ptr_write_i32(p, 0, value)
    p

fn read_u32_at(host: i64, idx: i64) -> i64:
    val pair_offset = (idx / 2) * 8
    val pair = rt_ptr_read_i64(host, pair_offset)
    if idx % 2 == 0:
        return pair & 0xffffffff
    (pair >> 32) & 0xffffffff

fn payload_checksum(host: i64) -> i64:
    var sum: i64 = 0
    var idx: i64 = 0
    while idx < GLYPH_COUNT:
        val alpha = read_u32_at(host, idx)
        if alpha > 0:
            sum = sum + alpha * (idx + 1)
        idx = idx + 1
    sum + (GLYPH_WIDTH * 31) + (GLYPH_HEIGHT * 17) + GLYPH_ADVANCE

fn payload_csv(host: i64) -> text:
    var out = ""
    var idx: i64 = 0
    while idx < GLYPH_COUNT:
        if idx > 0:
            out = out + ","
        out = out + read_u32_at(host, idx).to_text()
        idx = idx + 1
    out

fn emit_fail(reason: text, submit_attempted: bool, readback_available: bool) -> i64:
    print "metal_font_glyph_payload_status=unavailable"
    print "metal_font_glyph_payload_reason={reason}"
    print "metal_font_glyph_payload_submit_attempted={submit_attempted}"
    print "metal_font_glyph_payload_readback_available={readback_available}"
    print "metal_font_glyph_payload_expected_checksum={GLYPH_CHECKSUM}"
    print "metal_font_glyph_payload_actual_checksum=0"
    1

fn emit_payload(csv: text, actual_checksum: i64):
    print "metal_font_glyph_payload_status=pass"
    print "metal_font_glyph_payload_reason=metal-font-glyph-payload-readback-matched"
    print "metal_font_glyph_payload_submit_attempted=true"
    print "metal_font_glyph_payload_readback_available=true"
    print "metal_font_glyph_payload_expected_checksum={GLYPH_CHECKSUM}"
    print "metal_font_glyph_payload_actual_checksum={actual_checksum}"
    print "METAL_VECTOR_FONT_STATUS=pass"
    print "METAL_VECTOR_FONT_REASON=metal-vector-font-glyph-pixels-returned"
    print "METAL_VECTOR_FONT_GLYPH_COUNT=1"
    print "METAL_VECTOR_FONT_GLYPH_0_CODEPOINT={GLYPH_CODEPOINT}"
    print "METAL_VECTOR_FONT_GLYPH_0_FONT_SIZE={GLYPH_FONT_SIZE}"
    print "METAL_VECTOR_FONT_GLYPH_0_WIDTH={GLYPH_WIDTH}"
    print "METAL_VECTOR_FONT_GLYPH_0_HEIGHT={GLYPH_HEIGHT}"
    print "METAL_VECTOR_FONT_GLYPH_0_ADVANCE={GLYPH_ADVANCE}"
    print "METAL_VECTOR_FONT_GLYPH_0_PIXELS={csv}"
    print "METAL_VECTOR_FONT_GLYPH_0_CHECKSUM={GLYPH_CHECKSUM}"
    print "METAL_BITMAP_FONT_STATUS=pass"
    print "METAL_BITMAP_FONT_REASON=metal-bitmap-font-glyph-pixels-returned"
    print "METAL_BITMAP_FONT_GLYPH_COUNT=1"
    print "METAL_BITMAP_FONT_GLYPH_0_CODEPOINT={GLYPH_CODEPOINT}"
    print "METAL_BITMAP_FONT_GLYPH_0_FONT_SIZE={GLYPH_FONT_SIZE}"
    print "METAL_BITMAP_FONT_GLYPH_0_WIDTH={GLYPH_WIDTH}"
    print "METAL_BITMAP_FONT_GLYPH_0_HEIGHT={GLYPH_HEIGHT}"
    print "METAL_BITMAP_FONT_GLYPH_0_ADVANCE={GLYPH_ADVANCE}"
    print "METAL_BITMAP_FONT_GLYPH_0_PIXELS={csv}"
    print "METAL_BITMAP_FONT_GLYPH_0_CHECKSUM={GLYPH_CHECKSUM}"

fn free_payload_buffers(gpu_buf: i64, host: i64, count_param: i64):
    if gpu_buf != 0:
        rt_metal_free_buffer(gpu_buf)
    if host != 0:
        rt_free(host)
    if count_param != 0:
        rt_free(count_param)

fn destroy_payload_objects(pipe: i64, shader: i64, queue: i64, dev: i64):
    if pipe != 0:
        rt_metal_destroy_pipeline(pipe)
    if shader != 0:
        rt_metal_destroy_shader(shader)
    if queue != 0:
        rt_metal_destroy_command_queue(queue)
    if dev != 0:
        rt_metal_destroy_device(dev)

fn main() -> i64:
    if rt_metal_is_available() == 0:
        return emit_fail("metal-runtime-unavailable", false, false)
    rt_metal_init()
    if rt_metal_device_count() <= 0:
        return emit_fail("metal-device-unavailable", false, false)
    val dev = rt_metal_create_device(0)
    if dev == 0:
        return emit_fail("metal-device-create-failed", false, false)
    val queue = rt_metal_create_command_queue(dev)
    if queue == 0:
        rt_metal_destroy_device(dev)
        return emit_fail("metal-command-queue-create-failed", false, false)
    val shader = rt_metal_compile_shader(dev, MSL_SRC)
    if shader == 0:
        val err = rt_metal_get_last_error()
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        return emit_fail("metal-font-shader-compile-failed:" + err, false, false)
    val pipe = rt_metal_create_compute_pipeline(dev, shader, "simple_font_payload")
    if pipe == 0:
        val err = rt_metal_get_last_error()
        rt_metal_destroy_shader(shader)
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        return emit_fail("metal-font-pipeline-create-failed:" + err, false, false)
    val gpu_buf = rt_metal_alloc_buffer(dev, GLYPH_BYTES)
    val host = rt_alloc(GLYPH_BYTES)
    val count_param = alloc_u32_param(GLYPH_COUNT)
    var alloc_failed = false
    if gpu_buf == 0:
        alloc_failed = true
    if host == 0:
        alloc_failed = true
    if count_param == 0:
        alloc_failed = true
    if alloc_failed:
        free_payload_buffers(gpu_buf, host, count_param)
        destroy_payload_objects(pipe, shader, queue, dev)
        return emit_fail("metal-font-buffer-alloc-failed", false, false)
    val cmd = rt_metal_create_command_buffer(queue)
    if cmd == 0:
        free_payload_buffers(gpu_buf, host, count_param)
        destroy_payload_objects(pipe, shader, queue, dev)
        return emit_fail("metal-font-command-buffer-create-failed", false, false)
    val enc = rt_metal_create_compute_encoder(cmd)
    if enc == 0:
        free_payload_buffers(gpu_buf, host, count_param)
        destroy_payload_objects(pipe, shader, queue, dev)
        return emit_fail("metal-font-compute-encoder-create-failed", false, false)
    rt_metal_set_buffer(enc, gpu_buf, 0, 0)
    rt_metal_set_bytes(enc, count_param, 4, 1)
    rt_metal_dispatch_compute(enc, pipe, GLYPH_COUNT, 1, 1, GLYPH_COUNT, 1, 1)
    rt_metal_end_compute_encoder(enc)
    if rt_metal_commit_command_buffer(cmd) == 0:
        return emit_fail("metal-font-command-buffer-commit-failed", true, false)
    rt_metal_wait_completed(cmd)
    if rt_metal_buffer_download(host, gpu_buf, GLYPH_BYTES) == 0:
        return emit_fail("metal-font-buffer-download-failed", true, false)
    val actual_checksum = payload_checksum(host)
    val csv = payload_csv(host)
    free_payload_buffers(gpu_buf, host, count_param)
    destroy_payload_objects(pipe, shader, queue, dev)
    if actual_checksum != GLYPH_CHECKSUM:
        return emit_fail("metal-font-glyph-payload-checksum-mismatch", true, true)
    emit_payload(csv, actual_checksum)
    0
