# Measures the steady-state ("daemon already running") cost of
# wm_daemon_autoconnect() -- the probe every hosted GUI app launch pays via
# init_host_wm (see src/os/compositor/host_compositor_bootstrap.spl). Item 2
# of the WM hardening plan requires this to be sub-millisecond per call.
#
# Simulates the hit path by writing a lock file with this process's own live
# pid (so is_daemon_running() finds a "running" daemon and autoconnect
# returns immediately without spawning), then times N calls.
#
# Usage: bin/simple run scripts/check/measure_wm_daemon_autoconnect_overhead.spl
# Prints: wm_daemon_autoconnect_overhead_avg_us=<float>

use app.play.wm_daemon_client.{wm_daemon_config}
use app.play.wm_daemon_ensure.{wm_daemon_autoconnect}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_mkdir_p(path: text) -> bool
extern fn rt_getpid() -> i64

fn main():
    val config = wm_daemon_config()
    val parent = config.lock_path.substring(0, config.lock_path.last_index_of("/"))
    rt_mkdir_p(parent)
    val pid = rt_getpid()
    rt_file_write_text(config.lock_path, "{pid}\n0")

    val n = 1000
    val t0 = rt_time_now_unix_micros()
    var i = 0
    while i < n:
        wm_daemon_autoconnect()
        i = i + 1
    val t1 = rt_time_now_unix_micros()
    val total_us = t1 - t0
    val avg_us = total_us.to_f64() / n.to_f64()
    print "wm_daemon_autoconnect_calls={n}"
    print "wm_daemon_autoconnect_total_us={total_us}"
    print "wm_daemon_autoconnect_overhead_avg_us={avg_us}"
