write_erlang_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.erl" <<ERL
-module(fib_warm).
-export([main/1]).
fib(N) when N < 2 -> N;
fib(N) -> fib(N-1) + fib(N-2).
run_n(0, _) -> ok;
run_n(N, F) -> F(), run_n(N-1, F).
main(_) ->
    Warmup = ${WARM_IN_PROCESS}, Measured = ${RUNS},
    F = fun() -> fib(35) end,
    run_n(Warmup, F),
    T0 = erlang:monotonic_time(nanosecond),
    run_n(Measured, F),
    T1 = erlang:monotonic_time(nanosecond),
    AvgMs = (T1 - T0) / Measured / 1000000.0,
    io:format("warm_ms: ~.3f~n", [AvgMs]).
ERL
}

write_erlang_parallel() {
    cat >"$BUILD_DIR/parallel.erl" <<ERL
-module(parallel).
-export([main/1]).
lcg(_X, 0) -> _X;
lcg(X, N) -> lcg((X * 1103515245 + 12345) rem 2147483648, N - 1).
worker(Parent, Seed) -> Parent ! {self(), lcg(Seed, 100000)}.
main(_) ->
    Self = self(),
    Pids = [spawn(fun() -> worker(Self, I) end) || I <- lists:seq(0,$((WORKERS - 1)))],
    Total = lists:foldl(fun(Pid, Acc) -> receive {Pid, V} -> Acc + V end end, 0, Pids),
    io:format("total = ~w~n", [Total]).
ERL
}

write_erlang_fanout() {
    cat >"$BUILD_DIR/fanout.erl" <<ERL
-module(fanout).
-export([main/1]).
lcg(X, 0) -> X;
lcg(X, N) -> lcg((X * 1103515245 + 12345) rem 2147483648, N - 1).
worker(Parent, Seed) -> Parent ! {self(), lcg(Seed, ${FANOUT_ITERS})}.
main(_) ->
    Self = self(),
    Pids = [spawn(fun() -> worker(Self, I) end) || I <- lists:seq(0,$((FANOUT_WORKERS - 1)))],
    Total = lists:foldl(fun(Pid, Acc) -> receive {Pid, V} -> Acc + V end end, 0, Pids),
    io:format("total = ~w~n", [Total]).
ERL
}

