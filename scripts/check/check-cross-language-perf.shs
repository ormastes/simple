#!/bin/sh
set -eu

# Cross-language performance profile harness
# Compares Simple (interpreter / SMF loader / native) against
# bun, python, go, erlang, java, and C.
#
# Dimensions: binary/runtime size, cold startup, warm throughput (fib35),
#             parallel CPU workers, and large fanout scheduling.
#
# Warm throughput uses IN-PROCESS loops so JIT runtimes (Java HotSpot,
# Bun/JSC) reach steady state within a single process — not relaunched.
#
# Usage:
#   sh scripts/check/check-cross-language-perf.shs
#   RUNS=50 WORKERS=100 sh scripts/check/check-cross-language-perf.shs
#   RUNS=3 FANOUT_WORKERS=1000 FANOUT_ITERS=32 sh scripts/check/check-cross-language-perf.shs
#   RUNS=3 FANOUT_STRESS_WORKERS=2000 sh scripts/check/check-cross-language-perf.shs
#   PROFILE_DOCKER_ISOLATION=1 sh scripts/check/check-cross-language-perf.shs

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

PROFILE_DOCKER_ISOLATION="${PROFILE_DOCKER_ISOLATION:-0}"
PROFILE_DOCKER_INSIDE="${PROFILE_DOCKER_INSIDE:-0}"
PROFILE_DOCKER_IMAGE="${PROFILE_DOCKER_IMAGE:-simple-cross-language-perf:latest}"
PROFILE_DOCKER_MEMORY="${PROFILE_DOCKER_MEMORY:-2g}"
PROFILE_DOCKER_CPUS="${PROFILE_DOCKER_CPUS:-2.0}"
PROFILE_DOCKER_SIMPLE_BINARY="${PROFILE_DOCKER_SIMPLE_BINARY:-}"

if [ -z "${SIMPLE_BINARY:-}" ]; then
    if [ -x "bin/simple" ]; then
        SIMPLE_BINARY="bin/simple"
    elif [ -x "bin/release/simple" ]; then
        SIMPLE_BINARY="bin/release/simple"
    elif [ -x "bin/release/x86_64-unknown-linux-gnu/simple" ]; then
        SIMPLE_BINARY="bin/release/x86_64-unknown-linux-gnu/simple"
    else
        SIMPLE_BINARY="bin/simple"
    fi
fi
if [ -z "$PROFILE_DOCKER_SIMPLE_BINARY" ]; then
    PROFILE_DOCKER_SIMPLE_BINARY="$SIMPLE_BINARY"
fi
BUILD_DIR="${BUILD_DIR:-build/cross_lang_perf}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/cross_language_perf_$(date +%Y-%m-%d).md}"
PROFILE_REPORT_CONTRACT_TEST="${PROFILE_REPORT_CONTRACT_TEST:-test/05_perf/profile_scripts/profile_report_contract_test.shs}"
RUNS="${RUNS:-20}"
FIB_N="${FIB_N:-35}"
CPU_WORKERS="${CPU_WORKERS:-${WORKERS:-100}}"
OS_THREAD_WORKERS="${OS_THREAD_WORKERS:-$CPU_WORKERS}"
MULTICORE_GREEN_WORKERS="${MULTICORE_GREEN_WORKERS:-$CPU_WORKERS}"
WORKERS="$OS_THREAD_WORKERS"
FANOUT_WORKERS="${FANOUT_WORKERS:-1000}"
FANOUT_OS_THREAD_WORKERS="${FANOUT_OS_THREAD_WORKERS:-$FANOUT_WORKERS}"
FANOUT_MULTICORE_GREEN_WORKERS="${FANOUT_MULTICORE_GREEN_WORKERS:-$FANOUT_WORKERS}"
FANOUT_ITERS="${FANOUT_ITERS:-32}"
FANOUT_STRESS_WORKERS="${FANOUT_STRESS_WORKERS:-512}"
FANOUT_STRESS_ITERS="${FANOUT_STRESS_ITERS:-1}"
if [ -z "${COOPERATIVE_GREEN_WORKERS:-}" ]; then
    if [ -n "${GREEN_WORKERS:-}" ]; then
        COOPERATIVE_GREEN_WORKERS="$GREEN_WORKERS"
    elif [ "$CPU_WORKERS" -gt 10 ]; then
        COOPERATIVE_GREEN_WORKERS=10
    else
        COOPERATIVE_GREEN_WORKERS="$CPU_WORKERS"
    fi
fi
GREEN_WORKERS="$COOPERATIVE_GREEN_WORKERS"
if [ -z "${FANOUT_COOPERATIVE_GREEN_WORKERS:-}" ]; then
    if [ "$FANOUT_WORKERS" -gt 200 ]; then
        FANOUT_COOPERATIVE_GREEN_WORKERS=200
    else
        FANOUT_COOPERATIVE_GREEN_WORKERS="$FANOUT_WORKERS"
    fi
fi
WARM_ITERS="${WARM_ITERS:-5}"
WARM_IN_PROCESS="${WARM_IN_PROCESS:-10}"
RUN_TIMEOUT="${RUN_TIMEOUT:-30}"

if [ "$PROFILE_DOCKER_ISOLATION" = "1" ] && [ "$PROFILE_DOCKER_INSIDE" != "1" ]; then
    if ! command -v docker >/dev/null 2>&1; then
        echo "docker_isolation=false"
        echo "error=docker command not found"
        exit 1
    fi
    if ! docker image inspect "$PROFILE_DOCKER_IMAGE" >/dev/null 2>&1; then
        echo "docker_isolation=false"
        echo "error=missing docker image: $PROFILE_DOCKER_IMAGE"
        echo "hint=docker build -t $PROFILE_DOCKER_IMAGE -f tools/docker/Dockerfile.cross-language-perf tools/docker"
        exit 1
    fi
    exec docker run --rm \
        --entrypoint /bin/sh \
        --user "$(id -u):$(id -g)" \
        -v "$ROOT_DIR:/workspace:rw" \
        -w /workspace \
        --network=none \
        --memory="$PROFILE_DOCKER_MEMORY" \
        --cpus="$PROFILE_DOCKER_CPUS" \
        -e PROFILE_DOCKER_ISOLATION=0 \
        -e PROFILE_DOCKER_INSIDE=1 \
        -e PROFILE_DOCKER_IMAGE="$PROFILE_DOCKER_IMAGE" \
        -e SKIP_PROFILE_REPORT_CONTRACT="${SKIP_PROFILE_REPORT_CONTRACT:-0}" \
        -e SIMPLE_BINARY="$PROFILE_DOCKER_SIMPLE_BINARY" \
        -e BUILD_DIR="$BUILD_DIR" \
        -e REPORT_PATH="$REPORT_PATH" \
        -e PROFILE_REPORT_CONTRACT_TEST="$PROFILE_REPORT_CONTRACT_TEST" \
        -e RUNS="$RUNS" \
        -e FIB_N="$FIB_N" \
        -e CPU_WORKERS="$CPU_WORKERS" \
        -e OS_THREAD_WORKERS="$OS_THREAD_WORKERS" \
        -e MULTICORE_GREEN_WORKERS="$MULTICORE_GREEN_WORKERS" \
        -e COOPERATIVE_GREEN_WORKERS="$COOPERATIVE_GREEN_WORKERS" \
        -e GREEN_WORKERS="$GREEN_WORKERS" \
        -e FANOUT_WORKERS="$FANOUT_WORKERS" \
        -e FANOUT_OS_THREAD_WORKERS="$FANOUT_OS_THREAD_WORKERS" \
        -e FANOUT_MULTICORE_GREEN_WORKERS="$FANOUT_MULTICORE_GREEN_WORKERS" \
        -e FANOUT_COOPERATIVE_GREEN_WORKERS="$FANOUT_COOPERATIVE_GREEN_WORKERS" \
        -e FANOUT_ITERS="$FANOUT_ITERS" \
        -e FANOUT_STRESS_WORKERS="$FANOUT_STRESS_WORKERS" \
        -e FANOUT_STRESS_ITERS="$FANOUT_STRESS_ITERS" \
        -e WARM_ITERS="$WARM_ITERS" \
        -e WARM_IN_PROCESS="$WARM_IN_PROCESS" \
        -e RUN_TIMEOUT="$RUN_TIMEOUT" \
        "$PROFILE_DOCKER_IMAGE" \
        -lc 'sh scripts/check/check-cross-language-perf.shs'
fi

mkdir -p "$BUILD_DIR" "$(dirname "$REPORT_PATH")"

# ── PATH fixup for common non-PATH locations ─────────────────────────────
for _d in /usr/lib/erlang/bin /usr/lib/go/bin /usr/local/go/bin /snap/go/current/bin; do
    [ -d "$_d" ] && case ":$PATH:" in *":$_d:"*) ;; *) PATH="$_d:$PATH" ;; esac
done
export PATH

# ── helpers ──────────────────────────────────────────────────────────────

have() { command -v "$1" >/dev/null 2>&1; }

run_bounded() {
    _cmd="$1"
    if have timeout; then
        timeout "$RUN_TIMEOUT" sh -c "$_cmd"
    else
        sh -c "$_cmd"
    fi
}

bytes_of() {
    if [ -f "$1" ]; then wc -c <"$1" | tr -d ' '; else echo "n/a"; fi
}

simple_runtime_path() {
    _path="$(readlink -f "$SIMPLE_BINARY")"
    _dir="$(dirname "$_path")"
    _wrapped="$_dir/x86_64-unknown-linux-gnu/simple"
    if [ "$(basename "$_path")" = "simple" ] && [ -x "$_wrapped" ]; then
        echo "$_wrapped"
    else
        echo "$_path"
    fi
}

human_bytes() {
    awk "BEGIN { b=$1; u=\"B\";
      if(b>=1073741824){b/=1073741824;u=\"GB\"}
      else if(b>=1048576){b/=1048576;u=\"MB\"}
      else if(b>=1024){b/=1024;u=\"KB\"};
      printf \"%.1f %s\", b, u }"
}

avg_ms() {
    _cmd="$1"; _runs="$2"
    i=0; total=0; ok=0
    while [ "$i" -lt "$_runs" ]; do
        start="$(date +%s%N)"
        if run_bounded "$_cmd" >/dev/null 2>&1; then
            end="$(date +%s%N)"
            total=$((total + (end - start)))
            ok=$((ok + 1))
        fi
        i=$((i + 1))
    done
    if [ "$ok" -eq 0 ]; then echo "fail"
    else awk "BEGIN {printf \"%.3f\", ($total / $ok) / 1000000}"; fi
}

failure_reason() {
    _cmd="$1"
    _out=$(run_bounded "$_cmd" 2>&1) && { echo "ok"; return; }
    _status=$?
    if [ "$_status" -eq 124 ]; then
        echo "timeout"
    elif [ "$_status" -eq 139 ]; then
        echo "segfault"
    elif echo "$_out" | grep -q 'checksum_mismatch'; then
        echo "checksum mismatch"
    elif echo "$_out" | grep -q 'double free'; then
        echo "runtime-pool handle ownership blocker"
    elif echo "$_out" | grep -q 'function not found'; then
        echo "function lookup failed"
    elif echo "$_out" | grep -q 'Undefined symbol: rt_len'; then
        echo "missing rt_len"
    elif echo "$_out" | grep -q 'rt_pool_'; then
        echo "missing runtime pool symbol"
    else
        echo "failed"
    fi
}

pool_evidence() {
    _cmd="$1"
    _expected="$2"
    _out=$(run_bounded "$_cmd" 2>&1) || { echo "pool_used=fail/$_expected"; return; }
    _used=$(printf '%s\n' "$_out" | sed -n 's/.*multicore_green_pool_used = \([0-9][0-9]*\)\/[0-9][0-9]*.*/\1/p' | tail -1)
    _parallelism=$(printf '%s\n' "$_out" | sed -n 's/.*multicore_green_parallelism = \([0-9][0-9]*\/[0-9][0-9]*\).*/\1/p' | tail -1)
    _queue_models=$(printf '%s\n' "$_out" | sed -n 's/.*multicore_green_queue_model = \([A-Za-z_][A-Za-z0-9_]*\).*/\1/p')
    _queue_count=$(printf '%s\n' "$_queue_models" | sed '/^$/d' | wc -l | tr -d ' ')
    if [ -z "$_used" ]; then
        echo "pool_used=missing/$_expected"
    elif printf '%s\n' "$_queue_models" | grep -Eq '^(global_fifo|scheduler_owned)$'; then
        echo "pool_used=$_used/$_expected, queue_model=invalid"
    elif [ "$_queue_count" -ne 1 ]; then
        echo "pool_used=$_used/$_expected, queue_model=ambiguous"
    elif [ "$_queue_models" != "work_stealing" ]; then
        echo "pool_used=$_used/$_expected, queue_model=$_queue_models"
    else
        _evidence="pool_used=$_used/$_expected"
        if [ -n "$_parallelism" ]; then
            _evidence="$_evidence, parallelism=$_parallelism"
        fi
        _evidence="$_evidence, queue_model=work_stealing"
        echo "$_evidence"
    fi
}

# Extract in-process timing from program stdout (programs print "warm_ms: NNN.NNN")
extract_warm_ms() {
    _cmd="$1"
    _output=$(run_bounded "$_cmd" 2>/dev/null) || { echo "fail"; return; }
    echo "$_output" | grep 'warm_ms:' | tail -1 | sed 's/.*warm_ms: *//' | tr -d ' '
}

section() { printf "\n## %s\n\n" "$1" >>"$REPORT_PATH"; }
row() { printf "| %-22s | %12s | %12s | %12s | %12s |\n" "$@" >>"$REPORT_PATH"; }
sep() { printf "|%-24s|%14s|%14s|%14s|%14s|\n" "------------------------" "--------------" "--------------" "--------------" "--------------" >>"$REPORT_PATH"; }

# ── generate workload sources ────────────────────────────────────────────

write_simple_hello() {
    cat >"$BUILD_DIR/hello.spl" <<'SIMPLE'
fn main():
    println("Hello World")
SIMPLE
}

write_simple_fib() {
    cat >"$BUILD_DIR/fib.spl" <<'SIMPLE'
fn fib(n: i64) -> i64:
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

fn main():
    val n = 35
    val result = fib(n)
    println("fib({n}) = {result}")
SIMPLE
}

# Warm fib: runs fib(35) WARM_IN_PROCESS times in-process, reports steady-state
# Uses extern rt_time_now_unix_micros — only works in native mode.
# Interpreter/SMF fall back to outer-process measurement (shell-level timing).
write_simple_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.spl" <<SIMPLE
extern fn rt_time_now_unix_micros() -> i64

fn fib(n: i64) -> i64:
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

fn main():
    val warmup = ${WARM_IN_PROCESS}
    val measured = ${RUNS}
    for i in 0..warmup:
        fib(35)
    val start = rt_time_now_unix_micros()
    for i in 0..measured:
        fib(35)
    val elapsed = rt_time_now_unix_micros() - start
    val avg_us = elapsed / measured
    val avg_ms_int = avg_us / 1000
    val avg_ms_frac = avg_us % 1000
    println("warm_ms: {avg_ms_int}.{avg_ms_frac}")
SIMPLE
}

write_simple_parallel() {
    # Fork-join OS-thread pattern using Simple's direct thread_spawn API.
    # thread_spawn_with_args is tracked by a focused native ABI smoke; this row
    # must stay a real OS-thread scheduler baseline.
    {
        echo 'use std.nogc_sync_mut.concurrent.thread.{thread_spawn, ThreadHandle}'
        echo ''
        echo 'extern fn rt_exit(code: i32)'
        echo ''
        echo 'fn worker() -> i64:'
        echo '    var x = 1'
        echo '    for i in 0..100000:'
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn spawn_worker() -> ThreadHandle:'
        echo '    thread_spawn(\: worker())'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${WORKERS}:"
        echo '        total = total + worker()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo '    var handles: [ThreadHandle] = []'
        echo "    for task in 0..${WORKERS}:"
        echo '        handles.push(spawn_worker())'
        echo '    var total: i64 = 0'
        echo '    for index in 0..handles.len():'
        echo '        val handle = handles[index]'
        echo '        total = total + handle.join()'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/parallel.spl"
}

write_simple_parallel_cooperative_green() {
    # Cooperative green-thread queue pattern. The direct function-value call path
    # is tracked separately, so this benchmark enqueues computed values through
    # the queue and measures scheduler drain/join overhead without OS threads.
    {
        echo 'use std.concurrent.cooperative_green.{cooperative_green_spawn_value, cooperative_green_run_all, GreenThreadHandle}'
        echo ''
        echo 'extern fn rt_exit(code: i32)'
        echo ''
        echo 'fn worker() -> i64:'
        echo '    var x = 1'
        echo '    for i in 0..100000:'
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${GREEN_WORKERS}:"
        echo '        total = total + worker()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo '    var handles: [GreenThreadHandle] = []'
        echo "    for task in 0..${GREEN_WORKERS}:"
        echo '        handles.push(cooperative_green_spawn_value(worker()))'
        echo '    cooperative_green_run_all()'
        echo '    var total: i64 = 0'
        echo '    for index in 0..handles.len():'
        echo '        val handle = handles[index]'
        echo '        total = total + handle.join()'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/parallel_cooperative_green.spl"
}

write_simple_parallel_multicore_green() {
    # Pool-backed Simple task path. This is the current Pure Simple candidate
    # for Go-like M:N CPU-parallel work: many logical tasks over bounded runtime
    # workers when rt_pool_* is linked. It is intentionally separate from the
    # cooperative green-thread queue and from one-OS-thread-per-task spawn.
    {
        echo 'use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism, multicore_green_uses_global_fifo_queue, multicore_green_uses_work_stealing, MulticoreGreenHandle}'
        echo 'extern fn rt_exit(code: i32)'
        echo 'extern fn rt_pool_join(handle: i64) -> i64'
        echo ''
        echo ''
        echo 'fn worker() -> i64:'
        echo '    var x = 1'
        echo '    for i in 0..100000:'
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn spawn_worker() -> MulticoreGreenHandle:'
        echo '    multicore_green_spawn(\: worker())'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${MULTICORE_GREEN_WORKERS}:"
        echo '        total = total + worker()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo "    val requested_parallelism = multicore_green_set_parallelism(${CPU_WORKERS})"
        echo '    println("multicore_green_parallelism = {requested_parallelism}/{multicore_green_parallelism()}")'
        echo '    if multicore_green_uses_global_fifo_queue():'
        echo '        println("multicore_green_queue_model = global_fifo")'
        echo '        rt_exit(75)'
        echo '        return'
        echo '    if !multicore_green_uses_work_stealing():'
        echo '        println("multicore_green_queue_model = scheduler_owned")'
        echo '        rt_exit(76)'
        echo '        return'
        echo '    println("multicore_green_queue_model = work_stealing")'
        echo '    var native_handles: [i64] = []'
        echo "    for task in 0..${MULTICORE_GREEN_WORKERS}:"
        echo '        var handle = spawn_worker()'
        echo '        if handle.used_runtime_pool():'
        echo '            native_handles.push(handle.native_handle)'
        echo '            handle.native_handle = 0'
        echo '    var pool_used: i64 = 0'
        echo '    var total: i64 = 0'
        echo '    for index in 0..native_handles.len():'
        echo '        pool_used = pool_used + 1'
        echo '        total = total + rt_pool_join(native_handles[index])'
        echo "    println(\"multicore_green_pool_used = {pool_used}/${MULTICORE_GREEN_WORKERS}\")"
        echo "    if pool_used != ${MULTICORE_GREEN_WORKERS}:"
        echo '        rt_exit(73)'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/parallel_multicore_green.spl"
}

write_simple_fanout() {
    # OS-thread fanout pattern using Simple's direct thread_spawn API. This is
    # the Simple row comparable to C pthread-per-task fanout.
    {
        echo 'use std.nogc_sync_mut.concurrent.thread.{thread_spawn, ThreadHandle}'
        echo ''
        echo 'extern fn rt_exit(code: i32)'
        echo ''
        echo 'fn work() -> i64:'
        echo '    var x = 1'
        echo "    for i in 0..${FANOUT_ITERS}:"
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn spawn_work() -> ThreadHandle:'
        echo '    thread_spawn(\: work())'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${FANOUT_WORKERS}:"
        echo '        total = total + work()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo '    var handles: [ThreadHandle] = []'
        echo "    for task in 0..${FANOUT_WORKERS}:"
        echo '        handles.push(spawn_work())'
        echo '    var total: i64 = 0'
        echo '    for i in 0..handles.len():'
        echo '        val handle = handles[i]'
        echo '        total = total + handle.join()'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/fanout.spl"
}

write_simple_fanout_cooperative_green() {
    # Simple's implemented green-thread API is cooperative on the current OS
    # thread. This row measures queue fanout overhead, not CPU parallelism.
    {
        echo 'use std.concurrent.cooperative_green.{cooperative_green_spawn_value, cooperative_green_run_all, GreenThreadHandle}'
        echo ''
        echo 'extern fn rt_exit(code: i32)'
        echo ''
        echo 'fn work() -> i64:'
        echo '    var x = 1'
        echo "    for i in 0..${FANOUT_ITERS}:"
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${FANOUT_COOPERATIVE_GREEN_WORKERS}:"
        echo '        total = total + work()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo '    var handles: [GreenThreadHandle] = []'
        echo "    for task in 0..${FANOUT_COOPERATIVE_GREEN_WORKERS}:"
        echo '        handles.push(cooperative_green_spawn_value(work()))'
        echo '    cooperative_green_run_all()'
        echo '    var total: i64 = 0'
        echo '    for index in 0..handles.len():'
        echo '        val handle = handles[index]'
        echo '        total = total + handle.join()'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/fanout_cooperative_green.spl"
}

write_simple_fanout_multicore_green() {
    {
        echo 'use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism, multicore_green_uses_global_fifo_queue, multicore_green_uses_work_stealing, MulticoreGreenHandle}'
        echo 'extern fn rt_exit(code: i32)'
        echo 'extern fn rt_pool_join(handle: i64) -> i64'
        echo ''
        echo ''
        echo 'fn work() -> i64:'
        echo '    var x = 1'
        echo "    for i in 0..${FANOUT_ITERS}:"
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn spawn_work() -> MulticoreGreenHandle:'
        echo '    multicore_green_spawn(\: work())'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${FANOUT_MULTICORE_GREEN_WORKERS}:"
        echo '        total = total + work()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo "    val requested_parallelism = multicore_green_set_parallelism(${CPU_WORKERS})"
        echo '    println("multicore_green_parallelism = {requested_parallelism}/{multicore_green_parallelism()}")'
        echo '    if multicore_green_uses_global_fifo_queue():'
        echo '        println("multicore_green_queue_model = global_fifo")'
        echo '        rt_exit(75)'
        echo '        return'
        echo '    if !multicore_green_uses_work_stealing():'
        echo '        println("multicore_green_queue_model = scheduler_owned")'
        echo '        rt_exit(76)'
        echo '        return'
        echo '    println("multicore_green_queue_model = work_stealing")'
        echo '    var native_handles: [i64] = []'
        echo "    for task in 0..${FANOUT_MULTICORE_GREEN_WORKERS}:"
        echo '        var handle = spawn_work()'
        echo '        if handle.used_runtime_pool():'
        echo '            native_handles.push(handle.native_handle)'
        echo '            handle.native_handle = 0'
        echo '    var pool_used: i64 = 0'
        echo '    var total: i64 = 0'
        echo '    for index in 0..native_handles.len():'
        echo '        pool_used = pool_used + 1'
        echo '        total = total + rt_pool_join(native_handles[index])'
        echo "    println(\"multicore_green_pool_used = {pool_used}/${FANOUT_MULTICORE_GREEN_WORKERS}\")"
        echo "    if pool_used != ${FANOUT_MULTICORE_GREEN_WORKERS}:"
        echo '        rt_exit(73)'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/fanout_multicore_green.spl"
}

write_simple_fanout_stress_multicore_green() {
    {
        echo 'use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism, multicore_green_uses_global_fifo_queue, multicore_green_uses_work_stealing, MulticoreGreenHandle}'
        echo 'extern fn rt_exit(code: i32)'
        echo 'extern fn rt_pool_join(handle: i64) -> i64'
        echo ''
        echo 'fn work() -> i64:'
        echo '    var x = 1'
        echo "    for i in 0..${FANOUT_STRESS_ITERS}:"
        echo '        x = (x * 1103515245 + 12345) % 2147483648'
        echo '    x'
        echo ''
        echo 'fn spawn_work() -> MulticoreGreenHandle:'
        echo '    multicore_green_spawn(\: work())'
        echo ''
        echo 'fn expected_total() -> i64:'
        echo '    var total: i64 = 0'
        echo "    for task in 0..${FANOUT_STRESS_WORKERS}:"
        echo '        total = total + work()'
        echo '    total'
        echo ''
        echo 'fn main():'
        echo "    val requested_parallelism = multicore_green_set_parallelism(${CPU_WORKERS})"
        echo '    println("multicore_green_parallelism = {requested_parallelism}/{multicore_green_parallelism()}")'
        echo '    if multicore_green_uses_global_fifo_queue():'
        echo '        println("multicore_green_queue_model = global_fifo")'
        echo '        rt_exit(75)'
        echo '        return'
        echo '    if !multicore_green_uses_work_stealing():'
        echo '        println("multicore_green_queue_model = scheduler_owned")'
        echo '        rt_exit(76)'
        echo '        return'
        echo '    println("multicore_green_queue_model = work_stealing")'
        echo '    var native_handles: [i64] = []'
        echo "    for task in 0..${FANOUT_STRESS_WORKERS}:"
        echo '        var handle = spawn_work()'
        echo '        if handle.used_runtime_pool():'
        echo '            native_handles.push(handle.native_handle)'
        echo '            handle.native_handle = 0'
        echo '    var pool_used: i64 = 0'
        echo '    var total: i64 = 0'
        echo '    for index in 0..native_handles.len():'
        echo '        pool_used = pool_used + 1'
        echo '        total = total + rt_pool_join(native_handles[index])'
        echo "    println(\"multicore_green_pool_used = {pool_used}/${FANOUT_STRESS_WORKERS}\")"
        echo "    if pool_used != ${FANOUT_STRESS_WORKERS}:"
        echo '        rt_exit(73)'
        echo '    val expected = expected_total()'
        echo '    if total != expected:'
        echo '        println("checksum_mismatch total={total} expected={expected}")'
        echo '        rt_exit(74)'
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/fanout_stress_multicore_green.spl"
}

