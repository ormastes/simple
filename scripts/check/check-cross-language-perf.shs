write_bun_parallel() {
    cat >"$BUILD_DIR/parallel.js" <<JS
const { Worker, isMainThread, parentPort, workerData } = require("worker_threads");
if (!isMainThread) {
  const A = 1103515245, C = 12345, M = 2147483648, ITERS = 100000;
  let x = workerData.seed;
  for (let i = 0; i < ITERS; i++) x = (x * A + C) % M;
  parentPort.postMessage(x);
} else {
  const N = ${WORKERS};
  let total = 0, done = 0;
  for (let i = 0; i < N; i++) {
    const w = new Worker(__filename, { workerData: { seed: i } });
    w.on("message", v => { total += v; if (++done === N) console.log("total = " + total); });
  }
}
JS
}

write_bun_fanout() {
    cat >"$BUILD_DIR/fanout.js" <<JS
const { Worker, isMainThread, parentPort, workerData } = require("worker_threads");
if (!isMainThread) {
  const A = 1103515245, C = 12345, M = 2147483648, ITERS = ${FANOUT_ITERS};
  let x = workerData.seed;
  for (let i = 0; i < ITERS; i++) x = (x * A + C) % M;
  parentPort.postMessage(x);
} else {
  const N = ${FANOUT_WORKERS};
  let total = 0, done = 0;
  for (let i = 0; i < N; i++) {
    const w = new Worker(__filename, { workerData: { seed: i } });
    w.on("message", v => { total += v; if (++done === N) console.log("total = " + total); });
    w.on("error", e => { console.error(e.message); process.exitCode = 2; });
  }
}
JS
}

