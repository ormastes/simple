# ── 4c. Parallel peak RSS ──────────────────────────────────────────────

echo "=== Measuring parallel peak RSS ==="
section "4c. Parallel Peak RSS ($WORKERS workers)"
printf "| %-22s | %14s | %14s | %20s |\n" "Language" "Peak RSS" "Baseline RSS" "Per-worker delta" >>"$REPORT_PATH"
printf "|%-24s|%16s|%16s|%22s|\n" "------------------------" "----------------" "----------------" "----------------------" >>"$REPORT_PATH"

par_rss_row() {
    printf "| %-22s | %14s | %14s | %20s |\n" "$1" "$2" "$3" "$4" >>"$REPORT_PATH"
}

measure_rss() {
    _cmd="$1"
    if have timeout; then
        /usr/bin/time -v timeout "$RUN_TIMEOUT" sh -c "$_cmd" 2>&1 >/dev/null | grep "Maximum resident" | awk '{print $NF}'
    else
        /usr/bin/time -v sh -c "$_cmd" 2>&1 >/dev/null | grep "Maximum resident" | awk '{print $NF}'
    fi
}

rss_delta_per_worker() {
    _total="$1"; _baseline="$2"; _workers="$3"
    if [ -n "$_total" ] && [ -n "$_baseline" ] && [ "$_total" != "0" ] && [ "$_baseline" != "0" ]; then
        _delta=$(( _total - _baseline ))
        if [ "$_delta" -lt 0 ]; then _delta=0; fi
        _per=$(( _delta / _workers ))
        echo "$_per"
    else
        echo ""
    fi
}

echo "  Measuring baselines (hello world)..."
_base_simple_kb=""
_base_c_kb=""
_base_go_kb=""
if [ -x "$BUILD_DIR/hello_simple_native" ]; then
    _base_simple_kb=$(measure_rss "$BUILD_DIR/hello_simple_native")
fi
if [ -x "$BUILD_DIR/hello_c" ]; then
    _base_c_kb=$(measure_rss "$BUILD_DIR/hello_c")
fi
if [ -x "$BUILD_DIR/fib_go" ]; then
    _base_go_kb=$(measure_rss "$BUILD_DIR/fib_go 1")
fi

echo "  Measuring parallel RSS..."
if [ -x "$BUILD_DIR/parallel_simple_native" ]; then
    _rss_kb=$(measure_rss "$BUILD_DIR/parallel_simple_native")
    if [ -n "$_rss_kb" ] && [ "$_rss_kb" != "0" ]; then
        _per=$(rss_delta_per_worker "$_rss_kb" "$_base_simple_kb" "$WORKERS")
        _base_h=""; if [ -n "$_base_simple_kb" ]; then _base_h=$(human_bytes $((_base_simple_kb * 1024))); else _base_h="n/a"; fi
        _per_h=""; if [ -n "$_per" ]; then _per_h="~${_per}KB"; else _per_h="n/a"; fi
        par_rss_row "Simple (native)" "$(human_bytes $((_rss_kb * 1024)))" "$_base_h" "$_per_h"
    fi
fi
if [ -x "$BUILD_DIR/parallel_c" ]; then
    _rss_kb=$(measure_rss "$BUILD_DIR/parallel_c")
    if [ -n "$_rss_kb" ] && [ "$_rss_kb" != "0" ]; then
        _per=$(rss_delta_per_worker "$_rss_kb" "$_base_c_kb" "$WORKERS")
        _base_h=""; if [ -n "$_base_c_kb" ]; then _base_h=$(human_bytes $((_base_c_kb * 1024))); else _base_h="n/a"; fi
        _per_h=""; if [ -n "$_per" ]; then _per_h="~${_per}KB"; else _per_h="n/a"; fi
        par_rss_row "C (pthreads)" "$(human_bytes $((_rss_kb * 1024)))" "$_base_h" "$_per_h"
    fi
fi
if [ -x "$BUILD_DIR/parallel_go" ]; then
    _rss_kb=$(measure_rss "$BUILD_DIR/parallel_go")
    if [ -n "$_rss_kb" ] && [ "$_rss_kb" != "0" ]; then
        _per=$(rss_delta_per_worker "$_rss_kb" "$_base_go_kb" "$WORKERS")
        _base_h=""; if [ -n "$_base_go_kb" ]; then _base_h=$(human_bytes $((_base_go_kb * 1024))); else _base_h="n/a"; fi
        _per_h=""; if [ -n "$_per" ]; then _per_h="~${_per}KB"; else _per_h="n/a"; fi
        par_rss_row "Go" "$(human_bytes $((_rss_kb * 1024)))" "$_base_h" "$_per_h"
    fi
fi
if have python3; then
    _base_py_kb=$(measure_rss "python3 -c 'print(1)'")
    _rss_kb=$(measure_rss "python3 $BUILD_DIR/parallel.py")
    if [ -n "$_rss_kb" ] && [ "$_rss_kb" != "0" ]; then
        _per=$(rss_delta_per_worker "$_rss_kb" "$_base_py_kb" "$WORKERS")
        _base_h=""; if [ -n "$_base_py_kb" ]; then _base_h=$(human_bytes $((_base_py_kb * 1024))); else _base_h="n/a"; fi
        _per_h=""; if [ -n "$_per" ]; then _per_h="~${_per}KB"; else _per_h="n/a"; fi
        par_rss_row "Python" "$(human_bytes $((_rss_kb * 1024)))" "$_base_h" "$_per_h"
    fi
fi
if have java; then
    _base_java_kb=$(measure_rss "java -version")
    _rss_kb=$(measure_rss "java -cp $BUILD_DIR Parallel")
    if [ -n "$_rss_kb" ] && [ "$_rss_kb" != "0" ]; then
        _per=$(rss_delta_per_worker "$_rss_kb" "$_base_java_kb" "$WORKERS")
        _base_h=""; if [ -n "$_base_java_kb" ]; then _base_h=$(human_bytes $((_base_java_kb * 1024))); else _base_h="n/a"; fi
        _per_h=""; if [ -n "$_per" ]; then _per_h="~${_per}KB"; else _per_h="n/a"; fi
        par_rss_row "Java" "$(human_bytes $((_rss_kb * 1024)))" "$_base_h" "$_per_h"
    fi
fi

# ── parallel design note ────────────────────────────────────────────────

cat >>"$REPORT_PATH" <<'EOF'

> **Workload:** LCG (Linear Congruential Generator) with 100K iterations per worker.
> Each worker reads shared constants (LCG_A, LCG_C, LCG_M, ITERS).
> The large fanout section uses many tiny workers with `FANOUT_ITERS` iterations
> to expose scheduling overhead; this is the case where Go goroutines should
> usually beat one-pthread-per-task C.
>
> **Simple concurrency rows:** `Simple (native)` uses `thread_spawn`, which is
> the OS-thread API. `Simple green` uses `green_spawn_value`, which exercises the
> implemented cooperative green-thread queue on the current OS thread; it does
> not run in parallel and is not a Go M:N goroutine equivalent. The green row uses the
> `GREEN_WORKERS` count from the report header because the current cooperative
> seed is intentionally separate from the OS-thread/Goroutine worker count.
> Current direct-run blocker: SMF mutable globals can segfault before the
> cooperative queue runs, so the SMF green row is classified instead of treated
> as a scheduling result when that runtime failure appears.
>
> **Design comparison — Simple channels vs Go channels:**
> Both Simple and Go use the same pattern: workers send results through a channel,
> main collects via recv. Simple's `val` constants captured by closures add a
> **compile-time immutability guarantee** — the compiler rejects mutation of shared
> data. Go relies on convention (don't mutate shared vars) or channels for all data
> flow. C shares via globals with no safety guarantee.
> Same semantic, same safety for result collection; Simple adds compile-time
> enforcement for shared read-only data.
>
> **RSS note:** Per-worker delta = (parallel_RSS - hello_baseline_RSS) / worker count.
> Baseline measures the runtime's fixed overhead (startup, GC, stdlib).
> OS-thread languages (Simple, C) pay ~8MB default stack per thread but RSS
> reflects only committed pages, not reserved virtual memory.
EOF

# ── footer ───────────────────────────────────────────────────────────────

cat >>"$REPORT_PATH" <<'EOF'

## Size Definition

| Category | What "size" means |
|----------|-------------------|
| AOT (C, Go, Simple native) | Binary bytes on disk — self-contained |
| VM/bytecode (Java, Erlang, Simple SMF) | `.class`/`.beam`/`.smf` bytes — requires runtime |
| Interpreted (Python, Bun, Simple interp.) | Script bytes — requires interpreter binary |

## How to Optimize Simple Performance

All optimization in **pure Simple** (`.spl`) — do not modify Rust seed or C runtime.

1. **Interpreter → SMF loader** — `simple compile file.spl -o file.smf` for ~2-5x dispatch speedup
2. **SMF → native** — `simple compile file.spl --native -o file` for AOT via Cranelift (~4x slower than gcc -O2 for recursive workloads; no tail-call opt yet)
3. **Use `val` over `var`** — immutable bindings enable more aggressive constant folding
4. **Avoid deep recursion** — rewrite as iteration where possible (tail-call not yet optimized)
5. **Use typed collections** — `List<i64>` avoids boxing overhead vs untyped `List`
6. **Profile with `std.testing.benchmark`** — warmup + outlier detection built in
7. **`bin/simple build check`** — lint catches perf anti-patterns (mcp_perf_lint)
EOF

echo ""
echo "=== Report written to: $REPORT_PATH ==="
if [ -n "$COMPILE_FAIL$COMPILE_FAIL_SMF" ]; then
    echo "WARNING: Some Simple compilations failed — check output above"
fi
echo ""
