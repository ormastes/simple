    else
        evidence=$(pool_evidence "$BUILD_DIR/fanout_stress_multicore_green_simple_native" "$FANOUT_STRESS_WORKERS")
        stress_row "Simple multicore green (native)" "$ms" "multicore_green stress fanout ($evidence)"
    fi
elif echo "$COMPILE_FAIL" | grep -q 'native:fanout_stress_multicore_green(timeout)'; then
    stress_row "Simple multicore green (native)" "n/a" "multicore_green stress fanout compile timeout"
else
    stress_row "Simple multicore green (native)" "n/a" "compile failed"
fi
if [ -x "$BUILD_DIR/fanout_stress_go" ]; then
