#!/bin/sh
set -eu

# Cross-language performance comparison harness
# Compares Simple (interpreter / SMF loader / native) against
# bun, python, go, erlang, java, and C.
#
# Dimensions: binary/runtime size, cold startup, warm throughput (fib35),
#             parallel CPU workers, and large fanout scheduling.
#
# Warm throughput uses IN-PROCESS loops so JIT runtimes (Java HotSpot,
# Bun/JSC) reach steady state within a single process — not relaunched.
#
# Usage:
#   sh scripts/check/check-cross-language-perf.shs
#   RUNS=50 WORKERS=100 sh scripts/check/check-cross-language-perf.shs
#   RUNS=3 FANOUT_WORKERS=1000 FANOUT_ITERS=32 sh scripts/check/check-cross-language-perf.shs

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-bin/simple}"
BUILD_DIR="${BUILD_DIR:-build/cross_lang_perf}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/cross_language_perf_$(date +%Y-%m-%d).md}"
RUNS="${RUNS:-20}"
FIB_N="${FIB_N:-35}"
WORKERS="${WORKERS:-100}"
FANOUT_WORKERS="${FANOUT_WORKERS:-1000}"
FANOUT_ITERS="${FANOUT_ITERS:-32}"
if [ -z "${GREEN_WORKERS:-}" ]; then
    if [ "$WORKERS" -gt 10 ]; then
        GREEN_WORKERS=10
    else
        GREEN_WORKERS="$WORKERS"
    fi
fi
WARM_ITERS="${WARM_ITERS:-5}"
WARM_IN_PROCESS="${WARM_IN_PROCESS:-10}"
RUN_TIMEOUT="${RUN_TIMEOUT:-30}"

mkdir -p "$BUILD_DIR" "$(dirname "$REPORT_PATH")"

# ── PATH fixup for common non-PATH locations ─────────────────────────────
for _d in /usr/lib/erlang/bin /usr/lib/go/bin /usr/local/go/bin /snap/go/current/bin; do
    [ -d "$_d" ] && case ":$PATH:" in *":$_d:"*) ;; *) PATH="$_d:$PATH" ;; esac
done
export PATH

# ── helpers ──────────────────────────────────────────────────────────────

have() { command -v "$1" >/dev/null 2>&1; }

run_bounded() {
    _cmd="$1"
    if have timeout; then
        timeout "$RUN_TIMEOUT" sh -c "$_cmd"
    else
        sh -c "$_cmd"
    fi
}

bytes_of() {
    if [ -f "$1" ]; then wc -c <"$1" | tr -d ' '; else echo "n/a"; fi
}

human_bytes() {
    awk "BEGIN { b=$1; u=\"B\";
      if(b>=1073741824){b/=1073741824;u=\"GB\"}
      else if(b>=1048576){b/=1048576;u=\"MB\"}
      else if(b>=1024){b/=1024;u=\"KB\"};
      printf \"%.1f %s\", b, u }"
}

avg_ms() {
    _cmd="$1"; _runs="$2"
    i=0; total=0; ok=0
    while [ "$i" -lt "$_runs" ]; do
        start="$(date +%s%N)"
        if run_bounded "$_cmd" >/dev/null 2>&1; then
            end="$(date +%s%N)"
            total=$((total + (end - start)))
            ok=$((ok + 1))
        fi
        i=$((i + 1))
    done
    if [ "$ok" -eq 0 ]; then echo "fail"
    else awk "BEGIN {printf \"%.3f\", ($total / $ok) / 1000000}"; fi
}

failure_reason() {
    _cmd="$1"
    _out=$(run_bounded "$_cmd" 2>&1) && { echo "ok"; return; }
    _status=$?
    if [ "$_status" -eq 124 ]; then
        echo "timeout"
    elif [ "$_status" -eq 139 ]; then
        echo "segfault"
    elif echo "$_out" | grep -q 'Undefined symbol: rt_len'; then
        echo "missing rt_len"
    else
        echo "failed"
    fi
}

# Extract in-process timing from program stdout (programs print "warm_ms: NNN.NNN")
extract_warm_ms() {
    _cmd="$1"
    _output=$(run_bounded "$_cmd" 2>/dev/null) || { echo "fail"; return; }
    echo "$_output" | grep 'warm_ms:' | tail -1 | sed 's/.*warm_ms: *//' | tr -d ' '
}

section() { printf "\n## %s\n\n" "$1" >>"$REPORT_PATH"; }
row() { printf "| %-22s | %12s | %12s | %12s | %12s |\n" "$@" >>"$REPORT_PATH"; }
sep() { printf "|%-24s|%14s|%14s|%14s|%14s|\n" "------------------------" "--------------" "--------------" "--------------" "--------------" >>"$REPORT_PATH"; }

# ── generate workload sources ────────────────────────────────────────────

write_simple_hello() {
    cat >"$BUILD_DIR/hello.spl" <<'SIMPLE'
fn main():
    println("Hello World")
SIMPLE
}

write_simple_fib() {
    cat >"$BUILD_DIR/fib.spl" <<'SIMPLE'
fn fib(n: i64) -> i64:
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

fn main():
    val n = 35
    val result = fib(n)
    println("fib({n}) = {result}")
SIMPLE
}

# Warm fib: runs fib(35) WARM_IN_PROCESS times in-process, reports steady-state
# Uses extern rt_time_now_unix_micros — only works in native mode.
# Interpreter/SMF fall back to outer-process measurement (shell-level timing).
write_simple_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.spl" <<SIMPLE
extern fn rt_time_now_unix_micros() -> i64

fn fib(n: i64) -> i64:
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

fn main():
    val warmup = ${WARM_IN_PROCESS}
    val measured = ${RUNS}
    for i in 0..warmup:
        fib(35)
    val start = rt_time_now_unix_micros()
    for i in 0..measured:
        fib(35)
    val elapsed = rt_time_now_unix_micros() - start
    val avg_us = elapsed / measured
    val avg_ms_int = avg_us / 1000
    val avg_ms_frac = avg_us % 1000
    println("warm_ms: {avg_ms_int}.{avg_ms_frac}")
SIMPLE
}

write_simple_parallel() {
    # Channel-based pattern — same semantic as Go's goroutine + chan result.
    # Workers send results through a channel; main recvs and sums.
    # Unrolled: native codegen List iteration is broken (codegen bug).
    _last_worker=$((WORKERS - 1))
    {
        echo 'use std.concurrent.channel.{channel_new, channel_from_id}'
        echo 'use std.concurrent.thread.{thread_spawn}'
        echo ''
        echo 'val LCG_A: i64 = 1103515245'
        echo 'val LCG_C: i64 = 12345'
        echo 'val LCG_M: i64 = 2147483648'
        echo 'val ITERS: i64 = 100000'
        echo ''
        echo 'fn worker(seed: i64, ch_id: i64) -> i64:'
        echo '    var x = seed'
        echo '    for i in 0..ITERS:'
        echo '        x = (x * LCG_A + LCG_C) % LCG_M'
        echo '    val ch = channel_from_id(ch_id)'
        echo '    ch.send(x)'
        echo '    return 0'
        echo ''
        echo 'fn main():'
        echo '    val ch = channel_new()'
        echo '    val cid = ch.id()'
        for i in $(seq 0 "$_last_worker"); do
            echo "    var h${i} = thread_spawn(\\: worker(${i}, cid))"
        done
        for i in $(seq 0 "$_last_worker"); do
            echo "    h${i}.join()"
        done
        echo '    var total: i64 = 0'
        for i in $(seq 0 "$_last_worker"); do
            echo "    val v${i}: i64 = ch.recv()"
            echo "    total = total + v${i}"
        done
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/parallel.spl"
}

write_simple_parallel_green() {
    # Cooperative green-thread queue pattern. The direct function-value call path
    # is tracked separately, so this benchmark enqueues computed values through
    # the queue and measures scheduler drain/join overhead without OS threads.
    _last_green_worker=$((GREEN_WORKERS - 1))
    {
        echo 'use std.concurrent.green_thread.{green_spawn_value, green_run_all}'
        echo ''
        echo 'val LCG_A: i64 = 1103515245'
        echo 'val LCG_C: i64 = 12345'
        echo 'val LCG_M: i64 = 2147483648'
        echo 'val ITERS: i64 = 100000'
        echo ''
        echo 'fn worker(seed: i64) -> i64:'
        echo '    var x = seed'
        echo '    for i in 0..ITERS:'
        echo '        x = (x * LCG_A + LCG_C) % LCG_M'
        echo '    x'
        echo ''
        echo 'fn main():'
        for i in $(seq 0 "$_last_green_worker"); do
            echo "    var h${i} = green_spawn_value(worker(${i}))"
        done
        echo '    green_run_all()'
        echo '    var total: i64 = 0'
        for i in $(seq 0 "$_last_green_worker"); do
            echo "    total = total + h${i}.join()"
        done
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/parallel_green.spl"
}

write_simple_fanout_green() {
    # Simple's implemented green-thread API is cooperative on the current OS
    # thread. This row measures queue fanout overhead, not CPU parallelism.
    _last_fanout_worker=$((FANOUT_WORKERS - 1))
    {
        echo 'use std.concurrent.green_thread.{green_spawn_value, green_run_all}'
        echo ''
        echo 'val LCG_A: i64 = 1103515245'
        echo 'val LCG_C: i64 = 12345'
        echo 'val LCG_M: i64 = 2147483648'
        echo "val ITERS: i64 = ${FANOUT_ITERS}"
        echo ''
        echo 'fn work(seed: i64) -> i64:'
        echo '    var x = seed'
        echo '    for i in 0..ITERS:'
        echo '        x = (x * LCG_A + LCG_C) % LCG_M'
        echo '    x'
        echo ''
        echo 'fn main():'
        for i in $(seq 0 "$_last_fanout_worker"); do
            echo "    var h${i} = green_spawn_value(work(${i}))"
        done
        echo '    green_run_all()'
        echo '    var total: i64 = 0'
        for i in $(seq 0 "$_last_fanout_worker"); do
            echo "    total = total + h${i}.join()"
        done
        echo '    println("total = {total}")'
    } >"$BUILD_DIR/fanout_green.spl"
}

write_c_hello() {
    cat >"$BUILD_DIR/hello.c" <<'C'
#include <stdio.h>
int main(void) { puts("Hello World"); return 0; }
C
}

write_c_fib() {
    cat >"$BUILD_DIR/fib.c" <<'C'
#include <stdio.h>
#include <stdint.h>
static int64_t fib(int64_t n) { return n < 2 ? n : fib(n-1) + fib(n-2); }
int main(void) { printf("fib(35) = %ld\n", fib(35)); return 0; }
C
}

write_c_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.c" <<C
#include <stdio.h>
#include <stdint.h>
#include <time.h>
static int64_t fib(int64_t n) { return n < 2 ? n : fib(n-1) + fib(n-2); }
int main(void) {
    int warmup = ${WARM_IN_PROCESS}, measured = ${RUNS};
    for (int i = 0; i < warmup; i++) fib(35);
    struct timespec t0, t1;
    clock_gettime(CLOCK_MONOTONIC, &t0);
    for (int i = 0; i < measured; i++) fib(35);
    clock_gettime(CLOCK_MONOTONIC, &t1);
    int64_t ns = (t1.tv_sec - t0.tv_sec)*1000000000LL + (t1.tv_nsec - t0.tv_nsec);
    printf("warm_ms: %.3f\n", (double)ns / measured / 1e6);
    return 0;
}
C
}

write_c_parallel() {
    cat >"$BUILD_DIR/parallel.c" <<C
#include <stdio.h>
#include <stdint.h>
#include <pthread.h>
/* Shared globals — no immutability guarantee (programmer discipline only) */
static const int64_t LCG_A = 1103515245;
static const int64_t LCG_C = 12345;
static const int64_t LCG_M = 2147483648LL;
static const int ITERS = 100000;
static void *worker(void *arg) {
    int64_t x = (int64_t)(intptr_t)arg;
    for (int i = 0; i < ITERS; i++) x = (x * LCG_A + LCG_C) % LCG_M;
    return (void *)(intptr_t)x;
}
int main(void) {
    enum { N = ${WORKERS} };
    pthread_t t[N]; int64_t total = 0;
    for (int i = 0; i < N; i++) pthread_create(&t[i], NULL, worker, (void *)(intptr_t)i);
    for (int i = 0; i < N; i++) { void *r; pthread_join(t[i], &r); total += (int64_t)(intptr_t)r; }
    printf("total = %ld\n", total); return 0;
}
C
}

write_c_fanout() {
    cat >"$BUILD_DIR/fanout.c" <<C
#include <stdio.h>
#include <stdint.h>
#include <stdlib.h>
#include <pthread.h>
static const int64_t LCG_A = 1103515245;
static const int64_t LCG_C = 12345;
static const int64_t LCG_M = 2147483648LL;
static const int ITERS = ${FANOUT_ITERS};
static int64_t *results;
static int64_t work(int64_t seed) {
    int64_t x = seed;
    for (int i = 0; i < ITERS; i++) x = (x * LCG_A + LCG_C) % LCG_M;
    return x;
}
static void *worker(void *arg) {
    int64_t i = (int64_t)(intptr_t)arg;
    results[i] = work(i);
    return NULL;
}
int main(void) {
    enum { N = ${FANOUT_WORKERS} };
    pthread_t *t = calloc(N, sizeof(pthread_t));
    results = calloc(N, sizeof(int64_t));
    if (!t || !results) return 2;
    int created = 0;
    for (int i = 0; i < N; i++) {
        if (pthread_create(&t[i], NULL, worker, (void *)(intptr_t)i) != 0) break;
        created++;
    }
    if (created != N) {
        for (int i = 0; i < created; i++) pthread_join(t[i], NULL);
        fprintf(stderr, "pthread_create failed at %d/%d\n", created, N);
        return 2;
    }
    int64_t total = 0;
    for (int i = 0; i < N; i++) { pthread_join(t[i], NULL); total += results[i]; }
    printf("total = %ld\n", total);
    free(t); free(results);
    return 0;
}
C
}

write_go_fib() {
    cat >"$BUILD_DIR/fib.go" <<'GO'
package main
import "fmt"
func fib(n int64) int64 { if n < 2 { return n }; return fib(n-1) + fib(n-2) }
func main() { fmt.Printf("fib(35) = %d\n", fib(35)) }
GO
}

write_go_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.go" <<GO
package main
import ("fmt"; "time")
func fib(n int64) int64 { if n < 2 { return n }; return fib(n-1) + fib(n-2) }
func main() {
    warmup, measured := ${WARM_IN_PROCESS}, ${RUNS}
    for i := 0; i < warmup; i++ { fib(35) }
    start := time.Now()
    for i := 0; i < measured; i++ { fib(35) }
    elapsed := time.Since(start)
    fmt.Printf("warm_ms: %.3f\n", float64(elapsed.Nanoseconds())/float64(measured)/1e6)
}
GO
}

write_go_parallel() {
    cat >"$BUILD_DIR/parallel.go" <<GO
package main
import "fmt"
/* Idiomatic Go: results flow through channels (safe pattern) */
func worker(seed int64, ch chan<- int64) {
    const a, c, m int64 = 1103515245, 12345, 2147483648
    x := seed
    for i := 0; i < 100000; i++ { x = (x*a + c) % m }
    ch <- x
}
func main() {
    ch := make(chan int64, ${WORKERS})
    for i := 0; i < ${WORKERS}; i++ { go worker(int64(i), ch) }
    var total int64
    for i := 0; i < ${WORKERS}; i++ { total += <-ch }
    fmt.Printf("total = %d\n", total)
}
GO
}

write_go_fanout() {
    cat >"$BUILD_DIR/fanout.go" <<GO
package main
import "fmt"
func work(seed int64) int64 {
    const a, c, m int64 = 1103515245, 12345, 2147483648
    x := seed
    for i := 0; i < ${FANOUT_ITERS}; i++ { x = (x*a + c) % m }
    return x
}
func main() {
    ch := make(chan int64, ${FANOUT_WORKERS})
    for i := 0; i < ${FANOUT_WORKERS}; i++ {
        go func(seed int64) { ch <- work(seed) }(int64(i))
    }
    var total int64
    for i := 0; i < ${FANOUT_WORKERS}; i++ { total += <-ch }
    fmt.Printf("total = %d\n", total)
}
GO
}

write_python_fib() {
    cat >"$BUILD_DIR/fib.py" <<'PY'
import sys
sys.setrecursionlimit(100000)
def fib(n):
    if n < 2: return n
    return fib(n-1) + fib(n-2)
print(f"fib(35) = {fib(35)}")
PY
}

write_python_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.py" <<PY
import sys, time
sys.setrecursionlimit(100000)
def fib(n):
    if n < 2: return n
    return fib(n-1) + fib(n-2)
warmup, measured = ${WARM_IN_PROCESS}, ${RUNS}
for _ in range(warmup): fib(35)
t0 = time.monotonic_ns()
for _ in range(measured): fib(35)
elapsed = time.monotonic_ns() - t0
print(f"warm_ms: {elapsed / measured / 1e6:.3f}")
PY
}

write_python_parallel() {
    cat >"$BUILD_DIR/parallel.py" <<PY
import threading
A, C, M, ITERS = 1103515245, 12345, 2147483648, 100000
def worker(results, idx):
    x = idx
    for _ in range(ITERS):
        x = (x * A + C) % M
    results[idx] = x
results = [0]*${WORKERS}
threads = [threading.Thread(target=worker, args=(results,i)) for i in range(${WORKERS})]
for t in threads: t.start()
for t in threads: t.join()
print(f"total = {sum(results)}")
PY
}

write_python_fanout() {
    cat >"$BUILD_DIR/fanout.py" <<PY
import threading
A, C, M, ITERS = 1103515245, 12345, 2147483648, ${FANOUT_ITERS}
N = ${FANOUT_WORKERS}
results = [0] * N
def work(seed):
    x = seed
    for _ in range(ITERS):
        x = (x * A + C) % M
    return x
def worker(i):
    results[i] = work(i)
threads = [threading.Thread(target=worker, args=(i,)) for i in range(N)]
for t in threads: t.start()
for t in threads: t.join()
print(f"total = {sum(results)}")
PY
}

write_bun_fib() {
    cat >"$BUILD_DIR/fib.js" <<'JS'
function fib(n) { return n < 2 ? n : fib(n-1) + fib(n-2); }
console.log(`fib(35) = ${fib(35)}`);
JS
}

write_bun_fib_warm() {
    cat >"$BUILD_DIR/fib_warm.js" <<JS
function fib(n) { return n < 2 ? n : fib(n-1) + fib(n-2); }
const warmup = ${WARM_IN_PROCESS}, measured = ${RUNS};
for (let i = 0; i < warmup; i++) fib(35);
const t0 = process.hrtime.bigint();
for (let i = 0; i < measured; i++) fib(35);
const elapsed = Number(process.hrtime.bigint() - t0);
console.log(\`warm_ms: \${(elapsed / measured / 1e6).toFixed(3)}\`);
JS
}

write_bun_parallel() {
    cat >"$BUILD_DIR/parallel.js" <<JS
const { Worker, isMainThread, parentPort, workerData } = require("worker_threads");
if (!isMainThread) {
  const A = 1103515245, C = 12345, M = 2147483648, ITERS = 100000;
  let x = workerData.seed;
  for (let i = 0; i < ITERS; i++) x = (x * A + C) % M;
  parentPort.postMessage(x);
} else {
  const N = ${WORKERS};
  let total = 0, done = 0;
  for (let i = 0; i < N; i++) {
    const w = new Worker(__filename, { workerData: { seed: i } });
    w.on("message", v => { total += v; if (++done === N) console.log("total = " + total); });
  }
}
JS
}

write_bun_fanout() {
    cat >"$BUILD_DIR/fanout.js" <<JS
const { Worker, isMainThread, parentPort, workerData } = require("worker_threads");
if (!isMainThread) {
  const A = 1103515245, C = 12345, M = 2147483648, ITERS = ${FANOUT_ITERS};
  let x = workerData.seed;
  for (let i = 0; i < ITERS; i++) x = (x * A + C) % M;
  parentPort.postMessage(x);
} else {
  const N = ${FANOUT_WORKERS};
  let total = 0, done = 0;
  for (let i = 0; i < N; i++) {
    const w = new Worker(__filename, { workerData: { seed: i } });
    w.on("message", v => { total += v; if (++done === N) console.log("total = " + total); });
    w.on("error", e => { console.error(e.message); process.exitCode = 2; });
  }
}
JS
}

