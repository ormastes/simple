write_java_fib
write_java_fib_warm
write_java_parallel
write_java_fanout
write_erlang_fib
write_erlang_fib_warm
write_erlang_parallel
write_erlang_fanout

# ── compile what we can ──────────────────────────────────────────────────

echo "=== Compiling workloads ==="
COMPILE_FAIL=""

# C
if have gcc; then
    gcc -O2 -o "$BUILD_DIR/hello_c" "$BUILD_DIR/hello.c"
    gcc -O2 -o "$BUILD_DIR/fib_c" "$BUILD_DIR/fib.c"
    gcc -O2 -o "$BUILD_DIR/fib_warm_c" "$BUILD_DIR/fib_warm.c"
    gcc -O2 -pthread -o "$BUILD_DIR/parallel_c" "$BUILD_DIR/parallel.c"
    gcc -O2 -pthread -o "$BUILD_DIR/fanout_c" "$BUILD_DIR/fanout.c"
    gcc -O2 -pthread -o "$BUILD_DIR/fanout_stress_c" "$BUILD_DIR/fanout_stress.c"
    echo "  [ok] C (gcc)"
else echo "  [skip] C — gcc not found"; fi

# Go
GO_VERSION="unavailable"
GO_SCHEDULER="GOMAXPROCS=unavailable NumCPU=unavailable"
if have go; then
    GO_VERSION="$(go version 2>/dev/null || echo unavailable)"
    (cd "$BUILD_DIR" && go build -o fib_go fib.go && go build -o fib_warm_go fib_warm.go && go build -o parallel_go parallel.go && go build -o fanout_go fanout.go && go build -o fanout_stress_go fanout_stress.go && go build -o gomaxprocs_go gomaxprocs.go)
    GO_SCHEDULER="$("$BUILD_DIR/gomaxprocs_go" 2>/dev/null || echo "GOMAXPROCS=unavailable NumCPU=unavailable")"
    echo "  [ok] Go"
else echo "  [skip] Go — go not found"; fi

# Java
if have javac; then
    javac -d "$BUILD_DIR" "$BUILD_DIR/Fib.java" "$BUILD_DIR/FibWarm.java" "$BUILD_DIR/Parallel.java" "$BUILD_DIR/Fanout.java"
    echo "  [ok] Java (javac)"
else echo "  [skip] Java — javac not found"; fi

# Erlang
if have erlc; then
    erlc -o "$BUILD_DIR" "$BUILD_DIR/fib.erl" "$BUILD_DIR/fib_warm.erl" "$BUILD_DIR/parallel.erl" "$BUILD_DIR/fanout.erl"
    echo "  [ok] Erlang (erlc)"
else echo "  [skip] Erlang — erlc not found"; fi

# Simple native
if [ -x "$SIMPLE_BINARY" ]; then
    for _src in hello fib fib_warm parallel parallel_cooperative_green parallel_multicore_green fanout fanout_cooperative_green fanout_multicore_green fanout_stress_multicore_green; do
        _spl="$BUILD_DIR/${_src}.spl"
        _out="$BUILD_DIR/${_src}_simple_native"
        if [ -f "$_spl" ]; then
            if run_bounded "$SIMPLE_BINARY compile $_spl --native -o $_out" >/dev/null 2>&1; then
                : # ok
            else
                _status=$?
                rm -f "$_out"
                echo "  [FAIL] Simple native: $_spl"
                if [ "$_status" -eq 124 ]; then
                    COMPILE_FAIL="$COMPILE_FAIL native:$_src(timeout)"
                else
                    COMPILE_FAIL="$COMPILE_FAIL native:$_src"
                fi
            fi
        fi
    done
    echo "  [ok] Simple (native)${COMPILE_FAIL:+ — failures:$COMPILE_FAIL}"
else echo "  [skip] Simple — $SIMPLE_BINARY not found"; fi

# Simple SMF
COMPILE_FAIL_SMF=""
if [ -x "$SIMPLE_BINARY" ]; then
    for _src in hello fib fib_warm parallel parallel_cooperative_green parallel_multicore_green fanout fanout_cooperative_green fanout_multicore_green; do
        _spl="$BUILD_DIR/${_src}.spl"
        _out="$BUILD_DIR/${_src}_simple.smf"
        if [ -f "$_spl" ]; then
            if run_bounded "$SIMPLE_BINARY compile $_spl -o $_out" >/dev/null 2>&1; then
                : # ok
            else
                _status=$?
                rm -f "$_out"
                echo "  [FAIL] Simple SMF: $_spl"
                if [ "$_status" -eq 124 ]; then
                    COMPILE_FAIL_SMF="$COMPILE_FAIL_SMF smf:$_src(timeout)"
                else
                    COMPILE_FAIL_SMF="$COMPILE_FAIL_SMF smf:$_src"
                fi
            fi
        fi
    done
    echo "  [ok] Simple (SMF)${COMPILE_FAIL_SMF:+ — failures:$COMPILE_FAIL_SMF}"
fi

# ── report header ────────────────────────────────────────────────────────

PROFILE_CONTRACT_STATUS="enforced by $PROFILE_REPORT_CONTRACT_TEST"
if [ "${SKIP_PROFILE_REPORT_CONTRACT:-0}" = "1" ]; then
    PROFILE_CONTRACT_STATUS="skipped by SKIP_PROFILE_REPORT_CONTRACT=1"
fi

cat >"$REPORT_PATH" <<EOF
# Cross-Language Performance Profile

**Date:** $(date +%Y-%m-%d)
**Machine:** $(uname -m) / $(uname -s) $(uname -r)
**CPU:** $(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
**Runs per measurement:** $RUNS | **Warmup (in-process):** $WARM_IN_PROCESS | **fib(N):** $FIB_N | **CPU workers:** $CPU_WORKERS | **OS thread workers:** $OS_THREAD_WORKERS | **Cooperative green workers:** $COOPERATIVE_GREEN_WORKERS | **Multicore green workers:** $MULTICORE_GREEN_WORKERS | **Fanout workers:** $FANOUT_WORKERS | **Fanout cooperative green workers:** $FANOUT_COOPERATIVE_GREEN_WORKERS | **Fanout multicore green workers:** $FANOUT_MULTICORE_GREEN_WORKERS | **Fanout iters:** $FANOUT_ITERS | **Fanout stress workers:** $FANOUT_STRESS_WORKERS | **Fanout stress iters:** $FANOUT_STRESS_ITERS | **Per-run timeout:** ${RUN_TIMEOUT}s
**Profile script:** \`scripts/check/check-cross-language-perf.shs\`
**Report path:** \`$REPORT_PATH\`
**Profile contract:** $PROFILE_CONTRACT_STATUS
**Docker isolation:** inside_container=$PROFILE_DOCKER_INSIDE | image=\`$PROFILE_DOCKER_IMAGE\` | memory=$PROFILE_DOCKER_MEMORY | cpus=$PROFILE_DOCKER_CPUS

## Methodology

- Generates equivalent hello, recursive fib, in-process warm fib, worker, and fanout workloads for each supported runtime.
- Measures binary/script size, cold process startup, warm throughput, parallel worker latency, fanout latency, parallel binary size, and peak RSS where the runtime and compiler are available.
- Uses bounded commands so failed, missing, timed-out, or unavailable lanes are classified instead of silently treated as passing data.
- Supports \`PROFILE_DOCKER_ISOLATION=1\` to re-exec the same profile script in a Docker container with \`--network=none\`, a memory limit, a CPU limit, and the current UID/GID. Use this mode for crash-prone native and SMF profile runs. Build \`simple-cross-language-perf:latest\` with \`docker build -t simple-cross-language-perf:latest -f tools/docker/Dockerfile.cross-language-perf tools/docker\` for contract-gated C/Go comparison evidence. The fixed linker-order blocker for Simple native rows is recorded in \`doc/08_tracking/bug/docker_cross_language_profile_native_link_2026-06-08.md\`.
- Generated Simple concurrency workloads compute an expected checksum and exit nonzero on mismatch, so runtime-pool closure failures cannot be timed as valid M:N evidence.
- Warm throughput is measured in-process where the runtime can print \`warm_ms\`; interpreter and SMF rows use outer-process timing and are labeled that way.

## Environment

- Host: \`$(hostname)\`
- Shell: \`${SHELL:-unknown}\`
- Simple binary: \`$SIMPLE_BINARY\`
- Go runtime: \`$GO_VERSION\`
- Go scheduler: \`$GO_SCHEDULER\`

> Size for AOT = binary bytes. For VM/interpreted = script bytes (runtime not included).
> "Runtime dep" column shows runtime size where applicable.
> Warm throughput measured IN-PROCESS (JIT runtimes reach steady state).

## TUI startup scope

TUI startup speed is not measured by this cross-language profile. It is covered by
\`scripts/check/check-startup-size-performance-audit.shs\`, which builds and times
\`Simple standalone TUI\` and \`Simple full TUI app\` rows in
\`doc/09_report/startup_size_performance_audit_2026-05-27.md\`.
EOF

# ── Artifact footprint ───────────────────────────────────────────────────

echo "=== Measuring sizes ==="
section "Artifact Footprint — hello and fib"
row "Language" "Hello" "Fib" "Runtime dep" >>"$REPORT_PATH"
sep

measure_size() {
    _lang="$1"; _hello="$2"; _fib="$3"; _runtime="$4"
    _hs=$(bytes_of "$_hello"); _fs=$(bytes_of "$_fib")
    if [ "$_hs" = "n/a" ]; then _hh="n/a"; else _hh=$(human_bytes "$_hs"); fi
    if [ "$_fs" = "n/a" ]; then _fh="n/a"; else _fh=$(human_bytes "$_fs"); fi
    row "$_lang" "$_hh" "$_fh" "$_runtime"
}

_simple_rt="n/a"
if [ -x "$SIMPLE_BINARY" ]; then
    _sb=$(bytes_of "$(simple_runtime_path)")
    if [ "$_sb" != "n/a" ]; then _simple_rt=$(human_bytes "$_sb"); fi
fi

measure_size "Simple (interpreter)" "$BUILD_DIR/hello.spl" "$BUILD_DIR/fib.spl" "$_simple_rt"
measure_size "Simple (SMF loader)" "$BUILD_DIR/hello_simple.smf" "$BUILD_DIR/fib_simple.smf" "$_simple_rt"
measure_size "Simple (native)" "$BUILD_DIR/hello_simple_native" "$BUILD_DIR/fib_simple_native" "none"
measure_size "C (gcc -O2)" "$BUILD_DIR/hello_c" "$BUILD_DIR/fib_c" "libc"
have go && measure_size "Go" "$BUILD_DIR/fib_go" "$BUILD_DIR/fib_go" "none (static)"
have python3 && measure_size "Python" "$BUILD_DIR/fib.py" "$BUILD_DIR/fib.py" "$(python3 -c 'import sys;print(sys.executable)' 2>/dev/null || echo 'n/a')"
have bun && measure_size "Bun" "$BUILD_DIR/fib.js" "$BUILD_DIR/fib.js" "$(which bun 2>/dev/null || echo 'n/a')"
have java && measure_size "Java" "$BUILD_DIR/Fib.class" "$BUILD_DIR/Fib.class" "JRE"
have erl && measure_size "Erlang" "$BUILD_DIR/fib.beam" "$BUILD_DIR/fib.beam" "BEAM VM"

# ── Cold startup (hello world) ───────────────────────────────────────────

echo "=== Measuring cold startup ==="
section "Cold Startup — hello world ($RUNS runs avg)"
row "Language" "Avg (ms)" "Mode" "" "" >>"$REPORT_PATH"
sep

if [ -x "$SIMPLE_BINARY" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/hello.spl" "$RUNS")
    row "Simple (interpreter)" "$ms" "interpret" "" ""
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/hello_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/hello_simple.smf" "$RUNS")
    row "Simple (SMF loader)" "$ms" "smf" "" ""
fi
if [ -x "$BUILD_DIR/hello_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/hello_simple_native" "$RUNS")
    row "Simple (native)" "$ms" "native" "" ""
fi
if [ -x "$BUILD_DIR/hello_c" ]; then
    ms=$(avg_ms "$BUILD_DIR/hello_c" "$RUNS")
    row "C (gcc -O2)" "$ms" "native" "" ""
fi
if have go && [ -f "$BUILD_DIR/fib_go" ]; then
    ms=$(avg_ms "$BUILD_DIR/fib_go" "$RUNS")
    row "Go (compiled)" "$ms" "native" "" ""
fi
if have python3; then
    ms=$(avg_ms "python3 -c 'print(\"Hello World\")'" "$RUNS")
    row "Python" "$ms" "interpret" "" ""
fi
if have bun; then
    ms=$(avg_ms "bun $BUILD_DIR/fib.js" "$RUNS")
    row "Bun" "$ms" "JIT" "" ""
fi
if have java; then
    ms=$(avg_ms "java -cp $BUILD_DIR Fib" "$RUNS")
    row "Java" "$ms" "JIT (JVM)" "" ""
fi
if have erl; then
    ms=$(avg_ms "erl -noshell -pa $BUILD_DIR -eval 'fib:main([]).' -s init stop" "$RUNS")
    row "Erlang" "$ms" "BEAM VM" "" ""
fi

# ── Warm throughput — fib in-process ─────────────────────────────────────

echo "=== Measuring warm throughput — fib($FIB_N) in-process ==="
section "Warm Throughput — fib($FIB_N) in process ($WARM_IN_PROCESS warmup + $RUNS measured)"
printf "| %-22s | %12s | %40s |\n" "Language" "Avg (ms)" "Notes" >>"$REPORT_PATH"
printf "|%-24s|%14s|%42s|\n" "------------------------" "--------------" "------------------------------------------" >>"$REPORT_PATH"

warm_row() {
    printf "| %-22s | %12s | %40s |\n" "$1" "$2" "$3" >>"$REPORT_PATH"
}

# Simple interpreter/SMF: extern fn calls segfault in interpreter and SMF loader
# can't resolve time externs. Fall back to outer-process avg of fib.spl runs.
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/fib.spl" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/fib.spl" "$RUNS")
    warm_row "Simple (interpreter)" "$ms" "tree-walk (outer-process, no in-proc timing)"
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/fib_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/fib_simple.smf" "$RUNS")
    warm_row "Simple (SMF loader)" "$ms" "bytecode (outer-process, no in-proc timing)"
fi
# Simple native: in-process timing works via extern fn
if [ -x "$BUILD_DIR/fib_warm_simple_native" ]; then
    ms=$(extract_warm_ms "$BUILD_DIR/fib_warm_simple_native")
    warm_row "Simple (native)" "$ms" "AOT via Cranelift (in-process)"
fi
if [ -x "$BUILD_DIR/fib_warm_c" ]; then
    ms=$(extract_warm_ms "$BUILD_DIR/fib_warm_c")
    warm_row "C (gcc -O2)" "$ms" "baseline AOT"
fi
if [ -x "$BUILD_DIR/fib_warm_go" ]; then
    ms=$(extract_warm_ms "$BUILD_DIR/fib_warm_go")
    warm_row "Go" "$ms" "SSA AOT"
fi
if have python3; then
    ms=$(extract_warm_ms "python3 $BUILD_DIR/fib_warm.py")
    warm_row "Python" "$ms" "CPython bytecode"
fi
if have bun; then
    ms=$(extract_warm_ms "bun $BUILD_DIR/fib_warm.js")
    warm_row "Bun" "$ms" "JavaScriptCore JIT (steady-state)"
fi
if have java; then
    ms=$(extract_warm_ms "java -cp $BUILD_DIR FibWarm")
    warm_row "Java" "$ms" "HotSpot C2 JIT (steady-state)"
fi
if have erl; then
    ms=$(extract_warm_ms "erl -noshell -pa $BUILD_DIR -eval 'fib_warm:main([]).' -s init stop")
    warm_row "Erlang" "$ms" "BEAM (single-process)"
fi

# ── OS-thread parallel workers ───────────────────────────────────────────

echo "=== Measuring parallel — $WORKERS workers ==="
section "OS Thread Parallel Workers — spawn $WORKERS workers ($RUNS runs avg)"
printf "| %-22s | %12s | %40s |\n" "Language" "Avg (ms)" "Concurrency model" >>"$REPORT_PATH"
printf "|%-24s|%14s|%42s|\n" "------------------------" "--------------" "------------------------------------------" >>"$REPORT_PATH"

par_row() {
    printf "| %-22s | %12s | %40s |\n" "$1" "$2" "$3" >>"$REPORT_PATH"
}

par_row "Simple (interpreter)" "n/a" "extern thread FFI not supported"
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/parallel_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/parallel_simple.smf" "$RUNS")
    par_row "Simple (SMF loader)" "$ms" "std thread_spawn fork-join (bytecode)"
fi
if [ -x "$BUILD_DIR/parallel_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/parallel_simple_native" "$RUNS")
    par_row "Simple (native)" "$ms" "thread_spawn fork-join OS threads"
else
    par_row "Simple (native)" "n/a" "compile failed"
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/parallel_cooperative_green.spl" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY run $BUILD_DIR/parallel_cooperative_green.spl --mode=interpreter" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY run $BUILD_DIR/parallel_cooperative_green.spl --mode=interpreter")
        par_row "Simple cooperative green (interp)" "$ms" "cooperative_green_spawn_value cooperative queue ($reason)"
    else
        par_row "Simple cooperative green (interp)" "$ms" "cooperative_green_spawn_value cooperative queue"
    fi
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/parallel_cooperative_green_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/parallel_cooperative_green_simple.smf" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY $BUILD_DIR/parallel_cooperative_green_simple.smf")
        if [ "$reason" = "segfault" ]; then
            reason="SMF mutable-global runtime blocker"
        fi
        par_row "Simple cooperative green (SMF)" "$ms" "cooperative_green_spawn_value cooperative queue ($reason)"
    else
        par_row "Simple cooperative green (SMF)" "$ms" "cooperative_green_spawn_value cooperative queue"
    fi
fi
if [ -x "$BUILD_DIR/parallel_cooperative_green_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/parallel_cooperative_green_simple_native" "$RUNS")
    par_row "Simple cooperative green (native)" "$ms" "cooperative_green_spawn_value cooperative queue"
else
    par_row "Simple cooperative green (native)" "n/a" "compile failed"
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/parallel_multicore_green_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/parallel_multicore_green_simple.smf" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY $BUILD_DIR/parallel_multicore_green_simple.smf")
        par_row "Simple multicore green (SMF)" "$ms" "multicore_green runtime pool candidate ($reason)"
    else
        evidence=$(pool_evidence "$SIMPLE_BINARY $BUILD_DIR/parallel_multicore_green_simple.smf" "$MULTICORE_GREEN_WORKERS")
        par_row "Simple multicore green (SMF)" "$ms" "multicore_green runtime pool candidate ($evidence)"
    fi
fi
if [ -x "$BUILD_DIR/parallel_multicore_green_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/parallel_multicore_green_simple_native" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$BUILD_DIR/parallel_multicore_green_simple_native")
        par_row "Simple multicore green (native)" "$ms" "multicore_green runtime pool candidate ($reason)"
    else
        evidence=$(pool_evidence "$BUILD_DIR/parallel_multicore_green_simple_native" "$MULTICORE_GREEN_WORKERS")
        par_row "Simple multicore green (native)" "$ms" "multicore_green runtime pool candidate ($evidence)"
    fi
else
    par_row "Simple multicore green (native)" "n/a" "compile failed"
fi
if [ -x "$BUILD_DIR/parallel_c" ]; then
    ms=$(avg_ms "$BUILD_DIR/parallel_c" "$RUNS")
    par_row "C (pthreads)" "$ms" "OS threads"
fi
if [ -x "$BUILD_DIR/parallel_go" ]; then
    ms=$(avg_ms "$BUILD_DIR/parallel_go" "$RUNS")
    par_row "Go" "$ms" "goroutines + chan result (M:N)"
fi
if have python3; then
    ms=$(avg_ms "python3 $BUILD_DIR/parallel.py" "$RUNS")
    par_row "Python" "$ms" "threading (GIL)"
fi
if have bun; then
    ms=$(avg_ms "bun $BUILD_DIR/parallel.js" "$RUNS")
    par_row "Bun" "$ms" "worker_threads"
fi
if have java; then
    ms=$(avg_ms "java -cp $BUILD_DIR Parallel" "$RUNS")
    par_row "Java" "$ms" "ThreadPool"
fi
if have erl; then
    ms=$(avg_ms "erl -noshell -pa $BUILD_DIR -eval 'parallel:main([]).' -s init stop" "$RUNS")
    par_row "Erlang" "$ms" "lightweight processes"
fi

# ── Large fanout scheduling overhead ─────────────────────────────────────

echo "=== Measuring large fanout — $FANOUT_WORKERS workers ==="
section "Large Fanout Scheduling — spawn $FANOUT_WORKERS tiny workers ($RUNS runs avg)"
printf "| %-22s | %12s | %40s |\n" "Language" "Avg (ms)" "Concurrency model" >>"$REPORT_PATH"
printf "|%-24s|%14s|%42s|\n" "------------------------" "--------------" "------------------------------------------" >>"$REPORT_PATH"

fanout_row() {
    printf "| %-22s | %12s | %40s |\n" "$1" "$2" "$3" >>"$REPORT_PATH"
}

fanout_row "Simple (interpreter)" "n/a" "extern thread FFI not supported"
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/fanout_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/fanout_simple.smf" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY $BUILD_DIR/fanout_simple.smf")
        fanout_row "Simple (SMF loader)" "$ms" "std thread_spawn fanout ($reason)"
    else
        fanout_row "Simple (SMF loader)" "$ms" "std thread_spawn fanout"
    fi
elif echo "$COMPILE_FAIL_SMF" | grep -q 'smf:fanout(timeout)'; then
    fanout_row "Simple (SMF loader)" "n/a" "std thread_spawn fanout compile timeout"
fi
if [ -x "$BUILD_DIR/fanout_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/fanout_simple_native" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$BUILD_DIR/fanout_simple_native")
        fanout_row "Simple (native)" "$ms" "OS-thread fork-join fanout ($reason)"
    else
        fanout_row "Simple (native)" "$ms" "OS-thread fork-join fanout"
    fi
elif echo "$COMPILE_FAIL" | grep -q 'native:fanout(timeout)'; then
    fanout_row "Simple (native)" "n/a" "OS-thread fanout compile timeout"
else
    fanout_row "Simple (native)" "n/a" "compile failed"
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/fanout_cooperative_green.spl" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY run $BUILD_DIR/fanout_cooperative_green.spl --mode=interpreter" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY run $BUILD_DIR/fanout_cooperative_green.spl --mode=interpreter")
        fanout_row "Simple cooperative green (interp)" "$ms" "cooperative queue fanout ($reason)"
    else
        fanout_row "Simple cooperative green (interp)" "$ms" "cooperative queue fanout"
    fi
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/fanout_cooperative_green_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/fanout_cooperative_green_simple.smf" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY $BUILD_DIR/fanout_cooperative_green_simple.smf")
        if [ "$reason" = "segfault" ]; then
            reason="SMF mutable-global runtime blocker"
        fi
        fanout_row "Simple cooperative green (SMF)" "$ms" "cooperative queue fanout ($reason)"
    else
        fanout_row "Simple cooperative green (SMF)" "$ms" "cooperative queue fanout"
    fi
fi
if [ -x "$BUILD_DIR/fanout_cooperative_green_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/fanout_cooperative_green_simple_native" "$RUNS")
    fanout_row "Simple cooperative green (native)" "$ms" "cooperative queue fanout"
else
    fanout_row "Simple cooperative green (native)" "n/a" "compile failed"
fi
if [ -x "$SIMPLE_BINARY" ] && [ -f "$BUILD_DIR/fanout_multicore_green_simple.smf" ]; then
    ms=$(avg_ms "$SIMPLE_BINARY $BUILD_DIR/fanout_multicore_green_simple.smf" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$SIMPLE_BINARY $BUILD_DIR/fanout_multicore_green_simple.smf")
        fanout_row "Simple multicore green (SMF)" "$ms" "multicore_green runtime pool fanout ($reason)"
    else
        evidence=$(pool_evidence "$SIMPLE_BINARY $BUILD_DIR/fanout_multicore_green_simple.smf" "$FANOUT_MULTICORE_GREEN_WORKERS")
        fanout_row "Simple multicore green (SMF)" "$ms" "multicore_green runtime pool fanout ($evidence)"
    fi
elif echo "$COMPILE_FAIL_SMF" | grep -q 'smf:fanout_multicore_green(timeout)'; then
    fanout_row "Simple multicore green (SMF)" "n/a" "multicore_green runtime pool fanout compile timeout"
fi
if [ -x "$BUILD_DIR/fanout_multicore_green_simple_native" ]; then
    ms=$(avg_ms "$BUILD_DIR/fanout_multicore_green_simple_native" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$BUILD_DIR/fanout_multicore_green_simple_native")
        fanout_row "Simple multicore green (native)" "$ms" "multicore_green runtime pool fanout ($reason)"
    else
        evidence=$(pool_evidence "$BUILD_DIR/fanout_multicore_green_simple_native" "$FANOUT_MULTICORE_GREEN_WORKERS")
        fanout_row "Simple multicore green (native)" "$ms" "multicore_green runtime pool fanout ($evidence)"
    fi
elif echo "$COMPILE_FAIL" | grep -q 'native:fanout_multicore_green(timeout)'; then
    fanout_row "Simple multicore green (native)" "n/a" "multicore_green runtime pool fanout compile timeout"
else
    fanout_row "Simple multicore green (native)" "n/a" "compile failed"
fi
if [ -x "$BUILD_DIR/fanout_c" ]; then
    ms=$(avg_ms "$BUILD_DIR/fanout_c" "$RUNS")
    if [ "$ms" = "fail" ]; then
        reason=$(failure_reason "$BUILD_DIR/fanout_c")
        fanout_row "C (pthreads)" "$ms" "one OS thread per tiny task ($reason)"
    else
        fanout_row "C (pthreads)" "$ms" "one OS thread per tiny task"
    fi
fi
if [ -x "$BUILD_DIR/fanout_go" ]; then
    ms=$(avg_ms "$BUILD_DIR/fanout_go" "$RUNS")
    fanout_row "Go" "$ms" "goroutine per tiny task + channel"
fi
if have python3; then
    ms=$(avg_ms "python3 $BUILD_DIR/fanout.py" "$RUNS")
    fanout_row "Python" "$ms" "threading per tiny task (GIL)"
fi
if have bun; then
    ms=$(avg_ms "bun $BUILD_DIR/fanout.js" "$RUNS")
    fanout_row "Bun" "$ms" "worker_thread per tiny task"
fi
if have java; then
    ms=$(avg_ms "java -cp $BUILD_DIR Fanout" "$RUNS")
    fanout_row "Java" "$ms" "cached ThreadPool future per tiny task"
fi
if have erl; then
    ms=$(avg_ms "erl -noshell -pa $BUILD_DIR -eval 'fanout:main([]).' -s init stop" "$RUNS")
    fanout_row "Erlang" "$ms" "BEAM process per tiny task"
fi

# ── Simple-vs-Go-vs-C large fanout stress ────────────────────────────────

echo "=== Measuring Simple-vs-Go-vs-C large fanout stress — $FANOUT_STRESS_WORKERS workers ==="
section "Simple vs Go vs C Large Fanout Stress — spawn $FANOUT_STRESS_WORKERS tiny workers ($RUNS runs avg)"
printf "| %-22s | %12s | %40s |\n" "Language" "Avg (ms)" "Concurrency model" >>"$REPORT_PATH"
printf "|%-24s|%14s|%42s|\n" "------------------------" "--------------" "------------------------------------------" >>"$REPORT_PATH"

stress_row() {
    printf "| %-22s | %12s | %40s |\n" "$1" "$2" "$3" >>"$REPORT_PATH"
}

if [ -x "$BUILD_DIR/fanout_stress_c" ]; then
