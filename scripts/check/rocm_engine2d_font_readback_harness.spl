# Engine2D configured-font ROCm readback harness.
# The wrapper labels mock versus real execution; this program only reports
# the public Engine2D route and exact CPU-oracle result.

use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.text_layout.font_renderer.{FontExecutionPolicy, FontRenderConfig}
use std.gc_async_mut.io.rocm_sffi.{
    rt_rocm_get_device, rt_rocm_device_identity, rt_rocm_device_memory, rt_rocm_device_name
}

val WIDTH: i32 = 96
val HEIGHT: i32 = 40
val FONT_PATH = "assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf"

fn font_config(target: text) -> FontRenderConfig:
    FontRenderConfig(
        family: "Noto Sans Mono", category: "mono", language: "en", script: "latn", size: 18,
        weight: "normal", style: "normal", hinting: "none", antialiasing: "grayscale",
        atlas_policy: "shared-alpha-1024", execution_target: target,
        execution_policy: FontExecutionPolicy.Required
    )

fn pixel_checksum(pixels: [u32]) -> i64:
    var sum: i64 = 0
    var index: i64 = 0
    while index < pixels.len():
        sum = sum + pixels[index].to_i64() * (index + 1)
        index = index + 1
    sum

fn fail_evidence(reason: text) -> i64:
    print("status=fail")
    print("reason=" + reason)
    1

fn main() -> i64:
    val rocm_result = Engine2D.create_with_backend_strict(WIDTH, HEIGHT, "rocm")
    if not rocm_result.is_ok():
        return fail_evidence("strict-rocm-create-failed")
    var rocm = rocm_result.unwrap()
    if rocm.backend_name() != "rocm":
        rocm.shutdown()
        return fail_evidence("strict-rocm-backend-mismatch")
    if not rocm.load_font(FONT_PATH):
        rocm.shutdown()
        return fail_evidence("font-load-failed")
    val rocm_drawn = rocm.draw_text_configured(
        4, 4, "Simple 2D", 0xffc08040u32, font_config("rocm")
    )
    val attempts = rocm.font_execution_attempts()
    val target = rocm.font_execution_target()
    # Read before present so a pass must be a fresh device readback, not a host cache.
    val readback = rocm.read_pixels_with_source()

    val cpu_result = Engine2D.create_with_backend_strict(WIDTH, HEIGHT, "cpu")
    if not cpu_result.is_ok():
        rocm.shutdown()
        return fail_evidence("strict-cpu-create-failed")
    var cpu = cpu_result.unwrap()
    if not cpu.load_font(FONT_PATH):
        cpu.shutdown()
        rocm.shutdown()
        return fail_evidence("cpu-font-load-failed")
    val cpu_drawn = cpu.draw_text_configured(
        4, 4, "Simple 2D", 0xffc08040u32, font_config("cpu")
    )
    val cpu_pixels = cpu.read_pixels()

    var nonblank: i64 = 0
    var mismatches: i64 = 0
    var index: i64 = 0
    while index < readback.pixels.len():
        if readback.pixels[index] != 0u32:
            nonblank = nonblank + 1
        if index >= cpu_pixels.len() or readback.pixels[index] != cpu_pixels[index]:
            mismatches = mismatches + 1
        index = index + 1
    if cpu_pixels.len() > readback.pixels.len():
        mismatches = mismatches + cpu_pixels.len() - readback.pixels.len()

    val device = rt_rocm_get_device()
    val device_name = if device >= 0: rt_rocm_device_name(device) else: ""
    val device_memory = if device >= 0: rt_rocm_device_memory(device) else: 0
    val device_identity = if device >= 0: rt_rocm_device_identity(device) else: 0
    val device_checksum = pixel_checksum(readback.pixels)
    val cpu_checksum = pixel_checksum(cpu_pixels)
    val attempts_ok = attempts.len() == 1 and attempts[0] == "rocm:success"
    val attempts_text = if attempts_ok: "rocm:success" else: "unexpected"
    val passed = (rocm_drawn and cpu_drawn and attempts_ok and target == "rocm" and
        readback.source == "device_readback" and readback.backend_handle > 0 and
        readback.device_identity > 0 and readback.device_identity == device_identity and
        readback.pixel_count == WIDTH.to_i64() * HEIGHT.to_i64() and
        device_name != "" and device_memory > 0 and nonblank > 0 and
        device_checksum > 0 and device_checksum == cpu_checksum and mismatches == 0)

    print("backend_name=" + rocm.backend_name())
    print("font_path=" + FONT_PATH)
    print("font_loaded=true")
    print("draw_configured=" + rocm_drawn.to_text())
    print("execution_target=" + target)
    print("attempts=" + attempts_text)
    print("readback_source=" + readback.source)
    print("readback_handle=" + readback.backend_handle.to_text())
    print("device_identity=" + readback.device_identity.to_text())
    print("device_name=" + device_name)
    print("device_memory=" + device_memory.to_text())
    print("pixel_count=" + readback.pixel_count.to_text())
    print("nonblank_pixel_count=" + nonblank.to_text())
    print("device_checksum=" + device_checksum.to_text())
    print("cpu_checksum=" + cpu_checksum.to_text())
    print("mismatch_count=" + mismatches.to_text())
    cpu.shutdown()
    rocm.shutdown()
    if not passed:
        return fail_evidence("configured-font-readback-mismatch")
    print("status=pass")
    print("reason=configured-font-device-readback-matches-cpu")
    0
