#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/../.." && pwd)"
BUILD_DIR="$ROOT_DIR/build/electron_mdi_evidence"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT_DIR/src/compiler_rust/target/release/simple}"
ENTRY="$ROOT_DIR/examples/06_io/ui/electron_wm.spl"
VALIDATOR="$ROOT_DIR/scripts/check/validate-electron-mdi-proof.js"
PROOF_PATH="$BUILD_DIR/electron_mdi_proof.json"
SCREENSHOT_PATH="$BUILD_DIR/electron_mdi.png"
LOG_PATH="$BUILD_DIR/electron_mdi.log"
TIMEOUT_SECS="${ELECTRON_MDI_TIMEOUT_SECS:-60}"

mkdir -p "$BUILD_DIR"
rm -f "$PROOF_PATH" "$SCREENSHOT_PATH"

fail() {
    echo "status=fail"
    echo "reason=$1"
    exit 1
}

command -v node >/dev/null 2>&1 || fail "node not found"
command -v npm >/dev/null 2>&1 || fail "npm not found"
command -v xvfb-run >/dev/null 2>&1 || fail "xvfb-run not found"
test -x "$SIMPLE_BIN" || fail "host Simple runtime missing: $SIMPLE_BIN"
test -f "$ENTRY" || fail "Electron MDI entry missing: $ENTRY"
test -f "$VALIDATOR" || fail "Electron MDI proof validator missing: $VALIDATOR"

if [ ! -x "$ROOT_DIR/tools/electron-shell/node_modules/.bin/electron" ] \
    && [ ! -x "$ROOT_DIR/tools/electron-shell/node_modules/electron/dist/electron" ]; then
    fail "Electron dependency missing under tools/electron-shell/node_modules"
fi

if command -v timeout >/dev/null 2>&1; then
    timeout "$TIMEOUT_SECS" xvfb-run -a --server-args="-screen 0 1280x720x24" \
        env SIMPLE_ELECTRON_MDI_PROOF_PATH="$PROOF_PATH" \
            SIMPLE_ELECTRON_MDI_SCREENSHOT_PATH="$SCREENSHOT_PATH" \
            npm --prefix "$ROOT_DIR/tools/electron-shell" exec -- electron --no-sandbox "$ROOT_DIR/tools/electron-shell" \
            --simple-bin "$SIMPLE_BIN" --entry "$ENTRY" > "$LOG_PATH" 2>&1 \
        || fail "Electron MDI proof run failed; see $LOG_PATH"
else
    xvfb-run -a --server-args="-screen 0 1280x720x24" \
        env SIMPLE_ELECTRON_MDI_PROOF_PATH="$PROOF_PATH" \
            SIMPLE_ELECTRON_MDI_SCREENSHOT_PATH="$SCREENSHOT_PATH" \
            npm --prefix "$ROOT_DIR/tools/electron-shell" exec -- electron --no-sandbox "$ROOT_DIR/tools/electron-shell" \
            --simple-bin "$SIMPLE_BIN" --entry "$ENTRY" > "$LOG_PATH" 2>&1 \
        || fail "Electron MDI proof run failed; see $LOG_PATH"
fi

test -s "$PROOF_PATH" || fail "Electron MDI proof missing: $PROOF_PATH"
test -s "$SCREENSHOT_PATH" || fail "Electron MDI screenshot missing: $SCREENSHOT_PATH"

node "$VALIDATOR" "$PROOF_PATH" "$SCREENSHOT_PATH" || fail "electron-mdi-json-proof-failed"

"$SIMPLE_BIN" run "$ROOT_DIR/scripts/check/ios_mdi_probe_server.spl" --mode=interpreter --validate-screenshot \
    "$SCREENSHOT_PATH" electron_mdi_screenshot
"$SIMPLE_BIN" run "$ROOT_DIR/scripts/check/ios_mdi_probe_server.spl" --mode=interpreter --validate-electron-mdi-screenshot \
    "$SCREENSHOT_PATH"

echo "electron_mdi_screenshot=$SCREENSHOT_PATH"
echo "electron_mdi_proof=$PROOF_PATH"
echo "status=pass"
