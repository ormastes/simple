#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/tmp/macos_gui_live_window_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/macos_gui_live_window_evidence_$(date -u +%F).md}"
SAMPLE_SPL="${MACOS_GUI_LIVE_WINDOW_SAMPLE:-src/app/ui_shared_mdi/live_window.spl}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass
if [ -z "${SIMPLE_BIN+x}" ]; then
    SIMPLE_BIN=""
    SIMPLE_BIN_SOURCE=auto-self-hosted
    for _cand in bin/simple ./bin/simple release/*/simple bin/release/*/simple build/bootstrap/stage3/simple; do
        if [ -x "$_cand" ]; then
            SIMPLE_BIN="$_cand"
            break
        fi
    done
fi

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|./src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [ -z "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS
CAPTURE_PNG="$BUILD_DIR/simplegui-window.png"
CAPTURE_BMP="$BUILD_DIR/simplegui-window.bmp"
EVIDENCE_ENV="$BUILD_DIR/evidence.env"
LAUNCH_LOG="$BUILD_DIR/launch.log"
WINDOW_INFO="$BUILD_DIR/window.env"
EVENT_EVIDENCE="$BUILD_DIR/native-events.env"
LIVE_ARTIFACT="${MACOS_GUI_LIVE_WINDOW_ARTIFACT:-$BUILD_DIR/shared-mdi-live-window.smf}"
LIVE_ARTIFACT_LOG="$BUILD_DIR/live-artifact-compile.out"
LIVE_LAUNCH_INPUT="$SAMPLE_SPL"
LIVE_ARTIFACT_STATUS=not-run
LIVE_ARTIFACT_BYTES=0
TIMEOUT_SECS="${MACOS_GUI_LIVE_WINDOW_TIMEOUT_SECS:-45}"
SIMPLE_GUI_DYNLIB_ARTIFACT="${SIMPLE_GUI_DYNLIB_ARTIFACT:-build/gui/pure_gui_hot.smf}"
gui_smf_artifact_contract_out="$BUILD_DIR/gui-smf-artifact-contract.out"
mdi_titlebar_contract_out="$BUILD_DIR/shared-mdi-titlebar-contract.out"
gui_smf_artifact_contract_row="GUI_SMF_ARTIFACT_CONTRACT status=missing artifact=$SIMPLE_GUI_DYNLIB_ARTIFACT sha256= size=0 smf_role=-1 arch=0 embedded_dynlib=false symbol=${SIMPLE_GUI_DYNLIB_SYMBOL:-gui_dynlib_hot_probe_tick} qemu_status=not-run qemu_reason=live-qemu-not-executed macos_status=not-run macos_reason=requires-macos-arm64"
gui_smf_artifact_contract_status=missing
mdi_titlebar_contract_status=missing
mdi_titlebar_button_markup_present=false
mdi_titlebar_input_markup_present=false
mdi_body_button_markup_present=false
mdi_body_input_markup_present=false
mdi_titlebar_css_present=false
capture_titlebar_css_pixels=0
capture_titlebar_widget_fill_pixels=0
capture_titlebar_widget_accent_pixels=0
capture_titlebar_widget_text_pixels=0
capture_completed_event_counter_pixels=0
event_focus=false
event_keyboard_events=0
event_pointer_events=0
event_click_events=0
event_titlebar_click_events=0
event_body_click_events=0

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$CAPTURE_PNG" "$CAPTURE_BMP" "$EVIDENCE_ENV" "$LAUNCH_LOG" "$WINDOW_INFO" "$EVENT_EVIDENCE" "$REPORT_PATH" "$gui_smf_artifact_contract_out" "$mdi_titlebar_contract_out" "$LIVE_ARTIFACT_LOG"

append_env() {
    env_key="$1"
    env_value="$2"
    echo "$env_key=$env_value" >>"$EVIDENCE_ENV"
}

file_byte_count() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

file_cksum_value() {
    if [ -f "$1" ]; then
        cksum "$1" | sed 's/ .*//'
    else
        echo 0
    fi
}

host_os_name() {
    case "$(uname -s)" in
        Darwin) echo "macos" ;;
        Linux) echo "linux" ;;
        *) uname -s | tr '[:upper:]' '[:lower:]' ;;
    esac
}

write_report() {
    {
        echo "# macOS GUI Live Window Evidence"
        echo
        echo "- GUI SMF artifact contract status: $gui_smf_artifact_contract_status"
        echo "- GUI SMF artifact contract row: $gui_smf_artifact_contract_row"
        echo "- GUI SMF artifact contract scope: contract-only; does not promote live macOS window evidence"
        echo "- Shared MDI titlebar contract status: $mdi_titlebar_contract_status"
        echo "- Shared MDI titlebar sample: $SAMPLE_SPL"
        echo "- Native event focus: $event_focus"
        echo "- Native keyboard events: $event_keyboard_events"
        echo "- Native pointer events: $event_pointer_events"
        echo "- Native click events: $event_click_events"
        echo "- Native titlebar-control clicks: $event_titlebar_click_events"
        echo "- Native body-control clicks: $event_body_click_events"
        echo "- Rendered completed-event counter pixels: $capture_completed_event_counter_pixels"
        echo
        echo "## Raw Evidence"
        echo
        sed 's/^/- /' "$EVIDENCE_ENV"
        if [ -f "$gui_smf_artifact_contract_out" ]; then
            echo
            echo "## GUI SMF Artifact Contract Output"
            sed 's/^/- /' "$gui_smf_artifact_contract_out"
        fi
        if [ -f "$mdi_titlebar_contract_out" ]; then
            echo
            echo "## Shared MDI Titlebar Contract Output"
            sed 's/^/- /' "$mdi_titlebar_contract_out"
        fi
        if [ -f "$LIVE_ARTIFACT_LOG" ]; then
            echo
            echo "## Live Artifact Compile Output"
            sed 's/^/- /' "$LIVE_ARTIFACT_LOG"
        fi
    } >"$REPORT_PATH"
}

run_gui_smf_artifact_contract() {
    if [ -n "$SIMPLE_GUI_DYNLIB_ARTIFACT" ]; then
        set +e
        SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" run src/app/gui_perf/smf_artifact_contract.spl --mode=interpreter --clean >"$gui_smf_artifact_contract_out" 2>&1
        set -e
        gui_smf_artifact_contract_row="$(sed -n '/^GUI_SMF_ARTIFACT_CONTRACT /p' "$gui_smf_artifact_contract_out" | tail -n 1)"
        if [ -z "$gui_smf_artifact_contract_row" ]; then
            gui_smf_artifact_contract_row="GUI_SMF_ARTIFACT_CONTRACT status=fail artifact=${SIMPLE_GUI_DYNLIB_ARTIFACT:-} sha256= size=0 smf_role=-1 arch=0 embedded_dynlib=false symbol=${SIMPLE_GUI_DYNLIB_SYMBOL:-gui_dynlib_hot_probe_tick} qemu_status=not-run qemu_reason=live-qemu-not-executed macos_status=not-run macos_reason=requires-macos-arm64"
        fi
        gui_smf_artifact_contract_status="$(printf '%s\n' "$gui_smf_artifact_contract_row" | sed -n 's/^GUI_SMF_ARTIFACT_CONTRACT status=\([^ ]*\).*/\1/p' | tail -n 1)"
        if [ -z "$gui_smf_artifact_contract_status" ]; then
            gui_smf_artifact_contract_status=fail
        fi
    fi
}

mark_gui_smf_macos_pass_if_ready() {
    if [ "$gui_smf_artifact_contract_status" = pass ]; then
        gui_smf_artifact_contract_row="$(printf '%s\n' "$gui_smf_artifact_contract_row" | sed 's/ macos_status=[^ ]*/ macos_status=pass/; s/ macos_reason=[^ ]*/ macos_reason=live-macos-window-artifact-verified/')"
    fi
}

extract_probe_field() {
    field_name="$1"
    sed -n "s/^$field_name=//p" "$mdi_titlebar_contract_out" | tail -n 1
}

run_mdi_titlebar_contract() {
    set +e
    SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" run src/app/ui_shared_mdi/titlebar_contract_probe.spl --mode=interpreter --clean >"$mdi_titlebar_contract_out" 2>&1
    probe_code=$?
    set -e
    if [ "$probe_code" -ne 0 ]; then
        mdi_titlebar_contract_status=fail
        return
    fi
    mdi_titlebar_contract_status="$(extract_probe_field shared_mdi_titlebar_contract_status)"
    mdi_titlebar_button_markup_present="$(extract_probe_field shared_mdi_titlebar_contract_titlebar_button_markup_present)"
    mdi_titlebar_input_markup_present="$(extract_probe_field shared_mdi_titlebar_contract_titlebar_input_markup_present)"
    mdi_body_button_markup_present="$(extract_probe_field shared_mdi_titlebar_contract_body_button_markup_present)"
    mdi_body_input_markup_present="$(extract_probe_field shared_mdi_titlebar_contract_body_input_markup_present)"
    mdi_titlebar_css_present="$(extract_probe_field shared_mdi_titlebar_contract_titlebar_css_present)"
    if [ -z "$mdi_titlebar_contract_status" ]; then mdi_titlebar_contract_status=fail; fi
    if [ -z "$mdi_titlebar_button_markup_present" ]; then mdi_titlebar_button_markup_present=false; fi
    if [ -z "$mdi_titlebar_input_markup_present" ]; then mdi_titlebar_input_markup_present=false; fi
    if [ -z "$mdi_body_button_markup_present" ]; then mdi_body_button_markup_present=false; fi
    if [ -z "$mdi_body_input_markup_present" ]; then mdi_body_input_markup_present=false; fi
    if [ -z "$mdi_titlebar_css_present" ]; then mdi_titlebar_css_present=false; fi
}

append_mdi_titlebar_contract_env() {
    append_env "macos_gui_live_window_evidence_simple_bin" "$SIMPLE_BIN"
    append_env "macos_gui_live_window_evidence_simple_bin_source" "$SIMPLE_BIN_SOURCE"
    append_env "macos_gui_live_window_evidence_simple_bin_status" "$SIMPLE_BIN_STATUS"
    append_env "macos_gui_live_window_evidence_sample" "$SAMPLE_SPL"
    append_env "macos_gui_live_window_evidence_launch_input" "$LIVE_LAUNCH_INPUT"
    append_env "macos_gui_live_window_evidence_live_artifact" "$LIVE_ARTIFACT"
    append_env "macos_gui_live_window_evidence_live_artifact_status" "$LIVE_ARTIFACT_STATUS"
    append_env "macos_gui_live_window_evidence_live_artifact_bytes" "$LIVE_ARTIFACT_BYTES"
    append_env "macos_gui_live_window_evidence_mdi_titlebar_contract_status" "$mdi_titlebar_contract_status"
    append_env "macos_gui_live_window_evidence_mdi_titlebar_button_markup_present" "$mdi_titlebar_button_markup_present"
    append_env "macos_gui_live_window_evidence_mdi_titlebar_input_markup_present" "$mdi_titlebar_input_markup_present"
    append_env "macos_gui_live_window_evidence_mdi_body_button_markup_present" "$mdi_body_button_markup_present"
    append_env "macos_gui_live_window_evidence_mdi_body_input_markup_present" "$mdi_body_input_markup_present"
    append_env "macos_gui_live_window_evidence_mdi_titlebar_css_present" "$mdi_titlebar_css_present"
    append_env "macos_gui_live_window_evidence_event_focus" "$event_focus"
    append_env "macos_gui_live_window_evidence_event_keyboard_events" "$event_keyboard_events"
    append_env "macos_gui_live_window_evidence_event_pointer_events" "$event_pointer_events"
    append_env "macos_gui_live_window_evidence_event_click_events" "$event_click_events"
    append_env "macos_gui_live_window_evidence_event_titlebar_click_events" "$event_titlebar_click_events"
    append_env "macos_gui_live_window_evidence_event_body_click_events" "$event_body_click_events"
}

prepare_live_artifact() {
    case "$SAMPLE_SPL" in
        *.smf)
            LIVE_ARTIFACT="$SAMPLE_SPL"
            LIVE_LAUNCH_INPUT="$SAMPLE_SPL"
            LIVE_ARTIFACT_BYTES="$(file_byte_count "$SAMPLE_SPL")"
            if [ "$LIVE_ARTIFACT_BYTES" -le 300 ]; then
                LIVE_ARTIFACT_STATUS=invalid
                return 1
            fi
            LIVE_ARTIFACT_STATUS=provided
            return 0
            ;;
        *.spl) ;;
        *)
            LIVE_ARTIFACT_STATUS=invalid-source
            return 1
            ;;
    esac

    artifact_tmp="$LIVE_ARTIFACT.tmp.$$"
    mkdir -p "$(dirname -- "$LIVE_ARTIFACT")"
    rm -f "$artifact_tmp"
    set +e
    "$SIMPLE_BIN" compile --format=smf "$SAMPLE_SPL" -o "$artifact_tmp" >"$LIVE_ARTIFACT_LOG" 2>&1
    compile_code=$?
    set -e
    if [ "$compile_code" -ne 0 ] || [ ! -f "$artifact_tmp" ]; then
        rm -f "$artifact_tmp"
        LIVE_ARTIFACT_STATUS=compile-failed
        return 1
    fi
    LIVE_ARTIFACT_BYTES="$(file_byte_count "$artifact_tmp")"
    if [ "$LIVE_ARTIFACT_BYTES" -le 300 ]; then
        rm -f "$artifact_tmp"
        LIVE_ARTIFACT_STATUS=invalid
        return 1
    fi
    mv "$artifact_tmp" "$LIVE_ARTIFACT"
    LIVE_LAUNCH_INPUT="$LIVE_ARTIFACT"
    LIVE_ARTIFACT_STATUS=compiled
    return 0
}

emit_skip() {
    append_env "macos_gui_live_window_evidence_status" "skip"
    append_env "macos_gui_live_window_evidence_reason" "requires-macos"
    append_env "macos_gui_live_window_evidence_host_os" "$(host_os_name)"
    append_env "macos_gui_live_window_evidence_launcher" "macos-gui-run"
    append_mdi_titlebar_contract_env
    append_env "macos_gui_live_window_evidence_window_found" "false"
    append_env "macos_gui_live_window_evidence_window_title" ""
    append_env "macos_gui_live_window_evidence_window_rect" ""
    append_env "macos_gui_live_window_evidence_capture_path" ""
    append_env "macos_gui_live_window_evidence_capture_bytes" "0"
    append_env "macos_gui_live_window_evidence_capture_cksum" "0"
    append_env "macos_gui_live_window_evidence_capture_width" "0"
    append_env "macos_gui_live_window_evidence_capture_height" "0"
    append_env "macos_gui_live_window_evidence_capture_total_pixels" "0"
    append_env "macos_gui_live_window_evidence_non_background_pixels" "0"
    append_env "macos_gui_live_window_evidence_non_background_ratio" "0.000000"
    append_env "macos_gui_live_window_evidence_titlebar_css_pixels" "$capture_titlebar_css_pixels"
    append_env "macos_gui_live_window_evidence_titlebar_widget_fill_pixels" "$capture_titlebar_widget_fill_pixels"
    append_env "macos_gui_live_window_evidence_titlebar_widget_accent_pixels" "$capture_titlebar_widget_accent_pixels"
    append_env "macos_gui_live_window_evidence_titlebar_widget_text_pixels" "$capture_titlebar_widget_text_pixels"
    append_env "macos_gui_live_window_evidence_completed_event_counter_pixels" "$capture_completed_event_counter_pixels"
    append_env "macos_gui_live_window_evidence_release_gate" "live-macos-window-visual-proof"
    append_env "macos_gui_live_window_evidence_release_gate_status" "not-satisfied"
    append_env "macos_gui_live_window_evidence_gui_smf_artifact_contract_status" "$gui_smf_artifact_contract_status"
    append_env "macos_gui_live_window_evidence_gui_smf_artifact_contract_row" "$gui_smf_artifact_contract_row"
    append_env "macos_gui_live_window_evidence_report_path" "$REPORT_PATH"
    write_report
    cat "$EVIDENCE_ENV"
}

emit_fail() {
    fail_reason="$1"
    append_env "macos_gui_live_window_evidence_status" "fail"
    append_env "macos_gui_live_window_evidence_reason" "$fail_reason"
    append_env "macos_gui_live_window_evidence_host_os" "$(host_os_name)"
    append_env "macos_gui_live_window_evidence_launcher" "macos-gui-run"
    append_mdi_titlebar_contract_env
    append_env "macos_gui_live_window_evidence_window_found" "false"
    append_env "macos_gui_live_window_evidence_window_title" ""
    append_env "macos_gui_live_window_evidence_window_rect" ""
    append_env "macos_gui_live_window_evidence_capture_path" "$CAPTURE_PNG"
    append_env "macos_gui_live_window_evidence_capture_bytes" "$(file_byte_count "$CAPTURE_PNG")"
    append_env "macos_gui_live_window_evidence_capture_cksum" "$(file_cksum_value "$CAPTURE_PNG")"
    append_env "macos_gui_live_window_evidence_capture_width" "0"
    append_env "macos_gui_live_window_evidence_capture_height" "0"
    append_env "macos_gui_live_window_evidence_capture_total_pixels" "0"
    append_env "macos_gui_live_window_evidence_non_background_pixels" "0"
    append_env "macos_gui_live_window_evidence_non_background_ratio" "0.000000"
    append_env "macos_gui_live_window_evidence_titlebar_css_pixels" "$capture_titlebar_css_pixels"
    append_env "macos_gui_live_window_evidence_titlebar_widget_fill_pixels" "$capture_titlebar_widget_fill_pixels"
    append_env "macos_gui_live_window_evidence_titlebar_widget_accent_pixels" "$capture_titlebar_widget_accent_pixels"
    append_env "macos_gui_live_window_evidence_titlebar_widget_text_pixels" "$capture_titlebar_widget_text_pixels"
    append_env "macos_gui_live_window_evidence_completed_event_counter_pixels" "$capture_completed_event_counter_pixels"
    append_env "macos_gui_live_window_evidence_release_gate" "live-macos-window-visual-proof"
    append_env "macos_gui_live_window_evidence_release_gate_status" "not-satisfied"
    append_env "macos_gui_live_window_evidence_gui_smf_artifact_contract_status" "$gui_smf_artifact_contract_status"
    append_env "macos_gui_live_window_evidence_gui_smf_artifact_contract_row" "$gui_smf_artifact_contract_row"
    append_env "macos_gui_live_window_evidence_report_path" "$REPORT_PATH"
    write_report
    cat "$EVIDENCE_ENV"
    exit 1
}

cleanup_macos_app() {
    osascript -e 'tell application "SimpleGui" to quit' >/dev/null 2>&1 || true
    pkill -x SimpleGui >/dev/null 2>&1 || true
}

if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    emit_fail "simple-bin-$SIMPLE_BIN_STATUS"
fi

run_gui_smf_artifact_contract
run_mdi_titlebar_contract

if [ "$mdi_titlebar_contract_status" != "pass" ]; then
    emit_fail "mdi-titlebar-contract-failed"
fi

if [ "$(uname -s)" != "Darwin" ]; then
    emit_skip
    exit 0
fi

trap cleanup_macos_app EXIT

if [ ! -f "$SAMPLE_SPL" ]; then
    emit_fail "missing-sample"
fi

if ! prepare_live_artifact; then
    emit_fail "live-artifact-compile-failed"
fi

set +e
# This gate owns bounded window discovery below. Disable the launcher's
# best-effort AppleScript nudge so an Accessibility prompt or unavailable
# window cannot block before TIMEOUT_SECS starts.
SIMPLE_GUI_RUN_SKIP_NUDGE=1 SIMPLE_GUI_EVENT_EVIDENCE_PATH="$EVENT_EVIDENCE" SIMPLE_LIB="${SIMPLE_LIB:-src}" SIMPLE_TIMEOUT_SECONDS="${SIMPLE_TIMEOUT_SECONDS:-120}" \
    bash scripts/gui/macos-gui-run.shs "$LIVE_LAUNCH_INPUT" >"$LAUNCH_LOG" 2>&1
launch_code=$?
set -e
if [ "$launch_code" -ne 0 ]; then
    cat "$LAUNCH_LOG" >&2 || true
    emit_fail "launcher-failed"
fi

deadline=$(($(date +%s) + TIMEOUT_SECS))
while [ "$(date +%s)" -lt "$deadline" ]; do
    if osascript >"$WINDOW_INFO" 2>/dev/null <<'OSA'; then
tell application "System Events"
  repeat with proc in (processes whose name is "SimpleGui")
    tell proc
      if (count of windows) > 0 then
        set p to position of window 1
        set s to size of window 1
        set AppleScript's text item delimiters to ","
        return (item 1 of p as text) & "," & (item 2 of p as text) & "," & (item 1 of s as text) & "," & (item 2 of s as text)
      end if
    end tell
  end repeat
end tell
error "SimpleGui window not ready"
OSA
        break
    fi
    sleep 1
done

if [ ! -s "$WINDOW_INFO" ]; then
    emit_fail "window-not-found"
fi

window_rect="$(tr -d '\r\n ' <"$WINDOW_INFO")"
case "$window_rect" in
    *,*,*,*) ;;
    *) emit_fail "invalid-window-rect" ;;
esac

old_ifs=$IFS
IFS=,
set -- $window_rect
IFS=$old_ifs
window_x="${1:-0}"
window_y="${2:-0}"
if ! osascript - "$window_x" "$window_y" >/dev/null 2>&1 <<'OSA'; then
on run argv
  set wx to (item 1 of argv) as integer
  set wy to (item 2 of argv) as integer
  tell application "System Events"
    tell process "SimpleGui" to set frontmost to true
    delay 0.2
    click at {wx + 500, wy + 95}
    keystroke "g"
    click at {wx + 80, wy + 235}
  end tell
end run
OSA
    emit_fail "event-focus-failed"
fi
event_focus=true

event_deadline=$(($(date +%s) + 5))
while [ "$(date +%s)" -lt "$event_deadline" ]; do
    if [ -s "$EVENT_EVIDENCE" ]; then
        event_keyboard_events="$(sed -n 's/^keyboard_events=//p' "$EVENT_EVIDENCE" | tail -1)"
        event_pointer_events="$(sed -n 's/^pointer_events=//p' "$EVENT_EVIDENCE" | tail -1)"
        event_click_events="$(sed -n 's/^click_events=//p' "$EVENT_EVIDENCE" | tail -1)"
        event_titlebar_click_events="$(sed -n 's/^titlebar_click_events=//p' "$EVENT_EVIDENCE" | tail -1)"
        event_body_click_events="$(sed -n 's/^body_click_events=//p' "$EVENT_EVIDENCE" | tail -1)"
        event_keyboard_events="${event_keyboard_events:-0}"
        event_pointer_events="${event_pointer_events:-0}"
        event_click_events="${event_click_events:-0}"
        event_titlebar_click_events="${event_titlebar_click_events:-0}"
        event_body_click_events="${event_body_click_events:-0}"
        if [ "$event_keyboard_events" -gt 0 ] && [ "$event_pointer_events" -gt 0 ] && [ "$event_click_events" -gt 0 ] && [ "$event_titlebar_click_events" -gt 0 ] && [ "$event_body_click_events" -gt 0 ]; then
            break
        fi
    fi
    sleep 1
done

if [ "$event_keyboard_events" -le 0 ]; then
    emit_fail "event-keyboard-missing"
fi
if [ "$event_pointer_events" -le 0 ]; then
    emit_fail "event-pointer-missing"
fi
if [ "$event_click_events" -le 0 ]; then
    emit_fail "event-click-missing"
fi
if [ "$event_titlebar_click_events" -le 0 ]; then
    emit_fail "event-titlebar-control-click-missing"
fi
if [ "$event_body_click_events" -le 0 ]; then
    emit_fail "event-body-control-click-missing"
fi

if ! screencapture -x -R"$window_rect" "$CAPTURE_PNG" >/dev/null 2>&1; then
    emit_fail "screencapture-failed"
fi

if [ ! -s "$CAPTURE_PNG" ]; then
    emit_fail "capture-missing"
fi

if ! sips -s format bmp "$CAPTURE_PNG" --out "$CAPTURE_BMP" >/dev/null 2>&1; then
    emit_fail "capture-convert-failed"
fi

capture_metrics="$(MACOS_GUI_LIVE_WINDOW_BMP="$CAPTURE_BMP" "$SIMPLE_BIN" run scripts/check/measure_macos_gui_live_window_bmp.spl --mode=interpreter)"
set -- $capture_metrics
capture_width="${1:-0}"
capture_height="${2:-0}"
capture_total_pixels="${3:-0}"
non_background_pixels="${4:-0}"
non_background_ratio="${5:-0.000000}"
capture_titlebar_css_pixels="${6:-0}"
capture_titlebar_widget_fill_pixels="${7:-0}"
capture_titlebar_widget_accent_pixels="${8:-0}"
capture_titlebar_widget_text_pixels="${9:-0}"
capture_completed_event_counter_pixels="${10:-0}"

if [ "${non_background_pixels:-0}" -le 0 ]; then
    emit_fail "capture-has-no-visible-content"
fi

if [ "${capture_titlebar_widget_fill_pixels:-0}" -le 20 ]; then
    emit_fail "capture-titlebar-widget-fill-missing"
fi

if [ "${capture_titlebar_widget_accent_pixels:-0}" -le 2 ]; then
    emit_fail "capture-titlebar-widget-accent-missing"
fi

if [ "${capture_titlebar_widget_text_pixels:-0}" -le 2 ]; then
    emit_fail "capture-titlebar-widget-text-missing"
fi

if [ "${capture_completed_event_counter_pixels:-0}" -le 2 ]; then
    emit_fail "capture-completed-event-counters-missing"
fi

append_env "macos_gui_live_window_evidence_status" "pass"
append_env "macos_gui_live_window_evidence_reason" "pass"
append_env "macos_gui_live_window_evidence_host_os" "macos"
append_env "macos_gui_live_window_evidence_launcher" "macos-gui-run"
append_mdi_titlebar_contract_env
append_env "macos_gui_live_window_evidence_window_found" "true"
append_env "macos_gui_live_window_evidence_window_title" "SimpleGui"
append_env "macos_gui_live_window_evidence_window_rect" "$window_rect"
append_env "macos_gui_live_window_evidence_capture_path" "$CAPTURE_PNG"
append_env "macos_gui_live_window_evidence_capture_bytes" "$(file_byte_count "$CAPTURE_PNG")"
append_env "macos_gui_live_window_evidence_capture_cksum" "$(file_cksum_value "$CAPTURE_PNG")"
append_env "macos_gui_live_window_evidence_capture_width" "$capture_width"
append_env "macos_gui_live_window_evidence_capture_height" "$capture_height"
append_env "macos_gui_live_window_evidence_capture_total_pixels" "$capture_total_pixels"
append_env "macos_gui_live_window_evidence_non_background_pixels" "$non_background_pixels"
append_env "macos_gui_live_window_evidence_non_background_ratio" "$non_background_ratio"
append_env "macos_gui_live_window_evidence_titlebar_css_pixels" "$capture_titlebar_css_pixels"
append_env "macos_gui_live_window_evidence_titlebar_widget_fill_pixels" "$capture_titlebar_widget_fill_pixels"
append_env "macos_gui_live_window_evidence_titlebar_widget_accent_pixels" "$capture_titlebar_widget_accent_pixels"
append_env "macos_gui_live_window_evidence_titlebar_widget_text_pixels" "$capture_titlebar_widget_text_pixels"
append_env "macos_gui_live_window_evidence_completed_event_counter_pixels" "$capture_completed_event_counter_pixels"
append_env "macos_gui_live_window_evidence_release_gate" "live-macos-window-visual-proof"
append_env "macos_gui_live_window_evidence_release_gate_status" "satisfied"
mark_gui_smf_macos_pass_if_ready
append_env "macos_gui_live_window_evidence_gui_smf_artifact_contract_status" "$gui_smf_artifact_contract_status"
append_env "macos_gui_live_window_evidence_gui_smf_artifact_contract_row" "$gui_smf_artifact_contract_row"
append_env "macos_gui_live_window_evidence_report_path" "$REPORT_PATH"

write_report
cat "$EVIDENCE_ENV"
