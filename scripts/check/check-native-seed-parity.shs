    "seed does not bind the fields of a NESTED struct pattern inside an enum payload: 'case Shape.Circle(Point(x, y)):' takes the arm but binds x=0/y=0, printing 0 instead of 35 (binding the payload whole via 'case Shape.Circle(p):' works — same bind-zeros landmine class as tuple_pattern_match; reclassified from PARITY 2026-07-16 after empirical dual-run)"
run_native_authoritative_case mut_param write_case_mut_param "417" \
    "seed's JIT falls back to its interpreter on a mutation-capability HIR error and the fallback ignores 'mut' entirely, printing 77 (both unmutated)"
run_native_authoritative_case option_nil_check write_case_option_nil_check "7" \
    "seed's 'if val v = x.?:' pattern-bind is broken: it prints a bogus 'false' and never runs either branch body, regardless of x's value"
run_native_authoritative_case dict_get write_case_dict_get "2" \
    "seed's Dict.get() returns a bogus 0.0 on a present key (known landmine: Dict.get()-nil on present keys)"
run_native_authoritative_case range_for write_case_range_for "4" \
    "seed HANGS forever on 'continue' inside a for-i-in-a..b range loop (confirmed via 10+ minute 98%-CPU spin, killed under timeout) -- this is why every seed run in this harness is timeout-guarded"
run_native_authoritative_case rt_is_none_payload9 write_case_rt_is_none_payload9 "9" \
    "seed's 'if val x = a.?:' pattern-bind is broken (same landmine as option_nil_check): it prints a bogus 'false' and never runs the branch body"
run_native_authoritative_case compound_assign write_case_compound_assign "1512246" \
    "seed's frontend silently drops the arithmetic in compound assignment and rebinds to the RHS operand, printing 5/3/2/3 instead of 15/12/24/6"
run_native_authoritative_case tuple_pattern_match write_case_tuple_pattern_match "35" \
    "seed does not bind the elements of a 'case (a, b):' destructuring tuple pattern, printing 0 instead of 35"
run_native_authoritative_case const_pattern_refutable write_case_const_pattern_refutable "CONST_ARMOTHER_ARM" \
    "seed reinterprets a bare 'case Const(..)' enum-variant pattern as an irrefutable Struct pattern when a same-named class exists, taking the const arm for Inst.Other too (prints CONST_ARM twice)"

# --- LOUD-FAIL: native-build must refuse these constructs, not miscompile --
run_loud_fail_case int_overflow_loud write_case_int_overflow_loud \
    "integer literal out of range for i64"
run_loud_fail_case match_guard_loud write_case_match_guard_loud \
    "match guards (case x if cond:) are not supported by native codegen yet"
# static_ctor upgraded loud-fail -> parity: static impl/struct-body methods
# are now owner-qualified at HIR symbol definition (two `static fn new()` on
# different types get distinct symbols instead of colliding on one bare-name
# symbol), so `A.new()` / `B.new()` resolve unambiguously and no longer need
# the "ambiguous static method call" refusal. Seed agrees (prints 12).
run_parity_case static_ctor_disambiguated write_case_static_ctor_ambiguous_loud
run_loud_fail_case result_unwrap_u64_loud write_case_result_unwrap_u64_loud \
    "unsupported Result unwrap payload type"
# Option `?` (q_optiontry_dynload lane, 2026-07-17): the flat-nullable Option
# try lowering is now implemented (switch_operators_calls.spl lower_try_expr),
# so these cases upgrade from loud-fail to real builds -- but NOT to
# run_parity_case: the seed oracle itself silently produces ZERO stdout bytes
# for ANY `i64?` `.unwrap_or()` call (confirmed independent of `?` via minimal
# reproductions with no try operator involved at all -- a pre-existing seed
# defect, out of scope per "Fix .spl not Rust"). Native is authoritative here.
# Use ordinary present payloads here: payload `3` still collides with the flat
# ABI nil sentinel and remains an open tagged-Option bug, so accepting `0` for
# that input would encode the known defect as a green result.
run_native_authoritative_case option_try_annotated_loud write_case_option_try_annotated_loud "5" \
    "seed's Option .unwrap_or() silently prints zero bytes for any i64? receiver (confirmed independent of '?'); native must preserve the annotated present payload 5"
run_native_authoritative_case option_try_direct_loud write_case_option_try_direct_loud "4" \
    "seed's Option .unwrap_or() silently prints zero bytes for any i64? receiver (confirmed independent of '?'); native's payload 4 does not collide with the sentinel, so 4 is correct"
run_native_authoritative_case option_try_unresolved_method_loud write_case_option_try_unresolved_method_loud "6" \
    "seed's Option .unwrap_or() silently prints zero bytes for any i64? receiver; native must preserve the unresolved method return type through '?' and print payload 6"
run_loud_fail_case nonarray_iterable_loud write_case_nonarray_iterable_loud \
    "for-in over non-array iterables is not supported by native codegen yet (#143); iterate an array or use while"
run_loud_fail_case array_contains_loud write_case_array_contains_loud \
    "unresolved method call: contains"
run_loud_fail_case array_slice_loud write_case_array_slice_loud \
    "unresolved method call: slice"
run_runtime_fail_case result_unwrap_err_runtime write_case_result_unwrap_err_runtime \
    'called `.unwrap()` on an Err Result'
run_runtime_fail_case option_text_unwrap_nil_runtime write_case_option_text_unwrap_nil_runtime \
    'called `.unwrap()` on a nil Option'

echo ""
echo "===== check-native-seed-parity summary ====="
printf '%-24s %-22s %-6s %s\n' "ID" "MODE" "STATUS" "DETAIL"
while IFS="$(printf '\t')" read -r id mode status detail; do
    printf '%-24s %-22s %-6s %s\n' "$id" "$mode" "$status" "$detail"
done <"$RESULTS_FILE"

echo ""
echo "total=$TOTAL pass=$PASS_N fail=$FAIL_N xfail=$XFAIL_N"
echo "results_file=$RESULTS_FILE"

if [ -n "${NATIVE_PARITY_CASES:-}" ]; then
    for wanted in $NATIVE_PARITY_CASES; do
        matched=false
        for found in $MATCHED_PARITY_CASES; do
            [ "$wanted" = "$found" ] && matched=true
        done
        if [ "$matched" != true ]; then
            echo "native_seed_parity=false (unknown requested case: $wanted)"
            exit 1
        fi
    done
fi

if [ "${NATIVE_PARITY_FAIL_ON_XFAIL:-0}" = 1 ] && [ "$XFAIL_N" -gt 0 ]; then
    echo "native_seed_parity=false (xfail is forbidden by NATIVE_PARITY_FAIL_ON_XFAIL)"
    exit 1
fi

if [ "$FAIL_N" -gt 0 ]; then
    echo "native_seed_parity=false"
    exit 1
fi

echo "native_seed_parity=true"
