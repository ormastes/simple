fn main() -> i64:
    val t = (7, 9)
    print(t.0 + t.1)
    return 0
EOF
}

write_case_tuple_destructure() {
    cat >"$1" <<'EOF'
fn mkpair() -> (i64, i64):
    return (3, 13)

fn main() -> i64:
    val (a, b) = mkpair()
    print(a)
    print(b)
    return 0
EOF
}

write_case_tuple_for() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val pairs = [(1, 10), (2, 20), (3, 30)]
    var s = 0
    for (k, v) in pairs:
        s = s + k + v
    print(s)
