EOF
}

write_case_dict_has() {
    cat >"$1" <<'EOF'
fn has_key(d: Dict<text, i64>, key: text) -> bool:
    d.has(key)

fn main() -> i64:
    val d = {"a": 1, "b": 2}
    print(d.has("a"))
    print(d.has("z"))
    print(has_key(d, "b"))
    print(has_key(d, "z"))
    return 0
EOF
}

write_case_dict_keys_iter() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val d = {"a": 1, "b": 2, "c": 3}
    var s = 0
    for k in d.keys():
        s = s + d[k]
    print(s)
    return 0
EOF
}

write_case_value_match() {
    cat >"$1" <<'EOF'
fn classify(n: i64) -> i64:
    return match n:
        case 1: 10
        case _: 99

fn main() -> i64:
    print(classify(9))
    return 0
EOF
}

write_case_text_match() {
    cat >"$1" <<'EOF'
fn classify(s: text) -> i64:
    return match s:
        case "red": 1
        case "green": 2
        case _: 0

fn main() -> i64:
    print(classify("green"))
    return 0
EOF
}

write_case_or_pattern() {
    cat >"$1" <<'EOF'
fn classify(n: i64) -> i64:
    return match n:
        case 1 | 2 | 3: 100
        case _: 0

fn main() -> i64:
    print(classify(2))
    return 0
EOF
}

