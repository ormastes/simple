write_case_process_run_timeout() {
    cat >"$1" <<'EOF'
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn main() -> i64:
    val (arg_out, _, arg_code) = rt_process_run_timeout("/bin/sh", ["-c", "printf '%s' \"$1\"", "sh", "a b"], 2000)
    print(arg_out)
    print(arg_code)
    val (out, err, code) = rt_process_run_timeout("/bin/sh", ["-c", "printf out; printf err >&2; exit 7"], 2000)
    print(out)
    print(err)
    print(code)
    val (large_out, large_err, large_code) = rt_process_run_timeout("/bin/sh", ["-c", "(i=0; while [ $i -lt 25000 ]; do printf 0123456789; i=$((i+1)); done) & (i=0; while [ $i -lt 25000 ]; do printf 9876543210 >&2; i=$((i+1)); done) & wait"], 5000)
    print(large_out.len())
    print(large_err.len())
    print(large_code)
    val (partial_out, partial_err, timeout_code) = rt_process_run_timeout("/bin/sh", ["-c", "printf partial; printf problem >&2; sleep 2"], 500)
    print(partial_out)
    print(partial_err.contains("problem"))
    print(partial_err.contains("TIMEOUT"))
    print(timeout_code)
    val (_, _, orphan_code) = rt_process_run_timeout("/bin/sh", ["-c", "sleep 5 & echo $! > /tmp/simple_timeout_descendant_$PPID; exit 0"], 2000)
    print(orphan_code)
    val (descendant_state, _, descendant_check_code) = rt_process_run_timeout("/bin/sh", ["-c", "sleep 0.1; pid=$(cat /tmp/simple_timeout_descendant_$PPID); state=$(ps -o stat= -p \"$pid\" 2>/dev/null | tr -d ' '); case \"$state\" in ''|Z*) printf gone ;; *) printf alive ;; esac; rm -f /tmp/simple_timeout_descendant_$PPID"], 2000)
    print(descendant_state)
    print(descendant_check_code)
    0
EOF
}

write_case_dynload_tagged_text() {
    # OS detection deliberately uses the rt_platform_name extern, NOT
    # std.nogc_sync_mut.env.platform.detect_os: that import transitively
    # drags the whole std.env/std.path closure, which still contains
    # methods native codegen loud-refuses (find/join/last/pop — see bug
    # native_env_closure_unsupported_methods_2026-07-16.md). This case is
    # about hosted dynload of tagged text values, not the env stack.
    cat >"$1" <<'EOF'
extern fn rt_platform_name() -> text

extern fn spl_dlopen(path: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_dlclose(handle: i64) -> i64

fn main() -> i64:
    val os = rt_platform_name()
    var library_left = ""
    var library_right = ""
    var symbol_left = ""
    var symbol_right = ""
    if os == "linux":
        library_left = "libc."
        library_right = "so.6"
        symbol_left = "str"
        symbol_right = "len"
    elif os == "macos":
        library_left = "/usr/lib/libSystem."
        library_right = "B.dylib"
        symbol_left = "str"
        symbol_right = "len"
    elif os == "freebsd":
        library_left = "/lib/libc."
        library_right = "so.7"
        symbol_left = "str"
        symbol_right = "len"
    elif os == "windows":
        library_left = "kernel"
        library_right = "32.dll"
        symbol_left = "GetCurrentProcess"
        symbol_right = "Id"
    else:
        return 2

    val library = library_left + library_right
    val symbol = symbol_left + symbol_right
    val handle = spl_dlopen(library)
    if handle == 0:
        return 3
    if spl_dlsym(0, symbol) != 0:
        spl_dlclose(handle)
        return 4
    if spl_dlsym(handle, symbol) == 0:
        spl_dlclose(handle)
        return 5
    if spl_dlsym(handle, "simple_missing_" + "dynload_symbol") != 0:
        spl_dlclose(handle)
        return 6
    if spl_dlclose(handle) != 0:
        return 7
    if spl_dlclose(0) != 0:
        return 8
    print "dynload-ok"
    0
EOF
}

# ---------------------------------------------------------------------------
# Runner: shared helpers.
# ---------------------------------------------------------------------------

record() {
    record_id="$1"; record_mode="$2"; record_status="$3"; record_detail="$4"
    TOTAL=$((TOTAL + 1))
    case "$record_status" in
        PASS) PASS_N=$((PASS_N + 1)) ;;
        FAIL) FAIL_N=$((FAIL_N + 1)) ;;
        XFAIL) XFAIL_N=$((XFAIL_N + 1)) ;;
    esac
    printf '%s\t%s\t%s\t%s\n' "$record_id" "$record_mode" "$record_status" "$record_detail" >>"$RESULTS_FILE"
    echo "[$record_id] mode=$record_mode -> $record_status ($record_detail)"
}

case_selected() {
    [ -z "${NATIVE_PARITY_CASES:-}" ] && return 0
    for wanted in $NATIVE_PARITY_CASES; do
        if [ "$1" = "$wanted" ]; then
            MATCHED_PARITY_CASES="$MATCHED_PARITY_CASES $1"
            return 0
        fi
    done
    return 1
}

run_seed() {
    # $1 = src, writes stdout to $2. Timeout-guarded: the seed interpreter
    # is known to hang on some constructs (see `range_for`) — never let an
    # oracle run block the gate. rc is ignored; callers treat the seed as
    # a best-effort oracle only.
    src="$1"; out="$2"
    "$TIMEOUT_BIN" "$SEED_TIMEOUT_S" env -u SIMPLE_BOOTSTRAP "$SIMPLE_BINARY" run "$src" \
        >"$out" 2>"$out.stderr" || true
}

build_native() {
    # $1 = src, $2 = out bin, $3 = build log, optional $4 = strict backend,
    # optional $5 = native-build mode.
    src="$1"; bin="$2"; log="$3"
    if [ "$#" -ge 5 ]; then
        backend="$4"; mode="$5"
        env -u SIMPLE_BOOTSTRAP -u SIMPLE_RUNTIME_PATH SIMPLE_NO_STUB_FALLBACK=1 "$SIMPLE_BINARY" native-build \
            --backend="$backend" --mode="$mode" --entry "$src" -o "$bin" --clean >"$log" 2>&1
    elif [ "$#" -ge 4 ]; then
        backend="$4"
        env -u SIMPLE_BOOTSTRAP -u SIMPLE_RUNTIME_PATH SIMPLE_NO_STUB_FALLBACK=1 "$SIMPLE_BINARY" native-build \
            --backend="$backend" --entry "$src" -o "$bin" --clean >"$log" 2>&1
    else
        env -u SIMPLE_BOOTSTRAP -u SIMPLE_RUNTIME_PATH SIMPLE_NO_STUB_FALLBACK=1 "$SIMPLE_BINARY" native-build \
            --entry "$src" -o "$bin" --clean >"$log" 2>&1
    fi
}

build_native_fixture() {
    # Checked-in fixtures may import sibling fixture modules and stdlib code.
    src="$1"; bin="$2"; log="$3"; backend="$4"
    env -u SIMPLE_BOOTSTRAP -u SIMPLE_RUNTIME_PATH SIMPLE_NO_STUB_FALLBACK=1 "$SIMPLE_BINARY" native-build \
        --backend="$backend" --source test/fixtures --source src/lib --entry-closure \
        --entry "$src" -o "$bin" --clean >"$log" 2>&1
}

# Memoized capability probe for the strict-cranelift leg. The cranelift
# adapter (src/compiler/70.backend/backend/cranelift_codegen_adapter.spl) is
# interpreted live and calls rt_cranelift_* SFFI externs that must be exported
# by the deployed seed binary. Seeds older than the SFFI surface (e.g. missing
# rt_cranelift_declare_string_data / rt_cranelift_declare_global_data) fail
# EVERY cranelift build at interpretation time with "unknown extern function"
# regardless of the case under test. That is a seed-deployment gap, not a
# per-case regression: record those legs as XFAIL, referencing
# $CRANELIFT_XFAIL_BUG, instead of 9 misleading per-construct FAILs. The probe
# only downgrades on the exact missing-extern signature; any other cranelift
# build failure still runs the cases and FAILs loudly.
CRANELIFT_SEED_SUPPORT=""
CRANELIFT_XFAIL_BUG="doc/08_tracking/bug/cranelift_seed_missing_sffi_externs_2026-07-16.md"

cranelift_seed_supported() {
    if [ -z "$CRANELIFT_SEED_SUPPORT" ]; then
        probe_src="$WORK_DIR/cranelift_probe_${STAMP}.spl"
        probe_bin="$WORK_DIR/cranelift_probe_${STAMP}_bin"
        probe_log="$WORK_DIR/cranelift_probe_${STAMP}.build.log"
        printf 'fn main():\n    print("probe")\n' >"$probe_src"
        if build_native "$probe_src" "$probe_bin" "$probe_log" cranelift; then
            CRANELIFT_SEED_SUPPORT="yes"
        elif grep -q "unknown extern function: rt_cranelift_" "$probe_log"; then
            CRANELIFT_SEED_SUPPORT="no"
        else
            CRANELIFT_SEED_SUPPORT="yes"
        fi
    fi
    [ "$CRANELIFT_SEED_SUPPORT" = "yes" ]
}

run_strict_dual_backend_case() {
    id="$1"; writer="$2"; expected="$3"; mode="${4:-}"
    case_selected "$id" || return 0
    checked_in=0
    if [ -f "$writer" ]; then
        src="$writer"
        checked_in=1
    else
        src="$WORK_DIR/case_${id}_${STAMP}.spl"
        "$writer" "$src"
    fi

    for backend in llvm cranelift; do
        if [ "$backend" = "cranelift" ] && ! cranelift_seed_supported; then
            record "${id}_${backend}" "strict-$backend" "XFAIL" \
                "seed binary lacks rt_cranelift_* SFFI externs; see $CRANELIFT_XFAIL_BUG"
            continue
        fi
        bin="$WORK_DIR/case_${id}_${backend}_${STAMP}_bin"
        build_log="$WORK_DIR/case_${id}_${backend}_${STAMP}.build.log"
        build_ok=0
        if [ "$checked_in" -eq 1 ]; then
            if build_native_fixture "$src" "$bin" "$build_log" "$backend"; then
                build_ok=1
            fi
        elif [ "$backend" = "llvm" ] && [ "$mode" != "" ]; then
            if env -u SIMPLE_BOOTSTRAP -u SIMPLE_RUNTIME_PATH SIMPLE_NO_STUB_FALLBACK=1 "$SIMPLE_BINARY" native-build \
                --mode="$mode" --entry "$src" -o "$bin" --clean >"$build_log" 2>&1; then
                build_ok=1
            fi
        elif [ "$backend" = "llvm" ]; then
            if build_native "$src" "$bin" "$build_log"; then
                build_ok=1
            fi
        elif [ "$mode" != "" ]; then
            if build_native "$src" "$bin" "$build_log" "$backend" "$mode"; then
                build_ok=1
            fi
        else
            if build_native "$src" "$bin" "$build_log" "$backend"; then
                build_ok=1
            fi
        fi
        if [ "$build_ok" -eq 1 ]; then
            native_rc=0
            native_raw="$("$TIMEOUT_BIN" "$NATIVE_RUN_TIMEOUT_S" "$bin" 2>"$build_log.run.stderr")" || native_rc=$?
            native_norm="$(printf '%s' "$native_raw" | norm)"
            if [ "$native_rc" -ne 0 ]; then
                record "${id}_${backend}" "strict-$backend" "FAIL" \
                    "native run rc=$native_rc; stderr=$build_log.run.stderr"
            elif [ "$native_norm" = "$expected" ]; then
                record "${id}_${backend}" "strict-$backend" "PASS" \
                    "native=[$native_norm] want=[$expected]"
            else
                record "${id}_${backend}" "strict-$backend" "FAIL" \
                    "native=[$native_norm] want=[$expected] REGRESSION"
            fi
        else
            record "${id}_${backend}" "strict-$backend" "FAIL" \
                "native build failed; log=$build_log"
        fi
    done
}

run_parity_case() {
    id="$1"; writer="$2"
    expected="${3:-}"
    case_selected "$id" || return 0
    src="$WORK_DIR/case_${id}_${STAMP}.spl"
    bin="$WORK_DIR/case_${id}_${STAMP}_bin"
    seed_out="$WORK_DIR/case_${id}_${STAMP}.seed.out"
    build_log="$WORK_DIR/case_${id}_${STAMP}.build.log"

    "$writer" "$src"
    run_seed "$src" "$seed_out"
    seed_norm="$(norm <"$seed_out")"

    if build_native "$src" "$bin" "$build_log"; then
        native_rc=0
        native_raw="$("$TIMEOUT_BIN" "$NATIVE_RUN_TIMEOUT_S" "$bin" 2>"$build_log.run.stderr")" || native_rc=$?
        native_norm="$(printf '%s' "$native_raw" | norm)"
        if [ "$native_rc" -ne 0 ]; then
            record "$id" "parity" "FAIL" "native run rc=$native_rc; stderr=$build_log.run.stderr"
        elif [ -n "$expected" ] && [ "$seed_norm" != "$expected" ]; then
            record "$id" "parity" "FAIL" "seed=[$seed_norm] want=[$expected] REGRESSION"
        elif [ -n "$expected" ] && [ "$native_norm" != "$expected" ]; then
            record "$id" "parity" "FAIL" "native=[$native_norm] want=[$expected] REGRESSION"
        elif [ "$native_norm" = "$seed_norm" ]; then
            record "$id" "parity" "PASS" "seed=[$seed_norm] native=[$native_norm]"
        else
            record "$id" "parity" "FAIL" "seed=[$seed_norm] native=[$native_norm] MISMATCH"
        fi
    else
        record "$id" "parity" "FAIL" "native build failed unexpectedly; log=$build_log"
    fi
}

run_native_authoritative_case() {
    id="$1"; writer="$2"; expected="$3"; seed_note="$4"
    case_selected "$id" || return 0
    src="$WORK_DIR/case_${id}_${STAMP}.spl"
    bin="$WORK_DIR/case_${id}_${STAMP}_bin"
    seed_out="$WORK_DIR/case_${id}_${STAMP}.seed.out"
    build_log="$WORK_DIR/case_${id}_${STAMP}.build.log"

    "$writer" "$src"
    # Seed run is best-effort/logged only — never asserted on. It may fail
    # to parse entirely (e.g. `me`), hang (e.g. `continue` in range_for —
    # guarded by the timeout in run_seed), or run and silently produce
    # wrong output (documented per-case as $seed_note).
    run_seed "$src" "$seed_out"
    seed_norm="$(norm <"$seed_out" 2>/dev/null || echo '')"

    build_ok=0
    if [ "$NATIVE_PARITY_BACKEND" = cranelift ]; then
        if build_native "$src" "$bin" "$build_log" cranelift; then
            build_ok=1
        fi
    elif build_native "$src" "$bin" "$build_log"; then
        build_ok=1
    fi
    if [ "$build_ok" -eq 1 ]; then
        native_rc=0
        native_raw="$("$TIMEOUT_BIN" "$NATIVE_RUN_TIMEOUT_S" "$bin" 2>"$build_log.run.stderr")" || native_rc=$?
        native_norm="$(printf '%s' "$native_raw" | norm)"
        if [ "$native_rc" -ne 0 ]; then
            record "$id" "native-authoritative" "FAIL" \
                "native run rc=$native_rc; stderr=$build_log.run.stderr"
        elif [ "$native_norm" = "$expected" ]; then
            record "$id" "native-authoritative" "PASS" \
                "native=[$native_norm] want=[$expected] (seed diverges: $seed_note; seed_out=[$seed_norm])"
        else
            record "$id" "native-authoritative" "FAIL" \
                "native=[$native_norm] want=[$expected] REGRESSION (seed_out=[$seed_norm])"
        fi
    else
        record "$id" "native-authoritative" "FAIL" "native build failed; log=$build_log"
    fi
}

run_loud_fail_case() {
    id="$1"; writer="$2"; expected_diag="$3"
    case_selected "$id" || return 0
    src="$WORK_DIR/case_${id}_${STAMP}.spl"
    bin="$WORK_DIR/case_${id}_${STAMP}_bin"
    build_log="$WORK_DIR/case_${id}_${STAMP}.build.log"

    "$writer" "$src"
    build_rc=0
    if [ "$NATIVE_PARITY_BACKEND" = cranelift ]; then
        build_native "$src" "$bin" "$build_log" cranelift || build_rc=$?
    else
        build_native "$src" "$bin" "$build_log" || build_rc=$?
    fi

    if [ "$build_rc" -eq 0 ]; then
        record "$id" "loud-fail" "FAIL" "native build UNEXPECTEDLY SUCCEEDED (was supposed to refuse loudly) — REGRESSION"
        return
    fi
    if [ -e "$bin" ]; then
        record "$id" "loud-fail" "FAIL" "build rc!=0 but binary exists at $bin — silent partial output, not a loud fail"
        return
    fi
    if grep -qF "$expected_diag" "$build_log"; then
        record "$id" "loud-fail" "PASS" "build rc=$build_rc, no binary, diagnostic matched: $expected_diag"
    else
        record "$id" "loud-fail" "FAIL" "build rc=$build_rc, no binary, but expected diagnostic not found: $expected_diag (log=$build_log)"
    fi
}

run_runtime_fail_case() {
    id="$1"; writer="$2"; expected_diag="$3"
    case_selected "$id" || return 0
    src="$WORK_DIR/case_${id}_${STAMP}.spl"
    bin="$WORK_DIR/case_${id}_${STAMP}_bin"
    build_log="$WORK_DIR/case_${id}_${STAMP}.build.log"
    run_out="$WORK_DIR/case_${id}_${STAMP}.run.out"
    run_err="$WORK_DIR/case_${id}_${STAMP}.run.err"

    "$writer" "$src"
    if ! build_native "$src" "$bin" "$build_log"; then
        record "$id" "runtime-fail" "FAIL" "native build failed unexpectedly; log=$build_log"
        return
    fi
    run_rc=0
    "$TIMEOUT_BIN" "$NATIVE_RUN_TIMEOUT_S" "$bin" >"$run_out" 2>"$run_err" || run_rc=$?
    if [ "$run_rc" -eq 0 ]; then
        record "$id" "runtime-fail" "FAIL" "native run unexpectedly succeeded"
    elif grep -qF "$expected_diag" "$run_err"; then
        record "$id" "runtime-fail" "PASS" "run rc=$run_rc, diagnostic matched: $expected_diag"
    else
        record "$id" "runtime-fail" "FAIL" "run rc=$run_rc, expected diagnostic not found: $expected_diag"
    fi
}

