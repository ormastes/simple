fn bit(value: bool) -> i64:
    if value: return 1
    return 0

fn main() -> i64:
    val small: i64 = 1
    val high: u64 = 0x8000000000000000u64
    print(bit(small < high))
    print(bit(high < small))
    print(bit(small <= high))
    print(bit(high <= small))
    print(bit(small > high))
    print(bit(high > small))
    print(bit(small >= high))
    print(bit(high >= small))
    return 0
EOF
}

write_case_unsigned_div_rem_shift() {
    cat >"$1" <<'EOF'
fn bit(value: bool) -> i64:
    if value: return 1
    return 0

fn main() -> i64:
    val high: u64 = 0x8000000000000000u64
    val negative: i64 = -2
    val signed_count: u64 = 1u64
    val signed_expected: i64 = -1
    val signed_dividend: i64 = -9
    val shifted: i64 = negative >> signed_count
    print(bit(high / 2u64 == 0x4000000000000000u64))
    print(bit(high % 3u64 == 2u64))
    print(bit(high >> 63u64 == 1u64))
    print(bit(shifted == signed_expected))
    print(bit(signed_dividend / 2 == -4))
    print(bit(signed_dividend % 2 == -1))
    return 0
EOF
}

write_case_narrow_signed_shift_unsigned_count() {
    cat >"$1" <<'EOF'
fn bit(value: bool) -> i64:
    if value: return 1
    return 0

fn main() -> i64:
    val negative: i32 = -2
    val count: u32 = 1u32
    val expected: i32 = -1
    val shifted: i32 = negative >> count
    print(bit(shifted == expected))
    return 0
EOF
}

