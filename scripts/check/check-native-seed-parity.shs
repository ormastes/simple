    return 0
EOF
}

write_case_mixed_numeric_comparison() {
    cat >"$1" <<'EOF'
fn bit(value: bool) -> i64:
    if value: return 1
    return 0

fn main() -> i64:
    val nan = 0.0 / 0.0
    print(bit(41 < 41.5))
    print(bit(41.5 < 41))
    print(bit(41 <= 41.5))
    print(bit(41.5 <= 41))
    print(bit(41 > 41.5))
    print(bit(41.5 > 41))
    print(bit(41 >= 41.5))
    print(bit(41.5 >= 41))
    print(bit(42 < 42.0))
    print(bit(42.0 < 42))
    print(bit(42 <= 42.0))
    print(bit(42.0 <= 42))
    print(bit(42 > 42.0))
    print(bit(42.0 > 42))
    print(bit(42 >= 42.0))
    print(bit(42.0 >= 42))
    print(bit(0 < -0.0))
    print(bit(-0.0 < 0))
    print(bit(0 <= -0.0))
    print(bit(-0.0 <= 0))
    print(bit(0 > -0.0))
    print(bit(-0.0 > 0))
    print(bit(0 >= -0.0))
    print(bit(-0.0 >= 0))
    print(bit(nan < 0))
    print(bit(0 < nan))
    print(bit(nan <= 0))
    print(bit(0 <= nan))
    print(bit(nan > 0))
    print(bit(0 > nan))
    print(bit(nan >= 0))
    print(bit(0 >= nan))
    print(bit(42 == 42.0))
    print(bit(42.0 == 42))
    print(bit(42 != 42.0))
    print(bit(42.0 != 42))
    return 0
EOF
}

write_case_mixed_unsigned_float_comparison() {
    cat >"$1" <<'EOF'
fn bit(value: bool) -> i64:
    if value: return 1
    return 0

fn main() -> i64:
    val u8v: u8 = 255u8
    val u16v: u16 = 65535u16
    val u32v: u32 = 4294967295u32
    val u64v: u64 = 0x8000000000000000u64
    print(bit(u8v > 254.5f32))
    print(bit(u8v >= 254.5f32))
    print(bit(254.5f32 < u8v))
    print(bit(254.5f32 <= u8v))
    print(bit(u16v > 65534.5))
    print(bit(u16v >= 65534.5))
    print(bit(65534.5 < u16v))
    print(bit(65534.5 <= u16v))
    print(bit(u32v > 4294967294.5))
    print(bit(u32v >= 4294967294.5))
    print(bit(4294967294.5 < u32v))
    print(bit(4294967294.5 <= u32v))
    print(bit(u64v > 0.0))
    print(bit(u64v >= 0.0))
    print(bit(0.0 < u64v))
    print(bit(0.0 <= u64v))
    print(bit(u64v < 9223372036854775808.0))
    print(bit(u64v <= 9223372036854775808.0))
    print(bit(9223372036854775808.0 > u64v))
    print(bit(9223372036854775808.0 >= u64v))
    return 0
EOF
}

write_case_mixed_signed_unsigned_ordering() {
