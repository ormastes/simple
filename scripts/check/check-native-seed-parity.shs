        case true: 1
        case false: 0

fn main() -> i64:
    print(classify(true))
    return 0
EOF
}

write_case_bool_print() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    print(3 < 5)
    return 0
EOF
}

write_case_sized_int() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val a: i32 = -5
    print(a)
    val b: u8 = 200
    print(b)
    return 0
EOF
}

write_case_text_int_len_methods() {
    # NOTE: deliberately excludes "x".starts_with(y) and "x".contains(y) —
    # both were found broken on native during authoring (see header) and
    # are tracked as separate bugs, not folded into this passing case.
    cat >"$1" <<'EOF'
fn main() -> i64:
    print(int("42") + 1)
    print("hi".len())
    return 0
EOF
}

write_case_split_text_elements() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val parts = "aa,bb,cc".split(",")
    print(parts.len())
    print(parts[0])
    print(parts[1].len())
    print(parts[2] == "cc")
    var joined = ""
    for part in parts:
        joined = joined + part
    print(joined)
    val lines = "x\ny".split_lines()
    print(lines[1])
    return 0
EOF
}

write_case_text_lines_semantics() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val empty_long = "".split_lines()
    val empty_short = "".lines()
    val newline_long = "\n".split_lines()
    val newline_short = "\n".lines()
    val trailing = "a\n".lines()
    val double_trailing = "a\n\n".lines()
    val crlf = "a\r\nb".lines()
    val lone_cr = "a\rb".split_lines()
    print(empty_long.len())
    print(empty_short.len())
    print(newline_long.len())
    print(newline_short.len())
    print(trailing.len())
    print(trailing[0] == "a")
    print(double_trailing.len())
    print(double_trailing[1] == "")
    print(crlf.len())
    print(crlf[0] == "a")
    print(crlf[1] == "b")
    print(lone_cr.len())
    print(lone_cr[0] == "a\rb")
    return 0
EOF
}

write_case_some0() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val x: i64? = 0
    print(x ?? 3)
    return 0
EOF
}

write_case_me_receiver() {
    cat >"$1" <<'EOF'
struct Counter:
    x: i64

    fn selfset(me):
        me.x = 41

fn main() -> i64:
    var c = Counter(x: 1)
    c.selfset()
    print(c.x)
    return 0
EOF
}

write_case_float_print() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    print(2.0)
    print(0.5)
    print(0.1)
    print(3.5)
    return 0
EOF
}

write_case_mut_param() {
    cat >"$1" <<'EOF'
struct S:
    x: i64

fn withmut(mut s: S):
    s.x = 41

fn plain(s: S):
    s.x = 999

fn main() -> i64:
    var a = S(x: 7)
    withmut(a)
    print(a.x)
    var b = S(x: 7)
    plain(b)
    print(b.x)
    return 0
EOF
}

write_case_option_nil_check() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val x: i64? = 7
    if val v = x.?:
        print(v)
    return 0
EOF
}

write_case_dict_get() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val d = {"a": 1, "b": 2}
    print(d.get("b"))
    return 0
EOF
}

write_case_range_for() {
    # Also the seed-hang fixture: `continue` inside a range for-loop spins
    # the seed interpreter forever (see header). Never run this source
    # against the seed without a timeout.
    cat >"$1" <<'EOF'
fn main() -> i64:
    var total = 0
    for i in 0..5:
        if i == 2:
            continue
        if i == 4:
            break
        total = total + i
    print(total)
    return 0
EOF
}

write_case_int_overflow_loud() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val a = 99999999999999999999
    print(a)
    return 0
EOF
}

write_case_match_guard_loud() {
    cat >"$1" <<'EOF'
fn classify(x: i64) -> i64:
    return match x:
        case n if n > 0: 1
        case _: 0

fn main() -> i64:
    print(classify(5))
    return 0
EOF
}

# --- 2026-07-14 second batch (6 more landed native-build fixes) -------------

write_case_rt_is_none_payload9() {
    # `rt_is_none` fix (04255754a71): `if val x = a.?:` on an i64? whose
    # payload aliases the HEAP tag used to SIGSEGV native-build's runtime.
    # Same `.?` if-let landmine as option_nil_check makes the seed diverge.
    cat >"$1" <<'EOF'
fn get(v: i64) -> i64?:
    return v

fn main() -> i64:
    val a = get(9)
    if val x = a.?:
        print(x)
    return 0
EOF
}

write_case_str_method_var_arg() {
    # `starts_with`/`contains` with a *variable* argument (3cbe3293561):
    # previously crashed llc / always returned false on native. Bool results
    # are funneled through if/else to explicit int literals so the seed's
    # `true`/`false` vs native's `1`/`0` print formatting never diverges —
    # the construct under test is the method call, not bool stringification.
    cat >"$1" <<'EOF'
fn main() -> i64:
    val s = "hello"
    val p = "he"
    val sub = "ell"
    if s.starts_with(p):
        print(1)
    else:
        print(0)
    if s.contains(sub):
        print(1)
    else:
        print(0)
    if s.contains("zzz"):
        print(1)
    else:
        print(0)
    return 0
EOF
}

write_case_compound_assign() {
    # Compound assignment += -= *= (61bce1b3357): the seed's frontend
    # SILENTLY DROPS the arithmetic and just rebinds to the RHS operand, so
    # `x += 5` stores 5 (not 15), etc. — see $seed_note. Native applies the
    # op correctly, so this is native-authoritative.
    cat >"$1" <<'EOF'
fn main() -> i64:
    var x = 10
    x += 5
    print(x)
    x -= 3
    print(x)
    x *= 2
    print(x)
    var s = 0
    for i in [1, 2, 3]:
        s += i
    print(s)
    return 0
EOF
}

write_case_float_struct_field() {
    # Float struct fields (13e6f9d63ae): reading an f64 struct field used to
    # be fptosi-truncated to an int on native (1.5 -> 1). Now bit-preserved
    # and correctly typed; the seed was already sound here -> parity.
    cat >"$1" <<'EOF'
struct Point:
    x: f64
    y: f64

fn main() -> i64:
    val p = Point(x: 1.5, y: 3.5)
    print(p.x)
    print(p.y)
    print(p.x + p.y)
    return 0
EOF
}

write_case_text_num_concat() {
    # text + number/bool/float auto-stringify (3434196a876): `"n=" + 5` used
    # to SIGSEGV native-build. Now the non-text operand is stringified; the
    # seed already did this -> parity.
    cat >"$1" <<'EOF'
fn main() -> i64:
    print("n=" + 5)
    print("b=" + true)
    print("f=" + 3.5)
    print("a" + 1 + "b")
    return 0
EOF
}

write_case_text_ordering() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val raw_a = "abc"
    val raw_b = "abd"
    val tagged_a = "ab" + "c"
    val tagged_b = "ab" + "d"
    print(raw_a < raw_b)
    print(tagged_a < raw_b)
    print(raw_a < tagged_b)
    print(tagged_a < tagged_b)
    print(raw_b > raw_a)
    print(tagged_b > tagged_a)
    print(raw_a <= tagged_a)
    print(raw_a >= tagged_a)
    print(raw_a < tagged_a)
    print(tagged_a > raw_a)
    print(raw_b <= tagged_a)
    print(raw_a >= tagged_b)
    return 0
EOF
}

write_case_text_bracket_index() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val raw_ch = "hello"[1]
    val tagged = "wo" + "rld"
    val tagged_ch = tagged[3]
    print(raw_ch == "e")
    print(tagged_ch == "l")
    print("raw={raw_ch}/{raw_ch.len()};tagged={tagged_ch}/{tagged_ch.len()}")
    return 0
EOF
}

write_case_raw_string_interpolation_contract() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val name = "world"
    print("double={name}")
    print('single={name}')
    print("""triple={name}""")
    print(r"raw={name}")
    print(r"""raw-triple={name}""")
    return 0
EOF
}

write_case_new_keyword_identifier() {
    cat >"$1" <<'EOF'
fn show(x: text) -> text:
    return x

fn main() -> i64:
    val new = "L"
    val a = "hello"
    print("interp={new};")
    print("arg=" + show(new) + ";")
    print("replace=" + a.replace("l", new))
    return 0
EOF
}

write_case_bare_main() {
    # A main without a declared return type must still return process status 0.
    cat >"$1" <<'EOF'
fn main():
    print("ok")
EOF
}

write_case_iife() {
    # IIFE (bc33ade0120): a raw lambda-literal callee `(\x: x+1)(5)` used to
    # loud-fail native-build; now beta-reduces in the live scope. Seed evaluates
    # it too -> parity (expect 6, 15). (A curried `(\a: \b: ..)(4)(9)` is left
    # out on purpose: the inner lambda escapes+captures, which correctly
    # loud-fails native codegen -- not an IIFE the fix targets.)
    cat >"$1" <<'EOF'
fn main() -> i64:
    print((\x: x + 1)(5))
    val n = 9
    print((\x: x + n)(6))
    return 0
EOF
}

write_case_local_lambda_value() {
    # A non-capturing lambda remains callable after storage and can be passed
    # through an ordinary fn-typed parameter.
    cat >"$1" <<'EOF'
fn apply(f: fn(i64) -> i64, x: i64) -> i64:
    return f(x)

fn main() -> i64:
    val f = \x: x + 1
    print(f(5))
    print(apply(f, 10))
    return 0
EOF
}

write_case_method_owner_dispatch() {
    cat >"$1" <<'EOF'
struct CodegenCompiledModule:
    handle: i64

impl CodegenCompiledModule:
    fn cleanup(self) -> i64: 17
    static fn code() -> i64: 18

struct TieredJitManager:
    handle: i64

impl TieredJitManager:
    fn cleanup(self) -> i64: 99
    static fn code() -> i64: 100

fn main() -> i64:
    val compiled = CodegenCompiledModule(handle: 1)
    val jit = TieredJitManager(handle: 2)
    print(compiled.cleanup())
    print(jit.cleanup())
    print(CodegenCompiledModule.code())
    print(TieredJitManager.code())
    0
EOF
}

write_case_method_text_return() {
    cat >"$1" <<'EOF'
struct Widget:
    name: text

impl Widget:
    fn describe(self) -> text: "widget:" + self.name
    static fn category() -> text: "static"

fn main() -> i64:
    val widget = Widget(name: "w1")
    print(widget.describe())
    print("/")
    print(Widget.category())
    return 0
EOF
}

write_case_module_global_static_init() {
    # First reads must observe both nonzero and zero static initialization;
    # compound writes must then persist through StoreGlobal/LoadGlobal.
    cat >"$1" <<'EOF'
var g_nonzero: i64 = 17
var g_zero: i64 = 0

fn main() -> i64:
    print(g_nonzero)
    print("/")
    print(g_zero)
    g_nonzero += 5
    g_zero += 5
    print("|")
    print(g_nonzero)
    print("/")
    print(g_zero)
    return 0
EOF
}

write_case_module_global_false_first_read() {
    # A zero-valued bool global must be initialized before either its first
    # direct read or a read through a function. A read followed by a write in
    # the same function must keep resolving to the module slot, including
    # when the read is embedded in string interpolation.
    cat >"$1" <<'EOF'
var flag = false
var state = 7

fn read_flag() -> bool:
    return flag

fn take_state() -> i64:
    val before = state
    state = 3
    return before * 10 + state

fn bit(value: bool) -> i64:
    if value:
        return 1
    return 0

fn main() -> i64:
    print(bit(flag))
    print(bit(read_flag()))
    print("|")
    print(take_state())
    print("|state={state}")
    return 0
EOF
}

write_case_enum_text_callback() {
    # Preserve the declared text payload through callback delivery, pattern
    # binding, and assignment to another text field.
    cat >"$1" <<'EOF'
enum UiEvent:
    Action(text)

struct Capture:
    value: text

fn handle(event: UiEvent) -> text:
    var capture = Capture(value: "")
    match event:
        case UiEvent.Action(name):
            capture.value = name
    return capture.value

fn deliver(callback: fn(UiEvent) -> text, event: UiEvent) -> text:
    return callback(event)

fn main() -> i64:
    print(deliver(handle, UiEvent.Action("run")))
    return 0
EOF
}

write_case_any_forwarding() {
    # Any is a one-word handle. Forward it unchanged to an existing runtime
    # extern and compare against a non-forwarded text handle.
    cat >"$1" <<'EOF'
extern fn rt_native_eq(a: Any, b: Any) -> bool

fn forwarded_eq(value: Any) -> bool:
    return rt_native_eq(value, "forwarded")

fn bit(value: bool) -> i64:
    if value:
        return 1
    return 0

fn main() -> i64:
    print(bit(forwarded_eq("forwarded")))
    print(bit(forwarded_eq("other")))
    return 0
EOF
}

write_case_logical_short_circuit() {
    cat >"$1" <<'EOF'
fn rhs_true() -> bool:
    print "R"
    return true

fn rhs_false() -> bool:
    print "R"
    return false

fn main() -> i64:
    print(false and rhs_true())
    print(true or rhs_false())
    print(true and rhs_true())
    print(false or rhs_true())
    return 0
EOF
}

write_case_interp_logical_bool() {
    # A short-circuit expression makes the SSA alloca rewrite slot the
    # interpolation accumulator. Its fresh string-constant def must retain
    # pointer type through the generated Store (bug found 2026-07-16).
    cat >"$1" <<'EOF'
fn t() -> bool:
    return true

fn main() -> i64:
    print("v={t() and t()}")
    return 0
EOF
}

write_case_brace_literal_scope_exact() {
    # Exact June 2026 cross-function repro: unmatched literal braces must stay
    # literal and must not poison HIR scope or make the entry point disappear.
    # Keep the trailing call: it exercises the `_expr_N` restoration path and
    # the `functions.contains("main")` decision that participated in the bug.
    cat >"$1" <<'EOF'
fn open_brace(x: text) -> text:
    " { "

fn main():
    val ob = open_brace("unused")
    val rule = ".a" + ob + "color: red" + " } "
    print("RULE: [" + rule + "]")

main()
EOF
}

write_case_brace_literal_scope() {
    # Native-entry supporting case. The exact historical source, including its
    # top-level call, remains opt-in below while the scope-corruption bug is red.
    cat >"$1" <<'EOF'
fn open_brace(x: text) -> text:
    " { "

fn main() -> i64:
    val ob = open_brace("unused")
    val rule = ".a" + ob + "color: red" + " } "
    print("RULE: [" + rule + "]")
    return 0
EOF
}

write_case_dict_from_call_keys() {
    # dict returned from a function, keys()-iter index (abde1838e3e): the call
    # -result dict's string keys came back un-decoded so every d[k] returned 0;
    # now they round-trip. Seed handles it too -> parity (expect 3).
    cat >"$1" <<'EOF'
fn mk() -> Dict<text, i64>:
    var d = {}
    d["a"] = 1
    d["b"] = 2
    return d
fn main() -> i64:
    val d = mk()
    var t = 0
    for k in d.keys():
        t = t + d[k]
    print(t)
    return 0
EOF
}

write_case_array_concat() {
    # array `+` concat (e9165c53a66): `a + [x]` used to integer-add two
    # SplArray* pointers -> SIGSEGV; now routes to rt_array_concat. Seed
    # concatenates too -> parity (expect 4, 1, 4, 5).
    cat >"$1" <<'EOF'
fn main() -> i64:
    val a = [1, 2]
    val c = a + [3, 4]
    print(c.len())
    print(c[0])
    print(c[3])
    val e = a + [3, 4] + [5]
    print(e.len())
    return 0
EOF
}

write_case_interp_bool_float() {
    # bool/float in string interpolation (e9165c53a66): operands used to route
    # through rt_raw_i64_to_string, misrendering bools and floats; now use the
    # bool/f64 dispatch. Seed renders them the same -> parity.
    cat >"$1" <<'EOF'
fn main() -> i64:
    print("n={5} b={true} f={1.5}")
    print("{3 < 5}")
    return 0
EOF
}

write_case_bool_array_element_interp() {
    # Bool array element interpolation: preserve the element type both for a
    # direct index expression and after val/var bindings, so interpolation
    # selects rt_raw_bool_to_string instead of rendering tagged-value bits.
    cat >"$1" <<'EOF'
struct FlagBox:
    bits: [bool]

class NameBox:
    var marker: i64
    var values: [text]

fn main() -> i64:
    val flags: [bool] = [true, false]
    print("{flags[0]}/{flags[1]}")
    val val_true = flags[0]
    val val_false = flags[1]
    print(val_true)
    print(val_false)
    print("{val_true}/{val_false}")
    var var_true = flags[0]
    var var_false = flags[1]
    print(var_true)
    print(var_false)
    print("{var_true}/{var_false}")

    val box = FlagBox(bits: [false, true])
    val field_bool = box.bits[1]
    print("{box.bits[0]}/{field_bool}")

    var names = NameBox(marker: 99, values: ["left", "right"])
    val field_text = names.values[1]
    print("{names.values[0]}/{field_text}/{names.marker}")
    return 0
EOF
}

write_case_const_pattern_refutable() {
    # `case Inst.Const(..)` must stay a REFUTABLE enum-variant pattern even
    # when an unrelated class named `Const` exists (bug
    # native_const_pattern_lowers_irrefutably_2026-07-13, fixed 2026-07-16:
    # enum_variant_names precedence guard in HIR lower_pattern). Native must
    # print CONST_ARM then OTHER_ARM; the seed takes the const arm for BOTH.
    cat >"$1" <<'EOF'
enum Inst:
    Const(i64, i64, i64)
    Other

class Const:
    x: i64

fn classify(inst: Inst) -> text:
    return match inst:
        case Inst.Const(dest, _, _): "CONST_ARM"
        case _: "OTHER_ARM"

fn main() -> i64:
    print(classify(Inst.Const(42, 1, 2)))
    print(classify(Inst.Other))
    return 0
EOF
}

write_case_tuple_pattern_match() {
    # Destructuring tuple match pattern (99c7f3516b0): `case (a, b):` binds
    # the tuple elements. The seed does NOT bind them (prints 0); native
    # binds correctly (a=3,b=5 -> 3*10+5=35) -> native-authoritative.
    cat >"$1" <<'EOF'
fn main() -> i64:
    val p = (3, 5)
    match p:
        case (a, b):
            print(a * 10 + b)
    return 0
EOF
}

write_case_nested_enum_struct_match() {
    cat >"$1" <<'EOF'
struct Point:
    x: i64
    y: i64

enum Shape:
    Circle(Point)
    Empty

fn main() -> i64:
    val s = Shape.Circle(Point(x: 3, y: 5))
    match s:
        case Shape.Circle(Point(x, y)): print(x * 10 + y)
        case Shape.Empty: print(0)
    return 0
EOF
}

