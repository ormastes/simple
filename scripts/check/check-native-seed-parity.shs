#!/bin/sh
# check-native-seed-parity.shs — dual-backend parity regression harness.
#
# Purpose: this is the regression guard for the 2026-07-14 native-build
# bug-fix batch (~29 bugs fixed in the pure-Simple self-hosted native
# codegen path this session: nested struct fields, struct/array-of-struct
# value semantics, `mut`/`me` receivers, tuple access, dict iteration,
# match or-patterns, sized ints, text methods, and loud-fail diagnostics
# for constructs unsupported by design). Every case here runs the SAME
# tiny .spl program through BOTH compilers and asserts they agree (or,
# where the seed oracle is known-broken, that native alone matches ground
# truth) so none of these fixes silently regress.
#
# Both backends are the SAME deployed self-hosted bin/simple
# (bin/simple -> bin/release/<triple>/simple):
#   SEED ORACLE:         env -u SIMPLE_BOOTSTRAP bin/simple run prog.spl
#   PURE-SIMPLE NATIVE:   env -u SIMPLE_BOOTSTRAP -u SIMPLE_RUNTIME_PATH \
#                         bin/simple native-build \
#                         --entry prog.spl -o out --clean && ./out
# SIMPLE_BOOTSTRAP is unset so both invocations exercise the Rust-seed
# interpreter (`run`) vs the pure-Simple native codegen (`native-build`).
#
# NORMALIZATION: native `print()` emits NO trailing newline (Rust-style
# print, not println), while the seed's `run` adds a newline after every
# print — the seed's own quirk, not a bug on either side. So stdout is
# never byte-compared. stdout is captured on its own file descriptor
# (stderr — banners/diagnostics — is captured separately and never enters
# the compared value) and normalized via `tr -d '\n' | tr -d ' '` to a
# canonical, whitespace-insensitive character sequence before comparing.
# A parity case may also supply a fixed expected value; then both normalized
# outputs must match that value as well as each other.
#
# Every seed and native run is wrapped in `timeout` (see SEED_TIMEOUT_S /
# NATIVE_RUN_TIMEOUT_S below): while authoring this harness the seed
# interpreter was found to genuinely HANG (infinite loop, confirmed via a
# 10+ minute 98%-CPU spin) on `continue` inside a `for i in a..b:` range
# loop (see the `range_for` case) — an unbounded seed run must never be
# allowed to wedge this gate.
#
# FIVE CASE MODES:
#   1. PARITY               — the seed oracle is sound for this construct.
#      Assert normalize(native_stdout) == normalize(seed_stdout).
#   2. NATIVE-AUTHORITATIVE — the seed oracle is PROVABLY BROKEN, hangs,
#      or cannot even parse the construct (documented per-case below,
#      empirically verified during authoring — not guessed). Assert
#      normalize(native_stdout) == a fixed EXPECTED literal; the seed run
#      is executed only to log its (broken) behavior for documentation,
#      never asserted on.
#   3. STRICT-DUAL          — both LLVM and Cranelift native builds must
#      run and match a fixed expected value. Used where the seed is not a
#      dependable oracle and backend parity is the contract.
#   4. LOUD-FAIL            — native-build MUST refuse to build the
#      construct (unsupported-by-design, e.g. match guards, out-of-range
#      integer literals) with a nonzero exit and no binary produced,
#      rather than silently miscompiling. Assert build rc != 0 AND no
#      binary exists AND the build log contains the expected diagnostic.
#   5. RUNTIME-FAIL         — native-build must succeed, then the program
#      must exit nonzero with the expected runtime diagnostic.
#
# Every original case's mode was decided by actually running its required
# backends during authoring. The nine cases added on 2026-07-15 have bounded
# source review and await execution with the expanded matrix. Three original
# cases were reclassified after empirical testing disagreed:
#   - `mut_param` and `option_nil_check` were expected PARITY but the seed
#     proved to diverge (mut-capability propagation and `.?` if-let are
#     both silently broken in the seed's JIT-fallback interpreter path)
#     -> reclassified NATIVE-AUTHORITATIVE.
#   - `dict_get` was split out of a would-be parity `dict_methods` case
#     for the same reason (seed's Dict.get() returns a bogus `0.0` on a
#     present key — a known landmine, see
#     reference_interpreter_dict_and_value_quirks).
#   - `some0` was expected NATIVE-AUTHORITATIVE (spec assumed the seed
#     prints a `<special:...>` marker for `nil ?? default`) but both
#     backends actually agree (`0`) -> reclassified PARITY.
# Two more were reclassified 2026-07-16 after empirical dual-runs showed the
# NATIVE output correct and the SEED oracle broken (seed is Rust — not
# fixable from pure-Simple source):
#   - `nested_enum_struct_match`: seed binds x=0/y=0 for a nested struct
#     pattern inside an enum payload -> NATIVE-AUTHORITATIVE.
#   - `float_edges`: seed prints 1e-18 as the non-round-tripping
#     `0.00000000000000000` -> NATIVE-AUTHORITATIVE.
#
# Usage: sh scripts/check/check-native-seed-parity.shs
# Env:   SIMPLE_BINARY (default bin/simple), PARITY_WORK_DIR (default
#        /tmp/check-native-seed-parity.$$), NATIVE_PARITY_CASES (optional
#        space-separated case IDs), NATIVE_PARITY_BACKEND (llvm default or
#        cranelift for backend-selected loud-fail/native-authoritative cases),
#        NATIVE_OPEN_BUG_REPROS=1 (opt in to the remaining known-red repro),
#        NATIVE_PARITY_FAIL_ON_XFAIL=1 (optional strict gate),
#        SEED_TIMEOUT_S (default 20), and NATIVE_RUN_TIMEOUT_S (default 20)
# Requires `timeout` (Linux/FreeBSD/Windows) or `gtimeout` (macOS).
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-bin/simple}"
WORK_DIR="${PARITY_WORK_DIR:-/tmp/check-native-seed-parity.$$}"
SEED_TIMEOUT_S="${SEED_TIMEOUT_S:-20}"
NATIVE_RUN_TIMEOUT_S="${NATIVE_RUN_TIMEOUT_S:-20}"
NATIVE_PARITY_BACKEND="${NATIVE_PARITY_BACKEND:-llvm}"
case "$NATIVE_PARITY_BACKEND" in
    llvm|cranelift) ;;
    *) echo "unsupported NATIVE_PARITY_BACKEND: $NATIVE_PARITY_BACKEND" >&2; exit 2 ;;
esac
if command -v timeout >/dev/null 2>&1; then
    TIMEOUT_BIN=$(command -v timeout)
elif command -v gtimeout >/dev/null 2>&1; then
    TIMEOUT_BIN=$(command -v gtimeout)
else
    echo "error: timeout or gtimeout is required" >&2
    exit 2
fi
mkdir -p "$WORK_DIR"

STAMP="$(date +%s)_$$"
RESULTS_FILE="$WORK_DIR/results.tsv"
: >"$RESULTS_FILE"

TOTAL=0
PASS_N=0
FAIL_N=0
XFAIL_N=0
MATCHED_PARITY_CASES=""

norm() {
    # Canonicalize stdout: strip newlines and spaces so seed's added
    # newlines (vs native's newline-less print) never cause a mismatch.
    tr -d '\n' | tr -d ' '
}

# ---------------------------------------------------------------------------
# Case source writers — one tiny .spl program per fixed bug / construct.
# ---------------------------------------------------------------------------

write_case_struct_nested_field() {
    cat >"$1" <<'EOF'
struct Inner:
    v: i64

struct Outer:
    inner: Inner

fn main() -> i64:
    var o = Outer(inner: Inner(v: 7))
    print(o.inner.v)
    o.inner.v = 42
    print(o.inner.v)
    return 0
EOF
}

write_case_nested_struct_value_copy() {
    cat >"$1" <<'EOF'
struct InnerCopy:
    n: i64

class SharedRef:
    n: i64

struct OuterCopy:
    inner: InnerCopy
    shared: SharedRef

fn mutate_copy(value: OuterCopy):
    value.inner.n = 9
    value.shared.n = 5

fn main() -> i64:
    var original = OuterCopy(inner: InnerCopy(n: 1), shared: SharedRef(n: 3))
    var local_copy = original
    local_copy.inner.n = 2
    local_copy.shared.n = 4
    print("local=")
    print(original.inner.n)
    print(",class=")
    print(original.shared.n)
    mutate_copy(original)
    print(",param=")
    print(original.inner.n)
    print(",class=")
    print(original.shared.n)
    return 0
EOF
}

write_case_crossmodule_field_index_collision() {
    cat >"$1" <<'EOF'
use test.fixtures.native_crossmodule_field_index.provider.{DisplayState, make_display_state}

struct LargerDecoy:
    width: i64
    height: i64
    pad0: i64
    pad1: i64
    pad2: i64
    pad3: i64

fn main() -> i64:
    val state: DisplayState = make_display_state()
    val decoy = LargerDecoy(width: 1, height: 2, pad0: 3, pad1: 4, pad2: 5, pad3: 6)
    if decoy.width == -1:
        print(decoy.height)
    print(state.driver.width)
    print("/")
    print(state.driver.height)
    return 0
EOF
}

write_case_struct_return_byval() {
    cat >"$1" <<'EOF'
struct P:
    x: i64
    y: i64

fn make(n: i64) -> P:
    return P(x: n, y: n + 1)

fn main() -> i64:
    print(make(5).y)
    val p = make(5)
    print(p.x)
    print(p.y)
    return 0
EOF
}

write_case_method_owner_dispatch_i64() {
    # Regression for native method-cleanup global misresolution (bug doc
    # native_method_cleanup_global_misresolution_2026-07-13): two UNRELATED
    # owners expose the same method name; each receiver must dispatch to its
    # OWN owner's method (`m.cleanup()` must never bind the other owner's
    # `cleanup`). Verified fixed 2026-07-16 at c8f4b62261a (owner-qualified
    # HIR/MIR method identity, 2026-07-15 pure-Simple root fix).
    cat >"$1" <<'EOF'
struct JitMgr:
    id: i64

impl JitMgr:
    fn cleanup(self) -> i64:
        return 222

struct CompiledMod:
    name: i64

impl CompiledMod:
    fn cleanup(self) -> i64:
        return 111 + self.name

fn make_mod(n: i64) -> CompiledMod:
    return CompiledMod(name: n)

fn main() -> i64:
    val m = make_mod(1)
    val j = JitMgr(id: 7)
    print(m.cleanup())
    print(j.cleanup())
    return 0
EOF
}

write_case_static_ctor_field() {
    cat >"$1" <<'EOF'
struct Point:
    x: i64
    y: i64

    static fn new() -> Point:
        Point(x: 3, y: 7)

fn main() -> i64:
    print(Point.new().y)
    return 0
EOF
}

write_case_static_ctor_ambiguous_loud() {
    cat >"$1" <<'EOF'
struct A:
    x: i64
    static fn new() -> A: A(x: 1)

struct B:
    x: i64
    static fn new() -> B: B(x: 2)

fn main() -> i64:
    print(A.new().x)
    print(B.new().x)
    return 0
EOF
}

write_case_toplevel_array_len() {
    cat >"$1" <<'EOF'
val xs = [1, 2, 3]
print(xs.len())
EOF
}

write_case_result_cross_fn_text() {
    cat >"$1" <<'EOF'
fn text_error() -> Result<i64, text>:
    Err("boom")

fn int_error() -> Result<i64, i64>:
    Err(41)

fn print_text_result(r: Result<i64, text>):
    match r:
        case Ok(value): print(value)
        case Err(message): print(message)

fn print_int_result(r: Result<i64, i64>):
    match r:
        case Ok(value): print(value)
        case Err(code): print(code)

fn main() -> i64:
    print_text_result(text_error())
    match text_error():
        case Ok(value): print(value)
        case Err(message): print(message)
    match int_error():
        case Ok(value): print(value)
        case Err(code): print(code)
    return 0
EOF
}

write_case_result_unwrap() {
    cat >"$1" <<'EOF'
fn ok_num() -> Result<i64, text>: Ok(7)
fn err_num() -> Result<i64, text>: Err("boom")
fn ok_text() -> Result<text, i64>: Ok("yes")
fn option_fallback() -> text:
    print("F")
    return "fallback"

fn main() -> i64:
    print(ok_num().unwrap())
    print(ok_num().unwrap_or(9))
    print(err_num().unwrap_or(9))
    print(ok_text().unwrap())
    val some_num: i64? = 0
    val none_num: i64? = nil
    print(some_num.unwrap())
    print(none_num.unwrap_or(8))
    val present_text: text? = "opt"
    val absent_text: text? = nil
    print(present_text.unwrap())
    print(present_text.unwrap_or(option_fallback()))
    print(absent_text.unwrap_or(option_fallback()))
    return 0
EOF
}

write_case_result_unwrap_err_runtime() {
    cat >"$1" <<'EOF'
fn err_num() -> Result<i64, text>: Err("boom")
fn main() -> i64:
    print(err_num().unwrap())
    return 0
EOF
}

write_case_result_unwrap_u64_loud() {
    cat >"$1" <<'EOF'
fn wide() -> Result<u64, text>: Ok(1)
fn main() -> i64:
    print(wide().unwrap())
    return 0
EOF
}

write_case_option_text_unwrap_nil_runtime() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val absent_text: text? = nil
    print(absent_text.unwrap())
    return 0
EOF
}

write_case_struct_array_field() {
    cat >"$1" <<'EOF'
struct S:
    arr: [i64]

fn main() -> i64:
    var s = S(arr: [1, 2, 3])
    print(s.arr[1])
    s.arr[1] = 99
    print(s.arr[1])
    return 0
EOF
}

write_case_class_array_field_mutation() {
    # A class array field must remain the same live runtime-array handle when
    # mutated through a parameter: push and index-set must both be visible
    # through an alias captured before the call.
    cat >"$1" <<'EOF'
class Container:
    var marker: i64
    var items: [i64]

fn mutate(c: Container):
    c.items.push(42)
    c.items[0] = 7

fn main() -> i64:
    var c = Container(marker: 99, items: [11])
    val alias = c.items
    mutate(c)
    print(c.items.len())
    print(c.items[0])
    print(c.items[1])
    print(alias.len())
    print(alias[0])
    print(alias[1])
    print(c.marker)
    return 0
EOF
}

write_case_array_of_structs() {
    cat >"$1" <<'EOF'
struct Pt:
    x: i64
    y: i64

fn main() -> i64:
    var pts = [Pt(x: 1, y: 2), Pt(x: 10, y: 20), Pt(x: 100, y: 200)]
    print(pts[1].y)
    pts[1].y = 77
    print(pts[1].y)
    return 0
EOF
}

write_case_array_2d() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    var m = [[1, 2], [3, 4]]
    print(m[0][1])
    m[0][1] = 99
    print(m[0][1])
    return 0
EOF
}

write_case_tuple_access() {
