write_case_result_try() {
    cat >"$1" <<'EOF'
fn leaf_ok() -> Result<i64, text>:
    Ok(7)

fn leaf_err() -> Result<i64, text>:
    Err("boom")

fn forward_ok() -> Result<i64, text>:
    val value = leaf_ok()?
    Ok(value + 1)

fn forward_err() -> Result<i64, text>:
    val value = leaf_err()?
    Ok(value)

fn main() -> i64:
    match forward_ok():
        case Ok(value): print(value)
        case Err(message): print(message)
    match forward_err():
        case Ok(value): print(value)
        case Err(message): print(message)
    0
EOF
}

write_case_float_edges() {
