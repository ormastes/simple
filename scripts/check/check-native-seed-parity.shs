write_case_option_is_none_map() {
    cat >"$1" <<'EOF'
fn main() -> i64:
    val some: i64? = 5
    val none: i64? = nil
    if some.is_none():
        print(1)
    else:
        print(0)
    if none.is_none():
        print(1)
    else:
        print(0)
    print(some.map(\x: x * 2).unwrap_or(99))
    print(none.map(\x: x * 2).unwrap_or(99))
    print(some.map(fn(x: i64) -> text: "v").unwrap_or("d") == "v")
    print(none.map(fn(x: i64) -> text: "bad").unwrap_or("d") == "d")
    val some_text: text? = "a"
    print(some_text.map(fn(x: text) -> i64: x.len()).unwrap_or(0))
    val bias = 0.5
    val some_float: f64? = 1.5
    print(some_float.map(fn(x: f64) -> f64: x + bias).unwrap_or(0.0) == 2.0)
    val some_bool: bool? = true
    print(some_bool.map(fn(x: bool) -> bool: not x).unwrap_or(true))
    val filtered = [1, 2, 3].filter(fn(x: i64) -> bool: x > 1)
    print(filtered.len())
    return 0
EOF
}

