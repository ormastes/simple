# Validate hosted WM first-frame PPM capture evidence.

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?

struct PpmHeader:
    magic: i64
    width: i64
    height: i64
    max_value: i64
    data_offset: i64
    ok: bool

struct NumParse:
    value: i64
    next: i64
    ok: bool

struct Metrics:
    status: text
    reason: text
    width: i64
    height: i64
    non_bg: i64
    bright: i64
    accent: i64
    checksum: i64

fn byte_at(data: [u8], idx: i64) -> i64:
    if idx < 0 or idx >= data.len():
        return 0
    data[idx] as i64

fn is_ws(b: i64) -> bool:
    b == 32 or b == 9 or b == 10 or b == 13

fn is_digit(b: i64) -> bool:
    b >= 48 and b <= 57

fn skip_ws_comments(data: [u8], pos: i64) -> i64:
    var i = pos
    var again = true
    while again:
        again = false
        while i < data.len() and is_ws(byte_at(data, i)):
            i = i + 1
        if i < data.len() and byte_at(data, i) == 35:
            while i < data.len() and byte_at(data, i) != 10 and byte_at(data, i) != 13:
                i = i + 1
            again = true
    i

fn parse_num(data: [u8], pos: i64) -> NumParse:
    var i = skip_ws_comments(data, pos)
    if i >= data.len() or not is_digit(byte_at(data, i)):
        return NumParse(value: 0, next: i, ok: false)
    var value: i64 = 0
    while i < data.len() and is_digit(byte_at(data, i)):
        value = (value * 10) + (byte_at(data, i) - 48)
        i = i + 1
    NumParse(value: value, next: i, ok: true)

fn parse_header(data: [u8]) -> PpmHeader:
    var pos = skip_ws_comments(data, 0)
    if pos + 1 >= data.len() or byte_at(data, pos) != 80:
        return PpmHeader(magic: 0, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    val magic = byte_at(data, pos + 1)
    if magic != 54 and magic != 51:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    pos = pos + 2
    val width = parse_num(data, pos)
    if not width.ok:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    val height = parse_num(data, width.next)
    if not height.ok:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    val maxv = parse_num(data, height.next)
    if not maxv.ok:
        return PpmHeader(magic: magic, width: 0, height: 0, max_value: 0, data_offset: 0, ok: false)
    var data_offset = maxv.next
    while data_offset < data.len() and is_ws(byte_at(data, data_offset)):
        data_offset = data_offset + 1
    PpmHeader(magic: magic, width: width.value, height: height.value, max_value: maxv.value, data_offset: data_offset, ok: true)

fn max3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b > m:
        m = b
    if c > m:
        m = c
    m

fn min3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b < m:
        m = b
    if c < m:
        m = c
    m

fn fnv_step(checksum: i64, r: i64, g: i64, b: i64) -> i64:
    val mixed = checksum ^ ((r << 16) | (g << 8) | b)
    (mixed * 16777619) & 0xffffffff

fn fail_metrics(reason: text, width: i64, height: i64, non_bg: i64, bright: i64, accent: i64, checksum: i64) -> Metrics:
    Metrics(status: "fail", reason: reason, width: width, height: height, non_bg: non_bg, bright: bright, accent: accent, checksum: checksum)

fn validate_ppm(path: text) -> Metrics:
    val data = rt_file_read_bytes(path) ?? []
    val header = parse_header(data)
    if not header.ok:
        return fail_metrics("not-supported-ppm", 0, 0, 0, 0, 0, 0)
    var status = "pass"
    var reason = "hosted-first-frame-capture-valid"
    var non_bg: i64 = 0
    var bright: i64 = 0
    var accent: i64 = 0
    var checksum: i64 = 2166136261
    if header.width != 270 or header.height != 150 or header.max_value != 255:
        status = "fail"
        reason = "unexpected-ppm-shape"
    val total_values = header.width * header.height * 3
    if status == "pass" and header.magic == 54 and data.len() - header.data_offset < total_values:
        status = "fail"
        reason = "unexpected-ppm-shape"
    var p3_pos = header.data_offset
    var y = 0
    while y < header.height:
        var x = 0
        while x < header.width:
            val off = header.data_offset + ((y * header.width + x) * 3)
            var r: i64 = 0
            var g: i64 = 0
            var b: i64 = 0
            if status == "pass" and header.magic == 54:
                r = byte_at(data, off)
                g = byte_at(data, off + 1)
                b = byte_at(data, off + 2)
            elif status == "pass":
                val rp = parse_num(data, p3_pos)
                val gp = parse_num(data, rp.next)
                val bp = parse_num(data, gp.next)
                if not rp.ok or not gp.ok or not bp.ok:
                    status = "fail"
                    reason = "unexpected-ppm-shape"
                else:
                    r = rp.value
                    g = gp.value
                    b = bp.value
                    p3_pos = bp.next
            if r != 15 or g != 23 or b != 42:
                non_bg = non_bg + 1
            if r > 210 and g > 210 and b > 210:
                bright = bright + 1
            if max3(r, g, b) - min3(r, g, b) > 65:
                accent = accent + 1
            if (x % 17) == 0 and (y % 13) == 0:
                checksum = fnv_step(checksum, r, g, b)
            x = x + 1
        y = y + 1
    if status == "pass" and non_bg < 16000:
        status = "fail"
        reason = "too-few-rendered-pixels"
    elif status == "pass" and bright < 200:
        status = "fail"
        reason = "missing-text-or-highlight-pixels"
    elif status == "pass" and accent < 4000:
        status = "fail"
        reason = "missing-colored-window-content"
    Metrics(status: status, reason: reason, width: header.width, height: header.height, non_bg: non_bg, bright: bright, accent: accent, checksum: checksum)

fn print_metrics(metrics: Metrics):
    print "hosted_wm_capture_status=" + metrics.status
    print "hosted_wm_capture_reason=" + metrics.reason
    print "hosted_wm_capture_width=" + metrics.width.to_string()
    print "hosted_wm_capture_height=" + metrics.height.to_string()
    print "hosted_wm_capture_non_background_pixels=" + metrics.non_bg.to_string()
    print "hosted_wm_capture_bright_pixels=" + metrics.bright.to_string()
    print "hosted_wm_capture_accent_pixels=" + metrics.accent.to_string()
    print "hosted_wm_capture_sample_checksum=" + metrics.checksum.to_string()

fn main() -> i32:
    val path = rt_env_get("HOSTED_WM_CAPTURE_PPM") ?? ""
    if path == "":
        print_metrics(fail_metrics("missing-capture-path", 0, 0, 0, 0, 0, 0))
        return 1
    val metrics = validate_ppm(path)
    print_metrics(metrics)
    if metrics.status == "pass":
        return 0
    return 1
