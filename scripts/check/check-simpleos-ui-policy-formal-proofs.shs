#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
CHECK_LEAN="$ROOT_DIR/scripts/check/check-lean-proofs.shs"

require_theorem() {
    file="$1"
    name="$2"
    if ! grep -Eq "^[[:space:]]*theorem[[:space:]]+$name([[:space:]]|:|\\(|$)" "$ROOT_DIR/$file"; then
        echo "FAIL: missing theorem $name in $file" >&2
        exit 1
    fi
}

sh "$CHECK_LEAN" --self-test >/dev/null
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/ui_compositor" "verification/ui_compositor"

require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "merge_covers_left"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "merge_covers_right"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "clip_inside_left"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "clip_inside_right"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "insertSorted_is_perm"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "sortStackingContexts_perm"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "renorm_order_preserving"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "flattenTree_perm_treeSurfaces"

echo "STATUS: PASS simpleos-ui-policy-formal-proofs"
