#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
CHECK_LEAN="$ROOT_DIR/scripts/check/check-lean-proofs.shs"

require_theorem() {
    file="$1"
    name="$2"
    if ! grep -Eq "^[[:space:]]*theorem[[:space:]]+$name([[:space:]]|:|\\(|$)" "$ROOT_DIR/$file"; then
        echo "FAIL: missing theorem $name in $file" >&2
        exit 1
    fi
}

sh "$CHECK_LEAN" --self-test >/dev/null
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/ui_compositor" "verification/ui_compositor"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/aop_weaver" "verification/aop_weaver"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/tensor_dimensions" "verification/tensor_dimensions"

require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "damage_add_contains_new_rect"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "merge_covers_left"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "merge_covers_right"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "clip_inside_left"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "clip_inside_right"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "sortStackingContexts_perm"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "renorm_order_preserving"
require_theorem "src/verification/ui_compositor/UiCompositor/Theorems.lean" "flattenTree_perm_treeSurfaces"
require_theorem "src/verification/aop_weaver/src/AopWeaver/Model.lean" "T1_selection_sorted"
require_theorem "src/verification/aop_weaver/src/AopWeaver/Model.lean" "T2_selection_stable"
require_theorem "src/verification/aop_weaver/src/AopWeaver/Model.lean" "T4_deny_skips_target"
require_theorem "src/verification/aop_weaver/src/AopWeaver/Model.lean" "T5_deny_monotone"
require_theorem "src/verification/aop_weaver/src/AopWeaver/Model.lean" "T6_proceed_linear"
require_theorem "src/verification/tensor_dimensions/src/TensorDimensionsConstraints.lean" "shapesCompatible_rank_mismatch_left"
require_theorem "src/verification/tensor_dimensions/src/TensorDimensions.lean" "matmulShape_deterministic"
require_theorem "src/verification/tensor_dimensions/src/TensorDimensions.lean" "min_le_max_elements"
require_theorem "src/verification/tensor_dimensions/src/TensorMemory.lean" "training_fits_if_max_fits"
require_theorem "src/verification/tensor_dimensions/src/TensorMemoryConstraints.lean" "training_total_min_le_max"

echo "STATUS: PASS simpleos-ui-policy-formal-proofs"
