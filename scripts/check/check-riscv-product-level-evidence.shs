#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT_DIR/bin/simple}"

"$SIMPLE_BIN" test "$ROOT_DIR/test/03_system/app/hardware/feature/riscv_fpga_linux_spec.spl"
sh "$ROOT_DIR/scripts/check/check-riscv-formal-dual-track.shs"
sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" "$@"

echo "STATUS: PASS riscv-product-level-evidence"
