# Metal Generated 2D Readback Harness
#
# Compiles the same MSL kernels generated by check-portable-compute-toolchains.shs
# and dispatches fill/copy/alpha/scroll on the Metal GPU, then reads back results
# to compute checksums.  Output is line-based key=value for the shell wrapper.
#
# Run with:
#   SIMPLE_EXECUTION_MODE=interpret bin/simple run \
#     scripts/check/metal_generated_2d_readback_harness.spl --mode=interpreter
#
# Output lines (on success):
#   submit_attempted=true
#   readback_available=true
#   fill_checksum=<N>
#   copy_checksum=<N>
#   alpha_checksum=<N>
#   scroll_checksum=<N>
#   fill_expected=<N>
#   copy_expected=<N>
#   alpha_expected=<N>
#   scroll_expected=<N>
#   status=pass
#
# Output on failure:
#   submit_attempted=false|true
#   readback_available=false
#   error=<message>
#   status=fail

# ============================================================================
# Raw FFI
# ============================================================================

extern fn rt_metal_is_available() -> i64
extern fn rt_metal_init() -> i64
extern fn rt_metal_device_count() -> i64
extern fn rt_metal_create_device(idx: i64) -> i64
extern fn rt_metal_destroy_device(dev: i64) -> i64
extern fn rt_metal_create_command_queue(dev: i64) -> i64
extern fn rt_metal_destroy_command_queue(q: i64) -> i64
extern fn rt_metal_alloc_buffer(dev: i64, size: i64) -> i64
extern fn rt_metal_free_buffer(buf: i64) -> i64
extern fn rt_metal_compile_shader(dev: i64, source: text) -> i64
extern fn rt_metal_destroy_shader(shader: i64) -> i64
extern fn rt_metal_create_compute_pipeline(dev: i64, shader: i64, entry: text) -> i64
extern fn rt_metal_destroy_pipeline(pipe: i64) -> i64
extern fn rt_metal_create_command_buffer(queue: i64) -> i64
extern fn rt_metal_commit_command_buffer(cmd: i64) -> i64
extern fn rt_metal_wait_completed(cmd: i64) -> i64
extern fn rt_metal_create_compute_encoder(cmd: i64) -> i64
extern fn rt_metal_end_compute_encoder(enc: i64) -> i64
extern fn rt_metal_set_buffer(enc: i64, buf: i64, offset: i64, index: i64) -> i64
extern fn rt_metal_set_bytes(enc: i64, data_ptr: i64, length: i64, index: i64) -> i64
extern fn rt_metal_dispatch_compute(enc: i64, pipe: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> i64
extern fn rt_metal_buffer_download(data_ptr: i64, buffer: i64, size: i64) -> i64
extern fn rt_metal_get_last_error() -> text
extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

# ============================================================================
# MSL source — identical to write_metal_source in check-portable-compute-toolchains.shs
# ============================================================================

val MSL_SRC: text = "#include <metal_stdlib>\nusing namespace metal;\nkernel void simple_2d_fill_u32(device uint* dst [[buffer(0)]], constant uint& value [[buffer(1)]], constant uint& count [[buffer(2)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    dst[gid] = value;\n}\nkernel void simple_2d_copy_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& count [[buffer(2)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    dst[gid] = src[gid];\n}\nkernel void simple_2d_alpha_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& alpha [[buffer(2)]], constant uint& count [[buffer(3)]], uint gid [[thread_position_in_grid]]) {\n    if (gid >= count) { return; }\n    uint s = src[gid];\n    uint d = dst[gid];\n    uint inv = 255u - alpha;\n    uint rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;\n    uint g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;\n    dst[gid] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);\n}\nkernel void simple_2d_scroll_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& width [[buffer(2)]], constant uint& height [[buffer(3)]], constant int& delta_y [[buffer(4)]], uint gid [[thread_position_in_grid]]) {\n    uint count = width * height;\n    if (gid >= count) { return; }\n    uint x = gid % width;\n    uint y = gid / width;\n    int sy = (int)y - delta_y;\n    if (sy < 0 || sy >= (int)height) { dst[gid] = 0u; return; }\n    dst[gid] = src[(uint)sy * width + x];\n}\n"

# ============================================================================
# Constants
# ============================================================================

val N: i64 = 64
val BYTES: i64 = 256   # N * 4

# Fill constants
val FILL_COLOR: i64 = 0xAABBCCDD

# Alpha constants — src=0xFFFF0000 (opaque red), dst=0xFF0000FF (opaque blue), alpha=128
val ALPHA_SRC: i64 = 0xFFFF0000
val ALPHA_DST: i64 = 0xFF0000FF
val ALPHA_VAL: i64 = 128

# Scroll constants — 8x8, shift down by 2
val SCROLL_W: i64 = 8
val SCROLL_H: i64 = 8
val SCROLL_DELTA: i64 = 2
val SCROLL_BYTES: i64 = 256   # 8*8*4

# ============================================================================
# CPU reference computations
# ============================================================================

fn cpu_fill_checksum() -> i64:
    # All N pixels = FILL_COLOR; checksum = N * color (mod 2^32 wrapped)
    val color32 = FILL_COLOR & 0xFFFFFFFF
    (color32 * N) & 0xFFFFFFFF

fn cpu_copy_checksum() -> i64:
    # Copy pixels src[i]=FILL_COLOR → dst; checksum same as fill
    cpu_fill_checksum()

fn cpu_alpha_checksum() -> i64:
    # alpha=128 blend: src=0xFFFF0000, dst=0xFF0000FF
    val s = ALPHA_SRC & 0xFFFFFFFF
    val d = ALPHA_DST & 0xFFFFFFFF
    val a = ALPHA_VAL & 0xFF
    val inv = (255 - a) & 0xFF
    val s_rb = s & 0x00FF00FF
    val d_rb = d & 0x00FF00FF
    val s_g  = s & 0x0000FF00
    val d_g  = d & 0x0000FF00
    val rb = ((s_rb * a) + (d_rb * inv)) >> 8
    val g  = ((s_g  * a) + (d_g  * inv)) >> 8
    val pixel = (0xFF000000 as i64) | (rb & 0x00FF00FF) | (g & 0x0000FF00)
    val pixel32 = pixel & 0xFFFFFFFF
    (pixel32 * N) & 0xFFFFFFFF

fn cpu_scroll_checksum() -> i64:
    # 8x8 grid, scroll down by 2 (src row r maps to dst row r+2)
    # dst rows 0,1 become 0 (black); rows 2..7 get src rows 0..5
    # src pixels all = FILL_COLOR
    var sum: i64 = 0
    var y: i64 = 0
    while y < SCROLL_H:
        val sy = y - SCROLL_DELTA
        var x: i64 = 0
        while x < SCROLL_W:
            val pixel = if (sy < 0 or sy >= SCROLL_H): 0 else: FILL_COLOR & 0xFFFFFFFF
            sum = (sum + pixel) & 0xFFFFFFFF
            x = x + 1
        y = y + 1
    sum

# ============================================================================
# Dispatch helper: 1D kernel with one GPU buffer at index 0
# and setBytes scalars at higher indices
# ============================================================================

# Allocate a 4-byte param block, write a u32 value, return the ptr
fn alloc_u32_param(value: i64) -> i64:
    val p = rt_alloc(4)
    if p != 0:
        rt_ptr_write_i32(p, 0, value)
    p

# Checksum a downloaded host buffer (N pixels of u32 packed in host memory)
fn host_checksum(host: i64, count: i64) -> i64:
    var sum: i64 = 0
    var i: i64 = 0
    while i < count / 2:
        val pair = rt_ptr_read_i64(host, i * 8)
        val lo = pair & 0xFFFFFFFF
        val hi = (pair >> 32) & 0xFFFFFFFF
        sum = (sum + lo + hi) & 0xFFFFFFFF
        i = i + 1
    if count % 2 != 0:
        val pair = rt_ptr_read_i64(host, (count - 1) * 4)
        val lo = pair & 0xFFFFFFFF
        sum = (sum + lo) & 0xFFFFFFFF
    sum

# ============================================================================
# Main
# ============================================================================

fn main() -> i64:
    if rt_metal_is_available() == 0:
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Metal not available on this host")
        print("status=fail")
        return 1

    rt_metal_init()
    if rt_metal_device_count() <= 0:
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=No Metal devices found")
        print("status=fail")
        return 1

    val dev = rt_metal_create_device(0)
    if dev == 0:
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Metal device creation failed")
        print("status=fail")
        return 1

    val queue = rt_metal_create_command_queue(dev)
    if queue == 0:
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Metal command queue creation failed")
        print("status=fail")
        return 1

    val shader = rt_metal_compile_shader(dev, MSL_SRC)
    if shader == 0:
        val err = rt_metal_get_last_error()
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=MSL compile failed: {err}")
        print("status=fail")
        return 1

    val pipe_fill   = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_fill_u32")
    val pipe_copy   = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_copy_u32")
    val pipe_alpha  = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_alpha_u32")
    val pipe_scroll = rt_metal_create_compute_pipeline(dev, shader, "simple_2d_scroll_u32")

    if (pipe_fill == 0 or pipe_copy == 0 or pipe_alpha == 0 or pipe_scroll == 0):
        val err = rt_metal_get_last_error()
        if pipe_fill != 0: rt_metal_destroy_pipeline(pipe_fill)
        if pipe_copy != 0: rt_metal_destroy_pipeline(pipe_copy)
        if pipe_alpha != 0: rt_metal_destroy_pipeline(pipe_alpha)
        if pipe_scroll != 0: rt_metal_destroy_pipeline(pipe_scroll)
        rt_metal_destroy_shader(shader)
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Pipeline creation failed: {err}")
        print("status=fail")
        return 1

    # Allocate GPU buffers
    val buf_fill   = rt_metal_alloc_buffer(dev, BYTES)
    val buf_src    = rt_metal_alloc_buffer(dev, BYTES)
    val buf_dst    = rt_metal_alloc_buffer(dev, BYTES)
    val buf_scroll_src = rt_metal_alloc_buffer(dev, SCROLL_BYTES)
    val buf_scroll_dst = rt_metal_alloc_buffer(dev, SCROLL_BYTES)
    val host_mem   = rt_alloc(BYTES + 8)

    if (buf_fill == 0 or buf_src == 0 or buf_dst == 0 or buf_scroll_src == 0 or buf_scroll_dst == 0 or host_mem == 0):
        if buf_fill != 0: rt_metal_free_buffer(buf_fill)
        if buf_src != 0: rt_metal_free_buffer(buf_src)
        if buf_dst != 0: rt_metal_free_buffer(buf_dst)
        if buf_scroll_src != 0: rt_metal_free_buffer(buf_scroll_src)
        if buf_scroll_dst != 0: rt_metal_free_buffer(buf_scroll_dst)
        if host_mem != 0: rt_free(host_mem)
        rt_metal_destroy_pipeline(pipe_fill)
        rt_metal_destroy_pipeline(pipe_copy)
        rt_metal_destroy_pipeline(pipe_alpha)
        rt_metal_destroy_pipeline(pipe_scroll)
        rt_metal_destroy_shader(shader)
        rt_metal_destroy_command_queue(queue)
        rt_metal_destroy_device(dev)
        print("submit_attempted=false")
        print("readback_available=false")
        print("error=Buffer allocation failed")
        print("status=fail")
        return 1

    print("submit_attempted=true")

    # ---- Fill: simple_2d_fill_u32(dst[0], value[1], count[2]) ----
    var fill_checksum: i64 = -1
    val p_fill_value = alloc_u32_param(FILL_COLOR)
    val p_fill_count = alloc_u32_param(N)
    if (p_fill_value != 0 and p_fill_count != 0):
        val fill_cmd = rt_metal_create_command_buffer(queue)
        if fill_cmd != 0:
            val fill_enc = rt_metal_create_compute_encoder(fill_cmd)
            if fill_enc != 0:
                val buf_fill_local = buf_fill
                rt_metal_set_buffer(fill_enc, buf_fill_local, 0, 0)
                rt_metal_set_bytes(fill_enc, p_fill_value, 4, 1)
                rt_metal_set_bytes(fill_enc, p_fill_count, 4, 2)
                val pipe_fill_local = pipe_fill
                rt_metal_dispatch_compute(fill_enc, pipe_fill_local, N, 1, 1, 64, 1, 1)
                rt_metal_end_compute_encoder(fill_enc)
                rt_metal_commit_command_buffer(fill_cmd)
                rt_metal_wait_completed(fill_cmd)
                val host_fill = rt_alloc(BYTES + 8)
                if host_fill != 0:
                    val dl_ok = rt_metal_buffer_download(host_fill, buf_fill_local, BYTES)
                    if dl_ok != 0:
                        fill_checksum = host_checksum(host_fill, N)
                    rt_free(host_fill)
    if p_fill_value != 0: rt_free(p_fill_value)
    if p_fill_count != 0: rt_free(p_fill_count)

    # ---- Copy: first fill buf_src via fill kernel, then copy to buf_dst ----
    # Reuse fill kernel to populate buf_src
    var copy_checksum: i64 = -1
    val p_src_value = alloc_u32_param(FILL_COLOR)
    val p_src_count = alloc_u32_param(N)
    if (p_src_value != 0 and p_src_count != 0):
        val src_cmd = rt_metal_create_command_buffer(queue)
        if src_cmd != 0:
            val src_enc = rt_metal_create_compute_encoder(src_cmd)
            if src_enc != 0:
                val buf_src_local = buf_src
                rt_metal_set_buffer(src_enc, buf_src_local, 0, 0)
                rt_metal_set_bytes(src_enc, p_src_value, 4, 1)
                rt_metal_set_bytes(src_enc, p_src_count, 4, 2)
                val pipe_fill_l2 = pipe_fill
                rt_metal_dispatch_compute(src_enc, pipe_fill_l2, N, 1, 1, 64, 1, 1)
                rt_metal_end_compute_encoder(src_enc)
                rt_metal_commit_command_buffer(src_cmd)
                rt_metal_wait_completed(src_cmd)
    if p_src_value != 0: rt_free(p_src_value)
    if p_src_count != 0: rt_free(p_src_count)

    # Now copy buf_src -> buf_dst
    val p_copy_count = alloc_u32_param(N)
    if p_copy_count != 0:
        val copy_cmd = rt_metal_create_command_buffer(queue)
        if copy_cmd != 0:
            val copy_enc = rt_metal_create_compute_encoder(copy_cmd)
            if copy_enc != 0:
                val buf_src_lc = buf_src
                val buf_dst_lc = buf_dst
                rt_metal_set_buffer(copy_enc, buf_src_lc, 0, 0)
                rt_metal_set_buffer(copy_enc, buf_dst_lc, 0, 1)
                rt_metal_set_bytes(copy_enc, p_copy_count, 4, 2)
                val pipe_copy_l = pipe_copy
                rt_metal_dispatch_compute(copy_enc, pipe_copy_l, N, 1, 1, 64, 1, 1)
                rt_metal_end_compute_encoder(copy_enc)
                rt_metal_commit_command_buffer(copy_cmd)
                rt_metal_wait_completed(copy_cmd)
                val host_copy = rt_alloc(BYTES + 8)
                if host_copy != 0:
                    val dl_ok2 = rt_metal_buffer_download(host_copy, buf_dst_lc, BYTES)
                    if dl_ok2 != 0:
                        copy_checksum = host_checksum(host_copy, N)
                    rt_free(host_copy)
        rt_free(p_copy_count)

    # ---- Alpha blend: src=ALPHA_SRC into dst=ALPHA_DST with alpha=128 ----
    # First populate src buffer with ALPHA_SRC and dst buffer with ALPHA_DST
    var alpha_checksum: i64 = -1
    val p_asrc_v = alloc_u32_param(ALPHA_SRC)
    val p_asrc_c = alloc_u32_param(N)
    val p_adst_v = alloc_u32_param(ALPHA_DST)
    val p_adst_c = alloc_u32_param(N)
    if (p_asrc_v != 0 and p_asrc_c != 0 and p_adst_v != 0 and p_adst_c != 0):
        # fill buf_src with ALPHA_SRC
        val asrc_cmd = rt_metal_create_command_buffer(queue)
        if asrc_cmd != 0:
            val asrc_enc = rt_metal_create_compute_encoder(asrc_cmd)
            if asrc_enc != 0:
                val buf_src_la = buf_src
                rt_metal_set_buffer(asrc_enc, buf_src_la, 0, 0)
                rt_metal_set_bytes(asrc_enc, p_asrc_v, 4, 1)
                rt_metal_set_bytes(asrc_enc, p_asrc_c, 4, 2)
                val pipe_fill_la = pipe_fill
                rt_metal_dispatch_compute(asrc_enc, pipe_fill_la, N, 1, 1, 64, 1, 1)
                rt_metal_end_compute_encoder(asrc_enc)
                rt_metal_commit_command_buffer(asrc_cmd)
                rt_metal_wait_completed(asrc_cmd)
        # fill buf_dst with ALPHA_DST
        val adst_cmd = rt_metal_create_command_buffer(queue)
        if adst_cmd != 0:
            val adst_enc = rt_metal_create_compute_encoder(adst_cmd)
            if adst_enc != 0:
                val buf_dst_la = buf_dst
                rt_metal_set_buffer(adst_enc, buf_dst_la, 0, 0)
                rt_metal_set_bytes(adst_enc, p_adst_v, 4, 1)
                rt_metal_set_bytes(adst_enc, p_adst_c, 4, 2)
                val pipe_fill_lb = pipe_fill
                rt_metal_dispatch_compute(adst_enc, pipe_fill_lb, N, 1, 1, 64, 1, 1)
                rt_metal_end_compute_encoder(adst_enc)
                rt_metal_commit_command_buffer(adst_cmd)
                rt_metal_wait_completed(adst_cmd)
        # alpha blend buf_src into buf_dst
        val p_alpha_v = alloc_u32_param(ALPHA_VAL)
        val p_alpha_c = alloc_u32_param(N)
        if (p_alpha_v != 0 and p_alpha_c != 0):
            val alpha_cmd = rt_metal_create_command_buffer(queue)
            if alpha_cmd != 0:
                val alpha_enc = rt_metal_create_compute_encoder(alpha_cmd)
                if alpha_enc != 0:
                    val buf_src_laa = buf_src
                    val buf_dst_laa = buf_dst
                    rt_metal_set_buffer(alpha_enc, buf_src_laa, 0, 0)
                    rt_metal_set_buffer(alpha_enc, buf_dst_laa, 0, 1)
                    rt_metal_set_bytes(alpha_enc, p_alpha_v, 4, 2)
                    rt_metal_set_bytes(alpha_enc, p_alpha_c, 4, 3)
                    val pipe_alpha_l = pipe_alpha
                    rt_metal_dispatch_compute(alpha_enc, pipe_alpha_l, N, 1, 1, 64, 1, 1)
                    rt_metal_end_compute_encoder(alpha_enc)
                    rt_metal_commit_command_buffer(alpha_cmd)
                    rt_metal_wait_completed(alpha_cmd)
                    val host_alpha = rt_alloc(BYTES + 8)
                    if host_alpha != 0:
                        val dl_ok3 = rt_metal_buffer_download(host_alpha, buf_dst_laa, BYTES)
                        if dl_ok3 != 0:
                            alpha_checksum = host_checksum(host_alpha, N)
                        rt_free(host_alpha)
            if p_alpha_v != 0: rt_free(p_alpha_v)
            if p_alpha_c != 0: rt_free(p_alpha_c)
    if p_asrc_v != 0: rt_free(p_asrc_v)
    if p_asrc_c != 0: rt_free(p_asrc_c)
    if p_adst_v != 0: rt_free(p_adst_v)
    if p_adst_c != 0: rt_free(p_adst_c)

    # ---- Scroll: fill 8x8 src with FILL_COLOR, scroll down by SCROLL_DELTA ----
    var scroll_checksum: i64 = -1
    val p_ssrc_v = alloc_u32_param(FILL_COLOR)
    val p_ssrc_c = alloc_u32_param(SCROLL_W * SCROLL_H)
    if (p_ssrc_v != 0 and p_ssrc_c != 0):
        # fill scroll src
        val ss_cmd = rt_metal_create_command_buffer(queue)
        if ss_cmd != 0:
            val ss_enc = rt_metal_create_compute_encoder(ss_cmd)
            if ss_enc != 0:
                val buf_ss = buf_scroll_src
                rt_metal_set_buffer(ss_enc, buf_ss, 0, 0)
                rt_metal_set_bytes(ss_enc, p_ssrc_v, 4, 1)
                rt_metal_set_bytes(ss_enc, p_ssrc_c, 4, 2)
                val pipe_fill_lss = pipe_fill
                rt_metal_dispatch_compute(ss_enc, pipe_fill_lss, SCROLL_W * SCROLL_H, 1, 1, 64, 1, 1)
                rt_metal_end_compute_encoder(ss_enc)
                rt_metal_commit_command_buffer(ss_cmd)
                rt_metal_wait_completed(ss_cmd)
        # scroll
        val p_scroll_w = alloc_u32_param(SCROLL_W)
        val p_scroll_h = alloc_u32_param(SCROLL_H)
        val p_scroll_d = alloc_u32_param(SCROLL_DELTA)
        if (p_scroll_w != 0 and p_scroll_h != 0 and p_scroll_d != 0):
            val scroll_cmd = rt_metal_create_command_buffer(queue)
            if scroll_cmd != 0:
                val scroll_enc = rt_metal_create_compute_encoder(scroll_cmd)
                if scroll_enc != 0:
                    val buf_sss = buf_scroll_src
                    val buf_ssd = buf_scroll_dst
                    rt_metal_set_buffer(scroll_enc, buf_sss, 0, 0)
                    rt_metal_set_buffer(scroll_enc, buf_ssd, 0, 1)
                    rt_metal_set_bytes(scroll_enc, p_scroll_w, 4, 2)
                    rt_metal_set_bytes(scroll_enc, p_scroll_h, 4, 3)
                    rt_metal_set_bytes(scroll_enc, p_scroll_d, 4, 4)
                    val pipe_scroll_l = pipe_scroll
                    rt_metal_dispatch_compute(scroll_enc, pipe_scroll_l, SCROLL_W * SCROLL_H, 1, 1, 64, 1, 1)
                    rt_metal_end_compute_encoder(scroll_enc)
                    rt_metal_commit_command_buffer(scroll_cmd)
                    rt_metal_wait_completed(scroll_cmd)
                    val host_scroll = rt_alloc(SCROLL_BYTES + 8)
                    if host_scroll != 0:
                        val dl_ok4 = rt_metal_buffer_download(host_scroll, buf_ssd, SCROLL_BYTES)
                        if dl_ok4 != 0:
                            scroll_checksum = host_checksum(host_scroll, SCROLL_W * SCROLL_H)
                        rt_free(host_scroll)
        if p_scroll_w != 0: rt_free(p_scroll_w)
        if p_scroll_h != 0: rt_free(p_scroll_h)
        if p_scroll_d != 0: rt_free(p_scroll_d)
    if p_ssrc_v != 0: rt_free(p_ssrc_v)
    if p_ssrc_c != 0: rt_free(p_ssrc_c)

    # ---- Cleanup ----
    rt_metal_free_buffer(buf_fill)
    rt_metal_free_buffer(buf_src)
    rt_metal_free_buffer(buf_dst)
    rt_metal_free_buffer(buf_scroll_src)
    rt_metal_free_buffer(buf_scroll_dst)
    rt_free(host_mem)
    rt_metal_destroy_pipeline(pipe_fill)
    rt_metal_destroy_pipeline(pipe_copy)
    rt_metal_destroy_pipeline(pipe_alpha)
    rt_metal_destroy_pipeline(pipe_scroll)
    rt_metal_destroy_shader(shader)
    rt_metal_destroy_command_queue(queue)
    rt_metal_destroy_device(dev)

    # ---- Output ----
    val readback_ok = (fill_checksum >= 0 and copy_checksum >= 0 and alpha_checksum >= 0 and scroll_checksum >= 0)
    val fill_exp = cpu_fill_checksum()
    val copy_exp = cpu_copy_checksum()
    val alpha_exp = cpu_alpha_checksum()
    val scroll_exp = cpu_scroll_checksum()

    print("readback_available={readback_ok}")
    print("fill_checksum={fill_checksum}")
    print("copy_checksum={copy_checksum}")
    print("alpha_checksum={alpha_checksum}")
    print("scroll_checksum={scroll_checksum}")
    print("fill_expected={fill_exp}")
    print("copy_expected={copy_exp}")
    print("alpha_expected={alpha_exp}")
    print("scroll_expected={scroll_exp}")

    val checksums_match = (fill_checksum == fill_exp and copy_checksum == copy_exp and alpha_checksum == alpha_exp and scroll_checksum == scroll_exp)
    if readback_ok and checksums_match:
        print("status=pass")
        return 0

    if not readback_ok:
        print("status=fail")
        print("error=readback failed for one or more ops")
        return 1

    print("status=fail")
    print("error=checksum mismatch: fill={fill_checksum} vs {fill_exp}, copy={copy_checksum} vs {copy_exp}, alpha={alpha_checksum} vs {alpha_exp}, scroll={scroll_checksum} vs {scroll_exp}")
    return 1
