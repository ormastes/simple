#!/bin/sh
# codex-run-guard.shs — operational backstop around `codex` launches.
#
# Wraps the real `codex` binary and enforces process/session guards that AGENTS.md
# "Termination & Runaway Guard" rules ask agents to self-enforce — here as a
# process-level backstop that fires even when an agent ignores those rules:
#
#   1. Pre-flight poison-rollout refusal: refuse `codex resume <id>` when the
#      target rollout already accumulated more than CODEX_GUARD_MAX_RESUME_TOKENS
#      input tokens. Reloading a 99M-179M-token rollout re-triggers the same
#      runaway loop that abnormally ended past sessions — so we block it.
#   2. Wall-clock cap: kill the codex process tree after CODEX_GUARD_MAX_SECONDS.
#   3. RSS cap: kill the codex process tree if its total RSS exceeds
#      CODEX_GUARD_MAX_RSS_MB.
#   4. Live session-token cap: kill the codex tree if the ACTIVE rollout's
#      input-token count exceeds CODEX_GUARD_MAX_SESSION_TOKENS. The runaway
#      poll-loop that abnormally ends sessions (observed: re-running green
#      checks / polling a long-running spec forever) burns tokens unbounded at
#      *low* RSS, so it escapes caps 2-3 and only trips the 8h wall-clock after
#      enormous waste — this cap kills it directly. The active rollout is found
#      via /proc/<pid>/fd over our own codex tree, so it never reads or acts on
#      another concurrent session's rollout. Like cap 1, it always runs.
#   5. Explicit-resume ownership: refuse a second `resume <id>` while either a
#      guarded owner holds the lock or a legacy/direct Codex process is already
#      resuming that session, preventing shared SQLite/WAL contention.
#
# Caps 2 and 3 use the tightest generous defaults for an unattended bypass flag
# (--dangerously-bypass-approvals-and-sandbox / --yolo) and a looser-but-present
# backstop for interactive runs (a human may walk away mid-session). Caps 1 and 4
# always run. All thresholds are env-overridable (set to 0 to disable);
# CODEX_GUARD_FORCE=1 bypasses cap 1.
#
# codex runs in the FOREGROUND (keeps the controlling terminal, so the TUI works
# and no SIGTTIN); a sibling watchdog monitors and kills the tree on breach.
set -eu

log() { echo "[codex-run-guard] $*" >&2; }

# --- resolve the real codex, skipping this wrapper / the repo bin/codex ---------
SELF_REAL=$(cd "$(dirname "$0")" 2>/dev/null && pwd)/$(basename "$0")
REPO_ROOT=$(cd "$(dirname "$0")/../.." 2>/dev/null && pwd)
REPO_CODEX="$REPO_ROOT/bin/codex"                   # our launcher — skip ONLY this one
REAL_CODEX="${CODEX_REAL_BIN:-}"
if [ -z "$REAL_CODEX" ]; then
    _ifs=$IFS; IFS=:
    for _d in $PATH; do
        _c="$_d/codex"
        [ -x "$_c" ] || continue
        case "$(cd "$_d" 2>/dev/null && pwd)/codex" in
            "$SELF_REAL"|"$REPO_CODEX") ;;          # skip ourselves + the repo launcher
            *) REAL_CODEX="$_c"; break ;;           # first other codex on PATH = the real one
        esac
    done
    IFS=$_ifs
fi
if [ -z "$REAL_CODEX" ] || [ ! -x "$REAL_CODEX" ]; then
    log "FATAL: could not locate the real 'codex' binary (set CODEX_REAL_BIN)."
    exit 127
fi

# --- thresholds -----------------------------------------------------------------
MAX_RESUME_TOKENS="${CODEX_GUARD_MAX_RESUME_TOKENS:-20000000}"    # 20M input tokens: refuse poisoned resumes before the observed 99M+ runaway range
# Live per-session runaway cap. Unlike the resume cap, this permits a fresh
# session to make bounded progress while still stopping the observed 99M-179M
# poll-loop before it becomes an unrecoverable rollout. Set to 0 to disable.
MAX_SESSION_TOKENS="${CODEX_GUARD_MAX_SESSION_TOKENS:-50000000}"  # 50M input tokens
POLL_INTERVAL="${CODEX_GUARD_POLL_SECONDS:-15}"

# --- scan args: detect resume <id> and unattended bypass ------------------------
BYPASS=0
RESUME=0
SID=""
_prev=""
for _a in "$@"; do
    case "$_a" in
        --dangerously-bypass-approvals-and-sandbox|--yolo) BYPASS=1 ;;
        resume) RESUME=1 ;;
    esac
    if [ "$RESUME" = 1 ] && [ -z "$SID" ] && [ "$_a" != "resume" ]; then
        case "$_a" in
            -*) : ;;                                # a flag, not the session id
            *)  SID="$_a" ;;                        # first positional after resume
        esac
    fi
    _prev="$_a"
done

# Wall-clock / RSS caps. Bypass/--yolo runs get the tightest generous defaults.
# Interactive runs also get a generous-but-present backstop (was fully off): a
# human can walk away from a session that then spins into the same runaway loop,
# and earlyoom is configured to *avoid* killing codex, so this guard is the only
# RSS backstop. All thresholds stay env-overridable; set to 0 to disable.
if [ "$BYPASS" = 1 ]; then
    MAX_SECONDS="${CODEX_GUARD_MAX_SECONDS:-14400}"     # 4h
    MAX_RSS_MB="${CODEX_GUARD_MAX_RSS_MB:-49152}"       # 48 GiB tree RSS
else
    MAX_SECONDS="${CODEX_GUARD_MAX_SECONDS:-28800}"     # 8h — no interactive session runs this long
    MAX_RSS_MB="${CODEX_GUARD_MAX_RSS_MB:-32768}"       # 32 GiB tree RSS backstop
fi

# --- explicit session ownership + cap 1 poison-rollout refusal -----------------
ROLLOUT=""
if [ "$RESUME" = 1 ] && [ -n "$SID" ]; then
    ROLLOUT=$(find "$HOME/.codex/sessions" -name "rollout-*$SID*.jsonl" 2>/dev/null | head -1 || true)
fi

if [ -n "$ROLLOUT" ]; then
    command -v flock >/dev/null 2>&1 || { log "FATAL: flock is required for resume ownership"; exit 127; }
    exec 9>>"$ROLLOUT.resume.lock"
    if ! flock -n 9; then
        log "REFUSING concurrent resume of $SID: another guarded Codex process owns this session"
        exit 4
    fi

    # A direct/legacy launch has no repo lock. Catch it before starting another
    # writer; guarded peers are already serialized by flock above.
    LIVE_RESUME_PID=$(ps -eo pid=,comm=,args= 2>/dev/null | awk -v sid="$SID" '
        $2 == "codex" || $2 == "node" {
            saw_codex = 0; saw_resume = 0
            for (i = 3; i <= NF; i++) {
                if ($i == "codex" || $i ~ /\/codex$/) saw_codex = 1
                else if (saw_codex && $i == "resume") saw_resume = 1
                else if (saw_resume && $i == sid) { print $1; exit }
            }
        }
    ')
    if [ -n "$LIVE_RESUME_PID" ]; then
        log "REFUSING concurrent resume of $SID: live unguarded Codex process $LIVE_RESUME_PID owns this session"
        exit 4
    fi
fi

if [ -n "$ROLLOUT" ] && [ "$MAX_RESUME_TOKENS" -gt 0 ] 2>/dev/null; then
    PEAK=$(grep -o '"input_tokens":[0-9]\{1,\}' "$ROLLOUT" 2>/dev/null \
           | grep -o '[0-9]\{1,\}' | sort -n | tail -1 || true)
    [ -z "$PEAK" ] && PEAK=0
    if [ "$PEAK" -gt "$MAX_RESUME_TOKENS" ] 2>/dev/null; then
        log "REFUSING resume of $SID: rollout peaked at ${PEAK} input tokens"
        log "  (> CODEX_GUARD_MAX_RESUME_TOKENS=${MAX_RESUME_TOKENS}). This is a runaway/"
        log "  poison rollout — reloading it re-triggers the loop. Start a fresh session,"
        log "  or set CODEX_GUARD_FORCE=1 to override."
        [ "${CODEX_GUARD_FORCE:-0}" = 1 ] || exit 3
        log "  CODEX_GUARD_FORCE=1 set — proceeding against advice."
    fi
fi

# --- launch codex (foreground) + sibling watchdog -------------------------------
if [ "$MAX_SECONDS" -le 0 ] 2>/dev/null && [ "$MAX_RSS_MB" -le 0 ] 2>/dev/null \
   && [ "$MAX_SESSION_TOKENS" -le 0 ] 2>/dev/null; then
    exec "$REAL_CODEX" "$@"            # no runtime caps active: hand off cleanly
fi

GUARD_PID=$$

# sum RSS (KiB) of GUARD_PID's descendants — the codex tree (codex + simple/electron)
tree_rss_kb() {
    _all=$1
    _frontier=$1
    while [ -n "$_frontier" ]; do
        _next=""
        for _p in $_frontier; do
            _kids=$(ps -o pid= --ppid "$_p" 2>/dev/null || true)
            _next="$_next $_kids"
        done
        _frontier=$_next
        _all="$_all $_next"
    done
    _total=0
    for _p in $_all; do
        _r=$(ps -o rss= -p "$_p" 2>/dev/null | tr -d ' ' || true)
        [ -n "$_r" ] && _total=$((_total + _r))
    done
    echo "$_total"
}

kill_tree() {
    _all=$1; _frontier=$1
    while [ -n "$_frontier" ]; do
        _next=""
        for _p in $_frontier; do
            _kids=$(ps -o pid= --ppid "$_p" 2>/dev/null || true)
            _next="$_next $_kids"
        done
        _frontier=$_next; _all="$_all $_next"
    done
    for _p in $_all; do kill -TERM "$_p" 2>/dev/null || true; done
    sleep 3
    for _p in $_all; do kill -KILL "$_p" 2>/dev/null || true; done
}

# Print the rollout-*.jsonl the codex tree currently has open. Found via
# /proc/<pid>/fd over GUARD_PID's codex subtree, so it is bound to OUR session
# and never another concurrent session's rollout. Empty if none is open yet.
tree_active_rollout() {
    _all=$1
    _frontier=$1
    while [ -n "$_frontier" ]; do
        _next=""
        for _p in $_frontier; do
            _kids=$(ps -o pid= --ppid "$_p" 2>/dev/null || true)
            _next="$_next $_kids"
        done
        _frontier=$_next
        _all="$_all $_next"
    done
    for _p in $_all; do
        _r=$(ls -l "/proc/$_p/fd" 2>/dev/null \
             | grep -o '/[^ ]*rollout-[^ ]*\.jsonl' | head -1 || true)
        [ -n "$_r" ] && { echo "$_r"; return 0; }
    done
    return 0   # MUST succeed: caller uses `var=$(...)` under `set -e`; a
               # non-zero return here would kill the whole watchdog subshell.
}

watchdog() {
    _elapsed=0
    while :; do
        sleep "$POLL_INTERVAL"
        _elapsed=$((_elapsed + POLL_INTERVAL))
        # find the codex child of the guard (by command, excluding this guard and
        # the watchdog itself); exit once it's gone.
        _codex=$(ps -o pid=,args= --ppid "$GUARD_PID" 2>/dev/null \
                 | grep -i codex | grep -v codex-run-guard \
                 | awk '{print $1; exit}' || true)
        [ -z "$_codex" ] && return 0
        if [ "$MAX_SECONDS" -gt 0 ] 2>/dev/null && [ "$_elapsed" -ge "$MAX_SECONDS" ]; then
            log "WALL-CLOCK CAP: ${_elapsed}s >= ${MAX_SECONDS}s — killing codex tree."
            kill_tree "$_codex"; return 0
        fi
        if [ "$MAX_RSS_MB" -gt 0 ] 2>/dev/null; then
            _rss_kb=$(tree_rss_kb "$_codex")
            _rss_mb=$((_rss_kb / 1024))
            if [ "$_rss_mb" -ge "$MAX_RSS_MB" ]; then
                log "RSS CAP: tree ${_rss_mb}MiB >= ${MAX_RSS_MB}MiB — killing codex tree."
                kill_tree "$_codex"; return 0
            fi
        fi
        if [ "$MAX_SESSION_TOKENS" -gt 0 ] 2>/dev/null; then
            _roll=$(tree_active_rollout "$_codex")
            if [ -n "$_roll" ] && [ -f "$_roll" ]; then
                # input_tokens is cumulative, so the tail holds the current peak;
                # read only the tail to stay cheap on multi-hundred-MB rollouts.
                _tok=$(tail -c 1048576 "$_roll" 2>/dev/null \
                       | grep -o '"input_tokens":[0-9]\{1,\}' \
                       | grep -o '[0-9]\{1,\}' | sort -n | tail -1 || true)
                [ -z "$_tok" ] && _tok=0
                if [ "$_tok" -ge "$MAX_SESSION_TOKENS" ] 2>/dev/null; then
                    log "SESSION-TOKEN CAP: rollout input_tokens ${_tok} >= ${MAX_SESSION_TOKENS} — runaway poll-loop; killing codex tree."
                    kill_tree "$_codex"; return 0
                fi
            fi
        fi
    done
}

log "guard active (bypass=$BYPASS max_seconds=$MAX_SECONDS max_rss_mb=$MAX_RSS_MB max_session_tokens=$MAX_SESSION_TOKENS) -> $REAL_CODEX"
watchdog 9>&- &
WD=$!
trap 'kill "$WD" 2>/dev/null || true' EXIT INT TERM
# codex runs in the FOREGROUND so the TUI keeps the controlling terminal (no
# SIGTTIN); the backgrounded watchdog kills the tree on a wall-clock/RSS breach.
RC=0
"$REAL_CODEX" "$@" || RC=$?
kill "$WD" 2>/dev/null || true
exit $RC
