#!/bin/sh
# Production GUI-window + taskbar-shell widget rendering evidence.
#
# Builds a realistic Simple GUI window and the SimpleOS taskbar shell through
# the shared common.ui builder, wraps each in a themed HTML document, and
# renders them on the REAL Simple Web layout renderer over Engine2D/Metal.
# Fail-closed: both fixtures must render on the resolved backend with the
# light-theme generate_css surface tokens present (background/panel/accent).
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/production_gui_window_taskbar_widget_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_window_taskbar_widget_evidence_$(date -u +%F).md}"

WINDOW_WIDTH="${PRODUCTION_GUI_WINDOW_WIDTH:-320}"
WINDOW_HEIGHT="${PRODUCTION_GUI_WINDOW_HEIGHT:-200}"
TASKBAR_WIDTH="${PRODUCTION_GUI_TASKBAR_WIDTH:-480}"
TASKBAR_HEIGHT="${PRODUCTION_GUI_TASKBAR_HEIGHT:-64}"
TIMEOUT_SECS="${PRODUCTION_GUI_WIDGET_SHELL_TIMEOUT_SECS:-600}"

have() {
    command -v "$1" >/dev/null 2>&1
}

SIMPLE_BIN_EXPLICIT="${SIMPLE_BIN+x}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [ -z "$SIMPLE_BIN_EXPLICIT" ]; then
    SIMPLE_BIN_SOURCE="missing-self-hosted"
    for candidate in \
        "bin/simple" \
        "./bin/simple" \
        "release"/*/simple \
        "bin/release"/*/simple \
        "build/bootstrap/stage3/simple"
    do
        if [ -x "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            SIMPLE_BIN_SOURCE="repo-self-hosted-fallback"
            break
        fi
    done
    if [ "${SIMPLE_BIN:-}" = "" ] && [ "${ALLOW_PATH_SIMPLE_BIN:-0}" = "1" ] && have simple; then
        SIMPLE_BIN="$(command -v simple)"
        SIMPLE_BIN_SOURCE="path-opt-in"
    fi
fi
SIMPLE_BIN="${SIMPLE_BIN:-}"
if [ "$SIMPLE_BIN" = "" ]; then
    SIMPLE_BIN_STATUS=missing
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS

EVIDENCE_SRC="$BUILD_DIR/window_taskbar_widget_evidence.spl"
EVIDENCE_LOG="$BUILD_DIR/evidence.log"
ENV_PATH="$BUILD_DIR/evidence.env"

run_with_timeout() {
    if have timeout; then
        timeout "$TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

field_of() {
    key="$1"
    sed -n "s/^${key}=//p" "$EVIDENCE_LOG" | tail -n 1
}

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$EVIDENCE_SRC" "$EVIDENCE_LOG" "$ENV_PATH" "$REPORT_PATH"

cat >"$EVIDENCE_SRC" <<SIMPLE
use app.wm_compare.production_gui_window_taskbar_widget_shells.{run_gui_window_widget_shell_render, run_taskbar_shell_widget_render}

fn main():
    val w = run_gui_window_widget_shell_render(${WINDOW_WIDTH}, ${WINDOW_HEIGHT})
    print "production_gui_window_widget_status=" + w.status
    print "production_gui_window_widget_reason=" + w.reason
    print "production_gui_window_widget_fixture=" + w.fixture
    print "production_gui_window_widget_width=" + w.width.to_text()
    print "production_gui_window_widget_height=" + w.height.to_text()
    print "production_gui_window_widget_html_len=" + w.html_len.to_text()
    print "production_gui_window_widget_has_widget_markup=" + w.has_widget_markup.to_text()
    print "production_gui_window_widget_has_style_block=" + w.has_style_block.to_text()
    print "production_gui_window_widget_routes_pinned_stub=" + w.routes_pinned_stub.to_text()
    print "production_gui_window_widget_resolved_backend=" + w.resolved_backend
    print "production_gui_window_widget_pixel_count=" + w.pixel_count.to_text()
    print "production_gui_window_widget_distinct_colors=" + w.distinct_colors.to_text()
    print "production_gui_window_widget_bg_pixel_count=" + w.bg_pixel_count.to_text()
    print "production_gui_window_widget_panel_pixel_count=" + w.panel_pixel_count.to_text()
    print "production_gui_window_widget_accent_pixel_count=" + w.accent_pixel_count.to_text()
    print "production_gui_window_widget_themed_pixel_count=" + w.themed_pixel_count.to_text()
    print "production_gui_window_widget_first_pixel=" + w.first_pixel.to_text()
    print "production_gui_window_widget_checksum=" + w.checksum.to_text()
    print "production_gui_window_widget_render_elapsed_us=" + w.render_elapsed_us.to_text()
    val t = run_taskbar_shell_widget_render(${TASKBAR_WIDTH}, ${TASKBAR_HEIGHT})
    print "production_gui_taskbar_widget_status=" + t.status
    print "production_gui_taskbar_widget_reason=" + t.reason
    print "production_gui_taskbar_widget_fixture=" + t.fixture
    print "production_gui_taskbar_widget_width=" + t.width.to_text()
    print "production_gui_taskbar_widget_height=" + t.height.to_text()
    print "production_gui_taskbar_widget_html_len=" + t.html_len.to_text()
    print "production_gui_taskbar_widget_has_widget_markup=" + t.has_widget_markup.to_text()
    print "production_gui_taskbar_widget_has_style_block=" + t.has_style_block.to_text()
    print "production_gui_taskbar_widget_routes_pinned_stub=" + t.routes_pinned_stub.to_text()
    print "production_gui_taskbar_widget_resolved_backend=" + t.resolved_backend
    print "production_gui_taskbar_widget_pixel_count=" + t.pixel_count.to_text()
    print "production_gui_taskbar_widget_distinct_colors=" + t.distinct_colors.to_text()
    print "production_gui_taskbar_widget_bg_pixel_count=" + t.bg_pixel_count.to_text()
    print "production_gui_taskbar_widget_panel_pixel_count=" + t.panel_pixel_count.to_text()
    print "production_gui_taskbar_widget_accent_pixel_count=" + t.accent_pixel_count.to_text()
    print "production_gui_taskbar_widget_themed_pixel_count=" + t.themed_pixel_count.to_text()
    print "production_gui_taskbar_widget_first_pixel=" + t.first_pixel.to_text()
    print "production_gui_taskbar_widget_checksum=" + t.checksum.to_text()
    print "production_gui_taskbar_widget_render_elapsed_us=" + t.render_elapsed_us.to_text()
    val overall = if w.status == "pass" and t.status == "pass": "pass" else: "fail"
    print "production_gui_widget_shells_status=" + overall
SIMPLE

if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    {
        echo "production_gui_widget_shells_status=unavailable"
        echo "production_gui_widget_shells_reason=simple-bin-$SIMPLE_BIN_STATUS"
        echo "production_gui_window_widget_status=unavailable"
        echo "production_gui_taskbar_widget_status=unavailable"
        echo "production_gui_widget_shells_simple_bin=$SIMPLE_BIN"
        echo "production_gui_widget_shells_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "production_gui_widget_shells_simple_bin_status=$SIMPLE_BIN_STATUS"
    } >"$ENV_PATH"
    cp "$ENV_PATH" "$EVIDENCE_LOG"
    cat "$ENV_PATH"
    exit 1
fi

set +e
SIMPLE_LIB="${SIMPLE_LIB:-src}" SIMPLE_EXECUTION_MODE=interpret SIMPLE_EXECUTION_LIMIT=0 \
    run_with_timeout "$SIMPLE_BIN" run "$EVIDENCE_SRC" --mode=interpreter --clean >"$EVIDENCE_LOG" 2>&1
code=$?
set -e

if [ "$code" -eq 124 ]; then
    {
        echo "production_gui_widget_shells_status=timeout"
        echo "production_gui_widget_shells_reason=widget-shell-render-timeout"
        echo "production_gui_widget_shells_timeout_secs=$TIMEOUT_SECS"
        echo "production_gui_window_widget_status=timeout"
        echo "production_gui_taskbar_widget_status=timeout"
        echo "production_gui_widget_shells_simple_bin=$SIMPLE_BIN"
        echo "production_gui_widget_shells_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "production_gui_widget_shells_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "production_gui_widget_shells_evidence_log=$EVIDENCE_LOG"
    } >"$ENV_PATH"
elif [ "$code" -ne 0 ]; then
    {
        echo "production_gui_widget_shells_status=fail"
        echo "production_gui_widget_shells_reason=simple-evidence-run-failed"
        echo "production_gui_widget_shells_exit_code=$code"
        echo "production_gui_window_widget_status=fail"
        echo "production_gui_taskbar_widget_status=fail"
        echo "production_gui_widget_shells_simple_bin=$SIMPLE_BIN"
        echo "production_gui_widget_shells_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "production_gui_widget_shells_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "production_gui_widget_shells_evidence_log=$EVIDENCE_LOG"
    } >"$ENV_PATH"
else
    overall="$(field_of production_gui_widget_shells_status)"
    reason=pass
    if [ "$overall" != "pass" ]; then
        reason=widget-shell-render-failed
    fi
    {
        echo "production_gui_widget_shells_status=$overall"
        echo "production_gui_widget_shells_reason=$reason"
        for key in \
            production_gui_window_widget_status \
            production_gui_window_widget_reason \
            production_gui_window_widget_fixture \
            production_gui_window_widget_width \
            production_gui_window_widget_height \
            production_gui_window_widget_html_len \
            production_gui_window_widget_has_widget_markup \
            production_gui_window_widget_has_style_block \
            production_gui_window_widget_routes_pinned_stub \
            production_gui_window_widget_resolved_backend \
            production_gui_window_widget_pixel_count \
            production_gui_window_widget_distinct_colors \
            production_gui_window_widget_bg_pixel_count \
            production_gui_window_widget_panel_pixel_count \
            production_gui_window_widget_accent_pixel_count \
            production_gui_window_widget_themed_pixel_count \
            production_gui_window_widget_first_pixel \
            production_gui_window_widget_checksum \
            production_gui_window_widget_render_elapsed_us \
            production_gui_taskbar_widget_status \
            production_gui_taskbar_widget_reason \
            production_gui_taskbar_widget_fixture \
            production_gui_taskbar_widget_width \
            production_gui_taskbar_widget_height \
            production_gui_taskbar_widget_html_len \
            production_gui_taskbar_widget_has_widget_markup \
            production_gui_taskbar_widget_has_style_block \
            production_gui_taskbar_widget_routes_pinned_stub \
            production_gui_taskbar_widget_resolved_backend \
            production_gui_taskbar_widget_pixel_count \
            production_gui_taskbar_widget_distinct_colors \
            production_gui_taskbar_widget_bg_pixel_count \
            production_gui_taskbar_widget_panel_pixel_count \
            production_gui_taskbar_widget_accent_pixel_count \
            production_gui_taskbar_widget_themed_pixel_count \
            production_gui_taskbar_widget_first_pixel \
            production_gui_taskbar_widget_checksum \
            production_gui_taskbar_widget_render_elapsed_us
        do
            echo "$key=$(field_of "$key")"
        done
        echo "production_gui_widget_shells_blur_or_tolerance_used=false"
        echo "production_gui_widget_shells_simple_bin=$SIMPLE_BIN"
        echo "production_gui_widget_shells_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "production_gui_widget_shells_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "production_gui_widget_shells_evidence_log=$EVIDENCE_LOG"
    } >"$ENV_PATH"
fi

{
    echo "# Production GUI Window + Taskbar Shell Widget Evidence"
    echo
    echo "- status: $(sed -n 's/^production_gui_widget_shells_status=//p' "$ENV_PATH" | tail -n 1)"
    echo "- reason: $(sed -n 's/^production_gui_widget_shells_reason=//p' "$ENV_PATH" | tail -n 1)"
    echo "- window fixture: ${WINDOW_WIDTH}x${WINDOW_HEIGHT} status=$(sed -n 's/^production_gui_window_widget_status=//p' "$ENV_PATH" | tail -n 1) backend=$(sed -n 's/^production_gui_window_widget_resolved_backend=//p' "$ENV_PATH" | tail -n 1)"
    echo "- window pixels: $(sed -n 's/^production_gui_window_widget_pixel_count=//p' "$ENV_PATH" | tail -n 1) distinct=$(sed -n 's/^production_gui_window_widget_distinct_colors=//p' "$ENV_PATH" | tail -n 1) panel=$(sed -n 's/^production_gui_window_widget_panel_pixel_count=//p' "$ENV_PATH" | tail -n 1) accent=$(sed -n 's/^production_gui_window_widget_accent_pixel_count=//p' "$ENV_PATH" | tail -n 1) checksum=$(sed -n 's/^production_gui_window_widget_checksum=//p' "$ENV_PATH" | tail -n 1)"
    echo "- taskbar fixture: ${TASKBAR_WIDTH}x${TASKBAR_HEIGHT} status=$(sed -n 's/^production_gui_taskbar_widget_status=//p' "$ENV_PATH" | tail -n 1) backend=$(sed -n 's/^production_gui_taskbar_widget_resolved_backend=//p' "$ENV_PATH" | tail -n 1)"
    echo "- taskbar pixels: $(sed -n 's/^production_gui_taskbar_widget_pixel_count=//p' "$ENV_PATH" | tail -n 1) distinct=$(sed -n 's/^production_gui_taskbar_widget_distinct_colors=//p' "$ENV_PATH" | tail -n 1) panel=$(sed -n 's/^production_gui_taskbar_widget_panel_pixel_count=//p' "$ENV_PATH" | tail -n 1) accent=$(sed -n 's/^production_gui_taskbar_widget_accent_pixel_count=//p' "$ENV_PATH" | tail -n 1) checksum=$(sed -n 's/^production_gui_taskbar_widget_checksum=//p' "$ENV_PATH" | tail -n 1)"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$ENV_PATH"
    echo
    echo "## Evidence Log"
    sed 's/^/- /' "$EVIDENCE_LOG" 2>/dev/null || true
} >"$REPORT_PATH"

cat "$ENV_PATH"
echo "report_path=$REPORT_PATH"

final_status="$(sed -n 's/^production_gui_widget_shells_status=//p' "$ENV_PATH" | tail -n 1)"
[ "$final_status" = "pass" ]
