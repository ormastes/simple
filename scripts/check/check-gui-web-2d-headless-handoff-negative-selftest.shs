#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SELFTEST_ROOT="${BUILD_DIR:-build/gui_web_2d_headless_handoff_negative_selftest}"
mkdir -p "$SELFTEST_ROOT"

FRESHNESS_GATE="cross-platform-freshness"
FRESHNESS_HOST="cross-platform-freshness:main-plus-platform-freshness-review"
FRESHNESS_RUNBOOK="cross-platform-freshness:doc/03_plan/agent_tasks/gui_rendering_parallel_agent_plan_2026-06-27.md+scripts/check/check-gui-web-2d-headless-handoff-prep.shs"
FRESHNESS_PROOF="cross-platform-freshness:same-source-revision+runtime-build+browser-webview-electron-revision+graphics-sdk-driver+runbook-version"
BASE_GATES="linux-vulkan-renderdoc|macos-metal-xcode-gpu-capture|windows-d3d12-pix|ios-tauri-wkwebview-metal|android-tauri-webview-vulkan|retained-4k-8k-current-source|full-html-css|production-gui-web-parity|$FRESHNESS_GATE"
BAD_DUPLICATE_GATES="linux-vulkan-renderdoc|linux-vulkan-renderdoc|windows-d3d12-pix|ios-tauri-wkwebview-metal|android-tauri-webview-vulkan|retained-4k-8k-current-source|full-html-css|production-gui-web-parity|$FRESHNESS_GATE"
BAD_EMPTY_GATE_GATES="linux-vulkan-renderdoc||windows-d3d12-pix"
BAD_EMPTY_GATE_HOSTS="linux-vulkan-renderdoc:prepared-ubuntu-gui-vulkan-renderdoc|:empty-gate-host|windows-d3d12-pix:windows-gui-d3d12-pix"
BAD_EMPTY_GATE_RUNBOOKS="linux-vulkan-renderdoc:scripts/setup/setup-gui-web-2d-vulkan-env.shs|:empty-gate-runbook|windows-d3d12-pix:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md"
BAD_EMPTY_GATE_PROOFS="linux-vulkan-renderdoc:browser-backing+simple-backend+argb-pairwise+rdoc-magic+linux-render-log|:empty-gate-proof|windows-d3d12-pix:d3d12-readback+browser-backing+argb-pairwise+pix-artifact+gpu-debugger"
BAD_HOSTS_SHORT="linux-vulkan-renderdoc:prepared-ubuntu-gui-vulkan-renderdoc|macos-metal-xcode-gpu-capture:macos-gui-metal-xcode|windows-d3d12-pix:windows-gui-d3d12-pix|ios-tauri-wkwebview-metal:macos-ios-simulator-or-device|android-tauri-webview-vulkan:android-emulator-or-device-vulkan|retained-4k-8k-current-source:perf-capable-native-gui-host|full-html-css:headless-or-gui-source-plus-renderer-evidence"
BAD_HOSTS="linux-vulkan-renderdoc:prepared-ubuntu-gui-vulkan-renderdoc|bad-macos-gate:macos-gui-metal-xcode|windows-d3d12-pix:windows-gui-d3d12-pix|ios-tauri-wkwebview-metal:macos-ios-simulator-or-device|android-tauri-webview-vulkan:android-emulator-or-device-vulkan|retained-4k-8k-current-source:perf-capable-native-gui-host|full-html-css:headless-or-gui-source-plus-renderer-evidence|production-gui-web-parity:gui-host-with-tauri-chrome-backend-readback|$FRESHNESS_HOST"
BAD_HOSTS_EMPTY_VALUE="linux-vulkan-renderdoc:prepared-ubuntu-gui-vulkan-renderdoc|macos-metal-xcode-gpu-capture:|windows-d3d12-pix:windows-gui-d3d12-pix|ios-tauri-wkwebview-metal:macos-ios-simulator-or-device|android-tauri-webview-vulkan:android-emulator-or-device-vulkan|retained-4k-8k-current-source:perf-capable-native-gui-host|full-html-css:headless-or-gui-source-plus-renderer-evidence|production-gui-web-parity:gui-host-with-tauri-chrome-backend-readback|$FRESHNESS_HOST"
BAD_HOSTS_MALFORMED="linux-vulkan-renderdoc:prepared-ubuntu-gui-vulkan-renderdoc|macos-metal-xcode-gpu-capture|windows-d3d12-pix:windows-gui-d3d12-pix|ios-tauri-wkwebview-metal:macos-ios-simulator-or-device|android-tauri-webview-vulkan:android-emulator-or-device-vulkan|retained-4k-8k-current-source:perf-capable-native-gui-host|full-html-css:headless-or-gui-source-plus-renderer-evidence|production-gui-web-parity:gui-host-with-tauri-chrome-backend-readback|$FRESHNESS_HOST"
BAD_RUNBOOKS_SHORT="linux-vulkan-renderdoc:scripts/setup/setup-gui-web-2d-vulkan-env.shs+scripts/tool/renderdoc-evidence.shs+scripts/check/check-linux-vulkan-render-log-compare.shs|macos-metal-xcode-gpu-capture:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md|windows-d3d12-pix:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md|ios-tauri-wkwebview-metal:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|android-tauri-webview-vulkan:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|retained-4k-8k-current-source:scripts/check/check-widget-showcase-4k-200fps.shs|full-html-css:scripts/check/check-html-css-full-rendering-goal-status.shs"
BAD_RUNBOOKS="linux-vulkan-renderdoc:scripts/setup/setup-gui-web-2d-vulkan-env.shs+scripts/tool/renderdoc-evidence.shs+scripts/check/check-linux-vulkan-render-log-compare.shs|macos-metal-xcode-gpu-capture:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md|bad-windows-gate:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md|ios-tauri-wkwebview-metal:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|android-tauri-webview-vulkan:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|retained-4k-8k-current-source:scripts/check/check-widget-showcase-4k-200fps.shs|full-html-css:scripts/check/check-html-css-full-rendering-goal-status.shs|production-gui-web-parity:scripts/check/check-production-gui-web-renderer-parity-evidence.shs|$FRESHNESS_RUNBOOK"
BAD_RUNBOOKS_EMPTY_VALUE="linux-vulkan-renderdoc:scripts/setup/setup-gui-web-2d-vulkan-env.shs+scripts/tool/renderdoc-evidence.shs+scripts/check/check-linux-vulkan-render-log-compare.shs|macos-metal-xcode-gpu-capture:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md|windows-d3d12-pix:|ios-tauri-wkwebview-metal:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|android-tauri-webview-vulkan:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|retained-4k-8k-current-source:scripts/check/check-widget-showcase-4k-200fps.shs|full-html-css:scripts/check/check-html-css-full-rendering-goal-status.shs|production-gui-web-parity:scripts/check/check-production-gui-web-renderer-parity-evidence.shs|$FRESHNESS_RUNBOOK"
BAD_RUNBOOKS_MALFORMED="linux-vulkan-renderdoc:scripts/setup/setup-gui-web-2d-vulkan-env.shs+scripts/tool/renderdoc-evidence.shs+scripts/check/check-linux-vulkan-render-log-compare.shs|macos-metal-xcode-gpu-capture:doc/07_guide/app/ui/gui_web_2d_vulkan_setup.md|windows-d3d12-pix|ios-tauri-wkwebview-metal:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|android-tauri-webview-vulkan:doc/07_guide/platform/mobile/tauri_mobile_guide.md+scripts/check/check-tauri-mobile-renderer-parity-evidence.shs|retained-4k-8k-current-source:scripts/check/check-widget-showcase-4k-200fps.shs|full-html-css:scripts/check/check-html-css-full-rendering-goal-status.shs|production-gui-web-parity:scripts/check/check-production-gui-web-renderer-parity-evidence.shs|$FRESHNESS_RUNBOOK"
BAD_PROOFS_SHORT="linux-vulkan-renderdoc:browser-backing+simple-backend+argb-pairwise+rdoc-magic+linux-render-log|macos-metal-xcode-gpu-capture:metal-readback+browser-backing+argb-pairwise+xcode-gputrace|windows-d3d12-pix:d3d12-readback+browser-backing+argb-pairwise+pix-artifact+gpu-debugger|ios-tauri-wkwebview-metal:ios-screenshot+metal-marker+mdi-proof+render-log-source|android-tauri-webview-vulkan:android-screenshot+vulkan-marker+foreground+mdi-proof+render-log-source|retained-4k-8k-current-source:4k-200fps+8k-200fps+source-revision+rss+checksum+fallback-none|full-html-css:all-html+all-css-inventory+zero-unrendered+animation-css"
BAD_PROOFS="linux-vulkan-renderdoc:browser-backing+simple-backend+argb-pairwise+rdoc-magic+linux-render-log|macos-metal-xcode-gpu-capture:metal-readback+browser-backing+argb-pairwise+xcode-gputrace|windows-d3d12-pix:d3d12-readback+browser-backing+argb-pairwise+pix-artifact+gpu-debugger|ios-tauri-wkwebview-metal:ios-screenshot+metal-marker+mdi-proof+render-log-source|android-tauri-webview-vulkan:android-screenshot+vulkan-marker+foreground+mdi-proof+render-log-source|retained-4k-8k-current-source:4k-200fps+8k-200fps+source-revision+rss+checksum+fallback-none|full-html-css:all-html+all-css-inventory+zero-unrendered+animation-css|bad-production-parity:tauri-chrome-captures+device-readback+event-routing+checksum-match+no-tolerance|$FRESHNESS_PROOF"
BAD_PROOFS_EMPTY_VALUE="linux-vulkan-renderdoc:browser-backing+simple-backend+argb-pairwise+rdoc-magic+linux-render-log|macos-metal-xcode-gpu-capture:metal-readback+browser-backing+argb-pairwise+xcode-gputrace|windows-d3d12-pix:d3d12-readback+browser-backing+argb-pairwise+pix-artifact+gpu-debugger|ios-tauri-wkwebview-metal:|android-tauri-webview-vulkan:android-screenshot+vulkan-marker+foreground+mdi-proof+render-log-source|retained-4k-8k-current-source:4k-200fps+8k-200fps+source-revision+rss+checksum+fallback-none|full-html-css:all-html+all-css-inventory+zero-unrendered+animation-css|production-gui-web-parity:tauri-chrome-captures+device-readback+event-routing+checksum-match+no-tolerance|$FRESHNESS_PROOF"
BAD_PROOFS_MALFORMED="linux-vulkan-renderdoc:browser-backing+simple-backend+argb-pairwise+rdoc-magic+linux-render-log|macos-metal-xcode-gpu-capture:metal-readback+browser-backing+argb-pairwise+xcode-gputrace|windows-d3d12-pix:d3d12-readback+browser-backing+argb-pairwise+pix-artifact+gpu-debugger|ios-tauri-wkwebview-metal|android-tauri-webview-vulkan:android-screenshot+vulkan-marker+foreground+mdi-proof+render-log-source|retained-4k-8k-current-source:4k-200fps+8k-200fps+source-revision+rss+checksum+fallback-none|full-html-css:all-html+all-css-inventory+zero-unrendered+animation-css|production-gui-web-parity:tauri-chrome-captures+device-readback+event-routing+checksum-match+no-tolerance|$FRESHNESS_PROOF"
case_statuses=""

run_expected_failure() {
    name="$1"
    expected_reason="$2"
    out="$SELFTEST_ROOT/$name.out"
    shift 2

    if env \
        GUI_WEB_2D_HEADLESS_HANDOFF_PREP_CONTRACT_SELFTEST=1 \
        BUILD_DIR="$SELFTEST_ROOT/$name" \
        REPORT_PATH="$SELFTEST_ROOT/$name.md" \
        "$@" \
        sh scripts/check/check-gui-web-2d-headless-handoff-prep.shs >"$out" 2>&1; then
        echo "gui_web_2d_headless_handoff_negative_selftest_status=fail"
        echo "gui_web_2d_headless_handoff_negative_selftest_reason=$name-unexpected-pass"
        exit 1
    fi

    if ! grep -q "gui_web_2d_headless_handoff_prep_reason=$expected_reason" "$out"; then
        echo "gui_web_2d_headless_handoff_negative_selftest_status=fail"
        echo "gui_web_2d_headless_handoff_negative_selftest_reason=$name-wrong-reason"
        echo "gui_web_2d_headless_handoff_negative_selftest_expected=$expected_reason"
        exit 1
    fi

    if [ -z "$case_statuses" ]; then
        case_statuses="$name:pass"
    else
        case_statuses="$case_statuses|$name:pass"
    fi
}

run_expected_failure duplicate-gate remaining-live-gate-duplicate \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BAD_DUPLICATE_GATES"

run_expected_failure gate-value remaining-live-gate-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BAD_EMPTY_GATE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_HOSTS="$BAD_EMPTY_GATE_HOSTS" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_RUNBOOKS="$BAD_EMPTY_GATE_RUNBOOKS" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_PROOFS="$BAD_EMPTY_GATE_PROOFS"

run_expected_failure host-count remaining-live-host-count-mismatch \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_HOSTS="$BAD_HOSTS_SHORT"

run_expected_failure runbook-count remaining-live-runbook-count-mismatch \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_RUNBOOKS="$BAD_RUNBOOKS_SHORT"

run_expected_failure proof-count remaining-live-proof-count-mismatch \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_PROOFS="$BAD_PROOFS_SHORT"

run_expected_failure host-value remaining-live-host-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_HOSTS="$BAD_HOSTS_EMPTY_VALUE"

run_expected_failure runbook-value remaining-live-runbook-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_RUNBOOKS="$BAD_RUNBOOKS_EMPTY_VALUE"

run_expected_failure proof-value remaining-live-proof-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_PROOFS="$BAD_PROOFS_EMPTY_VALUE"

run_expected_failure host-format remaining-live-host-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_HOSTS="$BAD_HOSTS_MALFORMED"

run_expected_failure runbook-format remaining-live-runbook-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_RUNBOOKS="$BAD_RUNBOOKS_MALFORMED"

run_expected_failure proof-format remaining-live-proof-value-missing \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_PROOFS="$BAD_PROOFS_MALFORMED"

run_expected_failure host-gate-id remaining-live-host-gate-id-mismatch \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_HOSTS="$BAD_HOSTS"

run_expected_failure runbook-gate-id remaining-live-runbook-gate-id-mismatch \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_RUNBOOKS="$BAD_RUNBOOKS"

run_expected_failure proof-gate-id remaining-live-proof-gate-id-mismatch \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_GATES="$BASE_GATES" \
    GUI_WEB_2D_HEADLESS_HANDOFF_PREP_REMAINING_PROOFS="$BAD_PROOFS"

echo "gui_web_2d_headless_handoff_negative_selftest_status=pass"
echo "gui_web_2d_headless_handoff_negative_selftest_reason=pass"
echo "gui_web_2d_headless_handoff_negative_selftest_cases=duplicate-gate|gate-value|host-count|runbook-count|proof-count|host-value|runbook-value|proof-value|host-format|runbook-format|proof-format|host-gate-id|runbook-gate-id|proof-gate-id"
echo "gui_web_2d_headless_handoff_negative_selftest_case_statuses=$case_statuses"
