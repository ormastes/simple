#!/bin/sh
# HTML/CSS Chrome RenderDoc evidence wrapper over the canonical CLI.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

RDOC_OUTPUT_DIR="${RDOC_HTML_OUT:-${RDOC_OUTPUT_DIR:-build/renderdoc/html-capture}}" \
    scripts/tool/renderdoc-evidence.shs capture-html
