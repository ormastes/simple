#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
CHECK_LEAN="$ROOT_DIR/scripts/check/check-lean-proofs.shs"

require_theorem() {
    file="$1"
    name="$2"
    if ! grep -Eq "^[[:space:]]*theorem[[:space:]]+$name([[:space:]]|:|\\(|$)" "$ROOT_DIR/$file"; then
        echo "FAIL: missing theorem $name in $file" >&2
        exit 1
    fi
}

sh "$CHECK_LEAN" --self-test >/dev/null
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/kernel_scheduler" "verification/kernel_scheduler"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/actor_channel" "verification/actor_channel"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/memory_model_drf" "verification/memory_model_drf"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/kernel_capabilities" "verification/kernel_capabilities"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/memory_capabilities" "verification/memory_capabilities"

require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_acquire_preserves_wf"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_release_never_underflows"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_acquire_full_noop"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_acquire_denied_iff_at_capacity"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_zero_capacity_acquire_denied"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_release_preserves_wf"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_release_preserves_capacity_bound"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "resource_acquire_release_roundtrip"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "steal_fires_above_threshold"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "steal_does_not_fire_at_threshold"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "unpark_done_no_enqueue"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "complete_double_safe"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "complete_done_noop"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "complete_preserves_cpu_assignment"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "complete_records_result_when_not_done"
require_theorem "src/verification/kernel_scheduler/KernelScheduler/Theorems.lean" "complete_preserves_task_id"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "bounded_channel_backpressure_no_overflow"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "send_to_waiter_wakes_without_buffer_growth"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "no_lost_task_recv_parks"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "closed_send_reports_failure"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "closed_send_no_mutation"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "closed_empty_recv_no_park"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "closed_empty_recv_no_mutation"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "legacy_try_send_closed_fails"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "close_drains_parked"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "close_wakes_all_parked"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "dispatch_error_no_halt"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "scheduler_error_no_halt"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "scheduler_error_then_next_ok_dispatches"
require_theorem "src/verification/actor_channel/ActorChannel/Theorems.lean" "scheduler_two_ok_messages_dispatch_in_two_ticks"
require_theorem "src/verification/memory_model_drf/src/MemoryModelDRFConstraints.lean" "two_unordered_writes_same_location_race"
require_theorem "src/verification/memory_model_drf/src/MemoryModelDRFConstraints.lean" "two_unordered_read_write_same_location_race"
require_theorem "src/verification/memory_model_drf/src/MemoryModelDRFConstraints.lean" "two_unordered_lock_release_acquire_same_location_race"
require_theorem "src/verification/memory_model_drf/src/MemoryModelDRFConstraints.lean" "drf_two_synchronized_writes_same_location"
require_theorem "src/verification/memory_model_drf/src/MemoryModelDRF.lean" "scDRF"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "non_escalation"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "revocation_complete"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "default_deny_syscall"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "gate_denies_without_capability"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "empty_set_denies_all"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "empty_set_syscall_denies_all"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "sanitize_init_caps_non_trusted_full_denies_all"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "sanitize_init_caps_non_trusted_full_syscall_denies_all"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "invalid_permission_denies_file_access"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "write_request_requires_write_capability"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "read_request_requires_read_capability"
require_theorem "src/verification/kernel_capabilities/KernelCapabilities/Theorems.lean" "read_write_request_requires_both_capabilities"
require_theorem "src/verification/memory_capabilities/src/MemoryCapabilitiesConstraints.lean" "existing_ref_denies_unique_create"
require_theorem "src/verification/memory_capabilities/src/MemoryCapabilitiesConstraints.lean" "shared_write_any_loc_denied"
require_theorem "src/verification/memory_capabilities/src/MemoryCapabilitiesConstraints.lean" "write_access_iff_same_location_and_unique_cap"

echo "STATUS: PASS simpleos-critical-formal-proofs"
