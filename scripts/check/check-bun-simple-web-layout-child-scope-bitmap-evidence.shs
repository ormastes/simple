#!/bin/sh
set -eu

SIMPLE_WEB_ENGINE2D_SCENE="${SIMPLE_WEB_ENGINE2D_SCENE:-simple-web-layout-child-scope}"
BUILD_DIR="${BUILD_DIR:-build/bun_simple_web_layout_child_scope_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/bun_simple_web_layout_child_scope_bitmap_evidence_$(date -u +%F).md}"
JS_RENDER_RUNTIME="${JS_RENDER_RUNTIME:-bun}"
JS_RENDER_RUNTIME_BIN="${JS_RENDER_RUNTIME_BIN:-bun}"
export SIMPLE_WEB_ENGINE2D_SCENE BUILD_DIR REPORT_PATH JS_RENDER_RUNTIME JS_RENDER_RUNTIME_BIN
exec sh scripts/check/check-simple-web-engine2d-js-bitmap-evidence.shs
