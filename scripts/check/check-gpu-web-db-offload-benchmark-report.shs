#!/usr/bin/env sh
set -eu

if [ "${1:-}" = "--self-test-external-db-measured-parser" ]; then
    python3 - <<'PY'
external_db_measured_targets = {
    "db_clickbench_clickhouse_external_measured": (
        "clickbench_hits_scan_filter_project_1024_row_match",
        "clickhouse_scan_filter_project",
    ),
    "db_tpch_duckdb_external_measured": (
        "tpch_q3_join_aggregate_group_count_1024_row_match",
        "duckdb_tpch_q3_join_aggregate",
    ),
    "db_tpch_postgresql_external_measured": (
        "tpch_q3_join_aggregate_group_count_1024_row_match",
        "postgresql_tpch_q3_join_aggregate",
    ),
    "db_ycsb_mongo_external_measured": (
        "benchbase_ycsb_document_filter_1024_doc_match",
        "mongo_ycsb_document_filter",
    ),
    "db_key_value_redis_valkey_external_measured": (
        "redis_valkey_getset_1024_key_match",
        "redis_valkey_key_value_getset",
    ),
    "db_ann_vector_external_measured": (
        "ann_vector_topk_1024x128_recall_id_match",
        "ann_vector_topk_recall",
    ),
}

def positive_int(value):
    return value.isdigit() and int(value) > 0

def external_db_measured_row(value):
    parts = [part.strip() for part in value.split("|")]
    if len(parts) != 4:
        return ""
    name, dataset, target, query_time_us = parts
    expected = external_db_measured_targets.get(name)
    if not expected:
        return ""
    if dataset != expected[0] or target != expected[1] or not positive_int(query_time_us):
        return ""
    return (
        f"| {name} | external-db-measured | {dataset} | 0 | 0 | 0 | 0 | 1 | "
        f"{target} | 0 | 0 | {query_time_us} | external-db-baseline-driver | true |  | "
        "external-db-baseline-measured |\n"
    )

accepted = external_db_measured_row(
    "db_clickbench_clickhouse_external_measured|"
    "clickbench_hits_scan_filter_project_1024_row_match|"
    "clickhouse_scan_filter_project|901"
)
wrong_target = external_db_measured_row(
    "db_clickbench_clickhouse_external_measured|"
    "clickbench_hits_scan_filter_project_1024_row_match|"
    "duckdb_tpch_q3_join_aggregate|901"
)
zero_time = external_db_measured_row(
    "db_tpch_duckdb_external_measured|"
    "tpch_q3_join_aggregate_group_count_1024_row_match|"
    "duckdb_tpch_q3_join_aggregate|0"
)
unknown = external_db_measured_row(
    "db_unknown_external_measured|"
    "tpch_q3_join_aggregate_group_count_1024_row_match|"
    "duckdb_tpch_q3_join_aggregate|901"
)
if "external-db-baseline-measured" not in accepted:
    raise SystemExit("accepted measured external DB row was rejected")
redis_accepted = external_db_measured_row(
    "db_key_value_redis_valkey_external_measured|"
    "redis_valkey_getset_1024_key_match|"
    "redis_valkey_key_value_getset|905"
)
if "db_key_value_redis_valkey_external_measured" not in redis_accepted:
    raise SystemExit("accepted Redis/Valkey measured external DB row was rejected")
ann_accepted = external_db_measured_row(
    "db_ann_vector_external_measured|"
    "ann_vector_topk_1024x128_recall_id_match|"
    "ann_vector_topk_recall|906"
)
if "db_ann_vector_external_measured" not in ann_accepted:
    raise SystemExit("accepted ANN/vector measured external DB row was rejected")
if wrong_target or zero_time or unknown:
    raise SystemExit("invalid measured external DB row was accepted")
print("STATUS: PASS external DB measured parser self-test")
PY
    exit 0
fi

SPEC="test/05_perf/web_db_offload/gpu_web_db_offload_bench_spec.spl"
CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_cuda_measured_driver.spl"
COLUMNAR_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_columnar_scan_cuda_measured_driver.spl"
JOIN_AGGREGATE_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_join_aggregate_cuda_measured_driver.spl"
DOCUMENT_FILTER_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_document_filter_cuda_measured_driver.spl"
WEB_INFERENCE_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_web_inference_cuda_measured_driver.spl"
WEB_EMBEDDING_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_web_embedding_cuda_measured_driver.spl"
WEB_RANK_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_web_rank_cuda_measured_driver.spl"
WEB_TRANSFORM_CUDA_DRIVER="test/05_perf/web_db_offload/gpu_web_db_offload_web_transform_cuda_measured_driver.spl"
EXTERNAL_DB_BASELINE_DRIVER="scripts/check/check-gpu-web-db-offload-external-db-baselines.shs"
DOC="doc/06_spec/test/05_perf/web_db_offload/gpu_web_db_offload_bench_spec.md"
REPORT="doc/09_report/perf/gpu_web_db_offload_benchmark_2026-06-16.md"
TABLE="doc/10_metrics/perf/gpu_web_db_offload_benchmark.md"
BUILD_DIR="build/perf/gpu_web_db_offload"
EXTERNAL_DB_BASELINE_ROWS="$BUILD_DIR/external-db-baseline-measured-rows.env"
SIMPLE_BIN="${SIMPLE_BIN:-src/compiler_rust/target/debug/simple}"
if [ ! -x "$SIMPLE_BIN" ]; then
    if [ -x "bin/simple" ]; then
        SIMPLE_BIN="bin/simple"
    else
        SIMPLE_BIN="$(command -v simple)"
    fi
fi

"$SIMPLE_BIN" check "$SPEC" "$CUDA_DRIVER" "$COLUMNAR_CUDA_DRIVER" "$JOIN_AGGREGATE_CUDA_DRIVER" "$DOCUMENT_FILTER_CUDA_DRIVER" "$WEB_INFERENCE_CUDA_DRIVER" "$WEB_EMBEDDING_CUDA_DRIVER" "$WEB_RANK_CUDA_DRIVER" "$WEB_TRANSFORM_CUDA_DRIVER"
SIMPLE_LIB=src "$SIMPLE_BIN" test "$SPEC" --mode=interpreter --clean --sequential
SIMPLE_LIB=src "$SIMPLE_BIN" spipe-docgen "$SPEC" --output doc/06_spec --no-index

test -f "$DOC"
grep -q 'db_vector_gpu_hit' "$DOC"
grep -q 'db_vector_native_timing_probe' "$DOC"
grep -q 'web_embedding_tiny_cpu_fallback' "$DOC"
grep -q 'web_inference_device_validated_contract' "$DOC"
grep -q 'web_embedding_device_validated_contract' "$DOC"
grep -q 'web_rank_device_validated_contract' "$DOC"
grep -q 'web_transform_device_validated_contract' "$DOC"
grep -q 'web_transform_validated_profile_throughput_contract' "$DOC"
grep -q 'db_ssd_materialized_scan_device_validated_contract' "$DOC"
grep -q 'db_ssd_materialized_scan_profile_throughput_contract' "$DOC"
grep -q 'db_ssd_materialized_scan_runtime_queue_throughput_contract' "$DOC"
grep -q 'web_framework_inference_runtime_queue_validated_contract' "$DOC"
grep -q 'production_db_web_runtime_queue_throughput_contract' "$DOC"
grep -q 'db_batch_admission_policy_contract' "$DOC"
grep -q 'gpu_transfer_amortization_policy_contract' "$DOC"
grep -q 'db_clickbench_clickhouse_external_baseline_status' "$DOC"
grep -q 'db_tpch_duckdb_external_baseline_status' "$DOC"
grep -q 'db_tpch_postgresql_external_baseline_status' "$DOC"
grep -q 'db_ycsb_mongo_external_baseline_status' "$DOC"
grep -q 'host-safe-mock' "$DOC"
grep -q 'batch-too-small' "$DOC"

CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$CUDA_DRIVER" || true)"
COLUMNAR_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$COLUMNAR_CUDA_DRIVER" || true)"
JOIN_AGGREGATE_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$JOIN_AGGREGATE_CUDA_DRIVER" || true)"
DOCUMENT_FILTER_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$DOCUMENT_FILTER_CUDA_DRIVER" || true)"
WEB_INFERENCE_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$WEB_INFERENCE_CUDA_DRIVER" || true)"
WEB_EMBEDDING_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$WEB_EMBEDDING_CUDA_DRIVER" || true)"
WEB_RANK_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$WEB_RANK_CUDA_DRIVER" || true)"
WEB_TRANSFORM_CUDA_OUTPUT="$(SIMPLE_LIB=src timeout 45 "$SIMPLE_BIN" run "$WEB_TRANSFORM_CUDA_DRIVER" || true)"
mkdir -p "$BUILD_DIR"
if [ "${GPU_WDB_EXTERNAL_DB_BASELINE_OUTPUT:-}" = "" ] && [ -x "$EXTERNAL_DB_BASELINE_DRIVER" ]; then
    GPU_WDB_EXTERNAL_DB_BASELINE_OUTPUT="$(timeout 45 "$EXTERNAL_DB_BASELINE_DRIVER" || true)"
fi
EXTERNAL_DB_STANDARD_SHAPE_MANIFEST="external-db-standard-shape-manifest-unavailable"
if [ -x "$EXTERNAL_DB_BASELINE_DRIVER" ]; then
    EXTERNAL_DB_STANDARD_SHAPE_MANIFEST="$(timeout 10 "$EXTERNAL_DB_BASELINE_DRIVER" --print-standard-shape-manifest || printf '%s\n' 'external-db-standard-shape-manifest-unavailable')"
fi
printf '%s\n' "$GPU_WDB_EXTERNAL_DB_BASELINE_OUTPUT" > "$EXTERNAL_DB_BASELINE_ROWS"
export CUDA_OUTPUT
export COLUMNAR_CUDA_OUTPUT
export JOIN_AGGREGATE_CUDA_OUTPUT
export DOCUMENT_FILTER_CUDA_OUTPUT
export WEB_INFERENCE_CUDA_OUTPUT
export WEB_EMBEDDING_CUDA_OUTPUT
export WEB_RANK_CUDA_OUTPUT
export WEB_TRANSFORM_CUDA_OUTPUT
export GPU_WDB_EXTERNAL_DB_BASELINE_OUTPUT
export EXTERNAL_DB_BASELINE_ROWS
export EXTERNAL_DB_STANDARD_SHAPE_MANIFEST

python3 - <<'PY'
import os
import platform
import shutil
import subprocess
from pathlib import Path

report = Path("doc/09_report/perf/gpu_web_db_offload_benchmark_2026-06-16.md")
table = Path("doc/10_metrics/perf/gpu_web_db_offload_benchmark.md")
report.parent.mkdir(parents=True, exist_ok=True)
table.parent.mkdir(parents=True, exist_ok=True)

header = "| name | backend | dataset | rows | documents | vector_dims | batch_size | call_count | dispatch_target | gpu_hits | cpu_fallbacks | device_time_us | device_timing_source | backend_timing_valid | fallback_reason | hardware_claim |\n"
sep = "|---|---|---|---:|---:|---:|---:|---:|---|---:|---:|---:|---|---|---|---|\n"

def external_db_reason(tool_names, ready_target, unavailable_reason):
    for tool in tool_names:
        if shutil.which(tool):
            return f"external-db-baseline-ready-unmeasured:{ready_target}"
    return unavailable_reason

def external_db_row(name, dataset, target, tool_names, unavailable_reason):
    return (
        f"| {name} | external-db-baseline | {dataset} | 0 | 0 | 0 | 0 | 0 | "
        f"{target} | 0 | 0 | 0 | external-db-baseline-status | false | "
        f"{external_db_reason(tool_names, target, unavailable_reason)} | "
        "none-external-db-baseline-contract |\n"
    )

rows = [
    "| db_vector_gpu_hit | host-safe-mock | oracle_vectors_1024x128 | 1024 | 0 | 128 | 8 | 1 | gpu_db_vector_search_batch | 1 | 0 | 0 | host-derived | false |  | none-host-safe-contract |\n",
    "| db_vector_native_timing_probe | native-device-probe | oracle_vectors_1024x128 | 1024 | 0 | 128 | 8 | 1 | gpu_db_vector_search_batch | 1 | 0 | 37 | native-device-timer | true |  | none-native-provenance-contract |\n",
    "| web_inference_device_validated_contract | cuda | web_inference_16x512_response_match | 0 | 16 | 0 | 16 | 1 | gpu_web_inference_batch | 1 | 0 | 41 | cuda-event-contract | true |  | production-device-validated-contract |\n",
    "| web_embedding_device_validated_contract | cuda | web_embedding_16x512_response_match | 0 | 16 | 0 | 16 | 1 | gpu_web_embedding_batch | 1 | 0 | 43 | cuda-event-contract | true |  | production-device-validated-contract |\n",
    "| web_rank_device_validated_contract | cuda | web_rank_32x256_response_match | 0 | 32 | 0 | 32 | 1 | gpu_web_rank_batch | 1 | 0 | 47 | cuda-event-contract | true |  | production-device-validated-contract |\n",
    "| web_transform_device_validated_contract | cuda | web_transform_8x2048_response_match | 0 | 8 | 0 | 8 | 1 | gpu_web_transform_batch | 1 | 0 | 51 | cuda-event-contract | true |  | production-device-validated-contract |\n",
    "| web_transform_validated_profile_throughput_contract | cuda | web_transform_4x8x2048_response_match | 0 | 32 | 0 | 32 | 4 | gpu_web_transform_batch | 4 | 0 | 204 | cuda-event-contract | true |  | production-device-validated-throughput-contract |\n",
    "| db_ssd_materialized_scan_device_validated_contract | cuda | dbfs_ssd_materialized_scan_2x1024_row_match | 2 | 0 | 0 | 2 | 1 | gpu_db_columnar_scan_batch | 1 | 0 | 37 | cuda-event-contract | true |  | production-device-validated-contract |\n",
    "| db_ssd_materialized_scan_profile_throughput_contract | cuda | dbfs_ssd_materialized_scan_3x2x1024_row_match | 6 | 0 | 0 | 6 | 3 | gpu_db_columnar_scan_batch | 3 | 0 | 111 | cuda-event-contract | true |  | production-device-validated-throughput-contract |\n",
    "| db_ssd_materialized_scan_runtime_queue_throughput_contract | native-device-probe | dbfs_ssd_materialized_scan_2x2x1024_runtime_queue | 4 | 0 | 0 | 4 | 2 | gpu_db_columnar_scan_batch | 2 | 0 | 1 | rt_host_gpu_queue_last_device_time_us | true |  | runtime-queue-measured-throughput-contract |\n",
    "| db_batch_admission_policy_contract | host-safe-admission-policy | db_batch_admission_scan_join_document_policy | 2048 | 1 | 0 | 2049 | 3 | gpu_db_columnar_scan_batch | 1 | 2 | 0 | admission-policy-contract | false | queue-full+batch-too-small-covered | none-admission-policy-contract |\n",
    "| gpu_transfer_amortization_policy_contract | host-safe-transfer-policy | gpu_transfer_amortization_4x8x2048_batch | 0 | 32 | 0 | 32 | 4 | gpu_web_transform_batch | 1 | 0 | 0 | transfer-amortization-policy-contract | false | amortized-transfer-saved:3072 | none-transfer-amortization-policy-contract |\n",
    external_db_row("db_clickbench_clickhouse_external_baseline_status", "clickbench_hits_scan_filter_project_1024_row_match", "clickhouse_scan_filter_project", ["clickhouse", "clickhouse-client"], "external-db-baseline-unavailable:clickhouse-not-installed"),
    external_db_row("db_tpch_duckdb_external_baseline_status", "tpch_q3_join_aggregate_group_count_1024_row_match", "duckdb_tpch_q3_join_aggregate", ["duckdb"], "external-db-baseline-unavailable:duckdb-not-installed"),
    external_db_row("db_tpch_postgresql_external_baseline_status", "tpch_q3_join_aggregate_group_count_1024_row_match", "postgresql_tpch_q3_join_aggregate", ["psql", "pgbench"], "external-db-baseline-unavailable:postgresql-not-installed"),
    external_db_row("db_ycsb_mongo_external_baseline_status", "benchbase_ycsb_document_filter_1024_doc_match", "mongo_ycsb_document_filter", ["mongosh", "mongo"], "external-db-baseline-unavailable:mongo-not-installed"),
    external_db_row("db_key_value_redis_valkey_external_baseline_status", "redis_valkey_getset_1024_key_match", "redis_valkey_key_value_getset", ["redis-cli", "valkey-cli", "redis-benchmark"], "external-db-baseline-unavailable:redis-valkey-not-installed"),
    external_db_row("db_ann_vector_external_baseline_status", "ann_vector_topk_1024x128_recall_id_match", "ann_vector_topk_recall", [], "external-db-baseline-unavailable:ann-fixture-not-configured"),
    "| db_clickbench_olap_scan_shape_contract | host-safe-standard-shape | clickbench_hits_scan_filter_project_1024_row_match | 1024 | 0 | 0 | 8 | 1 | gpu_db_columnar_scan_batch | 0 | 1 | 0 | standard-shape-contract | false | standard-baseline-unavailable:clickhouse-duckdb-postgresql | none-standard-shape-contract |\n",
    "| db_tpch_join_aggregate_shape_contract | host-safe-standard-shape | tpch_q3_join_aggregate_group_count_1024_row_match | 1024 | 0 | 0 | 8 | 1 | gpu_db_join_aggregate_batch | 0 | 1 | 0 | standard-shape-contract | false | standard-baseline-unavailable:tpch-duckdb-postgresql | none-standard-shape-contract |\n",
    "| db_benchbase_ycsb_document_shape_contract | host-safe-standard-shape | benchbase_ycsb_document_filter_1024_doc_match | 0 | 1024 | 0 | 8 | 1 | gpu_db_document_filter_batch | 0 | 1 | 0 | standard-shape-contract | false | standard-baseline-unavailable:benchbase-ycsb-mongo | none-standard-shape-contract |\n",
    "| db_ann_vector_search_shape_contract | host-safe-standard-shape | ann_vector_topk_1024x128_recall_id_match | 1024 | 0 | 128 | 8 | 1 | gpu_db_vector_search_batch | 0 | 1 | 0 | standard-shape-contract | false | standard-baseline-unavailable:ann-fixture | none-standard-shape-contract |\n",
    "| web_framework_inference_runtime_queue_validated_contract | native-device-probe | web_framework_inference_16x512_runtime_queue_response_match | 0 | 16 | 0 | 16 | 1 | gpu_web_inference_batch | 1 | 0 | 1 | rt_host_gpu_queue_last_device_time_us | true |  | runtime-queue-measured-framework-contract |\n",
    "| production_db_web_runtime_queue_throughput_contract | native-device-probe | dbfs_ssd_and_web_framework_runtime_queue_response_match | 4 | 16 | 0 | 20 | 3 | gpu_db_columnar_scan_batch+gpu_web_inference_batch | 3 | 0 | 2 | rt_host_gpu_queue_last_device_time_us | true |  | runtime-queue-production-db-web-throughput-contract |\n",
    "| web_embedding_tiny_cpu_fallback | host-safe-mock | web_payloads_1x_small | 0 | 1 | 0 | 1 | 1 | cpu_fallback | 0 | 1 | 0 | host-derived | false | batch-too-small | none-host-safe-contract |\n",
]

cuda_output = os.environ.get("CUDA_OUTPUT", "")
columnar_cuda_output = os.environ.get("COLUMNAR_CUDA_OUTPUT", "")
join_aggregate_cuda_output = os.environ.get("JOIN_AGGREGATE_CUDA_OUTPUT", "")
document_filter_cuda_output = os.environ.get("DOCUMENT_FILTER_CUDA_OUTPUT", "")
web_inference_cuda_output = os.environ.get("WEB_INFERENCE_CUDA_OUTPUT", "")
web_embedding_cuda_output = os.environ.get("WEB_EMBEDDING_CUDA_OUTPUT", "")
web_rank_cuda_output = os.environ.get("WEB_RANK_CUDA_OUTPUT", "")
web_transform_cuda_output = os.environ.get("WEB_TRANSFORM_CUDA_OUTPUT", "")
external_db_standard_shape_manifest = os.environ.get("EXTERNAL_DB_STANDARD_SHAPE_MANIFEST", "")
def measured_input_text():
    chunks = []
    producer_path = Path(os.environ["EXTERNAL_DB_BASELINE_ROWS"])
    if producer_path.exists():
        chunks.append(producer_path.read_text(encoding="utf-8", errors="replace"))
    chunks.append(os.environ.get("GPU_WDB_EXTERNAL_DB_BASELINE_OUTPUT", ""))
    return "\n".join(chunks)

external_db_output = measured_input_text()
device = {}
for line in cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        device[key.strip()] = value.strip()

columnar_device = {}
for line in columnar_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        columnar_device[key.strip()] = value.strip()

join_aggregate_device = {}
for line in join_aggregate_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        join_aggregate_device[key.strip()] = value.strip()

document_filter_device = {}
for line in document_filter_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        document_filter_device[key.strip()] = value.strip()

web_inference_device = {}
for line in web_inference_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        web_inference_device[key.strip()] = value.strip()

web_embedding_device = {}
for line in web_embedding_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        web_embedding_device[key.strip()] = value.strip()

web_rank_device = {}
for line in web_rank_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        web_rank_device[key.strip()] = value.strip()

web_transform_device = {}
for line in web_transform_cuda_output.splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        web_transform_device[key.strip()] = value.strip()

def positive_int(value):
    return value.isdigit() and int(value) > 0

external_db_measured_targets = {
    "db_clickbench_clickhouse_external_measured": (
        "clickbench_hits_scan_filter_project_1024_row_match",
        "clickhouse_scan_filter_project",
    ),
    "db_tpch_duckdb_external_measured": (
        "tpch_q3_join_aggregate_group_count_1024_row_match",
        "duckdb_tpch_q3_join_aggregate",
    ),
    "db_tpch_postgresql_external_measured": (
        "tpch_q3_join_aggregate_group_count_1024_row_match",
        "postgresql_tpch_q3_join_aggregate",
    ),
    "db_ycsb_mongo_external_measured": (
        "benchbase_ycsb_document_filter_1024_doc_match",
        "mongo_ycsb_document_filter",
    ),
    "db_key_value_redis_valkey_external_measured": (
        "redis_valkey_getset_1024_key_match",
        "redis_valkey_key_value_getset",
    ),
    "db_ann_vector_external_measured": (
        "ann_vector_topk_1024x128_recall_id_match",
        "ann_vector_topk_recall",
    ),
}

def external_db_measured_row(value):
    parts = [part.strip() for part in value.split("|")]
    if len(parts) != 4:
        return ""
    name, dataset, target, query_time_us = parts
    expected = external_db_measured_targets.get(name)
    if not expected:
        return ""
    if dataset != expected[0] or target != expected[1] or not positive_int(query_time_us):
        return ""
    return (
        f"| {name} | external-db-measured | {dataset} | 0 | 0 | 0 | 0 | 1 | "
        f"{target} | 0 | 0 | {query_time_us} | external-db-baseline-driver | true |  | "
        "external-db-baseline-measured |\n"
    )

seen_external_db_measured = set()
measured_external_db_targets = set()
for line in external_db_output.splitlines():
    if not line.startswith("GPU_WDB_EXTERNAL_DB_MEASURED="):
        continue
    if line in seen_external_db_measured:
        continue
    seen_external_db_measured.add(line)
    measured_value = line.split("=", 1)[1]
    measured_row = external_db_measured_row(measured_value)
    if measured_row:
        measured_external_db_targets.add(measured_value.split("|")[2].strip())
        rows.insert(16, measured_row)

measured_status_replacements = {
    "clickhouse_scan_filter_project": "external-db-baseline-unavailable:clickhouse-not-installed",
    "duckdb_tpch_q3_join_aggregate": "external-db-baseline-unavailable:duckdb-not-installed",
    "postgresql_tpch_q3_join_aggregate": "external-db-baseline-unavailable:postgresql-not-installed",
    "mongo_ycsb_document_filter": "external-db-baseline-unavailable:mongo-not-installed",
    "redis_valkey_key_value_getset": "external-db-baseline-unavailable:redis-valkey-not-installed",
    "ann_vector_topk_recall": "external-db-baseline-unavailable:ann-fixture-not-configured",
}
for target in measured_external_db_targets:
    unavailable = measured_status_replacements.get(target)
    if unavailable:
        rows = [
            row.replace(unavailable, f"external-db-baseline-ready-measured:{target}")
            for row in rows
        ]

def command_output(args):
    try:
        out = subprocess.check_output(args, text=True, stderr=subprocess.DEVNULL, timeout=2).strip()
        return "; ".join(line.strip() for line in out.splitlines() if line.strip())
    except Exception:
        return ""

def first_cpu_model():
    try:
        for line in Path("/proc/cpuinfo").read_text(encoding="utf-8", errors="replace").splitlines():
            if line.startswith("model name"):
                return line.split(":", 1)[1].strip()
    except Exception:
        pass
    return platform.processor() or "unknown"

def mem_total():
    try:
        for line in Path("/proc/meminfo").read_text(encoding="utf-8", errors="replace").splitlines():
            if line.startswith("MemTotal:"):
                return " ".join(line.split()[1:3])
    except Exception:
        pass
    return "unknown"

def environment_markdown():
    nvidia = shutil.which("nvidia-smi")
    nvidia_summary = "missing"
    if nvidia:
        nvidia_summary = command_output([nvidia, "--query-gpu=name,driver_version", "--format=csv,noheader"]) or f"available at `{nvidia}`"
    storage = command_output(["df", "-h", "."])
    storage_line = storage.splitlines()[-1] if storage else "unknown"
    simple_runtime = os.environ.get("SIMPLE_BIN", f"auto:{shutil.which('simple') or 'missing'}")
    cuda_visible = os.environ.get("CUDA_VISIBLE_DEVICES", "unset")
    return (
        "## Environment\n\n"
        f"- CPU model: `{first_cpu_model()}`\n"
        f"- CPU cores: `{os.cpu_count() or 'unknown'}`\n"
        f"- Kernel: `{platform.release()}`\n"
        f"- RAM: `{mem_total()}`\n"
        f"- Storage: `{storage_line}`\n"
        f"- CUDA/nvidia-smi: `{nvidia_summary}`\n"
        f"- CUDA_VISIBLE_DEVICES: `{cuda_visible}`\n"
        f"- Simple runtime: `{simple_runtime}`\n\n"
    )

