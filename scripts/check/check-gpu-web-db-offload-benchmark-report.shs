    grep -q '| db_columnar_scan_cuda_measured | cuda | pure_sql_scan_filter_project |' "$REPORT"
    grep -q '| db_join_aggregate_cuda_measured | cuda | pure_sql_join_aggregate_group_count |' "$REPORT"
    grep -q '| db_document_filter_cuda_measured | cuda | nosql_document_filter_metadata |' "$REPORT"
    grep -q '| web_inference_cuda_measured | cuda | web_inference_16x512_response_match |' "$REPORT"
    grep -q '| web_embedding_cuda_measured | cuda | web_embedding_16x512_response_match |' "$REPORT"
    grep -q '| web_rank_cuda_measured | cuda | web_rank_32x256_response_match |' "$REPORT"
    grep -q '| web_transform_cuda_measured | cuda | web_transform_8x2048_response_match |' "$REPORT"
    grep -q 'cuda-measured-driver' "$TABLE"
fi
if grep -q 'external-db-baseline-measured' "$REPORT"; then
    grep -q 'external-db-baseline-driver' "$TABLE"
    grep -Eq 'db_clickbench_clickhouse_external_measured|db_tpch_duckdb_external_measured|db_tpch_postgresql_external_measured|db_ycsb_mongo_external_measured|db_key_value_redis_valkey_external_measured|db_ann_vector_external_measured' "$REPORT"
fi

echo "STATUS: PASS gpu web/db offload benchmark report"
