#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-bin/simple}"
WORK_DIR="${WORK_DIR:-/tmp/check-native-flat-option-map.$$}"
FIXTURE="test/fixtures/native_flat_option_map/main.spl"

test -x "$SIMPLE_BINARY"
mkdir -p "$WORK_DIR"
cleanup() {
    status=$?
    trap - EXIT HUP INT TERM
    if test "$status" -ne 0 && test -f "$WORK_DIR/build.log"; then
        cat "$WORK_DIR/build.log" >&2
    fi
    rm -rf "$WORK_DIR"
    exit "$status"
}
trap cleanup EXIT HUP INT TERM

env -u SIMPLE_BOOTSTRAP SIMPLE_NO_STUB_FALLBACK=1 "$SIMPLE_BINARY" native-build \
    --backend=cranelift --source test/fixtures --entry-closure --entry "$FIXTURE" \
    --cache-dir "$WORK_DIR/cache" --output "$WORK_DIR/probe" >"$WORK_DIR/build.log" 2>&1
set +e
actual="$(timeout 20 "$WORK_DIR/probe" 2>>"$WORK_DIR/build.log")"
status=$?
set -e
if test "$status" -ne 0 || test "$actual" != "flat-option-map-ok"; then
    echo "native-flat-option-map: failed (exit $status, output: $actual)" >&2
    exit 1
fi

echo "native-flat-option-map: pass"
