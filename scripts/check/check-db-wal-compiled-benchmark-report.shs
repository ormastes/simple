#!/usr/bin/env sh
set -eu

SPEC="test/05_perf/db/db_wal_compiled_bench_driver.spl"
BIN="build/perf/db_wal_compiled_bench_driver"
REPORT="doc/09_report/perf/perf_baseline_db_wal_compiled_2026-06-16.md"
TABLE="doc/10_metrics/perf/perf_baseline_db_wal_compiled_table.md"

bin/simple check "$SPEC"
mkdir -p build/perf
SIMPLE_LIB=src bin/simple native-build \
  --source src/lib \
  --source test/05_perf/db \
  --entry "$SPEC" \
  --entry-closure \
  --strip \
  --output "$BIN"

"$BIN" | tee build/perf/db_wal_compiled_bench_driver.out

test -f "$REPORT"
test -f "$TABLE"

grep -q 'STATUS: PASS db wal compiled benchmark' build/perf/db_wal_compiled_bench_driver.out
grep -q '| db_wal_insert100 | wal | insert+count_visible |' "$REPORT"
grep -q '| db_wal_insert100 | wal | insert+count_visible |' "$TABLE"
grep -q 'count_visible == 100' "$REPORT"

echo "STATUS: PASS db wal compiled benchmark report"
