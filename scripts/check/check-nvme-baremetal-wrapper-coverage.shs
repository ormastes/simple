#!/usr/bin/env sh
set -eu

ROOT_DIR="${NVME_WRAPPER_COVERAGE_ROOT:-$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)}"
cd "$ROOT_DIR"

STRICT=0
SELF_TEST=0
while [ "$#" -gt 0 ]; do
    case "$1" in
        --strict)
            STRICT=1
            ;;
        --self-test)
            SELF_TEST=1
            ;;
        *)
            echo "unknown argument: $1" >&2
            exit 2
            ;;
    esac
    shift
done

rv32_boot="examples/09_embedded/simpleos_nvme_fw/fw_rv32/boot.shs"
rv32_spec="test/03_system/app/nvme_firmware/nvme_rv32_baremetal_boot_spec.spl"
rv64_boot="examples/09_embedded/simpleos_nvme_fw/fw_rv64/boot.shs"
rv64_spec="test/03_system/app/nvme_firmware/nvme_rv64_baremetal_boot_spec.spl"

if [ "$SELF_TEST" -eq 1 ]; then
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT

    write_boot() {
        path="$1"
        status="$2"
        mkdir -p "$(dirname -- "$tmp_dir/$path")"
        cat >"$tmp_dir/$path" <<EOF
#!/usr/bin/env sh
[ "\${1:-}" = "--self-test" ] || exit 2
echo "STATUS: PASS $status"
EOF
        chmod +x "$tmp_dir/$path"
    }

    write_spec() {
        path="$1"
        status="$2"
        mkdir -p "$(dirname -- "$tmp_dir/$path")"
        {
            echo "boot.shs --self-test"
            echo "$status"
        } >"$tmp_dir/$path"
    }

    write_fixture() {
        write_boot "$rv32_boot" "nvme-rv32-boot self-test"
        write_spec "$rv32_spec" "STATUS: PASS nvme-rv32-boot self-test"
        write_boot "$rv64_boot" "nvme-rv64-boot self-test"
        write_spec "$rv64_spec" "STATUS: PASS nvme-rv64-boot self-test"
    }

    write_fixture
    NVME_WRAPPER_COVERAGE_ROOT="$tmp_dir" sh "$0" --strict >"$tmp_dir/pass.out"
    grep -Fq "nvme_baremetal_wrapper_coverage_status=pass" "$tmp_dir/pass.out" || {
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: complete fixture did not pass" >&2
        exit 1
    }

    rm -f "$tmp_dir/$rv64_spec"
    NVME_WRAPPER_COVERAGE_ROOT="$tmp_dir" sh "$0" >"$tmp_dir/missing-rv64-spec.out"
    grep -Fq "nvme_baremetal_wrapper_coverage_status=incomplete" "$tmp_dir/missing-rv64-spec.out" || {
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: missing RV64 spec was not incomplete" >&2
        exit 1
    }
    grep -Fq "nvme_baremetal_wrapper_coverage_blockers=rv64_nvme_spec" "$tmp_dir/missing-rv64-spec.out" || {
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: missing RV64 spec blocker absent" >&2
        exit 1
    }
    if NVME_WRAPPER_COVERAGE_ROOT="$tmp_dir" sh "$0" --strict >"$tmp_dir/missing-rv64-spec-strict.out" 2>&1; then
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: strict missing RV64 spec passed" >&2
        exit 1
    fi

    write_fixture
    rm -f "$tmp_dir/$rv64_boot"
    NVME_WRAPPER_COVERAGE_ROOT="$tmp_dir" sh "$0" >"$tmp_dir/missing-rv64-wrapper.out"
    grep -Fq "nvme_baremetal_wrapper_coverage_blockers=rv64_nvme_wrapper" "$tmp_dir/missing-rv64-wrapper.out" || {
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: missing RV64 wrapper blocker absent" >&2
        exit 1
    }

    write_fixture
    rm -f "$tmp_dir/$rv32_boot"
    if NVME_WRAPPER_COVERAGE_ROOT="$tmp_dir" sh "$0" >"$tmp_dir/missing-rv32-wrapper.out" 2>&1; then
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: missing RV32 wrapper passed" >&2
        exit 1
    fi
    grep -Fq "nvme_baremetal_wrapper_coverage_blockers=rv32_boot_wrapper_missing" "$tmp_dir/missing-rv32-wrapper.out" || {
        echo "STATUS: FAIL nvme-baremetal-wrapper-coverage self-test: missing RV32 wrapper blocker absent" >&2
        exit 1
    }

    echo "STATUS: PASS nvme-baremetal-wrapper-coverage self-test"
    exit 0
fi

blockers=none
add_blocker() {
    if [ "$blockers" = none ]; then
        blockers="$1"
    else
        blockers="$blockers,$1"
    fi
}

fail() {
    reason="$1"
    echo "nvme_baremetal_wrapper_coverage_status=fail"
    echo "nvme_baremetal_wrapper_coverage_blockers=$reason"
    echo "STATUS: FAIL nvme-baremetal-wrapper-coverage reason=$reason" >&2
    exit 1
}

[ -f "$rv32_boot" ] || fail rv32_boot_wrapper_missing
[ -f "$rv32_spec" ] || fail rv32_spec_missing

rv64_log=
rv32_log="$(mktemp)"
trap 'rm -f "$rv32_log" "$rv64_log"' EXIT
if sh "$rv32_boot" --self-test >"$rv32_log" 2>&1; then
    rv32_self_test=pass
else
    cat "$rv32_log" >&2
    fail rv32_boot_self_test_failed
fi

grep -Fq "boot.shs --self-test" "$rv32_spec" || fail rv32_spec_missing_wrapper_self_test_command
grep -Fq "STATUS: PASS nvme-rv32-boot self-test" "$rv32_spec" || fail rv32_spec_missing_wrapper_self_test_status
rv32_spec_status=pass

if [ -f "$rv64_boot" ]; then
    rv64_log="$(mktemp)"
    if sh "$rv64_boot" --self-test >"$rv64_log" 2>&1; then
        rv64_self_test=pass
    else
        cat "$rv64_log" >&2
        fail rv64_boot_self_test_failed
    fi
    if [ -f "$rv64_spec" ] \
        && grep -Fq "boot.shs --self-test" "$rv64_spec" \
        && grep -Fq "STATUS: PASS nvme-rv64-boot self-test" "$rv64_spec"; then
        rv64_spec_status=pass
    else
        rv64_spec_status=missing-self-test-coverage
        add_blocker rv64_nvme_spec
    fi
else
    rv64_self_test=missing-wrapper
    rv64_spec_status=missing-wrapper
    add_blocker rv64_nvme_wrapper
fi

if [ "$blockers" = none ]; then
    status=pass
    next_action=none
else
    status=incomplete
    next_action="add $rv64_boot with --self-test and $rv64_spec coverage"
fi

echo "nvme_baremetal_wrapper_coverage_status=$status"
echo "nvme_baremetal_wrapper_coverage_blockers=$blockers"
echo "nvme_baremetal_wrapper_rv32_self_test=$rv32_self_test"
echo "nvme_baremetal_wrapper_rv32_spec_status=$rv32_spec_status"
echo "nvme_baremetal_wrapper_rv64_self_test=$rv64_self_test"
echo "nvme_baremetal_wrapper_rv64_spec_status=$rv64_spec_status"
echo "nvme_baremetal_wrapper_coverage_next_action=$next_action"

if [ "$STRICT" -eq 1 ] && [ "$status" != pass ]; then
    echo "STATUS: FAIL nvme-baremetal-wrapper-coverage status=$status blockers=$blockers" >&2
    exit 1
fi

echo "STATUS: PASS nvme-baremetal-wrapper-coverage status=$status blockers=$blockers"
