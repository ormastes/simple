#!/bin/sh
set -eu

# f64 call-result ABI check — production (self-hosted) compiler.
#
# Guards the f64 function-call-result codegen bug: an f64 returned from a
# non-inlined function, then bound to a local / fed into a binop / passed as an
# argument / printed, must produce the real value (not 0.0 or garbage).
#
# The Rust *seed* compiler is already fixed and guarded by the cargo tests
#   src/compiler_rust/.../codegen/jit::tests::test_jit_f64_call_result_{value,print}
# This script targets the deployed self-hosted `bin/simple`, whose JIT/codegen
# still has the analogous bug (see
#   doc/08_tracking/bug/f64_self_hosted_call_result_codegen_2026-06-21.md).
# It is written to flip to a clean PASS automatically once a working self-hosted
# build with the port is deployed.
#
# Exit status:
#   0  interpret correct AND JIT either correct (PASS) or the known-pending 0.0
#   1  interpret wrong, or JIT produces an UNEXPECTED wrong value (real regression)

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE="${SIMPLE_BIN:-bin/simple}"
PROG="$(mktemp -t f64_call_abi.XXXXXX.spl)"
trap 'rm -f "$PROG"' EXIT

cat > "$PROG" <<'SPL'
fn half() -> f64:
    return 21.5
fn add(a: f64, b: f64) -> f64:
    return a + b
fn main():
    print(half())            # call result printed   -> 21.5
    print(add(1.5, 2.25))    # binop on params       -> 3.75
    print(half() + half())   # two call results binop -> 43
SPL

# Expected first value, normalised (strip a trailing .0 and any exponent noise).
norm() { sed 's/\.0*$//; s/0*$//; s/\.$//'; }

run_first() { # $1 = extra env/flags description, $2... = command
    "$@" run "$PROG" 2>/dev/null | sed -n '1p'
}

echo "== f64 call-result ABI check (bin: $SIMPLE) =="

# 1. Interpreter is the always-correct baseline — hard requirement.
INTERP="$(SIMPLE_EXECUTION_MODE=interpret "$SIMPLE" run "$PROG" 2>/dev/null | sed -n '1p' | norm)"
if [ "$INTERP" != "21.5" ]; then
    echo "FAIL: interpreter baseline wrong (got '$INTERP', want 21.5)" >&2
    exit 1
fi
echo "interpret: 21.5  OK"

# 2. JIT (compiled) path — the one the bug lives in.
JIT_RAW="$("$SIMPLE" run "$PROG" 2>/dev/null | sed -n '1p')"
JIT="$(printf '%s' "$JIT_RAW" | norm)"
case "$JIT" in
    21.5)
        echo "jit:       21.5  PASS — self-hosted f64 call-result codegen is fixed"
        exit 0 ;;
    0|0.0|"-0"|"")
        echo "jit:       $JIT_RAW  PENDING — known self-hosted codegen bug, not yet ported"
        echo "  tracked: doc/08_tracking/bug/f64_self_hosted_call_result_codegen_2026-06-21.md"
        exit 0 ;;
    *)
        echo "FAIL: jit produced an UNEXPECTED value '$JIT_RAW' (want 21.5, known-bad 0.0)" >&2
        exit 1 ;;
esac
