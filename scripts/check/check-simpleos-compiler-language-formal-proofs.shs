#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
CHECK_LEAN="$ROOT_DIR/scripts/check/check-lean-proofs.shs"

require_theorem() {
    file="$1"
    name="$2"
    if ! grep -Eq "^[[:space:]]*theorem[[:space:]]+$name([[:space:]]|:|\\(|$)" "$ROOT_DIR/$file"; then
        echo "FAIL: missing theorem $name in $file" >&2
        exit 1
    fi
}

if [ "${1:-}" = "--self-test" ]; then
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    grep -v '^theorem wellformed_not_ambiguous' \
        "$ROOT_DIR/src/verification/module_resolution/src/ModuleResolution.lean" \
        >"$tmp_dir/mutated.lean"
    if (ROOT_DIR="$tmp_dir" require_theorem "mutated.lean" "wellformed_not_ambiguous" 2>/dev/null); then
        echo "STATUS: FAIL simpleos-compiler-language-formal-proofs self-test: require_theorem did not fail on mutated copy" >&2
        exit 1
    fi
    echo "STATUS: PASS simpleos-compiler-language-formal-proofs self-test (require_theorem correctly rejects a stripped theorem)"
    exit 0
fi

sh "$CHECK_LEAN" --self-test >/dev/null
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/module_resolution" "verification/module_resolution"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/macro_auto_import" "verification/macro_auto_import"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/type_inference_compile" "verification/type_inference_compile"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/type_value_semantics" "verification/type_value_semantics"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/visibility_export" "verification/visibility_export"

require_theorem "src/verification/module_resolution/src/ModuleResolution.lean" "wellformed_not_ambiguous"
require_theorem "src/verification/module_resolution/src/ModuleResolution.lean" "resolve_deterministic"
require_theorem "src/verification/module_resolution/src/ModuleResolution.lean" "unique_implies_exists"
require_theorem "src/verification/module_resolution/src/ModuleResolution.lean" "notfound_means_neither"
require_theorem "src/verification/module_resolution/src/ModuleResolutionConstraints.lean" "both_paths_existing_resolves_ambiguous"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImport.lean" "glob_doesnt_leak_macros_wf"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImport.lean" "nonmacros_always_globbed"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImport.lean" "auto_imported_in_glob"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImport.lean" "glob_subset"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImport.lean" "empty_auto_import_no_macros"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImportConstraints.lean" "auto_import_true_implies_macro"
require_theorem "src/verification/macro_auto_import/src/MacroAutoImportConstraints.lean" "empty_auto_import_glob_nonmacros"
require_theorem "src/verification/type_inference_compile/src/TypeInferenceCompile.lean" "infer_deterministic"
require_theorem "src/verification/type_inference_compile/src/TypeInferenceCompileConstraints.lean" "infer_add_rejects_bool_operand"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "sync_safety"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "effect_deterministic"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "suspension_implies_async"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "async_propagation"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "lit_is_sync"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "async_returns_promise"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "sync_no_promise_wrap"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "no_double_wrap"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "await_inference_sound"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "await_not_inserted_for_i32"
require_theorem "src/verification/type_inference_compile/src/AsyncEffectInference.lean" "promise_unwrap_correct"
require_theorem "src/verification/type_inference_compile/src/ContractsConstraints.lean" "empty_contract_has_no_clauses"
require_theorem "src/verification/type_inference_compile/src/Contracts.lean" "empty_contract_has_no_preconditions"
require_theorem "src/verification/type_inference_compile/src/Contracts.lean" "empty_contract_has_no_postconditions"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "applySubst_empty"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "occurs_var_true"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "instantiate_preserves_shape"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "generalize_preserves_type"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "infer_lit_nat"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "infer_lit_bool"
require_theorem "src/verification/type_inference_compile/src/Generics.lean" "infer_lit_str"
require_theorem "src/verification/type_inference_compile/src/GenericsConstraints.lean" "apply_single_subst_var"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "read_write_same"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "read_write_other"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "class_shares_identity"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "class_alias_write_visible"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "struct_distinct_identity"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "struct_copy_snapshot"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "struct_copy_independent"
require_theorem "src/verification/type_value_semantics/src/TypeValueSemantics.lean" "struct_source_mut_preserves_copy"
require_theorem "src/verification/visibility_export/src/VisibilityExport.lean" "meet_comm"
require_theorem "src/verification/visibility_export/src/VisibilityExport.lean" "meet_assoc"
require_theorem "src/verification/visibility_export/src/VisibilityExport.lean" "meet_private_left"
require_theorem "src/verification/visibility_export/src/VisibilityExport.lean" "foldl_priv_absorbs"
require_theorem "src/verification/visibility_export/src/VisibilityExport.lean" "any_private_means_private"
require_theorem "src/verification/visibility_export/src/VisibilityExport.lean" "all_public_means_public"
require_theorem "src/verification/visibility_export/src/VisibilityExportConstraints.lean" "private_symbol_under_public_path_private"

echo "STATUS: PASS simpleos-compiler-language-formal-proofs"
