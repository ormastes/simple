#!/bin/sh
set -eu

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT INT TERM

awk '
  /^cat > simple_mcp_server <<'"'"'EOF'"'"'$/ { copying = 1; next }
  copying && /^EOF$/ { exit }
  copying { print }
' scripts/setup/setup.shs > "$TMPDIR/simple_mcp_server"
chmod +x "$TMPDIR/simple_mcp_server"

awk '
  /^cat > simple_lsp_mcp_server <<'"'"'EOF'"'"'$/ { copying = 1; next }
  copying && /^EOF$/ { exit }
  copying { print }
' scripts/setup/setup.shs > "$TMPDIR/simple_lsp_mcp_server"
chmod +x "$TMPDIR/simple_lsp_mcp_server"
cmp "$TMPDIR/simple_mcp_server" bin/simple_mcp_server
cmp "$TMPDIR/simple_lsp_mcp_server" bin/simple_lsp_mcp_server

# Production discovery must include native macOS artifacts generated by the
# bootstrap deploy layout, not only Linux release directories.
grep -q 'release/aarch64-apple-darwin/simple_mcp_server' "$TMPDIR/simple_mcp_server"
grep -q 'release/x86_64-apple-darwin/simple_mcp_server' "$TMPDIR/simple_mcp_server"
grep -q 'simple_binary_is_valid "${release_dir}/simple"' scripts/setup/setup.shs
grep -q 'native_hash_is_valid "${candidate}"' "$TMPDIR/simple_mcp_server"
grep -q 'native_hash_is_valid "${candidate}"' "$TMPDIR/simple_lsp_mcp_server"

if grep -q 'src/compiler_rust/target\|build/bootstrap/\|smf_runtime=\|mode=source\|exec .*src/app/' \
  "$TMPDIR/simple_mcp_server" "$TMPDIR/simple_lsp_mcp_server"; then
  exit 1
fi
if grep -q 'src/app/simple_lsp_mcp/main.spl\|SIMPLE_EXECUTION_MODE=interpreter' config/mcp/install.shs; then
  exit 1
fi

mkdir -p "$TMPDIR/release/x86_64-unknown-linux-gnu"
cat > "$TMPDIR/native" <<'EOF'
#!/bin/sh
if [ "${1:-}" = "--probe" ]; then
  printf '%s\n' 'simple-mcp probe ok contract-test'
  exit 0
fi
if [ "$#" -eq 0 ]; then
  case "$0" in
    *lsp*) printf '%s\n' '{"jsonrpc":"2.0","id":"2","result":{"tools":[{"name":"lsp_definition"}]}}' '{"jsonrpc":"2.0","id":"lsp-call-probe","result":{"symbols":[]}}' ;;
    *) printf '%s\n' '{"jsonrpc":"2.0","id":"2","result":{"tools":[{"name":"simple_pipe"}]}}' '{"jsonrpc":"2.0","id":"3","result":{"content":"spipe: linked"}}' ;;
  esac
  exit 0
fi
printf 'native=%s\n' "$0"
printf 'args=%s\n' "$*"
EOF
chmod +x "$TMPDIR/native"
cp "$TMPDIR/native" "$TMPDIR/release/x86_64-unknown-linux-gnu/simple_mcp_server"
cp "$TMPDIR/native" "$TMPDIR/release/x86_64-unknown-linux-gnu/simple_lsp_mcp_server"
if command -v sha256sum >/dev/null 2>&1; then
  native_hash="$(sha256sum "$TMPDIR/native" | awk '{print $1}')"
else
  native_hash="$(shasum -a 256 "$TMPDIR/native" | awk '{print $1}')"
fi
printf '%s\n' "$native_hash" >"$TMPDIR/release/x86_64-unknown-linux-gnu/simple_mcp_server.sha256"
printf '%s\n' "$native_hash" >"$TMPDIR/release/x86_64-unknown-linux-gnu/simple_lsp_mcp_server.sha256"

"$TMPDIR/simple_mcp_server" alpha beta >"$TMPDIR/mcp.out"
"$TMPDIR/simple_lsp_mcp_server" gamma >"$TMPDIR/lsp.out"
grep -q 'release/x86_64-unknown-linux-gnu/simple_mcp_server' "$TMPDIR/mcp.out"
grep -q 'args=alpha beta' "$TMPDIR/mcp.out"
grep -q 'release/x86_64-unknown-linux-gnu/simple_lsp_mcp_server' "$TMPDIR/lsp.out"
grep -q 'args=gamma' "$TMPDIR/lsp.out"

printf '%s\n' invalid >"$TMPDIR/release/x86_64-unknown-linux-gnu/simple_mcp_server.sha256"
if "$TMPDIR/simple_mcp_server" >/dev/null 2>&1; then
  exit 1
fi

rm -f "$TMPDIR/release/x86_64-unknown-linux-gnu/simple_mcp_server" \
  "$TMPDIR/release/x86_64-unknown-linux-gnu/simple_lsp_mcp_server" \
  "$TMPDIR/release/x86_64-unknown-linux-gnu/simple_mcp_server.sha256" \
  "$TMPDIR/release/x86_64-unknown-linux-gnu/simple_lsp_mcp_server.sha256"
if SIMPLE_MCP_NATIVE="$TMPDIR/missing" "$TMPDIR/simple_mcp_server" >/dev/null 2>&1; then
  exit 1
fi
if SIMPLE_PLATFORM_TRIPLE=missing "$TMPDIR/simple_lsp_mcp_server" >/dev/null 2>&1; then
  exit 1
fi

echo "mcp_wrapper_native_contract=pass"
