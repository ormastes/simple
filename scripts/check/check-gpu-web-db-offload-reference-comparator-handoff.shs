#!/usr/bin/env sh
set -eu

BUILD_DIR="${BUILD_DIR:-build/perf/gpu_web_db_offload}"
ENV_TEMPLATE="${ENV_TEMPLATE:-$BUILD_DIR/reference-comparator-fixtures.env}"
HANDOFF="${HANDOFF:-$BUILD_DIR/reference-comparator-handoff.md}"
PROXY_PRODUCER="${PROXY_PRODUCER:-scripts/check/check-web-server-proxy-external-live-compare.shs}"
WEB_REPORT="${WEB_REPORT:-scripts/check/check-web-server-nginx-compare-report.shs}"
EXTERNAL_SUITE="${EXTERNAL_SUITE:-scripts/check/check-gpu-web-db-offload-external-suite.shs}"
FASTEST_AUDIT="${FASTEST_AUDIT:-scripts/check/check-gpu-web-db-offload-fastest-comparator-evidence.shs}"

emit_env_template() {
    cat <<'EOF'
# GPU Web/DB reference comparator fixture env.
# Fill only after the matching Simple, uWebSockets, and Seastar plaintext
# services are actually running with identical payloads and connection profile.
SIMPLE_REFERENCE_PLAINTEXT_URL=
UWEBSOCKETS_PLAINTEXT_URL=
UWEBSOCKETS_PLAINTEXT_PROVENANCE=
SEASTAR_PLAINTEXT_URL=
SEASTAR_PLAINTEXT_PROVENANCE=
EOF
}

emit_handoff() {
    cat <<EOF
# GPU Web/DB Reference Comparator Handoff

This handoff is generated by
\`scripts/check/check-gpu-web-db-offload-reference-comparator-handoff.shs\`.
It is side-effect-free: it does not start servers, does not fill readiness
values, and does not claim fastest-server evidence.

## Required Comparator Inputs

| item | env field | requirement |
|---|---|---|
| Simple reference plaintext | \`SIMPLE_REFERENCE_PLAINTEXT_URL\` | Simple plaintext route with the same payload and connection profile |
| uWebSockets plaintext | \`UWEBSOCKETS_PLAINTEXT_URL\` | Real uWebSockets-style plaintext reference endpoint |
| uWebSockets provenance | \`UWEBSOCKETS_PLAINTEXT_PROVENANCE\` | Binary, image, or commit identifying the reference implementation |
| Seastar plaintext | \`SEASTAR_PLAINTEXT_URL\` | Real Seastar-style plaintext reference endpoint |
| Seastar provenance | \`SEASTAR_PLAINTEXT_PROVENANCE\` | Binary, image, or commit identifying the reference implementation |

## Strict Evidence Sequence

1. Fill \`$ENV_TEMPLATE\` with verified live endpoint URLs and provenance.
2. Copy only verified values into \`build/perf/gpu_web_db_offload/external-fixtures.env\`.
3. Run \`EXTERNAL_FIXTURE_ENV_FILE=build/perf/gpu_web_db_offload/external-fixtures.env $PROXY_PRODUCER\`.
4. Run \`$WEB_REPORT\`.
5. Run \`$EXTERNAL_SUITE --refresh-status\`.
6. Run \`$EXTERNAL_SUITE --require-ready\`.
7. Run \`$FASTEST_AUDIT --require-ready\`.

The final two gates must pass before claiming strict fastest-comparator
coverage for uWebSockets or Seastar.
EOF
}

write_env_template() {
    mkdir -p "$(dirname "$ENV_TEMPLATE")"
    emit_env_template > "$ENV_TEMPLATE"
    printf '%s\n' "$ENV_TEMPLATE"
}

write_handoff() {
    mkdir -p "$(dirname "$HANDOFF")"
    emit_handoff > "$HANDOFF"
    printf '%s\n' "$HANDOFF"
}

if [ "${1:-}" = "--write-env-template" ]; then
    write_env_template
    echo "STATUS: PASS gpu web/db reference comparator env template"
    exit 0
fi

if [ "${1:-}" = "--write-handoff" ]; then
    write_handoff
    echo "STATUS: PASS gpu web/db reference comparator handoff"
    exit 0
fi

if [ "${1:-}" = "--self-test" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    ENV_TEMPLATE="$tmpdir/reference.env"
    HANDOFF="$tmpdir/handoff.md"
    write_env_template >/dev/null
    write_handoff >/dev/null
    grep -q '^SIMPLE_REFERENCE_PLAINTEXT_URL=$' "$ENV_TEMPLATE"
    grep -q '^UWEBSOCKETS_PLAINTEXT_URL=$' "$ENV_TEMPLATE"
    grep -q '^UWEBSOCKETS_PLAINTEXT_PROVENANCE=$' "$ENV_TEMPLATE"
    grep -q '^SEASTAR_PLAINTEXT_URL=$' "$ENV_TEMPLATE"
    grep -q '^SEASTAR_PLAINTEXT_PROVENANCE=$' "$ENV_TEMPLATE"
    grep -q 'EXTERNAL_FIXTURE_ENV_FILE=build/perf/gpu_web_db_offload/external-fixtures.env scripts/check/check-web-server-proxy-external-live-compare.shs' "$HANDOFF"
    grep -q 'scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready' "$HANDOFF"
    grep -q 'scripts/check/check-gpu-web-db-offload-fastest-comparator-evidence.shs --require-ready' "$HANDOFF"
    grep -q 'does not claim fastest-server evidence' "$HANDOFF"
    echo "STATUS: PASS gpu web/db reference comparator handoff self-test"
    exit 0
fi

write_env_template
write_handoff
echo "STATUS: PASS gpu web/db reference comparator handoff artifacts"
