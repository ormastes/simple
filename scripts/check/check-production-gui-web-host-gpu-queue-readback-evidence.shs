if [ "$(status_of webgpu_upload_provenance_status)" != "pass" ] || [ "$(status_of presentation_provenance_device_readback_status)" != "not_device_readback" ]; then
    webgpu_spark_task_status="fail"
    webgpu_normal_llm_verification_status="fail"
