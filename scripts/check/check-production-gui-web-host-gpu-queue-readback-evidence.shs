if [ "$browser_first_gpu_readback_source" = "device_readback" ]; then
    same_frame_gpu_backend_readback_status="pass"
fi
if [ "$browser_frame_queue_status" != "pass" ]; then
    production_runtime_queue_integration_reason="browser-frame-queue-bridge-not-proven"
    if [ "$(status_of browser_first_render_under_budget)" != "true" ]; then
        production_runtime_queue_integration_reason="browser-frame-first-render-budget-not-met"
    fi
fi
if [ "$queue_emit_status" = "pass" ] \
    && [ "$queue_nonzero_backend_drain_status" = "pass" ] \
    && [ "$queue_nonzero_backend_payload_status" = "pass" ] \
    && [ "$queue_nonzero_backend_payload_text_status" = "pass" ] \
    && [ "$presentation_provenance_guard_status" = "pass" ] \
    && [ "$queue_overflow_status" = "pass" ] \
    && [ "$browser_frame_queue_status" = "pass" ] \
    && [ "$same_frame_backend_readback_status" = "pass" ] \
    && [ "$same_frame_gpu_backend_readback_status" = "pass" ] \
    && [ "$event_frame_correlation_status" = "pass" ] \
    && [ "$(status_of nogc_draw_ir_runtime_queue_status)" = "pass" ] \
    && [ "$(status_of queue_probe_native_status)" = "pass" ] \
    && [ "$(status_of browser_host_event_roundtrip_status)" = "pass" ] \
    && [ "$(status_of host_gpu_event_queue_status)" = "pass" ] \
    && [ "$(status_of backend_readback_handle_contract_status)" = "pass" ] \
    && [ "$(status_of engine2d_readback_metadata_status)" = "pass" ] \
    && [ "$(status_of compiler_host_gpu_lane_cleanup_status)" = "pass" ] \
    && [ "$(status_of readback_vulkan_verdict)" = "pass" ] \
    && [ "$(status_of readback_opencl_verdict)" = "pass" ] \
    && [ "$(status_of readback_opencl_submit_attempted)" = "true" ] \
    && [ "$(status_of readback_opencl_readback_available)" = "true" ] \
    && [ "$(status_of readback_cuda_verdict)" = "pass" ]; then
    if [ "$(status_of readback_cuda_submit_attempted)" = "true" ] \
        && [ "$(status_of readback_cuda_readback_available)" = "true" ]; then
    production_runtime_queue_integration_status="pass"
    production_runtime_queue_integration_reason="same-frame BrowserBackend queue, Draw IR dispatch, Vulkan/BrowserBackend device readback receipt, Engine2D readback proof predicate, and compiler HostGpuLane cleanup probes proven"
    fi
fi
production_gui_web_host_gpu_queue_readback_status="$production_runtime_queue_integration_status"
production_gui_web_host_gpu_queue_readback_reason="$production_runtime_queue_integration_reason"
linux_gui_web_queue_integration_status="$production_runtime_queue_integration_status"
linux_gui_web_queue_integration_reason="$production_runtime_queue_integration_reason"
