run_child "opencl" "scripts/check/check-opencl-generated-2d-readback.shs" "opencl_generated_2d_readback_status" "opencl_generated_2d_readback_reason"
run_child "metal" "scripts/check/check-metal-generated-2d-readback.shs" "metal_generated_2d_readback_status" "metal_generated_2d_readback_reason"
run_child "rocm" "scripts/check/check-rocm-generated-2d-readback.shs" "rocm_generated_2d_readback_status" "rocm_generated_2d_readback_reason"
run_child "directx_native" "scripts/check/check-directx-native-readback.shs" "directx_native_readback_status" "directx_native_readback_reason"
run_native_readback_wrapper_specs
run_webgpu_real_readback
audit_capacity_and_status

