mkdir -p "$(dirname -- "$REPORT_PATH")"
{
    echo "# Production GUI/Web Host-GPU Queue Readback Evidence"
    echo
    echo "Date: $(date -u +%F)"
    echo
    echo "## Summary"
    echo
    echo "- linux GUI/web queue integration status: ${report_linux_queue_status:-missing}"
    echo "- linux GUI/web queue integration reason: ${report_linux_queue_reason:-missing}"
    echo "- legacy compatibility status key: production_gui_web_host_gpu_queue_readback_status=$report_overall_status"
    echo "- legacy compatibility reason key: production_gui_web_host_gpu_queue_readback_reason=$report_overall_reason"
    echo "- full host-GPU platform matrix status: ${report_full_matrix_status:-missing}"
    echo "- joined GUI/web device readback backend: $joined_gui_web_device_readback_backend"
    echo "- missing device-readback platforms: ${missing_device_readback_platforms:-none}"
    echo "- queue emission via rt_host_gpu_queue_emit: $queue_emit_status"
    echo "- backend_code=0 drain result: $queue_zero_backend_status"
    echo "- nonzero backend-code drain result: $queue_nonzero_backend_drain_status"
    echo "- nonzero backend-code payload receipt: $queue_nonzero_backend_payload_status"
    echo "- nonzero backend-code payload text receipt: $queue_nonzero_backend_payload_text_status"
    echo "- DirectX/WebGPU provenance guard: $presentation_provenance_guard_status"
    echo "- DirectX native gate: ${report_directx_native_gate_status:-missing}"
    echo "- native readback wrapper SSpec coverage: ${report_native_readback_wrapper_sspec_coverage_status:-missing}"
    echo "- native readback wrapper generated-doc evidence: ${report_native_readback_wrapper_sspec_doc_evidence_status:-missing}"
    echo "- queue overflow rejection: $queue_overflow_status"
    echo "- BrowserBackend frame queue bridge: $browser_frame_queue_status"
    echo "- BrowserBackend host event roundtrip: ${report_browser_host_event_status:-missing}"
    echo "- same-frame BrowserBackend Engine2D pixel readback receipt: $same_frame_backend_readback_status"
    echo "- same-frame Vulkan/BrowserBackend device readback receipt: $same_frame_gpu_backend_readback_status"
    echo "- browser input event to queued frame/readback correlation: $event_frame_correlation_status"
    echo "- runtime event receipt contract: ${report_host_gpu_event_queue_status:-missing}"
    echo "- backend readback handle contract: ${report_backend_readback_handle_contract_status:-missing}"
    echo "- Engine2D readback metadata proof predicate: ${report_engine2d_readback_metadata_status:-missing}"
    echo "- compiler HostGpuLane cleanup probes: ${report_compiler_cleanup_status:-missing}"
    echo "- production runtime queue integration: $production_runtime_queue_integration_status"
    echo
    echo "The queue probe distinguishes emission and drain from backend-capable submit. Explicit backend_code=0 packets drain as typed UNAVAILABLE. BrowserBackend proves that a frame carries queue submit/drain metadata, a prepared Draw IR dispatch payload receipt, a positive backend handle from the Engine2D readback receipt, and a same-frame Engine2D pixel readback receipt, and resets all of them on cache hits."
    echo
    echo "## Run Environment"
    echo
    echo "- root: ${report_run_root_dir:-missing}"
    echo "- build_dir: ${report_run_build_dir:-missing}"
    echo "- report_path: ${report_run_report_path:-missing}"
    echo "- simple_bin: ${report_run_simple_bin:-missing}"
    echo "- simple_lib: ${report_run_simple_lib:-missing}"
    echo "- uname_s: ${report_run_uname_s:-missing}"
    echo "- uname_m: ${report_run_uname_m:-missing}"
    echo "- child_timeout_seconds: ${report_run_child_timeout:-missing}"
    echo "- probe_timeout_seconds: ${report_run_probe_timeout:-missing}"
    echo "- compiler_probe_timeout_seconds: ${report_run_compiler_probe_timeout:-missing}"
    echo
    echo "## Readback Matrix"
    echo
    echo "| Backend | Child status | Production subcheck | Submit attempted | Readback available | Timed out | Timeout s | Reason | Report |"
    echo "| --- | --- | --- | --- | --- | --- | --- | --- | --- |"
    for name in vulkan cuda opencl metal rocm; do
        child_status_key="readback_${name}_status"
        child_verdict_key="readback_${name}_verdict"
        child_submit_key="readback_${name}_submit_attempted"
        child_readback_key="readback_${name}_readback_available"
        child_reason_key="readback_${name}_reason"
        child_report_key="readback_${name}_report"
        child_timed_out_key="readback_${name}_timed_out"
        child_timeout_key="readback_${name}_timeout_seconds"
        child_status="$(field_of "$child_status_key" "$ENV_PATH")"
        child_verdict="$(field_of "$child_verdict_key" "$ENV_PATH")"
        child_submit="$(field_of "$child_submit_key" "$ENV_PATH")"
        child_readback="$(field_of "$child_readback_key" "$ENV_PATH")"
        child_reason="$(field_of "$child_reason_key" "$ENV_PATH")"
        child_report="$(field_of "$child_report_key" "$ENV_PATH")"
        child_timed_out="$(field_of "$child_timed_out_key" "$ENV_PATH")"
        child_timeout="$(field_of "$child_timeout_key" "$ENV_PATH")"
        echo "| $name | $child_status | $child_verdict | ${child_submit:-n/a} | ${child_readback:-n/a} | $child_timed_out | $child_timeout | $child_reason | $child_report |"
    done
    echo
    echo "## Presentation/Upload Provenance"
    echo
    echo "| Backend | Provenance-only status | Evidence kind | Source | Exit code | Device readback proof |"
    echo "| --- | --- | --- | --- | --- | --- |"
    echo "| directx | ${report_directx_presentation_display_status:-missing} | ${report_directx_presentation_evidence_kind:-missing} | ${report_directx_presentation_source:-missing} | ${report_directx_presentation_exit:-missing} | ${report_presentation_device_status:-not_device_readback} |"
    echo "| webgpu | ${report_webgpu_upload_display_status:-missing} | ${report_webgpu_upload_evidence_kind:-missing} | ${report_webgpu_upload_source:-missing} | ${report_webgpu_upload_exit:-missing} | ${report_presentation_device_status:-not_device_readback} |"
    echo "| webgpu_real | ${report_webgpu_real_status:-missing} | device_readback | ${report_webgpu_real_source:-missing} | ${report_webgpu_real_exit:-missing} | handle=${report_webgpu_real_handle:-missing}, checksum=${report_webgpu_real_actual_checksum:-missing}, report=${report_webgpu_real_report:-missing} |"
    echo "| directx_native | ${report_directx_native_status:-missing} | native_device_readback | gate=${report_directx_native_gate_status:-missing}, child_gate=${report_directx_native_wrapper_gate_status:-missing}, verdict=${report_directx_native_verdict:-missing} | ${report_directx_native_exit:-missing}/wrapper=${report_directx_native_wrapper_exit:-missing} | reason=${report_directx_native_reason:-missing}, report=${report_directx_native_report:-missing}, child_report=${report_directx_native_child_report:-missing} |"
    echo "| directx_native_spec | ${report_directx_native_readback_spec_status:-missing} | sspec_wrapper_contract | test/03_system/check/directx_native_readback_spec.spl | ${report_directx_native_readback_spec_exit:-missing} | wrapper contract evidence for native DirectX gate |"
    echo "| generated_2d_native_wrappers_spec | ${report_generated_2d_native_readback_wrappers_spec_status:-missing} | sspec_wrapper_contract | test/03_system/check/generated_2d_native_readback_wrappers_spec.spl | ${report_generated_2d_native_readback_wrappers_spec_exit:-missing} | wrapper contract evidence for Metal/ROCm native readback gates |"
    echo "| nogc_draw_ir_runtime_queue | ${report_nogc_draw_ir_runtime_queue_status:-missing} | canonical_no_gc_queue_dispatch | test/01_unit/lib/nogc_async_mut/gpu/engine2d/draw_ir_runtime_queue_spec.spl | ${report_nogc_draw_ir_runtime_queue_exit:-missing} | required_for_Draw_IR_queue_dispatch |"
    echo "| runtime_queue_probe_native | ${report_queue_probe_native_status:-missing} | direct_no_stub_native_queue_dispatch | test/01_unit/lib/nogc_async_mut/gpu/engine2d/runtime_queue_probe.spl | build=${report_queue_probe_native_build_exit:-missing}/run=${report_queue_probe_native_run_exit:-missing} | required_for_native_archive_and_SFFI_queue_dispatch |"
    echo "| gc_draw_ir_runtime_queue | ${report_gc_draw_ir_runtime_queue_status:-missing} | legacy_gc_queue_bridge | test/01_unit/lib/gc_async_mut/gpu/engine2d/draw_ir_runtime_queue_spec.spl | ${report_gc_draw_ir_runtime_queue_exit:-missing} | compatibility bridge evidence |"
    echo "| browser_event | ${report_browser_host_event_status:-missing} | host_event_roundtrip | ${report_browser_host_event_source:-missing} | ${report_browser_host_event_exit:-missing} | required_for_host_event_roundtrip |"
    echo "| event_queue | ${report_host_gpu_event_queue_status:-missing} | runtime_event_receipt | runtime_event_receipt | ${report_host_gpu_event_queue_exit:-missing} | required_for_event_flow |"
    echo "| contract | ${report_backend_readback_handle_contract_status:-missing} | backend_handle_contract | backend_handle_contract | ${report_backend_readback_handle_contract_exit:-missing} | required_for_device_readback |"
    echo "| metadata | ${report_engine2d_readback_metadata_status:-missing} | readback_metadata_predicate | device_readback/provenance_only | ${report_engine2d_readback_metadata_exit:-missing} | required_for_device_readback |"
    echo
    echo "## Platform Spark / Normal-LLM Verification"
    echo
    echo "| Platform | Spark task status | Normal-LLM verification | Expected proof | Current evidence |"
    echo "| --- | --- | --- | --- | --- |"
    echo "| linux_gui_web | ${linux_gui_web_queue_integration_status:-missing} | ${event_frame_correlation_status:-missing} | same-frame Vulkan BrowserBackend device_readback plus event/queue correlation | event=${report_browser_first_event_correlation_id:-missing}; packet=${report_browser_first_packet:-missing}; source=${report_browser_first_gpu_readback_source:-missing}; checksum=${report_browser_first_readback_checksum:-missing} |"
    echo "| metal | ${report_metal_spark_task_status:-missing} | ${report_metal_normal_llm_status:-missing} | native Metal device readback on Darwin | ${report_metal_unavailable_reason:-missing} |"
    echo "| rocm_hip | ${report_rocm_spark_task_status:-missing} | ${report_rocm_normal_llm_status:-missing} | ROCm/HIP submit/readback on AMD ROCm host | ${report_rocm_unavailable_reason:-missing} |"
    echo "| directx | ${report_directx_spark_task_status:-missing} | ${report_directx_normal_llm_status:-missing} | same-frame DirectX device_readback | structured=${report_directx_presentation_source:-missing}/${report_presentation_device_status:-not_device_readback}; native=${report_directx_native_verdict:-missing}/${report_directx_native_status:-missing}; gate=${report_directx_native_gate_status:-missing}; child_gate=${report_directx_native_wrapper_gate_status:-missing}; reason=${report_directx_native_reason:-missing} |"
    echo "| webgpu | ${report_webgpu_spark_task_status:-missing} | ${report_webgpu_normal_llm_status:-missing} | same-frame WebGPU device_readback | ${report_webgpu_platform_evidence:-missing} |"
    echo
    echo "## Host Validation Commands"
    cat <<'EOF'
### Apple Metal (Darwin)
- Ensure Xcode command-line tools are available and active:
  - `xcode-select --install`
  - `xcode-select --print-path`
- Validate Metal toolchain/runtime visibility:
  - `xcrun --find metal`
  - `xcrun --find metallib`
  - `system_profiler SPDisplaysDataType`
- Rebuild generated toolchains:
  - `SIMPLE_BIN=${SIMPLE_BIN:-bin/simple} SIMPLE_LIB=${SIMPLE_LIB:-src} sh scripts/check/check-portable-compute-toolchains.shs`
- Run direct Metal proof:
  - `SIMPLE_BIN=${SIMPLE_BIN:-bin/simple} SIMPLE_LIB=${SIMPLE_LIB:-src} sh scripts/check/check-metal-generated-2d-readback.shs`
- Re-run platform aggregate:
  - `SIMPLE_BIN=${SIMPLE_BIN:-bin/simple} SIMPLE_LIB=${SIMPLE_LIB:-src} sh scripts/check/check-production-gui-web-host-gpu-queue-readback-evidence.shs`

### AMD ROCm (Linux)
- Ensure ROCm/HIP tooling and runtime are available:
  - `hipcc --version`
  - `rocminfo`
- Verify AMD loader/runtime presence and target architecture.
- Rebuild generated toolchains:
  - `SIMPLE_BIN=${SIMPLE_BIN:-bin/simple} SIMPLE_LIB=${SIMPLE_LIB:-src} HIPCC_TOOL=${HIPCC_TOOL:-hipcc} HIP_ARCH=${HIP_ARCH:-gfx1100} sh scripts/check/check-portable-compute-toolchains.shs`
- Run direct ROCm/HIP proof:
  - `SIMPLE_BIN=${SIMPLE_BIN:-bin/simple} SIMPLE_LIB=${SIMPLE_LIB:-src} HIP_ARCH=${HIP_ARCH:-gfx1100} sh scripts/check/check-rocm-generated-2d-readback.shs`
- Re-run platform aggregate:
  - `SIMPLE_BIN=${SIMPLE_BIN:-bin/simple} SIMPLE_LIB=${SIMPLE_LIB:-src} sh scripts/check/check-production-gui-web-host-gpu-queue-readback-evidence.shs`
EOF
    echo
    echo "## Production Gaps"
    echo
    echo "- Rust/C capacity parity: ${report_queue_capacity_status:-missing} (C capacity ${report_queue_c_capacity:-missing}, Rust ${report_queue_rust_capacity:-missing})."
    echo "- Runtime queue overflow evidence: $queue_overflow_status (accepted ${report_queue_overflow_accepted:-missing}/${report_queue_overflow_capacity:-missing}, overflow packet ${report_queue_overflow_packet_id:-missing}, drained ${report_queue_overflow_drained:-missing})."
    echo "- SUBMITTED status usage: ${report_queue_submitted_usage:-missing} (${report_queue_submitted_assignments:-missing} assignments observed outside constants)."
    echo "- Runtime backend-handle field roundtrip: ${report_queue_backend_roundtrip:-missing} (synthetic probe handle ${report_queue_nonzero_backend_handle:-missing}; ${report_queue_handle_field_count:-missing} matching runtime queue handle accessors/fields observed)."
    echo "- Runtime payload metadata roundtrip: $queue_nonzero_backend_payload_status (payload_size ${report_queue_nonzero_payload_size:-missing}, payload_hash ${report_queue_nonzero_payload_hash:-missing})."
    echo "- Runtime payload text roundtrip: $queue_nonzero_backend_payload_text_status (${report_queue_nonzero_payload_text:-missing})."
    echo "- BrowserBackend host event roundtrip: ${report_browser_host_event_status:-missing} (source ${report_browser_host_event_source:-missing}, exit ${report_browser_host_event_exit:-missing}, reason ${report_browser_host_event_reason:-missing})."
    echo "- BrowserBackend runtime queue handle/payload/perf: $browser_frame_queue_status (backend ${report_browser_backend:-missing}, first_render_us ${report_browser_first_render_us:-missing}, first_under_budget ${report_browser_first_render_under_budget:-missing}, second_render_us ${report_browser_second_render_us:-missing}, second_under_budget ${report_browser_second_render_under_budget:-missing}, pixels ${report_browser_first_pixel_count:-missing}, checksum ${report_browser_first_checksum:-missing}, nonuniform ${report_browser_first_nonuniform_count:-missing}, handle ${report_browser_first_backend_handle:-missing}, packet ${report_browser_first_packet:-missing}, payload_size ${report_browser_first_payload_size:-missing}, payload_hash ${report_browser_first_payload_hash:-missing}, payload_text ${report_browser_first_payload_text:-missing}, dispatch ${report_browser_first_dispatch_status:-missing}, dispatch_payload_size ${report_browser_first_dispatch_payload_size:-missing}, dispatch_layout_commands ${report_browser_first_dispatch_layout_command_count:-missing}, dispatch_payload_hash ${report_browser_first_dispatch_payload_hash:-missing}, dispatch_payload_text ${report_browser_first_dispatch_payload_text:-missing}, semantic rect/text/image ${report_browser_first_dispatch_rect_command_count:-missing}/${report_browser_first_dispatch_text_command_count:-missing}/${report_browser_first_dispatch_image_command_count:-missing}, gui_ast ${report_browser_first_dispatch_has_gui_ast_source:-missing}, widgets root/copy/action/image ${report_browser_first_dispatch_has_root_widget:-missing}/${report_browser_first_dispatch_has_copy_text:-missing}/${report_browser_first_dispatch_has_action_text:-missing}/${report_browser_first_dispatch_has_image_widget:-missing}, image_uri ${report_browser_first_dispatch_has_image_uri:-missing}, event_context ${report_browser_first_dispatch_target_context_resolved:-missing}/${report_browser_first_dispatch_target_context_batch_id:-missing}/${report_browser_first_dispatch_target_context_source_kind:-missing}, cache reset ${report_browser_second_submit:-missing}/${report_browser_second_payload_size:-missing})."
    echo "- Same-frame GUI/web Engine2D pixel readback receipt: $same_frame_backend_readback_status (backend ${report_browser_first_readback_backend:-missing}, pixels ${report_browser_first_readback_pixel_count:-missing}, checksum ${report_browser_first_readback_checksum:-missing}, reason ${report_browser_first_readback_reason:-missing}, cache reset ${report_browser_second_readback_status:-missing})."
    echo "- Same-frame Vulkan/BrowserBackend device readback receipt: $same_frame_gpu_backend_readback_status (source ${report_browser_first_gpu_readback_source:-missing}; only device_readback is accepted as device proof. BrowserBackend backend handle ${report_browser_first_backend_handle:-missing}, same-frame checksum ${report_browser_first_readback_checksum:-missing}, Vulkan Engine2D child readback ${report_readback_vulkan_verdict:-missing})."
    echo "- Browser input event to queued frame/readback correlation: $event_frame_correlation_status (status ${report_browser_first_event_correlation_status:-missing}, event ${report_browser_first_event_correlation_id:-missing}, summary ${report_browser_first_event_correlation_summary:-missing}, cache reset ${report_browser_second_event_correlation_status:-missing})."
    echo "- Runtime event receipt contract: ${report_host_gpu_event_queue_status:-missing} (exit ${report_host_gpu_event_queue_exit:-missing}; drained backend handles must come from runtime receipt state)."
    echo "- Backend readback handle contract: ${report_backend_readback_handle_contract_status:-missing} (exit ${report_backend_readback_handle_contract_exit:-missing}; zero-handle device_readback must not masquerade as backend proof)."
    echo "- Engine2D readback metadata proof predicate: ${report_engine2d_readback_metadata_status:-missing} (exit ${report_engine2d_readback_metadata_exit:-missing}; device proof requires source device_readback, a positive backend handle, and nonempty pixels; DirectX structured readback remains native-pending, and surface_upload remains provenance_only)."
    echo "- Compiler HostGpuLane cleanup probes: ${report_compiler_cleanup_status:-missing} (${report_compiler_cleanup_reason:-missing}; HIR exit ${report_compiler_hir_cleanup_exit:-missing}, interpreter body-error exit ${report_compiler_interpreter_cleanup_exit:-missing})."
    echo "- DirectX/WebGPU presentation provenance: DirectX ${report_directx_presentation_status:-missing} source ${report_directx_presentation_source:-missing}; DirectX native gate ${report_directx_native_gate_status:-missing}, child gate ${report_directx_native_wrapper_gate_status:-missing}, wrapper exit ${report_directx_native_wrapper_exit:-missing}; WebGPU upload ${report_webgpu_upload_status:-missing} source ${report_webgpu_upload_source:-missing}; WebGPU real ${report_webgpu_real_status:-missing} source ${report_webgpu_real_source:-missing}, handle ${report_webgpu_real_handle:-missing}, expected/actual checksum ${report_webgpu_real_expected_checksum:-missing}/${report_webgpu_real_actual_checksum:-missing}; provenance guard ${report_presentation_provenance_guard_status:-missing}."
    echo "- Metal: ${report_metal_unavailable_reason:-missing}"
    echo "- ROCm: ${report_rocm_unavailable_reason:-missing}"
    echo
    echo "## TODO Tracker"
    echo
    echo "- Engine2DReadback carries source, backend_handle, pixel_count, checksum, and reason metadata; backend identity remains WebRender artifact metadata."
    echo "- Add Linux ROCm pass evidence when ROCm runtime, probe, device, and verified HSACO are present."
    echo "- Add Apple Metal pass evidence on an Apple host."
    echo "- Add native DirectX device-readback evidence by making ${report_directx_native_report:-scripts/check/check-directx-native-readback.shs} pass on Windows; current DirectX structured readback contract is handle/checksum-gated but remains native-pending and not production device_readback. WebGPU real device_readback evidence passes; surface_upload remains provenance-only."
    echo
    echo "## Raw Evidence"
    echo
    awk -F= '{ value = substr($0, index($0, "=") + 1); print "- " $1 "=" value }' "$ENV_PATH"
} >"$REPORT_PATH"

cp "$ENV_PATH" "$PUBLISHED_ENV_PATH"
cat "$ENV_PATH"
echo "report_path=$REPORT_PATH"
if [ "${report_overall_status:-missing}" = "pass" ]; then
    exit 0
fi
exit 1
