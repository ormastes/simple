    && [ "$(status_of browser_first_payload_text)" = "web-render-frame;backend=vulkan;pixels=3072;checksum=$(status_of browser_first_payload_hash)" ] \
    && [ "$(status_of browser_first_dispatch_status)" = "dispatched" ] \
    && [ "$(status_of browser_first_dispatch_reason)" = "Draw IR runtime packet dispatched to Engine2D backend" ] \
    && [ "$(status_of browser_first_dispatch_payload_size)" = "512" ] \
