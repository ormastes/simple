    && is_positive_int "$(status_of webgpu_real_readback_backend_handle)" \
    && [ "$(status_of webgpu_real_readback_expected_checksum)" = "$(status_of webgpu_real_readback_actual_checksum)" ]; then
    webgpu_spark_task_status="pass"
    webgpu_normal_llm_verification_status="pass"
fi
platform_matrix_status="partial"
joined_gui_web_device_readback_backend="$(status_of browser_first_readback_backend)"
missing_device_readback_platforms=""
add_missing_platform() {
    if [ -z "$missing_device_readback_platforms" ]; then
        missing_device_readback_platforms="$1"
    else
        missing_device_readback_platforms="$missing_device_readback_platforms,$1"
    fi
}
if [ "$metal_spark_task_status" != "pass" ]; then add_missing_platform "metal"; fi
if [ "$rocm_spark_task_status" != "pass" ]; then add_missing_platform "rocm"; fi
if [ "$directx_spark_task_status" != "pass" ]; then add_missing_platform "directx"; fi
if [ "$webgpu_spark_task_status" != "pass" ]; then add_missing_platform "webgpu"; fi
if [ -z "$missing_device_readback_platforms" ]; then
    platform_matrix_status="complete"
fi
full_host_gpu_platform_matrix_status="$platform_matrix_status"

