#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/production_gui_web_host_gpu_queue_readback}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/production_gui_web_host_gpu_queue_readback_$(date -u +%F).md}"
SIMPLE_BIN="${SIMPLE_BIN:-./bin/simple}"
SIMPLE_LIB_CONFIGURED="${SIMPLE_LIB:-src}"
CHILD_TIMEOUT="${CHILD_TIMEOUT:-240}"
PROBE_TIMEOUT="${PROBE_TIMEOUT:-180}"
COMPILER_PROBE_TIMEOUT="${COMPILER_PROBE_TIMEOUT:-300}"
RUN_UNAME_S="$(uname -s)"
RUN_UNAME_M="$(uname -m)"
PUBLISHED_ENV_PATH="$BUILD_DIR/evidence.env"
ENV_PATH="$BUILD_DIR/evidence.$$.env"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$ENV_PATH" "$PUBLISHED_ENV_PATH" "$REPORT_PATH"

field_of() {
    key="$1"
    file="$2"
    if [ -s "$file" ]; then
        sed -n "s/^${key}=//p" "$file" | tail -n 1
    fi
}

append_env() {
    key="$1"
    value="$2"
    mkdir -p "$(dirname -- "$ENV_PATH")"
    tmp="$(mktemp "${ENV_PATH}.tmp.XXXXXX")"
    if [ -f "$ENV_PATH" ]; then
        awk -v key="$key" -F= '$1 != key' "$ENV_PATH" > "$tmp" || true
        mv "$tmp" "$ENV_PATH"
    else
        rm -f "$tmp"
    fi
    printf '%s=%s\n' "$key" "$value" >>"$ENV_PATH"
}

append_probe_timeout_env() {
    prefix="$1"
    code="$2"
    timed_out="false"
    if [ "$code" = "124" ]; then
        timed_out="true"
    fi
    append_env "${prefix}_timeout_seconds" "$PROBE_TIMEOUT"
    append_env "${prefix}_timed_out" "$timed_out"
}

append_compiler_probe_timeout_env() {
    prefix="$1"
    code="$2"
    timed_out="false"
    if [ "$code" = "124" ]; then
        timed_out="true"
    fi
    append_env "${prefix}_timeout_seconds" "$COMPILER_PROBE_TIMEOUT"
    append_env "${prefix}_timed_out" "$timed_out"
}

append_env "run_root_dir" "$ROOT_DIR"
append_env "run_build_dir" "$BUILD_DIR"
append_env "run_report_path" "$REPORT_PATH"
append_env "run_simple_bin" "$SIMPLE_BIN"
append_env "run_simple_lib" "$SIMPLE_LIB_CONFIGURED"
append_env "run_uname_s" "$RUN_UNAME_S"
append_env "run_uname_m" "$RUN_UNAME_M"
append_env "run_child_timeout_seconds" "$CHILD_TIMEOUT"
append_env "run_probe_timeout_seconds" "$PROBE_TIMEOUT"
append_env "run_compiler_probe_timeout_seconds" "$COMPILER_PROBE_TIMEOUT"

is_positive_int() {
    value="${1:-}"
    case "$value" in
        '' | *[!0-9]*) return 1 ;;
        0) return 1 ;;
        *) return 0 ;;
    esac
}

normalize_backend_verdict() {
    name="$1"
    status="$2"
    reason="$3"
    case "$status" in
        pass)
            printf '%s\n' "pass"
            ;;
        unavailable)
            case "$name:$reason" in
                metal:* | rocm:*)
                    printf '%s\n' "host-unavailable"
                    ;;
                vulkan:missing-* | cuda:missing-*)
                    printf '%s\n' "host-unavailable"
                    ;;
                *)
                    printf '%s\n' "unavailable"
                    ;;
            esac
            ;;
        *)
            printf '%s\n' "fail"
            ;;
    esac
}

run_child() {
    name="$1"
    script="$2"
    status_key="$3"
    reason_key="$4"
    case_dir="$BUILD_DIR/$name"
    mkdir -p "$case_dir"
    set +e
    BUILD_DIR="$case_dir/build" SIMPLE_VULKAN_READBACK_WORK_DIR="$case_dir/build" REPORT_PATH="$case_dir/report.md" SIMPLE_BIN="$SIMPLE_BIN" SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$CHILD_TIMEOUT" sh "$script" >"$case_dir/stdout.env" 2>"$case_dir/stderr.log"
    code=$?
    set -e
    status="$(field_of "$status_key" "$case_dir/stdout.env")"
    reason="$(field_of "$reason_key" "$case_dir/stdout.env")"
    if [ -z "${status:-}" ] && [ -s "$case_dir/build/evidence.env" ]; then
        status="$(field_of "$status_key" "$case_dir/build/evidence.env")"
        reason="$(field_of "$reason_key" "$case_dir/build/evidence.env")"
    fi
    raw_evidence_status="$(field_of "evidence_status" "$case_dir/stdout.env")"
    timed_out="false"
    if [ "$code" = "124" ]; then
        timed_out="true"
        if [ -z "${status:-}" ]; then
            status="timeout"
        fi
        if [ -z "${reason:-}" ]; then
            reason="timeout-after-${CHILD_TIMEOUT}s"
        fi
    fi
    verdict="$(normalize_backend_verdict "$name" "${status:-missing}" "${reason:-missing}")"
    append_env "readback_${name}_exit_code" "$code"
    append_env "readback_${name}_timeout_seconds" "$CHILD_TIMEOUT"
    append_env "readback_${name}_timed_out" "$timed_out"
    append_env "readback_${name}_status" "${status:-missing}"
    append_env "readback_${name}_reason" "${reason:-missing}"
    append_env "readback_${name}_verdict" "$verdict"
    append_env "readback_${name}_raw_evidence_status" "${raw_evidence_status:-missing}"
    append_env "readback_${name}_report" "$case_dir/report.md"
    case "$name" in
        cuda | opencl | metal | rocm)
            child_prefix="$name"
            if [ "$name" = "cuda" ]; then child_prefix="cuda_generated_2d"; fi
            if [ "$name" = "opencl" ]; then child_prefix="opencl_generated_2d"; fi
            if [ "$name" = "metal" ]; then child_prefix="metal_generated_2d"; fi
            if [ "$name" = "rocm" ]; then child_prefix="rocm_generated_2d"; fi
            child_env="$case_dir/build/evidence.env"
            child_submit="$(field_of "${child_prefix}_readback_submit_attempted" "$case_dir/stdout.env")"
            child_readback="$(field_of "${child_prefix}_readback_readback_available" "$case_dir/stdout.env")"
            if [ -z "${child_submit:-}" ] && [ -s "$child_env" ]; then
                child_submit="$(field_of "${child_prefix}_readback_submit_attempted" "$child_env")"
                child_readback="$(field_of "${child_prefix}_readback_readback_available" "$child_env")"
            fi
            append_env "readback_${name}_submit_attempted" "${child_submit:-missing}"
            append_env "readback_${name}_readback_available" "${child_readback:-missing}"
            ;;
    esac
    if [ "$name" = "directx_native" ]; then
        child_env="$case_dir/build/evidence.env"
        gate="$(field_of directx_native_readback_wrapper_gate_status "$case_dir/stdout.env")"
        wrapper_exit="$(field_of directx_native_readback_wrapper_exit_code "$case_dir/stdout.env")"
        child_report="$(field_of directx_native_readback_report "$case_dir/stdout.env")"
        if [ -z "${gate:-}" ] && [ -s "$child_env" ]; then
            gate="$(field_of directx_native_readback_wrapper_gate_status "$child_env")"
            wrapper_exit="$(field_of directx_native_readback_wrapper_exit_code "$child_env")"
            child_report="$(field_of directx_native_readback_report "$child_env")"
        fi
        append_env "readback_directx_native_wrapper_gate_status" "${gate:-missing}"
        append_env "readback_directx_native_wrapper_exit_code" "${wrapper_exit:-missing}"
        append_env "readback_directx_native_child_report" "${child_report:-$case_dir/report.md}"
    fi
}

if [ "${1:-}" = "--self-test" ]; then
    self_dir="${BUILD_DIR}.self_test"
    rm -rf "$self_dir"
    mkdir -p "$self_dir"
    BUILD_DIR="$self_dir"
    ENV_PATH="$BUILD_DIR/evidence.env"
    : >"$ENV_PATH"

    cat >"$self_dir/vulkan_raw_pass_final_fail.shs" <<'SH'
#!/bin/sh
set -eu
mkdir -p "$BUILD_DIR"
echo "evidence_status=pass"
cat >"$BUILD_DIR/evidence.env" <<'EOF'
vulkan_engine2d_readback_status=fail
vulkan_engine2d_readback_reason=focused-specs-failed
EOF
SH
    chmod +x "$self_dir/vulkan_raw_pass_final_fail.shs"

    run_child vulkan "$self_dir/vulkan_raw_pass_final_fail.shs" vulkan_engine2d_readback_status vulkan_engine2d_readback_reason
    if ! grep -q '^readback_vulkan_status=fail$' "$ENV_PATH" \
        || ! grep -q '^readback_vulkan_verdict=fail$' "$ENV_PATH" \
        || ! grep -q '^readback_vulkan_raw_evidence_status=pass$' "$ENV_PATH"; then
        echo "self_test_status=fail"
        echo "self_test_reason=raw-evidence-overrode-final-status"
        exit 1
    fi

    echo "self_test_status=pass"
    echo "self_test_reason=backend-specific-status-wins"
    exit 0
fi

run_queue_probe() {
    queue_probe_source="test/01_unit/lib/nogc_async_mut/gpu/engine2d/runtime_queue_probe.spl"
    set +e
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" run "$queue_probe_source" --mode=interpreter >"$BUILD_DIR/queue_probe.env" 2>"$BUILD_DIR/queue_probe.err"
    code=$?
    set -e
    append_env "queue_probe_source" "$queue_probe_source"
    append_env "queue_probe_exit_code" "$code"
    append_probe_timeout_env "queue_probe" "$code"
    for key in \
        queue_zero_backend_packet_id queue_zero_backend_queued_status queue_zero_backend_drained queue_zero_backend_last_status queue_zero_backend_last_backend_handle \
        queue_nonzero_backend_packet_id queue_nonzero_backend_queued_status queue_nonzero_backend_drained \
        queue_nonzero_backend_packet_count queue_nonzero_backend_submitted_count queue_nonzero_backend_completed_count \
        queue_nonzero_backend_last_status queue_nonzero_backend_last_backend_handle queue_nonzero_backend_last_payload_size queue_nonzero_backend_last_payload_hash queue_nonzero_backend_last_payload_text \
        queue_overflow_capacity queue_overflow_accepted queue_overflow_packet_id queue_overflow_packet_count queue_overflow_drained
    do
        append_env "$key" "$(field_of "$key" "$BUILD_DIR/queue_probe.env")"
    done

    queue_probe_native="$BUILD_DIR/runtime_queue_probe_native"
    case "$RUN_UNAME_S" in
        MINGW*|MSYS*|CYGWIN*) queue_probe_native="${queue_probe_native}.exe" ;;
    esac
    queue_probe_native_runtime_path="${SIMPLE_RUNTIME_PATH:-$ROOT_DIR/src/compiler_rust/target/bootstrap}"
    rm -rf "$BUILD_DIR/queue_probe_native_cache" "$queue_probe_native" \
        "$BUILD_DIR/queue_probe_native.env" "$BUILD_DIR/queue_probe_native.err"
    set +e
    env -u SIMPLE_BOOTSTRAP SIMPLE_BINARY="$SIMPLE_BIN" SIMPLE_NO_STUB_FALLBACK=1 \
        SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" \
        timeout "$COMPILER_PROBE_TIMEOUT" "$SIMPLE_BIN" native-build \
        --runtime-bundle host-gpu --runtime-path "$queue_probe_native_runtime_path" \
        --entry "$queue_probe_source" --cache-dir "$BUILD_DIR/queue_probe_native_cache" \
        --mode one-binary --output "$queue_probe_native" \
        >"$BUILD_DIR/queue_probe_native_build.out" 2>"$BUILD_DIR/queue_probe_native_build.err"
    queue_probe_native_build_code=$?
    queue_probe_native_run_code=125
    if [ "$queue_probe_native_build_code" = "0" ] && [ -x "$queue_probe_native" ]; then
        timeout "$PROBE_TIMEOUT" "$queue_probe_native" \
            >"$BUILD_DIR/queue_probe_native.env" 2>"$BUILD_DIR/queue_probe_native.err"
        queue_probe_native_run_code=$?
    fi
    set -e
    append_env "queue_probe_native_runtime_path" "$queue_probe_native_runtime_path"
    append_env "queue_probe_native_build_exit_code" "$queue_probe_native_build_code"
    append_compiler_probe_timeout_env "queue_probe_native_build" "$queue_probe_native_build_code"
    append_env "queue_probe_native_run_exit_code" "$queue_probe_native_run_code"
    append_probe_timeout_env "queue_probe_native_run" "$queue_probe_native_run_code"
    if [ "$code" = "0" ] \
        && [ "$queue_probe_native_build_code" = "0" ] \
        && [ "$queue_probe_native_run_code" = "0" ] \
        && cmp -s "$BUILD_DIR/queue_probe.env" "$BUILD_DIR/queue_probe_native.env"; then
        append_env "queue_probe_native_status" "pass"
    else
        append_env "queue_probe_native_status" "fail"
    fi
}

run_existing_runtime_spec() {
    set +e
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/nogc_async_mut/gpu/engine2d/draw_ir_runtime_queue_spec.spl --mode=interpreter >"$BUILD_DIR/nogc_draw_ir_runtime_queue_spec.out" 2>"$BUILD_DIR/nogc_draw_ir_runtime_queue_spec.err"
    nogc_draw_ir_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/gc_async_mut/gpu/engine2d/draw_ir_runtime_queue_spec.spl --mode=interpreter >"$BUILD_DIR/gc_draw_ir_runtime_queue_spec.out" 2>"$BUILD_DIR/gc_draw_ir_runtime_queue_spec.err"
    gc_draw_ir_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/nogc_async_mut/gpu/engine2d/host_gpu_event_queue_spec.spl --mode=interpreter >"$BUILD_DIR/host_gpu_event_queue_spec.out" 2>"$BUILD_DIR/host_gpu_event_queue_spec.err"
    event_queue_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/app/ui/browser_host_event_roundtrip_spec.spl --mode=interpreter >"$BUILD_DIR/browser_host_event_roundtrip_spec.out" 2>"$BUILD_DIR/browser_host_event_roundtrip_spec.err"
    browser_event_code=$?
    set -e
    append_env "draw_ir_runtime_queue_spec_exit_code" "$nogc_draw_ir_code"
    append_probe_timeout_env "draw_ir_runtime_queue_spec" "$nogc_draw_ir_code"
    append_env "nogc_draw_ir_runtime_queue_spec_exit_code" "$nogc_draw_ir_code"
    append_probe_timeout_env "nogc_draw_ir_runtime_queue_spec" "$nogc_draw_ir_code"
    append_env "gc_draw_ir_runtime_queue_spec_exit_code" "$gc_draw_ir_code"
    append_probe_timeout_env "gc_draw_ir_runtime_queue_spec" "$gc_draw_ir_code"
    append_env "host_gpu_event_queue_spec_exit_code" "$event_queue_code"
    append_probe_timeout_env "host_gpu_event_queue_spec" "$event_queue_code"
    append_env "browser_host_event_roundtrip_exit_code" "$browser_event_code"
    append_probe_timeout_env "browser_host_event_roundtrip" "$browser_event_code"
    if [ "$nogc_draw_ir_code" = "0" ]; then
        append_env "draw_ir_runtime_queue_status" "pass"
        append_env "nogc_draw_ir_runtime_queue_status" "pass"
    else
        append_env "draw_ir_runtime_queue_status" "fail"
        append_env "nogc_draw_ir_runtime_queue_status" "fail"
    fi
    if [ "$gc_draw_ir_code" = "0" ]; then
        append_env "gc_draw_ir_runtime_queue_status" "pass"
    else
        append_env "gc_draw_ir_runtime_queue_status" "fail"
    fi
    if [ "$event_queue_code" = "0" ]; then
        append_env "host_gpu_event_queue_status" "pass"
    else
        append_env "host_gpu_event_queue_status" "fail"
    fi
    if [ "$browser_event_code" = "0" ]; then
        append_env "browser_host_event_roundtrip_status" "pass"
        append_env "browser_host_event_roundtrip_reason" "browser-backend-event-ingress-contract-pass"
    else
        append_env "browser_host_event_roundtrip_status" "fail"
        append_env "browser_host_event_roundtrip_reason" "browser-backend-event-ingress-contract-fail"
    fi
    append_env "browser_host_event_roundtrip_source" "browser_backend_event_queue"
}

run_presentation_provenance_specs() {
    set +e
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_directx_spec.spl --mode=interpreter >"$BUILD_DIR/backend_directx_spec.out" 2>"$BUILD_DIR/backend_directx_spec.err"
    directx_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_webgpu_spec.spl --mode=interpreter >"$BUILD_DIR/backend_webgpu_spec.out" 2>"$BUILD_DIR/backend_webgpu_spec.err"
    webgpu_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/gc_async_mut/gpu/engine2d/backend_readback_handle_contract_spec.spl --mode=interpreter >"$BUILD_DIR/backend_readback_handle_contract_spec.out" 2>"$BUILD_DIR/backend_readback_handle_contract_spec.err"
    contract_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/01_unit/lib/nogc_async_mut/gpu/engine2d/engine2d_readback_metadata_spec.spl --mode=interpreter >"$BUILD_DIR/engine2d_readback_metadata_spec.out" 2>"$BUILD_DIR/engine2d_readback_metadata_spec.err"
    metadata_code=$?
    set -e
    append_env "directx_presentation_provenance_spec_exit_code" "$directx_code"
    append_probe_timeout_env "directx_presentation_provenance_spec" "$directx_code"
    append_env "webgpu_upload_provenance_spec_exit_code" "$webgpu_code"
    append_probe_timeout_env "webgpu_upload_provenance_spec" "$webgpu_code"
    append_env "backend_readback_handle_contract_spec_exit_code" "$contract_code"
    append_probe_timeout_env "backend_readback_handle_contract_spec" "$contract_code"
    append_env "engine2d_readback_metadata_spec_exit_code" "$metadata_code"
    append_probe_timeout_env "engine2d_readback_metadata_spec" "$metadata_code"
    if [ "$directx_code" = "0" ]; then
        append_env "directx_presentation_provenance_status" "pass"
    else
        append_env "directx_presentation_provenance_status" "fail"
    fi
    if [ "$webgpu_code" = "0" ]; then
        append_env "webgpu_upload_provenance_status" "pass"
    else
        append_env "webgpu_upload_provenance_status" "fail"
    fi
    if [ "$contract_code" = "0" ]; then
        append_env "backend_readback_handle_contract_status" "pass"
    else
        append_env "backend_readback_handle_contract_status" "fail"
    fi
    if [ "$metadata_code" = "0" ]; then
        append_env "engine2d_readback_metadata_status" "pass"
    else
        append_env "engine2d_readback_metadata_status" "fail"
    fi
    if [ "$directx_code" = "0" ]; then
        append_env "directx_presentation_provenance_source" "structured_readback_contract"
        append_env "directx_structured_readback_contract_status" "pass"
        append_env "directx_structured_readback_contract_reason" "backend spec proves positive readback handle plus checksum gate"
    else
        append_env "directx_presentation_provenance_source" "swapchain_present"
        append_env "directx_structured_readback_contract_status" "fail"
        append_env "directx_structured_readback_contract_reason" "backend spec failed"
    fi
    append_env "webgpu_upload_provenance_source" "surface_upload"
    append_env "directx_presentation_evidence_kind" "structured_readback_contract"
    append_env "webgpu_upload_evidence_kind" "provenance_only"
    append_env "presentation_provenance_device_readback_status" "not_device_readback"
}

run_native_readback_wrapper_specs() {
    set +e
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/03_system/check/directx_native_readback_spec.spl --mode=interpreter >"$BUILD_DIR/directx_native_readback_spec.out" 2>"$BUILD_DIR/directx_native_readback_spec.err"
    directx_native_spec_code=$?
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" test test/03_system/check/generated_2d_native_readback_wrappers_spec.spl --mode=interpreter >"$BUILD_DIR/generated_2d_native_readback_wrappers_spec.out" 2>"$BUILD_DIR/generated_2d_native_readback_wrappers_spec.err"
    generated_2d_spec_code=$?
    set -e
    append_env "directx_native_readback_spec_exit_code" "$directx_native_spec_code"
    append_probe_timeout_env "directx_native_readback_spec" "$directx_native_spec_code"
    append_env "generated_2d_native_readback_wrappers_spec_exit_code" "$generated_2d_spec_code"
    append_probe_timeout_env "generated_2d_native_readback_wrappers_spec" "$generated_2d_spec_code"
    if [ "$directx_native_spec_code" = "0" ]; then
        append_env "directx_native_readback_spec_status" "pass"
    else
        append_env "directx_native_readback_spec_status" "fail"
    fi
    if [ "$generated_2d_spec_code" = "0" ]; then
        append_env "generated_2d_native_readback_wrappers_spec_status" "pass"
    else
        append_env "generated_2d_native_readback_wrappers_spec_status" "fail"
    fi
    if [ "$directx_native_spec_code" = "0" ] && [ "$generated_2d_spec_code" = "0" ]; then
        append_env "native_readback_wrapper_sspec_coverage_status" "pass"
        append_env "native_readback_wrapper_sspec_doc_evidence_status" "pass"
    else
        append_env "native_readback_wrapper_sspec_coverage_status" "fail"
        append_env "native_readback_wrapper_sspec_doc_evidence_status" "fail"
    fi
}

run_webgpu_real_readback() {
    webgpu_real_dir="$BUILD_DIR/webgpu_real"
    set +e
    BUILD_DIR="$webgpu_real_dir" REPORT_PATH="$webgpu_real_dir/report.md" timeout "$CHILD_TIMEOUT" sh scripts/check/check-webgpu-real-readback.shs >"$BUILD_DIR/webgpu_real.out" 2>"$BUILD_DIR/webgpu_real.err"
    code=$?
    set -e
    append_env "webgpu_real_readback_exit_code" "$code"
    append_probe_timeout_env "webgpu_real_readback" "$code"
    child_env="$webgpu_real_dir/evidence.env"
    append_env "webgpu_real_readback_status" "$(field_of webgpu_real_readback_status "$child_env")"
    append_env "webgpu_real_readback_reason" "$(field_of webgpu_real_readback_reason "$child_env")"
    append_env "webgpu_real_readback_source" "$(field_of webgpu_real_readback_source "$child_env")"
    append_env "webgpu_real_readback_backend_handle" "$(field_of webgpu_real_readback_backend_handle "$child_env")"
    append_env "webgpu_real_readback_expected_checksum" "$(field_of webgpu_real_readback_expected_checksum "$child_env")"
    append_env "webgpu_real_readback_actual_checksum" "$(field_of webgpu_real_readback_actual_checksum "$child_env")"
    append_env "webgpu_real_readback_report" "$webgpu_real_dir/report.md"
}

run_compiler_cleanup_specs() {
    set +e
    (cd src/compiler_rust && timeout "$COMPILER_PROBE_TIMEOUT" cargo test -p simple-compiler hir::lower::stmt_lowering::host_gpu_lane_statement_tests -- --nocapture) >"$BUILD_DIR/compiler_hir_host_gpu_lane_statement_tests.out" 2>"$BUILD_DIR/compiler_hir_host_gpu_lane_statement_tests.err"
    hir_code=$?
    (cd src/compiler_rust && timeout "$COMPILER_PROBE_TIMEOUT" cargo test -p simple-compiler --test host_gpu_lane_error_test -- --nocapture) >"$BUILD_DIR/compiler_host_gpu_lane_error_test.out" 2>"$BUILD_DIR/compiler_host_gpu_lane_error_test.err"
    error_code=$?
    set -e
    append_env "compiler_hir_host_gpu_lane_statement_tests_exit_code" "$hir_code"
    append_compiler_probe_timeout_env "compiler_hir_host_gpu_lane_statement_tests" "$hir_code"
    append_env "compiler_host_gpu_lane_error_test_exit_code" "$error_code"
    append_compiler_probe_timeout_env "compiler_host_gpu_lane_error_test" "$error_code"
    if [ "$hir_code" = "0" ] && [ "$error_code" = "0" ]; then
        append_env "compiler_host_gpu_lane_cleanup_status" "pass"
        append_env "compiler_host_gpu_lane_cleanup_reason" "hir-return-cleanup-and-interpreter-body-error-cleanup-pass"
    else
        append_env "compiler_host_gpu_lane_cleanup_status" "fail"
        append_env "compiler_host_gpu_lane_cleanup_reason" "hir-or-interpreter-cleanup-probe-failed"
    fi
}

run_browser_frame_probe() {
    set +e
    SIMPLE_LIB="$SIMPLE_LIB_CONFIGURED" timeout "$PROBE_TIMEOUT" "$SIMPLE_BIN" run test/01_unit/app/ui/browser_backend_runtime_queue_probe.spl --mode=interpreter >"$BUILD_DIR/browser_backend_runtime_queue_probe.env" 2>"$BUILD_DIR/browser_backend_runtime_queue_probe.err"
    code=$?
    set -e
    append_env "browser_frame_probe_exit_code" "$code"
    append_probe_timeout_env "browser_frame_probe" "$code"
    for key in \
        backend first_render_us first_render_under_budget first_render_dom_layout_us first_render_html_us first_render_pixel_artifact_us first_render_draw_ir_dispatch_us first_render_framebuffer_copy_us first_render_state_store_us first_pixel_count first_checksum first_nonuniform_count first_submit first_drain first_packet first_drained first_backend_handle first_payload_size first_payload_hash first_payload_text first_dispatch_status first_dispatch_reason first_dispatch_payload_size first_dispatch_layout_command_count first_dispatch_payload_hash first_dispatch_payload_text first_dispatch_rect_command_count first_dispatch_text_command_count first_dispatch_image_command_count first_dispatch_has_gui_ast_source first_dispatch_has_root_widget first_dispatch_has_copy_text first_dispatch_has_action_text first_dispatch_has_image_widget first_dispatch_has_image_uri first_dispatch_target_context_resolved first_dispatch_target_context_batch_id first_dispatch_target_context_surface_id first_dispatch_target_context_component_id first_dispatch_target_context_source_kind first_reason \
        first_readback_status first_readback_backend first_readback_pixel_count first_readback_checksum first_readback_reason first_gpu_readback_source first_event_correlation_status first_event_correlation_id first_event_correlation_summary first_event_correlation_queue_packet first_event_correlation_readback_source first_event_correlation_readback_checksum \
        event_roundtrip_status event_enqueued_count event_polled_count event_dispatched_count event_host_gpu_target_lane event_host_gpu_forwarded event_host_gpu_backward_completed event_host_gpu_summary \
        second_render_us second_render_under_budget second_fast_hits second_submit second_drain second_packet second_drained second_backend_handle second_payload_size second_payload_hash second_payload_text second_dispatch_status second_dispatch_reason second_dispatch_payload_size second_dispatch_layout_command_count second_dispatch_payload_hash second_dispatch_payload_text second_dispatch_rect_command_count second_dispatch_text_command_count second_dispatch_image_command_count second_dispatch_has_gui_ast_source second_dispatch_has_root_widget second_dispatch_has_copy_text second_dispatch_has_action_text second_dispatch_has_image_widget second_dispatch_has_image_uri second_dispatch_target_context_resolved second_dispatch_target_context_batch_id second_dispatch_target_context_surface_id second_dispatch_target_context_component_id second_dispatch_target_context_source_kind second_reason \
        second_readback_status second_readback_backend second_readback_pixel_count second_readback_checksum second_readback_reason second_gpu_readback_source second_event_correlation_status second_event_correlation_id second_event_correlation_summary second_event_correlation_queue_packet second_event_correlation_readback_source second_event_correlation_readback_checksum
    do
        append_env "browser_${key}" "$(field_of "$key" "$BUILD_DIR/browser_backend_runtime_queue_probe.env")"
    done
}

audit_capacity_and_status() {
    c_capacity="$(sed -n 's/^#define RT_HOST_GPU_QUEUE_CAPACITY //p' src/runtime/runtime_native.c | tail -n 1)"
    rust_capacity="$(awk '/pub const RT_HOST_GPU_QUEUE_CAPACITY: usize =/ { gsub(/;/, "", $6); print $6 }' src/compiler_rust/runtime/src/host_gpu_lane.rs | tail -n 1)"
    submitted_assignments="$(rg -n 'last_status.*RT_HOST_GPU_QUEUE_STATUS_SUBMITTED|RT_HOST_GPU_QUEUE_STATUS_SUBMITTED.*last_status' src/compiler_rust/runtime/src/host_gpu_lane.rs src/runtime/runtime_native.c | wc -l | tr -d ' ')"
    concrete_handle_fields="$(rg -n 'host_gpu_queue_.*handle|backend_handle|runtime_handle' src/compiler_rust/runtime/src/host_gpu_lane.rs src/runtime/runtime_native.c | wc -l | tr -d ' ')"
    append_env "queue_c_capacity" "${c_capacity:-missing}"
    append_env "queue_rust_capacity" "${rust_capacity:-missing}"
    if [ -n "${c_capacity:-}" ] && [ "$c_capacity" = "${rust_capacity:-}" ]; then
        append_env "queue_capacity_parity_status" "pass"
    else
        append_env "queue_capacity_parity_status" "gap"
    fi
    append_env "queue_submitted_status_assignment_count" "$submitted_assignments"
    if [ "$submitted_assignments" = "0" ]; then
        append_env "queue_submitted_status_usage" "unused"
    else
        append_env "queue_submitted_status_usage" "used"
    fi
    append_env "queue_concrete_backend_handle_field_count" "$concrete_handle_fields"
    if is_positive_int "$(field_of queue_nonzero_backend_last_backend_handle "$ENV_PATH")"; then
        append_env "queue_backend_handle_roundtrip_status" "pass"
        append_env "queue_concrete_backend_handle_status" "pass"
    else
        append_env "queue_backend_handle_roundtrip_status" "missing"
        append_env "queue_concrete_backend_handle_status" "missing"
    fi
}

provenance_display_status() {
    if [ "${1:-missing}" = "pass" ]; then
        printf '%s\n' "provenance-only-pass"
    else
        printf '%s\n' "${1:-missing}"
    fi
}

status_of() {
    field_of "$1" "$ENV_PATH"
}

