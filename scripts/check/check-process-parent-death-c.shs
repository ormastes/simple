#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
out=$(mktemp "${TMPDIR:-/tmp}/simple-pdeath-c.XXXXXX")
trap 'rm -f "$out"' EXIT INT TERM

cc -std=gnu11 -O0 -ffunction-sections -fdata-sections -I"$root/src/runtime" \
    "$root/src/runtime/runtime.c" \
    "$root/test/01_unit/runtime/process_guarded_parent_death_test.c" \
    -Wl,--gc-sections -ldl -lm -o "$out"
"$out"
echo "process_parent_death_c=true"
