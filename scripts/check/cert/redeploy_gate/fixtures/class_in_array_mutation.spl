# redeploy-gate fixture: class-in-array-mutation (guards #112)
# A CLASS instance stored in an array; mutating arr[0].field through the array
# slot must be visible on read-back (class = reference semantics, Value.Object).
# Run under the interpreter: SIMPLE_EXECUTION_MODE=interpret. #112 was the
# symptom where the mutation was silently dropped.
# EXPECT stdout: 777
class Cell:
    var value: int

fn main():
    var arr = [Cell(value: 0)]
    arr[0].value = 777
    print(arr[0].value)
