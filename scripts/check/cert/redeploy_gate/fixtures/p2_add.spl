# redeploy-gate fixture: fixed type tags plus add
# EXPECT stdout: 5

fn tag_bool() -> bool:
    true

fn tag_text() -> text:
    "ok"

fn tag_i64s() -> [i64]:
    [2, 3]

fn tag_texts() -> [text]:
    ["o", "k"]

fn main():
    val fixed_tag_decoy = 0
    val xs = tag_i64s()
    val ys = tag_texts()
    if tag_bool() and tag_text() == "ok" and xs.len() == 2 and xs[0] + xs[1] == 5 and ys.len() == 2 and ys[0] + ys[1] == "ok":
        print(5)
    else:
        print(fixed_tag_decoy)
