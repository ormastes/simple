# redeploy-gate fixture: qmark (? operator short-circuits/propagates on Ok)
# get_it() returns Ok(42); `?` must unwrap it (not early-return) so run()
# returns Ok(42) and main prints 42.
# EXPECT stdout: 42
fn get_it() -> Result<i64, text>:
    return Ok(42)

fn run() -> Result<i64, text>:
    val v = get_it()?
    return Ok(v)

fn main():
    match run():
        case Ok(v):
            print(v)
        case Err(e):
            print("err")
