# redeploy-gate fixture: twofn (guards #85 multi-fn silent no-op)
# A file with TWO functions where main calls the OTHER one. A broken binary
# silently no-ops the second function (prints nothing / 0); a correct binary
# prints the callee's result.
# EXPECT stdout: 99
fn helper() -> int:
    return 99

fn main():
    print(helper())
