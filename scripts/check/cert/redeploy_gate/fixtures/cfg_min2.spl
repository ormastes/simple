# redeploy-gate fixture: cfg-lowered-funcs=2 (count-check, recorded gate gap)
# Two @cfg variants of ONE function name. A correct compiler LOWERS exactly 2
# functions (one per cfg predicate); a #45 last-write-wins collision would drop
# one and lower only 1. The lowered-function COUNT is not observable from the
# current CLI output, so the gate treats this as a soft/skipped check.
# ponytail: needs an --emit=mir / lowered-fn dump flag to assert count == 2.
# On an x86_64 host main prints 64 (the x86_64 variant).
# EXPECT: compiler lowers exactly 2 variants of size2()
@cfg(x86_64)
fn size2() -> int:
    return 64

@cfg(arm64)
fn size2() -> int:
    return 32

fn main():
    print(size2())
