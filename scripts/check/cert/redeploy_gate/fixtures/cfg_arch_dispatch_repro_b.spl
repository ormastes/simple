# redeploy-gate fixture: cfg-arch-dispatch B (guards #45 last-write-wins collision)
# Same as A but order B declares the arm64 variant FIRST. Pre-fix, first-declared
# wins and this order wrongly returns "arm64". On an x86_64 host, arch_name()
# must resolve to "x86_64" in BOTH orders. The fixture self-checks (PASS/FAIL).
# EXPECT stdout (x86_64 host): "order B (arm64 first): arch_name() = x86_64" then "PASS"

@cfg(arm64)
fn arch_name() -> text:
    "arm64"

@cfg(x86_64)
fn arch_name() -> text:
    "x86_64"

fn main() -> i32:
    val got = arch_name()
    print("order B (arm64 first): arch_name() = {got}")
    if got == "x86_64":
        print("PASS")
        return 0
    print("FAIL: expected x86_64")
    1
