# redeploy-gate fixture: cfg-arch-dispatch B (guards #45 last-write-wins collision)
# Same as A but order B declares the arm64 variant FIRST. Pre-fix, first-declared
# wins and this order can select the wrong architecture. The gate compares the
# selected value with the actual host architecture for both supported hosts.

@cfg(arm64)
fn arch_name() -> text:
    "arm64"

@cfg(x86_64)
fn arch_name() -> text:
    "x86_64"

fn main() -> i32:
    val got = arch_name()
    print("order B (arm64 first): arch_name() = {got}")
    0
