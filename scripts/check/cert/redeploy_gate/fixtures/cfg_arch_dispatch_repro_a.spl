# redeploy-gate fixture: cfg-arch-dispatch A (guards #45 last-write-wins collision)
# Two @cfg arch variants of the SAME bare name arch_name(); order A declares the
# x86_64 variant FIRST. The gate compares the selected value with the actual
# host architecture so both x86_64 and arm64 redeploys exercise this ordering.

@cfg(x86_64)
fn arch_name() -> text:
    "x86_64"

@cfg(arm64)
fn arch_name() -> text:
    "arm64"

fn main() -> i32:
    val got = arch_name()
    print("order A (x86_64 first): arch_name() = {got}")
    0
