# redeploy-gate fixture: cfg-arch-dispatch A (guards #45 last-write-wins collision)
# Two @cfg arch variants of the SAME bare name arch_name(); order A declares the
# x86_64 variant FIRST. On an x86_64 host, arch_name() must resolve to "x86_64"
# in BOTH declaration orders. The fixture self-checks and prints PASS/FAIL.
# EXPECT stdout (x86_64 host): "order A (x86_64 first): arch_name() = x86_64" then "PASS"

@cfg(x86_64)
fn arch_name() -> text:
    "x86_64"

@cfg(arm64)
fn arch_name() -> text:
    "arm64"

fn main() -> i32:
    val got = arch_name()
    print("order A (x86_64 first): arch_name() = {got}")
    if got == "x86_64":
        print("PASS")
        return 0
    print("FAIL: expected x86_64")
    1
