    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_tauri_tracked_count=14" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_tauri_fail_count=0" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_tauri_mismatch_count=0" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_capture_status=pass" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_live_capture=true" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_case_count=50" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_pass_count=36" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_tracked_count=14" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_fail_count=0" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_chrome_mismatch_count=0" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_no_fake_capture=true" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_surface_manifest_blur_or_tolerance_used=false" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_backend_status=pass" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_backend_exact=true" \
    && contains "$PRODUCTION_GUI_PARITY_REPORT" "production_gui_web_renderer_parity_backend_cpu_simd_different_pixels=0"; then
    production_gui_parity_status=pass
fi
if [ "$simple_gui_webrenderer_status" = pass ] && [ "$production_gui_parity_status" != pass ]; then
    simple_gui_webrenderer_status=fail
fi

if [ -f "$RV64_DISPLAY_SMOKE_REPORT" ]; then
    rv64_display_smoke_qmp_status="$(sed -n 's/^- status: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_reason="$(sed -n 's/^- reason: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_contract_version="$(sed -n 's/^- contract_version: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_width="$(sed -n 's/^- width: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_height="$(sed -n 's/^- height: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_stride="$(sed -n 's/^- stride: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_present_revision="$(sed -n 's/^- present_revision: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_nonblack="$(sed -n 's/^- nonblack: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_palette_witnesses="$(sed -n 's/^- canonical_palette_witnesses: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
    rv64_display_smoke_qmp_palette_names="$(sed -n 's/^- canonical_palette_names: //p' "$RV64_DISPLAY_SMOKE_REPORT" | tail -n 1)"
fi
if [ "$rv64_display_smoke_qmp_status" = pass ] \
    && [ "$rv64_display_smoke_qmp_contract_version" -eq 2 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_reason" = rv64-canonical-desktop-qmp-pass ] \
    && [ "$rv64_display_smoke_qmp_width" -gt 0 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_height" -gt 0 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_stride" -ge "$((rv64_display_smoke_qmp_width * 4))" ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_present_revision" -gt 0 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_nonblack" -gt 0 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_palette_witnesses" -ge 4 ] 2>/dev/null \
    && contains "$RV64_DISPLAY_SMOKE_REPORT" "- ready: 1" \
    && contains "$RV64_DISPLAY_SMOKE_REPORT" "- lifecycle_markers: 1" \
    && contains "scripts/check/check-rv64-display-smoke-qmp-evidence.shs" "virtio-gpu-pci,disable-modern=on,disable-legacy=off"; then
    rv64_display_smoke_qmp_status=pass
else
    [ "$rv64_display_smoke_qmp_status" = pass ] && rv64_display_smoke_qmp_status=fail
fi

if [ "$rv64_display_smoke_qmp_status" = pass ] \
    && contains "src/os/_QemuRunner/scenario_catalog.spl" "fn scenario_riscv64_display_smoke()" \
    && contains "src/os/_QemuRunner/scenario_catalog.spl" "virtio-gpu-pci,disable-modern=on,disable-legacy=off" \
    && [ "$rv64_display_smoke_qmp_contract_version" -eq 2 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_nonblack" -gt 0 ] 2>/dev/null \
    && [ "$rv64_display_smoke_qmp_palette_witnesses" -ge 4 ] 2>/dev/null; then
    qemu_virtio_gpu_access_status=pass
    qemu_virtio_gpu_access_reason=rv64-qmp-virtio-gpu-canonical-desktop-pass
else
    qemu_virtio_gpu_access_reason=rv64-qmp-virtio-gpu-display-smoke-incomplete
fi

if contains "$QEMU_GTK_REPORT" "- status: pass" \
    && contains "$QEMU_GTK_REPORT" "auto QMP status: pass" \
    && contains "$QEMU_GTK_REPORT" "qemu live bitmap status: pass" \
    && contains "$QEMU_GTK_REPORT" "live capture sample mismatches: 0" \
    && contains "$QEMU_GTK_REPORT" "live capture full-scene mismatches: 0" \
    && contains "$QEMU_GTK_REPORT" "qemu-side perf release gate: guest-simple-frame-plus-host-gtk-baseline" \
    && contains "$QEMU_GTK_REPORT" "qemu-side perf required for release: true" \
    && contains "$QEMU_GTK_REPORT" "qemu-side perf harness sample origin:" \
    && contains "$QEMU_GTK_REPORT" "qemu-side perf harness required sample origin: qemu-guest" \
    && contains "$QEMU_GTK_REPORT" "host GTK GL WM scene mismatch count: 0" \
    && contains "$QEMU_GTK_REPORT" "host GTK GL WM scene blur/tolerance used: false" \
    && contains "$QEMU_GTK_REPORT" "host perf baseline promotes QEMU perf: false"; then
    qemu_host_counterpart_status=pass
fi
if [ -f "$QEMU_GTK_REPORT" ]; then
    qemu_guest_perf_harness_status="$(sed -n 's/^- qemu-side perf harness status: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_guest_perf_harness_reason="$(sed -n 's/^- qemu-side perf harness reason: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_guest_perf_harness_sample_origin="$(sed -n 's/^- qemu-side perf harness sample origin: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_guest_perf_harness_required_sample_origin="$(sed -n 's/^- qemu-side perf harness required sample origin: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_guest_perf_harness_pending_marker="$(sed -n 's/^- qemu-side perf harness pending marker: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_guest_perf_harness_marker_line="$(sed -n 's/^- qemu-side perf harness marker line: //p' "$QEMU_GTK_REPORT" | tail -n 1 | tr -d '\r')"
    qemu_guest_perf_release_blocker="$(sed -n 's/^- qemu-side perf release blocker: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_host_perf_promotes_qemu_perf="$(sed -n 's/^- host perf baseline promotes QEMU perf: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_gui_smf_artifact_contract_status="$(sed -n 's/^- GUI SMF artifact contract status: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    qemu_gui_smf_artifact_contract_row="$(sed -n 's/^- GUI SMF artifact contract row: //p' "$QEMU_GTK_REPORT" | tail -n 1)"
    if [ "$qemu_gui_smf_artifact_contract_status" = pass ] \
        && printf '%s\n' "$qemu_gui_smf_artifact_contract_row" | grep -Fq "GUI_SMF_ARTIFACT_CONTRACT status=pass" \
        && printf '%s\n' "$qemu_gui_smf_artifact_contract_row" | grep -Fq " qemu_status=pass" \
        && { printf '%s\n' "$qemu_gui_smf_artifact_contract_row" | grep -Fq " macos_status=pass" \
            || printf '%s\n' "$qemu_gui_smf_artifact_contract_row" | grep -Fq " macos_status=not-run macos_reason=requires-macos-arm64"; }; then
        qemu_gui_smf_artifact_status=pass
    fi
    if contains "$QEMU_GTK_REPORT" "qemu-side perf status: pass" \
        && [ "$qemu_guest_perf_harness_status" = pass ] \
        && [ "$qemu_guest_perf_harness_sample_origin" = "$qemu_guest_perf_harness_required_sample_origin" ] \
        && [ "$qemu_guest_perf_harness_required_sample_origin" = qemu-guest ] \
        && printf '%s\n' "$qemu_guest_perf_harness_marker_line" | grep -Fq "sample_origin=qemu-guest" \
        && printf '%s\n' "$qemu_guest_perf_harness_marker_line" | grep -Fq "simple_frame_cycles=" \
        && printf '%s\n' "$qemu_guest_perf_harness_marker_line" | grep -Fq "iterations=" \
        && contains "$QEMU_GTK_REPORT" "qemu-side perf host GTK frame us:" \
        && contains "$QEMU_GTK_REPORT" "host perf baseline status: pass" \
        && contains "$QEMU_GTK_REPORT" "host perf baseline comparison available: true" \
        && [ "$qemu_host_perf_promotes_qemu_perf" = false ]; then
        qemu_guest_perf_gate_status=pass
        qemu_guest_perf_release_blocker=none
    else
        qemu_guest_perf_gate_status="blocked-${qemu_guest_perf_harness_status:-missing}"
    fi
fi

GUI_DIR="$(latest_gui_dir)"
GUI_PPM_SIZE=0
GUI_RAW_SIZE=0
if [ -n "$GUI_DIR" ]; then
    GUI_PPM_SIZE="$(file_size "$GUI_DIR/capture.ppm")"
    GUI_RAW_SIZE="$(file_size "$GUI_DIR/capture.ppm.raw")"
    qemu_mdi_input_before_ppm_bytes="$(file_size "$GUI_DIR/capture-before-input.ppm")"
    qemu_mdi_input_after_ppm_bytes="$(file_size "$GUI_DIR/capture-after-input.ppm")"
    qemu_mdi_input_before_raw_bytes="$(file_size "$GUI_DIR/capture-before-input.ppm.raw")"
    qemu_mdi_input_after_raw_bytes="$(file_size "$GUI_DIR/capture-after-input.ppm.raw")"
    if [ -f "$GUI_DIR/capture-before-input.ppm.raw" ]; then
        qemu_mdi_input_before_sha256="$(sha256sum "$GUI_DIR/capture-before-input.ppm.raw" | awk '{print $1}')"
    fi
    if [ -f "$GUI_DIR/capture-after-input.ppm.raw" ]; then
        qemu_mdi_input_after_sha256="$(sha256sum "$GUI_DIR/capture-after-input.ppm.raw" | awk '{print $1}')"
    fi
    if [ "$qemu_mdi_input_before_ppm_bytes" -eq 2359312 ] \
        && [ "$qemu_mdi_input_after_ppm_bytes" -eq 2359312 ] \
        && [ "$qemu_mdi_input_before_raw_bytes" -eq 3145728 ] \
        && [ "$qemu_mdi_input_after_raw_bytes" -eq 3145728 ] \
        && [ -n "$qemu_mdi_input_before_sha256" ] \
        && [ -n "$qemu_mdi_input_after_sha256" ] \
        && [ "$qemu_mdi_input_before_sha256" != "$qemu_mdi_input_after_sha256" ]; then
        qemu_mdi_input_status=pass
    fi
    if [ -f "$GUI_DIR/capture.ppm" ]; then
        SIMPLE_BIN="$(resolve_simple_bin)"
        set +e
        SIMPLEOS_HARDENING_QEMU_MDI_PPM="$GUI_DIR/capture.ppm" "$SIMPLE_BIN" run scripts/check/validate_simpleos_hardening_qemu_mdi_ppm.spl --mode=interpreter >"$qemu_mdi_ppm_anchor_log"
        ppm_validator_code=$?
        set -e
        if [ "$ppm_validator_code" -ne 0 ] && [ ! -s "$qemu_mdi_ppm_anchor_log" ]; then
            {
                echo "simpleos_hardening_qemu_mdi_ppm_anchor_status=fail"
                echo "simpleos_hardening_qemu_mdi_ppm_nonblack=0"
                echo "simpleos_hardening_qemu_mdi_ppm_probe=false"
                echo "simpleos_hardening_qemu_mdi_ppm_header=false"
                echo "simpleos_hardening_qemu_mdi_ppm_bodyA=false"
                echo "simpleos_hardening_qemu_mdi_ppm_bodyB=false"
                echo "simpleos_hardening_qemu_mdi_ppm_top=false"
                echo "simpleos_hardening_qemu_mdi_ppm_taskbar=false"
            } >"$qemu_mdi_ppm_anchor_log"
        fi
        qemu_mdi_ppm_anchor_status="$(sed -n 's/^simpleos_hardening_qemu_mdi_ppm_anchor_status=//p' "$qemu_mdi_ppm_anchor_log" | tail -n 1)"
        qemu_mdi_ppm_nonblack="$(sed -n 's/^simpleos_hardening_qemu_mdi_ppm_nonblack=//p' "$qemu_mdi_ppm_anchor_log" | tail -n 1)"
    fi
fi
if [ "$GUI_PPM_SIZE" -eq 2359312 ] \
    && [ "$GUI_RAW_SIZE" -eq 3145728 ] \
    && [ "$qemu_mdi_ppm_anchor_status" = pass ] \
    && contains "$GUI_ENTRY_SPEC" "[wm-demo] wm-service-ready" \
    && contains "$GUI_ENTRY_SPEC" "shared-mdi-ready surfaces=5" \
    && contains "$GUI_ENTRY_SPEC" "windows-ready count=5" \
    && contains "$GUI_ENTRY_SPEC" "[integrated-demo] render-ready" \
    && contains "$GUI_ENTRY_SPEC" "capture_method=pmemsave" \
    && contains "$GUI_ENTRY_SPEC" "pmem_addr=0xfd000000" \
    && contains "$GUI_ENTRY_SPEC" "qmp_keyboard_input" \
    && contains "$GUI_ENTRY_SPEC" "capture-before-input.ppm" \
    && contains "$GUI_ENTRY_SPEC" "capture-after-input.ppm" \
    && contains "$GUI_ENTRY_SPEC" "probe=True" \
    && contains "$GUI_ENTRY_SPEC" "taskbar=True" \
    && [ "$qemu_mdi_input_status" = pass ] \
    && contains "$GUI_ENTRY_DOC" 'QMP `pmemsave 0xfd000000` captures the BGA framebuffer' \
    && contains "$GUI_ENTRY_DOC" "host keyboard event"; then
    qemu_mdi_status=pass
fi

passed_count=0
for s in "$exec_launch_fs_status" "$ssh_smf_exec_status" "$formal_lean_proofs_status" "$formal_riscv_dual_track_status" "$formal_critical_concurrency_status" "$formal_memory_safety_status" "$formal_storage_integrity_status" "$formal_boundary_integrity_status" "$formal_process_resource_lifecycle_status" "$formal_coroutine_resource_bounds_status" "$formal_compiler_language_status" "$formal_ui_policy_status" "$formal_coverage_status" "$byl_sby_artifact_audit_status" "$async_library_hardening_status" "$shared_wm_status" "$cpu_simd_status" "$llvm_port_status" "$gui_renderdoc_vulkan_status" "$web_renderer_engine2d_status" "$simple_gui_webrenderer_status" "$qemu_host_counterpart_status" "$qemu_gui_smf_artifact_status" "$qemu_mdi_status" "$rv64_display_smoke_qmp_status" "$qemu_virtio_gpu_access_status"; do
    if [ "$s" = pass ]; then
        passed_count=$((passed_count + 1))
    fi
done

blocked_rows=
add_blocker() {
    if [ -z "$blocked_rows" ]; then
        blocked_rows="$1"
    else
        blocked_rows="$blocked_rows,$1"
    fi
}

[ "$exec_launch_fs_status" = pass ] || add_blocker executable_launch_from_fs
[ "$ssh_smf_exec_status" = pass ] || add_blocker ssh_shell_smf_and_exec
[ "$formal_lean_proofs_status" = pass ] || add_blocker formal_lean_proofs
[ "$formal_riscv_dual_track_status" = pass ] || add_blocker formal_riscv_dual_track
[ "$formal_critical_concurrency_status" = pass ] || add_blocker formal_critical_concurrency
[ "$formal_memory_safety_status" = pass ] || add_blocker formal_memory_safety
[ "$formal_storage_integrity_status" = pass ] || add_blocker formal_storage_integrity
[ "$formal_boundary_integrity_status" = pass ] || add_blocker formal_boundary_integrity
[ "$formal_process_resource_lifecycle_status" = pass ] || add_blocker formal_process_resource_lifecycle
[ "$formal_coroutine_resource_bounds_status" = pass ] || add_blocker formal_coroutine_resource_bounds
[ "$formal_compiler_language_status" = pass ] || add_blocker formal_compiler_language
[ "$formal_ui_policy_status" = pass ] || add_blocker formal_ui_policy
[ "$formal_coverage_status" = pass ] || add_blocker formal_coverage
[ "$byl_sby_artifact_audit_status" = pass ] || add_blocker byl_sby_artifact_audit
[ "$async_library_hardening_status" = pass ] || add_blocker async_library_hardening
[ "$shared_wm_status" = pass ] || add_blocker shared_wm_logic
[ "$cpu_simd_status" = pass ] || add_blocker cpu_simd_engine2d_diagram
[ "$llvm_port_status" = pass ] || add_blocker llvm_port
[ "$gui_renderdoc_vulkan_status" = pass ] || add_blocker gui_renderdoc_vulkan
[ "$web_renderer_engine2d_status" = pass ] || add_blocker web_renderer_engine2d_bitmap
[ "$simple_gui_webrenderer_status" = pass ] || add_blocker simple_gui_webrenderer_bitmap
[ "$qemu_host_counterpart_status" = pass ] || add_blocker qemu_host_counterpart_bitmap
[ "$qemu_gui_smf_artifact_status" = pass ] || add_blocker qemu_gui_smf_artifact_contract
[ "$qemu_mdi_status" = pass ] || add_blocker qemu_wm_simple_gui_mdi
[ "$rv64_display_smoke_qmp_status" = pass ] || add_blocker rv64_display_smoke_qmp
[ "$qemu_virtio_gpu_access_status" = pass ] || add_blocker qemu_virtio_gpu_access
case "$riscv_rtl_sby_proof_status" in
    blocked*) add_blocker riscv_rtl_sby_proof ;;
esac
[ "$stale_report_count" -eq 0 ] || add_blocker stale_static_reports

recovery_hints="ssh=test/03_system/os/ssh_live_login_in_qemu_spec.spl;web=test/03_system/gui/layered_simple_gui_web_engine2d_bitmap_evidence_spec.spl;mdi=test/03_system/gui/gui_entry_engine2d_wm_simple_web_spec.spl"

status=fail
reason=matrix-incomplete
if [ "$passed_count" -eq "$MATRIX_ROW_COUNT" ]; then
    if [ "$qemu_guest_perf_gate_status" = pass ]; then
        status=pass
        reason=pass
    else
        status=blocked
        reason=qemu-guest-perf-release-gate-blocked
    fi
fi
if [ "$status" = pass ] && [ "$stale_report_count" -gt 0 ]; then
    status=blocked
    reason=stale-static-reports
fi

mission_critical_release_status=pass
mission_critical_release_blockers=none
add_mission_blocker() {
    if [ "$mission_critical_release_blockers" = none ]; then
        mission_critical_release_blockers="$1"
    else
        mission_critical_release_blockers="$mission_critical_release_blockers,$1"
    fi
    mission_critical_release_status=blocked
}

[ "$status" = pass ] || add_mission_blocker hardening_matrix
[ "$riscv_rtl_sby_proof_status" = pass ] || add_mission_blocker riscv_rtl_sby_proof
[ "$qemu_scheduler_smp_handoff_status" = pass ] || add_mission_blocker qemu_scheduler_smp_handoff
[ "$qemu_scheduler_hw_handoff_status" = pass ] || add_mission_blocker qemu_scheduler_hw_handoff
[ "$mission_critical_prereqs_status" = ready ] || add_mission_blocker mission_critical_prereqs
[ "$nvme_baremetal_wrapper_coverage_status" = pass ] || add_mission_blocker nvme_baremetal_wrapper_coverage
[ "$async_library_hardening_status" = pass ] || add_mission_blocker async_library_hardening
if [ "$status" = fail ] || [ "$riscv_rtl_sby_proof_status" = fail ] || [ "$qemu_scheduler_smp_handoff_status" = fail ] || [ "$qemu_scheduler_hw_handoff_status" = fail ] || [ "$nvme_baremetal_wrapper_coverage_status" = fail ] || [ "$async_library_hardening_status" = fail ]; then
    mission_critical_release_status=fail
fi

{
    echo "# SimpleOS Hardening Evidence Matrix"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- mission_critical_release_status: $mission_critical_release_status"
    echo "- mission_critical_release_blockers: $mission_critical_release_blockers"
    echo "- stale_reports: $stale_reports"
    echo "- stale_report_names: $stale_report_names"
    echo "- mission_critical_release_gate: scripts/check/check-simpleos-mission-critical-release.shs"
    echo "- mission_critical_release_prereq_gate: scripts/check/check-simpleos-mission-critical-prereqs.shs"
    echo "- mission_critical_prereqs_status: $mission_critical_prereqs_status"
    echo "- mission_critical_prereqs_missing: $mission_critical_prereqs_missing"
    echo "- mission_critical_prereqs_next_action: $mission_critical_prereqs_next_action"
    echo "- nvme_baremetal_wrapper_coverage: $nvme_baremetal_wrapper_coverage_status"
    echo "- nvme_baremetal_wrapper_coverage_log: $nvme_baremetal_wrapper_coverage_log"
    echo "- nvme_baremetal_wrapper_coverage_blockers: $nvme_baremetal_wrapper_coverage_blockers"
    echo "- nvme_baremetal_wrapper_rv32_self_test: $nvme_baremetal_wrapper_rv32_self_test"
    echo "- nvme_baremetal_wrapper_rv32_spec_status: $nvme_baremetal_wrapper_rv32_spec_status"
    echo "- nvme_baremetal_wrapper_rv64_self_test: $nvme_baremetal_wrapper_rv64_self_test"
    echo "- nvme_baremetal_wrapper_rv64_spec_status: $nvme_baremetal_wrapper_rv64_spec_status"
    echo "- nvme_baremetal_wrapper_coverage_next_action: $nvme_baremetal_wrapper_coverage_next_action"
    echo "- async_library_hardening: $async_library_hardening_status"
    echo "- async_library_hardening_log: $async_library_hardening_log"
    echo "- async_library_hardening_gate: $async_library_hardening_gate"
    echo "- async_library_hardening_scope: $async_library_hardening_scope"
    echo "- async_library_hardening_evidence: $async_library_hardening_evidence"
    echo "- async_library_hardening_total: $async_library_hardening_total"
    echo "- async_library_hardening_passed: $async_library_hardening_passed"
    echo "- async_library_hardening_failed: $async_library_hardening_failed"
    echo "- async_library_hardening_missing: $async_library_hardening_missing"
    echo "- passed: $passed_count/$MATRIX_ROW_COUNT"
    if [ -n "$blocked_rows" ]; then
        echo "- blocked_rows: $blocked_rows"
    else
        echo "- blocked_rows:"
    fi
    echo "- recovery_hints: $recovery_hints"
    echo "- executable_launch_from_fs: $exec_launch_fs_status"
    echo "- ssh_shell_smf_and_exec: $ssh_smf_exec_status"
    echo "- formal_lean_proofs: $formal_lean_proofs_status"
    echo "- formal_lean_proofs_log: $formal_lean_proofs_log"
    echo "- formal_riscv_dual_track: $formal_riscv_dual_track_status"
    echo "- formal_riscv_dual_track_log: $formal_riscv_dual_track_log"
    echo "- formal_critical_concurrency: $formal_critical_concurrency_status"
    echo "- formal_critical_concurrency_log: $formal_critical_concurrency_log"
    echo "- formal_critical_concurrency_gate: $formal_critical_concurrency_gate"
    echo "- formal_critical_concurrency_scope: $formal_critical_concurrency_scope"
    echo "- formal_critical_concurrency_evidence: $formal_critical_concurrency_evidence"
    echo "- formal_memory_safety: $formal_memory_safety_status"
    echo "- formal_memory_safety_log: $formal_memory_safety_log"
    echo "- formal_memory_safety_gate: $formal_memory_safety_gate"
