    prereq_out="$mission_critical_prereqs_override_log"
elif sh "$ROOT_DIR/scripts/check/check-simpleos-mission-critical-prereqs.shs" >"$prereq_out" 2>&1; then
    :
fi
mission_critical_prereqs_status="$(sed -n 's/^simpleos_mission_critical_prereqs_status=//p' "$prereq_out" | tail -n 1)"
mission_critical_prereqs_missing="$(sed -n 's/^simpleos_mission_critical_prereqs_missing=//p' "$prereq_out" | tail -n 1)"
mission_critical_prereqs_next_action="$(sed -n 's/^simpleos_mission_critical_prereqs_next_action=//p' "$prereq_out" | tail -n 1)"
mission_critical_prereqs_status="${mission_critical_prereqs_status:-unknown}"
mission_critical_prereqs_missing="${mission_critical_prereqs_missing:-unknown}"
mission_critical_prereqs_next_action="${mission_critical_prereqs_next_action:-unknown}"
if [ "$mission_critical_prereqs_status" = ready ] \
    && { [ "$mission_critical_prereqs_missing" != none ] \
