nvme_baremetal_wrapper_coverage_next_action="$(sed -n 's/^nvme_baremetal_wrapper_coverage_next_action=//p' "$nvme_baremetal_wrapper_coverage_log" | tail -n 1)"
nvme_baremetal_wrapper_coverage_status="${nvme_baremetal_wrapper_coverage_status:-fail}"
