#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/simpleos_hardening_evidence_matrix}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/simpleos_hardening_evidence_matrix_$(date -u +%F).md}"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
OLD_REPORT="$BUILD_DIR/previous_matrix_rows.md"
if [ -f "$REPORT_PATH" ]; then
    cp "$REPORT_PATH" "$OLD_REPORT"
else
    : >"$OLD_REPORT"
fi
rm -f "$REPORT_PATH"

SSH_SMF="build/os/x64-ssh-live.session-smf.txt"
SSH_EXEC="build/os/x64-ssh-live.session-exec.txt"
SSH_SERIAL="build/os/x64-ssh-live.serial.log"
SHARED_WM_REPORT="${SHARED_WM_REPORT:-doc/09_report/shared_wm_renderer_unification_evidence_2026-07-05.md}"
CPU_SIMD_REPORT="${CPU_SIMD_REPORT:-doc/09_report/cpu_simd_engine2d_evidence_current_2026-07-02.md}"
LLVM_PORT_REPORT="${LLVM_PORT_REPORT:-doc/09_report/simpleos_llvm_port_evidence_current_2026-07-02.md}"
GUI_RENDERDOC_REPORT="${GUI_RENDERDOC_REPORT:-doc/09_report/gui_renderdoc_feature_coverage_status_2026-07-03.md}"
LAYERED_REPORT="${LAYERED_REPORT:-doc/09_report/layered_simple_gui_web_engine2d_bitmap_evidence_2026-07-05.md}"
if [ -z "${PRODUCTION_GUI_PARITY_REPORT:-}" ]; then
    PRODUCTION_GUI_PARITY_REPORT="$(find doc/09_report -maxdepth 1 -name 'production_gui_web_renderer_parity_evidence_*.md' 2>/dev/null | sort | tail -n 1)"
    if [ -z "$PRODUCTION_GUI_PARITY_REPORT" ]; then
        PRODUCTION_GUI_PARITY_REPORT="doc/09_report/production_gui_web_renderer_parity_evidence_$(date -u +%F).md"
    fi
fi
SIMPLE_WEB_NODE_REPORT="${SIMPLE_WEB_NODE_REPORT:-doc/09_report/simple_web_engine2d_js_bitmap_evidence_2026-07-03.md}"
SIMPLE_WEB_BUN_REPORT="${SIMPLE_WEB_BUN_REPORT:-doc/09_report/bun_simple_web_engine2d_js_bitmap_evidence_2026-07-05.md}"
SIMPLE_WEB_NODE_ENV="build/simple_web_engine2d_js_bitmap_evidence_current/evidence.env"
SIMPLE_WEB_BUN_ENV="build/bun_simple_web_engine2d_js_bitmap_evidence_current/evidence.env"
QEMU_GTK_REPORT="${QEMU_GTK_REPORT:-doc/09_report/qemu_gtk_wm_capture_evidence_2026-07-05.md}"
RV64_DISPLAY_SMOKE_REPORT="${RV64_DISPLAY_SMOKE_REPORT:-doc/09_report/rv64_display_smoke_qmp_evidence_$(date -u +%F).md}"
# G4: the dated *_REPORT files above are trusted via plain `contains` string
# checks, so a stale-but-still-worded-right report would keep its row green
# forever. Age is derived from the YYYY-MM-DD embedded in the report filename
# rather than mtime: these are checked-in static reports, and a fresh
# checkout/rebase resets mtime to checkout time, which would silently hide real
# staleness.
report_age_days() {
    report_file="$1"
    report_date="$(basename -- "$report_file" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' | tail -n 1)"
    report_epoch=""
    [ -n "$report_date" ] && report_epoch="$(date -u -d "$report_date" +%s 2>/dev/null)"
    if [ -z "$report_epoch" ]; then
        echo -1
    else
        echo $(( ($(date -u +%s) - report_epoch) / 86400 ))
    fi
}
STALE_REPORT_AGE_DAYS_MAX=30
stale_report_count=0
stale_report_names=none
for report_file in "$SHARED_WM_REPORT" "$CPU_SIMD_REPORT" "$LLVM_PORT_REPORT" \
    "$GUI_RENDERDOC_REPORT" "$LAYERED_REPORT" "$PRODUCTION_GUI_PARITY_REPORT" \
    "$SIMPLE_WEB_NODE_REPORT" "$SIMPLE_WEB_BUN_REPORT" "$QEMU_GTK_REPORT" \
    "$RV64_DISPLAY_SMOKE_REPORT"; do
    report_age_days_val="$(report_age_days "$report_file")"
    report_name="$(basename -- "$report_file")"
    echo "simpleos_hardening_report_age=${report_name}:${report_age_days_val}d"
    if [ "$report_age_days_val" -ge "$STALE_REPORT_AGE_DAYS_MAX" ] 2>/dev/null; then
        stale_report_count=$((stale_report_count + 1))
        if [ "$stale_report_names" = none ]; then
            stale_report_names="$report_name"
        else
            stale_report_names="$stale_report_names,$report_name"
        fi
    fi
done
if [ "$stale_report_count" -eq 0 ]; then
    stale_reports=none
else
    stale_reports="$stale_report_count"
fi
echo "simpleos_hardening_stale_reports=$stale_reports"
echo "simpleos_hardening_stale_report_names=$stale_report_names"

GUI_ENTRY_SPEC="${GUI_ENTRY_SPEC:-test/03_system/gui/gui_entry_engine2d_wm_simple_web_spec.spl}"
GUI_ENTRY_DOC="${GUI_ENTRY_DOC:-doc/06_spec/03_system/gui/gui_entry_engine2d_wm_simple_web_spec.md}"
if [ ! -f "$GUI_ENTRY_DOC" ] && [ -f "doc/06_spec/system/gui_entry_engine2d_wm_simple_web_spec.md" ]; then
    GUI_ENTRY_DOC="doc/06_spec/system/gui_entry_engine2d_wm_simple_web_spec.md"
fi
MATRIX_ROW_COUNT=26
HOST_GPU_2D_REPORT="${SIMPLEOS_HOST_GPU_2D_REPORT:-$BUILD_DIR/simpleos_qemu_host_gpu_2d.env}"
host_gpu_2d_status=not-run
host_gpu_2d_reason=live-gate-not-requested
load_host_gpu_2d_report() {
    validation="$(sh scripts/check/check-simpleos-qemu-host-gpu-2d.shs --validate-report "$HOST_GPU_2D_REPORT" 2>/dev/null)" || {
        host_gpu_2d_status=fail
        host_gpu_2d_reason=malformed-wrapper-report
        return
    }
    host_gpu_2d_status="$(printf '%s\n' "$validation" | sed -n 's/^simpleos_qemu_host_gpu_2d_report_status=//p')"
    host_gpu_2d_reason="$(printf '%s\n' "$validation" | sed -n 's/^simpleos_qemu_host_gpu_2d_report_reason=//p')"
}
if [ "${SIMPLEOS_HOST_GPU_2D_LIVE:-0}" = 1 ]; then
    sh scripts/check/check-simpleos-qemu-host-gpu-2d.shs >"$HOST_GPU_2D_REPORT" 2>&1 || true
    load_host_gpu_2d_report
elif [ -f "$HOST_GPU_2D_REPORT" ]; then
    load_host_gpu_2d_report
fi

contains() {
    file="$1"
    text="$2"
    [ -f "$file" ] && grep -Fq -- "$text" "$file"
}

