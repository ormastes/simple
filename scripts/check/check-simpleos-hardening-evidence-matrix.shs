append_preserved_rows() {
    [ -s "$OLD_REPORT" ] || return 0
    awk -v keys="$OWNED_MATRIX_KEYS" '
        BEGIN {
            split(keys, a, /[[:space:]]+/)
            for (i in a) {
                if (a[i] != "") owned[a[i]] = 1
            }
        }
        /^- [A-Za-z0-9_]+:/ {
            key = $2
            sub(/:$/, "", key)
            if (!(key in owned)) print
        }
    ' "$OLD_REPORT"
}

latest_gui_dir() {
    find build/tmp -maxdepth 1 -type d -name 'gui_entry_engine2d_wm_simple_web_spec_*' -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -1 | cut -d' ' -f2-
}

file_size() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

resolve_simple_bin() {
    if [ -n "${SIMPLE_BIN:-}" ]; then
        echo "$SIMPLE_BIN"
        return 0
    fi
    for candidate in bin/simple ./bin/simple bin/release/*/simple release/*/simple build/bootstrap/stage3/simple; do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done
    echo "bin/simple"
}

pass_fail() {
    if "$@"; then
        echo pass
    else
        echo fail
    fi
}

sspec_summary_status() {
    summary_log="$1"
    summary_passed="$(grep -h -E 'Passed: [0-9]+' "$summary_log" 2>/dev/null | tail -n 1 | sed -E 's/^.*Passed: ([0-9]+).*$/\1/')"
    summary_failed="$(grep -h -E 'Failed: [0-9]+' "$summary_log" 2>/dev/null | tail -n 1 | sed -E 's/^.*Failed: ([0-9]+).*$/\1/')"
    if [ -n "$summary_passed" ] \
        && [ -n "$summary_failed" ] \
        && [ "$summary_failed" -eq 0 ] \
        && [ "$summary_passed" -gt 0 ]; then
        echo pass
    else
        echo fail
    fi
}

