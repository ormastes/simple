    riscv_rtl_sby_proof_blocker=none
elif grep -Fq "reason=sidecar-contract-failed" "$riscv_rtl_sby_proof_log"; then
    riscv_rtl_sby_proof_status=fail
    riscv_rtl_sby_proof_blocker=sidecar-contract-failed
elif grep -Fq "reason=missing-artifact" "$riscv_rtl_sby_proof_log"; then
    riscv_rtl_sby_proof_status=fail
    riscv_rtl_sby_proof_blocker=missing-artifact
elif grep -Fq "reason=empty-artifact" "$riscv_rtl_sby_proof_log"; then
    riscv_rtl_sby_proof_status=fail
    riscv_rtl_sby_proof_blocker=empty-artifact
elif grep -Fq "reason=invalid-artifact" "$riscv_rtl_sby_proof_log"; then
    riscv_rtl_sby_proof_status=fail
    riscv_rtl_sby_proof_blocker=invalid-artifact
elif grep -Fq "reason=missing-formal-prereqs" "$riscv_rtl_sby_proof_log"; then
    riscv_rtl_sby_proof_status=blocked-missing-formal-prereqs
    riscv_rtl_sby_proof_blocker="$(sed -n 's/.* missing=//p' "$riscv_rtl_sby_proof_log" | tail -n 1)"
elif grep -Fq "reason=sby-run-failed" "$riscv_rtl_sby_proof_log"; then
    riscv_rtl_sby_proof_status=fail
    riscv_rtl_sby_proof_blocker=sby-run-failed
else
    riscv_rtl_sby_proof_status=fail
    riscv_rtl_sby_proof_blocker=rtl-proof-unclassified-failure
fi

# G2: run both opt-in QEMU lanes for real. Do not trust process exit code alone
# (see riscv_rtl_sby_proof / async hardening evidence checkers for the same
# lesson); re-derive pass/fail from the printed "Passed: N" / "Failed: N"
# summary instead.
SIMPLE_BIN="$(resolve_simple_bin)"
if command -v qemu-system-x86_64 >/dev/null 2>&1; then
    set +e
    SIMPLEOS_GREEN_CARRIER_QEMU_LIVE=1 "$SIMPLE_BIN" test "$qemu_scheduler_smp_handoff_gate" --mode=interpreter --clean --timeout 240 --sequential >"$qemu_scheduler_smp_handoff_log" 2>&1
    set -e
    qemu_scheduler_smp_handoff_status="$(sspec_summary_status "$qemu_scheduler_smp_handoff_log")"

    set +e
    SIMPLEOS_GREEN_CARRIER_QEMU_HW_HANDOFF_LIVE=1 "$SIMPLE_BIN" test "$qemu_scheduler_hw_handoff_gate" --mode=interpreter --clean --timeout 240 --sequential >"$qemu_scheduler_hw_handoff_log" 2>&1
    set -e
    qemu_scheduler_hw_handoff_status="$(sspec_summary_status "$qemu_scheduler_hw_handoff_log")"
else
    echo "qemu-system-x86_64 missing; live QEMU scheduler/AP handoff evidence not executed" >"$qemu_scheduler_smp_handoff_log"
    echo "qemu-system-x86_64 missing; live QEMU final hardware handoff evidence not executed" >"$qemu_scheduler_hw_handoff_log"
fi

prereq_out="$BUILD_DIR/mission_critical_prereqs.out"
