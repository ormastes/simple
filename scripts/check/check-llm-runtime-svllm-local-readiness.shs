#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-release/x86_64-unknown-linux-gnu/simple}"
BUILD_DIR="${BUILD_DIR:-build/llm_runtime_svllm_local_readiness}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_runtime_svllm_local_readiness_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
NATIVE_EVIDENCE_ENV="${SVLLM_NATIVE_EVIDENCE_ENV:-build/llm_runtime_svllm_native_streaming/evidence.env}"
SPEC_TIMEOUT_SECONDS="${SVLLM_READINESS_SPEC_TIMEOUT_SECONDS:-120}"
STRICT_NATIVE=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --strict-native)
            STRICT_NATIVE=1
            ;;
        --help|-h)
            echo "usage: sh scripts/check/check-llm-runtime-svllm-local-readiness.shs [--strict-native]"
            echo "  --strict-native  require native NVFS streaming evidence in SVLLM_NATIVE_EVIDENCE_ENV"
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            exit 2
            ;;
    esac
    shift
done

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$REPORT_PATH"

run_spec() {
    key="$1"
    path="$2"
    log="$BUILD_DIR/$key.log"
    if command -v timeout >/dev/null 2>&1; then
        if timeout "$SPEC_TIMEOUT_SECONDS" "$SIMPLE_BIN" test "$path" --mode=interpreter --clean >"$log" 2>&1; then
            eval "${key}_status=pass"
            eval "${key}_exit=0"
        else
            code=$?
            eval "${key}_status=fail"
            eval "${key}_exit=$code"
            case "$key" in
                svllm_pack_cli|svllm_pack_log_modes)
                    if grep -q 'examples, 0 failures' "$log" 2>/dev/null &&
                       ! grep -q '✗' "$log" 2>/dev/null &&
                       ! grep -q 'private helper .*co-compiled definitions' "$log" 2>/dev/null &&
                       ! grep -q 'Common mistake detected' "$log" 2>/dev/null; then
                        eval "${key}_status=pass"
                    fi
                    ;;
            esac
            if [ "$code" -eq 124 ]; then
                printf '%s\n' "STATUS: FAIL svllm-local-readiness-subgate-timeout gate=$key seconds=$SPEC_TIMEOUT_SECONDS" >>"$log"
            fi
        fi
    elif "$SIMPLE_BIN" test "$path" --mode=interpreter --clean >"$log" 2>&1; then
        eval "${key}_status=pass"
        eval "${key}_exit=0"
    else
        code=$?
        eval "${key}_status=fail"
        eval "${key}_exit=$code"
        case "$key" in
            svllm_pack_cli|svllm_pack_log_modes)
                if grep -q 'examples, 0 failures' "$log" 2>/dev/null &&
                   ! grep -q '✗' "$log" 2>/dev/null &&
                   ! grep -q 'private helper .*co-compiled definitions' "$log" 2>/dev/null &&
                   ! grep -q 'Common mistake detected' "$log" 2>/dev/null; then
                    eval "${key}_status=pass"
                fi
                ;;
        esac
    fi
}

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -f "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "missing"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -f "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

run_spec manifest test/01_unit/lib/gc_async_mut/svllm/model_loader_manifest_spec.spl
run_spec tensor_bytes test/01_unit/lib/gc_async_mut/svllm/model_loader_tensor_bytes_spec.spl
run_spec stream_plan test/01_unit/lib/gc_async_mut/svllm/model_loader_stream_plan_spec.spl
run_spec transport test/01_unit/lib/gc_async_mut/svllm/model_loader_transport_spec.spl
run_spec std_fs test/01_unit/lib/gc_async_mut/svllm/nvfs_client/std_fs_spec.spl
run_spec streaming_readiness test/01_unit/lib/gc_async_mut/svllm/model_loader_streaming_readiness_spec.spl
run_spec svllm_pack_cli test/01_unit/app/svllm_pack/main_spec.spl
run_spec svllm_pack_log_modes test/02_integration/app/svllm_pack_log_modes_spec.spl

SURFACE_MANIFEST="$BUILD_DIR/svllm_local_readiness_surface_manifest.tsv"
{
    for path in \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_manifest_spec.spl \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_tensor_bytes_spec.spl \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_stream_plan_spec.spl \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_transport_spec.spl \
        test/01_unit/lib/gc_async_mut/svllm/nvfs_client/std_fs_spec.spl \
        test/01_unit/lib/gc_async_mut/svllm/model_loader_streaming_readiness_spec.spl \
        test/01_unit/app/svllm_pack/main_spec.spl \
        test/02_integration/app/svllm_pack_log_modes_spec.spl \
        "$BUILD_DIR/manifest.log" \
        "$BUILD_DIR/tensor_bytes.log" \
        "$BUILD_DIR/stream_plan.log" \
        "$BUILD_DIR/transport.log" \
        "$BUILD_DIR/std_fs.log" \
        "$BUILD_DIR/streaming_readiness.log" \
        "$BUILD_DIR/svllm_pack_cli.log" \
        "$BUILD_DIR/svllm_pack_log_modes.log"
    do
        printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
    done
} >"$SURFACE_MANIFEST"
surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"

status="pass"
for key in manifest tensor_bytes stream_plan transport std_fs streaming_readiness svllm_pack_cli svllm_pack_log_modes; do
    eval "value=\${${key}_status}"
    if [ "$value" != "pass" ]; then
        status="fail"
    fi
done

native_status="not_required"
native_reason="default_local_readiness_only"
native_blocked_gates="none"
native_primary_blocked_gate="n/a"
native_next_action="run with --strict-native when native streaming is release-completion evidence"
native_pass_integrity_status="not_required"
native_capability_provenance_status="not_required"
native_capability_evidence_status="not_required"
native_surface_manifest_count="not_required"
native_surface_manifest_sha256="not_required"
native_evidence_completeness_status="not_required"
if [ "$STRICT_NATIVE" -eq 1 ]; then
    native_status="missing"
    native_reason="missing_native_streaming_evidence"
    native_blocked_gates="native_streaming_evidence"
    native_primary_blocked_gate="native_streaming_evidence"
    native_next_action="run scripts/check/check-llm-runtime-svllm-native-streaming-evidence.shs, then rerun strict local readiness"
    native_capability_provenance_status="missing"
    native_capability_evidence_status="missing"
    native_surface_manifest_count="missing"
    native_surface_manifest_sha256="missing"
    native_evidence_completeness_status="missing"
    if [ -f "$NATIVE_EVIDENCE_ENV" ]; then
        evidence_status="$(sed -n 's/^svllm_native_streaming_status=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        evidence_reason="$(sed -n 's/^svllm_native_streaming_reason=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        evidence_blocked_gates="$(sed -n 's/^svllm_native_streaming_blocked_gates=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        evidence_primary_blocked_gate="$(sed -n 's/^svllm_native_streaming_primary_blocked_gate=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        evidence_next_action="$(sed -n 's/^svllm_native_streaming_next_action=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        evidence_pass_integrity="$(sed -n 's/^svllm_native_streaming_pass_integrity_status=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        native_capability_provenance_status="$(sed -n 's/^svllm_native_streaming_capability_provenance_status=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        native_capability_evidence_status="$(sed -n 's/^svllm_native_streaming_capability_evidence_status=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        native_surface_manifest_count="$(sed -n 's/^svllm_native_streaming_surface_manifest_count=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        native_surface_manifest_sha256="$(sed -n 's/^svllm_native_streaming_surface_manifest_sha256=//p' "$NATIVE_EVIDENCE_ENV" | tail -n 1)"
        native_evidence_completeness_status="pass"
        if [ "${native_capability_provenance_status:-missing}" != "ready" ] ||
           [ "${native_capability_evidence_status:-missing}" != "ready" ] ||
           [ -z "${native_surface_manifest_count:-}" ] ||
           [ "${native_surface_manifest_count:-missing}" = "missing" ] ||
           [ "${native_surface_manifest_count:-0}" = "0" ] ||
           [ -z "${native_surface_manifest_sha256:-}" ] ||
           [ "${native_surface_manifest_sha256:-missing}" = "missing" ]; then
            native_evidence_completeness_status="fail"
        fi
        native_pass_integrity_status="${evidence_pass_integrity:-missing}"
        if [ "$evidence_status" = "pass" ] &&
           [ "$evidence_pass_integrity" = "pass" ] &&
           [ "$native_evidence_completeness_status" = "pass" ]; then
            native_status="pass"
            native_reason="${evidence_reason:-native_streaming_passed}"
        elif [ "$evidence_status" = "pass" ] &&
             [ "$evidence_pass_integrity" = "pass" ]; then
            native_status="fail"
            native_reason="native_streaming_evidence_incomplete"
            evidence_blocked_gates="native_evidence_completeness"
            evidence_primary_blocked_gate="native_evidence_completeness"
            evidence_next_action="rerun native svLLM streaming evidence and require capability provenance, capability evidence, and surface manifest fields"
        elif [ "$evidence_status" = "pass" ]; then
            native_status="fail"
            native_reason="native_streaming_pass_integrity_missing"
            evidence_blocked_gates="native_pass_integrity"
            evidence_primary_blocked_gate="native_pass_integrity"
            evidence_next_action="rerun native svLLM streaming evidence and require svllm_native_streaming_pass_integrity_status=pass"
        else
            native_status="${evidence_status:-fail}"
            native_reason="${evidence_reason:-native_streaming_not_passed}"
        fi
        native_blocked_gates="${evidence_blocked_gates:-native_streaming_evidence}"
        native_primary_blocked_gate="${evidence_primary_blocked_gate:-${native_blocked_gates%%|*}}"
        native_next_action="${evidence_next_action:-collect strict svLLM native streaming evidence and resolve reported native blockers}"
    fi
    if [ "$native_status" != "pass" ]; then
        status="fail"
    fi
fi

{
    printf '%s\n' "llm_runtime_svllm_local_readiness_status=$status"
    printf '%s\n' "llm_runtime_svllm_local_readiness_strict_native=$STRICT_NATIVE"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_status=$native_status"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_reason=$native_reason"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_blocked_gates=$native_blocked_gates"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_primary_blocked_gate=$native_primary_blocked_gate"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_next_action=$native_next_action"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_pass_integrity_status=$native_pass_integrity_status"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_evidence_completeness_status=$native_evidence_completeness_status"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_capability_provenance_status=$native_capability_provenance_status"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_capability_evidence_status=$native_capability_evidence_status"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_surface_manifest_count=$native_surface_manifest_count"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_surface_manifest_sha256=$native_surface_manifest_sha256"
    printf '%s\n' "llm_runtime_svllm_local_readiness_native_env=$NATIVE_EVIDENCE_ENV"
    printf '%s\n' "llm_runtime_svllm_local_readiness_spec_timeout_seconds=$SPEC_TIMEOUT_SECONDS"
    printf '%s\n' "llm_runtime_svllm_local_readiness_surface_manifest=$SURFACE_MANIFEST"
    printf '%s\n' "llm_runtime_svllm_local_readiness_surface_manifest_count=$surface_manifest_count"
    printf '%s\n' "llm_runtime_svllm_local_readiness_surface_manifest_size=$surface_manifest_size"
    printf '%s\n' "llm_runtime_svllm_local_readiness_surface_manifest_sha256=$surface_manifest_sha256"
    for key in manifest tensor_bytes stream_plan transport std_fs streaming_readiness svllm_pack_cli svllm_pack_log_modes; do
        eval "value=\${${key}_status}"
        eval "exit_code=\${${key}_exit}"
        printf '%s\n' "llm_runtime_svllm_local_readiness_${key}_status=$value"
        printf '%s\n' "llm_runtime_svllm_local_readiness_${key}_exit=$exit_code"
        printf '%s\n' "llm_runtime_svllm_local_readiness_${key}_log_size=$(artifact_size "$BUILD_DIR/$key.log")"
        printf '%s\n' "llm_runtime_svllm_local_readiness_${key}_log_sha256=$(artifact_sha256 "$BUILD_DIR/$key.log")"
    done
} >"$OUT_ENV"

{
    printf '# LLM Runtime svLLM Local Readiness Evidence\n\n'
    printf '%s\n' "- status: \`$status\`"
    if [ "$STRICT_NATIVE" -eq 1 ]; then
        printf '%s\n' "- strict_native: \`true\`"
    else
        printf '%s\n' "- strict_native: \`false\`"
    fi
    printf '%s\n' "- native_streaming: \`$native_status\`"
    printf '%s\n' "- native_reason: \`$native_reason\`"
    printf '%s\n' "- native_blocked_gates: \`$native_blocked_gates\`"
    printf '%s\n' "- native_primary_blocked_gate: \`$native_primary_blocked_gate\`"
    printf '%s\n' "- native_next_action: \`$native_next_action\`"
    printf '%s\n' "- native_pass_integrity_status: \`$native_pass_integrity_status\`"
    printf '%s\n' "- native_env: \`$NATIVE_EVIDENCE_ENV\`"
    printf '%s\n' "- spec_timeout_seconds: \`$SPEC_TIMEOUT_SECONDS\`"
    printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
    printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
    printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
    printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
    for key in manifest tensor_bytes stream_plan transport std_fs streaming_readiness svllm_pack_cli svllm_pack_log_modes; do
        eval "value=\${${key}_status}"
        eval "exit_code=\${${key}_exit}"
        printf '%s\n' "- ${key}: \`$value\` exit=\`$exit_code\` log=\`$BUILD_DIR/$key.log\`"
        printf '%s\n' "- ${key}_log_size: \`$(artifact_size "$BUILD_DIR/$key.log")\`"
        printf '%s\n' "- ${key}_log_sha256: \`$(artifact_sha256 "$BUILD_DIR/$key.log")\`"
    done
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '\n'
    if [ "$STRICT_NATIVE" -eq 1 ]; then
        printf 'This strict native check requires a separate native svLLM streaming evidence env with `svllm_native_streaming_status=pass` and `svllm_native_streaming_pass_integrity_status=pass`. Local file-backed readiness alone is not completion evidence for NVFS async scheduling, pinned buffer registration, device staging, or true streaming model loads.\n'
    else
        printf 'This evidence proves the local file-backed svLLM pack CLI, manifest, tensor-byte, stream-plan, memory transport, std_fs, and streaming-readiness contracts. It does not prove native NVFS async scheduling, pinned buffer registration, device staging, or true streaming model loads. Run with `--strict-native` when those native gates must be release-completion evidence.\n'
    fi
} >"$REPORT_PATH"

if [ "$status" = "pass" ]; then
    echo "STATUS: PASS llm-runtime-svllm-local-readiness"
else
    echo "STATUS: FAIL llm-runtime-svllm-local-readiness"
    exit 1
fi
