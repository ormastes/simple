    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_gate_status" "$gpu_capture_gate_status"
    render_log_append_kv "macos_metal_render_log_compare_required_api" "metal"
    render_log_append_kv "macos_metal_render_log_compare_simple_log" "$SIMPLE_LOG"
    render_log_append_kv "macos_metal_render_log_compare_chrome_log" "$CHROME_LOG"
    render_log_append_kv "macos_metal_render_log_compare_electron_log" "$ELECTRON_LOG"
    render_log_append_kv "macos_metal_render_log_compare_tauri_ios_log" "$TAURI_IOS_LOG"
    render_log_append_kv "macos_metal_render_log_compare_compare_log" "$COMPARE_LOG"
    render_log_append_kv "macos_metal_render_log_compare_pairwise_status" "$pixel_gate_status"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_status" "${capture_status:-unavailable}"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_tool" "$gpu_capture_tool"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_tool_reason" "$capture_tool_reason"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact" "$capture_artifact"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_resolved" "$capture_artifact_resolved"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_file_status" "$capture_artifact_file_status"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_file_reason" "$capture_artifact_file_reason"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_status" "$capture_artifact_artifact_status"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_magic" "$capture_artifact_magic"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_claimed_magic" "$capture_artifact_claimed_magic"
    render_log_append_kv "macos_metal_render_log_compare_gpu_capture_artifact_claimed_magic_reason" "$capture_artifact_claimed_magic_reason"
    render_log_append_kv "macos_metal_render_log_compare_require_gpu_capture" "${MACOS_METAL_RENDER_LOG_REQUIRE_GPU_CAPTURE:-0}"
    render_log_append_kv "macos_metal_render_log_compare_require_tauri_ios" "${MACOS_METAL_RENDER_LOG_REQUIRE_TAURI_IOS:-0}"
} >"$OUT_ENV"

{
    echo "# macOS Metal Render Log Compare"
    echo
    echo "- status: $compare_status"
    echo "- reason: $reason_parts"
    echo "- simple log: $SIMPLE_LOG"
    echo "- chrome log: $CHROME_LOG"
    echo "- electron log: $ELECTRON_LOG"
    echo "- gate summary: generated=$metal_generated_gate_status framebuffer=$metal_framebuffer_gate_status browser=$browser_backing_gate_status pairwise=$pixel_gate_status argb=$argb_source_gate_status gpu_capture=$gpu_capture_gate_status"
    echo "- blocked gates: $blocked_gate_count / $blocked_gates"
    echo "- Electron Metal backing: $electron_backing detail=$electron_backing_detail_reason source=$electron_backing_source_reason artifact=$electron_backing_source_file_status/$electron_backing_source_artifact_status gpu=$electron_backing_gpu_compositing display=$electron_backing_display_type skia=$electron_backing_skia_backend_type"
    echo "- Chrome Metal backing: $chrome_backing detail=$chrome_backing_detail_reason source=$chrome_backing_source_reason artifact=$chrome_backing_source_file_status/$chrome_backing_source_artifact_status gpu=$chrome_backing_gpu_compositing display=$chrome_backing_display_type skia=$chrome_backing_skia_backend_type"
    echo "- Tauri iOS WKWebView Metal render-log: $tauri_ios_render_log_validation_status ($tauri_ios_render_log_validation_reason; backend=$tauri_ios_backend expected_gpu=$tauri_ios_expected_gpu_backend gate=$tauri_ios_gate_status)"
    echo "- browser source duplicate guard: $browser_backing_source_duplicate_reason"
    echo "- pairwise ARGB: mode=$pixel_mode electron_chrome=$ec_diff electron_simple=$es_diff chrome_simple=$cs_diff viewport=$argb_viewport_reason checksum=$argb_checksum_reason"
    echo "- Simple ARGB artifact: $simple_argb_artifact_file_status/$simple_argb_artifact_status reason=$simple_argb_artifact_reason format=$(render_log_value_of format "$SIMPLE_ARGB_ARTIFACT_ENV") size=$(render_log_value_of width "$SIMPLE_ARGB_ARTIFACT_ENV")x$(render_log_value_of height "$SIMPLE_ARGB_ARTIFACT_ENV") nonblank=$(render_log_value_of nonblank_pixel_count "$SIMPLE_ARGB_ARTIFACT_ENV") checksum=$(render_log_value_of checksum "$SIMPLE_ARGB_ARTIFACT_ENV")"
    echo "- Chrome ARGB artifact: $chrome_argb_artifact_file_status/$chrome_argb_artifact_status reason=$chrome_argb_artifact_reason format=$(render_log_value_of format "$CHROME_ARGB_ARTIFACT_ENV") size=$(render_log_value_of width "$CHROME_ARGB_ARTIFACT_ENV")x$(render_log_value_of height "$CHROME_ARGB_ARTIFACT_ENV") nonblank=$(render_log_value_of nonblank_pixel_count "$CHROME_ARGB_ARTIFACT_ENV") checksum=$(render_log_value_of checksum "$CHROME_ARGB_ARTIFACT_ENV")"
    echo "- Electron ARGB artifact: $electron_argb_artifact_file_status/$electron_argb_artifact_status reason=$electron_argb_artifact_reason format=$(render_log_value_of format "$ELECTRON_ARGB_ARTIFACT_ENV") size=$(render_log_value_of width "$ELECTRON_ARGB_ARTIFACT_ENV")x$(render_log_value_of height "$ELECTRON_ARGB_ARTIFACT_ENV") nonblank=$(render_log_value_of nonblank_pixel_count "$ELECTRON_ARGB_ARTIFACT_ENV") checksum=$(render_log_value_of checksum "$ELECTRON_ARGB_ARTIFACT_ENV")"
    echo "- Xcode GPU capture: status=${capture_status:-unavailable} tool=$gpu_capture_tool tool_reason=$capture_tool_reason artifact=$capture_artifact_file_status/$capture_artifact_artifact_status magic=$capture_artifact_magic claimed=$capture_artifact_claimed_magic claimed_reason=$capture_artifact_claimed_magic_reason"
    echo
    echo "## Evidence"
    sed 's/^/- /' "$OUT_ENV"
} >"$REPORT_PATH"

cat "$OUT_ENV"
[ "$compare_status" = "pass" ]
