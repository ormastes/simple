    grep -q '^REDIS_URL=' "$env_file"
    grep -q '^REDIS_BENCHMARK_CONTAINER=' "$env_file"
    grep -q '^H2O_STATIC_CONTAINER=' "$env_file"
    grep -q '^CLICKHOUSE_SCAN_FILTER_PROJECT_QUERY=' "$env_file"
    grep -q '^DUCKDB_TPCH_Q3_JOIN_AGGREGATE_QUERY=' "$env_file"
    grep -q '^POSTGRES_TPCH_Q3_JOIN_AGGREGATE_QUERY=' "$env_file"
    grep -q '^MONGO_YCSB_DOCUMENT_FILTER_EVAL=' "$env_file"
    grep -q '^ANN_VECTOR_SEARCH_SHAPE=' "$env_file"
