    printf '%s\n' "$output" | grep -q '^haproxy_upload_proxy_url=missing|HAPROXY_UPLOAD_PROXY_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^simple_tunnel_proxy_url=missing|SIMPLE_TUNNEL_PROXY_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^haproxy_tunnel_proxy_url=missing|HAPROXY_TUNNEL_PROXY_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^dynamic_cpu_plaintext_url=missing|DYNAMIC_CPU_PLAINTEXT_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^clickhouse_url=missing|CLICKHOUSE_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^postgres_url=missing|POSTGRES_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^mongo_url=missing|MONGO_URL-not-configured'
    printf '%s\n' "$output" | grep -q '^redis_url=missing|REDIS_URL-not-configured'
    echo "STATUS: PASS gpu web/db external fixture env template safe defaults self-test"
