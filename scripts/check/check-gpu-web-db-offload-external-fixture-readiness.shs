fi

if [ "${1:-}" = "--self-test-check-env-file" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    env_file="$tmpdir/external-fixtures.env"
    cat > "$env_file" <<'EOF'
DYNAMIC_GPU_PLAINTEXT_URL=http://127.0.0.1:8080/plaintext
DYNAMIC_CPU_PLAINTEXT_URL=http://127.0.0.1:8081/plaintext
DYNAMIC_GPU_JSON_URL=http://127.0.0.1:8080/json
DYNAMIC_CPU_JSON_URL=http://127.0.0.1:8081/json
SIMPLE_CACHED_PROXY_URL=http://127.0.0.1:8090/cacheable
HAPROXY_CACHED_PROXY_URL=http://127.0.0.1:8091/cacheable
ENVOY_CACHED_PROXY_URL=http://127.0.0.1:8092/cacheable
SIMPLE_UPLOAD_PROXY_URL=http://127.0.0.1:8090/upload
HAPROXY_UPLOAD_PROXY_URL=http://127.0.0.1:8091/upload
SIMPLE_TUNNEL_PROXY_URL=http://127.0.0.1:8090/tunnel
HAPROXY_TUNNEL_PROXY_URL=http://127.0.0.1:8091/tunnel
CLICKHOUSE_URL=clickhouse://127.0.0.1:9000/default
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
MONGO_URL=mongodb://127.0.0.1:27017/ycsb
REDIS_URL=redis://127.0.0.1:6379/0
EOF
    output="$(check_env_file "$env_file")"
    printf '%s\n' "$output" | grep -q '^dynamic_gpu_plaintext_url=ready|DYNAMIC_GPU_PLAINTEXT_URL-configured'
    printf '%s\n' "$output" | grep -q '^simple_cached_proxy_url=ready|SIMPLE_CACHED_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^haproxy_cached_proxy_url=ready|HAPROXY_CACHED_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^envoy_cached_proxy_url=ready|ENVOY_CACHED_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^simple_upload_proxy_url=ready|SIMPLE_UPLOAD_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^haproxy_upload_proxy_url=ready|HAPROXY_UPLOAD_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^simple_tunnel_proxy_url=ready|SIMPLE_TUNNEL_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^haproxy_tunnel_proxy_url=ready|HAPROXY_TUNNEL_PROXY_URL-configured'
    printf '%s\n' "$output" | grep -q '^dynamic_cpu_json_url=ready|DYNAMIC_CPU_JSON_URL-configured'
    printf '%s\n' "$output" | grep -q '^clickhouse_url=ready|CLICKHOUSE_URL-configured'
    printf '%s\n' "$output" | grep -q '^postgres_url=ready|POSTGRES_URL-configured'
    printf '%s\n' "$output" | grep -q '^mongo_url=ready|MONGO_URL-configured'
    printf '%s\n' "$output" | grep -q '^redis_url=ready|REDIS_URL-configured'
    printf '%s\n' "$output" | grep -q '^caddy=missing|caddy-not-installed'
    printf '%s\n' "$output" | grep -q 'STATUS: WARN gpu web/db external fixture env file missing:'
    empty_env="$tmpdir/empty.env"
    emit_env_template > "$empty_env"
    preserved_output="$(SIMPLE_CACHED_PROXY_URL=http://127.0.0.1:8090/cacheable check_env_file "$empty_env")"
    printf '%s\n' "$preserved_output" | grep -q '^simple_cached_proxy_url=ready|SIMPLE_CACHED_PROXY_URL-configured'
    printf '%s\n' "$preserved_output" | grep -q '^haproxy_cached_proxy_url=missing|HAPROXY_CACHED_PROXY_URL-not-configured'
    echo "STATUS: PASS gpu web/db external fixture env file check self-test"
    exit 0
fi

if [ "${1:-}" = "--self-test-bootstrap-status" ]; then
    output="$(emit_bootstrap_status)"
    printf '%s\n' "$output" | grep -Eq '^bootstrap_container_runtime=(ready|missing)\|'
    printf '%s\n' "$output" | grep -Eq '^bootstrap_container_engine=(ready|unavailable|missing|unknown)\|'
    printf '%s\n' "$output" | grep -Eq '^bootstrap_package_manager=(ready|missing)\|'
    printf '%s\n' "$output" | grep -Eq '^bootstrap_compose=(ready|optional-missing)\|'
    printf '%s\n' "$output" | grep -Eq '^bootstrap_compose=(ready\|(docker compose|docker-compose):|optional-missing\|docker-compose-not-installed$)'
    printf '%s\n' "$output" | grep -Eq '^bootstrap_missing_fixture_items=info\|[0-9]+$'
    printf '%s\n' "$output" | grep -Eq '^bootstrap_local_fixture_bootstrap=(possible|engine-unavailable|manual-install-possible|blocked)\|'
    printf '%s\n' "$output" | grep -q '^bootstrap_side_effects=none|status-only-no-install-no-container-start$'
    echo "STATUS: PASS gpu web/db external fixture bootstrap status self-test"
    exit 0
fi

if [ "${1:-}" = "--self-test-container-engine-status" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT INT TERM

    cat > "$tmpdir/docker" <<'EOF'
#!/usr/bin/env sh
if [ "${1:-}" = "info" ]; then
    exit 0
fi
exit 1
EOF
    chmod +x "$tmpdir/docker"
    output="$(PATH="$tmpdir:$PATH" container_engine_status "docker:$tmpdir/docker")"
    printf '%s\n' "$output" | grep -q '^bootstrap_container_engine=ready|docker-info$'

    cat > "$tmpdir/docker" <<'EOF'
#!/usr/bin/env sh
exit 1
EOF
    chmod +x "$tmpdir/docker"
    output="$(PATH="$tmpdir:$PATH" container_engine_status "docker:$tmpdir/docker")"
    printf '%s\n' "$output" | grep -q '^bootstrap_container_engine=unavailable|docker-info-failed$'

    output="$(container_engine_status "")"
    printf '%s\n' "$output" | grep -q '^bootstrap_container_engine=missing|container-runtime-not-installed$'

    output="$(container_engine_status "containerd:/usr/bin/containerd")"
    printf '%s\n' "$output" | grep -q '^bootstrap_container_engine=unknown|containerd:/usr/bin/containerd$'

    echo "STATUS: PASS gpu web/db external fixture container engine status self-test"
    exit 0
fi

