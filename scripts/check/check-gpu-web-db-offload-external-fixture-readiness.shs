write_local_env_candidates() {
    path="${1:-$LOCAL_ENV_CANDIDATES_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_local_env_candidates > "$path"
    printf '%s\n' "$path"
}

emit_runbook() {
    cat <<'EOF'
# GPU Web/DB External Fixture Runbook

This runbook is generated for operators who are preparing external web, proxy,
dynamic-route, and DB fixtures. Generation is side-effect-free: it writes
instructions only and does not pull images, start containers, or run benchmarks.

## 1. Generate Fixture Handoff Files

```sh
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-template
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-bootstrap-manifest
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-docker-compose-template
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-docker-run-template
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-proxy-config-templates
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-fields
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-blocker-manifest
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-hints
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-next-actions
```

## 2. Review And Start Optional Local Fixtures

Review `build/perf/gpu_web_db_offload/haproxy.cfg` and
`build/perf/gpu_web_db_offload/envoy.yaml` before starting proxy containers.
The generated proxy templates point to `host.docker.internal:8090`; on Linux,
the generated Compose and docker-run templates map `host.docker.internal` to
Docker's `host-gateway`. If the container runtime does not support that mapping,
replace the upstream host with the host gateway or host IP before starting the
proxy fixtures.

```sh
docker compose -f build/perf/gpu_web_db_offload/external-fixture-compose.yaml --profile needs-proxy-config up -d
```

If the host lacks Docker Compose, review and run the generated
`build/perf/gpu_web_db_offload/external-fixture-docker-run.shs` template, or
start equivalent Caddy, HAProxy, Envoy, ClickHouse, PostgreSQL, and MongoDB
fixtures manually with another container runtime. Re-running the generated
docker-run template restarts only its named `gpu-web-db-*` fixture containers.

## 3. Fill The Fixture Env File

Copy verified values from
`build/perf/gpu_web_db_offload/external-fixture-env-hints.md` into
`build/perf/gpu_web_db_offload/external-fixtures.env`. Keep unverified values
empty; empty assignments are safe and do not make readiness pass.

After starting the generated local fixture containers, this helper writes a
sourceable candidate file with the default local URLs. Review the services first,
then copy only verified values into `external-fixtures.env`:

```sh
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-local-env-candidates
```

## 4. Refresh Readiness

```sh
scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status
scripts/check/check-gpu-web-db-offload-external-suite.shs --status
scripts/check/check-gpu-web-db-offload-external-suite.shs --status-json
scripts/check/check-gpu-web-db-offload-external-suite.shs --preflight
```

## 5. Run The Guarded Suite

Use the strict readiness gate before a measured run:

```sh
scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready
scripts/check/check-gpu-web-db-offload-external-suite.shs
```

Use partial mode only to refresh local artifacts while fixtures remain missing:

```sh
scripts/check/check-gpu-web-db-offload-external-suite.shs --allow-partial
```
EOF
}

write_runbook() {
    path="${1:-$RUNBOOK_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_runbook > "$path"
    printf '%s\n' "$path"
}

emit_env_fields() {
    cat <<'EOF'
readiness_item	env_variable	category	fills
simple_cached_proxy_url	SIMPLE_CACHED_PROXY_URL	proxy_fixture_urls	Simple cached reverse-proxy fixture URL
haproxy_cached_proxy_url	HAPROXY_CACHED_PROXY_URL	proxy_fixture_urls	HAProxy cached reverse-proxy fixture URL
envoy_cached_proxy_url	ENVOY_CACHED_PROXY_URL	proxy_fixture_urls	Envoy cached reverse-proxy fixture URL
simple_upload_proxy_url	SIMPLE_UPLOAD_PROXY_URL	proxy_fixture_urls	Simple upload-streaming fixture URL
haproxy_upload_proxy_url	HAPROXY_UPLOAD_PROXY_URL	proxy_fixture_urls	HAProxy upload-streaming fixture URL
simple_tunnel_proxy_url	SIMPLE_TUNNEL_PROXY_URL	proxy_fixture_urls	Simple upgrade-tunnel fixture URL
haproxy_tunnel_proxy_url	HAPROXY_TUNNEL_PROXY_URL	proxy_fixture_urls	HAProxy upgrade-tunnel fixture URL
dynamic_gpu_plaintext_url	DYNAMIC_GPU_PLAINTEXT_URL	dynamic_route_urls	GPU plaintext dynamic route URL
dynamic_cpu_plaintext_url	DYNAMIC_CPU_PLAINTEXT_URL	dynamic_route_urls	CPU plaintext dynamic route URL
dynamic_gpu_json_url	DYNAMIC_GPU_JSON_URL	dynamic_route_urls	GPU JSON dynamic route URL
dynamic_cpu_json_url	DYNAMIC_CPU_JSON_URL	dynamic_route_urls	CPU JSON dynamic route URL
simple_reference_plaintext_url	SIMPLE_REFERENCE_PLAINTEXT_URL	reference_fixture_urls	Simple reference plaintext route URL
uwebsockets_plaintext_url	UWEBSOCKETS_PLAINTEXT_URL	reference_fixture_urls	uWebSockets plaintext reference URL
seastar_plaintext_url	SEASTAR_PLAINTEXT_URL	reference_fixture_urls	Seastar plaintext reference URL
clickhouse_url	CLICKHOUSE_URL	db_service_urls	ClickHouse service URL
postgres_url	POSTGRES_URL	db_service_urls	PostgreSQL service URL
mongo_url	MONGO_URL	db_service_urls	MongoDB service URL
redis_url	REDIS_URL	db_service_urls	Redis/Valkey service URL
EOF
}

write_env_fields() {
    path="${1:-$ENV_FIELDS_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_env_fields > "$path"
    printf '%s\n' "$path"
}

emit_blocker_manifest() {
    missing="${1:-$(emit_missing_by_category)}"
    source="${2:-ambient-environment}"
    export BLOCKER_MANIFEST_MISSING="$missing"
    export BLOCKER_MANIFEST_SOURCE="$source"
    python3 - <<'PY'
import os

env_fields = {
    "simple_cached_proxy_url": ("SIMPLE_CACHED_PROXY_URL", "proxy_fixture_urls", "Start the Simple cached reverse-proxy fixture and fill the URL."),
    "haproxy_cached_proxy_url": ("HAPROXY_CACHED_PROXY_URL", "proxy_fixture_urls", "Start the HAProxy cached reverse-proxy fixture and fill the URL."),
    "envoy_cached_proxy_url": ("ENVOY_CACHED_PROXY_URL", "proxy_fixture_urls", "Start the Envoy cached reverse-proxy fixture and fill the URL."),
    "simple_upload_proxy_url": ("SIMPLE_UPLOAD_PROXY_URL", "proxy_fixture_urls", "Start the Simple upload-streaming fixture and fill the URL."),
    "haproxy_upload_proxy_url": ("HAPROXY_UPLOAD_PROXY_URL", "proxy_fixture_urls", "Start the HAProxy upload-streaming fixture and fill the URL."),
    "simple_tunnel_proxy_url": ("SIMPLE_TUNNEL_PROXY_URL", "proxy_fixture_urls", "Start the Simple upgrade-tunnel fixture and fill the URL."),
    "haproxy_tunnel_proxy_url": ("HAPROXY_TUNNEL_PROXY_URL", "proxy_fixture_urls", "Start the HAProxy upgrade-tunnel fixture and fill the URL."),
    "dynamic_gpu_plaintext_url": ("DYNAMIC_GPU_PLAINTEXT_URL", "dynamic_route_urls", "Start the GPU plaintext dynamic route and fill the URL."),
    "dynamic_cpu_plaintext_url": ("DYNAMIC_CPU_PLAINTEXT_URL", "dynamic_route_urls", "Start the CPU plaintext dynamic route and fill the URL."),
    "dynamic_gpu_json_url": ("DYNAMIC_GPU_JSON_URL", "dynamic_route_urls", "Start the GPU JSON dynamic route and fill the URL."),
    "dynamic_cpu_json_url": ("DYNAMIC_CPU_JSON_URL", "dynamic_route_urls", "Start the CPU JSON dynamic route and fill the URL."),
    "simple_reference_plaintext_url": ("SIMPLE_REFERENCE_PLAINTEXT_URL", "reference_fixture_urls", "Start the Simple reference plaintext route and fill the URL."),
    "uwebsockets_plaintext_url": ("UWEBSOCKETS_PLAINTEXT_URL", "reference_fixture_urls", "Start the uWebSockets-style plaintext reference and fill the URL."),
    "seastar_plaintext_url": ("SEASTAR_PLAINTEXT_URL", "reference_fixture_urls", "Start the Seastar-style plaintext reference and fill the URL."),
    "clickhouse_url": ("CLICKHOUSE_URL", "db_service_urls", "Start or point to ClickHouse and fill the service URL."),
    "postgres_url": ("POSTGRES_URL", "db_service_urls", "Start or point to PostgreSQL and fill the service URL."),
    "mongo_url": ("MONGO_URL", "db_service_urls", "Start or point to MongoDB and fill the service URL."),
    "redis_url": ("REDIS_URL", "db_service_urls", "Start or point to Redis/Valkey and fill the service URL."),
}
tool_actions = {
    "wrk": "Install wrk.",
    "nginx": "Install nginx.",
    "caddy": "Install or start Caddy.",
    "h2o": "Install or start H2O.",
    "haproxy": "Install or start HAProxy.",
    "envoy": "Install or start Envoy.",
    "clickhouse": "Install ClickHouse client tooling.",
    "duckdb": "Install DuckDB.",
    "psql": "Install PostgreSQL psql.",
    "pgbench": "Install PostgreSQL pgbench.",
    "mongodb": "Install Mongo shell tooling.",
    "redis_valkey": "Install Redis/Valkey CLI tooling for readiness probes.",
    "redis_benchmark": "Install redis-benchmark for measured Redis/Valkey SET/GET rows.",
}

print("source\tcategory\treadiness_item\tenv_variable\taction")
source = os.environ["BLOCKER_MANIFEST_SOURCE"]
for line in os.environ["BLOCKER_MANIFEST_MISSING"].splitlines():
    if "=" not in line:
        continue
    category, items = line.split("=", 1)
    for item in [value for value in items.split(",") if value]:
        if item in env_fields:
            variable, category, action = env_fields[item]
        else:
            variable = ""
            action = tool_actions.get(item, "Resolve the missing readiness item.")
        print(f"{source}\t{category}\t{item}\t{variable}\t{action}")
PY
}

write_blocker_manifest() {
    path="${1:-$BLOCKER_MANIFEST_PATH}"
    env_file="${2:-$NEXT_ACTIONS_ENV_FILE}"
    mkdir -p "$(dirname "$path")"
    if [ -f "$env_file" ]; then
        missing="$(emit_missing_by_category_from_env_file "$env_file")"
        source="fixture-env-file:$env_file"
    else
        missing="$(emit_missing_by_category)"
        source="ambient-environment"
    fi
    emit_blocker_manifest "$missing" "$source" > "$path"
    printf '%s\n' "$path"
}

emit_next_actions() {
    missing="${1:-$(emit_missing_by_category)}"
    source="${2:-ambient-environment}"
    export NEXT_ACTIONS_MISSING="$missing"
    export NEXT_ACTIONS_SOURCE="$source"
    python3 - <<'PY'
import os

rows = []
missing_count = 0
missing_keys = []
for line in os.environ["NEXT_ACTIONS_MISSING"].splitlines():
    if "=" not in line:
        continue
    category, items = line.split("=", 1)
    values = [item for item in items.split(",") if item]
    missing_count += len(values)
    missing_keys.extend(values)
    rows.append((category, ", ".join(values) if values else "ready"))

actions = [
    ("core_load_tools", "Install `wrk` and `nginx`; these are required before web baseline rows can be measured."),
    ("web_proxy_tools", "Install or start Caddy, H2O, HAProxy, and Envoy baselines; generated Compose/docker-run templates can cover Caddy, HAProxy, and Envoy."),
    ("db_tools", "Install ClickHouse client, DuckDB, PostgreSQL `psql`/`pgbench`, Mongo shell tooling, Redis/Valkey CLI tooling, and `redis-benchmark` before DB producers can emit measured/status rows."),
    ("proxy_fixture_urls", "Start the Simple proxy fixture and HAProxy/Envoy proxy fixtures, then fill cached, upload, and tunnel proxy URLs in `external-fixtures.env`."),
    ("dynamic_route_urls", "Start paired CPU and GPU dynamic route servers and fill plaintext and JSON route URLs in `external-fixtures.env`."),
    ("reference_fixture_urls", "Start optional Simple/uWebSockets/Seastar plaintext reference servers with workload parity, then fill their URLs in `external-fixtures.env`."),
    ("db_service_urls", "Start or point to ClickHouse, PostgreSQL, MongoDB, and Redis/Valkey services, then fill their connection URLs in `external-fixtures.env`."),
]

env_fields = {
    "simple_cached_proxy_url": ("SIMPLE_CACHED_PROXY_URL", "Simple cached reverse-proxy fixture URL"),
    "haproxy_cached_proxy_url": ("HAPROXY_CACHED_PROXY_URL", "HAProxy cached reverse-proxy fixture URL"),
    "envoy_cached_proxy_url": ("ENVOY_CACHED_PROXY_URL", "Envoy cached reverse-proxy fixture URL"),
    "simple_upload_proxy_url": ("SIMPLE_UPLOAD_PROXY_URL", "Simple upload-streaming fixture URL"),
    "haproxy_upload_proxy_url": ("HAPROXY_UPLOAD_PROXY_URL", "HAProxy upload-streaming fixture URL"),
    "simple_tunnel_proxy_url": ("SIMPLE_TUNNEL_PROXY_URL", "Simple upgrade-tunnel fixture URL"),
    "haproxy_tunnel_proxy_url": ("HAPROXY_TUNNEL_PROXY_URL", "HAProxy upgrade-tunnel fixture URL"),
    "dynamic_gpu_plaintext_url": ("DYNAMIC_GPU_PLAINTEXT_URL", "GPU plaintext dynamic route URL"),
    "dynamic_cpu_plaintext_url": ("DYNAMIC_CPU_PLAINTEXT_URL", "CPU plaintext dynamic route URL"),
    "dynamic_gpu_json_url": ("DYNAMIC_GPU_JSON_URL", "GPU JSON dynamic route URL"),
    "dynamic_cpu_json_url": ("DYNAMIC_CPU_JSON_URL", "CPU JSON dynamic route URL"),
    "simple_reference_plaintext_url": ("SIMPLE_REFERENCE_PLAINTEXT_URL", "Simple reference plaintext route URL"),
    "uwebsockets_plaintext_url": ("UWEBSOCKETS_PLAINTEXT_URL", "uWebSockets plaintext reference URL"),
    "seastar_plaintext_url": ("SEASTAR_PLAINTEXT_URL", "Seastar plaintext reference URL"),
    "clickhouse_url": ("CLICKHOUSE_URL", "ClickHouse service URL"),
    "postgres_url": ("POSTGRES_URL", "PostgreSQL service URL"),
    "mongo_url": ("MONGO_URL", "MongoDB service URL"),
    "redis_url": ("REDIS_URL", "Redis/Valkey service URL"),
}
missing_env_fields = [
    (key, env_fields[key][0], env_fields[key][1])
    for key in missing_keys
    if key in env_fields
]

print("# GPU Web/DB External Fixture Next Actions")
print()
print("This file is generated from the current missing fixture categories. It is side-effect-free and does not install tools, start containers, or run benchmarks.")
print()
print(f"- Missing fixture items: `{missing_count}`")
print(f"- Missing data source: `{os.environ['NEXT_ACTIONS_SOURCE']}`")
print(f"- Strict readiness command: `scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready`")
print()
print("## Missing Categories")
print()
print("| category | missing items |")
print("|---|---|")
for category, items in rows:
    print(f"| {category} | {items} |")
print()
if missing_env_fields:
    print("## Fixture Env Fields")
    print()
    print("| readiness item | env variable | fills |")
    print("|---|---|---|")
    for key, variable, note in missing_env_fields:
        print(f"| {key} | `{variable}` | {note} |")
    print()
print("## Action Map")
print()
print("| category | next action |")
print("|---|---|")
for category, action in actions:
    print(f"| {category} | {action} |")
print()
print("## Refresh Commands")
print()
print("```sh")
print("scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status")
print("scripts/check/check-gpu-web-db-offload-external-suite.shs --preflight")
print("scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready")
print("```")
PY
}

write_next_actions() {
    path="${1:-$NEXT_ACTIONS_PATH}"
    env_file="${2:-$NEXT_ACTIONS_ENV_FILE}"
    mkdir -p "$(dirname "$path")"
    if [ -f "$env_file" ]; then
        missing="$(emit_missing_by_category_from_env_file "$env_file")"
        source="fixture-env-file:$env_file"
    else
        missing="$(emit_missing_by_category)"
        source="ambient-environment"
    fi
    emit_next_actions "$missing" "$source" > "$path"
    printf '%s\n' "$path"
}

emit_env_template() {
    cat <<'EOF'
# GPU Web/DB external fixture environment template.
# Fill these values before running live dynamic-route or DB baseline producers.
# Examples:
# DYNAMIC_GPU_PLAINTEXT_URL=http://127.0.0.1:8080/plaintext
# DYNAMIC_CPU_PLAINTEXT_URL=http://127.0.0.1:8081/plaintext
# DYNAMIC_GPU_JSON_URL=http://127.0.0.1:8080/json
# DYNAMIC_CPU_JSON_URL=http://127.0.0.1:8081/json
# SIMPLE_REFERENCE_PLAINTEXT_URL=http://127.0.0.1:8084/plaintext
# UWEBSOCKETS_PLAINTEXT_URL=http://127.0.0.1:8085/plaintext
# SEASTAR_PLAINTEXT_URL=http://127.0.0.1:8086/plaintext
# SIMPLE_CACHED_PROXY_URL=http://127.0.0.1:8090/cacheable
# HAPROXY_CACHED_PROXY_URL=http://127.0.0.1:8091/cacheable
# ENVOY_CACHED_PROXY_URL=http://127.0.0.1:8092/cacheable
# CADDY_STATIC_CONTAINER=gpu-web-db-caddy-static
# H2O_STATIC_CONTAINER=gpu-web-db-h2o-static
# SIMPLE_UPLOAD_PROXY_URL=http://127.0.0.1:8090/upload
# HAPROXY_UPLOAD_PROXY_URL=http://127.0.0.1:8091/upload
# SIMPLE_TUNNEL_PROXY_URL=http://127.0.0.1:8090/tunnel
# HAPROXY_TUNNEL_PROXY_URL=http://127.0.0.1:8091/tunnel
# CLICKHOUSE_URL=clickhouse://127.0.0.1:9000/default
# POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
# MONGO_URL=mongodb://127.0.0.1:27017/ycsb
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_BENCHMARK_CONTAINER=gpu-web-db-redis-valkey-kv
# Optional standard-shape query overrides. Leave empty to use producer defaults.
# CLICKHOUSE_SCAN_FILTER_PROJECT_QUERY=SELECT sum(number) FROM numbers(1024) WHERE number % 2 = 0
# DUCKDB_TPCH_Q3_JOIN_AGGREGATE_QUERY=SELECT b.range AS segment, count(*) AS order_count, sum(a.range) AS revenue FROM range(1024) a JOIN range(16) b ON a.range % 16 = b.range GROUP BY b.range ORDER BY revenue DESC LIMIT 8
# POSTGRES_TPCH_Q3_JOIN_AGGREGATE_QUERY=SELECT b AS segment, count(*) AS order_count, sum(a) AS revenue FROM generate_series(1, 1024) a JOIN generate_series(1, 16) b ON a % 16 = b GROUP BY b ORDER BY revenue DESC LIMIT 8
# MONGO_YCSB_DOCUMENT_FILTER_EVAL=const c=db.ycsb || db.getSiblingDB("ycsb").usertable; c.find({field0:{$gte:0}},{_id:1,field0:1}).limit(1024).itcount()
# ANN_VECTOR_SEARCH_SHAPE=top-k 8 vector search over 1024x128 vectors with recall/id match
SIMPLE_CACHED_PROXY_URL=
HAPROXY_CACHED_PROXY_URL=
ENVOY_CACHED_PROXY_URL=
CADDY_STATIC_CONTAINER=
H2O_STATIC_CONTAINER=
SIMPLE_UPLOAD_PROXY_URL=
HAPROXY_UPLOAD_PROXY_URL=
SIMPLE_TUNNEL_PROXY_URL=
HAPROXY_TUNNEL_PROXY_URL=
DYNAMIC_GPU_PLAINTEXT_URL=
DYNAMIC_CPU_PLAINTEXT_URL=
DYNAMIC_GPU_JSON_URL=
DYNAMIC_CPU_JSON_URL=
SIMPLE_REFERENCE_PLAINTEXT_URL=
UWEBSOCKETS_PLAINTEXT_URL=
SEASTAR_PLAINTEXT_URL=
CLICKHOUSE_URL=
POSTGRES_URL=
MONGO_URL=
REDIS_URL=
REDIS_BENCHMARK_CONTAINER=
CLICKHOUSE_SCAN_FILTER_PROJECT_QUERY=
DUCKDB_TPCH_Q3_JOIN_AGGREGATE_QUERY=
POSTGRES_TPCH_Q3_JOIN_AGGREGATE_QUERY=
MONGO_YCSB_DOCUMENT_FILTER_EVAL=
ANN_VECTOR_SEARCH_SHAPE=
EOF
}

write_env_template() {
    path="${1:-$ENV_TEMPLATE_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_env_template > "$path"
    printf '%s\n' "$path"
}

emit_setup_checklist() {
    cat <<'EOF'
# GPU Web/DB External Fixture Setup Checklist

Use this checklist to turn readiness rows from `missing` into `ready` before
running live web, proxy, dynamic-route, or DB baseline producers.

## Required Load Tools

- [ ] `wrk`: HTTP load generator used by the web comparison producers.
- [ ] `nginx`: static-file reference server for the first measured baseline.

## Additional Web And Proxy Baselines

- [ ] `caddy`: additional static-file baseline.
- [ ] `h2o`: additional static-file baseline.
- [ ] `haproxy`: reverse-proxy cached, upload, and upgrade-tunnel baseline.
- [ ] `envoy`: reverse-proxy cached baseline.

## DB Baseline Tools And Services

- [ ] `clickhouse` or `clickhouse-client`: ClickBench-style OLAP baseline.
- [ ] `duckdb`: local TPC-H-style baseline.
- [ ] `psql`: PostgreSQL connection probe and query client.
- [ ] `pgbench`: PostgreSQL load helper for TPC-H-style baseline preparation.
- [ ] `mongosh` or `mongo`: MongoDB/YCSB document-filter baseline.
- [ ] `redis-cli` or `valkey-cli`: Redis/Valkey key/value baseline status
      probe.
- [ ] `redis-benchmark`: Redis/Valkey measured SET/GET baseline producer.

## URL And Service Configuration

- [ ] Start the live GPU and CPU dynamic-route servers.
- [ ] Start the live Simple cached-proxy fixture and optional HAProxy/Envoy
      cached-proxy baselines.
- [ ] Fill `SIMPLE_CACHED_PROXY_URL`, `HAPROXY_CACHED_PROXY_URL`, and/or
      `ENVOY_CACHED_PROXY_URL`.
- [ ] Start the live Simple and HAProxy upload-streaming proxy fixtures.
- [ ] Fill `SIMPLE_UPLOAD_PROXY_URL` and `HAPROXY_UPLOAD_PROXY_URL`.
- [ ] Start the live Simple and HAProxy upgrade-tunnel proxy fixtures.
- [ ] Fill `SIMPLE_TUNNEL_PROXY_URL` and `HAPROXY_TUNNEL_PROXY_URL`.
- [ ] Fill `DYNAMIC_GPU_PLAINTEXT_URL`, `DYNAMIC_CPU_PLAINTEXT_URL`,
      `DYNAMIC_GPU_JSON_URL`, and `DYNAMIC_CPU_JSON_URL`.
- [ ] Start optional Simple/uWebSockets/Seastar plaintext reference fixtures
      with workload parity.
- [ ] Fill `SIMPLE_REFERENCE_PLAINTEXT_URL`, `UWEBSOCKETS_PLAINTEXT_URL`,
      and `SEASTAR_PLAINTEXT_URL` when those optional reference baselines are
      available.
- [ ] Start or point to ClickHouse, PostgreSQL, MongoDB, and Redis/Valkey
      services.
- [ ] Fill `CLICKHOUSE_URL`, `POSTGRES_URL`, `MONGO_URL`, and `REDIS_URL`.
- [ ] Leave the standard-shape query override variables empty for default
      ClickBench/TPC-H/YCSB shapes, or fill them only when the external fixture
      schema requires a compatible adjusted query.
- [ ] Run `scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs`
      until the required rows report `ready`.

## Handoff Commands

```sh
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-template
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-setup-checklist
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --check-env-file
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --bootstrap-status
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-bootstrap-manifest
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-docker-compose-template
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-docker-run-template
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-proxy-config-templates
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-fields
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-blocker-manifest
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-hints
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-runbook
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-next-actions
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --missing-by-category
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-missing-by-category
scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs
scripts/check/check-gpu-web-db-offload-external-suite.shs --dry-run
# Suite refresh/preflight use build/perf/gpu_web_db_offload/external-fixtures.env when it exists.
scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status
scripts/check/check-gpu-web-db-offload-external-suite.shs --status
scripts/check/check-gpu-web-db-offload-external-suite.shs --status-json
scripts/check/check-gpu-web-db-offload-external-suite.shs --preflight
scripts/check/check-gpu-web-db-offload-external-suite.shs --require-ready
scripts/check/check-gpu-web-db-offload-external-suite.shs
# Optional local artifact refresh when fixtures are still missing:
scripts/check/check-gpu-web-db-offload-external-suite.shs --allow-partial
```
EOF
}

write_setup_checklist() {
    path="${1:-$SETUP_CHECKLIST_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_setup_checklist > "$path"
    printf '%s\n' "$path"
}

check_env_file() {
    path="${1:-$ENV_TEMPLATE_PATH}"
    output="$(emit_readiness_from_env_file "$path")"
    printf '%s\n' "$output"
    missing_count="$(printf '%s\n' "$output" | awk -F'[=|]' '$2 == "missing" { count++ } END { print count + 0 }')"
    if [ "$missing_count" -eq 0 ]; then
        echo "STATUS: PASS gpu web/db external fixture env file ready"
    else
        echo "STATUS: WARN gpu web/db external fixture env file missing:$missing_count"
    fi
}

source_nonempty_readiness_env_file() {
    path="$1"
    test -f "$path"
    while IFS= read -r line; do
        case "$line" in
            export\ *) line="${line#export }" ;;
        esac
        case "$line" in
            *=*) ;;
            *) continue ;;
        esac
        name="${line%%=*}"
        value="${line#*=}"
        if [ "$value" = "" ]; then
            continue
        fi
        case "$value" in
            \"*\") value="${value#\"}"; value="${value%\"}" ;;
            \'*\') value="${value#\'}"; value="${value%\'}" ;;
        esac
        case "$name" in
            SIMPLE_CACHED_PROXY_URL|HAPROXY_CACHED_PROXY_URL|ENVOY_CACHED_PROXY_URL|CADDY_STATIC_CONTAINER|H2O_STATIC_CONTAINER|\
SIMPLE_UPLOAD_PROXY_URL|HAPROXY_UPLOAD_PROXY_URL|SIMPLE_TUNNEL_PROXY_URL|\
HAPROXY_TUNNEL_PROXY_URL|DYNAMIC_GPU_PLAINTEXT_URL|DYNAMIC_CPU_PLAINTEXT_URL|\
DYNAMIC_GPU_JSON_URL|DYNAMIC_CPU_JSON_URL|SIMPLE_REFERENCE_PLAINTEXT_URL|\
UWEBSOCKETS_PLAINTEXT_URL|SEASTAR_PLAINTEXT_URL|CLICKHOUSE_URL|POSTGRES_URL|MONGO_URL|REDIS_URL|REDIS_BENCHMARK_CONTAINER|\
ANN_VECTOR_SEARCH_SHAPE)
                export "$name=$value"
                ;;
        esac
    done < "$path"
}

emit_readiness_from_env_file() {
    path="${1:-$ENV_TEMPLATE_PATH}"
    source_nonempty_readiness_env_file "$path"
    emit_readiness
}

emit_missing_by_category() {
    output="${1:-$(emit_readiness)}"
    printf '%s\n' "$output" | awk -F'[=|]' '
        BEGIN {
            categories[1] = "core_load_tools"
            categories[2] = "web_proxy_tools"
            categories[3] = "db_tools"
            categories[4] = "proxy_fixture_urls"
            categories[5] = "dynamic_route_urls"
            categories[6] = "reference_fixture_urls"
            categories[7] = "db_service_urls"
        }
        function category_for(key) {
            if (key == "wrk" || key == "nginx") return "core_load_tools"
            if (key == "caddy" || key == "h2o" || key == "haproxy" || key == "envoy") return "web_proxy_tools"
            if (key == "clickhouse" || key == "duckdb" || key == "psql" || key == "pgbench" || key == "mongodb" || key == "redis_valkey" || key == "redis_benchmark") return "db_tools"
            if (key == "simple_cached_proxy_url" || key == "haproxy_cached_proxy_url" || key == "envoy_cached_proxy_url" || key == "simple_upload_proxy_url" || key == "haproxy_upload_proxy_url" || key == "simple_tunnel_proxy_url" || key == "haproxy_tunnel_proxy_url") return "proxy_fixture_urls"
            if (key == "dynamic_gpu_plaintext_url" || key == "dynamic_cpu_plaintext_url" || key == "dynamic_gpu_json_url" || key == "dynamic_cpu_json_url") return "dynamic_route_urls"
            if (key == "simple_reference_plaintext_url" || key == "uwebsockets_plaintext_url" || key == "seastar_plaintext_url") return "reference_fixture_urls"
            if (key == "clickhouse_url" || key == "postgres_url" || key == "mongo_url" || key == "redis_url") return "db_service_urls"
            return "other"
        }
        $2 == "missing" {
            category = category_for($1)
            if (missing[category] == "") {
                missing[category] = $1
            } else {
                missing[category] = missing[category] "," $1
            }
        }
        END {
            for (i = 1; i <= 7; i++) {
                category = categories[i]
                printf "%s=%s\n", category, missing[category]
            }
        }
    '
}

write_missing_by_category() {
    path="${1:-$MISSING_BY_CATEGORY_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_missing_by_category > "$path"
    printf '%s\n' "$path"
}

emit_missing_by_category_from_env_file() {
    env_file="${1:-$ENV_TEMPLATE_PATH}"
    output="$(emit_readiness_from_env_file "$env_file")"
    emit_missing_by_category "$output"
}

write_missing_by_category_from_env_file() {
    path="${1:-$MISSING_BY_CATEGORY_PATH}"
    env_file="${2:-$ENV_TEMPLATE_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_missing_by_category_from_env_file "$env_file" > "$path"
    printf '%s\n' "$path"
}

write_artifacts() {
    output="$1"
    missing_count="$2"
    export READINESS_OUTPUT="$output"
    export READINESS_MISSING_COUNT="$missing_count"
    export READINESS_BOOTSTRAP_STATUS="$(emit_bootstrap_status)"
    export READINESS_ENV_TEMPLATE="$(emit_env_template)"
    export READINESS_SETUP_CHECKLIST="$(emit_setup_checklist)"
    export REPORT TABLE
    mkdir -p "$(dirname "$REPORT")" "$(dirname "$TABLE")"
    python3 - <<'PY'
import os
from pathlib import Path

rows = []
for line in os.environ["READINESS_OUTPUT"].splitlines():
    if "=" not in line or "|" not in line:
        continue
    key, rest = line.split("=", 1)
    status, reason = rest.split("|", 1)
    rows.append((key, status, reason))

bootstrap_rows = []
for line in os.environ["READINESS_BOOTSTRAP_STATUS"].splitlines():
    if "=" not in line or "|" not in line:
        continue
    key, rest = line.split("=", 1)
    status, reason = rest.split("|", 1)
    bootstrap_rows.append((key, status, reason))

ready_count = sum(1 for _, status, _ in rows if status == "ready")
missing_count = int(os.environ["READINESS_MISSING_COUNT"])
header = "| fixture | status | reason |\n"
sep = "|---|---|---|\n"
body_rows = "".join(f"| {key} | {status} | {reason} |\n" for key, status, reason in rows)
bootstrap_header = "| bootstrap check | status | reason |\n"
bootstrap_sep = "|---|---|---|\n"
bootstrap_body = "".join(
    f"| {key} | {status} | {reason} |\n" for key, status, reason in bootstrap_rows
)
categories = [
    ("core_load_tools", {"wrk", "nginx"}),
    ("web_proxy_tools", {"caddy", "h2o", "haproxy", "envoy"}),
    ("db_tools", {"clickhouse", "duckdb", "psql", "pgbench", "mongodb", "redis_valkey", "redis_benchmark"}),
    (
        "proxy_fixture_urls",
        {
            "simple_cached_proxy_url",
            "haproxy_cached_proxy_url",
            "envoy_cached_proxy_url",
            "simple_upload_proxy_url",
            "haproxy_upload_proxy_url",
            "simple_tunnel_proxy_url",
            "haproxy_tunnel_proxy_url",
        },
    ),
    (
        "dynamic_route_urls",
        {
            "dynamic_gpu_plaintext_url",
            "dynamic_cpu_plaintext_url",
            "dynamic_gpu_json_url",
            "dynamic_cpu_json_url",
        },
    ),
    (
        "reference_fixture_urls",
        {
            "simple_reference_plaintext_url",
            "uwebsockets_plaintext_url",
            "seastar_plaintext_url",
        },
    ),
    ("db_service_urls", {"clickhouse_url", "postgres_url", "mongo_url", "redis_url"}),
]
category_header = "| category | ready | missing |\n"
category_sep = "|---|---:|---:|\n"
category_rows = []
for category, keys in categories:
    category_items = [(key, status) for key, status, _ in rows if key in keys]
    category_ready = sum(1 for _, status in category_items if status == "ready")
    category_missing = sum(1 for _, status in category_items if status == "missing")
    category_rows.append(f"| {category} | {category_ready} | {category_missing} |\n")
category_body = "".join(category_rows)
summary = (
    f"- Ready fixtures: `{ready_count}`\n"
    f"- Missing fixtures: `{missing_count}`\n"
    f"- Verdict: `{'PASS' if missing_count == 0 else 'WARN'}`\n\n"
)
report = (
    "# GPU Web/DB External Fixture Readiness\n\n"
    "This report is generated by `scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs`.\n"
    "It records host readiness for external web, proxy, dynamic-route, and DB baseline fixtures. "
    "It does not run benchmarks or create measured throughput claims.\n\n"
    "## Summary\n\n"
    + summary
    + "## Category Summary\n\n"
    + category_header
    + category_sep
    + category_body
    + "\n"
    + "## Bootstrap Status\n\n"
    + bootstrap_header
    + bootstrap_sep
    + bootstrap_body
    + "\n"
    + "## Fixtures\n\n"
    + header
    + sep
    + body_rows
    + "\n## Fixture Environment Template\n\n"
    + "Run `scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --print-env-template` "
    + "to print the URL contract required by live dynamic-route and DB baseline producers. "
    + "Run `scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-env-template` "
    + "to write the same template to `build/perf/gpu_web_db_offload/external-fixtures.env`.\n\n"
    + "```sh\n"
    + os.environ["READINESS_ENV_TEMPLATE"]
    + "\n```\n"
    + "\n## Fixture Setup Checklist\n\n"
    + "Run `scripts/check/check-gpu-web-db-offload-external-fixture-readiness.shs --write-setup-checklist` "
    + "to write a Markdown setup checklist to `build/perf/gpu_web_db_offload/external-fixture-setup-checklist.md`.\n\n"
    + os.environ["READINESS_SETUP_CHECKLIST"]
    + "\n"
)
metrics = (
    "# GPU Web/DB External Fixture Readiness Metrics\n\n"
    "## Bootstrap Status\n\n"
    + bootstrap_header
    + bootstrap_sep
    + bootstrap_body
    + "\n## Fixtures\n\n"
    + header
    + sep
    + body_rows
)
Path(os.environ["REPORT"]).write_text(report, encoding="utf-8")
Path(os.environ["TABLE"]).write_text(metrics, encoding="utf-8")
PY
}

