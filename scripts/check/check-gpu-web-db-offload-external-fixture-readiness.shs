#!/usr/bin/env sh
set -eu

REPORT="${REPORT:-doc/09_report/perf/gpu_web_db_offload_external_fixture_readiness_2026-06-17.md}"
TABLE="${TABLE:-doc/10_metrics/perf/gpu_web_db_offload_external_fixture_readiness.md}"
ENV_TEMPLATE_PATH="${ENV_TEMPLATE_PATH:-build/perf/gpu_web_db_offload/external-fixtures.env}"
SETUP_CHECKLIST_PATH="${SETUP_CHECKLIST_PATH:-build/perf/gpu_web_db_offload/external-fixture-setup-checklist.md}"
MISSING_BY_CATEGORY_PATH="${MISSING_BY_CATEGORY_PATH:-build/perf/gpu_web_db_offload/external-fixture-missing-by-category.env}"
BOOTSTRAP_MANIFEST_PATH="${BOOTSTRAP_MANIFEST_PATH:-build/perf/gpu_web_db_offload/external-fixture-bootstrap-manifest.tsv}"
DOCKER_COMPOSE_TEMPLATE_PATH="${DOCKER_COMPOSE_TEMPLATE_PATH:-build/perf/gpu_web_db_offload/external-fixture-compose.yaml}"
DOCKER_RUN_TEMPLATE_PATH="${DOCKER_RUN_TEMPLATE_PATH:-build/perf/gpu_web_db_offload/external-fixture-docker-run.shs}"
HAPROXY_CONFIG_TEMPLATE_PATH="${HAPROXY_CONFIG_TEMPLATE_PATH:-build/perf/gpu_web_db_offload/haproxy.cfg}"
ENVOY_CONFIG_TEMPLATE_PATH="${ENVOY_CONFIG_TEMPLATE_PATH:-build/perf/gpu_web_db_offload/envoy.yaml}"
ENV_HINTS_PATH="${ENV_HINTS_PATH:-build/perf/gpu_web_db_offload/external-fixture-env-hints.md}"
LOCAL_ENV_CANDIDATES_PATH="${LOCAL_ENV_CANDIDATES_PATH:-build/perf/gpu_web_db_offload/external-fixture-local-env-candidates.env}"
RUNBOOK_PATH="${RUNBOOK_PATH:-build/perf/gpu_web_db_offload/external-fixture-runbook.md}"
NEXT_ACTIONS_PATH="${NEXT_ACTIONS_PATH:-build/perf/gpu_web_db_offload/external-fixture-next-actions.md}"
NEXT_ACTIONS_ENV_FILE="${NEXT_ACTIONS_ENV_FILE:-$ENV_TEMPLATE_PATH}"
ENV_FIELDS_PATH="${ENV_FIELDS_PATH:-build/perf/gpu_web_db_offload/external-fixture-env-fields.tsv}"
BLOCKER_MANIFEST_PATH="${BLOCKER_MANIFEST_PATH:-build/perf/gpu_web_db_offload/external-fixture-blockers.tsv}"

tool_path() {
    command -v "$1" 2>/dev/null || true
}

first_available_tool() {
    for tool in "$@"; do
        path="$(tool_path "$tool")"
        if [ "$path" != "" ]; then
            printf '%s:%s\n' "$tool" "$path"
            return 0
        fi
    done
    return 1
}

docker_compose_tool() {
    docker_path="$(tool_path docker)"
    if [ "$docker_path" != "" ] && docker compose version >/dev/null 2>&1; then
        printf 'docker compose:%s\n' "$docker_path"
        return 0
    fi
    first_available_tool docker-compose || true
}

container_engine_status() {
    runtime="$1"
    case "$runtime" in
        docker:*)
            if docker info >/dev/null 2>&1; then
                status_line "bootstrap_container_engine" "ready" "docker-info"
            else
                status_line "bootstrap_container_engine" "unavailable" "docker-info-failed"
            fi
            ;;
        podman:*)
            if podman info >/dev/null 2>&1; then
                status_line "bootstrap_container_engine" "ready" "podman-info"
            else
                status_line "bootstrap_container_engine" "unavailable" "podman-info-failed"
            fi
            ;;
        nerdctl:*)
            if nerdctl version >/dev/null 2>&1; then
                status_line "bootstrap_container_engine" "ready" "nerdctl-version"
            else
                status_line "bootstrap_container_engine" "unavailable" "nerdctl-version-failed"
            fi
            ;;
        "")
            status_line "bootstrap_container_engine" "missing" "container-runtime-not-installed"
            ;;
        *)
            status_line "bootstrap_container_engine" "unknown" "$runtime"
            ;;
    esac
}

status_line() {
    key="$1"
    status="$2"
    reason="$3"
    printf '%s=%s|%s\n' "$key" "$status" "$reason"
}

tool_status() {
    key="$1"
    tool="$2"
    path="$(tool_path "$tool")"
    if [ "$path" != "" ]; then
        status_line "$key" "ready" "$path"
    else
        status_line "$key" "missing" "$tool-not-installed"
    fi
}

url_status() {
    key="$1"
    var_name="$2"
    eval value=\"\${$var_name:-}\"
    if [ "$value" != "" ]; then
        status_line "$key" "ready" "$var_name-configured"
    else
        status_line "$key" "missing" "$var_name-not-configured"
    fi
}

compound_tool_status() {
    key="$1"
    ready_reason="$2"
    shift 2
    for tool in "$@"; do
        path="$(tool_path "$tool")"
        if [ "$path" != "" ]; then
            status_line "$key" "ready" "$ready_reason:$tool:$path"
            return 0
        fi
    done
    status_line "$key" "missing" "$key-not-installed"
}

compound_tool_or_container_status() {
    key="$1"
    ready_reason="$2"
    container_var="$3"
    shift 3
    for tool in "$@"; do
        path="$(tool_path "$tool")"
        if [ "$path" != "" ]; then
            status_line "$key" "ready" "$ready_reason:$tool:$path"
            return 0
        fi
    done
    eval container_name=\"\${$container_var:-}\"
    if [ "$container_name" != "" ] && command -v docker >/dev/null 2>&1; then
        for tool in "$@"; do
            if docker inspect -f '{{.State.Running}}' "$container_name" 2>/dev/null | grep -q '^true$' \
                && docker exec "$container_name" sh -c "command -v $tool >/dev/null 2>&1" 2>/dev/null; then
                status_line "$key" "ready" "$ready_reason:docker-container:$container_name:$tool"
                return 0
            fi
        done
    fi
    status_line "$key" "missing" "$key-not-installed"
}

emit_readiness() {
    tool_status "wrk" "wrk"
    tool_status "nginx" "nginx"
    compound_tool_or_container_status "caddy" "caddy-ready" "CADDY_STATIC_CONTAINER" "caddy"
    compound_tool_or_container_status "h2o" "h2o-ready" "H2O_STATIC_CONTAINER" "h2o"
    tool_status "haproxy" "haproxy"
    tool_status "envoy" "envoy"
    compound_tool_status "clickhouse" "clickhouse-ready" "clickhouse" "clickhouse-client"
    tool_status "duckdb" "duckdb"
    tool_status "psql" "psql"
    tool_status "pgbench" "pgbench"
    compound_tool_status "mongodb" "mongodb-ready" "mongosh" "mongo"
    compound_tool_or_container_status "redis_valkey" "redis-valkey-ready" "REDIS_BENCHMARK_CONTAINER" "redis-cli" "valkey-cli"
    compound_tool_or_container_status "redis_benchmark" "redis-benchmark-ready" "REDIS_BENCHMARK_CONTAINER" "redis-benchmark"
    url_status "simple_cached_proxy_url" "SIMPLE_CACHED_PROXY_URL"
    url_status "haproxy_cached_proxy_url" "HAPROXY_CACHED_PROXY_URL"
    url_status "envoy_cached_proxy_url" "ENVOY_CACHED_PROXY_URL"
    url_status "simple_upload_proxy_url" "SIMPLE_UPLOAD_PROXY_URL"
    url_status "haproxy_upload_proxy_url" "HAPROXY_UPLOAD_PROXY_URL"
    url_status "simple_tunnel_proxy_url" "SIMPLE_TUNNEL_PROXY_URL"
    url_status "haproxy_tunnel_proxy_url" "HAPROXY_TUNNEL_PROXY_URL"
    url_status "dynamic_gpu_plaintext_url" "DYNAMIC_GPU_PLAINTEXT_URL"
    url_status "dynamic_cpu_plaintext_url" "DYNAMIC_CPU_PLAINTEXT_URL"
    url_status "dynamic_gpu_json_url" "DYNAMIC_GPU_JSON_URL"
    url_status "dynamic_cpu_json_url" "DYNAMIC_CPU_JSON_URL"
    url_status "simple_reference_plaintext_url" "SIMPLE_REFERENCE_PLAINTEXT_URL"
    url_status "uwebsockets_plaintext_url" "UWEBSOCKETS_PLAINTEXT_URL"
    url_status "seastar_plaintext_url" "SEASTAR_PLAINTEXT_URL"
    url_status "clickhouse_url" "CLICKHOUSE_URL"
    url_status "postgres_url" "POSTGRES_URL"
    url_status "mongo_url" "MONGO_URL"
    url_status "redis_url" "REDIS_URL"
}

emit_bootstrap_status() {
    runtime="$(first_available_tool docker podman nerdctl || true)"
    package_manager="$(first_available_tool apt apt-get dnf yum apk brew || true)"
    compose="$(docker_compose_tool)"
    engine_status="$(container_engine_status "$runtime")"

    if [ "$runtime" != "" ]; then
        status_line "bootstrap_container_runtime" "ready" "$runtime"
    else
        status_line "bootstrap_container_runtime" "missing" "docker-podman-nerdctl-not-installed"
    fi
    printf '%s\n' "$engine_status"
    if [ "$package_manager" != "" ]; then
        status_line "bootstrap_package_manager" "ready" "$package_manager"
    else
        status_line "bootstrap_package_manager" "missing" "supported-package-manager-not-installed"
    fi
    if [ "$compose" != "" ]; then
        status_line "bootstrap_compose" "ready" "$compose"
    else
        status_line "bootstrap_compose" "optional-missing" "docker-compose-not-installed"
    fi
    missing_count="$(emit_readiness | awk -F'[=|]' '$2 == "missing" { count++ } END { print count + 0 }')"
    status_line "bootstrap_missing_fixture_items" "info" "$missing_count"
    if printf '%s\n' "$engine_status" | grep -q '^bootstrap_container_engine=ready|'; then
        status_line "bootstrap_local_fixture_bootstrap" "possible" "container-engine-ready"
    elif [ "$runtime" != "" ]; then
        status_line "bootstrap_local_fixture_bootstrap" "engine-unavailable" "container-runtime-present-but-engine-unavailable"
    elif [ "$package_manager" != "" ]; then
        status_line "bootstrap_local_fixture_bootstrap" "manual-install-possible" "package-manager-available"
    else
        status_line "bootstrap_local_fixture_bootstrap" "blocked" "no-container-runtime-or-package-manager"
    fi
    status_line "bootstrap_side_effects" "none" "status-only-no-install-no-container-start"
}

emit_bootstrap_manifest() {
    cat <<'EOF'
fixture	kind	image_or_tool	default_port	fills	readiness_category	note
caddy_static	container	caddy:2	8082	tool:caddy	web_proxy_tools	static-file baseline candidate; map generated static fixture root read-only
h2o_static	manual_tool	h2o	8083	tool:h2o	web_proxy_tools	h2o packaging is host-specific; install tool or supply an equivalent fixture URL row
haproxy_cached_proxy	container	haproxy:2.9	8091	tool:haproxy,HAPROXY_CACHED_PROXY_URL	proxy_fixture_urls	cached reverse-proxy baseline for Simple cached proxy comparison
haproxy_upload_proxy	container	haproxy:2.9	8091	HAPROXY_UPLOAD_PROXY_URL	proxy_fixture_urls	upload-streaming proxy baseline; may share HAProxy container with cached proxy route
haproxy_tunnel_proxy	container	haproxy:2.9	8091	HAPROXY_TUNNEL_PROXY_URL	proxy_fixture_urls	upgrade-tunnel proxy baseline; may share HAProxy container with cached proxy route
envoy_cached_proxy	container	envoyproxy/envoy:v1.30-latest	8092	tool:envoy,ENVOY_CACHED_PROXY_URL	proxy_fixture_urls	cached reverse-proxy baseline for Envoy comparison
clickhouse_olap	container	clickhouse/clickhouse-server:latest	9000	tool:clickhouse,CLICKHOUSE_URL	db_service_urls	ClickBench-style OLAP baseline service
postgres_tpch	container	postgres:16	5432	tool:psql,tool:pgbench,POSTGRES_URL	db_service_urls	TPC-H-style relational baseline service
mongo_ycsb	container	mongo:7	27017	tool:mongodb,MONGO_URL	db_service_urls	YCSB-style document-filter baseline service
redis_valkey_kv	container	redis:7	6379	tool:redis-cli,tool:valkey-cli,tool:redis-benchmark,REDIS_URL	db_service_urls	Redis/Valkey-compatible key/value baseline service; redis-benchmark is required for measured SET/GET rows
simple_cached_proxy	external_url	repo-local-simple-web	8090	SIMPLE_CACHED_PROXY_URL	proxy_fixture_urls	Simple cached proxy fixture must come from the Simple server/proxy lane
simple_upload_proxy	external_url	repo-local-simple-web	8090	SIMPLE_UPLOAD_PROXY_URL	proxy_fixture_urls	Simple upload streaming fixture must come from the Simple server/proxy lane
simple_tunnel_proxy	external_url	repo-local-simple-web	8090	SIMPLE_TUNNEL_PROXY_URL	proxy_fixture_urls	Simple upgrade tunnel fixture must come from the Simple server/proxy lane
dynamic_gpu_plaintext	external_url	repo-local-simple-web	8080	DYNAMIC_GPU_PLAINTEXT_URL	dynamic_route_urls	GPU-tagged dynamic plaintext route; must expose GPU hit/fallback evidence separately
dynamic_cpu_plaintext	external_url	repo-local-simple-web	8081	DYNAMIC_CPU_PLAINTEXT_URL	dynamic_route_urls	CPU oracle plaintext route for dynamic route comparison
dynamic_gpu_json	external_url	repo-local-simple-web	8080	DYNAMIC_GPU_JSON_URL	dynamic_route_urls	GPU-tagged JSON route; must expose GPU hit/fallback evidence separately
dynamic_cpu_json	external_url	repo-local-simple-web	8081	DYNAMIC_CPU_JSON_URL	dynamic_route_urls	CPU oracle JSON route for dynamic route comparison
simple_reference_plaintext	external_url	repo-local-simple-web	8084	SIMPLE_REFERENCE_PLAINTEXT_URL	reference_fixture_urls	Simple plaintext reference route for optional uWebSockets/Seastar comparisons
uwebsockets_plaintext	external_url	external-uwebsockets	8085	UWEBSOCKETS_PLAINTEXT_URL	reference_fixture_urls	uWebSockets-style plaintext reference server with workload parity
seastar_plaintext	external_url	external-seastar	8086	SEASTAR_PLAINTEXT_URL	reference_fixture_urls	Seastar-style plaintext reference server with workload parity
EOF
}

write_bootstrap_manifest() {
    path="${1:-$BOOTSTRAP_MANIFEST_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_bootstrap_manifest > "$path"
    printf '%s\n' "$path"
}

emit_docker_compose_template() {
    cat <<'EOF'
# GPU Web/DB external fixture Docker Compose template.
# Generated by check-gpu-web-db-offload-external-fixture-readiness.shs.
# This file is side-effect-free: generation does not pull images or start services.
# Start manually after reviewing resource limits, ports, and proxy upstreams:
#   docker compose -f build/perf/gpu_web_db_offload/external-fixture-compose.yaml up -d
services:
  caddy_static:
    image: caddy:2
    command: ["caddy", "respond", "--listen", ":8082", "--body", "gpu-web-db-static-fixture"]
    ports:
      - "8082:8082"

  haproxy_cached_proxy:
    image: haproxy:2.9
    ports:
      - "8091:8091"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro
    profiles: ["needs-proxy-config"]

  envoy_cached_proxy:
    image: envoyproxy/envoy:v1.30-latest
    ports:
      - "8092:8092"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./envoy.yaml:/etc/envoy/envoy.yaml:ro
    profiles: ["needs-proxy-config"]

  clickhouse_olap:
    image: clickhouse/clickhouse-server:latest
    ports:
      - "9000:9000"
      - "8123:8123"

  postgres_tpch:
    image: postgres:16
    environment:
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: postgres
    ports:
      - "5432:5432"

  mongo_ycsb:
    image: mongo:7
    ports:
      - "27017:27017"

  redis_valkey_kv:
    image: redis:7
    ports:
      - "6379:6379"
EOF
}

write_docker_compose_template() {
    path="${1:-$DOCKER_COMPOSE_TEMPLATE_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_docker_compose_template > "$path"
    printf '%s\n' "$path"
}

emit_docker_run_template() {
    cat <<'EOF'
#!/usr/bin/env sh
set -eu

# GPU Web/DB external fixture docker-run template.
# Generated by check-gpu-web-db-offload-external-fixture-readiness.shs.
# Review resource limits, ports, and proxy upstreams before running this file.
# This generated file is an operator template; generators never execute it.
# Re-running this template restarts only the named gpu-web-db-* fixture
# containers below; it does not remove unrelated containers.

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

restart_fixture() {
    name="$1"
    shift
    if docker ps -a --format '{{.Names}}' | grep -qx "$name"; then
        docker rm -f "$name"
    fi
    docker run -d --name "$name" "$@"
}

restart_fixture gpu-web-db-caddy-static \
    -p 8082:8082 \
    caddy:2 caddy respond --listen :8082 --body gpu-web-db-static-fixture

restart_fixture gpu-web-db-haproxy-cached-proxy \
    -p 8091:8091 \
    --add-host=host.docker.internal:host-gateway \
    -v "$SCRIPT_DIR/haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro" \
    haproxy:2.9

restart_fixture gpu-web-db-envoy-cached-proxy \
    -p 8092:8092 \
    --add-host=host.docker.internal:host-gateway \
    -v "$SCRIPT_DIR/envoy.yaml:/etc/envoy/envoy.yaml:ro" \
    envoyproxy/envoy:v1.30-latest

restart_fixture gpu-web-db-clickhouse-olap \
    -p 9000:9000 -p 8123:8123 \
    clickhouse/clickhouse-server:latest

restart_fixture gpu-web-db-postgres-tpch \
    -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=postgres \
    -p 5432:5432 \
    postgres:16

restart_fixture gpu-web-db-mongo-ycsb \
    -p 27017:27017 \
    mongo:7

restart_fixture gpu-web-db-redis-valkey-kv \
    -p 6379:6379 \
    redis:7
EOF
}

write_docker_run_template() {
    path="${1:-$DOCKER_RUN_TEMPLATE_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_docker_run_template > "$path"
    chmod +x "$path"
    printf '%s\n' "$path"
}

emit_haproxy_config_template() {
    cat <<'EOF'
global
    log stdout format raw local0
    maxconn 4096

defaults
    mode http
    log global
    option httplog
    timeout connect 5s
    timeout client 60s
    timeout server 60s

frontend gpu_web_db_proxy
    bind *:8091
    default_backend simple_cached_proxy

backend simple_cached_proxy
    # Review this upstream before running the fixture.
    # On Docker Desktop, host.docker.internal reaches the host.
    # On Linux, replace it with the host gateway/IP if needed.
    server simple_proxy host.docker.internal:8090 check
EOF
}

emit_envoy_config_template() {
    cat <<'EOF'
static_resources:
  listeners:
    - name: gpu_web_db_proxy_listener
      address:
        socket_address:
          address: 0.0.0.0
          port_value: 8092
      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                stat_prefix: gpu_web_db_proxy
                route_config:
                  name: local_route
                  virtual_hosts:
                    - name: simple_cached_proxy
                      domains: ["*"]
                      routes:
                        - match:
                            prefix: "/"
                          route:
                            cluster: simple_cached_proxy
                http_filters:
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
  clusters:
    - name: simple_cached_proxy
      connect_timeout: 5s
      type: STRICT_DNS
      load_assignment:
        cluster_name: simple_cached_proxy
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      # Review this host before running the fixture.
                      address: host.docker.internal
                      port_value: 8090
EOF
}

write_proxy_config_templates() {
    haproxy_path="${1:-$HAPROXY_CONFIG_TEMPLATE_PATH}"
    envoy_path="${2:-$ENVOY_CONFIG_TEMPLATE_PATH}"
    mkdir -p "$(dirname "$haproxy_path")" "$(dirname "$envoy_path")"
    emit_haproxy_config_template > "$haproxy_path"
    emit_envoy_config_template > "$envoy_path"
    printf '%s\n' "$haproxy_path"
    printf '%s\n' "$envoy_path"
}

emit_env_hints() {
    cat <<'EOF'
# GPU Web/DB External Fixture Env Hints

These values are copy/paste hints for `external-fixtures.env` after the matching
fixtures are actually running. This file is intentionally Markdown, not a
sourceable env file, so generating it cannot mark readiness rows as `ready`.

## Compose/Proxy Template Derived Hints

```sh
# After starting the generated HAProxy proxy fixture on port 8091:
# HAPROXY_CACHED_PROXY_URL=http://127.0.0.1:8091/cacheable
# HAPROXY_UPLOAD_PROXY_URL=http://127.0.0.1:8091/upload
# HAPROXY_TUNNEL_PROXY_URL=http://127.0.0.1:8091/tunnel

# After starting the generated Envoy proxy fixture on port 8092:
# ENVOY_CACHED_PROXY_URL=http://127.0.0.1:8092/cacheable

# After starting the generated DB fixture containers:
# CLICKHOUSE_URL=clickhouse://127.0.0.1:9000/default
# POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
# MONGO_URL=mongodb://127.0.0.1:27017/ycsb
# REDIS_URL=redis://127.0.0.1:6379/0
```

## Operator-Supplied Simple/Dynamic Route Hints

```sh
# Fill these from the Simple web/proxy lane that owns the live route fixtures:
# SIMPLE_CACHED_PROXY_URL=http://127.0.0.1:8090/cacheable
# SIMPLE_UPLOAD_PROXY_URL=http://127.0.0.1:8090/upload
# SIMPLE_TUNNEL_PROXY_URL=http://127.0.0.1:8090/tunnel
# DYNAMIC_GPU_PLAINTEXT_URL=http://127.0.0.1:8080/plaintext
# DYNAMIC_CPU_PLAINTEXT_URL=http://127.0.0.1:8081/plaintext
# DYNAMIC_GPU_JSON_URL=http://127.0.0.1:8080/json
# DYNAMIC_CPU_JSON_URL=http://127.0.0.1:8081/json
# SIMPLE_REFERENCE_PLAINTEXT_URL=http://127.0.0.1:8084/plaintext
# UWEBSOCKETS_PLAINTEXT_URL=http://127.0.0.1:8085/plaintext
# SEASTAR_PLAINTEXT_URL=http://127.0.0.1:8086/plaintext
```

After copying verified values into `build/perf/gpu_web_db_offload/external-fixtures.env`,
run:

```sh
scripts/check/check-gpu-web-db-offload-external-suite.shs --refresh-status
scripts/check/check-gpu-web-db-offload-external-suite.shs --preflight
```
EOF
}

write_env_hints() {
    path="${1:-$ENV_HINTS_PATH}"
    mkdir -p "$(dirname "$path")"
    emit_env_hints > "$path"
    printf '%s\n' "$path"
}

emit_local_env_candidates() {
    cat <<'EOF'
# GPU Web/DB local fixture env candidates.
