if [ "${1:-}" = "--self-test" ]; then
    output="$(emit_readiness)"
    printf '%s\n' "$output" | grep -q '^wrk='
    printf '%s\n' "$output" | grep -q '^dynamic_gpu_plaintext_url='
    printf '%s\n' "$output" | grep -q '^simple_cached_proxy_url='
    printf '%s\n' "$output" | grep -q '^psql='
    printf '%s\n' "$output" | grep -q '^pgbench='
    printf '%s\n' "$output" | grep -q '^postgres_url='
    count="$(printf '%s\n' "$output" | wc -l)"
    if [ "$count" -lt 25 ]; then
        echo "ERROR: readiness output is missing rows" >&2
        exit 1
    fi
    echo "STATUS: PASS gpu web/db external fixture readiness self-test"
    exit 0
fi

