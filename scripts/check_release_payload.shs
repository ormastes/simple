#!/bin/sh
# Validate release licenses, exclusions, and byte-identical bundled fonts.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
FONT_SOURCE=${RELEASE_PAYLOAD_FONT_SOURCE_DIR:-$REPO_ROOT/assets/fonts}
MODE=""
TARGET=""
TMP=""

fail() {
    echo "[FAIL] $*" >&2
    exit 1
}

usage() {
    echo "usage: $0 --dir <directory> | --tar <archive>" >&2
    exit 2
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --dir|--tar)
            [ "$#" -ge 2 ] || usage
            [ -z "$MODE" ] || usage
            MODE=${1#--}
            TARGET=$2
            shift 2
            ;;
        --help|-h) usage ;;
        *) usage ;;
    esac
done
[ -n "$MODE" ] && [ -n "$TARGET" ] || usage

cleanup() {
    [ -z "$TMP" ] || rm -rf "$TMP"
}
trap cleanup EXIT HUP INT TERM

if [ "$MODE" = "dir" ]; then
    [ -d "$TARGET" ] || fail "directory not found: $TARGET"
    PAYLOAD_ROOT=$TARGET
else
    [ -f "$TARGET" ] || fail "archive not found: $TARGET"
    TMP=$(mktemp -d "${TMPDIR:-/tmp}/simple-release-payload.XXXXXX")
    tar -tf "$TARGET" > "$TMP/entries"
    flat_root=0
    if sed 's#\\#/#g; s#^\./##' "$TMP/entries" | grep -F -x LICENSE >/dev/null; then
        flat_root=1
    fi
    top_root=""
    while IFS= read -r entry; do
        normalized=$(printf '%s\n' "$entry" | sed 's#\\#/#g; s#^\./##')
        case "$normalized" in
            '' ) continue ;;
            ..|/*|../*|*/../*|*/..) fail "unsafe archive path: $entry" ;;
        esac
        top=${normalized%%/*}
        if [ -z "$top_root" ]; then
            top_root=$top
        elif [ "$flat_root" -eq 0 ] && [ "$top_root" != "$top" ]; then
            fail "archive has multiple top-level payload roots"
        fi
    done < "$TMP/entries"

    tar -tvf "$TARGET" > "$TMP/verbose-entries"
    while IFS= read -r record; do
        case "$record" in
            h*) fail "archive hardlink entries are not allowed" ;;
            l*)
                case "$record" in *' -> '*) ;; *) fail "unparseable archive symlink" ;; esac
                target=${record##* -> }
                member_record=${record% -> *}
                member=${member_record##* }
                member=$(printf '%s\n' "$member" | sed 's#\\#/#g; s#^\./##')
                case "$target" in /*|*\\*) fail "unsafe archive symlink: $member -> $target" ;; esac
                min_depth=0
                [ "$flat_root" -eq 1 ] || min_depth=1
                directory=${member%/*}
                [ "$directory" != "$member" ] || directory=""
                if ! awk -v path="$directory/$target" -v minimum="$min_depth" 'BEGIN {
                    count = split(path, part, "/")
                    depth = 0
                    for (i = 1; i <= count; i++) {
                        if (part[i] == "" || part[i] == ".") continue
                        if (part[i] == "..") {
                            if (depth <= minimum) exit 1
                            depth--
                        } else {
                            depth++
                        }
                    }
                }'; then
                    fail "archive symlink escapes payload root: $member -> $target"
                fi
                ;;
        esac
    done < "$TMP/verbose-entries"

    mkdir "$TMP/root"
    tar -xf "$TARGET" -C "$TMP/root"
    if [ "$flat_root" -eq 1 ]; then
        PAYLOAD_ROOT=$TMP/root
    else
        [ -n "$top_root" ] || fail "archive payload root not found"
        PAYLOAD_ROOT=$TMP/root/$top_root
    fi
fi

[ -f "$PAYLOAD_ROOT/LICENSE" ] || fail "missing root LICENSE"
[ -f "$PAYLOAD_ROOT/THIRD_PARTY_NOTICES.md" ] || fail "missing root THIRD_PARTY_NOTICES.md"
cmp -s "$REPO_ROOT/LICENSE" "$PAYLOAD_ROOT/LICENSE" || fail "root LICENSE differs from repository"
cmp -s "$REPO_ROOT/THIRD_PARTY_NOTICES.md" "$PAYLOAD_ROOT/THIRD_PARTY_NOTICES.md" || fail "root THIRD_PARTY_NOTICES.md differs from repository"

if ! (cd "$PAYLOAD_ROOT" && find . -print) | while IFS= read -r entry; do
    entry=${entry#./}
    case "/$entry/" in
        */src/app/vscode_extension/node_modules/*|*/src/app/vscode_extension/.vscode-test/*|*/src/compiler_rust/target/*|*/config/t32/libXp.so.6/*|*/config/t32/libjpeg.so.62.0.0/*)
            echo "forbidden payload entry: $entry" >&2
            exit 1
            ;;
    esac
done; then
    fail "release payload contains development-only files"
fi

require_fonts=0
case "$(basename "$TARGET")" in
    simple-bootstrap-*|simple-full-*) require_fonts=1 ;;
esac
if [ -d "$PAYLOAD_ROOT/assets/fonts" ]; then
    require_fonts=1
fi

if [ "$require_fonts" -eq 1 ]; then
    [ -d "$FONT_SOURCE" ] || fail "font source not found: $FONT_SOURCE"
    [ -d "$PAYLOAD_ROOT/assets/fonts" ] || fail "missing bundled assets/fonts"
    [ -z "$(find "$PAYLOAD_ROOT/assets/fonts" -type l -print -quit)" ] || fail "bundled font tree contains symlinks"

    LIST_DIR=${TMP:-$(mktemp -d "${TMPDIR:-/tmp}/simple-release-payload.XXXXXX")}
    if [ -z "$TMP" ]; then TMP=$LIST_DIR; fi
    (cd "$FONT_SOURCE" && find . -type f -print | sed 's#^\./##' | LC_ALL=C sort) > "$LIST_DIR/source-fonts"
    (cd "$PAYLOAD_ROOT/assets/fonts" && find . -type f -print | sed 's#^\./##' | LC_ALL=C sort) > "$LIST_DIR/payload-fonts"
    cmp -s "$LIST_DIR/source-fonts" "$LIST_DIR/payload-fonts" || fail "bundled font path set differs from repository"
    while IFS= read -r relative; do
        cmp -s "$FONT_SOURCE/$relative" "$PAYLOAD_ROOT/assets/fonts/$relative" || fail "bundled font bytes differ: $relative"
    done < "$LIST_DIR/source-fonts"
fi

echo "[OK] release payload validation passed for $TARGET"
