#!/usr/bin/env sh
# ============================================================================
# QEMU RV64 HTTP Integration Test
# ============================================================================
#
# Boots SimpleOS RV64 baremetal binary under QEMU virt, waits for the HTTP
# server to come up, then runs nc/openssl smoke tests against it.
#
# Usage:
#   sh scripts/qemu/qemu_rv64_http_test.shs [--elf <path>] [--expect-deferred] [--expect-http-only] [--with-display] [--with-storage] [--with-db] [--allow-prebuilt-artifact]
#
# Defaults:
#   --elf build/os/simpleos_riscv64.elf
#
# Requires: qemu-system-riscv64, nc
# ============================================================================
set -eu

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$REPO_ROOT"

# ---- defaults ----
ELF="${ELF:-build/os/simpleos_riscv64.elf}"
HTTP_PORT="${HTTP_PORT:-8080}"
HTTPS_PORT="${HTTPS_PORT:-8443}"
BOOT_TIMEOUT="${BOOT_TIMEOUT:-60}"
SERIAL_LOG="${SERIAL_LOG:-build/qemu-rv64-serial.log}"
DB_QUERY_LOG="${DB_QUERY_LOG:-$(dirname "$SERIAL_LOG")/db_query.log}"
EXPECT_DEFERRED=false
EXPECT_HTTP_ONLY=false
WITH_DISPLAY=false
WITH_STORAGE=false
WITH_DB=false
STORAGE_IMG="build/qemu-rv64-storage-probe.img"
ALLOW_PREBUILT_ARTIFACT=false

# ---- parse args ----
while [ "$#" -gt 0 ]; do
  case "$1" in
    --elf)
      shift
      ELF="$1"
      ;;
    --elf=*)
      ELF="${1#*=}"
      ;;
    --expect-deferred)
      EXPECT_DEFERRED=true
      ;;
    --expect-http-only)
      EXPECT_HTTP_ONLY=true
      ;;
    --with-display)
      WITH_DISPLAY=true
      ;;
    --with-storage)
      WITH_STORAGE=true
      ;;
    --with-db)
      WITH_DB=true
      WITH_STORAGE=true
      ;;
    --allow-prebuilt-artifact)
      ALLOW_PREBUILT_ARTIFACT=true
      ;;
    --help|-h)
      echo "Usage: sh scripts/qemu/qemu_rv64_http_test.shs [--elf <path>] [--expect-deferred] [--expect-http-only] [--with-display] [--with-storage] [--with-db] [--allow-prebuilt-artifact]"
      echo ""
      echo "  --elf <path>        Path to SimpleOS RV64 ELF (default: build/os/simpleos_riscv64.elf)"
      echo "  --expect-deferred   Pass when virtio is detected but packet RX is unavailable"
      echo "  --expect-http-only  Pass the live HTTP gate while HTTPS/TLS remains blocked"
      echo "  --with-display      Expose a virtio-gpu PCI device and require display readiness"
      echo "  --with-storage      Expose a virtio-blk PCI device and require sector-read readiness"
      echo "  --with-db           Exercise the guest Simple DB service through POST /db"
      echo "  --allow-prebuilt-artifact"
      echo "                      Permit smoke-only evidence from an ELF without a current-source build stamp"
      exit 0
      ;;
    *)
      echo "error: unknown option '$1'" >&2
      exit 1
      ;;
  esac
  shift
done

# ---- verify prerequisites ----
if [ ! -f "$ELF" ]; then
  echo "error: ELF not found: ${ELF}" >&2
  echo "  Build it first through the SimpleOS runner with a target-capable compiler:" >&2
  echo "  bin/simple os build --arch=riscv64" >&2
  echo "  Current seed builds without LLVM fail closed before QEMU; that is not live RV64 evidence." >&2
  exit 1
fi

BUILD_STAMP="${ELF}.build_stamp"
if [ "$ALLOW_PREBUILT_ARTIFACT" = "false" ]; then
  if [ ! -f "$BUILD_STAMP" ]; then
    echo "error: current-source build stamp not found: ${BUILD_STAMP}" >&2
    echo "  Refusing to treat ${ELF} as current-source RV64 QEMU evidence." >&2
    echo "  Build through: bin/simple os build --arch=riscv64" >&2
    echo "  For limited smoke-only evidence from a known prebuilt ELF, rerun with --allow-prebuilt-artifact." >&2
    exit 1
  fi
  if ! grep -Eq '^backend=(llvm|cranelift)$' "$BUILD_STAMP" 2>/dev/null ||
     ! grep -q '^target=riscv64-unknown-none$' "$BUILD_STAMP" 2>/dev/null ||
     ! grep -q '^entry=src/os/kernel/arch/riscv64/boot.spl$' "$BUILD_STAMP" 2>/dev/null; then
    echo "error: build stamp does not describe the RV64 current-source boot lane: ${BUILD_STAMP}" >&2
    exit 1
  fi
  if [ ! "$BUILD_STAMP" -nt "$ELF" ]; then
    echo "error: build stamp is older than the RV64 ELF: ${BUILD_STAMP}" >&2
    exit 1
  fi
  if grep -Eq '^simple_bin=.*(compiler_rust|simple_seed)' "$BUILD_STAMP" 2>/dev/null; then
    echo "error: Rust-seed provenance is not self-hosted RV64 evidence: ${BUILD_STAMP}" >&2
    exit 1
  fi
else
  echo "WARNING: --allow-prebuilt-artifact gives smoke-only evidence; it is not current-source RV64 rebuild evidence." >&2
fi

if ! command -v qemu-system-riscv64 >/dev/null 2>&1; then
  echo "error: qemu-system-riscv64 not found in PATH" >&2
  exit 1
fi

if command -v nm >/dev/null 2>&1; then
  UART_ADDR="$(nm -n "$ELF" 2>/dev/null | awk '$3 == "rt_riscv_uart_put" { print $1; exit }')"
  START_ADDR="$(nm -n "$ELF" 2>/dev/null | awk '$3 == "_start" { print $1; exit }')"
  if [ -n "$UART_ADDR" ] && [ -n "$START_ADDR" ] && [ "$UART_ADDR" = "$START_ADDR" ]; then
    echo "error: RV64 ELF symbol sanity failed: _start aliases rt_riscv_uart_put at 0x${START_ADDR}" >&2
    echo "  This is the known native entry-closure symbol mismatch; QEMU will only produce banner-loop evidence." >&2
    echo "  Fix the RV64 native-build source-worker path before rerunning this live HTTP/display gate." >&2
    exit 1
  fi
fi

if [ "$EXPECT_DEFERRED" = "false" ] && ! command -v nc >/dev/null 2>&1; then
  echo "error: nc not found in PATH" >&2
  exit 1
fi

# ---- prepare ----
mkdir -p "$(dirname "$SERIAL_LOG")"
rm -f "$SERIAL_LOG"
if [ "$WITH_DB" = "true" ]; then
  mkdir -p "$(dirname "$DB_QUERY_LOG")"
  rm -f "$DB_QUERY_LOG"
fi
QEMU_PID=""
if [ "$WITH_STORAGE" = "true" ]; then
  rm -f "$STORAGE_IMG"
  : > "$STORAGE_IMG"
  printf '\123\106\126\116\002\000\000\000\021\021\000\000\000\000\000\000\042\042\000\000\000\000\000\000\000\000\000\000\000\000\000\000\001\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000' > "$STORAGE_IMG"
  truncate -s 512 "$STORAGE_IMG"
  printf '\123\106\126\116\002\000\000\000\021\021\000\000\000\000\000\000\042\042\000\000\000\000\000\000\000\000\000\000\000\000\000\000\001\000\000\000\000\000\000\000\000\000\000\000\000\000\000\000\001\000\000\000\000\000' >> "$STORAGE_IMG"
  truncate -s 1M "$STORAGE_IMG"
  # NVFS arena-payload probe: rt_storage_init reads sector 65 (offset 65*512=33280)
  # and requires the magic "SIMPLEOS_NVFS_ARENA_FILE" at its start. Without it,
  # rt_storage_probe_nvfs_arena_payload() returns -3 and storage bringup fails.
  printf 'SIMPLEOS_NVFS_ARENA_FILE' | dd of="$STORAGE_IMG" bs=1 seek=33280 conv=notrunc 2>/dev/null
fi

# ---- cleanup on exit ----
cleanup() {
  if [ -n "$QEMU_PID" ]; then
    kill "$QEMU_PID" 2>/dev/null || true
    wait "$QEMU_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT

print_serial_tail() {
  if [ -f "$SERIAL_LOG" ]; then
    echo "--- serial log tail ---"
    tail -n "${SERIAL_TAIL_LINES:-200}" "$SERIAL_LOG"
    echo "--- end serial log tail ---"
  fi
}

# ---- launch QEMU ----
echo "[1/4] Launching QEMU RV64 with ${ELF}..."
DISPLAY_ARGS=""
if [ "$WITH_DISPLAY" = "true" ]; then
  DISPLAY_ARGS="-device virtio-gpu-pci,disable-modern=on,disable-legacy=off"
fi
STORAGE_ARGS=""
if [ "$WITH_STORAGE" = "true" ]; then
  STORAGE_ARGS="-drive file=${STORAGE_IMG},format=raw,if=none,id=blk0 -device virtio-blk-pci,drive=blk0"
fi
qemu-system-riscv64 \
  -machine virt \
  -cpu rv64 \
  -m 256M \
  -nographic \
  -monitor none \
  -netdev user,id=net0,hostfwd=tcp::${HTTP_PORT}-:${HTTP_PORT},hostfwd=tcp::${HTTPS_PORT}-:${HTTPS_PORT} \
  -device virtio-net-pci,netdev=net0 \
  ${DISPLAY_ARGS} \
  ${STORAGE_ARGS} \
  -kernel "$ELF" \
  -serial file:"$SERIAL_LOG" \
  </dev/null &
QEMU_PID=$!

echo "  QEMU PID: ${QEMU_PID}"

# ---- wait for boot gate marker ----
if [ "$EXPECT_DEFERRED" = "true" ]; then
  echo "[2/4] Waiting for deferred network marker (timeout: ${BOOT_TIMEOUT}s)..."
else
  echo "[2/4] Waiting for HTTP bind marker (timeout: ${BOOT_TIMEOUT}s)..."
fi
WAITED=0
BOOTED=false
while [ "$WAITED" -lt "$BOOT_TIMEOUT" ]; do
  if [ "$EXPECT_DEFERRED" = "true" ] &&
    [ -f "$SERIAL_LOG" ] &&
    grep -q "Network service ready" "$SERIAL_LOG" 2>/dev/null; then
    echo "FAILED: network reached ready state in deferred mode" >&2
    print_serial_tail
    exit 1
  fi
  if [ "$EXPECT_DEFERRED" = "true" ] &&
    [ -f "$SERIAL_LOG" ] &&
    grep -q "PMM OK" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "HEAP OK" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "PCI network device index" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "Network packet TX ready" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "Network packet RX unavailable" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "HTTP server deferred" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "Entering boot idle loop" "$SERIAL_LOG" 2>/dev/null; then
    echo "  Deferred network gate verified after ${WAITED}s"
    echo "DEFERRED PASSED"
    exit 0
  fi
  if [ -f "$SERIAL_LOG" ] && grep -q "HTTP server deferred" "$SERIAL_LOG" 2>/dev/null; then
    echo "FAILED: HTTP server was deferred" >&2
    print_serial_tail
    exit 1
  fi
  if [ -f "$SERIAL_LOG" ] &&
    grep -q "Network service ready" "$SERIAL_LOG" 2>/dev/null &&
    grep -Fq '[http_baremetal] Listening on 0.0.0.0:8080' "$SERIAL_LOG" 2>/dev/null; then
	    if [ "$WITH_DISPLAY" = "true" ] &&
	      ! grep -q "Display service ready" "$SERIAL_LOG" 2>/dev/null; then
	      sleep 1
      if ! grep -q "Display service ready" "$SERIAL_LOG" 2>/dev/null; then
        echo "FAILED: display device was requested but display service did not become ready" >&2
        print_serial_tail
	        exit 1
	      fi
	    fi
	    if [ "$WITH_DISPLAY" = "true" ]; then
	      echo "  Display service verified"
	    fi
	    if [ "$WITH_STORAGE" = "true" ] &&
	      ! grep -q "Storage service ready" "$SERIAL_LOG" 2>/dev/null; then
	      sleep 1
      if ! grep -q "Storage service ready" "$SERIAL_LOG" 2>/dev/null; then
        echo "FAILED: storage device was requested but storage service did not become ready" >&2
        print_serial_tail
	        exit 1
	      fi
	    fi
	    if [ "$WITH_STORAGE" = "true" ]; then
	      echo "  Storage service verified"
	    fi
	    if [ "$WITH_STORAGE" = "true" ] &&
	      ! grep -q "NVFS root superblock ready" "$SERIAL_LOG" 2>/dev/null; then
	      sleep 1
      if ! grep -q "NVFS root superblock ready" "$SERIAL_LOG" 2>/dev/null; then
        echo "FAILED: storage device was requested but NVFS root superblock was not verified" >&2
        print_serial_tail
	        exit 1
	      fi
	    fi
	    if [ "$WITH_STORAGE" = "true" ]; then
	      echo "  NVFS root superblock verified"
	    fi
	    if [ "$WITH_STORAGE" = "true" ] &&
	      ! grep -q "NVFS arena payload ready" "$SERIAL_LOG" 2>/dev/null; then
	      sleep 1
      if ! grep -q "NVFS arena payload ready" "$SERIAL_LOG" 2>/dev/null; then
        echo "FAILED: storage device was requested but NVFS arena payload was not verified" >&2
        print_serial_tail
	        exit 1
	      fi
	    fi
	    if [ "$WITH_STORAGE" = "true" ]; then
	      echo "  NVFS arena payload ready"
	    fi
	    BOOTED=true
    break
  fi
  sleep 1
  WAITED=$((WAITED + 1))
done

if [ "$BOOTED" = "false" ]; then
  echo "FAILED: HTTP bind marker not seen within ${BOOT_TIMEOUT}s" >&2
  print_serial_tail
  exit 1
fi

echo "  HTTP bind detected after ${WAITED}s"

http_response() {
  method="$1"
  path="$2"
  printf '%s %s HTTP/1.0\r\nHost: localhost\r\nConnection: close\r\n\r\n' "$method" "$path" |
    nc -w 5 localhost "${HTTP_PORT}" 2>/dev/null || true
}

http_status_code() {
  line=$(http_response GET "$1" | sed -n '1p')
  set -- $line
  if [ "$#" -ge 2 ]; then
    printf '%s\n' "$2"
  else
    printf '000\n'
  fi
}

http_content_type() {
  http_response GET "$1" | grep -i '^content-type:' | sed -n '1p'
}

https_status_code() {
  if ! command -v openssl >/dev/null 2>&1 || ! command -v timeout >/dev/null 2>&1; then
    printf 'skip\n'
    return
  fi
  line=$(
    printf 'GET /health HTTP/1.0\r\nHost: localhost\r\nConnection: close\r\n\r\n' |
      timeout 5s openssl s_client -quiet -connect "localhost:${HTTPS_PORT}" -servername localhost 2>/dev/null |
      sed -n '1p'
  )
  set -- $line
  if [ "$#" -ge 2 ]; then
    printf '%s\n' "$2"
  else
    printf '000\n'
  fi
}

db_request() {
  body="$1"
  length=${#body}
  printf 'POST /db HTTP/1.0\r\nHost: localhost\r\nContent-Length: %s\r\nConnection: close\r\n\r\n%s' "$length" "$body" |
    nc -w 5 localhost "${HTTP_PORT}" 2>/dev/null || true
}

db_query_response() {
  db_request 'CREATE codex'
  db_request 'INSERT codex answer codex-41'
  db_request 'SELECT codex answer'
}

# ---- run HTTP tests ----
echo "[3/4] Running HTTP smoke tests..."
PASS=0
FAIL=0

# Test 1: HTTP health check
printf '%s' "  GET /health (HTTP)... "
HTTP_CODE=$(http_status_code /health)
if [ "$HTTP_CODE" = "200" ]; then
  echo "PASS (${HTTP_CODE})"
  PASS=$((PASS + 1))
else
  echo "FAIL (${HTTP_CODE})"
  FAIL=$((FAIL + 1))
fi

# Test 2: HTTP root page
printf '%s' "  GET / (HTTP)... "
HTTP_CODE=$(http_status_code /)
if [ "$HTTP_CODE" = "200" ]; then
  echo "PASS (${HTTP_CODE})"
  PASS=$((PASS + 1))
else
  echo "FAIL (${HTTP_CODE})"
  FAIL=$((FAIL + 1))
fi

# Test 3: HTTPS health check (skip TLS verification for self-signed cert)
printf '%s' "  GET /health (HTTPS)... "
HTTP_CODE=$(https_status_code)
if [ "$EXPECT_HTTP_ONLY" = "true" ]; then
  echo "SKIP (HTTP-only gate; RISC-V TLS not production-ready)"
elif [ "$HTTP_CODE" = "skip" ]; then
  echo "SKIP (openssl or timeout unavailable)"
elif [ "$HTTP_CODE" = "200" ]; then
  echo "PASS (${HTTP_CODE})"
  PASS=$((PASS + 1))
else
  echo "FAIL (${HTTP_CODE})"
  FAIL=$((FAIL + 1))
fi

# Test 4: Health endpoint returns JSON
printf '%s' "  GET /health content-type... "
CONTENT_TYPE=$(http_content_type /health)
if echo "$CONTENT_TYPE" | grep -qi "json"; then
  echo "PASS (JSON)"
  PASS=$((PASS + 1))
else
  echo "FAIL (expected JSON, got: ${CONTENT_TYPE})"
  FAIL=$((FAIL + 1))
fi

# Test 5: Root page returns HTML
printf '%s' "  GET / content-type... "
CONTENT_TYPE=$(http_content_type /)
if echo "$CONTENT_TYPE" | grep -qi "html"; then
  echo "PASS (HTML)"
  PASS=$((PASS + 1))
else
  echo "FAIL (expected HTML, got: ${CONTENT_TYPE})"
  FAIL=$((FAIL + 1))
fi

if [ "$WITH_DB" = "true" ]; then
  printf '%s' "  DB CREATE/INSERT/SELECT... "
  DB_RESPONSE=$(db_query_response)
  printf '%s\n' "$DB_RESPONSE" > "$DB_QUERY_LOG"
  if echo "$DB_RESPONSE" | grep -q 'OK CREATE' &&
    echo "$DB_RESPONSE" | grep -q 'OK INSERT' &&
    echo "$DB_RESPONSE" | grep -q 'codex-41'; then
    echo "PASS (codex-41)"
    PASS=$((PASS + 1))
  else
    echo "FAIL (expected DB query result, got: ${DB_RESPONSE})"
    FAIL=$((FAIL + 1))
  fi
fi

# ---- report ----
echo ""
echo "[4/4] Results: ${PASS} passed, ${FAIL} failed out of $((PASS + FAIL)) tests"

if [ "$FAIL" -gt 0 ]; then
  echo "FAILED"
  exit 1
fi

if [ "$EXPECT_HTTP_ONLY" = "true" ]; then
  echo "HTTP-only PASSED"
else
  echo "ALL PASSED"
fi
exit 0
