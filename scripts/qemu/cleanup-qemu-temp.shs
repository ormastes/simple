#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
VM_DIR="${ROOT_DIR}/build/freebsd/vm"

remove_if_exists() {
    if [ -e "$1" ] || [ -L "$1" ]; then
        rm -rf -- "$1"
        printf 'removed %s\n' "$1"
    fi
}

# Repo-local disposable QEMU artifacts. Keep the downloaded base qcow2 image.
remove_if_exists "${VM_DIR}/qemu.pid"
remove_if_exists "${VM_DIR}/qemu-serial.log"
remove_if_exists "${VM_DIR}/freebsd-cloudinit-seed.iso"
remove_if_exists "${VM_DIR}"/*.overlay.qcow2
remove_if_exists "${VM_DIR}"/*.seed.iso
remove_if_exists "${VM_DIR}"/*.tmp

# Host temp artifacts created by older/manual QEMU flows.
remove_if_exists "/tmp/freebsd-qemu.pid"
remove_if_exists "/tmp/qemu_test_build.log"
remove_if_exists "/tmp/freebsd-cloudinit-seed.iso"

# Remove the temp directory only if it no longer contains a retained base image.
if [ -d "${VM_DIR}" ]; then
    if find "${VM_DIR}" -mindepth 1 -maxdepth 1 ! -name '*.qcow2' | grep -q .; then
        :
    elif ! find "${VM_DIR}" -mindepth 1 -maxdepth 1 | grep -q .; then
        rmdir "${VM_DIR}" 2>/dev/null || true
    fi
fi
