#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
VM_DIR="${ROOT_DIR}/build/freebsd/vm"

mkdir -p "${VM_DIR}"

printf '%s\n' "Prepared QEMU temp layout:"
printf '  %s\n' "${VM_DIR}/"
printf '  %s\n' "${VM_DIR}/qemu.pid"
printf '  %s\n' "${VM_DIR}/qemu-serial.log"
printf '  %s\n' "${VM_DIR}/freebsd-cloudinit-seed.iso"
printf '  %s\n' "/tmp/freebsd-qemu.pid"
printf '  %s\n' "/tmp/qemu_test_build.log"
