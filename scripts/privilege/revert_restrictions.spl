# Revert directory write restrictions
# Restores original permissions saved by apply_restrictions.spl
#
# Usage: sudo bin/simple run scripts/privilege/revert_restrictions.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn dir_exists(path: text) -> bool:
    val (_, _, code) = shell("test -d '{path}'")
    code == 0

fn main():
    val state_file = "scripts/privilege/.permissions_backup"

    print "=== Simple Project Directory Protection - Revert ==="
    print ""

    val euid = shell_output("id -u")
    if euid != "0":
        print "Error: This script must be run with sudo"
        rt_exit(1)

    if not rt_file_exists(state_file):
        print "Error: No backup file found at {state_file}"
        print "Restrictions may not have been applied, or backup was deleted."
        rt_exit(1)

    val content = rt_file_read_text(state_file) ?? ""
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if line.len() > 0 and not line.starts_with("#"):
            val parts = line.split_whitespace()
            if parts.len() >= 2:
                val path = parts[0]
                val perms = parts[1]
                if rt_file_exists(path) or dir_exists(path):
                    shell("chmod {perms} {path} 2>/dev/null || true")
                    if parts.len() >= 4:
                        val owner = parts[2]
                        val group = parts[3]
                        shell("chown {owner}:{group} {path} 2>/dev/null || true")
                    print "  Restored: {path}"
        i = i + 1

    shell("rm -f {state_file}")

    print ""
    print "=== Restrictions Reverted Successfully ==="
    print ""
    print "All directories restored to original permissions."
    print "To re-apply: sudo bin/simple run scripts/privilege/apply_restrictions.spl"
