# Apply directory write restrictions (cross-platform)
# Prevents creating/deleting files directly in specified directories
# while allowing modifications and full access to subdirectories
#
# Usage:
#   Linux/macOS: sudo bin/simple run scripts/privilege/apply_restrictions.spl
#   Windows: Run as Administrator

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn dir_exists(path: text) -> bool:
    val (_, _, code) = shell("test -d '{path}'")
    code == 0

fn main():
    val os = shell_output("uname -s | tr '[:upper:]' '[:lower:]'")
    val state_file = "scripts/privilege/.permissions_backup"

    print "=== Simple Project Directory Protection ==="
    print "OS detected: {os}"
    print ""

    val euid = shell_output("id -u")
    if euid != "0":
        print "Error: This script must be run with sudo"
        rt_exit(1)

    if rt_file_exists(state_file):
        print "Restrictions already applied. Run revert_restrictions.spl first."
        rt_exit(1)

    val dirs_to_lock = [".", "doc", "examples", "scripts"]

    print "Applying restrictions to prevent file creation/deletion in:"
    var i = 0
    while i < dirs_to_lock.len():
        print "  - {dirs_to_lock[i]}/"
        i = i + 1
    print ""

    # Save permissions and apply restrictions
    print "Saving current permissions..."
    var backup = "# Original permissions backup\n"
    var j = 0
    while j < dirs_to_lock.len():
        val d = dirs_to_lock[j]
        if d == "." or dir_exists(d):
            val perms = shell_output("stat -c '%a %U %G' {d} 2>/dev/null || stat -f '%Lp %Su %Sg' {d} 2>/dev/null")
            backup = backup + "{d} {perms}\n"
        j = j + 1
    rt_file_write_text(state_file, backup)

    var k = 0
    while k < dirs_to_lock.len():
        val d = dirs_to_lock[k]
        if d == "." or dir_exists(d):
            shell("chmod a-w {d}")
            print "  {d}/: removed write permission"
        k = k + 1

    print ""
    print "=== Restrictions Applied Successfully ==="
    print ""
    print "Effects:"
    print "  Cannot create new files/directories in restricted directories"
    print "  Cannot delete files/directories in restricted directories"
    print "  CAN modify existing files (file permissions unchanged)"
    print "  CAN create/delete in subdirectories"
    print ""
    print "To revert: sudo bin/simple run scripts/privilege/revert_restrictions.spl"
