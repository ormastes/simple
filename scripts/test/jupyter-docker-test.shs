#!/bin/sh
# Jupyter Kernel Docker E2E Test
#
# Builds a Docker image with Jupyter + Simple kernel, starts a container,
# runs the server E2E check inside it, and verifies all checks pass.
#
# Usage: sh scripts/test/jupyter-docker-test.shs
#
# Requirements:
#   - docker (or podman)
#   - deployed Simple runtime (`bin/simple` or `bin/release/<platform>/simple`)

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

IMAGE_NAME="simple-jupyter-test"
CONTAINER_NAME="simple-jupyter-test-$$"
DOCKERFILE="$PROJECT_ROOT/tools/docker/Dockerfile.jupyter-test"

cd "$PROJECT_ROOT"

find_simple_runtime() {
    if [ -x "$PROJECT_ROOT/bin/simple" ]; then
        printf '%s' "$PROJECT_ROOT/bin/simple"
        return 0
    fi
    for candidate in "$PROJECT_ROOT"/bin/release/simple "$PROJECT_ROOT"/bin/release/*/simple; do
        if [ -x "$candidate" ]; then
            printf '%s' "$candidate"
            return 0
        fi
    done
    return 1
}

# Check prerequisites
SIMPLE_RUNTIME="$(find_simple_runtime || true)"
if [ -z "$SIMPLE_RUNTIME" ]; then
    echo "ERROR: no deployed Simple runtime found. Build with: bin/simple build --release" >&2
    exit 1
fi

if [ ! -f "$DOCKERFILE" ]; then
    echo "ERROR: Dockerfile not found at $DOCKERFILE" >&2
    exit 1
fi

echo "=== Jupyter Docker E2E Test ==="
echo "  Project root: $PROJECT_ROOT"
echo "  Dockerfile:   $DOCKERFILE"

# Build Docker image
echo ""
echo "[1/3] Building Docker image..."
docker build \
    -t "$IMAGE_NAME" \
    -f "$DOCKERFILE" \
    "$PROJECT_ROOT" 2>&1 | tail -5

# Run test inside container
echo ""
echo "[2/3] Running E2E test in container..."
docker run \
    --name "$CONTAINER_NAME" \
    --rm \
    "$IMAGE_NAME" 2>&1

EXIT_CODE=$?

# Report
echo ""
echo "[3/3] Cleanup..."

if [ $EXIT_CODE -eq 0 ]; then
    echo ""
    echo "=== ALL CHECKS PASSED ==="
    exit 0
else
    echo ""
    echo "=== DOCKER E2E FAILED (exit $EXIT_CODE) ==="
    exit 1
fi
