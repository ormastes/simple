#!/bin/sh
# Jupyter Kernel Docker E2E Test
#
# Builds the jupyter-test Docker image and runs the full E2E test inside it:
#   1. Starts a real Jupyter notebook server
#   2. Registers the Simple kernel
#   3. Executes hello-world cells via HTTP API + ZMQ
#   4. Verifies output matches expected values
#
# Usage:
#   sh scripts/test/jupyter-docker-test.shs
#
# Requires: docker (or podman), bin/release/simple must exist

set -e

IMAGE_NAME="simple-jupyter-test:latest"

# Detect project root
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$PROJECT_ROOT"

# Check prerequisites
if [ ! -x "bin/release/simple" ]; then
    echo "ERROR: bin/release/simple not found. Build with: bin/simple build --release"
    exit 1
fi

# Detect container runtime
if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    RUNTIME=docker
elif command -v podman >/dev/null 2>&1; then
    RUNTIME=podman
else
    echo "ERROR: docker or podman required"
    exit 1
fi

echo "=== Jupyter Kernel Docker E2E Test ==="
echo "  Runtime: $RUNTIME"
echo "  Project: $PROJECT_ROOT"
echo ""

# Build the image
echo "[1/2] Building Docker image..."
$RUNTIME build \
    -t "$IMAGE_NAME" \
    -f tools/docker/Dockerfile.jupyter-test \
    . 2>&1 | tail -5

echo ""

# Run the test
echo "[2/2] Running E2E test inside container..."
$RUNTIME run \
    --rm \
    --memory=2g \
    --tmpfs /tmp:size=256m \
    "$IMAGE_NAME"

EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    echo ""
    echo "=== DOCKER E2E TEST PASSED ==="
else
    echo ""
    echo "=== DOCKER E2E TEST FAILED (exit $EXIT_CODE) ==="
fi

exit $EXIT_CODE
