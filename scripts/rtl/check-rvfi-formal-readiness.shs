#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
RTL_DIR="${RTL_DIR:-$ROOT_DIR/examples/09_embedded/fpga_riscv/rtl}"
CORE_VHDL="${CORE_VHDL:-${RV32I_CORE_VHDL:-$RTL_DIR/rv32i_core.vhd}}"
FORMAL_HARNESS="${FORMAL_HARNESS:-}"
FORMAL_SBY="${FORMAL_SBY:-}"
FORMAL_MANIFEST="${FORMAL_MANIFEST:-}"
REQUIRE_RVFI="${REQUIRE_RVFI:-0}"

if [ ! -f "$CORE_VHDL" ]; then
    echo "ERROR: RV32I core VHDL not found: $CORE_VHDL" >&2
    exit 1
fi

missing=""
for port in \
    rvfi_valid rvfi_order rvfi_insn rvfi_trap \
    rvfi_rs1_addr rvfi_rs2_addr rvfi_rs1_rdata rvfi_rs2_rdata \
    rvfi_rd_addr rvfi_rd_wdata rvfi_pc_rdata rvfi_pc_wdata \
    rvfi_mem_addr rvfi_mem_rmask rvfi_mem_wmask rvfi_mem_rdata rvfi_mem_wdata
do
    if ! grep -Eq "^[[:space:]]*${port}[[:space:]]*:" "$CORE_VHDL"; then
        missing="${missing}${port}
"
    fi
done

if [ -n "$missing" ]; then
    echo "RVFI readiness: missing RVFI ports in $CORE_VHDL"
    printf '%s' "$missing" | sed 's/^/  - /'
    if [ "$REQUIRE_RVFI" = "1" ]; then
        echo "ERROR: RVFI formal flow requires all RVFI ports" >&2
        exit 1
    fi
    echo "SKIP: RVFI formal checks require an RVFI-enabled core"
    exit 0
fi

echo "PASS: RVFI port manifest present in $CORE_VHDL"

if [ -n "$FORMAL_HARNESS" ] || [ -n "$FORMAL_SBY" ] || [ -n "$FORMAL_MANIFEST" ]; then
    core_base="$(basename "$CORE_VHDL" .vhd)"
    harness_base="${core_base}_formal.vhd"
    sby_base="${core_base}.sby"

    test -n "$FORMAL_HARNESS" && test -s "$FORMAL_HARNESS" || { echo "ERROR: formal harness missing or empty: $FORMAL_HARNESS" >&2; exit 1; }
    test -n "$FORMAL_SBY" && test -s "$FORMAL_SBY" || { echo "ERROR: formal sby missing or empty: $FORMAL_SBY" >&2; exit 1; }
    test -n "$FORMAL_MANIFEST" && test -s "$FORMAL_MANIFEST" || { echo "ERROR: formal manifest missing or empty: $FORMAL_MANIFEST" >&2; exit 1; }

    grep -Eq "^[[:space:]]*entity[[:space:]]+${core_base}_formal[[:space:]]+is[[:space:]]*$" "$FORMAL_HARNESS" || { echo "ERROR: formal harness missing top entity for $core_base" >&2; exit 1; }
    grep -Eq '^[[:space:]]*mode[[:space:]]+prove[[:space:]]*$' "$FORMAL_SBY" || { echo "ERROR: formal sby missing mode prove" >&2; exit 1; }
    grep -Eq '^[[:space:]]*\[engines\][[:space:]]*$' "$FORMAL_SBY" || { echo "ERROR: formal sby missing engines section" >&2; exit 1; }
    grep -Eq '^[[:space:]]*smtbmc[[:space:]]*$' "$FORMAL_SBY" || { echo "ERROR: formal sby missing smtbmc engine" >&2; exit 1; }
    grep -Eq '^[[:space:]]*\[script\][[:space:]]*$' "$FORMAL_SBY" || { echo "ERROR: formal sby missing script section" >&2; exit 1; }
    grep -Eq "^[[:space:]]*prep[[:space:]]+-top[[:space:]]+${core_base}_formal[[:space:]]*$" "$FORMAL_SBY" || { echo "ERROR: formal sby missing formal top prep" >&2; exit 1; }
    grep -Eq '^[[:space:]]*\[files\][[:space:]]*$' "$FORMAL_SBY" || { echo "ERROR: formal sby missing files section" >&2; exit 1; }
    awk -v file="$(basename "$CORE_VHDL")" 'BEGIN { found = 0 } /^[[:space:]]*(#|$)/ { next } { path = $1; sub(/^.*\//, "", path); if (path == file) found = 1 } END { exit(found ? 0 : 1) }' "$FORMAL_SBY" || { echo "ERROR: formal sby missing core file" >&2; exit 1; }
    awk -v file="$harness_base" 'BEGIN { found = 0 } /^[[:space:]]*(#|$)/ { next } { path = $1; sub(/^.*\//, "", path); if (path == file) found = 1 } END { exit(found ? 0 : 1) }' "$FORMAL_SBY" || { echo "ERROR: formal sby missing harness file" >&2; exit 1; }
    grep -Eq "^[[:space:]]*runner[[:space:]]*=[[:space:]]*\"sby -f ${sby_base}\"[[:space:]]*$" "$FORMAL_MANIFEST" || { echo "ERROR: formal manifest missing sby runner" >&2; exit 1; }
    echo "PASS: formal runner artifacts present for $core_base"
fi

if ! command -v sby >/dev/null 2>&1; then
    if [ "$REQUIRE_RVFI" = "1" ]; then
        echo "ERROR: sby not found" >&2
        exit 1
    fi
    echo "SKIP: sby not found"
    exit 0
fi

echo "READY: riscv-formal SymbiYosys runner can be wired for RV32I instruction checks"
