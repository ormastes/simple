#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
RTL_DIR="${RTL_DIR:-$ROOT_DIR/examples/09_embedded/fpga_riscv/rtl}"
WORK_DIR="${GHDL_WORK_DIR:-$ROOT_DIR/build/rtl/ghdl-work}"
REQUIRE_TOOLS="${REQUIRE_TOOLS:-0}"

if ! command -v ghdl >/dev/null 2>&1; then
    if [ "$REQUIRE_TOOLS" = "1" ]; then
        echo "ERROR: ghdl not found" >&2
        exit 1
    fi
    echo "SKIP: ghdl not found"
    exit 0
fi

rm -rf "$WORK_DIR"
mkdir -p "$WORK_DIR"

echo "GHDL: analyzing packages in $RTL_DIR"
find "$RTL_DIR" -maxdepth 1 -type f -name '*pkg*.vhd' | sort | while IFS= read -r file; do
    echo "  package $(basename "$file")"
    ghdl -a --std=08 --workdir="$WORK_DIR" "$file"
done

echo "GHDL: analyzing portable smoke design units in $RTL_DIR"
for design in addition_demo.vhd alu.vhd decoder.vhd regfile.vhd rv32i_core.vhd; do
    if [ -f "$RTL_DIR/$design" ]; then
        echo "  design $design"
        ghdl -a --std=08 --workdir="$WORK_DIR" "$RTL_DIR/$design"
    fi
done

echo "GHDL: elaborating rv32i_core"
ghdl -e --std=08 --workdir="$WORK_DIR" rv32i_core

echo "PASS: GHDL analysis completed"
