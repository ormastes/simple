#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/metal_engine2d_framebuffer_readback_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/metal_engine2d_framebuffer_readback_$(date -u +%F).md}"
ENV_PATH="$BUILD_DIR/evidence.env"
BACKEND_PATH="src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl"
SFFI_PATH="src/lib/nogc_sync_mut/io/metal_sffi.spl"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$ENV_PATH" "$REPORT_PATH"

platform="$(uname -s 2>/dev/null || echo unknown)"
read_pixels_mirror=false
download_binding=false

if grep -q 'self.mirror.read_pixels()' "$BACKEND_PATH"; then
    read_pixels_mirror=true
fi

if grep -q 'fn metal_sffi_buffer_download' "$SFFI_PATH"; then
    download_binding=true
fi

status=unavailable
reason=metal-requires-macos
exit_code=0

if [ "$platform" = "Darwin" ]; then
    status=fail
    reason=missing-native-metal-framebuffer-readback-proof
    exit_code=1
fi

if [ "$read_pixels_mirror" != "true" ]; then
    status=fail
    reason=metal-engine2d-read-pixels-contract-changed-review-required
    exit_code=1
fi

{
    echo "metal_engine2d_framebuffer_readback_status=$status"
    echo "metal_engine2d_framebuffer_readback_reason=$reason"
    echo "metal_engine2d_framebuffer_readback_platform=$platform"
    echo "metal_engine2d_framebuffer_readback_backend=$BACKEND_PATH"
    echo "metal_engine2d_framebuffer_readback_sffi=$SFFI_PATH"
    echo "metal_engine2d_framebuffer_cpu_mirror_readback_used=$read_pixels_mirror"
    echo "metal_engine2d_framebuffer_gpu_download_binding_present=$download_binding"
    echo "metal_engine2d_framebuffer_gpu_download_attempted=false"
    echo "metal_engine2d_framebuffer_gpu_readback_available=false"
    echo "metal_engine2d_framebuffer_exact_gpu_claimed=false"
    echo "metal_engine2d_framebuffer_blur_or_tolerance_used=false"
    echo "metal_engine2d_framebuffer_future_native_proof_required=true"
    echo "metal_engine2d_framebuffer_required_future_gate=darwin-native-compiled-metal-download-vs-cpu-mirror"
} >"$ENV_PATH"

{
    echo "# Metal Engine2D Framebuffer Readback Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- platform: $platform"
    echo "- backend: $BACKEND_PATH"
    echo "- sffi: $SFFI_PATH"
    echo "- cpu_mirror_readback_used: $read_pixels_mirror"
    echo "- gpu_download_binding_present: $download_binding"
    echo "- gpu_download_attempted: false"
    echo "- gpu_readback_available: false"
    echo "- exact_gpu_claimed: false"
    echo "- blur_or_tolerance_used: false"
    echo "- future_native_proof_required: true"
    echo "- required_future_gate: darwin-native-compiled-metal-download-vs-cpu-mirror"
    echo
    echo "This report is intentionally fail-closed: on non-macOS hosts it records"
    echo "Metal as unavailable, and on macOS it fails until a native compiled proof"
    echo "downloads the Metal framebuffer and compares it against the CPU mirror for"
    echo "a deterministic vector-font/Engine2D scene."
    echo
    echo "## Evidence"
    sed 's/^/- /' "$ENV_PATH"
} >"$REPORT_PATH"

cat "$ENV_PATH"
echo "report_path=$REPORT_PATH"
exit "$exit_code"
