#!/usr/bin/env bash
# Run linter with full verbose output
# Usage: scripts/lint_verbose.shs

set -euo pipefail

echo "=== Lint (verbose) ==="
echo ""

bin/simple build lint 2>&1

EXIT=$?
echo ""
if [ $EXIT -eq 0 ]; then
    echo "=== Lint passed ==="
else
    echo "=== Lint FAILED (exit $EXIT) ==="
fi
exit $EXIT
