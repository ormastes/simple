# Build libspl_torch.so from torch_ffi.cpp
#
# Usage: bin/simple run scripts/build/build_torch_ffi.spl
#
# Requires: PyTorch 2.x, clang++ (or g++), CUDA toolkit

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_env_get(key: text) -> text
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn shell_ok(command: text) -> bool:
    val (_, _, code) = shell(command)
    code == 0

fn main():
    val repo_root = shell_output("pwd")

    val torch_root = shell_output("python3 -c 'import torch; import os; print(os.path.dirname(torch.__file__))' 2>/dev/null")
    if torch_root.len() == 0:
        print "ERROR: PyTorch not found. Install with: pip install torch"
        rt_exit(1)

    print "Found libtorch at: {torch_root}"
    print "Repo root: {repo_root}"

    val torch_inc1 = "{torch_root}/include"
    val torch_inc2 = "{torch_root}/include/torch/csrc/api/include"
    val torch_lib = "{torch_root}/lib"

    shell("mkdir -p {repo_root}/build")

    val output = "{repo_root}/build/libspl_torch.so"
    val source = "{repo_root}/src/runtime/torch_ffi.cpp"

    if not rt_file_exists(source):
        print "ERROR: Source file not found: {source}"
        rt_exit(1)

    var cxx = rt_env_get("CXX") ?? ""
    if cxx.len() == 0:
        cxx = "clang++"
    if not shell_ok("command -v {cxx} >/dev/null 2>&1"):
        cxx = "g++"

    print "Compiling with: {cxx}"
    print "Output: {output}"

    val cmd = "{cxx} -shared -fPIC -std=c++17 -O2 -I {repo_root}/src/runtime -I {torch_inc1} -I {torch_inc2} -L {torch_lib} -Wl,-rpath,{torch_lib} -ltorch -ltorch_cpu -ltorch_cuda -lc10 -lc10_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -o {output} {source}"
    val (_, _, code) = shell(cmd)
    if code != 0:
        print "Build failed"
        rt_exit(1)

    print ""
    print "SUCCESS: Built {output}"
    print ""
    print "Run torch tests with GPU support:"
    print "  LD_PRELOAD=build/libspl_torch.so bin/simple test test/unit/lib/torch_spec.spl"
    print ""
    print "Monitor GPU during test:"
    print "  watch -n 0.5 nvidia-smi"
