# Build Bootstrap Package
# Creates a minimal runtime-only installation package
#
# Usage: bin/simple run scripts/build/build_bootstrap.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn dir_exists(path: text) -> bool:
    val (_, _, code) = shell("test -d '{path}'")
    code == 0

fn main():
    print "Building Simple Bootstrap Package"
    print ""

    val target = rt_env_get("TARGET") ?? ""
    var os_name = shell_output("uname -s | tr '[:upper:]' '[:lower:]'")
    var arch_name = shell_output("uname -m")

    # Normalize arch
    if arch_name == "amd64":
        arch_name = "x86_64"
    if arch_name == "aarch64" or arch_name == "arm64":
        arch_name = "arm64"

    if target.len() > 0:
        print "Using TARGET: {target}"
        val parts = target.split("-")
        if parts.len() > 0:
            val raw_arch = parts[0]
            if raw_arch == "aarch64":
                arch_name = "arm64"
            else:
                arch_name = raw_arch
        if target.contains("linux"):
            os_name = "linux"
        if target.contains("apple") or target.contains("darwin"):
            os_name = "darwin"
        if target.contains("windows"):
            os_name = "windows"

    val platform = "{os_name}-{arch_name}"
    print "Platform: {platform}"
    print ""

    var version = "0.0.0"
    if rt_file_exists("VERSION"):
        version = (rt_file_read_text("VERSION") ?? "0.0.0").trim()

    print "Version: {version}"
    print ""

    val output = "simple-bootstrap-{version}-{platform}.spk"
    var runtime_path = "rust/target/release-opt/simple"
    if target.len() > 0:
        runtime_path = "rust/target/{target}/release-opt/simple"

    val simple_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
    var use_simple_build = false

    if simple_bootstrap.len() > 0 and rt_file_exists(simple_bootstrap):
        print "Using previous Simple bootstrap binary for self-hosting build"
        val (_, _, code) = shell("{simple_bootstrap} src/app/build/main.spl --bootstrap --quiet 2>&1")
        if code == 0:
            print "Self-hosting build succeeded"
            use_simple_build = true
        else:
            print "Self-hosting build failed, falling back to cargo"

    if not use_simple_build:
        if not dir_exists("rust"):
            print "Error: Cannot build runtime - no rust/ directory"
            rt_exit(1)
        print "Building with cargo (bootstrap from scratch)..."
        var cargo_args = "build --profile release-opt --quiet --manifest-path rust/Cargo.toml"
        if target.len() > 0:
            cargo_args = cargo_args + " --target " + target
        val (_, _, code) = shell("cargo {cargo_args}")
        if code != 0:
            print "Cargo build failed"
            rt_exit(1)

    if not rt_file_exists(runtime_path):
        print "Error: Runtime binary not found at {runtime_path}"
        rt_exit(1)

    print "Runtime built"
    print ""

    val tmp_dir = "/tmp/simple-bootstrap-" + shell_output("echo $$")
    shell("rm -rf {tmp_dir}")
    shell("mkdir -p {tmp_dir}/bin {tmp_dir}/lib/simple/stdlib {tmp_dir}/lib/simple/app")

    print "Copying runtime binary..."
    shell("cp {runtime_path} {tmp_dir}/bin/simple")
    shell("chmod 755 {tmp_dir}/bin/simple")

    print "Copying stdlib files..."
    val stdlib_files = ["core.spl", "io.spl", "json.spl", "http.spl"]
    var copied = 0
    var si = 0
    while si < stdlib_files.len():
        val f = stdlib_files[si]
        if rt_file_exists("src/lib/{f}"):
            shell("cp src/lib/{f} {tmp_dir}/lib/simple/stdlib/")
            copied = copied + 1
        if rt_file_exists("src/lib/src/{f}"):
            shell("cp src/lib/src/{f} {tmp_dir}/lib/simple/stdlib/")
            copied = copied + 1
        si = si + 1

    if copied == 0 and dir_exists("src/lib/src"):
        shell("cp -r src/lib/src/. {tmp_dir}/lib/simple/stdlib/")

    print "Copying essential apps..."
    val apps = ["cli", "run", "compile", "check", "repl"]
    var ai = 0
    while ai < apps.len():
        val app = apps[ai]
        if dir_exists("src/app/{app}"):
            shell("cp -r src/app/{app} {tmp_dir}/lib/simple/app/")
        ai = ai + 1

    print "Generating manifest..."
    val commit = shell_output("git rev-parse --short HEAD 2>/dev/null || echo unknown")
    val timestamp = shell_output("date -u +'%Y-%m-%dT%H:%M:%SZ'")
    val runtime_size = shell_output("stat -c%s {runtime_path} 2>/dev/null || stat -f%z {runtime_path} 2>/dev/null || echo 0")

    var manifest = "package:\n"
    manifest = manifest + "  name: simple-bootstrap\n"
    manifest = manifest + "  version: {version}\n"
    manifest = manifest + "  type: bootstrap\n"
    manifest = manifest + "  platform: {platform}\n\n"
    manifest = manifest + "build:\n"
    manifest = manifest + "  timestamp: {timestamp}\n"
    manifest = manifest + "  profile: release-opt\n"
    manifest = manifest + "  commit: {commit}\n\n"
    manifest = manifest + "runtime:\n"
    manifest = manifest + "  binary: simple\n"
    manifest = manifest + "  size: {runtime_size}\n\n"
    manifest = manifest + "install:\n"
    manifest = manifest + "  default_prefix: ~/.local\n"
    manifest = manifest + "  system_prefix: /usr/local\n"

    rt_file_write_text(tmp_dir + "/manifest.sdn", manifest)

    print "Creating SPK archive..."
    shell("tar -czf {output} -C {tmp_dir} .")
    shell("rm -rf {tmp_dir}")

    print ""
    print "Bootstrap package built successfully"
    print ""
    print "Package:  {output}"
    print "Platform: {platform}"
    print "Version:  {version}"
    print ""
    print "To install:"
    print "  tar -xzf {output} -C /tmp/simple-test"
