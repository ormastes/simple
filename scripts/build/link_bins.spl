# Link binaries from bin/rust/ to bin/simple/ (cross-platform)
# On Windows: creates symlinks (requires admin or developer mode)
# On Unix: creates symlinks
#
# Usage: bin/simple run scripts/build/link_bins.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn main():
    val os = shell_output("uname -s | tr '[:upper:]' '[:lower:]'")
    val bin_rust = "bin/rust"
    val bin_simple = "bin/simple"

    print "Creating binary symlinks..."

    shell("mkdir -p {bin_simple}")

    var ext = ""
    if os == "windows" or os.contains("mingw") or os.contains("msys"):
        ext = ".exe"

    val binaries = ["simple", "simple-fmt", "simple-lint", "simple-test", "smh_coverage"]

    var i = 0
    while i < binaries.len():
        val name = binaries[i] + ext
        val source = "{bin_rust}/{name}"
        val target = "{bin_simple}/{name}"

        if rt_file_exists(source):
            print "  Linking {name}..."
            shell("rm -f {target}")
            shell("ln -sf {source} {target}")
        else:
            print "  Warning: {source} not found, skipping"

        i = i + 1

    print "Binary links created in {bin_simple}"
    print ""
    print "Add to your PATH:"
    print "  export PATH=\"{bin_simple}:$PATH\""
