#!/bin/bash
# SStack Autonomous Orchestrator
# Reads tasks from .sstack/TASKS.md, runs the full SStack pipeline for each,
# and loops forever. Handles features, TODOs, bugs, and code-quality tasks.
#
# Usage: scripts/sstack-orchestrator.shs
#   Runs in foreground. Use nohup or tmux for background operation.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

TASKS_FILE="$PROJECT_ROOT/.sstack/TASKS.md"
AGENT_DIR="$PROJECT_ROOT/.agent"
STATUS_FILE="$AGENT_DIR/STATUS.json"
PID_FILE="$AGENT_DIR/pid"
HISTORY_LOG="$AGENT_DIR/history.log"
AGENT_LOG="$AGENT_DIR/agent.log"

SLEEP_INTERVAL=600      # seconds to sleep when no tasks
HEARTBEAT_INTERVAL=30   # seconds between heartbeat writes
MAX_TURNS=25            # max claude turns per task

# --- Helpers ---

now_iso() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

log() {
    local ts
    ts="$(now_iso)"
    echo "[$ts] $*" | tee -a "$AGENT_LOG"
}

# Emit a JSONL event for the LLM Agent Dashboard.
# Usage: emit_event <type> <task> <phase> [extra_json_fields]
# extra must be valid JSON key-value pairs ending with a comma, e.g. '"role":"Engineer",'
emit_event() {
    local type="$1" task="$2" phase="$3" extra="${4:-}"
    mkdir -p "$AGENT_DIR/events"
    local escaped_task
    escaped_task="$(printf '%s' "$task" | sed 's/"/\\"/g')"
    local phase_field=""
    if [[ -n "$phase" ]]; then
        phase_field="\"phase\":\"$phase\","
    fi
    printf '{"type":"%s","agent_id":"sstack","task":"%s",%s%s"timestamp":"%s"}\n' \
        "$type" "$escaped_task" "$phase_field" "$extra" "$(now_iso)" \
        >> "$AGENT_DIR/events/sstack.jsonl"
}

json_string() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    value="${value//$'\r'/\\r}"
    value="${value//$'\t'/\\t}"
    printf '"%s"' "$value"
}

write_status() {
    local state="$1"
    local task="${2:-}"
    local tasks_remaining="${3:-0}"
    local claude_pid="${4:-null}"
    cat > "$STATUS_FILE" <<EOJSON
{
  "state": "$state",
  "task": $(json_string "$task"),
  "pid": $$,
  "claude_pid": $claude_pid,
  "tasks_remaining": $tasks_remaining,
  "last_heartbeat": "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
}
EOJSON
}

history_append() {
    local result="$1"
    local task="$2"
    local ts
    ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    echo "[$ts] $result: $task" >> "$HISTORY_LOG"
}

# --- Heartbeat ---

HEARTBEAT_PID=""

start_heartbeat() {
    local state="$1"
    local task="$2"
    local remaining="$3"
    local cpid="${4:-null}"
    (
        while true; do
            write_status "$state" "$task" "$remaining" "$cpid"
            sleep "$HEARTBEAT_INTERVAL"
        done
    ) &
    HEARTBEAT_PID=$!
}

stop_heartbeat() {
    if [[ -n "$HEARTBEAT_PID" ]] && kill -0 "$HEARTBEAT_PID" 2>/dev/null; then
        kill "$HEARTBEAT_PID" 2>/dev/null || true
        wait "$HEARTBEAT_PID" 2>/dev/null || true
    fi
    HEARTBEAT_PID=""
}

# --- Cleanup trap ---

cleanup() {
    log "Orchestrator exiting (PID $$)"
    stop_heartbeat
    write_status "crashed" "" 0 null
    rm -f "$PID_FILE"
}
trap cleanup EXIT

# --- Task parsing ---

# Extract unchecked tasks from a given section.
# Returns lines like: "section|task description"
parse_tasks() {
    local section=""
    local in_section=false
    while IFS= read -r line; do
        # Detect section headers: ## bugs, ## features, ## todos, ## code-quality
        if [[ "$line" =~ ^##[[:space:]]+(.*) ]]; then
            section="${BASH_REMATCH[1]}"
            section="$(echo "$section" | tr '[:upper:]' '[:lower:]' | xargs)"
            in_section=true
            continue
        fi
        if $in_section; then
            # Unchecked task: - [ ] description
            if [[ "$line" =~ ^-[[:space:]]+\[[[:space:]]\][[:space:]]+(.*) ]]; then
                local desc="${BASH_REMATCH[1]}"
                echo "${section}|${desc}"
            fi
        fi
    done < "$TASKS_FILE"
}

# Sort tasks by priority: bugs > features > todos > code-quality
sort_tasks_by_priority() {
    local -a bugs=() features=() todos=() quality=()
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local section="${line%%|*}"
        case "$section" in
            bugs)         bugs+=("$line") ;;
            features)     features+=("$line") ;;
            todos)        todos+=("$line") ;;
            code-quality) quality+=("$line") ;;
            *)            todos+=("$line") ;;  # fallback
        esac
    done
    for t in "${bugs[@]+"${bugs[@]}"}"; do echo "$t"; done
    for t in "${features[@]+"${features[@]}"}"; do echo "$t"; done
    for t in "${todos[@]+"${todos[@]}"}"; do echo "$t"; done
    for t in "${quality[@]+"${quality[@]}"}"; do echo "$t"; done
}

# Get the next task (highest priority unchecked)
next_task() {
    parse_tasks | sort_tasks_by_priority | head -1
}

# Count remaining unchecked tasks
count_remaining() {
    parse_tasks | wc -l | tr -d ' '
}

# Mark a task done in TASKS.md: - [ ] desc  -->  - [x] desc
mark_task_done() {
    local desc="$1"
    local escaped
    escaped="$(printf '%s\n' "$desc" | sed 's/[&/\]/\\&/g')"
    sed -i "s/^- \[ \] ${escaped}/- [x] ${escaped}/" "$TASKS_FILE"
}

# Mark a task failed in TASKS.md: - [ ] desc  -->  - [!] desc
mark_task_failed() {
    local desc="$1"
    local escaped
    escaped="$(printf '%s\n' "$desc" | sed 's/[&/\]/\\&/g')"
    sed -i "s/^- \[ \] ${escaped}/- [!] ${escaped}/" "$TASKS_FILE"
}

# --- Language detection ---

detect_language() {
    local task_text="$1"

    # 1. Explicit [lang:X] tag in task text
    if [[ "$task_text" =~ \[lang:([a-z_]+)\] ]]; then
        echo "${BASH_REMATCH[1]}"
        return
    fi

    # 2. Project structure detection
    if [[ -f "$PROJECT_ROOT/Cargo.toml" ]]; then
        echo "rust"
        return
    fi
    if [[ -f "$PROJECT_ROOT/package.json" ]]; then
        echo "typescript"
        return
    fi
    if [[ -f "$PROJECT_ROOT/go.mod" ]]; then
        echo "go"
        return
    fi
    if [[ -f "$PROJECT_ROOT/pyproject.toml" ]] || [[ -f "$PROJECT_ROOT/setup.py" ]]; then
        echo "python"
        return
    fi
    if [[ -f "$PROJECT_ROOT/CMakeLists.txt" ]] || [[ -f "$PROJECT_ROOT/Makefile" ]]; then
        echo "c_cpp"
        return
    fi

    # 3. Default
    echo "simple"
}

# --- Main loop ---

main() {
    mkdir -p "$AGENT_DIR"
    touch "$AGENT_LOG" "$HISTORY_LOG"

    # Check for existing orchestrator
    if [[ -f "$PID_FILE" ]]; then
        local old_pid
        old_pid="$(cat "$PID_FILE")"
        if kill -0 "$old_pid" 2>/dev/null; then
            log "ERROR: Orchestrator already running (PID $old_pid). Exiting."
            # Don't trigger cleanup trap for this case
            trap - EXIT
            exit 1
        fi
        log "Stale PID file found (PID $old_pid not running). Overwriting."
    fi
    echo $$ > "$PID_FILE"

    log "SStack Orchestrator started (PID $$)"
    log "Tasks file: $TASKS_FILE"

    if [[ ! -f "$TASKS_FILE" ]]; then
        log "ERROR: Tasks file not found: $TASKS_FILE"
        exit 1
    fi

    while true; do
        local task_line remaining task_section task_desc

        task_line="$(next_task)"
        remaining="$(count_remaining)"

        if [[ -z "$task_line" ]]; then
            log "No tasks remaining. Sleeping ${SLEEP_INTERVAL}s..."
            stop_heartbeat
            start_heartbeat "sleeping" "" 0 null
            sleep "$SLEEP_INTERVAL"
            stop_heartbeat
            continue
        fi

        task_section="${task_line%%|*}"
        task_desc="${task_line#*|}"

        log "Starting task [$task_section]: $task_desc (remaining: $remaining)"
        write_status "working" "$task_desc" "$remaining" null
        emit_event "task_start" "$task_desc" "" "\"tasks_remaining\":$remaining,"

        # Run claude with the SStack skill
        local claude_exit=0
        stop_heartbeat
        start_heartbeat "working" "$task_desc" "$remaining" null

        # Detect language for the task
        local detected_lang
        detected_lang="$(detect_language "$task_desc")"
        log "Detected language: $detected_lang"

        # Build the prompt
        local lang_instruction=""
        if [[ "$detected_lang" != "simple" ]]; then
            lang_instruction=" For Phase 5 (implement) and Phase 6 (refactor), include: Read .claude/agents/lang/${detected_lang}.md for language-specific rules."
        fi
        local prompt="Read .claude/skills/sstack.md and run the full SStack pipeline for: $task_desc${lang_instruction}"

        emit_event "phase_start" "$task_desc" "5-implement" '"role":"Engineer",'

        # Run claude in the project directory
        (
            cd "$PROJECT_ROOT"
            claude --dangerously-skip-permissions -p "$prompt" --max-turns "$MAX_TURNS" \
                >> "$AGENT_LOG" 2>&1
        ) || claude_exit=$?

        stop_heartbeat

        if [[ $claude_exit -eq 0 ]]; then
            log "Task completed successfully: $task_desc"
            mark_task_done "$task_desc"
            history_append "DONE" "$task_desc"
            emit_event "task_complete" "$task_desc" "" '"exit_code":0,'
        else
            log "Task FAILED (exit $claude_exit): $task_desc"
            mark_task_failed "$task_desc"
            history_append "FAIL(exit=$claude_exit)" "$task_desc"
            emit_event "task_failed" "$task_desc" "" "\"exit_code\":$claude_exit,"
        fi

        write_status "idle" "" "$((remaining - 1))" null
    done
}

main "$@"
