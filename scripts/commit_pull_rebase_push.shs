#!/usr/bin/env bash
# JJ commit-fetch-rebase-push workflow — stops on conflict
# Usage: scripts/commit_pull_rebase_push.shs "<commit message>"
#
# Steps: commit → fetch → rebase → check conflicts → bookmark → push
# If any step fails or conflicts are detected, the script stops immediately.

set -euo pipefail

MSG="${1:-}"

# 1. Commit (skip if no message and no changes)
if [ -n "$MSG" ]; then
    echo "=== Step 1: Commit ==="
    jj commit -m "$MSG"
    echo "Committed: $MSG"
elif jj st 2>&1 | grep -q "no changes"; then
    echo "=== Step 1: Commit (skipped — no changes) ==="
else
    echo "ERROR: Working copy has changes but no commit message provided."
    echo "Usage: $0 \"<commit message>\""
    exit 1
fi

# 2. Fetch
echo ""
echo "=== Step 2: Fetch ==="
jj git fetch
echo "Fetch done."

# 3. Rebase
echo ""
echo "=== Step 3: Rebase ==="
jj rebase -d main@origin
echo "Rebase done."

# 4. Check for conflicts
echo ""
echo "=== Step 4: Conflict check ==="
CONFLICTS=$(jj st 2>&1)
if echo "$CONFLICTS" | grep -qi "conflict"; then
    echo "CONFLICT DETECTED — stopping before push."
    echo ""
    echo "$CONFLICTS"
    echo ""
    echo "Resolve conflicts, then run:"
    echo "  jj bookmark set main -r @- && jj git push --bookmark main"
    exit 1
fi
echo "No conflicts."

# 5. Bookmark + Push
echo ""
echo "=== Step 5: Push ==="
jj bookmark set main -r @-
jj git push --bookmark main
echo ""
echo "=== Sync complete ==="
