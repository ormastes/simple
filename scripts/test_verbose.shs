#!/usr/bin/env bash
# Run tests with full verbose output
# Usage: scripts/test_verbose.shs [path/to/spec.spl] [--only-slow]

set -euo pipefail

ARGS="${*}"
echo "=== Test (verbose) ==="
echo "Args: ${ARGS:-all tests}"
echo ""

bin/simple test ${ARGS} 2>&1

EXIT=$?
echo ""
if [ $EXIT -eq 0 ]; then
    echo "=== Tests passed ==="
else
    echo "=== Tests FAILED (exit $EXIT) ==="
fi
exit $EXIT
