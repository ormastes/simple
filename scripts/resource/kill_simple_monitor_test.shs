#!/bin/sh
# Self-check for kill_simple_monitor.shs decision logic.
# Transforms the real script (one pass, all real kills neutralized) and feeds
# synthetic `ps` rows, asserting the kill/spare matrix. No real process is
# signalled. Run: sh scripts/resource/kill_simple_monitor_test.shs
set -eu

DIR=$(dirname "$0")
SRC="$DIR/kill_simple_monitor.shs"
TMP=$(mktemp)
ROWS=$(mktemp)
trap 'rm -f "$TMP" "$ROWS"' EXIT

# Neutralize real kills + side effects, source mock rows, run a single pass.
sed -e 's#ps -eo uid,pid,pcpu,rss,etimes,args --no-headers 2>/dev/null#cat "$MOCK_PS_FILE"#' \
    -e 's#^while true; do#for _one in 1; do#' \
    -e '/sleep "\$CHECK_INTERVAL"/d' \
    -e '/^[[:space:]]*sleep 1$/d' \
    -e 's#kill "\$_pid" 2>/dev/null || true#:#' \
    -e 's#kill -0 "\$_p".*#:#' \
    -e '/^set -eu*$/d;/^set -e$/d' \
    -e 's#echo \$\$ > "\$PIDFILE"#:#' \
    -e 's#trap cleanup INT TERM HUP EXIT#:#' \
    "$SRC" > "$TMP"

# uid pid pcpu rss(KB) etimes args
# simple threshold 24576MB = 25165824KB; generic threshold 64000MB = 67108864KB.
UID_VAL=$(id -u)
cat > "$ROWS" <<'EOF'
__UID__ 1001 5.0 31457280 5 bin/simple test mem_runaway
__UID__ 1002 99.0 1048576 120 bin/simple run cpu_spin
__UID__ 1003 10.0 524288 300 bin/simple test healthy
__UID__ 1004 99.0 31457280 300 bin/simple test claude session
__UID__ 1005 99.0 1048576 300 bin/simple run src/app/cli/native_build_worker.spl bootstrap_worker_cpu
__UID__ 1006 99.0 1048576 300 bin/simple run src/app/cli/native_build_main.spl bootstrap_main_cpu
__UID__ 1007 5.0 31457280 300 bin/simple run src/app/cli/native_build_worker.spl bootstrap_worker_mem
__UID__ 1008 5.0 31457280 300 bin/simple run src/app/cli/native_build_main.spl bootstrap_main_mem
__UID__ 1009 99.0 1048576 120 timeout 30 env SIMPLE_LIB=src /opt/simple/bin/simple test wrapped_cpu_spin
__UID__ 1010 99.0 31457280 300 bin/simple native-build --entry src/app/test_runner_new/main.spl
__UID__ 2002 99.0 1048576 5 bin/simple run cpu_young
__UID__ 3003 99.0 1048576 120 some_other_program busy
__UID__ 3004 1.0 73400320 120 python3 rogue_mem
0 4004 1.0 73400320 120 python3 root_owned
EOF
sed -i "s/__UID__/$UID_VAL/g" "$ROWS"

OUT=$(MOCK_PS_FILE="$ROWS" sh "$TMP" 2>&1 || true)
KILLED=$(printf '%s\n' "$OUT" | sed -n 's/.*Killing.*pid=\([0-9]*\).*/\1/p' | sort -u | tr '\n' ' ')
KILLED=$(echo $KILLED)  # trim

EXPECT="1001 1002 1007 1008 1009 3004"
if [ "$KILLED" = "$EXPECT" ]; then
    echo "PASS kill_simple_monitor: killed [$KILLED] (simple mem, simple cpu, generic mem), spared healthy/protected/native-build/young/root-owned"
    exit 0
fi
echo "FAIL kill_simple_monitor: killed [$KILLED], expected [$EXPECT]" >&2
printf '%s\n' "$OUT" >&2
exit 1
