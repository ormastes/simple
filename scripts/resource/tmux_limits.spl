# Install/uninstall tmux wrapper for automatic resource limits
#
# Usage:
#   bin/simple run scripts/resource/tmux_limits.spl install [memory] [processes]
#   bin/simple run scripts/resource/tmux_limits.spl uninstall
#
# Defaults: 32G memory, 16 processes

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_cli_get_args() -> [text]
extern fn rt_env_get(key: text) -> text
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn detect_shell_config() -> text:
    val shell_name = shell_output("basename $SHELL")
    val home = rt_env_get("HOME") ?? ""
    if shell_name == "zsh":
        return home + "/.zshrc"
    home + "/.bashrc"

fn install(memory: text, processes: text):
    val config_file = detect_shell_config()
    val shell_name = shell_output("basename $SHELL")

    print "=== Install tmux Resource Limits ==="
    print "Shell: {shell_name}"
    print "Config: {config_file}"
    print "Memory limit: {memory}"
    print "Process limit: {processes}"
    print ""

    val content = rt_file_read_text(config_file) ?? ""
    if content.contains("# tmux resource limits"):
        print "Warning: tmux limits already installed in {config_file}"
        print "Run uninstall first to reinstall"
        rt_exit(1)

    shell("cp {config_file} {config_file}.backup")

    var block = "\n# tmux resource limits - added by tmux_limits.spl\n"
    block = block + "export TMUX_MEMORY_LIMIT=\"{memory}\"\n"
    block = block + "export TMUX_PROCESS_LIMIT=\"{processes}\"\n"
    block = block + "export TMUX_LIMITS_ENABLED=\"1\"\n"
    block = block + "# End tmux resource limits\n"

    val new_content = content + block
    rt_file_write_text(config_file, new_content)

    print ""
    print "=== Installation Complete ==="
    print ""
    print "To apply changes: source {config_file}"
    print ""
    print "Uninstall: bin/simple run scripts/resource/tmux_limits.spl uninstall"

fn uninstall():
    val config_file = detect_shell_config()
    val shell_name = shell_output("basename $SHELL")

    print "=== Uninstall tmux Resource Limits ==="
    print "Shell: {shell_name}"
    print "Config: {config_file}"
    print ""

    val content = rt_file_read_text(config_file) ?? ""
    if not content.contains("# tmux resource limits"):
        print "tmux limits not found in {config_file}"
        print "Nothing to uninstall."
        rt_exit(0)

    shell("cp {config_file} {config_file}.backup")
    shell("sed -i '/# tmux resource limits - added by tmux_limits.spl/,/# End tmux resource limits/d' {config_file}")

    print "=== Uninstallation Complete ==="
    print ""
    print "tmux limits removed from {config_file}"
    print "To apply changes: source {config_file}"

fn main():
    val args = rt_cli_get_args()

    if args.len() < 2:
        print "Usage:"
        print "  bin/simple run scripts/resource/tmux_limits.spl install [memory] [processes]"
        print "  bin/simple run scripts/resource/tmux_limits.spl uninstall"
        rt_exit(1)

    val cmd = args[1]
    if cmd == "install":
        var memory = "32G"
        var processes = "16"
        if args.len() > 2:
            memory = args[2]
        if args.len() > 3:
            processes = args[3]
        install(memory, processes)
    else:
        if cmd == "uninstall":
            uninstall()
        else:
            print "Unknown command: {cmd}"
            print "Use 'install' or 'uninstall'"
            rt_exit(1)
