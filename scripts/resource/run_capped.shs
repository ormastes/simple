#!/bin/sh
# run_capped.shs — Run a heavy command under a hard memory cap so a no-GC
# `simple` runaway dies cleanly instead of OOM-killing the whole host.
#
# This is the REAL backstop for the recurring host-OOM crash
# (simple_runaway_oom_host_crash_2026-06-14): kill_simple_monitor.shs polls and
# can lose the race vs a balloon that hits 100GB in seconds; a cgroup MemoryMax
# kills the runaway the instant it crosses the cap, with zero poll latency.
#
# Use it for bootstrap rebuilds and full test runs — the two known OOM triggers:
#   scripts/resource/run_capped.shs bin/simple build bootstrap
#   scripts/resource/run_capped.shs bin/simple test
#
# Cap defaults to 32G (env CAP_MEM_MAX): above a healthy peak (<24GB), far below
# host RAM. Swap is disabled so a runaway can't thrash before dying.
# Falls back to a plain exec (with a warning) when systemd user scopes are
# unavailable, so the wrapper never blocks work on a host without cgroup v2.

set -eu

CAP_MEM_MAX="${CAP_MEM_MAX:-32G}"

if [ "$#" -eq 0 ]; then
    echo "usage: run_capped.shs <command> [args...]" >&2
    exit 2
fi

# `is-system-running` exits non-zero when the user manager is "degraded" (a
# common, benign state), so match on the word, not the exit code — otherwise the
# cap would be silently dropped on a perfectly capable host.
_sysd_state="$(systemctl --user is-system-running 2>/dev/null || true)"
case "$_sysd_state" in
    running|degraded|starting) _sysd_ok=1 ;;
    *) _sysd_ok=0 ;;
esac

if command -v systemd-run >/dev/null 2>&1 && [ "$_sysd_ok" = 1 ]; then
    exec systemd-run --user --scope --quiet \
        -p MemoryMax="$CAP_MEM_MAX" -p MemorySwapMax=0 \
        -- "$@"
fi

echo "[run_capped] WARNING: no systemd user scope available; running UNCAPPED — OOM monitor is the only guard." >&2
exec "$@"
