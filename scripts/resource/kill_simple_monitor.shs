#!/bin/sh
# kill_simple_monitor.sh — Kill runaway Simple processes, protect LLM/MCP/tmux
#
# Launched by ensure_kill_monitor_running() in system_monitor.spl.
# Runs in background, writes PID to /tmp/kill_simple_monitor.pid.
# Polls every $CHECK_INTERVAL secs for runaway processes (CPU spin or RSS balloon).
# NEVER kills: simple_mcp_server, simple_lsp_mcp_server, tmux, claude, codex, node, npm.

set -e

PIDFILE="/tmp/kill_simple_monitor.pid"
LOGFILE="${KILL_SIMPLE_LOG:-/tmp/kill_simple_monitor.log}"
CHECK_INTERVAL="${KILL_SIMPLE_INTERVAL:-10}"
CPU_THRESHOLD=95
MIN_AGE_SECS=60
# RSS guard: kill a bin/simple run/test proc this big regardless of CPU/age.
# A no-GC simple balloon doesn't peg CPU, so the CPU guard alone misses the
# host-OOM crash class (simple_runaway_oom_host_crash_2026-06-14). earlyoom is
# the kernel backstop; this kills a single proc long before the host degrades.
MEM_THRESHOLD_MB="${KILL_SIMPLE_MEM_MB:-24000}"
# Generic RSS cap for ANY non-protected proc owned by this uid (catches a rogue
# python/etc that isn't bin/simple — the class that OOM-crashed the host on
# 2026-06-26, a python3 leaking ~1.2GB/min to ~99GB). Set high so it only trips
# on a real runaway, never normal LLM/build work; raise KILL_ANY_MEM_MB for
# intentional big jobs.
GENERIC_MEM_THRESHOLD_MB="${KILL_ANY_MEM_MB:-64000}"
# Warn (log argv, do not kill) when any owned proc crosses this. Makes the
# offending command recoverable next time — argv is NOT logged anywhere else
# once the PID dies (no psacct/atop; earlyoom logs only the comm name).
WARN_MEM_MB="${KILL_SIMPLE_WARN_MB:-32000}"
MY_UID=$(id -u)

cleanup() {
    rm -f "$PIDFILE"
    exit 0
}
trap cleanup INT TERM HUP EXIT

echo $$ > "$PIDFILE"

is_protected() {
    _cmd="$1"
    case "$_cmd" in
        *simple_mcp_server*) return 0 ;;
        *simple_lsp_mcp_server*) return 0 ;;
        *t32_mcp_server*) return 0 ;;
        *t32_lsp_mcp_server*) return 0 ;;
        *mcp/main.spl*) return 0 ;;
        *mcp/main_*.spl*) return 0 ;;
        *lsp_mcp*) return 0 ;;
        *daemon*) return 0 ;;
        *claude*) return 0 ;;
        *codex*) return 0 ;;
        *tmux*) return 0 ;;
        *node*) return 0 ;;
        *npm*) return 0 ;;
    esac
    return 1
}

is_simple_run_or_test() {
    _cmd="$1"
    _had_noglob=0
    case $- in *f*) _had_noglob=1 ;; esac
    set -f
    set -- $_cmd
    [ "$_had_noglob" -eq 1 ] || set +f
    while [ "$#" -gt 1 ]; do
        case "$1:$2" in
            */simple:run|*/simple:test|simple:run|simple:test) return 0 ;;
        esac
        shift
    done
    return 1
}

safe_kill() {
    _pid="$1"
    case "$_pid" in
        ''|*[!0-9]*) return 0 ;;
    esac
    [ "$_pid" -le 1 ] 2>/dev/null && return 0
    kill "$_pid" 2>/dev/null || true
}

kill_hard() {
    _pid="$1"
    _why="$2"
    _line="[kill_monitor] Killing runaway process pid=$_pid ($_why)"
    echo "$_line" >&2
    echo "$(date '+%Y-%m-%dT%H:%M:%S') KILL $_line" >> "$LOGFILE" 2>/dev/null || true
    safe_kill "$_pid"
    sleep 1
    kill -0 "$_pid" 2>/dev/null && [ "$_pid" -gt 1 ] 2>/dev/null && kill -9 "$_pid" 2>/dev/null || true
}

# Append a timestamped argv record so the offending command is recoverable even
# after the PID dies. Throttled to once per pid per ramp via a /tmp marker.
log_proc() {
    _pid="$1"; _rss_mb="$2"; _cmd="$3"
    _marker="/tmp/.kill_monitor_warned_${_pid}"
    [ -e "$_marker" ] && return 0
    : > "$_marker" 2>/dev/null || true
    echo "$(date '+%Y-%m-%dT%H:%M:%S') WARN pid=$_pid rss=${_rss_mb}MB cmd=$_cmd" >> "$LOGFILE" 2>/dev/null || true
}

while true; do
    sleep "$CHECK_INTERVAL"

    # Drop warn-markers for dead pids so a reused pid warns again.
    for _m in /tmp/.kill_monitor_warned_*; do
        [ -e "$_m" ] || continue
        _mp="${_m##*_}"
        kill -0 "$_mp" 2>/dev/null || rm -f "$_m" 2>/dev/null || true
    done

    # uid filters to our own procs (can't/shouldn't kill root system procs);
    # rss is in KB; etimes in seconds. args is last so it captures full cmdline.
    ps -eo uid,pid,pcpu,rss,etimes,args --no-headers 2>/dev/null | while read uid pid cpu rss etime cmdline; do
        [ "$uid" = "$MY_UID" ] 2>/dev/null || continue

        if is_protected "$cmdline"; then
            continue
        fi

        rss_mb=$(( rss / 1024 ))

        # Warn-log argv for anything large, so a runaway is identifiable later.
        if [ "$rss_mb" -ge "$WARN_MEM_MB" ] 2>/dev/null; then
            log_proc "$pid" "$rss_mb" "$cmdline"
        fi

        if is_simple_run_or_test "$cmdline"; then
                # bin/simple RSS guard — fires regardless of CPU/age (OOM balloon).
                if [ "$rss_mb" -ge "$MEM_THRESHOLD_MB" ] 2>/dev/null; then
                    kill_hard "$pid" "rss=${rss_mb}MB>=${MEM_THRESHOLD_MB}MB: $cmdline"
                    continue
                fi

                case "$cmdline" in
                    *native_build_main.spl*|*native_build_worker.spl*)
                        # Native bootstrap builds are CPU-bound by design; the
                        # RSS guard above still catches real runaway balloons.
                        continue
                        ;;
                esac

                # CPU guard — runaway spin.
                cpu_int=$(printf '%.0f' "$cpu" 2>/dev/null || echo 0)
                if [ "$cpu_int" -lt "$CPU_THRESHOLD" ] 2>/dev/null; then
                    continue
                fi
                if [ "$etime" -lt "$MIN_AGE_SECS" ] 2>/dev/null; then
                    continue
                fi
                kill_hard "$pid" "cpu=${cpu}% age=${etime}s: $cmdline"
        else
                # Generic RSS cap for any other owned proc (rogue python/etc).
                if [ "$rss_mb" -ge "$GENERIC_MEM_THRESHOLD_MB" ] 2>/dev/null; then
                    kill_hard "$pid" "generic rss=${rss_mb}MB>=${GENERIC_MEM_THRESHOLD_MB}MB: $cmdline"
                fi
        fi
    done
done
