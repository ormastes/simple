# Start tmux session with resource limits
# All panes in the session inherit these limits
#
# Usage: bin/simple run scripts/resource/tmux_limited.spl [session-name] [options]
#
# Options:
#   -m, --memory SIZE     Memory limit (default: 32G)
#   -p, --processes NUM   Max processes (default: 16)

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_cli_get_args() -> [text]
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_ok(command: text) -> bool:
    val (_, _, code) = shell(command)
    code == 0

fn main():
    val args = rt_cli_get_args()
    var session_name = "limited"
    var memory = "32G"
    var processes = "16"

    var i = 1
    # First non-option arg is session name
    if i < args.len() and not args[i].starts_with("-"):
        session_name = args[i]
        i = i + 1

    while i < args.len():
        val arg = args[i]
        if arg == "-m" or arg == "--memory":
            i = i + 1
            memory = args[i]
        else:
            if arg == "-p" or arg == "--processes":
                i = i + 1
                processes = args[i]
            else:
                if arg == "-h" or arg == "--help":
                    print "Usage: bin/simple run scripts/resource/tmux_limited.spl [session-name] [options]"
                    print ""
                    print "Options:"
                    print "  -m, --memory SIZE     Memory limit (default: 32G)"
                    print "  -p, --processes NUM   Max processes (default: 16)"
                    rt_exit(0)
                else:
                    print "Error: Unknown option: {arg}"
                    rt_exit(1)
        i = i + 1

    if not shell_ok("command -v tmux >/dev/null 2>&1"):
        print "Error: tmux is not installed"
        print "Install with: sudo apt install tmux"
        rt_exit(1)

    # Check if session already exists
    if shell_ok("tmux has-session -t {session_name} 2>/dev/null"):
        print "Session '{session_name}' already exists. Attaching..."
        val (_, _, code) = shell("tmux attach-session -t {session_name}")
        rt_exit(code)

    print "=== Starting Resource-Limited tmux Session ==="
    print "Session name: {session_name}"
    print "Memory limit: {memory}"
    print "Process limit: {processes}"
    print ""

    val has_systemd = shell_ok("command -v systemd-run >/dev/null 2>&1")

    if has_systemd:
        val (_, _, code) = shell("systemd-run --user --scope --quiet -p MemoryMax={memory} -p TasksMax={processes} tmux new-session -s {session_name}")
        rt_exit(code)
    else:
        val (_, _, code) = shell("ulimit -u {processes} 2>/dev/null; tmux new-session -s {session_name}")
        rt_exit(code)
