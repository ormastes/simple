# Live JSONL protocol smoke for `src/app/spipe_mcp/main.spl serve`.

use app.io.mod.{file_write, process_run, exit}

fn shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\"'\"'") + "'"

fn fail(message: text, detail: text):
    print("STATUS: FAIL spipe_mcp_protocol_smoke " + message)
    if detail != "":
        print(detail)
    exit(1)

fn require_contains(haystack: text, needle: text, message: text):
    if not haystack.contains(needle):
        fail(message, haystack)

fn require_not_contains(haystack: text, needle: text, message: text):
    if haystack.contains(needle):
        fail(message, haystack)

fn require_jsonrpc_stdout(stdout: text):
    var count = 0
    for raw_line in stdout.split("\n"):
        val line = raw_line.trim()
        if line != "":
            count = count + 1
            if not line.starts_with("{") or not line.contains("\"jsonrpc\""):
                fail("non-mcp-stdout", stdout)
    if count != 17:
        fail("unexpected-response-count-" + count.to_string(), stdout)

val initialize = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"spipe-smoke\",\"version\":\"1\"}}}"
val tools_list = "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/list\",\"params\":{}}"
val context_put = "{\"jsonrpc\":\"2.0\",\"id\":3,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_context_put\",\"arguments\":{\"source_id\":\"exec:smoke\",\"source_kind\":\"command_output\",\"command\":\"simple build\",\"text\":\"[ERROR] src/app/main.spl:1: bad\\nok\"}}}"
val context_search = "{\"jsonrpc\":\"2.0\",\"id\":4,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_context_search\",\"arguments\":{\"query\":\"bad\"}}}"
val context_raw = "{\"jsonrpc\":\"2.0\",\"id\":5,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_context_get_raw\",\"arguments\":{\"source_id\":\"exec:smoke\",\"start_line\":1,\"end_line\":1,\"after\":1}}}"
val codebase_ingest = "{\"jsonrpc\":\"2.0\",\"id\":6,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_codebase_ingest\",\"arguments\":{\"source_id\":\"codebase:smoke\",\"text\":\"## File: src/app/spipe_mcp/main.spl\\nfn main()\\n\"}}}"
val codebase_search = "{\"jsonrpc\":\"2.0\",\"id\":7,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_codebase_search\",\"arguments\":{\"query\":\"spipe_mcp\"}}}"
val codebase_get = "{\"jsonrpc\":\"2.0\",\"id\":8,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_codebase_get\",\"arguments\":{\"source_id\":\"codebase:smoke\"}}}"
val minimality_check = "{\"jsonrpc\":\"2.0\",\"id\":9,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_minimality_check\",\"arguments\":{\"task\":\"add date picker\",\"text\":\"custom DatePicker component\",\"mode\":\"full\"}}}"
val hook_event = "{\"jsonrpc\":\"2.0\",\"id\":10,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_hook_event\",\"arguments\":{\"provider\":\"codex\",\"event\":\"tool_start\",\"tool\":\"Shell\",\"prompt\":\"run test\",\"raw\":\"payload\"}}}"
val sql_put = "{\"jsonrpc\":\"2.0\",\"id\":11,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_context_sql_put\",\"arguments\":{\"db_path\":\"build/spipe_mcp_protocol_smoke.db\",\"source_id\":\"sql:smoke\",\"source_kind\":\"command_output\",\"command\":\"pytest\",\"text\":\"ERROR src/app/sql_smoke.spl:2: failed\"}}}"
val sql_get = "{\"jsonrpc\":\"2.0\",\"id\":12,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_context_sql_get_tree\",\"arguments\":{\"db_path\":\"build/spipe_mcp_protocol_smoke.db\",\"source_id\":\"sql:smoke\"}}}"
val sql_search = "{\"jsonrpc\":\"2.0\",\"id\":13,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_context_sql_search\",\"arguments\":{\"db_path\":\"build/spipe_mcp_protocol_smoke.db\",\"query\":\"failed\",\"sourceId\":\"sql:smoke\"}}}"
val codebase_alias_reject = "{\"jsonrpc\":\"2.0\",\"id\":14,\"method\":\"tools/call\",\"params\":{\"name\":\"getCodebase\",\"arguments\":{\"root\":\"src/**; rm -rf /\"}}}"
val codebase_save_alias = "{\"jsonrpc\":\"2.0\",\"id\":15,\"method\":\"tools/call\",\"params\":{\"name\":\"saveCodebase\",\"arguments\":{\"sourceId\":\"codebase:alias\",\"codebase\":\"abc\"}}}"
val no_level_parse = "{\"jsonrpc\":\"2.0\",\"id\":16,\"method\":\"tools/call\",\"params\":{\"name\":\"spipe_tree_parse\",\"arguments\":{\"source_id\":\"exec:nolevel\",\"source_kind\":\"command_output\",\"command\":\"find src\",\"text\":\"src/app/main.spl\"}}}"
val unknown_method = "{\"jsonrpc\":\"2.0\",\"id\":17,\"method\":\"spipe/nope\",\"params\":{}}"

val input_path = "/tmp/spipe_mcp_protocol_smoke.jsonl"
val input = initialize + "\n" + tools_list + "\n" + context_put + "\n" + context_search + "\n" + context_raw + "\n" + codebase_ingest + "\n" + codebase_search + "\n" + codebase_get + "\n" + minimality_check + "\n" + hook_event + "\n" + sql_put + "\n" + sql_get + "\n" + sql_search + "\n" + codebase_alias_reject + "\n" + codebase_save_alias + "\n" + no_level_parse + "\n" + unknown_method + "\n"

if not file_write(input_path, input):
    fail("input-write-failed", input_path)

val command = "timeout 20 bin/release/simple run src/app/spipe_mcp/main.spl serve < " + shell_quote(input_path)
val result = process_run("/bin/sh", ["-c", command])
if result.2 != 0:
    fail("server-exit-" + result.2.to_string(), "STDOUT:\n" + result.0 + "\nSTDERR:\n" + result.1)

require_jsonrpc_stdout(result.0)
require_contains(result.0, "\"protocolVersion\"", "missing-initialize-response")
require_contains(result.0, "\"spipe_context_put\"", "missing-tools-list")
require_contains(result.0, "stored exec:smoke", "missing-context-put-result")
require_contains(result.0, "@group level=ERROR count=1", "missing-level-group")
require_contains(result.0, "@parent d=1 kind=dir path=", "missing-parent-chain")
require_contains(result.0, "raw=raw:exec:smoke#L1-L1", "missing-raw-pointer")
require_contains(result.0, "@raw id=exec:smoke range=L1-L2 mode=exact", "missing-raw-context")
require_contains(result.0, "| [ERROR] src/app/main.spl:1: bad", "missing-exact-raw-line")
require_contains(result.0, "ingested codebase:smoke", "missing-codebase-ingest-result")
require_contains(result.0, "@source id=codebase:smoke", "missing-codebase-source")
require_contains(result.0, "repomix_markdown", "missing-codebase-parser")
require_contains(result.0, "@parent d=3 kind=file path=", "missing-codebase-file-node")
require_contains(result.0, "@decision rung=native", "missing-minimality-decision")
require_contains(result.0, "keep validation", "missing-minimality-guard")
require_contains(result.0, "@hook v=1", "missing-hook-event")
require_contains(result.0, "client=codex", "missing-hook-client")
require_contains(result.0, "phase=pre_tool", "missing-hook-phase")
require_contains(result.0, "@tool name=", "missing-hook-tool")
require_contains(result.0, "Shell", "missing-hook-tool-name")
require_contains(result.0, "@prompt run test", "missing-hook-prompt")
require_contains(result.0, "source: sql:smoke", "missing-sql-put-result")
require_contains(result.0, "@source id=sql:smoke", "missing-sql-get-source")
require_contains(result.0, "src/app/sql_smoke.spl", "missing-sql-tree-path")
require_contains(result.0, "matches: 1", "missing-sql-search-match")
require_contains(result.0, "invalid: root", "missing-codebase-alias-reject")
require_contains(result.0, "@codebase_save v=1", "missing-codebase-save-alias")
require_contains(result.0, "codebase:alias", "missing-codebase-save-alias-source")
require_contains(result.0, "bytes=3", "missing-codebase-save-alias-bytes")
require_contains(result.0, "\"id\":16", "missing-no-level-response")
require_contains(result.0, "@source id=src:1", "missing-no-level-source")
require_contains(result.0, "level_detected=false", "missing-no-level-detection")
require_contains(result.0, "src/app/main.spl", "missing-no-level-path")
require_contains(result.0, "\"id\":17", "missing-error-response")
require_contains(result.0, "\"error\"", "missing-jsonrpc-error")
require_contains(result.0, "Method not found", "missing-method-not-found")
require_not_contains(result.0, "STATUS: PASS", "status-leaked-to-mcp-stdout")
require_contains(result.1, "WARN", "missing-stderr-diagnostics")

val no_level_path = "/tmp/spipe_mcp_protocol_smoke_nolevel.jsonl"
val no_level_input = no_level_parse + "\n"
if not file_write(no_level_path, no_level_input):
    fail("no-level-input-write-failed", no_level_path)
val no_level_result = process_run("/bin/sh", ["-c", "timeout 20 bin/release/simple run src/app/spipe_mcp/main.spl serve < " + shell_quote(no_level_path)])
if no_level_result.2 != 0:
    fail("no-level-server-exit-" + no_level_result.2.to_string(), "STDOUT:\n" + no_level_result.0 + "\nSTDERR:\n" + no_level_result.1)
require_contains(no_level_result.0, "level_detected=false", "isolated-no-level-detection")
require_not_contains(no_level_result.0, "@group level=", "isolated-no-level-group")

print("STATUS: PASS spipe_mcp_protocol_smoke")
exit(0)
