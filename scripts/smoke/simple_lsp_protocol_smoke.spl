# Live protocol smoke for `bin/simple lsp`.

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_exit(code: i32) -> void

fn lsp_frame(payload: text) -> text:
    "Content-Length: " + payload.len().to_string() + "\r\n\r\n" + payload

fn shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\"'\"'") + "'"

fn fail(message: text, detail: text):
    print("STATUS: FAIL simple_lsp_protocol_smoke " + message)
    if detail != "":
        print(detail)
    rt_exit(1)

fn require_contains(haystack: text, needle: text, message: text):
    if not haystack.contains(needle):
        fail(message, haystack)

val root_uri = "file://" + "."
val uri = "file:///tmp/simple_lsp_protocol_smoke.spl"
val source = "fn main():\n    pri\n"

val initialize =
    "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"processId\":null,\"rootUri\":\"" +
    root_uri + "\",\"capabilities\":{}}}"
val initialized = "{\"jsonrpc\":\"2.0\",\"method\":\"initialized\",\"params\":{}}"
val did_open =
    "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"" +
    uri + "\",\"languageId\":\"simple\",\"version\":1,\"text\":\"fn main():\\n    pri\\n\"}}}"
val completion =
    "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"textDocument/completion\",\"params\":{\"textDocument\":{\"uri\":\"" +
    uri + "\"},\"position\":{\"line\":1,\"character\":7}}}"
val definition =
    "{\"jsonrpc\":\"2.0\",\"id\":3,\"method\":\"textDocument/definition\",\"params\":{\"textDocument\":{\"uri\":\"" +
    uri + "\"},\"position\":{\"line\":0,\"character\":3}}}"
val code_action =
    "{\"jsonrpc\":\"2.0\",\"id\":4,\"method\":\"textDocument/codeAction\",\"params\":{\"textDocument\":{\"uri\":\"" +
    uri + "\"},\"range\":{\"start\":{\"line\":1,\"character\":4},\"end\":{\"line\":1,\"character\":7}},\"context\":{\"diagnostics\":[],\"only\":[\"quickfix\"]}}}"
val shutdown = "{\"jsonrpc\":\"2.0\",\"id\":5,\"method\":\"shutdown\",\"params\":{}}"
val exit_msg = "{\"jsonrpc\":\"2.0\",\"method\":\"exit\"}"

val input_path = "/tmp/simple_lsp_protocol_smoke.in"
val input =
    lsp_frame(initialize) +
    lsp_frame(initialized) +
    lsp_frame(did_open) +
    lsp_frame(completion) +
    lsp_frame(definition) +
    lsp_frame(code_action) +
    lsp_frame(shutdown) +
    lsp_frame(exit_msg)

if not rt_file_write_text(input_path, input):
    fail("input-write-failed", input_path)

val command = "timeout 15 bin/simple lsp < " + shell_quote(input_path)
val result = rt_process_run("/bin/sh", ["-c", command])
val stdout = result.0
val stderr = result.1
val code = result.2

if code != 0:
    fail("lsp-exit-code-" + code.to_string(), stderr)

require_contains(stdout, "\"capabilities\"", "missing-initialize-response")
require_contains(stdout, "completionProvider", "missing-completion-provider")
require_contains(stdout, "definitionProvider", "missing-definition-provider")
require_contains(stdout, "codeActionProvider", "missing-code-action-provider")
require_contains(stdout, "\"result\":[]", "missing-list-response")
require_contains(stdout, "\"result\":null", "missing-null-response")

print("STATUS: PASS simple_lsp_protocol_smoke")
rt_exit(0)
