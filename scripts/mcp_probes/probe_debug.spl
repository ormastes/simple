# MCP debug server probe
# Verifies the MCP server starts, lists tools, and creates a debug session
#
# Usage: bin/simple run scripts/mcp_probes/probe_debug.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_exit(code: i32)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn main():
    print "MCP Debug Server Probe"
    print "======================"
    print ""

    # Send initialize + initialized + tools/list as a pipeline
    val init_msg = r'{"jsonrpc":"2.0","id":"1","method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"probe","version":"1.0"}}}'
    val initialized_msg = r'{"jsonrpc":"2.0","method":"initialized","params":{}}'
    val tools_list_msg = r'{"jsonrpc":"2.0","id":"2","method":"tools/list","params":{}}'

    val cmd = "printf '%s\\n' '" + init_msg + "' '" + initialized_msg + "' '" + tools_list_msg + "' | timeout 10 bin/simple_mcp_server 2>/dev/null"
    val (output, _, code) = shell(cmd)

    if output.contains("result"):
        print "  Initialize: OK"
    else:
        print "  Initialize: FAIL"
        rt_exit(1)

    if output.contains("debug_create_session"):
        print "  Tools list contains debug_create_session: OK"
    else:
        print "  Tools list: FAIL (debug_create_session not found)"
        rt_exit(1)

    if output.contains("debug_log_status"):
        print "  Tools list contains debug_log_status: OK"
    else:
        print "  Tools list: FAIL (debug_log_status not found)"
        rt_exit(1)

    print ""
    print "probe: OK"
