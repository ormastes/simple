#!/bin/sh
# secret-scan.shs — Pre-commit hook that scans staged files for secrets
#
# Install as git hook:
#   cp scripts/secret-scan.shs .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or run manually:
#   sh scripts/secret-scan.shs
#
# Exit codes:
#   0 — no secrets found
#   1 — secrets detected (commit blocked)

set -e

FOUND=0
TOTAL=0

# Color codes (disabled if not a terminal)
if [ -t 1 ]; then
    RED='\033[0;31m'
    YELLOW='\033[1;33m'
    GREEN='\033[0;32m'
    BOLD='\033[1m'
    RESET='\033[0m'
else
    RED=''
    YELLOW=''
    GREEN=''
    BOLD=''
    RESET=''
fi

report_match() {
    _file="$1"
    _line="$2"
    _pattern="$3"
    _severity="$4"
    FOUND=$((FOUND + 1))
    if [ "$_severity" = "critical" ]; then
        printf "${RED}[CRITICAL]${RESET} %s:%s — %s\n" "$_file" "$_line" "$_pattern"
    else
        printf "${YELLOW}[WARNING]${RESET} %s:%s — %s\n" "$_file" "$_line" "$_pattern"
    fi
}

is_binary() {
    # Check if file contains null bytes (binary indicator)
    if file "$1" 2>/dev/null | grep -qE 'binary|executable|archive|image|font'; then
        return 0
    fi
    return 1
}

is_test_file() {
    case "$1" in
        *_spec.spl|*_test.spl) return 0 ;;
        *) return 1 ;;
    esac
}

# Get list of staged files (or all tracked files if not in git hook mode)
if git rev-parse --git-dir > /dev/null 2>&1; then
    FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)
    if [ -z "$FILES" ]; then
        # No staged files — nothing to scan
        exit 0
    fi
else
    echo "Not in a git repository. Run from repo root."
    exit 1
fi

for file in $FILES; do
    # Skip files that do not exist (deleted)
    [ -f "$file" ] || continue

    # Skip binary files
    if is_binary "$file"; then
        continue
    fi

    TOTAL=$((TOTAL + 1))
    LINENO_COUNT=0

    while IFS= read -r line; do
        LINENO_COUNT=$((LINENO_COUNT + 1))

        # Skip comment lines
        case "$line" in
            \#*|//*) continue ;;
        esac

        # --- Critical patterns ---

        # AWS Access Key
        if echo "$line" | grep -qE 'AKIA[0-9A-Z]{16}'; then
            report_match "$file" "$LINENO_COUNT" "AWS Access Key (AKIA...)" "critical"
        fi

        # GitHub tokens
        if echo "$line" | grep -qE 'gh[pors]_[A-Za-z0-9]{36}'; then
            report_match "$file" "$LINENO_COUNT" "GitHub token (ghp_/gho_/ghr_/ghs_)" "critical"
        fi

        # Anthropic API keys
        if echo "$line" | grep -qE 'sk-ant-[A-Za-z0-9_-]{20,}'; then
            report_match "$file" "$LINENO_COUNT" "Anthropic API key (sk-ant-...)" "critical"
        fi

        # OpenAI API keys
        if echo "$line" | grep -qE 'sk-[A-Za-z0-9]{20,}'; then
            # Exclude sk-ant- (already matched above)
            if ! echo "$line" | grep -qE 'sk-ant-'; then
                report_match "$file" "$LINENO_COUNT" "OpenAI API key (sk-...)" "critical"
            fi
        fi

        # Google API keys
        if echo "$line" | grep -qE 'AIza[0-9A-Za-z_-]{35}'; then
            report_match "$file" "$LINENO_COUNT" "Google API key (AIza...)" "critical"
        fi

        # Private keys
        if echo "$line" | grep -qE '-----BEGIN.*PRIVATE KEY-----'; then
            report_match "$file" "$LINENO_COUNT" "Private key header" "critical"
        fi

        # Slack tokens
        if echo "$line" | grep -qE 'xox[bps]-[A-Za-z0-9-]{10,}'; then
            report_match "$file" "$LINENO_COUNT" "Slack token (xoxb-/xoxp-/xoxs-)" "critical"
        fi

        # Stripe keys
        if echo "$line" | grep -qE '[sp]k_live_[A-Za-z0-9]{20,}'; then
            report_match "$file" "$LINENO_COUNT" "Stripe live key" "critical"
        fi

        # --- Warning patterns ---

        # Connection strings with embedded credentials
        if echo "$line" | grep -qE '://[^/]*:[^@]*@'; then
            # Skip common false positives: git URLs, http examples
            if ! echo "$line" | grep -qE '(git@|://localhost|://example|://\{|://\$|://user:pass)'; then
                report_match "$file" "$LINENO_COUNT" "Connection string with credentials" "warning"
            fi
        fi

        # Generic high-entropy strings (skip test files)
        if ! is_test_file "$file"; then
            # Long hex strings (> 64 chars) that look like keys
            if echo "$line" | grep -qE '[0-9a-fA-F]{64,}'; then
                # Skip known safe patterns: checksums in comments, hash examples
                if ! echo "$line" | grep -qiE '(checksum|hash|sha256|sha512|digest|fingerprint|expected)'; then
                    report_match "$file" "$LINENO_COUNT" "High-entropy hex string (>64 chars)" "warning"
                fi
            fi

            # Long base64-like strings (> 40 chars) outside of known safe contexts
            if echo "$line" | grep -qE '[A-Za-z0-9+/=]{40,}'; then
                # Skip known safe patterns
                if ! echo "$line" | grep -qiE '(base64|encode|decode|test|example|mock|fixture|checksum|hash|pub_key|public_key)'; then
                    # Skip if line also matches a comment or string literal pattern definition
                    if ! echo "$line" | grep -qE '(pattern|regex|grep|match)'; then
                        report_match "$file" "$LINENO_COUNT" "High-entropy base64-like string (>40 chars)" "warning"
                    fi
                fi
            fi
        fi

    done < "$file"
done

# Summary
echo ""
if [ "$FOUND" -gt 0 ]; then
    printf "${RED}${BOLD}Secret scan failed:${RESET} %d potential secret(s) found in %d file(s)\n" "$FOUND" "$TOTAL"
    echo ""
    echo "To fix:"
    echo "  1. Remove the secret from the file"
    echo "  2. Use environment variables or ~/.simple/credentials.sdn instead"
    echo "  3. If this is a false positive, add @allow(hardcoded_secret) annotation"
    echo "     above the line, or add the pattern to .secretscanignore"
    echo ""
    echo "If you already committed a secret, rotate it immediately!"
    exit 1
else
    printf "${GREEN}Secret scan passed:${RESET} %d file(s) scanned, no secrets found\n" "$TOTAL"
    exit 0
fi
