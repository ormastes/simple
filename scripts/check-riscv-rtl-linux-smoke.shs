#!/bin/bash
# Run the public generated RISC-V RTL Linux smoke gates.

set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TIMEOUT=30

for arg in "$@"; do
    case "$arg" in
        --timeout=*) TIMEOUT="${arg#--timeout=}" ;;
    esac
done

bash "$SCRIPT_DIR/rtl_riscv64_linux_generated.shs" --check-tools
bash "$SCRIPT_DIR/rtl_riscv64_linux_generated.shs" "--timeout=$TIMEOUT"
