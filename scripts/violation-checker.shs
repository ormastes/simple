#!/bin/sh
# check-bin-violations.shs — Detect bin/ binaries pointing to Rust instead of self-hosted Simple
#
# Rule: bin/simple must resolve to a self-hosted or deployed release binary.
#       bin/release/<triple>/ is the canonical deployed layout.
#       The flat release runtime path must not exist.
#       Rust bootstrap goes to src/compiler_rust/target/bootstrap/simple only.
#       Shell wrappers must resolve to deployed Simple binaries, not Rust-only links.

set -eu

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
RUST_TARGET_DIR="${REPO_ROOT}/src/compiler_rust/target"

VIOLATIONS=0
WARNINGS=0
CHECKS=0

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

violation() {
  VIOLATIONS=$((VIOLATIONS + 1))
  printf "${RED}[VIOLATION]${NC} %s\n" "$1"
  printf "           %s\n" "$2"
}

warning() {
  WARNINGS=$((WARNINGS + 1))
  printf "${YELLOW}[WARNING]${NC}  %s\n" "$1"
  printf "           %s\n" "$2"
}

ok() {
  printf "${GREEN}[OK]${NC}       %s\n" "$1"
}

info() {
  printf "${CYAN}[INFO]${NC}     %s\n" "$1"
}

check() {
  CHECKS=$((CHECKS + 1))
}

resolve_symlink() {
  target="$1"
  while [ -L "$target" ]; do
    link="$(readlink "$target")"
    case "$link" in
      /*) target="$link" ;;
      *)  target="$(dirname "$target")/$link" ;;
    esac
  done
  cd "$(dirname "$target")" && printf '%s/%s' "$(pwd)" "$(basename "$target")"
}

points_to_rust() {
  resolved="$1"
  case "$resolved" in
    ${RUST_TARGET_DIR}/*) return 0 ;;
    *) return 1 ;;
  esac
}

is_elf_binary() {
  file "$1" 2>/dev/null | grep -q "ELF"
}

# Check if item is in a space-separated allowed list
is_allowed() {
  _item="$1"
  shift
  for _a in "$@"; do
    [ "$_item" = "$_a" ] && return 0
  done
  return 1
}

# Suggest where a stray root entry should be moved
suggest_move() {
  _name="$1"
  _is_dir="$2"
  case "$_name" in
    unit|integration|system|feature|fuzz|perf|specs|verification|fixtures|shared)
      printf "test/%s/ (test directory)" "$_name" ;;
    bootstrap|bootstrap_*)
      printf "build/bootstrap/ (bootstrap artifacts)" ;;
    compile|target|artifacts)
      printf "build/ (build artifacts) or DELETE" ;;
    rustc*) printf "DELETE (Rust compiler temp)" ;;
    cc*.c|cc*.res|*.o|*.obj)
      printf "DELETE (compiler temp artifact)" ;;
    tmp|.tmp*)
      printf "DELETE (temporary files)" ;;
    app)
      printf "test/app/ or examples/ (application test dir)" ;;
    lib)
      printf "test/lib/ or src/lib/ (library test dir)" ;;
    docs)
      printf "MERGE into doc/ (duplicate documentation dir)" ;;
    data)
      printf "resources/ or config/ (project data)" ;;
    qemu)
      printf "examples/qemu/ or tools/qemu/" ;;
    resources)
      printf "config/ or data/ (project resources)" ;;
    .agents)
      printf ".claude/agents/ (agent definitions)" ;;
    *.md)
      printf "doc/09_report/ (documentation file)" ;;
    *.txt)
      printf "doc/09_report/ (documentation file)" ;;
    *.sh)
      printf "scripts/ (shell script)" ;;
    *)
      if [ "$_is_dir" = "dir" ]; then
        printf "REVIEW — unknown directory, check contents"
      else
        printf "REVIEW — unknown file, check contents"
      fi ;;
  esac
}

printf "${BOLD}=== Binary Violation Detector ===${NC}\n"
printf "Repo:       %s\n" "$REPO_ROOT"
printf "Rust target: %s\n\n" "$RUST_TARGET_DIR"

# ─────────────────────────────────────────────────────────
# 1. Check bin/simple symlink
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 1. bin/simple symlink ---${NC}\n"
check
BIN_SIMPLE="${REPO_ROOT}/bin/simple"
if [ -L "$BIN_SIMPLE" ]; then
  RAW_LINK="$(readlink "$BIN_SIMPLE")"
  RESOLVED="$(resolve_symlink "$BIN_SIMPLE")"
  if points_to_rust "$RESOLVED"; then
    violation "bin/simple -> Rust binary" \
      "Points to: $RAW_LINK (should be bin/simple or platform binary)"
  else
    ok "bin/simple -> $RAW_LINK (not Rust)"
  fi
elif [ -f "$BIN_SIMPLE" ]; then
  if is_elf_binary "$BIN_SIMPLE"; then
    FILE_INFO="$(file "$BIN_SIMPLE" 2>/dev/null)"
    info "bin/simple is a real binary: $FILE_INFO"
  else
    info "bin/simple exists (not a symlink)"
  fi
else
  warning "bin/simple does not exist" \
    "Expected symlink to bin/simple or platform binary"
fi
echo

# ─────────────────────────────────────────────────────────
# 2. Check the flat release runtime path is absent
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 2. Flat release runtime path (must be absent) ---${NC}\n"
check
BIN_RELEASE_FLAT="${REPO_ROOT}/bin/release/"simple
if [ -L "$BIN_RELEASE_FLAT" ] || [ -e "$BIN_RELEASE_FLAT" ]; then
  violation "flat release runtime PRESENT" \
    "Flat runtime path is no longer supported; remove ${BIN_RELEASE_FLAT#${REPO_ROOT}/}"
else
  ok "flat release runtime absent"
fi
echo

# ─────────────────────────────────────────────────────────
# 3. Check platform-specific binaries
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 3. Platform-specific binaries (bin/release/<triple>/) ---${NC}\n"
for PLATFORM_DIR in "${REPO_ROOT}"/bin/release/*/; do
  [ -d "$PLATFORM_DIR" ] || continue
  TRIPLE="$(basename "$PLATFORM_DIR")"
  # Skip non-platform dirs
  case "$TRIPLE" in
    __pycache__|*.bak) continue ;;
  esac
  PLAT_SIMPLE="${PLATFORM_DIR}simple"
  check
  if [ -L "$PLAT_SIMPLE" ]; then
    RAW_LINK="$(readlink "$PLAT_SIMPLE")"
    RESOLVED="$(resolve_symlink "$PLAT_SIMPLE")"
    if points_to_rust "$RESOLVED"; then
      violation "bin/release/${TRIPLE}/simple -> Rust binary" \
        "Points to: $RAW_LINK — platform binary must be self-hosted"
    else
      ok "bin/release/${TRIPLE}/simple -> $RAW_LINK"
    fi
  elif [ -f "$PLAT_SIMPLE" ]; then
    if is_elf_binary "$PLAT_SIMPLE"; then
      ok "bin/release/${TRIPLE}/simple is ELF binary"
    else
      info "bin/release/${TRIPLE}/simple exists ($(file "$PLAT_SIMPLE" 2>/dev/null | cut -d: -f2))"
    fi
  else
    warning "bin/release/${TRIPLE}/simple does not exist" \
      "No platform binary for triple: $TRIPLE"
  fi
done
echo

# ─────────────────────────────────────────────────────────
# 4. Check shell wrapper runtime resolution
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 4. Shell wrapper runtime fallback analysis ---${NC}\n"
for WRAPPER in \
  "${REPO_ROOT}"/bin/release/*_server \
  "${REPO_ROOT}"/bin/release/*_server.cmd \
  "${REPO_ROOT}"/bin/release/*/*_server \
  "${REPO_ROOT}"/bin/release/*/*_server.cmd
do
  [ -f "$WRAPPER" ] || continue
  # Skip .cmd (Windows)
  case "$WRAPPER" in *.cmd) continue ;; esac
  WNAME="$(basename "$WRAPPER")"
  WPATH="${WRAPPER#${REPO_ROOT}/}"
  check
  # Check if wrapper references Rust paths as fallback
  if grep -q 'compiler_rust/target' "$WRAPPER" 2>/dev/null; then
    if grep -q '\${SCRIPT_DIR}/simple\|%SCRIPT_DIR%simple.exe' "$WRAPPER" 2>/dev/null; then
      ok "$WPATH prefers platform binary before Rust fallback"
    elif [ ! -f "$BIN_RELEASE_SIMPLE" ] && [ ! -L "$BIN_RELEASE_SIMPLE" ]; then
      warning "$WPATH may fall back to Rust binary" \
        "No colocated platform runtime detected"
    else
      ok "$WPATH has Rust fallback after deployed runtime"
    fi
  else
    ok "$WPATH does not reference Rust target"
  fi
done
echo

# ─────────────────────────────────────────────────────────
# 5. Check all symlinks in bin/ pointing to Rust
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 5. All bin/ symlinks audit ---${NC}\n"
for LINK in "${REPO_ROOT}"/bin/*; do
  [ -L "$LINK" ] || continue
  LNAME="$(basename "$LINK")"
  RAW_LINK="$(readlink "$LINK")"
  RESOLVED="$(resolve_symlink "$LINK")"
  check
  if points_to_rust "$RESOLVED"; then
    violation "bin/${LNAME} -> Rust binary" \
      "Resolved: $RESOLVED"
  else
    ok "bin/${LNAME} -> $RAW_LINK"
  fi
done
echo

# ─────────────────────────────────────────────────────────
# 6. Check bin/release/<triple> symlinks
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 6. Platform dir symlinks audit ---${NC}\n"
FOUND_PLAT_LINKS=0
for PLATFORM_DIR in "${REPO_ROOT}"/bin/release/*/; do
  [ -d "$PLATFORM_DIR" ] || continue
  TRIPLE="$(basename "$PLATFORM_DIR")"
  case "$TRIPLE" in __pycache__|*.bak) continue ;; esac
  for LINK in "${PLATFORM_DIR}"*; do
    [ -L "$LINK" ] || continue
    FOUND_PLAT_LINKS=1
    LNAME="$(basename "$LINK")"
    RAW_LINK="$(readlink "$LINK")"
    RESOLVED="$(resolve_symlink "$LINK")"
    check
    if points_to_rust "$RESOLVED"; then
      violation "bin/release/${TRIPLE}/${LNAME} -> Rust binary" \
        "Resolved: $RESOLVED"
    else
      ok "bin/release/${TRIPLE}/${LNAME} -> $RAW_LINK"
    fi
  done
done
if [ "$FOUND_PLAT_LINKS" = "0" ]; then
  info "No symlinks found in platform directories"
fi
echo

# ─────────────────────────────────────────────────────────
# 7. Root directory structure validation (per FILE.md)
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 7. Root directory structure (per FILE.md) ---${NC}\n"

# Documented directories from FILE.md / CLAUDE.md
ALLOWED_DIRS="bin build config doc examples scripts src test tools"
# Dot-directories that tooling requires in project root
ALLOWED_DOTDIRS=".agents .build .claude .codex .gemini .git .github .jj .simple .sstack .vscode"
# Files documented in FILE.md as belonging in root
ALLOWED_FILES="AGENTS.md CHANGELOG.md CLAUDE.md FILE.md GEMINI.md LICENSE MCP.md README.md THIRD_PARTY_NOTICES.md VERSION gemini-extension.json install.shs simple.sdn Makefile_use_simple_command_instead"
# Dot-files that must be in project root (tooling/VCS)
ALLOWED_DOTFILES=".dockerignore .envrc .gitattributes .gitignore .gitmodules .jjignore .jscpd.json .mcp.json"

# Check non-dot entries in root
for entry in "${REPO_ROOT}"/*; do
  [ -e "$entry" ] || continue
  name="$(basename "$entry")"
  check

  if is_allowed "$name" $ALLOWED_DIRS $ALLOWED_FILES; then
    ok "root/$name"
    continue
  fi

  # Skip gitignored entries (local build artifacts like target/)
  if git check-ignore -q "$entry" 2>/dev/null; then
    info "root/$name (gitignored, skipped)"
    continue
  fi

  entry_type="file"
  [ -d "$entry" ] && entry_type="dir"

  # Empty entries → violation (safe to delete)
  if [ "$entry_type" = "dir" ]; then
    item_count="$(ls -1A "$entry" 2>/dev/null | wc -l)"
    if [ "$item_count" -eq 0 ]; then
      violation "root/$name/ — empty directory not in FILE.md" \
        "DELETE (empty, not documented)"
      continue
    fi
  elif [ ! -s "$entry" ]; then
    violation "root/$name — empty file not in FILE.md" \
      "DELETE (empty, not documented)"
    continue
  fi

  suggestion="$(suggest_move "$name" "$entry_type")"
  warning "root/$name — not in documented structure" \
    "Suggested: $suggestion"
done

# Check dot entries in root
for entry in "${REPO_ROOT}"/.*; do
  name="$(basename "$entry")"
  [ "$name" = "." ] || [ "$name" = ".." ] && continue
  check

  if is_allowed "$name" $ALLOWED_DOTDIRS $ALLOWED_DOTFILES; then
    ok "root/$name (root-only)"
    continue
  fi

  entry_type="file"
  [ -d "$entry" ] && entry_type="dir"

  # Temp dot-entries → violation
  case "$name" in
    .tmp*)
      violation "root/$name — temp file/dir" \
        "DELETE (temporary, not documented)"
      continue
      ;;
  esac

  suggestion="$(suggest_move "$name" "$entry_type")"
  warning "root/$name — not in documented root structure" \
    "Suggested: $suggestion"
done
echo

# ─────────────────────────────────────────────────────────
# 8. Cross-platform bin/ entry audit
# ─────────────────────────────────────────────────────────
printf "${BOLD}--- 8. Cross-platform bin/ entry audit ---${NC}\n"
# Every executable file/symlink directly under bin/ must work on all platforms.
# Rules:
#   - Symlinks (Unix native binaries) MUST have a matching .cmd wrapper for Windows
#   - Shell scripts (#!/bin/sh or #!/usr/bin/env) are cross-platform via sh/bash
#   - .js/.spl scripts are cross-platform via their runtimes
#   - Non-executable files (FILE.md, .a, .spl data) are exempt
#   - Directories are exempt

# Files/patterns exempt from cross-platform check
EXEMPT_BIN="FILE.md libsimple_runtime.a mcp_stdio_proxy.spl simple-stub"

for entry in "${REPO_ROOT}"/bin/*; do
  [ -e "$entry" ] || [ -L "$entry" ] || continue
  name="$(basename "$entry")"

  # Skip directories
  [ -d "$entry" ] && continue

  # Skip .cmd files (they ARE the Windows counterpart)
  case "$name" in *.cmd) continue ;; esac

  # Skip exempt files
  if is_allowed "$name" $EXEMPT_BIN; then
    continue
  fi

  check

  if [ -L "$entry" ]; then
    # Symlink → native binary. Must have a .cmd counterpart for Windows.
    cmd_name="${name}.cmd"
    cmd_path="${REPO_ROOT}/bin/${cmd_name}"
    # Also check in the release dir
    link_target="$(readlink "$entry")"
    release_cmd=""
    case "$link_target" in
      release/*)
        release_cmd="${REPO_ROOT}/bin/${link_target}.cmd"
        ;;
    esac

    if [ -f "$cmd_path" ]; then
      ok "bin/${name} — symlink + .cmd wrapper (cross-platform)"
    elif [ -n "$release_cmd" ] && [ -f "$release_cmd" ]; then
      ok "bin/${name} — symlink + release .cmd (cross-platform)"
    else
      warning "bin/${name} — symlink but NO .cmd wrapper for Windows" \
        "Add bin/${cmd_name} or bin/release/<triple>/${cmd_name}"
    fi
  elif [ -x "$entry" ]; then
    # Executable regular file — check if it's a cross-platform script
    first_line="$(head -c 128 "$entry" 2>/dev/null | head -1)"
    case "$first_line" in
      '#!'*)
        # Shebang script — check interpreter
        case "$first_line" in
          *node*|*python*|*env\ node*|*env\ python*)
            ok "bin/${name} — script (cross-platform interpreter)" ;;
          *sh*|*bash*|*zsh*)
            warning "bin/${name} — shell script (not native on Windows)" \
              "Add bin/${name}.cmd wrapper or convert to .spl" ;;
          *)
            warning "bin/${name} — script with unknown interpreter" \
              "Verify cross-platform: ${first_line}" ;;
        esac
        ;;
      *)
        # Executable without shebang — likely a compiled binary that shouldn't be here
        case "$name" in
          *.js)
            ok "bin/${name} — JavaScript (cross-platform)" ;;
          *.spl)
            ok "bin/${name} — Simple script (cross-platform)" ;;
          *)
            warning "bin/${name} — executable without shebang or symlink" \
              "Should be a symlink to release/<triple>/ or a cross-platform script" ;;
        esac
        ;;
    esac
  else
    # Non-executable regular file — generally fine
    info "bin/${name} — non-executable file"
  fi
done
echo

# ─────────────────────────────────────────────────────────
# Summary
# ─────────────────────────────────────────────────────────
printf "${BOLD}=== Summary ===${NC}\n"
printf "Checks:     %d\n" "$CHECKS"
printf "Violations: "
if [ "$VIOLATIONS" -gt 0 ]; then
  printf "${RED}%d${NC}\n" "$VIOLATIONS"
else
  printf "${GREEN}0${NC}\n"
fi
printf "Warnings:   "
if [ "$WARNINGS" -gt 0 ]; then
  printf "${YELLOW}%d${NC}\n" "$WARNINGS"
else
  printf "${GREEN}0${NC}\n"
fi
echo

if [ "$VIOLATIONS" -gt 0 ]; then
  printf "${RED}${BOLD}FAIL${NC} — %d violation(s) found.\n" "$VIOLATIONS"
  printf "Fix: deploy a self-hosted binary, then update symlinks:\n"
  printf "  bin/simple -> bin/release/<triple>/simple\n"
  printf "  MCP wrappers should live in bin/release/<triple>/ and prefer colocated runtime\n"
  exit 1
fi

if [ "$WARNINGS" -gt 0 ]; then
  printf "${YELLOW}${BOLD}WARN${NC} — passed with %d warning(s)\n" "$WARNINGS"
  exit 0
fi

printf "${GREEN}${BOLD}PASS${NC} — all binaries point to self-hosted Simple\n"
exit 0
