# Memory watchdog: kills all "simple" processes when free memory drops below half of total
# Usage: bin/simple run scripts/memory_watchdog.spl &

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn get_meminfo_kb(key: text) -> i64:
    val content = rt_file_read_text("/proc/meminfo") ?? ""
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if line.starts_with(key):
            val parts = line.split_whitespace()
            if parts.len() >= 2:
                return int(parts[1])
        i = i + 1
    0

fn main():
    val total_kb = get_meminfo_kb("MemTotal:")
    val half_kb = total_kb / 2
    val half_mb = half_kb / 1024
    val total_mb = total_kb / 1024

    print "Memory watchdog started. Total: {total_mb}MB, threshold: {half_mb}MB"

    while true:
        val free_kb = get_meminfo_kb("MemAvailable:")
        val free_mb = free_kb / 1024

        if free_kb < half_kb:
            print "WARNING: Free memory {free_mb}MB < threshold {half_mb}MB - killing simple processes"
            shell("pkill -f 'bin/.*simple' 2>/dev/null || true")
            shell("sleep 2")
            shell("pkill -9 -f 'bin/.*simple' 2>/dev/null || true")
            val after_mb = get_meminfo_kb("MemAvailable:") / 1024
            print "Cleanup done. Free: {after_mb}MB"

        shell("sleep 1")
