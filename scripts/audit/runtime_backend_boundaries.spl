# Audit runtime-family backend ownership and SimpleOS POSIX boundaries.

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_exit(code: i32) -> void

struct RuntimeBoundaryConfig:
    root: text

fn shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\"'\"'") + "'"

fn normalize_args(all_args: [text]) -> [text]:
    var start = 0
    var found = false
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("runtime_backend_boundaries.spl"):
            start = i + 1
            found = true
            break
        i = i + 1
    if not found and all_args.len() > 0:
        start = 1

    var args: [text] = []
    i = start
    while i < all_args.len():
        if all_args[i] != "--":
            args = args.push(all_args[i])
        i = i + 1
    args

fn parse_args(args: [text]) -> RuntimeBoundaryConfig:
    var config = RuntimeBoundaryConfig(root: ".")
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--root" and i + 1 < args.len():
            config.root = args[i + 1]
            i = i + 2
        elif arg.starts_with("--root="):
            config.root = arg.substring("--root=".len())
            i = i + 1
        else:
            i = i + 1
    config

fn async_compat_roots() -> [text]:
    ["src/lib/gc_async_mut", "src/lib/nogc_async_mut"]

fn simpleos_native_roots() -> [text]:
    ["src/os/kernel", "src/os/drivers", "src/os/services", "src/os/sosix", "src/os/userlib", "src/os/async"]

fn portable_lib_roots() -> [text]:
    [
        "src/lib/common",
        "src/lib/gc_async_mut",
        "src/lib/gc_sync_mut",
        "src/lib/gc_async_immut",
        "src/lib/gc_sync_immut",
        "src/lib/nogc_async_mut",
        "src/lib/nogc_sync_mut",
        "src/lib/nogc_async_immut",
        "src/lib/nogc_sync_immut",
    ]

fn join_path(root: text, path: text) -> text:
    if root == "" or root == ".":
        return path
    if root.ends_with("/"):
        return root + path
    root + "/" + path

fn rel_path(path: text, root: text) -> text:
    if root != "" and root != "." and path.starts_with(root + "/"):
        return path.substring(root.len() + 1)
    if path.starts_with("./"):
        return path.substring(2)
    path

fn list_spl_under(root: text, roots: [text]) -> [text]:
    var paths: [text] = []
    for rel_root in roots:
        val scan_root = join_path(root, rel_root)
        val command = "if [ -e " + shell_quote(scan_root) + " ]; then find " + shell_quote(scan_root) + " -type f -name '*.spl' | sort; fi"
        val result = rt_process_run("/bin/sh", ["-c", command])
        if result.2 != 0:
            continue
        for raw in result.0.split("\n"):
            val path = raw.trim()
            if path != "" and not path.contains("/vendor/"):
                paths = paths.push(path)
    paths

fn code_lines(path: text) -> [text]:
    val source = rt_file_read_text(path) ?? ""
    var lines: [text] = []
    var line_no = 0
    for line in source.split("\n"):
        line_no = line_no + 1
        val stripped = line.trim()
        if stripped != "" and not stripped.starts_with("#"):
            lines = lines.push(line_no.to_string() + "\t" + stripped)
    lines

fn split_lineno(entry: text) -> i64:
    val tab = entry.index_of("\t") ?? -1
    if tab < 0:
        return 0
    entry.substring(0, tab).to_i64()

fn split_code(entry: text) -> text:
    val tab = entry.index_of("\t") ?? -1
    if tab < 0:
        return entry
    entry.substring(tab + 1)

fn is_import_line(stripped: text) -> bool:
    stripped.starts_with("use ") or stripped.starts_with("import ") or stripped.starts_with("export use ")

fn has_direct_runtime_hook(stripped: text) -> bool:
    stripped.contains("extern fn rt_")

fn has_backend_hook(source: text) -> bool:
    source.contains("extern fn rt_") or source.contains("extern fn spl_memtrack_") or source.contains("extern fn stdin_read_char")

fn forbidden_simpleos_import(stripped: text) -> bool:
    stripped.contains("os.posix") or stripped.contains("os.libc") or stripped.contains("posix.") or stripped.contains("libc.")

fn forbidden_portable_import(stripped: text) -> bool:
    stripped.contains("std.posix") or stripped.contains("std.linux") or stripped.contains("os.posix") or stripped.contains("os.libc") or stripped.contains("posix.") or stripped.contains("linux.")

fn platform_or_compat_path(path: text, root: text) -> bool:
    val path_text = "/" + rel_path(path, root)
    path_text.contains("/posix/") or
        path_text.contains("/nvfs_posix/") or
        path_text.contains("/platform/") or
        path_text.contains("/linux/") or
        path_text.contains("posix_") or
        path_text.contains("_posix") or
        path_text.contains("linux_") or
        path_text.contains("_linux")

fn nogc_sync_module_from_wildcard(stripped: text) -> text:
    if not stripped.starts_with("export use "):
        return ""
    val marker = "nogc_sync_mut."
    val marker_idx = stripped.index_of(marker) ?? -1
    if marker_idx < 0:
        return ""
    val rest = stripped.substring(marker_idx + marker.len())
    val star_idx = rest.index_of(".*") ?? -1
    if star_idx < 0:
        return ""
    val module_name = rest.substring(0, star_idx)
    module_name.replace(".", "/")

fn direct_runtime_hooks(root: text) -> [text]:
    var hits: [text] = []
    for path in list_spl_under(root, async_compat_roots()):
        for entry in code_lines(path):
            val stripped = split_code(entry)
            if has_direct_runtime_hook(stripped):
                hits = hits.push(rel_path(path, root) + ":" + split_lineno(entry).to_string() + ": " + stripped)
    hits

fn async_runtime_owner_wildcards(root: text, scan_root: text) -> [text]:
    var hits: [text] = []
    for path in list_spl_under(root, [scan_root]):
        for entry in code_lines(path):
            val stripped = split_code(entry)
            val module_path = nogc_sync_module_from_wildcard(stripped)
            if module_path == "":
                continue
            val sync_path = join_path(root, "src/lib/nogc_sync_mut/" + module_path + ".spl")
            val sync_text = rt_file_read_text(sync_path) ?? ""
            if has_backend_hook(sync_text):
                hits = hits.push(rel_path(path, root) + ":" + split_lineno(entry).to_string() + ": " + stripped + " -> " + rel_path(sync_path, root))
    hits

fn simpleos_lower_layer_imports(root: text) -> [text]:
    var hits: [text] = []
    for path in list_spl_under(root, simpleos_native_roots()):
        for entry in code_lines(path):
            val stripped = split_code(entry)
            if is_import_line(stripped) and forbidden_simpleos_import(stripped):
                hits = hits.push(rel_path(path, root) + ":" + split_lineno(entry).to_string() + ": " + stripped)
    hits

fn portable_lib_imports(root: text) -> [text]:
    var hits: [text] = []
    for path in list_spl_under(root, portable_lib_roots()):
        if platform_or_compat_path(path, root):
            continue
        for entry in code_lines(path):
            val stripped = split_code(entry)
            if is_import_line(stripped) and forbidden_portable_import(stripped):
                hits = hits.push(rel_path(path, root) + ":" + split_lineno(entry).to_string() + ": " + stripped)
    hits

fn json_escape(value: text) -> text:
    val escaped_backslash = value.replace("\\", "\\\\")
    val escaped_quote = escaped_backslash.replace("\"", "\\\"")
    escaped_quote.replace("\n", "\\n")

fn json_array(values: [text], limit: i64) -> text:
    var body = "["
    var shown = 0
    while shown < values.len() and shown < limit:
        if shown > 0:
            body = body + ", "
        body = body + "\"" + json_escape(values[shown]) + "\""
        shown = shown + 1
    body + "]"

fn print_json_report(runtime_hooks: [text], gc_wildcards: [text], nogc_wildcards: [text], simpleos_imports: [text], portable_imports: [text]):
    val audit_passed = runtime_hooks.len() == 0 and gc_wildcards.len() == 0 and nogc_wildcards.len() == 0 and simpleos_imports.len() == 0 and portable_imports.len() == 0
    print("{")
    print("  \"async_compat_direct_runtime_hook_count\": " + runtime_hooks.len().to_string() + ",")
    print("  \"async_compat_direct_runtime_hook_samples\": " + json_array(runtime_hooks, 20) + ",")
    print("  \"gc_async_runtime_owner_wildcard_facade_count\": " + gc_wildcards.len().to_string() + ",")
    print("  \"gc_async_runtime_owner_wildcard_facade_samples\": " + json_array(gc_wildcards, 20) + ",")
    print("  \"generated_by\": \"scripts/audit/runtime_backend_boundaries.spl\",")
    print("  \"nogc_async_runtime_owner_wildcard_facade_count\": " + nogc_wildcards.len().to_string() + ",")
    print("  \"nogc_async_runtime_owner_wildcard_facade_samples\": " + json_array(nogc_wildcards, 20) + ",")
    print("  \"pass\": " + (if audit_passed: "true" else: "false") + ",")
    print("  \"portable_lib_forbidden_posix_linux_import_count\": " + portable_imports.len().to_string() + ",")
    print("  \"portable_lib_forbidden_posix_linux_import_samples\": " + json_array(portable_imports, 20) + ",")
    print("  \"simpleos_lower_layer_posix_libc_import_count\": " + simpleos_imports.len().to_string() + ",")
    print("  \"simpleos_lower_layer_posix_libc_import_samples\": " + json_array(simpleos_imports, 20))
    print("}")

val config = parse_args(normalize_args(rt_cli_get_args()))
val runtime_hooks = direct_runtime_hooks(config.root)
val gc_wildcards = async_runtime_owner_wildcards(config.root, "src/lib/gc_async_mut")
val nogc_wildcards = async_runtime_owner_wildcards(config.root, "src/lib/nogc_async_mut")
val simpleos_imports = simpleos_lower_layer_imports(config.root)
val portable_imports = portable_lib_imports(config.root)
print_json_report(runtime_hooks, gc_wildcards, nogc_wildcards, simpleos_imports, portable_imports)

if runtime_hooks.len() == 0 and gc_wildcards.len() == 0 and nogc_wildcards.len() == 0 and simpleos_imports.len() == 0 and portable_imports.len() == 0:
    rt_exit(0)
rt_exit(1)
