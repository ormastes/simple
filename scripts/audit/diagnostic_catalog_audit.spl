# Verify stable diagnostic codes have useful catalog explanations.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_exit(code: i32) -> void

fn is_digit_char(ch: text) -> bool:
    ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9"

fn is_stable_code(code: text) -> bool:
    if code.len() != 5:
        return false
    val prefix = code.substring(0, 1)
    if prefix != "E" and prefix != "W":
        return false
    is_digit_char(code.substring(1, 2)) and is_digit_char(code.substring(2, 3)) and is_digit_char(code.substring(3, 4)) and is_digit_char(code.substring(4, 5))

fn list_contains(values: [text], value: text) -> bool:
    for item in values:
        if item == value:
            return true
    false

fn push_unique(values: [text], value: text) -> [text]:
    if value == "" or list_contains(values, value):
        return values
    values.push(value)

fn quoted_value_after(source: text, marker: text) -> text:
    val marker_idx = source.index_of(marker) ?? -1
    if marker_idx < 0:
        return ""
    val rest = source.substring(marker_idx + marker.len())
    val first_quote = rest.index_of("\"") ?? -1
    if first_quote < 0:
        return ""
    val after_quote = rest.substring(first_quote + 1)
    val second_quote = after_quote.index_of("\"") ?? -1
    if second_quote < 0:
        return ""
    after_quote.substring(0, second_quote)

fn stable_code_literals_from_line(line: text) -> [text]:
    var codes: [text] = []
    val error_code = quoted_value_after(line, "error_code:")
    if is_stable_code(error_code):
        codes = push_unique(codes, error_code)
    val warning_code = quoted_value_after(line, "warning_code:")
    if is_stable_code(warning_code):
        codes = push_unique(codes, warning_code)
    val rust_code = quoted_value_after(line, "code: Some(")
    if is_stable_code(rust_code):
        codes = push_unique(codes, rust_code)
    codes

fn assigned_codes_from_file(path: text) -> [text]:
    val source = rt_file_read_text(path) ?? ""
    var codes: [text] = []
    var in_error_code_enum = false
    for line in source.split("\n"):
        for code in stable_code_literals_from_line(line):
            codes = push_unique(codes, code)

        val stripped = line.trim()
        if stripped.starts_with("enum ") and stripped.ends_with("ErrorCode:"):
            in_error_code_enum = true
        elif in_error_code_enum and stripped != "" and not line.starts_with(" ") and not line.starts_with("\t"):
            in_error_code_enum = false

        if in_error_code_enum and is_stable_code(stripped):
            codes = push_unique(codes, stripped)
    codes

fn list_scan_files() -> [text]:
    val command = "find src/compiler src/app src/compiler_rust/driver/src/cli -type f \\( -name '*.spl' -o -name '*.rs' \\) 2>/dev/null | sort"
    val result = rt_process_run("/bin/sh", ["-c", command])
    if result.2 != 0:
        print("Diagnostic Catalog Audit")
        print("========================")
        print("find failed:")
        print(result.1)
        rt_exit(1)
    var files: [text] = []
    for raw in result.0.split("\n"):
        val path = raw.trim()
        if path != "" and not path.contains("/vendor/"):
            files = files.push(path)
    files

fn all_assigned_codes() -> [text]:
    var codes: [text] = []
    for path in list_scan_files():
        for code in assigned_codes_from_file(path):
            codes = push_unique(codes, code)
    codes

fn block_until_close(source: text) -> [text]:
    var blocks: [text] = []
    val marker = "self.register(ErrorExplanation("
    val parts = source.split(marker)
    var idx = 1
    while idx < parts.len():
        val part = parts[idx]
        val end = part.index_of("))") ?? -1
        if end >= 0:
            blocks = blocks.push(part.substring(0, end))
        idx = idx + 1
    blocks

fn list_field_has_values(block: text, field: text) -> bool:
    val field_idx = block.index_of(field + ":") ?? -1
    if field_idx < 0:
        return false
    val rest = block.substring(field_idx)
    val open_idx = rest.index_of("[") ?? -1
    if open_idx < 0:
        return false
    val after_open = rest.substring(open_idx + 1)
    val close_idx = after_open.index_of("]") ?? -1
    if close_idx < 0:
        return false
    val items = after_open.substring(0, close_idx)
    var count = 0
    var scan = items
    while true:
        val first = scan.index_of("\"") ?? -1
        if first < 0:
            break
        val after_first = scan.substring(first + 1)
        val second = after_first.index_of("\"") ?? -1
        if second < 0:
            break
        if after_first.substring(0, second).trim() != "":
            count = count + 1
        scan = after_first.substring(second + 1)
    count > 0

fn catalog_code_index(codes: [text], code: text) -> i64:
    var idx = 0
    while idx < codes.len():
        if codes[idx] == code:
            return idx
        idx = idx + 1
    -1

val catalog_source = rt_file_read_text("src/compiler/95.interp/interpreter/errors.spl") ?? ""
var catalog_codes: [text] = []
var catalog_title_ok: [bool] = []
var catalog_description_ok: [bool] = []
var catalog_causes_ok: [bool] = []
var catalog_fixes_ok: [bool] = []

for block in block_until_close(catalog_source):
    val code = quoted_value_after(block, "code:")
    if is_stable_code(code):
        catalog_codes = catalog_codes.push(code)
        catalog_title_ok = catalog_title_ok.push(quoted_value_after(block, "title:").trim() != "")
        catalog_description_ok = catalog_description_ok.push(quoted_value_after(block, "description:").trim() != "")
        catalog_causes_ok = catalog_causes_ok.push(list_field_has_values(block, "causes"))
        catalog_fixes_ok = catalog_fixes_ok.push(list_field_has_values(block, "fixes"))

val assigned = all_assigned_codes()
var missing: [text] = []
var quality: [text] = []

for code in assigned:
    val idx = catalog_code_index(catalog_codes, code)
    if idx < 0:
        missing = missing.push(code)
    else:
        if not catalog_title_ok[idx]:
            quality = quality.push(code + ": missing non-empty title")
        if not catalog_description_ok[idx]:
            quality = quality.push(code + ": missing non-empty description")
        if not catalog_causes_ok[idx]:
            quality = quality.push(code + ": missing non-empty causes")
        if not catalog_fixes_ok[idx]:
            quality = quality.push(code + ": missing non-empty fixes")

print("Diagnostic Catalog Audit")
print("========================")
print("Assigned stable codes: " + assigned.len().to_string())
print("Catalog entries: " + catalog_codes.len().to_string())
if missing.len() == 0 and quality.len() == 0:
    print("All assigned stable diagnostic codes have useful catalog entries")
    rt_exit(0)

if missing.len() > 0:
    print("Missing catalog entries:")
    for code in missing:
        print("  - " + code)
if quality.len() > 0:
    print("Catalog quality violations:")
    for item in quality:
        print("  - " + item)
rt_exit(1)
