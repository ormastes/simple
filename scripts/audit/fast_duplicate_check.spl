# Fast exact line-window duplicate gate for Simple source trees.
# Facades kept to the lightweight io submodules (not the app.io hub) so the
# gate keeps its ~24ms cold start.

use std.nogc_sync_mut.io.file_ops.{file_read_text}
use std.nogc_sync_mut.io.dir_ops.{dir_walk_native}
use std.nogc_sync_mut.sffi.cli.{cli_get_args, cli_exit}

struct FastDupConfig:
    path: text
    min_lines: i64
    output_format: text
    max_allowed: i64
    excludes: [text]

struct FastDupBlock:
    file: text
    line_start: i64
    line_end: i64

struct FastDupBucket:
    key: text
    blocks: [FastDupBlock]

fn basename(path: text) -> text:
    var idx = path.len() - 1
    while idx >= 0:
        if path.substring(idx, idx + 1) == "/":
            return path.substring(idx + 1, path.len())
        idx = idx - 1
    path

fn parse_i64_or(value: text, fallback: i64) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return fallback
    trimmed.to_i64()

fn normalize_args(all_args: [text]) -> [text]:
    var start = 0
    var found = false
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("fast_duplicate_check.spl"):
            start = i + 1
            found = true
            break
        i = i + 1
    if not found and all_args.len() > 0:
        start = 1

    var args: [text] = []
    i = start
    while i < all_args.len():
        if all_args[i] != "--":
            args = args.push(all_args[i])
        i = i + 1
    args

fn default_config() -> FastDupConfig:
    FastDupConfig(
        path: "src/",
        min_lines: 5,
        output_format: "text",
        max_allowed: 0,
        excludes: ["test/", "doc/", "_spec.spl", "_test.spl"]
    )

fn parse_args(args: [text]) -> FastDupConfig:
    var config = default_config()
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--min-lines" and i + 1 < args.len():
            config.min_lines = parse_i64_or(args[i + 1], config.min_lines)
            i = i + 2
        elif arg.starts_with("--min-lines="):
            config.min_lines = parse_i64_or(arg.substring("--min-lines=".len()), config.min_lines)
            i = i + 1
        elif arg == "--format" and i + 1 < args.len():
            config.output_format = args[i + 1]
            i = i + 2
        elif arg.starts_with("--format="):
            config.output_format = arg.substring("--format=".len())
            i = i + 1
        elif arg == "--max-allowed" and i + 1 < args.len():
            config.max_allowed = parse_i64_or(args[i + 1], config.max_allowed)
            i = i + 2
        elif arg.starts_with("--max-allowed="):
            config.max_allowed = parse_i64_or(arg.substring("--max-allowed=".len()), config.max_allowed)
            i = i + 1
        elif arg == "--exclude" and i + 1 < args.len():
            config.excludes = config.excludes.push(args[i + 1])
            i = i + 2
        elif arg.starts_with("--exclude="):
            config.excludes = config.excludes.push(arg.substring("--exclude=".len()))
            i = i + 1
        elif not arg.starts_with("-"):
            config.path = arg
            i = i + 1
        else:
            i = i + 1

    if config.min_lines < 1:
        config.min_lines = 1
    config

fn excluded(path: text, excludes: [text]) -> bool:
    val name = basename(path)
    for pattern in excludes:
        val p = pattern.trim()
        if p == "":
            continue
        if p.ends_with("/") and path.contains("/" + p):
            return true
        if p.starts_with("**/*") and name.ends_with(p.substring(4)):
            return true
        if path.contains(p):
            return true
    false

fn collect_files(config: FastDupConfig) -> [text]:
    if config.path.ends_with(".spl"):
        if excluded(config.path, config.excludes):
            return []
        return [config.path]

    var files: [text] = []
    for path in dir_walk_native(config.path):
        if path.ends_with(".spl") and not excluded(path, config.excludes):
            files = files.push(path)
    files.sort()
    files

fn has_signal(window: text) -> bool:
    for line in window.split("\n"):
        val stripped = line.trim()
        if stripped.starts_with("#"):
            continue
        if stripped.starts_with("fn ") or stripped.starts_with("me ") or
            stripped.starts_with("if ") or stripped.starts_with("elif ") or
            stripped.starts_with("while ") or stripped.starts_with("for ") or
            stripped.starts_with("match ") or stripped.starts_with("return") or
            stripped.starts_with("val ") or stripped.starts_with("var ") or
            stripped.starts_with("class ") or stripped.starts_with("struct ") or
            stripped.starts_with("enum "):
            return true
    false

fn window_key(lines: [text], start: i64, min_lines: i64) -> text:
    var parts: [text] = []
    var idx = start
    while idx < start + min_lines:
        # Indentation is semantic in Simple, so exact-mode keys retain it.
        parts = parts.push(lines[idx])
        idx = idx + 1
    parts.join("\n")

fn find_duplicate_buckets(files: [text], min_lines: i64) -> [FastDupBucket]:
    var buckets: [FastDupBucket] = []
    var bucket_by_key: {text: i64} = {}
    for path in files:
        val source = file_read_text(path)
        val lines = source.split("\n")
        if lines.len() < min_lines:
            continue
        var start = 0
        while start <= lines.len() - min_lines:
            val key = window_key(lines, start, min_lines)
            if has_signal(key):
                val block = FastDupBlock(file: path, line_start: start + 1, line_end: start + min_lines)
                if bucket_by_key.has(key):
                    val idx = bucket_by_key[key]
                    var bucket = buckets[idx]
                    bucket.blocks = bucket.blocks.push(block)
                    buckets[idx] = bucket
                else:
                    bucket_by_key[key] = buckets.len()
                    buckets = buckets.push(FastDupBucket(key: key, blocks: [block]))
            start = start + 1
    collapse_shifted_duplicate_buckets(buckets, min_lines)

fn shifted_bucket_continues(previous: FastDupBucket, current: FastDupBucket, min_lines: i64) -> bool:
    if previous.blocks.len() < 2 or previous.blocks.len() != current.blocks.len():
        return false
    var i = 0
    while i < previous.blocks.len():
        val before = previous.blocks[i]
        val after = current.blocks[i]
        if before.file != after.file or after.line_start != before.line_end - min_lines + 2:
            return false
        i = i + 1
    true

fn merge_shifted_buckets(previous: FastDupBucket, current: FastDupBucket) -> FastDupBucket:
    var blocks: [FastDupBlock] = []
    var i = 0
    while i < previous.blocks.len():
        blocks.push(FastDupBlock(
            file: previous.blocks[i].file,
            line_start: previous.blocks[i].line_start,
            line_end: current.blocks[i].line_end
        ))
        i = i + 1
    FastDupBucket(key: previous.key, blocks: blocks)

fn collapse_shifted_duplicate_buckets(buckets: [FastDupBucket], min_lines: i64) -> [FastDupBucket]:
    var collapsed: [FastDupBucket] = []
    for bucket in buckets:
        if bucket.blocks.len() < 2:
            continue
        if collapsed.len() > 0 and shifted_bucket_continues(collapsed[collapsed.len() - 1], bucket, min_lines):
            collapsed[collapsed.len() - 1] = merge_shifted_buckets(collapsed[collapsed.len() - 1], bucket)
        else:
            collapsed.push(bucket)
    collapsed

fn duplicate_count(buckets: [FastDupBucket]) -> i64:
    var count = 0
    for bucket in buckets:
        if bucket.blocks.len() >= 2:
            count = count + 1
    count

fn duplicate_total_lines(buckets: [FastDupBucket], min_lines: i64) -> i64:
    var total = 0
    for bucket in buckets:
        if bucket.blocks.len() >= 2:
            total = total + bucket.blocks.len() * bucket_line_count(bucket, min_lines)
    total

fn impact_score(bucket: FastDupBucket, min_lines: i64) -> i64:
    bucket.blocks.len() * bucket.blocks.len() * bucket_line_count(bucket, min_lines)

fn bucket_line_count(bucket: FastDupBucket, fallback: i64) -> i64:
    if bucket.blocks.len() == 0:
        return fallback
    bucket.blocks[0].line_end - bucket.blocks[0].line_start + 1

fn best_unprinted_bucket(buckets: [FastDupBucket], printed: [bool], min_lines: i64) -> i64:
    var best = -1
    var best_score = -1
    var idx = 0
    while idx < buckets.len():
        if not printed[idx] and buckets[idx].blocks.len() >= 2:
            val score = impact_score(buckets[idx], min_lines)
            if score > best_score:
                best = idx
                best_score = score
        idx = idx + 1
    best

fn print_text_report(buckets: [FastDupBucket], file_count: i64, min_lines: i64):
    val group_count = duplicate_count(buckets)
    val total_lines = duplicate_total_lines(buckets, min_lines)
    print("Token Duplicate Report")
    print("======================")
    print("")
    print("Scanned " + file_count.to_string() + " files")
    print("Found " + group_count.to_string() + " duplicate groups (" + total_lines.to_string() + " total lines duplicated)")
    print("")

    var printed: [bool] = []
    for bucket in buckets:
        printed = printed.push(false)

    var group_num = 1
    while group_num <= 20:
        val idx = best_unprinted_bucket(buckets, printed, min_lines)
        if idx < 0:
            break
        printed[idx] = true
        val bucket = buckets[idx]
        val lines_each = bucket_line_count(bucket, min_lines)
        print(group_num.to_string() + ". Impact Score: " + impact_score(bucket, min_lines).to_string() + " (" + bucket.blocks.len().to_string() + " occurrences, " + lines_each.to_string() + " lines each)")
        print("   Files:")
        for block in bucket.blocks:
            print("   - " + block.file + ":" + block.line_start.to_string() + "-" + block.line_end.to_string())
        print("")
        group_num = group_num + 1

fn json_escape(value: text) -> text:
    val escaped_backslash = value.replace("\\", "\\\\")
    val escaped_quote = escaped_backslash.replace("\"", "\\\"")
    escaped_quote.replace("\n", "\\n")

fn print_json_report(buckets: [FastDupBucket], file_count: i64, min_lines: i64):
    print("{")
    print("  \"files\": " + file_count.to_string() + ",")
    print("  \"duplicates\": [")
    var first_group = true
    for bucket in buckets:
        if bucket.blocks.len() < 2:
            continue
        if not first_group:
            print(",")
        first_group = false
        val lines_each = bucket_line_count(bucket, min_lines)
        print("    {\"occurrences\": " + bucket.blocks.len().to_string() + ", \"lines_each\": " + lines_each.to_string() + ", \"total_lines\": " + (bucket.blocks.len() * lines_each).to_string() + ", \"impact_score\": " + impact_score(bucket, min_lines).to_string() + ", \"blocks\": [")
        var first_block = true
        for block in bucket.blocks:
            if not first_block:
                print(",")
            first_block = false
            print("      {\"file\": \"" + json_escape(block.file) + "\", \"line_start\": " + block.line_start.to_string() + ", \"line_end\": " + block.line_end.to_string() + "}")
        print("    ], \"code\": \"" + json_escape(bucket.key) + "\"}")
    print("")
    print("  ]")
    print("}")

val config = parse_args(normalize_args(cli_get_args()))
val files = collect_files(config)
val buckets = find_duplicate_buckets(files, config.min_lines)
if config.output_format == "json":
    print_json_report(buckets, files.len(), config.min_lines)
else:
    print_text_report(buckets, files.len(), config.min_lines)

if duplicate_count(buckets) > config.max_allowed:
    cli_exit(1)
cli_exit(0)
