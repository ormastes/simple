# Memory monitor - kills release/simple processes when memory > 50%
# Usage: bin/simple run scripts/mem_monitor.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn main():
    print "[mem_monitor] Started. Threshold: 50% memory usage."
    while true:
        val mem_percent = shell_output("free | awk '/^Mem:/{{printf \"%.0f\", $3/$2 * 100}}'")
        val pct = int(mem_percent)
        if pct >= 50:
            print "[mem_monitor] Memory at {mem_percent}% - killing release/simple processes"
            shell("pkill -f 'release/simple' 2>/dev/null || true")
            print "[mem_monitor] Killed. Waiting 10s before resuming monitoring..."
            shell("sleep 10")
        shell("sleep 2")
