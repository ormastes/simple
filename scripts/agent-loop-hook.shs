#!/usr/bin/env bash
# Agent Loop Stop Hook for Claude Code
# Checks for active agent loops and outputs continuation prompt.
# Used by Claude Code hooks to auto-resume iteration loops.

ACTIVE_LOOP_FILE=".build/agent_loop/active_loop.id"

# Exit early if no active loop
if [ ! -f "$ACTIVE_LOOP_FILE" ]; then
    exit 0
fi

LOOP_ID=$(cat "$ACTIVE_LOOP_FILE" 2>/dev/null)
if [ -z "$LOOP_ID" ]; then
    exit 0
fi

STATE_FILE=".build/agent_loop/loops/${LOOP_ID}.state"
if [ ! -f "$STATE_FILE" ]; then
    exit 0
fi

# Read state
STATUS=$(grep "^status=" "$STATE_FILE" | cut -d= -f2-)
ITERATION=$(grep "^iteration=" "$STATE_FILE" | cut -d= -f2-)
MAX_ITER=$(grep "^max_iterations=" "$STATE_FILE" | cut -d= -f2-)
PROMPT=$(grep "^prompt=" "$STATE_FILE" | cut -d= -f2-)

# Only continue if loop is active
if [ "$STATUS" != "active" ]; then
    exit 0
fi

# Output continuation prompt for Claude Code to re-feed
echo "Agent loop '${LOOP_ID}' is active (iteration ${ITERATION}/${MAX_ITER})."
echo "Continue the loop by calling agent_loop_step with the result of your work."
echo "Original prompt: ${PROMPT}"
