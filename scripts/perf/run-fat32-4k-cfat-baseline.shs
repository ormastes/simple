#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
CC_BIN="${CC:-cc}"
OUT="${TMPDIR:-/tmp}/cfat32_4k_baseline"

"$CC_BIN" -O2 "$ROOT/scripts/perf/cfat32_4k_baseline.c" -o "$OUT"

echo "=== Simple FAT32 4K benchmark ==="
SIMPLE_LIB="$ROOT/src" "$ROOT/src/compiler_rust/target/debug/simple" "$ROOT/test/perf/bench/fat32_4k_compare.spl"

echo
echo "=== C FAT32 direct-image baseline ==="
"$OUT"
