#!/usr/bin/env bash
# Build with full verbose output
# Usage: scripts/build_verbose.shs [--release]

set -euo pipefail

ARGS="${*}"
echo "=== Build (verbose) ==="
echo "Args: ${ARGS:-none}"
echo ""

bin/simple build ${ARGS} 2>&1

EXIT=$?
echo ""
if [ $EXIT -eq 0 ]; then
    echo "=== Build succeeded ==="
else
    echo "=== Build FAILED (exit $EXIT) ==="
fi
exit $EXIT
