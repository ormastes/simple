#!/bin/bash
# SStack Dashboard Bridge
# Watches .agent/STATUS.json for changes and converts SStack state transitions
# into JSONL events consumable by the LLM Agent Dashboard's JsonlWatcher +
# AgentDashboardStore.
#
# Usage:
#   scripts/sstack-dashboard-bridge.shs         # foreground
#   scripts/sstack-dashboard-bridge.shs &       # background alongside orchestrator
#
# The dashboard reads events from:  .agent/events/sstack.jsonl
# Launch dashboard:  bin/simple llm-dashboard --dir .agent/events --gui --port 3001

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

STATUS_FILE="$PROJECT_ROOT/.agent/STATUS.json"
EVENTS_DIR="$PROJECT_ROOT/.agent/events"
EVENTS_FILE="$EVENTS_DIR/sstack.jsonl"
POLL_INTERVAL=2   # seconds between STATUS.json checks

# --- Helpers ---

now_iso() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

emit_event() {
    local type="$1" agent_id="$2" extra="$3"
    mkdir -p "$EVENTS_DIR"
    printf '{"type":"%s","agent_id":"%s",%s"timestamp":"%s"}\n' \
        "$type" "$agent_id" "$extra" "$(now_iso)" >> "$EVENTS_FILE"
}

# Read a JSON field from STATUS.json (simple sed-based, no jq/python dependency)
json_field() {
    local field="$1" file="$2"
    sed -n "s/.*\"$field\"[[:space:]]*:[[:space:]]*\"\{0,1\}\([^,\"}\n]*\)\"\{0,1\}.*/\1/p" "$file" 2>/dev/null | head -1
}

# --- State tracking ---

PREV_STATE=""
PREV_TASK=""
TASK_START_EPOCH=""

# --- Main loop ---

main() {
    mkdir -p "$EVENTS_DIR"

    echo "[$(now_iso)] SStack Dashboard Bridge started (PID $$)"
    echo "[$(now_iso)] Watching: $STATUS_FILE"
    echo "[$(now_iso)] Writing events to: $EVENTS_FILE"

    # Emit bridge startup event
    emit_event "bridge_start" "sstack-bridge" '"role":"Bridge",'

    while true; do
        if [[ ! -f "$STATUS_FILE" ]]; then
            sleep "$POLL_INTERVAL"
            continue
        fi

        local state task remaining
        state="$(json_field "state" "$STATUS_FILE")"
        task="$(json_field "task" "$STATUS_FILE")"
        remaining="$(json_field "tasks_remaining" "$STATUS_FILE")"

        # Detect state transitions
        if [[ "$state" != "$PREV_STATE" ]] || [[ "$task" != "$PREV_TASK" ]]; then

            # --- Transition: idle/sleeping -> working (new task started) ---
            if [[ "$state" == "working" ]] && [[ "$PREV_STATE" != "working" ]]; then
                TASK_START_EPOCH="$(date +%s)"
                local escaped_task
                escaped_task="$(printf '%s' "$task" | sed 's/"/\\"/g')"
                emit_event "task_start" "sstack-orchestrator" \
                    "\"status\":\"working\",\"task\":\"$escaped_task\",\"tasks_remaining\":$remaining,\"role\":\"Engineer\","

                emit_event "agent_status" "sstack-orchestrator" \
                    "\"status\":\"working\",\"task\":\"$escaped_task\",\"phase\":\"5-implement\",\"role\":\"Engineer\","
            fi

            # --- Transition: working -> working (task changed mid-flight) ---
            if [[ "$state" == "working" ]] && [[ "$PREV_STATE" == "working" ]] && [[ "$task" != "$PREV_TASK" ]]; then
                # Previous task finished (implicitly), new one started
                if [[ -n "$PREV_TASK" ]]; then
                    local prev_escaped
                    prev_escaped="$(printf '%s' "$PREV_TASK" | sed 's/"/\\"/g')"
                    local duration=0
                    if [[ -n "$TASK_START_EPOCH" ]]; then
                        duration=$(( $(date +%s) - TASK_START_EPOCH ))
                    fi
                    emit_event "task_complete" "sstack-orchestrator" \
                        "\"task\":\"$prev_escaped\",\"duration_sec\":$duration,\"role\":\"Engineer\","
                fi
                TASK_START_EPOCH="$(date +%s)"
                local escaped_task
                escaped_task="$(printf '%s' "$task" | sed 's/"/\\"/g')"
                emit_event "task_start" "sstack-orchestrator" \
                    "\"status\":\"working\",\"task\":\"$escaped_task\",\"tasks_remaining\":$remaining,\"role\":\"Engineer\","
            fi

            # --- Transition: working -> idle (task completed) ---
            if [[ "$state" == "idle" ]] && [[ "$PREV_STATE" == "working" ]]; then
                local prev_escaped
                prev_escaped="$(printf '%s' "$PREV_TASK" | sed 's/"/\\"/g')"
                local duration=0
                if [[ -n "$TASK_START_EPOCH" ]]; then
                    duration=$(( $(date +%s) - TASK_START_EPOCH ))
                fi
                emit_event "task_complete" "sstack-orchestrator" \
                    "\"task\":\"$prev_escaped\",\"duration_sec\":$duration,\"tasks_remaining\":$remaining,\"role\":\"Engineer\","

                emit_event "agent_status" "sstack-orchestrator" \
                    "\"status\":\"idle\",\"task\":\"\",\"role\":\"Engineer\","
                TASK_START_EPOCH=""
            fi

            # --- Transition: working -> crashed ---
            if [[ "$state" == "crashed" ]] && [[ "$PREV_STATE" == "working" ]]; then
                local prev_escaped
                prev_escaped="$(printf '%s' "$PREV_TASK" | sed 's/"/\\"/g')"
                local duration=0
                if [[ -n "$TASK_START_EPOCH" ]]; then
                    duration=$(( $(date +%s) - TASK_START_EPOCH ))
                fi
                emit_event "task_failed" "sstack-orchestrator" \
                    "\"task\":\"$prev_escaped\",\"duration_sec\":$duration,\"exit_code\":1,\"role\":\"Engineer\","

                emit_event "agent_status" "sstack-orchestrator" \
                    "\"status\":\"crashed\",\"task\":\"$prev_escaped\",\"role\":\"Engineer\","
                TASK_START_EPOCH=""
            fi

            # --- Transition: * -> sleeping ---
            if [[ "$state" == "sleeping" ]]; then
                emit_event "agent_status" "sstack-orchestrator" \
                    "\"status\":\"sleeping\",\"task\":\"\",\"role\":\"Engineer\","
            fi

            PREV_STATE="$state"
            PREV_TASK="$task"
        fi

        sleep "$POLL_INTERVAL"
    done
}

main "$@"
