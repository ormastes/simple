    echo "| \`$RV32_SEMIHOST_TRAP\` | 1 | $RV32_SEMIHOST_TRAP_LINES | $RV32_SEMIHOST_TRAP_BYTES |"
    echo "| \`$RV64_SEMIHOST_TRAP\` | 1 | $RV64_SEMIHOST_TRAP_LINES | $RV64_SEMIHOST_TRAP_BYTES |"
    echo "| \`$SHARED_RISCV_SEMIHOST_TRAP\` | 1 | $SHARED_RISCV_SEMIHOST_TRAP_LINES | $SHARED_RISCV_SEMIHOST_TRAP_BYTES |"
    echo "| \`$ARM_SEMIHOST_TRAP\` | 1 | $ARM_SEMIHOST_TRAP_LINES | $ARM_SEMIHOST_TRAP_BYTES |"
    echo "| \`$SHARED_ARM_SEMIHOST_TRAP\` | 1 | $SHARED_ARM_SEMIHOST_TRAP_LINES | $SHARED_ARM_SEMIHOST_TRAP_BYTES |"
    echo "| \`$ARM64_SEMIHOST_TRAP\` | 1 | $ARM64_SEMIHOST_TRAP_LINES | $ARM64_SEMIHOST_TRAP_BYTES |"
    echo "| \`$PURE_POLICY_PROBE\` | 1 | $PURE_POLICY_PROBE_LINES | $PURE_POLICY_PROBE_BYTES |"
    echo "| \`$CONSOLE_POLICY\` | 1 | $CONSOLE_POLICY_LINES | $CONSOLE_POLICY_BYTES |"
    echo "| \`$STDOUT_PLAN\` | 1 | $STDOUT_PLAN_LINES | $STDOUT_PLAN_BYTES |"
    echo "| \`$STDOUT_POLICY_PLAN\` | 1 | $STDOUT_POLICY_PLAN_LINES | $STDOUT_POLICY_PLAN_BYTES |"
    echo "| \`$INTERRUPT_POLICY\` | 1 | $INTERRUPT_POLICY_LINES | $INTERRUPT_POLICY_BYTES |"
    echo "| \`$STARTUP_POLICY\` | 1 | $STARTUP_POLICY_LINES | $STARTUP_POLICY_BYTES |"
    echo "| \`$STARTUP_PLAN\` | 1 | $STARTUP_PLAN_LINES | $STARTUP_PLAN_BYTES |"
    echo "| \`$SEMIHOST_POLICY\` | 1 | $SEMIHOST_POLICY_LINES | $SEMIHOST_POLICY_BYTES |"
    echo "| \`$SEMIHOST_STDOUT_POLICY\` | 1 | $SEMIHOST_STDOUT_POLICY_LINES | $SEMIHOST_STDOUT_POLICY_BYTES |"
    echo "| \`$BAREMETAL_POLICY_FACADE\` | 1 | $BAREMETAL_POLICY_FACADE_LINES | $BAREMETAL_POLICY_FACADE_BYTES |"
    echo
    echo "## Browser Cluster Source Sizes"
    echo
    echo "| Cluster | Files | Lines | Bytes |"
    echo "|---|---:|---:|---:|"
    cat "$browser_cluster_rows"
    echo
    echo "## Retention Checks"
    echo
    echo "| Artifact | Forbidden Binary Marker Matches | Forbidden Build Log Marker Matches |"
    echo "|---|---:|---:|"
    echo "| Browser simple render HTML | n/a | $BROWSER_RENDER_FORBIDDEN_LOG_MARKERS |"
    echo "| Simple web static facade | $STATIC_WEB_FORBIDDEN_MARKERS | $STATIC_WEB_FORBIDDEN_LOG_MARKERS |"
    echo "| Simple web placeholder URL facade | $PLACEHOLDER_WEB_FORBIDDEN_MARKERS | $PLACEHOLDER_WEB_FORBIDDEN_LOG_MARKERS |"
    echo "| Simple web file facade | $FILE_WEB_FORBIDDEN_MARKERS | $FILE_WEB_FORBIDDEN_LOG_MARKERS |"
    echo "| Simple web script placeholder facade | $SCRIPT_PLACEHOLDER_WEB_FORBIDDEN_MARKERS | $SCRIPT_PLACEHOLDER_WEB_FORBIDDEN_LOG_MARKERS |"
    echo "| Simple web script file facade expected retention | $SCRIPT_FILE_WEB_RETENTION_MARKERS | $SCRIPT_FILE_WEB_RETENTION_LOG_MARKERS |"
    echo "| Simple web script file facade forbidden full renderer | $SCRIPT_FILE_WEB_FORBIDDEN_MARKERS | $SCRIPT_FILE_WEB_FORBIDDEN_LOG_MARKERS |"
    echo "| Bare-metal pure policy probe | $PURE_POLICY_FORBIDDEN_MARKERS | $PURE_POLICY_FORBIDDEN_LOG_MARKERS |"
    echo "| RV32 semihost trap capsule | $RV32_SEMIHOST_TRAP_FORBIDDEN_MARKERS | n/a |"
    echo "| RV64 semihost trap capsule | $RV64_SEMIHOST_TRAP_FORBIDDEN_MARKERS | n/a |"
    echo "| ARM semihost trap capsule | $ARM_SEMIHOST_TRAP_FORBIDDEN_MARKERS | n/a |"
    echo "| ARM64 semihost trap capsule | $ARM64_SEMIHOST_TRAP_FORBIDDEN_MARKERS | n/a |"
    echo "| x86_64 minimal boot/stdout capsule | $X86_64_MIN_BOOT_STDOUT_FORBIDDEN_MARKERS | n/a |"
    echo "| ARM64 minimal PL011 startup/stdout capsule | $ARM64_MIN_UART_STDOUT_FORBIDDEN_MARKERS | n/a |"
    echo "| ARM32 minimal PL011 startup/stdout capsule | $ARM32_MIN_UART_STDOUT_FORBIDDEN_MARKERS | n/a |"
    echo "| RV64 minimal 16550 startup/stdout capsule | $RV64_MIN_UART_STDOUT_FORBIDDEN_MARKERS | n/a |"
    echo "| RV32 minimal 16550 startup/stdout capsule | $RV32_MIN_UART_STDOUT_FORBIDDEN_MARKERS | n/a |"
    echo "| x86_64 interrupt-control capsule | $X86_64_INTERRUPT_CONTROL_FORBIDDEN_MARKERS | n/a |"
    echo "| ARM64 interrupt-control capsule | $ARM64_INTERRUPT_CONTROL_FORBIDDEN_MARKERS | n/a |"
    echo "| ARM32 interrupt-control capsule | $ARM32_INTERRUPT_CONTROL_FORBIDDEN_MARKERS | n/a |"
    echo "| RV64 interrupt-control capsule | $RV64_INTERRUPT_CONTROL_FORBIDDEN_MARKERS | n/a |"
    echo "| RV32 interrupt-control capsule | $RV32_INTERRUPT_CONTROL_FORBIDDEN_MARKERS | n/a |"
    echo "| x86_64 startup handoff capsule | $X86_64_STARTUP_HANDOFF_FORBIDDEN_MARKERS | n/a |"
    echo "| Shared startup handoff x86_64 capsule | $SHARED_STARTUP_HANDOFF_X86_64_FORBIDDEN_MARKERS | n/a |"
    echo "| Shared startup handoff ARM64 capsule | $SHARED_STARTUP_HANDOFF_ARM64_FORBIDDEN_MARKERS | n/a |"
    echo "| Shared startup handoff ARM32 capsule | $SHARED_STARTUP_HANDOFF_ARM32_FORBIDDEN_MARKERS | n/a |"
    echo "| Shared startup handoff RV64 capsule | $SHARED_STARTUP_HANDOFF_RV64_FORBIDDEN_MARKERS | n/a |"
    echo "| Shared startup handoff RV32 capsule | $SHARED_STARTUP_HANDOFF_RV32_FORBIDDEN_MARKERS | n/a |"
    echo
    echo "## Direction"
    echo
    echo "- Browser render size work should first split static render from script/session/network paths."
    echo "- \`simple_web_html_renderer\` is the HTML-only core; URL/file loading, script execution, and corpus fixtures must stay in separate facades."
    echo "- The static simple-web facade and about:/unloaded URL facade are measured separately so file, script, and fixture growth stays visible."
    echo "- \`simple_web_url_placeholder_renderer\` is the about:/unloaded URL lane and must not retain file I/O, BrowserRenderer, script execution, or corpus fixtures."
    echo "- \`simple_web_file_renderer\` is the file-capable facade and must not retain the compatibility class, script execution, BrowserRenderer, corpus fixtures, or the ARGB intermediate HTML core."
    echo "- \`simple_web_script_placeholder_renderer\` is the unloaded/about: script-mode lane and must not retain BrowserRenderer, process, file, or script execution code."
    echo "- \`simple_web_script_renderer\` is the explicit file:// script-capable lane; its BrowserRenderer/process/file stub cost is measured separately from static and placeholder facades."
    echo "- Corpus fixture compatibility lives in \`simple_web_corpus_fixture_renderer\`; production static render must not retain PPM baseline loading."
    echo "- x86_64 SimpleOS size work should split \`baremetal_stubs.c\` into boot, serial/stdout, interrupt, GUI, filesystem, network, and crypto/helper lanes."
    echo "- \`baremetal_boot_stdout.c\` is the current x86_64 platform capsule baseline for boot/stdout only; stdout ABI handling is shared through \`baremetal_min_stdout.h\`."
    echo "- \`common/baremetal_pl011_uart_stdout.c\` is the shared ARM32/ARM64 PL011 startup/stdout capsule; interrupt controllers, framebuffer, filesystem, network, and GUI stay out of this lane."
    echo "- \`arm64/boot/baremetal_uart_stdout.c\` is a thin ARM64 compatibility wrapper over the shared PL011 capsule."
    echo "- \`arm32/boot/baremetal_uart_stdout.c\` is a thin ARM32 compatibility wrapper over the shared PL011 capsule."
    echo "- \`common/baremetal_riscv_16550_uart_stdout.c\` is the shared RV32/RV64 16550 startup/stdout capsule; PLIC, CLINT, virtio, filesystem, and GUI stay out of this lane."
    echo "- \`riscv64/boot/baremetal_uart_stdout.c\` is a thin RV64 compatibility wrapper over the shared RISC-V 16550 capsule."
    echo "- \`riscv32/boot/baremetal_uart_stdout.c\` is a thin RV32 compatibility wrapper over the shared RISC-V 16550 capsule."
    echo "- \`baremetal_interrupt_control.c\` is the x86_64 platform capsule baseline for CLI/STI/HLT and PIC masking only; APIC policy stays in pure Simple until controller code is explicitly imported."
    echo "- \`common/baremetal_arm_interrupt_control.S\` is the shared ARM interrupt-control symbol scaffold; target wrappers provide only DAIF or CPSID/CPSIE/WFE instructions."
    echo "- \`arm64/boot/baremetal_interrupt_control.S\` is a thin ARM64 wrapper over the shared ARM interrupt-control scaffold; GIC policy stays in pure Simple until controller code is explicitly imported."
    echo "- \`arm32/boot/baremetal_interrupt_control.S\` is a thin ARM32 wrapper over the shared ARM interrupt-control scaffold; GIC/NVIC policy stays in pure Simple until controller code is explicitly imported."
    echo "- \`common/baremetal_riscv_interrupt_control.S\` is the shared RV32/RV64 interrupt-control capsule for mstatus.MIE mask/unmask and WFI only."
    echo "- \`riscv64/boot/baremetal_interrupt_control.S\` is a thin RV64 compatibility wrapper over the shared RISC-V interrupt-control capsule."
    echo "- \`riscv32/boot/baremetal_interrupt_control.S\` is a thin RV32 compatibility wrapper over the shared RISC-V interrupt-control capsule."
    echo "- \`common/baremetal_startup_handoff.c\` is the shared multiplatform capsule baseline for module-init and \`spl_start\` handoff only; stack/hart policy stays in pure Simple."
    echo "- \`x86_64/boot/baremetal_startup_handoff.c\` is a thin compatibility wrapper over the shared startup handoff capsule."
    echo "- Semihost stdout should use the noalloc bare-metal transport library as the shared cross-platform API surface, with only the trap instruction in the platform capsule."
    echo "- \`riscv_common/semihost_trap.S\` is the shared RV32/RV64 semihost trap scaffold for the magic sequence, WRITE0, and EXIT wrappers only."
    echo "- \`riscv32/semihost_trap.S\` is a thin RV32 compatibility wrapper over the shared RISC-V semihost trap scaffold."
    echo "- \`riscv/semihost_trap.S\` is a thin RV64 compatibility wrapper over the shared RISC-V semihost trap scaffold."
    echo "- \`common/arm_semihost_trap.S\` is the shared ARM/ARM64 semihost trap scaffold for call, WRITE0, and EXIT wrappers only."
    echo "- \`arm/semihost_trap.S\` is a thin ARM/Thumb wrapper over the shared ARM semihost trap scaffold."
    echo "- \`arm64/semihost_trap.S\` is a thin AArch64 wrapper over the shared ARM semihost trap scaffold."
    echo "- \`baremetal/console_policy.spl\` is the pure-Simple policy surface for shared semihost/UART stdout selection."
    echo "- \`baremetal/semihost_policy.spl\` is the pure-Simple policy surface for stdout semihost op selection before importing trap/transport code."
    echo "- \`baremetal/semihost_stdout_policy.spl\` adds null-safety/fd metadata while keeping the opcode policy importable for tiny native probes."
    echo "- \`baremetal/stdout_plan.spl\` combines console and semihost stdout policy before importing syscall, semihost transport, or UART implementations."
    echo "- \`baremetal/stdout_policy_plan.spl\` adds semihost stdout safety metadata while keeping the tiny stdout plan opcode-only."
    echo "- \`baremetal/interrupt_policy.spl\` is the pure-Simple policy surface for interrupt controller selection and vector classification."
    echo "- \`baremetal/startup_policy.spl\` is the pure-Simple policy surface for stack and hart startup defaults before importing architecture startup capsules."
    echo "- \`baremetal/startup_plan.spl\` composes startup defaults with interrupt-controller selection while keeping scalar startup policy importable for tiny native probes."
    echo "- \`baremetal/policy.spl\` is the aggregate pure-policy import surface; it must not import semihost transport, syscall, UART, or controller implementations."
    echo "- \`pure_policy_probe.spl\` proves examples can import only pure policies without retaining transport or controller implementations."
    echo "- The split lanes now have default regression budgets. Set any \`MAX_...\` environment value higher, lower, or empty to tune a specific gate."
} >"$REPORT_PATH"

echo "web_baremetal_size_audit_ready=true"
