RV32_MIN_UART_STDOUT_OBJ="$BUILD_DIR/rv32_baremetal_uart_stdout.o"
RV32_MIN_UART_STDOUT_LOG="$BUILD_DIR/rv32_baremetal_uart_stdout.build.log"
