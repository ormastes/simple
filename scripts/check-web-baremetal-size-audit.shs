RV32_MIN_UART_STDOUT_LINES="$(wc -l <"$RV32_MIN_UART_STDOUT" 2>/dev/null | tr -d ' ' || echo n/a)"
SHARED_RISCV_UART_STDOUT="examples/simple_os/arch/common/baremetal_riscv_16550_uart_stdout.c"
