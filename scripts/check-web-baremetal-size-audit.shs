        >"$SHARED_STARTUP_HANDOFF_RV32_LOG" 2>&1; then
        SHARED_STARTUP_HANDOFF_RV32_BUILD="ok"
    else
        SHARED_STARTUP_HANDOFF_RV32_BUILD="fail"
    fi
else
    SHARED_STARTUP_HANDOFF_X86_64_BUILD="skipped"
    SHARED_STARTUP_HANDOFF_ARM64_BUILD="skipped"
    SHARED_STARTUP_HANDOFF_ARM32_BUILD="skipped"
    SHARED_STARTUP_HANDOFF_RV64_BUILD="skipped"
    SHARED_STARTUP_HANDOFF_RV32_BUILD="skipped"
fi

