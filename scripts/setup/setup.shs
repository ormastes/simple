#!/bin/sh
set -eu

# Create bin/simple (and MCP server) symlinks pointing at the
# platform-specific release binaries. Run after a fresh clone, or before
# bootstrap verification when bin/simple has not been created yet.

repo_root="$(cd "$(dirname "$0")/../.." && pwd)"
. "${repo_root}/scripts/setup/platform-detect.shs"

# platform-detect emits the 3-part Rust triple (e.g. aarch64-apple-darwin), but
# release binaries live under the 4-part Simple-native triple (…-macho on macOS).
# Resolve PLATFORM_TRIPLE to whichever release dir actually exists.
if [ ! -x "${repo_root}/bin/release/${PLATFORM_TRIPLE}/simple" ]; then
  for cand in "${PLATFORM_TRIPLE}-macho" "${PLATFORM_ARCH}-apple-darwin-macho"; do
    if [ -x "${repo_root}/bin/release/${cand}/simple" ]; then
      PLATFORM_TRIPLE="${cand}"
      break
    fi
  done
fi

release_dir="${repo_root}/bin/release/${PLATFORM_TRIPLE}"

if [ ! -x "${release_dir}/simple" ]; then
  echo "setup: ${release_dir}/simple not found — run bootstrap first" >&2
  exit 0
fi

cd "${repo_root}/bin"

ln -sf "release/${PLATFORM_TRIPLE}/simple" simple

if [ -x "release/${PLATFORM_TRIPLE}/simple_seed" ]; then
  ln -sf "release/${PLATFORM_TRIPLE}/simple_seed" simple_seed
else
  rm -f simple_seed
fi

for b in simple_ui_backend t32_mcp_server t32_lsp_mcp_server; do
  if [ -x "release/${PLATFORM_TRIPLE}/${b}" ]; then
    ln -sf "release/${PLATFORM_TRIPLE}/${b}" "${b}"
  fi
done

rm -f simple_mcp_server
cat > simple_mcp_server <<'EOF'
#!/bin/sh
set -eu

case "${1:-}" in
  --version|-v)
    printf '%s\n' 'simple-mcp-server 4.0.0'
    exit 0
    ;;
  --help|-h)
    printf '%s\n' 'simple-mcp-server 4.0.0'
    printf '%s\n' 'Usage: simple_mcp_server'
    printf '%s\n' '       simple_mcp_server --version'
    exit 0
    ;;
esac

script_dir="${0%/*}"
if [ "${script_dir}" = "$0" ]; then
  script_dir="."
fi
repo_root="${script_dir}/.."
log_dir="${repo_root}/.simple/logs"
mkdir -p "${log_dir}"

probe_timeout() {
  _seconds=$1
  shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "${_seconds}" "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "${_seconds}" "$@"
  else
    "$@"
  fi
}

native_hash_is_valid() {
  _native=$1
  _sidecar="${_native}.sha256"
  [ -f "${_sidecar}" ] || return 1
  _expected="$(awk 'NR == 1 { print $1 }' "${_sidecar}")"
  if command -v sha256sum >/dev/null 2>&1; then
    _actual="$(sha256sum "${_native}" | awk '{print $1}')"
  elif command -v shasum >/dev/null 2>&1; then
    _actual="$(shasum -a 256 "${_native}" | awk '{print $1}')"
  else
    return 1
  fi
  [ -n "${_expected}" ] && [ "${_expected}" = "${_actual}" ]
}

if [ "${1:-}" = "--json" ]; then
  printf '%s\n' '{"command":"mcp","status":"ready","tool":"Simple MCP Server","version":"4.0.0"}'
  exit 0
fi

if [ "${SIMPLE_MCP_FULL:-1}" != "1" ]; then
  transport_mode="framed"
  tool_set="${SIMPLE_MCP_TOOL_SET:-core}"
  tool_name="simple_pipe"
  tool_desc="SPipe-linked codebase/context/Ponytail surface"
  if [ "${tool_set}" = "search" ]; then
    tool_name="simple_search"
    tool_desc="Codebase search"
  fi
  read_msg() {
    len=""
    while IFS= read -r line; do
      line="${line%$(printf '\r')}"
      case "$line" in
        \{*) transport_mode="jsonl"; printf '%s' "$line"; return 0 ;;
      esac
      [ -z "$line" ] && break
      case "$line" in
        Content-Length:*) len="$(printf '%s' "$line" | sed 's/^Content-Length:[[:space:]]*//')" ;;
      esac
    done
    [ -n "$len" ] || return 1
    dd bs=1 count="$len" 2>/dev/null
  }
  get_id() {
    printf '%s\n' "$1" | awk '
      {
        json = $0; depth = 0; quoted = 0; escaped = 0
        for (i = 1; i <= length(json); i++) {
          ch = substr(json, i, 1)
          if (quoted) {
            if (escaped) escaped = 0
            else if (ch == "\\") escaped = 1
            else if (ch == "\"") quoted = 0
            continue
          }
          if (ch == "{") { depth++; continue }
          if (ch == "}") { depth--; continue }
          if (ch != "\"") continue

          start = i; i++
          key = ""; key_escaped = 0
          while (i <= length(json)) {
            ch = substr(json, i, 1)
            if (!key_escaped && ch == "\"") break
            key = key ch
            if (key_escaped) key_escaped = 0
            else if (ch == "\\") key_escaped = 1
            i++
          }
          if (depth != 1 || key != "id") continue

          i++
          while (substr(json, i, 1) ~ /[[:space:]]/) i++
          if (substr(json, i, 1) != ":") continue
          i++
          while (substr(json, i, 1) ~ /[[:space:]]/) i++
          value_start = i
          if (substr(json, i, 1) == "\"") {
            i++; value_escaped = 0
            while (i <= length(json)) {
              ch = substr(json, i, 1)
              if (!value_escaped && ch == "\"") { i++; break }
              if (value_escaped) value_escaped = 0
              else if (ch == "\\") value_escaped = 1
              i++
            }
          } else {
            while (i <= length(json) && substr(json, i, 1) !~ /[,}[:space:]]/) i++
          }
          print substr(json, value_start, i - value_start)
          exit
        }
      }
    '
  }
  send_msg() {
    body="$1"
    if [ "$transport_mode" = "jsonl" ]; then
      printf '%s\n' "$body"
    else
      printf 'Content-Length: %s\r\n\r\n%s' "$(printf '%s' "$body" | wc -c | tr -d ' ')" "$body"
    fi
  }
  while msg="$(read_msg)"; do
    case "$msg" in
      \{*) transport_mode="jsonl" ;;
    esac
    id="$(get_id "$msg")"
    [ -n "$id" ] || id=null
    case "$msg" in
      *'"method"'*'"initialize"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{\"tools\":{},\"resources\":{},\"prompts\":{},\"logging\":{}},\"serverInfo\":{\"name\":\"simple-pipe-mcp\",\"version\":\"4.0.0\"}}}"
        ;;
      *'"method"'*'"tools/list"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"tools\":[{\"name\":\"$tool_name\",\"description\":\"$tool_desc\",\"inputSchema\":{\"type\":\"object\",\"properties\":{}}}]}}"
        ;;
      *'"method"'*'"tools/call"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"content\":[{\"type\":\"text\",\"text\":\"$tool_name ready\"}]}}"
        ;;
      *'"method"'*'"resources/list"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"resources\":[]}}"
        ;;
      *'"method"'*'"resources/templates/list"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"resourceTemplates\":[]}}"
        ;;
      *'"method"'*'"prompts/list"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"prompts\":[]}}"
        ;;
      *'"method"'*'"roots/list"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"roots\":[]}}"
        ;;
      *'"method"'*'"ping"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{}}"
        ;;
      *'"method"'*'"logging/setLevel"'*)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{}}"
        ;;
      *'"method"'*'"notifications/'*)
        ;;
      *)
        send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"error\":{\"code\":-32601,\"message\":\"Method not found\"}}"
        ;;
    esac
  done
  exit 0
fi

# Production launches only an admitted cached native server.

_MCP_PROBE_WRAPPER_VERSION="simple_mcp_server:4.1.1-correlated-call"

_mcp_probe_identity() {
  awk 'NR == 1 { print $1 }' "$1.sha256" 2>/dev/null || printf ''
}

_mcp_probe_stamp_path() {
  # Sanitize candidate path to a safe filename: replace non-alnum with _
  _key="$(printf '%s' "$1" | tr -c 'A-Za-z0-9.' '_')"
  printf '%s' "${repo_root}/.simple/cache/mcp-probe/${_key}.stamp"
}

_mcp_probe_stamp_valid() {
  # $1 = candidate binary path
  _stamp="$(_mcp_probe_stamp_path "$1")"
  [ -f "${_stamp}" ] || return 1
  _current="$(_mcp_probe_identity "$1")"
  [ -n "${_current}" ] || return 1
  _stored_stat="$(sed -n '1p' "${_stamp}" 2>/dev/null || printf '')"
  _stored_ver="$(sed -n '2p' "${_stamp}" 2>/dev/null || printf '')"
  [ "${_stored_stat}" = "${_current}" ] && [ "${_stored_ver}" = "${_MCP_PROBE_WRAPPER_VERSION}" ]
}

_mcp_probe_stamp_write() {
  # $1 = candidate binary path
  _stamp="$(_mcp_probe_stamp_path "$1")"
  _stamp_dir="$(dirname "${_stamp}")"
  mkdir -p "${_stamp_dir}" 2>/dev/null || return 1
  _current="$(_mcp_probe_identity "$1")"
  [ -n "${_current}" ] || return 1
  printf '%s\n%s\n' "${_current}" "${_MCP_PROBE_WRAPPER_VERSION}" >"${_stamp}.$$" && mv "${_stamp}.$$" "${_stamp}"
}

_mcp_probe_stamp_delete() {
  # $1 = candidate binary path
  rm -f "$(_mcp_probe_stamp_path "$1")" 2>/dev/null || true
}

mcp_probe_native() {
  probe_native="$1"
  # Cache hit is content-addressed by the already-validated SHA-256 sidecar.
  if _mcp_probe_stamp_valid "${probe_native}"; then
    printf 'probe_cache_hit wrapper=simple_mcp_server native=%s\n' "${probe_native}" >>"${log_dir}/simple_mcp_startup.log"
    return 0
  fi
  # Stale or missing stamp: delete it before probing so a probe failure leaves no stamp
  _mcp_probe_stamp_delete "${probe_native}"

  probe_tmp="$(mktemp "${TMPDIR:-/tmp}/simple_mcp_probe.XXXXXX")" || probe_tmp=""
  if [ -z "${probe_tmp}" ]; then
    return 1
  fi
  printf '{"jsonrpc":"2.0","id":"1","method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"wrapper-probe","version":"1"}}}\n{"jsonrpc":"2.0","method":"notifications/initialized","params":{}}\n{"jsonrpc":"2.0","id":"2","method":"tools/list","params":{}}\n{"jsonrpc":"2.0","id":"3","method":"tools/call","params":{"name":"simple_pipe","arguments":{"surface":"spipe"}}}\n' \
    | probe_timeout "${SIMPLE_MCP_NATIVE_PROBE_TIMEOUT:-5}" "${probe_native}" >"${probe_tmp}" 2>>"${log_dir}/simple_mcp_stderr.log" || true
  if grep -q '"simple_pipe"' "${probe_tmp}" \
    && grep -Eq '"id"[[:space:]]*:[[:space:]]*3.*"result"' "${probe_tmp}" \
    && ! grep -Eq '"id"[[:space:]]*:[[:space:]]*3.*"error"' "${probe_tmp}" \
    && grep -q 'spipe: linked' "${probe_tmp}"; then
    rm -f "${probe_tmp}"
    _mcp_probe_stamp_write "${probe_native}" || true
    printf 'probe_tools_call_ok wrapper=simple_mcp_server native=%s stamp=written\n' "${probe_native}" >>"${log_dir}/simple_mcp_startup.log"
    return 0
  fi
  printf 'native_probe_failed wrapper=simple_mcp_server native=%s reason=simple_pipe_tools_call_failed fallback=next_candidate\n' "${probe_native}" >>"${log_dir}/simple_mcp_stderr.log"
  rm -f "${probe_tmp}"
  return 1
}

native=""
if [ -n "${SIMPLE_MCP_NATIVE:-}" ]; then
  if [ -x "${SIMPLE_MCP_NATIVE}" ] && native_hash_is_valid "${SIMPLE_MCP_NATIVE}" && mcp_probe_native "${SIMPLE_MCP_NATIVE}"; then
    native="${SIMPLE_MCP_NATIVE}"
  else
    printf '%s\n' "error: SIMPLE_MCP_NATIVE is missing or failed its MCP probe: ${SIMPLE_MCP_NATIVE}" >&2
    exit 127
  fi
else
  for candidate in \
    "${script_dir}/release/aarch64-apple-darwin/simple_mcp_server" \
    "${script_dir}/release/aarch64-apple-darwin-macho/simple_mcp_server" \
    "${script_dir}/release/x86_64-apple-darwin/simple_mcp_server" \
    "${script_dir}/release/x86_64-apple-darwin-macho/simple_mcp_server" \
    "${script_dir}/release/x86_64-unknown-linux-gnu/simple_mcp_server" \
    "${script_dir}/release/linux-x86_64/simple_mcp_server"
  do
    if [ -x "${candidate}" ] && native_hash_is_valid "${candidate}" && mcp_probe_native "${candidate}"; then
      native="${candidate}"
      break
    fi
  done
fi

if [ -z "${native}" ]; then
  {
    printf '%s\n' "error: native simple_mcp_server not found"
    printf '%s\n' "checked release directory: ${script_dir}/release"
    printf '%s\n' "hint: rebuild with native-build for src/app/mcp/main.spl"
  } >&2
  exit 127
fi

export SIMPLE_LIB="${SIMPLE_LIB:-${repo_root}/src}"
export SIMPLE_LOG="${SIMPLE_LOG:-error}"
export SIMPLE_TIMEOUT_SECONDS="${SIMPLE_TIMEOUT_SECONDS:-86400}"
export SIMPLE_MEMORY_LIMIT_MB="${SIMPLE_MEMORY_LIMIT_MB:-${SIMPLE_TEST_MEMORY_LIMIT_MB:-100}}"
export RUST_LOG="${RUST_LOG:-error}"

printf 'startup wrapper=simple_mcp_server mode=native native=%s cwd=%s\n' "${native}" "$(pwd)" >>"${log_dir}/simple_mcp_startup.log"
exec "${native}" "$@" 2>>"${log_dir}/simple_mcp_stderr.log"
EOF
chmod +x simple_mcp_server

rm -f simple_lsp_mcp_server
cat > simple_lsp_mcp_server <<'EOF'
#!/bin/sh
set -eu

case "${1:-}" in
  --version|-v)
    printf '%s\n' 'simple-lsp-mcp-server 0.9.8'
    exit 0
    ;;
  --help|-h)
    printf '%s\n' 'simple-lsp-mcp-server 0.9.8'
    printf '%s\n' 'Usage: simple_lsp_mcp_server'
    printf '%s\n' '       simple_lsp_mcp_server --version'
    exit 0
    ;;
esac

script_dir="${0%/*}"
if [ "${script_dir}" = "$0" ]; then
  script_dir="."
fi
platform_dir="${SIMPLE_PLATFORM_TRIPLE:-x86_64-unknown-linux-gnu}"
repo_root="${script_dir}/.."
log_dir="${repo_root}/.simple/logs"
mkdir -p "${log_dir}"

probe_timeout() {
  _seconds=$1
  shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "${_seconds}" "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "${_seconds}" "$@"
  else
    "$@"
  fi
}

native_hash_is_valid() {
  _native=$1
  _sidecar="${_native}.sha256"
  [ -f "${_sidecar}" ] || return 1
  _expected="$(awk 'NR == 1 { print $1 }' "${_sidecar}")"
  if command -v sha256sum >/dev/null 2>&1; then
    _actual="$(sha256sum "${_native}" | awk '{print $1}')"
  elif command -v shasum >/dev/null 2>&1; then
    _actual="$(shasum -a 256 "${_native}" | awk '{print $1}')"
  else
    return 1
  fi
  [ -n "${_expected}" ] && [ "${_expected}" = "${_actual}" ]
}

if [ "${1:-}" = "--json" ]; then
  printf '%s\n' '{"command":"simple-lsp-mcp","status":"ready","version":"0.9.8"}'
  exit 0
fi

_LSP_MCP_PROBE_WRAPPER_VERSION="simple_lsp_mcp_server:0.9.10-tools-call"

_lsp_mcp_probe_identity() {
  awk 'NR == 1 { print $1 }' "$1.sha256" 2>/dev/null || printf ''
}

_lsp_mcp_probe_stamp_path() {
  _key="$(printf '%s' "$1" | tr -c 'A-Za-z0-9.' '_')"
  printf '%s' "${repo_root}/.simple/cache/mcp-probe/${_key}.stamp"
}

_lsp_mcp_probe_stamp_valid() {
  _stamp="$(_lsp_mcp_probe_stamp_path "$1")"
  [ -f "${_stamp}" ] || return 1
  _current="$(_lsp_mcp_probe_identity "$1")"
  [ -n "${_current}" ] || return 1
  _stored_stat="$(sed -n '1p' "${_stamp}" 2>/dev/null || printf '')"
  _stored_ver="$(sed -n '2p' "${_stamp}" 2>/dev/null || printf '')"
  [ "${_stored_stat}" = "${_current}" ] && [ "${_stored_ver}" = "${_LSP_MCP_PROBE_WRAPPER_VERSION}" ]
}

_lsp_mcp_probe_stamp_write() {
  _stamp="$(_lsp_mcp_probe_stamp_path "$1")"
  _stamp_dir="$(dirname "${_stamp}")"
  mkdir -p "${_stamp_dir}" 2>/dev/null || return 1
  _current="$(_lsp_mcp_probe_identity "$1")"
  [ -n "${_current}" ] || return 1
  printf '%s\n%s\n' "${_current}" "${_LSP_MCP_PROBE_WRAPPER_VERSION}" >"${_stamp}.$$" && mv "${_stamp}.$$" "${_stamp}"
}

_lsp_mcp_probe_stamp_delete() {
  rm -f "$(_lsp_mcp_probe_stamp_path "$1")" 2>/dev/null || true
}

mcp_probe_lsp_native() {
  probe_native="$1"
  if _lsp_mcp_probe_stamp_valid "${probe_native}"; then
    printf 'probe_cache_hit wrapper=simple_lsp_mcp_server native=%s\n' "${probe_native}" >>"${log_dir}/simple_lsp_mcp_startup.log"
    return 0
  fi
  _lsp_mcp_probe_stamp_delete "${probe_native}"
  probe_tmp="$(mktemp "${TMPDIR:-/tmp}/simple_lsp_mcp_probe.XXXXXX")" || probe_tmp=""
  if [ -z "${probe_tmp}" ]; then
    return 1
  fi
  printf '{"jsonrpc":"2.0","id":"1","method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"wrapper-probe","version":"1"}}}\n{"jsonrpc":"2.0","id":"2","method":"tools/list","params":{}}\n{"jsonrpc":"2.0","id":"lsp-call-probe","method":"tools/call","params":{"name":"lsp_symbols","arguments":{"file":"src/app/simple_lsp_mcp/main.spl"}}}\n' \
    | probe_timeout "${SIMPLE_LSP_MCP_NATIVE_PROBE_TIMEOUT:-3}" "${probe_native}" >"${probe_tmp}" 2>>"${log_dir}/simple_lsp_mcp_stderr.log" || true
  if grep -q '"lsp_definition"' "${probe_tmp}" \
    && grep -q '"id":"lsp-call-probe".*"result"' "${probe_tmp}" \
    && ! grep -q '"id":"lsp-call-probe".*"error"' "${probe_tmp}" \
    && ! grep -q 'Missing tool name' "${probe_tmp}"; then
    rm -f "${probe_tmp}"
    _lsp_mcp_probe_stamp_write "${probe_native}" || true
    printf 'probe_cache_miss wrapper=simple_lsp_mcp_server native=%s stamp=written\n' "${probe_native}" >>"${log_dir}/simple_lsp_mcp_startup.log"
    return 0
  fi
  printf 'native_probe_failed wrapper=simple_lsp_mcp_server native=%s reason=initialize_list_or_call_failed fallback=next_candidate\n' "${probe_native}" >>"${log_dir}/simple_lsp_mcp_startup.log"
  rm -f "${probe_tmp}"
  return 1
}

native=""
if [ -n "${SIMPLE_LSP_MCP_NATIVE:-}" ]; then
  if [ -x "${SIMPLE_LSP_MCP_NATIVE}" ] && native_hash_is_valid "${SIMPLE_LSP_MCP_NATIVE}" && mcp_probe_lsp_native "${SIMPLE_LSP_MCP_NATIVE}"; then
    native="${SIMPLE_LSP_MCP_NATIVE}"
  else
    printf '%s\n' "error: SIMPLE_LSP_MCP_NATIVE is missing or failed its LSP MCP probe: ${SIMPLE_LSP_MCP_NATIVE}" >&2
    exit 127
  fi
else
  for candidate in \
    "${script_dir}/release/aarch64-apple-darwin/simple_lsp_mcp_server" \
    "${script_dir}/release/x86_64-apple-darwin/simple_lsp_mcp_server" \
    "${script_dir}/release/${platform_dir}/simple_lsp_mcp_server" \
    "${script_dir}/release/linux-x86_64/simple_lsp_mcp_server"
  do
    if [ -x "${candidate}" ] && native_hash_is_valid "${candidate}" && mcp_probe_lsp_native "${candidate}"; then
      native="${candidate}"
      break
    fi
  done
fi

if [ ! -x "${native}" ]; then
  {
    printf '%s\n' "error: native simple_lsp_mcp_server not found"
    printf '%s\n' "checked release directory: ${script_dir}/release"
    printf '%s\n' "platform: ${platform_dir}"
    printf '%s\n' "hint: rebuild with native-build for src/app/simple_lsp_mcp/main.spl"
  } >&2
  exit 127
fi

printf 'startup wrapper=simple_lsp_mcp_server mode=native native=%s cwd=%s\n' "${native}" "$(pwd)" >>"${log_dir}/simple_lsp_mcp_startup.log"
exec "${native}" "$@" 2>>"${log_dir}/simple_lsp_mcp_stderr.log"
EOF
chmod +x simple_lsp_mcp_server

echo "setup: bin/simple -> release/${PLATFORM_TRIPLE}/simple"
