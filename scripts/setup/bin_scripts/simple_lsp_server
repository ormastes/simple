#!/bin/bash
# Simple language LSP wrapper for local editor/plugin clients.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${SCRIPT_DIR}/.."
ENTRY="${PROJECT_ROOT}/src/app/lsp/main.spl"
RUNTIME="${PROJECT_ROOT}/src/compiler_rust/target/release/simple"

if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${PROJECT_ROOT}/src/compiler_rust/target/bootstrap/simple"
fi
if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple"
fi
if [ ! -x "$RUNTIME" ]; then
  RUNTIME="${SCRIPT_DIR}/simple.exe"
fi

export SIMPLE_LIB="${PROJECT_ROOT}/src"
export SIMPLE_LOG=error

RUST_LOG=error exec "$RUNTIME" "$ENTRY" "$@" 2>/dev/null
