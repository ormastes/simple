#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

bootstrap_bin=""
for candidate in \
  "$repo_root/src/compiler_rust/target/bootstrap/simple" \
  "$repo_root/src/compiler_rust/target/bootstrap/simple.exe"
do
  if [[ -x "$candidate" ]]; then
    bootstrap_bin="$candidate"
    break
  fi
done

release_bin=""

for candidate in \
  "$repo_root/bin/release/x86_64-unknown-linux-gnu/simple" \
  "$repo_root/bin/release/linux-x86_64/simple" \
  "$repo_root/bin/release/x86_64-pc-windows-msvc/simple.exe" \
  "$repo_root/bin/release/x86_64-pc-windows-gnu/simple.exe" \
  "$repo_root/bin/release/aarch64-pc-windows-msvc/simple.exe" \
  "$repo_root/bin/release/aarch64-pc-windows-gnu/simple.exe" \
  "$repo_root/bin/release/simple.exe" \
  "$repo_root/bin/release/simple"
do
  if [[ -x "$candidate" ]]; then
    release_bin="$candidate"
    break
  fi
done

if [[ -x "$bootstrap_bin" ]]; then
  exec "$bootstrap_bin" "$@"
fi

if [[ -n "$release_bin" ]]; then
  exec "$release_bin" "$@"
fi

echo "error: no Simple runtime found" >&2
exit 1
