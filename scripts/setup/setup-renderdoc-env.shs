#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
. "$ROOT_DIR/scripts/lib/renderdoc-evidence-common.shs"

mode="${1:---check}"
renderdoc_home="$(rdoc_find_renderdoc_home "$ROOT_DIR" || true)"
chrome_bin="$(rdoc_find_chrome "$ROOT_DIR" || true)"

case "$mode" in
    --check)
        rdoc_status_env "$ROOT_DIR" "$renderdoc_home" "$chrome_bin"
        if [ "$renderdoc_home" = "" ]; then
            echo "rdoc_status=missing-renderdoc"
            exit 1
        fi
        echo "rdoc_status=ready"
        ;;
    --print)
        if [ "$renderdoc_home" != "" ]; then
            echo "export RDOC_HOME='$renderdoc_home'"
            renderdoc_lib="$(rdoc_renderdoc_lib_path "$renderdoc_home")"
            echo "export LD_LIBRARY_PATH='$renderdoc_lib'\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
            echo "export DYLD_LIBRARY_PATH='$renderdoc_lib'\${DYLD_LIBRARY_PATH:+:\$DYLD_LIBRARY_PATH}"
        fi
        if [ "$chrome_bin" != "" ]; then
            echo "export RDOC_CHROME='$chrome_bin'"
        fi
        echo "export RDOC_OUTPUT_DIR='\${RDOC_OUTPUT_DIR:-$ROOT_DIR/build/renderdoc/evidence}'"
        ;;
    --register-vulkan-layer)
        if [ "$renderdoc_home" = "" ]; then
            echo "SKIP: renderdoccmd not found under build/tools/renderdoc*"
            exit 0
        fi
        rdoc_cmd="$(rdoc_renderdoccmd_path "$renderdoc_home")"
        "$rdoc_cmd" vulkanlayer --register --user
        "$rdoc_cmd" vulkanlayer --explain
        ;;
    *)
        echo "usage: scripts/setup/setup-renderdoc-env.shs [--check|--print|--register-vulkan-layer]" >&2
        exit 2
        ;;
esac
