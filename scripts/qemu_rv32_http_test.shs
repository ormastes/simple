#!/usr/bin/env sh
# ============================================================================
# QEMU RV32 HTTP Integration Test
# ============================================================================
#
# Boots SimpleOS RV32 baremetal binary under QEMU virt, waits for the HTTP
# server to come up, then runs nc/openssl smoke tests against it.
#
# Usage:
#   sh scripts/qemu_rv32_http_test.shs [--elf <path>] [--expect-deferred]
#
# Defaults:
#   --elf build/simpleos-rv32.elf
#
# Requires: qemu-system-riscv32, nc
# ============================================================================
set -eu

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# ---- defaults ----
ELF="build/simpleos-rv32.elf"
HTTP_PORT=8080
HTTPS_PORT=8443
BOOT_TIMEOUT=60
SERIAL_LOG="build/qemu-rv32-serial.log"
EXPECT_DEFERRED=false

# ---- parse args ----
while [ "$#" -gt 0 ]; do
  case "$1" in
    --elf)
      shift
      ELF="$1"
      ;;
    --elf=*)
      ELF="${1#*=}"
      ;;
    --expect-deferred)
      EXPECT_DEFERRED=true
      ;;
    --help|-h)
      echo "Usage: sh scripts/qemu_rv32_http_test.shs [--elf <path>] [--expect-deferred]"
      echo ""
      echo "  --elf <path>        Path to SimpleOS RV32 ELF (default: build/simpleos-rv32.elf)"
      echo "  --expect-deferred   Pass when virtio is detected but packet RX is unavailable"
      exit 0
      ;;
    *)
      echo "error: unknown option '$1'" >&2
      exit 1
      ;;
  esac
  shift
done

# ---- verify prerequisites ----
if [ ! -f "$ELF" ]; then
  echo "error: ELF not found: ${ELF}" >&2
  echo "  Build it first with an LLVM-enabled compiler:" >&2
  echo "    SIMPLE_BOOTSTRAP=1 <simple> native-build --backend llvm --source src/os --source src/lib --entry src/os/kernel/arch/riscv32/boot.spl --entry-closure --linker-script src/os/kernel/arch/riscv32/linker.ld --target riscv32-unknown-none -o ${ELF}" >&2
  exit 1
fi

if ! command -v qemu-system-riscv32 >/dev/null 2>&1; then
  echo "error: qemu-system-riscv32 not found in PATH" >&2
  exit 1
fi

if [ "$EXPECT_DEFERRED" = "false" ] && ! command -v nc >/dev/null 2>&1; then
  echo "error: nc not found in PATH" >&2
  exit 1
fi

# ---- prepare ----
mkdir -p "$(dirname "$SERIAL_LOG")"
rm -f "$SERIAL_LOG"
QEMU_PID=""

# ---- cleanup on exit ----
cleanup() {
  if [ -n "$QEMU_PID" ]; then
    kill "$QEMU_PID" 2>/dev/null || true
    wait "$QEMU_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT

# ---- launch QEMU ----
echo "[1/4] Launching QEMU RV32 with ${ELF}..."
qemu-system-riscv32 \
  -machine virt \
  -cpu rv32 \
  -m 128M \
  -nographic \
  -netdev user,id=net0,hostfwd=tcp::${HTTP_PORT}-:${HTTP_PORT},hostfwd=tcp::${HTTPS_PORT}-:${HTTPS_PORT} \
  -device virtio-net-pci,netdev=net0 \
  -kernel "$ELF" \
  -serial file:"$SERIAL_LOG" \
  </dev/null &
QEMU_PID=$!

echo "  QEMU PID: ${QEMU_PID}"

# ---- wait for boot gate marker ----
if [ "$EXPECT_DEFERRED" = "true" ]; then
  echo "[2/4] Waiting for deferred network marker (timeout: ${BOOT_TIMEOUT}s)..."
else
  echo "[2/4] Waiting for HTTP bind marker (timeout: ${BOOT_TIMEOUT}s)..."
fi
WAITED=0
BOOTED=false
while [ "$WAITED" -lt "$BOOT_TIMEOUT" ]; do
  if [ "$EXPECT_DEFERRED" = "true" ] &&
    [ -f "$SERIAL_LOG" ] &&
    grep -q "Network service ready" "$SERIAL_LOG" 2>/dev/null; then
    echo "FAILED: network reached ready state in deferred mode" >&2
    echo "--- serial log ---"
    cat "$SERIAL_LOG"
    echo "--- end serial log ---"
    exit 1
  fi
  if [ "$EXPECT_DEFERRED" = "true" ] &&
    [ -f "$SERIAL_LOG" ] &&
    grep -q "PCI network device index" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "Network packet TX unavailable" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "HTTP server deferred" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "Entering boot idle loop" "$SERIAL_LOG" 2>/dev/null; then
    echo "  Deferred network gate verified after ${WAITED}s"
    echo "DEFERRED PASSED"
    exit 0
  fi
  if [ -f "$SERIAL_LOG" ] && grep -q "HTTP server deferred" "$SERIAL_LOG" 2>/dev/null; then
    echo "FAILED: HTTP server was deferred" >&2
    echo "--- serial log ---"
    cat "$SERIAL_LOG"
    echo "--- end serial log ---"
    exit 1
  fi
  if [ -f "$SERIAL_LOG" ] &&
    grep -q "Network service ready" "$SERIAL_LOG" 2>/dev/null &&
    grep -q "Bootstrap TCP shim bound on 0.0.0.0:8080" "$SERIAL_LOG" 2>/dev/null; then
    BOOTED=true
    break
  fi
  sleep 1
  WAITED=$((WAITED + 1))
done

if [ "$BOOTED" = "false" ]; then
  echo "FAILED: HTTP bind marker not seen within ${BOOT_TIMEOUT}s" >&2
  if [ -f "$SERIAL_LOG" ]; then
    echo "--- serial log ---"
    cat "$SERIAL_LOG"
    echo "--- end serial log ---"
  fi
  exit 1
fi

echo "  HTTP bind detected after ${WAITED}s"

http_response() {
  method="$1"
  path="$2"
  printf '%s %s HTTP/1.0\r\nHost: localhost\r\nConnection: close\r\n\r\n' "$method" "$path" |
    nc -w 5 localhost "${HTTP_PORT}" 2>/dev/null || true
}

http_status_code() {
  line=$(http_response GET "$1" | sed -n '1p')
  set -- $line
  if [ "$#" -ge 2 ]; then
    printf '%s\n' "$2"
  else
    printf '000\n'
  fi
}

http_content_type() {
  http_response GET "$1" | grep -i '^content-type:' | sed -n '1p'
}

https_status_code() {
  if ! command -v openssl >/dev/null 2>&1 || ! command -v timeout >/dev/null 2>&1; then
    printf 'skip\n'
    return
  fi
  line=$(
    printf 'GET /health HTTP/1.0\r\nHost: localhost\r\nConnection: close\r\n\r\n' |
      timeout 5s openssl s_client -quiet -connect "localhost:${HTTPS_PORT}" -servername localhost 2>/dev/null |
      sed -n '1p'
  )
  set -- $line
  if [ "$#" -ge 2 ]; then
    printf '%s\n' "$2"
  else
    printf '000\n'
  fi
}

# ---- run HTTP tests ----
echo "[3/4] Running HTTP smoke tests..."
PASS=0
FAIL=0

# Test 1: HTTP health check
printf '%s' "  GET /health (HTTP)... "
HTTP_CODE=$(http_status_code /health)
if [ "$HTTP_CODE" = "200" ]; then
  echo "PASS (${HTTP_CODE})"
  PASS=$((PASS + 1))
else
  echo "FAIL (${HTTP_CODE})"
  FAIL=$((FAIL + 1))
fi

# Test 2: HTTP root page
printf '%s' "  GET / (HTTP)... "
HTTP_CODE=$(http_status_code /)
if [ "$HTTP_CODE" = "200" ]; then
  echo "PASS (${HTTP_CODE})"
  PASS=$((PASS + 1))
else
  echo "FAIL (${HTTP_CODE})"
  FAIL=$((FAIL + 1))
fi

# Test 3: HTTPS health check (skip TLS verification for self-signed cert)
printf '%s' "  GET /health (HTTPS)... "
HTTP_CODE=$(https_status_code)
if [ "$HTTP_CODE" = "skip" ]; then
  echo "SKIP (openssl or timeout unavailable)"
elif [ "$HTTP_CODE" = "200" ]; then
  echo "PASS (${HTTP_CODE})"
  PASS=$((PASS + 1))
else
  echo "FAIL (${HTTP_CODE})"
  FAIL=$((FAIL + 1))
fi

# Test 4: Health endpoint returns JSON
printf '%s' "  GET /health content-type... "
CONTENT_TYPE=$(http_content_type /health)
if echo "$CONTENT_TYPE" | grep -qi "json"; then
  echo "PASS (JSON)"
  PASS=$((PASS + 1))
else
  echo "FAIL (expected JSON, got: ${CONTENT_TYPE})"
  FAIL=$((FAIL + 1))
fi

# Test 5: Root page returns HTML
printf '%s' "  GET / content-type... "
CONTENT_TYPE=$(http_content_type /)
if echo "$CONTENT_TYPE" | grep -qi "html"; then
  echo "PASS (HTML)"
  PASS=$((PASS + 1))
else
  echo "FAIL (expected HTML, got: ${CONTENT_TYPE})"
  FAIL=$((FAIL + 1))
fi

# ---- report ----
echo ""
echo "[4/4] Results: ${PASS} passed, ${FAIL} failed out of $((PASS + FAIL)) tests"

if [ "$FAIL" -gt 0 ]; then
  echo "FAILED"
  exit 1
fi

echo "ALL PASSED"
exit 0
