echo "gtk_benchmark_simple_frame_us=$gtk_benchmark_simple_frame_us"
echo "gtk_benchmark_gtk_frame_us=$gtk_benchmark_gtk_frame_us"
echo "gtk_benchmark_simple_text_us=$gtk_benchmark_simple_text_us"
echo "gtk_benchmark_gtk_text_us=$gtk_benchmark_gtk_text_us"
echo "gtk_benchmark_simple_iterations=$SIMPLE_ITERATIONS"
echo "gtk_benchmark_gtk_iterations=$GTK_ITERATIONS"
