# Kill simple processes and containers when free memory drops below threshold
# Combines kill-simple-low-mem.sh and kill-simple-on-low-mem.sh
#
# Usage:
#   bin/simple run scripts/tools/kill_simple_low_mem.spl               # default: 64GB, 1s
#   bin/simple run scripts/tools/kill_simple_low_mem.spl 100 30        # 100GB, 30s

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_cli_get_args() -> [text]

fn shell(command: text) -> (text, text, i64):
    rt_process_run("sh", ["-c", command])

fn shell_output(command: text) -> text:
    val (out, _, _) = shell(command)
    out.trim()

fn get_free_mb() -> i64:
    val content = rt_file_read_text("/proc/meminfo") ?? ""
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if line.starts_with("MemAvailable:"):
            val parts = line.split_whitespace()
            if parts.len() >= 2:
                val kb = int(parts[1])
                return kb / 1024
        i = i + 1
    0

fn main():
    val args = rt_cli_get_args()

    var threshold_gb = 64
    var check_interval = 1
    if args.len() > 1:
        threshold_gb = int(args[1])
    if args.len() > 2:
        check_interval = int(args[2])

    val threshold_mb = threshold_gb * 1024
    val pid = shell_output("echo $$")

    print "[kill-simple-low-mem] Started. Threshold: {threshold_gb}GB free. Interval: {check_interval}s. PID: {pid}"

    while true:
        val free_mb = get_free_mb()

        if free_mb < threshold_mb:
            val timestamp = shell_output("date '+%Y-%m-%d %H:%M:%S'")
            print "[{timestamp}] Free memory: {free_mb}MB (< {threshold_mb}MB). Killing simple processes..."

            # Kill docker containers
            val containers = shell_output("docker ps -q --filter 'name=simple' 2>/dev/null")
            if containers.len() > 0:
                print "  Killing docker containers: {containers}"
                shell("docker kill {containers} 2>/dev/null")
                shell("docker rm -f {containers} 2>/dev/null")

            # Kill simple processes
            shell("pkill -f 'bin/simple' 2>/dev/null || true")

            # Force kill survivors after 2s
            shell("sleep 2")
            shell("pkill -9 -f 'bin/simple' 2>/dev/null || true")

            print "  Done."

        shell("sleep {check_interval}")
