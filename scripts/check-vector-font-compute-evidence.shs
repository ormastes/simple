#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/vector_font_compute_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/vector_font_compute_evidence_$(date -u +%F).md}"
SIMPLE_BIN="${SIMPLE_BIN:-bin/simple}"
SIMPLE_SRC="$BUILD_DIR/vector_font_compute_evidence.spl"
SIMPLE_OUT="$BUILD_DIR/simple.out"
TEXT_RUN="${VECTOR_FONT_TEXT_RUN:-HARDENED}"
FONT_SIZE="${VECTOR_FONT_SIZE:-24}"
ITERATIONS="${VECTOR_FONT_ITERATIONS:-4}"

CUDA_STATUS="${CUDA_VECTOR_FONT_STATUS:-unavailable}"
CUDA_REASON="${CUDA_VECTOR_FONT_REASON:-missing-vector-font-cuda-kernel}"
CUDA_CHECKSUM="${CUDA_VECTOR_FONT_CHECKSUM:-0}"
CUDA_INK_PIXELS="${CUDA_VECTOR_FONT_INK_PIXELS:-0}"
CUDA_GLYPH_COUNT="${CUDA_VECTOR_FONT_GLYPH_COUNT:-1}"
CUDA_GLYPH_0_CODEPOINT="${CUDA_VECTOR_FONT_GLYPH_0_CODEPOINT:-0}"
CUDA_GLYPH_0_FONT_SIZE="${CUDA_VECTOR_FONT_GLYPH_0_FONT_SIZE:-0}"
CUDA_GLYPH_0_WIDTH="${CUDA_VECTOR_FONT_GLYPH_0_WIDTH:-0}"
CUDA_GLYPH_0_HEIGHT="${CUDA_VECTOR_FONT_GLYPH_0_HEIGHT:-0}"
CUDA_GLYPH_0_ADVANCE="${CUDA_VECTOR_FONT_GLYPH_0_ADVANCE:-0}"
CUDA_GLYPH_0_CHECKSUM="${CUDA_VECTOR_FONT_GLYPH_0_CHECKSUM:-0}"
CUDA_GLYPH_0_INK_PIXELS="${CUDA_VECTOR_FONT_GLYPH_0_INK_PIXELS:-0}"
CUDA_GLYPH_0_PIXELS="${CUDA_VECTOR_FONT_GLYPH_0_PIXELS:-}"
CUDA_GLYPH_1_CODEPOINT="${CUDA_VECTOR_FONT_GLYPH_1_CODEPOINT:-0}"
CUDA_GLYPH_1_FONT_SIZE="${CUDA_VECTOR_FONT_GLYPH_1_FONT_SIZE:-0}"
CUDA_GLYPH_1_WIDTH="${CUDA_VECTOR_FONT_GLYPH_1_WIDTH:-0}"
CUDA_GLYPH_1_HEIGHT="${CUDA_VECTOR_FONT_GLYPH_1_HEIGHT:-0}"
CUDA_GLYPH_1_ADVANCE="${CUDA_VECTOR_FONT_GLYPH_1_ADVANCE:-0}"
CUDA_GLYPH_1_CHECKSUM="${CUDA_VECTOR_FONT_GLYPH_1_CHECKSUM:-0}"
CUDA_GLYPH_1_INK_PIXELS="${CUDA_VECTOR_FONT_GLYPH_1_INK_PIXELS:-0}"
CUDA_GLYPH_1_PIXELS="${CUDA_VECTOR_FONT_GLYPH_1_PIXELS:-}"
OPENCL_STATUS="${OPENCL_VECTOR_FONT_STATUS:-unavailable}"
OPENCL_REASON="${OPENCL_VECTOR_FONT_REASON:-missing-vector-font-opencl-kernel}"
OPENCL_CHECKSUM="${OPENCL_VECTOR_FONT_CHECKSUM:-0}"
OPENCL_INK_PIXELS="${OPENCL_VECTOR_FONT_INK_PIXELS:-0}"
OPENCL_GLYPH_COUNT="${OPENCL_VECTOR_FONT_GLYPH_COUNT:-1}"
OPENCL_GLYPH_0_CODEPOINT="${OPENCL_VECTOR_FONT_GLYPH_0_CODEPOINT:-0}"
OPENCL_GLYPH_0_FONT_SIZE="${OPENCL_VECTOR_FONT_GLYPH_0_FONT_SIZE:-0}"
OPENCL_GLYPH_0_WIDTH="${OPENCL_VECTOR_FONT_GLYPH_0_WIDTH:-0}"
OPENCL_GLYPH_0_HEIGHT="${OPENCL_VECTOR_FONT_GLYPH_0_HEIGHT:-0}"
OPENCL_GLYPH_0_ADVANCE="${OPENCL_VECTOR_FONT_GLYPH_0_ADVANCE:-0}"
OPENCL_GLYPH_0_CHECKSUM="${OPENCL_VECTOR_FONT_GLYPH_0_CHECKSUM:-0}"
OPENCL_GLYPH_0_INK_PIXELS="${OPENCL_VECTOR_FONT_GLYPH_0_INK_PIXELS:-0}"
OPENCL_GLYPH_0_PIXELS="${OPENCL_VECTOR_FONT_GLYPH_0_PIXELS:-}"
OPENCL_GLYPH_1_CODEPOINT="${OPENCL_VECTOR_FONT_GLYPH_1_CODEPOINT:-0}"
OPENCL_GLYPH_1_FONT_SIZE="${OPENCL_VECTOR_FONT_GLYPH_1_FONT_SIZE:-0}"
OPENCL_GLYPH_1_WIDTH="${OPENCL_VECTOR_FONT_GLYPH_1_WIDTH:-0}"
OPENCL_GLYPH_1_HEIGHT="${OPENCL_VECTOR_FONT_GLYPH_1_HEIGHT:-0}"
OPENCL_GLYPH_1_ADVANCE="${OPENCL_VECTOR_FONT_GLYPH_1_ADVANCE:-0}"
OPENCL_GLYPH_1_CHECKSUM="${OPENCL_VECTOR_FONT_GLYPH_1_CHECKSUM:-0}"
OPENCL_GLYPH_1_INK_PIXELS="${OPENCL_VECTOR_FONT_GLYPH_1_INK_PIXELS:-0}"
OPENCL_GLYPH_1_PIXELS="${OPENCL_VECTOR_FONT_GLYPH_1_PIXELS:-}"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$SIMPLE_SRC" "$SIMPLE_OUT" "$REPORT_PATH"

emit_unavailable() {
    reason="$1"
    {
        echo "vector_font_compute_status=unavailable"
        echo "vector_font_compute_reason=$reason"
        echo "vector_font_compute_cpu_checksum=0"
        echo "vector_font_compute_cpu_ink_pixels=0"
        echo "vector_font_compute_cuda_status=$CUDA_STATUS"
        echo "vector_font_compute_cuda_reason=$CUDA_REASON"
        echo "vector_font_compute_opencl_status=$OPENCL_STATUS"
        echo "vector_font_compute_opencl_reason=$OPENCL_REASON"
    } >"$BUILD_DIR/evidence.env"
    {
        echo "# Vector Font Compute Evidence"
        echo
        echo "- status: unavailable"
        echo "- reason: $reason"
    } >"$REPORT_PATH"
    cat "$BUILD_DIR/evidence.env"
}

if [ ! -x "$SIMPLE_BIN" ]; then
    emit_unavailable "missing-simple-bin"
    exit 1
fi

cat >"$SIMPLE_SRC" <<SIMPLE_EOF
extern fn rt_time_now_nanos() -> i64
extern fn rt_env_get(key: text) -> text?

use common.ui.web_render_api.{web_render_vector_font_compute_evidence}
use std.nogc_sync_mut.text_layout.font_renderer.{FontRenderer}
use std.nogc_sync_mut.text_layout.font_rasterizer.{rasterize_vector, reset_vector_font_raster_stats, vector_font_raster_stats, vector_font_accelerator_stats}
use std.nogc_sync_mut.text_layout.font_vector_data.{vf_glyph_commands}

val TEXT_RUN: text = "$TEXT_RUN"
val FONT_SIZE: i32 = $FONT_SIZE
val ITERATIONS: i64 = $ITERATIONS

fn env_text(key: text, fallback: text) -> text:
    rt_env_get(key) ?? fallback

fn env_i64(key: text, fallback: i64) -> i64:
    (rt_env_get(key) ?? fallback.to_text()).parse_i64() ?? fallback

fn glyph_checksum(codepoint: i32) -> i64:
    val glyph = rasterize_vector(vf_glyph_commands(codepoint), codepoint, FONT_SIZE)
    var sum: i64 = 0
    var i = 0
    while i < glyph.pixels.len():
        val alpha = glyph.pixels[i].to_i64()
        if alpha > 0:
            sum = sum + alpha * ((i + 1) as i64)
        i = i + 1
    sum + (glyph.width.to_i64() * 31) + (glyph.height.to_i64() * 17) + glyph.advance.to_i64()

fn glyph_ink_pixels(codepoint: i32) -> i64:
    val glyph = rasterize_vector(vf_glyph_commands(codepoint), codepoint, FONT_SIZE)
    var ink_pixels: i64 = 0
    var p = 0
    while p < glyph.pixels.len():
        if glyph.pixels[p].to_i64() > 0:
            ink_pixels = ink_pixels + 1
        p = p + 1
    ink_pixels

fn glyph_command_count(codepoint: i32) -> i32:
    vf_glyph_commands(codepoint).len()

fn glyph_command_at(codepoint: i32, index: i32) -> i32:
    val commands = vf_glyph_commands(codepoint)
    if index >= 0 and index < commands.len():
        return commands[index]
    0

fn glyph_width(codepoint: i32) -> i32:
    val glyph = rasterize_vector(vf_glyph_commands(codepoint), codepoint, FONT_SIZE)
    glyph.width

fn glyph_pixels_csv(codepoint: i32) -> text:
    val glyph = rasterize_vector(vf_glyph_commands(codepoint), codepoint, FONT_SIZE)
    var csv = ""
    var i = 0
    while i < glyph.pixels.len():
        if i > 0:
            csv = csv + ","
        csv = csv + glyph.pixels[i].to_i64().to_text()
        i = i + 1
    csv

fn run_checksum() -> (i64, i64):
    var checksum: i64 = 0
    var ink_pixels: i64 = 0
    var i = 0
    while i < TEXT_RUN.len():
        val codepoint = TEXT_RUN.char_code_at(i) as i32
        val glyph = rasterize_vector(vf_glyph_commands(codepoint), codepoint, FONT_SIZE)
        checksum = checksum + glyph_checksum(codepoint) * ((i + 1) as i64)
        var p = 0
        while p < glyph.pixels.len():
            if glyph.pixels[p].to_i64() > 0:
                ink_pixels = ink_pixels + 1
            p = p + 1
        i = i + 1
    (checksum, ink_pixels)

fn production_text_render_checksum_for(run: text, size: i32) -> (i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, text):
    reset_vector_font_raster_stats()
    var renderer = FontRenderer.new()
    val width = 256
    val height = 64
    val bg = 0xFF000000u32
    var buffer: [u32] = [bg; width * height]
    val pixels = renderer.render_text(buffer, width, height, 4, 8, run, 0xFFFFFFFFu32, size)
    val stats = vector_font_raster_stats()
    val accel = vector_font_accelerator_stats()
    var checksum: i64 = 0
    var ink_pixels: i64 = 0
    var i = 0
    while i < pixels.len():
        val pixel = pixels[i]
        if pixel != bg:
            ink_pixels = ink_pixels + 1
            checksum = checksum + pixel.to_i64() * ((i + 1) as i64)
        i = i + 1
    (checksum, ink_pixels, stats.glyph_rasterizations, stats.output_pixels, accel.attempts, accel.cuda_hits, accel.opencl_hits, accel.cpu_fallback_hits, accel.gpu_returned_glyphs, accel.gpu_returned_glyph_pixels, accel.unavailable_reason)

fn production_text_render_checksum() -> (i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, text):
    production_text_render_checksum_for(TEXT_RUN, FONT_SIZE)

fn main():
    val warm = run_checksum()
    val production = production_text_render_checksum()
    var checksum: i64 = 0
    var ink_pixels: i64 = 0
    val start = rt_time_now_nanos()
    var iter: i64 = 0
    while iter < ITERATIONS:
        val result = run_checksum()
        checksum = result.0
        ink_pixels = result.1
        iter = iter + 1
    val elapsed = rt_time_now_nanos() - start
    var frame_us = elapsed / ITERATIONS / 1000
    if frame_us <= 0:
        frame_us = 1
    val cuda_status = env_text("CUDA_VECTOR_FONT_STATUS", "$CUDA_STATUS")
    val cuda_reason = env_text("CUDA_VECTOR_FONT_REASON", "$CUDA_REASON")
    val cuda_checksum = env_i64("CUDA_VECTOR_FONT_CHECKSUM", $CUDA_CHECKSUM)
    val cuda_glyph_count = env_i64("CUDA_VECTOR_FONT_GLYPH_COUNT", $CUDA_GLYPH_COUNT)
    val cuda_glyph0_codepoint = env_i64("CUDA_VECTOR_FONT_GLYPH_0_CODEPOINT", $CUDA_GLYPH_0_CODEPOINT)
    val cuda_glyph0_font_size = env_i64("CUDA_VECTOR_FONT_GLYPH_0_FONT_SIZE", $CUDA_GLYPH_0_FONT_SIZE)
    val cuda_glyph0_width = env_i64("CUDA_VECTOR_FONT_GLYPH_0_WIDTH", $CUDA_GLYPH_0_WIDTH)
    val cuda_glyph0_height = env_i64("CUDA_VECTOR_FONT_GLYPH_0_HEIGHT", $CUDA_GLYPH_0_HEIGHT)
    val cuda_glyph0_advance = env_i64("CUDA_VECTOR_FONT_GLYPH_0_ADVANCE", $CUDA_GLYPH_0_ADVANCE)
    val cuda_glyph0_checksum = env_i64("CUDA_VECTOR_FONT_GLYPH_0_CHECKSUM", $CUDA_GLYPH_0_CHECKSUM)
    val cuda_glyph0_ink_pixels = env_i64("CUDA_VECTOR_FONT_GLYPH_0_INK_PIXELS", $CUDA_GLYPH_0_INK_PIXELS)
    val cuda_glyph1_codepoint = env_i64("CUDA_VECTOR_FONT_GLYPH_1_CODEPOINT", $CUDA_GLYPH_1_CODEPOINT)
    val cuda_glyph1_font_size = env_i64("CUDA_VECTOR_FONT_GLYPH_1_FONT_SIZE", $CUDA_GLYPH_1_FONT_SIZE)
    val cuda_glyph1_width = env_i64("CUDA_VECTOR_FONT_GLYPH_1_WIDTH", $CUDA_GLYPH_1_WIDTH)
    val cuda_glyph1_height = env_i64("CUDA_VECTOR_FONT_GLYPH_1_HEIGHT", $CUDA_GLYPH_1_HEIGHT)
    val cuda_glyph1_advance = env_i64("CUDA_VECTOR_FONT_GLYPH_1_ADVANCE", $CUDA_GLYPH_1_ADVANCE)
    val cuda_glyph1_checksum = env_i64("CUDA_VECTOR_FONT_GLYPH_1_CHECKSUM", $CUDA_GLYPH_1_CHECKSUM)
    val cuda_glyph1_ink_pixels = env_i64("CUDA_VECTOR_FONT_GLYPH_1_INK_PIXELS", $CUDA_GLYPH_1_INK_PIXELS)
    val opencl_status = env_text("OPENCL_VECTOR_FONT_STATUS", "$OPENCL_STATUS")
    val opencl_reason = env_text("OPENCL_VECTOR_FONT_REASON", "$OPENCL_REASON")
    val opencl_checksum = env_i64("OPENCL_VECTOR_FONT_CHECKSUM", $OPENCL_CHECKSUM)
    val opencl_glyph_count = env_i64("OPENCL_VECTOR_FONT_GLYPH_COUNT", $OPENCL_GLYPH_COUNT)
    val opencl_glyph0_codepoint = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_CODEPOINT", $OPENCL_GLYPH_0_CODEPOINT)
    val opencl_glyph0_font_size = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_FONT_SIZE", $OPENCL_GLYPH_0_FONT_SIZE)
    val opencl_glyph0_width = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_WIDTH", $OPENCL_GLYPH_0_WIDTH)
    val opencl_glyph0_height = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_HEIGHT", $OPENCL_GLYPH_0_HEIGHT)
    val opencl_glyph0_advance = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_ADVANCE", $OPENCL_GLYPH_0_ADVANCE)
    val opencl_glyph0_checksum = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_CHECKSUM", $OPENCL_GLYPH_0_CHECKSUM)
    val opencl_glyph0_ink_pixels = env_i64("OPENCL_VECTOR_FONT_GLYPH_0_INK_PIXELS", $OPENCL_GLYPH_0_INK_PIXELS)
    val opencl_glyph1_codepoint = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_CODEPOINT", $OPENCL_GLYPH_1_CODEPOINT)
    val opencl_glyph1_font_size = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_FONT_SIZE", $OPENCL_GLYPH_1_FONT_SIZE)
    val opencl_glyph1_width = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_WIDTH", $OPENCL_GLYPH_1_WIDTH)
    val opencl_glyph1_height = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_HEIGHT", $OPENCL_GLYPH_1_HEIGHT)
    val opencl_glyph1_advance = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_ADVANCE", $OPENCL_GLYPH_1_ADVANCE)
    val opencl_glyph1_checksum = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_CHECKSUM", $OPENCL_GLYPH_1_CHECKSUM)
    val opencl_glyph1_ink_pixels = env_i64("OPENCL_VECTOR_FONT_GLYPH_1_INK_PIXELS", $OPENCL_GLYPH_1_INK_PIXELS)
    val evidence = web_render_vector_font_compute_evidence("wm-vector-text-grid", checksum, ink_pixels, cuda_status, cuda_reason, cuda_checksum, opencl_status, opencl_reason, opencl_checksum, false)
    print "vector_font_compute_status={evidence.status}"
    print "vector_font_compute_reason={evidence.reason}"
    print "vector_font_compute_scene=wm-vector-text-grid"
    print "vector_font_compute_text_run={TEXT_RUN}"
    print "vector_font_compute_font_size={FONT_SIZE}"
    print "vector_font_compute_iterations={ITERATIONS}"
    print "vector_font_compute_cpu_warm_checksum={warm.0}"
    print "vector_font_compute_cpu_checksum={checksum}"
    print "vector_font_compute_cpu_ink_pixels={ink_pixels}"
    print "vector_font_compute_cpu_frame_us={frame_us}"
    print "vector_font_compute_production_render_checksum={production.0}"
    print "vector_font_compute_production_render_ink_pixels={production.1}"
    print "vector_font_compute_production_vector_raster_hits={production.2}"
    print "vector_font_compute_production_vector_output_pixels={production.3}"
    print "vector_font_compute_production_accelerator_attempts={production.4}"
    print "vector_font_compute_production_cuda_hits={production.5}"
    print "vector_font_compute_production_opencl_hits={production.6}"
    print "vector_font_compute_production_cpu_fallback_hits={production.7}"
    print "vector_font_compute_production_gpu_returned_glyphs={production.8}"
    print "vector_font_compute_production_gpu_returned_glyph_pixels={production.9}"
    print "vector_font_compute_production_accelerator_unavailable_reason={production.10}"
    val matrix_a = production_text_render_checksum_for("CUDAOPENCL", 16)
    val matrix_b = production_text_render_checksum_for("GUIWM", 24)
    val matrix_c = production_text_render_checksum_for("FontRender", 32)
    print "vector_font_compute_matrix_0_text=CUDAOPENCL"
    print "vector_font_compute_matrix_0_font_size=16"
    print "vector_font_compute_matrix_0_checksum={matrix_a.0}"
    print "vector_font_compute_matrix_0_ink_pixels={matrix_a.1}"
    print "vector_font_compute_matrix_0_vector_raster_hits={matrix_a.2}"
    print "vector_font_compute_matrix_0_cpu_fallback_hits={matrix_a.7}"
    print "vector_font_compute_matrix_1_text=GUIWM"
    print "vector_font_compute_matrix_1_font_size=24"
    print "vector_font_compute_matrix_1_checksum={matrix_b.0}"
    print "vector_font_compute_matrix_1_ink_pixels={matrix_b.1}"
    print "vector_font_compute_matrix_1_vector_raster_hits={matrix_b.2}"
    print "vector_font_compute_matrix_1_cpu_fallback_hits={matrix_b.7}"
    print "vector_font_compute_matrix_2_text=FontRender"
    print "vector_font_compute_matrix_2_font_size=32"
    print "vector_font_compute_matrix_2_checksum={matrix_c.0}"
    print "vector_font_compute_matrix_2_ink_pixels={matrix_c.1}"
    print "vector_font_compute_matrix_2_vector_raster_hits={matrix_c.2}"
    print "vector_font_compute_matrix_2_cpu_fallback_hits={matrix_c.7}"
    var glyph_idx = 0
    while glyph_idx < TEXT_RUN.len():
        val codepoint = TEXT_RUN.char_code_at(glyph_idx) as i32
        print "vector_font_compute_glyph_{glyph_idx}_checksum={glyph_checksum(codepoint)}"
        print "vector_font_compute_glyph_{glyph_idx}_ink_pixels={glyph_ink_pixels(codepoint)}"
        print "vector_font_compute_glyph_{glyph_idx}_codepoint={codepoint}"
        print "vector_font_compute_glyph_{glyph_idx}_width={glyph_width(codepoint)}"
        print "vector_font_compute_glyph_{glyph_idx}_pixels={glyph_pixels_csv(codepoint)}"
        val command_count = glyph_command_count(codepoint)
        print "vector_font_compute_glyph_{glyph_idx}_command_count={command_count}"
        var command_idx = 0
        while command_idx < command_count:
            print "vector_font_compute_glyph_{glyph_idx}_command_{command_idx}={glyph_command_at(codepoint, command_idx)}"
            command_idx = command_idx + 1
        glyph_idx = glyph_idx + 1
    print "vector_font_compute_cuda_status={cuda_status}"
    print "vector_font_compute_cuda_reason={cuda_reason}"
    print "vector_font_compute_cuda_checksum={cuda_checksum}"
    print "vector_font_compute_cuda_glyph_count={cuda_glyph_count}"
    print "vector_font_compute_cuda_glyph_0_codepoint={cuda_glyph0_codepoint}"
    print "vector_font_compute_cuda_glyph_0_font_size={cuda_glyph0_font_size}"
    print "vector_font_compute_cuda_glyph_0_width={cuda_glyph0_width}"
    print "vector_font_compute_cuda_glyph_0_height={cuda_glyph0_height}"
    print "vector_font_compute_cuda_glyph_0_advance={cuda_glyph0_advance}"
    print "vector_font_compute_cuda_glyph_0_checksum={cuda_glyph0_checksum}"
    print "vector_font_compute_cuda_glyph_0_ink_pixels={cuda_glyph0_ink_pixels}"
    print "vector_font_compute_cuda_glyph_1_codepoint={cuda_glyph1_codepoint}"
    print "vector_font_compute_cuda_glyph_1_font_size={cuda_glyph1_font_size}"
    print "vector_font_compute_cuda_glyph_1_width={cuda_glyph1_width}"
    print "vector_font_compute_cuda_glyph_1_height={cuda_glyph1_height}"
    print "vector_font_compute_cuda_glyph_1_advance={cuda_glyph1_advance}"
    print "vector_font_compute_cuda_glyph_1_checksum={cuda_glyph1_checksum}"
    print "vector_font_compute_cuda_glyph_1_ink_pixels={cuda_glyph1_ink_pixels}"
    print "vector_font_compute_opencl_status={opencl_status}"
    print "vector_font_compute_opencl_reason={opencl_reason}"
    print "vector_font_compute_opencl_checksum={opencl_checksum}"
    print "vector_font_compute_opencl_glyph_count={opencl_glyph_count}"
    print "vector_font_compute_opencl_glyph_0_codepoint={opencl_glyph0_codepoint}"
    print "vector_font_compute_opencl_glyph_0_font_size={opencl_glyph0_font_size}"
    print "vector_font_compute_opencl_glyph_0_width={opencl_glyph0_width}"
    print "vector_font_compute_opencl_glyph_0_height={opencl_glyph0_height}"
    print "vector_font_compute_opencl_glyph_0_advance={opencl_glyph0_advance}"
    print "vector_font_compute_opencl_glyph_0_checksum={opencl_glyph0_checksum}"
    print "vector_font_compute_opencl_glyph_0_ink_pixels={opencl_glyph0_ink_pixels}"
    print "vector_font_compute_opencl_glyph_1_codepoint={opencl_glyph1_codepoint}"
    print "vector_font_compute_opencl_glyph_1_font_size={opencl_glyph1_font_size}"
    print "vector_font_compute_opencl_glyph_1_width={opencl_glyph1_width}"
    print "vector_font_compute_opencl_glyph_1_height={opencl_glyph1_height}"
    print "vector_font_compute_opencl_glyph_1_advance={opencl_glyph1_advance}"
    print "vector_font_compute_opencl_glyph_1_checksum={opencl_glyph1_checksum}"
    print "vector_font_compute_opencl_glyph_1_ink_pixels={opencl_glyph1_ink_pixels}"
    print "vector_font_compute_blur_or_tolerance_used=false"
    print "vector_font_compute_summary={evidence.summary()}"

main()
SIMPLE_EOF

set +e
CUDA_VECTOR_FONT_STATUS="$CUDA_STATUS" \
CUDA_VECTOR_FONT_REASON="$CUDA_REASON" \
CUDA_VECTOR_FONT_CHECKSUM="$CUDA_CHECKSUM" \
CUDA_VECTOR_FONT_GLYPH_COUNT="$CUDA_GLYPH_COUNT" \
CUDA_VECTOR_FONT_GLYPH_0_CODEPOINT="$CUDA_GLYPH_0_CODEPOINT" \
CUDA_VECTOR_FONT_GLYPH_0_FONT_SIZE="$CUDA_GLYPH_0_FONT_SIZE" \
CUDA_VECTOR_FONT_GLYPH_0_WIDTH="$CUDA_GLYPH_0_WIDTH" \
CUDA_VECTOR_FONT_GLYPH_0_HEIGHT="$CUDA_GLYPH_0_HEIGHT" \
CUDA_VECTOR_FONT_GLYPH_0_ADVANCE="$CUDA_GLYPH_0_ADVANCE" \
CUDA_VECTOR_FONT_GLYPH_0_CHECKSUM="$CUDA_GLYPH_0_CHECKSUM" \
CUDA_VECTOR_FONT_GLYPH_0_INK_PIXELS="$CUDA_GLYPH_0_INK_PIXELS" \
CUDA_VECTOR_FONT_GLYPH_0_PIXELS="$CUDA_GLYPH_0_PIXELS" \
CUDA_VECTOR_FONT_GLYPH_1_CODEPOINT="$CUDA_GLYPH_1_CODEPOINT" \
CUDA_VECTOR_FONT_GLYPH_1_FONT_SIZE="$CUDA_GLYPH_1_FONT_SIZE" \
CUDA_VECTOR_FONT_GLYPH_1_WIDTH="$CUDA_GLYPH_1_WIDTH" \
CUDA_VECTOR_FONT_GLYPH_1_HEIGHT="$CUDA_GLYPH_1_HEIGHT" \
CUDA_VECTOR_FONT_GLYPH_1_ADVANCE="$CUDA_GLYPH_1_ADVANCE" \
CUDA_VECTOR_FONT_GLYPH_1_CHECKSUM="$CUDA_GLYPH_1_CHECKSUM" \
CUDA_VECTOR_FONT_GLYPH_1_INK_PIXELS="$CUDA_GLYPH_1_INK_PIXELS" \
CUDA_VECTOR_FONT_GLYPH_1_PIXELS="$CUDA_GLYPH_1_PIXELS" \
OPENCL_VECTOR_FONT_STATUS="$OPENCL_STATUS" \
OPENCL_VECTOR_FONT_REASON="$OPENCL_REASON" \
OPENCL_VECTOR_FONT_CHECKSUM="$OPENCL_CHECKSUM" \
OPENCL_VECTOR_FONT_GLYPH_COUNT="$OPENCL_GLYPH_COUNT" \
OPENCL_VECTOR_FONT_GLYPH_0_CODEPOINT="$OPENCL_GLYPH_0_CODEPOINT" \
OPENCL_VECTOR_FONT_GLYPH_0_FONT_SIZE="$OPENCL_GLYPH_0_FONT_SIZE" \
OPENCL_VECTOR_FONT_GLYPH_0_WIDTH="$OPENCL_GLYPH_0_WIDTH" \
OPENCL_VECTOR_FONT_GLYPH_0_HEIGHT="$OPENCL_GLYPH_0_HEIGHT" \
OPENCL_VECTOR_FONT_GLYPH_0_ADVANCE="$OPENCL_GLYPH_0_ADVANCE" \
OPENCL_VECTOR_FONT_GLYPH_0_CHECKSUM="$OPENCL_GLYPH_0_CHECKSUM" \
OPENCL_VECTOR_FONT_GLYPH_0_INK_PIXELS="$OPENCL_GLYPH_0_INK_PIXELS" \
OPENCL_VECTOR_FONT_GLYPH_0_PIXELS="$OPENCL_GLYPH_0_PIXELS" \
OPENCL_VECTOR_FONT_GLYPH_1_CODEPOINT="$OPENCL_GLYPH_1_CODEPOINT" \
OPENCL_VECTOR_FONT_GLYPH_1_FONT_SIZE="$OPENCL_GLYPH_1_FONT_SIZE" \
OPENCL_VECTOR_FONT_GLYPH_1_WIDTH="$OPENCL_GLYPH_1_WIDTH" \
OPENCL_VECTOR_FONT_GLYPH_1_HEIGHT="$OPENCL_GLYPH_1_HEIGHT" \
OPENCL_VECTOR_FONT_GLYPH_1_ADVANCE="$OPENCL_GLYPH_1_ADVANCE" \
OPENCL_VECTOR_FONT_GLYPH_1_CHECKSUM="$OPENCL_GLYPH_1_CHECKSUM" \
OPENCL_VECTOR_FONT_GLYPH_1_INK_PIXELS="$OPENCL_GLYPH_1_INK_PIXELS" \
OPENCL_VECTOR_FONT_GLYPH_1_PIXELS="$OPENCL_GLYPH_1_PIXELS" \
SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" run "$SIMPLE_SRC" --mode=interpreter --clean >"$SIMPLE_OUT" 2>&1
simple_code=$?
set -e

if [ "$simple_code" -ne 0 ]; then
    emit_unavailable "simple-vector-font-evidence-failed"
    {
        echo
        echo "## Simple Output"
        sed 's/^/- /' "$SIMPLE_OUT" 2>/dev/null || true
    } >>"$REPORT_PATH"
    exit 1
fi

value_of() {
    key="$1"
    sed -n "s/^${key}=//p" "$SIMPLE_OUT" | tail -n 1
}

set_var() {
    name="$1"
    value="$2"
    eval "$name=\$value"
}

get_var() {
    name="$1"
    eval "printf '%s' \"\${$name:-}\""
}

csv_mismatch_count() {
    node -e 'const a=(process.argv[1]||"").split(",").filter((v)=>v.length); const b=(process.argv[2]||"").split(",").filter((v)=>v.length); let n=0; const m=Math.max(a.length,b.length); for (let i=0;i<m;i+=1) { if ((a[i]||"") !== (b[i]||"")) n += 1; } console.log(n);' "$1" "$2"
}

write_glyph_pixel_json() {
    out="$1"
    producer="$2"
    role="$3"
    slot="$4"
    source_index="$5"
    codepoint="$6"
    font_size="$7"
    width="$8"
    height="$9"
    advance="${10}"
    checksum="${11}"
    ink_pixels="${12}"
    pixels="${13}"
    tmp="$out.tmp"
    {
        printf '{"producer":"%s","role":"%s","slot":%s,"source_index":%s,' "$producer" "$role" "$slot" "$source_index"
        printf '"codepoint":%s,"font_size":%s,"width":%s,"height":%s,' "$codepoint" "$font_size" "$width" "$height"
        printf '"advance":%s,"checksum":%s,"ink_pixels":%s,"format":"alpha-u8","pixels":[' "$advance" "$checksum" "$ink_pixels"
        old_ifs="$IFS"
        IFS=,
        first=1
        for pixel in $pixels; do
            if [ "$first" -eq 0 ]; then
                printf ','
            fi
            printf '%s' "$pixel"
            first=0
        done
        IFS="$old_ifs"
        printf ']}'
    } >"$tmp"
    mv "$tmp" "$out"
}

write_provider_glyph_artifacts() {
    provider="$1"
    count="$2"
    slot=0
    while [ "$slot" -lt "$count" ]; do
        upper="$(printf '%s' "$provider" | tr '[:lower:]' '[:upper:]')"
        source_index="$(get_var "${upper}_GLYPH_${slot}_SOURCE_INDEX")"
        if [ -z "$source_index" ]; then
            source_index="$slot"
        fi
        expected_path="$BUILD_DIR/${provider}-glyph-${slot}-expected-alpha-u8.json"
        actual_path="$BUILD_DIR/${provider}-glyph-${slot}-actual-alpha-u8.json"
        expected_pixels="$(value_of "vector_font_compute_glyph_${source_index}_pixels")"
        expected_codepoint="$(value_of "vector_font_compute_glyph_${source_index}_codepoint")"
        expected_width="$(value_of "vector_font_compute_glyph_${source_index}_width")"
        expected_checksum="$(value_of "vector_font_compute_glyph_${source_index}_checksum")"
        expected_ink="$(value_of "vector_font_compute_glyph_${source_index}_ink_pixels")"
        actual_pixels="$(get_var "${upper}_GLYPH_${slot}_PIXELS")"
        actual_codepoint="$(get_var "${upper}_GLYPH_${slot}_CODEPOINT")"
        actual_width="$(get_var "${upper}_GLYPH_${slot}_WIDTH")"
        actual_height="$(get_var "${upper}_GLYPH_${slot}_HEIGHT")"
        actual_advance="$(get_var "${upper}_GLYPH_${slot}_ADVANCE")"
        actual_checksum="$(get_var "${upper}_GLYPH_${slot}_CHECKSUM")"
        actual_ink="$(get_var "${upper}_GLYPH_${slot}_INK_PIXELS")"
        if [ -n "$expected_pixels" ]; then
            write_glyph_pixel_json "$expected_path" "simple-cpu-vector-font" "expected" "$slot" "$source_index" "$expected_codepoint" "$FONT_SIZE" "$expected_width" "$FONT_SIZE" "$((expected_width + 1))" "$expected_checksum" "$expected_ink" "$expected_pixels"
            set_var "${upper}_GLYPH_${slot}_EXPECTED_PIXELS_PATH" "$expected_path"
        fi
        if [ -n "$actual_pixels" ]; then
            write_glyph_pixel_json "$actual_path" "${provider}-vector-font-readback" "actual" "$slot" "$source_index" "$actual_codepoint" "$FONT_SIZE" "$actual_width" "$actual_height" "$actual_advance" "$actual_checksum" "$actual_ink" "$actual_pixels"
            set_var "${upper}_GLYPH_${slot}_ACTUAL_PIXELS_PATH" "$actual_path"
        fi
        slot=$((slot + 1))
    done
}

require_provider_glyph_artifacts() {
    provider="$1"
    count="$2"
    upper="$(printf '%s' "$provider" | tr '[:lower:]' '[:upper:]')"
    slot=0
    while [ "$slot" -lt "$count" ]; do
        expected_path="$(get_var "${upper}_GLYPH_${slot}_EXPECTED_PIXELS_PATH")"
        actual_path="$(get_var "${upper}_GLYPH_${slot}_ACTUAL_PIXELS_PATH")"
        if [ ! -s "$expected_path" ] || [ ! -s "$actual_path" ]; then
            return 1
        fi
        slot=$((slot + 1))
    done
    return 0
}

export_vector_font_env() {
    export CUDA_VECTOR_FONT_STATUS="$CUDA_STATUS"
    export CUDA_VECTOR_FONT_REASON="$CUDA_REASON"
    export CUDA_VECTOR_FONT_CHECKSUM="$CUDA_CHECKSUM"
    export CUDA_VECTOR_FONT_GLYPH_COUNT="$CUDA_GLYPH_COUNT"
    slot=0
    while [ "$slot" -lt "$CUDA_GLYPH_COUNT" ]; do
        value="$(get_var "CUDA_GLYPH_${slot}_CODEPOINT")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_CODEPOINT=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_FONT_SIZE")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_FONT_SIZE=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_WIDTH")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_WIDTH=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_HEIGHT")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_HEIGHT=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_ADVANCE")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_ADVANCE=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_CHECKSUM")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_CHECKSUM=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_INK_PIXELS")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_INK_PIXELS=\"\$value\""
        value="$(get_var "CUDA_GLYPH_${slot}_PIXELS")"; eval "export CUDA_VECTOR_FONT_GLYPH_${slot}_PIXELS=\"\$value\""
        slot=$((slot + 1))
    done
    export OPENCL_VECTOR_FONT_STATUS="$OPENCL_STATUS"
    export OPENCL_VECTOR_FONT_REASON="$OPENCL_REASON"
    export OPENCL_VECTOR_FONT_CHECKSUM="$OPENCL_CHECKSUM"
    export OPENCL_VECTOR_FONT_GLYPH_COUNT="$OPENCL_GLYPH_COUNT"
    slot=0
    while [ "$slot" -lt "$OPENCL_GLYPH_COUNT" ]; do
        value="$(get_var "OPENCL_GLYPH_${slot}_CODEPOINT")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_CODEPOINT=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_FONT_SIZE")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_FONT_SIZE=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_WIDTH")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_WIDTH=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_HEIGHT")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_HEIGHT=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_ADVANCE")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_ADVANCE=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_CHECKSUM")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_CHECKSUM=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_INK_PIXELS")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_INK_PIXELS=\"\$value\""
        value="$(get_var "OPENCL_GLYPH_${slot}_PIXELS")"; eval "export OPENCL_VECTOR_FONT_GLYPH_${slot}_PIXELS=\"\$value\""
        slot=$((slot + 1))
    done
}

