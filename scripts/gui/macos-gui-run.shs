#!/usr/bin/env bash
# macos-gui-run.shs — run a Simple GUI program in a real on-screen window on macOS.
#
# Why this exists: a bare CLI process is never registered with the macOS window
# server, so an interpreter-driven winit window is created but never composites
# (lsappinfo shows it unregistered). Launching from a proper .app bundle via
# LaunchServices registers the process in the Aqua session, after which the window
# displays. (The Simple program must also poll the event loop continuously rather
# than rt_thread_sleep — see examples/06_io/ui/web_engine2d_gui.spl.)
# See doc/08_tracking/bug/macos_winit_window_not_displayed_2026-05-28.md.
#
# Usage: scripts/macos-gui-run.shs <file.spl|file.smf> [program args...]
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "macos-gui-run.shs is macOS-only; on Linux/Windows run the gui driver directly." >&2
  exit 1
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
program="${1:-$repo_root/src/os/hosted/hosted_entry.spl}"
if [[ $# -gt 0 ]]; then shift; fi
program="$(cd "$(dirname "$program")" && pwd)/$(basename "$program")"
if [[ ! -f "$program" ]]; then echo "error: file not found: $program" >&2; exit 1; fi
case "$program" in
  *.spl|*.smf) ;;
  *) echo "error: expected a .spl source or compiled .smf artifact: $program" >&2; exit 1 ;;
esac

program_args=()
for arg in "$@"; do
  if [[ -f "$arg" ]]; then
    program_args+=("$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")")
  elif [[ -f "$repo_root/$arg" ]]; then
    program_args+=("$repo_root/$arg")
  else
    program_args+=("$arg")
  fi
done

# Locate a GUI-enabled driver (contains the winit runtime).
gui_bin=""
for c in \
  "$repo_root/src/compiler_rust/target/gui/release/simple" \
  "$repo_root/src/compiler_rust/target/gui/debug/simple"; do
  # Release linking may strip the raw extern symbol name even though the GUI
  # feature and embedded window module are present. Accept either marker.
  if [[ -x "$c" ]] && LC_ALL=C grep -aq \
      -e "rt_winit_event_loop_new" -e "window_winitmodule.smf" "$c"; then
    gui_bin="$c"
    break
  fi
done
if [[ -z "$gui_bin" ]]; then
  echo "error: no GUI-enabled driver found." >&2
  echo "build one: (cd \"$repo_root/src/compiler_rust\" && CARGO_TARGET_DIR=target/gui cargo build -p simple-driver --features gui)" >&2
  exit 1
fi

# Build a throwaway .app bundle whose executable IS the driver (self-contained),
# so LaunchServices registers it. An exec-wrapper does NOT work (de-registers).
app="$(mktemp -d)/SimpleGui.app"
mkdir -p "$app/Contents/MacOS"
cp "$gui_bin" "$app/Contents/MacOS/SimpleGui"
cat > "$app/Contents/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key><string>SimpleGui</string>
  <key>CFBundleIdentifier</key><string>com.simple.gui.run.$$</string>
  <key>CFBundleName</key><string>SimpleGui</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleVersion</key><string>1</string>
  <key>NSHighResolutionCapable</key><false/>
  <key>LSEnvironment</key>
  <dict>
    <key>SIMPLE_GUI</key><string>1</string>
    <key>SIMPLE_EXECUTION_MODE</key><string>interpret</string>
    <key>SIMPLE_NO_DEPRECATED_WARNINGS</key><string>${SIMPLE_NO_DEPRECATED_WARNINGS:-1}</string>
    <key>SIMPLE_LIB</key><string>${SIMPLE_LIB:-$repo_root/src}</string>
    <key>SIMPLE_ASSET_ROOT</key><string>${SIMPLE_ASSET_ROOT:-$repo_root}</string>
    <!-- GUI sessions are intentionally long-lived. A positive example timeout
         makes the driver fork an unregistered child, which cannot own an Aqua
         window. Callers that launch a compiled non-example artifact may still
         opt into a bounded timeout explicitly. -->
    <key>SIMPLE_TIMEOUT_SECONDS</key><string>${SIMPLE_TIMEOUT_SECONDS:-0}</string>
    <key>SIMPLE_EVT_LOG</key><string>${SIMPLE_EVT_LOG:-}</string>
    <key>SIMPLE_GUI_EVENT_EVIDENCE_PATH</key><string>${SIMPLE_GUI_EVENT_EVIDENCE_PATH:-}</string>
    <key>SIMPLE_GUI_BACKEND</key><string>${SIMPLE_GUI_BACKEND:-}</string>
    <key>SIMPLE_GUI_EXIT_AFTER_INTERACTION</key><string>${SIMPLE_GUI_EXIT_AFTER_INTERACTION:-}</string>
    <key>SIMPLE_ONE_CALL_UPLOAD</key><string>${SIMPLE_ONE_CALL_UPLOAD:-1}</string>
    <key>SIMPLE_ONE_CALL_READBACK</key><string>${SIMPLE_ONE_CALL_READBACK:-1}</string>
    <key>SHOWCASE_RESOLUTION</key><string>${SHOWCASE_RESOLUTION:-}</string>
    <key>SHOWCASE_DPI</key><string>${SHOWCASE_DPI:-}</string>
    <key>VK_ICD_FILENAMES</key><string>${VK_ICD_FILENAMES:-}</string>
    <key>DYLD_LIBRARY_PATH</key><string>${DYLD_LIBRARY_PATH:-}</string>
  </dict>
</dict>
</plist>
PLIST

echo "launching $program as $app ..."
echo "app stdout: $app/../launch.out  stderr: $app/../launch.err"
if [[ "${#program_args[@]}" -gt 0 ]]; then
  open -n --stdout "$app/../launch.out" --stderr "$app/../launch.err" "$app" --args run "$program" --no-daemon "${program_args[@]}"
else
  open -n --stdout "$app/../launch.out" --stderr "$app/../launch.err" "$app" --args run "$program" --no-daemon
fi

if [[ "${SIMPLE_GUI_RUN_SKIP_NUDGE:-0}" = "1" ]]; then
  exit 0
fi

# winit may place small windows off-screen on multi-display macOS setups; nudge
# the first real app window on-screen once it appears. LaunchServices may show a
# transient process before the window-owning process, so select by window count.
for _ in $(seq 1 60); do
  if osascript <<'OSA' >/dev/null 2>&1; then
tell application "SimpleGui" to activate
tell application "System Events"
  repeat with proc in (processes whose name is "SimpleGui")
    tell proc
      if (count of windows) > 0 then
        set position of window 1 to {200, 120}
        return true
      end if
    end tell
  end repeat
end tell
error "SimpleGui window not ready"
OSA
    break
  fi
  sleep 1
done
