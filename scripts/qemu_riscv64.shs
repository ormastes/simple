#!/bin/sh
# SimpleOS QEMU Runner — RISC-V 64 (OpenSBI S-mode virt machine)
#
# Usage:
#   sh scripts/qemu_riscv64.shs              # full boot and validate serial output
#   sh scripts/qemu_riscv64.shs --smoke      # minimal boot smoke
#   sh scripts/qemu_riscv64.shs --skip-build # use prebuilt kernel
#   sh scripts/qemu_riscv64.shs --interactive --net --display
#   sh scripts/qemu_riscv64.shs --fs-image   # attach generated FAT/NVFS-marked image

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
KERNEL="$REPO_ROOT/build/os/simpleos_riscv64.elf"
SERIAL_LOG="$REPO_ROOT/build/os/serial_riscv64.log"
BUILD_LOG="$REPO_ROOT/build/os/build_riscv64.log"
SIMPLE_BIN="${SIMPLE_BINARY:-$REPO_ROOT/bin/simple}"
ENTRY_FILE="${RISCV64_ENTRY:-}"
SOURCE_ARGS="${RISCV64_SOURCE_ARGS:-}"
TIMEOUT_SEC=30
BUILD_TIMEOUT_SEC="${BUILD_TIMEOUT_SEC:-180}"
SKIP_BUILD=0
SMOKE=0
INTERACTIVE=0
NET=0
DISPLAY=0
FS_IMAGE=0
NVFS_IMAGE=0
DISK_IMAGE="${RISCV64_DISK_IMAGE:-$REPO_ROOT/build/os/fat32-riscv64.img}"
QMP_SOCKET=""
CAPTURE_PPM=""

while [ $# -gt 0 ]; do
    case "$1" in
        --skip-build) SKIP_BUILD=1 ;;
        --smoke)      SMOKE=1 ;;
        --interactive) INTERACTIVE=1 ;;
        --net) NET=1 ;;
        --display) DISPLAY=1 ;;
        --fs-image) FS_IMAGE=1 ;;
        --nvfs-image) FS_IMAGE=1; NVFS_IMAGE=1 ;;
        --disk-image=*) DISK_IMAGE="${1#--disk-image=}" ;;
        --disk-image)
            shift
            [ $# -gt 0 ] || { echo "Missing value for --disk-image"; exit 1; }
            DISK_IMAGE="$1"
            ;;
        *)            echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

if [ "$FS_IMAGE" -eq 1 ] && [ "$NET" -eq 0 ] && [ "$INTERACTIVE" -eq 0 ] && [ "$DISPLAY" -eq 0 ] && [ -z "$RISCV64_ENTRY" ]; then
    SMOKE=1
fi

if [ "$NET" -eq 1 ]; then
    KERNEL="$REPO_ROOT/build/os/simpleos_riscv64_net.elf"
    SERIAL_LOG="$REPO_ROOT/build/os/serial_riscv64_net.log"
    BUILD_LOG="$REPO_ROOT/build/os/build_riscv64_net.log"
elif [ "$SMOKE" -eq 1 ]; then
    KERNEL="$REPO_ROOT/build/os/simpleos_riscv64_smoke.elf"
    SERIAL_LOG="$REPO_ROOT/build/os/serial_riscv64_smoke.log"
    BUILD_LOG="$REPO_ROOT/build/os/build_riscv64_smoke.log"
fi

if [ "$DISPLAY" -eq 1 ]; then
    QMP_SOCKET="$REPO_ROOT/build/os/qmp_riscv64_display.sock"
    CAPTURE_PPM="$REPO_ROOT/build/os/riscv64_display.ppm"
fi

if [ -z "$ENTRY_FILE" ]; then
    if [ "$SMOKE" -eq 1 ]; then
        ENTRY_FILE="examples/simple_os/arch/riscv64/smoke_entry.spl"
    elif [ "$NET" -eq 1 ]; then
        ENTRY_FILE="examples/simple_os/arch/riscv64/net_entry.spl"
    else
        ENTRY_FILE="examples/simple_os/arch/riscv64/os_entry.spl"
    fi
fi

if [ -z "$SOURCE_ARGS" ]; then
    if [ -n "$RISCV64_SOURCE" ]; then
        SOURCE_ARGS="--source $RISCV64_SOURCE"
    elif [ "$SMOKE" -eq 1 ]; then
        SOURCE_ARGS="--source examples/simple_os/arch/riscv64"
    else
        SOURCE_ARGS="--source examples/simple_os/arch/riscv64 --source src"
    fi
fi

TIMEOUT_CMD=""
if command -v timeout >/dev/null 2>&1; then
    TIMEOUT_CMD="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
    TIMEOUT_CMD="gtimeout"
fi

if ! command -v qemu-system-riscv64 >/dev/null 2>&1; then
    echo "SKIP: qemu-system-riscv64 not found"
    exit 0
fi

if [ "$SKIP_BUILD" -eq 0 ] && [ -x "$SIMPLE_BIN" ]; then
    echo "[build] Building SimpleOS riscv64 kernel (per-file timeout: ${BUILD_TIMEOUT_SEC}s)..."
    mkdir -p "$REPO_ROOT/build/os"
    if [ "$SMOKE" -eq 1 ]; then
        SIMPLE_BOOT_MINIMAL=1 "$SIMPLE_BIN" native-build \
            --backend llvm \
            --timeout "$BUILD_TIMEOUT_SEC" \
            $SOURCE_ARGS \
            --entry "$ENTRY_FILE" \
            --entry-closure \
            --target riscv64-unknown-none \
            -o "$KERNEL" \
            --linker-script examples/simple_os/arch/riscv64/linker.ld >"$BUILD_LOG" 2>&1
    else
        SIMPLE_BOOT_MINIMAL=1 "$SIMPLE_BIN" native-build \
            --backend llvm \
            --timeout "$BUILD_TIMEOUT_SEC" \
            $SOURCE_ARGS \
            --entry "$ENTRY_FILE" \
            --entry-closure \
            --target riscv64-unknown-none \
            -o "$KERNEL" \
            --linker-script examples/simple_os/arch/riscv64/linker.ld >"$BUILD_LOG" 2>&1
    fi
    BUILD_RC=$?
    if [ "$BUILD_RC" -ne 0 ]; then
        echo "FAIL: Kernel build failed (exit $BUILD_RC)"
        echo "[build] Log tail ($BUILD_LOG):"
        tail -n 80 "$BUILD_LOG"
        exit 1
    fi
fi

if [ ! -f "$KERNEL" ]; then
    echo "SKIP: Kernel not found at $KERNEL"
    echo "  Build with: bin/simple native-build $SOURCE_ARGS --entry $ENTRY_FILE --entry-closure \\"
    echo "    --target riscv64-unknown-none -o $KERNEL \\"
    echo "    --linker-script examples/simple_os/arch/riscv64/linker.ld"
    exit 0
fi

ensure_fs_image() {
    _img="$1"
    _arch="$2"
    mkdir -p "$(dirname "$_img")"
    SIMPLEOS_IMAGE_VERSION="${SIMPLEOS_IMAGE_VERSION:-0.1.0}" \
        sh "$REPO_ROOT/scripts/make_os_disk.shs" 64 "$_img" "" "$_arch"
}

validate_fs_image_markers() {
    _img="$1"
    if [ ! -f "$_img" ]; then
        echo "FAIL: RISC-V filesystem image missing: $_img"
        return 1
    fi
    if ! grep -a -q "simpleos=" "$_img"; then
        echo "FAIL: RISC-V filesystem image lacks /SYS/VERSION.TXT marker"
        return 1
    fi
    if ! grep -a -q "nvfs-image-version=" "$_img"; then
        echo "FAIL: RISC-V filesystem image lacks /SYS/NVFSVER.TXT marker"
        return 1
    fi
    return 0
}

if [ "$FS_IMAGE" -eq 1 ]; then
    echo "[disk] Building RISC-V filesystem image: $DISK_IMAGE"
    if ! ensure_fs_image "$DISK_IMAGE" "riscv64"; then
        echo "FAIL: RISC-V filesystem image build failed"
        exit 1
    fi
    if ! validate_fs_image_markers "$DISK_IMAGE"; then
        exit 1
    fi
fi

echo "[boot] Booting SimpleOS riscv64 in QEMU (timeout: ${TIMEOUT_SEC}s)..."
rm -f "$SERIAL_LOG" "$QMP_SOCKET" "$CAPTURE_PPM"

QEMU_DEVICE_ARGS=""
if [ "$NET" -eq 1 ]; then
    QEMU_DEVICE_ARGS="$QEMU_DEVICE_ARGS -netdev user,id=net0 -device virtio-net-pci,netdev=net0,disable-legacy=on"
else
    QEMU_DEVICE_ARGS="$QEMU_DEVICE_ARGS -nic none"
fi
if [ "$DISPLAY" -eq 1 ]; then
    QEMU_DEVICE_ARGS="$QEMU_DEVICE_ARGS -device virtio-gpu-pci,disable-legacy=on"
fi
if [ "$FS_IMAGE" -eq 1 ]; then
    QEMU_DEVICE_ARGS="$QEMU_DEVICE_ARGS -drive file=$DISK_IMAGE,if=none,id=rvfs,format=raw -device virtio-blk-device,drive=rvfs"
fi

QMP_ARGS=""
if [ "$DISPLAY" -eq 1 ]; then
    QMP_ARGS="-qmp unix:$QMP_SOCKET,server,nowait"
fi

QEMU_ARGS="-nodefaults \
    -machine virt -cpu rv64 -m 512M \
    -bios default \
    -kernel $KERNEL \
    -serial file:$SERIAL_LOG \
    -display none \
    -global virtio-mmio.force-legacy=false \
    $QEMU_DEVICE_ARGS \
    $QMP_ARGS \
    -no-reboot"

wait_for_serial_marker() {
    _pattern="$1"
    _timeout="$2"
    _elapsed=0
    while [ "$_elapsed" -lt "$_timeout" ]; do
        if [ -f "$SERIAL_LOG" ] && grep -qiE "$_pattern" "$SERIAL_LOG"; then
            return 0
        fi
        sleep 1
        _elapsed=$((_elapsed + 1))
    done
    return 1
}

qmp_screendump() {
    _socket="$1"
    _out="$2"
    python3 - "$_socket" "$_out" <<'PY'
import json, os, socket, sys, time
sock_path, out_path = sys.argv[1], sys.argv[2]
deadline = time.time() + 10
while not os.path.exists(sock_path):
    if time.time() > deadline:
        raise SystemExit(2)
    time.sleep(0.1)
s = socket.socket(socket.AF_UNIX)
s.settimeout(5)
s.connect(sock_path)
f = s.makefile("rwb", buffering=0)
f.readline()
f.write(json.dumps({"execute": "qmp_capabilities"}).encode() + b"\n")
f.readline()
for cmd in (
    {"execute": "screendump", "arguments": {"filename": out_path, "format": "ppm"}},
    {"execute": "screendump", "arguments": {"filename": out_path}},
):
    f.write(json.dumps(cmd).encode() + b"\n")
    line = f.readline()
    try:
        resp = json.loads(line.decode() or "{}")
    except Exception:
        resp = {"error": {}}
    if "error" not in resp:
        break
for _ in range(50):
    if os.path.exists(out_path) and os.path.getsize(out_path) > 32:
        raise SystemExit(0)
    time.sleep(0.1)
raise SystemExit(3)
PY
}

validate_ppm() {
    _path="$1"
    python3 - "$_path" <<'PY'
import sys
p = sys.argv[1]
with open(p, "rb") as f:
    def tok():
        b = bytearray()
        while True:
            c = f.read(1)
            if not c:
                return bytes(b)
            if c == b"#":
                f.readline()
                continue
            if c.isspace():
                if b:
                    return bytes(b)
                continue
            b.extend(c)
    if tok() != b"P6":
        raise SystemExit(1)
    w, h, m = int(tok()), int(tok()), int(tok())
    data = f.read()
if w <= 0 or h <= 0 or m != 255 or len(data) < w * h * 3:
    raise SystemExit(1)
sample = data[:min(len(data), 200000)]
colors = {sample[i:i+3] for i in range(0, len(sample) - 2, 3)}
if len(colors) < 3 or all(c == b"\x00\x00\x00" for c in colors):
    raise SystemExit(1)
print(f"PPM {w}x{h} colors={len(colors)}")
PY
}

if [ "$DISPLAY" -eq 1 ]; then
    qemu-system-riscv64 $QEMU_ARGS 2>/dev/null &
    QEMU_PID=$!
    if ! wait_for_serial_marker "Display capture ready" 20; then
        echo "FAIL: Display capture marker not seen before capture"
        kill "$QEMU_PID" 2>/dev/null
        wait "$QEMU_PID" 2>/dev/null
        exit 1
    fi
    if ! qmp_screendump "$QMP_SOCKET" "$CAPTURE_PPM"; then
        echo "FAIL: QMP screendump failed"
        kill "$QEMU_PID" 2>/dev/null
        wait "$QEMU_PID" 2>/dev/null
        exit 1
    fi
    if ! validate_ppm "$CAPTURE_PPM"; then
        echo "FAIL: Display screenshot validation failed"
        kill "$QEMU_PID" 2>/dev/null
        wait "$QEMU_PID" 2>/dev/null
        exit 1
    fi
    _elapsed=0
    while kill -0 "$QEMU_PID" 2>/dev/null && [ "$_elapsed" -lt "$TIMEOUT_SEC" ]; do
        sleep 1
        _elapsed=$((_elapsed + 1))
    done
    if kill -0 "$QEMU_PID" 2>/dev/null; then
        kill "$QEMU_PID" 2>/dev/null
        wait "$QEMU_PID" 2>/dev/null
        QEMU_EXIT=124
    else
        wait "$QEMU_PID" 2>/dev/null
        QEMU_EXIT=$?
    fi
elif [ -n "$TIMEOUT_CMD" ]; then
    $TIMEOUT_CMD "$TIMEOUT_SEC" qemu-system-riscv64 $QEMU_ARGS 2>/dev/null
    QEMU_EXIT=$?
else
    qemu-system-riscv64 $QEMU_ARGS 2>/dev/null &
    QEMU_PID=$!
    sleep "$TIMEOUT_SEC"
    kill "$QEMU_PID" 2>/dev/null
    wait "$QEMU_PID" 2>/dev/null
    QEMU_EXIT=$?
fi

echo "[boot] QEMU exited with code: $QEMU_EXIT"

if [ "$QEMU_EXIT" -eq 124 ]; then
    echo "FAIL: QEMU timed out instead of exiting cleanly"
    exit 1
fi

if [ ! -f "$SERIAL_LOG" ]; then
    echo "FAIL: No serial output captured"
    exit 1
fi

echo "[boot] Serial output:"
head -80 "$SERIAL_LOG"
echo ""

PASS=0
FAIL=0

check_marker() {
    _name="$1"
    _pattern="$2"
    if grep -qiE "$_pattern" "$SERIAL_LOG"; then
        echo "PASS: $_name"
        PASS=$((PASS + 1))
    else
        echo "FAIL: $_name"
        FAIL=$((FAIL + 1))
    fi
}

check_marker "Boot banner"        "SimpleOS|simpleos|spl_start"
check_marker "UART / SBI console" "UART|SBI|serial|RV32 boot OK|RV64 boot OK"
check_marker "Boot complete"      "boot complete|SimpleOS ready|TEST PASSED"

if [ "$INTERACTIVE" -eq 1 ]; then
    check_marker "SPM service"      "SPM port"
    if [ "$DISPLAY" -eq 1 ]; then
        check_marker "Display service"  "Display service ready|display: ready"
    else
        check_marker "Display probe"    "Display unavailable|display: unavailable"
    fi
    check_marker "Shell service"    "Shell ready"
    if [ "$NET" -eq 1 ]; then
        check_marker "Network service" "Network service ready|network: ready"
    else
        check_marker "Network probe"   "Network unavailable|network: unavailable"
    fi
fi

if [ "$DISPLAY" -eq 1 ]; then
    check_marker "Display GPU I/O" "Display GPU ready|Display flush passed"
    echo "PASS: Display screenshot"
    PASS=$((PASS + 1))
fi

if [ "$FS_IMAGE" -eq 1 ]; then
    echo "PASS: RISC-V filesystem image attached"
    PASS=$((PASS + 1))
    if [ "$NVFS_IMAGE" -eq 1 ]; then
        echo "PASS: RISC-V NVFS image markers present"
        PASS=$((PASS + 1))
    fi
fi

echo ""
echo "=== Results: $PASS passed, $FAIL failed ==="

if [ "$FAIL" -gt 0 ]; then
    echo "TEST FAILED"
    exit 1
fi

echo "TEST PASSED"
exit 0
