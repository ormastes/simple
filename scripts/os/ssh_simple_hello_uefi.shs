#!/bin/sh
# ssh_simple_hello_uefi.shs — Lane B-v2 board gate: run the in-guest Simple
# interpreter (/usr/bin/simple) on SimpleOS booted through REAL UEFI firmware
# (OVMF pflash -> GRUB-EFI -> multiboot1), NOT QEMU `-kernel`, and drive it
# over SSH: `ssh root@host /usr/bin/simple simple /hello.spl`.
#
# Sibling of scripts/os/scp_retrieve_over_ssh_uefi.shs (the clang gate). The
# ONLY differences:
#   1. Payload = bin/release/x86_64-unknown-simpleos/simple (the focused
#      simpleos_tool build), staged at /usr/bin/simple + /FSEXEC.ELF via
#      scripts/os/fsexec_mkimg_simple.spl (sibling image writer).
#   2. Small guest file = /hello.spl (print line) instead of hello.c.
#   3. Gate command uses the ABSOLUTE path /usr/bin/simple: the sshd exec
#      dispatch intercepts bare "simple ..." with a canned legacy fixture
#      (_exec_success_output_for_command in ssh_session.spl) — the leading
#      '/' raw-byte branch bypasses it into the real deferred ring-3 exec.
#      An extra "simple" token is passed because sshd discards argv[0]
#      (see sshd.spl _sshd_run_pending_exec): guest argv becomes
#      ["simple", "/hello.spl"] so simpleos_tool main() sees args[1]=/hello.spl.
#
# GATES (serial):
#   L1 "[grub-uefi] multiboot loading"     OVMF -> GRUB-EFI app ran
#   L2 "call _start" / "SimpleOS Boot"      multiboot handoff -> kernel _start
#   L3 "accept loop start"                  sshd reached ring-3 accept loop
#   L4 serial/SSH: "hello from simple on simpleos"  in-guest interpreter ran
#
# Env: SEED, SIMPLE_BIN, SKIP_STAGE, SKIP_KERNEL=1 (default: reuse existing
#      128MB kernel), QEMU_MEM (2G), BOOT_WAIT.
set -eu
ROOT=$(cd "$(dirname "$0")/../.." && pwd)
cd "$ROOT"

SEED="${SEED:-src/compiler_rust/target/release/simple}"
SIMPLE_BIN="${SIMPLE_BIN:-bin/release/x86_64-unknown-simpleos/simple}"
ENTRY="examples/09_embedded/simple_os/arch/x86_64/ssh_ring3_clang_entry.spl"
LINKER="examples/09_embedded/simple_os/arch/x86_64/linker_128mb.ld"
KERNEL="build/os/simpleos_ssh_ring3_uefi128_laneb.elf"
IMG="build/os/elfexec_simple/fat32-simple.img"
SERIAL="build/os/ssh_simple_hello_uefi.serial.log"
CACHE="build/os/ssh_simple_cache_uefi128_laneb"
BUILD="build/os/uefi_simple"
ESP="$BUILD/esp"
EFIAPP="$ESP/EFI/BOOT/BOOTX64.EFI"
OVMF_CODE="${OVMF_CODE:-/usr/share/OVMF/OVMF_CODE_4M.fd}"
OVMF_VARS_SRC="${OVMF_VARS_SRC:-/usr/share/OVMF/OVMF_VARS_4M.fd}"
OVMF_VARS="$BUILD/OVMF_VARS_4M.fd"
QEMU_MEM="${QEMU_MEM:-2G}"
BOOT_WAIT="${BOOT_WAIT:-90}"
SCRATCH="${SCRATCH:-/tmp/claude-1000/-home-ormastes-dev-pub-simple/f6547767-3f36-4410-969d-edaead425415/scratchpad}"

command -v grub-mkstandalone >/dev/null 2>&1 || { echo "FAIL: grub-mkstandalone missing"; exit 1; }
command -v qemu-system-x86_64 >/dev/null 2>&1 || { echo "FAIL: qemu-system-x86_64 missing"; exit 1; }
command -v sshpass >/dev/null 2>&1 || { echo "FAIL: sshpass missing"; exit 1; }
[ -f "$OVMF_CODE" ] || { echo "FAIL: OVMF_CODE not found at $OVMF_CODE"; exit 1; }
[ -f "$OVMF_VARS_SRC" ] || { echo "FAIL: OVMF_VARS not found at $OVMF_VARS_SRC"; exit 1; }
mkdir -p build/os/elfexec_simple build/os/generated/generated "$SCRATCH"

# ---- 1. Payload image: /usr/bin/simple (+/FSEXEC.ELF alias) + /hello.spl ----
if [ "${SKIP_STAGE:-0}" != "1" ] || [ ! -f "$IMG" ]; then
    [ -f "$SIMPLE_BIN" ] || { echo "[uefi-simple] missing $SIMPLE_BIN (build it first)"; exit 1; }
    printf 'print("hello from simple on simpleos")\n' > build/os/elfexec_simple/hello.spl
    SIZE="$(stat -c%s "$SIMPLE_BIN")"; echo "$SIZE" > build/os/elfexec_simple/payload_size.txt
    MKOUT="$(SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SEED" run scripts/os/fsexec_mkimg_simple.spl 2>&1)"
    echo "$MKOUT" | tail -2
    TOTAL="$(echo "$MKOUT" | sed -n 's/.*total_bytes=\([0-9][0-9]*\).*/\1/p' | tail -1)"
    [ -n "$TOTAL" ] || { echo "[uefi-simple] could not parse total_bytes"; exit 1; }
    cat build/os/elfexec_simple/fat32-simple-prefix.bin "$SIMPLE_BIN" > "$IMG"
    truncate -s "$TOTAL" "$IMG"
fi
[ -f "$IMG" ] || { echo "[uefi-simple] missing image $IMG"; exit 1; }
if command -v readelf >/dev/null 2>&1; then
    PBASE="$(readelf -l "$SIMPLE_BIN" 2>/dev/null | awk '/LOAD/{print $3; exit}')"
    echo "[uefi-simple] simple first PT_LOAD vaddr = $PBASE (want 0x0000000040000000)"
fi

# ---- 2. Kernel: reuse the existing 128 MiB-base merged SSH kernel ----------
if [ "${SKIP_KERNEL:-0}" != "1" ] || [ ! -f "$KERNEL" ]; then
    printf 'pub fn ssh_live_build_marker() -> text:\n    "ssh-ring3-build:uefi-simple-128"\n' \
        > build/os/generated/ssh_live_build_marker.spl
    OBJCOPY_PREFIX=""
    for d in /usr/lib/llvm-20/bin /usr/lib/llvm-19/bin /usr/lib/llvm-18/bin; do
        [ -f "$d/llvm-objcopy" ] && OBJCOPY_PREFIX="$d" && break
    done
    rm -rf "$CACHE"; mkdir -p "$CACHE"; rm -f "$KERNEL"
    echo "[uefi-simple] building 128MB-base kernel -> $KERNEL"
    SIMPLE_BOOTSTRAP=1 SIMPLE_LIB="$ROOT/src" SIMPLE_OS_LOG_MODE=off SIMPLE_ALLOW_FREESTANDING_STUBS=1 \
    PATH="${OBJCOPY_PREFIX:+$OBJCOPY_PREFIX:}$PATH" \
        "$SEED" native-build --source build/os/generated --source src/os --source src/lib \
        --source examples/09_embedded/simple_os --backend cranelift --cpu x86-64-v1 \
        --opt-level=aggressive --log off --entry-closure --cache-dir "$CACHE" \
        --entry "$ENTRY" --target x86_64-unknown-none -o "$KERNEL" \
        --linker-script "$LINKER" 2>&1 | tail -20
    [ -f "$KERNEL" ] || { echo "[uefi-simple] KERNEL BUILD FAILED"; exit 1; }
fi
sh scripts/check/check-simpleos-x86-kernel-elf.shs "$KERNEL"
echo "[uefi-simple] kernel=$KERNEL ($(stat -c%s "$KERNEL") bytes)"

# ---- 3. ESP: self-contained BOOTX64.EFI (kernel in memdisk) ----------------
rm -rf "$BUILD"; mkdir -p "$ESP/EFI/BOOT"
cp "$OVMF_VARS_SRC" "$OVMF_VARS"
cat > "$BUILD/grub.cfg" <<'CFG'
set timeout=0
set default=0
insmod multiboot
insmod normal
menuentry "SimpleOS SSH ring-3 simple (UEFI/multiboot, 128MB)" {
    echo "[grub-uefi] multiboot loading /boot/kernel.elf ..."
    multiboot /boot/kernel.elf
    boot
}
CFG
grub-mkstandalone --format=x86_64-efi --output="$EFIAPP" \
    --modules="multiboot normal echo part_gpt fat" \
    "boot/grub/grub.cfg=$BUILD/grub.cfg" "boot/kernel.elf=$KERNEL"
[ -f "$EFIAPP" ] || { echo "FAIL: grub-mkstandalone did not produce $EFIAPP"; exit 1; }

# ---- 4. Free host port ------------------------------------------------------
SSH_PORT="${SSH_PORT:-42322}"
if ss -ltn 2>/dev/null | grep -q ":$SSH_PORT "; then
    for p in 43322 44322 45322 46322; do
        ss -ltn 2>/dev/null | grep -q ":$p " || { SSH_PORT=$p; break; }
    done
fi
echo "[uefi-simple] host ssh port = $SSH_PORT -> guest 22"

# ---- 5. Boot under OVMF pflash (NOT -kernel). ESP via vvfat, payload on NVMe.
rm -f "$SERIAL"
qemu-system-x86_64 -no-user-config -monitor none -nographic -no-reboot \
    -machine q35 -cpu qemu64 -m "$QEMU_MEM" \
    -drive "if=pflash,format=raw,readonly=on,file=$OVMF_CODE" \
    -drive "if=pflash,format=raw,file=$OVMF_VARS" \
    -drive "file=fat:rw:$ESP,format=raw,id=esp,if=none" \
    -device virtio-blk-pci,drive=esp,bootindex=0 \
    -serial "file:$SERIAL" \
    -device isa-debug-exit,iobase=0xf4,iosize=0x04 \
    -drive "file=$IMG,if=none,id=nvm,format=raw" -device nvme,serial=deadbeef,drive=nvm \
    -netdev "user,id=n0,hostfwd=tcp::$SSH_PORT-:22" -device virtio-net-pci,netdev=n0 &
QEMU_PID=$!
trap 'kill "$QEMU_PID" 2>/dev/null || true' EXIT

# ---- 6. Wait for the ring-3 accept loop under OVMF -------------------------
i=0
while [ $i -lt "$BOOT_WAIT" ]; do
    grep -qa "accept loop start" "$SERIAL" 2>/dev/null && break
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 1; i=$((i+1))
done
rung() { grep -qa "$1" "$SERIAL" 2>/dev/null && echo "  [ok]   $2" || echo "  [MISS] $2"; }
echo "===== UEFI boot ladder ====="
rung "\[grub-uefi\] multiboot loading" "L1 OVMF -> GRUB-EFI app ran"
rung "call _start\|SimpleOS Boot"       "L2 multiboot handoff -> kernel _start"
rung "accept loop start"                "L3 sshd ring-3 accept loop"
if ! grep -qa "accept loop start" "$SERIAL" 2>/dev/null; then
    echo "===== RESULT: accept loop NOT reached under OVMF ====="
    sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" 2>/dev/null | grep -a . | tail -30
    exit 1
fi

# ---- 7. In-guest simple interpreter over SSH --------------------------------
# argv[0] is discarded by sshd's deferred exec; pass an extra "simple" token
# so the guest argv is ["simple", "/hello.spl"].
SIMPLE_CMD="/usr/bin/simple /hello.spl"
echo "[uefi-simple] ssh -p $SSH_PORT root@127.0.0.1 $SIMPLE_CMD"
SSH_OUT="$(sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 $SIMPLE_CMD 2>&1 || true)"
SSH_RC=$?
echo "[uefi-simple] ssh channel output: <<$SSH_OUT>>"
j=0
while [ $j -lt 180 ]; do
    grep -qaE "hello from simple on simpleos|ring3 deferred .*returned rc|command not found" "$SERIAL" 2>/dev/null && break
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 2; j=$((j+2))
done
kill "$QEMU_PID" 2>/dev/null || true; sleep 1

echo "===== exec ladder (serial) ====="
rung "ring3 deferred"                       "L4a sshd deferred exec dispatched"
rung "hello from simple on simpleos"        "L4b in-guest simple interpreter printed hello"
echo "===== serial tail ====="
sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" | grep -a . | tail -40
if grep -qa "hello from simple on simpleos" "$SERIAL" 2>/dev/null || \
   printf '%s' "$SSH_OUT" | grep -q "hello from simple on simpleos"; then
    echo "PASS: in-guest simple interpreter ran /hello.spl under OVMF (board proxy)"
else
    echo "FAIL: hello output not observed (see serial tail above)"
    exit 1
fi
