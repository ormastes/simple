extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn sys_get_args() -> [text]

fn byte_at(data: [u8], idx: i64) -> i64:
    if idx < 0 or idx >= data.len():
        return 0
    return data[idx] as i64

fn le16(data: [u8], off: i64) -> i64:
    return byte_at(data, off) | (byte_at(data, off + 1) << 8)

fn le32(data: [u8], off: i64) -> i64:
    return byte_at(data, off) |
        (byte_at(data, off + 1) << 8) |
        (byte_at(data, off + 2) << 16) |
        (byte_at(data, off + 3) << 24)

fn ascii_char(code: i64) -> text:
    val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    val idx = code - 32
    if idx >= 0 and idx < chars.len():
        return chars[idx:idx + 1]
    return "?"

fn short_name(data: [u8], off: i64) -> text:
    var name = ""
    var i = 0
    while i < 8:
        val c = byte_at(data, off + i)
        if c != 32:
            name = name + ascii_char(c)
        i = i + 1

    var ext = ""
    i = 8
    while i < 11:
        val c = byte_at(data, off + i)
        if c != 32:
            ext = ext + ascii_char(c)
        i = i + 1

    if ext.len() > 0:
        return name + "." + ext
    return name

fn print_dir(data: [u8], data_start: i64, cluster_size: i64, cluster: i64, prefix: text, depth: i64):
    val dir_off = data_start + ((cluster - 2) * cluster_size)
    var pos = 0
    while pos < cluster_size:
        val entry = dir_off + pos
        val first = byte_at(data, entry)
        if first == 0:
            return

        val attr = byte_at(data, entry + 11)
        if first != 229 and attr != 15:
            val name = short_name(data, entry)
            val high = le16(data, entry + 20)
            val low = le16(data, entry + 26)
            val child_cluster = (high << 16) | low
            val size = le32(data, entry + 28)
            val is_dir = (attr & 16) != 0
            val kind = if is_dir: "dir" else: "file"
            print "{prefix}/{name} {kind} cluster={child_cluster} size={size}"
            if is_dir and depth < 1 and name != "." and name != "..":
                print_dir(data, data_start, cluster_size, child_cluster, prefix + "/" + name, depth + 1)
        pos = pos + 32

fn inspect_image(path: text) -> i32:
    val data = rt_file_read_bytes(path) ?? []
    if data.len() < 512:
        print "image_read_failed path={path}"
        return 1

    val bytes_per_sector = le16(data, 11)
    val sectors_per_cluster = byte_at(data, 13)
    val reserved_sectors = le16(data, 14)
    val fat_count = byte_at(data, 16)
    val sectors_per_fat = le32(data, 36)
    val root_cluster = le32(data, 44)
    val cluster_size = bytes_per_sector * sectors_per_cluster
    val data_start = (reserved_sectors + (fat_count * sectors_per_fat)) * bytes_per_sector

    print "image={path}"
    print "bytes_per_sector={bytes_per_sector} sectors_per_cluster={sectors_per_cluster} root_cluster={root_cluster}"
    print_dir(data, data_start, cluster_size, root_cluster, "", 0)
    return 0

fn main() -> i32:
    val args = sys_get_args()
    var image = "build/os/fat32-riscv64.img"
    for arg in args:
        if arg != "--":
            image = arg
    return inspect_image(image)
