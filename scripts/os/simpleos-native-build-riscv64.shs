#!/bin/sh
# Cross-build the Simple toolchain binary for riscv64-unknown-simpleos with the
# pure-Simple self-hosted compiler by default.
#
# Prereqs (run once):
#   sh scripts/os/simpleos-core-archive.shs --target riscv64-unknown-simpleos --backend cranelift
#   sh scripts/os/simpleos-sysroot-riscv64.shs
#
# The riscv64 sysroot is separate (build/os/sysroot-riscv64) so the x86_64
# sysroot is never clobbered. crt0 is injected via INPUT() in the linker
# script; libc + the pure-Simple core runtime ride the compiler-builtins link
# slot through the CC wrapper (cc-riscv64-simpleos -print-libgcc-file-name),
# because the seed's simpleos_user_runtime_paths() is x86_64-gated.
set -eu

REPO_ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$REPO_ROOT"

TARGET="riscv64-unknown-simpleos"
ENTRY="src/app/simpleos_tool/main.spl"
OUTPUT="bin/release/$TARGET/simple"
SYSROOT="$REPO_ROOT/build/os/sysroot-riscv64"
COMPILER="${SIMPLE_BUILD_COMPILER:-bin/release/simple}"
BACKEND="${SIMPLE_NATIVE_BACKEND:-cranelift}"

[ -x "$COMPILER" ] || { echo "error: compiler not found: $COMPILER" >&2; exit 1; }
[ -f "$SYSROOT/share/simpleos/simpleos.ld" ] || { echo "error: run simpleos-sysroot-riscv64.shs first" >&2; exit 1; }
[ -f "build/os/simple-core-simpleos-riscv64/libsimple_runtime.a" ] || { echo "error: run simpleos-core-archive.shs first" >&2; exit 1; }

mkdir -p "$(dirname "$OUTPUT")"

CC="$SYSROOT/lib/cc-riscv64-simpleos" \
SIMPLEOS_SYSROOT="$SYSROOT" \
SIMPLE_SIMPLE_CORE_PATH="build/os/simple-core-simpleos-riscv64" \
SIMPLE_BOOTSTRAP=1 SIMPLE_NO_STUB_FALLBACK=1 \
"$COMPILER" native-build \
  --source src/compiler --source src/lib --source src/app \
  --backend "$BACKEND" \
  --runtime-bundle simple-core \
  --entry-closure \
  --entry "$ENTRY" \
  --target "$TARGET" \
  --linker-script "$SYSROOT/share/simpleos/simpleos.ld" \
  -o "$OUTPUT"

[ -f "$OUTPUT" ] || { echo "FAILED: no output $OUTPUT" >&2; exit 1; }
FILE_INFO="$(file "$OUTPUT")"
case "$FILE_INFO" in
  *"ELF 64-bit"*RISC-V*"statically linked"*) ;;
  *) echo "FAILED: expected a static RISC-V ELF: $FILE_INFO" >&2; exit 1 ;;
esac
command -v readelf >/dev/null 2>&1 || { echo "FAILED: readelf is required" >&2; exit 1; }
readelf -h "$OUTPUT" | grep -Eq 'Class:[[:space:]]+ELF64' || {
  echo "FAILED: ELF header is not 64-bit" >&2
  exit 1
}
readelf -h "$OUTPUT" | grep -Eq 'Machine:[[:space:]]+RISC-V' || {
  echo "FAILED: ELF header is not RISC-V" >&2
  exit 1
}
printf '%s\n' "$FILE_INFO"

cat > "$OUTPUT.build_stamp" <<EOF
target=$TARGET
entry=$ENTRY
entry_closure=true
backend=$BACKEND
runtime_bundle=simple-core
runtime_archive=build/os/simple-core-simpleos-riscv64/libsimple_runtime.a (14 parts, cranelift --emit-archive --no-mangle)
linker_script=$SYSROOT/share/simpleos/simpleos.ld (base 0x90000000)
compiler=$COMPILER
built=$(date -u +%Y-%m-%dT%H:%M:%SZ)
size=$(wc -c < "$OUTPUT")
EOF
echo "SUCCESS: $OUTPUT"
