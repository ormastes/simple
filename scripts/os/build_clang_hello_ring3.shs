#!/bin/sh
# Build a REAL clang "hello world" C program, place it on a FAT32 filesystem, and
# run it from the filesystem in ring-3 via the SimpleOS general FS-exec loader —
# then verify it printed and exited cleanly.
#
# Proves end-to-end: clang builds hello -> loaded from FS -> mapped at its native
# 0x10000000 (PML4[0]) -> ring-3 (cs=0x2b) -> prints via syscall -> exit(42).
# Expected serial: "hello from clang on simpleos" then "[user] exit rc=42".
#
# Prereqs (built once):
#   - Host clang-20 on PATH (the cross clang-20 codegen is broken; host clang with
#     --target=x86_64-unknown-simpleos is used for codegen; cross ld.lld links).
#   - build/os/sysroot (crt0/libc/linker script) and the cross ld.lld.
#   - A base FAT32 image build/os/elfexec/fat32-fsexec.img (from the elfexec bake).
#
# Usage: sh scripts/os/build_clang_hello_ring3.shs
set -e
ROOT=$(cd "$(dirname "$0")/../.." && pwd)
cd "$ROOT"

SR=build/os/sysroot
LLD=build/os/llvm/cross-x86_64-unknown-simpleos/bin/ld.lld
SRC=examples/09_embedded/simpleos_hello_c/hello_fs.c
OUT=build/os/hello
BASE_IMG=build/os/elfexec/fat32-fsexec.img
HELLO_IMG=$OUT/fat32-hello.img
mkdir -p "$OUT"

[ -x "$(command -v clang-20)" ] || { echo "[clang-hello] need host clang-20 on PATH"; exit 1; }
[ -f "$SR/share/simpleos/simpleos.ld" ] || { echo "[clang-hello] missing sysroot $SR"; exit 1; }
[ -f "$BASE_IMG" ] || { echo "[clang-hello] missing base image $BASE_IMG (bake elfexec first)"; exit 1; }

echo "[clang-hello] 1/4 compile+link $SRC with clang (freestanding, entry 0x10000000)"
clang-20 --target=x86_64-unknown-simpleos --sysroot="$SR" -ffreestanding \
    -fno-stack-protector -nostdlib -static -O0 -c "$SRC" -o "$OUT/hello_fs.o"
"$LLD" -T "$SR/share/simpleos/simpleos.ld" -e _start "$OUT/hello_fs.o" -o "$OUT/hello_fs.elf"

echo "[clang-hello] 2/4 stage the ELF onto a FAT32 image as /FSEXEC.ELF"
cp "$BASE_IMG" "$HELLO_IMG.base" 2>/dev/null || true
rm -f "$HELLO_IMG"
bin/simple run examples/09_embedded/simpleos_hello_c/patch_fsexec_image.spl
[ -f "$HELLO_IMG" ] || { echo "[clang-hello] image patch failed"; exit 1; }

echo "[clang-hello] 3/4 boot the ring-3 FS-exec kernel with the clang-hello image"
FSEXEC_DISK="$ROOT/$HELLO_IMG" sh scripts/os/build_fsexec_prod_ring3.shs >/dev/null 2>&1 || true

echo "[clang-hello] 4/4 marker check"
SERIAL=build/os/elfexec/prod_ring3_run.log
if grep -q 'hello from clang on simpleos' "$SERIAL" 2>/dev/null; then
    echo "PASS clang-hello ran from filesystem in ring-3 (printed)"
else
    echo "MISS clang-hello print"; exit 1
fi
if grep -q '\[user\] exit rc=42' "$SERIAL" 2>/dev/null; then
    echo "PASS clang-hello exited cleanly rc=42"
else
    echo "MISS clang-hello clean exit"; exit 1
fi
echo "[clang-hello] OK — a clang-built C program ran from the filesystem in ring-3 and exited 42"
