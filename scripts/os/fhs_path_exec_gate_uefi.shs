#!/bin/sh
# fhs_path_exec_gate_uefi.shs — Lane A gate (clang_as_general_fs_exec Phase 2):
# proves the FHS image layout + sshd PATH resolution + search-cache + exit-127
# fallback all work TOGETHER in ONE OVMF boot. Copy of
# scp_retrieve_over_ssh_uefi.shs (same UEFI/multiboot/NVMe boot ladder), with
# step 7 extended into four sub-checks instead of one:
#   a. bare "clang" resolved via PATH from /usr/bin/clang (not hardcoded
#      /FSEXEC.ELF any more) -> compile OK, getfile byte-exact, host exit 7.
#   b. absolute "/usr/bin/clang" form -> compile OK, getfile byte-exact,
#      host exit 7.
#   c. a SECOND bare "clang" exec logs "[fs-exec] path-cache hit clang".
#   d. "nosuchcmd" -> ssh exit code 127, serial logs
#      "[fs-exec] command not found: nosuchcmd" — no hang.
#
# GATES (serial):
#   L1 "[grub-uefi] multiboot loading"     OVMF -> GRUB-EFI app ran
#   L2 "call _start" / "SimpleOS Boot"      multiboot handoff -> kernel _start
#   L3 "accept loop start"                  sshd reached ring-3 accept loop
#   L4a "oo-nvme] persist /hello.o -> OK"   bare "clang" PATH-resolved compile
#   L4b "oo-nvme] persist /hello2.o -> OK"  absolute "/usr/bin/clang" compile
#   L4c "[fs-exec] path-cache hit clang"    second bare-name exec cache hit
#   L4d ssh exit 127 + "command not found: nosuchcmd"
#   L5 host: retrieved.o / retrieved2.o both link and ./a return 7
#
# Env: SEED, CLANG_BIN, SKIP_STAGE (default 0 -- rebuild image so the new FHS
# layout is picked up), SKIP_KERNEL=1, QEMU_MEM (2G), BOOT_WAIT.
set -eu
ROOT=$(cd "$(dirname "$0")/../.." && pwd)
cd "$ROOT"

SEED="${SEED:-src/compiler_rust/target/release/simple}"
CLANG_BIN="${CLANG_BIN:-build/os/clang_static/bin/clang_static}"
ENTRY="examples/09_embedded/simple_os/arch/x86_64/ssh_ring3_clang_entry.spl"
LINKER="examples/09_embedded/simple_os/arch/x86_64/linker_128mb.ld"
KERNEL="build/os/simpleos_fhs_gate_uefi128.elf"
IMG="build/os/elfexec/fat32-clang.img"
SERIAL="build/os/fhs_path_exec_gate_uefi.serial.log"
CACHE="build/os/fhs_gate_cache_uefi128"
BUILD="build/os/uefi_fhs_gate"
ESP="$BUILD/esp"
EFIAPP="$ESP/EFI/BOOT/BOOTX64.EFI"
OVMF_CODE="${OVMF_CODE:-/usr/share/OVMF/OVMF_CODE_4M.fd}"
OVMF_VARS_SRC="${OVMF_VARS_SRC:-/usr/share/OVMF/OVMF_VARS_4M.fd}"
OVMF_VARS="$BUILD/OVMF_VARS_4M.fd"
QEMU_MEM="${QEMU_MEM:-2G}"
BOOT_WAIT="${BOOT_WAIT:-60}"
SCRATCH="${SCRATCH:-/tmp/claude-1000/-home-ormastes-dev-pub-simple/f6547767-3f36-4410-969d-edaead425415/scratchpad}"

command -v grub-mkstandalone >/dev/null 2>&1 || { echo "FAIL: grub-mkstandalone missing"; exit 1; }
command -v qemu-system-x86_64 >/dev/null 2>&1 || { echo "FAIL: qemu-system-x86_64 missing"; exit 1; }
command -v sshpass >/dev/null 2>&1 || { echo "FAIL: sshpass missing"; exit 1; }
[ -f "$OVMF_CODE" ] || { echo "FAIL: OVMF_CODE not found at $OVMF_CODE"; exit 1; }
[ -f "$OVMF_VARS_SRC" ] || { echo "FAIL: OVMF_VARS not found at $OVMF_VARS_SRC"; exit 1; }
mkdir -p build/os/generated/generated build/os/elfexec/stageD "$SCRATCH"

# ---- 1. Payload image with clang_static (linked at 0x40000000) + hello.c.
# SKIP_STAGE defaults to 0 here (unlike the base harness): the FHS
# subdirectory layout is new, so the image must be rebuilt unless the caller
# explicitly opts back into reuse.
if [ "${SKIP_STAGE:-0}" != "1" ] || [ ! -f "$IMG" ]; then
    [ -f "$CLANG_BIN" ] || { echo "[fhs-gate] missing $CLANG_BIN (relink clang_static at 0x40000000 first)"; exit 1; }
    printf 'int main(void){ return 7; }\n' > build/os/elfexec/stageD/hello.c
    SIZE="$(stat -c%s "$CLANG_BIN")"; echo "$SIZE" > build/os/elfexec/payload_size.txt
    MKOUT="$(SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SEED" run scripts/os/fsexec_mkimg_big.spl 2>&1)"
    echo "[fhs-gate] fsexec_mkimg_big: $MKOUT"
    TOTAL="$(echo "$MKOUT" | sed -n 's/.*total_bytes=\([0-9][0-9]*\).*/\1/p' | tail -1)"
    [ -n "$TOTAL" ] || { echo "[fhs-gate] could not parse total_bytes"; exit 1; }
    cat build/os/elfexec/fat32-clang-prefix.bin "$CLANG_BIN" > "$IMG"
    truncate -s "$TOTAL" "$IMG"
fi
[ -f "$IMG" ] || { echo "[fhs-gate] missing image $IMG"; exit 1; }

# ---- 2. Build the 128 MiB-base merged SSH + clang-stream kernel -------------
printf 'pub fn ssh_live_build_marker() -> text:\n    "ssh-ring3-build:fhs-gate-128"\n' \
    > build/os/generated/ssh_live_build_marker.spl
cat > build/os/generated/generated/simpleos_log_config.spl <<'SPL'
val SIMPLEOS_LOG_COMPILED: bool = false

fn simpleos_log_compile_enabled() -> bool:
    SIMPLEOS_LOG_COMPILED

fn simpleos_log_compile_mode_name() -> text:
    if SIMPLEOS_LOG_COMPILED:
        return "on"
    "off"
SPL

if [ "${SKIP_KERNEL:-0}" != "1" ] || [ ! -f "$KERNEL" ]; then
    OBJCOPY_PREFIX=""
    for d in /usr/lib/llvm-20/bin /usr/lib/llvm-19/bin /usr/lib/llvm-18/bin; do
        [ -f "$d/llvm-objcopy" ] && OBJCOPY_PREFIX="$d" && break
    done
    # Clean cache every kernel build (matches the base harness): reusing a
    # cache across struct-layout changes (e.g. SshSession field removal) can
    # mix stale field offsets from cached units into the link.
    rm -rf "$CACHE"; mkdir -p "$CACHE"; rm -f "$KERNEL"
    echo "[fhs-gate] building 128MB-base kernel -> $KERNEL"
    SIMPLE_BOOTSTRAP=1 SIMPLE_LIB="$ROOT/src" SIMPLE_OS_LOG_MODE=off SIMPLE_ALLOW_FREESTANDING_STUBS=1 \
    PATH="${OBJCOPY_PREFIX:+$OBJCOPY_PREFIX:}$PATH" \
        "$SEED" native-build --source build/os/generated --source src/os --source src/lib \
        --source examples/09_embedded/simple_os --backend cranelift --cpu x86-64-v1 \
        --opt-level=aggressive --log off --entry-closure --cache-dir "$CACHE" \
        --entry "$ENTRY" --target x86_64-unknown-none -o "$KERNEL" \
        --linker-script "$LINKER" 2>&1 | tail -60
    [ -f "$KERNEL" ] || { echo "[fhs-gate] KERNEL BUILD FAILED"; exit 1; }
fi
echo "[fhs-gate] kernel=$KERNEL ($(stat -c%s "$KERNEL") bytes)"

# ---- 3. Assemble the ESP: self-contained BOOTX64.EFI (kernel in memdisk) ----
rm -rf "$BUILD"; mkdir -p "$ESP/EFI/BOOT"
cp "$OVMF_VARS_SRC" "$OVMF_VARS"
cat > "$BUILD/grub.cfg" <<'CFG'
set timeout=0
set default=0
insmod multiboot
insmod normal
menuentry "SimpleOS FHS PATH-exec gate (UEFI/multiboot, 128MB)" {
    echo "[grub-uefi] multiboot loading /boot/kernel.elf ..."
    multiboot /boot/kernel.elf
    boot
}
CFG
echo "[fhs-gate] building self-contained BOOTX64.EFI (embeds kernel via memdisk) ..."
grub-mkstandalone --format=x86_64-efi --output="$EFIAPP" \
    --modules="multiboot normal echo part_gpt fat" \
    "boot/grub/grub.cfg=$BUILD/grub.cfg" "boot/kernel.elf=$KERNEL"
[ -f "$EFIAPP" ] || { echo "FAIL: grub-mkstandalone did not produce $EFIAPP"; exit 1; }

# ---- 4. Pick a free host port ----------------------------------------------
SSH_PORT="${SSH_PORT:-42322}"
if ss -ltn 2>/dev/null | grep -q ":$SSH_PORT "; then
    for p in 43322 44322 45322 46322; do
        ss -ltn 2>/dev/null | grep -q ":$p " || { SSH_PORT=$p; break; }
    done
fi
echo "[fhs-gate] host ssh port = $SSH_PORT -> guest 22"

# ---- 5. Boot under OVMF pflash (NOT -kernel). ESP via vvfat, payload on NVMe.
rm -f "$SERIAL"
qemu-system-x86_64 -no-user-config -monitor none -nographic -no-reboot \
    -machine q35 -cpu qemu64 -m "$QEMU_MEM" \
    -drive "if=pflash,format=raw,readonly=on,file=$OVMF_CODE" \
    -drive "if=pflash,format=raw,file=$OVMF_VARS" \
    -drive "file=fat:rw:$ESP,format=raw,id=esp,if=none" \
    -device virtio-blk-pci,drive=esp,bootindex=0 \
    -serial "file:$SERIAL" \
    -device isa-debug-exit,iobase=0xf4,iosize=0x04 \
    -drive "file=$IMG,if=none,id=nvm,format=raw" -device nvme,serial=deadbeef,drive=nvm \
    -netdev "user,id=n0,hostfwd=tcp::$SSH_PORT-:22" -device virtio-net-pci,netdev=n0 &
QEMU_PID=$!
trap 'kill "$QEMU_PID" 2>/dev/null || true' EXIT

# ---- 6. Wait for the ring-3 accept loop under OVMF -------------------------
i=0
while [ $i -lt "$BOOT_WAIT" ]; do
    grep -qa "accept loop start" "$SERIAL" 2>/dev/null && break
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 1; i=$((i+1))
done
rung() { grep -qa "$1" "$SERIAL" 2>/dev/null && echo "  [ok]   $2" || echo "  [MISS] $2"; }
echo "===== UEFI boot ladder ====="
rung "\[grub-uefi\] multiboot loading" "L1 OVMF -> GRUB-EFI app ran"
rung "call _start\|SimpleOS Boot"       "L2 multiboot handoff -> kernel _start"
rung "accept loop start"                "L3 sshd ring-3 accept loop"
if ! grep -qa "accept loop start" "$SERIAL" 2>/dev/null; then
    echo "===== RESULT: accept loop NOT reached under OVMF ====="
    sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" 2>/dev/null | grep -a . | tail -30
    kill "$QEMU_PID" 2>/dev/null || true
    exit 1
fi

wait_for() {
    # wait_for <pattern> <max_seconds>
    j=0
    while [ $j -lt "$2" ]; do
        grep -qaE "$1" "$SERIAL" 2>/dev/null && return 0
        kill -0 "$QEMU_PID" 2>/dev/null || return 1
        sleep 2; j=$((j+2))
    done
    return 1
}

# ---- 7a. bare "clang" resolved via PATH from /usr/bin/clang ----------------
CLANG_CMD_A="clang -cc1 -triple x86_64-unknown-simpleos -emit-obj -o /hello.o -x c /hello.c"
echo "[fhs-gate] 7a ssh -p $SSH_PORT root@127.0.0.1 $CLANG_CMD_A"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 $CLANG_CMD_A || true
wait_for "oo-nvme\] persist /hello\.o -> OK|heap:stream-open-fail|ring3 program exited" 120
if ! grep -qa "oo-nvme\] persist /hello\.o -> OK" "$SERIAL" 2>/dev/null; then
    echo "FAIL: 7a bare-name PATH exec did not persist /hello.o"
    kill "$QEMU_PID" 2>/dev/null || true; sleep 1
    sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" | tail -60
    exit 1
fi
echo "  [ok]   L4a bare \"clang\" PATH-resolved compile (/hello.o persisted)"

rm -f "$SCRATCH/retrieved_a.o"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 getfile /hello.o > "$SCRATCH/retrieved_a.o" 2>/dev/null || true
[ -s "$SCRATCH/retrieved_a.o" ] || { echo "FAIL: retrieved_a.o missing/empty"; exit 1; }
cc "$SCRATCH/retrieved_a.o" -o "$SCRATCH/a_a.out"
RC=0; "$SCRATCH/a_a.out" || RC=$?
echo "[fhs-gate] 7a retrieved.o host exit code = $RC (want 7)"
[ "$RC" = "7" ] || { echo "FAIL: 7a host exit code $RC"; exit 1; }

# ---- 7b. absolute "/usr/bin/clang" form ------------------------------------
CLANG_CMD_B="/usr/bin/clang -cc1 -triple x86_64-unknown-simpleos -emit-obj -o /hello2.o -x c /hello.c"
echo "[fhs-gate] 7b ssh -p $SSH_PORT root@127.0.0.1 $CLANG_CMD_B"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 $CLANG_CMD_B || true
wait_for "oo-nvme\] persist /hello2\.o -> OK|heap:stream-open-fail|ring3 program exited" 120
if ! grep -qa "oo-nvme\] persist /hello2\.o -> OK" "$SERIAL" 2>/dev/null; then
    echo "FAIL: 7b absolute-path exec did not persist /hello2.o"
    kill "$QEMU_PID" 2>/dev/null || true; sleep 1
    sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" | tail -60
    exit 1
fi
echo "  [ok]   L4b absolute \"/usr/bin/clang\" compile (/hello2.o persisted)"

rm -f "$SCRATCH/retrieved_b.o"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 getfile /hello2.o > "$SCRATCH/retrieved_b.o" 2>/dev/null || true
[ -s "$SCRATCH/retrieved_b.o" ] || { echo "FAIL: retrieved_b.o missing/empty"; exit 1; }
cc "$SCRATCH/retrieved_b.o" -o "$SCRATCH/a_b.out"
RC=0; "$SCRATCH/a_b.out" || RC=$?
echo "[fhs-gate] 7b retrieved2.o host exit code = $RC (want 7)"
[ "$RC" = "7" ] || { echo "FAIL: 7b host exit code $RC"; exit 1; }

# ---- 7c. second bare-name exec -> path-cache hit ---------------------------
CLANG_CMD_C="clang -cc1 -triple x86_64-unknown-simpleos -emit-obj -o /hello3.o -x c /hello.c"
echo "[fhs-gate] 7c ssh -p $SSH_PORT root@127.0.0.1 $CLANG_CMD_C"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 $CLANG_CMD_C || true
wait_for "oo-nvme\] persist /hello3\.o -> OK|heap:stream-open-fail|ring3 program exited" 120
if ! grep -qa "\[fs-exec\] path-cache hit clang" "$SERIAL" 2>/dev/null; then
    echo "FAIL: 7c second bare-name exec did not log path-cache hit"
    sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" | tail -60
    exit 1
fi
echo "  [ok]   L4c second bare-name exec logs \"[fs-exec] path-cache hit clang\""

# ---- 7d. unresolvable command -> exit 127, no hang -------------------------
echo "[fhs-gate] 7d ssh -p $SSH_PORT root@127.0.0.1 nosuchcmd"
NF_RC=0
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 nosuchcmd || NF_RC=$?
echo "[fhs-gate] 7d ssh exit code = $NF_RC (want 127)"
sleep 2
if ! grep -qa "\[fs-exec\] command not found: nosuchcmd" "$SERIAL" 2>/dev/null; then
    echo "FAIL: 7d serial log missing 'command not found: nosuchcmd'"
    sed 's/\x1b\[[0-9;]*[A-Za-z]//g' "$SERIAL" | tail -60
    exit 1
fi
if [ "$NF_RC" != "127" ]; then
    echo "FAIL: 7d ssh exit code $NF_RC (want 127)"
    exit 1
fi
echo "  [ok]   L4d \"nosuchcmd\" -> ssh exit 127, serial \"command not found: nosuchcmd\""

kill "$QEMU_PID" 2>/dev/null || true; sleep 1

echo "PASS: FHS layout + PATH resolution + search-cache + exit-127 gate VERIFIED (a+b+c+d) under OVMF"
