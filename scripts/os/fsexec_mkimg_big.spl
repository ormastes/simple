# fsexec_mkimg_big.spl — FAT32 *structural prefix* writer for a LARGE payload
# (clang_static ~119 MB). Writes only BPB + FSInfo + reserved + FAT1 + root-dir
# cluster (one /FSEXEC.ELF entry, first cluster = 3). The caller
# (scripts/os/build_clang_disk.shs) then appends the raw ELF payload right after
# the prefix (so it lands at cluster 3, contiguous) and truncates to the full
# image size.
#
# Geometry: bytes_per_sector=512, sectors_per_cluster=64 (32 KiB clusters, so the
# ~119 MB payload is only ~3.8 K clusters => a small FAT), reserved=32,
# num_fats=1 (the boot-side C reader _fat32_next_cluster reads FAT1 only). root
# dir = cluster 2, payload = clusters 3..N (contiguous chain).
#
# The whole prefix is built in a PRE-ALLOCATED zero buffer with O(1) index
# assignment (NOT [u8].push, which is O(n) per element in the seed interpreter
# and made a byte-by-byte builder take minutes for a 100 MB-class image).
#
# Input : build/os/elfexec/payload_size.txt  (decimal byte count of the ELF)
# Output: build/os/elfexec/fat32-clang-prefix.bin  (structural prefix)
#         build/os/elfexec/fat32-clang-total.txt   (total image size in bytes)

extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

fn _parse_u64(data: [u8]) -> u64:
    var v: u64 = 0u64
    var i: i64 = 0
    while i < data.length:
        val c = data[i] as u64
        if c >= 0x30u64 and c <= 0x39u64:
            v = (v * 10u64) + (c - 0x30u64)
        i = i + 1
    v

fn main() -> i64:
    val size_path = "build/os/elfexec/payload_size.txt"
    val prefix_path = "build/os/elfexec/fat32-clang-prefix.bin"
    val total_path = "build/os/elfexec/fat32-clang-total.txt"

    val size_bytes: [u8] = rt_file_read_bytes(size_path) ?? []
    if size_bytes.length == 0:
        print "fsexec_mkimg_big_error=missing payload_size.txt"
        return 1
    val payload: u64 = _parse_u64(size_bytes)
    if payload == 0u64:
        print "fsexec_mkimg_big_error=zero payload size"
        return 1

    # Stage D: HELLO.C is a real FAT file at cluster 3 (single cluster, embedded
    # in the prefix); FSEXEC.ELF (clang_static) shifts to cluster 4 and is
    # appended by the caller.
    val hello_path = "build/os/elfexec/stageD/hello.c"
    val hello_bytes: [u8] = rt_file_read_bytes(hello_path) ?? []
    val hello_len: u64 = hello_bytes.length as u64

    val SPC: u64 = 64u64
    val CLUSTER_BYTES: u64 = SPC * 512u64          # 32768
    val RESERVED: u64 = 32u64
    val NUM_FATS: u64 = 1u64

    if hello_len == 0u64 or hello_len > CLUSTER_BYTES:
        print "fsexec_mkimg_big_error=hello.c missing or too big"
        return 1

    var payload_clusters: u64 = payload / CLUSTER_BYTES
    if payload % CLUSTER_BYTES != 0u64:
        payload_clusters = payload_clusters + 1u64
    # root=2, hello=3, payload=4..highest
    val highest_cluster: u64 = 3u64 + payload_clusters
    val fat_entries: u64 = highest_cluster + 1u64
    var fat_sectors: u64 = (fat_entries * 4u64) / 512u64
    if (fat_entries * 4u64) % 512u64 != 0u64:
        fat_sectors = fat_sectors + 1u64
    fat_sectors = fat_sectors + 8u64                      # slack

    val data_start_sector: u64 = RESERVED + (NUM_FATS * fat_sectors)
    # prefix covers root-dir cluster (2) + hello cluster (3)
    val prefix_sectors: u64 = data_start_sector + (2u64 * SPC)
    val prefix_bytes_u: u64 = prefix_sectors * 512u64
    val total_sectors: u64 = data_start_sector + ((payload_clusters + 2u64) * SPC)
    val total_bytes: u64 = total_sectors * 512u64
    val total_clusters: u64 = (total_sectors - data_start_sector) / SPC

    val prefix_len: i64 = prefix_bytes_u as i64
    var img: [u8] = [0u8; prefix_len]

    # ---- Sector 0: BPB ----
    img[0] = 0xEBu8
    img[1] = 0x58u8
    img[2] = 0x90u8
    img[3] = 0x53u8   # OEM "SIMPLEOS"
    img[4] = 0x49u8
    img[5] = 0x4Du8
    img[6] = 0x50u8
    img[7] = 0x4Cu8
    img[8] = 0x45u8
    img[9] = 0x4Fu8
    img[10] = 0x53u8
    img[11] = 0x00u8  # bytes_per_sector = 512
    img[12] = 0x02u8
    img[13] = SPC as u8                        # sectors_per_cluster
    img[14] = (RESERVED & 0xFFu64) as u8       # reserved_sectors
    img[15] = ((RESERVED >> 8) & 0xFFu64) as u8
    img[16] = NUM_FATS as u8                    # num_fats
    # 17..20 root_entry_count / total_sectors_16 = 0
    img[21] = 0xF8u8  # media
    # 22..23 fat_size_16 = 0
    img[24] = 0x3Fu8  # sectors_per_track = 63
    img[26] = 0xFFu8  # num_heads = 255
    # 28..31 hidden = 0
    img[32] = (total_sectors & 0xFFu64) as u8          # total_sectors_32 LE
    img[33] = ((total_sectors >> 8) & 0xFFu64) as u8
    img[34] = ((total_sectors >> 16) & 0xFFu64) as u8
    img[35] = ((total_sectors >> 24) & 0xFFu64) as u8
    img[36] = (fat_sectors & 0xFFu64) as u8            # fat_size_32 LE
    img[37] = ((fat_sectors >> 8) & 0xFFu64) as u8
    img[38] = ((fat_sectors >> 16) & 0xFFu64) as u8
    img[39] = ((fat_sectors >> 24) & 0xFFu64) as u8
    # 40..43 ext_flags / fs_version = 0
    img[44] = 0x02u8  # root_cluster = 2
    img[48] = 0x01u8  # fs_info sector = 1
    img[50] = 0x06u8  # backup_boot_sector = 6
    img[64] = 0x80u8  # drive_number
    img[66] = 0x29u8  # boot_sig
    img[67] = 0x78u8  # vol_id 0x12345678 LE
    img[68] = 0x56u8
    img[69] = 0x34u8
    img[70] = 0x12u8
    img[71] = 0x53u8  # vol_label "SIMPLEOS   "
    img[72] = 0x49u8
    img[73] = 0x4Du8
    img[74] = 0x50u8
    img[75] = 0x4Cu8
    img[76] = 0x45u8
    img[77] = 0x4Fu8
    img[78] = 0x53u8
    img[79] = 0x20u8
    img[80] = 0x20u8
    img[81] = 0x20u8
    img[82] = 0x46u8  # "FAT32   "
    img[83] = 0x41u8
    img[84] = 0x54u8
    img[85] = 0x33u8
    img[86] = 0x32u8
    img[87] = 0x20u8
    img[88] = 0x20u8
    img[89] = 0x20u8
    img[510] = 0x55u8
    img[511] = 0xAAu8

    # ---- Sector 1: FSInfo ----
    img[512] = 0x52u8  # lead_sig 0x41615252 LE
    img[513] = 0x52u8
    img[514] = 0x61u8
    img[515] = 0x41u8
    img[512 + 484] = 0x72u8  # struct_sig 0x61417272 LE
    img[512 + 485] = 0x72u8
    img[512 + 486] = 0x41u8
    img[512 + 487] = 0x61u8
    img[512 + 488] = 0xFFu8  # free_count = unknown
    img[512 + 489] = 0xFFu8
    img[512 + 490] = 0xFFu8
    img[512 + 491] = 0xFFu8
    img[512 + 492] = 0xFFu8  # next_free = unknown
    img[512 + 493] = 0xFFu8
    img[512 + 494] = 0xFFu8
    img[512 + 495] = 0xFFu8
    img[512 + 510] = 0x55u8
    img[512 + 511] = 0xAAu8

    # ---- FAT1 (starts at RESERVED*512) ----
    val fat_base: i64 = (RESERVED * 512u64) as i64
    img[fat_base + 0] = 0xF8u8   # entry 0 (media)
    img[fat_base + 1] = 0xFFu8
    img[fat_base + 2] = 0xFFu8
    img[fat_base + 3] = 0x0Fu8
    img[fat_base + 4] = 0xFFu8   # entry 1 (EOC)
    img[fat_base + 5] = 0xFFu8
    img[fat_base + 6] = 0xFFu8
    img[fat_base + 7] = 0x0Fu8
    img[fat_base + 8] = 0xFFu8   # entry 2 (root dir EOC)
    img[fat_base + 9] = 0xFFu8
    img[fat_base + 10] = 0xFFu8
    img[fat_base + 11] = 0x0Fu8
    img[fat_base + 12] = 0xFFu8  # entry 3 (HELLO.C single cluster, EOC)
    img[fat_base + 13] = 0xFFu8
    img[fat_base + 14] = 0xFFu8
    img[fat_base + 15] = 0x0Fu8
    var c: u64 = 4u64            # clang payload chain starts at cluster 4
    while c <= highest_cluster:
        var next: u64 = 0x0FFFFFFFu64
        if c < highest_cluster:
            next = c + 1u64
        val eo: i64 = fat_base + ((c * 4u64) as i64)
        img[eo + 0] = (next & 0xFFu64) as u8
        img[eo + 1] = ((next >> 8) & 0xFFu64) as u8
        img[eo + 2] = ((next >> 16) & 0xFFu64) as u8
        img[eo + 3] = ((next >> 24) & 0xFFu64) as u8
        c = c + 1u64

    # ---- Root directory (cluster 2 at data_start_sector*512) ----
    val rd: i64 = (data_start_sector * 512u64) as i64
    # Entry 0: "HELLO   C  " at cluster 3, size = hello_len
    img[rd + 0] = 0x48u8  # H
    img[rd + 1] = 0x45u8  # E
    img[rd + 2] = 0x4Cu8  # L
    img[rd + 3] = 0x4Cu8  # L
    img[rd + 4] = 0x4Fu8  # O
    img[rd + 5] = 0x20u8
    img[rd + 6] = 0x20u8
    img[rd + 7] = 0x20u8
    img[rd + 8] = 0x43u8  # C
    img[rd + 9] = 0x20u8
    img[rd + 10] = 0x20u8
    img[rd + 11] = 0x20u8  # attr = archive
    img[rd + 26] = 0x03u8  # FstClusLO = 3
    img[rd + 28] = (hello_len & 0xFFu64) as u8
    img[rd + 29] = ((hello_len >> 8) & 0xFFu64) as u8
    img[rd + 30] = ((hello_len >> 16) & 0xFFu64) as u8
    img[rd + 31] = ((hello_len >> 24) & 0xFFu64) as u8
    # Entry 1: "FSEXEC  ELF" at cluster 4, size = payload
    img[rd + 32] = 0x46u8  # F
    img[rd + 33] = 0x53u8  # S
    img[rd + 34] = 0x45u8  # E
    img[rd + 35] = 0x58u8  # X
    img[rd + 36] = 0x45u8  # E
    img[rd + 37] = 0x43u8  # C
    img[rd + 38] = 0x20u8
    img[rd + 39] = 0x20u8
    img[rd + 40] = 0x45u8  # E
    img[rd + 41] = 0x4Cu8  # L
    img[rd + 42] = 0x46u8  # F
    img[rd + 43] = 0x20u8  # attr = archive
    img[rd + 26 + 32] = 0x04u8  # FstClusLO = 4
    img[rd + 28 + 32] = (payload & 0xFFu64) as u8
    img[rd + 29 + 32] = ((payload >> 8) & 0xFFu64) as u8
    img[rd + 30 + 32] = ((payload >> 16) & 0xFFu64) as u8
    img[rd + 31 + 32] = ((payload >> 24) & 0xFFu64) as u8

    # ---- HELLO.C data (cluster 3 = data_start_sector + SPC) ----
    val hello_base: i64 = ((data_start_sector + SPC) * 512u64) as i64
    var hi: i64 = 0
    while hi < hello_bytes.length:
        img[hello_base + hi] = hello_bytes[hi]
        hi = hi + 1

    if not rt_file_write_bytes(prefix_path, img):
        print "fsexec_mkimg_big_error=write prefix failed"
        return 1

    # Emit total image size (decimal) for the caller's truncate.
    var tot: [u8] = []
    var digits: [u8] = []
    var n: u64 = total_bytes
    if n == 0u64:
        digits.push(0x30u8)
    while n > 0u64:
        digits.push(((n % 10u64) + 0x30u64) as u8)
        n = n / 10u64
    var di: i64 = digits.length - 1
    while di >= 0:
        tot.push(digits[di])
        di = di - 1
    tot.push(0x0Au8)
    if not rt_file_write_bytes(total_path, tot):
        print "fsexec_mkimg_big_error=write total failed"
        return 1

    print "fsexec_mkimg_big_status=ok payload=" + payload.to_text() + " payload_clusters=" + payload_clusters.to_text() + " spc=" + SPC.to_text() + " fat_sectors=" + fat_sectors.to_text() + " prefix_bytes=" + prefix_bytes_u.to_text() + " total_bytes=" + total_bytes.to_text() + " total_clusters=" + total_clusters.to_text()
    return 0
