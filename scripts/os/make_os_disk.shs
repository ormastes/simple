#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/tools}"
BIN="$BUILD_DIR/make_os_disk"
SRC="scripts/os/make_os_disk.c"

mkdir -p "$BUILD_DIR"

if [ ! -x "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
    cc="${CC:-cc}"
    "$cc" -O2 -std=c11 -Wall -Wextra -o "$BIN" "$SRC"
fi

if [ "$#" -eq 4 ]; then
    case "$1" in
        32|64)
            exec "$BIN" "$2" "$4" "$1" "$3"
            ;;
    esac
fi
if [ "$#" -eq 2 ]; then
    case "$1" in
        32|64)
            "$BIN" "$2" "x86_64" "$1" ""
            if [ "$2" = "build/os/fat32-x86_64.img" ]; then
                cp "$2" "build/os/fat32.img"
            fi
            exit 0
            ;;
    esac
fi

exec "$BIN" "$@"
