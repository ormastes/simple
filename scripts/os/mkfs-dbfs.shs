#!/bin/sh
# mkfs-dbfs.shs — thin wrapper: build a bootable DBFS root filesystem image.
#
# Usage: scripts/os/mkfs-dbfs.shs [output_path] [size_sectors]
#   default output: build/os/simpleos_dbfs_root.img
#   default size:   65536 sectors (32 MiB)
set -eu
ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"
mkdir -p build/os
exec bin/simple run src/os/port/mkfs_dbfs.spl -- "$@"
