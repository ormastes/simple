#!/bin/sh
# scp_retrieve_over_ssh.shs — Phase 2e Inc 3: retrieve /hello.o from the
# guest over real SSH (scp -f handshake, Phase 2e Inc 3).
#
# Same merged SSH + ring-3 kernel entry as Inc 1/2
# (ssh_ring3_clang_entry.spl) with ssh_session.spl's new scp-source support
# (_handle_exec_request_inline 's','c','p',' ' raw-byte branch +
# _scp_step_inline handshake state machine). Flow, all in ONE boot:
#
#   1. ssh root@host clang -cc1 ... -o /hello.o -x c /hello.c   (creates the file)
#   2. scp -O -P <port> root@127.0.0.1:/hello.o <scratch>/retrieved.o  (retrieves it)
#
# GATES (serial):
#   1. "[oo-nvme] persist /hello.o -> OK" + "ring3 program exited" (step 1)
#   2. "[sshd-session] exec scp-source" + "scp read path=/hello.o fsize=712"
#   3. "scp step stage=0" / "stage=1" / "stage=2" (handshake progressed)
#   4. "scp final-ack -> exit 0"
#
# VERIFY (host): retrieved.o byte-identical to the raw-disk /hello.o extract
# (small embedded python FAT32 walker — non-committed host one-off, per task
# constraints), llvm-readobj ET_REL/EM_X86_64, `cc retrieved.o -o a && ./a;
# echo $?` == 7.
#
# Env: SEED, CLANG_BIN, SKIP_STAGE=1, SKIP_KERNEL=1, QEMU_MEM (2G), BOOT_WAIT (30s).
set -eu
ROOT=$(cd "$(dirname "$0")/../.." && pwd)
cd "$ROOT"

SEED="${SEED:-src/compiler_rust/target/release/simple}"
CLANG_BIN="${CLANG_BIN:-build/os/clang_static/bin/clang_static}"
ENTRY="examples/09_embedded/simple_os/arch/x86_64/ssh_ring3_clang_entry.spl"
LINKER="examples/09_embedded/simple_os/arch/x86_64/linker_low1mb.ld"
KERNEL="build/os/simpleos_ssh_ring3_scp_inc3.elf"
IMG="build/os/elfexec/fat32-clang.img"
SERIAL="build/os/scp_retrieve_over_ssh.serial.log"
CACHE="build/os/ssh_clang_cache_private_inc3"
QEMU_MEM="${QEMU_MEM:-2G}"
BOOT_WAIT="${BOOT_WAIT:-30}"
SCRATCH="${SCRATCH:-/tmp/claude-1000/-home-ormastes-dev-pub-simple/f6547767-3f36-4410-969d-edaead425415/scratchpad}"

mkdir -p build/os/generated/generated build/os/elfexec/stageD "$SCRATCH"

# ---- 1. Image: reuse fat32-clang.img, or build it (mirrors Inc 1/2) -------
if [ "${SKIP_STAGE:-1}" != "1" ] || [ ! -f "$IMG" ]; then
    [ -f "$CLANG_BIN" ] || { echo "[scp-retrieve] missing $CLANG_BIN"; exit 1; }
    printf 'int main(void){ return 7; }\n' > build/os/elfexec/stageD/hello.c
    SIZE="$(stat -c%s "$CLANG_BIN")"
    echo "$SIZE" > build/os/elfexec/payload_size.txt
    MKOUT="$(SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SEED" run scripts/os/fsexec_mkimg_big.spl 2>&1)"
    echo "$MKOUT" | grep -E 'fsexec_mkimg_big' || true
    TOTAL="$(echo "$MKOUT" | sed -n 's/.*total_bytes=\([0-9][0-9]*\).*/\1/p' | tail -1)"
    [ -n "$TOTAL" ] || { echo "[scp-retrieve] could not parse total_bytes from mkimg"; exit 1; }
    cat build/os/elfexec/fat32-clang-prefix.bin "$CLANG_BIN" > "$IMG"
    truncate -s "$TOTAL" "$IMG"
fi
[ -f "$IMG" ] || { echo "[scp-retrieve] missing image $IMG"; exit 1; }

# ---- 2. Build markers + merged SSH+clang-stream kernel (has the scp fix) --
printf 'pub fn ssh_live_build_marker() -> text:\n    "ssh-ring3-build:scp-retrieve-inc3"\n' \
    > build/os/generated/ssh_live_build_marker.spl
cat > build/os/generated/generated/simpleos_log_config.spl <<'SPL'
val SIMPLEOS_LOG_COMPILED: bool = false

fn simpleos_log_compile_enabled() -> bool:
    SIMPLEOS_LOG_COMPILED

fn simpleos_log_compile_mode_name() -> text:
    if SIMPLEOS_LOG_COMPILED:
        return "on"
    "off"
SPL

if [ "${SKIP_KERNEL:-0}" != "1" ] || [ ! -f "$KERNEL" ]; then
    OBJCOPY_PREFIX=""
    for d in /usr/lib/llvm-20/bin /usr/lib/llvm-19/bin /usr/lib/llvm-18/bin; do
        [ -f "$d/llvm-objcopy" ] && OBJCOPY_PREFIX="$d" && break
    done
    rm -rf "$CACHE"; mkdir -p "$CACHE"
    rm -f "$KERNEL"
    echo "[scp-retrieve] building merged kernel -> $KERNEL"
    SIMPLE_BOOTSTRAP=1 SIMPLE_LIB="$ROOT/src" SIMPLE_OS_LOG_MODE=off SIMPLE_ALLOW_FREESTANDING_STUBS=1 \
    PATH="${OBJCOPY_PREFIX:+$OBJCOPY_PREFIX:}$PATH" \
        "$SEED" native-build --source build/os/generated --source src/os --source src/lib \
        --source examples/09_embedded/simple_os --backend cranelift --cpu x86-64-v1 \
        --opt-level=aggressive --log off --entry-closure --cache-dir "$CACHE" \
        --entry "$ENTRY" --target x86_64-unknown-none -o "$KERNEL" \
        --linker-script "$LINKER" 2>&1 | tail -40
    [ -f "$KERNEL" ] || { echo "[scp-retrieve] KERNEL BUILD FAILED"; exit 1; }
fi

# ---- 3. Pick a free host port ----------------------------------------------
SSH_PORT="${SSH_PORT:-2222}"
if ss -ltn 2>/dev/null | grep -q ":$SSH_PORT "; then
    for p in 32222 33222 34222 35222; do
        ss -ltn 2>/dev/null | grep -q ":$p " || { SSH_PORT=$p; break; }
    done
fi
echo "[scp-retrieve] host ssh port = $SSH_PORT -> guest 22"

# ---- 4. Boot QEMU (serial -> FILE) -----------------------------------------
rm -f "$SERIAL"
qemu-system-x86_64 -no-user-config -monitor none -nographic -no-reboot \
    -machine q35 -cpu qemu64 -m "$QEMU_MEM" \
    -kernel "$KERNEL" -serial "file:$SERIAL" \
    -device isa-debug-exit,iobase=0xf4,iosize=0x04 \
    -drive "file=$IMG,if=none,id=nvm,format=raw" -device nvme,serial=deadbeef,drive=nvm \
    -netdev "user,id=n0,hostfwd=tcp::$SSH_PORT-:22" -device virtio-net-pci,netdev=n0 &
QEMU_PID=$!
trap 'kill "$QEMU_PID" 2>/dev/null || true' EXIT

# ---- 5. Wait for the accept loop, create /hello.o over SSH -----------------
i=0
while [ $i -lt "$BOOT_WAIT" ]; do
    grep -qa "accept loop start" "$SERIAL" 2>/dev/null && break
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 1; i=$((i+1))
done
if ! grep -qa "accept loop start" "$SERIAL" 2>/dev/null; then
    echo "[scp-retrieve] FAIL: sshd accept loop never started"
    echo "===== serial tail ====="; tail -40 "$SERIAL" 2>/dev/null || true
    exit 1
fi
CLANG_CMD="clang -cc1 -triple x86_64-unknown-simpleos -emit-obj -o /hello.o -x c /hello.c"
echo "[scp-retrieve] sshd up; running: ssh -p $SSH_PORT root@127.0.0.1 $CLANG_CMD"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 $CLANG_CMD || true

j=0
while [ $j -lt 90 ]; do
    grep -qaE "oo-nvme\] persist|heap:stream-open-fail|ring3 program exited" "$SERIAL" 2>/dev/null && break
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 2; j=$((j+2))
done
if ! grep -qa "oo-nvme\] persist /hello.o -> OK" "$SERIAL" 2>/dev/null; then
    echo "[scp-retrieve] FAIL: /hello.o was not persisted; skipping scp retrieval"
    kill "$QEMU_PID" 2>/dev/null || true; sleep 1
    echo "===== serial tail ====="; tail -60 "$SERIAL" 2>/dev/null || true
    exit 1
fi

# ---- 6. Retrieve /hello.o over scp -----------------------------------------
rm -f "$SCRATCH/retrieved.o"
echo "[scp-retrieve] retrieving via getfile: ssh -p $SSH_PORT root@127.0.0.1 getfile /hello.o > retrieved.o"
sshpass -p simpleos ssh -p "$SSH_PORT" -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 \
    root@127.0.0.1 getfile /hello.o > "$SCRATCH/retrieved.o" 2>/dev/null || true

k=0
while [ $k -lt 20 ]; do
    grep -qaE "getfile path|scp read-open-fail" "$SERIAL" 2>/dev/null && break
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 1; k=$((k+1))
done

kill "$QEMU_PID" 2>/dev/null || true
sleep 1

echo "===== full serial log ====="
cat "$SERIAL" 2>/dev/null || echo "(no serial log)"
echo "===== gate: create ====="
grep -aE "exec command=|clang argv|heap:resolve|heap:stream-open|oo-nvme|syscall\] exit|ring3 program exited" "$SERIAL" 2>/dev/null
echo "===== gate: scp ====="
grep -aE "exec scp-source|scp read path|scp step|scp ctrl-line|scp send-body|scp final-ack|scp read-open-fail|scp read-short" "$SERIAL" 2>/dev/null

if [ ! -s "$SCRATCH/retrieved.o" ]; then
    echo "FAIL: $SCRATCH/retrieved.o missing or empty"
    exit 1
fi
echo "[scp-retrieve] retrieved.o size=$(stat -c%s "$SCRATCH/retrieved.o")"
echo "[scp-retrieve] raw-disk byte-identity check is a separate host one-off"
echo "[scp-retrieve] (not embedded here: no Python in committed repo scripts) --"
echo "[scp-retrieve] compare $SCRATCH/retrieved.o against a raw FAT32 extract of $IMG:/HELLO.O"

echo "===== llvm-readobj ====="
llvm-readobj -h "$SCRATCH/retrieved.o" | grep -E "Type|Machine" || true

echo "===== host link+run ====="
cc "$SCRATCH/retrieved.o" -o "$SCRATCH/a.out" && "$SCRATCH/a.out"; RC=$?
echo "retrieved.o host exit code = $RC (want 7)"
[ "$RC" = "7" ] && echo "PASS host exit code 7" || echo "FAIL host exit code $RC"
