# fsexec_mkimg_simple.spl — sibling of fsexec_mkimg_big.spl (Lane B-v2,
# in-guest `simple` interpreter board gate). Structurally IDENTICAL FAT32
# *structural prefix* writer, just re-pointed at a different pair of
# payloads:
#   - big payload  = the SimpleOS x86_64-unknown-simpleos `simple` binary
#                     (aliased at /FSEXEC.ELF for back-compat with the
#                     existing ring3-exec probe AND at /usr/bin/simple so
#                     the generic PATH-resolved sshd exec dispatch
#                     (fs_exec_resolve / sshd.spl `_sshd_run_pending_exec`)
#                     finds it).
#   - small payload = a single-cluster guest text file staged at /hello.spl
#                     (instead of the clang harness's hello.c/o).
#
# fsexec_mkimg_big.spl is actively owned by another lane (clang-as-FS-exec
# goal) and is single-purpose (hardcoded HELLO.C/O + clang alias), so this
# is a deliberate sibling copy rather than a generalization of that file.
#
# Geometry: identical to fsexec_mkimg_big.spl (bytes_per_sector=512,
# sectors_per_cluster=64, reserved=32, num_fats=1). FHS directory skeleton
# kept for parity with tooling that inspects the image.
#
# Input : build/os/elfexec_simple/payload_size.txt   (decimal byte count of the `simple` ELF)
#         build/os/elfexec_simple/hello.spl           (guest /hello.spl content)
# Output: build/os/elfexec_simple/fat32-simple-prefix.bin (structural prefix)

extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_byte_array_new_len(len: u64) -> [u8]

fn _parse_u64(data: [u8]) -> u64:
    var v: u64 = 0u64
    var i: i64 = 0
    while i < data.len():
        val c = data[i] as u64
        if c >= 0x30u64 and c <= 0x39u64:
            v = (v * 10u64) + (c - 0x30u64)
        i = i + 1
    v

fn _pad_ascii(s: text, width: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < width:
        if i < s.length:
            out.push(s[i] as u8)
        else:
            out.push(0x20u8)
        i = i + 1u64
    out

fn _name83_bytes(base: text, ext: text) -> [u8]:
    """FAT32 8.3 name: 8-char base + 3-char ext, space-padded, no dot."""
    var out: [u8] = _pad_ascii(base, 8u64)
    val e = _pad_ascii(ext, 3u64)
    var i: u64 = 0u64
    while i < e.len():
        out.push(e[i])
        i = i + 1u64
    out

fn _dir_entry(name83: [u8], cluster: u64, size: u64, attr: u8) -> [u8]:
    """Build one 32-byte FAT32 directory entry."""
    var e: [u8] = []
    var i: u64 = 0u64
    while i < 11u64:
        e.push(name83[i])
        i = i + 1u64
    e.push(attr)                                    # attr
    e.push(0u8)                                      # NTRes
    e.push(0u8)                                      # CrtTimeTenth
    e.push(0u8)
    e.push(0u8)                                       # CrtTime
    e.push(0u8)
    e.push(0u8)                                       # CrtDate
    e.push(0u8)
    e.push(0u8)                                       # LstAccDate
    e.push(((cluster >> 16) & 0xFFu64) as u8)          # FstClusHI lo
    e.push(((cluster >> 24) & 0xFFu64) as u8)          # FstClusHI hi
    e.push(0u8)
    e.push(0u8)                                       # WrtTime
    e.push(0u8)
    e.push(0u8)                                       # WrtDate
    e.push((cluster & 0xFFu64) as u8)                  # FstClusLO lo
    e.push(((cluster >> 8) & 0xFFu64) as u8)           # FstClusLO hi
    e.push((size & 0xFFu64) as u8)                     # FileSize
    e.push(((size >> 8) & 0xFFu64) as u8)
    e.push(((size >> 16) & 0xFFu64) as u8)
    e.push(((size >> 24) & 0xFFu64) as u8)
    e

fn _write_bytes_at(buf: [u8], base: i64, data: [u8]) -> [u8]:
    var i: i64 = 0
    while i < data.len():
        buf[base + i] = data[i]
        i = i + 1
    buf

fn _cluster_base(data_start_sector: u64, cluster_bytes: u64, n: u64) -> i64:
    ((data_start_sector * 512u64) + ((n - 2u64) * cluster_bytes)) as i64

fn main() -> i64:
    val size_path = "build/os/elfexec_simple/payload_size.txt"
    val prefix_path = "build/os/elfexec_simple/fat32-simple-prefix.bin"

    val size_bytes: [u8] = rt_file_read_bytes(size_path) ?? []
    if size_bytes.len() == 0:
        print "fsexec_mkimg_simple_error=missing payload_size.txt"
        return 1
    val payload: u64 = _parse_u64(size_bytes)
    if payload == 0u64:
        print "fsexec_mkimg_simple_error=zero payload size"
        return 1

    val hello_path = "build/os/elfexec_simple/hello.spl"
    val hello_bytes: [u8] = rt_file_read_bytes(hello_path) ?? []
    val hello_len: u64 = hello_bytes.len() as u64

    val SPC: u64 = 64u64
    val CLUSTER_BYTES: u64 = SPC * 512u64          # 32768
    val RESERVED: u64 = 32u64
    val NUM_FATS: u64 = 1u64

    if hello_len == 0u64 or hello_len > CLUSTER_BYTES:
        print "fsexec_mkimg_simple_error=input missing or too big: " + hello_path
        return 1

    # -- FHS directory skeleton: 9 one-cluster directory nodes, clusters
    # 4..12, sitting between HELLO.SPL (cluster 3) and the payload chain.
    val DIR_START: u64 = 4u64
    val DIR_COUNT: u64 = 9u64
    val C_BIN: u64 = 4u64          # /bin
    val C_USR: u64 = 5u64          # /usr
    val C_USRBIN: u64 = 6u64       # /usr/bin
    val C_USRLOCAL: u64 = 7u64     # /usr/local
    val C_USRLOCALBIN: u64 = 8u64  # /usr/local/bin
    val C_ETC: u64 = 9u64          # /etc
    val C_TMP: u64 = 10u64         # /tmp
    val C_HOME: u64 = 11u64        # /home
    val C_HOMEROOT: u64 = 12u64    # /home/root
    val PAYLOAD_START: u64 = DIR_START + DIR_COUNT   # 13

    var payload_clusters: u64 = payload / CLUSTER_BYTES
    if payload % CLUSTER_BYTES != 0u64:
        payload_clusters = payload_clusters + 1u64
    val highest_cluster: u64 = (PAYLOAD_START - 1u64) + payload_clusters
    # Spare free clusters past the payload so an in-guest program can WRITE
    # output back to the FAT/NVMe disk (e.g. `simple compile --emit-object`
    # needs a free cluster for /hello2.o).
    val SPARE_CLUSTERS: u64 = 16u64
    val fat_entries: u64 = highest_cluster + 1u64 + SPARE_CLUSTERS
    var fat_sectors: u64 = (fat_entries * 4u64) / 512u64
    if (fat_entries * 4u64) % 512u64 != 0u64:
        fat_sectors = fat_sectors + 1u64
    fat_sectors = fat_sectors + 8u64                      # slack

    val data_start_sector: u64 = RESERVED + (NUM_FATS * fat_sectors)
    val prefix_sectors: u64 = data_start_sector + (11u64 * SPC)
    val prefix_bytes_u: u64 = prefix_sectors * 512u64
    val total_sectors: u64 = data_start_sector + ((payload_clusters + 11u64 + SPARE_CLUSTERS) * SPC)
    val total_bytes: u64 = total_sectors * 512u64
    val total_clusters: u64 = (total_sectors - data_start_sector) / SPC

    var img: [u8] = rt_byte_array_new_len(prefix_bytes_u)

    # ---- Sector 0: BPB ----
    img[0] = 0xEBu8
    img[1] = 0x58u8
    img[2] = 0x90u8
    img[3] = 0x53u8   # OEM "SIMPLEOS"
    img[4] = 0x49u8
    img[5] = 0x4Du8
    img[6] = 0x50u8
    img[7] = 0x4Cu8
    img[8] = 0x45u8
    img[9] = 0x4Fu8
    img[10] = 0x53u8
    img[11] = 0x00u8  # bytes_per_sector = 512
    img[12] = 0x02u8
    img[13] = SPC as u8                        # sectors_per_cluster
    img[14] = (RESERVED & 0xFFu64) as u8       # reserved_sectors
    img[15] = ((RESERVED >> 8) & 0xFFu64) as u8
    img[16] = NUM_FATS as u8                    # num_fats
    img[21] = 0xF8u8  # media
    img[24] = 0x3Fu8  # sectors_per_track = 63
    img[26] = 0xFFu8  # num_heads = 255
    img[32] = (total_sectors & 0xFFu64) as u8          # total_sectors_32 LE
    img[33] = ((total_sectors >> 8) & 0xFFu64) as u8
    img[34] = ((total_sectors >> 16) & 0xFFu64) as u8
    img[35] = ((total_sectors >> 24) & 0xFFu64) as u8
    img[36] = (fat_sectors & 0xFFu64) as u8            # fat_size_32 LE
    img[37] = ((fat_sectors >> 8) & 0xFFu64) as u8
    img[38] = ((fat_sectors >> 16) & 0xFFu64) as u8
    img[39] = ((fat_sectors >> 24) & 0xFFu64) as u8
    img[44] = 0x02u8  # root_cluster = 2
    img[48] = 0x01u8  # fs_info sector = 1
    img[50] = 0x06u8  # backup_boot_sector = 6
    img[64] = 0x80u8  # drive_number
    img[66] = 0x29u8  # boot_sig
    img[67] = 0x78u8  # vol_id 0x12345678 LE
    img[68] = 0x56u8
    img[69] = 0x34u8
    img[70] = 0x12u8
    img[71] = 0x53u8  # vol_label "SIMPLEOS   "
    img[72] = 0x49u8
    img[73] = 0x4Du8
    img[74] = 0x50u8
    img[75] = 0x4Cu8
    img[76] = 0x45u8
    img[77] = 0x4Fu8
    img[78] = 0x53u8
    img[79] = 0x20u8
    img[80] = 0x20u8
    img[81] = 0x20u8
    img[82] = 0x46u8  # "FAT32   "
    img[83] = 0x41u8
    img[84] = 0x54u8
    img[85] = 0x33u8
    img[86] = 0x32u8
    img[87] = 0x20u8
    img[88] = 0x20u8
    img[89] = 0x20u8
    img[510] = 0x55u8
    img[511] = 0xAAu8

    # ---- Sector 1: FSInfo ----
    img[512] = 0x52u8  # lead_sig 0x41615252 LE
    img[513] = 0x52u8
    img[514] = 0x61u8
    img[515] = 0x41u8
    img[512 + 484] = 0x72u8  # struct_sig 0x61417272 LE
    img[512 + 485] = 0x72u8
    img[512 + 486] = 0x41u8
    img[512 + 487] = 0x61u8
    img[512 + 488] = 0xFFu8  # free_count = unknown
    img[512 + 489] = 0xFFu8
    img[512 + 490] = 0xFFu8
    img[512 + 491] = 0xFFu8
    img[512 + 492] = 0xFFu8  # next_free = unknown
    img[512 + 493] = 0xFFu8
    img[512 + 494] = 0xFFu8
    img[512 + 495] = 0xFFu8
    img[512 + 510] = 0x55u8
    img[512 + 511] = 0xAAu8

    # ---- FAT1 (starts at RESERVED*512) ----
    val fat_base: i64 = (RESERVED * 512u64) as i64
    img[fat_base + 0] = 0xF8u8   # entry 0 (media)
    img[fat_base + 1] = 0xFFu8
    img[fat_base + 2] = 0xFFu8
    img[fat_base + 3] = 0x0Fu8
    img[fat_base + 4] = 0xFFu8   # entry 1 (EOC)
    img[fat_base + 5] = 0xFFu8
    img[fat_base + 6] = 0xFFu8
    img[fat_base + 7] = 0x0Fu8
    img[fat_base + 8] = 0xFFu8   # entry 2 (root dir EOC)
    img[fat_base + 9] = 0xFFu8
    img[fat_base + 10] = 0xFFu8
    img[fat_base + 11] = 0x0Fu8
    img[fat_base + 12] = 0xFFu8  # entry 3 (HELLO.SPL single cluster, EOC)
    img[fat_base + 13] = 0xFFu8
    img[fat_base + 14] = 0xFFu8
    img[fat_base + 15] = 0x0Fu8
    # entries DIR_START..DIR_START+DIR_COUNT-1 (9 one-cluster dir nodes, each EOC)
    var dc: u64 = DIR_START
    while dc < DIR_START + DIR_COUNT:
        val deo: i64 = fat_base + ((dc * 4u64) as i64)
        img[deo + 0] = 0xFFu8
        img[deo + 1] = 0xFFu8
        img[deo + 2] = 0xFFu8
        img[deo + 3] = 0x0Fu8
        dc = dc + 1u64
    var c: u64 = PAYLOAD_START    # simple payload chain
    while c <= highest_cluster:
        var next: u64 = 0x0FFFFFFFu64
        if c < highest_cluster:
            next = c + 1u64
        val eo: i64 = fat_base + ((c * 4u64) as i64)
        img[eo + 0] = (next & 0xFFu64) as u8
        img[eo + 1] = ((next >> 8) & 0xFFu64) as u8
        img[eo + 2] = ((next >> 16) & 0xFFu64) as u8
        img[eo + 3] = ((next >> 24) & 0xFFu64) as u8
        c = c + 1u64

    # ---- Root directory (cluster 2 at data_start_sector*512) ----
    val rd: i64 = (data_start_sector * 512u64) as i64
    img = _write_bytes_at(img, rd + 0 * 32, _dir_entry(_name83_bytes("HELLO", "SPL"), 3u64, hello_len, 0x20u8))
    img = _write_bytes_at(img, rd + 1 * 32, _dir_entry(_name83_bytes("FSEXEC", "ELF"), PAYLOAD_START, payload, 0x20u8))
    img = _write_bytes_at(img, rd + 2 * 32, _dir_entry(_name83_bytes("BIN", ""), C_BIN, 0u64, 0x10u8))
    img = _write_bytes_at(img, rd + 3 * 32, _dir_entry(_name83_bytes("USR", ""), C_USR, 0u64, 0x10u8))
    img = _write_bytes_at(img, rd + 4 * 32, _dir_entry(_name83_bytes("ETC", ""), C_ETC, 0u64, 0x10u8))
    img = _write_bytes_at(img, rd + 5 * 32, _dir_entry(_name83_bytes("TMP", ""), C_TMP, 0u64, 0x10u8))
    img = _write_bytes_at(img, rd + 6 * 32, _dir_entry(_name83_bytes("HOME", ""), C_HOME, 0u64, 0x10u8))

    # ---- /usr (cluster C_USR): BIN -> /usr/bin, LOCAL -> /usr/local ----
    val usr_base = _cluster_base(data_start_sector, CLUSTER_BYTES, C_USR)
    img = _write_bytes_at(img, usr_base + 0 * 32, _dir_entry(_name83_bytes("BIN", ""), C_USRBIN, 0u64, 0x10u8))
    img = _write_bytes_at(img, usr_base + 1 * 32, _dir_entry(_name83_bytes("LOCAL", ""), C_USRLOCAL, 0u64, 0x10u8))

    # ---- /usr/bin (cluster C_USRBIN): SIMPLE file, ALIASES the FSEXEC.ELF
    # cluster chain (same PAYLOAD_START, same size) -- no data duplication.
    val usrbin_base = _cluster_base(data_start_sector, CLUSTER_BYTES, C_USRBIN)
    img = _write_bytes_at(img, usrbin_base + 0 * 32, _dir_entry(_name83_bytes("SIMPLE", ""), PAYLOAD_START, payload, 0x20u8))

    # ---- /usr/local (cluster C_USRLOCAL): BIN -> /usr/local/bin ----
    val usrlocal_base = _cluster_base(data_start_sector, CLUSTER_BYTES, C_USRLOCAL)
    img = _write_bytes_at(img, usrlocal_base + 0 * 32, _dir_entry(_name83_bytes("BIN", ""), C_USRLOCALBIN, 0u64, 0x10u8))

    # ---- /home (cluster C_HOME): ROOT -> /home/root ----
    val home_base = _cluster_base(data_start_sector, CLUSTER_BYTES, C_HOME)
    img = _write_bytes_at(img, home_base + 0 * 32, _dir_entry(_name83_bytes("ROOT", ""), C_HOMEROOT, 0u64, 0x10u8))

    # /usr/local/bin, /bin, /etc, /tmp, /home/root are empty dirs: the
    # pre-zeroed buffer already gives them an implicit end-of-directory
    # marker (first byte 0x00), so no writes are needed for those clusters.

    # ---- HELLO.SPL data (cluster 3 = data_start_sector + SPC) ----
    val hello_base: i64 = ((data_start_sector + SPC) * 512u64) as i64
    var hi: i64 = 0
    while hi < hello_bytes.len():
        img[hello_base + hi] = hello_bytes[hi]
        hi = hi + 1

    if not rt_file_write_bytes(prefix_path, img):
        print "fsexec_mkimg_simple_error=write prefix failed"
        return 1

    print "fsexec_mkimg_simple_status=ok payload=" + payload.to_text() + " payload_clusters=" + payload_clusters.to_text() + " spc=" + SPC.to_text() + " fat_sectors=" + fat_sectors.to_text() + " prefix_bytes=" + prefix_bytes_u.to_text() + " total_bytes=" + total_bytes.to_text() + " total_clusters=" + total_clusters.to_text() + " dirs=9 usrbin_simple_alias_cluster=" + PAYLOAD_START.to_text()
    return 0
