populate_with_python_fat32() {
    if ! command -v python3 >/dev/null 2>&1; then
        return 1
    fi
    python3 - "$OUTPUT" "$TMPDIR" <<'PY'
import os
import pathlib
import struct
import sys

image = pathlib.Path(sys.argv[1])
source = pathlib.Path(sys.argv[2])
data = bytearray(image.read_bytes())

bps = struct.unpack_from("<H", data, 11)[0]
spc = data[13]
reserved = struct.unpack_from("<H", data, 14)[0]
fat_count = data[16]
spf = struct.unpack_from("<I", data, 36)[0]
root_cluster = struct.unpack_from("<I", data, 44)[0]
fat0 = reserved * bps
cluster0 = (reserved + fat_count * spf) * bps
cluster_size = bps * spc
data_clusters = (len(data) - cluster0) // cluster_size
max_cluster = root_cluster + data_clusters - 1
next_cluster = 3

def cluster_offset(cluster):
    return cluster0 + (cluster - 2) * cluster_size

def set_fat(cluster, value):
    for fat_index in range(fat_count):
        off = fat0 + fat_index * spf * bps + cluster * 4
        struct.pack_into("<I", data, off, value)

def alloc_cluster():
    global next_cluster
    cluster = next_cluster
    if cluster > max_cluster:
        raise RuntimeError(
            f"FAT32 image capacity exhausted: next cluster {cluster} exceeds max {max_cluster}"
        )
    next_cluster += 1
    start = cluster_offset(cluster)
    data[start:start + cluster_size] = b"\0" * cluster_size
    set_fat(cluster, 0x0FFFFFFF)
    return cluster

def fat_name(path):
    name = path.name.upper()
    if "." in name:
        base, ext = name.rsplit(".", 1)
    else:
        base, ext = name, ""
    valid = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_$~"
    base = "".join(ch if ch in valid else "_" for ch in base)[:8]
    ext = "".join(ch if ch in valid else "_" for ch in ext)[:3]
    if not base:
        raise ValueError(f"cannot encode empty FAT name for {path}")
    return base.ljust(8) + ext.ljust(3)

def fat_special_name(base):
    return base.ljust(11)

def write_dir_entry(dir_cluster, index, name11, attr, first_cluster, size):
    off = cluster_offset(dir_cluster) + index * 32
    entry = bytearray(32)
    entry[0:11] = name11.encode("ascii")
    entry[11] = attr
    struct.pack_into("<H", entry, 20, (first_cluster >> 16) & 0xFFFF)
    struct.pack_into("<H", entry, 26, first_cluster & 0xFFFF)
    struct.pack_into("<I", entry, 28, size)
    data[off:off + 32] = entry

entries_per_cluster = cluster_size // 32
dir_entries = {root_cluster: 0}
dir_chains = {root_cluster: [root_cluster]}
dirs = {source: root_cluster}

def alloc_dir_slot(dir_cluster):
    index = dir_entries[dir_cluster]
    chain = dir_chains[dir_cluster]
    chain_index = index // entries_per_cluster
    entry_index = index % entries_per_cluster
    if chain_index >= len(chain):
        new_cluster = alloc_cluster()
        set_fat(chain[-1], new_cluster)
        chain.append(new_cluster)
    dir_entries[dir_cluster] = index + 1
    return chain[chain_index], entry_index

def add_dir(path, parent_cluster):
    cluster = alloc_cluster()
    slot_cluster, index = alloc_dir_slot(parent_cluster)
    write_dir_entry(slot_cluster, index, fat_name(path), 0x10, cluster, 0)
    dirs[path] = cluster
    parent_dir_cluster = 0 if parent_cluster == root_cluster else parent_cluster
    write_dir_entry(cluster, 0, fat_special_name("."), 0x10, cluster, 0)
    write_dir_entry(cluster, 1, fat_special_name(".."), 0x10, parent_dir_cluster, 0)
    dir_entries[cluster] = 2
    dir_chains[cluster] = [cluster]
    return cluster

def add_file(path, parent_cluster):
    payload = path.read_bytes()
    if not payload:
        first = 0
    else:
        chunks = [payload[i:i + cluster_size] for i in range(0, len(payload), cluster_size)]
        clusters = [alloc_cluster() for _ in chunks]
        for i, (cluster, chunk) in enumerate(zip(clusters, chunks)):
            start = cluster_offset(cluster)
            data[start:start + len(chunk)] = chunk
            if i + 1 < len(clusters):
                set_fat(cluster, clusters[i + 1])
        first = clusters[0]
    slot_cluster, index = alloc_dir_slot(parent_cluster)
    write_dir_entry(slot_cluster, index, fat_name(path), 0x20, first, len(payload))

try:
    for root, dirnames, filenames in os.walk(source):
        root_path = pathlib.Path(root)
        parent_cluster = dirs[root_path]
        dirnames[:] = sorted(dirnames)
        for dirname in dirnames:
            child = root_path / dirname
            add_dir(child, parent_cluster)
        for filename in sorted(filenames):
            path = root_path / filename
            try:
                add_file(path, parent_cluster)
            except ValueError:
                pass
except RuntimeError as err:
    print(f"PYTHON_FAT32_CAPACITY_EXHAUSTED: {err}", file=sys.stderr)
    sys.exit(2)

image.write_bytes(data)
PY
}

retry_python_fat32_population() {
    if ! command -v python3 >/dev/null 2>&1; then
        return 1
    fi
    attempts=0
    while [ "$attempts" -lt 4 ]; do
        attempts=$((attempts + 1))
        if populate_with_python_fat32; then
            return 0
        fi
        rc=$?
        if [ "$rc" -ne 2 ]; then
            return "$rc"
        fi
        next_size_mb=$((SIZE_MB + 32))
        echo "[make_os_disk] Growing FAT image from ${SIZE_MB}MB to ${next_size_mb}MB after python capacity check"
        SIZE_MB="$next_size_mb"
        rm -f "$OUTPUT"
        create_raw_image || return 1
        format_fat32_image || return 1
    done
    return 1
}

ensure_image_capacity || exit 1

# Method 1: mtools (works on macOS and Linux without root)
if command -v mcopy >/dev/null 2>&1; then
    mcopy -s -i "$OUTPUT" "$TMPDIR"/* ::
    echo "[make_os_disk] Added filesystem tree (mtools)"
    POPULATED=1

# Method 2: pure userland fallback. It avoids privileged loop mounts and keeps
# the QEMU disk lanes usable in unprivileged containers where Python exists.
elif retry_python_fat32_population; then
    echo "[make_os_disk] Added filesystem tree (python fat32 writer)"
    POPULATED=1

# Method 3: explicit loop mount fallback for developer machines.
elif [ "$(uname -s)" = "Linux" ] && [ "${SIMPLEOS_DISK_ALLOW_LOOP:-0}" = "1" ]; then
    MOUNTDIR="$(mktemp -d)"
    if mount -o loop "$OUTPUT" "$MOUNTDIR" 2>/dev/null; then
        cp -R "$TMPDIR"/. "$MOUNTDIR"/
        sync
        umount "$MOUNTDIR"
        echo "[make_os_disk] Added filesystem tree (loop mount)"
        POPULATED=1
    elif [ "${SIMPLEOS_DISK_ALLOW_SUDO_LOOP:-0}" = "1" ] && command -v sudo >/dev/null 2>&1 && sudo mount -o loop "$OUTPUT" "$MOUNTDIR" 2>/dev/null; then
        sudo cp -R "$TMPDIR"/. "$MOUNTDIR"/
        sudo sync
        sudo umount "$MOUNTDIR"
        echo "[make_os_disk] Added filesystem tree (sudo loop mount)"
        POPULATED=1
    else
        echo "[make_os_disk] WARNING: loop mount fallback failed"
    fi
    rmdir "$MOUNTDIR" 2>/dev/null || true
else
    echo "[make_os_disk] WARNING: no userland FAT32 population tool succeeded"
fi

if [ "$POPULATED" -ne 1 ]; then
    echo "[make_os_disk] ERROR: FAT32 image was formatted but not populated"
    echo "[make_os_disk] Install mtools for mcopy, or python3 for the built-in FAT32 writer."
    echo "[make_os_disk] As a last resort on Linux, retry with SIMPLEOS_DISK_ALLOW_LOOP=1."
    echo "[make_os_disk] Sudo loop fallback is opt-in: SIMPLEOS_DISK_ALLOW_SUDO_LOOP=1."
    exit 1
fi

if [ "$ELFSEEDED" -eq 1 ]; then
    echo "[make_os_disk] hello-world payload: real ELF"
else
    echo "[make_os_disk] hello-world payload: placeholder"
fi

echo "[make_os_disk] Done: $OUTPUT"
