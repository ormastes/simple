#!/bin/sh
# Build a FAT32 disk image for SimpleOS QEMU testing.
# Usage: sh scripts/make_os_disk.shs [size_mb] [output_path] [seed_dir]
#
# Creates a FAT32-formatted disk image with test fixture files.
# Required by QEMU scenarios: x64-nvme-fat32, x64-full-stack
#
# Fixture files (used by test/system/os_*_spec.spl):
#   hello.txt    — "Hello from SimpleOS!\n"  (storage read test)
#   numbers.txt  — "1\n2\n3\n4\n5\n"        (multi-line read test)
#   hello.spl    — Simple source file        (cat test)
#   config.sdn   — SDN config fixture        (config read test)
#   testdir/     — empty directory            (readdir/mkdir test)
#
# Tool priority: mtools (mcopy/mmd) > loop mount (Linux) > skip

SIZE_MB="${1:-64}"
OUTPUT="${2:-build/os/fat32.img}"
SEED_DIR="${3:-}"
POPULATED=0

# Ensure output directory exists
mkdir -p "$(dirname "$OUTPUT")"

# Create empty disk image
dd if=/dev/zero of="$OUTPUT" bs=1M count="$SIZE_MB" 2>/dev/null
echo "[make_os_disk] Created ${SIZE_MB}MB image: $OUTPUT"

# Format as FAT32 (use mkfs.fat or mformat)
FORMATTED=0
if command -v mkfs.fat >/dev/null 2>&1; then
    mkfs.fat -F 32 -n "SIMPLEOS" "$OUTPUT"
    echo "[make_os_disk] Formatted as FAT32 (mkfs.fat)"
    FORMATTED=1
elif command -v mformat >/dev/null 2>&1; then
    mformat -F -v "SIMPLEOS" -i "$OUTPUT" ::
    echo "[make_os_disk] Formatted as FAT32 (mformat)"
    FORMATTED=1
else
    echo "[make_os_disk] WARNING: No mkfs.fat or mformat found"
    echo "[make_os_disk] Image created but not formatted"
    exit 0
fi

# ============================================================================
# Write test fixture files to image
# ============================================================================

# Prepare fixture content in temp directory
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

echo "Hello from SimpleOS!" > "$TMPDIR/hello.txt"

printf "1\n2\n3\n4\n5\n" > "$TMPDIR/numbers.txt"

cat > "$TMPDIR/hello.spl" << 'SPLEOF'
# Hello World for SimpleOS
fn main():
    print("Hello from SimpleOS!")
SPLEOF

cat > "$TMPDIR/config.sdn" << 'SDNEOF'
hostname: "simpleos"
version: "0.1.0"
boot_mode: "serial"
SDNEOF

cat > "$TMPDIR/BROWSER.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=browser_demo_remote_main
app_id=/sys/apps/browser_demo
APPEOF

cat > "$TMPDIR/HELLO.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=hello_world_remote_main
app_id=/sys/apps/hello_world
APPEOF

cat > "$TMPDIR/FILEMAN.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=file_manager_remote_main
app_id=/sys/apps/file_manager
APPEOF

cat > "$TMPDIR/SHELL.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=shell_remote_main
app_id=/sys/apps/shell
APPEOF

cat > "$TMPDIR/EDITOR.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=editor_remote_main
app_id=/sys/apps/editor
APPEOF

mkdir -p "$TMPDIR/SYS/APPS"
cp "$TMPDIR/BROWSER.APP" "$TMPDIR/SYS/APPS/BROWSER.APP"
cp "$TMPDIR/HELLO.APP" "$TMPDIR/SYS/APPS/HELLO.APP"
cp "$TMPDIR/FILEMAN.APP" "$TMPDIR/SYS/APPS/FILEMAN.APP"
cp "$TMPDIR/SHELL.APP" "$TMPDIR/SYS/APPS/SHELL.APP"
cp "$TMPDIR/EDITOR.APP" "$TMPDIR/SYS/APPS/EDITOR.APP"

mkdir -p "$TMPDIR/boot" "$TMPDIR/etc/pkg" "$TMPDIR/etc/shell" "$TMPDIR/bin" "$TMPDIR/sbin"
mkdir -p "$TMPDIR/usr/bin" "$TMPDIR/usr/sbin" "$TMPDIR/usr/lib" "$TMPDIR/usr/libexec/simpleos-installer"
mkdir -p "$TMPDIR/usr/local/bin" "$TMPDIR/usr/local/lib" "$TMPDIR/usr/local/share/themes"
mkdir -p "$TMPDIR/var/db/pkg/installed" "$TMPDIR/var/cache/pkg" "$TMPDIR/var/log" "$TMPDIR/home"

cat > "$TMPDIR/boot/kernel.elf" << 'EOFBOOT'
# staged kernel placeholder for disk deployment
arch = "x86_64"
EOFBOOT

cat > "$TMPDIR/etc/fstab" << 'EOFFSTAB'
# SimpleOS filesystem table
/dev/root / auto defaults 0 1
/dev/efi /boot/efi fat32 defaults 0 2
EOFFSTAB

cat > "$TMPDIR/etc/rc.conf" << 'EOFRC'
hostname="simpleos"
simpleos_desktop="YES"
EOFRC

cat > "$TMPDIR/etc/pkg/repos.sdn" << 'EOFPKG'
[repositories]
local = "/var/cache/pkg/local"
EOFPKG

cat > "$TMPDIR/etc/shell/profile.sdn" << 'EOFSHELL'
shell = "/bin/shell"
EOFSHELL

cat > "$TMPDIR/sbin/init" << 'EOFINIT'
#!/bin/simple-init
print("SIMPLEOS_INIT_OK")
EOFINIT

cat > "$TMPDIR/bin/shell" << 'EOFBIN'
# shell placeholder
EOFBIN

cat > "$TMPDIR/usr/sbin/pkg" << 'EOFPKGBIN'
# pkg placeholder
EOFPKGBIN

cat > "$TMPDIR/usr/local/bin/wget" << 'EOFWGET'
# wget placeholder
EOFWGET

cat > "$TMPDIR/usr/bin/hello-world" << 'EOFHELLO'
# hello-world app placeholder
EOFHELLO

cat > "$TMPDIR/var/db/pkg/installed/simpleos-shell.sdn" << 'EOFPKGDB'
[package]
name = "simpleos-shell"
EOFPKGDB

cat > "$TMPDIR/deployed-files.sdn" << 'EOFMANIFEST'
[artifact]
kind = "disk-image"
layout = "freebsd-like"
EOFMANIFEST

if [ -n "$SEED_DIR" ] && [ -d "$SEED_DIR" ]; then
    cp -R "$SEED_DIR"/. "$TMPDIR"/
fi

# Method 1: mtools (works on macOS and Linux without root)
if command -v mcopy >/dev/null 2>&1; then
    mcopy -s -i "$OUTPUT" "$TMPDIR"/* ::
    echo "[make_os_disk] Added filesystem tree (mtools)"
    POPULATED=1

# Method 2: loop mount (Linux only, requires root or sudo)
elif [ "$(uname -s)" = "Linux" ]; then
    MOUNTDIR="$(mktemp -d)"
    if mount -o loop "$OUTPUT" "$MOUNTDIR" 2>/dev/null; then
        cp -R "$TMPDIR"/. "$MOUNTDIR"/
        sync
        umount "$MOUNTDIR"
        echo "[make_os_disk] Added filesystem tree (loop mount)"
        POPULATED=1
    elif sudo mount -o loop "$OUTPUT" "$MOUNTDIR" 2>/dev/null; then
        sudo cp -R "$TMPDIR"/. "$MOUNTDIR"/
        sudo sync
        sudo umount "$MOUNTDIR"
        echo "[make_os_disk] Added filesystem tree (sudo loop mount)"
        POPULATED=1
    else
        echo "[make_os_disk] WARNING: loop mount failed -- no fixture files added"
    fi
    rmdir "$MOUNTDIR" 2>/dev/null || true
else
    echo "[make_os_disk] WARNING: No mtools and not Linux -- no fixture files added"
    echo "[make_os_disk] Install mtools: brew install mtools (macOS) / apt install mtools (Linux)"
fi

if [ "$POPULATED" -ne 1 ] && command -v python3 >/dev/null 2>&1; then
    if python3 scripts/fat32_seed.py "$OUTPUT" "$TMPDIR"; then
        echo "[make_os_disk] Added fixture files (python fallback)"
        POPULATED=1
    else
        echo "[make_os_disk] WARNING: python fallback failed -- no fixture files added"
    fi
fi

if [ "$POPULATED" -ne 1 ]; then
    echo "[make_os_disk] ERROR: FAT32 image was formatted but not populated"
    exit 1
fi

echo "[make_os_disk] Done: $OUTPUT"
