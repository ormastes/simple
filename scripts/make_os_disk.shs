    make_exec_smf "$TMPDIR/SYS/APPS/shell" "$TMPDIR/SHELLSMF.SMF" || true
    cp "$TMPDIR/SHELLSMF.SMF" "$TMPDIR/SYS/APPS/SHELLSMF.SMF" 2>/dev/null || true
    build_remote_window_elf \
