    make_exec_smf "$TMPDIR/SYS/APPS/file_manager" "$TMPDIR/FILESMF.SMF" || true
    cp "$TMPDIR/FILESMF.SMF" "$TMPDIR/SYS/APPS/FILESMF.SMF" 2>/dev/null || true
    build_remote_window_elf \
