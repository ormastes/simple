#!/bin/sh
# Build a FAT32 disk image for SimpleOS QEMU testing.
# Usage: sh scripts/make_os_disk.shs [size_mb] [output_path] [seed_dir] [arch]
#
# Creates a FAT32-formatted disk image with test fixture files.
# Required by QEMU scenarios: x64-nvme-fat32, x64-desktop-disk, x64-full-stack
#
# Fixture files (used by test/system/os_*_spec.spl):
#   hello.txt    — "Hello from SimpleOS!\n"  (storage read test)
#   numbers.txt  — "1\n2\n3\n4\n5\n"        (multi-line read test)
#   hello.spl    — Simple source file        (cat test)
#   config.sdn   — SDN config fixture        (config read test)
#   testdir/     — empty directory            (readdir/mkdir test)
#
# Tool priority: qemu-img/dd create, mformat/mkfs.fat format,
# mtools or Python FAT32 populate, optional loop mount fallback.

SIZE_MB="${1:-64}"
OUTPUT="${2:-build/os/fat32.img}"
SEED_DIR="${3:-}"
ARCH_MODE="${4:-x86_64}"
SIMPLEOS_IMAGE_VERSION="${SIMPLEOS_IMAGE_VERSION:-0.1.0}"
SIMPLEOS_CLI_APP_CATALOG="${SIMPLEOS_CLI_APP_CATALOG:-scripts/simpleos_cli_app_catalog.txt}"
SIMPLEOS_CLI_APP_CACHE_ROOT="${SIMPLEOS_CLI_APP_CACHE_ROOT:-build/os/simple_cli_apps}"
SIMPLEOS_CLI_BUILD_TARGET="${SIMPLEOS_CLI_BUILD_TARGET:-x86_64-unknown-none}"
SIMPLEOS_REQUIRED_CLI_APPS="${SIMPLEOS_REQUIRED_CLI_APPS:-}"
POPULATED=0
ELFSEEDED=0

if [ -n "${SIMPLEOS_UEFI_KERNEL:-}" ] && [ -z "$SIMPLEOS_REQUIRED_CLI_APPS" ]; then
    SIMPLEOS_REQUIRED_CLI_APPS="info"
fi

create_raw_image() {
    mkdir -p "$(dirname "$OUTPUT")"
    rm -f "$OUTPUT"
    if command -v qemu-img >/dev/null 2>&1; then
        if qemu-img create -f raw "$OUTPUT" "${SIZE_MB}M" >/dev/null; then
            echo "[make_os_disk] Created ${SIZE_MB}MB raw image with qemu-img: $OUTPUT"
            return 0
        fi
        echo "[make_os_disk] ERROR: qemu-img failed to create raw image: $OUTPUT"
        return 1
    fi
    if dd if=/dev/zero of="$OUTPUT" bs=1M count="$SIZE_MB" 2>/dev/null; then
        echo "[make_os_disk] Created ${SIZE_MB}MB raw image with dd: $OUTPUT"
        return 0
    fi
    echo "[make_os_disk] ERROR: dd failed to create raw image: $OUTPUT"
    return 1
}

format_fat32_image() {
    if command -v mformat >/dev/null 2>&1; then
        mformat -F -v "SIMPLEOS" -i "$OUTPUT" ::
        echo "[make_os_disk] Formatted as FAT32 (mformat)"
        return 0
    fi
    if command -v mkfs.fat >/dev/null 2>&1; then
        mkfs.fat -F 32 -n "SIMPLEOS" "$OUTPUT"
        echo "[make_os_disk] Formatted as FAT32 (mkfs.fat)"
        return 0
    fi
    echo "[make_os_disk] ERROR: no FAT32 formatter found"
    echo "[make_os_disk] Install mtools (mformat) or dosfstools (mkfs.fat)."
    echo "[make_os_disk] Examples: apt install mtools dosfstools; brew install mtools dosfstools"
    return 1
}

# ============================================================================
# Write test fixture files to image
# ============================================================================

# Prepare fixture content in temp directory
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

ensure_image_capacity() {
    if ! command -v du >/dev/null 2>&1; then
        return 0
    fi
    staged_mb="$(du -sm "$TMPDIR" 2>/dev/null | awk 'NR == 1 { print $1 }')"
    case "$staged_mb" in
        ''|*[!0-9]*)
            return 0
            ;;
    esac
    required_mb=$((staged_mb + 32))
    rounded_mb=$((((required_mb + 31) / 32) * 32))
    if [ "$rounded_mb" -le "$SIZE_MB" ]; then
        return 0
    fi
    echo "[make_os_disk] Growing FAT image from ${SIZE_MB}MB to ${rounded_mb}MB for ${staged_mb}MB staged payload"
    SIZE_MB="$rounded_mb"
    rm -f "$OUTPUT"
    create_raw_image || return 1
    format_fat32_image || return 1
}

create_raw_image || exit 1
format_fat32_image || exit 1

stage_simpleos_cli_catalog() {
    [ -f "$SIMPLEOS_CLI_APP_CATALOG" ] || return 0

    mkdir -p "$TMPDIR/SYS/APPS"
    : > "$TMPDIR/SYS/APPS/SIMPLECLI.CAT"

    case "$ARCH_MODE" in
        x86_64|amd64|x64)
            ;;
        *)
            while IFS='|' read -r app_name source_path smoke_tag; do
                case "$app_name" in
                    ""|\#*) continue ;;
                esac
                printf "%s|%s|%s|skipped-non-x86_64\n" "$app_name" "$source_path" "$smoke_tag" >> "$TMPDIR/SYS/APPS/SIMPLECLI.CAT"
            done < "$SIMPLEOS_CLI_APP_CATALOG"
            echo "[make_os_disk] Recorded Simple CLI catalog metadata for $ARCH_MODE (payload staging is x86_64-only)"
            return 0
            ;;
    esac

    mkdir -p "$SIMPLEOS_CLI_APP_CACHE_ROOT/$ARCH_MODE" "$SIMPLEOS_CLI_APP_CACHE_ROOT/logs" "$TMPDIR/SYS/APPS"
    app_count=0
    smoke_count=0

    while IFS='|' read -r app_name source_path smoke_tag; do
        case "$app_name" in
            ""|\#*) continue ;;
        esac

        required_stage=0
        case " $SIMPLEOS_REQUIRED_CLI_APPS " in
            *" $app_name "*) required_stage=1 ;;
        esac

        if [ "$smoke_tag" != "smoke" ] && [ "$required_stage" -ne 1 ]; then
            printf "%s|%s|%s|catalog-only\n" "$app_name" "$source_path" "$smoke_tag" >> "$TMPDIR/SYS/APPS/SIMPLECLI.CAT"
            continue
        fi

        cache_path="$SIMPLEOS_CLI_APP_CACHE_ROOT/$ARCH_MODE/${app_name}.smf"
        log_path="$SIMPLEOS_CLI_APP_CACHE_ROOT/logs/${app_name}.log"

        if [ ! -f "$cache_path" ] || [ "$source_path" -nt "$cache_path" ] || [ "$SIMPLEOS_CLI_APP_CATALOG" -nt "$cache_path" ]; then
            echo "[make_os_disk] Compiling Simple CLI app: $app_name"
            if ! bin/simple compile "$source_path" --target "$SIMPLEOS_CLI_BUILD_TARGET" -o "$cache_path" >"$log_path" 2>&1; then
                echo "[make_os_disk] ERROR: failed to compile $app_name from $source_path"
                tail -n 40 "$log_path" 2>/dev/null || true
                return 1
            fi
        fi

        cp "$cache_path" "$TMPDIR/SYS/APPS/$app_name.smf" || return 1
        cp "$cache_path" "$TMPDIR/SYS/APPS/$app_name" || return 1
        printf "%s|%s|%s|staged\n" "$app_name" "$source_path" "$smoke_tag" >> "$TMPDIR/SYS/APPS/SIMPLECLI.CAT"
        app_count=$((app_count + 1))
        smoke_count=$((smoke_count + 1))
    done < "$SIMPLEOS_CLI_APP_CATALOG"

    echo "[make_os_disk] Staged $app_count Simple CLI apps into /SYS/APPS ($smoke_count smoke targets)"
}

echo "Hello from SimpleOS!" > "$TMPDIR/hello.txt"

printf "1\n2\n3\n4\n5\n" > "$TMPDIR/numbers.txt"

cat > "$TMPDIR/hello.spl" << 'SPLEOF'
# Hello World for SimpleOS
fn main():
    print("Hello from SimpleOS!")
SPLEOF

cat > "$TMPDIR/config.sdn" << 'SDNEOF'
hostname: "simpleos"
version: "0.1.0"
boot_mode: "serial"
SDNEOF

mkdir -p "$TMPDIR/SYS"
printf "simpleos=%s\nfilesystem=fat32\nnvfs=available\n" "$SIMPLEOS_IMAGE_VERSION" > "$TMPDIR/SYS/VERSION.TXT"
printf "nvfs-image-version=%s\n" "$SIMPLEOS_IMAGE_VERSION" > "$TMPDIR/SYS/NVFSVER.TXT"
cp "$TMPDIR/SYS/VERSION.TXT" "$TMPDIR/VERSION.TXT"

if command -v openssl >/dev/null 2>&1; then
    if openssl genpkey -algorithm RSA \
        -pkeyopt rsa_keygen_bits:2048 \
        -out "$TMPDIR/SYS/HOST_RSA.PEM" >/dev/null 2>&1 \
        && openssl pkcs8 -topk8 -nocrypt -inform PEM -outform DER \
            -in "$TMPDIR/SYS/HOST_RSA.PEM" \
            -out "$TMPDIR/SYS/HOST_RSA.DER" >/dev/null 2>&1; then
        if command -v ssh-keygen >/dev/null 2>&1; then
            if ssh-keygen -f "$TMPDIR/SYS/HOST_RSA.PEM" -y > "$TMPDIR/SYS/HOST_RSA.PUBTXT" 2>/dev/null; then
                pub_b64="$(awk 'NR==1 { print $2 }' "$TMPDIR/SYS/HOST_RSA.PUBTXT")"
                if [ -n "$pub_b64" ]; then
                    if command -v base64 >/dev/null 2>&1; then
                        printf '%s' "$pub_b64" | base64 -d > "$TMPDIR/SYS/HOST_RSA.BIN" 2>/dev/null || true
                    elif command -v python3 >/dev/null 2>&1; then
                        python3 - <<'PY' "$pub_b64" "$TMPDIR/SYS/HOST_RSA.BIN" >/dev/null 2>&1 || true
import base64
import pathlib
import sys
pathlib.Path(sys.argv[2]).write_bytes(base64.b64decode(sys.argv[1]))
PY
                    fi
                fi
            fi
        fi
    else
        echo "[make_os_disk] WARNING: openssl RSA key generation failed -- SSH live lane stays Ed25519-only"
    fi
else
    echo "[make_os_disk] WARNING: openssl not found -- SSH live lane stays Ed25519-only"
fi

cat > "$TMPDIR/BROWSER.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=browser_demo_remote_main
app_id=/sys/apps/browser_demo
APPEOF

cat > "$TMPDIR/HELLO.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=hello_world_remote_main
app_id=/sys/apps/hello_world
APPEOF

cat > "$TMPDIR/FILEMAN.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=file_manager_remote_main
app_id=/sys/apps/file_manager
APPEOF

cat > "$TMPDIR/SHELL.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=shell_remote_main
app_id=/sys/apps/shell
APPEOF

cat > "$TMPDIR/EDITOR.APP" << 'APPEOF'
# SimpleOS transitional disk launch manifest
kind=resident_remote_app
entry=editor_remote_main
app_id=/sys/apps/editor
APPEOF

cat > "$TMPDIR/SBROWSER.APP" << 'APPEOF'
# SimpleOS filesystem app marker
kind=fs_remote_app
entry=simple_browser
app_id=/sys/apps/simple_browser
APPEOF

cat > "$TMPDIR/SCOMP.APP" << 'APPEOF'
# SimpleOS filesystem app marker
kind=fs_remote_app
entry=simple_compiler
app_id=/sys/apps/simple_compiler
APPEOF

cat > "$TMPDIR/SINTERP.APP" << 'APPEOF'
# SimpleOS filesystem app marker
kind=fs_remote_app
entry=simple_interpreter
app_id=/sys/apps/simple_interpreter
APPEOF

cat > "$TMPDIR/SLOADER.APP" << 'APPEOF'
# SimpleOS filesystem app marker
kind=fs_remote_app
entry=simple_loader
app_id=/sys/apps/simple_loader
APPEOF

cat > "$TMPDIR/LLVM.APP" << 'APPEOF'
# SimpleOS filesystem app marker
kind=fs_remote_app
entry=llvm
app_id=/sys/apps/llvm
APPEOF

cat > "$TMPDIR/RUST.APP" << 'APPEOF'
# SimpleOS filesystem app marker
kind=fs_remote_app
entry=rust
app_id=/sys/apps/rust
APPEOF

mkdir -p "$TMPDIR/SYS/APPS"
cp "$TMPDIR/BROWSER.APP" "$TMPDIR/SYS/APPS/BROWSER.APP"
cp "$TMPDIR/HELLO.APP" "$TMPDIR/SYS/APPS/HELLO.APP"
cp "$TMPDIR/FILEMAN.APP" "$TMPDIR/SYS/APPS/FILEMAN.APP"
cp "$TMPDIR/SHELL.APP" "$TMPDIR/SYS/APPS/SHELL.APP"
cp "$TMPDIR/EDITOR.APP" "$TMPDIR/SYS/APPS/EDITOR.APP"
cp "$TMPDIR/SBROWSER.APP" "$TMPDIR/SYS/APPS/SBROWSER.APP"
cp "$TMPDIR/SCOMP.APP" "$TMPDIR/SYS/APPS/SCOMP.APP"
cp "$TMPDIR/SINTERP.APP" "$TMPDIR/SYS/APPS/SINTERP.APP"
cp "$TMPDIR/SLOADER.APP" "$TMPDIR/SYS/APPS/SLOADER.APP"
cp "$TMPDIR/LLVM.APP" "$TMPDIR/SYS/APPS/LLVM.APP"
cp "$TMPDIR/RUST.APP" "$TMPDIR/SYS/APPS/RUST.APP"
stage_simpleos_cli_catalog || exit 1

mkdir -p "$TMPDIR/boot" "$TMPDIR/etc/pkg" "$TMPDIR/etc/shell" "$TMPDIR/bin" "$TMPDIR/sbin"
mkdir -p "$TMPDIR/usr/bin" "$TMPDIR/usr/sbin" "$TMPDIR/usr/lib" "$TMPDIR/usr/libexec/simpleos-installer"
mkdir -p "$TMPDIR/usr/local/bin" "$TMPDIR/usr/local/lib" "$TMPDIR/usr/local/share/themes"
mkdir -p "$TMPDIR/var/db/pkg/installed" "$TMPDIR/var/cache/pkg" "$TMPDIR/var/log" "$TMPDIR/home"

cat > "$TMPDIR/boot/kernel.elf" << 'EOFBOOT'
# staged kernel placeholder for disk deployment
arch = "x86_64"
EOFBOOT

stage_uefi_boot_media() {
    if [ -z "${SIMPLEOS_UEFI_KERNEL:-}" ]; then
        return 0
    fi
    if [ ! -f "$SIMPLEOS_UEFI_KERNEL" ]; then
        echo "[make_os_disk] ERROR: SIMPLEOS_UEFI_KERNEL does not exist: $SIMPLEOS_UEFI_KERNEL"
        return 1
    fi

    mkdir -p "$TMPDIR/EFI/BOOT" "$TMPDIR/boot/grub" "build/os/esp/EFI/BOOT" "build/os/esp/boot/grub"
    cp "$SIMPLEOS_UEFI_KERNEL" "$TMPDIR/boot/kernel.elf"
    cp "$SIMPLEOS_UEFI_KERNEL" "build/os/esp/boot/kernel.elf"
    cat > "$TMPDIR/boot/grub/grub.cfg" << 'EOFGRUB'
serial --unit=0 --speed=115200
terminal_input serial console
terminal_output serial console
set timeout=0
set default=0

menuentry "SimpleOS desktop" {
    search --no-floppy --file --set=root /BOOT/KERNEL.ELF
    multiboot /BOOT/KERNEL.ELF
    boot
}
EOFGRUB
    cp "$TMPDIR/boot/grub/grub.cfg" "build/os/esp/boot/grub/grub.cfg"

    if command -v grub-mkstandalone >/dev/null 2>&1; then
        if grub-mkstandalone -O x86_64-efi \
            --modules="part_gpt part_msdos fat normal multiboot search search_fs_file serial terminal configfile" \
            -o "$TMPDIR/EFI/BOOT/BOOTX64.EFI" \
            "/boot/grub/grub.cfg=$TMPDIR/boot/grub/grub.cfg" >/dev/null 2>&1; then
            cp "$TMPDIR/EFI/BOOT/BOOTX64.EFI" "build/os/esp/EFI/BOOT/BOOTX64.EFI"
            echo "[make_os_disk] Seeded GRUB x86_64 UEFI fallback loader"
            return 0
        fi
        echo "[make_os_disk] WARNING: grub-mkstandalone failed -- trying monolithic grubx64.efi fallback"
    fi

    for candidate in \
        /usr/lib/grub/x86_64-efi/monolithic/grubx64.efi \
        /usr/share/grub/x86_64-efi/monolithic/grubx64.efi
    do
        if [ -f "$candidate" ]; then
            cp "$candidate" "$TMPDIR/EFI/BOOT/BOOTX64.EFI"
            cp "$candidate" "build/os/esp/EFI/BOOT/BOOTX64.EFI"
            echo "[make_os_disk] Seeded monolithic GRUB x86_64 UEFI fallback loader"
            return 0
        fi
    done

    echo "[make_os_disk] ERROR: no x86_64 UEFI bootloader generator found"
    echo "[make_os_disk] Install grub-efi-amd64-bin or provide SIMPLEOS_UEFI_BOOTLOADER."
    return 1
}

stage_uefi_boot_media || exit 1

cat > "$TMPDIR/etc/fstab" << 'EOFFSTAB'
# SimpleOS filesystem table
/dev/root / auto defaults 0 1
/dev/efi /boot/efi fat32 defaults 0 2
EOFFSTAB

cat > "$TMPDIR/etc/rc.conf" << 'EOFRC'
hostname="simpleos"
simpleos_desktop="YES"
EOFRC

cat > "$TMPDIR/etc/pkg/repos.sdn" << 'EOFPKG'
[repositories]
local = "/var/cache/pkg/local"
EOFPKG

cat > "$TMPDIR/etc/shell/profile.sdn" << 'EOFSHELL'
shell = "/bin/shell"
EOFSHELL

cat > "$TMPDIR/sbin/init" << 'EOFINIT'
#!/bin/simple-init
print("SIMPLEOS_INIT_OK")
EOFINIT

cat > "$TMPDIR/bin/shell" << 'EOFBIN'
# shell placeholder
EOFBIN

cat > "$TMPDIR/usr/sbin/pkg" << 'EOFPKGBIN'
# pkg placeholder
EOFPKGBIN

cat > "$TMPDIR/usr/local/bin/wget" << 'EOFWGET'
# wget placeholder
EOFWGET

cat > "$TMPDIR/usr/bin/hello-world" << 'EOFHELLO'
# hello-world app placeholder
EOFHELLO

cat > "$TMPDIR/SYS/APPS/hello_world" << 'EOFHELLOAPP'
# hello_world app placeholder
EOFHELLOAPP

cat > "$TMPDIR/var/db/pkg/installed/simpleos-shell.sdn" << 'EOFPKGDB'
[package]
name = "simpleos-shell"
EOFPKGDB

cat > "$TMPDIR/deployed-files.sdn" << 'EOFMANIFEST'
[artifact]
kind = "disk-image"
layout = "freebsd-like"
EOFMANIFEST

if [ -n "$SEED_DIR" ] && [ -d "$SEED_DIR" ]; then
    cp -R "$SEED_DIR"/. "$TMPDIR"/
fi

HOST_CLANG="clang"
HOST_LLD="ld.lld"
if [ -x /opt/homebrew/opt/llvm/bin/clang ]; then
    HOST_CLANG="/opt/homebrew/opt/llvm/bin/clang"
elif [ -x /usr/local/opt/llvm/bin/clang ]; then
    HOST_CLANG="/usr/local/opt/llvm/bin/clang"
fi
if [ -x /opt/homebrew/opt/llvm/bin/ld.lld ]; then
    HOST_LLD="/opt/homebrew/opt/llvm/bin/ld.lld"
elif [ -x /usr/local/opt/llvm/bin/ld.lld ]; then
    HOST_LLD="/usr/local/opt/llvm/bin/ld.lld"
elif [ -x /opt/homebrew/bin/ld.lld ]; then
    HOST_LLD="/opt/homebrew/bin/ld.lld"
elif [ -x /usr/local/bin/ld.lld ]; then
    HOST_LLD="/usr/local/bin/ld.lld"
fi

build_disk_hello_elf() {
    if ! command -v "$HOST_CLANG" >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: clang not found -- keeping hello-world placeholder"
        return 1
    fi
    if ! command -v "$HOST_LLD" >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: ld.lld not found -- keeping hello-world placeholder"
        return 1
    fi
    if ! /bin/sh src/os/port/llvm/sysroot.shs >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: sysroot build failed -- keeping hello-world placeholder"
        return 1
    fi

    HELLO_OBJ="$TMPDIR/disk_hello.o"
    HELLO_ELF="$TMPDIR/disk_hello.elf"
    if ! "$HOST_CLANG" --target=x86_64-unknown-none-elf -ffreestanding -nostdlib \
        -I build/os/sysroot/include \
        -c examples/simpleos_hello_c/disk_hello.c -o "$HELLO_OBJ"; then
        echo "[make_os_disk] WARNING: clang build failed -- keeping hello-world placeholder"
        return 1
    fi
    if ! "$HOST_LLD" -T build/os/sysroot/share/simpleos/simpleos.ld \
        "$HELLO_OBJ" build/os/sysroot/lib/crt0.o \
        -L build/os/sysroot/lib -lsimpleos_c \
        -o "$HELLO_ELF"; then
        echo "[make_os_disk] WARNING: ld.lld link failed -- keeping hello-world placeholder"
        return 1
    fi

    cp "$HELLO_ELF" "$TMPDIR/usr/bin/hello-world"
    cp "$HELLO_ELF" "$TMPDIR/SYS/APPS/hello_world"
    echo "[make_os_disk] Seeded real hello-world ELF into /usr/bin and /sys/apps"
    return 0
}

if [ "$ARCH_MODE" = "x86_64" ] && build_disk_hello_elf; then
    ELFSEEDED=1
fi

restage_uefi_boot_files() {
    if [ -z "${SIMPLEOS_UEFI_KERNEL:-}" ]; then
        return 0
    fi
    mkdir -p "$TMPDIR/boot/grub"
    if [ -f "build/os/esp/boot/kernel.elf" ]; then
        cp "build/os/esp/boot/kernel.elf" "$TMPDIR/boot/kernel.elf" || return 1
    elif [ -f "$SIMPLEOS_UEFI_KERNEL" ]; then
        cp "$SIMPLEOS_UEFI_KERNEL" "$TMPDIR/boot/kernel.elf" || return 1
    fi
    if [ -f "build/os/esp/boot/grub/grub.cfg" ]; then
        cp "build/os/esp/boot/grub/grub.cfg" "$TMPDIR/boot/grub/grub.cfg" || return 1
    fi
    if [ -f "build/os/esp/EFI/BOOT/BOOTX64.EFI" ]; then
        mkdir -p "$TMPDIR/EFI/BOOT"
        cp "build/os/esp/EFI/BOOT/BOOTX64.EFI" "$TMPDIR/EFI/BOOT/BOOTX64.EFI" || return 1
    fi
    if [ ! -f "$TMPDIR/EFI/BOOT/BOOTX64.EFI" ] || [ ! -f "$TMPDIR/boot/kernel.elf" ] || [ ! -f "$TMPDIR/boot/grub/grub.cfg" ]; then
        echo "[make_os_disk] ERROR: UEFI boot files incomplete before FAT population"
        return 1
    fi
    return 0
}

build_remote_window_elf() {
    SRC="$1"
    DEST_PRIMARY="$2"
    DEST_SECONDARY="$3"
    OBJ="$TMPDIR/$(basename "$SRC" .c).o"
    ELF="$TMPDIR/$(basename "$SRC" .c).elf"

    if ! command -v "$HOST_CLANG" >/dev/null 2>&1; then
        return 1
    fi
    if ! command -v "$HOST_LLD" >/dev/null 2>&1; then
        return 1
    fi

    if ! "$HOST_CLANG" --target=x86_64-unknown-none-elf -ffreestanding -nostdlib \
        -I build/os/sysroot/include \
        -c "$SRC" -o "$OBJ"; then
        echo "[make_os_disk] WARNING: clang build failed for $SRC"
        return 1
    fi
    if ! "$HOST_LLD" -T build/os/sysroot/share/simpleos/simpleos.ld \
        "$OBJ" build/os/sysroot/lib/crt0.o \
        -L build/os/sysroot/lib -lsimpleos_c \
        -o "$ELF"; then
        echo "[make_os_disk] WARNING: ld.lld link failed for $SRC"
        return 1
    fi

    cp "$ELF" "$DEST_PRIMARY"
    if [ -n "$DEST_SECONDARY" ]; then
        cp "$ELF" "$DEST_SECONDARY"
    fi
    echo "[make_os_disk] Seeded $(basename "$SRC" .c) ELF"
    return 0
}

build_simple_app_elf() {
    SRC="$1"
    DEST_PRIMARY="$2"
    DEST_SECONDARY="$3"
    CACHE_KEY="$4"
    CACHE_PATH="$SIMPLEOS_CLI_APP_CACHE_ROOT/$ARCH_MODE/${CACHE_KEY}.smf"
    LOG_PATH="$SIMPLEOS_CLI_APP_CACHE_ROOT/logs/${CACHE_KEY}.log"

    mkdir -p "$SIMPLEOS_CLI_APP_CACHE_ROOT/$ARCH_MODE" "$SIMPLEOS_CLI_APP_CACHE_ROOT/logs"

    if [ ! -f "$CACHE_PATH" ] || [ "$SRC" -nt "$CACHE_PATH" ]; then
        echo "[make_os_disk] Compiling Simple app: $CACHE_KEY"
        if ! bin/simple compile "$SRC" --target "$SIMPLEOS_CLI_BUILD_TARGET" -o "$CACHE_PATH" >"$LOG_PATH" 2>&1; then
            echo "[make_os_disk] ERROR: failed to compile $CACHE_KEY from $SRC"
            tail -n 40 "$LOG_PATH" 2>/dev/null || true
            return 1
        fi
    fi

    cp "$CACHE_PATH" "$DEST_PRIMARY" || return 1
    if [ -n "$DEST_SECONDARY" ]; then
        cp "$CACHE_PATH" "$DEST_SECONDARY" || return 1
    fi
    echo "[make_os_disk] Seeded ${CACHE_KEY} ELF"
    return 0
}

make_exec_smf() {
    SRC_ELF="$1"
    DEST_SMF="$2"
    if [ ! -f "$SRC_ELF" ]; then
        return 1
    fi
    if ! command -v python3 >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: python3 not found -- skipping SMF wrapper for $DEST_SMF"
        return 1
    fi
    python3 - "$SRC_ELF" "$DEST_SMF" <<'PY'
import pathlib
import struct
import sys

src = pathlib.Path(sys.argv[1])
dst = pathlib.Path(sys.argv[2])
payload = src.read_bytes()
header = bytearray(128)
header[0:4] = b"SMF\0"
struct.pack_into("<I", header, 52, len(payload))
struct.pack_into("<I", header, 56, len(payload))
dst.parent.mkdir(parents=True, exist_ok=True)
dst.write_bytes(payload + header)
PY
}

build_ring3_smoke_elf() {
    if ! command -v "$HOST_CLANG" >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: clang not found -- skipping ring3_smoke ELF"
        return 1
    fi
    if ! command -v "$HOST_LLD" >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: ld.lld not found -- skipping ring3_smoke ELF"
        return 1
    fi

    RING3_SRC="examples/simpleos_ring3_smoke/ring3_smoke.S"
    if [ ! -f "$RING3_SRC" ]; then
        echo "[make_os_disk] WARNING: $RING3_SRC not found -- skipping ring3_smoke ELF"
        return 1
    fi

    RING3_OBJ="$TMPDIR/ring3_smoke.o"
    RING3_ELF="$TMPDIR/ring3_smoke.elf"

    if ! "$HOST_CLANG" --target=x86_64-unknown-none-elf -ffreestanding -nostdlib \
        -c "$RING3_SRC" -o "$RING3_OBJ"; then
        echo "[make_os_disk] WARNING: clang assemble failed for ring3_smoke -- skipping"
        return 1
    fi
    if ! "$HOST_LLD" -e _start -static "$RING3_OBJ" -o "$RING3_ELF"; then
        echo "[make_os_disk] WARNING: ld.lld link failed for ring3_smoke -- skipping"
        return 1
    fi

    mkdir -p "$TMPDIR/SYS/APPS"
    cp "$RING3_ELF" "$TMPDIR/SYS/APPS/RING3_SMOKE.SMF"
    echo "[make_os_disk] Seeded ring3_smoke ELF into /sys/apps/ring3_smoke.smf"
    return 0
}

build_arm_minimal_hello_elf() {
    DEST="$TMPDIR/SYS/APPS/hello_world"
    if ! command -v python3 >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: python3 not found -- keeping hello-world placeholder"
        return 1
    fi
    python3 - "$ARCH_MODE" "$DEST" <<'PY'
import pathlib
import struct
import sys

arch = sys.argv[1]
dst = pathlib.Path(sys.argv[2])
dst.parent.mkdir(parents=True, exist_ok=True)

if arch in ("arm64", "aarch64"):
    entry = 0x400000
    code = bytes.fromhex("080080d2000080d2010000d400000014") + b"SIMPLEOS_ARM64_HELLO_ELF"
    ident = b"\x7fELF" + bytes([2, 1, 1, 0]) + bytes(8)
    ehdr = struct.pack("<16sHHIQQQIHHHHHH", ident, 2, 183, 1, entry, 64, 0, 0, 64, 56, 1, 0, 0, 0)
    phdr = struct.pack("<IIQQQQQQ", 1, 5, 0x1000, entry, entry, len(code), len(code), 0x1000)
    payload = ehdr + phdr
    payload += bytes(0x1000 - len(payload))
    payload += code
elif arch in ("arm32", "armv7"):
    entry = 0x80000000
    code = bytes.fromhex("0070a0e30000a0e3000000effeffffea") + b"SIMPLEOS_ARM32_HELLO_ELF"
    ident = b"\x7fELF" + bytes([1, 1, 1, 0]) + bytes(8)
    ehdr = struct.pack("<16sHHIIIIIHHHHHH", ident, 2, 40, 1, entry, 52, 0, 0, 52, 32, 1, 0, 0, 0)
    phdr = struct.pack("<IIIIIIII", 1, 0x100, entry, entry, len(code), len(code), 5, 0x1000)
    payload = ehdr + phdr
    payload += bytes(0x100 - len(payload))
    payload += code
else:
    raise SystemExit(f"unsupported ARM fixture arch: {arch}")

dst.write_bytes(payload)
PY
}

build_riscv_minimal_app_elves() {
    if ! command -v python3 >/dev/null 2>&1; then
        echo "[make_os_disk] WARNING: python3 not found -- keeping RISC-V app placeholders"
        return 1
    fi
    python3 - "$ARCH_MODE" "$TMPDIR/SYS/APPS/hello_world" "$TMPDIR/SYS/APPS/browser_demo" <<'PY'
import pathlib
import struct
import sys

arch = sys.argv[1]
hello_dst = pathlib.Path(sys.argv[2])
gui_dst = pathlib.Path(sys.argv[3])
hello_dst.parent.mkdir(parents=True, exist_ok=True)

def rv_payload(bits: int, marker: bytes) -> bytes:
    machine = 243
    entry = 0x80000000
    code = b"\x13\x00\x00\x00" + marker
    if bits == 64:
        ident = b"\x7fELF" + bytes([2, 1, 1, 0]) + bytes(8)
        ehdr = struct.pack("<16sHHIQQQIHHHHHH", ident, 2, machine, 1, entry, 64, 0, 0, 64, 56, 1, 0, 0, 0)
        phdr = struct.pack("<IIQQQQQQ", 1, 5, 0x100, entry, entry, len(code), len(code), 0x1000)
    else:
        ident = b"\x7fELF" + bytes([1, 1, 1, 0]) + bytes(8)
        ehdr = struct.pack("<16sHHIIIIIHHHHHH", ident, 2, machine, 1, entry, 52, 0, 0, 52, 32, 1, 0, 0, 0)
        phdr = struct.pack("<IIIIIIII", 1, 0x100, entry, entry, len(code), len(code), 5, 0x1000)
    payload = ehdr + phdr
    payload += marker
    payload += bytes(0x100 - len(payload))
    payload += code
    return payload

if arch in ("riscv64", "rv64"):
    hello = rv_payload(64, b"SIMPLEOS_RISCV64_HELLO_ELF")
    gui = rv_payload(64, b"SIMPLEOS_RISCV64_GUI_ELF")
elif arch in ("riscv32", "rv32"):
    hello = rv_payload(32, b"SIMPLEOS_RISCV32_HELLO_ELF")
    gui = rv_payload(32, b"SIMPLEOS_RISCV32_GUI_ELF")
else:
    raise SystemExit(f"unsupported RISC-V fixture arch: {arch}")

hello_dst.write_bytes(hello)
gui_dst.write_bytes(gui)
PY
}

if [ "$ARCH_MODE" = "arm64" ] || [ "$ARCH_MODE" = "aarch64" ] || [ "$ARCH_MODE" = "arm32" ] || [ "$ARCH_MODE" = "armv7" ]; then
    if build_arm_minimal_hello_elf; then
        cp "$TMPDIR/SYS/APPS/hello_world" "$TMPDIR/usr/bin/hello-world"
