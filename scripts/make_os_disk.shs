    make_exec_smf "$TMPDIR/SYS/APPS/simple_browser" "$TMPDIR/SBROWSMF.SMF" || true
    cp "$TMPDIR/SBROWSMF.SMF" "$TMPDIR/SYS/APPS/SBROWSMF.SMF" 2>/dev/null || true
