# Generate real RV32I VHDL template modules already owned by the compiler
# backend. This is not a full CPU core or bitstream handoff.

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create(path: text) -> bool

use compiler.backend.vhdl.{
    render_rv32i_register_file_vhdl,
    render_rv32i_opcode_package,
    render_rv32i_field_extractor,
    render_rv32i_alu_control
}
use std.hardware.fpga_linux.riscv_fpga_linux.{RiscvFpgaLane}

fn rv32_top_vhdl() -> text:
    var l = "library ieee;\nuse ieee.std_logic_1164.all;\nuse ieee.numeric_std.all;\n\n"
    l = l + "entity soc_top_rv32 is\n"
    l = l + "  port (\n"
    l = l + "    clk     : in  std_logic;\n"
    l = l + "    rst     : in  std_logic;\n"
    l = l + "    uart_tx : out std_logic;\n"
    l = l + "    uart_rx : in  std_logic\n"
    l = l + "  );\n"
    l = l + "end entity soc_top_rv32;\n\n"
    l = l + "architecture rtl of soc_top_rv32 is\n"
    l = l + "  signal instr_q : unsigned(31 downto 0) := x\"00000013\";\n"
    l = l + "  signal rd_q    : unsigned(31 downto 0) := (others => '0');\n"
    l = l + "  signal result  : unsigned(31 downto 0);\n"
    l = l + "begin\n"
    l = l + "  u_decode : entity work.simple_rv32i_core_decode_writeback\n"
    l = l + "    port map (imem_rdata => instr_q, next_rd => rd_q, result_out => result);\n\n"
    l = l + "  process(clk)\n"
    l = l + "  begin\n"
    l = l + "    if rising_edge(clk) then\n"
    l = l + "      if rst = '1' then\n"
    l = l + "        instr_q <= x\"00000013\";\n"
    l = l + "        rd_q    <= (others => '0');\n"
    l = l + "      else\n"
    l = l + "        instr_q <= instr_q + 1;\n"
    l = l + "        rd_q    <= result;\n"
    l = l + "      end if;\n"
    l = l + "    end if;\n"
    l = l + "  end process;\n\n"
    l = l + "  -- ponytail: liveness pin, replace with UART boot marker when RV32 executes payloads.\n"
    l = l + "  uart_tx <= result(0) xor result(5) xor uart_rx;\n"
    l = l + "end architecture rtl;\n"
    l

fn write_vhd(out_dir: text, name: text, content: text) -> bool:
    val path = "{out_dir}/{name}.vhd"
    val ok = rt_file_write_text(path, content)
    if ok:
        print("OK {path} bytes={content.length()}")
    else:
        print("FAIL {path}")
    ok

fn write_text(out_dir: text, name: text, content: text) -> bool:
    val path = "{out_dir}/{name}"
    val ok = rt_file_write_text(path, content)
    if ok:
        print("OK {path} bytes={content.length()}")
    else:
        print("FAIL {path}")
    ok

fn main():
    val out_dir = "build/vhdl/rv32"
    rt_dir_create(out_dir)

    write_vhd(out_dir, "rv32i_pkg", render_rv32i_opcode_package())
    write_vhd(out_dir, "rv32i_decode", render_rv32i_field_extractor() + "\n\n" + render_rv32i_alu_control())
    write_text(out_dir, "rv32_core.spl", RiscvFpgaLane.rv32_default().hardware_source_spl())

    val regfile = render_rv32i_register_file_vhdl()
    match regfile:
        Ok(vhdl):
            write_vhd(out_dir, "rv32i_regfile", vhdl)
        Err(_):
            print("FAIL rv32i_regfile")

    write_vhd(out_dir, "soc_top_rv32", rv32_top_vhdl())
