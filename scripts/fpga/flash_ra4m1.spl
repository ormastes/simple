"""Flash RA4M1 via OpenOCD TCL interface and FACI register writes.

Usage:
  1. Start OpenOCD:  openocd -f scripts/openocd_ra4m1.cfg
  2. Run this:       bin/simple run scripts/fpga/flash_ra4m1.spl build/os/simpleos_ra4m1.bin
"""

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_io_tcp_connect(addr: text) -> i64
extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_write_bytes(fd: i64, data: [u8]) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool
extern fn rt_text_to_bytes(s: text) -> [u8]
extern fn rt_bytes_to_text(data: [u8]) -> text
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn faci_cmd() -> i64:
    0x407E0000

fn fstatr() -> i64:
    0x407FE080

fn fentryr() -> i64:
    0x407FE084

fn fsaddr() -> i64:
    0x407FE030

fn block_size() -> i64:
    2048

fn prog_unit() -> i64:
    64

fn prog_words() -> i64:
    32

fn tcl_eof() -> u8:
    26u8

fn usage() -> i32:
    print "Usage: bin/simple run scripts/fpga/flash_ra4m1.spl <binary.bin>"
    return 1

fn first_image_arg(all_args: [text]) -> text:
    var seen_script = false
    var fallback_mode = false
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("flash_ra4m1.spl"):
            seen_script = true
        elif seen_script:
            val arg = all_args[i]
            if arg == "--help" or arg == "-h":
                return "__HELP__"
            if arg != "--" and arg != "--clean" and not arg.starts_with("--mode="):
                return arg
        elif i > 0:
            fallback_mode = true
        i = i + 1
    if fallback_mode:
        i = 1
        while i < all_args.len():
            val arg = all_args[i]
            if arg == "--help" or arg == "-h":
                return "__HELP__"
            if arg != "--" and arg != "--clean" and not arg.starts_with("--mode="):
                return arg
            i = i + 1
    return ""

fn byte_at(data: [u8], idx: i64) -> i64:
    if idx < 0 or idx >= data.len():
        return 0
    data[idx] as i64

fn le16(data: [u8], off: i64) -> i64:
    byte_at(data, off) | (byte_at(data, off + 1) << 8)

fn le32(data: [u8], off: i64) -> i64:
    byte_at(data, off) |
        (byte_at(data, off + 1) << 8) |
        (byte_at(data, off + 2) << 16) |
        (byte_at(data, off + 3) << 24)

fn hex_digit(n: i64) -> text:
    val digits = "0123456789abcdef"
    digits.substring(n, n + 1)

fn hex_fixed(value: i64, width: i64) -> text:
    var out = ""
    var shift = (width - 1) * 4
    while shift >= 0:
        out = out + hex_digit((value >> shift) & 15)
        shift = shift - 4
    out

fn hx32(value: i64) -> text:
    "0x" + hex_fixed(value & 0xffffffff, 8)

fn hx16(value: i64) -> text:
    "0x" + hex_fixed(value & 0xffff, 4)

fn hx8(value: i64) -> text:
    "0x" + hex_fixed(value & 0xff, 2)

fn sleep_ms(ms: i64):
    if ms <= 0:
        return
    if ms >= 100:
        val ignored_sleep_long = rt_process_run("sleep", ["0.1"])
    elif ms >= 10:
        val ignored_sleep_medium = rt_process_run("sleep", ["0.01"])
    else:
        val ignored_sleep_short = rt_process_run("sleep", ["0.005"])

fn command_bytes(cmd: text) -> [u8]:
    var data = rt_text_to_bytes(cmd)
    data.push(tcl_eof())
    data

fn ocd(fd: i64, cmd: text) -> text:
    val data = command_bytes(cmd)
    val written = rt_io_tcp_write_bytes(fd, data)
    if written < data.len():
        return "__ERROR__ short tcp write for " + cmd

    var out: [u8] = []
    var done = false
    var guard = 0
    while not done and guard < 64:
        val chunk = rt_io_tcp_read(fd, 4096)
        if chunk.len() == 0:
            return "__ERROR__ tcp read closed for " + cmd
        var i = 0
        while i < chunk.len():
            val b = chunk[i]
            if b == tcl_eof():
                done = true
            else:
                out.push(b)
            i = i + 1
        guard = guard + 1
    if not done:
        return "__ERROR__ TCL response exceeded read guard for " + cmd
    rt_bytes_to_text(out).trim()

fn hex_value(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    if ch == "a" or ch == "A": return 10
    if ch == "b" or ch == "B": return 11
    if ch == "c" or ch == "C": return 12
    if ch == "d" or ch == "D": return 13
    if ch == "e" or ch == "E": return 14
    if ch == "f" or ch == "F": return 15
    return -1

fn parse_first_hex(text_value: text) -> i64:
    var i = 0
    var value: i64 = 0
    var seen = false
    while i < text_value.len():
        val ch = text_value.substring(i, i + 1)
        val v = hex_value(ch)
        if v >= 0:
            seen = true
            value = (value << 4) | v
        elif seen:
            return value
        i = i + 1
    if seen:
        return value
    return -1

fn value_after_colon(response: text) -> i64:
    val idx = response.index_of(":") ?? -1
    if idx >= 0:
        return parse_first_hex(response.substring(idx + 1, response.len()))
    parse_first_hex(response)

fn read32(fd: i64, addr: i64) -> i64:
    val response = ocd(fd, "ocd_mdw " + hx32(addr))
    if response.starts_with("__ERROR__"):
        print response
        return -1
    value_after_colon(response)

fn wait_frdy(fd: i64, timeout_ms: i64) -> i64:
    val start = rt_time_now_unix_micros()
    while (rt_time_now_unix_micros() - start) < (timeout_ms * 1000):
        val status = read32(fd, fstatr())
        if (status & 0x8000) != 0:
            return status
        sleep_ms(5)
    val final_status = read32(fd, fstatr())
    print "FACI timeout, FSTATR=" + hx32(final_status)
    return -1

fn pad_image(data: [u8]) -> [u8]:
    var out = data
    val pad = (prog_unit() - (out.len() % prog_unit())) % prog_unit()
    var i = 0
    while i < pad:
        out.push(0xffu8)
        i = i + 1
    out

fn fail_with_reset(fd: i64, msg: text) -> i32:
    print msg
    val ignored_clear = ocd(fd, "mwb " + hx32(faci_cmd()) + " 0xB3")
    val ignored_ready = wait_frdy(fd, 2000)
    rt_io_tcp_close(fd)
    return 1

fn program_unit(fd: i64, data: [u8], offset: i64) -> i32:
    val ignored_addr = ocd(fd, "mww " + hx32(fsaddr()) + " " + hx32(offset))
    val ignored_cmd = ocd(fd, "mwb " + hx32(faci_cmd()) + " 0xE8")
    val ignored_words = ocd(fd, "mwb " + hx32(faci_cmd()) + " " + hx8(prog_words()))

    var j = 0
    while j < prog_unit():
        val hw = le16(data, offset + j)
        val ignored_halfword = ocd(fd, "mwh " + hx32(faci_cmd()) + " " + hx16(hw))
        j = j + 2

    val ignored_commit = ocd(fd, "mwb " + hx32(faci_cmd()) + " 0xD0")
    val status = wait_frdy(fd, 2000)
    if status < 0 or (status & 0x70) != 0:
        return fail_with_reset(fd, "Program error at " + hx32(offset) + ": FSTATR=" + hx32(status))
    return 0

fn flash(path: text) -> i32:
    val raw = rt_file_read_bytes(path) ?? []
    if raw.len() == 0:
        print "failed to read binary: " + path
        return 1
    val data = pad_image(raw)
    val num_blocks = (data.len() + block_size() - 1) / block_size()
    val num_units = data.len() / prog_unit()
    print "Binary: " + data.len().to_string() + " bytes, " + num_blocks.to_string() + " blocks, " + num_units.to_string() + " program units"

    val fd = rt_io_tcp_connect("127.0.0.1:6666")
    if fd < 0:
        print "failed to connect to OpenOCD TCL port 127.0.0.1:6666"
        return 1

    print "Halting CPU..."
    val ignored_halt = ocd(fd, "halt")
    sleep_ms(100)

    print "Entering P/E mode..."
    val ignored_enter = ocd(fd, "mwh " + hx32(fentryr()) + " 0xAA01")
    sleep_ms(10)
    val fentr = read32(fd, fentryr())
    if (fentr & 0x0001) == 0:
        print "WARNING: FENTRYR=" + hx16(fentr) + ", P/E mode may not be active"

    print "Erasing " + num_blocks.to_string() + " blocks..."
    var block = 0
    while block < num_blocks:
        val addr = block * block_size()
        val ignored_block_addr = ocd(fd, "mww " + hx32(fsaddr()) + " " + hx32(addr))
        val ignored_erase = ocd(fd, "mwb " + hx32(faci_cmd()) + " 0x20")
        val ignored_erase_commit = ocd(fd, "mwb " + hx32(faci_cmd()) + " 0xD0")
        val status = wait_frdy(fd, 5000)
        if status < 0 or (status & 0x70) != 0:
            return fail_with_reset(fd, "Block " + block.to_string() + " erase error: FSTATR=" + hx32(status))
        if ((block + 1) % 4) == 0 or block == num_blocks - 1:
            print "  Erased " + (block + 1).to_string() + "/" + num_blocks.to_string()
        block = block + 1

    print "Programming " + num_units.to_string() + " units (" + prog_unit().to_string() + "B each)..."
    var program_index = 0
    while program_index < num_units:
        val offset = program_index * prog_unit()
        val rc = program_unit(fd, data, offset)
        if rc != 0:
            return rc
        if ((program_index + 1) % 50) == 0 or program_index == num_units - 1:
            val pct = (100 * (program_index + 1)) / num_units
            print "  Programmed " + ((program_index + 1) * prog_unit()).to_string() + "/" + data.len().to_string() + " bytes (" + pct.to_string() + "%)"
        program_index = program_index + 1

    print "Exiting P/E mode..."
    val ignored_exit = ocd(fd, "mwh " + hx32(fentryr()) + " 0xAA00")
    sleep_ms(10)

    print "Verifying first 16 bytes..."
    var i = 0
    while i < 16:
        val expected = le32(data, i)
        val actual = read32(fd, i)
        val status = if actual == expected: "OK" else: "MISMATCH"
        print "  " + hx32(i) + ": expected=" + hx32(expected) + " actual=" + hx32(actual) + " " + status
        i = i + 4

    print "Resetting..."
    val ignored_reset = ocd(fd, "reset run")
    rt_io_tcp_close(fd)
    print "Done!"
    return 0

fn main() -> i32:
    val image = first_image_arg(rt_cli_get_args())
    if image == "":
        return usage()
    if image == "__HELP__":
        return usage()
    flash(image)
