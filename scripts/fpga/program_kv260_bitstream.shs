#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

VIVADO="${VIVADO:-/home/ormastes/Xilinx/2025.2/Vivado/bin/vivado}"
BITSTREAM="${1:-build/build/xilinx_kv260/gateware/xilinx_kv260.bit}"
OUT_DIR="${OUT_DIR:-build}"

if [ ! -x "$VIVADO" ]; then
    echo "PROGRAM_STATUS=vivado_missing path=$VIVADO"
    exit 1
fi

if [ ! -f "$BITSTREAM" ]; then
    echo "PROGRAM_STATUS=bitstream_missing path=$BITSTREAM"
    exit 1
fi

mkdir -p "$OUT_DIR"
tcl="$(mktemp /tmp/kv260_program.XXXXXX.tcl)"
log="$OUT_DIR/kv260_program_$(date +%Y%m%d_%H%M%S).log"

cat > "$tcl" <<TCL
open_hw_manager
connect_hw_server -allow_non_jtag
open_hw_target
current_hw_device [get_hw_devices xck26_0]
set_property PROGRAM.FILE {$BITSTREAM} [current_hw_device]
program_hw_devices [current_hw_device]
puts "PROGRAM_HW_DEVICES_DONE"
close_hw_target
close_hw_manager
quit
TCL

status=0
if timeout "${PROGRAM_TIMEOUT_SECONDS:-180}s" "$VIVADO" -mode batch -nojournal -nolog -notrace -source "$tcl" >"$log" 2>&1; then
    echo "PROGRAM_STATUS=ok log=$log"
else
    status=$?
    echo "PROGRAM_STATUS=fail exit=$status log=$log"
fi

if command -v rg >/dev/null 2>&1; then
    rg 'End of startup status|PROGRAM_HW_DEVICES_DONE|ERROR:|CRITICAL WARNING:' "$log" || true
else
    grep -E 'End of startup status|PROGRAM_HW_DEVICES_DONE|ERROR:|CRITICAL WARNING:' "$log" || true
fi

rm -f "$tcl"
exit "$status"
