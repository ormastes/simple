#!/bin/sh
# ghdl_validate_rv64.shs — GHDL validation of RV64GC SoC VHDL
#
# Usage: sh scripts/fpga/ghdl_validate_rv64.shs [--analyze|--elaborate|--simulate]
#
# Phases:
#   --analyze   (default) Run ghdl -a --std=08 on all .vhd files
#   --elaborate Also run ghdl -e --std=08 on soc_top_rv64
#   --simulate  Also run ghdl -r with testbench

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
VHDL_DIR="$PROJECT_ROOT/build/vhdl/rv64"
WORK_DIR="$PROJECT_ROOT/build/ghdl/rv64"
TB_DIR="$PROJECT_ROOT/examples/09_embedded/fpga_riscv/rtl"

PHASE="analyze"
for arg in "$@"; do
    case "$arg" in
        --analyze)   PHASE="analyze" ;;
        --elaborate) PHASE="elaborate" ;;
        --simulate)  PHASE="simulate" ;;
    esac
done

# Verify GHDL is available
if ! command -v ghdl >/dev/null 2>&1; then
    echo "ERROR: ghdl not found in PATH"
    exit 1
fi

echo "=== GHDL RV64GC Validation ==="
echo "Phase: $PHASE"
echo "VHDL dir: $VHDL_DIR"
echo "Work dir: $WORK_DIR"
echo ""

mkdir -p "$WORK_DIR"

# Analysis order per D-5:
# pkg -> leaves (alu, regfile, csr_s, csr) -> composites (decode, lsu, mmu_sv39,
# mul_div, atomics, trap) -> core -> soc_top_rv64 -> testbench
# Order: pkg -> RTL leaves -> RTL composites -> core -> peripherals -> soc_top
ANALYSIS_ORDER="pkg alu regfile csr_s csr decode lsu mmu_sv39 mul_div atomics trap rv64gc_core clint plic uart ram bootrom wb_interconnect soc_top_rv64"
MODULE_COUNT=19

# Phase 1: Analyze
echo "--- Phase: Analyze ---"
PASS=0
FAIL=0

for module in $ANALYSIS_ORDER; do
    VHD_FILE="$VHDL_DIR/${module}.vhd"
    if [ ! -f "$VHD_FILE" ]; then
        echo "  SKIP: $module.vhd (not found)"
        continue
    fi
    printf "  Analyzing %s.vhd ... " "$module"
    GHDL_OUT=$(ghdl -a --std=08 --workdir="$WORK_DIR" "$VHD_FILE" 2>&1) || true
    if echo "$GHDL_OUT" | grep -q ":error:"; then
        echo "FAIL"
        echo "$GHDL_OUT" | tail -40
        FAIL=$((FAIL + 1))
    else
        echo "OK"
        PASS=$((PASS + 1))
    fi
done

echo ""
echo "Analysis: $PASS passed, $FAIL failed out of $MODULE_COUNT modules"

if [ "$PHASE" = "analyze" ]; then
    [ $FAIL -eq 0 ] && exit 0 || exit 1
fi

# Phase 2: Elaborate
echo ""
echo "--- Phase: Elaborate ---"
printf "  Elaborating soc_top_rv64 ... "
if ghdl -e --std=08 --workdir="$WORK_DIR" soc_top_rv64 2>&1 | tail -40; then
    echo "OK"
else
    echo "FAIL"
    exit 1
fi

if [ "$PHASE" = "elaborate" ]; then
    exit 0
fi

# Phase 3: Simulate
echo ""
echo "--- Phase: Simulate ---"
TB_FILE="$TB_DIR/tb_rv64_wb_soc_smoke.vhd"
if [ ! -f "$TB_FILE" ]; then
    echo "  ERROR: testbench not found at $TB_FILE"
    exit 1
fi

printf "  Analyzing testbench ... "
TB_OUT=$(ghdl -a --std=08 --workdir="$WORK_DIR" "$TB_FILE" 2>&1) || true
if echo "$TB_OUT" | grep -q ":error:"; then
    echo "FAIL"
    echo "$TB_OUT" | tail -40
    exit 1
fi
echo "OK"

printf "  Elaborating testbench ... "
ELAB_OUT=$(ghdl -e --std=08 --workdir="$WORK_DIR" tb_rv64_wb_soc_smoke 2>&1) || true
if echo "$ELAB_OUT" | grep -q "error"; then
    echo "FAIL"
    echo "$ELAB_OUT" | tail -40
    exit 1
fi
echo "OK"

printf "  Running simulation ... "
SIM_OUT=$(ghdl -r --std=08 --workdir="$WORK_DIR" tb_rv64_wb_soc_smoke --stop-time=10ms 2>&1) || true
echo "$SIM_OUT" | tail -40
SIM_EXIT=0
if echo "$SIM_OUT" | grep -q "error"; then
    SIM_EXIT=1
fi

if [ $SIM_EXIT -eq 0 ]; then
    echo "Simulation PASSED"
else
    echo "Simulation FAILED (exit $SIM_EXIT)"
    exit 1
fi
