# Telnet-over-Serial Bridge runner
#
# Exposes a serial console (FPGA PL UART / SimpleOS RISC-V console) as a
# telnet server for system tests. Run detached, in its own process:
#
#   setsid timeout 120 bin/simple run scripts/fpga/telnet_serial_bridge.spl \
#       /dev/ttyUSB0 115200 127.0.0.1:2323 1 5000 60000 &
#
# Args: DEVICE BAUD BIND_ADDR [MAX_SESSIONS] [IDLE_LIMIT_MS] [MAX_WAIT_MS]
#   MAX_SESSIONS  0 = serve forever (default 1)
#   IDLE_LIMIT_MS 0 = no idle limit (default 0)
#   MAX_WAIT_MS   0 = wait forever for a client (default 0)
#
# Markers on stdout: BRIDGE_LISTENING / BRIDGE_SESSION_DONE / BRIDGE_TIMEOUT /
# BRIDGE_DONE / BRIDGE_ERROR=...

use std.nogc_sync_mut.io.telnet_serial_bridge.{BridgeConfig, bridge_serve}

extern fn rt_cli_get_args() -> [text]

fn main():
    val args = rt_cli_get_args()
    if args.len() < 3:
        print("usage: telnet_serial_bridge.spl DEVICE BAUD BIND_ADDR [MAX_SESSIONS] [IDLE_LIMIT_MS] [MAX_WAIT_MS]")
        return

    val device = args[0]
    val baud = args[1].to_int()
    val bind_addr = args[2]

    var max_sessions = 1
    if args.len() > 3:
        max_sessions = args[3].to_int()
    var idle_limit_ms = 0
    if args.len() > 4:
        idle_limit_ms = args[4].to_int()
    var max_wait_ms = 0
    if args.len() > 5:
        max_wait_ms = args[5].to_int()

    val cfg = BridgeConfig(device: device, baud: baud, bind_addr: bind_addr, max_sessions: max_sessions, idle_limit_ms: idle_limit_ms, max_wait_ms: max_wait_ms)
    val rc = bridge_serve(cfg)
    print("BRIDGE_EXIT rc={rc}")

main()
