# rv64_vhdl_driver.spl — Generate all RV64GC SoC VHDL files
#
# Writes .vhd files to build/vhdl/rv64/:
#   - soc_top_rv64.vhd       (SoC top-level from generate_soc_top_vhdl_rv64)
#   - Per-module RTL stubs   (SKIPPED — no .spl-to-VHDL compiler backend exists;
#                             see honest per-module print below, not a phantom call)
#   - Peripheral stubs        (clint, plic, uart, ram, bootrom, wb_interconnect)
#
# NOTE: this driver previously imported+called `compile_to_vhdl_module` from
# std.hardware.fpga_linux.riscv_fpga_linux — that function is never defined
# anywhere in src/ (repo-wide grep confirms zero `fn compile_to_vhdl_module`).
# The import made the whole driver fail to compile, so nothing after the SoC
# top-level ever ran. Per-module RTL-to-VHDL compilation is honestly reported
# as SKIPPED until that backend exists.

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create(path: text) -> bool

use std.hardware.fpga_linux._SocVhdlGen.top_testbench.{generate_soc_top_vhdl_rv64}

fn vhdl_header() -> text:
    "library ieee;\nuse ieee.std_logic_1164.all;\nuse ieee.numeric_std.all;\n"

fn vhdl_textio_header() -> text:
    "library ieee;\nuse ieee.std_logic_1164.all;\nuse ieee.numeric_std.all;\nuse std.textio.all;\nuse ieee.std_logic_textio.all;\n"

fn gen_rv64gc_core() -> text:
    var l = vhdl_header()
    l = l + "\nentity rv64gc_core is\n"
    l = l + "  generic (\n    CLK_FREQ : natural := 100000000\n  );\n"
    l = l + "  port (\n"
    l = l + "    clk      : in  std_logic;\n"
    l = l + "    rst      : in  std_logic;\n"
    l = l + "    wb_adr_o : out std_logic_vector(63 downto 0);\n"
    l = l + "    wb_dat_o : out std_logic_vector(63 downto 0);\n"
    l = l + "    wb_dat_i : in  std_logic_vector(63 downto 0);\n"
    l = l + "    wb_we_o  : out std_logic;\n"
    l = l + "    wb_sel_o : out std_logic_vector(7 downto 0);\n"
    l = l + "    wb_stb_o : out std_logic;\n"
    l = l + "    wb_cyc_o : out std_logic;\n"
    l = l + "    wb_ack_i : in  std_logic;\n"
    l = l + "    msip_i   : in  std_logic;\n"
    l = l + "    mtip_i   : in  std_logic\n"
    l = l + "  );\n"
    l = l + "end entity rv64gc_core;\n\n"
    l = l + "architecture rtl of rv64gc_core is\n"
    l = l + "  type state_t is (S_FETCH, S_FETCH_ACK, S_FETCH_HI, S_FETCH_HI_ACK, S_EXEC, S_LOAD, S_LOAD_ACK, S_LOAD_HI, S_LOAD_HI_ACK, S_STORE, S_STORE_ACK);\n"
    l = l + "  type regs_t is array(0 to 31) of unsigned(63 downto 0);\n"
    l = l + "  signal state_q   : state_t := S_FETCH;\n"
    l = l + "  signal pc_q      : unsigned(63 downto 0) := x\"0000000080000000\";\n"
    l = l + "  signal regs_q    : regs_t := (2 => x\"0000000080072bf0\", others => (others => '0'));\n"
    l = l + "  signal instr_q   : std_logic_vector(63 downto 0) := (others => '0');\n"
    l = l + "  signal instr_cross_q : std_logic := '0';\n"
    l = l + "  signal mem_addr_q : unsigned(63 downto 0) := (others => '0');\n"
    l = l + "  signal mem_wdata_q : std_logic_vector(63 downto 0) := (others => '0');\n"
    l = l + "  signal mem_sel_q : std_logic_vector(7 downto 0) := (others => '0');\n"
    l = l + "  signal mem_rd_q  : natural range 0 to 31 := 0;\n"
    l = l + "  signal mem_is_byte_q : std_logic := '0';\n"
    l = l + "  signal load_low_q : std_logic_vector(63 downto 0) := (others => '0');\n"
    l = l + "  signal fetch_low_q : std_logic_vector(63 downto 0) := (others => '0');\n"
    l = l + "  function sext12(v : std_logic_vector(11 downto 0)) return unsigned is\n"
    l = l + "  begin\n"
    l = l + "    return unsigned(resize(signed(v), 64));\n"
    l = l + "  end function;\n"
    l = l + "  function sext13(v : std_logic_vector(12 downto 0)) return unsigned is\n"
    l = l + "  begin\n"
    l = l + "    return unsigned(resize(signed(v), 64));\n"
    l = l + "  end function;\n"
    l = l + "  function sext21(v : std_logic_vector(20 downto 0)) return unsigned is\n"
    l = l + "  begin\n"
    l = l + "    return unsigned(resize(signed(v), 64));\n"
    l = l + "  end function;\n"
    l = l + "  function zext64(v : std_logic_vector(63 downto 0)) return unsigned is\n"
    l = l + "  begin\n"
    l = l + "    return unsigned(v);\n"
    l = l + "  end function;\n"
    l = l + "  function c_addi_imm(h : std_logic_vector(15 downto 0)) return unsigned is\n"
    l = l + "    variable imm : std_logic_vector(5 downto 0);\n"
    l = l + "  begin\n"
    l = l + "    imm := h(12) & h(6 downto 2);\n"
    l = l + "    return unsigned(resize(signed(imm), 64));\n"
    l = l + "  end function;\n"
    l = l + "  function c_addi4spn_imm(h : std_logic_vector(15 downto 0)) return unsigned is\n"
    l = l + "    variable imm : unsigned(9 downto 0) := (others => '0');\n"
    l = l + "  begin\n"
    l = l + "    imm(5 downto 4) := unsigned(h(12 downto 11));\n"
    l = l + "    imm(9 downto 6) := unsigned(h(10 downto 7));\n"
    l = l + "    imm(2) := h(6);\n"
    l = l + "    imm(3) := h(5);\n"
    l = l + "    return resize(imm, 64);\n"
    l = l + "  end function;\n"
    l = l + "  function c_addi16sp_imm(h : std_logic_vector(15 downto 0)) return unsigned is\n"
    l = l + "    variable imm : std_logic_vector(9 downto 0) := (others => '0');\n"
    l = l + "  begin\n"
    l = l + "    imm(9) := h(12); imm(4) := h(6); imm(6) := h(5); imm(8 downto 7) := h(4 downto 3); imm(5) := h(2);\n"
    l = l + "    return unsigned(resize(signed(imm), 64));\n"
    l = l + "  end function;\n"
    l = l + "  function c_ldsp_imm(h : std_logic_vector(15 downto 0)) return unsigned is\n"
    l = l + "    variable imm : unsigned(8 downto 0) := (others => '0');\n"
    l = l + "  begin\n"
    l = l + "    imm(5) := h(12); imm(4 downto 3) := unsigned(h(6 downto 5)); imm(8 downto 6) := unsigned(h(4 downto 2));\n"
    l = l + "    return resize(imm, 64);\n"
    l = l + "  end function;\n"
    l = l + "  function c_sdsp_imm(h : std_logic_vector(15 downto 0)) return unsigned is\n"
    l = l + "    variable imm : unsigned(8 downto 0) := (others => '0');\n"
    l = l + "  begin\n"
    l = l + "    imm(5 downto 3) := unsigned(h(12 downto 10)); imm(8 downto 6) := unsigned(h(9 downto 7));\n"
    l = l + "    return resize(imm, 64);\n"
    l = l + "  end function;\n"
    l = l + "begin\n"
    l = l + "  wb_adr_o <= std_logic_vector(pc_q) when state_q = S_FETCH or state_q = S_FETCH_ACK else std_logic_vector(mem_addr_q);\n"
    l = l + "  wb_dat_o <= mem_wdata_q;\n"
    l = l + "  wb_we_o  <= '1' when state_q = S_STORE or state_q = S_STORE_ACK else '0';\n"
    l = l + "  wb_sel_o <= (others => '1') when state_q = S_FETCH or state_q = S_FETCH_ACK or state_q = S_FETCH_HI or state_q = S_FETCH_HI_ACK or state_q = S_LOAD or state_q = S_LOAD_ACK or state_q = S_LOAD_HI or state_q = S_LOAD_HI_ACK else mem_sel_q;\n"
    l = l + "  wb_stb_o <= '1' when state_q = S_FETCH or state_q = S_FETCH_ACK or state_q = S_FETCH_HI or state_q = S_FETCH_HI_ACK or state_q = S_LOAD or state_q = S_LOAD_ACK or state_q = S_LOAD_HI or state_q = S_LOAD_HI_ACK or state_q = S_STORE or state_q = S_STORE_ACK else '0';\n"
    l = l + "  wb_cyc_o <= '1' when state_q = S_FETCH or state_q = S_FETCH_ACK or state_q = S_FETCH_HI or state_q = S_FETCH_HI_ACK or state_q = S_LOAD or state_q = S_LOAD_ACK or state_q = S_LOAD_HI or state_q = S_LOAD_HI_ACK or state_q = S_STORE or state_q = S_STORE_ACK else '0';\n"
    l = l + "\n"
    l = l + "  process(clk)\n"
    l = l + "    variable r : regs_t;\n"
    l = l + "    variable word : std_logic_vector(63 downto 0);\n"
    l = l + "    variable ins : std_logic_vector(31 downto 0);\n"
    l = l + "    variable h : std_logic_vector(15 downto 0);\n"
    l = l + "    variable op : std_logic_vector(6 downto 0);\n"
    l = l + "    variable rd : natural range 0 to 31;\n"
    l = l + "    variable rs1 : natural range 0 to 31;\n"
    l = l + "    variable rs2 : natural range 0 to 31;\n"
    l = l + "    variable imm12 : unsigned(63 downto 0);\n"
    l = l + "    variable target : unsigned(63 downto 0);\n"
    l = l + "    variable eff_addr : unsigned(63 downto 0);\n"
    l = l + "    variable byte_lane : natural range 0 to 7;\n"
    l = l + "  begin\n"
    l = l + "    if rising_edge(clk) then\n"
    l = l + "      if rst = '1' then\n"
    l = l + "        pc_q    <= x\"0000000080000000\";\n"
    l = l + "        regs_q  <= (2 => x\"0000000080072bf0\", others => (others => '0'));\n"
    l = l + "        state_q <= S_FETCH;\n"
    l = l + "        instr_q <= (others => '0');\n"
    l = l + "        instr_cross_q <= '0';\n"
    l = l + "      else\n"
    l = l + "        r := regs_q;\n"
    l = l + "        case state_q is\n"
    l = l + "          when S_FETCH =>\n"
    l = l + "            state_q <= S_FETCH_ACK;\n"
    l = l + "          when S_FETCH_ACK =>\n"
    l = l + "            if wb_ack_i = '1' then\n"
    l = l + "              if pc_q(2 downto 1) = \"11\" and wb_dat_i(49 downto 48) = \"11\" then\n"
    l = l + "                fetch_low_q <= wb_dat_i; mem_addr_q <= pc_q + 2; state_q <= S_FETCH_HI;\n"
    l = l + "              else\n"
    l = l + "                instr_q <= wb_dat_i; instr_cross_q <= '0'; state_q <= S_EXEC;\n"
    l = l + "              end if;\n"
    l = l + "            end if;\n"
    l = l + "          when S_FETCH_HI =>\n"
    l = l + "            state_q <= S_FETCH_HI_ACK;\n"
    l = l + "          when S_FETCH_HI_ACK =>\n"
    l = l + "            if wb_ack_i = '1' then\n"
    l = l + "              instr_q <= x\"00000000\" & wb_dat_i(15 downto 0) & fetch_low_q(63 downto 48); instr_cross_q <= '1'; state_q <= S_EXEC;\n"
    l = l + "            end if;\n"
    l = l + "          when S_LOAD =>\n"
    l = l + "            state_q <= S_LOAD_ACK;\n"
    l = l + "          when S_LOAD_ACK =>\n"
    l = l + "            if wb_ack_i = '1' then\n"
    l = l + "            if mem_is_byte_q = '1' then\n"
    l = l + "              if mem_rd_q /= 0 then\n"
    l = l + "                byte_lane := to_integer(mem_addr_q(2 downto 0));\n"
    l = l + "                r(mem_rd_q) := resize(unsigned(wb_dat_i(byte_lane * 8 + 7 downto byte_lane * 8)), 64);\n"
    l = l + "              end if;\n"
    l = l + "              r(0) := (others => '0'); regs_q <= r; state_q <= S_FETCH;\n"
    l = l + "            elsif mem_addr_q(2) = '1' and mem_addr_q(1 downto 0) = \"00\" then\n"
    l = l + "              load_low_q <= wb_dat_i; mem_addr_q <= mem_addr_q + 4; state_q <= S_LOAD_HI;\n"
    l = l + "            else\n"
    l = l + "              if mem_rd_q /= 0 then r(mem_rd_q) := zext64(wb_dat_i); end if;\n"
    l = l + "              r(0) := (others => '0'); regs_q <= r; state_q <= S_FETCH;\n"
    l = l + "            end if;\n"
    l = l + "            end if;\n"
    l = l + "          when S_LOAD_HI =>\n"
    l = l + "            state_q <= S_LOAD_HI_ACK;\n"
    l = l + "          when S_LOAD_HI_ACK =>\n"
    l = l + "            if wb_ack_i = '1' then\n"
    l = l + "              if mem_rd_q /= 0 then r(mem_rd_q) := unsigned(wb_dat_i(31 downto 0) & load_low_q(63 downto 32)); end if;\n"
    l = l + "              r(0) := (others => '0'); regs_q <= r; state_q <= S_FETCH;\n"
    l = l + "            end if;\n"
    l = l + "          when S_STORE =>\n"
    l = l + "            state_q <= S_STORE_ACK;\n"
    l = l + "          when S_STORE_ACK =>\n"
    l = l + "            if wb_ack_i = '1' then\n"
    l = l + "            state_q <= S_FETCH;\n"
    l = l + "            end if;\n"
    l = l + "          when S_EXEC =>\n"
    l = l + "            word := instr_q;\n"
    l = l + "            state_q <= S_FETCH;\n"
    l = l + "            case pc_q(2 downto 1) is\n"
    l = l + "              when \"00\" => h := word(15 downto 0);\n"
    l = l + "              when \"01\" => h := word(31 downto 16);\n"
    l = l + "              when \"10\" => h := word(47 downto 32);\n"
    l = l + "              when others => h := word(63 downto 48);\n"
    l = l + "            end case;\n"
    l = l + "            if instr_cross_q = '1' then h := x\"0003\"; end if;\n"
    l = l + "            if h(1 downto 0) /= \"11\" then\n"
    l = l + "              if h(1 downto 0) = \"00\" and h(15 downto 13) = \"000\" then\n"
    l = l + "                rd := 8 + to_integer(unsigned(h(4 downto 2)));\n"
    l = l + "                r(rd) := r(2) + c_addi4spn_imm(h);\n"
    l = l + "                pc_q <= pc_q + 2;\n"
    l = l + "              elsif h(1 downto 0) = \"01\" and h(15 downto 13) = \"000\" then\n"
    l = l + "                rd := to_integer(unsigned(h(11 downto 7)));\n"
    l = l + "                if rd /= 0 then r(rd) := r(rd) + c_addi_imm(h); end if;\n"
    l = l + "                pc_q <= pc_q + 2;\n"
    l = l + "              elsif h(1 downto 0) = \"01\" and h(15 downto 13) = \"011\" and h(11 downto 7) = \"00010\" then\n"
    l = l + "                r(2) := r(2) + c_addi16sp_imm(h);\n"
    l = l + "                pc_q <= pc_q + 2;\n"
    l = l + "              elsif h = x\"8082\" then\n"
    l = l + "                pc_q <= r(1);\n"
    l = l + "              elsif h(1 downto 0) = \"10\" and h(15 downto 13) = \"011\" then\n"
    l = l + "                rd := to_integer(unsigned(h(11 downto 7)));\n"
    l = l + "                mem_addr_q <= r(2) + c_ldsp_imm(h); mem_rd_q <= rd; mem_is_byte_q <= '0'; pc_q <= pc_q + 2; state_q <= S_LOAD;\n"
    l = l + "              elsif h(1 downto 0) = \"10\" and h(15 downto 13) = \"111\" then\n"
    l = l + "                rs2 := to_integer(unsigned(h(6 downto 2)));\n"
    l = l + "                mem_addr_q <= r(2) + c_sdsp_imm(h); mem_wdata_q <= std_logic_vector(r(rs2)); mem_sel_q <= (others => '1'); pc_q <= pc_q + 2; state_q <= S_STORE;\n"
    l = l + "              else\n"
    l = l + "                pc_q <= pc_q + 2;\n"
    l = l + "              end if;\n"
    l = l + "            else\n"
    l = l + "              if instr_cross_q = '1' then\n"
    l = l + "                ins := word(31 downto 0);\n"
    l = l + "              else\n"
    l = l + "              case pc_q(2 downto 1) is\n"
    l = l + "                when \"00\" => ins := word(31 downto 0);\n"
    l = l + "                when \"01\" => ins := word(47 downto 16);\n"
    l = l + "                when others => ins := word(63 downto 32);\n"
    l = l + "              end case;\n"
    l = l + "              end if;\n"
    l = l + "              op := ins(6 downto 0); rd := to_integer(unsigned(ins(11 downto 7))); rs1 := to_integer(unsigned(ins(19 downto 15))); rs2 := to_integer(unsigned(ins(24 downto 20)));\n"
    l = l + "              if op = \"0010011\" then\n"
    l = l + "                if rd /= 0 then r(rd) := r(rs1) + sext12(ins(31 downto 20)); end if; pc_q <= pc_q + 4;\n"
    l = l + "              elsif op = \"0010111\" then\n"
    l = l + "                if rd /= 0 then r(rd) := pc_q + unsigned(resize(signed(ins(31 downto 12) & x\"000\"), 64)); end if; pc_q <= pc_q + 4;\n"
    l = l + "              elsif op = \"0110111\" then\n"
    l = l + "                if rd /= 0 then r(rd) := unsigned(resize(signed(ins(31 downto 12) & x\"000\"), 64)); end if; pc_q <= pc_q + 4;\n"
    l = l + "              elsif op = \"1101111\" then\n"
    l = l + "                target := pc_q + sext21(ins(31) & ins(19 downto 12) & ins(20) & ins(30 downto 21) & '0');\n"
    l = l + "                if rd /= 0 then r(rd) := pc_q + 4; end if; pc_q <= target;\n"
    l = l + "              elsif op = \"1100111\" then\n"
    l = l + "                target := (r(rs1) + sext12(ins(31 downto 20))) and not to_unsigned(1, 64);\n"
    l = l + "                if rd /= 0 then r(rd) := pc_q + 4; end if; pc_q <= target;\n"
    l = l + "              elsif op = \"0000011\" then\n"
    l = l + "                mem_addr_q <= r(rs1) + sext12(ins(31 downto 20)); mem_rd_q <= rd;\n"
    l = l + "                if ins(14 downto 12) = \"100\" then mem_is_byte_q <= '1'; else mem_is_byte_q <= '0'; end if;\n"
    l = l + "                pc_q <= pc_q + 4; state_q <= S_LOAD;\n"
    l = l + "              elsif op = \"0100011\" then\n"
    l = l + "                imm12 := sext12(ins(31 downto 25) & ins(11 downto 7)); eff_addr := r(rs1) + imm12; mem_addr_q <= eff_addr; byte_lane := to_integer(eff_addr(2 downto 0));\n"
    l = l + "                if ins(14 downto 12) = \"000\" then mem_wdata_q <= (others => '0'); mem_wdata_q(byte_lane * 8 + 7 downto byte_lane * 8) <= std_logic_vector(r(rs2)(7 downto 0)); mem_sel_q <= std_logic_vector(shift_left(to_unsigned(1, 8), byte_lane));\n"
    l = l + "                else mem_wdata_q <= std_logic_vector(r(rs2)); mem_sel_q <= (others => '1'); end if; pc_q <= pc_q + 4; state_q <= S_STORE;\n"
    l = l + "              elsif op = \"1100011\" then\n"
    l = l + "                target := pc_q + sext13(ins(31) & ins(7) & ins(30 downto 25) & ins(11 downto 8) & '0');\n"
    l = l + "                if (ins(14 downto 12) = \"000\" and r(rs1) = r(rs2)) or (ins(14 downto 12) = \"001\" and r(rs1) /= r(rs2)) or (ins(14 downto 12) = \"111\" and r(rs1) >= r(rs2)) then pc_q <= target; else pc_q <= pc_q + 4; end if;\n"
    l = l + "              elsif op = \"1110011\" then\n"
    l = l + "                if rd /= 0 then r(rd) := (others => '0'); end if; pc_q <= pc_q + 4;\n"
    l = l + "              else\n"
    l = l + "                pc_q <= pc_q + 4;\n"
    l = l + "              end if;\n"
    l = l + "            end if;\n"
    l = l + "            r(0) := (others => '0'); regs_q <= r;\n"
    l = l + "        end case;\n"
    l = l + "      end if;\n"
    l = l + "    end if;\n"
    l = l + "  end process;\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_clint_stub() -> text:
    var l = vhdl_header()
    l = l + "\nentity clint is\n  port (\n"
    l = l + "    clk      : in  std_logic;\n"
    l = l + "    rst      : in  std_logic;\n"
    l = l + "    wb_adr   : in  std_logic_vector(15 downto 0);\n"
    l = l + "    wb_dat_i : in  std_logic_vector(63 downto 0);\n"
    l = l + "    wb_dat_o : out std_logic_vector(63 downto 0);\n"
    l = l + "    wb_we    : in  std_logic;\n"
    l = l + "    wb_stb   : in  std_logic;\n"
    l = l + "    wb_ack   : out std_logic;\n"
    l = l + "    msip_o   : out std_logic;\n"
    l = l + "    mtip_o   : out std_logic\n"
    l = l + "  );\nend entity clint;\n\n"
    l = l + "architecture rtl of clint is\nbegin\n"
    l = l + "  wb_dat_o <= (others => '0');\n"
    l = l + "  wb_ack   <= '0';\n"
    l = l + "  msip_o   <= '0';\n"
    l = l + "  mtip_o   <= '0';\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_plic_stub() -> text:
    var l = vhdl_header()
    l = l + "\nentity plic is\n  port (\n"
    l = l + "    clk         : in  std_logic;\n"
    l = l + "    rst         : in  std_logic;\n"
    l = l + "    wb_adr      : in  std_logic_vector(23 downto 0);\n"
    l = l + "    wb_dat_i    : in  std_logic_vector(63 downto 0);\n"
    l = l + "    wb_dat_o    : out std_logic_vector(63 downto 0);\n"
    l = l + "    wb_we       : in  std_logic;\n"
    l = l + "    wb_stb      : in  std_logic;\n"
    l = l + "    wb_ack      : out std_logic;\n"
    l = l + "    irq_sources : in  std_logic_vector(0 downto 0)\n"
    l = l + "  );\nend entity plic;\n\n"
    l = l + "architecture rtl of plic is\nbegin\n"
    l = l + "  wb_dat_o <= (others => '0');\n"
    l = l + "  wb_ack   <= '0';\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_uart_stub() -> text:
    var l = vhdl_header()
    l = l + "\nentity uart is\n"
    l = l + "  generic (\n"
    l = l + "    CLK_FREQ  : natural := 100000000;\n"
    l = l + "    BAUD_RATE : natural := 115200\n"
    l = l + "  );\n"
    l = l + "  port (\n"
    l = l + "    clk      : in  std_logic;\n"
    l = l + "    rst      : in  std_logic;\n"
    l = l + "    wb_adr   : in  std_logic_vector(4 downto 0);\n"
    l = l + "    wb_dat_i : in  std_logic_vector(7 downto 0);\n"
    l = l + "    wb_dat_o : out std_logic_vector(7 downto 0);\n"
    l = l + "    wb_we    : in  std_logic;\n"
    l = l + "    wb_stb   : in  std_logic;\n"
    l = l + "    wb_ack   : out std_logic;\n"
    l = l + "    tx       : out std_logic;\n"
    l = l + "    rx       : in  std_logic;\n"
    l = l + "    irq      : out std_logic;\n"
    l = l + "    debug_uart_valid : out std_logic;\n"
    l = l + "    debug_uart_byte  : out std_logic_vector(7 downto 0)\n"
    l = l + "  );\nend entity uart;\n\n"
    l = l + "architecture rtl of uart is\n"
    l = l + "  constant BAUD_DIV : natural := CLK_FREQ / BAUD_RATE;\n"
    l = l + "  signal tx_q      : std_logic := '1';\n"
    l = l + "  signal ack_q     : std_logic := '0';\n"
    l = l + "  signal busy_q    : std_logic := '0';\n"
    l = l + "  signal baud_cnt  : natural range 0 to CLK_FREQ := 0;\n"
    l = l + "  signal bit_count : natural range 0 to 10 := 0;\n"
    l = l + "  signal shreg     : std_logic_vector(9 downto 0) := (others => '1');\n"
    l = l + "  signal debug_uart_valid_q : std_logic := '0';\n"
    l = l + "  signal debug_uart_valid_next_q : std_logic := '0';\n"
    l = l + "  signal debug_uart_byte_q  : std_logic_vector(7 downto 0) := (others => '0');\n"
    l = l + "begin\n"
    l = l + "  wb_dat_o <= \"0000000\" & busy_q;\n"
    l = l + "  wb_ack   <= ack_q;\n"
    l = l + "  tx       <= tx_q;\n"
    l = l + "  irq      <= '0';\n"
    l = l + "  debug_uart_valid <= debug_uart_valid_q;\n"
    l = l + "  debug_uart_byte <= debug_uart_byte_q;\n"
    l = l + "  process(clk)\n"
    l = l + "  begin\n"
    l = l + "    if rising_edge(clk) then\n"
    l = l + "      ack_q <= '0';\n"
    l = l + "      debug_uart_valid_q <= debug_uart_valid_next_q;\n"
    l = l + "      debug_uart_valid_next_q <= '0';\n"
    l = l + "      if rst = '1' then\n"
    l = l + "        tx_q <= '1'; ack_q <= '0'; busy_q <= '0'; baud_cnt <= 0; bit_count <= 0; shreg <= (others => '1'); debug_uart_valid_q <= '0'; debug_uart_valid_next_q <= '0'; debug_uart_byte_q <= (others => '0');\n"
    l = l + "      else\n"
    l = l + "        if busy_q = '1' then\n"
    l = l + "          if baud_cnt >= BAUD_DIV - 1 then\n"
    l = l + "            baud_cnt <= 0;\n"
    l = l + "            if bit_count > 1 then\n"
    l = l + "              tx_q <= shreg(1); shreg <= '1' & shreg(9 downto 1); bit_count <= bit_count - 1;\n"
    l = l + "            else\n"
    l = l + "              tx_q <= '1'; busy_q <= '0'; bit_count <= 0;\n"
    l = l + "            end if;\n"
    l = l + "          else\n"
    l = l + "            baud_cnt <= baud_cnt + 1;\n"
    l = l + "          end if;\n"
    l = l + "        end if;\n"
    l = l + "        if wb_stb = '1' and (wb_we = '0' or busy_q = '0') then\n"
    l = l + "          ack_q <= '1';\n"
    l = l + "          if wb_we = '1' then\n"
    l = l + "            shreg <= '1' & wb_dat_i & '0'; tx_q <= '0'; busy_q <= '1'; bit_count <= 10; baud_cnt <= 0; debug_uart_valid_next_q <= '1'; debug_uart_byte_q <= wb_dat_i;\n"
    l = l + "          end if;\n"
    l = l + "        end if;\n"
    l = l + "      end if;\n"
    l = l + "    end if;\n"
    l = l + "  end process;\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_ram_stub() -> text:
    var l = vhdl_textio_header()
    l = l + "\nentity ram is\n"
    l = l + "  generic (\n    ADDR_WIDTH : natural := 24\n  );\n"
    l = l + "  port (\n"
    l = l + "    clk      : in  std_logic;\n"
    l = l + "    wb_adr   : in  std_logic_vector(ADDR_WIDTH - 1 downto 0);\n"
    l = l + "    wb_dat_i : in  std_logic_vector(63 downto 0);\n"
    l = l + "    wb_dat_o : out std_logic_vector(63 downto 0);\n"
    l = l + "    wb_we    : in  std_logic;\n"
    l = l + "    wb_sel   : in  std_logic_vector(7 downto 0);\n"
    l = l + "    wb_stb   : in  std_logic;\n"
    l = l + "    wb_ack   : out std_logic\n"
    l = l + "  );\nend entity ram;\n\n"
    l = l + "architecture rtl of ram is\n"
    l = l + "  constant DEPTH : natural := 2**(ADDR_WIDTH-3);\n"
    l = l + "  type ram_t is array(0 to DEPTH-1) of std_logic_vector(63 downto 0);\n"
    l = l + "  impure function init_ram return ram_t is\n"
    l = l + "    file f : text open read_mode is \"rv64_payload.mem\";\n"
    l = l + "    variable line_v : line;\n"
    l = l + "    variable word_v : std_logic_vector(63 downto 0);\n"
    l = l + "    variable mem_v : ram_t := (others => (others => '0'));\n"
    l = l + "    variable idx : natural := 0;\n"
    l = l + "  begin\n"
    l = l + "    while not endfile(f) loop\n"
    l = l + "      readline(f, line_v);\n"
    l = l + "      hread(line_v, word_v);\n"
    l = l + "      if idx < DEPTH then\n"
    l = l + "        mem_v(idx) := word_v;\n"
    l = l + "      end if;\n"
    l = l + "      idx := idx + 1;\n"
    l = l + "    end loop;\n"
    l = l + "    return mem_v;\n"
    l = l + "  end function;\n"
    l = l + "  signal mem : ram_t := init_ram;\n"
    l = l + "  signal ack_q : std_logic := '0';\n"
    l = l + "  signal stb_q : std_logic := '0';\n"
    l = l + "begin\n"
    l = l + "  wb_ack <= ack_q;\n"
    l = l + "  process(clk)\n"
    l = l + "    variable idx : natural range 0 to DEPTH-1;\n"
    l = l + "  begin\n"
    l = l + "    if rising_edge(clk) then\n"
    l = l + "      ack_q <= stb_q;\n"
    l = l + "      stb_q <= wb_stb;\n"
    l = l + "      idx := to_integer(unsigned(wb_adr(ADDR_WIDTH - 1 downto 3)));\n"
    l = l + "      wb_dat_o <= mem(idx);\n"
    l = l + "      if wb_stb = '1' and wb_we = '1' then\n"
    l = l + "        for i in 0 to 7 loop\n"
    l = l + "          if wb_sel(i) = '1' then\n"
    l = l + "            mem(idx)(i * 8 + 7 downto i * 8) <= wb_dat_i(i * 8 + 7 downto i * 8);\n"
    l = l + "          end if;\n"
    l = l + "        end loop;\n"
    l = l + "      end if;\n"
    l = l + "    end if;\n"
    l = l + "  end process;\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_k26_top() -> text:
    var l = "library ieee;\nuse ieee.std_logic_1164.all;\nuse ieee.numeric_std.all;\nlibrary unisim;\nuse unisim.vcomponents.all;\n\n"
    l = l + "entity soc_top_rv64_k26 is\n"
    l = l + "  generic (\n"
    l = l + "    RESET_RELEASE_COUNT : natural := 255\n"
    l = l + "  );\n"
    l = l + "  port (\n"
    l = l + "    uart_tx : out std_logic\n"
    l = l + "  );\n"
    l = l + "end entity soc_top_rv64_k26;\n\n"
    l = l + "architecture rtl of soc_top_rv64_k26 is\n"
    l = l + "  signal cfgclk  : std_logic;\n"
    l = l + "  signal cfgmclk : std_logic;\n"
    l = l + "  signal di      : std_logic_vector(3 downto 0);\n"
    l = l + "  signal eos     : std_logic;\n"
    l = l + "  signal preq    : std_logic;\n"
    l = l + "  signal rst_q   : std_logic := '1';\n"
    l = l + "  signal rst_cnt : unsigned(31 downto 0) := (others => '0');\n"
    l = l + "  signal uart_tx_core : std_logic;\n"
    l = l + "  signal debug_uart_valid : std_logic;\n"
    l = l + "  signal debug_uart_byte : std_logic_vector(7 downto 0);\n"
    l = l + "  signal marker_idx : natural range 0 to 17 := 0;\n"
    l = l + "  signal marker_seen : std_logic := '0';\n"
    l = l + "  signal uart_ila_probe : std_logic_vector(9 downto 0);\n"
    l = l + "  function marker_byte(idx : natural) return std_logic_vector is\n"
    l = l + "  begin\n"
    l = l + "    case idx is\n"
    l = l + "      when 0 => return x\"53\"; when 1 => return x\"69\"; when 2 => return x\"6D\"; when 3 => return x\"70\";\n"
    l = l + "      when 4 => return x\"6C\"; when 5 => return x\"65\"; when 6 => return x\"4F\"; when 7 => return x\"53\";\n"
    l = l + "      when 8 => return x\"20\"; when 9 => return x\"52\"; when 10 => return x\"56\"; when 11 => return x\"36\";\n"
    l = l + "      when 12 => return x\"34\"; when 13 => return x\"20\"; when 14 => return x\"46\"; when 15 => return x\"50\";\n"
    l = l + "      when 16 => return x\"47\"; when others => return x\"41\";\n"
    l = l + "    end case;\n"
    l = l + "  end function;\n"
    l = l + "  attribute dont_touch : string;\n"
    l = l + "  attribute mark_debug : string;\n"
    l = l + "  attribute dont_touch of uart_tx_core : signal is \"true\";\n"
    l = l + "  attribute mark_debug of uart_tx_core : signal is \"true\";\n"
    l = l + "  attribute dont_touch of uart_ila_probe : signal is \"true\";\n"
    l = l + "  attribute mark_debug of uart_ila_probe : signal is \"true\";\n"
    l = l + "begin\n"
    l = l + "  uart_tx <= uart_tx_core;\n"
    l = l + "  uart_ila_probe <= marker_seen & debug_uart_valid & debug_uart_byte;\n"
    l = l + "  u_startup : STARTUPE3\n"
    l = l + "    generic map (PROG_USR => \"FALSE\", SIM_CCLK_FREQ => 0.0)\n"
    l = l + "    port map (\n"
    l = l + "      CFGCLK => cfgclk, CFGMCLK => cfgmclk, DI => di, EOS => eos, PREQ => preq,\n"
    l = l + "      DO => \"0000\", DTS => \"1111\", FCSBO => '1', FCSBTS => '1', GSR => '0', GTS => '0',\n"
    l = l + "      KEYCLEARB => '1', PACK => '0', USRCCLKO => '0', USRCCLKTS => '1',\n"
    l = l + "      USRDONEO => '1', USRDONETS => '1'\n"
    l = l + "    );\n\n"
    l = l + "  process(cfgmclk)\n"
    l = l + "  begin\n"
    l = l + "    if rising_edge(cfgmclk) then\n"
    l = l + "      if rst_cnt < to_unsigned(RESET_RELEASE_COUNT, rst_cnt'length) then rst_cnt <= rst_cnt + 1; rst_q <= '1'; else rst_q <= '0'; end if;\n"
    l = l + "    end if;\n"
    l = l + "  end process;\n\n"
    l = l + "  process(cfgmclk)\n"
    l = l + "  begin\n"
    l = l + "    if rising_edge(cfgmclk) then\n"
    l = l + "      if rst_q = '1' then marker_idx <= 0; marker_seen <= '0';\n"
    l = l + "      elsif debug_uart_valid = '1' then\n"
    l = l + "        if debug_uart_byte = marker_byte(marker_idx) then\n"
    l = l + "          if marker_idx = 17 then marker_seen <= '1'; marker_idx <= 0; else marker_idx <= marker_idx + 1; end if;\n"
    l = l + "        elsif debug_uart_byte = marker_byte(0) then marker_idx <= 1;\n"
    l = l + "        else marker_idx <= 0;\n"
    l = l + "        end if;\n"
    l = l + "      end if;\n"
    l = l + "    end if;\n"
    l = l + "  end process;\n\n"
    l = l + "  u_soc : entity work.soc_top_rv64\n"
    l = l + "    port map (\n"
    l = l + "      clk => cfgmclk, rst => rst_q, uart_tx => uart_tx_core, uart_rx => '1',\n"
    l = l + "      debug_uart_valid => debug_uart_valid,\n"
    l = l + "      debug_uart_byte => debug_uart_byte\n"
    l = l + "    );\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_bootrom_stub() -> text:
    var l = vhdl_header()
    l = l + "\nentity bootrom is\n  port (\n"
    l = l + "    clk      : in  std_logic;\n"
    l = l + "    wb_adr   : in  std_logic_vector(11 downto 0);\n"
    l = l + "    wb_dat_o : out std_logic_vector(63 downto 0);\n"
    l = l + "    wb_stb   : in  std_logic\n"
    l = l + "  );\nend entity bootrom;\n\n"
    l = l + "architecture rtl of bootrom is\nbegin\n"
    l = l + "  wb_dat_o <= (others => '0');\n"
    l = l + "end architecture rtl;\n"
    l

fn gen_wb_interconnect_stub() -> text:
    var l = vhdl_header()
    l = l + "\nentity wb_interconnect is\n  port (\n"
    l = l + "    m_adr   : in  std_logic_vector(63 downto 0);\n"
    l = l + "    m_dat_o : in  std_logic_vector(63 downto 0);\n"
    l = l + "    m_dat_i : out std_logic_vector(63 downto 0);\n"
    l = l + "    m_we    : in  std_logic;\n"
    l = l + "    m_sel   : in  std_logic_vector(7 downto 0);\n"
    l = l + "    m_stb   : in  std_logic;\n"
    l = l + "    m_cyc   : in  std_logic;\n"
    l = l + "    m_ack   : out std_logic;\n"
    l = l + "    s0_dat  : in  std_logic_vector(63 downto 0);\n"
    l = l + "    s0_stb  : out std_logic;\n"
    l = l + "    s1_dat  : in  std_logic_vector(63 downto 0);\n"
    l = l + "    s1_stb  : out std_logic;\n"
    l = l + "    s1_ack  : in  std_logic;\n"
    l = l + "    s2_dat  : in  std_logic_vector(63 downto 0);\n"
    l = l + "    s2_stb  : out std_logic;\n"
    l = l + "    s2_ack  : in  std_logic;\n"
    l = l + "    s3_dat  : in  std_logic_vector(63 downto 0);\n"
    l = l + "    s3_stb  : out std_logic;\n"
    l = l + "    s3_ack  : in  std_logic;\n"
    l = l + "    s4_dat  : in  std_logic_vector(63 downto 0);\n"
    l = l + "    s4_stb  : out std_logic;\n"
    l = l + "    s4_ack  : in  std_logic\n"
    l = l + "  );\nend entity wb_interconnect;\n\n"
    l = l + "architecture rtl of wb_interconnect is\n"
    l = l + "  signal sel_bootrom : std_logic;\n"
    l = l + "  signal sel_clint   : std_logic;\n"
    l = l + "  signal sel_plic    : std_logic;\n"
    l = l + "  signal sel_uart    : std_logic;\n"
    l = l + "  signal sel_ram     : std_logic;\n"
    l = l + "begin\n"
    l = l + "  sel_bootrom <= '1' when m_adr(31 downto 12) = x\"00001\" else '0';\n"
    l = l + "  sel_clint   <= '1' when m_adr(31 downto 16) = x\"0200\" else '0';\n"
    l = l + "  sel_plic    <= '1' when m_adr(31 downto 24) = x\"0C\" else '0';\n"
    l = l + "  sel_uart    <= '1' when m_adr(31 downto 8) = x\"100000\" else '0';\n"
    l = l + "  sel_ram     <= '1' when m_adr(31) = '1' else '0';\n"
    l = l + "\n"
    l = l + "  s0_stb <= m_stb and m_cyc and sel_bootrom;\n"
    l = l + "  s1_stb <= m_stb and m_cyc and sel_clint;\n"
    l = l + "  s2_stb <= m_stb and m_cyc and sel_plic;\n"
    l = l + "  s3_stb <= m_stb and m_cyc and sel_uart;\n"
    l = l + "  s4_stb <= m_stb and m_cyc and sel_ram;\n"
    l = l + "\n"
    l = l + "  m_dat_i <= s0_dat when sel_bootrom = '1' else\n"
    l = l + "             s1_dat when sel_clint = '1' else\n"
    l = l + "             s2_dat when sel_plic = '1' else\n"
    l = l + "             s3_dat when sel_uart = '1' else\n"
    l = l + "             s4_dat when sel_ram = '1' else\n"
    l = l + "             (others => '0');\n"
    l = l + "  m_ack <= (m_stb and m_cyc and sel_bootrom) or\n"
    l = l + "           (s1_ack and sel_clint) or\n"
    l = l + "           (s2_ack and sel_plic) or\n"
    l = l + "           (s3_ack and sel_uart) or\n"
    l = l + "           (s4_ack and sel_ram);\n"
    l = l + "end architecture rtl;\n"
    l

fn write_vhd(out_dir: text, name: text, content: text) -> bool:
    val path = "{out_dir}/{name}.vhd"
    val ok = rt_file_write_text(path, content)
    if ok:
        print("  OK: {name}.vhd ({content.length()} chars)")
    else:
        print("  FAIL: {name}.vhd")
    ok

fn main():
    val out_dir = "build/vhdl/rv64"
    rt_dir_create(out_dir)

    # Generate SoC top-level
    print("Generating soc_top_rv64.vhd...")
    val soc_top = generate_soc_top_vhdl_rv64()
    write_vhd(out_dir, "soc_top_rv64", soc_top)
    write_vhd(out_dir, "soc_top_rv64_k26", gen_k26_top())

    # Per-module RTL-to-VHDL compilation: no compiler backend exists yet
    # (no `compile_to_vhdl_module` anywhere in src/). Report honestly instead
    # of calling a phantom API.
    print("Generating RTL module stubs...")
    val modules = [
        "pkg", "alu", "regfile", "csr_s", "csr",
        "decode", "lsu", "mmu_sv39", "mul_div", "atomics", "trap"
    ]

    for mod_name in modules:
        print("  SKIPPED: {mod_name}.vhd (no .spl-to-VHDL compiler backend)")

    # Generate rv64gc_core executor (entity name matches soc_top port map)
    print("Generating rv64gc_core executor...")
    write_vhd(out_dir, "rv64gc_core", gen_rv64gc_core())

    # Generate peripheral stubs
    print("Generating peripheral stubs...")
    write_vhd(out_dir, "clint", gen_clint_stub())
    write_vhd(out_dir, "plic", gen_plic_stub())
    write_vhd(out_dir, "uart", gen_uart_stub())
    write_vhd(out_dir, "ram", gen_ram_stub())
    write_vhd(out_dir, "bootrom", gen_bootrom_stub())
    write_vhd(out_dir, "wb_interconnect", gen_wb_interconnect_stub())

    val skipped_count = modules.length()
    print("")
    print("Generated 9 VHDL files (soc tops + core + peripherals); {skipped_count} RTL module stubs SKIPPED (no compiler backend)")
