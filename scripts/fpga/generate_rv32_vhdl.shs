#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-bin/release/simple}"
OUT_DIR="build/vhdl/rv32"
RV32_PAYLOAD_BIN="${RV32_PAYLOAD_BIN:-build/rv32_bringup_check/hello_litex_rv32.bin}"
RTL_TEMPLATE_DIR="examples/09_embedded/fpga_riscv/rtl"

mkdir -p "$OUT_DIR"
"$SIMPLE_BINARY" run scripts/fpga/rv32_vhdl_driver.spl || driver_status=$?
if [ -s "$OUT_DIR/rv32_core.spl" ]; then
    "$SIMPLE_BINARY" compile --backend=vhdl "$OUT_DIR/rv32_core.spl" -o "$OUT_DIR/rv32_core.vhd"
fi

cp "$RTL_TEMPLATE_DIR/rv32_exec_core.vhd" "$OUT_DIR/rv32_exec_core.vhd"
cp "$RTL_TEMPLATE_DIR/soc_top_rv32_sim.vhd" "$OUT_DIR/soc_top_rv32_sim.vhd"
cp "$RTL_TEMPLATE_DIR/soc_top_rv32.vhd" "$OUT_DIR/soc_top_rv32.vhd"

count="$(find "$OUT_DIR" -name '*.vhd' 2>/dev/null | wc -l | tr -d ' ')"
printf 'generated_rv32_vhdl_files=%s\n' "$count"

for path in "$OUT_DIR/rv32i_pkg.vhd" "$OUT_DIR/rv32i_decode.vhd" "$OUT_DIR/rv32i_regfile.vhd" "$OUT_DIR/rv32_core.vhd" "$OUT_DIR/rv32_exec_core.vhd" "$OUT_DIR/soc_top_rv32.vhd" "$OUT_DIR/soc_top_rv32_sim.vhd"; do
    if [ ! -s "$path" ]; then
        printf 'ERROR missing generated RV32 VHDL: %s\n' "$path" >&2
        exit "${driver_status:-1}"
    fi
done

if ! grep -q 'entity rv32i_regfile is' "$OUT_DIR/rv32i_regfile.vhd"; then
    printf 'ERROR generated RV32 register file is invalid\n' >&2
    exit 1
fi

if ! grep -q 'entity simple_rv32i_core_decode_writeback is' "$OUT_DIR/rv32_core.vhd"; then
    printf 'ERROR generated RV32 core helper VHDL is invalid\n' >&2
    exit 1
fi

if [ -f "$RV32_PAYLOAD_BIN" ]; then
    od -An -v -tx4 -w4 "$RV32_PAYLOAD_BIN" | tr -d ' ' | awk 'NF { print }' >"$OUT_DIR/rv32_payload.mem"
    printf 'rv32_payload_mem=%s words=%s\n' "$OUT_DIR/rv32_payload.mem" "$(wc -l <"$OUT_DIR/rv32_payload.mem" | tr -d ' ')"
else
    printf 'WARNING: RV32 payload binary missing, preload not generated: %s\n' "$RV32_PAYLOAD_BIN" >&2
fi
