#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BINARY="${SIMPLE_BINARY:-bin/release/simple}"
OUT_DIR="build/vhdl/rv32"

mkdir -p "$OUT_DIR"
"$SIMPLE_BINARY" run scripts/fpga/rv32_vhdl_driver.spl || driver_status=$?

count="$(find "$OUT_DIR" -name '*.vhd' 2>/dev/null | wc -l | tr -d ' ')"
printf 'generated_rv32_vhdl_files=%s\n' "$count"

for path in "$OUT_DIR/rv32i_pkg.vhd" "$OUT_DIR/rv32i_decode.vhd" "$OUT_DIR/rv32i_regfile.vhd"; do
    if [ ! -s "$path" ]; then
        printf 'ERROR missing generated RV32 VHDL: %s\n' "$path" >&2
        exit "${driver_status:-1}"
    fi
done

if ! grep -q 'entity rv32i_regfile is' "$OUT_DIR/rv32i_regfile.vhd"; then
    printf 'ERROR generated RV32 register file is invalid\n' >&2
    exit 1
fi
