#!/bin/sh
# Deploy Simple Language plugins/extensions to all marketplaces.
#
# Usage:
#   scripts/deploy-marketplaces.shs                  # Show status of all
#   scripts/deploy-marketplaces.shs all              # Deploy to all markets
#   scripts/deploy-marketplaces.shs npm              # npm publish only
#   scripts/deploy-marketplaces.shs mcp-registry     # MCP Registry only
#   scripts/deploy-marketplaces.shs gemini           # Gemini CLI extension
#   scripts/deploy-marketplaces.shs claude           # Claude plugin marketplace
#   scripts/deploy-marketplaces.shs codex            # Codex plugin catalog
#   scripts/deploy-marketplaces.shs github-release   # Create GitHub Release with binaries
#   scripts/deploy-marketplaces.shs --check          # Check prerequisites
#   scripts/deploy-marketplaces.shs --dry-run all    # Show what would happen
#
# Prerequisites:
#   npm login                        (npm + MCP Registry)
#   gh auth login                    (GitHub Release + Gemini + Claude + Codex)
#   bin/simple build --release       (platform binaries)
#   sh scripts/check-core-runtime-smoke.shs <runtime>      (compiler/core/lib changes)
#   SIMPLE_BINARY=<runtime> sh scripts/check-mcp-native-smoke.shs
#   sh scripts/check-mcp-package-smoke.shs                 (before npm/plugin publish)
#
# See: MCP.md and doc/07_guide/tooling/ai_cli_registration.md

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

# --- Config ---
REPO="ormastes/simple"
NPM_SCOPE="@simple-lang"
NPM_PACKAGE="${NPM_SCOPE}/mcp-server"
VERSION=""
DRY_RUN=false

# Colors (if terminal supports it)
if [ -t 1 ]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; NC=''
fi

ok()   { printf "${GREEN}[OK]${NC} %s\n" "$1"; }
warn() { printf "${YELLOW}[WARN]${NC} %s\n" "$1"; }
fail() { printf "${RED}[FAIL]${NC} %s\n" "$1"; }
info() { printf "${BLUE}[INFO]${NC} %s\n" "$1"; }

find_release_assets() {
    for FILE in \
        "$PROJECT_ROOT"/bin/release/*/simple \
        "$PROJECT_ROOT"/bin/release/*/simple.exe \
        "$PROJECT_ROOT"/bin/release/*/simple_mcp_server \
        "$PROJECT_ROOT"/bin/release/*/simple_mcp_server.exe \
        "$PROJECT_ROOT"/bin/release/*/simple_lsp_mcp_server \
        "$PROJECT_ROOT"/bin/release/*/simple_lsp_mcp_server.exe \
        "$PROJECT_ROOT"/bin/release/*/t32_mcp_server \
        "$PROJECT_ROOT"/bin/release/*/t32_mcp_server.exe \
        "$PROJECT_ROOT"/bin/release/*/t32_lsp_mcp_server \
        "$PROJECT_ROOT"/bin/release/*/t32_lsp_mcp_server.exe
    do
        [ -f "$FILE" ] || continue
        printf '%s\n' "${FILE#${PROJECT_ROOT}/}"
    done | sort -u
}

# --- Version detection ---
detect_version() {
    if [ -f "$PROJECT_ROOT/VERSION" ]; then
        VERSION="$(cat "$PROJECT_ROOT/VERSION" | tr -d '[:space:]')"
    elif [ -f "$PROJECT_ROOT/gemini-extension.json" ]; then
        VERSION="$(sed -n 's/.*"version": *"\([^"]*\)".*/\1/p' "$PROJECT_ROOT/gemini-extension.json" | head -n 1)"
    fi
    if [ -z "$VERSION" ]; then
        fail "Cannot detect version. Create VERSION file or pass --version."
        exit 1
    fi
    info "Version: $VERSION"
}

# --- Prerequisite checks ---
check_tool() {
    if command -v "$1" >/dev/null 2>&1; then
        ok "$1 found"
        return 0
    else
        fail "$1 not found"
        return 1
    fi
}

check_npm_auth() {
    if npm whoami >/dev/null 2>&1; then
        ok "npm authenticated as $(npm whoami)"
        return 0
    else
        fail "npm not authenticated — run: npm login"
        return 1
    fi
}

check_gh_auth() {
    if gh auth status >/dev/null 2>&1; then
        ok "gh authenticated"
        return 0
    else
        fail "gh not authenticated — run: gh auth login"
        return 1
    fi
}

check_repo_public() {
    VISIBILITY="$(gh repo view "$REPO" --json isPrivate -q '.isPrivate' 2>/dev/null || echo "unknown")"
    if [ "$VISIBILITY" = "false" ]; then
        ok "Repo $REPO is public"
        return 0
    elif [ "$VISIBILITY" = "true" ]; then
        fail "Repo $REPO is private — Gemini gallery requires public repo"
        return 1
    else
        warn "Cannot check repo visibility for $REPO"
        return 1
    fi
}

check_prerequisites() {
    info "Checking prerequisites..."
    ERRORS=0
    check_tool npm   || ERRORS=$((ERRORS + 1))
    check_tool gh    || ERRORS=$((ERRORS + 1))
    check_tool npx   || ERRORS=$((ERRORS + 1))
    check_tool jq    || warn "jq not found (optional, for JSON validation)"
    echo ""
    check_npm_auth   || ERRORS=$((ERRORS + 1))
    check_gh_auth    || ERRORS=$((ERRORS + 1))
    echo ""
    check_repo_public || ERRORS=$((ERRORS + 1))
    echo ""

    if find_release_assets | grep -q .; then
        ok "Release binary exists"
    else
        fail "No deployed release binaries — run: bin/simple build --release"
        ERRORS=$((ERRORS + 1))
    fi

    echo ""
    if [ "$ERRORS" -eq 0 ]; then
        ok "All prerequisites met"
    else
        fail "$ERRORS prerequisite(s) missing"
    fi
    return $ERRORS
}

# --- Deploy: GitHub Release ---
deploy_github_release() {
    info "=== GitHub Release v$VERSION ==="

    TAG="v$VERSION"

    # Check if release already exists
    if gh release view "$TAG" --repo "$REPO" >/dev/null 2>&1; then
        warn "Release $TAG already exists — skipping"
        return 0
    fi

    # Collect deployed platform binaries and wrappers.
    ASSETS="$(find_release_assets | tr '\n' ' ')"

    if [ -z "$ASSETS" ]; then
        fail "No deployed binaries found under bin/release/"
        return 1
    fi

    if [ "$DRY_RUN" = true ]; then
        info "[DRY RUN] gh release create $TAG --title $TAG with: $ASSETS"
        return 0
    fi

    # shellcheck disable=SC2086
    gh release create "$TAG" \
        --repo "$REPO" \
        --title "$TAG" \
        --notes "Release $VERSION — MCP servers, plugins, and extensions. See MCP.md for details." \
        $ASSETS

    ok "GitHub Release $TAG created"
}

# --- Deploy: npm ---
deploy_npm() {
    info "=== npm: $NPM_PACKAGE ==="

    # Check if already published
    PUBLISHED="$(npm view "$NPM_PACKAGE" version 2>/dev/null || echo "")"
    if [ "$PUBLISHED" = "$VERSION" ]; then
        warn "$NPM_PACKAGE@$VERSION already published — skipping"
        return 0
    fi

    if [ "$DRY_RUN" = true ]; then
        info "[DRY RUN] cd tools/mcp-registry && npm publish --access public"
        return 0
    fi

    cd "$PROJECT_ROOT/tools/mcp-registry"

    # Verify version matches
    PKG_VERSION="$(sed -n 's/.*"version": *"\([^"]*\)".*/\1/p' package.json | head -n 1)"
    if [ "$PKG_VERSION" != "$VERSION" ]; then
        fail "tools/mcp-registry/package.json version ($PKG_VERSION) != $VERSION"
        fail "Run version sync first. See MCP.md > Version Synchronization"
        cd "$PROJECT_ROOT"
        return 1
    fi

    info "Running MCP package smoke test before npm publish"
    if ! sh "$PROJECT_ROOT/scripts/check-mcp-release-assets.shs"; then
        fail "Matching GitHub bootstrap asset is missing — create the release before npm publish"
        cd "$PROJECT_ROOT"
        return 1
    fi

    if ! sh "$PROJECT_ROOT/scripts/check-mcp-package-smoke.shs"; then
        fail "MCP package smoke test failed — refusing to publish broken tarballs"
        cd "$PROJECT_ROOT"
        return 1
    fi

    npm publish --access public
    cd "$PROJECT_ROOT"
    ok "Published $NPM_PACKAGE@$VERSION to npm"
}

# --- Deploy: MCP Registry ---
deploy_mcp_registry() {
    info "=== MCP Registry ==="

    # Check npm package exists first
    PUBLISHED="$(npm view "$NPM_PACKAGE" version 2>/dev/null || echo "")"
    if [ -z "$PUBLISHED" ]; then
        fail "$NPM_PACKAGE not on npm — run: scripts/deploy-marketplaces.shs npm"
        return 1
    fi
    if [ "$PUBLISHED" != "$VERSION" ]; then
        fail "$NPM_PACKAGE@$PUBLISHED is published, but current version is $VERSION"
        fail "Publish the current npm package before registering MCP Registry metadata"
        return 1
    fi
    if ! sh "$PROJECT_ROOT/scripts/check-mcp-release-assets.shs"; then
        fail "Matching GitHub bootstrap asset is missing — MCP Registry redeploy would still install a broken package"
        return 1
    fi

    if [ "$DRY_RUN" = true ]; then
        info "[DRY RUN] npx @anthropic-ai/mcp-publisher register --server-json tools/mcp-registry/server.json"
        return 0
    fi

    npx -y @anthropic-ai/mcp-publisher register \
        --server-json "$PROJECT_ROOT/tools/mcp-registry/server.json"

    ok "Registered on MCP Registry"
    info "Check: https://registry.modelcontextprotocol.io/servers/${NPM_PACKAGE}"
}

# --- Deploy: Gemini CLI Extension ---
deploy_gemini() {
    info "=== Gemini CLI Extension Gallery ==="

    # Validate manifest
    if [ ! -f "$PROJECT_ROOT/gemini-extension.json" ]; then
        fail "gemini-extension.json not found at project root"
        return 1
    fi

    if command -v jq >/dev/null 2>&1; then
        if jq . "$PROJECT_ROOT/gemini-extension.json" >/dev/null 2>&1; then
            ok "gemini-extension.json is valid JSON"
        else
            fail "gemini-extension.json is invalid JSON"
            return 1
        fi
    fi

    # Check GitHub topic
    TOPICS="$(gh repo view "$REPO" --json repositoryTopics -q '.repositoryTopics[].name' 2>/dev/null || echo "")"
    HAS_TOPIC=false
    for T in $TOPICS; do
        if [ "$T" = "gemini-cli-extension" ]; then
            HAS_TOPIC=true
            break
        fi
    done

    if [ "$HAS_TOPIC" = true ]; then
        ok "GitHub topic 'gemini-cli-extension' already set"
        info "Extension will appear at https://geminicli.com/extensions/ within 24h"
        return 0
    fi

    if [ "$DRY_RUN" = true ]; then
        info "[DRY RUN] gh repo edit $REPO --add-topic gemini-cli-extension"
        return 0
    fi

    gh repo edit "$REPO" --add-topic gemini-cli-extension
    ok "Added 'gemini-cli-extension' topic to $REPO"
    info "Gallery auto-crawls daily. Extension will appear at:"
    info "  https://geminicli.com/extensions/"
    info "Users install with: gemini extensions install $REPO"
}

# --- Deploy: Claude Plugin Marketplace ---
deploy_claude() {
    info "=== Claude Code Plugin Marketplace ==="

    # Package plugins
    if [ "$DRY_RUN" = true ]; then
        info "[DRY RUN] sh tools/claude-plugin/package_release_plugins.shs --version $VERSION"
        info "[DRY RUN] Would push marketplace to public repo for discovery"
        return 0
    fi

    sh "$PROJECT_ROOT/tools/claude-plugin/package_release_plugins.shs" --version "$VERSION"
    ok "Packaged plugins to build/release/plugins/"

    info ""
    info "To publish, choose one:"
    info ""
    info "  Option A — Official directory (PR):"
    info "    1. Fork https://github.com/anthropics/claude-plugins-official"
    info "    2. Add plugin entry referencing this repo"
    info "    3. Submit PR"
    info ""
    info "  Option B — Git-hosted marketplace:"
    info "    1. Push tools/claude-plugin/marketplace/ to a public repo"
    info "    2. Users add with: claude plugin marketplace add <git-url>"
    info ""
    info "  Option C — Community sites:"
    info "    Submit to https://claudemarketplaces.com/ or https://buildwithclaude.com/"
    info ""
    info "Plugin archives ready at: build/release/plugins/"
    ls -la "$PROJECT_ROOT/build/release/plugins/"*.tar.gz 2>/dev/null || warn "No archives found"
}

# --- Deploy: Codex Plugin ---
deploy_codex() {
    info "=== Codex Plugin Catalog ==="

    if [ ! -d "$PROJECT_ROOT/.codex/skills" ]; then
        fail ".codex/skills/ directory not found"
        return 1
    fi

    SKILL_COUNT="$(find "$PROJECT_ROOT/.codex/skills" -name "SKILL.md" | wc -l | tr -d ' ')"
    ok "Found $SKILL_COUNT Codex skills in .codex/skills/"

    if [ "$DRY_RUN" = true ]; then
        info "[DRY RUN] Would prepare Codex plugin bundle"
        return 0
    fi

    info ""
    info "Codex plugin system launched 2026-03-26. To publish:"
    info ""
    info "  1. Package skills + MCP config into a Codex plugin bundle:"
    info "     - Skills: .codex/skills/ ($SKILL_COUNT skills)"
    info "     - MCP servers: simple-mcp, simple-lsp-mcp, t32-mcp, t32-lsp-mcp"
    info "     - See https://developers.openai.com/codex/plugins for bundle format"
    info ""
    info "  2. Submit to Skills catalog:"
    info "     - Fork https://github.com/openai/skills"
    info "     - Add plugin entry"
    info "     - Submit PR"
    info ""
    info "  Verification before publish:"
    info "     - sh scripts/check-core-runtime-smoke.shs <runtime>"
    info "     - SIMPLE_BINARY=<runtime> sh scripts/check-mcp-native-smoke.shs"
    info "     - sh scripts/check-mcp-package-smoke.shs"
    info ""
    info "  3. Users install via /plugins command in Codex CLI"
}

# --- Status ---
show_status() {
    detect_version
    echo ""

    info "=== Marketplace Deployment Status ==="
    echo ""

    # GitHub Release
    if gh release view "v$VERSION" --repo "$REPO" >/dev/null 2>&1; then
        ok "GitHub Release v$VERSION exists"
    else
        fail "GitHub Release v$VERSION not found"
    fi

    # npm
    PUBLISHED="$(npm view "$NPM_PACKAGE" version 2>/dev/null || echo "")"
    if [ "$PUBLISHED" = "$VERSION" ]; then
        ok "npm: $NPM_PACKAGE@$VERSION published"
    elif [ -n "$PUBLISHED" ]; then
        warn "npm: $NPM_PACKAGE@$PUBLISHED published (current: $VERSION)"
    else
        fail "npm: $NPM_PACKAGE not published"
    fi

    # Gemini topic
    TOPICS="$(gh repo view "$REPO" --json repositoryTopics -q '.repositoryTopics[].name' 2>/dev/null || echo "")"
    HAS_TOPIC=false
    for T in $TOPICS; do
        if [ "$T" = "gemini-cli-extension" ]; then
            HAS_TOPIC=true
            break
        fi
    done
    if [ "$HAS_TOPIC" = true ]; then
        ok "Gemini: gemini-cli-extension topic set"
    else
        fail "Gemini: gemini-cli-extension topic not set"
    fi

    # Claude plugin packages
    if ls "$PROJECT_ROOT/build/release/plugins/"*"$VERSION"*.tar.gz >/dev/null 2>&1; then
        ok "Claude: plugin archives built for v$VERSION"
        info "Claude plugin prepublish checks: core runtime smoke, MCP native smoke, MCP package smoke"
    else
        fail "Claude: no plugin archives for v$VERSION"
    fi

    # Codex
    SKILL_COUNT="$(find "$PROJECT_ROOT/.codex/skills" -name "SKILL.md" 2>/dev/null | wc -l | tr -d ' ')"
    if [ "$SKILL_COUNT" -gt 0 ]; then
        ok "Codex: $SKILL_COUNT skills in .codex/skills/ (ad-hoc, not yet plugin bundle)"
    else
        fail "Codex: no skills found"
    fi

    echo ""
    info "Front pages:"
    info "  MCP Registry:  https://registry.modelcontextprotocol.io/"
    info "  Gemini:        https://geminicli.com/extensions/"
    info "  Claude:        https://github.com/anthropics/claude-plugins-official"
    info "  Codex:         https://developers.openai.com/codex/plugins"
}

# --- Main ---
parse_version_arg() {
    for arg in "$@"; do
        case "$arg" in
            --version=*) VERSION="${arg#--version=}" ;;
        esac
    done
}

# Parse flags
for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        --version=*) VERSION="${arg#--version=}" ;;
    esac
done

# Get target (skip flags)
TARGET=""
for arg in "$@"; do
    case "$arg" in
        --*) ;;
        *) TARGET="$arg"; break ;;
    esac
done

# Default to status
if [ -z "$TARGET" ]; then
    TARGET="status"
fi

# Detect version if not set
if [ -z "$VERSION" ] && [ "$TARGET" != "--check" ]; then
    detect_version
fi

case "$TARGET" in
    status)
        show_status
        ;;
    --check)
        check_prerequisites
        ;;
    github-release)
        deploy_github_release
        ;;
    npm)
        deploy_npm
        ;;
    mcp-registry)
        deploy_mcp_registry
        ;;
    gemini)
        deploy_gemini
        ;;
    claude)
        deploy_claude
        ;;
    codex)
        deploy_codex
        ;;
    all)
        echo ""
        deploy_github_release
        echo ""
        deploy_npm
        echo ""
        deploy_mcp_registry
        echo ""
        deploy_gemini
        echo ""
        deploy_claude
        echo ""
        deploy_codex
        echo ""
        info "=== Done ==="
        ;;
    *)
        echo "Unknown target: $TARGET" >&2
        echo "Usage: scripts/deploy-marketplaces.shs [status|all|npm|mcp-registry|gemini|claude|codex|github-release|--check]" >&2
        exit 1
        ;;
esac
