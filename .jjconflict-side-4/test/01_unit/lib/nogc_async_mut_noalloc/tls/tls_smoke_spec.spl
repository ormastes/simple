# Smoke spec for no-alloc TLS 1.3 baremetal modules.
# Verifies that all modules parse and basic functions are callable.

use std.spec
use src.lib.nogc_async_mut_noalloc.tls.types.{
    content_type_from_byte,
    content_type_to_byte,
    TlsError,
    TlsState
}
use src.lib.nogc_async_mut_noalloc.tls.transcript.{
    transcript_new,
    transcript_add,
    transcript_hash
}
use src.lib.nogc_async_mut_noalloc.tls.x25519.{
    x25519_pubkey
}
use src.lib.nogc_async_mut_noalloc.tls.record.{
    record_make_nonce,
    RecordKey
}
use src.lib.nogc_async_mut_noalloc.tls.handshake.{
    parse_handshake_header,
    build_finished
}
describe "tls no-alloc smoke":
    it "types: content_type_from_byte round-trips 0x14":
        val ct = content_type_from_byte(0x14u8)
        expect(content_type_to_byte(ct)).to_equal(0x14u8)

    it "transcript: new transcript has zero length":
        val tr = transcript_new()
        expect(tr.buf_len).to_equal(0u64)

    it "transcript: add bytes increases buf_len":
        var tr = transcript_new()
        val data: [u8] = [0x01u8, 0x02u8, 0x03u8]
        tr = transcript_add(tr, data)
        expect(tr.buf_len).to_equal(3u64)

    it "transcript: hash of empty transcript is 32 bytes":
        val tr = transcript_new()
        val h = transcript_hash(tr)
        expect(h.len()).to_equal(32)

    it "record: make_nonce returns 12 bytes":
        val iv: [u8] = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]
        val nonce = record_make_nonce(iv, 0u64)
        expect(nonce.len()).to_equal(12)

    it "record: make_nonce XORs seq_num into last 8 bytes":
        val iv: [u8] = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]
        val nonce = record_make_nonce(iv, 1u64)
        expect(nonce[11]).to_equal(1u8)

    it "handshake: parse_handshake_header of short buffer returns msg_type 0":
        val data: [u8] = [0x01u8, 0x00u8, 0x00u8]
        val ph = parse_handshake_header(data)
        expect(ph.msg_type).to_equal(0u8)

    it "handshake: build_finished wraps verify_data correctly":
        val vd: [u8] = [0xAAu8, 0xBBu8, 0xCCu8]
        val msg = build_finished(vd)
        # type byte is 20 (0x14) for Finished
        expect(msg[0]).to_equal(20u8)
        # length bytes: 0x00 0x00 0x03
        expect(msg[1]).to_equal(0u8)
        expect(msg[2]).to_equal(0u8)
        expect(msg[3]).to_equal(3u8)
        expect(msg.len()).to_equal(7)

    it "x25519: pubkey of all-zero scalar returns 32 bytes":
        val scalar: [u8] = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                            0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                            0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
                            0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8]
        val pub = x25519_pubkey(scalar)
        expect(pub.len()).to_equal(32)
