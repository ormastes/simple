# VHDL Sim Runner Integration System Tests
#
# System-level tests for GHDL runner integration: analyze, elaborate, and run
# phase modeling plus failure surfacing. Tests verify that GhdlResult and
# SourceMapHook model the runner output correctly and that phase failures are
# distinguishable by Simple test results.
#
# Text-grep pattern: logic replicated at module level to avoid import issues.
#
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench_render.spl 70%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench_source.spl 60%

"""
# VHDL Sim Runner Integration System Specification

**Feature IDs:** #VHDL-PARITY-012
**Category:** Tooling
**Difficulty:** 3/5
**Status:** In Progress
**Plan:** doc/03_plan/agent_tasks/vhdl_testbench_conversion.md

## Overview

System-level tests for the GHDL simulator runner integration layer. Covers
GhdlResult phase discrimination, failure surfacing, SourceMapHook field
requirements, and the VhdlTestbenchDiagnostic structure. Tests ensure that
deliberately invalid VHDL (analyze failure), elaboration failure, and
assertion failure at runtime are each surfaced as distinct failing Simple test
results.

## Key Concepts

- GhdlResult: phase ("analyze"|"elaborate"|"run"), passed, stderr_capture, exit_code
- Phase discrimination: is_analyze(), is_elaborate(), is_run()
- Failure: is_failure() when passed == false
- SourceMapHook: test_name, expectation_index, generated_entity, dut_instance, is_enabled
- VhdlTestbenchDiagnostic: code (e.g. "VHDL-TB-CONV-NO-DUT"), message, source_line

## Behavior

- GhdlResult.ok(phase) creates a passed result with empty stderr and exit_code 0
- GhdlResult.fail(phase, err, code) creates a failed result with stderr and exit_code
- Analyze failure causes the Simple test to fail before elaboration runs
- Elaboration failure causes the Simple test to fail before simulation runs
- Run failure (assertion) causes the Simple test to fail with stderr context
- SourceMapHook.is_enabled must be true for source-map fields to be emitted
- Diagnostic code must be non-empty and message must name the failing test
"""

# ===========================================================================
# Module-level helpers (text-grep pattern; no imports needed)
# ===========================================================================

fn ghdl_phase_is_analyze(phase: text) -> bool:
    """True when phase is the analyze step."""
    phase == "analyze"

fn ghdl_phase_is_elaborate(phase: text) -> bool:
    """True when phase is the elaborate step."""
    phase == "elaborate"

fn ghdl_phase_is_run(phase: text) -> bool:
    """True when phase is the run/simulation step."""
    phase == "run"

fn ghdl_is_failure(passed: bool) -> bool:
    """True when the result represents a failure."""
    passed == false

fn ghdl_ok_text(phase: text) -> text:
    """Human-readable summary for a passing phase."""
    "GHDL " + phase + ": OK"

fn ghdl_fail_text(phase: text, exit_code: i64) -> text:
    """Human-readable summary for a failing phase."""
    "GHDL " + phase + ": FAIL exit=" + exit_code.to_text()

fn ghdl_result_to_text(phase: text, passed: bool, exit_code: i64) -> text:
    """Produce the canonical to_text() output for a GhdlResult."""
    if passed:
        return ghdl_ok_text(phase)
    ghdl_fail_text(phase, exit_code)

fn source_map_is_enabled(is_enabled: bool) -> bool:
    """True when the SourceMapHook is enabled."""
    is_enabled

fn source_map_hook_to_text(test_name: text, expectation_index: i64, generated_entity: text, dut_instance: text, is_enabled: bool) -> text:
    """Produce source-map hook summary."""
    if not is_enabled:
        return "disabled"
    test_name + ":" + expectation_index.to_text() + " entity=" + generated_entity + " instance=" + dut_instance

fn diag_code_nonempty(code: text) -> bool:
    """True when diagnostic code is non-empty."""
    code.len() > 0

fn diag_message_names_test(message: text, test_name: text) -> bool:
    """True when diagnostic message contains the failing test name."""
    message.contains(test_name)

fn diag_has_source_line(source_line: i64) -> bool:
    """True when source line is a positive integer."""
    source_line > 0

fn analyze_error_in_vhdl(vhdl: text) -> bool:
    """Simulate detection of a syntax error that would fail GHDL analysis."""
    vhdl.contains("INVALID_SYNTAX") or vhdl.contains("error:")

fn is_valid_vhdl_shell(vhdl: text) -> bool:
    """Very basic check: VHDL has entity and end architecture."""
    vhdl.contains("entity ") and vhdl.contains("end architecture")

fn run_phase_assertion_fails(stderr: text) -> bool:
    """True when stderr indicates a VHDL assertion failure."""
    stderr.contains("severity failure") or stderr.contains("FAILURE:")

fn all_phases_passed(analyze: bool, elaborate: bool, run: bool) -> bool:
    """True when all three GHDL phases passed."""
    analyze and elaborate and run

fn first_failure_phase(analyze: bool, elaborate: bool, run: bool) -> text:
    """Return the name of the first failing phase, or empty if all pass."""
    if not analyze:
        return "analyze"
    if not elaborate:
        return "elaborate"
    if not run:
        return "run"
    ""

# ===========================================================================
# Test Group 1: GhdlResult Phase Discrimination
# ===========================================================================

describe "VHDL Sim Runner - GhdlResult Phase Discrimination":
    it "analyze phase is recognized as analyze":
        expect(ghdl_phase_is_analyze("analyze")).to_equal(true)
        expect(ghdl_phase_is_elaborate("analyze")).to_equal(false)
        expect(ghdl_phase_is_run("analyze")).to_equal(false)

    it "elaborate phase is recognized as elaborate":
        expect(ghdl_phase_is_elaborate("elaborate")).to_equal(true)
        expect(ghdl_phase_is_analyze("elaborate")).to_equal(false)
        expect(ghdl_phase_is_run("elaborate")).to_equal(false)

    it "run phase is recognized as run":
        expect(ghdl_phase_is_run("run")).to_equal(true)
        expect(ghdl_phase_is_analyze("run")).to_equal(false)
        expect(ghdl_phase_is_elaborate("run")).to_equal(false)

# ===========================================================================
# Test Group 2: GhdlResult Pass/Fail
# ===========================================================================

describe "VHDL Sim Runner - GhdlResult Pass/Fail":
    it "passed result is not a failure":
        expect(ghdl_is_failure(true)).to_equal(false)

    it "failed result is a failure":
        expect(ghdl_is_failure(false)).to_equal(true)

    it "ok result to_text contains phase name and OK":
        val s = ghdl_result_to_text("analyze", true, 0)
        expect(s.contains("analyze")).to_equal(true)
        expect(s.contains("OK")).to_equal(true)

    it "fail result to_text contains phase name and FAIL":
        val s = ghdl_result_to_text("elaborate", false, 1)
        expect(s.contains("elaborate")).to_equal(true)
        expect(s.contains("FAIL")).to_equal(true)

    it "fail result to_text contains exit code":
        val s = ghdl_result_to_text("run", false, 127)
        expect(s.contains("127")).to_equal(true)

    it "ok result to_text does not contain FAIL":
        val s = ghdl_result_to_text("analyze", true, 0)
        expect(s.contains("FAIL")).to_equal(false)

    it "fail result to_text does not contain OK":
        val s = ghdl_result_to_text("run", false, 1)
        expect(s.contains(": OK")).to_equal(false)

# ===========================================================================
# Test Group 3: Failure Phase Ordering
# ===========================================================================

describe "VHDL Sim Runner - Failure Phase Ordering":
    it "all phases passing means no failure":
        val phase = first_failure_phase(true, true, true)
        expect(phase).to_equal("")

    it "analyze failure is reported before elaborate":
        val phase = first_failure_phase(false, true, true)
        expect(phase).to_equal("analyze")

    it "elaborate failure is reported when analyze passes":
        val phase = first_failure_phase(true, false, true)
        expect(phase).to_equal("elaborate")

    it "run failure is reported when analyze and elaborate pass":
        val phase = first_failure_phase(true, true, false)
        expect(phase).to_equal("run")

    it "all phases passing returns empty string":
        val ok = all_phases_passed(true, true, true)
        expect(ok).to_equal(true)

    it "analyze failure means not all phases passed":
        val ok = all_phases_passed(false, true, true)
        expect(ok).to_equal(false)

# ===========================================================================
# Test Group 4: Invalid VHDL Detection
# ===========================================================================

describe "VHDL Sim Runner - Invalid VHDL Detection":
    it "deliberately invalid VHDL is detected before simulation":
        val vhdl = "INVALID_SYNTAX entity broken is end;"
        val bad = analyze_error_in_vhdl(vhdl)
        expect(bad).to_equal(true)

    it "valid VHDL shell passes basic structural check":
        val vhdl = "entity tb_adder is\nend entity tb_adder;\narchitecture sim of tb_adder is\nbegin\nend architecture sim;"
        val valid = is_valid_vhdl_shell(vhdl)
        expect(valid).to_equal(true)

    it "VHDL missing entity fails basic structural check":
        val vhdl = "architecture sim of tb_adder is\nbegin\nend architecture sim;"
        val valid = is_valid_vhdl_shell(vhdl)
        expect(valid).to_equal(false)

    it "VHDL missing end architecture fails basic structural check":
        val vhdl = "entity tb_adder is\nend entity tb_adder;\narchitecture sim of tb_adder is\nbegin\n"
        val valid = is_valid_vhdl_shell(vhdl)
        expect(valid).to_equal(false)

# ===========================================================================
# Test Group 5: Assertion Failure Surfacing
# ===========================================================================

describe "VHDL Sim Runner - Assertion Failure Surfacing":
    it "stderr containing severity failure signals assertion failure":
        val stderr = "tb_adder.vhd:42:5: assertion violation: severity failure"
        val fail = run_phase_assertion_fails(stderr)
        expect(fail).to_equal(true)

    it "stderr containing FAILURE: signals assertion failure":
        val stderr = "FAILURE: expectation 1 in half_adder: expected s_sum to equal '0'"
        val fail = run_phase_assertion_fails(stderr)
        expect(fail).to_equal(true)

    it "clean stderr does not signal assertion failure":
        val stderr = ""
        val fail = run_phase_assertion_fails(stderr)
        expect(fail).to_equal(false)

    it "stderr with informational message does not signal assertion failure":
        val stderr = "note: simulation finished"
        val fail = run_phase_assertion_fails(stderr)
        expect(fail).to_equal(false)

# ===========================================================================
# Test Group 6: SourceMapHook
# ===========================================================================

describe "VHDL Sim Runner - SourceMapHook":
    it "enabled hook is recognized as enabled":
        val enabled = source_map_is_enabled(true)
        expect(enabled).to_equal(true)

    it "disabled hook is not enabled":
        val enabled = source_map_is_enabled(false)
        expect(enabled).to_equal(false)

    it "disabled hook to_text returns disabled":
        val s = source_map_hook_to_text("half_adder_test", 1, "tb_half_adder", "dut", false)
        expect(s).to_equal("disabled")

    it "enabled hook to_text contains test name":
        val s = source_map_hook_to_text("half_adder_test", 1, "tb_half_adder", "dut", true)
        expect(s.contains("half_adder_test")).to_equal(true)

    it "enabled hook to_text contains expectation index":
        val s = source_map_hook_to_text("half_adder_test", 3, "tb_half_adder", "dut", true)
        expect(s.contains("3")).to_equal(true)

    it "enabled hook to_text contains generated entity":
        val s = source_map_hook_to_text("half_adder_test", 1, "tb_half_adder", "dut", true)
        expect(s.contains("tb_half_adder")).to_equal(true)

    it "enabled hook to_text contains dut instance name":
        val s = source_map_hook_to_text("half_adder_test", 1, "tb_half_adder", "dut", true)
        expect(s.contains("dut")).to_equal(true)

# ===========================================================================
# Test Group 7: VhdlTestbenchDiagnostic
# ===========================================================================

describe "VHDL Sim Runner - VhdlTestbenchDiagnostic":
    it "diagnostic code is non-empty":
        val code = "VHDL-TB-CONV-NO-DUT"
        expect(diag_code_nonempty(code)).to_equal(true)

    it "empty diagnostic code is rejected":
        val code = ""
        expect(diag_code_nonempty(code)).to_equal(false)

    it "diagnostic message names the failing test":
        val msg = "No @hardware DUT declaration found in test 'half_adder_test'"
        expect(diag_message_names_test(msg, "half_adder_test")).to_equal(true)

    it "diagnostic message without test name does not satisfy naming check":
        val msg = "No @hardware DUT declaration found"
        expect(diag_message_names_test(msg, "half_adder_test")).to_equal(false)

    it "diagnostic source_line is positive":
        val line: i64 = 12
        expect(diag_has_source_line(line)).to_equal(true)

    it "diagnostic source_line of zero is not valid":
        val line: i64 = 0
        expect(diag_has_source_line(line)).to_equal(false)

    it "NO-DUT diagnostic code matches expected pattern":
        val code = "VHDL-TB-CONV-NO-DUT"
        expect(code.starts_with("VHDL-TB-")).to_equal(true)

    it "NO-ASSERT diagnostic code matches expected pattern":
        val code = "VHDL-TB-CONV-NO-ASSERT"
        expect(code.starts_with("VHDL-TB-")).to_equal(true)

    it "MULTI-DUT diagnostic code matches expected pattern":
        val code = "VHDL-TB-CONV-MULTI-DUT"
        expect(code.starts_with("VHDL-TB-")).to_equal(true)

    it "NO-PORTS diagnostic code matches expected pattern":
        val code = "VHDL-TB-CONV-NO-PORTS"
        expect(code.starts_with("VHDL-TB-")).to_equal(true)
