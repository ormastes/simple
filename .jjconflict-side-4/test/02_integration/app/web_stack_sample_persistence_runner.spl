use app.web_stack_sample.app.{open_web_stack_sample}
use std.sffi.cli.{cli_get_args}

val USERNAME = "persist_user"
val EMAIL = "persist@example.com"
val PASSWORD = "persist-pass-123"
val TITLE = "Persistent item"
val DETAILS = "Created before restart and found after restart"

fn usage():
    print "Usage: web_stack_sample_persistence_runner.spl <seed|verify> <db-path>"

fn main():
    val args = cli_get_args()
    var mode = ""
    var path = ""
    var i = 0
    while i + 1 < args.len():
        if args[i] == "seed" or args[i] == "verify":
            mode = args[i]
            path = args[i + 1]
            break
        i = i + 1
    if mode == "" or path == "":
        usage()
        return
    if mode == "seed":
        run_seed(path)
        return
    if mode == "verify":
        run_verify(path)
        return
    usage()

fn run_seed(path: text):
    val app_result = open_web_stack_sample("simpledb", path)
    if app_result.is_err():
        panic("open seed app failed: " + app_result.unwrap_err())
    val app = app_result.unwrap()
    val register_result = app.post_register(USERNAME, EMAIL, PASSWORD)
    if register_result.is_err():
        panic("register failed: " + register_result.unwrap_err())
    val register = register_result.unwrap()
    if register.status != 302:
        panic("register status mismatch")
    if register.session_id.len() == 0:
        panic("register session id missing")
    val item_result = app.create_item(register.session_id, TITLE, DETAILS)
    if item_result.is_err():
        panic("create item failed: " + item_result.unwrap_err())
    val item = item_result.unwrap()
    print "PERSISTENCE_SEEDED user={USERNAME} item={item.title} id={item.id}"

fn run_verify(path: text):
    val app_result = open_web_stack_sample("simpledb", path)
    if app_result.is_err():
        panic("open verify app failed: " + app_result.unwrap_err())
    val app = app_result.unwrap()
    val login_result = app.post_login(USERNAME, PASSWORD)
    if login_result.is_err():
        panic("login failed: " + login_result.unwrap_err())
    val login = login_result.unwrap()
    if login.status != 302:
        panic("login status mismatch")
    if login.session_id.len() == 0:
        panic("login session id missing")
    val search_result = app.search_items(login.session_id, "Persistent")
    if search_result.is_err():
        panic("search failed: " + search_result.unwrap_err())
    val search = search_result.unwrap()
    if search.status != 200:
        panic("search status mismatch")
    if not search.body.contains(TITLE):
        panic("title missing after restart")
    if not search.body.contains(DETAILS):
        panic("details missing after restart")
    if not search.body.contains("LOGIN-SUCCESS:{USERNAME}"):
        panic("login marker missing after restart")
    if not search.body.contains("SEARCH-HIT:{TITLE}"):
        panic("search marker missing after restart")
    print "PERSISTENCE_VERIFIED user={USERNAME} item={TITLE}"
