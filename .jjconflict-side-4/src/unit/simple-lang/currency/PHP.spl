# Unit: Php
# Kind: Currency
# Symbol: PHP
# Canonical scale: 1.0 USD

class Php:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Php) -> Php: Php(value: self.value + other.value)
    fn sub(other: Php) -> Php: Php(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "PHP"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Php: Php(value: 0.0)

export Php
