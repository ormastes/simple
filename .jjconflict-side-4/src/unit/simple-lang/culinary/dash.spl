# Unit: Dash
# Kind: Culinary
# Symbol: dash
# Canonical scale: 0.6 mL

class Dash:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dash) -> Dash: Dash(value: self.value + other.value)
    fn sub(other: Dash) -> Dash: Dash(value: self.value - other.value)

    static fn kind() -> text: "Culinary"
    static fn symbol() -> text: "dash"
    static fn scale_to_base() -> f64: 0.6
    static fn base_unit() -> text: "mL"
    static fn zero() -> Dash: Dash(value: 0.0)

export Dash
