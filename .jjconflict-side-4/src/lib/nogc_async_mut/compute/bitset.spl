@no_gc

# bitset — fixed-width bit set, i64-word packed (libcu++ <bitset> / std::bitset parity).
#   Bitset    — N-bit set over [i64] words (64 bits/word).
# Clears via subtract (no `~` operator dependency); counts/tests via per-bit
# extraction `(word >> b) & 1`, which is sign-safe even when bit 63 is set
# (a set bit 63 makes the word negative, but masking `& 1` reads the right bit).

val BITSET_WORD_BITS = 64

class Bitset:
    words: [i64]
    nbits: i64

    static fn zeros(nbits: i64) -> Bitset:
        val nwords = (nbits + BITSET_WORD_BITS - 1) / BITSET_WORD_BITS
        val safe = if nwords < 1: 1 else: nwords
        Bitset(words: [for i in 0..safe: 0], nbits: nbits)

    fn size() -> i64:
        self.nbits

    fn test(i: i64) -> bool:
        val w = i / BITSET_WORD_BITS
        val b = i % BITSET_WORD_BITS
        ((self.words[w] >> b) & 1) == 1

    me set(i: i64):
        val w = i / BITSET_WORD_BITS
        val b = i % BITSET_WORD_BITS
        self.words[w] = self.words[w] | (1 << b)

    me clear_bit(i: i64):
        if self.test(i):
            val w = i / BITSET_WORD_BITS
            val b = i % BITSET_WORD_BITS
            self.words[w] = self.words[w] - (1 << b)

    me set_to(i: i64, v: bool):
        if v:
            self.set(i)
        else:
            self.clear_bit(i)

    me flip(i: i64):
        if self.test(i):
            self.clear_bit(i)
        else:
            self.set(i)

    fn count() -> i64:
        var total = 0
        var i = 0
        while i < self.nbits:
            if self.test(i):
                total = total + 1
            i = i + 1
        return total

    fn any() -> bool:
        self.count() > 0

    fn none() -> bool:
        self.count() == 0

    fn all() -> bool:
        self.count() == self.nbits

export BITSET_WORD_BITS, Bitset
