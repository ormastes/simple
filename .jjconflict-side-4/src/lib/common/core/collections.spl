# core.collections — generic List type
#
# List<T> is a dynamic growable sequence backed by a native array.
# In the interpreter, native [] arrays are used; this class provides
# the named-type facade that typed code expects.

pub class List<T>:
    items: [T]

    static fn new() -> List<T>:
        List(items: [])

    me push(item: T):
        self.items.push(item)

    me append(item: T):
        self.items.push(item)

    fn len() -> i64:
        self.items.len()

    fn get(i: i64) -> T:
        self.items[i]

    me clear():
        self.items = []

    fn is_empty() -> bool:
        self.items.len() == 0

export List
