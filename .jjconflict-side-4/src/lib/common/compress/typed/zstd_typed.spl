# ============================================================================
# common/compress/typed/zstd_typed.spl — typed Zstd frame codec (C3)
#
# Implements real Zstd framing + raw/RLE block round-trip + FseTable scaffold.
# Full FSE compressed-block path is deferred (see deferral note).
#
# Spec:  https://github.com/facebook/zstd/blob/dev/doc/zstd_compression_format.md
# Magic: 0xFD2FB528 LE = bytes [28 B5 2F FD]
#
# Frame layout (Single_Segment, no checksum, no dict):
#   [28 B5 2F FD]  Magic (4 bytes LE)
#   [FHD]          Frame_Header_Descriptor (1 byte)
#   [FCS]          Frame_Content_Size (1/2/4/8 bytes — 1 byte when SS=1 & size<256)
#   blocks...      one or more Block_Header(3B) + Block_Data
#
# Block_Header (3 bytes LE):
#   bits [0]     = Last_Block flag
#   bits [2:1]   = Block_Type  (0=Raw, 1=RLE, 2=Compressed/deferred, 3=Reserved)
#   bits [23:3]  = Block_Size  (raw: stored size; RLE: regenerated size)
#   value = (Block_Size << 3) | (Block_Type << 1) | Last_Block
#   emitted LE: v&0xFF, (v>>8)&0xFF, (v>>16)&0xFF
#
# Block_Type values
ZSTD_BLOCK_RAW  = 0
ZSTD_BLOCK_RLE  = 1
ZSTD_BLOCK_COMP = 2

# Maximum raw block payload (RFC: 128 KB)
ZSTD_MAX_RAW_BLOCK = 131072

# Zstd magic number bytes (little-endian)
ZSTD_MAGIC_B0 = 0x28
ZSTD_MAGIC_B1 = 0xB5
ZSTD_MAGIC_B2 = 0x2F
ZSTD_MAGIC_B3 = 0xFD

# ============================================================================
# Frame header helpers
# ============================================================================

# Build a Zstd frame header for a single-segment frame with no checksum, no dict.
# Uses Single_Segment_flag=1, FCS_flag depends on content_size:
#   content_size < 256  → FCS_field_size = 1  (FHD bits [7:6] = 00)
#   content_size < 65792 → FCS_field_size = 2 (FHD bits [7:6] = 01), stored = size-256
#   otherwise           → FCS_field_size = 4  (FHD bits [7:6] = 10)
#
# Returns the header bytes as [u8].
fn zstd_frame_header_bytes(content_size: i64) -> [u8]:
    """Encode a Zstd Frame_Header_Descriptor + FCS for the given content size.
    Single_Segment=1, checksum=0, no dict. Returns header bytes (5 or 6 bytes)."""
    var out: [u8] = []
    # Magic
    out.push(ZSTD_MAGIC_B0.to_u8())
    out.push(ZSTD_MAGIC_B1.to_u8())
    out.push(ZSTD_MAGIC_B2.to_u8())
    out.push(ZSTD_MAGIC_B3.to_u8())

    # Frame_Header_Descriptor byte:
    # bit 5    = Single_Segment_flag = 1  → no Window_Descriptor
    # bits 7:6 = FCS_Field_Size:
    #   00 = 1 byte  (only when SS=1, content_size 0..255)
    #   01 = 2 bytes (stored = content_size - 256, range 256..65791)
    #   10 = 4 bytes
    #   11 = 8 bytes
    # bits 4:3 = Content_Checksum_flag=0, Dict_ID_flag=00
    var fhd = 0x20  # Single_Segment=1, FCS=00(1B), no checksum, no dict
    if content_size > 255 and content_size < 65792:
        fhd = 0x60  # FCS=01 (2 bytes), Single_Segment=1
    else:
        if content_size >= 65792:
            fhd = 0xA0  # FCS=10 (4 bytes), Single_Segment=1
    out.push(fhd.to_u8())

    # FCS field
    if content_size <= 255:
        out.push((content_size & 0xFF).to_u8())
    else:
        if content_size < 65792:
            val stored = content_size - 256
            out.push((stored & 0xFF).to_u8())
            out.push(((stored >> 8) & 0xFF).to_u8())
        else:
            out.push((content_size & 0xFF).to_u8())
            out.push(((content_size >> 8) & 0xFF).to_u8())
            out.push(((content_size >> 16) & 0xFF).to_u8())
            out.push(((content_size >> 24) & 0xFF).to_u8())
    out

# Encode a 3-byte block header (little-endian).
fn zstd_block_header_bytes(block_size: i64, block_type: i64, last_block: bool) -> [u8]:
    """Encode a Zstd Block_Header as 3 bytes LE.
    value = (block_size << 3) | (block_type << 1) | last_block_flag"""
    var last = 0
    if last_block:
        last = 1
    val v = (block_size << 3) | (block_type << 1) | last
    var out: [u8] = []
    out.push((v & 0xFF).to_u8())
    out.push(((v >> 8) & 0xFF).to_u8())
    out.push(((v >> 16) & 0xFF).to_u8())
    out

# ============================================================================
# ZstdFrame — parsed frame header
# ============================================================================
struct ZstdFrame:
    """Parsed Zstd frame header fields."""
    content_size: i64
    single_segment: bool
    has_checksum: bool
    header_len: i64

# ============================================================================
# ZstdDecodeResult — output of zstd_decompress
# ============================================================================
struct ZstdDecodeResult:
    """Result of decoding a Zstd frame."""
    ok: bool
    data: [u8]
    error: text

# ============================================================================
# zstd_compress_raw — compress input as a sequence of raw blocks
# ============================================================================

fn zstd_compress_raw(input: [u8]) -> [u8]:
    """Compress `input` into a Zstd frame using only raw (uncompressed) blocks.
    Splits input into chunks of at most ZSTD_MAX_RAW_BLOCK bytes. Returns the
    full frame as [u8] (magic + frame header + blocks)."""
    val content_size = input.len()
    val hdr = zstd_frame_header_bytes(content_size)
    var out: [u8] = []

    # Emit frame header
    var hi = 0
    while hi < hdr.len():
        out.push(hdr[hi])
        hi = hi + 1

    # Emit raw blocks
    var pos = 0
    while pos < content_size:
        var chunk_size = content_size - pos
        if chunk_size > ZSTD_MAX_RAW_BLOCK:
            chunk_size = ZSTD_MAX_RAW_BLOCK
        val is_last = (pos + chunk_size) >= content_size
        val bh = zstd_block_header_bytes(chunk_size, ZSTD_BLOCK_RAW, is_last)

        # Block header
        var bhi = 0
        while bhi < bh.len():
            out.push(bh[bhi])
            bhi = bhi + 1

        # Block data (raw copy)
        var di = 0
        while di < chunk_size:
            out.push(input[pos + di])
            di = di + 1

        pos = pos + chunk_size

    # Special case: empty input → one zero-size last raw block
    if content_size == 0:
        val bh = zstd_block_header_bytes(0, ZSTD_BLOCK_RAW, true)
        var bhi = 0
        while bhi < bh.len():
            out.push(bh[bhi])
            bhi = bhi + 1

    out

# ============================================================================
# zstd_decompress — parse frame + raw/RLE blocks
# ============================================================================

fn zstd_decompress(input: [u8]) -> ZstdDecodeResult:
    """Decompress a Zstd frame that contains raw (type=0) and/or RLE (type=1)
    blocks. Compressed blocks (type=2) are not supported (returns error).
    Returns ZstdDecodeResult with ok=true and reconstructed data on success."""
    val n = input.len()
    if n < 4:
        return ZstdDecodeResult(ok: false, data: [], error: "too short for magic")

    # Verify magic
    if input[0].to_i64() != ZSTD_MAGIC_B0:
        return ZstdDecodeResult(ok: false, data: [], error: "bad magic b0")
    if input[1].to_i64() != ZSTD_MAGIC_B1:
        return ZstdDecodeResult(ok: false, data: [], error: "bad magic b1")
    if input[2].to_i64() != ZSTD_MAGIC_B2:
        return ZstdDecodeResult(ok: false, data: [], error: "bad magic b2")
    if input[3].to_i64() != ZSTD_MAGIC_B3:
        return ZstdDecodeResult(ok: false, data: [], error: "bad magic b3")

    if n < 5:
        return ZstdDecodeResult(ok: false, data: [], error: "too short for FHD")

    val fhd = input[4].to_i64()
    val single_segment = (fhd & 0x20) != 0
    val fcs_size_flag = (fhd >> 6) & 0x03
    val has_checksum = (fhd & 0x04) != 0
    if not single_segment:
        return ZstdDecodeResult(ok: false, data: [], error: "window descriptor not supported")
    if (fhd & 0x03) != 0:
        return ZstdDecodeResult(ok: false, data: [], error: "dictionary id not supported")
    if (fhd & 0x10) != 0:
        return ZstdDecodeResult(ok: false, data: [], error: "unused frame header bit")
    if (fhd & 0x08) != 0:
        return ZstdDecodeResult(ok: false, data: [], error: "reserved frame header bit")
    if has_checksum:
        return ZstdDecodeResult(ok: false, data: [], error: "checksum not supported")
    if fcs_size_flag == 3:
        return ZstdDecodeResult(ok: false, data: [], error: "8-byte content size not supported")

    # Determine FCS field size
    var fcs_bytes = 1
    if fcs_size_flag == 1:
        fcs_bytes = 2
    else:
        if fcs_size_flag == 2:
            fcs_bytes = 4
        else:
            if fcs_size_flag == 3:
                fcs_bytes = 8

    # Window_Descriptor present only when single_segment=0
    var wdesc_bytes = 0
    if not single_segment:
        wdesc_bytes = 1

    val hdr_end = 5 + wdesc_bytes + fcs_bytes
    if n < hdr_end:
        return ZstdDecodeResult(ok: false, data: [], error: "too short for frame header")

    val fcs_pos = 5 + wdesc_bytes
    var expected_content_size = 0
    var fci = 0
    while fci < fcs_bytes:
        expected_content_size = expected_content_size | (input[fcs_pos + fci].to_i64() << (8 * fci))
        fci = fci + 1
    if fcs_size_flag == 1:
        expected_content_size = expected_content_size + 256

    # pos now points to first block
    var pos = hdr_end

    var out: [u8] = []
    var done = false
    var saw_block = false

    while not done:
        if saw_block and out.len() == expected_content_size:
            return ZstdDecodeResult(ok: false, data: [], error: "extra block after content size")
        if pos + 3 > n:
            return ZstdDecodeResult(ok: false, data: [], error: "truncated block header")

        # Read 3-byte LE block header
        val bh0 = input[pos].to_i64()
        val bh1 = input[pos + 1].to_i64()
        val bh2 = input[pos + 2].to_i64()
        val bh_val = bh0 | (bh1 << 8) | (bh2 << 16)

        val last_block = (bh_val & 1) != 0
        val block_type = (bh_val >> 1) & 0x03
        val block_size = (bh_val >> 3) & 0x1FFFFF

        pos = pos + 3

        if block_size > ZSTD_MAX_RAW_BLOCK:
            return ZstdDecodeResult(ok: false, data: [], error: "block size too large")

        if block_type == ZSTD_BLOCK_RAW:
            # Raw block: block_size bytes of literal data
            if out.len() + block_size > expected_content_size:
                return ZstdDecodeResult(ok: false, data: [], error: "block exceeds content size")
            if pos + block_size > n:
                return ZstdDecodeResult(ok: false, data: [], error: "truncated raw block")
            var bi = 0
            while bi < block_size:
                out.push(input[pos + bi])
                bi = bi + 1
            pos = pos + block_size

        else:
            if block_type == ZSTD_BLOCK_RLE:
                # RLE block: 1 stored byte, block_size = regenerated size
                if block_size == 0:
                    return ZstdDecodeResult(ok: false, data: [], error: "zero-size RLE block")
                if out.len() + block_size > expected_content_size:
                    return ZstdDecodeResult(ok: false, data: [], error: "block exceeds content size")
                if pos + 1 > n:
                    return ZstdDecodeResult(ok: false, data: [], error: "truncated RLE block")
                val rle_byte = input[pos]
                pos = pos + 1
                var ri = 0
                while ri < block_size:
                    out.push(rle_byte)
                    ri = ri + 1

            else:
                if block_type == ZSTD_BLOCK_COMP:
                    return ZstdDecodeResult(ok: false, data: [], error: "compressed blocks not supported (FSE deferred)")
                else:
                    return ZstdDecodeResult(ok: false, data: [], error: "reserved block type")

        if last_block:
            done = true
        saw_block = true

    if pos != n:
        return ZstdDecodeResult(ok: false, data: [], error: "trailing bytes")

    if out.len() != expected_content_size:
        return ZstdDecodeResult(ok: false, data: [], error: "content size mismatch")

    ZstdDecodeResult(ok: true, data: out, error: "")

# ============================================================================
# FseTable — FSE decode table scaffold (C3 typed scaffolding)
#
# Full FSE compressed-block decode is deferred:
#   doc/08_tracking/bug/zstd_fse_compressed_block_deferred_2026-06-15.md
#
# What IS implemented here:
#   - FseTableEntry: one slot in the decode table (symbol + nb_bits + baseline)
#   - FseTable.from_normalized_counts: builds the decode table per the
#     zstd spec §3.1.1 "Symbol distribution" spread algorithm
#   - FseTable.slots_for_symbol: query — how many slots does sym occupy?
#
# What is NOT implemented (deferred):
#   - decode_symbol(state, r: BitReader): full reverse-bitstream symbol decode
#     Requires: read nbBits from reversed bitstream, compute newState,
#     look up FseTableEntry[newState]. Deferred because it needs the full
#     reverse-bitstream reader (zstd reads FSE from back to front).
#   - Compressed-block decode: requires FSE decode for sequences + literals.
# ============================================================================

struct FseTableEntry:
    """One slot in an FSE decode table.
    symbol   — the decoded symbol for this state
    nb_bits  — number of bits to read from the stream to find the next state
    baseline — base value added to the read bits to compute next state"""
    symbol: i64
    nb_bits: i64
    baseline: i64

struct FseTable:
    """FSE (Finite State Entropy) decode table.
    table_log  — log2 of table size; table has 1<<table_log entries
    entries    — decode table entries indexed by state
    n_sym      — number of symbols in the alphabet"""
    table_log: i64
    entries: [FseTableEntry]
    n_sym: i64

impl FseTable:
    static fn from_normalized_counts(counts: [i64], table_log: i64) -> FseTable:
        """Build an FSE decode table from normalized symbol probabilities.
        `counts` must sum to 1<<table_log. A count of -1 means probability
        'less than 1' (the symbol gets exactly 1 slot at the top of the table,
        not through the spread).

        Algorithm: zstd spec §3.1.1 spread — symbols are distributed into
        table slots using the formula: pos = (pos * step) % table_size,
        where step = (table_size >> 1) + (table_size >> 3) + 3.

        INVARIANT (proved by unit test):
          For each symbol s with counts[s] == c > 0:
            slots_for_symbol(s) == c
          Total occupied slots == 1 << table_log.
        """
        if table_log < 0 or table_log > 20:
            return FseTable(table_log: 0, entries: [], n_sym: counts.len())

        val table_size = 1 << table_log
        val n_sym = counts.len()
        var normalized_total = 0
        var ci = 0
        while ci < n_sym:
            val c = counts[ci]
            if c < -1:
                return FseTable(table_log: 0, entries: [], n_sym: n_sym)
            if c == -1:
                normalized_total = normalized_total + 1
            else:
                normalized_total = normalized_total + c
            ci = ci + 1
        if normalized_total != table_size:
            return FseTable(table_log: 0, entries: [], n_sym: n_sym)

        val step = (table_size >> 1) + (table_size >> 3) + 3
        val mask = table_size - 1

        # Initialize entries to a safe sentinel
        var entries: [FseTableEntry] = []
        var ii = 0
        while ii < table_size:
            entries.push(FseTableEntry(symbol: -1, nb_bits: 0, baseline: 0))
            ii = ii + 1

        # First pass: place probability-1 symbols (-1 count) at the top
        # (zstd spec: low-prob symbols occupy highest indices in reverse order)
        var high_pos = table_size - 1
        var sym = 0
        while sym < n_sym:
            if counts[sym] == -1:
                if high_pos < 0:
                    return FseTable(table_log: 0, entries: [], n_sym: n_sym)
                entries[high_pos] = FseTableEntry(symbol: sym, nb_bits: table_log, baseline: 0)
                high_pos = high_pos - 1
            sym = sym + 1

        # Second pass: spread remaining symbols through the table
        var pos = 0
        sym = 0
        while sym < n_sym:
            val c = counts[sym]
            if c > 0:
                var placed = 0
                while placed < c:
                    # Advance pos, skipping slots reserved for low-prob symbols
                    while pos > high_pos and high_pos >= 0:
                        pos = (pos + step) & mask
                    # Check if pos is already used (by low-prob / prior spread)
                    # Simple slot: place if symbol == -1 (free)
                    if entries[pos].symbol == -1:
                        entries[pos] = FseTableEntry(symbol: sym, nb_bits: 0, baseline: 0)
                        placed = placed + 1
                    pos = (pos + step) & mask
            sym = sym + 1

        # Third pass: assign nb_bits and baseline per state
        # For state s holding symbol with count c:
        #   nb_bits  = table_log - floor_log2(c + current_rank)
        #   baseline = (2 * c - slots already assigned) * (1 << nb_bits)
        # Simplified: just record which slots each symbol occupies,
        # and set nb_bits = table_log - floor_log2(c) (approximate for scaffold).
        # Full production decode needs exact per-slot nbBits from the spec.
        sym = 0
        while sym < n_sym:
            val c = counts[sym]
            if c > 0:
                # floor_log2(c)
                var lg = 0
                var tmp = c
                while tmp > 1:
                    tmp = tmp >> 1
                    lg = lg + 1
                val nb = table_log - lg
                # Assign nb_bits to all slots for this symbol
                var si = 0
                while si < table_size:
                    if entries[si].symbol == sym:
                        entries[si] = FseTableEntry(symbol: sym, nb_bits: nb, baseline: 0)
                    si = si + 1
            sym = sym + 1

        FseTable(table_log: table_log, entries: entries, n_sym: n_sym)

    fn slots_for_symbol(sym: i64) -> i64:
        """Count how many decode table slots are assigned to `sym`."""
        var count = 0
        var i = 0
        while i < self.entries.len():
            if self.entries[i].symbol == sym:
                count = count + 1
            i = i + 1
        count

    fn table_size() -> i64:
        """Return the total number of table slots (1 << table_log)."""
        1 << self.table_log

    fn decode_symbol_stub(state: i64) -> i64:
        """Return the symbol for the given FSE state. nb_bits / baseline
        advancement is NOT implemented here — see deferral note.
        This is a scaffold: symbol lookup only."""
        if state < 0 or state >= self.entries.len():
            return -1
        self.entries[state].symbol

# ============================================================================
# Byte-level helpers used in specs
# ============================================================================

fn zstd_bytes_equal(a: [u8], b: [u8]) -> bool:
    """Compare two byte arrays for equality."""
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true
