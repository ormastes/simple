# host_cpu_config.spl — Host CPU feature detection, config clamping, tier precedence
#
# AC-1: Host CPU feature detection (CpuFeatureSet)
# AC-2: Config clamping — clamp requested tier to hardware max (TierClamp)
# AC-3: Tier fallback chain / precedence (TierFallbackChain)
#
# @tag:stdlib
# @tag:simd

# ============================================================================
# SimdTier — represents a named SIMD capability tier with rank and width
# ============================================================================

class SimdTier:
    """Named SIMD tier with rank ordering and vector width."""
    name: text
    rank: i32
    vector_width: i32

impl SimdTier:

    static fn scalar() -> Self:
        SimdTier(name: "scalar", rank: 0, vector_width: 0)

    static fn sse4() -> Self:
        SimdTier(name: "sse4", rank: 1, vector_width: 128)

    static fn avx() -> Self:
        SimdTier(name: "avx", rank: 2, vector_width: 256)

    static fn avx2() -> Self:
        SimdTier(name: "avx2", rank: 3, vector_width: 256)

    static fn avx512() -> Self:
        SimdTier(name: "avx512", rank: 4, vector_width: 512)

    static fn neon() -> Self:
        SimdTier(name: "neon", rank: 5, vector_width: 128)

    static fn sve() -> Self:
        SimdTier(name: "sve", rank: 6, vector_width: 256)

    fn is_x86(self) -> bool:
        if self.name == "sse4":
            true
        elif self.name == "avx":
            true
        elif self.name == "avx2":
            true
        elif self.name == "avx512":
            true
        else:
            false

    fn is_arm(self) -> bool:
        if self.name == "neon":
            true
        elif self.name == "sve":
            true
        else:
            false

    fn is_higher_than(self, other_rank: i32) -> bool:
        self.rank > other_rank

    fn summary(self) -> text:
        "SimdTier(" + self.name + " rank=" + self.rank.to_text() + " width=" + self.vector_width.to_text() + ")"

# ============================================================================
# Internal helpers — tier name to rank and rank to name
# ============================================================================

fn tier_rank_of(tier_name: text) -> i32:
    if tier_name == "avx512":
        4
    elif tier_name == "avx2":
        3
    elif tier_name == "avx":
        2
    elif tier_name == "sse4":
        1
    elif tier_name == "sve":
        6
    elif tier_name == "neon":
        5
    else:
        0

fn tier_of_name(tier_name: text) -> SimdTier:
    if tier_name == "avx512":
        SimdTier.avx512()
    elif tier_name == "avx2":
        SimdTier.avx2()
    elif tier_name == "avx":
        SimdTier.avx()
    elif tier_name == "sse4":
        SimdTier.sse4()
    elif tier_name == "neon":
        SimdTier.neon()
    elif tier_name == "sve":
        SimdTier.sve()
    else:
        SimdTier.scalar()

# ============================================================================
# CpuFeatureSet — AC-1: detected CPU features
# ============================================================================

class CpuFeatureSet:
    """Detected CPU features for a given architecture.

    AC-1: Represents the SIMD capabilities available on the host CPU.
    Use the static constructors for known hardware profiles, or build
    a custom instance by setting fields directly.
    """
    arch: text
    has_sse4: bool
    has_avx: bool
    has_avx2: bool
    has_avx512: bool
    has_neon: bool
    has_sve: bool
    max_vector_width: i32

impl CpuFeatureSet:

    static fn x86_baseline() -> Self:
        """x86_64 baseline: SSE4 only."""
        CpuFeatureSet(
            arch: "x86_64",
            has_sse4: true,
            has_avx: false,
            has_avx2: false,
            has_avx512: false,
            has_neon: false,
            has_sve: false,
            max_vector_width: 128
        )

    static fn x86_modern() -> Self:
        """x86_64 modern: through AVX2."""
        CpuFeatureSet(
            arch: "x86_64",
            has_sse4: true,
            has_avx: true,
            has_avx2: true,
            has_avx512: false,
            has_neon: false,
            has_sve: false,
            max_vector_width: 256
        )

    static fn x86_server() -> Self:
        """x86_64 server: through AVX-512."""
        CpuFeatureSet(
            arch: "x86_64",
            has_sse4: true,
            has_avx: true,
            has_avx2: true,
            has_avx512: true,
            has_neon: false,
            has_sve: false,
            max_vector_width: 512
        )

    static fn arm_baseline() -> Self:
        """AArch64 baseline: NEON only."""
        CpuFeatureSet(
            arch: "aarch64",
            has_sse4: false,
            has_avx: false,
            has_avx2: false,
            has_avx512: false,
            has_neon: true,
            has_sve: false,
            max_vector_width: 128
        )

    static fn arm_server() -> Self:
        """AArch64 server: NEON + SVE."""
        CpuFeatureSet(
            arch: "aarch64",
            has_sse4: false,
            has_avx: false,
            has_avx2: false,
            has_avx512: false,
            has_neon: true,
            has_sve: true,
            max_vector_width: 256
        )

    static fn riscv() -> Self:
        """RISC-V: scalar only (no SIMD extensions assumed)."""
        CpuFeatureSet(
            arch: "riscv64",
            has_sse4: false,
            has_avx: false,
            has_avx2: false,
            has_avx512: false,
            has_neon: false,
            has_sve: false,
            max_vector_width: 0
        )

    fn highest_tier(self) -> SimdTier:
        """Returns the best available SIMD tier for this feature set."""
        if self.has_avx512:
            SimdTier.avx512()
        elif self.has_avx2:
            SimdTier.avx2()
        elif self.has_avx:
            SimdTier.avx()
        elif self.has_sve:
            SimdTier.sve()
        elif self.has_neon:
            SimdTier.neon()
        elif self.has_sse4:
            SimdTier.sse4()
        else:
            SimdTier.scalar()

    fn supports_tier(self, tier_name: text) -> bool:
        """True if the given tier name is supported by this feature set."""
        if tier_name == "scalar":
            true
        elif tier_name == "sse4":
            self.has_sse4
        elif tier_name == "avx":
            self.has_avx
        elif tier_name == "avx2":
            self.has_avx2
        elif tier_name == "avx512":
            self.has_avx512
        elif tier_name == "neon":
            self.has_neon
        elif tier_name == "sve":
            self.has_sve
        else:
            false

    fn summary(self) -> text:
        var parts = "CpuFeatureSet(arch=" + self.arch
        if self.has_sse4:
            parts = parts + " sse4"
        if self.has_avx:
            parts = parts + " avx"
        if self.has_avx2:
            parts = parts + " avx2"
        if self.has_avx512:
            parts = parts + " avx512"
        if self.has_neon:
            parts = parts + " neon"
        if self.has_sve:
            parts = parts + " sve"
        parts = parts + " max_width=" + self.max_vector_width.to_text() + ")"
        parts

# ============================================================================
# TierClamp — AC-2: clamp requested tier to hardware maximum
# ============================================================================

class TierClamp:
    """Clamps a requested SIMD tier to the hardware maximum.

    AC-2: If the requested tier exceeds the hardware maximum, effective is
    set to the hardware maximum. Otherwise effective equals requested.
    """
    requested: text
    hardware_max: text
    effective: text

impl TierClamp:

    static fn clamp(requested_name: text, hw_max_name: text) -> Self:
        """Clamp requested to min(requested, hardware_max) by rank."""
        var req_rank = tier_rank_of(requested_name)
        var hw_rank = tier_rank_of(hw_max_name)
        var eff_name = requested_name
        if req_rank > hw_rank:
            eff_name = hw_max_name
        TierClamp(requested: requested_name, hardware_max: hw_max_name, effective: eff_name)

    fn was_clamped(self) -> bool:
        self.effective == self.hardware_max and (self.requested == self.effective) == false

    fn summary(self) -> text:
        var clamped_note = ""
        if self.was_clamped():
            clamped_note = " [clamped]"
        "TierClamp(requested=" + self.requested + " hw_max=" + self.hardware_max + " effective=" + self.effective + clamped_note + ")"

# ============================================================================
# TierFallbackChain — AC-3: ordered fallback from preferred tier down to scalar
# ============================================================================

class TierFallbackChain:
    """Ordered fallback chain from preferred tier down to scalar.

    AC-3: Defines the precedence ordering used when the preferred tier is
    unavailable. Slots f0..f5 hold tier names in descending preference order.
    chain_len indicates how many slots are populated.
    """
    preferred: text
    f0: text
    f1: text
    f2: text
    f3: text
    f4: text
    f5: text
    chain_len: i32

impl TierFallbackChain:

    static fn for_x86(preferred: text) -> Self:
        """Build fallback chain for x86: preferred -> avx512 -> avx2 -> avx -> sse4 -> scalar."""
        var pref_rank = tier_rank_of(preferred)
        var slots_f0 = preferred
        var slots_f1 = "scalar"
        var slots_f2 = "scalar"
        var slots_f3 = "scalar"
        var slots_f4 = "scalar"
        var slots_f5 = "scalar"
        var length = 1
        if pref_rank >= 4 and (preferred == "avx512") == false:
            # preferred is something above avx512 — clamp to avx512 ordering
            slots_f1 = "avx2"
            slots_f2 = "avx"
            slots_f3 = "sse4"
            slots_f4 = "scalar"
            length = 5
        elif preferred == "avx512":
            slots_f1 = "avx2"
            slots_f2 = "avx"
            slots_f3 = "sse4"
            slots_f4 = "scalar"
            length = 5
        elif preferred == "avx2":
            slots_f1 = "avx"
            slots_f2 = "sse4"
            slots_f3 = "scalar"
            length = 4
        elif preferred == "avx":
            slots_f1 = "sse4"
            slots_f2 = "scalar"
            length = 3
        elif preferred == "sse4":
            slots_f1 = "scalar"
            length = 2
        TierFallbackChain(
            preferred: preferred,
            f0: slots_f0,
            f1: slots_f1,
            f2: slots_f2,
            f3: slots_f3,
            f4: slots_f4,
            f5: slots_f5,
            chain_len: length
        )

    static fn for_arm(preferred: text) -> Self:
        """Build fallback chain for ARM: preferred -> sve -> neon -> scalar."""
        var slots_f0 = preferred
        var slots_f1 = "scalar"
        var slots_f2 = "scalar"
        var slots_f3 = "scalar"
        var slots_f4 = "scalar"
        var slots_f5 = "scalar"
        var length = 1
        if preferred == "sve":
            slots_f1 = "neon"
            slots_f2 = "scalar"
            length = 3
        elif preferred == "neon":
            slots_f1 = "scalar"
            length = 2
        TierFallbackChain(
            preferred: preferred,
            f0: slots_f0,
            f1: slots_f1,
            f2: slots_f2,
            f3: slots_f3,
            f4: slots_f4,
            f5: slots_f5,
            chain_len: length
        )

    fn tier_at(self, idx: i32) -> text:
        """Return the tier name at position idx in the fallback chain."""
        if idx >= self.chain_len:
            "scalar"
        elif idx == 0:
            self.f0
        elif idx == 1:
            self.f1
        elif idx == 2:
            self.f2
        elif idx == 3:
            self.f3
        elif idx == 4:
            self.f4
        else:
            self.f5

    fn summary(self) -> text:
        var out = "TierFallbackChain(preferred=" + self.preferred + " chain=["
        var i = 0
        while i < self.chain_len:
            if i > 0:
                out = out + ","
            out = out + self.tier_at(i)
            i = i + 1
        out = out + "])"
        out
