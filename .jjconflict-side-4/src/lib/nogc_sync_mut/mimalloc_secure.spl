@no_gc
# mimalloc secure mode — abandoned segment tracking + aligned metadata + secure alloc/free
#
# Provides:
#   - MiAbandonedSegment / MiAbandonedList — cross-thread segment reclaim queue
#   - MiAllocMeta — metadata for aligned allocation verification
#   - mi_malloc_secure / mi_free_secure — zeroing wrappers for data-leak prevention
#   - mi_malloc_raw_aligned — raw allocation with alignment metadata

use std.nogc_sync_mut.mimalloc.{MiSegment, mi_zalloc, mi_free, mi_malloc_raw}

# ============================================================================
# Abandoned segment structures
# ============================================================================

struct MiAbandonedSegment:
    """A segment that was abandoned by its owning thread and is pending reclaim."""
    segment: MiSegment
    remaining_pages: i64

struct MiAbandonedList:
    """Queue of abandoned segments awaiting collection."""
    segments: [MiAbandonedSegment]

fn abandoned_list_new() -> MiAbandonedList:
    """Create an empty abandoned segment list."""
    MiAbandonedList(segments: [])

fn abandoned_push(list: MiAbandonedList, seg: MiAbandonedSegment) -> MiAbandonedList:
    """Add a segment to the abandoned list. Returns updated list."""
    MiAbandonedList(segments: list.segments.push(seg))

fn abandoned_collect(list: MiAbandonedList) -> (MiAbandonedList, [MiAbandonedSegment]):
    """Drain all abandoned segments for reclamation.

    Returns (empty list, drained segments). The caller is responsible for
    reclaiming or reinserting each segment.
    """
    val drained = list.segments
    (MiAbandonedList(segments: []), drained)

fn abandoned_count(list: MiAbandonedList) -> i64:
    """Return the number of abandoned segments in the list."""
    list.segments.len() as i64

# ============================================================================
# Allocation metadata
# ============================================================================

struct MiAllocMeta:
    """Metadata for a raw allocation: address, size, alignment, and alignment check."""
    address: usize
    size: usize
    alignment: usize
    is_aligned: bool

fn alloc_meta_new(address: usize, size: usize, alignment: usize) -> MiAllocMeta:
    """Create allocation metadata, computing is_aligned.

    is_aligned is true when alignment <= 1 (no alignment constraint) or when
    address % alignment == 0. Division by zero is avoided by the alignment <= 1
    guard.
    """
    val aligned = if alignment <= 1:
        true
    else:
        address % alignment == 0
    MiAllocMeta(address: address, size: size, alignment: alignment, is_aligned: aligned)

fn alloc_meta_verify(meta: MiAllocMeta) -> bool:
    """Return true if the metadata describes a valid, aligned, non-empty allocation."""
    meta.is_aligned and meta.size > 0

# ============================================================================
# Secure allocation / free
# ============================================================================

fn mi_malloc_secure(size: usize) -> [u8]?:
    """Allocate zeroed memory. No stale data is exposed to the caller (security)."""
    mi_zalloc(size)

fn mi_free_secure(ptr: [u8], size: usize):
    """Zero memory before freeing to prevent data leaks from reused pages.

    Zeros every byte in ptr first, then delegates to mi_free.
    """
    for i in 0..ptr.len():
        ptr[i] = 0u8
    mi_free(ptr, size)

fn mi_malloc_raw_aligned(size: usize, alignment: usize) -> MiAllocMeta:
    """Allocate raw memory and return alignment metadata.

    Delegates to mi_malloc_raw (kernel-facing, returns VirtAddr as usize).
    Wraps the result in MiAllocMeta so callers can verify alignment contracts.
    """
    val addr = mi_malloc_raw(size)
    alloc_meta_new(addr, size, alignment)

# ============================================================================
# Exports
# ============================================================================

export MiAbandonedSegment
export MiAbandonedList
export MiAllocMeta
export abandoned_list_new
export abandoned_push
export abandoned_collect
export abandoned_count
export alloc_meta_new
export alloc_meta_verify
export mi_malloc_secure
export mi_free_secure
export mi_malloc_raw_aligned
