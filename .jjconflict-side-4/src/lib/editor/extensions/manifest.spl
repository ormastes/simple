# Extension Manifest — SDN manifest types for editor extensions.
#
# Provides: ExtensionCommand, ExtensionLanguage, ExtensionDebugAdapterManifest,
#           ExtensionTheme, ExtensionKeybinding, ExtensionManifest.

use std.io_runtime.{file_read}

struct ExtensionCommand:
    id: text
    title: text

struct ExtensionLanguage:
    id: text
    extensions: [text]

struct ExtensionDebugAdapterManifest:
    id: text
    label: text
    program: text

struct ExtensionTheme:
    id: text
    label: text
    ui_theme: text
    path: text

struct ExtensionKeybinding:
    command: text
    key: text
    when: text

struct ExtensionManifest:
    name: text
    version: text
    main: text
    activation_events: [text]
    contributes_commands: [ExtensionCommand]
    contributes_languages: [ExtensionLanguage]
    contributes_debug_adapters: [ExtensionDebugAdapterManifest]
    contributes_themes: [ExtensionTheme]
    contributes_keybindings: [ExtensionKeybinding]

fn extension_manifest_empty() -> ExtensionManifest:
    ExtensionManifest(
        name: "",
        version: "",
        main: "",
        activation_events: [],
        contributes_commands: [],
        contributes_languages: [],
        contributes_debug_adapters: [],
        contributes_themes: [],
        contributes_keybindings: []
    )

fn extension_manifest_load(path: text) -> ExtensionManifest:
    val content = file_read(path) ?? ""
    if content == "":
        return extension_manifest_empty()
    var manifest = extension_manifest_empty()
    manifest.name = _extension_manifest_text_value(content, "name")
    manifest.version = _extension_manifest_text_value(content, "version")
    manifest.main = _extension_manifest_text_value(content, "main")
    manifest.activation_events = _extension_manifest_list_value(content, "activation_events")
    manifest.contributes_commands = _extension_manifest_command_list(content)
    manifest.contributes_languages = _extension_manifest_language_list(content)
    manifest.contributes_debug_adapters = _extension_manifest_debug_adapter_list(content)
    manifest.contributes_themes = []
    manifest.contributes_keybindings = []
    manifest

fn _extension_manifest_text_value(content: text, key: text) -> text:
    val lines = content.split("\n")
    val quoted = "\"" + key + "\""
    for line in lines:
        if line.index_of(quoted) >= 0:
            val parts = line.split("\"")
            var i = 0
            while i + 2 < parts.len():
                if parts[i] == key:
                    return parts[i + 2]
                i = i + 1
    ""

fn _extension_manifest_list_value(content: text, key: text) -> [text]:
    val lines = content.split("\n")
    val quoted = "\"" + key + "\""
    var result: [text] = []
    for line in lines:
        if line.index_of(quoted) >= 0:
            val parts = line.split("\"")
            var seen_key = false
            var i = 0
            while i < parts.len():
                if parts[i] == key:
                    seen_key = true
                elif seen_key and i % 2 == 1:
                    result.push(parts[i])
                i = i + 1
            return result
    result

fn _extension_manifest_command_list(content: text) -> [ExtensionCommand]:
    val ids = _extension_manifest_object_field_values(content, "id")
    val titles = _extension_manifest_object_field_values(content, "title")
    var result: [ExtensionCommand] = []
    var i = 0
    while i < ids.len():
        var title = ids[i]
        if i < titles.len():
            title = titles[i]
        result.push(ExtensionCommand(id: ids[i], title: title))
        i = i + 1
    result

fn _extension_manifest_language_list(content: text) -> [ExtensionLanguage]:
    val ids = _extension_manifest_object_field_values(content, "id")
    var result: [ExtensionLanguage] = []
    for id in ids:
        if id != "":
            result.push(ExtensionLanguage(id: id, extensions: []))
    result

fn _extension_manifest_debug_adapter_list(content: text) -> [ExtensionDebugAdapterManifest]:
    []

fn _extension_manifest_object_field_values(content: text, field: text) -> [text]:
    var values: [text] = []
    val lines = content.split("\n")
    for line in lines:
        val parts = line.split("\"")
        var i = 0
        while i + 2 < parts.len():
            if parts[i] == field and parts[i + 2] != "":
                values.push(parts[i + 2])
            i = i + 1
    values
