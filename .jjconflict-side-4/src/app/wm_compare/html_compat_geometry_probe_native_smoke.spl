use app.wm_compare.html_compat_geometry_probe.{html_compat_fixture_simple_boxes_from_html}
use gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_draw_ir}

fn _inline_fixture_html(fixture_id: text) -> text:
    if fixture_id == "24_flex_wrap_reverse_basic":
        return "<body><div id='wrap_reverse_shell' style='margin:16px;width:140px;display:flex;flex-direction:row;flex-wrap:wrap-reverse'><div id='wrap_reverse_a' style='width:60px;height:24px'></div><div id='wrap_reverse_b' style='width:60px;height:24px'></div><div id='wrap_reverse_c' style='width:60px;height:24px'></div></div></body>"
    ""

fn main() -> i64:
    val fixture_id = "24_flex_wrap_reverse_basic"
    val viewport_width = 320
    val viewport_height = 240
    val html = _inline_fixture_html("24_flex_wrap_reverse_basic")
    val boxes = html_compat_fixture_simple_boxes_from_html(fixture_id, html, viewport_width, viewport_height)
    if boxes.len() == 0:
        val composition = simple_web_layout_render_html_draw_ir(html, viewport_width, viewport_height)
        val command_count = if composition.batches.len() > 0: composition.batches[0].commands.len() else: 0
        print "status=fail"
        print "reason=no-boxes"
        print "html_len=" + html.len().to_string()
        print "batch_count=" + composition.batches.len().to_string()
        print "command_count=" + command_count.to_string()
        return 1
    print "status=pass"
    print "box_count=" + boxes.len().to_string()
    print "first_label=" + boxes[0].label
    print "first_x=" + boxes[0].x.to_string()
    print "first_y=" + boxes[0].y.to_string()
    0
