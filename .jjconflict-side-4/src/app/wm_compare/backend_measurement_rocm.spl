# ROCm/HIP device-buffer measurement capture for wm_compare backend evidence.

use app.wm_compare.backend_measurement_capture.{InitializedGpuRuntimeMeasurement, initialized_gpu_runner_comparison_sample_from_probe}
use app.wm_compare.backend_measurement_report.{BackendComparisonSample}
use std.gpu.engine2d.backend_probe.{BackendProbeResult}
use std.gc_async_mut.gpu.engine2d.rocm_session.{RocmSession}
use std.gpu.engine2d.sffi_rocm.{RocmFfi}

pub struct RocmDeviceMeasurementOptions:
    fixture_id: text
    shell: text
    command: text
    host: text
    width: i64
    height: i64
    color: i64
    binary_size_bytes: i64
    baseline_binary_size_bytes: i64
    package_size_bytes: i64

fn _positive_or_one(value: i64) -> i64:
    if value > 0: value else: 1

fn _rocm_probe_from_evidence(status: text, reason: text) -> BackendProbeResult:
    var probe = if status == "initialized":
        BackendProbeResult.success("rocm", reason)
    elif status == "failed":
        BackendProbeResult.failed("rocm", reason)
    else:
        BackendProbeResult.unavailable("rocm", reason)
    probe.api_name = "hip"
    probe.feature_gate = "rocm_device_buffer_measurement"
    probe.shader_format = "hip-cpp"
    probe.has_compute = true
    probe.has_graphics = false
    probe.has_present = false
    probe

fn _measurement_evidence(opts: RocmDeviceMeasurementOptions,
                         runtime_ready: bool,
                         module_ready: bool,
                         args_ptr: i64) -> InitializedGpuRuntimeMeasurement:
    InitializedGpuRuntimeMeasurement(
        backend: "rocm",
        operation_family: "fill",
        fixture_id: opts.fixture_id,
        shell: opts.shell,
        command: opts.command,
        host: opts.host,
        warmup_count: 0,
        sample_count: 1,
        p50_frame_us: 1,
        p95_frame_us: 1,
        max_rss_kb: 1,
        binary_size_bytes: _positive_or_one(opts.binary_size_bytes),
        baseline_binary_size_bytes: _positive_or_one(opts.baseline_binary_size_bytes),
        render_readback_scope: "render+readback",
        cold_start_us: 1,
        warm_start_us: 1,
        package_size_bytes: _positive_or_one(opts.package_size_bytes),
        p95_input_to_paint_us: 1,
        artifact_build_us: 1,
        artifact_load_us: 1,
        artifact_submit_us: 1,
        artifact_sync_us: 1,
        artifact_readback_us: 1,
        checksum: "",
        pixel_proof: "",
        device_id: "rocm:0",
        width: opts.width,
        height: opts.height,
        runtime_ready: runtime_ready,
        module_ready: module_ready,
        args_ptr: args_ptr
    )

fn _rocm_unavailable_sample(opts: RocmDeviceMeasurementOptions, reason: text) -> BackendComparisonSample:
    initialized_gpu_runner_comparison_sample_from_probe(
        _measurement_evidence(opts, false, false, 0),
        _rocm_probe_from_evidence("unavailable", reason)
    )

pub fn rocm_device_buffer_measurement_sample(opts: RocmDeviceMeasurementOptions) -> BackendComparisonSample:
    if opts.width <= 0 or opts.height <= 0:
        return _rocm_unavailable_sample(opts, "invalid ROCm/HIP measurement dimensions")
    val session = RocmSession.create_with_ffi(RocmFfi.create_static())
    val init_ev = session.init_evidence()
    if not init_ev.success:
        session.shutdown()
        return _rocm_unavailable_sample(opts, init_ev.reason)
    session.shutdown()
    _rocm_unavailable_sample(opts, "rocm-generated-session-measurement-incomplete")
