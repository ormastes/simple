# RISC-V64 entropy/time adapter surface.
#
# Keeps arch-neutral consumers from importing os.kernel.arch.riscv64 directly.

use os.kernel.arch.riscv64.timer.{Rv64Timer}
use os.kernel.arch.riscv64.cpu.{csrr_cycle, csrr_instret, csrr_time}

fn _mix64(x: u64) -> u64:
    var v = x ^ (x >> 30)
    v = v * 0xBF58476D1CE4E5B9
    v = v ^ (v >> 27)
    v = v * 0x94D049BB133111EB
    v ^ (v >> 31)

fn riscv64_boot_elapsed_us() -> u64:
    var timer = Rv64Timer()
    timer.elapsed_us()

fn riscv64_csr_entropy_seed(extra: u64) -> u64:
    _mix64(csrr_cycle() ^ csrr_time() ^ csrr_instret() ^ extra)
