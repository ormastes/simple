# Truthful readiness contract for Linux, Steam Runtime, and Proton game support.

struct GameCompatibilityTarget:
    name: text
    linux_abi: bool
    vulkan: bool
    audio: bool
    input: bool
    filesystem_prefix: bool
    network: bool
    steam_runtime: bool
    proton_host: bool
    cpu_translation: bool

fn game_compatibility_target(name: text, linux_abi: bool, vulkan: bool, audio: bool, input: bool, filesystem_prefix: bool, network: bool, steam_runtime: bool, proton_host: bool, cpu_translation: bool) -> GameCompatibilityTarget:
    GameCompatibilityTarget(name: name, linux_abi: linux_abi, vulkan: vulkan, audio: audio, input: input, filesystem_prefix: filesystem_prefix, network: network, steam_runtime: steam_runtime, proton_host: proton_host, cpu_translation: cpu_translation)

fn game_target_native_linux(linux_abi: bool, vulkan: bool, audio: bool, input: bool, filesystem_prefix: bool, network: bool) -> GameCompatibilityTarget:
    game_compatibility_target("native-linux", linux_abi, vulkan, audio, input, filesystem_prefix, network, false, false, false)

fn game_target_steam_linux(linux_abi: bool, vulkan: bool, audio: bool, input: bool, filesystem_prefix: bool, network: bool, steam_runtime: bool) -> GameCompatibilityTarget:
    game_compatibility_target("steam-linux", linux_abi, vulkan, audio, input, filesystem_prefix, network, steam_runtime, false, false)

fn game_target_proton_x86(linux_abi: bool, vulkan: bool, audio: bool, input: bool, filesystem_prefix: bool, network: bool, steam_runtime: bool, proton_host: bool) -> GameCompatibilityTarget:
    game_compatibility_target("proton-x86_64", linux_abi, vulkan, audio, input, filesystem_prefix, network, steam_runtime, proton_host, false)

fn game_target_proton_translated(linux_abi: bool, vulkan: bool, audio: bool, input: bool, filesystem_prefix: bool, network: bool, steam_runtime: bool, proton_host: bool, cpu_translation: bool) -> GameCompatibilityTarget:
    game_compatibility_target("proton-translated", linux_abi, vulkan, audio, input, filesystem_prefix, network, steam_runtime, proton_host, cpu_translation)

fn game_target_simple_native(vulkan: bool, audio: bool, input: bool, filesystem_prefix: bool, network: bool) -> GameCompatibilityTarget:
    game_compatibility_target("simple-native", false, vulkan, audio, input, filesystem_prefix, network, false, false, false)

fn game_target_ready(t: GameCompatibilityTarget) -> bool:
    val base_ready = t.vulkan and t.audio and t.input and t.filesystem_prefix and t.network
    if t.name == "simple-native":
        return base_ready
    if t.name == "native-linux":
        return t.linux_abi and base_ready
    if t.name == "steam-linux":
        return t.linux_abi and base_ready and t.steam_runtime
    if t.name == "proton-x86_64":
        return t.linux_abi and base_ready and t.steam_runtime and t.proton_host
    if t.name == "proton-translated":
        return t.linux_abi and base_ready and t.steam_runtime and t.proton_host and t.cpu_translation
    false

fn game_target_blocker(t: GameCompatibilityTarget) -> text:
    if not t.linux_abi and t.name != "simple-native":
        return "missing-linux-abi"
    if not t.vulkan:
        return "missing-vulkan"
    if not t.audio:
        return "missing-audio"
    if not t.input:
        return "missing-input"
    if not t.filesystem_prefix:
        return "missing-filesystem-prefix"
    if not t.network:
        return "missing-network"
    if (t.name == "steam-linux" or t.name == "proton-x86_64" or t.name == "proton-translated") and not t.steam_runtime:
        return "missing-steam-runtime"
    if (t.name == "proton-x86_64" or t.name == "proton-translated") and not t.proton_host:
        return "missing-proton-host"
    if t.name == "proton-translated" and not t.cpu_translation:
        return "missing-cpu-translation"
    if game_target_ready(t):
        return "ready"
    "unknown-target:" + t.name

struct GameRuntimePrefix:
    app_id: text
    root: bool
    compatdata: bool
    shadercache: bool
    saves: bool
    logs: bool
    config: bool

fn game_runtime_prefix(app_id: text, root: bool, compatdata: bool, shadercache: bool, saves: bool, logs: bool, config: bool) -> GameRuntimePrefix:
    GameRuntimePrefix(app_id: app_id, root: root, compatdata: compatdata, shadercache: shadercache, saves: saves, logs: logs, config: config)

fn game_runtime_prefix_ready(p: GameRuntimePrefix) -> bool:
    p.root and p.compatdata and p.shadercache and p.saves and p.logs and p.config

fn game_runtime_prefix_blocker(p: GameRuntimePrefix) -> text:
    if not p.root:
        return "missing-root:/games/app_" + p.app_id + "/root"
    if not p.compatdata:
        return "missing-compatdata:/games/app_" + p.app_id + "/compatdata/pfx"
    if not p.shadercache:
        return "missing-shadercache:/games/app_" + p.app_id + "/shadercache"
    if not p.saves:
        return "missing-saves:/games/app_" + p.app_id + "/saves"
    if not p.logs:
        return "missing-logs:/games/app_" + p.app_id + "/logs"
    if not p.config:
        return "missing-config:/games/app_" + p.app_id + "/config.sdn"
    "ready"

fn game_target_marker(t: GameCompatibilityTarget) -> text:
    "[game-platform] target=" + t.name + " blocker=" + game_target_blocker(t)
