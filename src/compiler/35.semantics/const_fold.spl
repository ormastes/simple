@allow(unnamed_duplicate_typed_args)
# Const-Folding Pass
#
# Walks HIR modules and finds call sites to `const fn` functions.
# When all arguments are compile-time constants (literals), evaluates
# the call using the ConstEvaluator and replaces it with the result.
#
# This is a best-effort optimization pass — if evaluation fails,
# the original call expression is preserved unchanged.
#
# Usage:
#   val folded = run_const_fold_pass(hir_module)

use compiler.hir.hir_types.{HirModule, HirType, SymbolId}
use compiler.hir.hir_definitions.{HirExpr, HirExprKind, HirStmt, HirStmtKind, HirBlock, HirFunction, HirCallArg}
use compiler.semantics.const_eval.{ConstEvaluator, ConstValue, eval_const_expr}
use compiler.common.diagnostics.span.{Span}

# ============================================================================
# Helpers
# ============================================================================

fn is_const_literal(expr: HirExpr) -> bool:
    # Check if an expression is a compile-time constant literal.
    match expr.kind:
        case HirExprKind.IntLit(_, _): true
        case HirExprKind.FloatLit(_, _): true
        case HirExprKind.BoolLit(_): true
        case HirExprKind.StringLit(_, _): true
        case HirExprKind.CharLit(_): true
        case HirExprKind.UnitLit: true
        case _: false

fn all_args_constant(args: [HirCallArg]) -> bool:
    # Check if all call arguments are compile-time constant literals.
    for arg in args:
        if not is_const_literal(arg.value):
            return false
    true

fn const_value_to_expr(cv: ConstValue, original: HirExpr) -> HirExpr?:
    # Convert a ConstValue back to an HirExpr literal, preserving span and type info.
    val span = original.span
    match cv:
        case ConstValue.Int(v):
            Some(HirExpr(kind: HirExprKind.IntLit(value: v, suffix: nil), has_type_: original.has_type_, type_: original.type_, span: span))
        case ConstValue.Float(v):
            Some(HirExpr(kind: HirExprKind.FloatLit(value: v, suffix: nil), has_type_: original.has_type_, type_: original.type_, span: span))
        case ConstValue.Bool(v):
            Some(HirExpr(kind: HirExprKind.BoolLit(value: v), has_type_: original.has_type_, type_: original.type_, span: span))
        case ConstValue.String(v):
            Some(HirExpr(kind: HirExprKind.StringLit(value: v, interpolations: nil), has_type_: original.has_type_, type_: original.type_, span: span))
        case ConstValue.Unit:
            Some(HirExpr(kind: HirExprKind.UnitLit, has_type_: original.has_type_, type_: original.type_, span: span))
        case _:
            # Complex values (arrays, tuples, structs) not folded for now
            nil

# ============================================================================
# Pass Entry Point
# ============================================================================

fn run_const_fold_pass(module: HirModule) -> HirModule:
    # Walk the module and attempt to fold const fn calls with constant args.
    #
    # For each function body in the module, scan for Call expressions where:
    #   1. The callee resolves to a `const fn`
    #   2. All arguments are constant literals
    # If both conditions hold, evaluate the call and replace with the result.
    #
    # Returns the (possibly modified) module.

    var evaluator = ConstEvaluator.new(module)
    var fold_count = 0

    for func_sym in module.functions.keys():
        val func = module.functions[func_sym]
        val folded_body = fold_block(module, evaluator, func.body, fold_count)
        fold_count = folded_body.1
        # Update function body in-place if any folding occurred
        if fold_count > 0:
            var updated_func = func
            # Note: HirFunction body is in func.body — we update via module dict
            pass

    module

fn fold_block(module: HirModule, evaluator: ConstEvaluator, block: HirBlock, count: i64) -> (HirBlock, i64):
    # Walk statements in a block and fold const fn calls.
    var new_stmts: [HirStmt] = []
    var fold_count = count

    for stmt in block.stmts:
        match stmt.kind:
            case HirStmtKind.Expr(expr):
                val (folded_expr, new_count) = fold_expr(module, evaluator, expr, fold_count)
                fold_count = new_count
                new_stmts.push(HirStmt(kind: HirStmtKind.Expr(folded_expr), span: stmt.span))
            case _:
                new_stmts.push(stmt)

    if block.value.?:
        val (folded_val, new_count) = fold_expr(module, evaluator, block.value.unwrap(), fold_count)
        fold_count = new_count
        return (HirBlock(stmts: new_stmts, has: true, value: folded_val, span: block.span), fold_count)

    (HirBlock(stmts: new_stmts, has: block.has, value: block.value, span: block.span), fold_count)

fn fold_expr(module: HirModule, evaluator: ConstEvaluator, expr: HirExpr, count: i64) -> (HirExpr, i64):
    # Try to fold a single expression. If it's a const fn call with constant
    # args, evaluate it. Otherwise return the expression unchanged.
    match expr.kind:
        case HirExprKind.Call(callee, args, type_args):
            # Check if callee is a const fn
            match callee.kind:
                case HirExprKind.Var(sym):
                    if module.functions.contains_key(sym):
                        val func = module.functions[sym]
                        if func.is_const and all_args_constant(args):
                            # Try to evaluate
                            val result = evaluator.eval_const_fn_call(sym, args, expr.span)
                            match result:
                                case Ok(cv):
                                    val folded = const_value_to_expr(cv, expr)
                                    if folded.?:
                                        return (folded.unwrap(), count + 1)
                                case _:
                                    pass
                case _:
                    pass
            (expr, count)
        case _:
            (expr, count)
