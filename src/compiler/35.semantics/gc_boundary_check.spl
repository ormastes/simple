# GC Boundary Semantic Check
#
# Wires the GcBoundaryChecker into the semantic analysis pipeline.
# Checks that cross-family imports respect GC mode boundaries:
# - nogc_* modules should not import from gc_* families
# - nogc_*_noalloc modules should not import from any allocating family
#
# Produces warnings (not errors) to alert developers about potential
# ownership/lifetime issues at GC mode boundaries.

use compiler.common.gc_config.{GcMode, GcConfig, gc_mode_from_family_prefix, is_noalloc_family}
use compiler.common.gc_boundary.{GcBoundaryChecker, GC_BOUNDARY_LINT_NAME}
use compiler.common.diagnostics.span.{Span}


# ============================================================================
# Cross-Family Import Warning
# ============================================================================

struct FamilyImportWarning:
    """Warning about a cross-family import that crosses GC boundaries."""
    source_module: text
    imported_module: text
    message: text

struct RuntimeFamilyManifestEntry:
    """Canonical runtime-family capability manifest entry."""
    family: text
    gc_mode: text
    rank: i64
    allocates: bool
    noalloc: bool

struct FamilyImportViolation:
    """Hard runtime-family import violation backed by the manifest table."""
    source_module: text
    imported_module: text
    reason: text
    message: text

val RUNTIME_FAMILY_MANIFEST: [RuntimeFamilyManifestEntry] = [
    RuntimeFamilyManifestEntry(family: "common", gc_mode: "neutral", rank: 0, allocates: false, noalloc: false),
    RuntimeFamilyManifestEntry(family: "nogc_async_mut_noalloc", gc_mode: "nogc", rank: 1, allocates: false, noalloc: true),
    RuntimeFamilyManifestEntry(family: "nogc_async_mut", gc_mode: "nogc", rank: 2, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "nogc_async_immut", gc_mode: "nogc", rank: 2, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "nogc_sync_immut", gc_mode: "nogc", rank: 2, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "async", gc_mode: "nogc", rank: 3, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "nogc_sync_mut", gc_mode: "nogc", rank: 3, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "gc_async_mut", gc_mode: "gc", rank: 4, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "gc_async_immut", gc_mode: "gc", rank: 4, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "gc_sync_mut", gc_mode: "gc", rank: 4, allocates: true, noalloc: false),
    RuntimeFamilyManifestEntry(family: "gc_sync_immut", gc_mode: "gc", rank: 4, allocates: true, noalloc: false)
]

fn is_common_family_path(module_path: text) -> bool:
    """Return true for the neutral common runtime family.

    Common is parsed as GC by `gc_mode_from_family_prefix` because it inherits
    the default pointer mode, but it is not a GC runtime family for import
    boundary warnings.
    """
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("common")

fn normalized_family_path(module_path: text) -> text:
    """Strip import prefixes before runtime-family classification."""
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path

fn runtime_family_manifest_entry(module_path: text) -> RuntimeFamilyManifestEntry:
    """Return the manifest entry for a runtime family path.

    Unknown paths return an entry with rank `-1` and `gc_mode == "unknown"`.
    The manifest is ordered from most-specific to least-specific names so
    `nogc_async_mut_noalloc` is classified before `nogc_async_mut`.
    """
    val path = normalized_family_path(module_path)
    for entry in RUNTIME_FAMILY_MANIFEST:
        if path.starts_with(entry.family):
            return entry
    RuntimeFamilyManifestEntry(family: "", gc_mode: "unknown", rank: -1, allocates: false, noalloc: false)

fn runtime_family_rank(module_path: text) -> i64:
    """Return dependency rank for stdlib runtime families.

    Lower ranks are allowed backend dependencies. Higher ranks are adapter or
    hosted layers and must not be imported by lower layers.
    """
    runtime_family_manifest_entry(module_path).rank

fn is_known_runtime_family_path(module_path: text) -> bool:
    runtime_family_rank(module_path) >= 0

fn import_violation_reason(source_module: text, imported_module: text) -> text:
    """Return a hard violation reason for a runtime-family import, or empty text."""
    val source = runtime_family_manifest_entry(source_module)
    val imported = runtime_family_manifest_entry(imported_module)
    if source.rank < 0 or imported.rank < 0:
        return ""
    if imported.gc_mode == "neutral":
        return ""

    if source.noalloc and imported.gc_mode == "gc":
        return "noalloc_imports_gc_family"

    if source.noalloc and imported.allocates:
        return "noalloc_imports_allocating_family"

    if source.gc_mode == "nogc" and imported.gc_mode == "gc":
        return "nogc_imports_gc_family"

    # Symmetric: GC family must not import from NoGC families
    if source.gc_mode == "gc" and imported.gc_mode == "nogc":
        return "gc_imports_nogc_family"

    if imported.rank > source.rank:
        return "higher_layer_runtime_family"

    ""

fn check_runtime_family_import_violations(source_module: text, imported_modules: [text]) -> [FamilyImportViolation]:
    """Return manifest-backed hard runtime-family import violations.

    This is the hard-error model used by compiler/target integrations. The
    legacy warning API remains available for lints and compatibility output.
    """
    var violations: [FamilyImportViolation] = []
    for imported in imported_modules:
        val reason = import_violation_reason(source_module, imported)
        if reason != "":
            violations.push(FamilyImportViolation(
                source_module: source_module,
                imported_module: imported,
                reason: reason,
                message: "error[{GC_BOUNDARY_LINT_NAME}]: runtime family '{source_module}' cannot import '{imported}' ({reason})"
            ))
    violations


# ============================================================================
# GC Boundary Semantic Pass
# ============================================================================

fn check_gc_boundary_imports(source_module: text, imported_modules: [text]) -> [FamilyImportWarning]:
    """Check a module's imports for GC boundary violations.

    Arguments:
    - source_module: The module path of the file being compiled (e.g., "std.nogc_sync_mut.fs")
    - imported_modules: List of module paths imported by the source module

    Returns a list of warnings for cross-GC-boundary imports.

    sdoctest:
        expect(check_gc_boundary_imports("nogc_sync_mut.fs", ["gc_async_mut.task"]).len()).to_equal(1)
        expect(check_gc_boundary_imports("nogc_sync_mut.fs", ["common.text"]).len()).to_equal(0)
        expect(check_gc_boundary_imports("gc_async_mut.task", ["nogc_sync_mut.fs"]).len()).to_equal(0)
    """
    var warnings: [FamilyImportWarning] = []

    val source_rank = runtime_family_rank(source_module)
    val source_gc = gc_mode_from_family_prefix(source_module)

    # Only check if source module is in a nogc family
    if source_gc.is_gc():
        if not source_gc.explicit and source_rank < 0:
            return warnings  # Unknown family, skip check

    for imported in imported_modules:
        if is_common_family_path(imported):
            continue

        val violation_reason = import_violation_reason(source_module, imported)

        # Rule 0: runtime-family dependency direction must flow from hosted
        # adapters down toward async/no-GC backends and common contracts.
        if violation_reason == "higher_layer_runtime_family":
            warnings.push(FamilyImportWarning(
                source_module: source_module,
                imported_module: imported,
                message: "error[{GC_BOUNDARY_LINT_NAME}]: runtime family '{source_module}' imports higher-layer family '{imported}'"
            ))

        # Rule 1: nogc_*_noalloc must not import from any allocating family
        if violation_reason == "noalloc_imports_gc_family":
            warnings.push(FamilyImportWarning(
                source_module: source_module,
                imported_module: imported,
                message: "error[{GC_BOUNDARY_LINT_NAME}]: no-alloc module '{source_module}' imports GC family '{imported}'"
            ))
        elif violation_reason == "noalloc_imports_allocating_family":
            warnings.push(FamilyImportWarning(
                source_module: source_module,
                imported_module: imported,
                message: "error[{GC_BOUNDARY_LINT_NAME}]: no-alloc module '{source_module}' imports allocating family '{imported}'"
            ))

        # Rule 2: nogc_* must not import from gc_* families
        elif violation_reason == "nogc_imports_gc_family":
            warnings.push(FamilyImportWarning(
                source_module: source_module,
                imported_module: imported,
                message: "error[{GC_BOUNDARY_LINT_NAME}]: no-gc module '{source_module}' imports GC family '{imported}'"
            ))

        # Rule 3: gc_* must not import from nogc_* families (symmetric)
        elif violation_reason == "gc_imports_nogc_family":
            warnings.push(FamilyImportWarning(
                source_module: source_module,
                imported_module: imported,
                message: "error[{GC_BOUNDARY_LINT_NAME}]: gc module '{source_module}' imports no-gc family '{imported}'"
            ))

    warnings

fn format_family_warnings(warnings: [FamilyImportWarning]) -> [text]:
    """Format family import warnings as human-readable messages.

    sdoctest:
        expect(format_family_warnings([]).len()).to_equal(0)
        expect(format_family_warnings([FamilyImportWarning(source_module: "a", imported_module: "b", message: "warn!")]).len()).to_equal(1)
        expect(format_family_warnings([FamilyImportWarning(source_module: "a", imported_module: "b", message: "warn!")]).to_contain("warn!")).to_equal(true)
    """
    var messages: [text] = []
    for w in warnings:
        messages.push(w.message)
    messages

export FamilyImportWarning, RuntimeFamilyManifestEntry, FamilyImportViolation
export RUNTIME_FAMILY_MANIFEST
export runtime_family_manifest_entry, runtime_family_rank
export check_gc_boundary_imports, format_family_warnings
