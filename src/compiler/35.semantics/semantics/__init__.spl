# Semantics Module
#
# Shared semantic definitions for interpreter and codegen.
#
# This module provides a single source of truth for language semantics
# that must be consistent between the interpreter and compiled code.
#
# Motivation:
# Previously, the interpreter and codegen independently implemented:
# - Type coercion rules
# - Truthiness evaluation
# - Binary/unary operation semantics
# - Method dispatch logic
#
# This led to bitwise_not(2),600 lines of duplicated logic. This module unifies these
# definitions to ensure semantic consistency and reduce maintenance burden.

mod binary_ops
mod cast_rules
mod truthiness
mod type_coercion

# Binary operations
export use .binary_ops.{BinaryOpResult, BinaryOpSemantics}

# Cast rules
export use .cast_rules.{NumericType, CastNumericResult}
export use .cast_rules.{cast_int_to_numeric, cast_float_to_numeric}
use cast_rules.cast_bool_to_numeric
export cast_bool_to_numeric
export use .cast_rules.{BoolCast, StringCast}

# Truthiness rules
use truthiness.TruthinessRules
export TruthinessRules

# Type coercion
export use .type_coercion.{CoercionResult, TypeCoercion}

# Re-exported from binary_ops.spl
export BinaryOpResult, BinaryOpSemantics

# Re-exported from cast_rules.spl
export NumericType, CastNumericResult
export cast_int_to_numeric, cast_float_to_numeric, cast_bool_to_numeric
export BoolCast, StringCast

# Re-exported from truthiness.spl
export TruthinessRules

# Re-exported from type_coercion.spl
export CoercionResult, TypeCoercion
