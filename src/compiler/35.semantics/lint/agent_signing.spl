# Agent Signing — HMAC-Based Signing for Lint Verification Results
#
# Each agent derives a per-agent HMAC key from a master secret and its
# agent_id. Lint results are signed with this key and can be verified
# by any party that knows the master secret and the agent_id.
# Keys are never stored on disk — derived on demand.

use std.nogc_sync_mut.io.crypto_ffi.{hmac_sha256, hmac_verify}
use compiler.semantics.lint.required_comment.{RequiredCommentWarning}

# ============================================================================
# Data Structures
# ============================================================================

class SignedLintResult:
    agent_id: text
    timestamp: i64
    payload: text
    signature: text

# ============================================================================
# Key Derivation
# ============================================================================

fn derive_agent_key(master_key: text, agent_id: text) -> text:
    """Derive a per-agent key from the master key using HMAC-SHA256."""
    hmac_sha256(master_key, agent_id)

# ============================================================================
# Signing and Verification
# ============================================================================

fn sign_lint_result(master_key: text, agent_id: text, warnings: [RequiredCommentWarning]) -> SignedLintResult:
    """Sign a list of warnings and produce a SignedLintResult."""
    val payload = serialize_warnings(warnings)
    val agent_key = derive_agent_key(master_key, agent_id)
    val sig = hmac_sha256(agent_key, payload)
    SignedLintResult(
        agent_id: agent_id,
        timestamp: 0,
        payload: payload,
        signature: sig
    )

fn verify_lint_result(master_key: text, result: SignedLintResult) -> bool:
    """Verify the signature on a SignedLintResult."""
    val agent_key = derive_agent_key(master_key, result.agent_id)
    hmac_verify(agent_key, result.payload, result.signature)

# ============================================================================
# Serialization
# ============================================================================

fn serialize_warnings(warnings: [RequiredCommentWarning]) -> text:
    """Deterministic serialization of warnings for signing."""
    var parts: [text] = []
    for w in warnings:
        parts.push("code:{w.code}|severity:{w.severity}|message:{w.message}|site:{w.site_name}|line:{w.line}")
    parts.join("\n")
