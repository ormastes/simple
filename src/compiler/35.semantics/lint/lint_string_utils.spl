# Lint String Utilities
#
# Shared text-search helpers used by multiple security lint modules.

fn find_substring(haystack: text, needle: text) -> i64:
    """Find the first occurrence of needle in haystack."""
    if needle.len() == 0:
        return 0
    if haystack.len() < needle.len():
        return -1
    var i = 0
    val limit = haystack.len() - needle.len() + 1
    while i < limit:
        if haystack.slice(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1
