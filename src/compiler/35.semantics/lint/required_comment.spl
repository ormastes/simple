# Required Comment Lint
#
# Detects pass_todo, pass_do_nothing, pass_dn nodes and dangerous keyword
# calls that are missing a required comment string argument.
#
# REQC001: pass_* used without a comment string           WARNING
# REQC002: Dangerous keyword call without a comment       WARNING
# REQC003: todo(...) without useful rationale             WARNING
# REQC004: wildcard match arm without rationale           WARNING
#
# Works with the arena-based core AST (integer-tagged nodes).

use compiler.core.ast_expr.{
    expr_get_tag, expr_get_str, expr_get_left, expr_get_right,
    expr_get_extra, expr_get_args, expr_get_stmts
}
use compiler.core.ast_stmt.{
    stmt_get_tag, stmt_get_expr, stmt_get_body
}
use compiler.core.ast.{
    decl_get_tag, decl_get_name, decl_get_body,
    arm_get_pattern, arm_get_guard, arm_get_body, arm_get_rationale
}
use compiler.frontend.core.dangerous_keywords.{is_dangerous_keyword}

# ============================================================================
# Warning Struct
# ============================================================================

class RequiredCommentWarning:
    code: text
    severity: text
    message: text
    hint: text
    site_name: text
    line: i64

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message} at '{self.site_name}' line {self.line} — {self.hint}"

# ============================================================================
# Main Entry Point
# ============================================================================

fn check_required_comment(decl_indices: [i64]) -> [RequiredCommentWarning]:
    """Walk module declarations and check pass_* and dangerous keyword nodes."""
    var warnings: [RequiredCommentWarning] = []

    for idx in decl_indices:
        val tag = decl_get_tag(idx)

        if tag != 1:
            continue

        val fn_name = decl_get_name(idx)
        val body = decl_get_body(idx)

        for stmt_idx in body:
            val stmt_warnings = _check_stmt(stmt_idx, fn_name)
            for warning in stmt_warnings:
                warnings.push(warning)

    warnings

fn _is_weak_rationale(msg: text) -> bool:
    val t = msg.trim().lower()
    if t == "":
        return true
    if t.len() < 10:
        return true
    if t == "todo" or t == "fix" or t == "later" or t == "unknown":
        return true
    if t == "because" or t == "n/a" or t == "na":
        return true
    false

# ============================================================================
# Statement and Expression Walking
# ============================================================================

fn _check_stmt(stmt_idx: i64, site_name: text) -> [RequiredCommentWarning]:
    var warnings: [RequiredCommentWarning] = []
    if stmt_idx < 0:
        return warnings
    val tag = stmt_get_tag(stmt_idx)

    if tag == 1:
        val e = stmt_get_expr(stmt_idx)
        val expr_warnings = _check_expr(e, site_name)
        for warning in expr_warnings:
            warnings.push(warning)
    elif tag == 5:
        val e = stmt_get_expr(stmt_idx)
        if e >= 0:
            val expr_warnings = _check_expr(e, site_name)
            for warning in expr_warnings:
                warnings.push(warning)
    elif tag == 10:
        val body = stmt_get_body(stmt_idx)
        for s in body:
            val stmt_warnings = _check_stmt(s, site_name)
            for warning in stmt_warnings:
                warnings.push(warning)
    elif tag == 6:
        val body = stmt_get_body(stmt_idx)
        for s in body:
            val stmt_warnings = _check_stmt(s, site_name)
            for warning in stmt_warnings:
                warnings.push(warning)
    elif tag == 7:
        val body = stmt_get_body(stmt_idx)
        for s in body:
            val stmt_warnings = _check_stmt(s, site_name)
            for warning in stmt_warnings:
                warnings.push(warning)
    elif tag == 8:
        val body = stmt_get_body(stmt_idx)
        for s in body:
            val stmt_warnings = _check_stmt(s, site_name)
            for warning in stmt_warnings:
                warnings.push(warning)
    elif tag == 9:
        val e = stmt_get_expr(stmt_idx)
        val expr_warnings = _check_expr(e, site_name)
        for warning in expr_warnings:
            warnings.push(warning)
        val arms = stmt_get_body(stmt_idx)
        for arm_idx in arms:
            val arm_warnings = _check_match_arm(arm_idx, site_name)
            for warning in arm_warnings:
                warnings.push(warning)
    warnings

fn _check_match_arm(arm_idx: i64, site_name: text) -> [RequiredCommentWarning]:
    var warnings: [RequiredCommentWarning] = []
    if arm_idx < 0:
        return warnings
    val pattern = arm_get_pattern(arm_idx)
    val pattern_warnings = _check_expr(pattern, site_name)
    for warning in pattern_warnings:
        warnings.push(warning)
    val guard = arm_get_guard(arm_idx)
    if guard >= 0:
        val guard_warnings = _check_expr(guard, site_name)
        for warning in guard_warnings:
            warnings.push(warning)
    if pattern >= 0 and expr_get_tag(pattern) == 6 and expr_get_str(pattern) == "_":
        val rationale = arm_get_rationale(arm_idx)
        if _is_weak_rationale(rationale):
            warnings.push(RequiredCommentWarning(
                code: "REQC004",
                severity: "warn",
                message: "wildcard match arm used without a rationale",
                hint: "Use case _(\"why catch-all is correct\"):",
                site_name: site_name,
                line: 0
            ))
    val body = arm_get_body(arm_idx)
    for s in body:
        val stmt_warnings = _check_stmt(s, site_name)
        for warning in stmt_warnings:
            warnings.push(warning)
    warnings

fn _check_expr(expr_idx: i64, site_name: text) -> [RequiredCommentWarning]:
    var warnings: [RequiredCommentWarning] = []
    if expr_idx < 0:
        return warnings
    val tag = expr_get_tag(expr_idx)

    # Check pass_* nodes for missing comment
    val is_pass_todo = tag == 40
    val is_pass_dn = tag == 43
    val is_pass_do_nothing = tag == 41
    val is_pass = is_pass_todo or is_pass_dn
    val is_any_pass = is_pass or is_pass_do_nothing

    if is_any_pass:
        val msg = expr_get_str(expr_idx)
        if _is_weak_rationale(msg):
            val w = RequiredCommentWarning(
                code: "REQC001",
                severity: "warn",
                message: "pass_* used without a comment string",
                hint: "Add a rationale: pass_todo(\"what remains\", \"hint or issue\")",
                site_name: site_name,
                line: 0
            )
            warnings.push(w)
        return warnings

    if tag == 9:
        val callee_idx = expr_get_left(expr_idx)
        if callee_idx >= 0:
            val callee_tag = expr_get_tag(callee_idx)
            if callee_tag == 6:
                val callee_name = expr_get_str(callee_idx)
                if callee_name == "todo":
                    val args = expr_get_args(expr_idx)
                    var has_what = false
                    var has_hint = false
                    if args.len() > 0 and args[0] >= 0 and expr_get_tag(args[0]) == 3:
                        has_what = not _is_weak_rationale(expr_get_str(args[0]))
                    if args.len() > 1 and args[1] >= 0 and expr_get_tag(args[1]) == 3:
                        has_hint = not _is_weak_rationale(expr_get_str(args[1]))
                    if not has_what or not has_hint:
                        warnings.push(RequiredCommentWarning(
                            code: "REQC003",
                            severity: "warn",
                            message: "todo used without what-remains and next-step strings",
                            hint: "Use todo(\"what remains\", \"hint or issue\")",
                            site_name: site_name,
                            line: 0
                        ))
                if is_dangerous_keyword(callee_name):
                    val args = expr_get_args(expr_idx)
                    var has_comment = false
                    if args.len() > 0:
                        val first_arg = args[0]
                        if first_arg >= 0:
                            val first_tag = expr_get_tag(first_arg)
                            if first_tag == 3:
                                val first_val = expr_get_str(first_arg)
                                if not _is_weak_rationale(first_val):
                                    has_comment = true
                    if not has_comment:
                        val w = RequiredCommentWarning(
                            code: "REQC002",
                            severity: "warn",
                            message: "dangerous keyword '{callee_name}' used without a comment string",
                            hint: "Add a comment: {callee_name}(\"reason\")",
                            site_name: site_name,
                            line: 0
                        )
                        warnings.push(w)
        val args2 = expr_get_args(expr_idx)
        for arg in args2:
            val arg_warnings = _check_expr(arg, site_name)
            for warning in arg_warnings:
                warnings.push(warning)
        return warnings

    if tag == 15:
        val left_warnings = _check_expr(expr_get_left(expr_idx), site_name)
        for warning in left_warnings:
            warnings.push(warning)
        val arms = expr_get_args(expr_idx)
        for arm_idx in arms:
            val arm_warnings = _check_match_arm(arm_idx, site_name)
            for warning in arm_warnings:
                warnings.push(warning)
        return warnings

    if tag == 7:
        val left_warnings = _check_expr(expr_get_left(expr_idx), site_name)
        for warning in left_warnings:
            warnings.push(warning)
        val right_warnings = _check_expr(expr_get_right(expr_idx), site_name)
        for warning in right_warnings:
            warnings.push(warning)
    elif tag == 8:
        val left_warnings = _check_expr(expr_get_left(expr_idx), site_name)
        for warning in left_warnings:
            warnings.push(warning)
    elif tag == 14:
        val left_warnings = _check_expr(expr_get_left(expr_idx), site_name)
        for warning in left_warnings:
            warnings.push(warning)
        val right_warnings = _check_expr(expr_get_right(expr_idx), site_name)
        for warning in right_warnings:
            warnings.push(warning)
        val extra_warnings = _check_expr(expr_get_extra(expr_idx), site_name)
        for warning in extra_warnings:
            warnings.push(warning)
    elif tag == 18:
        val body = expr_get_stmts(expr_idx)
        for s in body:
            val stmt_warnings = _check_stmt(s, site_name)
            for warning in stmt_warnings:
                warnings.push(warning)
    warnings
