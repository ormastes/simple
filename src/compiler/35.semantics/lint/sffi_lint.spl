#![allow(export_outside_init)]
# SFFI Lint Rules
#
# Compile-time lint checks for SFFI bidirectional class interop.
# Validates that @export("C") classes have C-compatible layouts and types.
#
# SFFI001: Non-C-compatible field type in exported class              ERROR
#          (Note: plain function pointers Fn<(A) -> B> are ALLOWED;
#           only closures with captures Fn<...>[...] are rejected)
# SFFI002: text field in exported struct (needs marshalling)          WARNING
# SFFI003: Struct passed by-value without @repr("C")                  ERROR
# SFFI004: Bitfield without explicit width                            ERROR
# SFFI005: Platform-dependent type size in FFI struct                 ERROR/WARNING
# SFFI006: Callback parameter without ownership documentation         WARNING
# SFFI008: Invalid @platform layout annotation                         ERROR/WARNING
#
# These checks run on HirClass definitions at the semantic analysis stage,
# catching ABI safety issues before code generation.
#
# ============================================================================

from hir_definitions import {HirClass, HirStruct, HirField}
from hir_types import {HirType, HirTypeKind}
from compiler.types.type_layout import {LayoutKind}
from compiler.core.types import {TYPE_BOOL, TYPE_I64, TYPE_F64}
from compiler.core.types import {custom_primitive_underlying_type_tag_by_symbol}


# ============================================================================
# Warning Struct
# ============================================================================

struct SffiLintWarning:
    code: text          # SFFI001, SFFI002, etc.
    severity: text      # "ERROR" or "WARNING"
    message: text
    hint: text
    line_num: i64
    file_path: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.file_path}:{self.line_num} — {self.message} — {self.hint}"


# ============================================================================
# C-Compatibility Helpers
# ============================================================================

fn _is_c_compatible_primitive(kind: HirTypeKind) -> bool:
    """Check if a HirTypeKind is a C-compatible primitive type.

    C-compatible types: all fixed-size integers, floats, bool.
    NOT compatible: text (Str), collections, optionals, closures.
    """
    match kind:
        case Int(bits, signed): true
        case Float(bits): true
        case Bool: true
        case Char: true
        case Unit: true
        case Ptr(inner, mutable): true
        case _: false

fn _is_c_compatible_type_tag(tag: i64) -> bool:
    tag == TYPE_BOOL or tag == TYPE_I64 or tag == TYPE_F64

fn _is_c_compatible_type(type_: HirType) -> bool:
    match type_.kind:
        case Named(symbol, args):
            val underlying = custom_primitive_underlying_type_tag_by_symbol(symbol.id)
            if underlying >= 0:
                return _is_c_compatible_type_tag(underlying)
            false
        case _:
            _is_c_compatible_primitive(type_.kind)

fn _is_text_type(kind: HirTypeKind) -> bool:
    """Check if a type is the text/Str type (pointer in C, needs marshalling)."""
    match kind:
        case Str: true
        case _: false

fn _is_collection_type(kind: HirTypeKind) -> bool:
    """Check if a type is a collection (List, Dict, etc.)."""
    match kind:
        case Array(element, size): true
        case Slice(element): true
        case Dict(key, value): true
        case Tuple(elements): true
        case _: false

fn _is_optional_type(kind: HirTypeKind) -> bool:
    """Check if a type is Optional<T>."""
    match kind:
        case Optional(inner): true
        case _: false

fn _is_function_type(kind: HirTypeKind) -> bool:
    """Check if a type is a function/closure type."""
    match kind:
        case Function(params, ret, effects): true
        case _: false

fn _is_callback_function_type(kind: HirTypeKind) -> bool:
    """Check if a type is a plain function pointer (stateless, no captures).

    Plain function pointers have a stable C ABI and can cross the FFI
    boundary as typedef'd function pointer types. Closures with captures
    carry hidden state and are NOT allowed.

    In HIR, Function types without a capture list represent plain function
    pointers. The effects field distinguishes: empty effects = stateless.
    """
    match kind:
        case Function(params, ret, effects):
            # A function type with no effects/captures is a plain function pointer
            # that maps to a C callback typedef. If effects contains "captures",
            # it's a closure and should be rejected.
            not effects.contains("captures")
        case _: false

fn _is_platform_dependent_type(kind: HirTypeKind) -> bool:
    """Check if a type has platform-dependent size.

    Currently isize/usize vary by platform. All other Simple types
    are fixed-size. This is a guard for future types too.
    """
    match kind:
        case Named(symbol, args):
            # Named types could be isize/usize aliases
            # For now, these are caught by the Named check below
            false
        case _: false

fn _type_kind_name(kind: HirTypeKind) -> text:
    """Get a human-readable name for a type kind."""
    match kind:
        case Int(bits, signed):
            if signed:
                "i{bits}"
            else:
                "u{bits}"
        case Float(bits): "f{bits}"
        case Bool: "bool"
        case Char: "char"
        case Str: "text"
        case Unit: "()"
        case Tuple(elements): "Tuple"
        case Array(element, size): "Array"
        case Slice(element): "Slice"
        case Dict(key, value): "Dict"
        case Ref(inner, mutable): "Ref"
        case Ptr(inner, mutable): "Ptr"
        case Optional(inner): "Optional"
        case Result(ok, err): "Result"
        case Named(symbol, args): "Named"
        case Function(params, ret, effects): "Function"
        case DynTrait(trait_): "dyn Trait"
        case TypeParam(name, bounds): name
        case Infer(id, level): "infer"
        case Error: "error"
        case Never: "!"
        case Any: "Any"
        case Projection(base, assoc_name): "Projection"

fn _field_line_num(field: HirField) -> i64:
    """Extract line number from a field's span."""
    field.span.line


# ============================================================================
# SFFI001: Non-C-compatible field type in exported class
# ============================================================================

fn check_sffi001_c_compatible_types(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Check that all fields in an @export("C") class use C-compatible types.

    C-compatible types: i8, i16, i32, i64, u8, u16, u32, u64, f32, f64, bool, Ptr.
    Non-C-compatible: text (separate warning via SFFI002), List, Dict, Option,
    custom classes without @repr("C"), closures, trait objects.
    """
    var warnings: [SffiLintWarning] = []

    var fi = 0
    while fi < class_def.fields.len():
        val field = class_def.fields[fi]
        val kind = field.type_.kind

        # Skip text fields — they get SFFI002 (warning, not error)
        if _is_text_type(kind):
            fi = fi + 1
            continue

        # Skip C-compatible primitives and Ptr
        if _is_c_compatible_type(field.type_):
            fi = fi + 1
            continue

        # Everything else is non-C-compatible
        val type_name = _type_kind_name(kind)
        val line = _field_line_num(field)

        if _is_collection_type(kind):
            warnings.push(SffiLintWarning(
                code: "SFFI001",
                severity: "ERROR",
                message: "field '{field.name}' has non-C-compatible type '{type_name}' in @export(\"C\") class '{class_def.name}'",
                hint: "use a C-compatible type (i8..i64, u8..u64, f32, f64, bool, Ptr) or pass by handle",
                line_num: line,
                file_path: file_path
            ))
        elif _is_optional_type(kind):
            warnings.push(SffiLintWarning(
                code: "SFFI001",
                severity: "ERROR",
                message: "field '{field.name}' has non-C-compatible type 'Optional' in @export(\"C\") class '{class_def.name}'",
                hint: "Optional<T> has no stable C ABI — use a sentinel value or a separate bool flag",
                line_num: line,
                file_path: file_path
            ))
        elif _is_function_type(kind):
            # Allow plain function pointers (stateless) — they map to C callback typedefs
            if _is_callback_function_type(kind):
                # Plain function pointer: C-compatible via typedef, no error
                fi = fi + 1
                continue
            # Closure with captures: cannot cross FFI boundary
            warnings.push(SffiLintWarning(
                code: "SFFI001",
                severity: "ERROR",
                message: "field '{field.name}' has non-C-compatible type 'closure' in @export(\"C\") class '{class_def.name}'",
                hint: "closures with captures cannot cross the FFI boundary — use a plain function pointer (Fn<(A) -> B> without captures) instead",
                line_num: line,
                file_path: file_path
            ))
        else:
            # Named types (custom classes), trait objects, etc.
            warnings.push(SffiLintWarning(
                code: "SFFI001",
                severity: "ERROR",
                message: "field '{field.name}' has non-C-compatible type '{type_name}' in @export(\"C\") class '{class_def.name}'",
                hint: "use a C-compatible type or mark the nested struct with @repr(\"C\") and pass by Ptr",
                line_num: line,
                file_path: file_path
            ))

        fi = fi + 1

    warnings


# ============================================================================
# SFFI002: text field in exported struct
# ============================================================================

fn check_sffi002_text_field(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Warn when an @export("C") class contains a 'text' field.

    The 'text' type maps to char* in C, which requires special marshalling
    (lifetime, encoding, allocation). Not an error, but the user should be
    aware of the implications.
    """
    var warnings: [SffiLintWarning] = []

    var fi = 0
    while fi < class_def.fields.len():
        val field = class_def.fields[fi]

        if _is_text_type(field.type_.kind):
            val line = _field_line_num(field)
            warnings.push(SffiLintWarning(
                code: "SFFI002",
                severity: "WARNING",
                message: "field '{field.name}' is 'text' in @export(\"C\") class '{class_def.name}' — maps to char* in C",
                hint: "text requires marshalling (encoding, lifetime). Consider using a byte buffer or opaque handle for complex strings",
                line_num: line,
                file_path: file_path
            ))

        fi = fi + 1

    warnings


# ============================================================================
# SFFI003: Struct passed by-value without @repr("C")
# ============================================================================

fn check_sffi003_repr_required(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Check that @export("C") classes also have @repr("C") or compatible layout.

    If a class is exported for C interop, its layout MUST be C-compatible.
    Without @repr("C"), the Simple compiler may reorder fields for optimization,
    causing silent data corruption across the FFI boundary.
    """
    var warnings: [SffiLintWarning] = []

    # Check if the class has @repr("C") or @repr("packed") layout
    if class_def.has_layout_attr:
        val layout_kind = class_def.layout_attr.layout_kind
        match layout_kind:
            case LayoutKind.C:
                # Good — has @repr("C")
                return warnings
            case LayoutKind.Packed:
                # Packed is C-compatible (no reordering)
                return warnings
            case LayoutKind.Transparent:
                # Transparent is C-compatible (single-field)
                return warnings
            case LayoutKind.Simple:
                # Default layout — not guaranteed C-compatible
                pass_dn

    # Missing @repr("C") on an @export("C") class
    val line = class_def.span.line
    warnings.push(SffiLintWarning(
        code: "SFFI003",
        severity: "ERROR",
        message: "@export(\"C\") class '{class_def.name}' does not have @repr(\"C\") layout",
        hint: "add @repr(\"C\") to guarantee C-compatible field ordering and alignment",
        line_num: line,
        file_path: file_path
    ))

    warnings


# ============================================================================
# SFFI004: Bitfield without explicit width
# ============================================================================

fn check_sffi004_bitfield_width(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Check that bitfield fields in @export("C") classes have explicit @bits(N) width.

    In C, bitfield packing is implementation-defined (MSVC vs GCC vs Clang differ).
    Sub-byte fields must have explicit @bits(N) annotations so the compiler can
    verify the layout matches the C side.

    Preferred behavior uses explicit field-level @bits(N) metadata when present.
    For older parse paths that do not yet carry bits metadata into HIR, this
    falls back to the previous heuristic on consecutive sub-word fields.
    """
    var warnings: [SffiLintWarning] = []

    var has_explicit_bits = false
    for field in class_def.fields:
        if field.has_bits_attr:
            has_explicit_bits = true
            break

    if has_explicit_bits:
        for field in class_def.fields:
            if not field.has_bits_attr:
                continue

            val capacity = _bit_capacity_type(field.type_)
            val line = _field_line_num(field)
            if capacity == 0:
                warnings.push(SffiLintWarning(
                    code: "SFFI004",
                    severity: "ERROR",
                    message: "field '{field.name}' in @export(\"C\") class '{class_def.name}' uses @bits({field.bits_width}) on a non-bitfield-capable type",
                    hint: "@bits(N) is only valid on integer and bool fields in FFI-exposed layouts",
                    line_num: line,
                    file_path: file_path
                ))
                continue

            if field.bits_width <= 0 or field.bits_width > capacity:
                warnings.push(SffiLintWarning(
                    code: "SFFI004",
                    severity: "ERROR",
                    message: "field '{field.name}' in @export(\"C\") class '{class_def.name}' uses invalid @bits({field.bits_width}) width for '{_type_kind_name(field.type_.kind)}'",
                    hint: "use @bits(N) with 1 <= N <= {capacity} for this field type",
                    line_num: line,
                    file_path: file_path
                ))

        return warnings

    # Fallback heuristic for legacy parse paths without field-level bits metadata.
    var consecutive_small = 0
    var first_small_idx = 0

    var fi = 0
    while fi < class_def.fields.len():
        val field = class_def.fields[fi]
        val kind = field.type_.kind

        val is_small = _is_sub_word_type(kind)
        if is_small:
            if consecutive_small == 0:
                first_small_idx = fi
            consecutive_small = consecutive_small + 1
        else:
            consecutive_small = 0

        # If we see 4+ consecutive small fields, it smells like bitfields
        if consecutive_small >= 4:
            val first_field = class_def.fields[first_small_idx]
            val line = _field_line_num(first_field)
            warnings.push(SffiLintWarning(
                code: "SFFI004",
                severity: "ERROR",
                message: "class '{class_def.name}' has {consecutive_small} consecutive sub-word fields starting at '{first_field.name}' — likely intended as bitfields",
                hint: "add @bits(N) to specify exact bit widths, or use @repr(\"packed\") for byte-level packing",
                line_num: line,
                file_path: file_path
            ))
            # Only warn once per consecutive group
            consecutive_small = 0

        fi = fi + 1

    warnings

fn _is_sub_word_type(kind: HirTypeKind) -> bool:
    """Check if a type is smaller than a machine word (sub-word)."""
    match kind:
        case Int(bits, signed):
            bits <= 8
        case Bool: true
        case Char: false  # char is 4 bytes in Simple
        case _: false

fn _bit_capacity(kind: HirTypeKind) -> i64:
    """Return the legal maximum @bits width for a field type, or 0 if unsupported."""
    match kind:
        case Int(bits, signed): bits
        case Bool: 1
        case _: 0

fn _bit_capacity_type(type_: HirType) -> i64:
    match type_.kind:
        case Named(symbol, args):
            val underlying = custom_primitive_underlying_type_tag_by_symbol(symbol.id)
            if underlying == TYPE_BOOL:
                return 1
            if underlying == TYPE_I64:
                return 64
            0
        case _:
            _bit_capacity(type_.kind)


# ============================================================================
# SFFI005: Platform-dependent type size
# ============================================================================

fn check_sffi005_platform_dependent(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Flag @export("C") classes that use types whose size varies by platform.

    Currently all Simple primitive types are fixed-size (i32 is always 32 bits).
    The main concern is pointer-sized types (isize, usize) and Named types
    that might wrap platform-dependent values.

    This is primarily a future guard — Simple avoids the C pitfall of
    platform-dependent int/long sizes.
    """
    var warnings: [SffiLintWarning] = []
    val has_platform = class_def.has_platform_attr
    val severity = if has_platform: "WARNING" else: "ERROR"
    val hint = if has_platform:
        "verify each supported target has an explicit @platform bit/size/align contract"
    else:
        "add @platform(...) variants for target-specific layout, or replace the field with a fixed-size ABI type"

    var fi = 0
    while fi < class_def.fields.len():
        val field = class_def.fields[fi]
        val kind = field.type_.kind

        # Check for Named types that could be isize/usize
        # In the future, HirTypeKind may get explicit Isize/Usize variants
        # For now, Ref types are pointer-sized
        match kind:
            case Ref(inner, mutable):
                val line = _field_line_num(field)
                warnings.push(SffiLintWarning(
                    code: "SFFI005",
                    severity: severity,
                    message: "field '{field.name}' uses reference type in @export(\"C\") class '{class_def.name}' — reference size is platform-dependent",
                    hint: hint,
                    line_num: line,
                    file_path: file_path
                ))
            case _:
                pass_dn

        fi = fi + 1

    warnings

fn check_sffi008_platform_attr_diagnostics(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Surface @platform parser diagnostics on exported C classes."""
    var warnings: [SffiLintWarning] = []
    if not class_def.has_platform_attr:
        return warnings

    if class_def.platform_has_error:
        warnings.push(SffiLintWarning(
            code: "SFFI008",
            severity: "ERROR",
            message: class_def.platform_diagnostic_message,
            hint: "fix the @platform annotation so ABI layout is target-explicit and unambiguous",
            line_num: class_def.platform_diagnostic_line,
            file_path: file_path
        ))
    elif class_def.platform_has_warning:
        warnings.push(SffiLintWarning(
            code: "SFFI008",
            severity: "WARNING",
            message: class_def.platform_diagnostic_message,
            hint: "fix the @platform annotation so ABI layout is target-explicit and unambiguous",
            line_num: class_def.platform_diagnostic_line,
            file_path: file_path
        ))

    warnings


# ============================================================================
# Main Entry Point
# ============================================================================

fn lint_sffi_export(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Run all SFFI lint checks on a class definition.

    Only checks classes with @export("C") attribute. Returns an empty list
    for non-exported classes.

    Checks:
    - SFFI001: Non-C-compatible field types (ERROR) — allows plain fn ptrs
    - SFFI002: text fields needing marshalling (WARNING)
    - SFFI003: Missing @repr("C") layout (ERROR)
    - SFFI004: Bitfield without explicit width (ERROR)
    - SFFI005: Platform-dependent type sizes (ERROR unless @platform-tagged)
    - SFFI006: Callback parameter without ownership docs (WARNING)
    - SFFI008: Invalid @platform annotations (ERROR/WARNING)
    """
    var warnings: [SffiLintWarning] = []

    # Only check classes with @export("C")
    if not class_def.has_export_attr:
        return warnings

    if not class_def.export_attr.is_export_c:
        return warnings

    warnings = warnings + check_sffi001_c_compatible_types(class_def, file_path)
    warnings = warnings + check_sffi002_text_field(class_def, file_path)
    warnings = warnings + check_sffi003_repr_required(class_def, file_path)
    warnings = warnings + check_sffi004_bitfield_width(class_def, file_path)
    warnings = warnings + check_sffi005_platform_dependent(class_def, file_path)
    warnings = warnings + check_sffi006_callback_ownership(class_def, file_path)
    warnings = warnings + check_sffi008_platform_attr_diagnostics(class_def, file_path)

    warnings


# ============================================================================
# SFFI006: Callback parameter without ownership documentation
# ============================================================================

fn check_sffi006_callback_ownership(class_def: HirClass, file_path: text) -> [SffiLintWarning]:
    """Warn when an @export("C") class has a callback (function pointer) field
    without explicit documentation of ownership semantics.

    Callback parameters in FFI APIs should clearly document whether the
    function pointer is "borrowed" (caller retains ownership, callee does
    not store it) or "owned" (callee may store and invoke later).

    This is a WARNING, not an error — the code will compile, but the API
    contract should be documented for safety.
    """
    var warnings: [SffiLintWarning] = []

    var fi = 0
    while fi < class_def.fields.len():
        val field = class_def.fields[fi]
        val kind = field.type_.kind

        if _is_callback_function_type(kind):
            val line = _field_line_num(field)
            warnings.push(SffiLintWarning(
                code: "SFFI006",
                severity: "WARNING",
                message: "callback parameter '{field.name}' should document ownership (borrowed/owned) in @export(\"C\") class '{class_def.name}'",
                hint: "add a doc comment specifying whether the callback is borrowed (not stored) or owned (may be stored and called later)",
                line_num: line,
                file_path: file_path
            ))

        fi = fi + 1

    warnings


# ============================================================================
# Struct Lint (for HirStruct too)
# ============================================================================

fn lint_sffi_export_struct(struct_def: HirStruct, file_path: text) -> [SffiLintWarning]:
    """Run SFFI lint checks on a struct definition.

    HirStruct has the same field structure as HirClass but uses layout_attr
    directly. This provides the same checks for struct definitions.
    """
    var warnings: [SffiLintWarning] = []

    # HirStruct does not have export_attr currently — structs are exported
    # when used as fields in @export("C") classes. Check layout consistency.
    if struct_def.has_layout_attr:
        val layout_kind = struct_def.layout_attr.layout_kind
        match layout_kind:
            case LayoutKind.C:
                # Good — has @repr("C"), check field compatibility
                var fi = 0
                while fi < struct_def.fields.len():
                    val field = struct_def.fields[fi]
                    val kind = field.type_.kind

                    if not _is_c_compatible_type(field.type_) and not _is_text_type(kind) and not _is_callback_function_type(kind):
                        val type_name = _type_kind_name(kind)
                        val line = _field_line_num(field)
                        # Closures with captures get a specific message
                        if _is_function_type(kind) and not _is_callback_function_type(kind):
                            warnings.push(SffiLintWarning(
                                code: "SFFI001",
                                severity: "ERROR",
                                message: "field '{field.name}' has non-C-compatible type 'closure' in @repr(\"C\") struct '{struct_def.name}'",
                                hint: "closures with captures cannot cross the FFI boundary — use a plain function pointer instead",
                                line_num: line,
                                file_path: file_path
                            ))
                        else:
                            warnings.push(SffiLintWarning(
                                code: "SFFI001",
                                severity: "ERROR",
                                message: "field '{field.name}' has non-C-compatible type '{type_name}' in @repr(\"C\") struct '{struct_def.name}'",
                                hint: "use a C-compatible type (i8..i64, u8..u64, f32, f64, bool, Ptr)",
                                line_num: line,
                                file_path: file_path
                            ))

                    if _is_text_type(kind):
                        val line = _field_line_num(field)
                        warnings.push(SffiLintWarning(
                            code: "SFFI002",
                            severity: "WARNING",
                            message: "field '{field.name}' is 'text' in @repr(\"C\") struct '{struct_def.name}' — maps to char* in C",
                            hint: "text requires marshalling (encoding, lifetime)",
                            line_num: line,
                            file_path: file_path
                        ))

                    fi = fi + 1
            case _:
                pass_dn

    warnings


# ============================================================================
# SFFI007: Driver-shim conformance (FR-DRIVER-0001)
# ============================================================================
#
# A module that declares one or more `extern fn` AND carries `@driver(...)`
# must also provide a matching `impl Driver for <Type>`. The lint closes
# the "C-only driver" escape hatch: every C driver is wrapped by a pure-
# Simple shim whose trait impl maps C status codes to DriverError (see
# doc/04_architecture/driver_architecture.md §5).
#
# Inputs are three shallow facts about the containing module:
#   - has_extern_fn: any `extern fn` declared in the module
#   - has_driver_attr: `@driver(...)` attached to any module-level decl
#   - has_driver_impl: a trait-impl block whose trait name is "Driver"
#
# The rule fires when has_extern_fn AND has_driver_attr AND NOT has_driver_impl.

fn check_sffi007_driver_shim(has_extern_fn: bool,
                             has_driver_attr: bool,
                             has_driver_impl: bool,
                             module_name: text,
                             file_path: text) -> [SffiLintWarning]:
    """SFFI007 — a module that declares @driver(...) and has extern fn
    declarations must also provide an `impl Driver for X` block."""
    var warnings: [SffiLintWarning] = []
    if has_extern_fn and has_driver_attr and not has_driver_impl:
        warnings.push(SffiLintWarning(
            code: "SFFI007",
            severity: "ERROR",
            message: "module '{module_name}' has @driver(...) and extern fn declarations but no `impl Driver for X` — every C driver needs a pure-Simple trait shim",
            hint: "add `impl Driver for <YourDriverStruct>:` that wraps the extern calls and maps C status codes to DriverError (see doc/04_architecture/driver_architecture.md §5)",
            line_num: 0,
            file_path: file_path
        ))
    warnings


