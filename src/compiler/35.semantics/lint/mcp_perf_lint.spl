# MCP Performance Lint
#
# Source-level lint checks that catch performance anti-patterns in MCP
# server code.  All checks are text-based (they scan raw .spl source
# lines) so they run before the AST is formed.
#
# MCP001: Source entrypoint in production wrapper                     WARNING
# MCP002: Full-tree scan in request handler                           WARNING
# MCP003: Per-request subprocess execution in hot path                WARNING
# MCP004: Cache without invalidation hook                             WARNING
#
# Does NOT flag:
# - Comment lines or docstrings
# - Scan calls inside functions named *reindex*, *rebuild*, *admin*
# - Subprocess calls in CLI passthrough (handler_kind="cli")
# - Cache usage with matching invalidation in the same module
#
# ============================================================================

use std.io_runtime


# ============================================================================
# Warning Struct
# ============================================================================

struct McpPerfLintWarning:
    code: text
    severity: text
    message: text
    hint: text
    line_num: i64
    file_path: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.file_path}:{self.line_num} -- {self.message} -- {self.hint}"


# ============================================================================
# MCP001: Source Entrypoint in Production Wrapper
# ============================================================================

fn lint_source_entrypoint(source: text, path: text) -> [McpPerfLintWarning]:
    """Detect wrapper scripts that execute .spl source files directly instead
    of using cached compiled artifacts (.smf or native binary).

    Production MCP wrappers should execute compiled artifacts for fast startup.
    Looks for patterns like:
    - exec "$RUNTIME" "path/to/main.spl"
    - ENTRY="path/to/main.spl"
    - "$RUNTIME" "$ENTRY_SOURCE"  (where ENTRY_SOURCE ends in .spl)
    """
    var warnings: [McpPerfLintWarning] = []

    # Only check wrapper scripts (shell scripts or .cmd files)
    val is_wrapper = path.ends_with("_mcp_server") or path.ends_with("_mcp_server.cmd") or path.ends_with("_lsp_mcp_server") or path.ends_with("_lsp_mcp_server.cmd")
    if not is_wrapper:
        return warnings

    val lines = source.split("\n")
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()

        # Skip comment lines
        if not trimmed.starts_with("#") and not trimmed.starts_with("::"):
            # Check for ENTRY= or ENTRY_SOURCE= pointing to .spl file
            if _has_spl_entrypoint_assign(trimmed):
                warnings.push(McpPerfLintWarning(
                    code: "MCP001",
                    severity: "WARNING",
                    message: "wrapper assigns source entrypoint (.spl) instead of compiled artifact",
                    hint: "use a cached .smf or native binary instead of raw .spl for production",
                    line_num: li + 1,
                    file_path: path
                ))

            # Check for exec with .spl argument
            if _has_exec_spl(trimmed):
                warnings.push(McpPerfLintWarning(
                    code: "MCP001",
                    severity: "WARNING",
                    message: "wrapper executes .spl source file directly in production path",
                    hint: "compile to .smf or native binary and execute that instead",
                    line_num: li + 1,
                    file_path: path
                ))

        li = li + 1

    warnings


# ============================================================================
# MCP002: Full-Tree Scan in Request Handler
# ============================================================================

fn lint_full_tree_scan(source: text, path: text) -> [McpPerfLintWarning]:
    """Detect full directory tree scans in MCP request handler code.

    Flags calls to rt_dir_walk, scan_vault, walk_directory, or
    list_all_files inside functions that appear to be request handlers
    (functions whose name starts with handle_ or dispatch_).

    Does NOT flag scans inside functions named *reindex*, *rebuild*,
    *admin*, or *maintenance*.
    """
    var warnings: [McpPerfLintWarning] = []

    # Only check MCP-related source files
    if not _is_mcp_source(path):
        return warnings

    val lines = source.split("\n")
    var in_docstring = false
    var current_fn = ""
    var fn_start_line = 0

    var li = 0
    while li < lines.len():
        val line = lines[li]

        # Track triple-quoted docstring regions
        if _count_triple_quotes(line) % 2 == 1:
            in_docstring = not in_docstring

        if not in_docstring:
            val trimmed = line.trim()

            # Skip comment lines
            if not trimmed.starts_with("#"):
                # Track current function name
                if trimmed.starts_with("fn ") or trimmed.starts_with("me "):
                    current_fn = _extract_fn_name(trimmed)
                    fn_start_line = li + 1

                # Check for scan calls in handler functions
                if _is_handler_fn(current_fn) and not _is_admin_fn(current_fn):
                    if _has_tree_scan_call(trimmed):
                        warnings.push(McpPerfLintWarning(
                            code: "MCP002",
                            severity: "WARNING",
                            message: "full-tree scan in request handler '{current_fn}'",
                            hint: "use a cached index or limit scan scope; move to reindex/admin flow if needed",
                            line_num: li + 1,
                            file_path: path
                        ))

        li = li + 1

    warnings


# ============================================================================
# MCP003: Per-Request Subprocess in Hot Path
# ============================================================================

fn lint_per_request_subprocess(source: text, path: text) -> [McpPerfLintWarning]:
    """Detect subprocess execution inside MCP request handlers.

    Flags calls to rt_process_run, shell_cmd, or os.exec inside handler
    functions.  CLI passthrough handlers (handler_kind="cli") are excluded
    because they are explicitly designed to delegate to the CLI binary.
    """
    var warnings: [McpPerfLintWarning] = []

    # Only check MCP-related source files
    if not _is_mcp_source(path):
        return warnings

    # Skip cli_passthrough.spl -- it is designed to shell out
    if path.ends_with("cli_passthrough.spl"):
        return warnings

    val lines = source.split("\n")
    var in_docstring = false
    var current_fn = ""

    var li = 0
    while li < lines.len():
        val line = lines[li]

        # Track triple-quoted docstring regions
        if _count_triple_quotes(line) % 2 == 1:
            in_docstring = not in_docstring

        if not in_docstring:
            val trimmed = line.trim()

            # Skip comment lines
            if not trimmed.starts_with("#"):
                # Track current function
                if trimmed.starts_with("fn ") or trimmed.starts_with("me "):
                    current_fn = _extract_fn_name(trimmed)

                # Check for subprocess calls in handler functions
                if _is_handler_fn(current_fn):
                    if _has_subprocess_call(trimmed):
                        warnings.push(McpPerfLintWarning(
                            code: "MCP003",
                            severity: "WARNING",
                            message: "subprocess execution in request handler '{current_fn}'",
                            hint: "use in-process function calls instead of shelling out per request",
                            line_num: li + 1,
                            file_path: path
                        ))

        li = li + 1

    warnings


# ============================================================================
# MCP004: Cache Without Invalidation
# ============================================================================

fn lint_cache_no_invalidation(source: text, path: text) -> [McpPerfLintWarning]:
    """Detect cache variables that are written to but never invalidated.

    Looks for module-level cache variables (var *_CACHE, var *_cache,
    var cached_*) and checks whether the same module contains an
    invalidation pattern (setting the cache to empty/nil, or a function
    named *invalidate*, *clear_cache*, *reset_cache*).
    """
    var warnings: [McpPerfLintWarning] = []

    # Only check MCP-related source files
    if not _is_mcp_source(path):
        return warnings

    val lines = source.split("\n")
    var cache_vars: [text] = []
    var cache_var_lines: [i64] = []
    var has_invalidation = false

    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()

        # Skip comments
        if not trimmed.starts_with("#"):
            # Find cache variable declarations at module level (not indented)
            if not line.starts_with(" ") and not line.starts_with("\t"):
                if _is_cache_var_decl(trimmed):
                    val var_name = _extract_var_name(trimmed)
                    if var_name != "":
                        cache_vars.push(var_name)
                        cache_var_lines.push(li + 1)

            # Check for invalidation patterns anywhere in the file
            if _has_invalidation_pattern(trimmed):
                has_invalidation = true

        li = li + 1

    # If caches exist but no invalidation, warn
    if cache_vars.len() > 0 and not has_invalidation:
        var ci = 0
        while ci < cache_vars.len():
            warnings.push(McpPerfLintWarning(
                code: "MCP004",
                severity: "WARNING",
                message: "cache variable '{cache_vars[ci]}' has no invalidation path in this module",
                hint: "add invalidation on write/delete events, or add a clear_cache/invalidate function",
                line_num: cache_var_lines[ci],
                file_path: path
            ))
            ci = ci + 1

    warnings


# ============================================================================
# Helper Functions
# ============================================================================

fn _has_spl_entrypoint_assign(trimmed: text) -> bool:
    """Check if line assigns an ENTRY variable to a .spl file."""
    if trimmed.contains("ENTRY=") or trimmed.contains("ENTRY_SOURCE="):
        if trimmed.contains(".spl"):
            return true
    if trimmed.contains("set \"ENTRY="):
        if trimmed.contains(".spl"):
            return true
    false

fn _has_exec_spl(trimmed: text) -> bool:
    """Check if line executes a .spl file via exec or similar."""
    if trimmed.starts_with("exec ") or trimmed.contains(" exec "):
        if trimmed.contains(".spl"):
            return true
    # Check for Windows-style direct execution ending in .spl
    if trimmed.contains("\"%RUNTIME%\"") and trimmed.contains(".spl"):
        return true
    false

fn _is_mcp_source(path: text) -> bool:
    """Check if a file path is MCP-related source code."""
    if path.contains("/mcp/"):
        return true
    if path.contains("/mcp_"):
        return true
    if path.contains("mcp_server"):
        return true
    false

fn _extract_fn_name(trimmed: text) -> text:
    """Extract function name from a fn/me declaration line."""
    var start = 0
    if trimmed.starts_with("fn "):
        start = 3
    elif trimmed.starts_with("me "):
        start = 3
    elif trimmed.starts_with("static fn "):
        start = 10
    else:
        return ""

    var end = start
    while end < trimmed.len():
        val ch = trimmed.slice(end, end + 1)
        if ch == "(" or ch == " " or ch == ":":
            break
        end = end + 1

    if end <= start:
        return ""
    trimmed.slice(start, end)

fn _is_handler_fn(name: text) -> bool:
    """Check if function name looks like a request handler."""
    if name.starts_with("handle_"):
        return true
    if name.starts_with("dispatch_"):
        return true
    if name.starts_with("_dispatch_"):
        return true
    false

fn _is_admin_fn(name: text) -> bool:
    """Check if function name is an admin/maintenance operation."""
    if name.contains("reindex"):
        return true
    if name.contains("rebuild"):
        return true
    if name.contains("admin"):
        return true
    if name.contains("maintenance"):
        return true
    false

fn _has_tree_scan_call(trimmed: text) -> bool:
    """Check if line contains a full-tree scan call."""
    if trimmed.contains("rt_dir_walk("):
        return true
    if trimmed.contains("scan_vault("):
        return true
    if trimmed.contains("walk_directory("):
        return true
    if trimmed.contains("list_all_files("):
        return true
    if trimmed.contains("scan_all_files("):
        return true
    false

fn _has_subprocess_call(trimmed: text) -> bool:
    """Check if line contains a subprocess execution call."""
    if trimmed.contains("rt_process_run("):
        return true
    if trimmed.contains("shell_cmd("):
        return true
    if trimmed.contains("os.exec("):
        return true
    false

fn _is_cache_var_decl(trimmed: text) -> bool:
    """Check if a line declares a cache variable."""
    if not trimmed.starts_with("var "):
        return false
    val after_var = trimmed.slice(4)
    if after_var.contains("_CACHE") or after_var.contains("_cache"):
        return true
    if after_var.starts_with("cached_"):
        return true
    if after_var.starts_with("CACHE_") or after_var.starts_with("cache_"):
        return true
    false

fn _extract_var_name(trimmed: text) -> text:
    """Extract variable name from a var declaration."""
    if not trimmed.starts_with("var "):
        return ""
    val rest = trimmed.slice(4)
    var end = 0
    while end < rest.len():
        val ch = rest.slice(end, end + 1)
        if ch == " " or ch == "=" or ch == ":" or ch == "\t":
            break
        end = end + 1
    if end == 0:
        return ""
    rest.slice(0, end)

fn _has_invalidation_pattern(trimmed: text) -> bool:
    """Check if line contains a cache invalidation pattern."""
    # Function definitions that are invalidation-related
    if trimmed.starts_with("fn invalidate") or trimmed.starts_with("fn clear_cache") or trimmed.starts_with("fn reset_cache"):
        return true
    if trimmed.starts_with("me invalidate") or trimmed.starts_with("me clear_cache") or trimmed.starts_with("me reset_cache"):
        return true
    # Assignments that reset cache to empty
    if trimmed.contains("_CACHE = \"\"") or trimmed.contains("_cache = \"\""):
        return true
    if trimmed.contains("_CACHE = nil") or trimmed.contains("_cache = nil"):
        return true
    if trimmed.contains("_CACHE = []") or trimmed.contains("_cache = []"):
        return true
    if trimmed.contains("_CACHE = {}") or trimmed.contains("_cache = {}"):
        return true
    false

fn _count_triple_quotes(line: text) -> i64:
    """Count the number of triple-quote sequences in a line."""
    var count = 0
    var i = 0
    while i + 2 < line.len():
        val chunk = line.slice(i, i + 3)
        if chunk == "\"\"\"":
            count = count + 1
            i = i + 3
        else:
            i = i + 1
    count


# ============================================================================
# Exports
# ============================================================================

export McpPerfLintWarning
export lint_source_entrypoint
export lint_full_tree_scan
export lint_per_request_subprocess
export lint_cache_no_invalidation
