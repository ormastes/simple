# Critical File Guard Lint
#
# Checks protected files against deletion or significant shrinkage.
# Reads config/critical_files.sdn for the list of guarded paths.
#
# CFG001: Critical file deleted (missing)                              ERROR
# CFG002: Critical file shrunk below min_lines threshold               WARNING

use std.io_runtime.{read_file, file_exists}

struct CriticalFileEntry:
    path: text
    min_lines: i64

struct CriticalFileWarning:
    code: text
    severity: text
    message: text
    file_path: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message} — '{self.file_path}'"

fn load_critical_config(config_path: text) -> [CriticalFileEntry]:
    var entries: [CriticalFileEntry] = []
    if not file_exists(config_path):
        return entries

    val content = read_file(config_path)
    val lines = content.split("\n")
    var in_entries = false

    var i = 0
    while i < lines.len():
        val trimmed = lines[i].trim()
        if trimmed == "entries:":
            in_entries = true
            i = i + 1
            continue
        if trimmed == "protected_dirs:":
            in_entries = false
            i = i + 1
            continue

        if in_entries and trimmed.starts_with("- path:"):
            val path = trimmed.slice(7, trimmed.len()).trim()
            var min_lines = 0
            if i + 1 < lines.len():
                val next_trimmed = lines[i + 1].trim()
                if next_trimmed.starts_with("min_lines:"):
                    val num_str = next_trimmed.slice(10, next_trimmed.len()).trim()
                    min_lines = num_str.to_i64()
                    i = i + 1
            entries.push(CriticalFileEntry(path: path, min_lines: min_lines))
        i = i + 1

    entries

fn check_critical_file_deletion(entries: [CriticalFileEntry]) -> [CriticalFileWarning]:
    var warnings: [CriticalFileWarning] = []
    for entry in entries:
        if not file_exists(entry.path):
            warnings.push(CriticalFileWarning(
                code: "CFG001",
                severity: "ERROR",
                message: "critical file deleted or missing",
                file_path: entry.path
            ))
    warnings

fn check_critical_file_shrinkage(entries: [CriticalFileEntry]) -> [CriticalFileWarning]:
    var warnings: [CriticalFileWarning] = []
    for entry in entries:
        if entry.min_lines <= 0:
            continue
        if not file_exists(entry.path):
            continue
        val content = read_file(entry.path)
        val line_count = content.split("\n").len()
        if line_count < entry.min_lines:
            warnings.push(CriticalFileWarning(
                code: "CFG002",
                severity: "WARNING",
                message: "critical file shrunk below {entry.min_lines} lines (now {line_count})",
                file_path: entry.path
            ))
    warnings

fn check_all_critical_files(config_path: text) -> [CriticalFileWarning]:
    val entries = load_critical_config(config_path)
    var warnings: [CriticalFileWarning] = []
    val del_warnings = check_critical_file_deletion(entries)
    for w in del_warnings:
        warnings.push(w)
    val shrink_warnings = check_critical_file_shrinkage(entries)
    for w in shrink_warnings:
        warnings.push(w)
    warnings
