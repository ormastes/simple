# Ignored Return Value Lint
#
# Detects when a function call's return value is discarded as an
# expression statement. Functions that return non-unit values should
# generally have their results used.
#
# RET001: Function return value is discarded                          WARNING
#
# Does NOT flag:
# - Known side-effectful functions: print, push, pop, clear, sort, remove,
#   insert, write, close, flush, set, delete, reset, append
# - Method calls on known mutating receivers (me methods)
# - Calls in the last position of a block (implicit return)
# - extern fn declarations (no body)
# - void/unit-returning functions (by convention, if name starts with known prefix)
#
# Works with the arena-based core AST (integer-tagged nodes).

use compiler.core.ast_expr.{
    EXPR_CALL, EXPR_METHOD_CALL, EXPR_IDENT,
    EXPR_IF, EXPR_FOR, EXPR_WHILE, EXPR_BLOCK,
    EXPR_ASSIGN, EXPR_COMPOUND_ASSIGN,
    EXPR_PASS_TODO, EXPR_PASS_DO_NOTHING, EXPR_PASS_DN,
    expr_tag, expr_s_val, expr_left, expr_right, expr_args, expr_stmts
}
use compiler.core.ast_stmt.{
    STMT_EXPR, STMT_VAL_DECL, STMT_VAR_DECL, STMT_IF,
    STMT_FOR, STMT_WHILE, STMT_BLOCK, STMT_MATCH,
    stmt_tag, stmt_expr, stmt_name, stmt_body
}
use compiler.core.ast.{
    DECL_FN, DECL_EXTERN_FN,
    decl_tag, decl_name, decl_body_stmts
}

# ============================================================================
# Warning Struct
# ============================================================================

struct IgnoredReturnWarning:
    code: text
    severity: text
    message: text
    hint: text
    fn_name: text
    call_name: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message} in '{self.fn_name}' — {self.hint}"

# ============================================================================
# Known side-effectful functions (return value can safely be ignored)
# ============================================================================

val SIDE_EFFECT_FUNCTIONS: [text] = [
    "print", "println", "eprint", "eprintln",
    "push", "pop", "clear", "sort", "reverse", "remove", "insert",
    "write", "close", "flush", "set", "delete", "reset", "append",
    "log", "info", "warn", "error", "debug", "trace",
    "sleep", "exit", "abort",
    "send", "emit", "notify", "dispatch",
    "lock", "unlock", "acquire", "release"
]

val SIDE_EFFECT_PREFIXES: [text] = [
    "set_", "add_", "remove_", "delete_", "clear_", "reset_",
    "push_", "pop_", "insert_", "update_", "init_", "destroy_",
    "register_", "unregister_", "emit_", "on_", "handle_",
    "log_", "print_", "write_", "close_", "flush_", "send_"
]

# ============================================================================
# Main Entry Point
# ============================================================================

fn check_ignored_return(decl_indices: [i64]) -> [IgnoredReturnWarning]:
    """Run ignored-return lint on module declarations.

    For each function body, scans statement sequences for expression
    statements that are bare function calls (EXPR_CALL or EXPR_METHOD_CALL).
    If the called function is not a known side-effectful function, warn
    that the return value is being discarded.
    """
    var warnings: [IgnoredReturnWarning] = []

    for idx in decl_indices:
        val tag = decl_tag[idx]

        # Only check regular functions
        if tag != DECL_FN:
            continue

        val fn_name = decl_name[idx]
        val body = decl_body_stmts[idx]

        if body.len() == 0:
            continue

        # Check all statements except the last (last may be implicit return)
        val fn_warnings = check_stmts_ignored_return(body, fn_name)
        for w in fn_warnings:
            warnings.push(w)

    warnings

# ============================================================================
# Statement Walker
# ============================================================================

fn check_stmts_ignored_return(stmts: [i64], fn_name: text) -> [IgnoredReturnWarning]:
    """Check a list of statements for ignored return values.

    Skips the last statement in the list since it may be an implicit
    return value for the enclosing block/function.
    """
    var warnings: [IgnoredReturnWarning] = []
    val count = stmts.len()

    var i = 0
    while i < count:
        val s = stmts[i]
        if s < 0:
            i = i + 1
            continue

        val tag = stmt_tag[s]

        # Only check non-last expression statements for ignored return
        if tag == STMT_EXPR and i < count - 1:
            val e = stmt_expr[s]
            if e >= 0:
                val ws = check_expr_ignored_return(e, fn_name)
                for w in ws:
                    warnings.push(w)

        # Recurse into nested blocks
        if tag == STMT_IF or tag == STMT_BLOCK or tag == STMT_FOR or tag == STMT_WHILE or tag == STMT_MATCH:
            val nested = check_stmts_ignored_return(stmt_body[s], fn_name)
            for w in nested:
                warnings.push(w)

        i = i + 1

    warnings

# ============================================================================
# Expression Checker
# ============================================================================

fn check_expr_ignored_return(e: i64, fn_name: text) -> [IgnoredReturnWarning]:
    """Check if a standalone expression is a function call with an ignored return value."""
    var warnings: [IgnoredReturnWarning] = []
    if e < 0:
        return warnings

    val tag = expr_tag[e]

    # EXPR_CALL: direct function call
    if tag == EXPR_CALL:
        val callee = expr_left[e]
        if callee >= 0 and expr_tag[callee] == EXPR_IDENT:
            val call_name = expr_s_val[callee]
            if not is_known_side_effect(call_name):
                warnings.push(IgnoredReturnWarning(
                    code: "RET001",
                    severity: "WARNING",
                    message: "return value of '{call_name}()' is discarded",
                    hint: "use the return value or assign to _ if intentionally unused",
                    fn_name: fn_name,
                    call_name: call_name
                ))

    # EXPR_METHOD_CALL: method call
    if tag == EXPR_METHOD_CALL:
        val method_name = expr_s_val[e]
        if not is_known_side_effect(method_name):
            warnings.push(IgnoredReturnWarning(
                code: "RET001",
                severity: "WARNING",
                message: "return value of '.{method_name}()' is discarded",
                hint: "use the return value or assign to _ if intentionally unused",
                fn_name: fn_name,
                call_name: method_name
            ))

    warnings

# ============================================================================
# Side-Effect Classification
# ============================================================================

fn is_known_side_effect(name: text) -> bool:
    """Check if a function/method name is a known side-effectful operation
    whose return value can safely be ignored."""

    # Exact name match
    for se in SIDE_EFFECT_FUNCTIONS:
        if name == se:
            return true

    # Prefix match
    for prefix in SIDE_EFFECT_PREFIXES:
        if name.starts_with(prefix):
            return true

    # Common test/assert functions
    if name.starts_with("assert") or name.starts_with("expect") or name.starts_with("check"):
        return true

    # Functions starting with _ are often internal side-effectful helpers
    if name.starts_with("_"):
        return true

    false

# ============================================================================
# Exports
# ============================================================================
