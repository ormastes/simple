#![allow(export_outside_init)]
#![allow(unnamed_duplicate_typed_args)]
# Security Lint: Hardcoded Secret Detection
#
# Detects string literals matching known credential and secret patterns
# in source code. Hardcoded secrets are one of the most common security
# vulnerabilities in LLM-generated code.
#
# SEC-SEC001: AWS access key (AKIA prefix)                              DENY
# SEC-SEC002: GitHub token (ghp_, gho_, ghs_, ghr_ prefix)             DENY
# SEC-SEC003: Anthropic API key (sk-ant- prefix)                        DENY
# SEC-SEC004: OpenAI API key (sk- prefix, 48+ chars)                    DENY
# SEC-SEC005: PEM private key (BEGIN/PRIVATE KEY markers)               DENY
# SEC-SEC006: High-entropy hex string (64+ chars)                       DENY
# SEC-SEC007: High-entropy base64 string (40+ chars)                    DENY
# SEC-SEC008: Generic password assignment                               DENY
#
# Does NOT flag:
# - Strings in test files (*_spec.spl, *_test.spl)
# - Functions/lines with @allow(hardcoded_secret) annotation
# - Comment lines or docstrings
# - Empty strings or very short strings
# - Environment variable lookups (env.get, env.require)
#
# Rationale: LLMs reproduce credential patterns from training data.
# Developers often forget to replace LLM-generated placeholder keys.
#
# Fix: Use env.get("SECRET_NAME") or env.require("SECRET_NAME") to
#      load secrets from environment variables at runtime.
#
# ============================================================================

use std.io_runtime


# ============================================================================
# Warning Struct
# ============================================================================

struct HardcodedSecretWarning:
    code: text
    severity: text
    message: text
    hint: text
    pattern_matched: text
    line_num: i64
    file_path: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.file_path}:{self.line_num} -- {self.message} ({self.pattern_matched}) -- {self.hint}"


# ============================================================================
# Main Entry Point
# ============================================================================

fn check_hardcoded_secret(source: text, path: text) -> [HardcodedSecretWarning]:
    """Scan source text for string literals matching known credential patterns.

    For each non-comment, non-docstring line, extracts string literals and
    checks them against known secret patterns (AWS keys, GitHub tokens,
    API keys, PEM blocks, high-entropy strings).

    Test files are skipped entirely. Individual lines can be suppressed
    with @allow(hardcoded_secret).

    Returns a list of HardcodedSecretWarning for each violation found.
    """
    var warnings: [HardcodedSecretWarning] = []

    # Skip test files
    if path.ends_with("_spec.spl") or path.ends_with("_test.spl"):
        return warnings

    val lines = source.split("\n")
    var in_docstring = false

    var li = 0
    while li < lines.len():
        val line = lines[li]

        # Track triple-quoted docstring regions
        if _count_triple_quotes(line) % 2 == 1:
            in_docstring = not in_docstring

        if not in_docstring:
            val trimmed = line.trim()

            # Skip comment lines
            if not trimmed.starts_with("#"):
                # Skip lines with allow annotation
                if not trimmed.contains("@allow(hardcoded_secret)"):
                    # Skip environment variable lookups
                    if not trimmed.contains("env.get(") and not trimmed.contains("env.require("):
                        # Extract and check all string literals on this line
                        val line_warnings = _check_line_for_secrets(trimmed, li + 1, path)
                        var wi = 0
                        while wi < line_warnings.len():
                            warnings.push(line_warnings[wi])
                            wi = wi + 1

        li = li + 1

    warnings


# ============================================================================
# Per-Line Secret Checking
# ============================================================================

fn _check_line_for_secrets(line: text, line_num: i64, file_path: text) -> [HardcodedSecretWarning]:
    """Check a single line for all secret patterns."""
    var warnings: [HardcodedSecretWarning] = []

    # Extract string literals from the line
    val strings = _extract_string_literals(line)

    var si = 0
    while si < strings.len():
        val s = strings[si]

        # Skip empty or very short strings (less than 8 chars)
        if s.len() >= 8:
            # Check each pattern
            val w = _check_all_patterns(s, line_num, file_path)
            var wi = 0
            while wi < w.len():
                warnings.push(w[wi])
                wi = wi + 1

        si = si + 1

    # Also check for password assignment patterns (no string extraction needed)
    val pw_warning = _check_password_assignment(line, line_num, file_path)
    if pw_warning.?:
        warnings.push(pw_warning)

    warnings

fn _check_all_patterns(s: text, line_num: i64, file_path: text) -> [HardcodedSecretWarning]:
    """Check a string literal against all known secret patterns."""
    var warnings: [HardcodedSecretWarning] = []

    # AWS access key: starts with "AKIA" followed by 16 uppercase alphanum
    if s.starts_with("AKIA") and s.len() >= 20:
        if _is_aws_key_format(s):
            warnings.push(HardcodedSecretWarning(
                code: "SEC-SEC001",
                severity: "DENY",
                message: "hardcoded AWS access key detected",
                hint: "use env.require(\"AWS_ACCESS_KEY_ID\") instead of hardcoding credentials",
                pattern_matched: "AWS key (AKIA...)",
                line_num: line_num,
                file_path: file_path
            ))
            return warnings

    # GitHub tokens: ghp_, gho_, ghs_, ghr_
    if _is_github_token(s):
        warnings.push(HardcodedSecretWarning(
            code: "SEC-SEC002",
            severity: "DENY",
            message: "hardcoded GitHub token detected",
            hint: "use env.require(\"GITHUB_TOKEN\") instead of hardcoding tokens",
            pattern_matched: "GitHub token ({s.slice(0, 4)}...)",
            line_num: line_num,
            file_path: file_path
        ))
        return warnings

    # Anthropic API key: starts with "sk-ant-"
    if s.starts_with("sk-ant-"):
        warnings.push(HardcodedSecretWarning(
            code: "SEC-SEC003",
            severity: "DENY",
            message: "hardcoded Anthropic API key detected",
            hint: "use env.require(\"ANTHROPIC_API_KEY\") instead of hardcoding keys",
            pattern_matched: "Anthropic key (sk-ant-...)",
            line_num: line_num,
            file_path: file_path
        ))
        return warnings

    # OpenAI API key: starts with "sk-" and 48+ chars (but not sk-ant-)
    if s.starts_with("sk-") and not s.starts_with("sk-ant-") and s.len() >= 48:
        if _is_likely_api_key(s):
            warnings.push(HardcodedSecretWarning(
                code: "SEC-SEC004",
                severity: "DENY",
                message: "hardcoded OpenAI API key detected",
                hint: "use env.require(\"OPENAI_API_KEY\") instead of hardcoding keys",
                pattern_matched: "OpenAI key (sk-...)",
                line_num: line_num,
                file_path: file_path
            ))
            return warnings

    # PEM private key
    if s.contains("-----BEGIN") and s.contains("PRIVATE KEY-----"):
        warnings.push(HardcodedSecretWarning(
            code: "SEC-SEC005",
            severity: "DENY",
            message: "hardcoded PEM private key detected",
            hint: "load private keys from files or environment variables, never hardcode in source",
            pattern_matched: "PEM private key",
            line_num: line_num,
            file_path: file_path
        ))
        return warnings

    # High-entropy hex string (64+ hex chars)
    if s.len() >= 64 and _is_hex_string(s):
        warnings.push(HardcodedSecretWarning(
            code: "SEC-SEC006",
            severity: "DENY",
            message: "high-entropy hex string detected (possible secret or hash)",
            hint: "if this is a secret, use env.require() to load at runtime; if a hash, add @allow(hardcoded_secret)",
            pattern_matched: "hex string ({s.len()} chars)",
            line_num: line_num,
            file_path: file_path
        ))
        return warnings

    # High-entropy base64 string (40+ chars, looks like base64)
    if s.len() >= 40 and _is_base64_string(s):
        warnings.push(HardcodedSecretWarning(
            code: "SEC-SEC007",
            severity: "DENY",
            message: "high-entropy base64 string detected (possible encoded secret)",
            hint: "if this is a secret, use env.require() to load at runtime; add @allow(hardcoded_secret) if safe",
            pattern_matched: "base64 string ({s.len()} chars)",
            line_num: line_num,
            file_path: file_path
        ))
        return warnings

    warnings


# ============================================================================
# Pattern Matchers
# ============================================================================

fn _is_aws_key_format(s: text) -> bool:
    """Check if string matches AWS access key format: AKIA + 16 uppercase alphanum."""
    if s.len() < 20:
        return false
    # Check chars 4-19 are uppercase letters or digits
    var i = 4
    while i < 20:
        val ch = s.slice(i, i + 1)
        if not _is_upper_alphanum(ch):
            return false
        i = i + 1
    true

fn _is_github_token(s: text) -> bool:
    """Check if string matches GitHub token format."""
    if s.starts_with("ghp_") and s.len() >= 40:
        return true
    if s.starts_with("gho_") and s.len() >= 40:
        return true
    if s.starts_with("ghs_") and s.len() >= 40:
        return true
    if s.starts_with("ghr_") and s.len() >= 40:
        return true
    false

fn _is_likely_api_key(s: text) -> bool:
    """Check if a sk- prefixed string looks like an API key (mostly alphanum)."""
    var alphanum_count = 0
    var i = 3  # Skip "sk-"
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if _is_alphanum(ch) or ch == "-" or ch == "_":
            alphanum_count = alphanum_count + 1
        i = i + 1
    # At least 80% of chars after prefix should be alphanum/dash/underscore
    val total = s.len() - 3
    if total == 0:
        return false
    alphanum_count * 100 / total >= 80

fn _is_hex_string(s: text) -> bool:
    """Check if string is entirely hex characters (0-9, a-f, A-F)."""
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if not _is_hex_char(ch):
            return false
        i = i + 1
    true

fn _is_base64_string(s: text) -> bool:
    """Check if string looks like base64 (alphanum, +, /, =)."""
    var valid_count = 0
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if _is_alphanum(ch) or ch == "+" or ch == "/" or ch == "=":
            valid_count = valid_count + 1
        i = i + 1
    # At least 90% of chars should be valid base64
    if s.len() == 0:
        return false
    valid_count * 100 / s.len() >= 90

fn _check_password_assignment(line: text, line_num: i64, file_path: text) -> HardcodedSecretWarning:
    """Check for direct password/secret assignment patterns like:
    password = "hardcoded"
    db_password: "hardcoded"
    """
    val sensitive_names = ["password", "passwd", "pwd", "secret", "api_key", "apikey",
                           "private_key", "db_password", "db_passwd"]

    var ni = 0
    while ni < sensitive_names.len():
        val name = sensitive_names[ni]
        # Check for: name = "..." or name: "..."
        val assign_pattern = name + " = \""
        val field_pattern = name + ": \""
        if line.contains(assign_pattern) or line.contains(field_pattern):
            # Make sure it's not assigning env.get or empty string
            if not line.contains("env.get") and not line.contains("env.require"):
                # Check it's not assigning ""
                val eq_idx = _find_substring(line, "\"")
                if eq_idx >= 0:
                    # Find closing quote
                    val close_idx = _find_substring_from(line, "\"", eq_idx + 1)
                    if close_idx > eq_idx + 1:  # Non-empty string
                        return HardcodedSecretWarning(
                            code: "SEC-SEC008",
                            severity: "DENY",
                            message: "hardcoded value assigned to sensitive variable '{name}'",
                            hint: "use env.require(\"{name.to_upper()}\") instead of hardcoding",
                            pattern_matched: "password assignment ({name})",
                            line_num: line_num,
                            file_path: file_path
                        )
        ni = ni + 1

    nil


# ============================================================================
# String Extraction
# ============================================================================

fn _extract_string_literals(line: text) -> [text]:
    """Extract all double-quoted string literals from a line.
    Does not handle escaped quotes inside strings (simple heuristic).
    """
    var result: [text] = []
    var in_string = false
    var start = 0
    var i = 0

    while i < line.len():
        val ch = line.slice(i, i + 1)
        if ch == "\"":
            if in_string:
                val content = line.slice(start, i)
                result.push(content)
                in_string = false
            else:
                in_string = true
                start = i + 1
        elif ch == "\\" and in_string:
            # Skip escaped character
            i = i + 1
        i = i + 1

    result


# ============================================================================
# Character Classification Helpers
# ============================================================================

fn _is_upper_alphanum(ch: text) -> bool:
    """Check if character is uppercase letter or digit."""
    if ch.len() != 1:
        return false
    val c = ch.to_byte()
    if c >= 65 and c <= 90:
        return true
    if c >= 48 and c <= 57:
        return true
    false

fn _is_alphanum(ch: text) -> bool:
    """Check if character is letter or digit."""
    if ch.len() != 1:
        return false
    val c = ch.to_byte()
    if c >= 97 and c <= 122:
        return true
    if c >= 65 and c <= 90:
        return true
    if c >= 48 and c <= 57:
        return true
    false

fn _is_hex_char(ch: text) -> bool:
    """Check if character is a hex digit (0-9, a-f, A-F)."""
    if ch.len() != 1:
        return false
    val c = ch.to_byte()
    if c >= 48 and c <= 57:
        return true
    if c >= 97 and c <= 102:
        return true
    if c >= 65 and c <= 70:
        return true
    false

fn _count_triple_quotes(line: text) -> i64:
    """Count the number of triple-quote sequences in a line."""
    var count = 0
    var i = 0
    while i + 2 < line.len():
        val chunk = line.slice(i, i + 3)
        if chunk == "\"\"\"":
            count = count + 1
            i = i + 3
        else:
            i = i + 1
    count

fn _find_substring(haystack: text, needle: text) -> i64:
    """Find the first occurrence of needle in haystack. Returns -1 if not found."""
    if needle.len() == 0:
        return 0
    if haystack.len() < needle.len():
        return -1
    var i = 0
    val limit = haystack.len() - needle.len() + 1
    while i < limit:
        val chunk = haystack.slice(i, i + needle.len())
        if chunk == needle:
            return i
        i = i + 1
    -1

fn _find_substring_from(haystack: text, needle: text, start: i64) -> i64:
    """Find needle in haystack starting from position start."""
    if start >= haystack.len():
        return -1
    val sub = haystack.slice(start)
    val idx = _find_substring(sub, needle)
    if idx < 0:
        return -1
    idx + start


# ============================================================================
# Exports
# ============================================================================

export HardcodedSecretWarning
export check_hardcoded_secret
