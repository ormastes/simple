# Param Tag Lint
#
# Detects public functions with ≥2 same-type primitive parameters that lack
# a `# @tag(...)` annotation, which would disambiguate parameter roles for
# callers and suppress the DTYP001 "positional swap" hazard.
#
# PTAG001: `pub fn` has ≥2 same-type primitive params with no @tag annotation
# PTAG002: Same-type params carry different tags; callers should use named args
#           (emitted on the function definition — call-site detection is future AST work)
#
# Annotation format — comment on the line immediately before the fn declaration:
#   # @tag(h1=hash_value, h2=hash_value)
#   pub fn hash_combine(h1: i64, h2: i64) -> i64:
#
# Does NOT flag:
# - Non-pub functions (PTAG001 is pub-only)
# - Functions whose name appears in COMMUTATIVE_FN_NAMES
# - Functions that already carry a @tag annotation
# - Params whose type is NOT in BARE_PRIMITIVES
#
# ============================================================================

use std.io_runtime

# ============================================================================
# Constants
# ============================================================================

val BARE_PRIMITIVES: [text] = [
    "i64", "i32", "i16", "i8",
    "u64", "u32", "u16", "u8",
    "f64", "f32",
    "text", "bool"
]

val COMMUTATIVE_FN_NAMES: [text] = [
    "hash_combine", "min", "max", "add", "mul", "xor",
    "combine", "merge", "gcd", "lcm"
]

# ============================================================================
# Warning Struct
# ============================================================================

pub struct ParamTagWarning:
    code: text
    severity: text
    message: text
    hint: text
    fn_name: text
    line_num: i64
    file_path: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.file_path}:{self.line_num} — {self.message} — {self.hint}"

# ============================================================================
# Helpers: character classification
# ============================================================================

fn _is_ident_char(ch: text) -> bool:
    if ch.len() != 1:
        return false
    if ch >= "a" and ch <= "z":
        return true
    if ch >= "A" and ch <= "Z":
        return true
    if ch >= "0" and ch <= "9":
        return true
    if ch == "_":
        return true
    false

fn _is_space_char(ch: text) -> bool:
    ch == " " or ch == "\t"

# ============================================================================
# Annotation Parsing
# ============================================================================

pub fn parse_tag_annotation(line: text) -> {text: text}:
    """Parse a `# @tag(name1=role1, name2=role2, ...)` comment line.

    Returns a map of param_name → role_name.
    Returns an empty map if the line is not a valid @tag comment.
    """
    var result: {text: text} = {}
    val trimmed = line.trim()
    # Must start with '# @tag('
    if not trimmed.starts_with("# @tag("):
        return result
    # Length of "# @tag" = 6, so char at index 6 should be '('
    val open_idx = 6
    if open_idx >= trimmed.len():
        return result
    if trimmed.slice(open_idx, open_idx + 1) != "(":
        return result
    # Find closing paren
    val close_idx = trimmed.index_of(")") ?? -1
    if close_idx < open_idx + 1:
        return result
    # Extract the inner content
    val inner = trimmed.slice(open_idx + 1, close_idx).trim()
    if inner == "":
        return result
    # Split by comma and parse key=value pairs
    val parts = inner.split(",")
    var pi = 0
    while pi < parts.len():
        val part = parts[pi].trim()
        val eq_idx = part.index_of("=") ?? -1
        if eq_idx > 0:
            val key = part.slice(0, eq_idx).trim()
            val value = part.slice(eq_idx + 1).trim()
            if key != "" and value != "":
                result[key] = value
        pi = pi + 1
    result

# ============================================================================
# Signature Parsing
# ============================================================================

pub fn extract_fn_name_from_sig(sig_line: text) -> text:
    """Extract the function name from a fn declaration line.

    Handles: `fn name(`, `pub fn name(`, `pub fn name :`
    Returns empty string if no function name found.
    """
    val trimmed = sig_line.trim()
    # Locate 'fn ' keyword offset within the line
    var pos = -1
    if trimmed.starts_with("fn "):
        pos = 3
    elif trimmed.starts_with("pub fn "):
        pos = 7
    elif trimmed.starts_with("me "):
        pos = 3
    elif trimmed.starts_with("pub me "):
        pos = 7
    elif trimmed.starts_with("static fn "):
        pos = 10
    elif trimmed.starts_with("pub static fn "):
        pos = 14
    else:
        return ""
    # Skip whitespace after keyword
    while pos < trimmed.len() and _is_space_char(trimmed.slice(pos, pos + 1)):
        pos = pos + 1
    # Read identifier chars
    val name_start = pos
    while pos < trimmed.len() and _is_ident_char(trimmed.slice(pos, pos + 1)):
        pos = pos + 1
    if pos == name_start:
        return ""
    trimmed.slice(name_start, pos)

pub fn extract_param_names_from_sig(sig_line: text) -> [text]:
    """Extract parameter names from a fn declaration line."""
    var names: [text] = []
    val trimmed = sig_line.trim()
    val open_paren = trimmed.index_of("(") ?? -1
    if open_paren < 0:
        return names
    val close_paren = trimmed.index_of(")") ?? -1
    if close_paren <= open_paren:
        return names
    val params_str = trimmed.slice(open_paren + 1, close_paren).trim()
    if params_str == "":
        return names
    val parts = params_str.split(",")
    var pi = 0
    while pi < parts.len():
        val part = parts[pi].trim()
        if part == "" or part == "self" or part == "me":
            pi = pi + 1
            continue
        if part.starts_with("*") or part.starts_with("&"):
            pi = pi + 1
            continue
        val colon_idx = part.index_of(":") ?? -1
        if colon_idx > 0:
            val pname = part.slice(0, colon_idx).trim()
            if pname != "":
                names.push(pname)
        pi = pi + 1
    names

pub fn extract_param_types_from_sig(sig_line: text) -> [text]:
    """Extract parameter type names from a fn declaration line.

    Returns types in the same order as extract_param_names_from_sig.
    Only returns simple identifier types (no generics, no tuple types).
    Returns empty string entries for params with complex types.
    """
    var types: [text] = []
    val trimmed = sig_line.trim()
    val open_paren = trimmed.index_of("(") ?? -1
    if open_paren < 0:
        return types
    val close_paren = trimmed.index_of(")") ?? -1
    if close_paren <= open_paren:
        return types
    val params_str = trimmed.slice(open_paren + 1, close_paren).trim()
    if params_str == "":
        return types
    val parts = params_str.split(",")
    var pi = 0
    while pi < parts.len():
        val part = parts[pi].trim()
        if part == "" or part == "self" or part == "me":
            pi = pi + 1
            continue
        if part.starts_with("*") or part.starts_with("&"):
            pi = pi + 1
            continue
        val colon_idx = part.index_of(":") ?? -1
        if colon_idx > 0:
            val ptype = part.slice(colon_idx + 1).trim()
            if ptype != "":
                val is_simple = (not ptype.contains("<") and
                                 not ptype.contains("(") and
                                 not ptype.contains("[") and
                                 not ptype.contains("{"))
                if is_simple:
                    types.push(ptype)
                else:
                    types.push("")
            else:
                types.push("")
        else:
            types.push("")
        pi = pi + 1
    types

# ============================================================================
# Internal Helpers
# ============================================================================

fn _is_primitive(ty: text) -> bool:
    """Check if a type name is in BARE_PRIMITIVES."""
    var pi = 0
    while pi < BARE_PRIMITIVES.len():
        if BARE_PRIMITIVES[pi] == ty:
            return true
        pi = pi + 1
    false

fn _is_commutative_fn(name: text) -> bool:
    """Check if a function name is in the commutative allowlist."""
    var ci = 0
    while ci < COMMUTATIVE_FN_NAMES.len():
        if COMMUTATIVE_FN_NAMES[ci] == name:
            return true
        ci = ci + 1
    false

fn _is_pub_fn_line(trimmed: text) -> bool:
    """Check if a trimmed line is a pub fn declaration."""
    trimmed.starts_with("pub fn ") or trimmed.starts_with("pub me ")

fn _is_fn_line(trimmed: text) -> bool:
    """Check if a trimmed line is any fn declaration."""
    (trimmed.starts_with("fn ") or trimmed.starts_with("pub fn ") or
     trimmed.starts_with("me ") or trimmed.starts_with("pub me ") or
     trimmed.starts_with("static fn ") or trimmed.starts_with("pub static fn "))

# ============================================================================
# Main Entry Point
# ============================================================================

pub fn check_param_tag(lines: [text], file: text) -> [ParamTagWarning]:
    """Scan source lines for pub fn declarations with same-type primitive params.

    Text-heuristic algorithm:
    1. For each line, detect `# @tag(...)` comment → remember as pending tag.
    2. On the next fn declaration line:
       a. PTAG001: pub fn with ≥2 same-type primitive params and no @tag → warn.
       b. PTAG002: @tag present but same-type params have different roles → warn.
    3. Clear pending tag after consuming it (or on any non-fn, non-comment line).

    PTAG001 applies only to `pub fn`.
    PTAG002 signals that callers must use named args; call-site detection is future AST work.
    Commutative fn names are excluded from PTAG001.

    Returns list of ParamTagWarning.
    """
    var warnings: [ParamTagWarning] = []
    var pending_tag: {text: text} = {}
    var has_pending_tag = false

    var li = 0
    while li < lines.len():
        val raw = lines[li]
        val trimmed = raw.trim()
        val line_num = li + 1

        if trimmed == "":
            # Blank lines do not clear the pending tag
            li = li + 1
            continue

        if trimmed.starts_with("# @tag("):
            pending_tag = parse_tag_annotation(trimmed)
            has_pending_tag = true
            li = li + 1
            continue

        if trimmed.starts_with("#"):
            # Other comment lines do not clear the pending tag
            li = li + 1
            continue

        if _is_fn_line(trimmed):
            val is_pub = _is_pub_fn_line(trimmed)
            val fn_name = extract_fn_name_from_sig(trimmed)
            val param_names = extract_param_names_from_sig(trimmed)
            val param_types = extract_param_types_from_sig(trimmed)

            if fn_name != "" and param_names.len() >= 2 and param_names.len() == param_types.len():
                # Group primitive params by type (parallel arrays)
                # IMPORTANT: dict[key].push() does NOT mutate in-place; must get/push/reassign
                var by_type_names: {text: [text]} = {}
                var pi = 0
                while pi < param_names.len():
                    val pname = param_names[pi]
                    val ptype = param_types[pi]
                    if ptype != "" and _is_primitive(ptype):
                        if by_type_names.has(ptype):
                            var existing_list = by_type_names[ptype]
                            existing_list.push(pname)
                            by_type_names[ptype] = existing_list
                        else:
                            by_type_names[ptype] = [pname]
                    pi = pi + 1

                # Find types that appear for ≥2 params
                # IMPORTANT: dict iteration yields (key, value) tuples; use .0 and .1
                var dup_types: [text] = []
                for kv in by_type_names:
                    if kv.1.len() >= 2:
                        dup_types.push(kv.0)

                if dup_types.len() > 0 and is_pub and not _is_commutative_fn(fn_name):
                    if not has_pending_tag:
                        # PTAG001: missing @tag annotation
                        val type_list = dup_types.join(", ")
                        warnings.push(ParamTagWarning(
                            code: "PTAG001",
                            severity: "WARNING",
                            message: "pub fn '{fn_name}' has ≥2 params sharing type(s) [{type_list}] with no @tag annotation",
                            hint: "add `# @tag(p1=role, p2=role)` on the line before the declaration",
                            fn_name: fn_name,
                            line_num: line_num,
                            file_path: file
                        ))
                    else:
                        # @tag present — check if same-type params have different roles
                        var ti = 0
                        while ti < dup_types.len():
                            val ty = dup_types[ti]
                            val names = by_type_names[ty]
                            # Collect tags for each param in this type group
                            var roles: [text] = []
                            var ni = 0
                            while ni < names.len():
                                val pname = names[ni]
                                val role = pending_tag[pname] ?? ""
                                roles.push(role)
                                ni = ni + 1
                            # Check if all roles are identical (commutative / interchangeable)
                            var all_same = true
                            var ri = 1
                            while ri < roles.len():
                                if roles[ri] != roles[0]:
                                    all_same = false
                                    break
                                ri = ri + 1
                            if not all_same:
                                # PTAG002: different roles — callers must use named args
                                val param_list = names.join(", ")
                                warnings.push(ParamTagWarning(
                                    code: "PTAG002",
                                    severity: "WARNING",
                                    message: "pub fn '{fn_name}' params [{param_list}] share type '{ty}' but have different @tag roles",
                                    hint: "callers must use named args to avoid silent parameter swap (call-site enforcement is future work)",
                                    fn_name: fn_name,
                                    line_num: line_num,
                                    file_path: file
                                ))
                            ti = ti + 1

            # Consume the pending tag
            pending_tag = {}
            has_pending_tag = false
        else:
            # Non-fn, non-comment, non-blank: clear pending tag
            pending_tag = {}
            has_pending_tag = false

        li = li + 1
    warnings

# ============================================================================
# Exports
# ============================================================================
