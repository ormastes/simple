# Unused Variables Lint
#
# Detects declarations that are never referenced after their definition:
#
# UNUSED001: Variable declared with val/var but never used               WARNING
# UNUSED002: Imported symbol never used in the file                      WARNING
# UNUSED003: Function parameter never used in body                       WARNING
#
# Does NOT flag:
# - Variables named with _ prefix (convention for intentionally unused)
# - The 'self' parameter (implicit receiver)
# - extern fn declarations (no body to check)
# - Functions already marked with pass_todo / pass_do_nothing / pass_dn
#
# Works with the arena-based core AST (integer-tagged nodes).

use compiler.core.ast_expr.{
    EXPR_IDENT, EXPR_CALL, EXPR_METHOD_CALL, EXPR_BINARY, EXPR_UNARY,
    EXPR_INDEX, EXPR_FIELD_ACCESS, EXPR_ARRAY_LIT, EXPR_IF, EXPR_MATCH,
    EXPR_FOR, EXPR_WHILE, EXPR_BLOCK, EXPR_RETURN, EXPR_LAMBDA,
    EXPR_ASSIGN, EXPR_COMPOUND_ASSIGN, EXPR_DICT_LIT, EXPR_STRUCT_LIT,
    EXPR_TUPLE, EXPR_SLICE, EXPR_NULL_COALESCE, EXPR_OPTIONAL_CHAIN,
    EXPR_CAST, EXPR_INTERPOLATED_STRING, EXPR_RANGE, EXPR_SPREAD,
    EXPR_DO_BLOCK, EXPR_LIST_COMP, EXPR_DICT_COMP,
    EXPR_PASS_TODO, EXPR_PASS_DO_NOTHING, EXPR_PASS_DN,
    expr_tag, expr_s_val, expr_left, expr_right, expr_extra, expr_args, expr_stmts
}
use compiler.core.ast_stmt.{
    STMT_EXPR, STMT_VAL_DECL, STMT_VAR_DECL, STMT_ASSIGN, STMT_RETURN,
    STMT_IF, STMT_FOR, STMT_WHILE, STMT_MATCH, STMT_BLOCK,
    STMT_COMPOUND_ASSIGN, STMT_LAZY_VAL_DECL,
    stmt_tag, stmt_expr, stmt_name, stmt_body
}
use compiler.core.ast.{
    DECL_FN, DECL_EXTERN_FN, DECL_VAL, DECL_VAR, DECL_USE, DECL_LAZY_VAL,
    decl_tag, decl_name, decl_param_names, decl_body_stmts, decl_imports
}

# ============================================================================
# Warning Struct
# ============================================================================

struct UnusedVarWarning:
    code: text
    severity: text
    message: text
    hint: text
    item_name: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message} — {self.hint}"

# ============================================================================
# Main Entry Point
# ============================================================================

fn check_unused_vars(decl_indices: [i64]) -> [UnusedVarWarning]:
    """Run unused-variable lint on module declarations.

    Three checks:
    1. UNUSED001: val/var declarations inside function bodies never referenced
    2. UNUSED002: Imported symbols never used in the file
    3. UNUSED003: Function parameters never used in the body
    """
    var warnings: [UnusedVarWarning] = []

    # Check function-level unused params and local vars
    for idx in decl_indices:
        val tag = decl_tag[idx]

        if tag == DECL_FN:
            val fn_name = decl_name[idx]
            val params = decl_param_names[idx]
            val body = decl_body_stmts[idx]

            # Skip functions with pass markers (stubs)
            if body_has_pass_marker_uv(body):
                continue

            # UNUSED003: Check unused parameters
            val param_warnings = check_unused_params(fn_name, params, body)
            for w in param_warnings:
                warnings.push(w)

            # UNUSED001: Check unused local variables
            val local_warnings = check_unused_locals(fn_name, body)
            for w in local_warnings:
                warnings.push(w)

    # UNUSED002: Check unused imports
    val import_warnings = check_unused_imports(decl_indices)
    for w in import_warnings:
        warnings.push(w)

    warnings

# ============================================================================
# UNUSED003: Unused Parameters
# ============================================================================

fn check_unused_params(fn_name: text, params: [text], body: [i64]) -> [UnusedVarWarning]:
    """Check for function parameters that are never referenced in the body."""
    var warnings: [UnusedVarWarning] = []

    # Skip empty bodies
    if body.len() == 0:
        return warnings

    # Collect all identifier references in the body
    var refs: {text: bool} = {}
    collect_refs_in_stmts(body, refs)

    for param in params:
        # Skip 'self' — always implicit
        if param == "self":
            continue
        # Skip _ prefixed (intentionally unused)
        if param.starts_with("_"):
            continue
        # Check if param is referenced anywhere in body
        if not refs.has(param):
            warnings.push(UnusedVarWarning(
                code: "UNUSED003",
                severity: "WARNING",
                message: "parameter '{param}' is never used in '{fn_name}'",
                hint: "prefix with _ to mark as intentionally unused",
                item_name: fn_name
            ))

    warnings

# ============================================================================
# UNUSED001: Unused Local Variables
# ============================================================================

fn check_unused_locals(fn_name: text, body: [i64]) -> [UnusedVarWarning]:
    """Check for local val/var declarations that are never referenced after definition."""
    var warnings: [UnusedVarWarning] = []

    # Collect all local declarations
    var locals: [text] = []
    collect_local_decls(body, locals)

    if locals.len() == 0:
        return warnings

    # Collect all identifier references in the body
    var refs: {text: bool} = {}
    collect_refs_in_stmts(body, refs)

    for local in locals:
        # Skip _ prefixed
        if local.starts_with("_"):
            continue
        # A local variable is "used" if it appears as an identifier reference
        # beyond its own declaration. Since we collect refs from the full body
        # including initializer expressions, we need to check if it appears
        # in any expression context (not just the declaration itself).
        # The name appears in stmt_name for decls but refs collect EXPR_IDENT
        # so a variable only in refs if it is actually read somewhere.
        if not refs.has(local):
            warnings.push(UnusedVarWarning(
                code: "UNUSED001",
                severity: "WARNING",
                message: "variable '{local}' is declared but never used in '{fn_name}'",
                hint: "remove the variable or prefix with _ to mark as intentionally unused",
                item_name: fn_name
            ))

    warnings

fn collect_local_decls(stmts: [i64], locals: [text]):
    """Collect all val/var declaration names from a statement list."""
    for s in stmts:
        if s < 0:
            continue
        val tag = stmt_tag[s]

        if tag == STMT_VAL_DECL or tag == STMT_VAR_DECL or tag == STMT_LAZY_VAL_DECL:
            val name = stmt_name[s]
            if name != "":
                locals.push(name)

        # Recurse into nested blocks
        if tag == STMT_IF or tag == STMT_BLOCK or tag == STMT_FOR or tag == STMT_WHILE or tag == STMT_MATCH:
            collect_local_decls(stmt_body[s], locals)

# ============================================================================
# UNUSED002: Unused Imports
# ============================================================================

fn check_unused_imports(decl_indices: [i64]) -> [UnusedVarWarning]:
    """Check for imported symbols never referenced in the file."""
    var warnings: [UnusedVarWarning] = []

    # Collect all explicitly imported names
    var imported_names: [text] = []
    var import_sources: {text: text} = {}

    for idx in decl_indices:
        if decl_tag[idx] == DECL_USE:
            val mod_path = decl_name[idx]
            val names = decl_imports[idx]
            for name in names:
                # Strip alias if present (name:alias)
                val base = strip_import_alias(name)
                imported_names.push(base)
                import_sources[base] = mod_path

    if imported_names.len() == 0:
        return warnings

    # Collect all identifier references across all declarations
    var refs: {text: bool} = {}
    for idx in decl_indices:
        val tag = decl_tag[idx]
        if tag == DECL_FN:
            collect_refs_in_stmts(decl_body_stmts[idx], refs)
        elif tag == DECL_VAL or tag == DECL_VAR or tag == DECL_LAZY_VAL:
            val body = decl_body_stmts[idx]
            for s in body:
                if s >= 0:
                    collect_refs_in_expr(s, refs)

    for name in imported_names:
        if not refs.has(name):
            val source = import_sources[name] ?? ""
            warnings.push(UnusedVarWarning(
                code: "UNUSED002",
                severity: "WARNING",
                message: "imported symbol '{name}' from '{source}' is never used",
                hint: "remove the unused import",
                item_name: name
            ))

    warnings

# ============================================================================
# Reference Collection
# ============================================================================

fn collect_refs_in_stmts(stmts: [i64], refs: {text: bool}):
    """Collect all EXPR_IDENT references from a statement list."""
    for s in stmts:
        if s < 0:
            continue
        val tag = stmt_tag[s]

        # Collect from expression
        val e = stmt_expr[s]
        if e >= 0:
            collect_refs_in_expr(e, refs)

        # Recurse into child statements
        val children = stmt_body[s]
        collect_refs_in_stmts(children, refs)

fn collect_refs_in_expr(e: i64, refs: {text: bool}):
    """Collect all EXPR_IDENT names referenced in an expression tree."""
    if e < 0:
        return

    val tag = expr_tag[e]

    if tag == EXPR_IDENT:
        val name = expr_s_val[e]
        if name != "":
            refs[name] = true
        return

    # Recurse into sub-expressions
    collect_refs_in_expr(expr_left[e], refs)
    collect_refs_in_expr(expr_right[e], refs)
    collect_refs_in_expr(expr_extra[e], refs)

    for arg in expr_args[e]:
        collect_refs_in_expr(arg, refs)

    for child_stmt in expr_stmts[e]:
        if child_stmt >= 0:
            val child_tag = stmt_tag[child_stmt]
            val child_e = stmt_expr[child_stmt]
            if child_e >= 0:
                collect_refs_in_expr(child_e, refs)
            collect_refs_in_stmts(stmt_body[child_stmt], refs)

# ============================================================================
# Pass Marker Detection (local copy to avoid circular imports)
# ============================================================================

fn body_has_pass_marker_uv(stmts: [i64]) -> bool:
    """Check if any statement contains pass_todo/pass_do_nothing/pass_dn."""
    for s in stmts:
        if s < 0:
            continue
        val e = stmt_expr[s]
        if e >= 0:
            val etag = expr_tag[e]
            if etag == EXPR_PASS_TODO or etag == EXPR_PASS_DO_NOTHING or etag == EXPR_PASS_DN:
                return true
    false

# ============================================================================
# Helpers
# ============================================================================

fn strip_import_alias(name: text) -> text:
    """Strip alias suffix from import name. 'foo:bar' -> 'foo'."""
    for i in 0..name.len():
        if name.char_at(i) == ":":
            return name.slice(0, i)
    name

# ============================================================================
# Exports
# ============================================================================
