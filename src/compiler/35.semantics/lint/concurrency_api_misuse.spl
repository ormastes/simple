# Concurrency API Misuse Lint
#
# Detects five categories of concurrency API misuse (E-PAR-001 through E-PAR-005).
# These rules guard the OS-thread / cooperative-green / multicore-green surface
# boundaries so callers can never accidentally mix the three scheduling models.
#
# E-PAR-001: task_spawn imported from std.concurrent.thread (wrong surface)         ERROR
# E-PAR-002: numbered-suffix concurrency alias (e.g. thread_spawn2)                  ERROR
# E-PAR-003: concurrency symbol imported from wrong module surface                    ERROR
# E-PAR-004: call-shape violation — wrong arity OR non-closure/non-integer arg        ERROR
# E-PAR-005: direct use of internal rt_pool_* extern symbols outside the facade       ERROR
#
# Rule intents (from Rust seed validate_concurrency_api_calls / validate_numbered_concurrency_source):
#
#  E-PAR-001 — `task_spawn` is a green-task primitive that belongs to
#              std.nogc_async_mut.thread_pool.  Importing it from any
#              std.concurrent.thread path is a surface violation.
#              Message: "task_spawn is not part of the OS-thread facade"
#
#  E-PAR-002 — Numbered names (thread_spawn2, spawn_isolated2, spawn_limited2)
#              are internal aliases that expose implementation details.
#              Message: "<name> is a numbered name and is not a public API"
#
#  E-PAR-003 — A concurrency symbol is imported from the wrong module.
#              e.g. green_spawn from std.concurrent.thread, or thread_spawn
#              from std.concurrent.cooperative_green.
#              Message: "<name> belongs to <expected>, not <actual>"
#
#  E-PAR-004 — Call-shape violation: wrong arity (any count != 1) on a spawn/
#              parallelism call, OR first argument is not the required type.
#              - wrong arity →        message contains "single zero-argument value closure"
#              - non-closure spawn →  message contains "pass a closure"
#              - bad set_parallelism → message contains "single integer worker count"
#
#  E-PAR-005 — Direct use of an internal rt_pool_* runtime symbol (rt_pool_submit,
#              rt_pool_join, rt_pool_is_done, rt_pool_set_parallelism,
#              rt_pool_get_parallelism) anywhere outside the sanctioned multicore_green
#              facade implementation files.
#              Trigger: any `extern fn` line containing one of those symbol names.
#              Exempt: files whose path ends with
#                src/lib/nogc_async_mut/concurrent/multicore_green.spl
#                src/lib/gc_async_mut/concurrent/multicore_green.spl
#                src/lib/nogc_sync_mut/concurrent/multicore_green.spl
#                src/lib/gc_sync_mut/concurrent/multicore_green.spl
#              Message: "<name> is an internal runtime-pool symbol and is not a public API"
#
# This file uses text-heuristic analysis (no AST dependency) so it can run in
# interpreter-mode specs.  The API-call shape checks (E-PAR-004) scan source lines
# for call patterns the way validate_concurrency_api_calls does.  E-PAR-005 scans
# extern fn lines the way validate_numbered_concurrency_source does.
# check_concurrency_api_misuse accepts an optional file_path parameter used only
# for the E-PAR-005 path exemption; pass "" when the path is unknown.

# ============================================================================
# Finding Struct
# ============================================================================

struct ConcurrencyMisuseFinding:
    code: text
    severity: text
    message: text
    name: text
    note: text

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message}"

# ============================================================================
# Helpers — identifier / token utilities
# ============================================================================

fn _cam_is_ident_char(c: text) -> bool:
    val alpha = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
    alpha.contains(c)

fn _cam_is_digit(c: text) -> bool:
    val digits = "0123456789"
    digits.contains(c)

fn _cam_find_substr(haystack: text, needle: text) -> i64:
    """Return start index of first occurrence of needle in haystack, or -1."""
    val nlen = needle.len()
    val hlen = haystack.len()
    var i = 0
    while i <= hlen - nlen:
        val sub = haystack.substring(i, i + nlen)
        if sub == needle:
            return i
        i = i + 1
    -1

fn _cam_extract_name(after_kw: text) -> text:
    """Extract identifier from text starting right after a keyword+space."""
    var i = 0
    val len = after_kw.len()
    while i < len:
        val c = after_kw.substring(i, i + 1)
        if not _cam_is_ident_char(c):
            break
        i = i + 1
    after_kw.substring(0, i)

fn _cam_is_token(line: text, token: text) -> bool:
    """True if token appears as a whole identifier in line (not part of a longer name)."""
    val tlen = token.len()
    val llen = line.len()
    var i = 0
    while i <= llen - tlen:
        val sub = line.substring(i, i + tlen)
        if sub == token:
            var after_ok = true
            var before_ok = true
            if i + tlen < llen:
                val ac = line.substring(i + tlen, i + tlen + 1)
                if _cam_is_ident_char(ac):
                    after_ok = false
            if i > 0:
                val bc = line.substring(i - 1, i)
                if _cam_is_ident_char(bc):
                    before_ok = false
            if after_ok and before_ok:
                return true
        i = i + 1
    false

fn _cam_count_call_args(line: text, callee: text) -> i64:
    """Count comma-separated top-level arguments in the call to `callee` on this line.
    Returns -1 if callee call not found, 0 if empty parens."""
    val call_start = _cam_find_substr(line, callee + "(")
    if call_start < 0:
        return -1
    val after = line.substring(call_start + callee.len() + 1)
    # Find matching close paren (depth 0)
    var depth = 1
    var i = 0
    var commas = 0
    var has_content = false
    val len = after.len()
    while i < len and depth > 0:
        val c = after.substring(i, i + 1)
        if c == "(":
            depth = depth + 1
            has_content = true
        elif c == ")":
            depth = depth - 1
            if depth == 0:
                # done
                i = i + 1
            else:
                has_content = true
        elif c == "," and depth == 1:
            commas = commas + 1
            has_content = true
        elif c != " " and c != "\t":
            has_content = true
        if depth > 0:
            i = i + 1
    if not has_content:
        return 0
    commas + 1

fn _cam_first_arg_text(line: text, callee: text) -> text:
    """Extract the text of the first argument to callee( on this line."""
    val call_start = _cam_find_substr(line, callee + "(")
    if call_start < 0:
        return ""
    val after = line.substring(call_start + callee.len() + 1)
    var depth = 1
    var i = 0
    val len = after.len()
    while i < len and depth > 0:
        val c = after.substring(i, i + 1)
        if c == "(":
            depth = depth + 1
        elif c == ")":
            depth = depth - 1
            if depth == 0:
                return after.substring(0, i).trim()
        elif c == "," and depth == 1:
            return after.substring(0, i).trim()
        i = i + 1
    after.trim()

fn _cam_first_arg_is_closure(arg_text: text) -> bool:
    """True if the first-arg text looks like a closure (\: ...) or multi-line lambda."""
    val t = arg_text.trim()
    t.starts_with("\\:") or t.starts_with("\\")

fn _cam_first_arg_is_integer(arg_text: text) -> bool:
    """True if the first-arg text looks like an integer literal."""
    val t = arg_text.trim()
    if t.len() == 0:
        return false
    var i = 0
    val len = t.len()
    # Allow leading minus
    if t.substring(0, 1) == "-":
        i = 1
    if i >= len:
        return false
    var all_digits = true
    while i < len:
        val c = t.substring(i, i + 1)
        if not _cam_is_digit(c):
            all_digits = false
        i = i + 1
    all_digits

# ============================================================================
# Import line parsers
# ============================================================================

fn _cam_is_thread_path(path: text) -> bool:
    (path == "std.concurrent.thread" or
     path == "std.nogc_async_mut.concurrent.thread" or
     path == "std.nogc_sync_mut.concurrent.thread" or
     path == "concurrency.threads" or
     path == "std.concurrency.threads")

fn _cam_is_green_thread_path(path: text) -> bool:
    (path == "std.concurrent.green_thread" or
     path == "std.nogc_async_mut.concurrent.green_thread")

fn _cam_is_cooperative_green_path(path: text) -> bool:
    (path == "std.concurrent.cooperative_green" or
     path == "std.nogc_async_mut.concurrent.cooperative_green")

fn _cam_is_multicore_green_path(path: text) -> bool:
    (path == "std.concurrent.multicore_green" or
     path == "std.nogc_async_mut.concurrent.multicore_green")

fn _cam_numbered_replacement(name: text) -> text:
    """Return replacement name for numbered aliases, or empty string if not a numbered alias."""
    if name == "thread_spawn2":
        return "thread_spawn_with_args"
    if name == "spawn_isolated2":
        return "spawn_isolated_with_args"
    if name == "spawn_limited2":
        return "spawn_limited_with_args"
    ""

fn _cam_expected_owner(name: text) -> text:
    """Return the canonical module for a concurrency symbol, or '' if unknown."""
    if name == "thread_spawn" or name == "thread_spawn_with_args":
        return "std.concurrent.thread"
    if name == "green_spawn":
        return "std.concurrent.green_thread"
    if (name == "cooperative_green_spawn" or name == "cooperative_green_spawn_value" or
        name == "cooperative_green_run_one" or name == "cooperative_green_run_all"):
        return "std.concurrent.cooperative_green"
    if name == "multicore_green_spawn" or name == "multicore_green_set_parallelism":
        return "std.concurrent.multicore_green"
    if name == "task_spawn":
        return "std.nogc_async_mut.thread_pool"
    ""

fn _cam_owner_accepts(owner_path: text, name: text) -> bool:
    """True if owner_path is a valid import surface for symbol name."""
    if name == "thread_spawn" or name == "thread_spawn_with_args":
        return _cam_is_thread_path(owner_path)
    if name == "green_spawn":
        return _cam_is_green_thread_path(owner_path) or _cam_is_cooperative_green_path(owner_path)
    if (name == "cooperative_green_spawn" or name == "cooperative_green_spawn_value"):
        return _cam_is_cooperative_green_path(owner_path)
    if name == "multicore_green_spawn" or name == "multicore_green_set_parallelism":
        return _cam_is_multicore_green_path(owner_path)
    if name == "task_spawn":
        return owner_path == "std.nogc_async_mut.thread_pool" or owner_path == "nogc_async_mut.thread_pool"
    true

fn _cam_parse_use_line(line: text) -> [text]:
    """Parse a `use path.{sym1, sym2}` or `use path.sym` line.
    Returns a flat list of [owner_path, sym1, sym2, ...] or empty list if not a use line."""
    val t = line.trim()
    if not t.starts_with("use "):
        return []
    val rest = t.substring(4).trim()
    # Find the last dot before { or end of path
    val brace_pos = _cam_find_substr(rest, "{")
    if brace_pos >= 0:
        # use path.{sym1, sym2, ...}
        val path_part = rest.substring(0, brace_pos)
        # Remove trailing dot
        var owner = path_part
        val plen = path_part.len()
        if plen > 0 and path_part.substring(plen - 1) == ".":
            owner = path_part.substring(0, plen - 1)
        # Remove any trailing spaces
        owner = owner.trim()
        val close = _cam_find_substr(rest, "}")
        val syms_text = if close >= 0: rest.substring(brace_pos + 1, close) else rest.substring(brace_pos + 1)
        val syms_raw = syms_text.split(",")
        var result: [text] = [owner]
        for s in syms_raw:
            # Handle aliased imports: "name as alias" — use the original name for rule checks
            val stripped = s.trim()
            val as_pos = _cam_find_substr(stripped, " as ")
            val sym_name = if as_pos >= 0: stripped.substring(0, as_pos).trim() else stripped
            if sym_name != "":
                result.push(sym_name)
        return result
    # use path.sym  (no braces)
    val last_dot = _cam_rfind_char(rest, ".")
    if last_dot >= 0:
        val owner = rest.substring(0, last_dot)
        val sym = rest.substring(last_dot + 1)
        val sym_clean = _cam_extract_name(sym.trim())
        if sym_clean != "":
            return [owner, sym_clean]
    []

fn _cam_rfind_char(s: text, ch: text) -> i64:
    """Return last index of ch in s, or -1."""
    val len = s.len()
    var i = len - 1
    while i >= 0:
        if s.substring(i, i + 1) == ch:
            return i
        i = i - 1
    -1

# ============================================================================
# E-PAR-002 / E-PAR-001 / E-PAR-003 — import-level checks
# ============================================================================

fn _cam_check_import_findings(owner: text, sym_name: text) -> [ConcurrencyMisuseFinding]:
    """Given an import `use <owner>.{sym_name}`, return any E-PAR-001/002/003 findings."""
    var findings: [ConcurrencyMisuseFinding] = []

    # E-PAR-002: numbered alias
    val replacement = _cam_numbered_replacement(sym_name)
    if replacement != "":
        findings.push(ConcurrencyMisuseFinding(
            code: "E-PAR-002",
            severity: "ERROR",
            message: "{sym_name} is a numbered name and is not a public API",
            name: sym_name,
            note: "use {replacement} for explicit-argument spawning"
        ))
        return findings

    # E-PAR-001: task_spawn imported from a thread path
    if _cam_is_thread_path(owner) and sym_name == "task_spawn":
        findings.push(ConcurrencyMisuseFinding(
            code: "E-PAR-001",
            severity: "ERROR",
            message: "task_spawn is not part of the OS-thread facade",
            name: "task_spawn",
            note: "import task_spawn from std.nogc_async_mut.thread_pool instead"
        ))
        return findings

    # E-PAR-003: symbol imported from wrong surface
    val expected_owner = _cam_expected_owner(sym_name)
    if expected_owner != "" and not _cam_owner_accepts(owner, sym_name):
        findings.push(ConcurrencyMisuseFinding(
            code: "E-PAR-003",
            severity: "ERROR",
            message: "{sym_name} belongs to {expected_owner}, not {owner}",
            name: sym_name,
            note: "import {sym_name} from {expected_owner}"
        ))

    findings

# ============================================================================
# E-PAR-004 / E-PAR-005 — call-shape checks (per call line)
# ============================================================================

fn _cam_call_shape_findings(line: text, callee: text) -> [ConcurrencyMisuseFinding]:
    """Check a source line for E-PAR-004 on the given callee call.
    E-PAR-004 covers both wrong arity and wrong first-arg type."""
    var findings: [ConcurrencyMisuseFinding] = []

    val argc = _cam_count_call_args(line, callee)
    if argc < 0:
        return findings

    # E-PAR-004: wrong arity (expected 1)
    if argc != 1:
        findings.push(ConcurrencyMisuseFinding(
            code: "E-PAR-004",
            severity: "ERROR",
            message: "{callee} must be called with a single zero-argument value closure",
            name: callee,
            note: "expected: single zero-argument value closure; found: {argc} argument(s)"
        ))
        return findings

    # E-PAR-004: wrong first-arg type
    val arg_text = _cam_first_arg_text(line, callee)

    if callee == "multicore_green_set_parallelism":
        if not _cam_first_arg_is_integer(arg_text):
            findings.push(ConcurrencyMisuseFinding(
                code: "E-PAR-004",
                severity: "ERROR",
                message: "{callee} must be called with a single integer worker count",
                name: callee,
                note: "expected: single integer worker count; found: {arg_text}"
            ))
    else:
        if not _cam_first_arg_is_closure(arg_text):
            findings.push(ConcurrencyMisuseFinding(
                code: "E-PAR-004",
                severity: "ERROR",
                message: "{callee} requires you to pass a closure as the first argument",
                name: callee,
                note: "expected: single zero-argument value closure; found: {arg_text}"
            ))

    findings

# ============================================================================
# E-PAR-005 — rt_pool direct access checker
# ============================================================================

val _cam_rt_pool_symbols = [
    "rt_pool_submit",
    "rt_pool_join",
    "rt_pool_is_done",
    "rt_pool_set_parallelism",
    "rt_pool_get_parallelism",
    "rt_pool_submitted_count",
    "rt_pool_completed_count",
    "rt_pool_pending_count",
    "rt_pool_busy_count",
    "rt_pool_blocked_count"
]

val _cam_exempt_path_suffixes = [
    "src/lib/nogc_async_mut/concurrent/multicore_green.spl",
    "src/lib/gc_async_mut/concurrent/multicore_green.spl",
    "src/lib/nogc_sync_mut/concurrent/multicore_green.spl",
    "src/lib/gc_sync_mut/concurrent/multicore_green.spl"
]

fn _cam_is_exempt_path(file_path: text) -> bool:
    """True if file_path is one of the sanctioned multicore_green facade paths."""
    for suffix in _cam_exempt_path_suffixes:
        if file_path.ends_with(suffix):
            return true
    false

fn _cam_is_call_shape_exempt_path(file_path: text, callee: text) -> bool:
    """True for stdlib facade implementation calls that must forward typed params."""
    if callee == "green_spawn":
        return file_path.ends_with("src/lib/nogc_async_mut/concurrent/cooperative_green.spl")
    false

fn _cam_rt_pool_findings(source: text, file_path: text) -> [ConcurrencyMisuseFinding]:
    """Scan for E-PAR-005: extern fn lines containing rt_pool_* symbol names."""
    var findings: [ConcurrencyMisuseFinding] = []
    if _cam_is_exempt_path(file_path):
        return findings
    val lines = source.split("\n")
    for line in lines:
        val t = line.trim()
        if not t.starts_with("extern fn "):
            continue
        for sym in _cam_rt_pool_symbols:
            if _cam_is_token(t, sym):
                findings.push(ConcurrencyMisuseFinding(
                    code: "E-PAR-005",
                    severity: "ERROR",
                    message: "{sym} is an internal runtime-pool symbol and is not a public API",
                    name: sym,
                    note: "use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism}"
                ))
    findings

# ============================================================================
# Main Entry Point
# ============================================================================

fn check_concurrency_api_misuse(source: text, file_path: text) -> [ConcurrencyMisuseFinding]:
    """Text-based heuristic for E-PAR-001..005 detection.
    Scans source lines for import, call, and extern-fn patterns.
    file_path is used for the E-PAR-005 path exemption; pass "" when unknown.
    Returns findings with .code, .severity, .message, .name, .note."""
    var findings: [ConcurrencyMisuseFinding] = []

    val spawn_callees = [
        "thread_spawn",
        "green_spawn",
        "cooperative_green_spawn",
        "multicore_green_spawn",
        "multicore_green_set_parallelism"
    ]

    val lines = source.split("\n")
    for line in lines:
        val t = line.trim()

        # --- Import checks (E-PAR-001, E-PAR-002, E-PAR-003) ---
        val parts = _cam_parse_use_line(line)
        if parts.len() >= 2:
            val owner = parts[0]
            var pi = 1
            while pi < parts.len():
                val sym = parts[pi]
                val fs = _cam_check_import_findings(owner, sym)
                for f in fs:
                    findings.push(f)
                pi = pi + 1

        # --- Call-shape checks (E-PAR-004) ---
        for callee in spawn_callees:
            if t.contains(callee + "("):
                if _cam_is_call_shape_exempt_path(file_path, callee):
                    continue
                val fs = _cam_call_shape_findings(t, callee)
                for f in fs:
                    findings.push(f)

    # --- rt_pool extern fn checks (E-PAR-005) ---
    val pool_fs = _cam_rt_pool_findings(source, file_path)
    for f in pool_fs:
        findings.push(f)

    findings

# ============================================================================
# Convenience query helpers
# ============================================================================

fn cam_findings_with_code(findings: [ConcurrencyMisuseFinding], code: text) -> [ConcurrencyMisuseFinding]:
    """Filter findings by error code."""
    var result: [ConcurrencyMisuseFinding] = []
    for f in findings:
        if f.code == code:
            result.push(f)
    result

fn cam_findings_contain_code(findings: [ConcurrencyMisuseFinding], code: text) -> bool:
    for f in findings:
        if f.code == code:
            return true
    false

fn cam_findings_contain_name(findings: [ConcurrencyMisuseFinding], name: text) -> bool:
    for f in findings:
        if f.name == name:
            return true
    false

fn cam_any_message_contains(findings: [ConcurrencyMisuseFinding], fragment: text) -> bool:
    for f in findings:
        if f.message.contains(fragment):
            return true
    false

fn cam_any_note_contains(findings: [ConcurrencyMisuseFinding], fragment: text) -> bool:
    for f in findings:
        if f.note.contains(fragment):
            return true
    false

# ============================================================================
# Exports
# ============================================================================

export ConcurrencyMisuseFinding
export check_concurrency_api_misuse
export cam_findings_with_code, cam_findings_contain_code, cam_findings_contain_name
export cam_any_message_contains, cam_any_note_contains
