# Public Documentation Lint — Step 2r: contains instead of find

struct PublicDocWarning:
    code: text
    severity: text
    message: text
    fn_name: text
    line: i64

fn check_public_doc(source: text) -> [PublicDocWarning]:
    var warnings: [PublicDocWarning] = []
    val lines = source.split("\n")
    val line_count = lines.len()

    var line_idx = 0
    while line_idx < line_count:
        val src_line = lines[line_idx]
        val trimmed = src_line.trim()
        if trimmed.starts_with("fn "):
            val after_fn = trimmed.slice(3)
            val p = after_fn.find("(")
            val the_name = after_fn.slice(0, p)
            if the_name.contains("_"):
                line_idx = line_idx + 1
                continue
            warnings.push(PublicDocWarning(
                code: "PDOC001",
                severity: "WARNING",
                message: "test",
                fn_name: the_name,
                line: 1
            ))
        line_idx = line_idx + 1

    warnings
