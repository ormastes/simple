# Argument Count Lint
#
# Detects functions with too many parameters, which hurts readability
# and is often a sign that a function should be refactored (e.g., group
# related params into a struct, use a builder/options pattern).
#
# ARG001: Function has too many parameters (> threshold)       WARNING
# ARG002: Function has too many parameters (> strict limit)    ERROR (deny)
#
# Thresholds:
#   ARG001 fires at > 7 parameters (warning, matches Rust clippy default)
#   ARG002 fires at > 12 parameters (error, almost certainly needs refactoring)
#
# Does NOT flag:
# - extern fn declarations (FFI wrappers often need many params)
# - Functions named with _ffi_ or _raw_ prefix (expected low-level code)
# - Static constructors (new/create/build) — often need all fields
#
# Works with the arena-based core AST (integer-tagged nodes).

use compiler.core.ast.{
    DECL_FN, DECL_EXTERN_FN,
    decl_tag, decl_name, decl_param_names
}

# ============================================================================
# Warning Struct
# ============================================================================

struct ArgCountWarning:
    code: text
    severity: text
    message: text
    hint: text
    fn_name: text
    param_count: i64

    fn fmt() -> text:
        "[{self.code}] {self.severity}: {self.message} in '{self.fn_name}' ({self.param_count} params) — {self.hint}"

# ============================================================================
# Configurable thresholds
# ============================================================================

val ARG_WARN_THRESHOLD = 7
val ARG_DENY_THRESHOLD = 12

# ============================================================================
# Main Entry Point
# ============================================================================

fn check_argument_count(decl_indices: [i64]) -> [ArgCountWarning]:
    """Run argument-count lint on module declarations.

    For each function, checks the number of parameters against thresholds.
    ARG001 (WARNING) fires when param count > 7.
    ARG002 (DENY) fires when param count > 12.
    """
    var warnings: [ArgCountWarning] = []

    for idx in decl_indices:
        val tag = decl_tag[idx]

        # Only check regular functions, skip extern fn (FFI)
        if tag != DECL_FN:
            continue

        val fn_name = decl_name[idx]
        val params = decl_param_names[idx]
        val count = params.len()

        # Skip functions with acceptable parameter counts
        if count <= ARG_WARN_THRESHOLD:
            continue

        # Skip FFI wrapper functions (naming convention)
        if fn_name.starts_with("_ffi_") or fn_name.starts_with("_raw_"):
            continue

        # Skip static constructors — they often need all struct fields
        if fn_name == "new" or fn_name == "create" or fn_name == "build":
            continue
        if fn_name.starts_with("new_") or fn_name.starts_with("create_") or fn_name.starts_with("build_"):
            continue

        # Skip 'self' parameter — don't count it towards threshold
        var effective_count = count
        if count > 0 and params[0] == "self":
            effective_count = count - 1

        if effective_count <= ARG_WARN_THRESHOLD:
            continue

        # ARG002: strict limit exceeded
        if effective_count > ARG_DENY_THRESHOLD:
            warnings.push(ArgCountWarning(
                code: "ARG002",
                severity: "error",
                message: "Function has {effective_count} parameters (limit: {ARG_DENY_THRESHOLD})",
                hint: "Group related parameters into a struct or use an options/config object",
                fn_name: fn_name,
                param_count: effective_count
            ))
        else:
            # ARG001: warning threshold exceeded
            warnings.push(ArgCountWarning(
                code: "ARG001",
                severity: "warning",
                message: "Function has {effective_count} parameters (recommended max: {ARG_WARN_THRESHOLD})",
                hint: "Consider grouping related parameters into a struct",
                fn_name: fn_name,
                param_count: effective_count
            ))

    warnings

# ============================================================================
# Exports
# ============================================================================

