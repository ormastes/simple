# src/compiler/70.backend/lowering/intrinsic_lowering_riscv.spl
#
# RV64 Cipher + Scalar Bit-Manip Intrinsic Lowering — Pure Simple
#
# Maps canonical MirInstKind.Intrinsic `name` strings to RVV Zvk or RV64
# scalar Zbb/Zbkb byte sequences, gated by Rv64Caps.
#
# Arity contract (positional args list):
#   crypto_aes_round          args=[vd, vs2]          -> 2  (vaesem.vv)
#   crypto_aes_round_last     args=[vd, vs2]          -> 2  (vaesef.vv)
#   crypto_aes_inv_round      args=[vd, vs2]          -> 2  (vaesdm.vv)
#   crypto_aes_inv_round_last args=[vd, vs2]          -> 2  (vaesdf.vv)
#   crypto_sha256_rnds2       args=[vd, vs2, vs1]     -> 3  (vsha2cl.vv + vsha2ch.vv)
#   clmul_lo                  args=[vd, vs2, vs1]     -> 3  (vghsh.vv)
#   clmul_hi                  args=[vd, vs2]          -> 2  (vgmul.vv)
#   bit_rotate_left           args=[rd, rs1, rs2]     -> 3  (rol)
#   bit_rotate_right          args=[rd, rs1, rs2]     -> 3  (ror)
#   bit_popcount              args=[rd, rs]           -> 2  (cpop)
#   bit_clz                   args=[rd, rs]           -> 2  (clz)
#   bit_ctz                   args=[rd, rs]           -> 2  (ctz)
#   bit_bswap                 args=[rd, rs]           -> 2  (rev8)
#   bit_bitreverse            args=[rd, rs]           -> 2  (brev8 + rev8)
#
# LoweringResult reasons:
#   ""          — success; bytes is non-empty
#   "unknown"   — unrecognised intrinsic name
#   "no-cap"    — capability not present in Rv64Caps
#   "bad-arity" — args.len() does not match contract

use compiler.backend.feature_caps.{TargetIdiom, Rv64Caps}
use compiler.backend.lowering.intrinsic_lowering_x86.{LoweringResult}
use compiler.backend.backend.native.encode_rvv_zvk.{
    emit_vaesef_vv, emit_vaesem_vv, emit_vaesdf_vv, emit_vaesdm_vv,
    emit_vsha2ch_vv, emit_vsha2cl_vv,
    emit_vghsh_vv, emit_vgmul_vv
}
# ============================================================================
# TargetIdiom mapping for RV64 Zvk intrinsics
# ============================================================================

"""Map a canonical cipher intrinsic name to its TargetIdiom tag.

Returns nil for unrecognised names.  Use this to gate capability checks
before dispatching to an emit_* helper.  Shared with the x86 path; the
returned idiom is interpreted by Rv64Caps.supports.
"""
fn intrinsic_to_target_idiom_riscv(name: text) -> TargetIdiom?:
    match name:
        case "crypto_aes_round":            Some(TargetIdiom.AesEnc)
        case "crypto_aes_round_last":       Some(TargetIdiom.AesEncLast)
        case "crypto_aes_inv_round":        Some(TargetIdiom.AesDec)
        case "crypto_aes_inv_round_last":   Some(TargetIdiom.AesDecLast)
        case "crypto_sha256_rnds2":         Some(TargetIdiom.Sha256Rounds2)
        case "clmul_lo":                    Some(TargetIdiom.ClmulLo)
        case "clmul_hi":                    Some(TargetIdiom.ClmulHi)
        case "bit_rotate_left":             Some(TargetIdiom.RotateLeft)
        case "bit_rotate_right":            Some(TargetIdiom.RotateRight)
        case "bit_popcount":                Some(TargetIdiom.Popcount)
        case "bit_clz":                     Some(TargetIdiom.CountLeadingZeros)
        case "bit_ctz":                     Some(TargetIdiom.CountTrailingZeros)
        case "bit_bswap":                   Some(TargetIdiom.ByteSwap)
        case "bit_bitreverse":              Some(TargetIdiom.BitReverse)
        case "crypto_clmul":                Some(TargetIdiom.ClmulLo)
        case "matrix_dot":                  Some(TargetIdiom.MatrixDot)
        case "matrix_outer_product":        Some(TargetIdiom.MatrixOuterProduct)
        case "matrix_fma_kernel":           Some(TargetIdiom.MatrixFmaKernel)
        case "bit_parity":                  Some(TargetIdiom.Parity)
        case "crypto_sha512_rnds2":         Some(TargetIdiom.Sha512Rounds2)
        case "crypto_sha512_msg1":          Some(TargetIdiom.Sha512Msg1)
        case "crypto_sha512_msg2":          Some(TargetIdiom.Sha512Msg2)
        case _:                             nil

fn intrinsic_requires_placeholder_lowering(idiom: TargetIdiom) -> bool:
    match idiom:
        case RotateLeft:            true
        case RotateRight:           true
        case MatrixDot:             true
        case MatrixOuterProduct:    true
        case MatrixFmaKernel:       true
        case _:                     false

fn append_bytes(dst: [i64], src: [i64]) -> [i64]:
    var out = dst
    var i = 0
    while i < src.len():
        out.push(src[i])
        i = i + 1
    out

fn riscv_word_to_le4(word: i64) -> [i64]:
    var w = word
    if w < 0:
        w = w + 4294967296
    val b0 = w % 256
    val b1 = (w / 256) % 256
    val b2 = (w / 65536) % 256
    val b3 = (w / 16777216) % 256
    [b0, b1, b2, b3]

fn emit_scalar_bitmanip_r_type(funct7: i64, rs2: i64, rs1: i64, funct3: i64, rd: i64) -> [i64]:
    # Keep these encoders local to avoid interpreter-mode issues when pulling
    # the shared encoding helpers into the standalone intrinsic-lowering specs.
    val word = (funct7 * 33554432) + (rs2 * 1048576) + (rs1 * 32768) + (funct3 * 4096) + (rd * 128) + 51
    riscv_word_to_le4(word)

fn emit_scalar_bitmanip_i_type(funct12: i64, rs1: i64, funct3: i64, rd: i64) -> [i64]:
    val word = (funct12 * 1048576) + (rs1 * 32768) + (funct3 * 4096) + (rd * 128) + 19
    riscv_word_to_le4(word)

# ============================================================================
# lower_cipher_intrinsic_riscv — main lowering entry point
# ============================================================================

"""Lower a canonical cipher intrinsic to RV64 byte sequences.

Steps:
  1. Resolve name -> TargetIdiom; unknown names return reason="unknown".
  2. Check caps.supports(idiom); unsupported targets return reason="no-cap".
  3. Return reason="unimplemented" for recognised portable intrinsics whose
     backend encoder has not landed yet.
  4. Validate args arity; mismatches return reason="bad-arity".
  5. Dispatch to the matching emit_* helper and return the bytes.

For crypto_sha256_rnds2 the result is vsha2cl.vv + vsha2ch.vv concatenated
(8 bytes total) because the SHA-2 round pair requires both low and high halves.
For bit_bitreverse the result is brev8 + rev8 (8 bytes total) because RV64
needs both scalar instructions to reverse all bits in the register.
"""
fn lower_cipher_intrinsic_riscv(name: text, args: [i64], caps: Rv64Caps) -> LoweringResult:
    var empty: [i64] = []

    # Step 1: name -> idiom
    var maybe_idiom = intrinsic_to_target_idiom_riscv(name)
    match maybe_idiom:
        case Some(idiom):
            # Step 2: capability gate
            if not caps.supports(idiom):
                return LoweringResult(empty, false, "no-cap")

            # Direct scalar RV64 bitmanip lowers should report arity before
            # falling through the generic placeholder path.
            match name:
                case "bit_rotate_left":
                    if args.len() != 3:
                        return LoweringResult(empty, false, "unimplemented")
                    return LoweringResult(empty, false, "unimplemented")

                case "bit_rotate_right":
                    if args.len() != 3:
                        return LoweringResult(empty, false, "unimplemented")
                    return LoweringResult(empty, false, "unimplemented")

                case "bit_bswap":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_scalar_bitmanip_i_type(0x6b8, args[1], 0x5, args[0])
                    return LoweringResult(bytes, true, "")

                case "bit_clz":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_scalar_bitmanip_i_type(0x600, args[1], 0x1, args[0])
                    return LoweringResult(bytes, true, "")

                case "bit_ctz":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_scalar_bitmanip_i_type(0x601, args[1], 0x1, args[0])
                    return LoweringResult(bytes, true, "")

                case "bit_popcount":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_scalar_bitmanip_i_type(0x602, args[1], 0x1, args[0])
                    return LoweringResult(bytes, true, "")

                case "bit_bitreverse":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_scalar_bitmanip_i_type(0x687, args[1], 0x5, args[0])
                    bytes = append_bytes(bytes, emit_scalar_bitmanip_i_type(0x6b8, args[1], 0x5, args[0]))
                    return LoweringResult(bytes, true, "")

                case _:
                    pass

            if intrinsic_requires_placeholder_lowering(idiom):
                return LoweringResult(empty, false, "unimplemented")

            # Step 4 + 5: arity check then emit
            match name:
                case "crypto_aes_round":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_vaesem_vv(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_aes_round_last":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_vaesef_vv(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_aes_inv_round":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_vaesdm_vv(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_aes_inv_round_last":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_vaesdf_vv(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_sha256_rnds2":
                    # Emit vsha2cl.vv + vsha2ch.vv (two 4-byte instructions).
                    # args=[vd, vs2, vs1]; both instructions use the same regs.
                    if args.len() != 3:
                        return LoweringResult(empty, false, "bad-arity")
                    var vd = args[0]
                    var vs2 = args[1]
                    var vs1 = args[2]
                    var lo = emit_vsha2cl_vv(vd, vs2, vs1)
                    var hi = emit_vsha2ch_vv(vd, vs2, vs1)
                    var bytes = append_bytes([], lo)
                    bytes = append_bytes(bytes, hi)
                    LoweringResult(bytes, true, "")

                case "clmul_lo":
                    if args.len() != 3:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_vghsh_vv(args[0], args[1], args[2])
                    LoweringResult(bytes, true, "")

                case "clmul_hi":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_vgmul_vv(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "bit_parity":
                    # Needs Zbb cpop + andi; Phase 3B.
                    LoweringResult(empty, false, "unimplemented")

                case "crypto_sha512_rnds2":
                    # Needs Zvknhb vsha2ms; Phase 3B.
                    LoweringResult(empty, false, "unimplemented")

                case "crypto_sha512_msg1":
                    # Needs Zvknhb encoder; Phase 3B.
                    LoweringResult(empty, false, "unimplemented")

                case "crypto_sha512_msg2":
                    # Needs Zvknhb encoder; Phase 3B.
                    LoweringResult(empty, false, "unimplemented")

                case _:
                    LoweringResult(empty, false, "unknown")

        case _:
            LoweringResult(empty, false, "unknown")

# ============================================================================
# Exports
# ============================================================================

export LoweringResult
export intrinsic_to_target_idiom_riscv
export lower_cipher_intrinsic_riscv
