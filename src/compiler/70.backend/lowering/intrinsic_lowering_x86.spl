# x86_64 Cipher Intrinsic Lowering — Pure Simple
#
# Maps canonical MirInstKind.Intrinsic `name` strings to x86_64 byte sequences
# via the emit_* helpers in encode_x86_64_crypto.spl, gated by X86Caps.supports.
#
# When caps.has_avx is true, AES and PCLMULQDQ intrinsics are lowered to VEX
# 3-operand forms (non-destructive: dst ← op(src1, src2)).  When has_avx is
# false (legacy SSE), the 2-operand destructive forms are used instead.
#
# Arity contract (positional args list):
#   VEX path (has_avx=true):
#     crypto_aes_round          args=[dst, src1, src2]             -> 3
#     crypto_aes_round_last     args=[dst, src1, src2]             -> 3
#     crypto_aes_inv_round      args=[dst, src1, src2]             -> 3
#     crypto_aes_inv_round_last args=[dst, src1, src2]             -> 3
#     clmul_lo                  args=[dst, src1, src2]  imm8=0x00  -> 3
#     clmul_hi                  args=[dst, src1, src2]  imm8=0x11  -> 3
#   Legacy SSE path (has_avx=false):
#     crypto_aes_round          args=[dst, src]             -> 2
#     crypto_aes_round_last     args=[dst, src]             -> 2
#     crypto_aes_inv_round      args=[dst, src]             -> 2
#     crypto_aes_inv_round_last args=[dst, src]             -> 2
#     clmul_lo                  args=[dst, src]  imm8=0x00  -> 2
#     clmul_hi                  args=[dst, src]  imm8=0x11  -> 2
#   Common (arity unchanged):
#     bit_rotate_left           args=[dst, src, count_imm8]  -> 3
#     bit_rotate_right          args=[dst, src, count_imm8]  -> 3
#     crypto_aes_imc            args=[dst, src]             -> 2
#     crypto_aes_keygen_assist  args=[dst, src, rcon_u8]   -> 3
#     crypto_sha256_rounds2     args=[dst, src, _implicit]  -> 3
#       (third arg is implicit XMM0 in hardware; encoder takes dst+src only)
#     crypto_sha256_msg1        args=[dst, src]             -> 2
#     crypto_sha256_msg2        args=[dst, src]             -> 2
#     crc32_u8                  args=[dst, src]             -> 2
#     crc32_u32                 args=[dst, src]             -> 2
#     crc32_u64                 args=[dst, src]             -> 2
#     bit_popcount              args=[dst, src]             -> 2
#     bit_clz                   args=[dst, src]             -> 2  (LZCNT, requires BMI1)
#     bit_ctz                   args=[dst, src]             -> 2  (TZCNT, requires BMI1)
#     bit_parity                args=[dst, src]             -> 2  (POPCNT + AND 1)
#     bit_bswap                 args=[dst]                  -> 1

use compiler.mir.intrinsics.{
    CRYPTO_AES_ROUND, CRYPTO_AES_ROUND_LAST,
    CRYPTO_AES_INV_ROUND, CRYPTO_AES_INV_ROUND_LAST,
    CRYPTO_AES_IMC, CRYPTO_AES_KEYGEN_ASSIST,
    CRYPTO_SHA256_RNDS2, CRYPTO_SHA256_MSG1, CRYPTO_SHA256_MSG2,
    CRC32_U8, CRC32_U32, CRC32_U64,
    CLMUL_LO, CLMUL_HI
}
use compiler.backend.feature_caps.{TargetIdiom, X86Caps}
use compiler.backend.backend.native.encode_x86_64_crypto.{
    emit_aesenc, emit_aesenclast, emit_aesdec, emit_aesdeclast,
    emit_aesimc, emit_aeskeygenassist,
    emit_sha256rnds2, emit_sha256msg1, emit_sha256msg2,
    emit_crc32_r32_r8, emit_crc32_r32_r32, emit_crc32_r64_r64,
    emit_pclmulqdq,
    emit_vaesenc, emit_vaesenclast, emit_vaesdec, emit_vaesdeclast,
    emit_vpclmulqdq
}

# ============================================================================
# LoweringResult — outcome of lowering one MirInstKind.Intrinsic
# ============================================================================

"""Outcome of lowering one MirInstKind.Intrinsic to x86_64 bytes.

bytes   — emitted byte sequence; empty when not lowered.
lowered — true iff a real byte sequence was produced.
reason  — empty string on success; "unknown", "no-cap", "bad-arity", or
          "unimplemented" on miss.
"""
struct LoweringResult:
    bytes: [i64]
    lowered: bool
    reason: text

fn emit_bswap_r64(dst: i64) -> [i64]:
    var bytes: [i64] = []
    val rex = if dst >= 8: 0x49 else: 0x48
    bytes.push(rex)
    bytes.push(0x0f)
    bytes.push(0xc8 + (dst % 8))
    bytes

fn emit_popcnt_r64(dst: i64, src: i64) -> [i64]:
    var bytes: [i64] = []
    var rex = 0x48
    if dst >= 8:
        rex = rex + 4
    if src >= 8:
        rex = rex + 1
    bytes.push(0xf3)
    bytes.push(rex)
    bytes.push(0x0f)
    bytes.push(0xb8)
    bytes.push(0xc0 + ((dst % 8) * 8) + (src % 8))
    bytes

fn emit_lzcnt_r64(dst: i64, src: i64) -> [i64]:
    # LZCNT r64, r/m64: F3 REX.W 0F BD /r
    var bytes: [i64] = []
    var rex = 0x48
    if dst >= 8:
        rex = rex + 4
    if src >= 8:
        rex = rex + 1
    bytes.push(0xf3)
    bytes.push(rex)
    bytes.push(0x0f)
    bytes.push(0xbd)
    bytes.push(0xc0 + ((dst % 8) * 8) + (src % 8))
    bytes

fn emit_tzcnt_r64(dst: i64, src: i64) -> [i64]:
    # TZCNT r64, r/m64: F3 REX.W 0F BC /r
    var bytes: [i64] = []
    var rex = 0x48
    if dst >= 8:
        rex = rex + 4
    if src >= 8:
        rex = rex + 1
    bytes.push(0xf3)
    bytes.push(rex)
    bytes.push(0x0f)
    bytes.push(0xbc)
    bytes.push(0xc0 + ((dst % 8) * 8) + (src % 8))
    bytes

fn emit_and_imm8_r64(dst: i64, imm8: i64) -> [i64]:
    # AND r/m64, imm8 (sign-extended): REX.W 83 /4 ib
    # ModRM: mod=11 (0xc0), reg=4 (/4 subop), rm=dst%8
    var bytes: [i64] = []
    val rex = if dst >= 8: 0x49 else: 0x48
    bytes.push(rex)
    bytes.push(0x83)
    bytes.push(0xe0 + (dst % 8))
    bytes.push(imm8 % 256)
    bytes

fn emit_mov_r64_r64(dst: i64, src: i64) -> [i64]:
    var bytes: [i64] = []
    var rex = 0x48
    if src >= 8:
        rex = rex + 4
    if dst >= 8:
        rex = rex + 1
    bytes.push(rex)
    bytes.push(0x89)
    bytes.push(0xc0 + ((src % 8) * 8) + (dst % 8))
    bytes

fn emit_rotate_imm8_r64(dst: i64, count: i64, is_left: bool) -> [i64]:
    var bytes: [i64] = []
    val rex = if dst >= 8: 0x49 else: 0x48
    var imm8 = count % 256
    if imm8 < 0:
        imm8 = imm8 + 256
    bytes.push(rex)
    bytes.push(0xc1)
    val subop = if is_left: 0 else: 1
    bytes.push(0xc0 + (subop * 8) + (dst % 8))
    bytes.push(imm8)
    bytes

fn append_bytes(dst: [i64], src: [i64]) -> [i64]:
    var out = dst
    var i = 0
    while i < src.len():
        out.push(src[i])
        i = i + 1
    out

fn intrinsic_requires_placeholder_lowering(idiom: TargetIdiom) -> bool:
    match idiom:
        case RotateLeft:            false
        case RotateRight:           false
        case CountLeadingZeros:     false
        case CountTrailingZeros:    false
        case ByteSwap:              false
        case BitReverse:            true
        case MatrixDot:             true
        case MatrixOuterProduct:    true
        case MatrixFmaKernel:       true
        case _:                     false

# ============================================================================
# intrinsic_to_target_idiom — name -> TargetIdiom?
# ============================================================================

"""Map a canonical intrinsic name to its TargetIdiom tag.

Returns nil for unrecognised names.  Use this to gate capability checks
before dispatching to an emit_* helper.
"""
fn intrinsic_to_target_idiom(name: text) -> TargetIdiom?:
    match name:
        case "crypto_aes_round":            Some(TargetIdiom.AesEnc)
        case "crypto_aes_round_last":       Some(TargetIdiom.AesEncLast)
        case "crypto_aes_inv_round":        Some(TargetIdiom.AesDec)
        case "crypto_aes_inv_round_last":   Some(TargetIdiom.AesDecLast)
        case "crypto_aes_imc":              Some(TargetIdiom.AesImc)
        case "crypto_aes_keygen_assist":    Some(TargetIdiom.AesKeygenAssist)
        case "crypto_sha256_rounds2":       Some(TargetIdiom.Sha256Rounds2)
        case "crypto_sha256_msg1":          Some(TargetIdiom.Sha256Msg1)
        case "crypto_sha256_msg2":          Some(TargetIdiom.Sha256Msg2)
        case "crc32_u8":                    Some(TargetIdiom.Crc32U8)
        case "crc32_u32":                   Some(TargetIdiom.Crc32U32)
        case "crc32_u64":                   Some(TargetIdiom.Crc32U64)
        case "clmul_lo":                    Some(TargetIdiom.ClmulLo)
        case "clmul_hi":                    Some(TargetIdiom.ClmulHi)
        case "bit_rotate_left":             Some(TargetIdiom.RotateLeft)
        case "bit_rotate_right":            Some(TargetIdiom.RotateRight)
        case "bit_popcount":                Some(TargetIdiom.Popcount)
        case "bit_clz":                     Some(TargetIdiom.CountLeadingZeros)
        case "bit_ctz":                     Some(TargetIdiom.CountTrailingZeros)
        case "bit_bswap":                   Some(TargetIdiom.ByteSwap)
        case "bit_bitreverse":              Some(TargetIdiom.BitReverse)
        case "crypto_clmul":                Some(TargetIdiom.ClmulLo)
        case "matrix_dot":                  Some(TargetIdiom.MatrixDot)
        case "matrix_outer_product":        Some(TargetIdiom.MatrixOuterProduct)
        case "matrix_fma_kernel":           Some(TargetIdiom.MatrixFmaKernel)
        case "bit_parity":                  Some(TargetIdiom.Parity)
        case "crypto_sha512_rnds2":         Some(TargetIdiom.Sha512Rounds2)
        case "crypto_sha512_msg1":          Some(TargetIdiom.Sha512Msg1)
        case "crypto_sha512_msg2":          Some(TargetIdiom.Sha512Msg2)
        case _:                             nil

# ============================================================================
# lower_cipher_intrinsic_x86 — main lowering entry point
# ============================================================================

"""Lower a canonical cipher intrinsic to an x86_64 byte sequence.

Steps:
  1. Resolve name -> TargetIdiom; unknown names return reason="unknown".
  2. Check caps.supports(idiom); unsupported targets return reason="no-cap".
  3. Return reason="unimplemented" for recognised portable intrinsics whose
     backend encoder has not landed yet.
  4. Validate args arity; mismatches return reason="bad-arity".
  5. Dispatch to the matching emit_* helper and return the bytes.

See top-of-file comment for the full arity table per intrinsic name.
"""
fn lower_cipher_intrinsic_x86(name: text, args: [i64], caps: X86Caps) -> LoweringResult:
    var empty: [i64] = []

    # Step 1: name -> idiom
    var maybe_idiom = intrinsic_to_target_idiom(name)
    match maybe_idiom:
        case Some(idiom):
            # Step 2: capability gate
            if not caps.supports(idiom):
                return LoweringResult(empty, false, "no-cap")
            match name:
                case "bit_rotate_left":
                    if args.len() != 3:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_mov_r64_r64(args[0], args[1])
                    bytes = append_bytes(bytes, emit_rotate_imm8_r64(args[0], args[2], true))
                    return LoweringResult(bytes, true, "")

                case "bit_rotate_right":
                    if args.len() != 3:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_mov_r64_r64(args[0], args[1])
                    bytes = append_bytes(bytes, emit_rotate_imm8_r64(args[0], args[2], false))
                    return LoweringResult(bytes, true, "")

                case _:
                    pass
            if intrinsic_requires_placeholder_lowering(idiom):
                return LoweringResult(empty, false, "unimplemented")

            # Step 4 + 5: arity check then emit.
            # AES round and CLMUL ops use VEX 3-operand forms when has_avx,
            # otherwise fall back to legacy SSE 2-operand (destructive) forms.
            match name:
                case "crypto_aes_round":
                    if caps.has_avx:
                        if args.len() != 3:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_vaesenc(args[0], args[1], args[2])
                        LoweringResult(bytes, true, "")
                    else:
                        if args.len() != 2:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_aesenc(args[0], args[1])
                        LoweringResult(bytes, true, "")

                case "crypto_aes_round_last":
                    if caps.has_avx:
                        if args.len() != 3:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_vaesenclast(args[0], args[1], args[2])
                        LoweringResult(bytes, true, "")
                    else:
                        if args.len() != 2:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_aesenclast(args[0], args[1])
                        LoweringResult(bytes, true, "")

                case "crypto_aes_inv_round":
                    if caps.has_avx:
                        if args.len() != 3:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_vaesdec(args[0], args[1], args[2])
                        LoweringResult(bytes, true, "")
                    else:
                        if args.len() != 2:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_aesdec(args[0], args[1])
                        LoweringResult(bytes, true, "")

                case "crypto_aes_inv_round_last":
                    if caps.has_avx:
                        if args.len() != 3:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_vaesdeclast(args[0], args[1], args[2])
                        LoweringResult(bytes, true, "")
                    else:
                        if args.len() != 2:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_aesdeclast(args[0], args[1])
                        LoweringResult(bytes, true, "")

                case "crypto_aes_imc":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_aesimc(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_aes_keygen_assist":
                    if args.len() != 3:
                        return LoweringResult(empty, false, "bad-arity")
                    var rcon = args[2]
                    var bytes = emit_aeskeygenassist(args[0], args[1], rcon)
                    LoweringResult(bytes, true, "")

                case "crypto_sha256_rounds2":
                    # args[2] is the implicit XMM0 operand in hardware; encoder
                    # takes dst+src only (XMM0 is always the third implicit reg).
                    if args.len() != 3:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_sha256rnds2(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_sha256_msg1":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_sha256msg1(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crypto_sha256_msg2":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_sha256msg2(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crc32_u8":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_crc32_r32_r8(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crc32_u32":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_crc32_r32_r32(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "crc32_u64":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_crc32_r64_r64(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "clmul_lo":
                    if caps.has_avx:
                        if args.len() != 3:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_vpclmulqdq(args[0], args[1], args[2], 0x00)
                        LoweringResult(bytes, true, "")
                    else:
                        if args.len() != 2:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_pclmulqdq(args[0], args[1], 0x00)
                        LoweringResult(bytes, true, "")

                case "clmul_hi":
                    if caps.has_avx:
                        if args.len() != 3:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_vpclmulqdq(args[0], args[1], args[2], 0x11)
                        LoweringResult(bytes, true, "")
                    else:
                        if args.len() != 2:
                            return LoweringResult(empty, false, "bad-arity")
                        var bytes = emit_pclmulqdq(args[0], args[1], 0x11)
                        LoweringResult(bytes, true, "")

                case "bit_bswap":
                    if args.len() != 1:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_bswap_r64(args[0])
                    LoweringResult(bytes, true, "")

                case "bit_popcount":
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_popcnt_r64(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "bit_clz":
                    # LZCNT r64, r/m64 — count leading zeros.  args=[dst, src].
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_lzcnt_r64(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "bit_ctz":
                    # TZCNT r64, r/m64 — count trailing zeros.  args=[dst, src].
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_tzcnt_r64(args[0], args[1])
                    LoweringResult(bytes, true, "")

                case "bit_parity":
                    # Parity = POPCNT(src) & 1.  args=[dst, src].
                    if args.len() != 2:
                        return LoweringResult(empty, false, "bad-arity")
                    var bytes = emit_popcnt_r64(args[0], args[1])
                    bytes = append_bytes(bytes, emit_and_imm8_r64(args[0], 1))
                    LoweringResult(bytes, true, "")

                case "crypto_sha512_rnds2":
                    # x86 has no SHA-512 hardware instruction — permanent software fallback.
                    LoweringResult(empty, false, "unimplemented")

                case "crypto_sha512_msg1":
                    # x86 has no SHA-512 hardware instruction — permanent software fallback.
                    LoweringResult(empty, false, "unimplemented")

                case "crypto_sha512_msg2":
                    # x86 has no SHA-512 hardware instruction — permanent software fallback.
                    LoweringResult(empty, false, "unimplemented")

                case _:
                    LoweringResult(empty, false, "unknown")

        case _:
            LoweringResult(empty, false, "unknown")
