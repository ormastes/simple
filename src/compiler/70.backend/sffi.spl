# SFFI Declarations - Shared Runtime SFFI Bindings
#
# This module consolidates SFFI declarations used across the compiler.
# Now imports from centralized sffi modules instead of duplicating declarations.

use std.sffi.io*
use std.sffi.system*

# ============================================================================
# Type Definitions
# ============================================================================

# Shell execution result
struct ShellResult:
    exit_code: i64
    # # DESUGARED: stdout: text
    has_stdout: bool
    stdout: text
    # # DESUGARED: stderr: text
    has_stderr: bool
    stderr: text

