# Verification Codegen Types Re-export
#
# Re-exports verification codegen trait types without going through "common".

use compiler.mir.mir_data.{MirModule, MirBody}
use compiler.backend.backend.backend_types.{CompileError}

trait VerificationCodegen:
    """Interface for formal verification export backends."""
    fn export_function(name: text, body: MirBody) -> Result<text, CompileError>
    fn generate_proof_obligations(module: MirModule) -> [text]
    fn verification_level() -> text

