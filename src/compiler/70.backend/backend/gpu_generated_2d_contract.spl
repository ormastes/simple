# Shared generated Engine2D GPU backend compile contract.
#
# CUDA, HIP/ROCm, OpenCL, and Metal generated 2D compiler adapters use the
# portable compute emitter. Vulkan stays SPIR-V-only and validates the same
# public readiness contract without admitting runtime GLSL.

use compiler.backend.gpu_portable_compute.{
    PortableComputeCompilePlan,
    PortableComputeCompiledArtifactEvidence,
    PortableComputeTarget,
    emit_portable_2d_optimization_module,
    emit_vulkan_font_atlas_composite_source,
    portable_compute_2d_optimization_compile_plan,
    portable_compute_compiled_artifact_evidence,
    portable_compute_exported_symbol_present,
    portable_compute_target_name
}

class VulkanFontAtlasCompilePlan:
    source: text
    entry_name: text
    required_symbols: text
    source_format: text
    binary_format: text
    tool_hint: text
    source_path_suffix: text
    artifact_path_suffix: text

class VulkanFontAtlasArtifactEvidence:
    plan: VulkanFontAtlasCompilePlan
    artifact_magic: text
    exported_symbols: text
    byte_count: i64
    valid: bool
    reason: text

fn vulkan_font_atlas_compile_plan(output_stem: text) -> VulkanFontAtlasCompilePlan:
    VulkanFontAtlasCompilePlan(
        source: emit_vulkan_font_atlas_composite_source(),
        entry_name: "main",
        required_symbols: "main",
        source_format: "vulkan-glsl-450",
        binary_format: "spirv",
        tool_hint: "glslangValidator-or-glslc",
        source_path_suffix: "{output_stem}.comp",
        artifact_path_suffix: "{output_stem}.spv"
    )

fn vulkan_font_atlas_artifact_evidence(plan: VulkanFontAtlasCompilePlan, artifact_magic: text,
                                       exported_symbols: text, byte_count: i64) -> VulkanFontAtlasArtifactEvidence:
    val reason = if byte_count <= 0:
        "missing-artifact-bytes"
    elif not artifact_magic.contains("SPIR-V"):
        "artifact-magic-mismatch"
    elif not portable_compute_exported_symbol_present(exported_symbols, plan.required_symbols):
        "missing-entry-symbol:main"
    else:
        "pass"
    VulkanFontAtlasArtifactEvidence(
        plan: plan,
        artifact_magic: artifact_magic,
        exported_symbols: exported_symbols,
        byte_count: byte_count,
        valid: reason == "pass",
        reason: reason
    )

class GpuGenerated2DBackendCompileContract:
    backend_name: text
    source: text
    plan: PortableComputeCompilePlan
    evidence: PortableComputeCompiledArtifactEvidence
    ready: bool
    status: text
    diagnostic: text

    static fn create(backend_name: text, target: PortableComputeTarget, output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> GpuGenerated2DBackendCompileContract:
        val clean_backend = if backend_name == "": portable_compute_target_name(target) else: backend_name
        val module = emit_portable_2d_optimization_module(target)
        val plan = portable_compute_2d_optimization_compile_plan(target, output_stem)
        val evidence = portable_compute_compiled_artifact_evidence(plan, artifact_magic, exported_symbols, byte_count)
        val status = if evidence.artifact_valid:
            "compiled_artifact_verified"
        else:
            evidence.reason
        GpuGenerated2DBackendCompileContract(
            backend_name: clean_backend,
            source: module.source,
            plan: plan,
            evidence: evidence,
            ready: evidence.artifact_valid,
            status: status,
            diagnostic: if evidence.artifact_valid: "" else: "{gpu_generated_2d_backend_diagnostic_label(clean_backend)} artifact rejected: {evidence.reason}"
        )

    fn summary() -> text:
        "GpuGenerated2DBackendCompileContract[backend={self.backend_name} source={self.plan.source_format} binary={self.plan.binary_format} entry={self.plan.entry_name} ready={self.ready.to_text()} status={self.status}]"

class VulkanSpirvGenerated2DCompileContract:
    backend_name: text
    source_format: text
    binary_format: text
    required_symbols: text
    artifact_path_suffix: text
    artifact_magic: text
    exported_symbols: text
    byte_count: i64
    ready: bool
    status: text
    diagnostic: text

    static fn create(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> VulkanSpirvGenerated2DCompileContract:
        val required = "simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32 simple_2d_bitmap_glyph_raster_u32"
        val status = vulkan_spirv_generated_2d_status(required, artifact_magic, exported_symbols, byte_count)
        VulkanSpirvGenerated2DCompileContract(
            backend_name: "vulkan",
            source_format: "spirv",
            binary_format: "spirv",
            required_symbols: required,
            artifact_path_suffix: "{output_stem}.spirv",
            artifact_magic: artifact_magic,
            exported_symbols: exported_symbols,
            byte_count: byte_count,
            ready: status == "compiled_artifact_verified",
            status: status,
            diagnostic: if status == "compiled_artifact_verified": "" else: "Vulkan SPIR-V artifact rejected: {status}"
        )

    fn summary() -> text:
        "VulkanSpirvGenerated2DCompileContract[backend={self.backend_name} source={self.source_format} binary={self.binary_format} ready={self.ready.to_text()} status={self.status}]"

fn gpu_generated_2d_backend_compile_contract(backend_name: text, target: PortableComputeTarget, output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> GpuGenerated2DBackendCompileContract:
    GpuGenerated2DBackendCompileContract.create(backend_name, target, output_stem, artifact_magic, exported_symbols, byte_count)

fn gpu_generated_2d_backend_diagnostic_label(backend_name: text) -> text:
    val clean = backend_name.trim().lower()
    if clean == "cuda":
        return "CUDA"
    if clean == "hip" or clean == "rocm":
        return "HIP"
    if clean == "opencl":
        return "OpenCL"
    if clean == "metal" or clean == "msl":
        return "Metal"
    if clean == "vulkan" or clean == "vulkan-spirv":
        return "Vulkan"
    clean.upper()

fn vulkan_spirv_generated_2d_status(required_symbols: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> text:
    if byte_count <= 0:
        return "missing-artifact-bytes"
    if artifact_magic == "":
        return "missing-artifact-magic"
    if not artifact_magic.contains("SPIR-V"):
        return "artifact-magic-mismatch"
    if exported_symbols == "":
        return "missing-exported-symbols"
    val required = required_symbols.split(" ")
    for symbol in required:
        if symbol != "" and not exported_symbols.contains(symbol):
            return "missing-entry-symbol:{symbol}"
    "compiled_artifact_verified"

fn cuda_generated_2d_compile_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> GpuGenerated2DBackendCompileContract:
    gpu_generated_2d_backend_compile_contract("cuda", PortableComputeTarget.Cuda, output_stem, artifact_magic, exported_symbols, byte_count)

fn hip_generated_2d_compile_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> GpuGenerated2DBackendCompileContract:
    gpu_generated_2d_backend_compile_contract("hip", PortableComputeTarget.Hip, output_stem, artifact_magic, exported_symbols, byte_count)

fn opencl_generated_2d_compile_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> GpuGenerated2DBackendCompileContract:
    gpu_generated_2d_backend_compile_contract("opencl", PortableComputeTarget.OpenCl, output_stem, artifact_magic, exported_symbols, byte_count)

fn metal_generated_2d_compile_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> GpuGenerated2DBackendCompileContract:
    gpu_generated_2d_backend_compile_contract("metal", PortableComputeTarget.Metal, output_stem, artifact_magic, exported_symbols, byte_count)

fn vulkan_spirv_generated_2d_compile_contract(output_stem: text, artifact_magic: text, exported_symbols: text, byte_count: i64) -> VulkanSpirvGenerated2DCompileContract:
    VulkanSpirvGenerated2DCompileContract.create(output_stem, artifact_magic, exported_symbols, byte_count)
