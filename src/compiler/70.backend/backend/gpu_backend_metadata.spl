# GPU Backend Metadata Helpers
#
# Shared acceptance logic for compiler GPU backends consuming MIR metadata from
# @gpu/@gpu_kernel attributes.

use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget}
use compiler.common.gpu_target_metadata.{normalize_gpu_target_metadata_name}
use compiler.mir.mir_data.{MirModule}
use compiler.mir.mir_instructions.{MirFunction}

class GpuBackendKernelPlan:
    backend_name: text
    accepted_kernel_count: i64
    rejected_kernel_count: i64
    rejected_kernel_names: text
    ready: bool
    diagnostic: text

    static fn create(backend_name: text, accepted_kernel_count: i64, rejected_kernel_count: i64, rejected_kernel_names: text) -> GpuBackendKernelPlan:
        GpuBackendKernelPlan(
            backend_name: backend_name,
            accepted_kernel_count: accepted_kernel_count,
            rejected_kernel_count: rejected_kernel_count,
            rejected_kernel_names: rejected_kernel_names,
            ready: rejected_kernel_count == 0,
            diagnostic: if rejected_kernel_count == 0:
                ""
            else:
                "{backend_name} backend rejected incompatible GPU kernel(s): {rejected_kernel_names}"
        )

    fn summary() -> text:
        "GpuBackendKernelPlan[backend={self.backend_name} accepted={self.accepted_kernel_count} rejected={self.rejected_kernel_count} ready={self.ready.to_text()}]"

fn normalize_gpu_backend_metadata_name(name: text) -> text:
    normalize_gpu_target_metadata_name(name)

fn gpu_backend_metadata_name(kind: BackendKind) -> text:
    if kind == BackendKind.Cuda:
        return "cuda"
    if kind == BackendKind.OpenCl:
        return "opencl"
    if kind == BackendKind.Hip:
        return "hip"
    if kind == BackendKind.Vulkan:
        return "vulkan"
    if kind == BackendKind.Vhdl:
        return "vhdl"
    kind.to_text()

fn gpu_backend_order_contains(backend_order: text, backend_name: text) -> bool:
    val trimmed = backend_order.trim()
    if trimmed == "":
        return true
    val parts = trimmed.split(",")
    for part in parts:
        val normalized = normalize_gpu_backend_metadata_name(part)
        if normalized == "auto" or normalized == backend_name:
            return true
    false

fn gpu_backend_accepts_kernel_metadata(kind: BackendKind, target_name: text, backend_order: text) -> bool:
    val backend_name = gpu_backend_metadata_name(kind)
    val normalized_target = normalize_gpu_backend_metadata_name(target_name)
    if normalized_target != "auto" and normalized_target != backend_name:
        return false
    gpu_backend_order_contains(backend_order, backend_name)

fn gpu_backend_accepts_kernel(kind: BackendKind, func: MirFunction) -> bool:
    if not func.is_kernel:
        return true
    gpu_backend_accepts_kernel_metadata(kind, func.gpu_target, func.gpu_backend_order)

fn gpu_backend_supports_target(kind: BackendKind, target: CodegenTarget) -> bool:
    if kind == BackendKind.Cuda:
        return target == CodegenTarget.CudaPtx
    if kind == BackendKind.Hip:
        return target == CodegenTarget.HipHsaco
    if kind == BackendKind.OpenCl:
        return target == CodegenTarget.OpenClC or target == CodegenTarget.OpenClSpirv
    if kind == BackendKind.Vulkan:
        return target == CodegenTarget.VulkanSpirv
    false

fn gpu_backend_plan_module_kernels(kind: BackendKind, module: MirModule) -> GpuBackendKernelPlan:
    val backend_name = gpu_backend_metadata_name(kind)
    var accepted = 0
    var rejected = 0
    var rejected_names: [text] = []
    for symbol in module.functions.keys():
        val func: MirFunction = module.functions[symbol]
        if func.is_kernel:
            if gpu_backend_accepts_kernel(kind, func):
                accepted = accepted + 1
            else:
                rejected = rejected + 1
                rejected_names.push(func.name)
    GpuBackendKernelPlan.create(backend_name, accepted, rejected, rejected_names.join(","))
