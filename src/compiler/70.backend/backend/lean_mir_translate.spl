# Lean Backend - MIR-to-Lean Translation
#
# Extracted from lean_backend.spl. Contains MIR body/block/instruction
# translation to Lean 4 syntax.
#
# SOUNDNESS CONTRACT (mission-critical, verification-carrying codegen):
# Every construct that cannot be faithfully modelled in Lean MUST return
# `Err(CompileError)` naming the construct. This module NEVER emits `sorry`,
# never silently drops an instruction/terminator, and never substitutes a
# plausible-but-wrong operator/type for an unknown one. Emitting a wrong-but-
# well-typed Lean model would let a false theorem be "proved", so refusing to
# emit is the only sound behaviour.
#
# DETERMINISM: any `Dict` iterated here is key-sorted before emission so the
# generated Lean is byte-identical for identical MIR.

use compiler.mir.mir_data.*
use compiler.backend.backend.backend_types.{BackendKind, CompileError, compileerror_backend_error}

fn lean_err(msg: text) -> CompileError:
    """Construct a named Lean-backend diagnostic."""
    compileerror_backend_error(BackendKind.Lean, msg)

# ============================================================================
# MIR Type to Lean Conversion
# ============================================================================

fn mir_type_to_lean(ty: MirType) -> Result<text, CompileError>:
    """Convert MIR type to a faithful Lean 4 type, or hard-fail.

    Signedness and width are preserved so the Lean model matches MIR
    semantics. Types without a faithful primitive Lean representation
    (SIMD lanes, raw references, foreign/opaque, hardware bit lanes)
    return an error naming the kind rather than a lossy placeholder.
    """
    match ty.kind:
        case I8: Ok("Int8")
        case I16: Ok("Int16")
        case I32: Ok("Int32")
        case I64: Ok("Int")
        case U8: Ok("UInt8")
        case U16: Ok("UInt16")
        case U32: Ok("UInt32")
        case U64: Ok("UInt64")
        case F32: Ok("Float32")
        case F64: Ok("Float")
        case Bool: Ok("Bool")
        case Char: Ok("Char")
        case Unit: Ok("Unit")
        case Never: Ok("Empty")
        case Ptr(inner, _):
            val i = mir_type_to_lean(inner)?
            Ok("Ptr ({i})")
        case Array(elem, size):
            val e = mir_type_to_lean(elem)?
            Ok("Array ({e}) {size}")
        case Slice(elem):
            val e = mir_type_to_lean(elem)?
            Ok("Array ({e})")
        case Struct(id):
            Ok("Struct{id}")
        case Enum(id):
            Ok("Enum{id}")
        case Tuple(elems):
            var parts: [text] = []
            for e in elems:
                parts = parts.push(mir_type_to_lean(e)?)
            Ok("({parts.join(\" x \")})")
        case _:
            Err(lean_err("lean-backend: MIR type kind `{ty.kind}` has no faithful Lean 4 representation; refusing to emit an unsound placeholder"))

# ============================================================================
# MIR-to-Lean Body Translation
# ============================================================================

fn translate_mir_body(body: MirBody) -> Result<text, CompileError>:
    """Translate a MIR function body to a Lean 4 term, or hard-fail.

    Walks the basic blocks and instructions of the MIR body, producing a
    let-binding chain whose final value is the return expression. A body
    with no blocks, or one that produces no translatable statements, is an
    error: the previous behaviour emitted `sorry`, which in Lean admits any
    goal and would silently validate false theorems.
    """
    if body.blocks.len() == 0:
        return Err(lean_err("lean-backend: function `{body.name}` has no MIR basic blocks; cannot emit a sound Lean term (refusing to emit `sorry`)"))

    var lines: [text] = []
    for block in body.blocks:
        val block_lines = translate_mir_block(block, body)?
        for line in block_lines:
            lines = lines.push(line)

    if lines.len() == 0:
        return Err(lean_err("lean-backend: function `{body.name}` produced no translatable statements; refusing to emit an empty/placeholder body"))

    Ok(lines.join("\n"))

fn translate_mir_block(block: MirBlock, body: MirBody) -> Result<[text], CompileError>:
    """Translate a single MIR basic block to Lean let-bindings."""
    var lines: [text] = []

    # Add block label as a comment if present
    if block.label.?:
        lines = lines.push("-- block: {block.label.unwrap()}")

    # Translate each instruction
    for inst in block.instructions:
        val translated = translate_mir_inst(inst)?
        if translated != "":
            lines = lines.push(translated)

    # Translate the terminator
    val term_line = translate_mir_terminator(block.terminator)?
    if term_line != "":
        lines = lines.push(term_line)

    Ok(lines)

fn translate_mir_inst(inst: MirInst) -> Result<text, CompileError>:
    """Translate a single MIR instruction to a Lean let-binding, or hard-fail.

    Any instruction kind without a sound Lean lowering returns an error
    naming the kind instead of silently emitting a comment (which would drop
    the instruction from the model).
    """
    match inst.kind:
        case Const(dest, value, type_):
            val lean_val = translate_const_value(value)
            Ok("let _l{dest.id} := {lean_val}")

        case Copy(dest, src):
            Ok("let _l{dest.id} := _l{src.id}")

        case Move(dest, src):
            Ok("let _l{dest.id} := _l{src.id}")

        case BinOp(dest, op, left, right):
            val lean_op = translate_binop(op)?
            val l = translate_operand(left)
            val r = translate_operand(right)
            Ok("let _l{dest.id} := {l} {lean_op} {r}")

        case UnaryOp(dest, op, operand):
            val lean_op = translate_unaryop(op)
            val o = translate_operand(operand)
            Ok("let _l{dest.id} := {lean_op}{o}")

        case CheckedBinOp(dest, op, left, right):
            val lean_op = translate_binop(op)?
            val l = translate_operand(left)
            val r = translate_operand(right)
            Ok("let _l{dest.id} := {l} {lean_op} {r}  -- checked")

        case Alloc(dest, type_):
            val lean_ty = mir_type_to_lean(type_)?
            Ok("let _l{dest.id} : Ptr ({lean_ty}) := Ptr.alloc")

        case Load(dest, ptr):
            val p = translate_operand(ptr)
            Ok("let _l{dest.id} := Ptr.read {p}")

        case Store(ptr, value):
            val p = translate_operand(ptr)
            val v = translate_operand(value)
            Ok("let _ := Ptr.write {p} {v}")

        case GetElementPtr(dest, base, indices):
            val b = translate_operand(base)
            val idx_str = translate_operand_list(indices, " ")
            Ok("let _l{dest.id} := Ptr.offset {b} {idx_str}")

        case Aggregate(dest, kind, operands):
            val ops_str = translate_operand_list(operands, ", ")
            match kind:
                case Tuple:
                    Ok("let _l{dest.id} := ({ops_str})")
                case Array(_):
                    Ok("let _l{dest.id} := #[{ops_str}]")
                case Struct(sym):
                    Ok("let _l{dest.id} := Struct.mk {ops_str}")
                case Enum(sym, variant):
                    Ok("let _l{dest.id} := Enum.variant{variant} {ops_str}")

        case GetField(dest, base, field):
            val b = translate_operand(base)
            Ok("let _l{dest.id} := {b}.{field}")

        case SetField(base, field, value):
            val b = translate_operand(base)
            val v = translate_operand(value)
            Ok("let _ := set_field {b} {field} {v}")

        case Cast(dest, operand, target):
            val o = translate_operand(operand)
            val lean_ty = mir_type_to_lean(target)?
            Ok("let _l{dest.id} : {lean_ty} := cast {o}")

        case Call(dest, func, args):
            val f = translate_operand(func)
            val args_str = translate_operand_list(args, " ")
            if dest.?:
                val d = dest.unwrap()
                Ok("let _l{d.id} := {f} {args_str}")
            else:
                Ok("let _ := {f} {args_str}")

        case Intrinsic(dest, name, args):
            val args_str = translate_operand_list(args, " ")
            if dest.?:
                val d = dest.unwrap()
                Ok("let _l{d.id} := intrinsic_{name} {args_str}")
            else:
                Ok("let _ := intrinsic_{name} {args_str}")

        case DebugValue(local, name):
            Ok("-- debug: {name} = _l{local.id}")

        case Nop:
            Ok("")

        case _:
            Err(lean_err("lean-backend: MIR instruction `{inst.kind}` has no sound Lean lowering; refusing to drop it from the model"))

fn translate_operand_list(ops: [MirOperand], sep: text) -> text:
    """Translate and join a list of operands (operands are total)."""
    var parts: [text] = []
    for o in ops:
        parts = parts.push(translate_operand(o))
    parts.join(sep)

fn translate_mir_terminator(term: MirTerminator) -> Result<text, CompileError>:
    """Translate a MIR terminator to a Lean expression, or hard-fail.

    The flat let-binding translator can only faithfully model a single
    block that ends in a return/abort/unreachable. Inter-block control flow
    (goto/branch/switch/call-with-successor) cannot be represented as a
    straight-line term, so it hard-fails instead of emitting references to
    non-existent `goto_blockN` identifiers (a plausible-but-invalid model).
    """
    match term:
        case Ret(value):
            if value.?:
                Ok(translate_operand(value.unwrap()))
            else:
                Ok("()")
        case Unreachable:
            Ok("panic! \"unreachable\"")
        case Abort(message):
            Ok("panic! \"{message}\"")
        case Goto(target):
            Err(lean_err("lean-backend: unstructured control flow `goto block{target.id}` cannot be lowered to a Lean term by the flat translator; structured-CFG lowering is required"))
        case If(cond, then_, else_):
            val c = translate_operand(cond)
            Err(lean_err("lean-backend: conditional branch on `{c}` (then block{then_.id}, else block{else_.id}) requires structured-CFG lowering; refusing to emit a term referencing undefined block labels"))
        case Switch(value, targets, default):
            val v = translate_operand(value)
            Err(lean_err("lean-backend: switch on `{v}` (default block{default.id}) requires structured-CFG lowering; refusing to emit a term that drops branch targets"))
        case CallTerminator(dest, func, args, normal, _):
            val f = translate_operand(func)
            Err(lean_err("lean-backend: call terminator `{f}` continuing at block{normal.id} requires structured-CFG lowering; refusing to drop the successor edge"))

fn translate_operand(op: MirOperand) -> text:
    """Translate a MIR operand to a Lean term (total)."""
    match op.kind:
        case Copy(local):
            "_l{local.id}"
        case Move(local):
            "_l{local.id}"
        case Const(value, _):
            translate_const_value(value)

fn translate_const_value(value: MirConstValue) -> text:
    """Translate a MIR constant value to a Lean literal (total).

    Struct constants carry a name-keyed field dictionary; fields are emitted
    in sorted key order (deterministic) with their values preserved, rather
    than dropped as the previous `Struct.mk` placeholder did.
    """
    match value:
        case Int(v):
            "{v}"
        case Float(v):
            "{v}"
        case Bool(v):
            if v: "true" else: "false"
        case Str(v):
            "\"{v}\""
        case Array(elements):
            var elems: [text] = []
            for el in elements:
                elems = elems.push(translate_const_value(el))
            "#[{elems.join(\", \")}]"
        case Tuple(elements):
            var elems: [text] = []
            for el in elements:
                elems = elems.push(translate_const_value(el))
            "({elems.join(\", \")})"
        case Struct(fields):
            var keys = fields.keys()
            keys.sort()
            if keys.len() == 0:
                "Struct.mk"
            else:
                var parts: [text] = []
                for k in keys:
                    parts = parts.push("{k} := {translate_const_value(fields[k])}")
                "{{ {parts.join(\", \")} }}"
        case Zero:
            "0"

fn translate_binop(op: MirBinOp) -> Result<text, CompileError>:
    """Translate a MIR binary operation to a Lean operator, or hard-fail.

    Only scalar operations with a faithful Lean infix operator are emitted.
    Matrix (`@`), broadcast (`.+` etc.) and pointer-offset operations have no
    faithful scalar Lean operator and return a named error rather than being
    silently rewritten as `+` (the previous behaviour, which would turn a
    comparison or bit-op into addition).
    """
    match op:
        case Add: Ok("+")
        case Sub: Ok("-")
        case Mul: Ok("*")
        case Div: Ok("/")
        case Rem: Ok("%")
        case Pow: Ok("^")
        case Eq: Ok("==")
        case Ne: Ok("!=")
        case Lt: Ok("<")
        case Le: Ok("≤")
        case Gt: Ok(">")
        case Ge: Ok("≥")
        case BitAnd: Ok("&&&")
        case BitOr: Ok("|||")
        case BitXor: Ok("^^^")
        case Shl: Ok("<<<")
        case Shr: Ok(">>>")
        case _:
            Err(lean_err("lean-backend: binary operator `{op}` has no faithful scalar Lean operator; refusing to substitute a wrong operator"))

fn translate_unaryop(op: MirUnaryOp) -> text:
    """Translate a MIR unary operation to a Lean operator (total)."""
    match op:
        case Neg: "-"
        case Not: "!"
        case BitNot: "~~~"
        case Transpose: "ᵀ"

# ============================================================================
# Deterministic function ordering
# ============================================================================

fn sort_mir_functions_by_name(fns: [MirFunction]) -> [MirFunction]:
    """Stable insertion sort of MIR functions by name.

    `MirModule.functions` is a `Dict`, whose key iteration order is not
    guaranteed; sorting by function name makes generated Lean byte-identical
    across runs.
    """
    var result: [MirFunction] = []
    for f in fns:
        var inserted = false
        var out: [MirFunction] = []
        for g in result:
            if (not inserted) and f.name < g.name:
                out = out.push(f)
                inserted = true
            out = out.push(g)
        if not inserted:
            out = out.push(f)
        result = out
    result
