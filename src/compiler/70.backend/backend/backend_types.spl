# Backend Type Definitions
#
# Core type definitions for the unified backend API:
# - BackendKind: Available compiler backends
# - CodegenTarget: Compilation targets (architectures)
# - BuildMode: Build mode (Debug/Release/Test/Bootstrap)
# - OptimizationLevel: Optimization levels (O0-O3)
# - BackendCompileOptions: Compilation option set
# - CompiledModule/CompiledSymbol: Compilation results
# - CompileError: Compilation errors
#
# Split from backend_api.spl for modularity.

use compiler.mir_opt.mir_opt.mod.{TargetOptContext, target_opt_context_default}

# ============================================================================
# Backend Kind
# ============================================================================

enum BackendKind:
    """Available compiler backends."""
    Cranelift   # JIT and AOT, 64-bit focused
    Llvm        # Full optimization, 32-bit support (text-based, uses llc)
    LlvmLib     # LLVM via C API (no llc, no external tools)
    Native      # Direct machine code generation (no external tools)
    Wasm        # WebAssembly output
    Lean        # Lean 4 verification export
    Byl         # BYL generated proof-model IR
    Interpreter # Debug interpreter
    Cuda        # NVIDIA CUDA (PTX output)
    Hip         # AMD HIP / ROCm (HSACO output)
    OpenCl      # OpenCL C / SPIR-V compute output
    Vulkan      # Vulkan compute (SPIR-V output)
    Vhdl        # VHDL hardware description output
    CCodegen    # C++20 source code generation (MIR-based)
    IrTc        # mLLVM_QEMU unified backend (8/16/32/64-bit)
    Lua         # Lua 5.2+/LuaJIT source code generation (MIR-based)
    Compiler    # Legacy HIR-to-native backend selector
    Sdn         # Legacy data-only backend selector
    CraneliftJit # Legacy always-JIT interpreter selector
    LlvmJit     # Legacy LLVM JIT selector
    AutoJit     # Legacy automatic JIT selector

impl BackendKind:
    fn to_text() -> text:
        match self:
            case Cranelift: "cranelift"
            case Llvm: "llvm"
            case LlvmLib: "llvm-lib"
            case Native: "native"
            case Wasm: "wasm"
            case Lean: "lean"
            case Byl: "byl"
            case Interpreter: "interpreter"
            case Cuda: "cuda"
            case Hip: "hip"
            case OpenCl: "opencl"
            case Vulkan: "vulkan"
            case Vhdl: "vhdl"
            case CCodegen: "c"
            case IrTc: "irtc"
            case Lua: "lua"
            case Compiler: "compiler"
            case Sdn: "sdn"
            case CraneliftJit: "cranelift-jit"
            case LlvmJit: "llvm-jit"
            case AutoJit: "auto-jit"


# ============================================================================
# BackendKind Methods (was: impl BackendKind:)
# ============================================================================

# ============================================================================
# Codegen Target
# ============================================================================

enum CodegenTarget:
    """Compilation targets."""
    # 64-bit targets
    X86_64
    AArch64
    Riscv64

    # 32-bit targets
    X86
    Arm
    Riscv32

    # Native (host-detected target)
    Native

    # Host (detected at runtime - kept for compatibility)
    Host

    # WebAssembly targets
    Wasm32
    Wasm64

    # SimpleOS targets
    SimpleOS_X86_64

    # GPU targets
    CudaPtx
    HipHsaco
    OpenClC
    OpenClSpirv
    VulkanSpirv

    # mLLVM_QEMU targets (via IrTc backend)
    Avr         # 8-bit AVR via mLLVM_QEMU
    I8086       # 16-bit Intel 8086 via mLLVM_QEMU


# ============================================================================
# CodegenTarget Methods (was: impl CodegenTarget:)
# ============================================================================

impl CodegenTarget:
    fn to_text() -> text:
        match self:
            case X86_64: "x86_64"
            case AArch64: "aarch64"
            case Riscv64: "riscv64"
            case X86: "x86"
            case Arm: "arm"
            case Riscv32: "riscv32"
            case Native: "native"
            case Host: "host"
            case Wasm32: "wasm32"
            case Wasm64: "wasm64"
            case SimpleOS_X86_64: "simpleos-x86_64"
            case CudaPtx: "cuda-ptx"
            case HipHsaco: "hip-hsaco"
            case OpenClC: "opencl-c"
            case OpenClSpirv: "opencl-spirv"
            case VulkanSpirv: "vulkan-spirv"
            case Avr: "avr"
            case I8086: "i8086"

    fn is_8bit() -> bool:
        match self:
            case Avr:
                true
            case _:
                false

    fn is_16bit() -> bool:
        match self:
            case I8086:
                true
            case _:
                false

    fn is_32bit() -> bool:
        match self:
            case X86 | Arm | Riscv32 | Wasm32:
                true
            case _:
                false

    fn is_64bit() -> bool:
        match self:
            case X86_64 | AArch64 | Riscv64 | Wasm64 | Native | Host | SimpleOS_X86_64:
                true
            case _:
                false

    fn is_irtc() -> bool:
        match self:
            case Avr | I8086:
                true
            case _:
                false

    fn is_wasm() -> bool:
        match self:
            case Wasm32 | Wasm64:
                true
            case _:
                false

    fn is_gpu() -> bool:
        match self:
            case CudaPtx | HipHsaco | OpenClC | OpenClSpirv | VulkanSpirv:
                true
            case _:
                false

    fn gpu_source_format() -> text:
        match self:
            case CudaPtx: "cuda-c"
            case HipHsaco: "hip-cpp"
            case OpenClC: "opencl-c"
            case OpenClSpirv: "opencl-c"
            case VulkanSpirv: "spirv"
            case _: "none"

    fn gpu_binary_format() -> text:
        match self:
            case CudaPtx: "ptx"
            case HipHsaco: "hsaco"
            case OpenClC: "source"
            case OpenClSpirv: "spirv"
            case VulkanSpirv: "spirv"
            case _: "none"

# ============================================================================
# Build Mode
# ============================================================================

enum BuildMode:
    """Build mode determines backend selection and optimization strategy."""
    Debug      # Debug builds: fast compilation (Cranelift), debug symbols
    Release    # Release builds: optimized runtime (LLVM), stripped
    Test       # Test mode: no compilation (Interpreter)
    Bootstrap  # Bootstrap builds: minimal dependencies (Cranelift)


# ============================================================================
# BuildMode Methods (was: impl BuildMode:)
# ============================================================================

# ============================================================================
# Optimization Level
# ============================================================================

enum OptimizationLevel:
    """Optimization levels for code generation."""
    None_        # -O0: No optimization, fast compile
    Debug       # -Og: Debug-friendly optimization
    Basic       # -O1: Basic optimization compatibility level
    Size        # -Os: Optimize for size
    Standard    # -O2: Standard optimization compatibility level
    Speed       # -O2: Standard optimization
    Aggressive  # -O3: Aggressive optimization


# ============================================================================
# OptimizationLevel Methods (was: impl OptimizationLevel:)
# ============================================================================

# ============================================================================
# Compilation Options
# ============================================================================

struct BackendCompileOptions:
    """Options for compilation."""
    target: CodegenTarget
    opt_level: OptimizationLevel
    debug_info: bool
    emit_assembly: bool
    emit_llvm_ir: bool
    emit_mir: bool
    verify_output: bool
    target_opt_ctx: TargetOptContext
    backend_kind: text?
    allowed_families: [text] # seed-compiler duplicate-name compatibility


# ============================================================================
# BackendCompileOptions Methods (was: impl BackendCompileOptions:)
# ============================================================================

fn compileoptions_default_options() -> BackendCompileOptions:
        BackendCompileOptions(
            target: CodegenTarget.Host,
            opt_level: OptimizationLevel.Speed,
            debug_info: false,
            emit_assembly: false,
            emit_llvm_ir: false,
            emit_mir: false,
            verify_output: true,
            target_opt_ctx: target_opt_context_default(),
            backend_kind: nil,
            allowed_families: []
        )


fn compileoptions_debug_options() -> BackendCompileOptions:
        BackendCompileOptions(
            target: CodegenTarget.Host,
            opt_level: OptimizationLevel.Debug,
            debug_info: true,
            emit_assembly: false,
            emit_llvm_ir: false,
            emit_mir: true,
            verify_output: true,
            target_opt_ctx: target_opt_context_default(),
            backend_kind: nil,
            allowed_families: []
        )


fn compileoptions_release_options() -> BackendCompileOptions:
        BackendCompileOptions(
            target: CodegenTarget.Host,
            opt_level: OptimizationLevel.Speed,
            debug_info: false,
            emit_assembly: false,
            emit_llvm_ir: false,
            emit_mir: false,
            verify_output: true,
            target_opt_ctx: target_opt_context_default(),
            backend_kind: nil,
            allowed_families: []
        )

impl BackendCompileOptions:
    fn with_target(target: CodegenTarget) -> BackendCompileOptions:
        BackendCompileOptions(
            target: target,
            opt_level: self.opt_level,
            debug_info: self.debug_info,
            emit_assembly: self.emit_assembly,
            emit_llvm_ir: self.emit_llvm_ir,
            emit_mir: self.emit_mir,
            verify_output: self.verify_output,
            target_opt_ctx: self.target_opt_ctx,
            backend_kind: self.backend_kind,
            allowed_families: self.allowed_families
        )

    fn with_optimization(opt_level: OptimizationLevel) -> BackendCompileOptions:
        BackendCompileOptions(
            target: self.target,
            opt_level: opt_level,
            debug_info: self.debug_info,
            emit_assembly: self.emit_assembly,
            emit_llvm_ir: self.emit_llvm_ir,
            emit_mir: self.emit_mir,
            verify_output: self.verify_output,
            target_opt_ctx: self.target_opt_ctx,
            backend_kind: self.backend_kind,
            allowed_families: self.allowed_families
        )

fn compileoptions_backend_kind(options: BackendCompileOptions) -> text?:
        options.backend_kind

fn compileoptions_mode(options: BackendCompileOptions) -> BuildMode:
        match options.opt_level:
            case Debug:
                BuildMode.Debug
            case Aggressive:
                BuildMode.Release
            case Speed:
                BuildMode.Release
            case Size:
                BuildMode.Release
            case None_:
                BuildMode.Debug

# ============================================================================
# Compilation Result
# ============================================================================

struct CompiledModule:
    """Result of compiling a module."""
    name: text
    object_code: [u8]?
    # # DESUGARED: assembly: text
    has_assembly: bool
    assembly: text
    # # DESUGARED: llvm_ir: text
    has_llvm_ir: bool
    llvm_ir: text
    # # DESUGARED: mir_dump: text
    has_mir_dump: bool
    mir_dump: text
    symbols: [CompiledSymbol]
    compile_time_ms: i64

struct CompiledSymbol:
    """A symbol in the compiled module."""
    name: text
    kind: CompiledSymbolKind
    address: i64
    size: i64

enum CompiledSymbolKind:
    Function
    Data
    Const


# ============================================================================
# CompiledSymbolKind Methods (was: impl CompiledSymbolKind:)
# ============================================================================

struct CompileError:
    """Error during compilation."""
    message: text
    phase: text
    # # DESUGARED: location: text
    has_location: bool
    location: text


# ============================================================================
# CompileError Methods (was: impl CompileError:)
# ============================================================================

fn compileerror_backend_error(backend: BackendKind, message: text) -> CompileError:
        CompileError(
            message: message,
            phase: "backend ({backend.to_text()})",
            has_location: false,
            location: nil
        )


fn compileerror_target_unsupported(backend: BackendKind, target: CodegenTarget) -> CompileError:
        CompileError(
            message: "Backend {backend.to_text()} does not support target {target.to_text()}",
            phase: "target selection",
            has_location: false,
            location: nil
        )
