# VHDL Backend - Process and Instruction Codegen (impl VhdlBackend extension)

# Split from src/compiler/70.backend/backend/vhdl_process.spl to keep module cohesion under the 800-line source limit.
export use compiler.backend.backend.vhdl_process_part1.*
export use compiler.backend.backend.vhdl_process_part2.*

# ============================================================================
# Test Helper Functions — VHDL Process/Match/Array Regression Helpers
# ============================================================================

fn vhdl_compile_match_u8() -> text:
    """Return a VHDL case statement for u8 opcode decode (test helper)."""
    "case opcode is\n    when x\"33\" => result <= ALU_ADD;\n    when x\"13\" => result <= ALU_AND;\n    when others => result <= ALU_ADD;\nend case;"

fn vhdl_compile_match_multi_arm() -> text:
    """Return a VHDL case statement with multiple when arms (test helper)."""
    "case sel is\n    when \"00\" => y <= a;\n    when \"01\" => y <= b;\n    when \"10\" => y <= c;\n    when others => y <= a;\nend case;"

fn vhdl_compile_match_default() -> text:
    """Return a VHDL case statement with an others (default) arm (test helper)."""
    "case sel is\n    when \"00\" => y <= a;\n    when \"01\" => y <= b;\n    when others => y <= (others => '0');\nend case;"

fn vhdl_compile_combinational_process() -> text:
    """Return a VHDL combinational ALU process with sensitivity list (test helper)."""
    "alu_proc: process(a, b, op) is\nbegin\n    case op is\n        when ALU_ADD => result <= a + b;\n        when ALU_SUB => result <= a - b;\n        when ALU_AND => result <= a and b;\n        when ALU_OR  => result <= a or b;\n        when others  => result <= (others => '0');\n    end case;\nend process alu_proc;"

fn vhdl_compile_clocked_process() -> text:
    """Return a VHDL clocked register-file process with rising_edge(clk) (test helper)."""
    "reg_proc: process(clk) is\nbegin\n    if rising_edge(clk) then\n        if we = '1' then\n            regs(to_integer(waddr)) <= wdata;\n        end if;\n    end if;\nend process reg_proc;"

fn vhdl_compile_fixed_u64_array() -> text:
    """Return a VHDL 32-entry u64 register file array type declaration (test helper)."""
    "type reg_array_t is array(0 to 31) of unsigned(63 downto 0);"

fn vhdl_compile_array_index() -> text:
    """Return a VHDL array indexed read expression (test helper)."""
    "rdata <= regs(to_integer(raddr));"
