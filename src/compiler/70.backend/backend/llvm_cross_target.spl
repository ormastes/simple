# LLVM Cross-Target Toolchain Descriptors
#
# Defines explicit per-target toolchain requirements: linker, sysroot,
# CRT objects, and default flags. Provides resolution order and
# actionable error messages when prerequisites are missing.
#
# Resolution order per field:
# 1. Explicit CLI args (--linker=, --sysroot=)
# 2. Environment variables (SIMPLE_LINKER, SIMPLE_SYSROOT)
# 3. Config file settings
# 4. Built-in defaults (this module)

use app.io.mod (shell)
use std.platform.get_host_os
use std.io_runtime.{file_exists, host_arch}
use compiler.backend.backend.backend_types.{CodegenTarget}

# ============================================================================
# Toolchain Descriptor
# ============================================================================

struct TargetToolchain:
    """Complete toolchain description for a target.

    Contains everything needed to compile and link for a specific target:
    linker, sysroot, CRT objects, and linker flags.
    """
    target: CodegenTarget
    triple: text
    linker: text                # Linker binary name/path
    linker_flavor: text         # "gnu", "lld", "msvc", "wasm-ld"
    sysroot: text               # Sysroot path (empty = system default)
    crt_dir: text               # Directory containing CRT objects
    default_flags: [text]       # Default linker flags for this target
    requires_external: bool     # Whether external sysroot/toolchain is needed
    install_hint: text          # How to install the toolchain

impl TargetToolchain:
    fn is_available() -> bool:
        """Check if this toolchain is usable on the current host."""
        # Linker must be findable
        if self.linker == "":
            return false
        val (out, err, code) = shell("command -v {self.linker} 2>/dev/null || where {self.linker} 2>NUL")
        if code != 0:
            return false
        # If sysroot is required, it must exist
        if self.sysroot != "" and not file_exists(self.sysroot):
            return false
        true

    fn diagnostic() -> text:
        """Generate diagnostic message if toolchain is not available."""
        var issues: [text] = []

        # Check linker
        if self.linker != "":
            val (out, err, code) = shell("command -v {self.linker} 2>/dev/null || where {self.linker} 2>NUL")
            if code != 0:
                issues.push("Linker '{self.linker}' not found")

        # Check sysroot
        if self.sysroot != "" and not file_exists(self.sysroot):
            issues.push("Sysroot not found: {self.sysroot}")

        # Check CRT dir
        if self.crt_dir != "" and not file_exists(self.crt_dir):
            issues.push("CRT directory not found: {self.crt_dir}")

        if issues.len() == 0:
            return "Toolchain for {self.triple}: OK"

        var msg = "Toolchain for {self.triple}: MISSING PREREQUISITES\n"
        for issue in issues:
            msg = msg + "  - {issue}\n"
        msg = msg + "\n  Install: {self.install_hint}\n"
        msg

# ============================================================================
# Built-in Toolchain Descriptors
# ============================================================================

fn toolchain_for_target(target: CodegenTarget) -> TargetToolchain:
    """Get the built-in toolchain descriptor for a target.

    These are defaults; CLI args, env vars, and config override them.
    """
    val os = get_host_os()
    val arch = host_arch()

    match target:
        case X86_64:
            toolchain_x86_64_native(os)
        case X86:
            toolchain_i686(os)
        case AArch64:
            toolchain_aarch64(os, arch)
        case Arm:
            toolchain_armv7(os, arch)
        case Riscv64:
            toolchain_riscv64(os, arch)
        case Riscv32:
            toolchain_riscv32(os, arch)
        case Wasm32:
            toolchain_wasm32()
        case Wasm64:
            toolchain_wasm64()
        case _:
            toolchain_x86_64_native(os)

fn toolchain_x86_64_native(os: text) -> TargetToolchain:
    if os == "macos":
        TargetToolchain(
            target: CodegenTarget.X86_64,
            triple: "x86_64-apple-darwin",
            linker: "ld",
            linker_flavor: "macho",
            sysroot: "",
            crt_dir: "",
            default_flags: ["-arch", "x86_64", "-lSystem"],
            requires_external: false,
            install_hint: "Xcode Command Line Tools: xcode-select --install"
        )
    elif os == "windows":
        TargetToolchain(
            target: CodegenTarget.X86_64,
            triple: "x86_64-pc-windows-msvc",
            linker: "link.exe",
            linker_flavor: "msvc",
            sysroot: "",
            crt_dir: "",
            default_flags: ["/MACHINE:X64"],
            requires_external: false,
            install_hint: "Visual Studio Build Tools or MSVC"
        )
    else:
        # Linux / FreeBSD
        TargetToolchain(
            target: CodegenTarget.X86_64,
            triple: "x86_64-unknown-linux-gnu",
            linker: "mold",
            linker_flavor: "gnu",
            sysroot: "",
            crt_dir: "/usr/lib/x86_64-linux-gnu",
            default_flags: ["-pie", "--eh-frame-hdr"],
            requires_external: false,
            install_hint: "apt install mold (or gcc, binutils)"
        )

fn toolchain_i686(os: text) -> TargetToolchain:
    if os == "linux":
        TargetToolchain(
            target: CodegenTarget.X86,
            triple: "i686-unknown-linux-gnu",
            linker: "mold",
            linker_flavor: "gnu",
            sysroot: "",
            crt_dir: "/usr/lib/i386-linux-gnu",
            default_flags: ["-pie", "--eh-frame-hdr", "-m", "elf_i386"],
            requires_external: true,
            install_hint: "apt install gcc-multilib libc6-dev-i386"
        )
    else:
        TargetToolchain(
            target: CodegenTarget.X86,
            triple: "i686-unknown-linux-gnu",
            linker: "ld",
            linker_flavor: "gnu",
            sysroot: "",
            crt_dir: "",
            default_flags: [],
            requires_external: true,
            install_hint: "Install 32-bit development libraries for your platform"
        )

fn toolchain_aarch64(os: text, host: text) -> TargetToolchain:
    if os == "macos":
        TargetToolchain(
            target: CodegenTarget.AArch64,
            triple: "aarch64-apple-darwin",
            linker: "ld",
            linker_flavor: "macho",
            sysroot: "",
            crt_dir: "",
            default_flags: ["-arch", "arm64", "-lSystem"],
            requires_external: false,
            install_hint: "Xcode Command Line Tools: xcode-select --install"
        )
    elif host == "aarch64":
        # Native aarch64 Linux
        TargetToolchain(
            target: CodegenTarget.AArch64,
            triple: "aarch64-unknown-linux-gnu",
            linker: "mold",
            linker_flavor: "gnu",
            sysroot: "",
            crt_dir: "/usr/lib/aarch64-linux-gnu",
            default_flags: ["-pie", "--eh-frame-hdr"],
            requires_external: false,
            install_hint: "apt install mold (native build)"
        )
    else:
        # Cross-compile to aarch64
        TargetToolchain(
            target: CodegenTarget.AArch64,
            triple: "aarch64-unknown-linux-gnu",
            linker: "aarch64-linux-gnu-ld",
            linker_flavor: "gnu",
            sysroot: "/usr/aarch64-linux-gnu",
            crt_dir: "/usr/lib/aarch64-linux-gnu",
            default_flags: ["--sysroot=/usr/aarch64-linux-gnu", "-pie"],
            requires_external: true,
            install_hint: "apt install gcc-aarch64-linux-gnu libc6-dev-arm64-cross"
        )

fn toolchain_armv7(os: text, host: text) -> TargetToolchain:
    if host == "armv7l" or host == "armv7" or host == "arm":
        # Native ARM build
        TargetToolchain(
            target: CodegenTarget.Arm,
            triple: "armv7-unknown-linux-gnueabihf",
            linker: "ld",
            linker_flavor: "gnu",
            sysroot: "",
            crt_dir: "/usr/lib/arm-linux-gnueabihf",
            default_flags: ["-pie"],
            requires_external: false,
            install_hint: "Native ARM build"
        )
    else:
        # Cross-compile to ARM
        TargetToolchain(
            target: CodegenTarget.Arm,
            triple: "armv7-unknown-linux-gnueabihf",
            linker: "arm-linux-gnueabihf-ld",
            linker_flavor: "gnu",
            sysroot: "/usr/arm-linux-gnueabihf",
            crt_dir: "/usr/lib/arm-linux-gnueabihf",
            default_flags: ["--sysroot=/usr/arm-linux-gnueabihf", "-pie"],
            requires_external: true,
            install_hint: "apt install gcc-arm-linux-gnueabihf libc6-dev-armhf-cross"
        )

fn toolchain_riscv64(os: text, host: text) -> TargetToolchain:
    if host == "riscv64":
        TargetToolchain(
            target: CodegenTarget.Riscv64,
            triple: "riscv64-unknown-linux-gnu",
            linker: "ld",
            linker_flavor: "gnu",
            sysroot: "",
            crt_dir: "/usr/lib/riscv64-linux-gnu",
            default_flags: ["-pie"],
            requires_external: false,
            install_hint: "Native RISC-V 64 build"
        )
    else:
        TargetToolchain(
            target: CodegenTarget.Riscv64,
            triple: "riscv64-unknown-linux-gnu",
            linker: "riscv64-linux-gnu-ld",
            linker_flavor: "gnu",
            sysroot: "/usr/riscv64-linux-gnu",
            crt_dir: "/usr/lib/riscv64-linux-gnu",
            default_flags: ["--sysroot=/usr/riscv64-linux-gnu", "-pie"],
            requires_external: true,
            install_hint: "apt install gcc-riscv64-linux-gnu libc6-dev-riscv64-cross"
        )

fn toolchain_riscv32(os: text, host: text) -> TargetToolchain:
    TargetToolchain(
        target: CodegenTarget.Riscv32,
        triple: "riscv32-unknown-none-elf",
        linker: "riscv64-linux-gnu-ld",
        linker_flavor: "gnu",
        sysroot: "",
        crt_dir: "",
        default_flags: ["-melf32lriscv", "--no-relax"],
        requires_external: true,
        install_hint: "apt install gcc-riscv64-linux-gnu (also handles rv32 ELF linking)"
    )

fn toolchain_wasm32() -> TargetToolchain:
    TargetToolchain(
        target: CodegenTarget.Wasm32,
        triple: "wasm32-unknown-wasi",
        linker: "wasm-ld",
        linker_flavor: "wasm-ld",
        sysroot: "",
        crt_dir: "",
        default_flags: ["--export=_start", "--stack-first", "-z", "stack-size=1048576", "--initial-memory=4194304"],
        requires_external: true,
        install_hint: "apt install lld (provides wasm-ld) && install wasi-sdk for sysroot"
    )

fn toolchain_wasm64() -> TargetToolchain:
    TargetToolchain(
        target: CodegenTarget.Wasm64,
        triple: "wasm64-unknown-wasi",
        linker: "wasm-ld",
        linker_flavor: "wasm-ld",
        sysroot: "",
        crt_dir: "",
        default_flags: ["--export=_start", "--stack-first"],
        requires_external: true,
        install_hint: "apt install lld (provides wasm-ld) && install wasi-sdk for sysroot"
    )

# ============================================================================
# Toolchain Resolution with Overrides
# ============================================================================

struct ToolchainOverrides:
    """User-provided overrides for toolchain settings."""
    linker: text?
    sysroot: text?
    crt_dir: text?
    extra_flags: [text]

impl ToolchainOverrides:
    static fn none() -> ToolchainOverrides:
        ToolchainOverrides(linker: nil, sysroot: nil, crt_dir: nil, extra_flags: [])

fn resolve_toolchain(target: CodegenTarget, overrides: ToolchainOverrides) -> TargetToolchain:
    """Resolve toolchain with override precedence:

    1. Explicit overrides (CLI args)
    2. Environment variables
    3. Built-in defaults
    """
    var tc = toolchain_for_target(target)

    # Apply explicit overrides
    if overrides.linker.?:
        tc.linker = overrides.linker.unwrap()
    if overrides.sysroot.?:
        tc.sysroot = overrides.sysroot.unwrap()
    if overrides.crt_dir.?:
        tc.crt_dir = overrides.crt_dir.unwrap()

    # Check environment variables
    val (env_linker, e1, c1) = shell("echo $SIMPLE_LINKER 2>/dev/null")
    if c1 == 0 and env_linker.trim() != "" and not overrides.linker.?:
        tc.linker = env_linker.trim()

    val (env_sysroot, e2, c2) = shell("echo $SIMPLE_SYSROOT 2>/dev/null")
    if c2 == 0 and env_sysroot.trim() != "" and not overrides.sysroot.?:
        tc.sysroot = env_sysroot.trim()

    # Append extra flags from overrides
    for flag in overrides.extra_flags:
        tc.default_flags.push(flag)

    tc

# ============================================================================
# Diagnostic for All Targets
# ============================================================================

fn diagnose_all_targets() -> text:
    """Generate a diagnostic report for all target toolchains."""
    val targets = [
        CodegenTarget.X86_64,
        CodegenTarget.X86,
        CodegenTarget.AArch64,
        CodegenTarget.Arm,
        CodegenTarget.Riscv64,
        CodegenTarget.Riscv32,
        CodegenTarget.Wasm32,
        CodegenTarget.Wasm64
    ]

    var report = "Cross-Target Toolchain Status\n"
    report = report + "=============================\n\n"

    for target in targets:
        val tc = toolchain_for_target(target)
        report = report + tc.diagnostic() + "\n"

    report

# ============================================================================
# Exports
# ============================================================================
