# C Codegen Adapter
#
# Wraps MirToC translator to implement the Codegen trait.
# Delegates to existing C++20 code generation.

use compiler.mir.mir_data.{MirModule}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileOptions, CompileError}
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.common.bootstrap_guard.{BOOTSTRAP_NO_C}
when not BOOTSTRAP_NO_C:
    use compiler.backend.c_backend.{MirToC}

# ============================================================================
# C Codegen Adapter
# ============================================================================

class CCodegenAdapter:
    """Adapts MirToC translator to the Codegen trait interface."""
    options: CompileOptions

impl Codegen for CCodegenAdapter:
    fn backend_kind() -> BackendKind: BackendKind.CCodegen
    fn backend_name() -> text: "c"
    fn supports_target(target: CodegenTarget) -> bool:
        match target:
            case X86_64: true
            case AArch64: true
            case Riscv64: true
            case X86: true
            case Arm32: true
            case Riscv32: true
            case Wasm32: true
            case Wasm64: true
            case C: true
            case CudaPtx: false
            case VulkanSpirv: false
            case Metal: false
            case OpenCL: false
            case Avr: true
            case I8086: true
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.TextSource

    fn compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        var translator = MirToC.create(module.name)
        val c_source = translator.translate_module(module)
        val h_source = translator.build_header()
        Ok(CodegenOutput.text_with_header(module.name, c_source, h_source))

# ============================================================================
# Exports
# ============================================================================
