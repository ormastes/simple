# LLVM Optimization Passes
#
# LlvmPass enum, explicit diagnostic pass lists, and default pipeline helpers.
# Split from llvm_ir_builder.spl for modularity.

use compiler.backend.backend_api.*

# ============================================================================
# LLVM Optimization Passes
# ============================================================================

enum LlvmPass:
    """LLVM optimization passes."""
    # Analysis passes
    DominatorTree
    LoopInfo
    ScalarEvolution
    AliasAnalysis

    # Transform passes
    InstCombine
    SimplifyCFG
    Reassociate
    GVN
    LICM
    IndVarSimplify
    LoopUnroll
    LoopVectorize
    SLPVectorize
    DeadCodeElimination
    Inlining

impl LlvmPass:
    fn to_text() -> text:
        match self:
            case DominatorTree: "domtree"
            case LoopInfo: "loop-info"
            case ScalarEvolution: "scev"
            case AliasAnalysis: "alias-analysis"
            case InstCombine: "instcombine"
            case SimplifyCFG: "simplifycfg"
            case Reassociate: "reassociate"
            case GVN: "gvn"
            case LICM: "licm"
            case IndVarSimplify: "indvars"
            case LoopUnroll: "loop-unroll"
            case LoopVectorize: "loop-vectorize"
            case SLPVectorize: "slp-vectorize"
            case DeadCodeElimination: "dce"
            case Inlining: "inline"

fn llvm_default_pipeline_for_level(level: OptimizationLevel) -> text:
    """Map Simple optimization levels to LLVM new-pass-manager defaults.

    Keep this separate from passes_for_level: the explicit pass list is useful
    for diagnostics and custom-pass reporting, while production optimization
    should prefer LLVM's maintained default<O*> pipelines.
    """
    match level:
        case nil | None_ | Debug: "default<O0>"
        case Size: "default<Os>"
        case Speed: "default<O2>"
        case Aggressive: "default<O3>"

fn llvm_default_pipeline_for_flag(flag: text) -> text?:
    """Return the LLVM default pipeline for a CLI-style optimization flag."""
    match flag:
        case "-O0" | "O0" | "0": "default<O0>"
        case "-O1" | "O1" | "1": "default<O1>"
        case "-O2" | "O2" | "2": "default<O2>"
        case "-O3" | "O3" | "3": "default<O3>"
        case "-Os" | "Os" | "s": "default<Os>"
        case "-Oz" | "Oz" | "z": "default<Oz>"
        case _: nil

fn llvm_default_pipeline_for_size_min() -> text:
    """LLVM min-size pipeline for frontends that expose -Oz distinctly."""
    "default<Oz>"

fn passes_for_level(level: OptimizationLevel) -> [LlvmPass]:
    """Get LLVM passes for optimization level."""
    match level:
        case nil:
            []
        case Debug:
            [
                LlvmPass.InstCombine,
                LlvmPass.SimplifyCFG
            ]
        case Size:
            [
                LlvmPass.InstCombine,
                LlvmPass.SimplifyCFG,
                LlvmPass.DeadCodeElimination,
                LlvmPass.GVN
            ]
        case Speed:
            [
                LlvmPass.InstCombine,
                LlvmPass.SimplifyCFG,
                LlvmPass.Reassociate,
                LlvmPass.GVN,
                LlvmPass.LICM,
                LlvmPass.DeadCodeElimination,
                LlvmPass.Inlining
            ]
        case Aggressive:
            [
                LlvmPass.InstCombine,
                LlvmPass.SimplifyCFG,
                LlvmPass.Reassociate,
                LlvmPass.GVN,
                LlvmPass.LICM,
                LlvmPass.IndVarSimplify,
                LlvmPass.LoopUnroll,
                LlvmPass.LoopVectorize,
                LlvmPass.SLPVectorize,
                LlvmPass.DeadCodeElimination,
                LlvmPass.Inlining
            ]
