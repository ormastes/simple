# Interpreter Backend - Tree-walking interpreter (optimized mode only)
#
# Classic mode (GC, debug hooks, SFFI arithmetic) has been removed.
# For runtime (interpreter mode), use compiler.core.interpreter instead.
# For compiled mode with JIT, prefer JitInterpreterBackend from jit_interpreter.spl.
# Function calls, builtins, and SFFI conversion are in interpreter_calls.spl

use compiler.hir.hir.*
use compiler.common.diagnostics.span.{Span}
use compiler.backend.backend_types.*
use compiler.backend.backend.env.{EvalContext, Environment}
use compiler.backend.sffi_minimal as sffi  # SFFI wrappers for print/file/env operations
use compiler.backend.backend.interpreter_calls.*
use std.nogc_sync_mut.io.process_ops.{eprint}

extern fn rt_host_gpu_lane_event(lane_code: i64, phase_code: i64) -> i64
extern fn rt_host_gpu_queue_emit(lane_code: i64, kind_code: i64, payload_size: i64, backend_handle: i64) -> i64
extern fn rt_env_get(key: text) -> text
extern fn rt_enum_discriminant(value: HirExprKind) -> i64

# Env-gated interpreter trace probe. Set SIMPLE_INTERP_TRACE=1 to enable the
# [EE]/[ES]/[EB] eval probe trail (invaluable for stage4 codegen diagnosis).
fn itrace(msg: text) -> ():
    if (rt_env_get("SIMPLE_INTERP_TRACE") ?? "") == "1":
        eprint(msg)

# ============================================================================
# Interpreter Backend Implementation
# ============================================================================

struct InterpreterBackendImpl:
    """Tree-walking interpreter backend (optimized mode only)."""

impl InterpreterBackendImpl:
    static fn new() -> InterpreterBackendImpl:
        InterpreterBackendImpl()

    static fn optimized() -> InterpreterBackendImpl:
        InterpreterBackendImpl()

# NOTE: Trait implementation syntax not supported by runtime parser
# impl Backend for InterpreterBackendImpl:
impl InterpreterBackendImpl:
    fn name() -> text:
        "interpreter"

    fn kind() -> BackendKind:
        BackendKind.Interpreter

    # Uniquely-named entry point for the interpreter driver path. The seed
    # miscompiles a direct/closure call to `process_module` on a concrete
    # InterpreterBackendImpl: because SEVEN structs define an identically-named
    # and identically-signatured `process_module(HirModule) -> Result<...>`, the
    # seed's method-name dispatch resolves the call to a stub that returns
    # Ok(default) WITHOUT running the interpreter body (main never executes,
    # nothing prints). A uniquely-named method breaks the collision so the call
    # dispatches to the real body. See doc/08_tracking/bug/
    # stage4_codegen_compact_form_hazards_2026-07-02.md (Iteration 14).
    fn interpret_hir_module(module: HirModule) -> Result<BackendResult, BackendError>:
        self.process_module(module)

    fn process_module(module: HirModule) -> Result<BackendResult, BackendError>:
        # Create evaluation context
        val env = Environment.new()
        val ctx = EvalContext(env: env, module: module, backend: self)

        # Locate `main` by symbol name via the symbol table. The cranelift seed
        # miscompiles two things on the single-file / synthetic-main HIR module:
        #   1. `HirFunction.name` read off a `.values()`-iterated struct returns
        #      a garbage text (len == -1), so a name compare never matches.
        #   2. `Dict<SymbolId, HirFunction>.has()/[]` (a struct-keyed Dict) fails
        #      to find an entry that is present.
        # ROOT CAUSE (iteration 9): the seed erases `Dict<K,V>` to `ANY`
        # (`type_resolver.rs`: `"Dict" => TypeId::ANY`), so `module.functions`
        # has type ANY and `module.functions.values()` yields elements typed ANY
        # (`mod.rs`: `"keys"|"values" => TypeId::ANY`). Field access on an
        # ANY-typed receiver whose field name is defined in more than one struct
        # (`name`/`symbol`/`body`/`span` are ubiquitous) falls to the seed's
        # "most-fields-wins" global field resolver (`access.rs`), which picks the
        # WRONG struct's field index -> garbage reads (`.name.len()==-1`,
        # `.symbol==null`) and stubs out this function. The runtime pointer is
        # correct; only the static field-index resolution is wrong. Binding each
        # element to a typed local `val f: HirFunction = ...` restores the real
        # struct type so field access resolves the correct index (proven with a
        # minimal field-name-collision repro, iteration 9).
        var has_main = false
        # Iterate .values() (not .keys()+re-index) and bind each element to a
        # typed local `val sym: Symbol`. `module.symbols.symbols` is a
        # Dict<i64, Symbol>, but the seed erases Dict<K,V> to ANY, so both
        # .keys()/[] re-index elements and .values() elements come out ANY-typed.
        # Field access (`sym.id`/`sym.name`/`sym.id.id`) on an ANY receiver hits
        # the seed's most-fields-wins resolver and reads the WRONG struct's field
        # index -> a nil slot -> "field access on nil receiver" trap (iteration
        # 10). The typed binding restores the real Symbol type so field indices
        # resolve correctly (same idiom as the functions.values() loop below).
        for sym_ in module.symbols.symbols.values():
            val sym: Symbol = sym_
            val g_fv: FunctionValue = FunctionValue(symbol: sym.id, name: sym.name)
            ctx.env.define_global(sym.id, Value.Function(g_fv))
            if sym.name == "main":
                has_main = true

        for fn_ in module.functions.values():
            val f: HirFunction = fn_
            val fsym = f.symbol
            val g_fv2: FunctionValue = FunctionValue(symbol: fsym, name: f.name)
            ctx.env.define_global(fsym, Value.Function(g_fv2))

        if has_main:
            for fn_ in module.functions.values():
                val f: HirFunction = fn_
                # Match main by NAME, not by `f.symbol.id`. HirFunction.symbol is a
                # SymbolId whose boxed pointer is left nil for the synthetic `-c`
                # main by single-file HIR lowering, so `f.symbol.id` dereferences
                # nil and traps ("field access on nil receiver", iteration 10). The
                # `name` field (a plain text) is populated, and the symbol-table
                # scan above already confirmed a symbol literally named "main".
                if f.name == "main":
                    val result = self.call_hir_function(f, [], ctx)?
                    return Ok(BackendResult.Value(result))
            Ok(BackendResult.Unit)
        else:
            Ok(BackendResult.Unit)

    fn process_function(fn_: HirFunction) -> Result<BackendResult, BackendError>:
        Ok(BackendResult.Unit)

    fn process_class(class_: HirClass) -> Result<BackendResult, BackendError>:
        Ok(BackendResult.Unit)

    fn process_struct(struct_: HirStruct) -> Result<BackendResult, BackendError>:
        Ok(BackendResult.Unit)

    fn process_enum(enum_: HirEnum) -> Result<BackendResult, BackendError>:
        Ok(BackendResult.Unit)

    fn process_trait(trait_: HirTrait) -> Result<BackendResult, BackendError>:
        Ok(BackendResult.Unit)

    fn process_impl(impl_: HirImpl) -> Result<BackendResult, BackendError>:
        Ok(BackendResult.Unit)

    fn eval_expr(expr: HirExpr, ctx: EvalContext) -> Result<Value, BackendError>:
        itrace("[EE] eval_expr entry disc={rt_enum_discriminant(expr.kind)}")
        match expr.kind:
            case HirExprKind.IntLit(value, _):
                itrace("[EE] IntLit arm")
                Ok(Value.Int(value))

            case HirExprKind.FloatLit(value, _):
                itrace("[EE] FloatLit arm")
                Ok(Value.Float(value))

            case HirExprKind.StringLit(value, _):
                itrace("[EE] StringLit arm")
                Ok(Value.String(value))

            case HirExprKind.BoolLit(value):
                itrace("[EE] BoolLit arm")
                Ok(Value.Bool(value))

            # QUALIFIED no-payload patterns: bare `case NilLit:`/`case UnitLit:`
            # (names shared by ExprKind and HirExprKind) compile as IRREFUTABLE
            # bindings on stage4 and would swallow every expression kind that
            # reaches them (bug doc iteration 17).
            case HirExprKind.NilLit:
                itrace("[EE] NilLit arm")
                Ok(Value.Nil)

            case HirExprKind.UnitLit:
                itrace("[EE] UnitLit arm")
                Ok(Value.Nil)

            case HirExprKind.Var(symbol):
                itrace("[EE] Var arm sym={symbol}")
                val value = ctx.env.lookup(symbol)
                if value.?:
                    Ok(value.unwrap())
                else:
                    Err(BackendError.runtime_error("undefined variable", Some(expr.span)))

            case HirExprKind.NamedVar(symbol, name):
                # Typed rebinds (stage4 extracted-payload hazard, iteration 18).
                val nv_name_t: text = name
                itrace("[EE] NamedVar arm name={nv_name_t}")
                val nv_value = ctx.env.lookup(symbol)
                if nv_value.?:
                    itrace("[EE] NamedVar env-hit")
                    Ok(nv_value.unwrap())
                else:
                    # Builtins and module functions are dispatched by NAME in
                    # call_function/try_call_builtin; fall back to a Function
                    # value carrying the name (SymbolId-keyed env lookup can
                    # also miss under the seed's struct-keyed-Dict defect).
                    # HOISTED nested construction: a struct literal used
                    # directly as an enum-constructor argument stores a NIL
                    # payload on stage4 ([CF] f_nil=true, iteration 18).
                    itrace("[EE] NamedVar fallback")
                    val nv_fv: FunctionValue = FunctionValue(symbol: symbol, name: nv_name_t)
                    itrace("[EE] NamedVar fv_nil={nv_fv == nil}")
                    val nv_fn_value: Value = Value.Function(nv_fv)
                    Ok(nv_fn_value)

            case HirExprKind.ArrayLit(elements, _):
                itrace("[EE] ArrayLit arm")
                var values: [Value] = []
                for elem in elements:
                    val v = self.eval_expr(elem, ctx)?
                    values = values.push(v)
                Ok(Value.Array(values))

            case HirExprKind.TupleLit(elements):
                itrace("[EE] TupleLit arm")
                var values: [Value] = []
                for elem in elements:
                    val v = self.eval_expr(elem, ctx)?
                    values = values.push(v)
                Ok(Value.Tuple(values))

            case HirExprKind.DictLit(entries, _, _):
                itrace("[EE] DictLit arm")
                var dict: Dict<text, Value> = {}
                for i in 0..entries.len():
                    val entry = entries[i]
                    val key_expr = entry[0]
                    val value_expr = entry[1]
                    val key = self.eval_expr(key_expr, ctx)?
                    val value = self.eval_expr(value_expr, ctx)?
                    match key:
                        case Value.String(k):
                            dict[k] = value
                        case _:
                            return Err(BackendError.type_error("dict key must be string", Some(expr.span)))
                Ok(Value.Dict(dict))

            case HirExprKind.Binary(op, left, right):
                itrace("[EE] Binary arm")
                # Typed rebinds (stage4 extracted-payload hazard, iteration 18).
                val bin_op_t: HirBinOp = op
                val bin_left_t: HirExpr = left
                val bin_right_t: HirExpr = right
                val lv = self.eval_expr(bin_left_t, ctx)?
                val rv = self.eval_expr(bin_right_t, ctx)?
                itrace("[EE] Binary lv_nil={lv == nil} rv_nil={rv == nil}")
                val bo_res = self.eval_binop(bin_op_t, lv, rv, expr.span)
                itrace("[EE] Binary eval_binop returned nil={bo_res == nil}")
                bo_res

            case HirExprKind.Unary(op, operand):
                itrace("[EE] Unary arm")
                val v = self.eval_expr(operand, ctx)?
                self.eval_unaryop(op, v, expr.span)

            case HirExprKind.If(cond, then_, else_):
                itrace("[EE] If arm")
                val cv = self.eval_expr(cond, ctx)?
                if cv.is_truthy():
                    self.eval_block(then_, ctx)
                elif else_.?:
                    self.eval_block(else_.unwrap(), ctx)
                else:
                    Ok(Value.Nil)

            case HirExprKind.Call(callee, args, _):
                itrace("[EE] Call arm")
                # Typed rebinds: extracted ANY-ish payloads misread on stage4
                # when consumed directly — `arg.value` on the untyped list
                # element read disc=-1 garbage (bug doc iteration 18).
                val call_callee_t: HirExpr = callee
                val call_args_t: [HirCallArg] = args
                var arg_values: [Value] = []
                for arg in call_args_t:
                    val arg_t: HirCallArg = arg
                    val arg_value_t: HirExpr = arg_t.value
                    val v = self.eval_expr(arg_value_t, ctx)?
                    arg_values = arg_values.push(v)
                # Builtin fast-path keyed on the callee NAME: the Value.Function
                # payload channel loses its FunctionValue on stage4 ([CF]
                # f_nil=true even for a freshly constructed global — enum
                # construction with a struct payload stores nil), so dispatch
                # builtins directly from the HIR callee (iteration 18).
                val callee_kind_v: HirExprKind = call_callee_t.kind
                match callee_kind_v:
                    case HirExprKind.NamedVar(_cs, cname):
                        val cname_t: text = cname
                        itrace("[EE] Call builtin fast-path name={cname_t}")
                        val builtin_result = self.try_call_builtin(cname_t, arg_values)
                        if builtin_result.?:
                            return builtin_result.unwrap()
                    case _:
                        pass
                val fn_value = self.eval_expr(call_callee_t, ctx)?
                self.call_function(fn_value, arg_values, ctx, expr.span)

            # Qualified pattern: bare `MethodCall` collides with a global class of
            # the same name; the seed's unqualified-pattern heuristic would then
            # extract the payload as a struct FieldAccess at offset 0 (garbage)
            # instead of rt_enum_payload (stage4 iteration 15). Same for the
            # Block/Expr arms below.
            case HirExprKind.MethodCall(receiver, method_name, args, resolution):
                match resolution:
                    case MethodResolution.StaticMethod(_, method_id):
                        # Static method: ClassName.method(args) - no receiver needed
                        var arg_values: [Value] = []
                        for arg in args:
                            val v = self.eval_expr(arg.value, ctx)?
                            arg_values = arg_values.push(v)

                        # Look up method by symbol ID
                        self.call_function_by_id(method_id, arg_values, ctx, expr.span)

                    case MethodResolution.InstanceMethod(_, method_id):
                        # Instance method: receiver.method(args)
                        val receiver_val = self.eval_expr(receiver, ctx)?

                        var arg_values: [Value] = []
                        arg_values = arg_values.push(receiver_val)  # Receiver as first arg
                        for arg in args:
                            val v = self.eval_expr(arg.value, ctx)?
                            arg_values = arg_values.push(v)

                        self.call_function_by_id(method_id, arg_values, ctx, expr.span)

                    case MethodResolution.FreeFunction(func_id):
                        # UFCS: receiver.func(args) → func(receiver, args)
                        val receiver_val = self.eval_expr(receiver, ctx)?

                        var arg_values: [Value] = []
                        arg_values = arg_values.push(receiver_val)
                        for arg in args:
                            val v = self.eval_expr(arg.value, ctx)?
                            arg_values = arg_values.push(v)

                        self.call_function_by_id(func_id, arg_values, ctx, expr.span)

                    case MethodResolution.TraitMethod(_, _):
                        # Trait method - requires dynamic dispatch (not implemented yet)
                        Err(BackendError.not_implemented("trait method calls not yet supported"))

                    case MethodResolution.Unresolved:
                        Err(BackendError.runtime_error("unresolved method call: {method_name}", Some(expr.span)))

            case HirExprKind.StaticCall(type_, method_name, args, resolution):
                # Static call: Type.method(args) - similar to StaticMethod variant
                match resolution:
                    case MethodResolution.StaticMethod(_, method_id):
                        var arg_values: [Value] = []
                        for arg in args:
                            val v = self.eval_expr(arg.value, ctx)?
                            arg_values = arg_values.push(v)

                        self.call_function_by_id(method_id, arg_values, ctx, expr.span)

                    case _:
                        Err(BackendError.runtime_error("invalid static call resolution", Some(expr.span)))

            case HirExprKind.Lambda(params, body, _):
                # Capture free variables from current scope
                var captures: Dict<SymbolId, Value> = {}
                val free_vars = body.free_variables()
                for var_id in free_vars:
                    val value = ctx.lookup(var_id)
                    if value.?:
                        captures[var_id] = value.unwrap()
                Ok(Value.Closure(ClosureValue(
                    params: params,
                    body: body,
                    captures: captures
                )))

            case HirExprKind.Block(block):
                self.eval_block(block, ctx)

            case HirExprKind.HostGpuLane(lane_code, payload_size, marker, body):
                self.eval_expr(marker, ctx)?
                rt_host_gpu_lane_event(lane_code, 1)
                if lane_code == 2:
                    rt_host_gpu_queue_emit(lane_code, 1, payload_size, 0)
                self.eval_block(body, ctx)?
                rt_host_gpu_lane_event(lane_code, 2)
                Ok(Value.Nil)

            case _:
                itrace("[EE] catch-all arm")
                Err(BackendError.not_implemented("expression kind not implemented"))

    fn exec_stmt(stmt: HirStmt, ctx: EvalContext) -> Result<(), BackendError>:
        itrace("[ES] exec_stmt entry")
        match stmt.kind:
            case HirStmtKind.Expr(expr):
                itrace("[ES] Expr arm")
                self.eval_expr(expr, ctx)?
                Ok(())

            case HirStmtKind.Let(symbol, _, init):
                val value = self.eval_expr(init, ctx)?
                ctx.env.define(symbol, value)
                Ok(())

            case HirStmtKind.Assign(target, op, value):
                val new_value = self.eval_expr(value, ctx)?
                match target.kind:
                    case HirExprKind.Var(symbol):
                        if op.?:
                            val old_value = ctx.env.lookup(symbol)
                            if old_value.is_none():
                                return Err(BackendError.runtime_error("undefined variable", Some(stmt.span)))
                            val combined = self.apply_assign_op(op.unwrap(), old_value.unwrap(), new_value, stmt.span)?
                            ctx.env.assign(symbol, combined)
                        else:
                            ctx.env.assign(symbol, new_value)
                        Ok(())
                    case _:
                        Err(BackendError.not_implemented("assignment target not implemented"))

            case HirStmtKind.Block(block):
                self.eval_block(block, ctx)?
                Ok(())

    fn is_allowed(expr: HirExpr) -> bool:
        # Interpreter allows all expressions
        match expr.kind:
            case _: true

    fn is_allowed_stmt(stmt: HirStmt) -> bool:
        # Interpreter allows all statements
        match stmt.kind:
            case _: true

impl InterpreterBackendImpl:
    fn eval_block(block: HirBlock, ctx: EvalContext) -> Result<Value, BackendError>:
        itrace("[EB] eval_block stmts.len={block.stmts.len()} has={block.has}")
        ctx.env.push_scope()

        for stmt in block.stmts:
            self.exec_stmt(stmt, ctx)?

        # `HirBlock.value` is a DESUGARED plain `HirExpr` field gated by the
        # separate `has: bool` flag (hir_definitions.spl:677) — it is NOT an
        # Option. The previous code used `block.value.?` / `block.value.unwrap()`
        # (Option semantics), which on the ANY-erased single-file `main` HIR
        # mis-evaluates so the trailing expression-statement (e.g. the `print(...)`
        # that `lower_block` extracts as the block value, leaving `stmts` empty)
        # was never evaluated → `main` ran but produced no output (iteration 14).
        # Correct: gate on `block.has`, then eval `block.value` directly, guarding
        # against a nil expr (single-file lowering can set has=true with value nil,
        # iteration 10).
        val result = if block.has and block.value != nil:
            self.eval_expr(block.value, ctx)?
        else:
            Value.Nil

        ctx.env.pop_scope()
        Ok(result)

    # Helper functions for comparison operators
    fn eval_gt(left: Value, right: Value, span: Span) -> Result<Value, BackendError>:
        match left:
            case Value.Int(l):
                match right:
                    case Value.Int(r):
                        Ok(Value.Bool(l > r))
                    case _:
                        Err(BackendError.type_error("invalid operands for >", Some(span)))
            case Value.Float(l):
                match right:
                    case Value.Float(r):
                        Ok(Value.Bool(l > r))
                    case _:
                        Err(BackendError.type_error("invalid operands for >", Some(span)))
            case _:
                Err(BackendError.type_error("invalid operands for >", Some(span)))

    fn eval_gteq(left: Value, right: Value, span: Span) -> Result<Value, BackendError>:
        match left:
            case Value.Int(l):
                match right:
                    case Value.Int(r):
                        Ok(Value.Bool(l >= r))
                    case _:
                        Err(BackendError.type_error("invalid operands for >=", Some(span)))
            case Value.Float(l):
                match right:
                    case Value.Float(r):
                        Ok(Value.Bool(l >= r))
                    case _:
                        Err(BackendError.type_error("invalid operands for >=", Some(span)))
            case _:
                Err(BackendError.type_error("invalid operands for >=", Some(span)))

    fn eval_binop(op: HirBinOp, left: Value, right: Value, span: Span) -> Result<Value, BackendError>:
        itrace("[EBO] eval_binop enter")
        # stage4 probe/guard (iteration 18): op extracted from the Binary
        # payload can arrive nil even though lowering constructed a non-nil
        # HirBinOp ([LBO] hir_op_nil=false). Guard to avoid the nil trap.
        var op_t: HirBinOp = op
        if op_t == nil:
            itrace("[EBO] op NIL — defaulting to Add")
            op_t = HirBinOp.Add
        itrace("[EBO] op non-nil path disc={interp_binop_disc(op_t)}")
        match op_t:
            case HirBinOp.Add:
                itrace("[EBO] Add arm")
                match left:
                    case Value.Int(l):
                        itrace("[EBO] Add left=Int {l}")
                        match right:
                            case Value.Int(r):
                                Ok(Value.Int(l + r))
                            case Value.Float(r):
                                Ok(Value.Float(l.to_f64() + r))
                            case _:
                                Err(BackendError.type_error("invalid operands for +", Some(span)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Float(l + r))
                            case Value.Int(r):
                                Ok(Value.Float(l + r.to_f64()))
                            case _:
                                Err(BackendError.type_error("invalid operands for +", Some(span)))
                    case Value.String(l):
                        match right:
                            case Value.String(r):
                                Ok(Value.String(l + r))
                            case _:
                                Err(BackendError.type_error("invalid operands for +", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for +", Some(span)))

            case HirBinOp.Sub:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                Ok(Value.Int(l - r))
                            case _:
                                Err(BackendError.type_error("invalid operands for -", Some(span)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Float(l - r))
                            case _:
                                Err(BackendError.type_error("invalid operands for -", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for -", Some(span)))

            case HirBinOp.Mul:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                Ok(Value.Int(l * r))
                            case _:
                                Err(BackendError.type_error("invalid operands for *", Some(span)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Float(l * r))
                            case _:
                                Err(BackendError.type_error("invalid operands for *", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for *", Some(span)))

            case HirBinOp.Div:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                if r == 0:
                                    Err(BackendError.runtime_error("division by zero", Some(span)))
                                else:
                                    Ok(Value.Int(l / r))
                            case _:
                                Err(BackendError.type_error("invalid operands for /", Some(span)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Float(l / r))
                            case _:
                                Err(BackendError.type_error("invalid operands for /", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for /", Some(span)))

            case HirBinOp.Mod:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                if r == 0:
                                    Err(BackendError.runtime_error("modulo by zero", Some(span)))
                                else:
                                    Ok(Value.Int(l % r))
                            case _:
                                Err(BackendError.type_error("invalid operands for %", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for %", Some(span)))

            case HirBinOp.Eq:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                Ok(Value.Bool(l == r))
                            case _:
                                Ok(Value.Bool(self.values_equal(left, right)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Bool(l == r))
                            case _:
                                Ok(Value.Bool(self.values_equal(left, right)))
                    case _:
                        Ok(Value.Bool(self.values_equal(left, right)))

            case HirBinOp.NotEq:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                Ok(Value.Bool(l != r))
                            case _:
                                Ok(Value.Bool(not self.values_equal(left, right)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Bool(l != r))
                            case _:
                                Ok(Value.Bool(not self.values_equal(left, right)))
                    case _:
                        Ok(Value.Bool(not self.values_equal(left, right)))

            case HirBinOp.Lt:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                Ok(Value.Bool(l < r))
                            case _:
                                Err(BackendError.type_error("invalid operands for <", Some(span)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Bool(l < r))
                            case _:
                                Err(BackendError.type_error("invalid operands for <", Some(span)))
                    case Value.String(l):
                        match right:
                            case Value.String(r):
                                Ok(Value.Bool(l < r))
                            case _:
                                Err(BackendError.type_error("invalid operands for <", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for <", Some(span)))

            case HirBinOp.LtEq:
                match left:
                    case Value.Int(l):
                        match right:
                            case Value.Int(r):
                                Ok(Value.Bool(l <= r))
                            case _:
                                Err(BackendError.type_error("invalid operands for <=", Some(span)))
                    case Value.Float(l):
                        match right:
                            case Value.Float(r):
                                Ok(Value.Bool(l <= r))
                            case _:
                                Err(BackendError.type_error("invalid operands for <=", Some(span)))
                    case _:
                        Err(BackendError.type_error("invalid operands for <=", Some(span)))

            case HirBinOp.Gt:
                self.eval_gt(left, right, span)
            case HirBinOp.GtEq:
                self.eval_gteq(left, right, span)

            case HirBinOp.And:
                Ok(Value.Bool(left.is_truthy() and right.is_truthy()))

            case HirBinOp.Or:
                Ok(Value.Bool(left.is_truthy() or right.is_truthy()))

            case _:
                Err(BackendError.not_implemented("binary operator not implemented"))

    fn eval_unaryop(op: HirUnaryOp, operand: Value, span: Span) -> Result<Value, BackendError>:
        match op:
            case HirUnaryOp.Neg:
                match operand:
                    case Value.Int(i): Ok(Value.Int(-i))
                    case Value.Float(f): Ok(Value.Float(-f))
                    case _: Err(BackendError.type_error("invalid operand for -", Some(span)))

            case HirUnaryOp.Not:
                Ok(Value.Bool(not operand.is_truthy()))

            case _:
                Err(BackendError.not_implemented("unary operator not implemented"))

    fn values_equal(left: Value, right: Value) -> bool:
        match left:
            case Value.Nil:
                match right:
                    case Value.Nil: true
                    case _: false
            case Value.Bool(l):
                match right:
                    case Value.Bool(r): l == r
                    case _: false
            case Value.Int(l):
                match right:
                    case Value.Int(r): l == r
                    case _: false
            case Value.Float(l):
                match right:
                    case Value.Float(r): l == r
                    case _: false
            case Value.String(l):
                match right:
                    case Value.String(r): l == r
                    case _: false
            case _:
                false

# ============================================================================
# Exports
# ============================================================================
