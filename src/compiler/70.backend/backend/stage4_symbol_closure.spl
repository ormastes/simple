# Stage4 final object symbol-closure derivation.

fn stage4_sorted_text(values: [text]) -> [text]:
    # The deployed seed's built-in text-array sorting is a no-op.
    var sorted: [text] = []
    for value in values:
        var inserted = false
        var next: [text] = []
        for current in sorted:
            if not inserted and value < current:
                next = next.push(value)
                inserted = true
            next = next.push(current)
        if not inserted:
            next = next.push(value)
        sorted = next
    sorted

fn stage4_split_whitespace(value: text) -> [text]:
    var parts: [text] = []
    var start = -1
    var i = 0
    while i < value.len():
        val ch = value[i:i + 1]
        val whitespace = ch == " " or ch == "\t" or ch == "\n" or ch == "\u000B" or ch == "\u000C" or ch == "\r"
        if whitespace:
            if start >= 0:
                parts = parts.push(value.substring(start, i))
                start = -1
        elif start < 0:
            start = i
        i = i + 1
    if start >= 0:
        parts = parts.push(value.substring(start))
    parts

fn stage4_is_runtime_abi_symbol(name: text) -> bool:
    name.starts_with("rt_") or name.starts_with("spl_") or name.starts_with("__simple_") or name == "g_memtrack_enabled"

fn stage4_canonical_host_symbol(name: text, macho_prefixes: bool) -> text:
    if macho_prefixes and name.starts_with("_"):
        val unprefixed = name.substring(1)
        if stage4_is_runtime_abi_symbol(unprefixed):
            return unprefixed
    name

fn stage4_provider_symbol(name: text, object_format: text) -> text:
    var symbol = name
    if object_format == "macho" and symbol.starts_with("_"):
        symbol = symbol.substring(1)
    elif object_format == "coff-msvc" or object_format == "coff-mingw":
        var imported = false
        if symbol.starts_with("__imp_"):
            imported = true
            symbol = symbol.substring(6)
        if symbol.starts_with("_"):
            symbol = symbol.substring(1)
        val decoration = symbol.last_index_of("@") ?? -1
        val known_stdcall_import = symbol == "LoadLibraryA@4" or symbol == "GetProcAddress@8" or symbol == "FreeLibrary@4"
        if imported and known_stdcall_import:
            symbol = symbol.substring(0, decoration)
    symbol

# Named struct instead of a labeled tuple return: `-> (definitions: [text],
# undefined: [text])` is unparseable syntax (labeled-tuple returns; see
# doc/08_tracking/bug/seed_parser_labeled_tuple_return_type_gap_2026-07-17.md),
# but a plain unlabeled `-> ([text], [text])` trips the seed's own
# "anonymous multi-return tuple contains repeated field types" ambiguity
# check (src/compiler_rust/type/src/checker_check.rs) unconditionally on
# this function declaration, since both elements are `[text]`. A struct
# return type is neither: it is not the labeled-tuple grammar form, and it
# is not an anonymous `AstType::Tuple` at all, so the repeated-element-type
# check (which only matches tuple return types) never fires.
struct Stage4NmGlobalSymbols:
    definitions: [text]
    undefined: [text]

fn stage4_exact_nm_global_symbols(nm_output: text) -> Stage4NmGlobalSymbols:
    """Parse the exact two/three-field global-symbol form emitted by portable nm."""
    var definitions: [text] = []
    var undefined: Dict<text, bool> = {}
    for line in nm_output.split("\n"):
        val parts = stage4_split_whitespace(line)
        if parts.len() != 2 and parts.len() != 3:
            continue
        var type_index = 0
        if parts.len() == 3:
            type_index = 1
        val type_code = parts[type_index]
        if type_code.len() != 1:
            continue
        val symbol = parts[parts.len() - 1]
        if type_code == "U" or type_code == "w" or type_code == "v":
            undefined[symbol] = true
        else:
            definitions = definitions.push(symbol)
    Stage4NmGlobalSymbols(definitions: definitions, undefined: stage4_sorted_text(undefined.keys()))

pub fn stage4_compiler_backfill_symbol_table_fingerprint(nm_output: text) -> Result<text, text>:
    """Return a deterministic fingerprint input for an exact raw global symbol table."""
    val nm_symbols = stage4_exact_nm_global_symbols(nm_output)
    val definitions = nm_symbols.definitions
    val undefined = nm_symbols.undefined
    var definition_counts: Dict<text, i64> = {}
    for symbol in definitions:
        definition_counts[symbol] = (definition_counts[symbol] ?? 0) + 1

    var rows: [text] = []
    for symbol in definition_counts.keys():
        rows = rows.push("defined\t{definition_counts[symbol]}\t" + symbol)
    for symbol in undefined:
        rows = rows.push("undefined\t" + symbol)
    Ok(stage4_sorted_text(rows).join("\n"))

pub fn stage4_validate_compiler_backfill_provider_disjoint(capsule_nm: text, provider_labels: [text], provider_nms: [text], object_format: text) -> Result<(), text>:
    """Reject canonical global definitions shared by the compiler capsule and a provider."""
    if object_format != "elf" and object_format != "macho":
        return Err("Unsupported Stage4 compiler backfill provider object format '" + object_format + "'")
    if provider_labels.len() == 0 or provider_labels.len() != provider_nms.len():
        return Err("Stage4 compiler backfill provider labels and symbol scans must be non-empty and have equal length")

    var labels_seen: Dict<text, bool> = {}
    for label in provider_labels:
        if label == "":
            return Err("Stage4 compiler backfill provider label is empty")
        if labels_seen.has(label):
            return Err("Stage4 compiler backfill provider label '" + label + "' is repeated")
        labels_seen[label] = true

    val capsule_raw_definitions = stage4_exact_nm_global_symbols(capsule_nm).definitions
    if capsule_raw_definitions.len() == 0:
        return Err("Stage4 compiler backfill capsule defines no global symbols")
    var capsule_definitions: Dict<text, bool> = {}
    for raw_symbol in capsule_raw_definitions:
        capsule_definitions[stage4_provider_symbol(raw_symbol, object_format)] = true

    var provider_i = 0
    while provider_i < provider_labels.len():
        val label = provider_labels[provider_i]
        val provider_raw_definitions = stage4_exact_nm_global_symbols(provider_nms[provider_i]).definitions
        if provider_raw_definitions.len() == 0:
            return Err("Stage4 compiler backfill provider '" + label + "' defines no global symbols")
        var provider_definitions: Dict<text, bool> = {}
        for raw_symbol in provider_raw_definitions:
            provider_definitions[stage4_provider_symbol(raw_symbol, object_format)] = true
        for symbol in stage4_sorted_text(provider_definitions.keys()):
            if capsule_definitions.has(symbol):
                return Err("Stage4 compiler backfill overlaps provider '" + label + "': " + symbol)
        provider_i = provider_i + 1
    Ok(())

pub fn stage4_runtime_provider_object_matches(path: text, object_stem: text, object_ext: text, windows_paths: bool) -> bool:
    """Match one generated provider object at a final-component token boundary."""
    if path == "" or object_stem == "" or object_ext == "":
        return false
    var normalized = path
    var expected = object_stem + object_ext
    if windows_paths:
        normalized = normalized.replace("\\", "/").lower()
        expected = expected.lower()
    val parts = normalized.split("/")
    val leaf = parts[parts.len() - 1]
    leaf == expected or leaf.ends_with("_" + expected)

fn stage4_hosted_provider_archive_file(provider: text, target_os_name: text, msvc_linker: bool) -> Result<text, text>:
    if target_os_name == "windows":
        if msvc_linker:
            return Ok("simple_stage4_" + provider + ".lib")
        return Ok("libsimple_stage4_" + provider + ".a")
    if msvc_linker:
        return Err("Stage4 MSVC provider archives require a Windows target")
    if target_os_name == "linux" or target_os_name == "macos" or target_os_name == "freebsd":
        return Ok("libsimple_stage4_" + provider + ".a")
    Err("Stage4 provider has no archive policy for target OS '" + target_os_name + "'")

pub fn stage4_compiler_backfill_archive_file(target_os_name: text) -> Result<text, text>:
    """Return the dedicated compiler capsule name on supported producer hosts."""
    if target_os_name == "linux" or target_os_name == "macos":
        return Ok("libsimple_compiler_backfill.a")
    Err("Stage4 compiler backfill has no capsule producer for target OS '" + target_os_name + "'")

pub fn stage4_dynload_provider_archive_file(target_os_name: text, msvc_linker: bool) -> Result<text, text>:
    """Return the target/linker-specific archive name without building or selecting it."""
    stage4_hosted_provider_archive_file("dynload", target_os_name, msvc_linker)

pub fn stage4_runtime_native_archive_file(target_os_name: text, msvc_linker: bool) -> Result<text, text>:
    """Return the target/linker-specific runtime-native archive name."""
    stage4_hosted_provider_archive_file("runtime_native", target_os_name, msvc_linker)

pub fn stage4_runtime_legacy_compat_archive_file(target_os_name: text, msvc_linker: bool) -> Result<text, text>:
    """Return the exact localized legacy compatibility archive name."""
    stage4_hosted_provider_archive_file("runtime_legacy_compat", target_os_name, msvc_linker)

