# Stage4 final object symbol-closure derivation.

fn stage4_canonical_host_symbol(name: text, macho_prefixes: bool) -> text:
    if macho_prefixes and (name.starts_with("_rt_") or name.starts_with("_spl_")):
        return name.substring(1)
    name

fn stage4_nm_has_address(parts: [text], type_index: i64) -> bool:
    if type_index <= 0:
        return false
    var address = parts[type_index - 1]
    val colon = address.last_index_of(":") ?? -1
    if colon >= 0:
        address = address.substring(colon + 1)
    if address == "":
        return false
    var i = 0
    while i < address.len():
        val digit = address[i:i + 1]
        if not ((digit >= "0" and digit <= "9") or
                (digit >= "a" and digit <= "f") or
                (digit >= "A" and digit <= "F")):
            return false
        i = i + 1
    true

pub fn stage4_requested_from_nm_output(nm_output: text, macho_prefixes: bool) -> [text]:
    """Return sorted strong rt_*/spl_* requests not defined by sibling objects."""
    var defined: Dict<text, bool> = {}
    var undefined: Dict<text, bool> = {}
    for line in nm_output.split("\n"):
        val parts = line.split_whitespace()
        if parts.len() < 2:
            continue
        val type_index = parts.len() - 2
        val type_code = parts[type_index]
        val symbol = stage4_canonical_host_symbol(parts[parts.len() - 1], macho_prefixes)
        if not symbol.starts_with("rt_") and not symbol.starts_with("spl_"):
            continue
        if type_code == "U":
            undefined[symbol] = true
        elif type_code == "u" and stage4_nm_has_address(parts, type_index):
            defined[symbol] = true
        elif type_code != "w" and type_code != "v" and stage4_nm_has_address(parts, type_index):
            defined[symbol] = true

    var requested: [text] = []
    for symbol in undefined.keys():
        if not defined.has(symbol):
            requested = requested.push(symbol)
    requested.sort()
    requested

fn stage4_global_definitions_from_nm_output(nm_output: text, macho_prefixes: bool, owner: text) -> Result<[text], text>:
    var seen: Dict<text, bool> = {}
    var definitions: [text] = []
    for line in nm_output.split("\n"):
        val parts = line.split_whitespace()
        if parts.len() < 3:
            continue
        val type_index = parts.len() - 2
        val type_code = parts[type_index]
        if type_code == "U" or not stage4_nm_has_address(parts, type_index):
            continue
        val symbol = stage4_canonical_host_symbol(parts[parts.len() - 1], macho_prefixes)
        if seen.has(symbol):
            return Err("Stage4 archive '" + owner + "' repeats global definition '" + symbol + "'")
        seen[symbol] = true
        definitions = definitions.push(symbol)
    if definitions.len() == 0:
        return Err("Stage4 archive '" + owner + "' has no global definitions")
    definitions.sort()
    Ok(definitions)

pub fn stage4_validate_candidate_archive_inputs(archive_labels: [text], archive_paths: [text]) -> Result<(), text>:
    """Validate the strict Stage4 candidate archive identity inputs."""
    if archive_labels.len() == 0 or archive_labels.len() != archive_paths.len():
        return Err("Stage4 archive labels and paths must be non-empty and have equal length")
    var labels_seen: Dict<text, bool> = {}
    var paths_seen: Dict<text, bool> = {}
    var i = 0
    while i < archive_labels.len():
        val label = archive_labels[i]
        val path = archive_paths[i]
        if label == "" or path == "":
            return Err("Stage4 archive label and path must be non-empty")
        val path_parts = path.replace("\\", "/").split("/")
        val file_name = path_parts[path_parts.len() - 1].lower()
        if (not file_name.ends_with(".a") and not file_name.ends_with(".lib")) or file_name.ends_with(".dll.a"):
            return Err("Stage4 candidate archive '" + label + "' uses an unsupported archive path: '" + path + "'")
        # Seed-parser compat: block-form `val x = if:` initializers and
        # unparenthesized multi-line booleans do not parse under the deployed
        # seed (known runtime limitation) — keep single-line forms here.
        var path_key = path
        if file_name.ends_with(".lib"):
            path_key = path.replace("\\", "/").lower()
        if labels_seen.has(label):
            return Err("Stage4 archive label '" + label + "' is repeated")
        if paths_seen.has(path_key):
            return Err("Stage4 archive path '" + path + "' is repeated")
        if (file_name == "libsimple_native_all.a" or file_name == "simple_native_all.lib" or
                file_name == "libsimple_runtime.a" or file_name == "simple_runtime.lib"):
            return Err("Stage4 candidate archive '" + label + "' uses forbidden aggregate path '" + path + "'")
        labels_seen[label] = true
        paths_seen[path_key] = true
        i = i + 1
    Ok(())

pub fn stage4_forbidden_archive_sections(section_headers: text) -> [text]:
    """Return initializer/finalizer section families forbidden in Stage4 providers."""
    var found: [text] = []
    for section in [
        ".preinit_array", ".init_array", ".ctors", ".fini_array", ".dtors",
        "__mod_init_func", "__mod_term_func",
        ".CRT$XI", ".CRT$XC", ".CRT$XP", ".CRT$XT", ".CRT$XL"
    ]:
        if section_headers.contains(section):
            found.push(section)
    found

pub fn stage4_resolve_requested_archive_owners(requested: [text], archive_labels: [text], archive_nm_outputs: [text], macho_prefixes: bool) -> Result<([i64], [text]), text>:
    """Validate unique ownership and return selected archives plus requested owner rows."""
    if requested.len() == 0:
        return Err("Stage4 requested symbol closure is empty")
    if archive_labels.len() == 0 or archive_labels.len() != archive_nm_outputs.len():
        return Err("Stage4 archive labels and symbol scans must be non-empty and have equal length")

    var owner_by_symbol: Dict<text, i64> = {}
    var labels_seen: Dict<text, bool> = {}
    var archive_i = 0
    while archive_i < archive_labels.len():
        val label = archive_labels[archive_i]
        if label == "":
            return Err("Stage4 archive label is empty")
        if labels_seen.has(label):
            return Err("Stage4 archive label '" + label + "' is repeated")
        labels_seen[label] = true
        val definitions_result = stage4_global_definitions_from_nm_output(archive_nm_outputs[archive_i], macho_prefixes, label)
        val definitions = match definitions_result:
            case Ok(symbols): symbols
            case Err(err): return Err(err)
        for symbol in definitions:
            if owner_by_symbol.has(symbol):
                val previous_i = owner_by_symbol[symbol]
                return Err("Stage4 global definition '" + symbol + "' overlaps archives '" + archive_labels[previous_i] + "' and '" + label + "'")
            owner_by_symbol[symbol] = archive_i
        archive_i = archive_i + 1

    var requested_seen: Dict<text, bool> = {}
    var selected_by_index: Dict<i64, bool> = {}
    var owner_rows: [text] = []
    for symbol in requested:
        if requested_seen.has(symbol):
            continue
        requested_seen[symbol] = true
        if not owner_by_symbol.has(symbol):
            return Err("Stage4 requested symbol '" + symbol + "' has no archive owner")
        val owner_i = owner_by_symbol[symbol]
        selected_by_index[owner_i] = true
        owner_rows = owner_rows.push(symbol + "=" + archive_labels[owner_i])

    var selected: [i64] = []
    archive_i = 0
    while archive_i < archive_labels.len():
        if selected_by_index.has(archive_i):
            selected = selected.push(archive_i)
        archive_i = archive_i + 1
    owner_rows.sort()
    Ok((selected, owner_rows))

pub fn stage4_select_requested_archive_indices(requested: [text], archive_labels: [text], archive_nm_outputs: [text], macho_prefixes: bool) -> Result<[i64], text>:
    """Validate unique symbol ownership and return selected archives in declared order."""
    match stage4_resolve_requested_archive_owners(requested, archive_labels, archive_nm_outputs, macho_prefixes):
        case Ok((selected, _)): Ok(selected)
        case Err(err): Err(err)

fn stage4_canonical_fingerprint_rows(group: text, rows: [text]) -> Result<[text], text>:
    if rows.len() == 0:
        return Err("Stage4 link profile " + group + " rows are empty")
    var names: Dict<text, bool> = {}
    var canonical: [text] = []
    for row in rows:
        val separator = row.index_of("=") ?? -1
        if separator <= 0 or separator >= row.len() - 1:
            return Err("Stage4 link profile " + group + " row must be non-empty name=value")
        val name = row.substring(0, separator)
        if names.has(name):
            return Err("Stage4 link profile " + group + " repeats name '" + name + "'")
        names[name] = true
        canonical = canonical.push(row)
    canonical.sort()
    Ok(canonical)

pub fn stage4_link_profile_fingerprint_input(target: text, backend: text, link_options: text, compiler_hash: text, source_hash_rows: [text], archive_hash_rows: [text], owner_rows: [text]) -> Result<text, text>:
    """Return the versioned canonical input for a separate Stage4 link-profile hash."""
    if target == "" or backend == "" or link_options == "" or compiler_hash == "":
        return Err("Stage4 link profile scalar fields must be non-empty")

    val source_result = stage4_canonical_fingerprint_rows("source hash", source_hash_rows)
    val sources = match source_result:
        case Ok(rows): rows
        case Err(err): return Err(err)
    val archive_result = stage4_canonical_fingerprint_rows("archive hash", archive_hash_rows)
    val archives = match archive_result:
        case Ok(rows): rows
        case Err(err): return Err(err)
    val owner_result = stage4_canonical_fingerprint_rows("owner", owner_rows)
    val owners = match owner_result:
        case Ok(rows): rows
        case Err(err): return Err(err)

    var input = "stage4-link-profile-v1"
    input = input + "\ntarget[{target.len()}]=" + target
    input = input + "\nbackend[{backend.len()}]=" + backend
    input = input + "\nlink_options[{link_options.len()}]=" + link_options
    input = input + "\ncompiler_hash[{compiler_hash.len()}]=" + compiler_hash
    for row in sources:
        input = input + "\nsource_hash[{row.len()}]=" + row
    for row in archives:
        input = input + "\narchive_hash[{row.len()}]=" + row
    for row in owners:
        input = input + "\nowner[{row.len()}]=" + row
    Ok(input)
