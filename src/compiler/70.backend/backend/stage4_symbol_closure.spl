    """Return the target/linker-specific memtrack archive name without selecting it."""
    stage4_hosted_provider_archive_file("memtrack", target_os_name, msvc_linker)

pub fn stage4_time_provider_archive_file(target_os_name: text, msvc_linker: bool) -> Result<text, text>:
    """Return the target/linker-specific time/progress archive name without selecting it."""
    stage4_hosted_provider_archive_file("time", target_os_name, msvc_linker)

pub fn stage4_fork_provider_archive_file(target_os_name: text, msvc_linker: bool) -> Result<text, text>:
    """Return the POSIX fork-isolation archive name without selecting Windows stubs."""
    if target_os_name == "windows":
        return Err("Stage4 fork isolation has no Windows provider")
    stage4_hosted_provider_archive_file("fork", target_os_name, msvc_linker)

pub fn stage4_windows_c_object_uses_msvc_abi(target_os_name: text, target: text, cc: text, msvc_linker: bool) -> Result<bool, text>:
    """Classify the selected Windows C driver and reject linker-ABI disagreement."""
    if target_os_name != "windows":
        if msvc_linker:
            return Err("Stage4 MSVC linker policy requires a Windows target")
        return Ok(false)

    val normalized = cc.lower().replace("\\", "/")
    val parts = normalized.split("/")
    val driver = parts[parts.len() - 1]
    val msvc_driver = driver == "cl" or driver == "cl.exe" or driver == "clang-cl" or driver == "clang-cl.exe"
    val mingw_driver = driver == "gcc" or driver == "gcc.exe" or driver == "cc" or driver == "cc.exe" or driver.ends_with("-gcc") or driver.ends_with("-gcc.exe")

    if not msvc_driver and not mingw_driver:
        return Err("Stage4 cannot determine Windows object ABI from C compiler '" + cc + "'")
    if msvc_driver and not msvc_linker:
        return Err("Stage4 MSVC C compiler is incompatible with the MinGW linker policy")
    if mingw_driver and msvc_linker:
        return Err("Stage4 MinGW C compiler is incompatible with the MSVC linker policy")
    if target.contains("-") and target.ends_with("-pc-windows-msvc") and not msvc_driver:
        return Err("Stage4 MinGW C compiler is incompatible with explicit MSVC target '" + target + "'")
    Ok(msvc_driver)

fn stage4_hosted_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    if target_os_name == "windows":
        return Ok(if msvc_objects: "coff-msvc" else: "coff-mingw")
    if msvc_objects:
        return Err("Stage4 MSVC provider objects require a Windows target")
    if target_os_name == "macos":
        return Ok("macho")
    if target_os_name == "linux" or target_os_name == "freebsd":
        return Ok("elf")
    Err("Stage4 provider has no object-format policy for target OS '" + target_os_name + "'")

pub fn stage4_compiler_backfill_object_format(target_os_name: text) -> Result<text, text>:
    """Return the portable-nm contract for a supported compiler capsule."""
    if target_os_name == "linux":
        return Ok("elf")
    if target_os_name == "macos":
        return Ok("macho")
    Err("Stage4 compiler backfill has no object-format policy for target OS '" + target_os_name + "'")

pub fn stage4_derive_compiler_backfill_manifest(nm_output: text, object_format: text) -> Result<[text], text>:
    """Derive the exact compiler-capsule export manifest from a portable nm scan."""
    if object_format != "elf" and object_format != "macho":
        return Err("Unsupported Stage4 compiler backfill object format '" + object_format + "'")

    var definition_counts: Dict<text, i64> = {}
    var runtime_symbols: Dict<text, bool> = {}
    val nm_symbols = stage4_exact_nm_global_symbols(nm_output)
    val raw_definitions = nm_symbols.definitions
    val raw_undefined = nm_symbols.undefined
    for raw_symbol in raw_definitions:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if symbol.starts_with("rt_") or symbol.starts_with("spl_"):
            runtime_symbols[symbol] = true
        if symbol.starts_with("rt_cranelift_"):
            definition_counts[symbol] = (definition_counts[symbol] ?? 0) + 1
    for raw_symbol in raw_undefined:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if symbol.starts_with("rt_") or symbol.starts_with("spl_"):
            runtime_symbols[symbol] = true

    if definition_counts.len() == 0:
        return Err("Stage4 compiler backfill defines no rt_cranelift_* symbols")
    for symbol in definition_counts.keys():
        val count = definition_counts[symbol]
        if count != 1:
            return Err("Stage4 compiler backfill export '" + symbol + "' must be defined exactly once")
    for symbol in runtime_symbols.keys():
        if not definition_counts.has(symbol):
            return Err("Stage4 compiler backfill source contains runtime/provider ownership outside the manifest: " + symbol)
    Ok(stage4_sorted_text(definition_counts.keys()))

pub fn stage4_compiler_backfill_localization_symbols(nm_output: text, object_format: text, manifest: [text]) -> Result<[text], text>:
    """Return raw closure-object definitions that must be localized."""
    if object_format != "elf" and object_format != "macho":
        return Err("Unsupported Stage4 compiler backfill object format '" + object_format + "'")
    if manifest.len() == 0:
        return Err("Stage4 compiler backfill manifest is empty")

    var manifest_symbols: Dict<text, bool> = {}
    var definition_counts: Dict<text, i64> = {}
    var localize: Dict<text, bool> = {}
    for symbol in manifest:
        if manifest_symbols.has(symbol):
            return Err("Stage4 compiler backfill manifest repeats export '" + symbol + "'")
        manifest_symbols[symbol] = true

    val nm_symbols = stage4_exact_nm_global_symbols(nm_output)
    val raw_definitions = nm_symbols.definitions
    val raw_undefined = nm_symbols.undefined
    for raw_symbol in raw_undefined:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if symbol.starts_with("rt_") or symbol.starts_with("spl_"):
            return Err("Stage4 compiler backfill closure has forbidden runtime dependency '" + symbol + "'")
    for raw_symbol in raw_definitions:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if manifest_symbols.has(symbol):
            definition_counts[symbol] = (definition_counts[symbol] ?? 0) + 1
        else:
            localize[raw_symbol] = true

    for symbol in manifest:
        val count = definition_counts[symbol] ?? 0
        if count != 1:
            return Err("Stage4 compiler backfill closure export '" + symbol + "' must be defined exactly once")
    Ok(stage4_sorted_text(localize.keys()))

pub fn stage4_validate_compiler_backfill_symbol_envelope(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the derived compiler-capsule symbol envelope without a manual manifest."""
    val manifest = match stage4_derive_compiler_backfill_manifest(nm_output, object_format):
        case Ok(symbols): symbols
        case Err(err): return Err(err)
    if manifest.contains("rt_cranelift_module_new") or manifest.contains("rt_cranelift_emit_object"):
        return Err("Stage4 compiler backfill retains an excluded compatibility wrapper")
    val localize = match stage4_compiler_backfill_localization_symbols(nm_output, object_format, manifest):
        case Ok(symbols): symbols
        case Err(err): return Err(err)
    if localize.len() != 0:
        return Err("Stage4 compiler backfill retains unexpected global definitions: " + localize.join(", "))
    Ok(())

pub fn stage4_dynload_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for a hosted dynamic-loader provider."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_runtime_native_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for the runtime-native archive."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_runtime_legacy_compat_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for the localized legacy compatibility archive."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_runtime_legacy_compat_exports() -> [text]:
    """Exact legacy helpers retained for runtime-native and emitted compiler calls."""
    [
        "rt_dir_remove_all", "rt_getcwd", "rt_is_dir", "rt_process_spawn_async",
        "rt_sleep_ms_native", "spl_env_get", "spl_file_read", "spl_panic",
        "spl_print", "spl_println", "spl_str_cmp", "spl_str_concat",
        "spl_strdup", "spl_str_index_of", "spl_str_len", "spl_str_new",
        "spl_str_replace", "spl_str_slice"
    ]

pub fn stage4_runtime_legacy_compat_localization_symbols(nm_output: text, object_format: text) -> Result<[text], text>:
    """Localize every raw legacy definition outside the audited 18-symbol ABI."""
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 runtime legacy compatibility object format '" + object_format + "'")
    val exports = stage4_runtime_legacy_compat_exports()
    var export_set: Dict<text, bool> = {}
    for symbol in exports:
        export_set[symbol] = true

    var definition_counts: Dict<text, i64> = {}
    var localize: [text] = []
    val (raw_definitions, raw_undefined) = stage4_exact_nm_global_symbols(nm_output)
    for raw_symbol in raw_definitions:
        if (object_format == "coff-msvc" or object_format == "coff-mingw") and raw_symbol == "@feat.00":
            continue
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        definition_counts[symbol] = (definition_counts[symbol] ?? 0) + 1
        if (definition_counts[symbol] ?? 0) != 1:
            return Err("Stage4 runtime legacy compatibility source repeats global definition '" + symbol + "'")
        if not export_set.has(symbol):
            localize = localize.push(raw_symbol)
    for symbol in exports:
        if (definition_counts[symbol] ?? 0) != 1:
            return Err("Stage4 runtime legacy compatibility source export '" + symbol + "' must exist exactly once")

    var runtime_undefined: Dict<text, bool> = {}
    for raw_symbol in raw_undefined:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if symbol.starts_with("rt_") or symbol.starts_with("spl_"):
            runtime_undefined[symbol] = true
    if runtime_undefined.len() != 1 or not runtime_undefined.has("rt_value_bool"):
        return Err("Stage4 runtime legacy compatibility source runtime dependencies differ from exact ABI: " + runtime_undefined.keys().join(", "))

    Ok(stage4_sorted_text(localize))

pub fn stage4_validate_runtime_legacy_compat_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Require exactly the 18 safe globals and the sole rt_value_bool dependency."""
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 runtime legacy compatibility object format '" + object_format + "'")
    val exports = stage4_runtime_legacy_compat_exports()
    var expected: Dict<text, bool> = {}
    for symbol in exports:
        expected[symbol] = true
    var definition_counts: Dict<text, i64> = {}
    val (raw_definitions, raw_undefined) = stage4_exact_nm_global_symbols(nm_output)
    for raw_symbol in raw_definitions:
        if (object_format == "coff-msvc" or object_format == "coff-mingw") and raw_symbol == "@feat.00":
            continue
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if not expected.has(symbol):
            return Err("Stage4 runtime legacy compatibility retained forbidden global definition '" + symbol + "'")
        definition_counts[symbol] = (definition_counts[symbol] ?? 0) + 1
    for symbol in exports:
        if (definition_counts[symbol] ?? 0) != 1:
            return Err("Stage4 runtime legacy compatibility export '" + symbol + "' must exist exactly once")

    var runtime_undefined: Dict<text, bool> = {}
    for raw_symbol in raw_undefined:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if symbol.starts_with("rt_") or symbol.starts_with("spl_"):
            runtime_undefined[symbol] = true
    if runtime_undefined.len() != 1 or not runtime_undefined.has("rt_value_bool"):
        return Err("Stage4 runtime legacy compatibility dependencies differ from exact ABI: " + runtime_undefined.keys().join(", "))
    Ok(())

pub fn stage4_process_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for the process provider."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_runtime_native_localization_symbols(nm_output: text, object_format: text) -> Result<[text], text>:
    """Return the raw legacy dynload definitions to localize in runtime_native."""
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 runtime-native object format '" + object_format + "'")
    val legacy = ["spl_dlclose", "spl_dlopen", "spl_dlsym"]
    val required = [
        "rt_http_download", "rt_http_get", "rt_http_request", "rt_interp_cstr",
        "rt_string_data", "rt_string_new", "rt_time_now_nanos", "rt_time_now_unix_micros"
    ]
    var counts: Dict<text, i64> = {}
    var raw_by_symbol: Dict<text, text> = {}
    val raw_definitions = stage4_exact_nm_global_symbols(nm_output).definitions
    for raw_symbol in raw_definitions:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        counts[symbol] = (counts[symbol] ?? 0) + 1
        raw_by_symbol[symbol] = raw_symbol
    for symbol in legacy:
        if (counts[symbol] ?? 0) != 1:
            return Err("Stage4 runtime-native legacy definition '" + symbol + "' must exist exactly once")
    for symbol in required:
        if (counts[symbol] ?? 0) != 1:
            return Err("Stage4 runtime-native required definition '" + symbol + "' must exist exactly once")
    var localize: [text] = []
    for symbol in legacy:
        localize = localize.push(raw_by_symbol[symbol])
    Ok(stage4_sorted_text(localize))

pub fn stage4_validate_runtime_native_core_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Require the core dependencies and forbid exported legacy dynload owners."""
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 runtime-native object format '" + object_format + "'")
    val legacy = ["spl_dlclose", "spl_dlopen", "spl_dlsym"]
    val required = [
        "rt_http_download", "rt_http_get", "rt_http_request", "rt_interp_cstr",
        "rt_string_data", "rt_string_new", "rt_time_now_nanos", "rt_time_now_unix_micros"
    ]
    var definitions: Dict<text, bool> = {}
    val raw_definitions = stage4_exact_nm_global_symbols(nm_output).definitions
    for raw_symbol in raw_definitions:
        definitions[stage4_provider_symbol(raw_symbol, object_format)] = true
    for symbol in legacy:
        if definitions.has(symbol):
            return Err("Stage4 runtime-native retained legacy provider definition '" + symbol + "'")
    for symbol in required:
        if not definitions.has(symbol):
            return Err("Stage4 runtime-native is missing required core definition '" + symbol + "'")
    Ok(())

pub fn stage4_font_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for a hosted font provider."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_memtrack_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for a hosted memtrack provider."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_time_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for a hosted time/progress provider."""
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_fork_provider_object_format(target_os_name: text, msvc_objects: bool) -> Result<text, text>:
    """Return the portable-nm contract for a POSIX fork-isolation provider."""
    if target_os_name == "windows":
        return Err("Stage4 fork isolation has no Windows provider")
    stage4_hosted_provider_object_format(target_os_name, msvc_objects)

pub fn stage4_validate_dynload_provider_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the exact dedicated dynamic-loader ABI from a portable nm scan."""
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 dynamic-loader object format '" + object_format + "'")

    var definitions: Dict<text, bool> = {}
    var undefined: Dict<text, bool> = {}
    for line in nm_output.split("\n"):
        val parts = stage4_split_whitespace(line)
        if parts.len() < 2:
            continue
        val type_index = parts.len() - 2
        val type_code = parts[type_index]
        val raw_symbol = parts[parts.len() - 1]
        if (object_format == "coff-msvc" or object_format == "coff-mingw") and raw_symbol == "@feat.00":
            continue
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        val is_undefined = type_code == "U" or ((type_code == "w" or type_code == "v") and not stage4_nm_has_address(parts, type_index))
        if is_undefined:
            if undefined.has(symbol):
                return Err("Stage4 dynamic-loader provider repeats undefined symbol '" + symbol + "'")
            undefined[symbol] = true
        elif stage4_nm_has_address(parts, type_index):
            if definitions.has(symbol):
                return Err("Stage4 dynamic-loader provider repeats global definition '" + symbol + "'")
            definitions[symbol] = true

    if definitions.len() != 3 or not definitions.has("spl_dlclose") or not definitions.has("spl_dlopen") or not definitions.has("spl_dlsym"):
        return Err("Stage4 dynamic-loader provider definitions differ from the exact ABI: " + definitions.keys().join(", "))
    if object_format == "coff-msvc" or object_format == "coff-mingw":
        if undefined.len() != 4 or not undefined.has("FreeLibrary") or not undefined.has("GetProcAddress") or not undefined.has("LoadLibraryA") or not undefined.has("rt_interp_cstr"):
            return Err("Stage4 dynamic-loader provider undefined symbols differ from the Windows contract: " + undefined.keys().join(", "))
    elif undefined.len() != 4 or not undefined.has("dlclose") or not undefined.has("dlopen") or not undefined.has("dlsym") or not undefined.has("rt_interp_cstr"):
        return Err("Stage4 dynamic-loader provider undefined symbols differ from the Unix contract: " + undefined.keys().join(", "))
    Ok(())

fn stage4_validate_runtime_provider_symbol_contract(nm_output: text, object_format: text, provider: text, expected: [text], required_runtime_dependencies: [text], allow_other_runtime_dependencies: bool = false) -> Result<(), text>:
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 " + provider + " object format '" + object_format + "'")
    var definitions: Dict<text, bool> = {}
    var required: Dict<text, bool> = {}
    var dependencies: Dict<text, bool> = {}
    for symbol in required_runtime_dependencies:
        required[symbol] = true
    for line in nm_output.split("\n"):
        val parts = stage4_split_whitespace(line)
        if parts.len() < 2:
            continue
        val type_index = parts.len() - 2
        val type_code = parts[type_index]
        val raw_symbol = parts[parts.len() - 1]
        if (object_format == "coff-msvc" or object_format == "coff-mingw") and raw_symbol == "@feat.00":
            continue
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        val is_undefined = type_code == "U" or ((type_code == "w" or type_code == "v") and not stage4_nm_has_address(parts, type_index))
        if is_undefined:
            if symbol.starts_with("rt_") or symbol.starts_with("spl_") or symbol == "g_memtrack_enabled":
                if not required.has(symbol):
                    if allow_other_runtime_dependencies:
                        continue
                    return Err("Stage4 " + provider + " provider has unexpected runtime dependency '" + symbol + "'")
                if dependencies.has(symbol):
                    return Err("Stage4 " + provider + " provider repeats runtime dependency '" + symbol + "'")
                dependencies[symbol] = true
        elif stage4_nm_has_address(parts, type_index):
            if definitions.has(symbol):
                return Err("Stage4 " + provider + " provider repeats global definition '" + symbol + "'")
            definitions[symbol] = true

    if definitions.len() != expected.len():
        return Err("Stage4 " + provider + " provider definitions differ from the exact ABI: " + definitions.keys().join(", "))
    for symbol in expected:
        if not definitions.has(symbol):
            return Err("Stage4 " + provider + " provider is missing exact ABI symbol '" + symbol + "'")
    for symbol in required_runtime_dependencies:
        if not dependencies.has(symbol):
            return Err("Stage4 " + provider + " provider is missing required runtime dependency '" + symbol + "'")
    Ok(())

pub fn stage4_validate_process_provider_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the exact process ABI; transitive resolution owns its runtime dependencies."""
    if object_format != "elf" and object_format != "macho" and object_format != "coff-msvc" and object_format != "coff-mingw":
        return Err("Unsupported Stage4 process object format '" + object_format + "'")
    var expected = [
        "rt_process_is_alive", "rt_process_read_stdout", "rt_process_run_bounded", "rt_process_run_timeout",
        "rt_process_spawn_piped", "rt_process_write_stdin"
    ]
    if object_format == "elf" or object_format == "macho":
        expected = expected + [
            "rt_editor_poll_simple_dap_stopped", "rt_editor_spawn_simple_dap",
            "rt_editor_start_simple_dap", "rt_editor_wait_simple_dap_stopped"
        ]
    stage4_validate_runtime_provider_symbol_contract(nm_output, object_format, "process", expected, [], true)

pub fn stage4_validate_font_provider_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the exact public font ABI and forbid hidden runtime dependencies."""
    stage4_validate_runtime_provider_symbol_contract(nm_output, object_format, "font", [
        "rt_font_load_bytes", "rt_font_load", "rt_font_free",
        "rt_font_glyph_bitmap", "rt_font_glyph_index", "rt_font_glyph_bitmap_index",
        "rt_font_bitmap_width", "rt_font_bitmap_height", "rt_font_bitmap_xoff",
        "rt_font_bitmap_yoff", "rt_font_bitmap_get_pixel", "rt_font_bitmap_free",
        "rt_font_glyph_advance", "rt_font_glyph_advance_index", "rt_font_line_height",
        "rt_font_ascent", "rt_font_descent", "rt_font_line_gap"
    ], [])

pub fn stage4_validate_memtrack_provider_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the exact public memtrack ABI and forbid hidden runtime dependencies."""
    stage4_validate_runtime_provider_symbol_contract(nm_output, object_format, "memtrack", [
        "g_memtrack_enabled", "spl_memtrack_enable", "spl_memtrack_disable",
        "spl_memtrack_is_enabled", "spl_memtrack_record", "spl_memtrack_unrecord",
        "spl_memtrack_snapshot", "spl_memtrack_dump_since", "spl_memtrack_live_count",
        "spl_memtrack_live_bytes", "spl_memtrack_reset", "spl_memtrack_count_since",
        "spl_memtrack_bytes_since", "spl_memtrack_set_listener", "spl_memtrack_clear_listener"
    ], [])

pub fn stage4_validate_time_provider_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the exact time/progress ABI and its target-specific core clock dependencies."""
    var clock_dependencies: [text] = []
    if object_format == "coff-msvc" or object_format == "coff-mingw":
        clock_dependencies = ["rt_time_now_unix_micros", "rt_time_now_nanos"]
    stage4_validate_runtime_provider_symbol_contract(nm_output, object_format, "time", [
        "rt_progress_get_elapsed_seconds", "rt_progress_init", "rt_progress_reset",
        "rt_time_now_seconds_f64", "rt_timestamp_add_days", "rt_timestamp_diff_days",
        "rt_timestamp_from_components", "rt_timestamp_get_day", "rt_timestamp_get_hour",
        "rt_timestamp_get_microsecond", "rt_timestamp_get_minute", "rt_timestamp_get_month",
        "rt_timestamp_get_second", "rt_timestamp_get_year"
    ], clock_dependencies)

pub fn stage4_validate_fork_provider_symbol_contract(nm_output: text, object_format: text) -> Result<(), text>:
    """Validate the exact fork-isolation ABI and its POSIX memtrack dependencies."""
    if object_format == "coff-msvc" or object_format == "coff-mingw":
        return Err("Stage4 fork isolation has no Windows provider")
    var memtrack_dependencies: [text] = []
    if object_format == "elf" or object_format == "macho":
        memtrack_dependencies = ["g_memtrack_enabled", "spl_memtrack_record", "spl_memtrack_unrecord"]
    stage4_validate_runtime_provider_symbol_contract(nm_output, object_format, "fork", [
        "rt_fork_child_setup", "rt_fork_parent_wait", "rt_fork_parent_wait_bounded", "rt_fork_parent_timed_out",
        "rt_fork_parent_signaled", "rt_fork_parent_stdout", "rt_fork_parent_stderr",
        "rt_fork_child_exit"
    ], memtrack_dependencies)

fn stage4_nm_has_address(parts: [text], type_index: i64) -> bool:
    if type_index <= 0:
        return false
    var address = parts[type_index - 1]
    val colon = address.last_index_of(":") ?? -1
    if colon >= 0:
        address = address.substring(colon + 1)
    if address == "":
        return false
    var i = 0
    while i < address.len():
        val digit = address[i:i + 1]
        if not ((digit >= "0" and digit <= "9") or
                (digit >= "a" and digit <= "f") or
                (digit >= "A" and digit <= "F")):
            return false
        i = i + 1
    true

pub fn stage4_requested_from_nm_output(nm_output: text, macho_prefixes: bool) -> [text]:
    """Return sorted strong runtime ABI requests not defined by sibling objects."""
    var defined: Dict<text, bool> = {}
    var undefined: Dict<text, bool> = {}
    for line in nm_output.split("\n"):
        val parts = stage4_split_whitespace(line)
        if parts.len() < 2:
            continue
        val type_index = parts.len() - 2
        val type_code = parts[type_index]
        val symbol = stage4_canonical_host_symbol(parts[parts.len() - 1], macho_prefixes)
        if not stage4_is_runtime_abi_symbol(symbol):
            continue
        if type_code == "U":
            undefined[symbol] = true
        elif type_code == "u" and stage4_nm_has_address(parts, type_index):
            defined[symbol] = true
        elif type_code != "w" and type_code != "v" and stage4_nm_has_address(parts, type_index):
            defined[symbol] = true

    var requested: [text] = []
    for symbol in undefined.keys():
        if not defined.has(symbol):
            requested = requested.push(symbol)
    stage4_sorted_text(requested)

fn stage4_global_definitions_from_nm_output(nm_output: text, macho_prefixes: bool, owner: text) -> Result<[text], text>:
    var seen: Dict<text, bool> = {}
    var definitions: [text] = []
    for line in nm_output.split("\n"):
        val parts = stage4_split_whitespace(line)
        if parts.len() < 3:
            continue
        val type_index = parts.len() - 2
        val type_code = parts[type_index]
        if type_code == "U" or not stage4_nm_has_address(parts, type_index):
            continue
        val symbol = stage4_canonical_host_symbol(parts[parts.len() - 1], macho_prefixes)
        if seen.has(symbol):
            return Err("Stage4 archive '" + owner + "' repeats global definition '" + symbol + "'")
        seen[symbol] = true
        definitions = definitions.push(symbol)
    if definitions.len() == 0:
        return Err("Stage4 archive '" + owner + "' has no global definitions")
    Ok(stage4_sorted_text(definitions))

pub fn stage4_validate_candidate_archive_inputs_for_platform(archive_labels: [text], archive_paths: [text], windows_paths: bool) -> Result<(), text>:
    """Validate the strict Stage4 candidate archive identity inputs."""
    if archive_labels.len() == 0 or archive_labels.len() != archive_paths.len():
        return Err("Stage4 archive labels and paths must be non-empty and have equal length")
    var labels_seen: Dict<text, bool> = {}
    var paths_seen: Dict<text, bool> = {}
    var i = 0
    while i < archive_labels.len():
        val label = archive_labels[i]
        val path = archive_paths[i]
        if label == "" or path == "":
            return Err("Stage4 archive label and path must be non-empty")
        val path_parts = path.replace("\\", "/").split("/")
        val file_name = path_parts[path_parts.len() - 1].lower()
        if (not file_name.ends_with(".a") and not file_name.ends_with(".lib")) or file_name.ends_with(".dll.a"):
            return Err("Stage4 candidate archive '" + label + "' uses an unsupported archive path: '" + path + "'")
        # Seed-parser compat: block-form `val x = if:` initializers and
        # unparenthesized multi-line booleans do not parse under the deployed
        # seed (known runtime limitation) — keep single-line forms here.
        var path_key = path
        if windows_paths:
            path_key = path.replace("\\", "/").lower()
        if labels_seen.has(label):
            return Err("Stage4 archive label '" + label + "' is repeated")
        if paths_seen.has(path_key):
            return Err("Stage4 archive path '" + path + "' is repeated")
        if (file_name == "libsimple_native_all.a" or file_name == "simple_native_all.lib" or
                file_name == "libsimple_runtime.a" or file_name == "simple_runtime.lib"):
            return Err("Stage4 candidate archive '" + label + "' uses forbidden aggregate path '" + path + "'")
        labels_seen[label] = true
        paths_seen[path_key] = true
        i = i + 1
    Ok(())

pub fn stage4_validate_candidate_archive_inputs(archive_labels: [text], archive_paths: [text]) -> Result<(), text>:
    stage4_validate_candidate_archive_inputs_for_platform(archive_labels, archive_paths, false)

pub fn stage4_forbidden_archive_sections(section_headers: text) -> [text]:
    """Return initializer/finalizer section families forbidden in Stage4 providers."""
    var found: [text] = []
    for section in [
        ".preinit_array", ".init_array", ".ctors", ".fini_array", ".dtors",
        "__mod_init_func", "__mod_term_func",
        ".CRT$XI", ".CRT$XC", ".CRT$XP", ".CRT$XT", ".CRT$XL"
    ]:
        if section_headers.contains(section):
            found.push(section)
    found

pub fn stage4_resolve_requested_archive_owners(requested: [text], archive_labels: [text], archive_nm_outputs: [text], macho_prefixes: bool) -> Result<([i64], [text]), text>:
    """Validate transitive runtime ownership and return selected archives plus owner rows."""
    if requested.len() == 0:
        return Err("Stage4 requested symbol closure is empty")
    if archive_labels.len() == 0 or archive_labels.len() != archive_nm_outputs.len():
        return Err("Stage4 archive labels and symbol scans must be non-empty and have equal length")

    var owner_by_symbol: Dict<text, i64> = {}
    var labels_seen: Dict<text, bool> = {}
    var archive_i = 0
    while archive_i < archive_labels.len():
        val label = archive_labels[archive_i]
        if label == "":
            return Err("Stage4 archive label is empty")
        if labels_seen.has(label):
            return Err("Stage4 archive label '" + label + "' is repeated")
        labels_seen[label] = true
        val definitions_result = stage4_global_definitions_from_nm_output(archive_nm_outputs[archive_i], macho_prefixes, label)
        val definitions = match definitions_result:
            case Ok(symbols): symbols
            case Err(err): return Err(err)
        for symbol in definitions:
            if owner_by_symbol.has(symbol):
                val previous_i = owner_by_symbol[symbol]
                return Err("Stage4 global definition '" + symbol + "' overlaps archives '" + archive_labels[previous_i] + "' and '" + label + "'")
            owner_by_symbol[symbol] = archive_i
        archive_i = archive_i + 1

    var requested_seen: Dict<text, bool> = {}
    var queued: Dict<text, bool> = {}
    var selected_by_index: Dict<i64, bool> = {}
    var expanded_by_index: Dict<i64, bool> = {}
    var owner_rows: [text] = []
    var pending_symbols: [text] = []
    var pending_sources: [text] = []
    for symbol in requested:
        if queued.has(symbol):
            continue
        queued[symbol] = true
        pending_symbols = pending_symbols.push(symbol)
        pending_sources = pending_sources.push("")

    var pending_i = 0
    while pending_i < pending_symbols.len():
        val symbol = pending_symbols[pending_i]
        val source = pending_sources[pending_i]
        pending_i = pending_i + 1
        if requested_seen.has(symbol):
            continue
        requested_seen[symbol] = true
        if not owner_by_symbol.has(symbol):
            if source != "":
                return Err("Stage4 archive '" + source + "' runtime dependency '" + symbol + "' has no archive owner")
            return Err("Stage4 requested symbol '" + symbol + "' has no archive owner")
        val owner_i = owner_by_symbol[symbol]
        selected_by_index[owner_i] = true
        owner_rows = owner_rows.push(symbol + "=" + archive_labels[owner_i])
        if not expanded_by_index.has(owner_i):
            expanded_by_index[owner_i] = true
            val dependencies = stage4_requested_from_nm_output(archive_nm_outputs[owner_i], macho_prefixes)
            for dependency in dependencies:
                if not queued.has(dependency):
                    queued[dependency] = true
                    pending_symbols = pending_symbols.push(dependency)
                    pending_sources = pending_sources.push(archive_labels[owner_i])

    var selected: [i64] = []
    archive_i = 0
    while archive_i < archive_labels.len():
        if selected_by_index.has(archive_i):
            selected = selected.push(archive_i)
        archive_i = archive_i + 1
    Ok((selected, stage4_sorted_text(owner_rows)))

pub fn stage4_select_requested_archive_indices(requested: [text], archive_labels: [text], archive_nm_outputs: [text], macho_prefixes: bool) -> Result<[i64], text>:
    """Validate unique symbol ownership and return selected archives in declared order."""
    match stage4_resolve_requested_archive_owners(requested, archive_labels, archive_nm_outputs, macho_prefixes):
        case Ok((selected, _)): Ok(selected)
        case Err(err): Err(err)

pub fn stage4_projection_localization_symbols(nm_output: text, object_format: text, requested: [text]) -> Result<[text], text>:
    """Return raw globals to localize so a Stage4 capsule exports only its requested roots."""
    if object_format != "elf" and object_format != "macho":
        return Err("Unsupported Stage4 projection object format '" + object_format + "'")
    if requested.len() == 0:
        return Err("Stage4 projection requested symbol set is empty")
    var expected: Dict<text, bool> = {}
    for symbol in requested:
        if not stage4_is_runtime_abi_symbol(symbol):
            return Err("Stage4 projection root '" + symbol + "' is not a runtime ABI symbol")
        if expected.has(symbol):
            return Err("Stage4 projection root '" + symbol + "' is repeated")
        expected[symbol] = true

    var counts: Dict<text, i64> = {}
    var localize: [text] = []
    val (raw_definitions, raw_undefined) = stage4_exact_nm_global_symbols(nm_output)
    for raw_symbol in raw_definitions:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        counts[symbol] = (counts[symbol] ?? 0) + 1
        if (counts[symbol] ?? 0) != 1:
            return Err("Stage4 projection closure repeats global definition '" + symbol + "'")
        if not expected.has(symbol):
            localize = localize.push(raw_symbol)
    for symbol in requested:
        if (counts[symbol] ?? 0) != 1:
            return Err("Stage4 projection root '" + symbol + "' must exist exactly once")
    for raw_symbol in raw_undefined:
        val symbol = stage4_provider_symbol(raw_symbol, object_format)
        if stage4_is_runtime_abi_symbol(symbol):
            return Err("Stage4 projection closure retains unresolved runtime symbol '" + symbol + "'")
    Ok(stage4_sorted_text(localize))

pub fn stage4_validate_projection_symbol_contract(nm_output: text, object_format: text, requested: [text]) -> Result<(), text>:
    """Require a projected capsule's global ABI to equal the requested roots exactly."""
    val localize = match stage4_projection_localization_symbols(nm_output, object_format, requested):
        case Ok(symbols): symbols
        case Err(err): return Err(err)
    if localize.len() != 0:
        return Err("Stage4 projection retained unexpected global definitions: " + localize.join(", "))
    Ok(())

fn stage4_canonical_fingerprint_rows(group: text, rows: [text]) -> Result<[text], text>:
    if rows.len() == 0:
        return Err("Stage4 link profile " + group + " rows are empty")
    var names: Dict<text, bool> = {}
    var canonical: [text] = []
    for row in rows:
        val separator = row.index_of("=") ?? -1
        if separator <= 0 or separator >= row.len() - 1:
            return Err("Stage4 link profile " + group + " row must be non-empty name=value")
        val name = row.substring(0, separator)
        if names.has(name):
            return Err("Stage4 link profile " + group + " repeats name '" + name + "'")
        names[name] = true
        canonical = canonical.push(row)
    Ok(stage4_sorted_text(canonical))

pub fn stage4_link_profile_fingerprint_input(target: text, backend: text, link_options: text, compiler_hash: text, source_hash_rows: [text], archive_hash_rows: [text], owner_rows: [text]) -> Result<text, text>:
    """Return the versioned canonical input for a separate Stage4 link-profile hash."""
    if target == "" or backend == "" or link_options == "" or compiler_hash == "":
        return Err("Stage4 link profile scalar fields must be non-empty")

    val source_result = stage4_canonical_fingerprint_rows("source hash", source_hash_rows)
    val sources = match source_result:
        case Ok(rows): rows
        case Err(err): return Err(err)
    val archive_result = stage4_canonical_fingerprint_rows("archive hash", archive_hash_rows)
    val archives = match archive_result:
        case Ok(rows): rows
        case Err(err): return Err(err)
    val owner_result = stage4_canonical_fingerprint_rows("owner", owner_rows)
    val owners = match owner_result:
        case Ok(rows): rows
        case Err(err): return Err(err)

    var input = "stage4-link-profile-v1"
    input = input + "\ntarget[{target.len()}]=" + target
    input = input + "\nbackend[{backend.len()}]=" + backend
    input = input + "\nlink_options[{link_options.len()}]=" + link_options
    input = input + "\ncompiler_hash[{compiler_hash.len()}]=" + compiler_hash
    for row in sources:
        input = input + "\nsource_hash[{row.len()}]=" + row
    for row in archives:
        input = input + "\narchive_hash[{row.len()}]=" + row
    for row in owners:
        input = input + "\nowner[{row.len()}]=" + row
    Ok(input)
