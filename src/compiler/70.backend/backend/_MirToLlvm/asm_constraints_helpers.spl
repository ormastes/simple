# Part 3 of src/compiler/70.backend/backend/mir_to_llvm.spl
use compiler.backend.backend.mir_to_llvm.*
# MIR to LLVM IR Translation
#
# MirToLlvm class that translates MIR to LLVM IR.
# Implements MirTextCodegen trait for shared instruction dispatch.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}
use compiler.mir.mir_lowering.{bootstrap_mir_function_count, bootstrap_mir_function_at, bootstrap_mir_function_name_at}
use compiler.backend.backend_api.*
use compiler.backend.backend.llvm_target.{LlvmTargetTriple, LlvmTargetConfig}
use compiler.backend.llvm_type_mapper.LlvmTypeMapper
use compiler.backend.llvm_ir_builder.{LlvmIRBuilder, natural_alignment, is_integer_type, is_signed_int_type, is_float_type,
    llvm_ir_builder_build}
use compiler.backend.common.mir_text_codegen.MirTextCodegen

extern fn rt_env_get(key: text) -> text

var _llvm_bootstrap_string_global_text: text = ""

fn llvm_bootstrap_string_globals_reset():
    _llvm_bootstrap_string_global_text = ""

fn llvm_bootstrap_string_globals_text() -> text:
    _llvm_bootstrap_string_global_text ?? ""

fn llvm_bootstrap_string_globals_add(decl: text):
    val current = _llvm_bootstrap_string_global_text ?? ""
    if current == "":
        _llvm_bootstrap_string_global_text = decl
    else:
        _llvm_bootstrap_string_global_text = "{current}\n{decl}"

# ============================================================================
# MIR to LLVM IR Translation
# ============================================================================

impl MirToLlvm:

    me emit_aes2_intrinsic(dest: LocalId?, llvm_name: text, args: [MirOperand]):
        """Emit a 2-operand AES-NI intrinsic: <16 x i8> @llvm_name(<16 x i8>, <16 x i8>).

        The MIR args are i64 locals; we bitcast them to <16 x i8> before the
        call and bitcast the result back to the dest local type.
        """
        val vec_ty = "<2 x i64>"
        val arg0_raw = self.translate_operand(args[0])
        val arg1_raw = self.translate_operand(args[1])
        val bc0 = self.builder.fresh_local()
        val bc1 = self.builder.fresh_local()
        val nit = self.native_int()
        self.builder.emit("  {bc0} = bitcast {nit} {arg0_raw} to {vec_ty}  ; aes arg0")
        self.builder.emit("  {bc1} = bitcast {nit} {arg1_raw} to {vec_ty}  ; aes arg1")
        match dest:
            Some(dest_local):
                val dest_id = self.local_id_value(dest_local)
                val dest_name = self.get_local(dest_id)
                val ret_ty = self.valid_llvm_type(self.get_local_type(dest_id))
                val raw_result = self.builder.fresh_local()
                self.builder.emit("  {raw_result} = call {vec_ty} @{llvm_name}({vec_ty} {bc0}, {vec_ty} {bc1})")
                self.builder.emit("  {dest_name} = bitcast {vec_ty} {raw_result} to {ret_ty}  ; aes result")
            nil:
                self.builder.emit("  call {vec_ty} @{llvm_name}({vec_ty} {bc0}, {vec_ty} {bc1})")

    me emit_sha256_rnds2_intrinsic(dest: LocalId?, args: [MirOperand]):
        """Emit @llvm.x86.sha256rnds2(<4 x i32>, <4 x i32>, <4 x i32>).

        sha256rnds2 takes three <4 x i32> operands (the third is the W schedule
        implicit input). MIR passes 3 args: [dst_acc, src, w_xmm0].
        """
        val vec_ty = "<2 x i64>"
        val arg0_raw = self.translate_operand(args[0])
        val arg1_raw = self.translate_operand(args[1])
        val arg2_raw = self.translate_operand(args[2])
        val bc0 = self.builder.fresh_local()
        val bc1 = self.builder.fresh_local()
        val bc2 = self.builder.fresh_local()
        val nit = self.native_int()
        self.builder.emit("  {bc0} = bitcast {nit} {arg0_raw} to {vec_ty}  ; sha256 arg0")
        self.builder.emit("  {bc1} = bitcast {nit} {arg1_raw} to {vec_ty}  ; sha256 arg1")
        self.builder.emit("  {bc2} = bitcast {nit} {arg2_raw} to {vec_ty}  ; sha256 w")
        match dest:
            Some(dest_local):
                val dest_id = self.local_id_value(dest_local)
                val dest_name = self.get_local(dest_id)
                val ret_ty = self.valid_llvm_type(self.get_local_type(dest_id))
                val raw_result = self.builder.fresh_local()
                self.builder.emit("  {raw_result} = call {vec_ty} @llvm.x86.sha256rnds2({vec_ty} {bc0}, {vec_ty} {bc1}, {vec_ty} {bc2})")
                self.builder.emit("  {dest_name} = bitcast {vec_ty} {raw_result} to {ret_ty}  ; sha256 result")
            nil:
                self.builder.emit("  call {vec_ty} @llvm.x86.sha256rnds2({vec_ty} {bc0}, {vec_ty} {bc1}, {vec_ty} {bc2})")

    me emit_crc32_intrinsic(dest: LocalId?, llvm_name: text, acc_ty: text, src_ty: text, args: [MirOperand]):
        """Emit a CRC32 scalar intrinsic: i32 @llvm_name(i32, i8|i32).

        MIR args are i64; truncate to the required scalar widths.
        """
        val nit = self.native_int()
        val arg0_raw = self.translate_operand(args[0])
        val arg1_raw = self.translate_operand(args[1])
        val tc0 = self.builder.fresh_local()
        val tc1 = self.builder.fresh_local()
        self.builder.emit("  {tc0} = trunc {nit} {arg0_raw} to {acc_ty}  ; crc32 acc")
        self.builder.emit("  {tc1} = trunc {nit} {arg1_raw} to {src_ty}  ; crc32 src")
        match dest:
            Some(dest_local):
                val dest_id = self.local_id_value(dest_local)
                val dest_name = self.get_local(dest_id)
                val ret_ty = self.valid_llvm_type(self.get_local_type(dest_id))
                val raw_result = self.builder.fresh_local()
                self.builder.emit("  {raw_result} = call {acc_ty} @{llvm_name}({acc_ty} {tc0}, {src_ty} {tc1})")
                self.builder.emit("  {dest_name} = zext {acc_ty} {raw_result} to {ret_ty}  ; crc32 result")
            nil:
                self.builder.emit("  call {acc_ty} @{llvm_name}({acc_ty} {tc0}, {src_ty} {tc1})")

    me emit_clmul_intrinsic(dest: LocalId?, args: [MirOperand], imm8: text):
        """Emit @llvm.x86.pclmulqdq(<2 x i64>, <2 x i64>, i8 immarg).

        imm8 = "0" for clmul_lo (low × low), "17" for clmul_hi (high × high).
        MIR args are i64 locals; bitcast to <2 x i64>.
        """
        val vec_ty = "<2 x i64>"
        val nit = self.native_int()
        val arg0_raw = self.translate_operand(args[0])
        val arg1_raw = self.translate_operand(args[1])
        val bc0 = self.builder.fresh_local()
        val bc1 = self.builder.fresh_local()
        self.builder.emit("  {bc0} = bitcast {nit} {arg0_raw} to {vec_ty}  ; clmul arg0")
        self.builder.emit("  {bc1} = bitcast {nit} {arg1_raw} to {vec_ty}  ; clmul arg1")
        match dest:
            Some(dest_local):
                val dest_id = self.local_id_value(dest_local)
                val dest_name = self.get_local(dest_id)
                val ret_ty = self.valid_llvm_type(self.get_local_type(dest_id))
                val raw_result = self.builder.fresh_local()
                self.builder.emit("  {raw_result} = call {vec_ty} @llvm.x86.pclmulqdq({vec_ty} {bc0}, {vec_ty} {bc1}, i8 {imm8})")
                self.builder.emit("  {dest_name} = bitcast {vec_ty} {raw_result} to {ret_ty}  ; clmul result")
            nil:
                self.builder.emit("  call {vec_ty} @llvm.x86.pclmulqdq({vec_ty} {bc0}, {vec_ty} {bc1}, i8 {imm8})")

    me emit_runtime_declarations():
        """Emit declarations required by the textual LLVM backend."""
        self.builder.emit("declare ptr @rt_get_args()")
        self.builder.emit("declare ptr @rt_env_get(...)")
        self.builder.emit("declare ptr @rt_env_get_value(i64)")
        self.builder.emit("declare void @rt_print(ptr)")
        self.builder.emit("declare void @rt_println(ptr)")
        self.builder.emit("declare void @rt_panic(ptr)")
        self.builder.emit("declare ptr @rt_array_new(i64)")
        self.builder.emit("declare void @rt_array_free(ptr)")
        self.builder.emit("declare i64 @rt_array_len(ptr)")
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            self.builder.emit("declare ptr @rt_array_get(ptr, i64)")
        else:
            self.builder.emit("declare i64 @rt_array_get(ptr, i64)")
        self.builder.emit("declare void @rt_array_set(ptr, i64, i64)")
        self.builder.emit("declare i8 @rt_array_push(ptr, i64)")
        self.builder.emit("declare i8 @rt_array_clear(ptr)")
        # Bug #149: `rt_array_repeat` (backs `[value; count]` fill literals)
        # had no static override here, so it fell back to the generic
        # `declare i64 @name(...)` auto-declare in core_codegen's
        # unknown_func_decls pass. Every call site (translate_call's
        # `known_ret_ty` registration) then registered its result as i64,
        # while the MIR-declared destination local (Array kind, from
        # lower_array_repeat) primed `ptr_locals` to true for that same id
        # -- a stale-flag mismatch (local defined `i64` but later treated as
        # `ptr` by a copy or a subsequent `.len()`/index call argument) that
        # produced invalid IR ("defined with type 'i64' but expected 'ptr'").
        # rt_array_repeat genuinely returns `SplArray*` in C (same as
        # rt_array_new), so declare it `ptr` here to match every other
        # array-handle-returning rt_array_* function above.
        self.builder.emit("declare ptr @rt_array_repeat(i64, i64)")
        self.builder.emit("declare i64 @__simple_intrinsic_bounds_check(i64, i64)")
        self.builder.emit("declare ptr @rt_engine2d_simd_fill_row_u32(i64, i64)")
        self.builder.emit("declare ptr @rt_engine2d_simd_fill_rows_u32(i64, i64, i64, i64)")
        self.builder.emit("declare ptr @rt_engine2d_simd_copy_row_u32(ptr)")
        self.builder.emit("declare ptr @rt_engine2d_simd_blend_row_u32(ptr, ptr)")
        self.builder.emit("declare i64 @rt_engine2d_simd_row_probe()")
        self.builder.emit("declare i64 @rt_simd_engine2d_neon_hits()")
        self.builder.emit("declare i64 @rt_simd_engine2d_neon_reset()")
        # Enum runtime: exact portable C ABI.
        self.builder.emit("declare i64 @rt_enum_new(i32, i32, i64)")
        self.builder.emit("declare i64 @rt_enum_id(i64)")
        self.builder.emit("declare i64 @rt_enum_discriminant(i64)")
        self.builder.emit("declare i8 @rt_enum_check_discriminant(i64, i64)")
        self.builder.emit("declare i64 @rt_enum_payload(i64)")
        # Dict runtime (tagged i64 handle; keys/values are the flat i64 ABI).
        # rt_dict_set/rt_dict_contains return int8_t in C, declared i64 here to
        # match the discarded MIR i64 call result (same i64-widening philosophy
        # as the enum block above). String helpers tag a raw char* literal key
        # into a heap RtCoreString so rt_native_eq compares by content.
        self.builder.emit("declare i64 @rt_dict_new(i64)")
        self.builder.emit("declare i64 @rt_dict_get(i64, i64)")
        self.builder.emit("declare i64 @rt_dict_set(i64, i64, i64)")
        self.builder.emit("declare i64 @rt_dict_contains(i64, i64)")
        self.builder.emit("declare i64 @rt_strlen(ptr)")
        self.builder.emit("declare ptr @rt_strcat(ptr, ptr)")
        # Concat-drop fix: rt_strcat_tagged is the tagged-result counterpart of
        # rt_strcat used by the `+` binop lowering (expr_dispatch.spl
        # bin_is_str_concat) -- the C signature is `int64_t
        # rt_strcat_tagged(int64_t, int64_t)`, but declared `ptr` here (not
        # `i64`) to match the Opaque("str") MIR type the call site uses for
        # both operands and the result (same "ptr" mapping llvm_type_mapper.spl
        # gives every Opaque(_) type). x86-64 SysV passes/returns a pointer and
        # an i64 in the same integer register, so this is ABI-identical to an
        # i64 declaration.
        self.builder.emit("declare ptr @rt_strcat_tagged(ptr, ptr)")
        # Bug #136: string interpolation coerces each `{expr}` result to a raw
        # C string via rt_interp_cstr before rt_strcat splices it (see MIR
        # lower_string_interpolation).
        self.builder.emit("declare ptr @rt_interp_cstr(i64)")
        self.builder.emit("declare i64 @rt_text_eq_any(i64, i64)")
        self.builder.emit("declare i64 @rt_text_cmp_any(i64, i64)")
        self.builder.emit("declare i64 @rt_raw_u64_to_string(i64)")
        self.builder.emit("declare i64 @rt_raw_i64_to_string(i64)")
        # native print(bool) divergence fix: bool-typed print args must render
        # "true"/"false", not the decimal 0/1 rt_raw_i64_to_string would give
        # (see lower_bootstrap_print_call in switch_operators_calls.spl).
        self.builder.emit("declare i64 @rt_raw_bool_to_string(i64)")
        # native print(float) SIGSEGV fix: F32/F64-typed print args must
        # render an oracle-matching decimal string via rt_raw_f64_to_string
        # (see lower_bootstrap_print_call in switch_operators_calls.spl); the
        # actual call-site arg type is the operand's own MIR type (double),
        # independent of this `declare`'s i64 (same as rt_raw_bool_to_string
        # above -- see translate_call's param_ty lookup in core_codegen.spl).
        self.builder.emit("declare i64 @rt_raw_f64_to_string(double)")
        self.builder.emit("declare i64 @rt_string_new(ptr, i64)")
        self.builder.emit("declare i64 @__simple_rt_string_char_code_at(i64, i64)")
        # bootstrap_main's whole body is one extern call; without this declare
        # the .ll references @rt_native_build undefined and llc rejects the
        # module (the symbol itself is defined in libsimple_native_all.a).
        self.builder.emit("declare i64 @rt_native_build(ptr)")
        # Process externs are rewritten by translate_call to the
        # runtime_native.c *_tuple facades (see the remap comment there):
        # cmd is one tagged-or-raw text value (i64), args the [text] array
        # handle (ptr), and the result is the rt_alloc'd 3-i64-word tuple
        # block the Tuple destructure loads expect -- hence `ptr` returns.
        self.builder.emit("declare ptr @rt_process_run_tuple(i64, ptr)")
        self.builder.emit("declare ptr @rt_process_run_bounded_tuple(i64, ptr, i64, i64)")
        self.builder.emit("declare i64 @rt_process_run_inherit_value(i64, ptr)")
        self.builder.emit("declare ptr @rt_process_run_timeout_tuple(i64, ptr, i64)")
        # Register EVERY name declared above so the auto-declare pass in
        # core_codegen never emits a conflicting duplicate declare for them.
        self.defined_func_names["rt_get_args"] = true
        self.defined_func_names["rt_env_get"] = true
        self.defined_func_names["rt_env_get_value"] = true
        self.defined_func_names["rt_print"] = true
        self.defined_func_names["rt_println"] = true
        self.defined_func_names["rt_panic"] = true
        self.defined_func_names["__simple_intrinsic_bounds_check"] = true
        self.defined_func_names["rt_interp_cstr"] = true
        self.defined_func_names["rt_text_eq_any"] = true
        self.defined_func_names["rt_text_cmp_any"] = true
        self.defined_func_names["rt_raw_u64_to_string"] = true
        self.defined_func_names["rt_raw_i64_to_string"] = true
        self.defined_func_names["rt_raw_bool_to_string"] = true
        self.defined_func_names["rt_raw_f64_to_string"] = true
        self.defined_func_names["__simple_rt_string_char_code_at"] = true
        # Register param types so the arg-coercion in translate_call /
        # CallTerminator actually fires for these callees: without an entry
        # here, lookup_function_param_type returns "" and a narrower-than-i64
        # arg (i8/i16/i32/u8/u16/u32) is passed with NO explicit sext/zext,
        # silently relying on x86-64's zero-extend-on-32-bit-write register
        # behavior -- correct by accident for unsigned values, wrong for
        # negative signed ones (i32 -5 printed as 4294967291).
        self.remember_function_param_types("rt_raw_i64_to_string", ["i64"])
        self.remember_function_param_types("rt_raw_u64_to_string", ["i64"])
        self.remember_function_param_types("rt_raw_bool_to_string", ["i64"])
        self.remember_function_param_types("rt_text_eq_any", ["i64", "i64"])
        self.remember_function_param_types("rt_text_cmp_any", ["i64", "i64"])
        self.remember_function_param_types("rt_env_get_value", ["i64"])
        self.remember_function_return_type("rt_env_get_value", "ptr")
        self.remember_function_param_types("__simple_rt_string_char_code_at", ["i64", "i64"])
        self.remember_function_return_type("__simple_rt_string_char_code_at", "i64")
        # Process tuple facades: register param types so translate_call
        # coerces the cmd text value (a ptr-typed local) to the declared
        # i64 param, and the return type so the destructured tuple local
        # is tracked as ptr.
        self.defined_func_names["rt_process_run_tuple"] = true
        self.defined_func_names["rt_process_run_bounded_tuple"] = true
        self.defined_func_names["rt_process_run_inherit_value"] = true
        self.defined_func_names["rt_process_run_timeout_tuple"] = true
        self.remember_function_param_types("rt_process_run_tuple", ["i64", "ptr"])
        self.remember_function_param_types("rt_process_run_bounded_tuple", ["i64", "ptr", "i64", "i64"])
        self.remember_function_param_types("rt_process_run_inherit_value", ["i64", "ptr"])
        self.remember_function_param_types("rt_process_run_timeout_tuple", ["i64", "ptr", "i64"])
        self.remember_function_return_type("rt_process_run_tuple", "ptr")
        self.remember_function_return_type("rt_process_run_bounded_tuple", "ptr")
        self.remember_function_return_type("rt_process_run_inherit_value", "i64")
        self.remember_function_return_type("rt_process_run_timeout_tuple", "ptr")
        self.defined_func_names["rt_array_new"] = true
        self.defined_func_names["rt_array_free"] = true
        self.defined_func_names["rt_array_len"] = true
        self.defined_func_names["rt_array_get"] = true
        self.defined_func_names["rt_array_set"] = true
        self.defined_func_names["rt_array_push"] = true
        self.defined_func_names["rt_array_clear"] = true
        self.defined_func_names["rt_array_repeat"] = true
        self.remember_function_param_types("rt_array_free", ["ptr"])
        self.remember_function_return_type("rt_array_free", "void")
        self.remember_function_param_types("rt_array_clear", ["ptr"])
        self.remember_function_return_type("rt_array_clear", "i8")
        self.defined_func_names["rt_engine2d_simd_fill_row_u32"] = true
        self.defined_func_names["rt_engine2d_simd_fill_rows_u32"] = true
        self.defined_func_names["rt_engine2d_simd_copy_row_u32"] = true
        self.defined_func_names["rt_engine2d_simd_blend_row_u32"] = true
        self.defined_func_names["rt_engine2d_simd_row_probe"] = true
        self.defined_func_names["rt_simd_engine2d_neon_hits"] = true
        self.defined_func_names["rt_simd_engine2d_neon_reset"] = true
        self.defined_func_names["rt_enum_new"] = true
        self.defined_func_names["rt_enum_id"] = true
        self.defined_func_names["rt_enum_discriminant"] = true
        self.defined_func_names["rt_enum_check_discriminant"] = true
        self.defined_func_names["rt_enum_payload"] = true
        self.defined_func_names["rt_dict_new"] = true
        self.defined_func_names["rt_dict_get"] = true
        self.defined_func_names["rt_dict_set"] = true
        self.defined_func_names["rt_dict_contains"] = true
        self.defined_func_names["rt_strlen"] = true
        self.defined_func_names["rt_strcat"] = true
        self.defined_func_names["rt_strcat_tagged"] = true
        self.defined_func_names["rt_string_new"] = true
        self.defined_func_names["rt_native_build"] = true
        self.builder.emit("")

    me add_string_global(value: text) -> text:
        """Register a string constant and return its LLVM global name."""
        val id = self.string_counter
        self.string_counter = self.string_counter + 1
        val global_name = "@.str.{id}"
        val escaped = escape_llvm_string(value)
        val str_len = escaped_string_byte_len(value) + 1
        val decl = "{global_name} = private unnamed_addr constant [{str_len} x i8] c\"{escaped}\\00\""
        if (rt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
            llvm_bootstrap_string_globals_add(decl)
        self.string_globals = self.string_globals.push(decl)
        if self.string_global_text.len() == 0:
            self.string_global_text = decl
        else:
            self.string_global_text = "{self.string_global_text}\n{decl}"
        global_name

    me emit_unsupported_panic(message: text):
        """Emit a hard runtime panic instead of silently lowering unsupported ops."""
        val global_name = self.add_string_global(message)
        val str_len = escaped_string_byte_len(message) + 1
        val ptr_name = self.builder.fresh_local()
        self.builder.emit("  {ptr_name} = getelementptr inbounds [{str_len} x i8], ptr {global_name}, i64 0, i64 0")
        self.builder.emit("  call void @rt_panic(ptr {ptr_name})")
        self.builder.emit("  unreachable")

    fn select_cast_instruction(src_ty: text, target_ty: text) -> text:
        """Select the appropriate LLVM cast instruction based on source and target types."""
        if src_ty == "i8" and (target_ty == "i16" or target_ty == "i32" or target_ty == "i64"):
            return "sext"
        if src_ty == "i16" and (target_ty == "i32" or target_ty == "i64"):
            return "sext"
        if src_ty == "i32" and target_ty == "i64":
            return "sext"
        if src_ty == "i64" and (target_ty == "i32" or target_ty == "i16" or target_ty == "i8"):
            return "trunc"
        if src_ty == "i32" and (target_ty == "i16" or target_ty == "i8"):
            return "trunc"
        if src_ty == "i16" and target_ty == "i8":
            return "trunc"
        if src_ty == "i1" and (target_ty == "i8" or target_ty == "i16" or target_ty == "i32" or target_ty == "i64"):
            return "zext"
        if (src_ty == "i8" or src_ty == "i16" or src_ty == "i32" or src_ty == "i64") and target_ty == "i1":
            return "trunc"
        if (src_ty == "i8" or src_ty == "i16" or src_ty == "i32" or src_ty == "i64") and target_ty == "double":
            return "sitofp"
        if (src_ty == "i8" or src_ty == "i16" or src_ty == "i32" or src_ty == "i64") and target_ty == "float":
            return "sitofp"
        if (src_ty == "double" or src_ty == "float") and (target_ty == "i8" or target_ty == "i16" or target_ty == "i32" or target_ty == "i64"):
            return "fptosi"
        if src_ty == "float" and target_ty == "double":
            return "fpext"
        if src_ty == "double" and target_ty == "float":
            return "fptrunc"
        if src_ty == "ptr" and (target_ty == "i32" or target_ty == "i64"):
            return "ptrtoint"
        if (src_ty == "i32" or src_ty == "i64") and target_ty == "ptr":
            return "inttoptr"
        "bitcast"

    fn build_output_constraint(output: MirAsmOperand) -> text:
        """Build LLVM constraint string for output operand."""
        val prefix = match output.kind:
            case Out: "="
            case LateOut: "=&"
            case InOut: "+"
            case _: "="
        val location = self.constraint_location(output.location)
        "{prefix}{location}"

    fn build_input_constraint(input: MirAsmOperand) -> text:
        """Build LLVM constraint string for input operand."""
        self.constraint_location(input.location)

    fn constraint_location(location: AsmLocation) -> text:
        """Convert AsmLocation to LLVM constraint code."""
        match location:
            case Reg: "r"
            case Mem: "m"
            case Imm: "i"
            case RegSpec(name): "{{name}}"

    me emit_comparison(dest_name: text, dest_ty: text, cmp_pred: text, cmp_ty: text, left_val: text, right_val: text):
        """Emit comparison with proper type handling.

        Uses fcmp for float types, icmp for integer/ptr types.
        Extends i1 result to dest_ty if needed (zext).
        """
        val cmp_prefix = if is_float_type(cmp_ty): "fcmp" else: "icmp"

        if dest_ty == "i1":
            self.builder.emit("  {dest_name} = {cmp_prefix} {cmp_pred} {cmp_ty} {left_val}, {right_val}")
        elif dest_ty == "ptr":
            # zext i1 -> ptr is an invalid cast opcode; go through i64.
            val tmp = self.builder.fresh_local()
            val tmp_int = self.builder.fresh_local()
            self.builder.emit("  {tmp} = {cmp_prefix} {cmp_pred} {cmp_ty} {left_val}, {right_val}")
            self.builder.emit("  {tmp_int} = zext i1 {tmp} to i64")
            self.builder.emit("  {dest_name} = inttoptr i64 {tmp_int} to ptr")
        else:
            val tmp = self.builder.fresh_local()
            self.builder.emit("  {tmp} = {cmp_prefix} {cmp_pred} {cmp_ty} {left_val}, {right_val}")
            self.builder.emit("  {dest_name} = zext i1 {tmp} to {dest_ty}")

# ============================================================================
# Free Helper Functions
# ============================================================================

fn escape_llvm_string(value: text) -> text:
    """Escape special characters in strings for LLVM IR c\"...\" format.

    LLVM IR uses \\xx hex escapes for non-printable characters.
    """
    var s = value
    s = s.replace("\\", "\\5C")
    s = s.replace("\n", "\\0A")
    s = s.replace("\r", "\\0D")
    s = s.replace("\t", "\\09")
    s = s.replace("\"", "\\22")
    s

fn escaped_string_byte_len(value: text) -> i64:
    """Compute byte length of original string (not escaped) for LLVM array size."""
    value.len()

fn ensure_float_literal(s: text) -> text:
    """Ensure a float value string is valid for LLVM IR.

    LLVM IR requires float literals to have a decimal point or exponent.
    Converts '3' to '3.0' if needed.
    """
    if s.contains(".") or s.contains("e") or s.contains("E") or s.contains("inf") or s.contains("nan"):
        s
    else:
        "{s}.0"
