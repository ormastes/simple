# Part 1 of src/compiler/70.backend/backend/mir_to_llvm.spl
use compiler.backend.backend.mir_to_llvm.*
# MIR to LLVM IR Translation
#
# MirToLlvm class that translates MIR to LLVM IR.
# Implements MirTextCodegen trait for shared instruction dispatch.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}
use compiler.mir.mir_lowering.{bootstrap_mir_function_count, bootstrap_mir_function_at, bootstrap_mir_function_name_at}
use compiler.backend.backend_api.*
use compiler.backend.backend.llvm_target.{LlvmTargetTriple, LlvmTargetConfig}
use compiler.backend.llvm_type_mapper.{LlvmTypeMapper, llvm_type_mapper_create_for_target}
use compiler.backend.llvm_ir_builder.{LlvmIRBuilder, natural_alignment, is_integer_type, is_signed_int_type, is_float_type,
    llvm_ir_builder_build}
use compiler.backend.common.mir_text_codegen.MirTextCodegen
use compiler.mir.mir_call_ownership.{mir_runtime_owned_call_name, mir_runtime_owned_local_symbol}

extern fn rt_env_get(key: text) -> text

# ============================================================================
# MIR to LLVM IR Translation
# ============================================================================

class MirToLlvm:
    """Translates MIR to LLVM IR."""
    builder: LlvmIRBuilder
    local_map: Dict
    config: LlvmTargetConfig
    type_mapper: LlvmTypeMapper
    string_globals: [text]
    string_global_text: text
    string_counter: i64
    local_types: Dict<i64, text>
    value_types: Dict<text, text>
    defined_locals: Dict<i64, bool>
    return_locals: Dict<i64, bool>
    bool_locals: Dict<i64, bool>
    ptr_locals: Dict<i64, bool>
    # Element LLVM type per alloca slot local (var_reassign_ssa spill slots).
    # Load/Store through a slot must use THIS type: the SSA pass's fresh
    # load/store temps have no MirLocal entry, so get_local_type falls back to
    # i64 and an f64 slot value would round-trip through fptosi (data loss).
    alloca_elem_types: Dict<i64, text>
    # Unsigned bit for the alloca slot's declared MIR type (U8/U16/U32/U64),
    # parallel to alloca_elem_types. Needed because llvm_type_text collapses
    # I8/U8 (etc) to the same LLVM text type "i8" -- the LLVM type string
    # alone can't tell a sext-on-widen call site (signed) from a
    # zext-on-widen one (unsigned). See select_widen_instruction.
    alloca_elem_unsigned: Dict<i64, bool>
    # Per-value-local unsigned flag, propagated from alloca_elem_unsigned at
    # Load time (see translate_load) and set directly for Const/Cast dests.
    unsigned_locals: Dict<i64, bool>
    function_return_types: Dict<text, text>
    # Unsigned bit for a function's declared return type (U8/U16/U32/U64),
    # parallel to function_return_types. See is_unsigned_mir_kind: a Call's
    # dest local needs this to widen a narrower-than-i64 unsigned return
    # value correctly (e.g. print(fn_returning_u8())).
    function_return_unsigned: Dict<text, bool>
    function_param_types: Dict<text, [text]>
    unknown_func_decls: Dict<text, bool>
    defined_func_names: Dict<text, bool>
    native_int_type: text      # "i32" for 32-bit targets, "i64" for 64-bit
    current_return_type: text
    current_function_name: text
    current_bootstrap_module: i64
    entry_main_symbol: bool
    no_mangle: bool
    # mutglobal lane (module-level `var` mutation storage, see
    # scratchpad/mutglobal_plan.md): SymbolId.id -> the real `@name` LLVM
    # global emitted for that MirModule.statics entry, and its LLVM element
    # type -- populated by translate_module's static-declaration pass,
    # consumed by LoadGlobal/StoreGlobal translation.
    global_static_names: Dict<text, text>
    global_static_types: Dict<text, text>
    # Runtime-owned names (see mir_call_ownership.spl) that this module ALSO
    # defines a local function for -- populated once at the start of
    # translate_module. Non-empty membership is what triggers the local
    # definition's private-symbol mangling (see llvm_function_symbol_name)
    # so a compiler-generated hardcoded runtime call keeps sole ownership of
    # the bare symbol.
    owned_name_has_local: Dict<text, bool>

    fn native_int() -> text:
        """Return the native integer type for the current target."""
        self.native_int_type

    fn llvm_function_symbol_name(name: text) -> text:
        if name == "main":
            if self.entry_main_symbol:
                return "__simple_main"
            return "__simple_main_" + self.builder.module_name.replace(".", "_")
        if self.no_mangle:
            return name
        if mir_runtime_owned_call_name(name) and self.owned_name_has_local.has(name):
            return mir_runtime_owned_local_symbol(name)
        name

    fn is_unsigned_mir_kind(kind: MirTypeKind) -> bool:
        """True for U8/U16/U32/U64 -- the MIR-level distinction llvm_type_text
        collapses (both I32 and U32 map to the LLVM text type "i32"). Needed
        wherever a narrower-than-target value is widened: unsigned sources
        must zext, signed sources must sext, and the collapsed LLVM type
        string alone can no longer tell them apart."""
        match kind:
            case MirTypeKind.U8 | MirTypeKind.U16 | MirTypeKind.U32 | MirTypeKind.U64:
                true
            case _:
                false

    fn llvm_type_text(ty: MirType) -> text:
        val kind: MirTypeKind = ty.kind
        match kind:
            case MirTypeKind.I64 | MirTypeKind.U64: return "i64"
            case MirTypeKind.I32 | MirTypeKind.U32 | MirTypeKind.Char: return "i32"
            case MirTypeKind.I16 | MirTypeKind.U16: return "i16"
            case MirTypeKind.I8 | MirTypeKind.U8: return "i8"
            case MirTypeKind.F64: return "double"
            case MirTypeKind.F32: return "float"
            case MirTypeKind.Bool: return "i1"
            case MirTypeKind.Unit | MirTypeKind.Never: return "void"
            case MirTypeKind.Ptr(_, _) | MirTypeKind.Ref(_, _) | MirTypeKind.FuncPtr(_) | MirTypeKind.Function(_, _) | MirTypeKind.Opaque(_):
                return "ptr"
            case MirTypeKind.Struct(_) | MirTypeKind.Enum(_) | MirTypeKind.Tuple(_) | MirTypeKind.Array(_, _) | MirTypeKind.Dict(_, _) | MirTypeKind.Slice(_) | MirTypeKind.Union(_):
                return "ptr"
            case MirTypeKind.Promise(_) | MirTypeKind.Generator(_, _) | MirTypeKind.ActorType(_):
                return "ptr"
            case _:
                return self.native_int_type

    static fn create(module_name: text, target: CodegenTarget, cpu_override: text?) -> MirToLlvm:
        val config: LlvmTargetConfig = LlvmTargetConfig.for_target_portable_numeric(target, cpu_override)
        val nit = if target.is_32bit(): "i32" else: "i64"
        MirToLlvm(
            builder: LlvmIRBuilder.create(module_name, config.triple),
            local_map: {},
            config: config,
            type_mapper: llvm_type_mapper_create_for_target(target),
            string_globals: [],
            string_global_text: "",
            string_counter: 0,
            local_types: {},
            value_types: {},
            defined_locals: {},
            return_locals: {},
            bool_locals: {},
            ptr_locals: {},
            alloca_elem_types: {},
            alloca_elem_unsigned: {},
            unsigned_locals: {},
            function_return_types: {},
            function_return_unsigned: {},
            function_param_types: {},
            unknown_func_decls: {},
            defined_func_names: {},
            native_int_type: nit,
            current_return_type: "void",
            current_function_name: "",
            current_bootstrap_module: -1,
            entry_main_symbol: true,
            no_mangle: (rt_env_get("SIMPLE_NATIVE_BUILD_NO_MANGLE") ?? "") == "1",
            global_static_names: {},
            global_static_types: {},
            owned_name_has_local: {}
        )

    static fn create_baremetal(module_name: text, target: CodegenTarget, cpu_override: text?) -> MirToLlvm:
        """Create MIR->LLVM translator for bare-metal targets."""
        val config = LlvmTargetConfig.for_target_portable_numeric_baremetal(target, cpu_override)
        val builder = LlvmIRBuilder.create(module_name, config.triple)
        val nit = if target.is_32bit(): "i32" else: "i64"

        builder.emit_baremetal_attributes()

        MirToLlvm(
            builder: builder,
            local_map: {},
            config: config,
            type_mapper: llvm_type_mapper_create_for_target(target),
            string_globals: [],
            string_global_text: "",
            string_counter: 0,
            local_types: {},
            value_types: {},
            defined_locals: {},
            return_locals: {},
            bool_locals: {},
            ptr_locals: {},
            alloca_elem_types: {},
            alloca_elem_unsigned: {},
            unsigned_locals: {},
            function_return_types: {},
            function_return_unsigned: {},
            function_param_types: {},
            unknown_func_decls: {},
            defined_func_names: {},
            native_int_type: nit,
            current_return_type: "void",
            current_function_name: "",
            current_bootstrap_module: -1,
            entry_main_symbol: true,
            no_mangle: (rt_env_get("SIMPLE_NATIVE_BUILD_NO_MANGLE") ?? "") == "1",
            global_static_names: {},
            global_static_types: {},
            owned_name_has_local: {}
        )

# ============================================================================
# MirTextCodegen Trait Implementation
# ============================================================================
