# Part 1 of src/compiler/70.backend/backend/mir_to_llvm.spl
use compiler.backend.backend.mir_to_llvm.*
# MIR to LLVM IR Translation
#
# MirToLlvm class that translates MIR to LLVM IR.
# Implements MirTextCodegen trait for shared instruction dispatch.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}
use compiler.mir.mir_lowering.{bootstrap_mir_function_count, bootstrap_mir_function_at, bootstrap_mir_function_name_at}
use compiler.backend.backend_api.*
use compiler.backend.backend.llvm_target.{LlvmTargetTriple, LlvmTargetConfig}
use compiler.backend.llvm_type_mapper.{LlvmTypeMapper, llvm_type_mapper_create_for_target}
use compiler.backend.llvm_ir_builder.{LlvmIRBuilder, natural_alignment, is_integer_type, is_signed_int_type, is_float_type,
    llvm_ir_builder_build}
use compiler.backend.common.mir_text_codegen.MirTextCodegen

extern fn rt_env_get(key: text) -> text

# ============================================================================
# MIR to LLVM IR Translation
# ============================================================================

class MirToLlvm:
    """Translates MIR to LLVM IR."""
    builder: LlvmIRBuilder
    local_map: Dict
    config: LlvmTargetConfig
    type_mapper: LlvmTypeMapper
    string_globals: [text]
    string_global_text: text
    string_counter: i64
    local_types: Dict<i64, text>
    value_types: Dict<text, text>
    defined_locals: Dict<i64, bool>
    return_locals: Dict<i64, bool>
    bool_locals: Dict<i64, bool>
    ptr_locals: Dict<i64, bool>
    # Element LLVM type per alloca slot local (var_reassign_ssa spill slots).
    # Load/Store through a slot must use THIS type: the SSA pass's fresh
    # load/store temps have no MirLocal entry, so get_local_type falls back to
    # i64 and an f64 slot value would round-trip through fptosi (data loss).
    alloca_elem_types: Dict<i64, text>
    function_return_types: Dict<text, text>
    function_param_types: Dict<text, [text]>
    unknown_func_decls: Dict<text, bool>
    defined_func_names: Dict<text, bool>
    native_int_type: text      # "i32" for 32-bit targets, "i64" for 64-bit
    current_return_type: text
    current_function_name: text
    entry_main_symbol: bool

    fn native_int() -> text:
        """Return the native integer type for the current target."""
        self.native_int_type

    fn llvm_function_symbol_name(name: text) -> text:
        if name != "main":
            return name
        if self.entry_main_symbol:
            return "__simple_main"
        "__simple_main_" + self.builder.module_name.replace(".", "_")

    fn llvm_type_text(ty: MirType) -> text:
        if ty == nil:
            return self.native_int_type
        match ty.kind:
            case I64 | U64: "i64"
            case I32 | U32 | Char: "i32"
            case I16 | U16: "i16"
            case I8 | U8: "i8"
            case F64: "double"
            case F32: "float"
            case Bool: "i1"
            case Unit | Never: "void"
            case Ptr(_, _) | Ref(_, _) | FuncPtr(_) | Function(_, _) | Opaque(_):
                "ptr"
            case Struct(_) | Enum(_) | Tuple(_) | Array(_, _) | Dict(_, _) | Slice(_) | Union(_):
                "ptr"
            case Promise(_) | Generator(_, _) | ActorType(_):
                "ptr"
            case _:
                self.native_int_type

    static fn create(module_name: text, target: CodegenTarget, cpu_override: text?) -> MirToLlvm:
        val config = LlvmTargetConfig.for_target_portable_numeric(target, cpu_override)
        val nit = if target.is_32bit(): "i32" else: "i64"
        MirToLlvm(
            builder: LlvmIRBuilder.create(module_name, config.triple),
            local_map: {},
            config: config,
            type_mapper: llvm_type_mapper_create_for_target(target),
            string_globals: [],
            string_global_text: "",
            string_counter: 0,
            local_types: {},
            value_types: {},
            defined_locals: {},
            return_locals: {},
            bool_locals: {},
            ptr_locals: {},
            alloca_elem_types: {},
            function_return_types: {},
            function_param_types: {},
            unknown_func_decls: {},
            defined_func_names: {},
            native_int_type: nit,
            current_return_type: "void",
            current_function_name: "",
            entry_main_symbol: true
        )

    static fn create_baremetal(module_name: text, target: CodegenTarget, cpu_override: text?) -> MirToLlvm:
        """Create MIR->LLVM translator for bare-metal targets."""
        val config = LlvmTargetConfig.for_target_portable_numeric_baremetal(target, cpu_override)
        val builder = LlvmIRBuilder.create(module_name, config.triple)
        val nit = if target.is_32bit(): "i32" else: "i64"

        builder.emit_baremetal_attributes()

        MirToLlvm(
            builder: builder,
            local_map: {},
            config: config,
            type_mapper: llvm_type_mapper_create_for_target(target),
            string_globals: [],
            string_global_text: "",
            string_counter: 0,
            local_types: {},
            value_types: {},
            defined_locals: {},
            return_locals: {},
            bool_locals: {},
            ptr_locals: {},
            alloca_elem_types: {},
            function_return_types: {},
            function_param_types: {},
            unknown_func_decls: {},
            defined_func_names: {},
            native_int_type: nit,
            current_return_type: "void",
            current_function_name: "",
            entry_main_symbol: true
        )

# ============================================================================
# MirTextCodegen Trait Implementation
# ============================================================================
