# VHDL Backend - Validation, Package, and Tuple Type Registration
#
# Validation rules for MIR-to-VHDL lowering, package emission,
# and tuple type handling. Extension of VhdlBackend via impl block.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock, MirTerminator}
use compiler.backend.backend_api.*
use compiler.backend.backend.backend_types.{BackendKind, CompileError, compileerror_backend_error}
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.vhdl_type_mapper.VhdlTypeMapper
use compiler.backend.vhdl.vhdl_builder.{VhdlBuilder}
use .vhdl.vhdl_builder.{VhdlBuilder}
use .vhdl.vhdl_helpers.{vhdl_sanitize_identifier, vhdl_function_is_hardware_entity, vhdl_helper_is_procedure, vhdl_helper_collision_message, vhdl_function_is_runtime_module_initializer}
use compiler.common.diagnostics.span.{Span}
use .vhdl_backend.{VhdlBackend, VhdlPortSpec, VhdlReturnField, VhdlReturnAbi}

impl VhdlBackend:
    fn backend_error(message: text) -> CompileError:
        compileerror_backend_error(BackendKind.Vhdl, message)

    fn backend_error_at(message: text, span: Span?) -> CompileError:
        var err = self.backend_error(message)
        match span:
            case Some(value):
                err.has_location = true
                err.location = value.to_range_string()
            case None:
                ()
        err

    fn unsupported_type_error(ty: MirType, context: text, span: Span?) -> CompileError?:
        val diagnostic = self.type_mapper.unsupported_mir_type_diagnostic(ty, context)
        match diagnostic:
            case Some(message):
                Some(self.backend_error_at(message, span))
            case None:
                nil

    fn module_has_vhdl_hardware(module: MirModule) -> bool:
        for symbol in module.functions.keys():
            if vhdl_function_is_hardware_entity(module.functions[symbol]):
                return true
        false

    fn direct_vhdl_call_target(operand: MirOperand) -> text?:
        match operand.kind:
            case Const(value, _):
                match value:
                    case Str(name): Some(name)
                    case _: nil
            case _: nil

    fn helper_local_is_mutable(func: MirFunction, id: LocalId) -> bool:
        for local in func.locals:
            if local.id.id == id.id:
                match local.kind:
                    case Var | Temp | Return: return true
                    case Arg(_): return false
        false

    fn helper_block_shape_supported(func: MirFunction, block_id: BlockId, blocks: Dict<i64, MirBlock>, seen: [i64]) -> bool:
        for prior in seen:
            if prior == block_id.id:
                return false
        if not blocks.has(block_id.id):
            return false
        val block = blocks[block_id.id]
        for inst in block.instructions:
            match inst.kind:
                case Const(_, _, _) | Copy(_, _) | Move(_, _) | BinOp(_, _, _, _) | CheckedBinOp(_, _, _, _) | UnaryOp(_, _, _) | Cast(_, _, _) | Bitcast(_, _, _) | Aggregate(_, _, _) | GetField(_, _, _) | VhdlResize(_, _, _, _) | VhdlSlice(_, _, _, _) | VhdlConcat(_, _) | Nop:
                    ()
                case SetField(base, _, _):
                    match base.kind:
                        case Copy(local) | Move(local):
                            if not self.helper_local_is_mutable(func, local):
                                return false
                        case _: return false
                case Call(_, operand, _):
                    val target = self.direct_vhdl_call_target(operand)
                    if not target.? or not self.active_function_by_name.has(target.unwrap()):
                        return false
                    val callee = self.active_function_by_name[target.unwrap()]
                    if vhdl_function_is_hardware_entity(callee) and callee.vhdl_metadata.has_clocked:
                        return false
                case _:
                    return false
        var next_seen = seen
        next_seen = next_seen.push(block_id.id)
        match block.terminator:
            case Ret(_): true
            case Goto(target): self.helper_block_shape_supported(func, target, blocks, next_seen)
            case If(_, then_, else_):
                self.helper_block_shape_supported(func, then_, blocks, next_seen) and self.helper_block_shape_supported(func, else_, blocks, next_seen)
            case Switch(_, targets, default):
                for target in targets:
                    if not self.helper_block_shape_supported(func, target.target, blocks, next_seen):
                        return false
                self.helper_block_shape_supported(func, default, blocks, next_seen)
            case _: false

    fn helper_subprogram_shape_supported(func: MirFunction) -> bool:
        var blocks: Dict<i64, MirBlock> = {}
        for block in func.blocks:
            blocks[block.id.id] = block
        self.helper_block_shape_supported(func, func.entry_block, blocks, [])

    fn helper_call_reaches(from: text, target: text, seen: [text]) -> bool:
        if from == target:
            return true
        for prior in seen:
            if prior == from:
                return false
        val known = self.active_function_by_name.get(from)
        if not known.? or not self.active_helper_name_by_source.has(from):
            return false
        var next_seen = seen
        next_seen = next_seen.push(from)
        for block in known.unwrap().blocks:
            for inst in block.instructions:
                match inst.kind:
                    case Call(_, operand, _):
                        val callee = self.direct_vhdl_call_target(operand)
                        if callee.? and self.active_helper_name_by_source.has(callee.unwrap()):
                            if self.helper_call_reaches(callee.unwrap(), target, next_seen):
                                return true
                    case _: ()
        false

    fn validate_helper_call_cycles() -> Result<(), CompileError>:
        for caller_name in self.active_helper_name_by_source.keys():
            val caller = self.active_function_by_name[caller_name]
            for block in caller.blocks:
                for inst in block.instructions:
                    match inst.kind:
                        case Call(_, operand, _):
                            val callee = self.direct_vhdl_call_target(operand)
                            if callee.? and self.active_helper_name_by_source.has(callee.unwrap()):
                                val callee_name = callee.unwrap()
                                if self.helper_call_reaches(callee_name, caller_name, [caller_name]):
                                    return Err(self.backend_error("Recursive VHDL helper call cycle `{caller_name}` -> `{callee_name}` is not synthesizable"))
                        case _: ()
        Ok(())

    me prepare_helper_subprograms(module: MirModule) -> Result<(), CompileError>:
        var used: Dict<text, text> = {}
        var helper_reachable: Dict<text, bool> = {}
        self.active_helper_name_by_source = {}
        # Role rule: a direct @hardware child of a clocked product entry is an
        # entity/port-map boundary. Every other direct call made by hardware is
        # an in-process helper candidate, including annotated unclocked leaves.
        for symbol in module.functions.keys():
            val caller = module.functions[symbol]
            if not vhdl_function_is_hardware_entity(caller):
                continue
            for block in caller.blocks:
                for inst in block.instructions:
                    match inst.kind:
                        case Call(_, operand, _):
                            val target = self.direct_vhdl_call_target(operand)
                            if target.? and self.active_function_by_name.has(target.unwrap()):
                                val callee = self.active_function_by_name[target.unwrap()]
                                val entity_boundary = caller.vhdl_metadata.has_clocked and vhdl_function_is_hardware_entity(callee)
                                if not entity_boundary:
                                    helper_reachable[target.unwrap()] = true
                        case _: ()
        var changed = true
        while changed:
            changed = false
            for symbol in module.functions.keys():
                val caller = module.functions[symbol]
                if not helper_reachable.has(caller.name):
                    continue
                for block in caller.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case Call(_, operand, _):
                                val target = self.direct_vhdl_call_target(operand)
                                if target.? and self.active_function_by_name.has(target.unwrap()):
                                    val callee = self.active_function_by_name[target.unwrap()]
                                    if vhdl_function_is_hardware_entity(callee) and callee.vhdl_metadata.has_clocked:
                                        continue
                                    if not helper_reachable.has(target.unwrap()):
                                        helper_reachable[target.unwrap()] = true
                                        changed = true
                            case _: ()
        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            if vhdl_function_is_runtime_module_initializer(func):
                continue
            if not helper_reachable.has(func.name) or not self.helper_subprogram_shape_supported(func):
                continue
            val safe_name = vhdl_sanitize_identifier(func.name)
            val prior = used.get(safe_name)
            if prior != nil:
                return Err(self.backend_error(vhdl_helper_collision_message(safe_name, prior, func.name)))
            used[safe_name] = func.name
            self.active_helper_name_by_source[func.name] = safe_name
        Ok(())

    fn validate_module_supported_before_emit(module: MirModule, hardware_mode: bool) -> Result<(), CompileError>:
        match self.validate_hardware_call_cycles(module):
            case Ok(_): ()
            case Err(err): return Err(err)
        match self.validate_helper_call_cycles():
            case Ok(_): ()
            case Err(err): return Err(err)
        for symbol in module.types.keys():
            match self.validate_type_def_supported_before_emit(module.types[symbol]):
                case Ok(_): ()
                case Err(err): return Err(err)
        for symbol in module.constants.keys():
            val constant = module.constants[symbol]
            match self.validate_vhdl_value_type_supported(constant.type_, "constant `{constant.name}`", nil):
                case Ok(_): ()
                case Err(err): return Err(err)
            match self.validate_vhdl_constant_supported_before_emit(constant.value, constant.type_, "constant `{constant.name}`", nil):
                case Ok(_): ()
                case Err(err): return Err(err)
        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            if hardware_mode:
                if vhdl_function_is_hardware_entity(func):
                    match self.validate_function_supported_before_emit(func, false):
                        case Ok(_): ()
                        case Err(err): return Err(err)
                elif self.active_helper_name_by_source.get(func.name).?:
                    match self.validate_function_supported_before_emit(func, true):
                        case Ok(_): ()
                        case Err(err): return Err(err)
            else:
                match self.validate_function_supported_before_emit(func, false):
                    case Ok(_): ()
                    case Err(err): return Err(err)
        Ok(())

    fn validate_type_def_supported_before_emit(type_def: MirTypeDef) -> Result<(), CompileError>:
        match type_def.kind:
            case Struct(fields):
                for field in fields:
                    match self.validate_vhdl_value_type_supported(field.type_, "field `{type_def.name}.{field.name}`", nil):
                        case Ok(_): ()
                        case Err(err): return Err(err)
                Ok(())
            case Enum(variants):
                for variant in variants:
                    match variant.payload:
                        case Some(payload):
                            match self.validate_vhdl_value_type_supported(payload, "payload `{type_def.name}.{variant.name}`", nil):
                                case Ok(_): ()
                                case Err(err): return Err(err)
                        case None:
                            ()
                Ok(())
            case Union(members):
                for member in members:
                    match self.validate_vhdl_value_type_supported(member, "union member `{type_def.name}`", nil):
                        case Ok(_): ()
                        case Err(err): return Err(err)
                Ok(())

    me validate_vhdl_value_type_supported(ty: MirType, context: text, span: Span?) -> Result<(), CompileError>:
        match self.unsupported_type_error(ty, context, span):
            case Some(err): return Err(err)
            case None: ()
        match ty.kind:
            case Array(element, _):
                self.validate_vhdl_value_type_supported(element, context, span)
            case Tuple(elements):
                for element in elements:
                    match self.validate_vhdl_value_type_supported(element, context, span):
                        case Ok(_): ()
                        case Err(err): return Err(err)
                Ok(())
            case Union(members):
                for member in members:
                    match self.validate_vhdl_value_type_supported(member, context, span):
                        case Ok(_): ()
                        case Err(err): return Err(err)
                Ok(())
            case _:
                Ok(())

    me validate_vhdl_constant_supported_before_emit(value: MirConstValue, ty: MirType, context: text, span: Span?) -> Result<(), CompileError>:
        match self.unsupported_type_error(ty, context, span):
            case Some(err): return Err(err)
            case None: ()
        match value:
            case Float(_):
                Err(self.backend_error_at("VHDL backend does not support floating-point {context}; floating-point constants require explicit fixed-point or integer lowering before VHDL emission", span))
            case _:
                Ok(())

    fn validate_function_supported_before_emit(func: MirFunction, is_helper: bool) -> Result<(), CompileError>:
        var idx = 0
        while idx < func.signature.params.len():
            match self.validate_vhdl_value_type_supported(func.signature.params[idx], "input port `arg{idx}`", Some(func.span)):
                case Ok(_): ()
                case Err(err): return Err(err)
            idx = idx + 1
        if func.signature.return_type.kind != MirTypeKind.Unit:
            match self.validate_hardware_output_abi_supported(func):
                case Ok(_): ()
                case Err(err): return Err(err)
            match self.validate_vhdl_value_type_supported(func.signature.return_type, "output port", Some(func.span)):
                case Ok(_): ()
                case Err(err): return Err(err)
        for local in func.locals:
            match local.kind:
                case Var | Temp:
                    match self.validate_vhdl_value_type_supported(local.type_, "local signal", Some(func.span)):
                        case Ok(_): ()
                        case Err(err): return Err(err)
                case _:
                    ()
        var blocks: Dict<i64, MirBlock> = {}
        for block in func.blocks:
            blocks[block.id.id] = block
        val allow_clocked_state = func.has_vhdl_metadata and func.vhdl_metadata.has_clocked and not func.vhdl_metadata.clocked.has_reset
        if allow_clocked_state and self.function_static_symbols(func).len() > 0:
            match self.validate_clocked_state_owner(func, blocks):
                case Ok(_): pass
                case Err(err): return Err(err)
        for block in func.blocks:
            match self.validate_block_supported_before_emit(block, blocks, is_helper, allow_clocked_state):
                case Ok(_): ()
                case Err(err): return Err(err)
        Ok(())

    fn validate_clocked_state_owner(func: MirFunction, blocks: Dict<i64, MirBlock>) -> Result<(), CompileError>:
        if not blocks.has(func.entry_block.id):
            return Err(self.backend_error("VHDL clocked state owner `{func.name}` has no entry block"))
        val entry = blocks[func.entry_block.id]
        match entry.terminator:
            case If(condition, reset_path, feedback_path):
                if not self.clocked_entry_condition_is_active_low_reset(func, entry, condition):
                    return Err(self.backend_error("VHDL clocked global state owner `{func.name}` requires `if not reset_n` as its entry reset guard"))
                for symbol in self.function_static_symbols(func):
                    if not self.active_statics.has(symbol.id):
                        return Err(self.backend_error("VHDL global state references unknown static symbol {symbol.id}"))
                    val state_name = self.active_statics[symbol.id].name
                    for inst in entry.instructions:
                        match inst.kind:
                            case LoadGlobal(_, accessed) | StoreGlobal(accessed, _):
                                if accessed.id == symbol.id:
                                    return Err(self.backend_error("VHDL clocked state `{state_name}` cannot be accessed before the reset/feedback branch"))
                            case _:
                                ()
                    val reset_access = self.block_path_static_access_order(reset_path, symbol, blocks, [], 0)
                    if reset_access != 2:
                        return Err(self.backend_error("VHDL clocked state `{state_name}` reset branch must store an initial value without loading prior state"))
                    val feedback_access = self.block_path_static_access_order(feedback_path, symbol, blocks, [], 0)
                    if feedback_access != 3:
                        return Err(self.backend_error("VHDL clocked state `{state_name}` feedback branch must load once before its final store; store-then-load is not supported"))
                Ok(())
            case _:
                Err(self.backend_error("VHDL clocked global state owner `{func.name}` requires an explicit entry reset/feedback branch"))

    fn clocked_entry_condition_is_active_low_reset(func: MirFunction, entry: MirBlock, condition: MirOperand) -> bool:
        var reset_local = -1
        for local in func.locals:
            match local.kind:
                case Arg(_):
                    if (local.name ?? "") == "reset_n" and local.type_.kind == MirTypeKind.Bool:
                        reset_local = local.id.id
                case _:
                    ()
        if reset_local < 0:
            return false
        val condition_local = self.mir_operand_use_id(condition)
        if condition_local < 0:
            return false
        for inst in entry.instructions:
            match inst.kind:
                case UnaryOp(dest, Not, operand):
                    if dest.id == condition_local and self.mir_operand_use_id(operand) == reset_local:
                        return true
                case _:
                    ()
        false

    fn block_path_static_access_order(block_id: BlockId, symbol: SymbolId, blocks: Dict<i64, MirBlock>, seen: [i64], phase: i64) -> i64:
        for prior in seen:
            if prior == block_id.id:
                return -1
        if not blocks.has(block_id.id):
            return -1
        val block = blocks[block_id.id]
        var next_phase = phase
        for inst in block.instructions:
            match inst.kind:
                case LoadGlobal(_, loaded):
                    if loaded.id == symbol.id:
                        if next_phase == 0:
                            next_phase = 1
                        elif next_phase >= 2:
                            return -1
                case StoreGlobal(stored, _):
                    if stored.id == symbol.id:
                        if next_phase == 0:
                            next_phase = 2
                        elif next_phase == 1:
                            next_phase = 3
                        else:
                            return -1
                case _:
                    ()
        match block.terminator:
            case Goto(next):
                var next_seen = seen
                next_seen = next_seen.push(block_id.id)
                self.block_path_static_access_order(next, symbol, blocks, next_seen, next_phase)
            case Ret(_):
                next_phase
            case _:
                -1

    fn validate_hardware_output_abi_supported(func: MirFunction) -> Result<(), CompileError>:
        if not vhdl_function_is_hardware_entity(func):
            return Ok(())
        match func.signature.return_type.kind:
            case Tuple(elements):
                if not func.has_vhdl_metadata:
                    return Err(self.backend_error_at("Anonymous VHDL hardware tuple outputs require labels; write the return type as `(name: type, ...)` so output ports have a stable public API", Some(func.span)))
                val fields = func.vhdl_metadata.return_fields
                if fields.len() < elements.len():
                    return Err(self.backend_error_at("Anonymous VHDL hardware tuple outputs require labels; write the return type as `(name: type, ...)` so output ports have a stable public API", Some(func.span)))
                var field_index = 0
                while field_index < elements.len():
                    if fields[field_index].label.trim() == "":
                        return Err(self.backend_error_at("Anonymous VHDL hardware tuple outputs require labels; write the return type as `(name: type, ...)` so output ports have a stable public API", Some(func.span)))
                    field_index = field_index + 1
                Ok(())
            case _:
                Ok(())

    fn validate_block_supported_before_emit(block: MirBlock, blocks: Dict<i64, MirBlock>, is_helper: bool, allow_clocked_state: bool) -> Result<(), CompileError>:
        for inst in block.instructions:
            match self.validate_instruction_supported_before_emit(inst, blocks, is_helper, allow_clocked_state):
                case Ok(_): ()
                case Err(err): return Err(err)
        Ok(())

    fn validate_instruction_supported_before_emit(inst: MirInst, blocks: Dict<i64, MirBlock>, is_helper: bool, allow_clocked_state: bool) -> Result<(), CompileError>:
        if is_helper:
            match inst.kind:
                case Const(_, _, _) | Copy(_, _) | Move(_, _) | BinOp(_, _, _, _) | CheckedBinOp(_, _, _, _) | UnaryOp(_, _, _) | Cast(_, _, _) | Bitcast(_, _, _) | Aggregate(_, _, _) | GetField(_, _, _) | SetField(_, _, _) | VhdlResize(_, _, _, _) | VhdlSlice(_, _, _, _) | VhdlConcat(_, _) | Nop:
                    Ok(())
                case Call(_, func, _):
                    self.validate_call_supported_before_emit(func)
                case _:
                    Err(self.unsupported_vhdl_helper_instruction_error(inst))
        else:
            match inst.kind:
                case Const(_, _, _) | Copy(_, _) | Move(_, _) | BinOp(_, _, _, _) | CheckedBinOp(_, _, _, _) | UnaryOp(_, _, _) | Aggregate(_, _, _) | GetField(_, _, _) | SetField(_, _, _) | Cast(_, _, _) | Bitcast(_, _, _) | VhdlSignalAssign(_, _, _) | VhdlVarAssign(_, _) | VhdlPortMap(_, _, _) | VhdlResize(_, _, _, _) | VhdlSlice(_, _, _, _) | VhdlConcat(_, _) | Nop:
                    Ok(())
                case VhdlProcess(_, body_block):
                    val block = blocks.get(body_block.id)
                    if block.?:
                        self.validate_block_supported_before_emit(block, blocks, false, allow_clocked_state)
                    else:
                        Err(self.backend_error("VHDL process references unknown block BB{body_block.id}"))
                case Call(_, func, _):
                    self.validate_call_supported_before_emit(func)
                case LoadGlobal(_, symbol):
                    self.validate_clocked_static_access(symbol, allow_clocked_state, inst.span)
                case StoreGlobal(symbol, _):
                    self.validate_clocked_static_access(symbol, allow_clocked_state, inst.span)
                case _:
                    Err(self.unsupported_vhdl_instruction_error(inst))

    fn validate_clocked_static_access(symbol: SymbolId, allow_clocked_state: bool, span: Span?) -> Result<(), CompileError>:
        if not allow_clocked_state:
            return Err(self.backend_error_at("VHDL global state access requires an @clocked(clk, none) @hardware entity with an explicit source reset branch", span))
        if not self.active_statics.has(symbol.id):
            return Err(self.backend_error_at("VHDL global state references unknown static symbol {symbol.id}", span))
        val static_ = self.active_statics[symbol.id]
        if not static_.is_mutable:
            return Err(self.backend_error_at("VHDL global state `{static_.name}` must be a mutable module var", span))
        match self.validate_clocked_static_type(static_.type_, static_.name, [], span):
            case Ok(_): pass
            case Err(err): return Err(err)
        Ok(())

    fn validate_clocked_static_type(ty: MirType, name: text, seen: [i64], span: Span?) -> Result<(), CompileError>:
        match ty.kind:
            case I8 | I16 | I32 | I64 | U8 | U16 | U32 | U64 | Bool:
                Ok(())
            case Bits(width, _):
                if width > 0:
                    Ok(())
                else:
                    Err(self.backend_error_at("VHDL clocked global `{name}` has non-positive bit width {width}", span))
            case Struct(symbol):
                for prior in seen:
                    if prior == symbol.id:
                        return Err(self.backend_error_at("VHDL clocked global `{name}` has a recursive record type", span))
                val type_def = match self.type_def_by_symbol(symbol):
                    case Ok(value): value
                    case Err(err): return Err(err)
                match type_def.kind:
                    case Struct(fields):
                        var next_seen = seen
                        next_seen = next_seen.push(symbol.id)
                        for field in fields:
                            match self.validate_clocked_static_type(field.type_, "{name}.{field.name}", next_seen, span):
                                case Ok(_): pass
                                case Err(err): return Err(err)
                        Ok(())
                    case _:
                        Err(self.backend_error_at("VHDL clocked global `{name}` references non-record type `{type_def.name}`", span))
            case _:
                Err(self.backend_error_at("VHDL clocked global `{name}` must be a fixed scalar or transitive record; dynamic/unsupported type `{ty.kind}` is not synthesizable", span))

    fn validate_call_supported_before_emit(func: MirOperand) -> Result<(), CompileError>:
        val target = match self.call_target_name(func):
            case Ok(result): result
            case Err(err): return Err(err)
        val helper_name = self.active_helper_name_by_source.get(target)
        if not helper_name.?:
            val known = self.active_function_by_name.get(target)
            match known:
                case Some(func_def):
                    if vhdl_function_is_hardware_entity(func_def):
                        return Ok(())
                    if not self.helper_subprogram_shape_supported(func_def):
                        return Err(self.backend_error("VHDL call `{target}` requires an acyclic combinational helper with local-only mutation"))
                case None:
                    ()
            return Err(self.backend_error("Synthesizable VHDL backend does not support generic Call lowering for `{target}`; only planned pure combinational helpers can be called"))
        Ok(())

    fn unsupported_vhdl_helper_instruction_error(inst: MirInst) -> CompileError:
        match inst.kind:
            case Load(_, _) | Store(_, _) | Alloc(_, _) | GetElementPtr(_, _, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer or memory instruction in helper subprogram: {inst.kind}", inst.span)
            case CallIndirect(_, _, _, _):
                self.backend_error("Unsupported VHDL helper subprogram indirect call behavior: {inst.kind}; helpers must use direct planned calls")
            case VhdlProcess(_, _) | VhdlPortMap(_, _, _) | VhdlSignalAssign(_, _, _) | VhdlVarAssign(_, _):
                self.backend_error("Unsupported VHDL helper subprogram hardware behavior: {inst.kind}; keep public hardware as entity lowering")
            case Intrinsic(_, name, _):
                self.backend_error("Unsupported VHDL helper subprogram intrinsic `{name}`; helpers must be pure combinational")
            case _:
                self.backend_error("Unsupported VHDL helper subprogram instruction: {inst.kind}")

    fn unsupported_vhdl_instruction_error(inst: MirInst) -> CompileError:
        match inst.kind:
            case Alloc(_, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer Alloc storage allocation", inst.span)
            case Load(_, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer Load lowering", inst.span)
            case Store(_, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer Store lowering", inst.span)
            case GetElementPtr(_, _, _):
                self.backend_error_at("Synthesizable VHDL backend does not support pointer GetElementPtr lowering", inst.span)
            case CallIndirect(_, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support CallIndirect lowering")
            case CheckedBinOp(_, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support checked arithmetic MIR instruction: {inst.kind}")
            case Intrinsic(_, name, _):
                self.backend_error("Synthesizable VHDL backend does not support intrinsic '{name}'")
            case SimdAddF32x4(_, _, _) | SimdSubF32x4(_, _, _) | SimdMulF32x4(_, _, _) | SimdDivF32x4(_, _, _) | SimdFmaF32x4(_, _, _, _) | SimdAddF32x8(_, _, _) | SimdSubF32x8(_, _, _) | SimdMulF32x8(_, _, _) | SimdDivF32x8(_, _, _) | SimdFmaF32x8(_, _, _, _) | SimdAddF64x4(_, _, _) | SimdSubF64x4(_, _, _) | SimdMulF64x4(_, _, _) | SimdDivF64x4(_, _, _) | SimdFmaF64x4(_, _, _, _) | SimdAddI32x4(_, _, _) | SimdSubI32x4(_, _, _) | SimdMulI32x4(_, _, _) | SimdXorI32x4(_, _, _) | SimdAndI32x4(_, _, _) | SimdOrI32x4(_, _, _) | SimdShlI32x4(_, _, _) | SimdShrI32x4(_, _, _) | SimdAddI32x8(_, _, _) | SimdSubI32x8(_, _, _) | SimdMulI32x8(_, _, _) | SimdXorI32x8(_, _, _) | SimdAndI32x8(_, _, _) | SimdOrI32x8(_, _, _) | SimdShlI32x8(_, _, _) | SimdShrI32x8(_, _, _) | SimdHaddF32x4(_, _) | SimdHmaxF32x4(_, _) | SimdHminF32x4(_, _):
                self.backend_error("Synthesizable VHDL backend does not support SIMD MIR instruction: {inst.kind}")
            case InlineAsm(_, _, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support inline assembly MIR instruction")
            case PipeForward(_, _, _) | Compose(_, _, _, _) | Parallel(_, _) | LayerConnect(_, _, _):
                self.backend_error("Synthesizable VHDL backend does not support functional pipeline MIR instruction: {inst.kind}")
            case DebugValue(_, _):
                self.backend_error("Synthesizable VHDL backend does not support debug metadata MIR instruction: {inst.kind}")
            case CreatePromise(_, _, _) | Await(_, _) | Yield(_) | Spawn(_, _, _) | Send(_, _) | Receive(_, _):
                self.backend_error("Synthesizable VHDL backend does not support async or actor MIR instruction: {inst.kind}")
            case Ref(_, _, _):
                self.backend_error("Synthesizable VHDL backend does not support borrow/reference MIR instruction: {inst.kind}")
            case GpuKernelDef(_) | GpuLaunch(_) | GpuGlobalId(_, _) | GpuLocalId(_, _) | GpuBlockId(_, _) | GpuBlockDim(_, _) | GpuGridDim(_, _) | GpuBarrier(_) | GpuMemFence(_) | GpuSharedAlloc(_, _, _) | GpuAtomicOp(_, _, _, _) | GpuAtomicCas(_, _, _, _):
                self.backend_error("Synthesizable VHDL backend does not support GPU MIR instruction: {inst.kind}")
            case _:
                self.backend_error("Synthesizable VHDL backend does not support MIR instruction: {inst.kind}")

    me compile_package_into(mut builder: VhdlBuilder, module: MirModule) -> Result<(), CompileError>:
        """Compile type and constant definitions into a VHDL package."""
        builder.emit_package_begin(module.name)

        for tuple_key in self.active_tuple_type_order:
            val tuple_name = self.active_tuple_type_names[tuple_key]
            val tuple_elements = self.active_tuple_type_shapes[tuple_key]
            if tuple_elements.len() == 0:
                return Err(self.backend_error("Empty tuple types are not supported by the VHDL backend"))
            var tuple_fields: [(text, text)] = []
            var tuple_idx = 0
            for tuple_element in tuple_elements:
                val tuple_type = match self.mir_type_to_vhdl(tuple_element):
                    case Ok(result): result
                    case Err(err): return Err(err)
                tuple_fields = tuple_fields.push(("f{tuple_idx}", tuple_type))
                tuple_idx = tuple_idx + 1
            val tuple_def = self.type_mapper.map_record(tuple_fields)
            builder.emit_type_decl(tuple_name, tuple_def)

        # Emit type definitions
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for symbol in self.active_type_emit_order:
            val type_def = module.types[symbol]
            match type_def.kind:
                case Struct(fields):
                    var field_pairs: [(text, text)] = []
                    for f in fields:
                        val mapped = match self.mir_type_to_vhdl(f.type_):
                            case Ok(result): result
                            case Err(err): return Err(err)
                        field_pairs = field_pairs.push((f.name, mapped))
                    val record_def = self.type_mapper.map_record(field_pairs)
                    builder.emit_type_decl(type_def.name, record_def)

                case Enum(variants):
                    match self.emit_enum_type_decls(builder, type_def, variants):
                        case Ok(_): ()
                        case Err(err): return Err(err)

                case _:
                    return Err(self.backend_error(
                        "Unsupported VHDL package type definition: {type_def.name}"
                    ))

        # Emit constants
        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for symbol in module.constants.keys():
            val constant = module.constants[symbol]
            val vhdl_type = match self.mir_type_to_vhdl(constant.type_):
                case Ok(result): result
                case Err(err): return Err(err)
            val vhdl_value = match self.const_value_to_vhdl(constant.value, constant.type_):
                case Ok(result): result
                case Err(err): return Err(err)
            builder.emit_constant_decl(constant.name, vhdl_type, vhdl_value)

        for source_name in self.active_helper_name_by_source.keys():
            val func = match self.helper_function_by_name(source_name):
                case Ok(result): result
                case Err(err): return Err(err)
            match self.emit_helper_declaration(builder, func):
                case Ok(_): ()
                case Err(err): return Err(err)

        builder.emit_package_end(module.name)

        if self.active_helper_name_by_source.len() > 0:
            builder.emit_library_header()
            builder.emit_line("package body {module.name}_pkg is")
            builder.indent_level = builder.indent_level + 1
            for source_name in self.active_helper_name_by_source.keys():
                val func = match self.helper_function_by_name(source_name):
                    case Ok(result): result
                    case Err(err): return Err(err)
                match self.emit_helper_body(builder, func):
                    case Ok(_): ()
                    case Err(err): return Err(err)
            builder.indent_level = builder.indent_level - 1
            builder.emit_line("end package body {module.name}_pkg;")
            builder.emit_raw("")

        Ok(())

    fn emit_enum_type_decls(builder: VhdlBuilder, type_def: MirTypeDef, variants: [MirVariantDef]) -> Result<(), CompileError>:
        var names: [text] = []
        var used_names: Dict<text, bool> = {}
        var has_payload = false
        for v in variants:
            val safe_name = self.sanitize_vhdl_identifier(v.name)
            if used_names.get(safe_name).?:
                return Err(self.backend_error(
                    "Duplicate VHDL enum literal after sanitization in `{type_def.name}`: `{safe_name}`"
                ))
            used_names[safe_name] = true
            names = names.push(safe_name)
            if v.payload.?:
                has_payload = true
        if not has_payload:
            val enum_def = self.type_mapper.map_enum_type(names)
            builder.emit_type_decl(type_def.name, enum_def)
            return Ok(())

        builder.emit_type_decl("{type_def.name}_tag_t", self.type_mapper.map_enum_type(names))
        var record_fields: [(text, text)] = [("tag", "{type_def.name}_tag_t")]
        var used_payload_fields: Dict<text, bool> = {"tag": true}
        for v in variants:
            match v.payload:
                case Some(payload):
                    val field_name = self.payload_enum_field_name(v)
                    if used_payload_fields.get(field_name).?:
                        return Err(self.backend_error(
                            "Duplicate VHDL payload enum field after sanitization in `{type_def.name}`: `{field_name}`"
                        ))
                    used_payload_fields[field_name] = true
                    val payload_type = match self.mir_type_to_vhdl(payload):
                        case Ok(result): result
                        case Err(err): return Err(err)
                    record_fields = record_fields.push((field_name, payload_type))
                case None:
                    ()
        builder.emit_type_decl(type_def.name, self.type_mapper.map_record(record_fields))
        Ok(())

    me prepare_tuple_types_for_module(module: MirModule):
        self.active_tuple_type_names = {}
        self.active_tuple_type_shapes = {}
        self.active_tuple_type_order = []

        for symbol in module.types.keys():
            val type_def = module.types[symbol]
            self.register_tuple_types_in_type_def(type_def)

        for symbol in module.constants.keys():
            val constant = module.constants[symbol]
            self.register_tuple_types_in_type(constant.type_)

        for symbol in module.functions.keys():
            val func = module.functions[symbol]
            self.register_tuple_types_in_type(func.signature.return_type)
            for param_type in func.signature.params:
                self.register_tuple_types_in_type(param_type)
            for local in func.locals:
                self.register_tuple_types_in_type(local.type_)

    me register_tuple_types_in_type_def(type_def: MirTypeDef):
        match type_def.kind:
            case Struct(fields):
                for field in fields:
                    self.register_tuple_types_in_type(field.type_)
            case Enum(variants):
                for variant in variants:
                    match variant.payload:
                        case Some(payload):
                            self.register_tuple_types_in_type(payload)
                        case None:
                            ()
            case Union(members):
                for member in members:
                    self.register_tuple_types_in_type(member)

    me register_tuple_types_in_type(ty: MirType):
        match ty.kind:
            case Tuple(elements):
                for element in elements:
                    self.register_tuple_types_in_type(element)
                val tuple_key = self.tuple_type_key(ty)
                if not self.active_tuple_type_names.get(tuple_key).?:
                    val tuple_name = "tuple_t_{self.active_tuple_type_order.len()}"
                    self.active_tuple_type_names[tuple_key] = tuple_name
                    self.active_tuple_type_shapes[tuple_key] = elements
                    self.active_tuple_type_order = self.active_tuple_type_order.push(tuple_key)
            case Array(element, _):
                self.register_tuple_types_in_type(element)
            case Slice(element):
                self.register_tuple_types_in_type(element)
            case Ptr(pointee, _):
                self.register_tuple_types_in_type(pointee)
            case Ref(referent, _):
                self.register_tuple_types_in_type(referent)
            case FuncPtr(signature):
                for param_type in signature.params:
                    self.register_tuple_types_in_type(param_type)
                self.register_tuple_types_in_type(signature.return_type)
            case Promise(inner):
                self.register_tuple_types_in_type(inner)
            case Generator(yield_ty, return_ty):
                self.register_tuple_types_in_type(yield_ty)
                self.register_tuple_types_in_type(return_ty)
            case ActorType(message):
                self.register_tuple_types_in_type(message)
            case Union(members):
                for member in members:
                    self.register_tuple_types_in_type(member)
            case _:
                ()

    fn tuple_type_key(ty: MirType) -> text:
        match ty.kind:
            case Tuple(elements):
                var element_keys: [text] = []
                for element in elements:
                    element_keys = element_keys.push(self.tuple_type_key_or_leaf(element))
                "tuple({element_keys.join(\",\")})"
            case _:
                self.tuple_type_key_or_leaf(ty)

    fn tuple_type_key_or_leaf(ty: MirType) -> text:
        match ty.kind:
            case I8: "i8"
            case I16: "i16"
            case I32: "i32"
            case I64: "i64"
            case U8: "u8"
            case U16: "u16"
            case U32: "u32"
            case U64: "u64"
            case F32: "f32"
            case F64: "f64"
            case Bool: "bool"
            case Char: "char"
            case Unit: "unit"
            case Vec4f: "vec4f"
            case Vec8f: "vec8f"
            case Vec4d: "vec4d"
            case Vec4i: "vec4i"
            case Vec8i: "vec8i"
            case Array(element, size): "array({self.tuple_type_key_or_leaf(element)};{size})"
            case Slice(element): "slice({self.tuple_type_key_or_leaf(element)})"
            case Tuple(elements):
                var nested_keys: [text] = []
                for element in elements:
                    nested_keys = nested_keys.push(self.tuple_type_key_or_leaf(element))
                "tuple({nested_keys.join(\",\")})"
            case Struct(symbol): "struct#{symbol.id}"
            case Enum(symbol): "enum#{symbol.id}"
            case Union(members):
                var member_keys: [text] = []
                for member in members:
                    member_keys = member_keys.push(self.tuple_type_key_or_leaf(member))
                "union({member_keys.join(\",\")})"
            case Ptr(pointee, mutable):
                "ptr({self.tuple_type_key_or_leaf(pointee)},{mutable})"
            case Ref(referent, mutable):
                "ref({self.tuple_type_key_or_leaf(referent)},{mutable})"
            case FuncPtr(signature):
                var param_keys: [text] = []
                for param_type in signature.params:
                    param_keys = param_keys.push(self.tuple_type_key_or_leaf(param_type))
                "fn({param_keys.join(\",\")})->{self.tuple_type_key_or_leaf(signature.return_type)}"
            case Promise(inner):
                "promise({self.tuple_type_key_or_leaf(inner)})"
            case Generator(yield_ty, return_ty):
                "gen({self.tuple_type_key_or_leaf(yield_ty)}->{self.tuple_type_key_or_leaf(return_ty)})"
            case ActorType(message):
                "actor({self.tuple_type_key_or_leaf(message)})"
            case Never: "never"
            case Opaque(name): "opaque({name})"
            case _: "type#{ty.kind}"

    fn sanitize_vhdl_identifier(name: text) -> text:
        """Return a deterministic VHDL-safe identifier fragment."""
        var result = name.trim()
        if result.len() == 0:
            result = "out"
        result = result.replace(" ", "_")
        result = result.replace("-", "_")
        result = result.replace(".", "_")
        result = result.replace(":", "_")
        result = result.replace("/", "_")
        result = result.replace("\\", "_")
        result = result.replace("(", "_")
        result = result.replace(")", "_")
        result = result.replace("[", "_")
        result = result.replace("]", "_")
        result

    fn vhdl_return_field_name(func: MirFunction, index: i64) -> text:
        if func.has_vhdl_metadata:
            val meta = func.vhdl_metadata
            if index < meta.return_fields.len():
                val label = meta.return_fields[index].label
                if label.len() > 0:
                    return self.sanitize_vhdl_identifier(label)
        "out{index}"

    fn vhdl_return_abi(func: MirFunction) -> Result<VhdlReturnAbi, CompileError>:
        match func.signature.return_type.kind:
            case Unit:
                Ok(VhdlReturnAbi(is_tuple: false, fields: []))
            case Tuple(elements):
                var fields: [VhdlReturnField] = []
                var used: Dict<text, bool> = {}
                var idx = 0
                while idx < elements.len():
                    val name = self.vhdl_return_field_name(func, idx)
                    if used.get(name).?:
                        return Err(self.backend_error("Duplicate VHDL output port after sanitization: {name}"))
                    used[name] = true
                    fields = fields.push(VhdlReturnField(
                        name: name,
                        type_: elements[idx],
                        index: idx,
                        selector: "f{idx}"
                    ))
                    idx = idx + 1
                Ok(VhdlReturnAbi(is_tuple: true, fields: fields))
            case Struct(symbol):
                if not func.has_vhdl_metadata or not func.vhdl_metadata.flatten_struct_output:
                    return Ok(VhdlReturnAbi(is_tuple: false, fields: [
                        VhdlReturnField(name: "result_out",
                            type_: func.signature.return_type, index: 0,
                            selector: "")
                    ]))
                if not self.active_type_defs.has(symbol.id):
                    return Err(self.backend_error("Flattened VHDL struct output type is missing from the active type catalog"))
                val type_def = self.active_type_defs[symbol.id]
                match type_def.kind:
                    case Struct(struct_fields):
                        var fields: [VhdlReturnField] = []
                        var used: Dict<text, bool> = {}
                        var idx = 0
                        for field in struct_fields:
                            val name = self.sanitize_vhdl_identifier(field.name)
                            if used.get(name).?:
                                return Err(self.backend_error("Duplicate VHDL output port after sanitization: {name}"))
                            used[name] = true
                            var port_type = field.type_
                            var selector = self.sanitize_vhdl_identifier(field.name)
                            if field.has_bits_attr:
                                if field.bits_width <= 0:
                                    return Err(self.backend_error("Flattened VHDL struct output `{field.name}` has invalid @bits width"))
                                val capacity = match field.type_.kind:
                                    case I8 | U8: 8
                                    case I16 | U16: 16
                                    case I32 | U32: 32
                                    case I64 | U64: 64
                                    case Bool: 1
                                    case _:
                                        return Err(self.backend_error("Flattened VHDL struct output @bits field `{field.name}` must be integer or bool"))
                                if field.bits_width > capacity:
                                    return Err(self.backend_error("Flattened VHDL struct output `{field.name}` @bits width exceeds its field type"))
                                val signed = match field.type_.kind:
                                    case I8 | I16 | I32 | I64: true
                                    case U8 | U16 | U32 | U64 | Bool: false
                                    case _:
                                        return Err(self.backend_error("Flattened VHDL struct output @bits field `{field.name}` must be integer or bool"))
                                match field.type_.kind:
                                    case Bool:
                                        port_type = field.type_
                                    case _:
                                        port_type = MirType(kind: MirTypeKind.Bits(field.bits_width, signed))
                                        selector = "{selector}({field.bits_width - 1} downto 0)"
                            fields = fields.push(VhdlReturnField(name: name,
                                type_: port_type, index: idx,
                                selector: selector))
                            idx = idx + 1
                        Ok(VhdlReturnAbi(is_tuple: true, fields: fields))
                    case _:
                        Err(self.backend_error("@flatten_struct_output requires a struct return type"))
            case _:
                if func.has_vhdl_metadata and func.vhdl_metadata.flatten_struct_output:
                    return Err(self.backend_error("@flatten_struct_output requires a struct return type"))
                Ok(VhdlReturnAbi(is_tuple: false, fields: [
                    VhdlReturnField(
                        name: "result_out",
                        type_: func.signature.return_type,
                        index: 0,
                        selector: ""
                    )
                ]))

    fn vhdl_arg_local_name(func: MirFunction, idx: i64) -> text:
        """Resolve the source-level name for parameter `idx`, falling back to
        a positional placeholder when the MIR local has no recorded name."""
        for local in func.locals:
            match local.kind:
                case Arg(arg_idx):
                    if arg_idx == idx:
                        return local.name ?? "arg{idx}"
                case _:
                    pass
        "arg{idx}"

    fn vhdl_ports_for_function(func: MirFunction) -> Result<[VhdlPortSpec], CompileError>:
        var ports: [VhdlPortSpec] = []

        var idx = 0
        while idx < func.signature.params.len():
            if self.type_has_general_memory(func.signature.params[idx]):
                return Err(self.backend_error("VHDL-MEM-GENERAL: Array, slice, pointer, and reference ports require an explicit package-level memory ABI before VHDL emission"))
            val param_type = match self.mir_type_to_vhdl_at(func.signature.params[idx], Some(func.span)):
                case Ok(result): result
                case Err(err): return Err(err)
            ports = ports.push(VhdlPortSpec(
                name: self.vhdl_arg_local_name(func, idx),
                direction: "in",
                type_name: param_type
            ))
            idx = idx + 1

        val abi = match self.vhdl_return_abi(func):
            case Ok(result): result
            case Err(err): return Err(err)
        for field in abi.fields:
            if self.type_has_general_memory(field.type_):
                return Err(self.backend_error("VHDL-MEM-GENERAL: Array, slice, pointer, and reference result ports require an explicit package-level memory ABI before VHDL emission"))
            val return_type = match self.mir_type_to_vhdl_at(field.type_, Some(func.span)):
                case Ok(result): result
                case Err(err): return Err(err)
            ports = ports.push(VhdlPortSpec(
                name: field.name,
                direction: "out",
                type_name: return_type
            ))

        Ok(ports)

    fn type_has_general_memory(ty: MirType) -> bool:
        match ty.kind:
            case Array(_, _) | Slice(_) | Ptr(_, _) | Ref(_, _):
                true
            case Tuple(elements):
                for element in elements:
                    if self.type_has_general_memory(element):
                        return true
                false
            case Union(members):
                for member in members:
                    if self.type_has_general_memory(member):
                        return true
                false
            case _:
                false
