# Backend boundary for immutable MIR target state.

use compiler.common.mir_target_context.{MirTargetContext, mir_target_context_from}
use compiler.backend.backend.llvm_capability.{get_llvm_capabilities}
use std.platform.{host_arch, host_os}

extern fn rt_env_get(key: text) -> text

fn backend_mir_target_context(backend: text) -> MirTargetContext:
    var version = -1
    if backend == "llvm":
        val capabilities = get_llvm_capabilities()
        version = capabilities.llc.version.major
    elif backend == "llvm-lib" or backend == "llvmlib":
        val capabilities = get_llvm_capabilities()
        version = capabilities.libllvm.version.major

    val known_version = if version > 0: version else: -1
    mir_target_context_from(
        rt_env_get("SIMPLE_NATIVE_BUILD_TARGET") ?? "",
        host_arch(),
        host_os(),
        backend,
        known_version
    )
